    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Doubly Linked List Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-bottom: 10px;\n        }\n        .visualization {\n            min-height: 200px;\n            border: 1px solid #000;\n            padding: 20px;\n            position: relative;\n            overflow-x: auto;\n        }\n        .node {\n            display: inline-flex;\n            align-items: center;\n            margin: 0 5px;\n            position: relative;\n        }\n        .node-value {\n            border: 1px solid #000;\n            padding: 10px 15px;\n            background: #fff;\n        }\n        .prev-pointer, .next-pointer {\n            width: 30px;\n            height: 2px;\n            background: #000;\n            position: relative;\n        }\n        .prev-pointer::after, .next-pointer::after {\n            content: '';\n            position: absolute;\n            width: 0;\n            height: 0;\n            border-style: solid;\n        }\n        .prev-pointer::after {\n            border-width: 5px 10px 5px 0;\n            border-color: transparent #000 transparent transparent;\n            left: 0;\n            top: -4px;\n        }\n        .next-pointer::after {\n            border-width: 5px 0 5px 10px;\n            border-color: transparent transparent transparent #000;\n            right: 0;\n            top: -4px;\n        }\n        .node-actions {\n            position: absolute;\n            top: -20px;\n            left: 0;\n            right: 0;\n            display: flex;\n            justify-content: center;\n            gap: 5px;\n        }\n        .node-actions button {\n            font-size: 10px;\n            padding: 2px 5px;\n        }\n        .head-marker, .tail-marker {\n            position: absolute;\n            font-size: 12px;\n            top: -15px;\n        }\n        .head-marker {\n            left: 10px;\n        }\n        .tail-marker {\n            right: 10px;\n        }\n        .highlight {\n            background-color: rgba(255, 255, 0, 0.3);\n        }\n        .traversal-path {\n            position: absolute;\n            bottom: 10px;\n            left: 20px;\n            right: 20px;\n            height: 30px;\n            border-top: 1px dashed #000;\n            display: flex;\n            align-items: center;\n            padding: 0 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Doubly Linked List Interactive Demo</h1>\n        \n        <div class=\"control-group\">\n            <h3>List Operations</h3>\n            <div class=\"controls\">\n                <input type=\"number\" id=\"nodeValue\" placeholder=\"Value\" min=\"0\">\n                <button id=\"addHead\">Add to Head</button>\n                <button id=\"addTail\">Add to Tail</button>\n                <button id=\"removeHead\">Remove Head</button>\n                <button id=\"removeTail\">Remove Tail</button>\n                <button id=\"clearList\">Clear List</button>\n            </div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Node Operations</h3>\n            <div class=\"controls\">\n                <input type=\"number\" id=\"searchValue\" placeholder=\"Search value\">\n                <button id=\"searchNode\">Search</button>\n                <input type=\"number\" id=\"insertValue\" placeholder=\"Insert value\">\n                <input type=\"number\" id=\"afterValue\" placeholder=\"After value\">\n                <button id=\"insertAfter\">Insert After</button>\n                <input type=\"number\" id=\"removeValue\" placeholder=\"Remove value\">\n                <button id=\"removeNode\">Remove Node</button>\n            </div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Traversal</h3>\n            <div class=\"controls\">\n                <button id=\"traverseForward\">Traverse Forward</button>\n                <button id=\"traverseBackward\">Traverse Backward</button>\n                <input type=\"number\" id=\"traverseSteps\" placeholder=\"Steps\" min=\"1\" value=\"1\">\n                <button id=\"stepForward\">Step Forward</button>\n                <button id=\"stepBackward\">Step Backward</button>\n                <button id=\"resetTraversal\">Reset Traversal</button>\n            </div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>List Information</h3>\n            <div>\n                <p>Length: <span id=\"listLength\">0</span></p>\n                <p>Head: <span id=\"headValue\">null</span></p>\n                <p>Tail: <span id=\"tailValue\">null</span></p>\n                <p>Current Node: <span id=\"currentNode\">null</span></p>\n            </div>\n        </div>\n        \n        <div class=\"visualization\" id=\"listVisualization\">\n            <div class=\"head-marker\">Head</div>\n            <div class=\"tail-marker\">Tail</div>\n            <div class=\"traversal-path\" id=\"traversalPath\"></div>\n        </div>\n    </div>\n\n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.prev = null;\n                this.next = null;\n            }\n        }\n\n        class DoublyLinkedList {\n            constructor() {\n                this.head = null;\n                this.tail = null;\n                this.length = 0;\n                this.current = null;\n            }\n\n            addToHead(value) {\n                const newNode = new Node(value);\n                if (!this.head) {\n                    this.head = newNode;\n                    this.tail = newNode;\n                } else {\n                    newNode.next = this.head;\n                    this.head.prev = newNode;\n                    this.head = newNode;\n                }\n                this.length++;\n                this.updateUI();\n            }\n\n            addToTail(value) {\n                const newNode = new Node(value);\n                if (!this.tail) {\n                    this.head = newNode;\n                    this.tail = newNode;\n                } else {\n                    newNode.prev = this.tail;\n                    this.tail.next = newNode;\n                    this.tail = newNode;\n                }\n                this.length++;\n                this.updateUI();\n            }\n\n            removeHead() {\n                if (!this.head) return null;\n                const removed = this.head;\n                if (this.head === this.tail) {\n                    this.head = null;\n                    this.tail = null;\n                } else {\n                    this.head = this.head.next;\n                    this.head.prev = null;\n                }\n                this.length--;\n                this.updateUI();\n                return removed.value;\n            }\n\n            removeTail() {\n                if (!this.tail) return null;\n                const removed = this.tail;\n                if (this.head === this.tail) {\n                    this.head = null;\n                    this.tail = null;\n                } else {\n                    this.tail = this.tail.prev;\n                    this.tail.next = null;\n                }\n                this.length--;\n                this.updateUI();\n                return removed.value;\n            }\n\n            search(value) {\n                let current = this.head;\n                while (current) {\n                    if (current.value === value) {\n                        this.current = current;\n                        this.updateUI();\n                        return current;\n                    }\n                    current = current.next;\n                }\n                return null;\n            }\n\n            insertAfter(value, afterValue) {\n                const afterNode = this.search(afterValue);\n                if (!afterNode) return false;\n                \n                const newNode = new Node(value);\n                newNode.prev = afterNode;\n                newNode.next = afterNode.next;\n                \n                if (afterNode.next) {\n                    afterNode.next.prev = newNode;\n                } else {\n                    this.tail = newNode;\n                }\n                \n                afterNode.next = newNode;\n                this.length++;\n                this.updateUI();\n                return true;\n            }\n\n            remove(value) {\n                const nodeToRemove = this.search(value);\n                if (!nodeToRemove) return false;\n                \n                if (nodeToRemove.prev) {\n                    nodeToRemove.prev.next = nodeToRemove.next;\n                } else {\n                    this.head = nodeToRemove.next;\n                }\n                \n                if (nodeToRemove.next) {\n                    nodeToRemove.next.prev = nodeToRemove.prev;\n                } else {\n                    this.tail = nodeToRemove.prev;\n                }\n                \n                this.length--;\n                this.updateUI();\n                return true;\n            }\n\n            traverseForward(steps = 1) {\n                if (!this.current) this.current = this.head;\n                if (!this.current) return;\n                \n                let i = 0;\n                while (i < steps && this.current.next) {\n                    this.current = this.current.next;\n                    i++;\n                }\n                this.updateUI();\n            }\n\n            traverseBackward(steps = 1) {\n                if (!this.current) this.current = this.tail;\n                if (!this.current) return;\n                \n                let i = 0;\n                while (i < steps && this.current.prev) {\n                    this.current = this.current.prev;\n                    i++;\n                }\n                this.updateUI();\n            }\n\n            resetTraversal() {\n                this.current = null;\n                this.updateUI();\n            }\n\n            clear() {\n                this.head = null;\n                this.tail = null;\n                this.length = 0;\n                this.current = null;\n                this.updateUI();\n            }\n\n            updateUI() {\n                const visualization = document.getElementById('listVisualization');\n                visualization.innerHTML = `\n                    <div class=\"head-marker\">Head</div>\n                    <div class=\"tail-marker\">Tail</div>\n                    <div class=\"traversal-path\" id=\"traversalPath\"></div>\n                `;\n                \n                let current = this.head;\n                let html = '';\n                let position = 0;\n                \n                while (current) {\n                    const isCurrent = this.current === current;\n                    const isHead = current === this.head;\n                    const isTail = current === this.tail;\n                    \n                    html += `\n                        <div class=\"node\" data-value=\"${current.value}\" data-position=\"${position}\">\n                            <div class=\"node-actions\">\n                                <button class=\"set-current\" data-value=\"${current.value}\">Set Current</button>\n                                <button class=\"remove-node\" data-value=\"${current.value}\">Remove</button>\n                            </div>\n                            <divPointer(current.prev, 'prev-pointer')}\n                            <divPointer(current.next, 'next-pointer')}\n                            <div class=\"node-value ${isCurrent ? 'highlight' : ''}\">\n                                ${current.value}\n                                ${isHead ? ' (H)' : ''}\n                                ${isTail ? ' (T)' : ''}\n                            </div>\n                        </div>\n                    `;\n                    \n                    current = current.next;\n                    position++;\n                }\n                \n                visualization.insertAdjacentHTML('beforeend', html);\n                \n                document.getElementById('listLength').textContent = this.length;\n                document.getElementById('headValue').textContent = this.head ? this.head.value : 'null';\n                document.getElementById('tailValue').textContent = this.tail ? this.tail.value : 'null';\n                document.getElementById('currentNode').textContent = this.current ? this.current.value : 'null';\n                \n                // Add event listeners to node action buttons\n                document.querySelectorAll('.set-current').forEach(btn => {\n                    btn.addEventListener('click', (e) => {\n                        const value = parseInt(e.target.getAttribute('data-value'));\n                        list.search(value);\n                    });\n                });\n                \n                document.querySelectorAll('.remove-node').forEach(btn => {\n                    btn.addEventListener('click', (e) => {\n                        const value = parseInt(e.target.getAttribute('data-value'));\n                        list.remove(value);\n                    });\n                });\n            }\n        }\n\n        function divPointer(node, className) {\n            if (node) {\n                return `<div class=\"${className}\"></div>`;\n            } else {\n                return `<div class=\"${className}\" style=\"visibility:hidden;\"></div>`;\n            }\n        }\n\n        const list = new DoublyLinkedList();\n\n        // Event listeners\n        document.getElementById('addHead').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('nodeValue').value);\n            if (!isNaN(value)) {\n                list.addToHead(value);\n                document.getElementById('nodeValue').value = '';\n            }\n        });\n\n        document.getElementById('addTail').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('nodeValue').value);\n            if (!isNaN(value)) {\n                list.addToTail(value);\n                document.getElementById('nodeValue').value = '';\n            }\n        });\n\n        document.getElementById('removeHead').addEventListener('click', () => {\n            list.removeHead();\n        });\n\n        document.getElementById('removeTail').addEventListener('click', () => {\n            list.removeTail();\n        });\n\n        document.getElementById('clearList').addEventListener('click', () => {\n            list.clear();\n        });\n\n        document.getElementById('searchNode').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('searchValue').value);\n            if (!isNaN(value)) {\n                const found = list.search(value);\n                if (!found) {\n                    alert('Value not found in the list');\n                }\n                document.getElementById('searchValue').value = '';\n            }\n        });\n\n        document.getElementById('insertAfter').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('insertValue').value);\n            const afterValue = parseInt(document.getElementById('afterValue').value);\n            if (!isNaN(value) && !isNaN(afterValue)) {\n                const success = list.insertAfter(value, afterValue);\n                if (!success) {\n                    alert(`Could not insert ${value} after ${afterValue} - value not found`);\n                }\n                document.getElementById('insertValue').value = '';\n                document.getElementById('afterValue').value = '';\n            }\n        });\n\n        document.getElementById('removeNode').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('removeValue').value);\n            if (!isNaN(value)) {\n                const success = list.remove(value);\n                if (!success) {\n                    alert('Value not found in the list');\n                }\n                document.getElementById('removeValue').value = '';\n            }\n        });\n\n        document.getElementById('traverseForward').addEventListener('click', () => {\n            list.traverseForward();\n        });\n\n        document.getElementById('traverseBackward').addEventListener('click', () => {\n            list.traverseBackward();\n        });\n\n        document.getElementById('stepForward').addEventListener('click', () => {\n            const steps = parseInt(document.getElementById('traverseSteps').value) || 1;\n            list.traverseForward(steps);\n        });\n\n        document.getElementById('stepBackward').addEventListener('click', () => {\n            const steps = parseInt(document.getElementById('traverseSteps').value) || 1;\n            list.traverseBackward(steps);\n        });\n\n        document.getElementById('resetTraversal').addEventListener('click', () => {\n            list.resetTraversal();\n        });\n\n        // Initialize\n        list.updateUI();\n    </script>\n</body>\n</html>"
  },
