    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Interpolation Search — Visual Demonstration</title>\n\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@700&display=swap\" rel=\"stylesheet\">\n\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #0b1020;\n    --glass: rgba(255,255,255,0.04);\n    --accent: #7be4ff;\n    --accent-2: #8ef4c2;\n    --muted: rgba(255,255,255,0.7);\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --success: #7be48a;\n    --danger: #ff8a8a;\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124, 58, 237, 0.12), transparent 6%),\n                radial-gradient(900px 420px at 90% 90%, rgba(14, 165, 233, 0.06), transparent 6%),\n                linear-gradient(180deg, var(--bg-1), var(--bg-2));\n    color: #e8eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  /* Subtle decorative floating shapes */\n  .scene {\n    position:relative;\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px 32px;\n    box-sizing:border-box;\n    overflow:hidden;\n  }\n\n  .floating {\n    position:absolute;\n    filter: blur(36px);\n    opacity:0.12;\n    transform-origin:center;\n    animation: float 12s ease-in-out infinite;\n    mix-blend-mode:screen;\n  }\n  .floating.one{ width:420px; height:420px; left:-80px; top:-60px; background:radial-gradient(circle at 30% 30%, #7c3aed, #118ab2); animation-duration:14s; }\n  .floating.two{ width:320px; height:320px; right:-60px; bottom:-60px; background:radial-gradient(circle at 70% 70%, #06b6d4, #34d399); animation-duration:18s; }\n  @keyframes float {\n    0% { transform: translateY(-8px) rotate(-3deg) }\n    50% { transform: translateY(8px) rotate(3deg) }\n    100% { transform: translateY(-8px) rotate(-3deg) }\n  }\n\n  /* Card layout */\n  .card {\n    width:1100px;\n    max-width:calc(100% - 64px);\n    border-radius:18px;\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:28px;\n    padding:28px;\n    box-sizing:border-box;\n    background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow);\n    backdrop-filter: blur(8px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:visible;\n  }\n\n  /* Header */\n  .header {\n    grid-column: 1 / -1;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:20px;\n    margin-bottom:6px;\n  }\n\n  .title {\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n  }\n  .title h1{\n    margin:0;\n    font-family: \"Playfair Display\", serif;\n    letter-spacing: -0.6px;\n    font-size:26px;\n    color: white;\n    text-shadow: 0 6px 24px rgba(0,0,0,0.6);\n  }\n  .title p{\n    margin:0;\n    color:var(--muted);\n    font-size:13.5px;\n  }\n\n  /* Controls */\n  .controls {\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  .btn {\n    border:0;\n    padding:10px 16px;\n    border-radius:12px;\n    font-weight:600;\n    cursor:pointer;\n    color: #06202A;\n    background: linear-gradient(90deg,var(--accent), #6ee7b7);\n    box-shadow: 0 8px 24px rgba(40,200,220,0.12), inset 0 -2px 8px rgba(255,255,255,0.06);\n    transition: transform .18s ease, box-shadow .18s ease;\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    font-size:14px;\n    letter-spacing:0.2px;\n  }\n  .btn:active{ transform: translateY(2px) }\n  .btn.secondary {\n    background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    color: #d9edf9;\n    border: 1px solid rgba(255,255,255,0.04);\n    box-shadow: none;\n  }\n\n  .pill {\n    padding:6px 10px;\n    border-radius:999px;\n    background: rgba(255,255,255,0.03);\n    color: var(--muted);\n    font-weight:600;\n    font-size:13px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Left: array visualization */\n  .visual {\n    padding:22px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border: 1px solid rgba(255,255,255,0.02);\n    position:relative;\n    overflow:hidden;\n  }\n\n  .array-frame{\n    height:280px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n  }\n\n  .array {\n    display:flex;\n    gap:12px;\n    padding:18px 24px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    box-shadow: 0 12px 40px rgba(3,8,20,0.6) inset;\n    transition: transform .6s cubic-bezier(.2,.9,.2,1);\n  }\n\n  .cell {\n    width:58px;\n    height:120px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    gap:6px;\n    color:var(--muted);\n    font-size:13px;\n    position:relative;\n    box-shadow: 0 8px 20px rgba(2,6,23,0.6);\n    transition: transform .45s cubic-bezier(.2,.9,.2,1), box-shadow .45s, background .45s, border .45s;\n    border: 1px solid rgba(255,255,255,0.025);\n    overflow:visible;\n  }\n\n  .cell .index {\n    font-size:11px;\n    color: rgba(255,255,255,0.35);\n    position:absolute;\n    top:8px;\n    left:8px;\n  }\n  .cell .value {\n    font-weight:700;\n    font-size:18px;\n    color: white;\n    letter-spacing:0.6px;\n    text-shadow: 0 6px 18px rgba(2,6,23,0.6);\n  }\n\n  .cell.low {\n    outline: 2px dashed rgba(123,228,255,0.18);\n    box-shadow: 0 12px 30px rgba(24,180,190,0.08);\n  }\n  .cell.high {\n    outline: 2px dashed rgba(142,244,194,0.15);\n    box-shadow: 0 12px 30px rgba(18,200,130,0.06);\n  }\n  .cell.pos {\n    transform: translateY(-10px) scale(1.05);\n    background: linear-gradient(180deg, rgba(123,228,255,0.12), rgba(142,244,194,0.05));\n    border: 1px solid rgba(255,255,255,0.06);\n    box-shadow: 0 16px 54px rgba(15,60,80,0.35);\n  }\n  .cell.found {\n    background: linear-gradient(90deg, rgba(123,228,255,0.18), rgba(142,244,194,0.14));\n    box-shadow: 0 18px 64px rgba(12,50,60,0.48);\n    transform: translateY(-16px) scale(1.12);\n    border: 1px solid rgba(255,255,255,0.08);\n  }\n\n  /* pointer marker */\n  .pointer {\n    position:absolute;\n    top:30px;\n    height:0;\n    width:0;\n    transition: left 650ms cubic-bezier(.2,.9,.2,1), transform 400ms ease;\n    z-index:20;\n    filter: drop-shadow(0 10px 30px rgba(4,20,30,0.6));\n  }\n  .pointer .tip {\n    width:0; height:0;\n    border-left: 12px solid transparent;\n    border-right: 12px solid transparent;\n    border-bottom: 18px solid rgba(255,255,255,0.06);\n    transform: translateY(0);\n    transition: border-bottom-color 300ms;\n  }\n  .pointer .bubble {\n    margin-top:8px;\n    background: linear-gradient(90deg,#0b1320, rgba(255,255,255,0.02));\n    border-radius:10px;\n    padding:8px 12px;\n    font-weight:700;\n    font-size:13px;\n    color:var(--accent);\n    border:1px solid rgba(123,228,255,0.12);\n    transform: translateY(-6px);\n    box-shadow: 0 8px 24px rgba(20,60,70,0.24);\n  }\n\n  /* Right panel: details */\n  .info {\n    padding:22px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.00));\n    border: 1px solid rgba(255,255,255,0.03);\n    min-height: 320px;\n    box-sizing:border-box;\n  }\n\n  .info h3 {\n    margin:0;\n    font-size:16px;\n    font-weight:800;\n    letter-spacing:0.6px;\n    font-family: \"Playfair Display\", serif;\n    color: #f0fbff;\n  }\n  .info p { color:var(--muted); margin-top:6px; margin-bottom:16px; font-size:13px; }\n\n  .formula {\n    margin-top:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:16px;\n    border: 1px solid rgba(255,255,255,0.02);\n  }\n\n  .formula .line {\n    display:flex;\n    gap:10px;\n    align-items:center;\n    font-weight:700;\n    color: #dffbff;\n    letter-spacing:0.4px;\n  }\n\n  .small {\n    font-size:13px;\n    color:var(--muted);\n    margin-top:10px;\n  }\n\n  .progress {\n    height:10px;\n    background: rgba(255,255,255,0.03);\n    border-radius:999px;\n    overflow:hidden;\n    margin-top:16px;\n    border: 1px solid rgba(255,255,255,0.02);\n  }\n  .progress > i {\n    display:block;\n    height:100%;\n    width:0%;\n    background: linear-gradient(90deg, var(--accent), var(--accent-2));\n    transition: width 600ms cubic-bezier(.2,.9,.2,1);\n  }\n\n  .status {\n    margin-top:12px;\n    display:flex;\n    align-items:center;\n    gap:8px;\n  }\n  .status .dot {\n    width:10px;height:10px;border-radius:50%;\n    background: linear-gradient(90deg,#39ffea, #60ffa1);\n    box-shadow: 0 6px 20px rgba(50,220,170,0.08);\n    border: 1px solid rgba(255,255,255,0.06);\n  }\n\n  .meta {\n    margin-top:18px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n    flex-wrap:wrap;\n  }\n\n  .meta .k {\n    padding:10px 12px;\n    border-radius:10px;\n    background: rgba(255,255,255,0.02);\n    font-weight:700;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.02);\n    font-size:13px;\n  }\n\n  /* footer tip */\n  .foot {\n    grid-column: 1 / -1;\n    margin-top:6px;\n    color: rgba(255,255,255,0.08);\n    font-size:12px;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n  }\n\n  /* responsive */\n  @media (max-width:980px){\n    .card{ grid-template-columns: 1fr; padding:18px; }\n    .info{ order:2; margin-top:8px; }\n    .array-frame{ height:220px; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"scene\">\n    <div class=\"floating one\" aria-hidden=\"true\"></div>\n    <div class=\"floating two\" aria-hidden=\"true\"></div>\n\n    <main class=\"card\" role=\"main\" aria-labelledby=\"title\">\n      <header class=\"header\">\n        <div class=\"title\">\n          <h1 id=\"title\">Interpolation Search</h1>\n          <p>Elegant visual demonstration — observe how estimated probes narrow the search range using value-based interpolation.</p>\n        </div>\n\n        <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n          <div class=\"pill\" id=\"targetPill\">Target: —</div>\n          <button class=\"btn\" id=\"playBtn\" title=\"Start animation\">\n            ▶ Play\n          </button>\n          <button class=\"btn secondary\" id=\"resetBtn\" title=\"Reset visualization\">Reset</button>\n        </div>\n      </header>\n\n      <section class=\"visual\" aria-label=\"Array visualization\">\n        <div class=\"array-frame\">\n          <div class=\"pointer\" id=\"pointer\" aria-hidden=\"true\" style=\"left:0px\">\n            <div class=\"tip\"></div>\n            <div class=\"bubble\" id=\"bubble\">est</div>\n          </div>\n\n          <div class=\"array\" id=\"array\" role=\"list\" aria-label=\"Array elements\">\n            <!-- cells injected by JS -->\n          </div>\n        </div>\n\n        <div class=\"foot\">\n          <div style=\"display:flex;gap:12px;align-items:center\">\n            <div style=\"font-size:13px;color:var(--muted)\">Array: sorted integers</div>\n            <div style=\"font-size:12px;color:rgba(255,255,255,0.06)\">Length: <strong id=\"arrLen\">—</strong></div>\n          </div>\n          <div style=\"font-size:12px;color:rgba(255,255,255,0.06)\">Visualization: interpolation formula driven probe</div>\n        </div>\n      </section>\n\n      <aside class=\"info\" aria-label=\"Information and formula\">\n        <h3>How the estimate is computed</h3>\n        <p>Interpolation Search uses a value-proportional formula to estimate where the target might be within the current low–high interval. This often outperforms binary search for uniformly distributed data.</p>\n\n        <div class=\"formula\" aria-hidden=\"true\">\n          <div style=\"font-size:12px;color:var(--muted);margin-bottom:8px\">Formula</div>\n          <div class=\"line\" id=\"formulaLine\">\n            pos = low + ((target - A[low]) × (high - low)) ÷ (A[high] - A[low])\n          </div>\n\n          <div class=\"small\" id=\"calcText\">Calculated position: —</div>\n\n          <div class=\"progress\" aria-hidden=\"true\">\n            <i id=\"progressBar\"></i>\n          </div>\n\n          <div class=\"status\">\n            <div class=\"dot\" id=\"statusDot\"></div>\n            <div id=\"statusText\" style=\"font-size:13px;color:var(--muted)\">Idle</div>\n          </div>\n\n          <div class=\"meta\" aria-hidden=\"true\">\n            <div class=\"k\" id=\"metaLow\">low: —</div>\n            <div class=\"k\" id=\"metaHigh\">high: —</div>\n            <div class=\"k\" id=\"metaPos\">pos: —</div>\n            <div class=\"k\" id=\"metaVal\">A[pos]: —</div>\n          </div>\n        </div>\n      </aside>\n    </main>\n  </div>\n\n<script>\n(() => {\n  // Basic configuration\n  const N = 21; // number of elements\n  const arrayEl = document.getElementById('array');\n  const pointer = document.getElementById('pointer');\n  const bubble = document.getElementById('bubble');\n\n  const targetPill = document.getElementById('targetPill');\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  const arrLen = document.getElementById('arrLen');\n\n  const formulaLine = document.getElementById('formulaLine');\n  const calcText = document.getElementById('calcText');\n  const progressBar = document.getElementById('progressBar');\n  const statusText = document.getElementById('statusText');\n  const statusDot = document.getElementById('statusDot');\n\n  const metaLow = document.getElementById('metaLow');\n  const metaHigh = document.getElementById('metaHigh');\n  const metaPos = document.getElementById('metaPos');\n  const metaVal = document.getElementById('metaVal');\n\n  let arr = [];\n  let target = null;\n  let steps = [];\n  let animating = false;\n  let cells = [];\n  let animTimeouts = [];\n\n  // Utils\n  function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n\n  // Create a nicely distributed sorted array (mostly uniform)\n  function buildArray(n){\n    const out = [];\n    let base = randInt(2, 7);\n    let current = randInt(2, 9);\n    for(let i=0;i<n;i++){\n      // arithmetic progression with slight jitter\n      current += base + Math.round((Math.sin(i*0.6)+1)*0.6*randInt(0,1));\n      out.push(current);\n    }\n    // occasionally make it perfectly uniform for aesthetic variation\n    if(Math.random() > 0.6){\n      for(let i=0;i<n;i++) out[i] = out[0] + i * (base+1);\n    }\n    return out;\n  }\n\n  function createCells(){\n    arrayEl.innerHTML = '';\n    cells = [];\n    for(let i=0;i<arr.length;i++){\n      const el = document.createElement('div');\n      el.className = 'cell';\n      el.setAttribute('role','listitem');\n      el.setAttribute('aria-label', `A[${i}] = ${arr[i]}`);\n      el.innerHTML = `<div class=\"index\">${i}</div><div class=\"value\">${arr[i]}</div>`;\n      arrayEl.appendChild(el);\n      cells.push(el);\n    }\n    arrLen.textContent = arr.length;\n  }\n\n  function placePointerAt(idx, label){\n    const targetCell = cells[idx];\n    if(!targetCell) return;\n    // compute left offset relative to array container\n    const cellRect = targetCell.getBoundingClientRect();\n    const containerRect = arrayEl.getBoundingClientRect();\n    const left = (cellRect.left - containerRect.left) + (cellRect.width/2) - 12; // center minus tip half\n    pointer.style.left = `${Math.max(6,left)}px`;\n    bubble.textContent = label ?? 'est';\n    pointer.style.transform = `translateY(${targetCell.classList.contains('pos') ? '-6px' : '0px'})`;\n  }\n\n  function highlightState(s){\n    // clear\n    cells.forEach(c => c.classList.remove('low','high','pos','found'));\n    if(s.low != null) cells[s.low].classList.add('low');\n    if(s.high != null) cells[s.high].classList.add('high');\n    if(s.pos != null) cells[s.pos].classList.add('pos');\n    if(s.found) cells[s.pos].classList.add('found');\n  }\n\n  function computeSteps(A, target){\n    const seq = [];\n    let low = 0, high = A.length - 1;\n    let found = false;\n    while(low <= high && target >= A[low] && target <= A[high]){\n      if(A[low] === A[high]){\n        // all equal in range; choose low and break\n        const pos = low;\n        seq.push({low, high, pos, value: A[pos], action: 'equal-range', found: A[pos] === target});\n        if(A[pos] === target) found = true;\n        break;\n      }\n      const numerator = (target - A[low]) * (high - low);\n      const denom = (A[high] - A[low]);\n      let pos = low + Math.floor(numerator / denom);\n      if(pos < low) pos = low;\n      if(pos > high) pos = high;\n      seq.push({low, high, pos, value: A[pos], action: A[pos] === target ? 'found' : (A[pos] < target ? 'move-low' : 'move-high'), found: A[pos] === target});\n      if(A[pos] === target){ found = true; break; }\n      if(A[pos] < target) low = pos + 1;\n      else high = pos - 1;\n    }\n    if(!found){\n      seq.push({low: null, high: null, pos: null, value: null, action: 'not-found', found:false});\n    }\n    return seq;\n  }\n\n  function setStatus(text, color){\n    statusText.textContent = text;\n    if(color==='ok'){\n      statusDot.style.background = 'linear-gradient(90deg,#39ffea,#60ffa1)';\n      statusText.style.color = 'var(--muted)';\n    } else if(color==='searching'){\n      statusDot.style.background = 'linear-gradient(90deg,#7be4ff,#8ef4c2)';\n      statusText.style.color = '#dffbff';\n    } else {\n      statusDot.style.background = 'linear-gradient(90deg,#ff8a8a,#ffd1d1)';\n      statusText.style.color = '#ffd7d7';\n    }\n  }\n\n  function clearTimeouts(){\n    animTimeouts.forEach(t => clearTimeout(t));\n    animTimeouts = [];\n  }\n\n  // Animate the steps sequentially\n  function animateSteps(seq){\n    if(!seq || seq.length===0) return;\n    animating = true;\n    playBtn.disabled = true;\n    resetBtn.disabled = true;\n    setStatus('Searching...', 'searching');\n    progressBar.style.width = '0%';\n\n    // initial clear\n    cells.forEach(c => c.classList.remove('low','high','pos','found'));\n    pointer.style.opacity = 1;\n\n    const total = seq.length;\n    let cumulative = 0;\n\n    function runStep(i){\n      if(i >= seq.length){ finish(); return; }\n      const s = seq[i];\n\n      // update meta\n      metaLow.textContent = `low: ${s.low === null ? '—' : s.low}`;\n      metaHigh.textContent = `high: ${s.high === null ? '—' : s.high}`;\n      metaPos.textContent = `pos: ${s.pos === null ? '—' : s.pos}`;\n      metaVal.textContent = `A[pos]: ${s.value === null ? '—' : s.value}`;\n\n      // update formula calculation visually\n      if(s.pos !== null){\n        const A_low = arr[s.low];\n        const A_high = arr[s.high];\n        const numerator = (target - A_low) * (s.high - s.low);\n        const denom = (A_high - A_low);\n        const computed = s.pos;\n        calcText.innerHTML = `pos = ${s.low} + ((${target} - ${A_low}) × (${s.high} - ${s.low})) ÷ (${A_high} - ${A_low}) = <strong style=\"color:#dffbff\">${computed}</strong>`;\n      } else {\n        calcText.innerHTML = `<strong style=\"color:#ffd1d1\">Not found within bounds</strong>`;\n      }\n\n      // highlight bounds & pos\n      highlightState(s);\n      // place pointer\n      if(s.pos !== null){\n        placePointerAt(s.pos, s.found ? '✓' : 'est');\n      } else {\n        // fade pointer out\n        pointer.style.opacity = 0;\n      }\n\n      // animate bubble color briefly\n      if(s.found){\n        bubble.style.color = '#042524';\n        bubble.style.background = 'linear-gradient(90deg,#7be48a,#60ffa1)';\n      } else {\n        bubble.style.color = '#7be4ff';\n        bubble.style.background = 'transparent';\n      }\n\n      // update progress\n      cumulative = Math.min(100, Math.round(((i+1)/total)*100));\n      progressBar.style.width = `${cumulative}%`;\n\n      // update status\n      if(s.action === 'found' || s.found){\n        setStatus(`Found at index ${s.pos}`, 'ok');\n      } else if(s.action === 'not-found'){\n        setStatus('Target not found', 'err');\n      } else {\n        setStatus(`Probe at index ${s.pos}`, 'searching');\n      }\n\n      // subtle zoom animation on element\n      if(s.pos !== null && cells[s.pos]){\n        cells[s.pos].style.transition = 'transform 420ms cubic-bezier(.2,.9,.2,1)';\n      }\n\n      // schedule next\n      const delay = s.found ? 1200 : 1100;\n      const t = setTimeout(()=>{\n        if(s.found || s.action==='not-found'){\n          finish();\n        } else {\n          runStep(i+1);\n        }\n      }, delay);\n      animTimeouts.push(t);\n    }\n\n    function finish(){\n      animating = false;\n      playBtn.disabled = false;\n      resetBtn.disabled = false;\n      pointer.style.transform = 'translateY(0)';\n      if(seq[seq.length-1].found){\n        setStatus(`Completed: Found ${target}`, 'ok');\n        // small celebratory glow on found cell\n        const idx = seq.slice().find(s=>s.found).pos;\n        if(cells[idx]){\n          cells[idx].classList.add('found');\n          // sparkle effect\n          sparkleAt(cells[idx]);\n        }\n      } else {\n        setStatus('Completed: Not found', 'err');\n      }\n    }\n\n    runStep(0);\n  }\n\n  // small decorative sparkle using radial pseudo-element anchored to cell\n  function sparkleAt(cell){\n    const sparkle = document.createElement('div');\n    sparkle.style.position = 'absolute';\n    sparkle.style.pointerEvents = 'none';\n    sparkle.style.width = '140px';\n    sparkle.style.height = '140px';\n    sparkle.style.left = `${cell.offsetLeft - 42}px`;\n    sparkle.style.top = `${cell.offsetTop - 52}px`;\n    sparkle.style.borderRadius = '50%';\n    sparkle.style.background = 'radial-gradient(circle at 30% 30%, rgba(255,255,255,0.75), rgba(123,228,255,0.18) 25%, rgba(142,244,194,0.12) 40%, transparent 60%)';\n    sparkle.style.opacity = '0';\n    sparkle.style.transform = 'scale(.6)';\n    sparkle.style.transition = 'opacity 420ms ease, transform 600ms cubic-bezier(.2,.9,.2,1)';\n    arrayEl.appendChild(sparkle);\n    requestAnimationFrame(()=>{\n      sparkle.style.opacity = '1';\n      sparkle.style.transform = 'scale(1)';\n    });\n    setTimeout(()=>{\n      sparkle.style.opacity = '0';\n      sparkle.style.transform = 'scale(1.4)';\n      setTimeout(()=> sparkle.remove(), 600);\n    }, 600);\n  }\n\n  // Initialize new visualization\n  function reset(){\n    clearTimeouts();\n    animating = false;\n    playBtn.disabled = false;\n    resetBtn.disabled = false;\n    bubble.textContent = 'est';\n    bubble.style.background = 'transparent';\n    bubble.style.color = 'var(--accent)';\n    statusText.textContent = 'Idle';\n    statusDot.style.background = 'linear-gradient(90deg,#39ffea,#60ffa1)';\n    progressBar.style.width = '0%';\n    calcText.textContent = 'Calculated position: —';\n    metaLow.textContent = 'low: —';\n    metaHigh.textContent = 'high: —';\n    metaPos.textContent = 'pos: —';\n    metaVal.textContent = 'A[pos]: —';\n    pointer.style.opacity = 1;\n\n    arr = buildArray(N);\n    createCells();\n    // choose a target from array (often pick a random existing element — demonstrates success)\n    target = arr[randInt(0,arr.length-1)];\n    targetPill.textContent = 'Target: ' + target;\n    arrLen.textContent = arr.length;\n    // compute steps now\n    steps = computeSteps(arr, target);\n    // Initially highlight global bounds\n    if(cells.length){\n      cells[0].classList.add('low');\n      cells[cells.length-1].classList.add('high');\n      placePointerAt(Math.floor(cells.length/2),'est');\n    }\n  }\n\n  // Bind handlers\n  playBtn.addEventListener('click', ()=>{\n    if(animating) return;\n    // recompute steps each time (center changes)\n    steps = computeSteps(arr, target);\n    animateSteps(steps);\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    reset();\n  });\n\n  // initial\n  reset();\n\n  // Small accessibility: enable keyboard activation\n  playBtn.addEventListener('keyup', (e)=>{ if(e.key === 'Enter') playBtn.click(); });\n  resetBtn.addEventListener('keyup', (e)=>{ if(e.key === 'Enter') resetBtn.click(); });\n\n  // Ensure pointer reposition on resize\n  window.addEventListener('resize', ()=>{\n    // move pointer to center cell or pos if present\n    const posCell = document.querySelector('.cell.pos') || document.querySelector('.cell.low') || document.querySelector('.cell');\n    if(posCell){\n      const idx = Array.prototype.indexOf.call(cells, posCell);\n      placePointerAt(idx, 'est');\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
