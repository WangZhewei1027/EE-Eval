    "content": "<html>\n<head>\n    <title>Interactive Interpreter</title>\n    <style>\n        body {\n            font-family: monospace;\n            margin: 20px;\n            line-height: 1.5;\n        }\n        #codeInput {\n            width: 100%;\n            height: 100px;\n            font-family: monospace;\n        }\n        #output {\n            border: 1px solid #ccc;\n            padding: 10px;\n            min-height: 100px;\n            white-space: pre-wrap;\n        }\n        .control-panel {\n            margin: 10px 0;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n        button {\n            margin: 5px;\n        }\n        .var-display {\n            margin-top: 20px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n        }\n        th, td {\n            border: 1px solid #ccc;\n            padding: 5px;\n            text-align: left;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interactive Interpreter</h1>\n    <div class=\"control-panel\">\n        <h3>Code Input</h3>\n        <textarea id=\"codeInput\" placeholder=\"Enter your code here...\"></textarea>\n        <div>\n            <button onclick=\"executeCode()\">Execute</button>\n            <button onclick=\"clearCode()\">Clear</button>\n            <button onclick=\"stepThrough()\">Step Through</button>\n            <button onclick=\"showAST()\">Show AST</button>\n            <button onclick=\"showSymbolTable()\">Show Symbols</button>\n        </div>\n    </div>\n\n    <div class=\"control-panel\">\n        <h3>Execution Controls</h3>\n        <div>\n            <label>Execution Speed: </label>\n            <input type=\"range\" id=\"execSpeed\" min=\"0\" max=\"1000\" value=\"100\" onchange=\"updateSpeed()\">\n            <span id=\"speedValue\">100ms</span>\n        </div>\n        <div>\n            <label>Max Steps: </label>\n            <input type=\"number\" id=\"maxSteps\" value=\"100\" min=\"1\" max=\"1000\">\n        </div>\n        <div>\n            <button onclick=\"pauseExecution()\">Pause</button>\n            <button onclick=\"resumeExecution()\">Resume</button>\n            <button onclick=\"resetInterpreter()\">Reset</button>\n        </div>\n    </div>\n\n    <div class=\"control-panel\">\n        <h3>Output</h3>\n        <div id=\"output\"></div>\n    </div>\n\n    <div class=\"control-panel var-display\">\n        <h3>Variable Inspector</h3>\n        <div>\n            <input type=\"text\" id=\"varName\" placeholder=\"Variable name\">\n            <button onclick=\"inspectVariable()\">Inspect</button>\n            <button onclick=\"watchVariable()\">Watch</button>\n            <button onclick=\"unwatchVariable()\">Unwatch</button>\n        </div>\n        <div id=\"variableValue\"></div>\n        <table id=\"watchedVars\">\n            <thead>\n                <tr>\n                    <th>Variable</th>\n                    <th>Value</th>\n                    <th>Type</th>\n                </tr>\n            </thead>\n            <tbody></tbody>\n        </table>\n    </div>\n\n    <div class=\"control-panel\">\n        <h3>Environment</h3>\n        <div>\n            <button onclick=\"showEnvironment()\">Show Environment</button>\n            <button onclick=\"saveEnvironment()\">Save Environment</button>\n            <button onclick=\"loadEnvironment()\">Load Environment</button>\n        </div>\n        <div id=\"environmentInfo\"></div>\n    </div>\n\n    <script>\n        // Interpreter state\n        let interpreterState = {\n            variables: {},\n            functions: {},\n            executionPaused: false,\n            executionSpeed: 100,\n            stepIndex: 0,\n            maxSteps: 100,\n            watchedVariables: [],\n            ast: null,\n            symbolTable: {},\n            executionStack: []\n        };\n\n        // DOM elements\n        const codeInput = document.getElementById('codeInput');\n        const output = document.getElementById('output');\n        const execSpeed = document.getElementById('execSpeed');\n        const speedValue = document.getElementById('speedValue');\n        const maxSteps = document.getElementById('maxSteps');\n        const varName = document.getElementById('varName');\n        const variableValue = document.getElementById('variableValue');\n        const watchedVarsTbody = document.querySelector('#watchedVars tbody');\n        const environmentInfo = document.getElementById('environmentInfo');\n\n        // Core interpreter functions\n        function executeCode() {\n            const code = codeInput.value;\n            if (!code.trim()) {\n                output.textContent = \"No code to execute\";\n                return;\n            }\n\n            try {\n                // Parse and build AST\n                interpreterState.ast = parseCode(code);\n                interpreterState.symbolTable = buildSymbolTable(interpreterState.ast);\n                \n                // Execute\n                const result = evaluate(interpreterState.ast);\n                output.textContent += `\\n>> ${result}`;\n                updateWatchedVariables();\n            } catch (e) {\n                output.textContent += `\\nError: ${e.message}`;\n            }\n        }\n\n        function parseCode(code) {\n            // Simplified parsing\n            const lines = code.split('\\n').filter(line => line.trim());\n            const ast = {\n                type: 'Program',\n                body: []\n            };\n\n            for (const line of lines) {\n                if (line.includes('=')) {\n                    // Variable assignment\n                    const [varName, expr] = line.split('=').map(s => s.trim());\n                    ast.body.push({\n                        type: 'Assignment',\n                        varName,\n                        expression: parseExpression(expr)\n                    });\n                } else if (line.startsWith('function ')) {\n                    // Function definition\n                    const match = line.match(/function\\s+(\\w+)\\((.*)\\)\\s*\\{?/);\n                    if (match) {\n                        const funcName = match[1];\n                        const params = match[2].split(',').map(p => p.trim()).filter(p => p);\n                        ast.body.push({\n                            type: 'FunctionDeclaration',\n                            name: funcName,\n                            params,\n                            body: [] // Simplified\n                        });\n                    }\n                } else {\n                    // Expression\n                    ast.body.push({\n                        type: 'Expression',\n                        expression: parseExpression(line)\n                    });\n                }\n            }\n\n            return ast;\n        }\n\n        function parseExpression(expr) {\n            // Very simplified expression parser\n            if (expr.includes('+')) {\n                const [left, right] = expr.split('+').map(s => s.trim());\n                return {\n                    type: 'BinaryExpression',\n                    operator: '+',\n                    left: parseExpression(left),\n                    right: parseExpression(right)\n                };\n            } else if (expr.includes('*')) {\n                const [left, right] = expr.split('*').map(s => s.trim());\n                return {\n                    type: 'BinaryExpression',\n                    operator: '*',\n                    left: parseExpression(left),\n                    right: parseExpression(right)\n                };\n            } else if (!isNaN(expr)) {\n                return {\n                    type: 'Literal',\n                    value: Number(expr)\n                };\n            } else {\n                return {\n                    type: 'Identifier',\n                    name: expr\n                };\n            }\n        }\n\n        function buildSymbolTable(ast) {\n            const symbols = {};\n            for (const node of ast.body) {\n                if (node.type === 'Assignment') {\n                    symbols[node.varName] = { type: 'variable' };\n                } else if (node.type === 'FunctionDeclaration') {\n                    symbols[node.name] = { type: 'function', params: node.params };\n                }\n            }\n            return symbols;\n        }\n\n        function evaluate(node) {\n            if (node.type === 'Program') {\n                let result;\n                for (const stmt of node.body) {\n                    result = evaluate(stmt);\n                }\n                return result;\n            } else if (node.type === 'Assignment') {\n                const value = evaluate(node.expression);\n                interpreterState.variables[node.varName] = value;\n                return value;\n            } else if (node.type === 'Expression') {\n                return evaluate(node.expression);\n            } else if (node.type === 'BinaryExpression') {\n                const left = evaluate(node.left);\n                const right = evaluate(node.right);\n                switch (node.operator) {\n                    case '+': return left + right;\n                    case '*': return left * right;\n                    default: throw new Error(`Unknown operator: ${node.operator}`);\n                }\n            } else if (node.type === 'Literal') {\n                return node.value;\n            } else if (node.type === 'Identifier') {\n                if (interpreterState.variables.hasOwnProperty(node.name)) {\n                    return interpreterState.variables[node.name];\n                }\n                throw new Error(`Undefined variable: ${node.name}`);\n            }\n            return undefined;\n        }\n\n        // Interactive controls\n        function clearCode() {\n            codeInput.value = '';\n            output.textContent = '';\n        }\n\n        function stepThrough() {\n            if (!interpreterState.ast) {\n                const code = codeInput.value;\n                if (!code.trim()) {\n                    output.textContent = \"No code to execute\";\n                    return;\n                }\n                interpreterState.ast = parseCode(code);\n                interpreterState.symbolTable = buildSymbolTable(interpreterState.ast);\n                interpreterState.stepIndex = 0;\n            }\n\n            if (interpreterState.stepIndex < interpreterState.ast.body.length) {\n                const node = interpreterState.ast.body[interpreterState.stepIndex];\n                output.textContent += `\\nStep ${interpreterState.stepIndex + 1}: Executing ${node.type}`;\n                if (node.type === 'Assignment') {\n                    output.textContent += ` ${node.varName}`;\n                }\n                const result = evaluate(node);\n                if (result !== undefined) {\n                    output.textContent += ` → ${result}`;\n                }\n                interpreterState.stepIndex++;\n                updateWatchedVariables();\n            } else {\n                output.textContent += \"\\nExecution complete\";\n            }\n        }\n\n        function showAST() {\n            if (!interpreterState.ast) {\n                output.textContent = \"No AST available. Execute code first.\";\n                return;\n            }\n            output.textContent = \"Abstract Syntax Tree:\\n\" + JSON.stringify(interpreterState.ast, null, 2);\n        }\n\n        function showSymbolTable() {\n            if (!interpreterState.symbolTable) {\n                output.textContent = \"No symbol table available. Execute code first.\";\n                return;\n            }\n            output.textContent = \"Symbol Table:\\n\" + JSON.stringify(interpreterState.symbolTable, null, 2);\n        }\n\n        function updateSpeed() {\n            interpreterState.executionSpeed = parseInt(execSpeed.value);\n            speedValue.textContent = `${interpreterState.executionSpeed}ms`;\n        }\n\n        function pauseExecution() {\n            interpreterState.executionPaused = true;\n            output.textContent += \"\\nExecution paused\";\n        }\n\n        function resumeExecution() {\n            interpreterState.executionPaused = false;\n            output.textContent += \"\\nResuming execution\";\n            executeCode();\n        }\n\n        function resetInterpreter() {\n            interpreterState = {\n                variables: {},\n                functions: {},\n                executionPaused: false,\n                executionSpeed: 100,\n                stepIndex: 0,\n                maxSteps: 100,\n                watchedVariables: [],\n                ast: null,\n                symbolTable: {},\n                executionStack: []\n            };\n            output.textContent = \"Interpreter reset\";\n            updateWatchedVariables();\n        }\n\n        function inspectVariable() {\n            const name = varName.value.trim();\n            if (!name) return;\n            \n            if (interpreterState.variables.hasOwnProperty(name)) {\n                variableValue.textContent = `${name} = ${interpreterState.variables[name]}`;\n            } else {\n                variableValue.textContent = `Variable ${name} not found`;\n            }\n        }\n\n        function watchVariable() {\n            const name = varName.value.trim();\n            if (!name) return;\n            \n            if (!interpreterState.watchedVariables.includes(name)) {\n                interpreterState.watchedVariables.push(name);\n                updateWatchedVariables();\n            }\n        }\n\n        function unwatchVariable() {\n            const name = varName.value.trim();\n            if (!name) return;\n            \n            interpreterState.watchedVariables = interpreterState.watchedVariables.filter(v => v !== name);\n            updateWatchedVariables();\n        }\n\n        function updateWatchedVariables() {\n            watchedVarsTbody.innerHTML = '';\n            for (const name of interpreterState.watchedVariables) {\n                const row = document.createElement('tr');\n                const nameCell = document.createElement('td');\n                const valueCell = document.createElement('td');\n                const typeCell = document.createElement('td');\n                \n                nameCell.textContent = name;\n                \n                if (interpreterState.variables.hasOwnProperty(name)) {\n                    const value = interpreterState.variables[name];\n                    valueCell.textContent = value;\n                    typeCell.textContent = typeof value;\n                } else {\n                    valueCell.textContent = \"undefined\";\n                    typeCell.textContent = \"undefined\";\n                }\n                \n                row.appendChild(nameCell);\n                row.appendChild(valueCell);\n                row.appendChild(typeCell);\n                watchedVarsTbody.appendChild(row);\n            }\n        }\n\n        function showEnvironment() {\n            environmentInfo.innerHTML = `\n                <h4>Current Environment</h4>\n                <pre>Variables: ${JSON.stringify(interpreterState.variables, null, 2)}</pre>\n                <pre>Functions: ${JSON.stringify(interpreterState.functions, null, 2)}</pre>\n            `;\n        }\n\n        function saveEnvironment() {\n            localStorage.setItem('interpreterEnvironment', JSON.stringify({\n                variables: interpreterState.variables,\n                functions: interpreterState.functions\n            }));\n            output.textContent += \"\\nEnvironment saved\";\n        }\n\n        function loadEnvironment() {\n            const saved = localStorage.getItem('interpreterEnvironment');\n            if (saved) {\n                const env = JSON.parse(saved);\n                interpreterState.variables = env.variables || {};\n                interpreterState.functions = env.functions || {};\n                output.textContent += \"\\nEnvironment loaded\";\n                updateWatchedVariables();\n            } else {\n                output.textContent += \"\\nNo saved environment found\";\n            }\n        }\n\n        // Initialize\n        output.textContent = \"Interpreter ready. Enter code to begin.\";\n    </script>\n</body>\n</html>"
  },
