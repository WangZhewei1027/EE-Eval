    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Amortized Analysis Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #result {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Amortized Analysis Interactive Demo</h1>\n\n    <label for=\"operation\">Select Operation:</label>\n    <select id=\"operation\">\n        <option value=\"insert\">Insert</option>\n        <option value=\"delete\">Delete</option>\n        <option value=\"get\">Get</option>\n    </select>\n\n    <label for=\"size\">Current Size of Data Structure:</label>\n    <input type=\"number\" id=\"size\" value=\"0\" min=\"0\" />\n\n    <button id=\"execute\">Execute Operation</button>\n    <button id=\"reset\">Reset</button>\n\n    <div id=\"result\"></div>\n\n    <script>\n        let currentSize = 0;\n        let totalOperations = 0;\n        let cost = 0;\n\n        document.getElementById(\"execute\").onclick = function () {\n            const operation = document.getElementById(\"operation\").value;\n            const sizeInput = parseInt(document.getElementById(\"size\").value);\n            let currentCost = 0;\n\n            if (operation === \"insert\") {\n                currentCost = 1; // Basic insert cost\n                if (sizeInput >= 1) {\n                    currentCost += 1; // Increment cost for growing array\n                }\n                currentSize += 1;\n            } else if (operation === \"delete\") {\n                if (sizeInput >= 1) {\n                    currentCost = 1; // Basic delete cost\n                    currentSize -= 1;\n                } else {\n                    currentCost = 0; // No cost if nothing to delete\n                }\n            } else if (operation === \"get\") {\n                currentCost = 1; // Cost to retrieve an element\n            }\n\n            totalOperations++;\n            cost += currentCost;\n\n            const amortizedCost = (cost / totalOperations).toFixed(2);\n            document.getElementById(\"result\").innerHTML = \n                `Operation: ${operation}<br>Current Size: ${currentSize}<br>Current Cost: ${currentCost}<br>Total Cost: ${cost}<br>Amortized Cost: ${amortizedCost}`;\n        };\n\n        document.getElementById(\"reset\").onclick = function () {\n            currentSize = 0;\n            totalOperations = 0;\n            cost = 0;\n            document.getElementById(\"size\").value = 0;\n            document.getElementById(\"result\").innerHTML = \"\";\n        };\n    </script>\n</body>\n</html>"
