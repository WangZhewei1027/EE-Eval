  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Runtime Environment Interactive Explorer</title>\n<style>\n  /* Minimal styling for layout only, no visual styling */\n  body {\n    margin: 1em;\n    font-family: monospace, monospace;\n  }\n  textarea, input, select, button {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    margin-top: 0.2em;\n    margin-bottom: 0.5em;\n    display: block;\n    width: 100%;\n    box-sizing: border-box;\n  }\n  label {\n    margin-top: 0.8em;\n    display: block;\n  }\n  fieldset {\n    margin-top: 1em;\n  }\n  #log {\n    white-space: pre-wrap;\n    height: 150px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 0.2em;\n  }\n</style>\n</head>\n<body>\n<h1>Runtime Environment Interactive Explorer</h1>\n\n<p>\nThis tool helps you explore and interact with a simulated Runtime Environment (RE), demonstrating concepts such as processes, memory, system calls, and other RE components. Use the controls below to create, manage, and inspect processes, manipulate environment variables, and explore advanced settings.\n</p>\n\n<div id=\"controls\">\n\n  <fieldset>\n    <legend>Process Management</legend>\n\n    <label for=\"procName\">Create New Process: Enter process name</label>\n    <input type=\"text\" id=\"procName\" placeholder=\"e.g. myProcess\" autocomplete=\"off\" />\n\n    <label for=\"procPriority\">Select Priority (1 = Highest, 10 = Lowest)</label>\n    <input type=\"range\" id=\"procPriority\" min=\"1\" max=\"10\" value=\"5\" />\n\n    <button id=\"createProc\">Create Process</button>\n\n    <label for=\"selectProc\">Select Existing Process</label>\n    <select id=\"selectProc\" size=\"5\" style=\"height:7em;\"></select>\n\n    <button id=\"startProc\">Start Process</button>\n    <button id=\"pauseProc\">Pause Process</button>\n    <button id=\"killProc\">Kill Process</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Process Operations</legend>\n\n    <label for=\"syscallSelect\">Invoke System Call</label>\n    <select id=\"syscallSelect\">\n      <option value=\"read\">read()</option>\n      <option value=\"write\">write()</option>\n      <option value=\"fork\">fork()</option>\n      <option value=\"exec\">exec()</option>\n      <option value=\"exit\">exit()</option>\n      <option value=\"getenv\">getenv()</option>\n      <option value=\"setenv\">setenv()</option>\n    </select>\n\n    <label for=\"syscallArgs\">System Call Arguments (comma-separated)</label>\n    <input type=\"text\" id=\"syscallArgs\" placeholder=\"e.g. filename.txt, 100\" autocomplete=\"off\" />\n\n    <button id=\"invokeSyscall\">Invoke</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Environment Variables (Global)</legend>\n\n    <label for=\"envKey\">Variable Name</label>\n    <input type=\"text\" id=\"envKey\" placeholder=\"e.g. PATH\" autocomplete=\"off\" />\n\n    <label for=\"envValue\">Variable Value</label>\n    <input type=\"text\" id=\"envValue\" placeholder=\"e.g. /usr/bin\" autocomplete=\"off\" />\n\n    <button id=\"setEnv\">Set Environment Variable</button>\n    <button id=\"unsetEnv\">Unset Environment Variable</button>\n\n    <button id=\"listEnv\">List Global Environment Variables</button>\n  </fieldset>\n\n  <fieldset>\n    <legend>Memory Management (per process)</legend>\n\n    <label for=\"memSize\">Allocate Memory Size (KB)</label>\n    <input type=\"number\" id=\"memSize\" min=\"1\" value=\"64\" />\n\n    <button id=\"allocMem\">Allocate Memory</button>\n    <button id=\"freeMem\">Free All Memory</button>\n\n    <label>Process Memory Blocks</label>\n    <select id=\"memBlocks\" size=\"4\" style=\"height:6em;\" disabled></select>\n\n    <button id=\"inspectMemBlock\" disabled>Inspect Selected Memory Block</button>\n\n    <pre id=\"memBlockInfo\" style=\"border: 1px solid black; min-height: 4em; white-space: pre-wrap;\"></pre>\n  </fieldset>\n\n  <fieldset>\n    <legend>Runtime Environment Info & Logs</legend>\n    <button id=\"showREInfo\">Show Runtime Environment Info</button>\n    <button id=\"clearLog\">Clear Log</button>\n    <div id=\"log\"></div>\n  </fieldset>\n\n</div>\n\n<script>\n(() => {\n\n// Data structures\nclass Process {\n  constructor(name, priority) {\n    this.id = Process.nextId++;\n    this.name = name || ('Process'+this.id);\n    this.priority = priority || 5;\n    this.state = 'created'; // possible states: created, running, paused, killed, exited\n    this.env = Object.assign({}, RuntimeEnv.globalEnv); // process env copies global env at creation\n    this.memoryBlocks = []; // { id, sizeKB, details }\n    this.syscallHistory = []; // { syscall, args, timestamp, result }\n    this.children = []; // for forked children\n    this.parent = null;\n  }\n  toString() {\n    return `#${this.id} \"${this.name}\" [Priority:${this.priority}] State:${this.state}`;\n  }\n}\nProcess.nextId = 1;\n\nconst RuntimeEnv = {\n  globalEnv: {},\n\n  processes: [],\n\n  logBuffer: [],\n\n  maxLogEntries: 1000,\n\n  addLog(msg) {\n    const time = new Date().toLocaleTimeString();\n    const entry = `[${time}] ${msg}`;\n    this.logBuffer.push(entry);\n    if (this.logBuffer.length > this.maxLogEntries) {\n      this.logBuffer.shift();\n    }\n    updateLog();\n  },\n\n  getProcessById(id) {\n    return this.processes.find(p => p.id === id);\n  },\n\n  getProcessByName(name) {\n    return this.processes.find(p => p.name === name);\n  }\n};\n\n// UI elements\nconst procNameInput = document.getElementById('procName');\nconst procPriorityInput = document.getElementById('procPriority');\nconst createProcBtn = document.getElementById('createProc');\nconst selectProc = document.getElementById('selectProc');\nconst startProcBtn = document.getElementById('startProc');\nconst pauseProcBtn = document.getElementById('pauseProc');\nconst killProcBtn = document.getElementById('killProc');\n\nconst syscallSelect = document.getElementById('syscallSelect');\nconst syscallArgsInput = document.getElementById('syscallArgs');\nconst invokeSyscallBtn = document.getElementById('invokeSyscall');\n\nconst envKeyInput = document.getElementById('envKey');\nconst envValueInput = document.getElementById('envValue');\nconst setEnvBtn = document.getElementById('setEnv');\nconst unsetEnvBtn = document.getElementById('unsetEnv');\nconst listEnvBtn = document.getElementById('listEnv');\n\nconst memSizeInput = document.getElementById('memSize');\nconst allocMemBtn = document.getElementById('allocMem');\nconst freeMemBtn = document.getElementById('freeMem');\nconst memBlocksSelect = document.getElementById('memBlocks');\nconst inspectMemBlockBtn = document.getElementById('inspectMemBlock');\nconst memBlockInfoPre = document.getElementById('memBlockInfo');\n\nconst showREInfoBtn = document.getElementById('showREInfo');\nconst clearLogBtn = document.getElementById('clearLog');\nconst logDiv = document.getElementById('log');\n\nfunction updateProcessList() {\n  // Clear options\n  selectProc.innerHTML = '';\n  RuntimeEnv.processes.forEach(p => {\n    const opt = document.createElement('option');\n    opt.value = p.id;\n    opt.textContent = p.toString();\n    selectProc.appendChild(opt);\n  });\n  updateMemBlocksList();\n  updateProcessControlsState();\n}\n\nfunction updateMemBlocksList() {\n  memBlocksSelect.innerHTML = '';\n  const p = getSelectedProcess();\n  if (p && p.memoryBlocks.length > 0) {\n    memBlocksSelect.disabled = false;\n    inspectMemBlockBtn.disabled = false;\n    p.memoryBlocks.forEach(block => {\n      const opt = document.createElement('option');\n      opt.value = block.id;\n      opt.textContent = `Block #${block.id} - ${block.sizeKB}KB`;\n      memBlocksSelect.appendChild(opt);\n    });\n  } else {\n    memBlocksSelect.disabled = true;\n    inspectMemBlockBtn.disabled = true;\n  }\n}\n\nfunction updateProcessControlsState() {\n  const p = getSelectedProcess();\n  const runningState = p && p.state === 'running';\n  const pausedState = p && p.state === 'paused';\n  startProcBtn.disabled = !(p && (p.state === 'created' || p.state === 'paused'));\n  pauseProcBtn.disabled = !(p && runningState);\n  killProcBtn.disabled = !(p && (p.state !== 'killed' && p.state !== 'exited'));\n  invokeSyscallBtn.disabled = !p;\n  allocMemBtn.disabled = !(p && p.state === 'running');\n  freeMemBtn.disabled = !(p && p.memoryBlocks.length > 0);\n  memSizeInput.disabled = !(p && p.state === 'running');\n}\n\nfunction getSelectedProcess() {\n  const val = selectProc.value;\n  if (!val) return null;\n  const pid = parseInt(val,10);\n  return RuntimeEnv.getProcessById(pid);\n}\n\nfunction addMemoryBlockToProcess(p, sizeKB) {\n  const blockId = (p.memoryBlocks.length ? p.memoryBlocks[p.memoryBlocks.length-1].id + 1 : 1);\n  const details = `Dummy memory block of size ${sizeKB}KB. Simulated content: ${generateRandomHex(sizeKB*1024)}`;\n  const block = { id: blockId, sizeKB, details };\n  p.memoryBlocks.push(block);\n  RuntimeEnv.addLog(`Memory block #${block.id} allocated (${block.sizeKB}KB) in process #${p.id} \"${p.name}\"`);\n}\n\nfunction generateRandomHex(numBytes) {\n  // Generates a hex string roughly of numBytes length / 2 (bytes)\n  const length = Math.min(128, numBytes / 2); // limit for display\n  let s = '';\n  for (let i = 0; i < length; i++) {\n    const n = Math.floor(Math.random() * 256);\n    s += n.toString(16).padStart(2, '0');\n  }\n  return s + (length < numBytes/2 ? '...' : '');\n}\n\n// Process lifecycle functions\nfunction createProcess(name, priority) {\n  const normalizedName = name.trim();\n  if (normalizedName.length === 0) {\n    alert('Process name cannot be empty.');\n    return null;\n  }\n  if (RuntimeEnv.processes.some(p => p.name === normalizedName)) {\n    alert('Process name must be unique.');\n    return null;\n  }\n  const p = new Process(normalizedName, priority);\n  RuntimeEnv.processes.push(p);\n  RuntimeEnv.addLog(`Created process #${p.id} \"${p.name}\" with priority ${p.priority}`);\n  return p;\n}\n\nfunction changeProcessState(p, newState) {\n  if (!p) return;\n  const oldState = p.state;\n  if (oldState === 'killed' || oldState === 'exited') {\n    RuntimeEnv.addLog(`Cannot change state of process #${p.id} \"${p.name}\" because it is already ${oldState}`);\n    return;\n  }\n  if (oldState === newState) return;\n  p.state = newState;\n  RuntimeEnv.addLog(`Process #${p.id} \"${p.name}\" changed state: ${oldState} → ${newState}`);\n  updateProcessControlsState();\n  updateProcessList();\n}\n\n// System calls logic: simulate basic behaviors\nfunction invokeSyscall(p, syscall, args) {\n  if (!p) {\n    alert('No process selected');\n    return;\n  }\n  if (p.state !== 'running') {\n    alert(`Process must be running to invoke syscalls (current state: ${p.state})`);\n    return;\n  }\n  args = args.map(a => a.trim());\n\n  // syscall result and side effects\n  let result = null;\n  const timestamp = new Date();\n\n  switch (syscall) {\n    case 'read':\n      if (args.length < 1) {\n        alert('read(filename) requires at least 1 argument');\n        return;\n      }\n      // Simulate file read with dummy content\n      result = `Content of \"${args[0]}\" (simulated)`;\n      break;\n\n    case 'write':\n      if (args.length < 2) {\n        alert('write(filename, content) requires at least 2 arguments');\n        return;\n      }\n      result = `Wrote to \"${args[0]}\" content length ${args[1].length}`;\n      break;\n\n    case 'fork':\n      // create a child process as copy of current\n      const childName = `${p.name}_child${p.children.length + 1}`;\n      const child = new Process(childName, p.priority);\n      child.state = 'created';\n      child.env = Object.assign({}, p.env);\n      child.parent = p;\n      p.children.push(child);\n      RuntimeEnv.processes.push(child);\n      result = `Forked child process #${child.id} \"${child.name}\" from parent #${p.id}`;\n      updateProcessList();\n      break;\n\n    case 'exec':\n      if (args.length < 1) {\n        alert('exec(programName) requires at least 1 argument');\n        return;\n      }\n      result = `Process #${p.id} exec() replaced image by \"${args[0]}\" (simulated)`;\n      p.name = args[0];\n      updateProcessList();\n      break;\n\n    case 'exit':\n      changeProcessState(p, 'exited');\n      result = `Process #${p.id} has exited.`;\n      break;\n\n    case 'getenv':\n      if (args.length < 1) {\n        alert('getenv(variableName) requires at least 1 argument');\n        return;\n      }\n      const value = p.env[args[0]] === undefined ? '(unset)' : p.env[args[0]];\n      result = `getenv(\"${args[0]}\") → \"${value}\"`;\n      break;\n\n    case 'setenv':\n      if (args.length < 2) {\n        alert('setenv(variableName, value) requires at least 2 arguments');\n        return;\n      }\n      p.env[args[0]] = args[1];\n      result = `setenv(\"${args[0]}\") = \"${args[1]}\" for process #${p.id}`;\n      break;\n\n    default:\n      alert('Unknown syscall: ' + syscall);\n      return;\n  }\n\n  p.syscallHistory.push({ syscall, args, timestamp, result });\n  RuntimeEnv.addLog(`Process #${p.id} syscall: ${syscall}(${args.join(', ')}) → ${result}`);\n}\n\n// Environment Variables global management\nfunction setGlobalEnvVariable(key, value) {\n  if (!key) {\n    alert('Environment variable key cannot be empty.');\n    return;\n  }\n  RuntimeEnv.globalEnv[key] = value;\n  RuntimeEnv.addLog(`Global environment variable set: ${key} = ${value}`);\n}\n\nfunction unsetGlobalEnvVariable(key) {\n  if (!key) {\n    alert('Environment variable key cannot be empty.');\n    return;\n  }\n  if (RuntimeEnv.globalEnv.hasOwnProperty(key)) {\n    delete RuntimeEnv.globalEnv[key];\n    RuntimeEnv.addLog(`Global environment variable unset: ${key}`);\n  } else {\n    RuntimeEnv.addLog(`Global environment variable ${key} does not exist`);\n  }\n}\n\nfunction listGlobalEnvVariables() {\n  let entries = Object.entries(RuntimeEnv.globalEnv);\n  if (entries.length === 0) {\n    alert('No global environment variables set.');\n  } else {\n    let msg = 'Global Environment Variables:\\n';\n    entries.forEach(([k,v]) => msg += `${k} = ${v}\\n`);\n    alert(msg);\n  }\n}\n\n// Memory management for process\nfunction allocateMemoryForProcess(p, sizeKB) {\n  if (!p) return;\n  if (sizeKB <= 0) {\n    alert('Memory size must be positive');\n    return;\n  }\n  addMemoryBlockToProcess(p, sizeKB);\n  updateMemBlocksList();\n  updateProcessControlsState();\n}\n\nfunction freeAllMemoryForProcess(p) {\n  if (!p) return;\n  if (p.memoryBlocks.length === 0) return;\n  p.memoryBlocks.length = 0;\n  RuntimeEnv.addLog(`Freed all memory for process #${p.id} \"${p.name}\"`);\n  updateMemBlocksList();\n  updateProcessControlsState();\n}\n\nfunction inspectMemoryBlock(p, blockId) {\n  if (!p) return '';\n  const block = p.memoryBlocks.find(b => b.id === blockId);\n  if (!block) return 'Memory block not found.';\n  return `Memory Block #${block.id}\\nSize: ${block.sizeKB} KB\\nDetails:\\n${block.details}`;\n}\n\n// Logs and Runtime Environment info\nfunction updateLog() {\n  logDiv.textContent = RuntimeEnv.logBuffer.join('\\n');\n  logDiv.scrollTop = logDiv.scrollHeight;\n}\n\nfunction clearLog() {\n  RuntimeEnv.logBuffer.length = 0;\n  updateLog();\n}\n\nfunction showRuntimeEnvInfo() {\n  let info = '=== Runtime Environment Info ===\\n';\n  info += `Total processes: ${RuntimeEnv.processes.length}\\n`;\n  const stateCounts = {\n    created: 0, running: 0, paused: 0, killed: 0, exited: 0\n  };\n  RuntimeEnv.processes.forEach(p => {\n    if (stateCounts.hasOwnProperty(p.state)) stateCounts[p.state]++;\n  });\n  for (const state in stateCounts) {\n    info += `Processes ${state}: ${stateCounts[state]}\\n`;\n  }\n  info += `\\nGlobal Environment Variables (${Object.keys(RuntimeEnv.globalEnv).length}):\\n`;\n  for (const [k,v] of Object.entries(RuntimeEnv.globalEnv)) {\n    info += `  ${k} = ${v}\\n`;\n  }\n  info += '\\nProcesses detail:\\n';\n  RuntimeEnv.processes.forEach(p => {\n    info += `#${p.id} \"${p.name}\": State=${p.state}, Priority=${p.priority}, MemoryBlocks=${p.memoryBlocks.length}, Syscalls invoked=${p.syscallHistory.length}\\n`;\n  });\n  alert(info);\n}\n\n// Event handlers\ncreateProcBtn.addEventListener('click', () => {\n  const name = procNameInput.value;\n  const prio = parseInt(procPriorityInput.value, 10);\n  if (!name.trim()) {\n    alert('Enter a non-empty process name.');\n    return;\n  }\n  if (RuntimeEnv.getProcessByName(name.trim())) {\n    alert('Process name already exists, choose another name.');\n    return;\n  }\n  const proc = createProcess(name, prio);\n  if (proc) {\n    procNameInput.value = '';\n    updateProcessList();\n  }\n});\n\nselectProc.addEventListener('change', () => {\n  updateProcessControlsState();\n  updateMemBlocksList();\n  memBlockInfoPre.textContent = '';\n});\n\nstartProcBtn.addEventListener('click', () => {\n  const p = getSelectedProcess();\n  if (!p) {\n    alert('Select a process first.');\n    return;\n  }\n  if (p.state === 'running') {\n    alert('Process already running.');\n    return;\n  }\n  changeProcessState(p, 'running');\n});\n\npauseProcBtn.addEventListener('click', () => {\n  const p = getSelectedProcess();\n  if (!p) {\n    alert('Select a process first.');\n    return;\n  }\n  if (p.state !== 'running') {\n    alert('Process must be running to pause.');\n    return;\n  }\n  changeProcessState(p, 'paused');\n});\n\nkillProcBtn.addEventListener('click', () => {\n  const p = getSelectedProcess();\n  if (!p) {\n    alert('Select a process first.');\n    return;\n  }\n  if (p.state === 'killed' || p.state === 'exited') {\n    alert(`Process already ${p.state}.`);\n    return;\n  }\n  changeProcessState(p, 'killed');\n});\n\ninvokeSyscallBtn.addEventListener('click', () => {\n  const p = getSelectedProcess();\n  if (!p) {\n    alert('Select a process first.');\n    return;\n  }\n  const syscall = syscallSelect.value;\n  let argsStr = syscallArgsInput.value.trim();\n  let args = [];\n  if (argsStr) {\n    // Very simple CSV splitting allowing commas inside quotes\n    args = parseArgsCSV(argsStr);\n  }\n  invokeSyscall(p, syscall, args);\n  syscallArgsInput.value = '';\n  updateProcessList();\n});\n\nsetEnvBtn.addEventListener('click', () => {\n  const k = envKeyInput.value.trim();\n  const v = envValueInput.value.trim();\n  if (!k) {\n    alert('Variable name cannot be empty.');\n    return;\n  }\n  setGlobalEnvVariable(k, v);\n});\n\nunsetEnvBtn.addEventListener('click', () => {\n  const k = envKeyInput.value.trim();\n  if (!k) {\n    alert('Variable name cannot be empty.');\n    return;\n  }\n  unsetGlobalEnvVariable(k);\n});\n\nlistEnvBtn.addEventListener('click', () => {\n  listGlobalEnvVariables();\n});\n\nallocMemBtn.addEventListener('click', () => {\n  const p = getSelectedProcess();\n  if (!p) {\n    alert('Select a process.');\n    return;\n  }\n  if (p.state !== 'running') {\n    alert('Process must be running to allocate memory.');\n    return;\n  }\n  const sizeKB = parseInt(memSizeInput.value, 10);\n  if (isNaN(sizeKB) || sizeKB <= 0) {\n    alert('Enter a valid positive memory size in KB.');\n    return;\n  }\n  allocateMemoryForProcess(p, sizeKB);\n});\n\nfreeMemBtn.addEventListener('click', () => {\n  const p = getSelectedProcess();\n  if (!p) return;\n  if (p.memoryBlocks.length === 0) {\n    alert('No memory blocks to free.');\n    return;\n  }\n  if (!confirm(`Free all ${p.memoryBlocks.length} memory blocks for process #${p.id} \"${p.name}\"?`)) return;\n  freeAllMemoryForProcess(p);\n});\n\ninspectMemBlockBtn.addEventListener('click', () => {\n  const p = getSelectedProcess();\n  if (!p) {\n    alert('Select a process.');\n    return;\n  }\n  const blockIdStr = memBlocksSelect.value;\n  if (!blockIdStr) {\n    alert('Select a memory block.');\n    return;\n  }\n  const blockId = parseInt(blockIdStr, 10);\n  memBlockInfoPre.textContent = inspectMemoryBlock(p, blockId);\n});\n\nshowREInfoBtn.addEventListener('click', () => {\n  showRuntimeEnvInfo();\n});\n\nclearLogBtn.addEventListener('click', () => {\n  clearLog();\n});\n\n// Utility to parse simple CSV that supports quoted strings with commas:\n// e.g.  filename.txt, \"some,complex,arg\", 123\nfunction parseArgsCSV(str) {\n  const result = [];\n  let current = '';\n  let inQuotes = false;\n  for (let i = 0; i < str.length; i++) {\n    const c = str[i];\n    if (c === '\"') {\n      inQuotes = !inQuotes;\n    } else if (c === ',' && !inQuotes) {\n      result.push(current.trim());\n      current = '';\n    } else {\n      current += c;\n    }\n  }\n  if (current) result.push(current.trim());\n  // Strip quotes from args\n  return result.map(arg => {\n    if (arg.startsWith('\"') && arg.endsWith('\"') && arg.length >= 2) {\n      return arg.slice(1, -1);\n    }\n    return arg;\n  });\n}\n\n// Initialize some environment variables\nRuntimeEnv.globalEnv = {\n  PATH: '/usr/bin:/bin',\n  HOME: '/home/user',\n  LANG: 'en_US.UTF-8'\n};\nRuntimeEnv.addLog('Initialized global environment variables: PATH, HOME, LANG');\n\n// Focus on process name input for quick creation\nprocNameInput.focus();\n\nupdateProcessList();\nupdateProcessControlsState();\nupdateMemBlocksList();\nupdateLog();\n\n})();\n</script>\n</body>\n</html>"
  },
