Control = null;\n        let currentState = null;\n\n        function updateControl() {\n            const currentControl = controls.find(control => control.id === currentControl);\n            const currentState = currentControl ? currentControl.label : '';\n\n            document.getElementById('current-control').innerText = currentControl ? currentControl.label : 'No control selected';\n            document.getElementById('current-state').innerText = currentState;\n        }\n\n        function toggleControl() {\n            currentControl = controls.find(control => control.id === currentControl);\n            updateControl();\n\n            if (currentControl) {\n                currentState = currentControl.label;\n            }\n        }\n\n        function switchControl(newControl) {\n            currentControl = newControl;\n            updateControl();\n\n            if (currentControl) {\n                currentState = currentControl.label;\n            }\n        }\n\n        document.getElementById('search-input').addEventListener('input', () => {\n            currentControl = controls.find(control => control.id === 'search-input');\n            updateControl();\n        });\n\n        document.getElementById('clear-button').addEventListener('click', () => {\n            currentControl = controls.find(control => control.id === 'clear-button');\n            updateControl();\n        });\n\n        document.getElementById('save-button').addEventListener('click', () => {\n            currentControl = controls.find(control => control.id === 'save-button');\n            updateControl();\n        });\n\n        document.getElementById('load-button').addEventListener('click', () => {\n            currentControl = controls.find(control => control.id === 'load-button');\n            updateControl();\n        });\n\n        document.getElementById('reset-button').addEventListener('click', () => {\n            switchControl(null);\n        });\n\n        document.getElementById('maximize-button').addEventListener('click', () => {\n            switchControl('Maximize');\n        });\n\n        document.getElementById('minimize-button').addEventListener('click', () => {\n            switchControl('Minimize');\n        });\n\n        document.getElementById('close-button').addEventListener('click', () => {\n            document.body.style.maxWidth = '0px';\n            document.body.style.minWidth = '0px';\n            document.body.style.maxHeight = '0px';\n            document.body.style.minHeight = '0px';\n            document.body.style.width = '0px';\n            document.body.style.height = '0px';\n            document.body.style.overflow = 'hidden';\n            document.body.style.display = 'block';\n            document.body.style.position = 'fixed';\n            document.body.style.zIndex = '1000';\n            document.body.style.background = 'none';\n            document.body.style.border = 'none';\n            document.body.style.boxSizing = 'border-box';\n            document.body.style.mozBorder = 'none';\n            document.body.style.msBorder = 'none';\n            document.body.style.oBorder = 'none';\n            document.body.style.webBorder = 'none';\n            document.getElementById('reset-button').style.display = 'none';\n            document.getElementById('maximize-button').style.display = 'none';\n            document.getElementById('minimize-button').style.display = 'none';\n            document.getElementById('close-button').style.display = 'none';\n            document.getElementById('search-input').style.display = 'none';\n            document.getElementById('clear-button').style.display = 'none';\n            document.getElementById('save-button').style.display = 'none';\n            document.getElementById('load-button').style.display = 'none';\n            document.getElementById('button-container').style.display = 'none';\n        });\n\n        document.getElementById('maximize-button').a