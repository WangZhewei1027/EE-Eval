    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Two Pointers Interactive Explorer</title>\n<style>\n  /* Minimal styling: only VERY basic spacing */\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea, input[type=number], input[type=text] {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    width: 100%;\n    box-sizing: border-box;\n  }\n  table {\n    border-collapse: collapse;\n    margin-top: 0.5em;\n  }\n  td, th {\n    border: 1px solid black;\n    padding: 0.15em 0.5em;\n    text-align: center;\n    min-width: 1.5em;\n  }\n  button {\n    margin-top: 0.3em;\n    margin-right: 0.3em;\n  }\n  fieldset {\n    margin-top: 1em;\n    padding: 0.5em;\n  }\n  legend {\n    font-weight: bold;\n  }\n  label {\n    display: inline-block;\n    margin-right: 0.5em;\n  }\n  input[type=range] {\n    vertical-align: middle;\n    width: 4em;\n  }\n  .inline-block {\n    display: inline-block;\n    vertical-align: middle;\n    margin-right: 0.5em;\n  }\n  #log {\n    width: 100%;\n    height: 10em;\n    margin-top: 1em;\n    font-family: monospace, monospace;\n    font-size: 0.9em;\n    overflow-y: scroll;\n  }\n  #arrayDisplay {\n    margin-top: 0.5em;\n  }\n</style>\n</head>\n<body>\n<h1>Two Pointers Concept Interactive Explorer</h1>\n\n<p>\n  This tool explores the <b>Two Pointers</b> concept through array input and multiple usage patterns.\n  You can input an array, select algorithms demonstrating two pointers, and step through the logic while controlling pointer speed, direction, and parameters.\n</p>\n\n<!-- Input array section -->\n\n<fieldset>\n<legend>Input Array</legend>\n<label for=\"arrayInput\">Enter array elements separated by commas:</label><br />\n<textarea id=\"arrayInput\" rows=\"3\" aria-label=\"Input array elements separated by commas\">1,2,3,4,5,6,7,8,9</textarea><br />\n<button id=\"loadArrayBtn\">Load Array</button>\n<span id=\"arrayLoadMsg\" role=\"status\" aria-live=\"polite\"></span>\n</fieldset>\n\n<!-- Array displays -->\n\n<fieldset>\n<legend>Array Visualization</legend>\n<div id=\"arrayDisplay\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n</fieldset>\n\n<!-- Algorithm selector -->\n\n<fieldset>\n<legend>Select Two Pointers Algorithm</legend>\n<label for=\"algorithmSelect\">Choose algorithm pattern:</label>\n<select id=\"algorithmSelect\" aria-describedby=\"algoDesc\" style=\"min-width: 320px;\">\n  <option value=\"\">-- Select --</option>\n  <option value=\"reverseArray\">Reverse Array In-Place</option>\n  <option value=\"removeElement\">Remove Element (In-place)</option>\n  <option value=\"sortSquares\">Squares of Sorted Array (Overview)</option>\n  <option value=\"removeDuplicates\">Remove Duplicates from Sorted Array</option>\n  <option value=\"sumPairs\">Find Pairs with Target Sum</option>\n  <option value=\"maxArea\">Container With Most Water</option>\n  <option value=\"trapRainWater\">Trapping Rain Water</option>\n  <option value=\"partitionArray\">Partition Array by Pivot</option>\n</select>\n<p id=\"algoDesc\" style=\"max-width:50em; font-style: italic;\"></p>\n</fieldset>\n\n<!-- Algorithm controls and info -->\n\n<div id=\"algoControls\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<!-- Step control -->\n\n<fieldset>\n<legend>Step Controls</legend>\n<button id=\"stepBackBtn\" disabled>Step Back</button>\n<button id=\"stepForwardBtn\" disabled>Step Forward</button>\n<button id=\"autoRunBtn\" disabled>Auto Run</button>\n<button id=\"pauseRunBtn\" disabled>Pause</button>\n<button id=\"resetRunBtn\" disabled>Reset</button>\n<label class=\"inline-block\" for=\"autoRunSpeed\" style=\"vertical-align: baseline;\">Speed (ms per step):</label>\n<input type=\"range\" id=\"autoRunSpeed\" min=\"100\" max=\"2000\" step=\"50\" value=\"500\" />\n<span id=\"speedDisplay\">500</span>\n</fieldset>\n\n<!-- Log -->\n\n<fieldset>\n<legend>Execution Log</legend>\n<textarea id=\"log\" readonly aria-label=\"Execution log of steps\"></textarea>\n</fieldset>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // Utility functions for element creation, parsing, array comparison etc.\n  function parseArrayInput(text) {\n    // Parse comma separated numbers, ignoring empty, trimming spaces\n    const arr = text.split(',').map(s => s.trim()).filter(s => s.length > 0).map(s => {\n      if (/^-?\\d+(\\.\\d+)?$/.test(s)) {\n        // parse as number\n        return Number(s);\n      } else {\n        return NaN;\n      }\n    });\n    if(arr.some(isNaN)) return null;\n    return arr;\n  }\n\n  function renderArray(arr, pointers={}) {\n    // pointers: object mapping pointerName->index or array of indices to highlight\n    // Highlight pointers by enclosing in []\n    if(!Array.isArray(arr)) return '';\n    // Build HTML table showing elements in a row\n    // For minimal layout, just space separated text with pointer indicators above and below:\n    // We'll do a table row with three rows:\n    // 1) pointer names (spaces if no pointer)\n    // 2) elements\n    // 3) pointer indices (optional)\n    // to visualize pointers overlapping multiple (e.g. left and right at same idx)\n    const pointerNames = Object.keys(pointers);\n    // For each index, list pointers at this position\n    const pointerMap = {};\n    for(const p of pointerNames) {\n      const pos = pointers[p];\n      if (typeof pos === \"number\") {\n        pointerMap[pos] = pointerMap[pos] || [];\n        pointerMap[pos].push(p);\n      } else if (Array.isArray(pos)) {\n        for(const idx of pos) {\n          pointerMap[idx] = pointerMap[idx] || [];\n          pointerMap[idx].push(p);\n        }\n      }\n    }\n    // Build rows\n    // Row1: pointers (join pointer names or blank)\n    const rowPointerNames = arr.map((_,i) => (pointerMap[i]||[]).join(\",\") || \"\");\n    // Row2: elements\n    const rowElements = arr.map(e => e.toString());\n    // Row3: indices\n    const rowIndices = arr.map((_,i) => i.toString());\n\n    // Create HTML table\n    let html = '<table aria-label=\"Array visualization\"><thead><tr>';\n    for(let i=0;i<arr.length;i++) {\n      const pn = rowPointerNames[i];\n      html += '<th>';\n      if (pn) {\n        const escaped = pn.replace(/&/g,\"&amp;\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\");\n        html += escaped;\n      } else {\n        html += \"&nbsp;\";\n      }\n      html += '</th>';\n    }\n    html += '</tr></thead><tbody>';\n    html += '<tr>';\n    for(let i=0;i<arr.length;i++) {\n      html += '<td>' + rowElements[i] + '</td>';\n    }\n    html += '</tr><tr>';\n    for(let i=0;i<arr.length;i++) {\n      html += '<td>' + rowIndices[i] + '</td>';\n    }\n    html += '</tr></tbody></table>';\n    return html;\n  }\n\n  function logAppend(text) {\n    const logEl = document.getElementById('log');\n    logEl.value += text + \"\\n\";\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  // Two pointers algorithm states and steps for different patterns —\n\n  // Each algorithm object should have:\n  // - name (string)\n  // - description (string)\n  // - init(state, inputArray) => state object\n  // - step(state) => new state or null (if done)\n  // - back(state) => previous state or null (if no back)\n  // - render(state) => html or text description\n  // - getPointers(state) => pointers object for visualization\n  // - controls(state, updateStateFn) => html controls for interactive params for this algo step\n  // - isDone(state) => boolean\n\n  // To handle step backward, we can keep an array of states and move an index\n\n  // ==================\n  // Algorithm: Reverse Array In-Place\n  // ==================\n\n  // Idea: use two pointers left and right to swap elements until they meet/cross\n\n  const ReverseArray = {\n    name: \"Reverse Array In-Place\",\n    description: \"Use two pointers (left and right) moving towards center to reverse the array elements in-place by swapping.\",\n    init: function(inputArray) {\n      let arr = inputArray.slice();\n      return {\n        arr,\n        left: 0,\n        right: arr.length - 1,\n        done: arr.length <= 1 ? true : false,\n        lastAction: 'Initial state'\n      };\n    },\n    step: function(state) {\n      // If done, return null:\n      if(state.done) return null;\n      // Swap arr[left], arr[right]\n      let arr = state.arr.slice();\n      let l = state.left, r = state.right;\n      [arr[l], arr[r]] = [arr[r], arr[l]];\n      l++; r--;\n      let done = l >= r;\n      return {\n        arr,\n        left: l,\n        right: r,\n        done,\n        lastAction: `Swapped elements at indices ${state.left} and ${state.right}`\n      };\n    },\n    back: function(prevStates, currIdx) {\n      // For reverse, we can revert to previous state from history (handled by main)\n      if(currIdx > 0) return prevStates[currIdx-1];\n      return null;\n    },\n    render: function(state) {\n      const swapMsg = state.lastAction || \"\";\n      return `<p>Left pointer at index ${state.left}${state.left<state.arr.length ? ' (value '+state.arr[state.left]+')' : ''}.<br>` +\n             `Right pointer at index ${state.right}${state.right>=0 ? ' (value '+state.arr[state.right]+')' : ''}.<br>` +\n             swapMsg +\n             `</p>`;\n    },\n    getPointers: function(state) {\n      if(state.done) return {};\n      return { left: state.left, right: state.right };\n    },\n    controls: function(state, updateState) {\n      // For this algorithm no parameter controls.\n      return `<p>No additional parameters for this algorithm.</p>`;\n    },\n    isDone: function(state) {return state.done;}\n  };\n\n  // ==================\n  // Algorithm: Remove Element (In-Place)\n  // ==================\n  // Given an array and a val, remove all instances of val in-place and return new length.\n  // Pointer i = next write position\n  // Pointer j scans through array\n\n  const RemoveElement = {\n    name: \"Remove Element (In-place)\",\n    description: \"Remove all instances of a value in the array by using two pointers: one to scan, one to overwrite. Returns new length of valid elements.\",\n    init: function(inputArray) {\n      // default val to remove is 0\n      let arr = inputArray.slice();\n      return {\n        arr,\n        i: 0,\n        j: 0,\n        val: 0,\n        done: false,\n        lastAction: 'Initial state'\n      }\n    },\n    step: function(state) {\n      if(state.done) return null;\n\n      let arr = state.arr.slice();\n      let i = state.i;\n      let j = state.j;\n      let val = state.val;\n\n      if(j >= arr.length) {\n        return {...state, done:true, lastAction:`Completed scan. New length is ${i}`};\n      }\n\n      let lastAction=\"\";\n      if(arr[j] !== val) {\n        arr[i] = arr[j];\n        lastAction = `arr[${j}] (${arr[j]}) != val (${val}), moved to arr[${i}]`;\n        i++;\n      } else {\n        lastAction = `arr[${j}] (${arr[j]}) == val (${val}), skipped`;\n      }\n      j++;\n\n      return {\n        arr,\n        i,\n        j,\n        val,\n        done: j >= arr.length,\n        lastAction\n      };\n    },\n    back: function(prevStates, currIdx) {\n      if(currIdx > 0) return prevStates[currIdx-1];\n      return null;\n    },\n    render: function(state) {\n      return `<p>Scan pointer j at index ${state.j}${state.j<state.arr.length ? ' (value '+state.arr[state.j]+')' : ''}.<br>` +\n             `Write pointer i at index ${state.i}<br>` +\n             `Removing value: ${state.val}.<br>` +\n             state.lastAction +\n             (state.done ? `<br>Done. New length = ${state.i}` : '') +\n             `</p>`;\n    },\n    getPointers: function(state) {\n      // Two pointers: i, j\n      return { i: state.i, j: state.j >= state.arr.length ? null : state.j };\n    },\n    controls: function(state, updateState) {\n      // Provide input field to update val to remove (only integer)\n      return `<label for=\"valToRemove\">Value to remove:</label> `+\n             `<input type=\"number\" id=\"valToRemove\" value=\"${state.val}\" aria-label=\"Value to remove from array\" />`+\n             `<button id=\"valRemoveSetBtn\">Set Value</button>`;\n    },\n    isDone: function(state) {\n      return state.done;\n    }\n  };\n\n  // ==================\n  // Algorithm: Squares of Sorted Array (Overview)\n  // ==================\n  // Given sorted array (non-decreasing), output squares sorted\n  // Use two pointers left and right from both ends\n\n  const SquaresSorted = {\n    name: \"Squares of Sorted Array\",\n    description: \"Given a sorted array, use two pointers from ends to place squares into result array from end to start.\",\n    init: function(inputArray) {\n      let arr = inputArray.slice();\n      let n = arr.length;\n      let res = new Array(n);\n      return {\n        arr,\n        res,\n        left: 0,\n        right: n-1,\n        pos: n-1,\n        done: n === 0,\n        lastAction: 'Initial state'\n      };\n    },\n    step: function(state) {\n      if(state.done) return null;\n      let {arr,res,left,right,pos} = state;\n      let leftVal = arr[left];\n      let rightVal = arr[right];\n      let leftSq = leftVal*leftVal;\n      let rightSq = rightVal*rightVal;\n      let lastAction = \"\";\n      if(leftSq > rightSq) {\n        res[pos] = leftSq;\n        lastAction = `Placed ${leftSq} from arr[${left}]^2 at res[${pos}]`;\n        left++;\n      } else {\n        res[pos] = rightSq;\n        lastAction = `Placed ${rightSq} from arr[${right}]^2 at res[${pos}]`;\n        right--;\n      }\n      pos--;\n      let done = pos < 0;\n      return {\n        arr,\n        res,\n        left,\n        right,\n        pos,\n        done,\n        lastAction\n      };\n    },\n    back: function(prevStates, currIdx) {\n      if(currIdx > 0) return prevStates[currIdx-1];\n      return null;\n    },\n    render: function(state) {\n      return `<p>Left pointer at index ${state.left}${state.left < state.arr.length ? ' (value '+state.arr[state.left]+')' : ''}.<br>`+\n        `Right pointer at index ${state.right}${state.right >= 0 ? ' (value '+state.arr[state.right]+')' : ''}.<br>`+\n        `Result array position: ${state.pos+1}<br>`+\n        state.lastAction+\n        (state.done ? `<br>Done. Result: [${state.res.join(\", \")}]` : '')+\n        `</p>`;\n    },\n    getPointers: function(state) {\n      return { left: state.left, right: state.right };\n    },\n    controls: function(state, updateState) {\n      return `<p>No parameters for this algorithm.</p>`;\n    },\n    isDone: function(state) {return state.done;}\n  };\n\n  // ==================\n  // Algorithm: Remove Duplicates from Sorted Array\n  // ==================\n  // Remove duplicates in-place from sorted array, return new length\n  // Pointer i tracks position to write next unique, j scans array\n\n  const RemoveDuplicatesSorted = {\n    name: \"Remove Duplicates from Sorted Array\",\n    description: \"Given a sorted array, remove duplicates in-place. Use two pointers: i for last unique index, j to scan.\",\n    init: function(inputArray) {\n      let arr = inputArray.slice();\n      return {\n        arr,\n        i: 0,\n        j: 1,\n        done: arr.length <= 1,\n        lastAction: 'Initial state'\n      };\n    },\n    step: function(state) {\n      if(state.done) return null;\n\n      let arr = state.arr.slice();\n      let i = state.i;\n      let j = state.j;\n\n      if(j >= arr.length) {\n        return {...state, done:true, lastAction:`Done. New length: ${i+1}`};\n      }\n\n      let lastAction=\"\";\n      if(arr[j] !== arr[i]) {\n        i++;\n        arr[i] = arr[j];\n        lastAction = `arr[${j}] (${arr[j]}) != arr[${i-1}] (${arr[i-1]}), moved to arr[${i}]`;\n      } else {\n        lastAction = `arr[${j}] (${arr[j]}) == arr[${i}] (${arr[i]}), skipped`;\n      }\n      j++;\n\n      return {\n        arr,\n        i,\n        j,\n        done: j >= arr.length,\n        lastAction\n      };\n    },\n    back: function(prevStates, currIdx) {\n      if(currIdx > 0) return prevStates[currIdx-1];\n      return null;\n    },\n    render: function(state) {\n      return `<p>Last unique pointer i at index ${state.i}${state.i < state.arr.length ? ' (value '+state.arr[state.i]+')' : ''}.<br>` +\n             `Scan pointer j at index ${state.j}${state.j<state.arr.length ? ' (value '+state.arr[state.j]+')' : ''}.<br>` +\n             state.lastAction +\n             (state.done ? `<br>Done. New length = ${state.i + 1}` : '') +\n             `</p>`;\n    },\n    getPointers: function(state) {\n      return {\n        i: state.i,\n        j: state.j >= state.arr.length ? null : state.j\n      };\n    },\n    controls: function(state, updateState) {\n      return `<p>No parameters for this algorithm.</p>`;\n    },\n    isDone: function(state) {return state.done;}\n  };\n\n  // ==================\n  // Algorithm: Find Pairs with Target Sum in Sorted Array\n  // ==================\n  // Given a sorted array and a target sum, find all pairs that sum to target using two pointers\n\n  const FindPairsTargetSum = {\n    name: \"Find Pairs with Target Sum\",\n    description: \"Given a sorted array and target, use two pointers to find all pairs whose sum equals the target.\",\n    init: function(inputArray) {\n      let arr = inputArray.slice();\n      return {\n        arr,\n        left: 0,\n        right: arr.length - 1,\n        target: 0,\n        results: [],\n        done: arr.length < 2,\n        lastAction: 'Initial state'\n      };\n    },\n    step: function(state) {\n      if(state.done) return null;\n\n      let {arr, left, right, target, results} = state;\n\n      if(left >= right) {\n        return {...state, done:true, lastAction:`Finished. Found ${results.length} pairs.`}\n      }\n\n      let sum = arr[left] + arr[right];\n      let lastAction = \"\";\n      let newResults = results.slice();\n\n      if(sum === target) {\n        newResults.push([arr[left], arr[right]]);\n        lastAction = `Found pair (${arr[left]}, ${arr[right]}) with sum ${target}. Moving both pointers.`;\n        left++;\n        right--;\n      } else if(sum < target) {\n        lastAction = `Sum ${sum} < target ${target}. Moving left pointer.`;\n        left++;\n      } else {\n        lastAction = `Sum ${sum} > target ${target}. Moving right pointer.`;\n        right--;\n      }\n\n      let done = left >= right;\n\n      return {\n        arr,\n        left,\n        right,\n        target,\n        results: newResults,\n        done,\n        lastAction\n      };\n    },\n    back: function(prevStates, currIdx) {\n      if(currIdx > 0) return prevStates[currIdx-1];\n      return null;\n    },\n    render: function(state) {\n      return `<p>Left pointer at index ${state.left}${state.left < state.arr.length ? ' (value '+state.arr[state.left]+')' : ''}.<br>` +\n             `Right pointer at index ${state.right}${state.right >= 0 ? ' (value '+state.arr[state.right]+')' : ''}.<br>` +\n             `Target sum: ${state.target}.<br>`+\n             state.lastAction +\n             (state.done ? `<br>Done. Pairs found (${state.results.length}): [${state.results.map(p => '('+p[0]+','+p[1]+')').join(\", \")}]` : '') +\n             `</p>`;\n    },\n    getPointers: function(state) {\n      if(state.done) return {};\n      return { left: state.left, right: state.right };\n    },\n    controls: function(state, updateState) {\n      return `<label for=\"targetSum\">Target Sum:</label>`+\n             `<input type=\"number\" id=\"targetSum\" value=\"${state.target}\" aria-label=\"Target sum for pairs\" />`+\n             `<button id=\"targetSumSetBtn\">Set Target</button>`;\n    },\n    isDone: function(state) {\n      return state.done;\n    }\n  };\n\n  // ==================\n  // Algorithm: Container With Most Water\n  // ==================\n  // Given array of heights, find max area between two vertical lines using two pointers\n\n  const ContainerMostWater = {\n    name: \"Container with Most Water\",\n    description: \"Given heights, use two pointers at ends and move inward, calculating area, tracking max.\",\n    init: function(inputArray) {\n      let arr = inputArray.slice();\n      return {\n        arr,\n        left: 0,\n        right: arr.length - 1,\n        maxArea: 0,\n        maxLeft: null,\n        maxRight: null,\n        done: arr.length < 2,\n        lastAction: 'Initial state'\n      }\n    },\n    step: function(state) {\n      if(state.done) return null;\n      let {arr, left, right, maxArea, maxLeft, maxRight} = state;\n      if(left >= right){\n        return {...state, done:true, lastAction:`Done. Max area is ${maxArea} between ${maxLeft} and ${maxRight}`};\n      }\n      let heightL = arr[left];\n      let heightR = arr[right];\n      let width = right - left;\n      let area = Math.min(heightL, heightR) * width;\n      let newMaxArea = maxArea;\n      let newMaxLeft = maxLeft;\n      let newMaxRight = maxRight;\n      if(area > maxArea){\n        newMaxArea = area;\n        newMaxLeft = left;\n        newMaxRight = right;\n      }\n\n      let lastAction=\"\";\n      // Move the pointer at lower height inward\n      if(heightL < heightR){\n        lastAction = `Calculated area ${area} with left=${left} (${heightL}), right=${right} (${heightR}). Moving left pointer right.`;\n        left++;\n      } else {\n        lastAction = `Calculated area ${area} with left=${left} (${heightL}), right=${right} (${heightR}). Moving right pointer left.`;\n        right--;\n      }\n\n      let done = left >= right;\n\n      return {\n        arr,\n        left,\n        right,\n        maxArea: newMaxArea,\n        maxLeft: newMaxLeft,\n        maxRight: newMaxRight,\n        done,\n        lastAction\n      };\n    },\n    back: function(prevStates, currIdx) {\n      if(currIdx > 0) return prevStates[currIdx-1];\n      return null;\n    },\n    render: function(state) {\n      let finishedPart = state.done ? `<br>Max area found: ${state.maxArea} between indices ${state.maxLeft} and ${state.maxRight}.` : \"\";\n      return `<p>Left pointer at index ${state.left}${state.left < state.arr.length ? \" (height \"+state.arr[state.left]+\")\" : \"\"}.<br>`+\n             `Right pointer at index ${state.right}${state.right >= 0 ? \" (height \"+state.arr[state.right]+\")\" : \"\"}.`+\n             finishedPart + \"<br>\" +\n             state.lastAction +\n             `</p>`;\n    },\n    getPointers: function(state) {\n      if(state.done) return {};\n      return { left: state.left, right: state.right };\n    },\n    controls: function(state, updateState) {\n      return `<p>No parameters for this algorithm.</p>`;\n    },\n    isDone: function(state) {return state.done;}\n  };\n\n  // ==================\n  // Algorithm: Trapping Rain Water (two pointers solution overview)\n  // ==================\n  // Use left and right pointers, track maxLeft and maxRight height, add trapped water\n\n  const TrapRainWater = {\n    name: \"Trapping Rain Water\",\n    description: \"Calculate how much water can be trapped after raining. Use two pointers and track max heights from both ends.\",\n    init: function(inputArray) {\n      let arr = inputArray.slice();\n      return {\n        arr,\n        left: 0,\n        right: arr.length - 1,\n        maxLeft: 0,\n        maxRight: 0,\n        water: 0,\n        done: arr.length < 3,\n        lastAction: \"Initial state\"\n      };\n    },\n    step: function(state) {\n      if(state.done) return null;\n      let {arr,left,right,maxLeft,maxRight,water} = state;\n      if(left >= right){\n        return {...state, done:true, lastAction:`Done. Total trapped water: ${water}`};\n      }\n      let leftHeight = arr[left];\n      let rightHeight = arr[right];\n      let lastAction = \"\";\n\n      if(leftHeight < rightHeight){\n        if(leftHeight >= maxLeft){\n          lastAction = `Updated maxLeft from ${maxLeft} to ${leftHeight}`;\n          maxLeft = leftHeight;\n        } else {\n          let trapped = maxLeft - leftHeight;\n          water += trapped;\n          lastAction = `Trapped ${trapped} water at index ${left}`;\n        }\n        left++;\n      } else {\n        if(rightHeight >= maxRight){\n          lastAction = `Updated maxRight from ${maxRight} to ${rightHeight}`;\n          maxRight = rightHeight;\n        } else {\n          let trapped = maxRight - rightHeight;\n          water += trapped;\n          lastAction = `Trapped ${trapped} water at index ${right}`;\n        }\n        right--;\n      }\n\n      let done = left >= right;\n\n      return {\n        arr,\n        left,\n        right,\n        maxLeft,\n        maxRight,\n        water,\n        done,\n        lastAction\n      };\n    },\n    back: function(prevStates, currIdx) {\n      if(currIdx > 0) return prevStates[currIdx-1];\n      return null;\n    },\n    render: function(state) {\n      let finishedPart = state.done ? `<br>Total trapped water: ${state.water}.` : \"\";\n      return `<p>Left pointer at index ${state.left}${state.left < state.arr.length ? \" (height \"+state.arr[state.left]+\")\" : \"\"}.<br>`+\n             `Right pointer at index ${state.right}${state.right >= 0 ? \" (height \"+state.arr[state.right]+\")\" : \"\"}.<br>`+\n             `maxLeft: ${state.maxLeft}, maxRight: ${state.maxRight}, Water trapped: ${state.water}`+\n             finishedPart + \"<br>\" +\n             state.lastAction +\n             `</p>`;\n    },\n    getPointers: function(state) {\n      if(state.done) return {};\n      return { left: state.left, right: state.right };\n    },\n    controls: function(state, updateState) {\n      return `<p>No parameters for this algorithm.</p>`;\n    },\n    isDone: function(state) {return state.done;}\n  };\n\n  // ==================\n  // Algorithm: Partition Array by Pivot\n  // ==================\n  // Two pointers partition array so elements < pivot move left, others right (like quicksort partition)\n\n  const PartitionArray = {\n    name: \"Partition Array by Pivot\",\n    description: \"Partition array so that all elements less than pivot come before elements greater or equal. Two pointers swap elements in-place.\",\n    init: function(inputArray) {\n      let arr = inputArray.slice();\n      // default pivot = 0 or median of array or input length for control\n      let pivot = arr.length > 0 ? arr[Math.floor(arr.length/2)] : 0;\n      return {\n        arr,\n        left: 0,\n        right: arr.length -1,\n        pivot,\n        done: arr.length === 0,\n        lastAction: 'Initial state'\n      };\n    },\n    step: function(state) {\n      if(state.done) return null;\n      let {arr, left, right, pivot} = state;\n      if(left > right) return {...state, done:true, lastAction:\"Partition finished\"};\n      let arrc = arr.slice();\n      let lastAction = \"\";\n\n      // While arr[left] < pivot, left++\n      while(left <= right && arrc[left] < pivot) {\n        left++;\n        lastAction = `Moved left pointer to index ${left}`;\n      }\n      // While arr[right] >= pivot, right--\n      while(right >= left && arrc[right] >= pivot) {\n        right--;\n        lastAction = `Moved right pointer to index ${right}`;\n      }\n      if(left < right) {\n        // Swap\n        [arrc[left], arrc[right]] = [arrc[right], arrc[left]];\n        lastAction = `Swapped elements at ${left} and ${right}`;\n        left++;\n        right--;\n      } else {\n        return {...state, arr: arrc, left, right, done:true, lastAction:\"Partition finished\"};\n      }\n      return {...state, arr: arrc, left, right, lastAction};\n    },\n    back: function(prevStates, currIdx) {\n      if(currIdx > 0) return prevStates[currIdx-1];\n      return null;\n    },\n    render: function(state) {\n      let doneMsg = state.done ? \"<br>Partition finished.\" : \"\";\n      return `<p>Pivot value: ${state.pivot}.<br>` +\n             `Left pointer at index ${state.left}${state.left < state.arr.length ? ' (value '+state.arr[state.left]+')' : ''}.<br>` +\n             `Right pointer at index ${state.right}${state.right >= 0 ? ' (value '+state.arr[state.right]+')' : ''}.<br>` +\n             state.lastAction + doneMsg +\n             `</p>`;\n    },\n    getPointers: function(state) {\n      if(state.done) return {};\n      return { left: state.left, right: state.right };\n    },\n    controls: function(state, updateState) {\n      return `<label for=\"pivotVal\">Pivot value:</label>`+\n             `<input type=\"number\" id=\"pivotVal\" value=\"${state.pivot}\" aria-label=\"Pivot value for partition\" />`+\n             `<button id=\"pivotSetBtn\">Set Pivot</button>`;\n    },\n    isDone: function(state) {return state.done;}\n  };\n\n  // ==================\n  // Main management and UI binding\n  // ==================\n\n  const algorithms = {\n    reverseArray: ReverseArray,\n    removeElement: RemoveElement,\n    sortSquares: SquaresSorted,\n    removeDuplicates: RemoveDuplicatesSorted,\n    sumPairs: FindPairsTargetSum,\n    maxArea: ContainerMostWater,\n    trapRainWater: TrapRainWater,\n    partitionArray: PartitionArray\n  };\n\n  let currentArray = [];\n  let currentAlgorithm = null;\n  let statesHistory = [];\n  let currentStateIndex = -1;\n  let autoRunInterval = null;\n\n  // DOM references\n  const arrayInput = document.getElementById('arrayInput');\n  const loadArrayBtn = document.getElementById('loadArrayBtn');\n  const arrayLoadMsg = document.getElementById('arrayLoadMsg');\n  const arrayDisplay = document.getElementById('arrayDisplay');\n  const algorithmSelect = document.getElementById('algorithmSelect');\n  const algoDesc = document.getElementById('algoDesc');\n  const algoControlsContainer = document.getElementById('algoControls');\n  const stepBackBtn = document.getElementById('stepBackBtn');\n  const stepForwardBtn = document.getElementById('stepForwardBtn');\n  const autoRunBtn = document.getElementById('autoRunBtn');\n  const pauseRunBtn = document.getElementById('pauseRunBtn');\n  const resetRunBtn = document.getElementById('resetRunBtn');\n  const autoRunSpeed = document.getElementById('autoRunSpeed');\n  const speedDisplay = document.getElementById('speedDisplay');\n  const logEl = document.getElementById('log');\n\n  function updateSpeedDisplay(){\n    speedDisplay.textContent = autoRunSpeed.value;\n  }\n\n  autoRunSpeed.addEventListener('input', () => {\n    updateSpeedDisplay();\n    if(autoRunInterval !== null){\n      clearInterval(autoRunInterval);\n      autoRunInterval = setInterval(autoStepForward, Number(autoRunSpeed.value));\n    }\n  });\n  updateSpeedDisplay();\n\n  function clearExecLog() {\n    logEl.value = \"\";\n  }\n\n  function displayArray() {\n    arrayDisplay.innerHTML = renderArray(currentArray);\n  }\n\n  function displayState() {\n    if(currentStateIndex < 0 || currentStateIndex >= statesHistory.length) return;\n    let state = statesHistory[currentStateIndex];\n    if(!currentAlgorithm) return;\n\n    // Show array + pointers\n    const pointers = currentAlgorithm.getPointers(state) || {};\n    const arrToShow = (state.arr !== undefined) ? state.arr : currentArray;\n    arrayDisplay.innerHTML = renderArray(arrToShow, pointers);\n\n    // Show textual info from algorithm's render()\n    const html = currentAlgorithm.render(state);\n    algoControlsContainer.innerHTML = html + \"<hr>\" + currentAlgorithm.controls(state, updateStateFromControls);\n\n    // Bind controls events if present\n    bindAlgorithmParameterControls();\n\n    // Update step buttons\n    updateStepButtons();\n\n    // Log the current step (once, only if new step)\n    if(!logEl.value.includes(state.lastAction)){\n      logAppend(`Step ${currentStateIndex+1}: ${state.lastAction}`);\n    }\n  }\n\n  function updateStepButtons() {\n    // back enabled if currentStateIndex > 0\n    stepBackBtn.disabled = (currentStateIndex <= 0);\n    // forward enabled if can step forward\n    stepForwardBtn.disabled = (currentAlgorithm == null) || (currentStateIndex >= statesHistory.length-1) || currentAlgorithm.isDone(statesHistory[currentStateIndex]);\n    autoRunBtn.disabled = stepForwardBtn.disabled;\n    pauseRunBtn.disabled = true;\n    resetRunBtn.disabled = (statesHistory.length === 0);\n  }\n\n  function updateStateFromControls() {\n    // For each algorithm, read controls and apply changes to current state, reinit statesHistory from current, reset history after current index\n    if(!currentAlgorithm || currentStateIndex < 0) return;\n\n    const state = {...statesHistory[currentStateIndex]};\n    let changed = false;\n\n    function setStateAndResetHistory(newState){\n      statesHistory = statesHistory.slice(0, currentStateIndex+1);\n      statesHistory[currentStateIndex] = newState;\n      displayState();\n      changed = true;\n    }\n\n    // Algo specific parameter controls:\n    switch(currentAlgorithm) {\n      case RemoveElement:\n        // val to remove from #valToRemove input\n        {\n          let input = document.getElementById('valToRemove');\n          if(input){\n            let valParsed = Number(input.value);\n            if(!isNaN(valParsed) && valParsed !== state.val){\n              let newState = currentAlgorithm.init(state.arr);\n              newState.val = valParsed;\n              statesHistory = [newState];\n              currentStateIndex = 0;\n              changed = true;\n            }\n          }\n        }\n        break;\n      case FindPairsTargetSum:\n        {\n          let input = document.getElementById('targetSum');\n          if(input){\n            let valParsed = Number(input.value);\n            if(!isNaN(valParsed) && valParsed !== state.target){\n              let newState = currentAlgorithm.init(state.arr);\n              newState.target = valParsed;\n              statesHistory = [newState];\n              currentStateIndex = 0;\n              changed = true;\n            }\n          }\n        }\n        break;\n      case PartitionArray:\n        {\n          let input = document.getElementById('pivotVal');\n          if(input){\n            let valParsed = Number(input.value);\n            if(!isNaN(valParsed) && valParsed !== state.pivot){\n              // Reinit with new pivot\n              let newState = {...state};\n              newState.pivot = valParsed;\n              statesHistory = [newState];\n              currentStateIndex = 0;\n              changed = true;\n            }\n          }\n        }\n        break;\n      default:\n        break;\n    }\n\n    if(changed){\n      displayState();\n    }\n  }\n\n  function bindAlgorithmParameterControls() {\n    // Attach events to parameter buttons for each algorithm control dynamically\n    // RemoveElement:\n    const valRemoveBtn = document.getElementById('valRemoveSetBtn');\n    if(valRemoveBtn){\n      valRemoveBtn.onclick = function(e) {\n        e.preventDefault();\n        updateStateFromControls();\n      }\n    }\n    // FindPairsTargetSum:\n    const targetSumBtn = document.getElementById('targetSumSetBtn');\n    if(targetSumBtn){\n      targetSumBtn.onclick = function(e){\n        e.preventDefault();\n        updateStateFromControls();\n      }\n    }\n    // PartitionArray:\n    const pivotSetBtn = document.getElementById('pivotSetBtn');\n    if(pivotSetBtn){\n      pivotSetBtn.onclick = function(e){\n        e.preventDefault();\n        updateStateFromControls();\n      }\n    }\n  }\n\n  // Step functions\n\n  function stepForward(){\n    if(!currentAlgorithm) return;\n    if(currentStateIndex < 0 && statesHistory.length === 0){\n      // Initialize statesHistory with init state\n      let initState = currentAlgorithm.init(currentArray);\n      statesHistory = [initState];\n      currentStateIndex = 0;\n      clearExecLog();\n      logAppend(`Algorithm ${currentAlgorithm.name} started.`);\n      displayState();\n      return;\n    }\n    if(currentStateIndex < statesHistory.length-1){\n      // Forward to next saved state\n      currentStateIndex++;\n      displayState();\n      return;\n    }\n    // Otherwise run step function to get next state\n    let currState = statesHistory[currentStateIndex];\n    if(currentAlgorithm.isDone(currState)) return;\n    let nextState = currentAlgorithm.step(currState);\n    if(nextState){\n      statesHistory.push(nextState);\n      currentStateIndex++;\n      displayState();\n    }\n  }\n  function stepBack(){\n    if(currentStateIndex > 0){\n      currentStateIndex--;\n      displayState();\n    }\n  }\n  function resetRun(){\n    if(!currentAlgorithm) return;\n    statesHistory = [];\n    currentStateIndex = -1;\n    clearExecLog();\n    displayArray();\n    algoControlsContainer.innerHTML = \"\";\n    updateStepButtons();\n  }\n\n  // Auto run functions\n\n  function autoStepForward(){\n    if(!currentAlgorithm) return;\n    if(currentStateIndex >= statesHistory.length-1){\n      let lastState = statesHistory[currentStateIndex];\n      if(lastState && currentAlgorithm.isDone(lastState)){\n        clearInterval(autoRunInterval);\n        autoRunInterval = null;\n        autoRunBtn.disabled = false;\n        pauseRunBtn.disabled = true;\n        resetRunBtn.disabled = false;\n        return;\n      }\n      stepForward();\n    } else {\n      currentStateIndex++;\n      displayState();\n    }\n  }\n\n  function startAutoRun(){\n    if(autoRunInterval !== null) return;\n    autoRunBtn.disabled = true;\n    pauseRunBtn.disabled = false;\n    resetRunBtn.disabled = true;\n    autoRunInterval = setInterval(autoStepForward, Number(autoRunSpeed.value));\n  }\n\n  function pauseAutoRun(){\n    if(autoRunInterval !== null){\n      clearInterval(autoRunInterval);\n      autoRunInterval = null;\n    }\n    autoRunBtn.disabled = false;\n    pauseRunBtn.disabled = true;\n    resetRunBtn.disabled = false;\n  }\n\n  // Event bindings\n\n  loadArrayBtn.addEventListener('click', function(){\n    const parsed = parseArrayInput(arrayInput.value);\n    if(parsed === null){\n      arrayLoadMsg.textContent = \"Invalid input: please enter only numbers separated by commas.\";\n      return;\n    }\n    currentArray = parsed;\n    arrayLoadMsg.textContent = `Array loaded with ${currentArray.length} elements.`;\n    displayArray();\n\n    // Reset algorithm selection and state\n    algorithmSelect.value = \"\";\n    currentAlgorithm = null;\n    statesHistory = [];\n    currentStateIndex = -1;\n    algoDesc.textContent = \"\";\n    algoControlsContainer.innerHTML = \"\";\n    clearExecLog();\n    updateStepButtons();\n  });\n\n  algorithmSelect.addEventListener('change', function(){\n    const val = algorithmSelect.value;\n    if(!val || !algorithms[val]){\n      currentAlgorithm = null;\n      algoDesc.textContent = \"\";\n      statesHistory = [];\n      currentStateIndex = -1;\n      algoControlsContainer.innerHTML = \"\";\n      clearExecLog();\n      displayArray();\n      updateStepButtons();\n      return;\n    }\n    currentAlgorithm = algorithms[val];\n    algoDesc.textContent = currentAlgorithm.description;\n\n    // Init history from current array\n    let initState = currentAlgorithm.init(currentArray);\n    statesHistory = [initState];\n    currentStateIndex = 0;\n    clearExecLog();\n    logAppend(`Algorithm ${currentAlgorithm.name} initialized.`);\n    displayState();\n  });\n\n  stepForwardBtn.addEventListener('click', function(){\n    stepForward();\n  });\n  stepBackBtn.addEventListener('click', function(){\n    stepBack();\n  });\n  resetRunBtn.addEventListener('click', function(){\n    resetRun();\n  });\n  autoRunBtn.addEventListener('click', function(){\n    startAutoRun();\n  });\n  pauseRunBtn.addEventListener('click', function(){\n    pauseAutoRun();\n  });\n\n  // Load initial array on page load\n  window.addEventListener('load', () => {\n    const parsed = parseArrayInput(arrayInput.value);\n    if(parsed !== null) {\n      currentArray = parsed;\n      displayArray();\n    }\n    updateStepButtons();\n  });\n\n})();\n</script>\n</body>\n</html>"
