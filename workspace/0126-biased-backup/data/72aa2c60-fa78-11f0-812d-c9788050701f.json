    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interpolation Search | Visual Elegance</title>\n    <style>\n        :root {\n            --primary: #6a11cb;\n            --secondary: #2575fc;\n            --accent: #ff4e50;\n            --light: #f8f9fa;\n            --dark: #212529;\n            --success: #28a745;\n            --info: #17a2b8;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: var(--light);\n            min-height: 100vh;\n            padding: 2rem;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            background-color: rgba(255, 255, 255, 0.1);\n            backdrop-filter: blur(10px);\n            border-radius: 20px;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);\n            animation: fadeIn 1s ease-out;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            margin-bottom: 1rem;\n            text-align: center;\n            background: linear-gradient(to right, var(--light), #ffffff);\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            text-align: center;\n            margin-bottom: 2rem;\n            opacity: 0.8;\n            font-weight: 300;\n        }\n\n        .search-container {\n            display: flex;\n            justify-content: center;\n            margin: 3rem 0;\n            gap: 1rem;\n        }\n\n        input, button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            font-size: 1rem;\n            transition: all 0.3s ease;\n        }\n\n        input {\n            width: 300px;\n            background-color: rgba(255, 255, 255, 0.2);\n            color: white;\n            outline: none;\n        }\n\n        input::placeholder {\n            color: rgba(255, 255, 255, 0.5);\n        }\n\n        button {\n            background-color: var(--accent);\n            color: white;\n            cursor: pointer;\n            font-weight: 500;\n            box-shadow: 0 5px 15px rgba(255, 78, 80, 0.3);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(255, 78, 80, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .array-container {\n            margin: 3rem auto;\n            display: flex;\n            justify-content: center;\n            flex-wrap: wrap;\n            gap: 0.5rem;\n            max-width: 800px;\n        }\n\n        .array-element {\n            width: 60px;\n            height: 60px;\n            background: linear-gradient(145deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.05));\n            border-radius: 10px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.2rem;\n            font-weight: 600;\n            transition: all 0.5s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .array-element::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);\n            transition: 0.5s;\n        }\n\n        .array-element:hover::before {\n            left: 100%;\n        }\n\n        .array-element.active {\n            transform: scale(1.1);\n            background: linear-gradient(145deg, var(--success), #5cb85c);\n            box-shadow: 0 0 20px rgba(40, 167, 69, 0.5);\n            z-index: 10;\n        }\n\n        .array-element.checked {\n            background: linear-gradient(145deg, var(--info), #17a2b8);\n        }\n\n        .array-element.probe {\n            background: linear-gradient(145deg, var(--accent), #ff6b6b);\n            animation: pulse 1.5s infinite;\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 78, 80, 0.7); }\n            70% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(255, 78, 80, 0); }\n            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 78, 80, 0); }\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin: 2rem 0;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .explanation {\n            max-width: 800px;\n            margin: 3rem auto;\n            padding: 2rem;\n            background-color: rgba(0, 0, 0, 0.2);\n            border-radius: 15px;\n            line-height: 1.6;\n        }\n\n        .explanation h2 {\n            margin-bottom: 1rem;\n            font-weight: 400;\n            color: white;\n        }\n\n        .explanation p {\n            margin-bottom: 1rem;\n            opacity: 0.9;\n        }\n\n        .formula {\n            font-family: 'Courier New', Courier, monospace;\n            background-color: rgba(0, 0, 0, 0.3);\n            padding: 1rem;\n            border-radius: 8px;\n            margin: 1rem 0;\n            display: inline-block;\n        }\n\n        .status {\n            text-align: center;\n            margin: 1rem 0;\n            font-size: 1.2rem;\n            min-height: 2rem;\n            opacity: 0;\n            transition: opacity 0.5s ease;\n        }\n\n        .status.show {\n            opacity: 1;\n        }\n\n        .particles {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n            pointer-events: none;\n        }\n\n        .particle {\n            position: absolute;\n            background-color: rgba(255, 255, 255, 0.3);\n            border-radius: 50%;\n            animation: float linear infinite;\n        }\n\n        @keyframes float {\n            0% { transform: translateY(0) rotate(0deg); opacity: 1; }\n            100% { transform: translateY(-100vh) rotate(360deg); opacity: 0; }\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 3rem;\n            opacity: 0.7;\n            font-size: 0.9rem;\n        }\n\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2rem;\n            }\n            .array-element {\n                width: 40px;\n                height: 40px;\n                font-size: 0.9rem;\n            }\n            .search-container {\n                flex-direction: column;\n                align-items: center;\n            }\n            input {\n                width: 100%;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <div class=\"container\">\n        <h1>Interpolation Search</h1>\n        <p class=\"subtitle\">A beautifully visualized search algorithm for uniformly distributed sorted arrays</p>\n        \n        <div class=\"search-container\">\n            <input type=\"number\" id=\"searchValue\" placeholder=\"Enter a number to search...\" min=\"1\" max=\"100\">\n            <button id=\"searchButton\">Search</button>\n        </div>\n        \n        <div class=\"status\" id=\"status\"></div>\n        \n        <div class=\"array-container\" id=\"arrayContainer\"></div>\n        \n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(145deg, var(--success), #5cb85c);\"></div>\n                <span>Target Found</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(145deg, var(--info), #17a2b8);\"></div>\n                <span>Checked Element</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(145deg, var(--accent), #ff6b6b);\"></div>\n                <span>Current Probe</span>\n            </div>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>How Interpolation Search Works</h2>\n            <p>Interpolation search is an algorithm for searching for a key in a sorted array that has been uniformly distributed. It parallels how humans search through a telephone directory: we make a guess where the name might be based on the distribution of names.</p>\n            \n            <p>The algorithm calculates the probable position of the target value using the formula:</p>\n            <div class=\"formula\">\n                pos = low + ((target - arr[low]) * (high - low)) / (arr[high] - arr[low])\n            </div>\n            \n            <p>This approach gives interpolation search a time complexity of O(log log n) for uniformly distributed data, making it faster than binary search in such cases.</p>\n        </div>\n        \n        <footer>\n            Visualized with HTML5, CSS3, and JavaScript | Designed for aesthetic excellence\n        </footer>\n    </div>\n\n    <script>\n        // Create particles\n        function createParticles() {\n            const particles = document.getElementById('particles');\n            const particleCount = 30;\n            \n            for (let i = 0; i < particleCount; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                const size = Math.random() * 10 + 5;\n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                \n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.top = `${Math.random() * 100}%`;\n                \n                const duration = Math.random() * 20 + 10;\n                particle.style.animationDuration = `${duration}s`;\n                particle.style.animationDelay = `${Math.random() * 5}s`;\n                \n                particles.appendChild(particle);\n            }\n        }\n        \n        // Initialize sorted array\n        function initializeArray() {\n            const arrayContainer = document.getElementById('arrayContainer');\n            arrayContainer.innerHTML = '';\n            \n            // Create a sorted array with 15 elements (1-100)\n            const arr = [];\n            for (let i = 0; i < 15; i++) {\n                // Generate numbers with some gaps to show non-uniform distribution\n                arr.push(Math.floor(Math.random() * 50) + i * 5);\n            }\n            \n            // Ensure the array is sorted\n            arr.sort((a, b) => a - b);\n            \n            // Display the array\n            arr.forEach((num, index) => {\n                const element = document.createElement('div');\n                element.classList.add('array-element');\n                element.textContent = num;\n                element.dataset.value = num;\n                element.dataset.index = index;\n                arrayContainer.appendChild(element);\n            });\n            \n            return arr;\n        }\n        \n        // Interpolation search algorithm\n        async function interpolationSearch(arr, target) {\n            const status = document.getElementById('status');\n            const elements = document.querySelectorAll('.array-element');\n            \n            let low = 0;\n            let high = arr.length - 1;\n            let steps = 0;\n            \n            status.textContent = `Starting search for ${target}...`;\n            status.classList.add('show');\n            \n            // Add slight delay for animation\n            await new Promise(resolve => setTimeout(resolve, 1000));\n            \n            while (low <= high && target >= arr[low] && target <= arr[high]) {\n                steps++;\n                \n                // Calculate position using interpolation formula\n                const pos = Math.floor(\n                    low + ((target - arr[low]) * (high - low)) / (arr[high] - arr[low])\n                );\n                \n                // Highlight current probe\n                elements[pos].classList.add('probe');\n                status.textContent = `Probing position ${pos} (value: ${arr[pos]})`;\n                \n                // Add slight delay to visualize\n                await new Promise(resolve => setTimeout(resolve, 1000));\n                \n                // Check if we found the target\n                if (arr[pos] === target) {\n                    elements[pos].classList.remove('probe');\n                    elements[pos].classList.add('active');\n                    status.textContent = `Found ${target} at position ${pos} in ${steps} steps!`;\n                    return pos;\n                }\n                \n                // Mark as checked\n                elements[pos].classList.remove('probe');\n                elements[pos].classList.add('checked');\n                \n                // If target is less than current element, search left\n                if (arr[pos] > target) {\n                    high = pos - 1;\n                    status.textContent = `${target} < ${arr[pos]} → searching left half`;\n                } \n                // Else search right\n                else {\n                    low = pos + 1;\n                    status.textContent = `${target} > ${arr[pos]} → searching right half`;\n                }\n                \n                // Add slight delay\n                await new Promise(resolve => setTimeout(resolve, 1000));\n            }\n            \n            status.textContent = `${target} not found in the array after ${steps} steps`;\n            return -1;\n        }\n        \n        // Reset visualization\n        function resetVisualization() {\n            const elements = document.querySelectorAll('.array-element');\n            elements.forEach(el => {\n                el.classList.remove('active', 'checked', 'probe');\n            });\n            \n            const status = document.getElementById('status');\n            status.classList.remove('show');\n        }\n        \n        // Initialize everything when DOM is loaded\n        document.addEventListener('DOMContentLoaded', () => {\n            createParticles();\n            const arr = initializeArray();\n            \n            document.getElementById('searchButton').addEventListener('click', async () => {\n                const searchValue = parseInt(document.getElementById('searchValue').value);\n                if (!isNaN(searchValue)) {\n                    resetVisualization();\n                    await interpolationSearch(arr, searchValue);\n                }\n            });\n        });\n    </script>\n</body>\n</html>"
