    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Search Tree (BST) Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: #1a1a2e;\n    color: #e0e0e0;\n    font-family: 'Montserrat', sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    height: 100vh;\n    overflow: hidden;\n  }\n\n  h1 {\n    margin: 1.2rem 0 .3rem 0;\n    font-weight: 700;\n    font-size: 2.8rem;\n    letter-spacing: 0.12em;\n    color: #f4d35e;\n    text-shadow:\n      0 0 8px #f4d35e,\n      0 0 20px #f4d35e88;\n  }\n\n  h2 {\n    font-weight: 500;\n    color: #abedd8;\n    letter-spacing: 0.07em;\n    margin: 0 0 1.8rem 0;\n    font-size: 1.2rem;\n  }\n\n  .container {\n    position: relative;\n    width: 100%;\n    max-width: 960px;\n    flex-grow: 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding-bottom: 3rem;\n  }\n\n  svg {\n    width: 100%;\n    height: 100%;\n    max-height: 600px;\n    overflow: visible;\n  }\n\n  /* Node styles */\n  .node {\n    cursor: default;\n    filter: drop-shadow(0 2px 3px rgba(0,0,0,0.25));\n  }\n  .node circle {\n    fill: linear-gradient(135deg, #f4d35e, #ee964b);\n    fill: #f4d35e;\n    filter:\n      drop-shadow(0 0 6px #f4d35e99);\n    transition: fill 0.3s ease;\n  }\n  .node text {\n    font-weight: 700;\n    fill: #1a1a2e;\n    font-size: 1.2rem;\n    user-select: none;\n    dominant-baseline: middle;\n    text-anchor: middle;\n    pointer-events: none;\n    font-family: 'Montserrat', sans-serif;\n  }\n\n  /* Connectors */\n  .link {\n    fill: none;\n    stroke: #5fb4a9;\n    stroke-width: 3;\n    stroke-linecap: round;\n    filter: drop-shadow(0 1px 3px #5fb4a933);\n    transition: stroke 0.3s ease;\n  }\n\n  /* Buttons Panel */\n  .controls {\n    position: absolute;\n    bottom: 1.5rem;\n    display: flex;\n    gap: 1rem;\n    user-select: none;\n  }\n  button {\n    background: #16213e;\n    border: 2.5px solid #f4d35e;\n    color: #f4d35e;\n    font-weight: 700;\n    font-family: 'Montserrat', sans-serif;\n    letter-spacing: 0.07em;\n    padding: 0.6em 1.6em;\n    border-radius: 30px;\n    cursor: pointer;\n    box-shadow:\n      0 0 10px #f4d35e77;\n    transition:\n      background-color 0.35s ease,\n      color 0.35s ease,\n      box-shadow 0.5s ease;\n  }\n  button:hover,\n  button:focus {\n    background-color: #f4d35e;\n    color: #16213e;\n    outline: none;\n    box-shadow:\n      0 0 18px #f4d35eff,\n      0 0 30px #f4d35eff;\n  }\n\n  /* Tooltip for nodes */\n  .tooltip {\n    position: absolute;\n    background: #16213edd;\n    color: #f4d35e;\n    padding: 6px 12px;\n    font-weight: 600;\n    border-radius: 12px;\n    pointer-events: none;\n    font-size: 0.85rem;\n    letter-spacing: 0.08em;\n    opacity: 0;\n    transform: translate(-50%, -140%);\n    transition: opacity 0.3s ease;\n    white-space: nowrap;\n    user-select: none;\n  }\n  .tooltip.visible {\n    opacity: 1;\n  }\n</style>\n</head>\n<body>\n  <h1>BINARY SEARCH TREE</h1>\n  <h2>Aesthetic & Elegant Visualization</h2>\n\n  <div class=\"container\">\n    <svg id=\"bst-svg\" viewBox=\"0 0 960 600\" xmlns=\"http://www.w3.org/2000/svg\" aria-label=\"Binary Search Tree Visualization\" role=\"img\" />\n  </div>\n  <div class=\"controls\" aria-label=\"Tree controls\">\n    <button id=\"buttonInsert\" aria-pressed=\"false\" title=\"Insert next node\">Insert Node</button>\n    <button id=\"buttonReset\" title=\"Reset tree\">Reset</button>\n  </div>\n\n  <div id=\"tooltip\" class=\"tooltip\" role=\"tooltip\" aria-hidden=\"true\"></div>\n\n<script>\n  /**\n   * Binary Search Tree visualization with progressive insertion animations\n   * Minimal interaction: Insert Node button and Reset button\n   * Nodes appear smoothly with elastic scale and connectors stroke-drawn\n   * Visual approach: nodes arranged in balanced fashion for clarity and beauty\n   */\n\n  // Tree node class for data and position\n  class BSTNode {\n    constructor(value) {\n      this.value = value;\n      this.left = null;\n      this.right = null;\n      this.parent = null;\n      // position for rendering\n      this.x = 0;\n      this.y = 0;\n      this.depth = 0;\n    }\n  }\n\n  // Main BST class handles insertion and layout\n  class BSTree {\n    constructor(svg) {\n      this.svg = svg;\n      this.root = null;\n      this.nodes = [];\n      this.links = [];\n      this.animationDuration = 900;\n      this.insertedValues = [];\n    }\n\n    insert(value) {\n      let newNode = new BSTNode(value);\n      if (!this.root) {\n        this.root = newNode;\n        this.nodes.push(newNode);\n        this.computePositions();\n        this.redraw();\n        return newNode;\n      }\n\n      let current = this.root;\n      while (true) {\n        if (value === current.value) {\n          // no duplicates - skip insertion\n          return null;\n        }\n        if (value < current.value) {\n          if (!current.left) {\n            current.left = newNode;\n            newNode.parent = current;\n            this.nodes.push(newNode);\n            break;\n          } else {\n            current = current.left;\n          }\n        } else {\n          if (!current.right) {\n            current.right = newNode;\n            newNode.parent = current;\n            this.nodes.push(newNode);\n            break;\n          } else {\n            current = current.right;\n          }\n        }\n      }\n      this.computePositions();\n      this.redraw();\n      return newNode;\n    }\n\n    clear() {\n      this.root = null;\n      this.nodes = [];\n      this.links = [];\n      this.svg.innerHTML = '';\n    }\n\n    computePositions() {\n      // Assign depth for each node and clear position\n      this._setDepths(this.root, 0);\n\n      // Calculate horizontal positions with inorder traversal\n      let xPos = 0;\n      function inorderPositions(node) {\n        if (!node) return;\n        inorderPositions(node.left);\n        node.x = xPos++;\n        inorderPositions(node.right);\n      }\n      xPos = 0;\n      inorderPositions(this.root);\n\n      // Normalize x and y for the SVG viewport\n      // X scale: space nodes by about 80 px horizontally (minimum)\n      // Y scale: 100 px per depth level with top margin\n\n      const horizontalSpacing = 80;\n      const verticalSpacing = 100;\n      const marginX = 60;\n      const marginY = 80;\n\n      this.nodes.forEach(n => {\n        n.cx = marginX + n.x * horizontalSpacing;\n        n.cy = marginY + n.depth * verticalSpacing;\n      });\n\n      // Prepare links from parent to children\n      this.links = [];\n      this.nodes.forEach(n => {\n        if (n.left) this.links.push({ from: n, to: n.left });\n        if (n.right) this.links.push({ from: n, to: n.right });\n      });\n    }\n\n    _setDepths(node, depth) {\n      if (!node) return;\n      node.depth = depth;\n      this._setDepths(node.left, depth + 1);\n      this._setDepths(node.right, depth + 1);\n    }\n\n    redraw() {\n      // Clear existing svg\n      this.svg.innerHTML = '';\n\n      // Draw links first\n      this.links.forEach(({ from, to }) => {\n        let path = createLinkPath(from.cx, from.cy, to.cx, to.cy);\n        path.classList.add('link');\n        this.svg.appendChild(path);\n        strokeDrawAnimation(path);\n      });\n\n      // Draw nodes\n      this.nodes.forEach(node => {\n        let g = document.createElementNS('http://www.w3.org/2000/svg', 'g');\n        g.classList.add('node');\n        g.style.transformOrigin = `${node.cx}px ${node.cy}px`;\n        g.setAttribute('data-value', node.value);\n        g.setAttribute('tabindex', '-1');\n\n        let circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n        circle.setAttribute('cx', node.cx);\n        circle.setAttribute('cy', node.cy);\n        circle.setAttribute('r', 24);\n        g.appendChild(circle);\n\n        let text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n        text.setAttribute('x', node.cx);\n        text.setAttribute('y', node.cy);\n        text.textContent = node.value;\n        g.appendChild(text);\n\n        // Animate node with elastic scale and fade in from 0\n        g.style.opacity = '0';\n        g.style.transform = 'scale(0)';\n\n        this.svg.appendChild(g);\n\n        setTimeout(() => {\n          g.style.transition = 'transform 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55), opacity 0.6s ease-out';\n          g.style.opacity = '1';\n          g.style.transform = 'scale(1)';\n        }, 50);\n      });\n    }\n  }\n\n  // Helper: creates a smooth curved path between two points for BST connector\n  function createLinkPath(x1, y1, x2, y2) {\n    // Use a cubic Bezier curve that bends downward\n    let deltaX = (x2 - x1) / 2;\n    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');\n    let d = `M${x1},${y1} C${x1},${y1 + deltaX} ${x2},${y2 - deltaX} ${x2},${y2}`;\n    path.setAttribute('d', d);\n    return path;\n  }\n\n  // Animate stroke-dashoffset on path for drawing effect\n  function strokeDrawAnimation(path) {\n    const length = path.getTotalLength();\n    path.style.strokeDasharray = length;\n    path.style.strokeDashoffset = length;\n    path.getBoundingClientRect(); // trigger layout\n    path.style.transition = 'stroke-dashoffset 0.8s ease-out';\n    path.style.strokeDashoffset = '0';\n  }\n\n  // Set up base tree and controls\n  const svg = document.getElementById('bst-svg');\n  const bst = new BSTree(svg);\n\n  // Data sequence for insertion, balanced-ish for visual harmony\n  const insertionSequence = [50, 30, 70, 20, 40, 60, 80, 10, 25, 35, 45, 55, 65, 75, 85];\n\n  let insertionIndex = 0;\n\n  // Insert next node, with small delay for smooth viewing\n  function insertNextNode() {\n    if (insertionIndex >= insertionSequence.length) {\n      buttonInsert.disabled = true;\n      buttonInsert.setAttribute('aria-pressed', 'true');\n      return;\n    }\n    let val = insertionSequence[insertionIndex++];\n    let inserted = bst.insert(val);\n    if (!inserted) insertNextNode(); // skip duplicates (shouldn't happen here)\n  }\n\n  // Reset entire tree\n  function resetTree() {\n    insertionIndex = 0;\n    bst.clear();\n    buttonInsert.disabled = false;\n    buttonInsert.setAttribute('aria-pressed', 'false');\n  }\n\n  let buttonInsert = document.getElementById('buttonInsert');\n  let buttonReset = document.getElementById('buttonReset');\n\n  buttonInsert.addEventListener('click', () => {\n    insertNextNode();\n  });\n\n  buttonReset.addEventListener('click', () => {\n    resetTree();\n  });\n\n  // Optional tooltip for node values on hover (a subtle aesthetic touch)\n  const tooltip = document.getElementById('tooltip');\n\n  svg.addEventListener('mousemove', e => {\n    // Find closest node under cursor\n    let target = e.target;\n    if (target.tagName === 'circle' || target.tagName === 'text') {\n      let g = target.parentNode;\n      if (g && g.classList.contains('node')) {\n        const value = g.getAttribute('data-value');\n        let pt = svg.createSVGPoint();\n        pt.x = e.clientX;\n        pt.y = e.clientY;\n        let cursor = pt;\n\n        tooltip.textContent = `Value: ${value}`;\n        tooltip.style.left = `${e.pageX}px`;\n        tooltip.style.top = `${e.pageY}px`;\n        tooltip.classList.add('visible');\n        tooltip.setAttribute('aria-hidden', 'false');\n        return;\n      }\n    }\n    tooltip.classList.remove('visible');\n    tooltip.setAttribute('aria-hidden', 'true');\n  });\n\n  svg.addEventListener('mouseleave', () => {\n    tooltip.classList.remove('visible');\n    tooltip.setAttribute('aria-hidden', 'true');\n  });\n\n  // Initial prompt message in SVG\n  const promptText = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n  promptText.setAttribute('x', '50%');\n  promptText.setAttribute('y', '50%');\n  promptText.setAttribute('text-anchor', 'middle');\n  promptText.setAttribute('dominant-baseline', 'middle');\n  promptText.setAttribute('fill', '#5fb4a9cc');\n  promptText.setAttribute('font-size', '1.4rem');\n  promptText.setAttribute('font-weight', '600');\n  promptText.style.userSelect = 'none';\n  promptText.style.fontFamily = \"'Montserrat', sans-serif\";\n  promptText.style.letterSpacing = '0.15em';\n  promptText.textContent = 'Click \"Insert Node\" to build the BST';\n  svg.appendChild(promptText);\n</script>\n</body>\n</html>"
  },
