    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>P vs NP Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>P vs NP Demonstration</h1>\n    <p>Explore the concept of P vs NP through an interactive experience.</p>\n    \n    <h2>Select a Problem Type</h2>\n    <button onclick=\"selectProblem('SAT')\">SAT Problem</button>\n    <button onclick=\"selectProblem('TSP')\">Traveling Salesman Problem</button>\n    <button onclick=\"selectProblem('Knapsack')\">Knapsack Problem</button>\n    \n    <div id=\"problemInput\" style=\"display:none;\">\n        <h2>Problem Input</h2>\n        <p id=\"problemDescription\"></p>\n        <label for=\"inputData\">Enter your data (comma-separated):</label>\n        <input type=\"text\" id=\"inputData\" placeholder=\"e.g., 1,2,3\">\n        <button onclick=\"solveProblem()\">Solve Problem</button>\n        <h3>Solution:</h3>\n        <p id=\"solutionOutput\"></p>\n    </div>\n\n    <div id=\"maxPathInput\" style=\"display:none;\">\n        <h2>Explore Solution Path</h2>\n        <label for=\"pathData\">Enter possible solutions (comma-separated):</label>\n        <input type=\"text\" id=\"pathData\" placeholder=\"e.g., path1,path2\">\n        <button onclick=\"explorePaths()\">Explore Paths</button>\n        <h3>Exploration Output:</h3>\n        <p id=\" explorationOutput\"></p>\n    </div>\n\n    <script>\n        function selectProblem(type) {\n            document.getElementById('problemInput').style.display = 'block';\n            document.getElementById('problemDescription').innerText = 'You selected ' + type + '.';\n            // Store the type for later use\n            window.selectedProblemType = type;\n        }\n\n        function solveProblem() {\n            const inputData = document.getElementById('inputData').value.split(',').map(Number);\n            let output;\n            switch(window.selectedProblemType) {\n                case 'SAT':\n                    output = 'SAT solution logic not implemented. Inputs: ' + inputData.join(', ');\n                    break;\n                case 'TSP':\n                    output = 'TSP solution logic not implemented. Inputs: ' + inputData.join(', ');\n                    break;\n                case 'Knapsack':\n                    output = 'Knapsack solution logic not implemented. Inputs: ' + inputData.join(', ');\n                    break;\n                default:\n                    output = 'No problem selected.';\n            }\n            document.getElementById('solutionOutput').innerText = output;\n            document.getElementById('maxPathInput').style.display = 'block';\n        }\n\n        function explorePaths() {\n            const pathData = document.getElementById('pathData').value.split(',');\n            let output = 'Explored following paths: ' + pathData.join(', ');\n            document.getElementById('explorationOutput').innerText = output;\n        }\n    </script>\n</body>\n</html>"
