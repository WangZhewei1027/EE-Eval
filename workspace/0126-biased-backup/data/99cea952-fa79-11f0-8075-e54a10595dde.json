    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Selection Sort Visualizer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #arrayContainer {\n            display: flex;\n            align-items: flex-end;\n            height: 200px;\n            width: 100%;\n            border: 1px solid black;\n        }\n        .bar {\n            width: 20px;\n            margin-right: 2px;\n            background-color: black;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Selection Sort Visualizer</h1>\n<label for=\"arrayInput\">Enter comma-separated numbers:</label>\n<input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 34,7,23,32,5\" />\n<button id=\"generateArray\">Generate Array</button>\n<button id=\"startSort\">Start Selection Sort</button>\n<button id=\"reset\">Reset</button>\n\n<div id=\"arrayContainer\"></div>\n\n<script>\n    let array = [];\n    let interval;\n\n    document.getElementById('generateArray').onclick = function() {\n        const input = document.getElementById('arrayInput').value;\n        array = input.split(',').map(Number);\n        renderArray();\n    };\n\n    document.getElementById('startSort').onclick = function() {\n        if (array.length === 0) {\n            alert('Please generate an array first.');\n            return;\n        }\n        SelectionSort();\n    };\n\n    document.getElementById('reset').onclick = function() {\n        clearInterval(interval);\n        array = [];\n        document.getElementById('arrayInput').value = '';\n        document.getElementById('arrayContainer').innerHTML = '';\n    };\n\n    function renderArray() {\n        const container = document.getElementById('arrayContainer');\n        container.innerHTML = '';\n        array.forEach(num => {\n            const bar = document.createElement('div');\n            bar.className = 'bar';\n            bar.style.height = num * 5 + 'px'; // height for visual representation\n            container.appendChild(bar);\n        });\n    }\n\n    function SelectionSort() {\n        let n = array.length;\n        let i = 0;\n        let j = 0;\n        let minIndex = 0;\n\n        interval = setInterval(() => {\n            if (i < n - 1) {\n                minIndex = i;\n                j = i + 1;\n\n                if (j < n) {\n                    if (array[j] < array[minIndex]) {\n                        minIndex = j;\n                    }\n                    if (j === n - 1) {\n                        [array[i], array[minIndex]] = [array[minIndex], array[i]];\n                        i++;\n                        renderArray();\n                    }\n                    j++;\n                } \n            } else {\n                clearInterval(interval);\n            }\n        }, 500);\n    }\n</script>\n\n</body>\n</html>"
