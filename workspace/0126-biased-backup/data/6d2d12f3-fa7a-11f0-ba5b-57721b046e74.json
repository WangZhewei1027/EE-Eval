  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Red-Black Tree Interactive</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .container { display: flex; flex-direction: column; gap: 10px; }\n        .controls { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; }\n        .control-group { border: 1px solid #ccc; padding: 10px; }\n        .tree-container { min-height: 500px; border: 1px solid #ccc; padding: 10px; position: relative; }\n        .node { position: absolute; width: 30px; height: 30px; border: 1px solid black; \n                display: flex; align-items: center; justify-content: center; border-radius: 15px; }\n        .red { background-color: red; color: white; }\n        .black { background-color: black; color: white; }\n        .line { position: absolute; background-color: black; height: 1px; transform-origin: 0 0; }\n        .log { border: 1px solid #ccc; padding: 10px; height: 100px; overflow-y: auto; }\n    </style>\n</head>\n<body>\n    <h1>Red-Black Tree Interactive</h1>\n    <div class=\"container\">\n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Node Operations</h3>\n                <input type=\"number\" id=\"insertValue\" placeholder=\"Value\">\n                <button onclick=\"insertNode()\">Insert</button>\n                <input type=\"number\" id=\"deleteValue\" placeholder=\"Value\">\n                <button onclick=\"deleteNode()\">Delete</button>\n                <input type=\"number\" id=\"searchValue\" placeholder=\"Value\">\n                <button onclick=\"searchNode()\">Search</button>\n            </div>\n            <div class=\"control-group\">\n                <h3>Tree Operations</h3>\n                <button onclick=\"clearTree()\">Clear Tree</button>\n                <button onclick=\"randomTree()\">Random Tree (5-15 nodes)</button>\n                <button onclick=\"balanceTree()\">Balance Tree</button>\n            </div>\n            <div class=\"control-group\">\n                <h3>Visualization</h3>\n                <label>Node Size: <input type=\"range\" id=\"nodeSize\" min=\"20\" max=\"50\" value=\"30\" onchange=\"updateNodeSize()\"></label>\n                <label>Spacing: <input type=\"range\" id=\"treeSpacing\" min=\"50\" max=\"200\" value=\"100\" onchange=\"drawTree()\"></label>\n                <label><input type=\"checkbox\" id=\"showValues\" checked onchange=\"drawTree()\"> Show Values</label>\n            </div>\n            <div class=\"control-group\">\n                <h3>Step-by-Step</h3>\n                <button onclick=\"startStepByStep()\">Start Insert/Delete</button>\n                <button onclick=\"nextStep()\">Next Step</button>\n                <span id=\"stepInfo\"></span>\n            </div>\n        </div>\n        \n        <div class=\"tree-container\" id=\"treeCanvas\"></div>\n        \n        <div class=\"log\" id=\"operationLog\"></div>\n    </div>\n\n    <script>\n        // Red-Black Tree implementation\n        class Node {\n            constructor(value, color = 'red') {\n                this.value = value;\n                this.color = color;\n                this.left = null;\n                this.right = null;\n                this.parent = null;\n            }\n        }\n\n        class RedBlackTree {\n            constructor() {\n                this.root = null;\n                this.NIL = new Node(null, 'black');\n            }\n\n            insert(value) {\n                let newNode = new Node(value);\n                if (!this.root) {\n                    this.root = newNode;\n                    this.root.color = 'black';\n                    return;\n                }\n\n                let current = this.root;\n                let parent = null;\n\n                while (current !== this.NIL && current !== null) {\n                    parent = current;\n                    if (value < current.value) {\n                        current = current.left || this.NIL;\n                    } else if (value > current.value) {\n                        current = current.right || this.NIL;\n                    } else {\n                        return; // Duplicate value\n                    }\n                }\n\n                newNode.parent = parent;\n                if (value < parent.value) {\n                    parent.left = newNode;\n                } else {\n                    parent.right = newNode;\n                }\n\n                this.fixInsert(newNode);\n            }\n\n            fixInsert(node) {\n                while (node.parent && node.parent.color === 'red') {\n                    let uncle;\n                    if (node.parent === node.parent.parent.left) {\n                        uncle = node.parent.parent.right || this.NIL;\n                        if (uncle.color === 'red') {\n                            // Case 1: Uncle is red\n                            node.parent.color = 'black';\n                            uncle.color = 'black';\n                            node.parent.parent.color = 'red';\n                            node = node.parent.parent;\n                        } else {\n                            // Case 2: Uncle is black and node is right child\n                            if (node === node.parent.right) {\n                                node = node.parent;\n                                this.rotateLeft(node);\n                            }\n                            // Case 3: Uncle is black and node is left child\n                            node.parent.color = 'red';\n                            node.parent.parent.color = 'black';\n                            this.rotateRight(node.parent.parent);\n                        }\n                    } else {\n                        uncle = node.parent.parent.left || this.NIL;\n                        if (uncle.color === 'red') {\n                            // Case 1 mirror\n                            node.parent.color = 'black';\n                            uncle.color = 'black';\n                            node.parent.parent.color = 'red';\n                            node = node.parent.parent;\n                        } else {\n                            // Case 2 mirror\n                            if (node === node.parent.left) {\n                                node = node.parent;\n                                this.rotateRight(node);\n                            }\n                            // Case 3 mirror\n                            node.parent.color = 'red';\n                            node.parent.parent.color = 'black';\n                            this.rotateLeft(node.parent.parent);\n                        }\n                    }\n                }\n                this.root.color = 'black';\n            }\n\n            rotateLeft(node) {\n                let rightChild = node.right;\n                node.right = rightChild.left;\n                if (rightChild.left) rightChild.left.parent = node;\n                rightChild.parent = node.parent;\n                if (!node.parent) {\n                    this.root = rightChild;\n                } else if (node === node.parent.left) {\n                    node.parent.left = rightChild;\n                } else {\n                    node.parent.right = rightChild;\n                }\n                rightChild.left = node;\n                node.parent = rightChild;\n            }\n\n            rotateRight(node) {\n                let leftChild = node.left;\n                node.left = leftChild.right;\n                if (leftChild.right) leftChild.right.parent = node;\n                leftChild.parent = node.parent;\n                if (!node.parent) {\n                    this.root = leftChild;\n                } else if (node === node.parent.right) {\n                    node.parent.right = leftChild;\n                } else {\n                    node.parent.left = leftChild;\n                }\n                leftChild.right = node;\n                node.parent = leftChild;\n            }\n\n            delete(value) {\n                let node = this.search(value);\n                if (!node) return;\n\n                let originalColor = node.color;\n                let x;\n                \n                if (!node.left || node.left === this.NIL) {\n                    x = node.right || this.NIL;\n                    this.transplant(node, x);\n                } else if (!node.right || node.right === this.NIL) {\n                    x = node.left || this.NIL;\n                    this.transplant(node, x);\n                } else {\n                    let successor = this.minimum(node.right);\n                    originalColor = successor.color;\n                    x = successor.right || this.NIL;\n                    \n                    if (successor.parent === node) {\n                        x.parent = successor;\n                    } else {\n                        this.transplant(successor, x);\n                        successor.right = node.right;\n                        successor.right.parent = successor;\n                    }\n                    \n                    this.transplant(node, successor);\n                    successor.left = node.left;\n                    successor.left.parent = successor;\n                    successor.color = node.color;\n                }\n                \n                if (originalColor === 'black') {\n                    this.fixDelete(x);\n                }\n            }\n\n            fixDelete(node) {\n                while (node !== this.root && node.color === 'black') {\n                    if (node === node.parent.left) {\n                        let sibling = node.parent.right || this.NIL;\n                        \n                        if (sibling.color === 'red') {\n                            sibling.color = 'black';\n                            node.parent.color = 'red';\n                            this.rotateLeft(node.parent);\n                            sibling = node.parent.right || this.NIL;\n                        }\n                        \n                        if ((!sibling.left || sibling.left.color === 'black') && \n                            (!sibling.right || sibling.right.color === 'black')) {\n                            sibling.color = 'red';\n                            node = node.parent;\n                        } else {\n                            if (!sibling.right || sibling.right.color === 'black') {\n                                if (sibling.left) sibling.left.color = 'black';\n                                sibling.color = 'red';\n                                this.rotateRight(sibling);\n                                sibling = node.parent.right || this.NIL;\n                            }\n                            \n                            sibling.color = node.parent.color;\n                            node.parent.color = 'black';\n                            if (sibling.right) sibling.right.color = 'black';\n                            this.rotateLeft(node.parent);\n                            node = this.root;\n                        }\n                    } else {\n                        let sibling = node.parent.left || this.NIL;\n                        \n                        if (sibling.color === 'red') {\n                            sibling.color = 'black';\n                            node.parent.color = 'red';\n                            this.rotateRight(node.parent);\n                            sibling = node.parent.left || this.NIL;\n                        }\n                        \n                        if ((!sibling.right || sibling.right.color === 'black') && \n                            (!sibling.left || sibling.left.color === 'black')) {\n                            sibling.color = 'red';\n                            node = node.parent;\n                        } else {\n                            if (!sibling.left || sibling.left.color === 'black') {\n                                if (sibling.right) sibling.right.color = 'black';\n                                sibling.color = 'red';\n                                this.rotateLeft(sibling);\n                                sibling = node.parent.left || this.NIL;\n                            }\n                            \n                            sibling.color = node.parent.color;\n                            node.parent.color = 'black';\n                            if (sibling.left) sibling.left.color = 'black';\n                            this.rotateRight(node.parent);\n                            node = this.root;\n                        }\n                    }\n                }\n                node.color = 'black';\n            }\n\n            transplant(u, v) {\n                if (!u.parent) {\n                    this.root = v;\n                } else if (u === u.parent.left) {\n                    u.parent.left = v;\n                } else {\n                    u.parent.right = v;\n                }\n                v.parent = u.parent;\n            }\n\n            minimum(node) {\n                while (node.left && node.left !== this.NIL) {\n                    node = node.left;\n                }\n                return node;\n            }\n\n            search(value) {\n                let current = this.root;\n                while (current && current !== this.NIL) {\n                    if (value === current.value) {\n                        return current;\n                    } else if (value < current.value) {\n                        current = current.left || this.NIL;\n                    } else {\n                        current = current.right || this.NIL;\n                    }\n                }\n                return null;\n            }\n\n            inOrderTraversal(node = this.root, result = []) {\n                if (node && node !== this.NIL) {\n                    this.inOrderTraversal(node.left, result);\n                    result.push(node.value);\n                    this.inOrderTraversal(node.right, result);\n                }\n                return result;\n            }\n        }\n\n        // Visualization and interaction\n        const tree = new RedBlackTree();\n        let stepQueue = [];\n        let currentStep = null;\n\n        function insertNode() {\n            const value = parseInt(document.getElementById('insertValue').value);\n            if (isNaN(value)) return;\n            \n            tree.insert(value);\n            logOperation(`Inserted ${value}`);\n            drawTree();\n            document.getElementById('insertValue').value = '';\n        }\n\n        function deleteNode() {\n            const value = parseInt(document.getElementById('deleteValue').value);\n            if (isNaN(value)) return;\n            \n            tree.delete(value);\n            logOperation(`Deleted ${value}`);\n            drawTree();\n            document.getElementById('deleteValue').value = '';\n        }\n\n        function searchNode() {\n            const value = parseInt(document.getElementById('searchValue').value);\n            if (isNaN(value)) return;\n            \n            const node = tree.search(value);\n            if (node) {\n                logOperation(`Found ${value}`);\n                highlightNode(node);\n            } else {\n                logOperation(`${value} not found`);\n            }\n            document.getElementById('searchValue').value = '';\n        }\n\n        function clearTree() {\n            tree.root = null;\n            logOperation('Tree cleared');\n            drawTree();\n        }\n\n        function randomTree() {\n            clearTree();\n            const count = Math.floor(Math.random() * 11) + 5; // 5-15 nodes\n            const values = new Set();\n            \n            while (values.size < count) {\n                values.add(Math.floor(Math.random() * 100));\n            }\n            \n            values.forEach(value => tree.insert(value));\n            logOperation(`Generated random tree with ${count} nodes`);\n            drawTree();\n        }\n\n        function balanceTree() {\n            const values = tree.inOrderTraversal();\n            clearTree();\n            \n            // Build balanced tree\n            function buildBalanced(arr, start, end) {\n                if (start > end) return null;\n                \n                const mid = Math.floor((start + end) / 2);\n                const node = new Node(arr[mid], 'black');\n                \n                node.left = buildBalanced(arr, start, mid - 1);\n                if (node.left) node.left.parent = node;\n                \n                node.right = buildBalanced(arr, mid + 1, end);\n                if (node.right) node.right.parent = node;\n                \n                return node;\n            }\n            \n            tree.root = buildBalanced(values, 0, values.length - 1);\n            logOperation('Tree rebalanced');\n            drawTree();\n        }\n\n        function startStepByStep() {\n            const insertValue = parseInt(document.getElementById('insertValue').value);\n            const deleteValue = parseInt(document.getElementById('deleteValue').value);\n            \n            stepQueue = [];\n            \n            if (!isNaN(insertValue)) {\n                stepQueue.push({ type: 'insert', value: insertValue });\n                document.getElementById('insertValue').value = '';\n            }\n            \n            if (!isNaN(deleteValue)) {\n                stepQueue.push({ type: 'delete', value: deleteValue });\n                document.getElementById('deleteValue').value = '';\n            }\n            \n            if (stepQueue.length > 0) {\n                document.getElementById('stepInfo').textContent = `Step 1/${stepQueue.length}`;\n            }\n        }\n\n        function nextStep() {\n            if (stepQueue.length === 0) return;\n            \n            currentStep = stepQueue.shift();\n            \n            if (currentStep.type === 'insert') {\n                tree.insert(currentStep.value);\n                logOperation(`Step: Inserted ${currentStep.value}`);\n            } else {\n                tree.delete(currentStep.value);\n                logOperation(`Step: Deleted ${currentStep.value}`);\n            }\n            \n            drawTree();\n            document.getElementById('stepInfo').textContent = stepQueue.length > 0 ? \n                `Step ${stepQueue.length}/${stepQueue.length + 1}` : 'All steps completed';\n        }\n\n        function updateNodeSize() {\n            const size = document.getElementById('nodeSize').value;\n            document.documentElement.style.setProperty('--node-size', `${size}px`);\n            drawTree();\n        }\n\n        function logOperation(message) {\n            const log = document.getElementById('operationLog');\n            log.innerHTML += `<div>${new Date().toLocaleTimeString()}: ${message}</div>`;\n            log.scrollTop = log.scrollHeight;\n        }\n\n        function highlightNode(node) {\n            const canvas = document.getElementById('treeCanvas');\n            const nodes = canvas.querySelectorAll('.node');\n            \n            nodes.forEach(n => {\n                if (parseInt(n.textContent) === node.value) {\n                    n.style.border = '2px solid blue';\n                    setTimeout(() => n.style.border = '1px solid black', 1000);\n                }\n            });\n        }\n\n        function drawTree() {\n            const canvas = document.getElementById('treeCanvas');\n            canvas.innerHTML = '';\n            \n            if (!tree.root) return;\n            \n            const spacing = parseInt(document.getElementById('treeSpacing').value);\n            const nodeSize = parseInt(document.getElementById('nodeSize').value);\n            const showValues = document.getElementById('showValues').checked;\n            \n            // Calculate tree dimensions\n            function getHeight(node) {\n                if (!node || node === tree.NIL) return 0;\n                return 1 + Math.max(getHeight(node.left), getHeight(node.right));\n            }\n            \n            const height = getHeight(tree.root);\n            const canvasWidth = Math.pow(2, height) * spacing;\n            canvas.style.width = `${canvasWidth}px`;\n            \n            // Draw tree recursively\n            function drawNode(node, x, y, level, parentX, parentY) {\n                if (!node || node === tree.NIL) return;\n                \n                const nodeElement = document.createElement('div');\n                nodeElement.className = `node ${node.color}`;\n                nodeElement.style.width = `${nodeSize}px`;\n                nodeElement.style.height = `${nodeSize}px`;\n                nodeElement.style.left = `${x - nodeSize/2}px`;\n                nodeElement.style.top = `${y}px`;\n                \n                if (showValues) {\n                    nodeElement.textContent = node.value;\n                }\n                \n                canvas.appendChild(nodeElement);\n                \n                // Draw line to parent\n                if (parentX !== undefined && parentY !== undefined) {\n                    const line = document.createElement('div');\n                    line.className = 'line';\n                    \n                    const length = Math.sqrt(Math.pow(x - parentX, 2) + Math.pow(y - parentY, 2));\n                    const angle = Math.atan2(y - parentY, x - parentX);\n                    \n                    line.style.width = `${length}px`;\n                    line.style.left = `${parentX}px`;\n                    line.style.top = `${parentY + nodeSize/2}px`;\n                    line.style.transform = `rotate(${angle}rad)`;\n                    \n                    canvas.appendChild(line);\n                }\n                \n                const xOffset = spacing * Math.pow(2, height - level - 1);\n                \n                drawNode(node.left, x - xOffset, y + 60, level + 1, x, y + nodeSize/2);\n                drawNode(node.right, x + xOffset, y + 60, level + 1, x, y + nodeSize/2);\n            }\n            \n            drawNode(tree.root, canvasWidth / 2, 20, 1);\n        }\n\n        // Initialize\n        drawTree();\n    </script>\n</body>\n</html>"
  },
