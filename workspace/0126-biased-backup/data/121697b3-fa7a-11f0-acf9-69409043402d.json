  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Interactive Git Simulator</title>\n</head>\n<body>\n<h1>Interactive Git Simulator</h1>\n<p>\nThis minimal simulator lets you create a local git repository, make commits, create and switch branches, stage changes, and perform merges with conflicts, resets, rebases, and more. All purely simulated in the browser.\n</p>\n\n<!-- Repository Init -->\n<div id=\"initSection\">\n  <button id=\"initBtn\">Initialize New Repository</button>\n</div>\n\n<!-- Repository Info & Controls -->\n<div id=\"repoSection\" style=\"display:none; margin-top:10px;\">\n  <div>\n    <label>Working Directory File (edit content):<br/>\n      <textarea id=\"workingFile\" rows=\"4\" cols=\"60\"></textarea>\n    </label>\n  </div>\n  <div style=\"margin-top:5px;\">\n    <button id=\"stageBtn\">Stage Changes</button>\n    <button id=\"commitBtn\">Commit Staged</button>\n  </div>\n  <div style=\"margin-top:10px;\">\n    <label>New Branch Name: <input type=\"text\" id=\"newBranchName\" size=\"12\"/></label>\n    <button id=\"createBranchBtn\">Create Branch</button>\n    &nbsp;&nbsp;\n    <label>Checkout Branch:\n      <select id=\"branchSelect\"></select>\n    </label>\n    <button id=\"checkoutBtn\">Switch Branch</button>\n  </div>\n  <div style=\"margin-top:10px;\">\n    <button id=\"logBtn\">Show Commit Log</button>\n    <button id=\"statusBtn\">Show Status</button>\n    <button id=\"diffBtn\">Show Diff</button>\n  </div>\n  <div style=\"margin-top:10px;\">\n    <label>Merge Branch:\n      <select id=\"mergeBranchSelect\"></select>\n    </label>\n    <button id=\"mergeBtn\">Merge</button>\n  </div>\n  <div style=\"margin-top:10px;\">\n    <label>Reset to Commit Hash (or empty to cancel): <input type=\"text\" id=\"resetCommitInput\" size=\"25\"/></label>\n    <button id=\"resetBtn\">Reset --mixed</button>\n    <button id=\"resetHardBtn\">Reset --hard</button>\n  </div>\n  <div style=\"margin-top:10px;\">\n    <label>Rebase ontop of (commit hash or branch): <input type=\"text\" id=\"rebaseTargetInput\" size=\"25\" /></label>\n    <button id=\"rebaseBtn\">Rebase Current Branch</button>\n  </div>\n</div>\n\n<!-- Output -->\n<div style=\"margin-top:15px;\">\n  <h3>Output</h3>\n  <pre id=\"output\" style=\"white-space: pre-wrap; max-height: 500px; overflow-y: scroll; border:1px solid #000; padding:5px;\"></pre>\n</div>\n\n<script>\n(() => {\n  // Data structures for simulation:\n\n  class Commit {\n    constructor(hash, message, parentHashes, changes, branch) {\n      // hash is string unique id\n      this.hash = hash;\n      this.message = message;\n      this.parents = parentHashes; // array of parent commit hashes\n      this.changes = changes; // snapshot of file content at commit\n      this.branch = branch; // branch name where commit was created (for info)\n    }\n  }\n\n  // Utility for generating simple hashes:\n  function simpleHash(text) {\n    // simple hash by character codes sum + timestamp (for uniqueness)\n    let hash = 0;\n    for(let i=0; i<text.length; i++) {\n      hash = (hash + text.charCodeAt(i)) % 1000000;\n    }\n    hash = hash.toString(16);\n    if(hash.length < 6) hash = hash.padStart(6, '0');\n    return hash;\n  }\n\n  function generateCommitHash(message, parentHashes) {\n    // Incorporate time + message + parents\n    const input = message + parentHashes.join(',') + Date.now() + Math.random();\n    return simpleHash(input).slice(0,6);\n  }\n\n  // Global state\n  let repo = null;\n\n  // repo = {\n  //    branches: { [branchName]: commitHash },\n  //    commits: { [hash]: Commit },\n  //    head: { type:'branch', name: 'master' } or { type:'detached', hash: 'abc123' },\n  //    index: null or string of staged content,\n  //    working: string content in working directory,\n  // }\n\n  // Initialize repository\n  function initRepo() {\n    const initialContent = \"\"; // empty file\n    const initialHash = generateCommitHash(\"Initial commit\", []);\n    const initialCommit = new Commit(initialHash, \"Initial commit\", [], initialContent, \"master\");\n    repo = {\n      branches: { master: initialHash },\n      commits: { [initialHash]: initialCommit },\n      head: { type:\"branch\", name:\"master\" },\n      index: null, // if null => no staged changes, else string content staged\n      working: initialContent,\n    };\n    updateUIAfterRepoChange();\n    printOutput(\"Repository initialized with empty master branch and initial commit.\");\n  }\n\n  // UI Elements\n  const initBtn = document.getElementById('initBtn');\n  const repoSection = document.getElementById('repoSection');\n  const workingFile = document.getElementById('workingFile');\n  const stageBtn = document.getElementById('stageBtn');\n  const commitBtn = document.getElementById('commitBtn');\n  const newBranchName = document.getElementById('newBranchName');\n  const createBranchBtn = document.getElementById('createBranchBtn');\n  const branchSelect = document.getElementById('branchSelect');\n  const checkoutBtn = document.getElementById('checkoutBtn');\n  const logBtn = document.getElementById('logBtn');\n  const output = document.getElementById('output');\n  const statusBtn = document.getElementById('statusBtn');\n  const diffBtn = document.getElementById('diffBtn');\n  const mergeBranchSelect = document.getElementById('mergeBranchSelect');\n  const mergeBtn = document.getElementById('mergeBtn');\n  const resetCommitInput = document.getElementById('resetCommitInput');\n  const resetBtn = document.getElementById('resetBtn');\n  const resetHardBtn = document.getElementById('resetHardBtn');\n  const rebaseTargetInput = document.getElementById('rebaseTargetInput');\n  const rebaseBtn = document.getElementById('rebaseBtn');\n\n  // Helpers for UI updates\n  function updateBranchSelectors() {\n    // clear all branch selects (branchSelect, mergeBranchSelect)\n    [branchSelect, mergeBranchSelect].forEach(sel => {\n      while(sel.firstChild) sel.removeChild(sel.firstChild);\n      Object.keys(repo.branches).forEach(branchName => {\n        let opt = document.createElement(\"option\");\n        opt.value = branchName;\n        opt.textContent = branchName;\n        sel.appendChild(opt);\n      });\n    });\n  }\n\n  // Get commit for current HEAD\n  function getHeadCommit() {\n    if(repo.head.type === \"branch\") {\n      const branchName = repo.head.name;\n      const commitHash = repo.branches[branchName];\n      return repo.commits[commitHash];\n    } else if(repo.head.type === \"detached\") {\n      return repo.commits[repo.head.hash];\n    }\n    return null;\n  }\n\n  // Update UI elements on repo changes\n  function updateUIAfterRepoChange() {\n    if(!repo) {\n      repoSection.style.display = \"none\";\n      return;\n    }\n    repoSection.style.display = \"block\";\n    updateBranchSelectors();\n\n    // Set working file content as repo.working\n    if(typeof repo.working === \"string\") {\n      workingFile.value = repo.working;\n    }\n\n    // Enable or disable commit button based on staged changes\n    commitBtn.disabled = (repo.index === null);\n  }\n\n  // print output and scroll to bottom\n  function printOutput(text) {\n    output.textContent += text + \"\\n\";\n    output.scrollTop = output.scrollHeight;\n  }\n\n  // Get difference between two strings line-based\n  function diffStrings(a, b) {\n    // simple line based diff to show lines that differ or added or deleted\n    const aLines = a.split('\\n');\n    const bLines = b.split('\\n');\n    let diff = [];\n    let maxLines = Math.max(aLines.length, bLines.length);\n    for(let i=0; i<maxLines; i++) {\n      let aLine = aLines[i];\n      let bLine = bLines[i];\n      if(aLine === undefined) {\n        diff.push(`+ ${bLine}`);\n      } else if(bLine === undefined) {\n        diff.push(`- ${aLine}`);\n      } else if(aLine !== bLine) {\n        diff.push(`- ${aLine}`);\n        diff.push(`+ ${bLine}`);\n      } else {\n        diff.push(`  ${aLine}`);\n      }\n    }\n    return diff.join('\\n');\n  }\n\n  // Stage changes (copy working to index)\n  function stageChanges() {\n    if(!repo) return;\n    if(repo.working === getHeadCommit().changes) {\n      repo.index = null;\n      printOutput(\"No changes to stage.\");\n      commitBtn.disabled = true;\n    } else {\n      repo.index = repo.working;\n      printOutput(\"Changes staged.\");\n      commitBtn.disabled = false;\n    }\n  }\n\n  // Commit staged changes\n  function commitStaged() {\n    if(!repo || repo.index === null) {\n      printOutput(\"Nothing staged to commit.\");\n      return;\n    }\n    const parentHash = getHeadCommit().hash;\n    let msg = prompt(\"Enter commit message:\");\n    if(msg === null) {\n      printOutput(\"Commit cancelled.\");\n      return;\n    }\n    msg = msg.trim();\n    if(msg === \"\") {\n      printOutput(\"Commit message cannot be empty.\");\n      return;\n    }\n    const parents = [parentHash];\n    const hash = generateCommitHash(msg, parents);\n    const branchName = (repo.head.type === \"branch\") ? repo.head.name : null;\n    let commit = new Commit(hash, msg, parents, repo.index, branchName);\n    repo.commits[hash] = commit;\n\n    if(repo.head.type === \"branch\") {\n      repo.branches[repo.head.name] = hash;\n    } else if(repo.head.type === \"detached\") {\n      repo.head.hash = hash;\n    }\n\n    repo.index = null;\n    repo.working = commit.changes;\n    workingFile.value = repo.working;\n    commitBtn.disabled = true;\n    printOutput(`Committed new commit ${hash} on ${repo.head.type === \"branch\" ? repo.head.name : \"detached HEAD\"}.`);\n  }\n\n  // Create branch at HEAD\n  function createBranch() {\n    if(!repo) return;\n    const name = newBranchName.value.trim();\n    if(name === \"\") {\n      printOutput(\"Branch name cannot be empty.\");\n      return;\n    }\n    if(repo.branches.hasOwnProperty(name)) {\n      printOutput(\"Branch name already exists.\");\n      return;\n    }\n    const commitHash = getHeadCommit().hash;\n    repo.branches[name] = commitHash;\n    updateBranchSelectors();\n    printOutput(`Branch '${name}' created at commit ${commitHash}.`);\n  }\n\n  // Checkout branch\n  function checkoutBranch() {\n    if(!repo) return;\n    const branch = branchSelect.value;\n    if(!repo.branches.hasOwnProperty(branch)) {\n      printOutput(\"Branch does not exist.\");\n      return;\n    }\n    // checkout\n    repo.head = { type: \"branch\", name: branch };\n    const commit = repo.commits[repo.branches[branch]];\n    repo.working = commit.changes;\n    repo.index = null;\n    workingFile.value = repo.working;\n    commitBtn.disabled = true;\n    printOutput(`Checked out branch '${branch}'.`);\n  }\n\n  // Show commit log for current branch or detached HEAD\n  function showLog() {\n    if(!repo) return;\n    let startCommit = null;\n    if(repo.head.type === \"branch\") {\n      const branchName = repo.head.name;\n      startCommit = repo.commits[repo.branches[branchName]];\n    } else if(repo.head.type === \"detached\") {\n      startCommit = repo.commits[repo.head.hash];\n    }\n    if(!startCommit) {\n      printOutput(\"No commits to show.\");\n      return;\n    }\n    let lines = [];\n    let visited = new Set();\n    let stack = [startCommit];\n    // Traverse commits reachable from startCommit (linear history expected, but we allow merges)\n    while(stack.length > 0) {\n      let c = stack.pop();\n      if(visited.has(c.hash)) continue;\n      visited.add(c.hash);\n      lines.push(`Commit: ${c.hash}\\nMessage: ${c.message}\\nParents: ${c.parents.join(\", \") || \"None\"}\\nBranch: ${c.branch || \"detached\"}\\n---`);\n      c.parents.forEach(pHash => {\n        if(repo.commits[pHash]) stack.push(repo.commits[pHash]);\n      });\n    }\n    printOutput(\"Commit log (most recent first):\\n\" + lines.join(\"\\n\"));\n  }\n\n  // Show status: staged changes, unstaged changes, HEAD, branch\n  function showStatus() {\n    if(!repo) return;\n    let lines = [];\n    lines.push(\"On \" + (repo.head.type === \"branch\" ? `branch ${repo.head.name}` : `detached HEAD at ${repo.head.hash}`));\n    const headContent = getHeadCommit().changes;\n    if(repo.index !== null && repo.index !== headContent) {\n      lines.push(\"Changes staged for commit.\");\n    } else {\n      lines.push(\"No changes staged.\");\n    }\n    if(repo.working !== headContent) {\n      lines.push(\"Unstaged changes in working directory.\");\n    } else {\n      lines.push(\"Working directory clean.\");\n    }\n    printOutput(lines.join(\"\\n\"));\n  }\n\n  // Show diff between HEAD and working directory (unstaged changes)\n  function showDiff() {\n    if(!repo) return;\n    const headContent = getHeadCommit().changes;\n    if(repo.working === headContent) {\n      printOutput(\"No differences between HEAD and working directory.\");\n      return;\n    }\n    const diffText = diffStrings(headContent, repo.working);\n    printOutput(\"Diff (HEAD -> Working directory):\\n\" + diffText);\n  }\n\n  // Merge branch into current branch\n  function mergeBranch() {\n    if(!repo) return;\n    if(repo.head.type !== \"branch\") {\n      printOutput(\"Can only merge on a branch (not detached HEAD).\");\n      return;\n    }\n    const currentBranch = repo.head.name;\n    const mergeBranch = mergeBranchSelect.value;\n    if(mergeBranch === currentBranch) {\n      printOutput(\"Cannot merge a branch into itself.\");\n      return;\n    }\n    if(!repo.branches.hasOwnProperty(mergeBranch)) {\n      printOutput(\"Selected branch does not exist.\");\n      return;\n    }\n\n    // Find commits to merge\n    const currentCommitHash = repo.branches[currentBranch];\n    const mergeCommitHash = repo.branches[mergeBranch];\n\n    // Find common ancestor (merge base)\n    const baseHash = findMergeBase(currentCommitHash, mergeCommitHash);\n    if(baseHash === mergeCommitHash) {\n      printOutput(`Branch '${mergeBranch}' is already merged (fast-forward).`);\n      return;\n    }\n    // Fast-forward case:\n    if(baseHash === currentCommitHash) {\n      repo.branches[currentBranch] = mergeCommitHash;\n      const newCommit = repo.commits[mergeCommitHash];\n      repo.working = newCommit.changes;\n      repo.index = null;\n      workingFile.value = repo.working;\n      printOutput(`Fast-forward merged '${mergeBranch}' into '${currentBranch}'.`);\n      return;\n    }\n\n    // Normal 3-way merge\n\n    const baseCommit = repo.commits[baseHash];\n    const currentCommit = repo.commits[currentCommitHash];\n    const mergeCommit = repo.commits[mergeCommitHash];\n\n    const mergedContent = threeWayMerge(baseCommit.changes, currentCommit.changes, mergeCommit.changes);\n\n    if(mergedContent.conflict) {\n      // Write conflict markers in working directory\n      repo.working = mergedContent.content;\n      repo.index = null;\n      workingFile.value = repo.working;\n      printOutput(\"Merge conflict detected! Resolve conflicts in working directory and stage changes.\");\n    } else {\n      // Create merge commit:\n      let msg = `Merge branch '${mergeBranch}' into ${currentBranch}`;\n      const parentHashes = [currentCommitHash, mergeCommitHash];\n      const hash = generateCommitHash(msg, parentHashes);\n      const mergeCommitObj = new Commit(hash, msg, parentHashes, mergedContent.content, currentBranch);\n      repo.commits[hash] = mergeCommitObj;\n      repo.branches[currentBranch] = hash;\n      repo.working = mergedContent.content;\n      repo.index = null;\n      workingFile.value = repo.working;\n      printOutput(`Merge successful. New merge commit ${hash} created on branch '${currentBranch}'.`);\n    }\n  }\n\n  // Find merge base (lowest common ancestor) naive BFS walk back through parents\n  function findMergeBase(hash1, hash2) {\n    // Edge case: if equal then return hash\n    if(hash1 === hash2) return hash1;\n\n    function getAncestors(hash) {\n      let ancestors = new Set();\n      let queue = [hash];\n      while(queue.length > 0) {\n        let h = queue.shift();\n        if(ancestors.has(h)) continue;\n        ancestors.add(h);\n        const commit = repo.commits[h];\n        if(commit) {\n          commit.parents.forEach(p => queue.push(p));\n        }\n      }\n      return ancestors;\n    }\n\n    const ancestors1 = getAncestors(hash1);\n    const ancestors2 = getAncestors(hash2);\n\n    // Intersection of ancestors:\n    let common = [...ancestors1].filter(x => ancestors2.has(x));\n\n    if(common.length === 0) return null;\n\n    // Pick closest common ancestor by preferring earliest visited from hash1:\n    // We can do a BFS from hash1 to find the first common ancestor:\n    let queue = [hash1];\n    let visited = new Set();\n    while(queue.length > 0) {\n      let cur = queue.shift();\n      if(common.includes(cur)) return cur;\n      visited.add(cur);\n      const commit = repo.commits[cur];\n      if(commit) {\n        commit.parents.forEach(p => {\n          if(!visited.has(p)) queue.push(p);\n        });\n      }\n    }\n    return common[0];\n  }\n\n  // Three-way merge naive line-based with simple conflict markers\n  // Return {content: mergedString, conflict: bool}\n  function threeWayMerge(base, current, other) {\n    // Strategy: For each line:\n    // if current==other use line\n    // if current==base use other line\n    // if other==base use current line\n    // else conflict => put <<<<<<<, =======, >>>>>>>\n    const baseLines = base.split('\\n');\n    const curLines = current.split('\\n');\n    const othLines = other.split('\\n');\n\n    const maxLines = Math.max(baseLines.length, curLines.length, othLines.length);\n    let mergedLines = [];\n    let conflict = false;\n\n    function safeGet(lines,i) {\n      return (i < lines.length) ? lines[i] : \"\";\n    }\n\n    for(let i=0; i<maxLines; i++) {\n      const b = safeGet(baseLines,i);\n      const c = safeGet(curLines,i);\n      const o = safeGet(othLines,i);\n      if(c === o) {\n        mergedLines.push(c);\n      } else if(c === b) {\n        mergedLines.push(o);\n      } else if(o === b) {\n        mergedLines.push(c);\n      } else {\n        // Conflict\n        conflict = true;\n        mergedLines.push(\"<<<<<<< HEAD\");\n        mergedLines.push(c);\n        mergedLines.push(\"=======\");\n        mergedLines.push(o);\n        mergedLines.push(\">>>>>>>\");\n      }\n    }\n    return { content: mergedLines.join('\\n'), conflict };\n  }\n\n  // Reset HEAD to commit hash with --mixed (move HEAD and branch or detached) and reset index but not working directory\n  // or --hard (also reset working directory)\n  function resetCommit(h, hard) {\n    if(!repo) return;\n    if(h.trim() === \"\") {\n      printOutput(\"Reset cancelled: empty commit hash.\");\n      return;\n    }\n    // Find commit starting with h - allow prefix\n    let matches = Object.keys(repo.commits).filter(k => k.startsWith(h));\n    if(matches.length === 0) {\n      printOutput(\"No matching commit found for hash: \" + h);\n      return;\n    }\n    if(matches.length > 1) {\n      printOutput(\"Ambiguous commit hash prefix - multiple matches.\");\n      return;\n    }\n    h = matches[0];\n    if(repo.head.type === \"branch\") {\n      repo.branches[repo.head.name] = h;\n    } else if(repo.head.type === \"detached\") {\n      repo.head.hash = h;\n    }\n    if(hard) {\n      repo.working = repo.commits[h].changes;\n      workingFile.value = repo.working;\n    }\n    repo.index = null;\n    commitBtn.disabled = true;\n    printOutput(`Reset ${hard ? \"--hard\" : \"--mixed\"} to commit ${h}.`);\n  }\n\n  // Rebase current branch onto another branch or commit\n  // Steps:\n  // 1) Find upstream commit commitObj for target (branch or hash prefix)\n  // 2) Find commits on current branch not in upstream history (commits to replay)\n  // 3) Reset current branch to upstream\n  // 4) Replay commits by applying changes (simulate patches)\n  function rebaseCurrent(targetInput) {\n    if(!repo) return;\n    if(repo.head.type !== \"branch\") {\n      printOutput(\"Rebase only supported on a branch.\");\n      return;\n    }\n    if(!targetInput || targetInput.trim() === \"\") {\n      printOutput(\"Rebase target cannot be empty.\");\n      return;\n    }\n    // Resolve target commit or branch\n    let targetCommitHash = null;\n\n    if(repo.branches.hasOwnProperty(targetInput)) {\n      targetCommitHash = repo.branches[targetInput];\n    } else {\n      // Match prefix hash\n      let matches = Object.keys(repo.commits).filter(k=>k.startsWith(targetInput));\n      if(matches.length === 1) targetCommitHash = matches[0];\n      else if(matches.length === 0) {\n        printOutput(\"Rebase target not found: \"+targetInput);\n        return;\n      } else {\n        printOutput(\"Rebase target ambiguous prefix.\");\n        return;\n      }\n    }\n    const currentBranch = repo.head.name;\n    const currentCommitHash = repo.branches[currentBranch];\n\n    // Get upstream ancestors\n    function getAllAncestors(hash) {\n      let ancestors = new Set();\n      let stack = [hash];\n      while(stack.length > 0) {\n        let c = stack.pop();\n        if(ancestors.has(c)) continue;\n        ancestors.add(c);\n        let commit = repo.commits[c];\n        if(commit) {\n          commit.parents.forEach(p => stack.push(p));\n        }\n      }\n      return ancestors;\n    }\n\n    const upstreamAncestors = getAllAncestors(targetCommitHash);\n\n    // Get commits on current branch not in upstreamAncestors, sorted oldest->newest\n    const commitsToReplay = [];\n\n    function getCommitChainTo(fromHash, untilNotIncludedSet) {\n      // Collect commits from fromHash backwards until hit commit in untilNotIncludedSet\n      let chain = [];\n      let cur = fromHash;\n      while(cur && !untilNotIncludedSet.has(cur)) {\n        chain.push(cur);\n        let c = repo.commits[cur];\n        if(!c.parents.length) break;\n        cur = c.parents[0]; // linear history assumed for replay\n      }\n      return chain.reverse(); // oldest->newest\n    }\n\n    const toReplay = getCommitChainTo(currentCommitHash, upstreamAncestors);\n\n    if(toReplay.length === 0) {\n      printOutput(\"Nothing to rebase: current branch already up-to-date with target.\");\n      return;\n    }\n\n    // Reset current branch to targetCommitHash -- effectively git reset\n    repo.branches[currentBranch] = targetCommitHash;\n\n    // Replay commits applying changes on top of targetCommitHash\n    // We simulate patch apply by using commit changes as snapshots:\n    let baseContent = repo.commits[targetCommitHash].changes;\n    let newParent = targetCommitHash;\n\n    for(let i=0; i<toReplay.length; i++) {\n      const oldCommit = repo.commits[toReplay[i]];\n      // Compute diff between oldCommit.parent and oldCommit\n      // We'll just apply commit changes as new snapshot:\n      const newContent = oldCommit.changes;\n\n      // Create new commit on top of newParent with same message and \"rebased:\"\n      const msg = \"(rebased) \" + oldCommit.message;\n      const hash = generateCommitHash(msg, [newParent]);\n      const newCommit = new Commit(hash, msg, [newParent], newContent, currentBranch);\n      repo.commits[hash] = newCommit;\n\n      repo.branches[currentBranch] = hash;\n      newParent = hash;\n      baseContent = newContent;\n      printOutput(`Replayed commit ${oldCommit.hash} as ${hash}.`);\n    }\n    repo.working = baseContent;\n    workingFile.value = baseContent;\n    repo.index = null;\n    commitBtn.disabled = true;\n    printOutput(`Rebase completed on branch '${currentBranch}'.`);\n  }\n\n  // Event bindings\n  initBtn.onclick = () => {\n    initRepo();\n  };\n  stageBtn.onclick = () => {\n    if(!repo) {\n      printOutput(\"Repository not initialized.\");\n      return;\n    }\n    repo.working = workingFile.value;\n    stageChanges();\n  };\n  commitBtn.onclick = () => {\n    commitStaged();\n  };\n  createBranchBtn.onclick = () => { createBranch(); };\n  checkoutBtn.onclick = () => { checkoutBranch(); };\n  logBtn.onclick = () => { showLog(); };\n  statusBtn.onclick = () => { showStatus(); };\n  diffBtn.onclick = () => { showDiff(); };\n  mergeBtn.onclick = () => { mergeBranch(); };\n  resetBtn.onclick = () => { resetCommit(resetCommitInput.value.trim(), false); };\n  resetHardBtn.onclick = () => { resetCommit(resetCommitInput.value.trim(), true); };\n  rebaseBtn.onclick = () => { rebaseCurrent(rebaseTargetInput.value.trim()); };\n\n  // Start with no repo loaded\n  updateUIAfterRepoChange();\n\n})();\n</script>\n</body>\n</html>"
