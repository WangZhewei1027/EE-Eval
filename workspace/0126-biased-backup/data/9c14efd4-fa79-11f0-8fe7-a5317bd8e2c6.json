  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Time Complexity Explorer</title>\n<style>\n/* Extremely minimal plain layout - no colors, no fancy styling */\nbody { font-family: sans-serif; margin: 12px; color: #000; background: #fff; }\nh1 { font-size: 18px; margin: 4px 0 12px 0; }\nlabel { display: inline-block; margin: 4px 8px 4px 0; }\nsection { margin-bottom: 18px; padding: 0; }\n.control-row { margin: 6px 0; }\npre { background: #fff; border: 1px solid #000; padding: 6px; white-space: pre-wrap; overflow: auto; max-height: 220px; }\ninput[type=\"range\"] { vertical-align: middle; }\nsmall { display: block; margin-top: 6px; color: #000; }\nbutton, select, input, textarea { margin: 2px 6px 2px 0; }\ntextarea { width: 100%; height: 100px; }\ntable { border-collapse: collapse; margin-top: 6px; }\ntd, th { border: 1px solid #000; padding: 4px; }\n.hidden { display: none; }\n</style>\n</head>\n<body>\n<h1>Time Complexity Explorer</h1>\n\n<section>\n<label for=\"modeSelect\">Mode:</label>\n<select id=\"modeSelect\">\n  <option value=\"algo\">Algorithm Stepper & Visualizer</option>\n  <option value=\"bench\">Empirical Benchmark</option>\n  <option value=\"builder\">Complexity Builder (Nested Loops)</option>\n  <option value=\"master\">Master Theorem Solver</option>\n  <option value=\"custom\">Custom Pseudocode Estimator</option>\n</select>\n</section>\n\n<!-- Algorithm Stepper -->\n<section id=\"algoPanel\">\n  <h2>Algorithm Stepper & Visualizer</h2>\n  <div class=\"control-row\">\n    <label for=\"algoSelect\">Algorithm:</label>\n    <select id=\"algoSelect\">\n      <option value=\"linear\">Linear Search</option>\n      <option value=\"binary\">Binary Search (requires sorted)</option>\n      <option value=\"selection\">Selection Sort</option>\n      <option value=\"insertion\">Insertion Sort</option>\n      <option value=\"merge\">Merge Sort</option>\n      <option value=\"quick\">Quick Sort (random pivot)</option>\n    </select>\n\n    <label for=\"nRange\">n:</label>\n    <input id=\"nRange\" type=\"range\" min=\"1\" max=\"200\" value=\"16\">\n    <input id=\"nInput\" type=\"number\" min=\"1\" max=\"10000\" value=\"16\" style=\"width:70px;\">\n    <label for=\"patternSelect\">Pattern:</label>\n    <select id=\"patternSelect\">\n      <option value=\"random\">Random</option>\n      <option value=\"sorted\">Sorted</option>\n      <option value=\"reversed\">Reversed</option>\n      <option value=\"few\">Few unique</option>\n      <option value=\"almost\">Almost sorted</option>\n    </select>\n    <button id=\"generateBtn\">Generate Input</button>\n    <button id=\"shuffleBtn\">Shuffle</button>\n  </div>\n\n  <div class=\"control-row\">\n    <label for=\"targetInput\">Search target (for search):</label>\n    <input id=\"targetInput\" type=\"number\" style=\"width:90px;\">\n    <button id=\"findBtn\">Place Random Target</button>\n  </div>\n\n  <div class=\"control-row\">\n    <button id=\"stepBtn\">Step</button>\n    <button id=\"prevBtn\">Prev</button>\n    <button id=\"runBtn\">Run</button>\n    <button id=\"pauseBtn\">Pause</button>\n    <button id=\"resetBtn\">Reset</button>\n    <label for=\"speedRange\">Speed:</label>\n    <input id=\"speedRange\" type=\"range\" min=\"1\" max=\"1000\" value=\"250\">\n    <span id=\"statusLabel\"></span>\n  </div>\n\n  <div>\n    <strong>Array:</strong>\n    <pre id=\"arrayView\"></pre>\n  </div>\n\n  <div>\n    <strong>Counters:</strong>\n    <div id=\"counters\">\n      Comparisons: <span id=\"compCount\">0</span>,\n      Swaps: <span id=\"swapCount\">0</span>,\n      Assignments: <span id=\"assignCount\">0</span>,\n      Recursion depth: <span id=\"recDepth\">0</span>,\n      Steps executed: <span id=\"stepsCount\">0</span>\n    </div>\n  </div>\n\n  <div>\n    <strong>Theoretical Complexity:</strong>\n    <div id=\"theory\">Select algorithm to see complexities.</div>\n  </div>\n\n  <div class=\"control-row\">\n    <label for=\"guessInput\">Guess Big-O (e.g. O(n), O(n log n), O(1)):</label>\n    <input id=\"guessInput\" type=\"text\" style=\"width:160px;\">\n    <button id=\"guessBtn\">Check Guess</button>\n    <span id=\"guessResult\"></span>\n  </div>\n\n  <div>\n    <strong>Operation Log (recent):</strong>\n    <pre id=\"opLog\"></pre>\n  </div>\n</section>\n\n<!-- Benchmark Panel -->\n<section id=\"benchPanel\" class=\"hidden\">\n  <h2>Empirical Benchmark</h2>\n\n  <div class=\"control-row\">\n    <label for=\"benchAlgo\">Algorithm:</label>\n    <select id=\"benchAlgo\">\n      <option value=\"selection\">Selection Sort</option>\n      <option value=\"insertion\">Insertion Sort</option>\n      <option value=\"merge\">Merge Sort</option>\n      <option value=\"quick\">Quick Sort</option>\n      <option value=\"native\">JS Native sort</option>\n    </select>\n\n    <label for=\"minN\">min n:</label>\n    <input id=\"minN\" type=\"number\" value=\"16\" style=\"width:70px;\">\n    <label for=\"maxN\">max n:</label>\n    <input id=\"maxN\" type=\"number\" value=\"1024\" style=\"width:90px;\">\n    <label for=\"stepN\">step:</label>\n    <input id=\"stepN\" type=\"number\" value=\"16\" style=\"width:70px;\">\n    <label for=\"trials\">trials:</label>\n    <input id=\"trials\" type=\"number\" value=\"5\" style=\"width:60px;\">\n    <button id=\"runBenchBtn\">Run Benchmark</button>\n  </div>\n\n  <div>\n    <label for=\"benchPattern\">Input pattern:</label>\n    <select id=\"benchPattern\">\n      <option value=\"random\">Random</option>\n      <option value=\"sorted\">Sorted</option>\n      <option value=\"reversed\">Reversed</option>\n      <option value=\"few\">Few unique</option>\n    </select>\n    <button id=\"copyCsv\">Copy CSV</button>\n  </div>\n\n  <div>\n    <strong>Results (n, median ms):</strong>\n    <pre id=\"benchResults\"></pre>\n  </div>\n\n  <div>\n    <strong>Model comparison (lower SSE is better):</strong>\n    <pre id=\"modelResults\"></pre>\n  </div>\n</section>\n\n<!-- Complexity Builder -->\n<section id=\"builderPanel\" class=\"hidden\">\n  <h2>Complexity Builder (Nested Loops)</h2>\n\n  <div class=\"control-row\">\n    <button id=\"addLoop\">Add Loop</button>\n    <button id=\"clearLoops\">Clear</button>\n    <small>Each loop contributes multiplicatively when nested. You can add sequential blocks to sum complexities.</small>\n  </div>\n\n  <div id=\"loopsList\"></div>\n\n  <div class=\"control-row\">\n    <label for=\"blockCost\">Inner block cost (choose expression):</label>\n    <select id=\"blockCost\">\n      <option value=\"1\">1 (constant)</option>\n      <option value=\"n\">n</option>\n      <option value=\"logn\">log n</option>\n      <option value=\"nlogn\">n log n</option>\n      <option value=\"n2\">n^2</option>\n      <option value=\"n3\">n^3</option>\n    </select>\n    <button id=\"addBlock\">Add Sequential Block</button>\n  </div>\n\n  <div>\n    <strong>Built Expression:</strong>\n    <pre id=\"builtExpr\"></pre>\n    <strong>Simplified Big-O:</strong>\n    <div id=\"builtBigO\"></div>\n  </div>\n</section>\n\n<!-- Master Theorem -->\n<section id=\"masterPanel\" class=\"hidden\">\n  <h2>Master Theorem Solver</h2>\n\n  <div>\n    <label for=\"aVal\">a:</label>\n    <input id=\"aVal\" type=\"number\" value=\"2\" style=\"width:60px;\">\n    <label for=\"bVal\">b:</label>\n    <input id=\"bVal\" type=\"number\" value=\"2\" style=\"width:60px;\">\n    <label for=\"fSelect\">f(n):</label>\n    <select id=\"fSelect\">\n      <option value=\"n^0\">1</option>\n      <option value=\"n^0.5\">n^0.5</option>\n      <option value=\"n\">n</option>\n      <option value=\"n log n\">n log n</option>\n      <option value=\"n^2\">n^2</option>\n      <option value=\"n^3\">n^3</option>\n    </select>\n    <button id=\"solveMaster\">Solve</button>\n  </div>\n\n  <div>\n    <pre id=\"masterResult\"></pre>\n  </div>\n</section>\n\n<!-- Custom Pseudocode -->\n<section id=\"customPanel\" class=\"hidden\">\n  <h2>Custom Pseudocode Estimator</h2>\n  <small>Use a simple line-based language. Example:\nfor n\nfor n\ndo 1\nend\n</small>\n  <textarea id=\"pseudoInput\" placeholder=\"Write pseudocode: use 'for n', 'for c' (constant), 'for logn', 'do n', 'do 1' and 'end' to close loops.\"></textarea>\n  <div>\n    <button id=\"parsePseudo\">Parse & Estimate</button>\n    <button id=\"clearPseudo\">Clear</button>\n  </div>\n  <div>\n    <strong>Estimated Complexity:</strong>\n    <pre id=\"pseudoResult\"></pre>\n  </div>\n</section>\n\n<script>\n// Utility helpers\nfunction randint(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\nfunction clone(a){ return a.slice(); }\nfunction formatArrayForView(arr, highlight){ // highlight: {i:true, j:true}\n  var s = '';\n  for(var i=0;i<arr.length;i++){\n    var v = arr[i];\n    var h = (highlight && (highlight[i]||highlight['i']==i||highlight['j']==i)) ? '^' : ' ';\n    s += (('   '+i).slice(-3)) + ':' + ('   '+v).slice(-4) + ' ' + h + '\\n';\n  }\n  return s;\n}\nfunction simpleArrayLine(arr, hl){ // inline one-line\n  var parts=[];\n  for(var i=0;i<arr.length;i++){\n    var v = arr[i];\n    var mark = (hl && hl[i]) ? '<' : ' ';\n    parts.push((''+v)+mark);\n  }\n  return parts.join(' ');\n}\n\n// Algorithm generator interface: yields events and state\n// We'll implement generators for algorithms used in the visualizer\n\n// Linear search\nfunction* genLinearSearch(arr, target, counters){\n  counters.recDepth = 1;\n  for(var i=0;i<arr.length;i++){\n    counters.steps++;\n    yield {type:'mark', i:i, reason:'checking'};\n    counters.comparisons++;\n    yield {type:'compare', i:i, val:arr[i], target:target};\n    if(arr[i] === target){\n      counters.assignments++;\n      yield {type:'found', i:i};\n      counters.recDepth = 0;\n      return i;\n    }\n  }\n  counters.recDepth = 0;\n  yield {type:'complete'};\n  return -1;\n}\n\n// Binary search (iterative)\nfunction* genBinarySearch(arr, target, counters){\n  counters.recDepth = 1;\n  var lo = 0, hi = arr.length - 1;\n  while(lo <= hi){\n    counters.steps++;\n    var mid = Math.floor((lo + hi)/2);\n    yield {type:'markRange', lo:lo, hi:hi, mid:mid};\n    counters.comparisons++;\n    yield {type:'compare', i:mid, val:arr[mid], target:target};\n    if(arr[mid] === target){\n      counters.assignments++;\n      yield {type:'found', i:mid};\n      counters.recDepth = 0;\n      return mid;\n    } else if(arr[mid] < target){\n      lo = mid + 1;\n      yield {type:'move', lo:lo, hi:hi};\n    } else {\n      hi = mid - 1;\n      yield {type:'move', lo:lo, hi:hi};\n    }\n  }\n  counters.recDepth = 0;\n  yield {type:'complete'};\n  return -1;\n}\n\n// Selection sort\nfunction* genSelectionSort(arr, counters){\n  counters.recDepth = 1;\n  var a = arr;\n  for(var i=0;i<a.length-1;i++){\n    var minIdx = i;\n    yield {type:'select', i:i, min:minIdx};\n    for(var j=i+1;j<a.length;j++){\n      counters.steps++;\n      counters.comparisons++;\n      yield {type:'compare', i:j, j:minIdx};\n      if(a[j] < a[minIdx]){\n        minIdx = j;\n        yield {type:'minUpdate', i:j};\n      }\n    }\n    if(minIdx !== i){\n      counters.swaps++;\n      var tmp = a[i]; a[i] = a[minIdx]; a[minIdx] = tmp;\n      counters.assignments += 3;\n      yield {type:'swap', i:i, j:minIdx, array:a.slice()};\n    }\n  }\n  counters.recDepth = 0;\n  yield {type:'complete', array:a.slice()};\n}\n\n// Insertion sort\nfunction* genInsertionSort(arr, counters){\n  counters.recDepth = 1;\n  var a = arr;\n  for(var i=1;i<a.length;i++){\n    var key = a[i];\n    var j = i-1;\n    yield {type:'pick', i:i, key:key};\n    while(j >= 0){\n      counters.steps++;\n      counters.comparisons++;\n      yield {type:'compare', i:j, key:key};\n      if(a[j] > key){\n        a[j+1] = a[j];\n        counters.assignments++;\n        yield {type:'shift', from:j, to:j+1, array:a.slice()};\n        j--;\n      } else break;\n    }\n    a[j+1] = key;\n    counters.assignments++;\n    yield {type:'insert', pos:j+1, key:key, array:a.slice()};\n  }\n  counters.recDepth = 0;\n  yield {type:'complete', array:a.slice()};\n}\n\n// Merge sort (recursive generator wrapper)\nfunction* genMergeSort(arr, counters){\n  counters.recDepth = 0;\n  function* mergeRange(a, l, r, depth){\n    counters.recDepth = Math.max(counters.recDepth, depth);\n    if(r - l <= 1){\n      return a.slice(l,r);\n    }\n    var m = Math.floor((l + r)/2);\n    var left = yield* mergeRange(a, l, m, depth+1);\n    var right = yield* mergeRange(a, m, r, depth+1);\n    var i=0,j=0, res=[];\n    while(i<left.length || j<right.length){\n      counters.steps++;\n      if(i<left.length && j<right.length){\n        counters.comparisons++;\n        yield {type:'compareVal', left:left[i], right:right[j], lindex:l+i, rindex:m+j};\n        if(left[i] <= right[j]){\n          res.push(left[i]); i++;\n          counters.assignments++;\n          yield {type:'write', val:res[res.length-1], index:l+res.length-1};\n        } else {\n          res.push(right[j]); j++;\n          counters.assignments++;\n          yield {type:'write', val:res[res.length-1], index:l+res.length-1};\n        }\n      } else if(i<left.length){\n        res.push(left[i]); i++; counters.assignments++;\n        yield {type:'write', val:res[res.length-1], index:l+res.length-1};\n      } else {\n        res.push(right[j]); j++; counters.assignments++;\n        yield {type:'write', val:res[res.length-1], index:l+res.length-1};\n      }\n    }\n    return res;\n  }\n  var result = yield* mergeRange(arr, 0, arr.length, 1);\n  // copy back\n  for(var i=0;i<result.length;i++){\n    arr[i]=result[i];\n  }\n  counters.recDepth = 0;\n  yield {type:'complete', array:arr.slice()};\n}\n\n// Quick sort (random pivot) generator\nfunction* genQuickSort(arr, counters){\n  counters.recDepth = 0;\n  function* quick(a, l, r, depth){\n    counters.recDepth = Math.max(counters.recDepth, depth);\n    if(l>=r) return;\n    var pivotIndex = randint(l,r);\n    var pivot = a[pivotIndex];\n    yield {type:'pivot', index:pivotIndex, val:pivot};\n    var i = l, j = r;\n    while(i<=j){\n      while(a[i] < pivot){\n        counters.steps++; counters.comparisons++;\n        yield {type:'compare', i:i, pivot:pivot};\n        i++;\n      }\n      while(a[j] > pivot){\n        counters.steps++; counters.comparisons++;\n        yield {type:'compare', i:j, pivot:pivot};\n        j--;\n      }\n      if(i<=j){\n        if(i!==j){\n          var tmp = a[i]; a[i]=a[j]; a[j]=tmp;\n          counters.swaps++; counters.assignments+=3;\n          yield {type:'swap', i:i, j:j, array:a.slice()};\n        }\n        i++; j--;\n      }\n    }\n    if(l < j) yield* quick(a, l, j, depth+1);\n    if(i < r) yield* quick(a, i, r, depth+1);\n  }\n  yield* quick(arr, 0, arr.length-1, 1);\n  counters.recDepth = 0;\n  yield {type:'complete', array:arr.slice()};\n}\n\n// Map algorithm id to generator factory and theoretical complexities\nvar ALGO_MAP = {\n  linear: {gen: genLinearSearch, theory: {best:'O(1)', avg:'O(n)', worst:'O(n)'}},\n  binary: {gen: genBinarySearch, theory: {best:'O(1)', avg:'O(log n)', worst:'O(log n)'}},\n  selection: {gen: genSelectionSort, theory: {best:'O(n^2)', avg:'O(n^2)', worst:'O(n^2)'}},\n  insertion: {gen: genInsertionSort, theory: {best:'O(n)', avg:'O(n^2)', worst:'O(n^2)'}},\n  merge: {gen: genMergeSort, theory: {best:'O(n log n)', avg:'O(n log n)', worst:'O(n log n)'}},\n  quick: {gen: genQuickSort, theory: {best:'O(n log n)', avg:'O(n log n)', worst:'O(n^2)'}}\n};\n\n// UI wiring for algorithm panel\nvar nRange = document.getElementById('nRange');\nvar nInput = document.getElementById('nInput');\nnRange.addEventListener('input', function(){ nInput.value = nRange.value; });\nnInput.addEventListener('change', function(){ var v = Number(nInput.value); if(isNaN(v)||v<1) v=1; if(v>10000) v=10000; nInput.value=v; nRange.value = Math.min(v, nRange.max); });\n\nvar generateBtn = document.getElementById('generateBtn');\nvar shuffleBtn = document.getElementById('shuffleBtn');\nvar arrayView = document.getElementById('arrayView');\nvar compCount = document.getElementById('compCount');\nvar swapCount = document.getElementById('swapCount');\nvar assignCount = document.getElementById('assignCount');\nvar recDepth = document.getElementById('recDepth');\nvar stepsCount = document.getElementById('stepsCount');\nvar opLog = document.getElementById('opLog');\nvar theory = document.getElementById('theory');\nvar statusLabel = document.getElementById('statusLabel');\n\nvar stepBtn = document.getElementById('stepBtn');\nvar prevBtn = document.getElementById('prevBtn');\nvar runBtn = document.getElementById('runBtn');\nvar pauseBtn = document.getElementById('pauseBtn');\nvar resetBtn = document.getElementById('resetBtn');\nvar speedRange = document.getElementById('speedRange');\n\nvar algoSelect = document.getElementById('algoSelect');\nvar patternSelect = document.getElementById('patternSelect');\nvar targetInput = document.getElementById('targetInput');\nvar findBtn = document.getElementById('findBtn');\n\nvar guessInput = document.getElementById('guessInput');\nvar guessBtn = document.getElementById('guessBtn');\nvar guessResult = document.getElementById('guessResult');\n\nvar currentArray = [];\nvar originalArray = [];\nvar currentGen = null;\nvar currentCounters = null;\nvar runInterval = null;\nvar history = []; // store snapshots for prev\n\nfunction updateTheory(){\n  var alg = algoSelect.value;\n  var t = ALGO_MAP[alg].theory;\n  theory.textContent = 'Best: ' + t.best + ', Average: ' + t.avg + ', Worst: ' + t.worst;\n}\nupdateTheory();\nalgoSelect.addEventListener('change', updateTheory);\n\nfunction makeArray(n, pattern){\n  var a = [];\n  if(pattern === 'random') for(var i=0;i<n;i++) a.push(randint(0,999));\n  else if(pattern === 'sorted'){ for(var i=0;i<n;i++) a.push(i); }\n  else if(pattern === 'reversed'){ for(var i=0;i<n;i++) a.push(n-i); }\n  else if(pattern === 'few'){ for(var i=0;i<n;i++) a.push(randint(0,4)); }\n  else if(pattern === 'almost'){ for(var i=0;i<n;i++) a.push(i); for(var i=0;i<Math.floor(n*0.05);i++){ var x=randint(0,n-1), y=randint(0,n-1); var t=a[x];a[x]=a[y];a[y]=t; } }\n  return a;\n}\n\nfunction renderArrayView(arr, highlight){\n  var s = '';\n  // display as one-line values with index markers minimal\n  for(var i=0;i<arr.length;i++){\n    var mark = (highlight && highlight[i]) ? '<' : ' ';\n    s += ('[' + i + ']' + ':' + arr[i] + mark + ' ');\n    if(i%16===15) s += '\\n';\n  }\n  arrayView.textContent = s;\n}\n\ngenerateBtn.addEventListener('click', function(){\n  var n = Number(nInput.value);\n  if(n < 1) n = 1;\n  if(n > 5000) n = 5000;\n  currentArray = makeArray(n, patternSelect.value);\n  originalArray = currentArray.slice();\n  resetExecution();\n  renderArrayView(currentArray);\n});\n\nshuffleBtn.addEventListener('click', function(){\n  for(var i=0;i<currentArray.length;i++){\n    var j = randint(0,currentArray.length-1);\n    var t = currentArray[i]; currentArray[i]=currentArray[j]; currentArray[j]=t;\n  }\n  originalArray = currentArray.slice();\n  resetExecution();\n  renderArrayView(currentArray);\n});\n\nfindBtn.addEventListener('click', function(){\n  if(currentArray.length===0) return;\n  var idx = randint(0,currentArray.length-1);\n  targetInput.value = currentArray[idx];\n});\n\nfunction resetExecution(){\n  if(runInterval) { clearInterval(runInterval); runInterval = null; }\n  currentGen = null;\n  currentCounters = null;\n  history = [];\n  compCount.textContent = '0'; swapCount.textContent='0'; assignCount.textContent='0'; recDepth.textContent='0'; stepsCount.textContent='0'; opLog.textContent='';\n  statusLabel.textContent = '';\n}\n\nfunction prepareGenerator(){\n  resetExecution();\n  var alg = algoSelect.value;\n  var f = ALGO_MAP[alg].gen;\n  currentCounters = {comparisons:0, swaps:0, assignments:0, recDepth:0, steps:0};\n  var arrCopy = currentArray.slice();\n  if(alg === 'linear' || alg === 'binary'){\n    var target = Number(targetInput.value);\n    if(isNaN(target)) target = currentArray.length>0 ? currentArray[0] : 0;\n    currentGen = f(arrCopy, target, currentCounters);\n  } else {\n    currentGen = f(arrCopy, currentCounters);\n  }\n  // save initial snapshot\n  history.push({arr:arrCopy.slice(), counters:JSON.parse(JSON.stringify(currentCounters)), desc:'start'});\n  updateCountersDisplay();\n}\n\nfunction updateCountersDisplay(){\n  compCount.textContent = currentCounters ? currentCounters.comparisons : '0';\n  swapCount.textContent = currentCounters ? currentCounters.swaps : '0';\n  assignCount.textContent = currentCounters ? currentCounters.assignments : '0';\n  recDepth.textContent = currentCounters ? currentCounters.recDepth : '0';\n  stepsCount.textContent = currentCounters ? currentCounters.steps : '0';\n}\n\nfunction stepOnce(){\n  if(!currentGen){\n    prepareGenerator();\n  }\n  var res = currentGen.next();\n  if(res.done){\n    logOperation('done: ' + JSON.stringify(res.value || 'finished'));\n    if(res.value && res.value.array) renderArrayView(res.value.array);\n    updateCountersDisplay();\n    currentGen = null;\n    return;\n  } else {\n    handleEvent(res.value);\n  }\n}\n\nfunction handleEvent(ev){\n  if(!ev) return;\n  if(ev.array) renderArrayView(ev.array, null);\n  switch(ev.type){\n    case 'mark':\n      renderArrayView(history[history.length-1].arr, {[ev.i]:true});\n      logOperation('mark index ' + ev.i + ' ('+ (ev.reason||'') +')');\n      break;\n    case 'compare':\n      logOperation('compare i:' + ev.i + (ev.j!==undefined ? (' j:'+ev.j) : '') + ' val:'+(ev.val!==undefined?ev.val:'') + (ev.target!==undefined?(' target:'+ev.target):''));\n      if(ev.j!==undefined){\n        renderArrayView(history[history.length-1].arr, {[ev.i]:true, [ev.j]:true});\n      } else renderArrayView(history[history.length-1].arr, {[ev.i]:true});\n      break;\n    case 'compareVal':\n      logOperation('compare values ' + ev.left + ' and ' + ev.right);\n      break;\n    case 'found':\n      logOperation('found at ' + ev.i);\n      var arr = history[history.length-1].arr.slice();\n      arr[ev.i] = arr[ev.i] + ' (FOUND)';\n      renderArrayView(arr, {[ev.i]:true});\n      break;\n    case 'select':\n      logOperation('select position ' + ev.i);\n      break;\n    case 'minUpdate':\n      logOperation('min updated to ' + ev.i);\n      break;\n    case 'swap':\n      logOperation('swap ' + ev.i + ' and ' + ev.j);\n      if(ev.array) renderArrayView(ev.array, {[ev.i]:true, [ev.j]:true});\n      break;\n    case 'pick':\n      logOperation('pick key at ' + ev.i + ' val ' + ev.key);\n      break;\n    case 'shift':\n      logOperation('shift from ' + ev.from + ' to ' + ev.to);\n      if(ev.array) renderArrayView(ev.array, {[ev.to]:true});\n      break;\n    case 'insert':\n      logOperation('insert key at ' + ev.pos);\n      if(ev.array) renderArrayView(ev.array, {[ev.pos]:true});\n      break;\n    case 'write':\n      logOperation('write val ' + ev.val + ' at ' + ev.index);\n      break;\n    case 'pivot':\n      logOperation('pivot chosen at ' + ev.index + ' val ' + ev.val);\n      break;\n    case 'markRange':\n      logOperation('range ['+ev.lo+','+ev.hi+'] mid '+ev.mid);\n      break;\n    case 'move':\n      logOperation('move range to ['+ev.lo+','+ev.hi+']');\n      break;\n    case 'complete':\n      logOperation('complete');\n      if(ev.array) renderArrayView(ev.array);\n      break;\n    default:\n      logOperation('event: ' + JSON.stringify(ev));\n  }\n  // capture snapshot\n  var arrSnapshot = null;\n  if(ev.array) arrSnapshot = ev.array.slice();\n  else if(history.length>0) arrSnapshot = history[history.length-1].arr.slice();\n  else arrSnapshot = currentArray.slice();\n  history.push({arr:arrSnapshot, counters:JSON.parse(JSON.stringify(currentCounters)), desc:ev.type});\n  updateCountersDisplay();\n}\n\nfunction logOperation(s){\n  opLog.textContent = (new Date()).toISOString().split('T')[1].slice(0,12) + ' ' + s + '\\n' + opLog.textContent;\n  if(opLog.textContent.length > 5000) opLog.textContent = opLog.textContent.slice(0,5000);\n}\n\nstepBtn.addEventListener('click', function(){ stepOnce(); });\n\nprevBtn.addEventListener('click', function(){\n  if(history.length <= 1) return;\n  history.pop();\n  var cur = history[history.length-1];\n  renderArrayView(cur.arr || currentArray, null);\n  if(cur.counters){\n    currentCounters = JSON.parse(JSON.stringify(cur.counters));\n    updateCountersDisplay();\n  }\n});\n\nrunBtn.addEventListener('click', function(){\n  if(runInterval) return;\n  if(!currentGen) prepareGenerator();\n  var speed = Number(speedRange.value) || 250;\n  runInterval = setInterval(function(){\n    try {\n      var res = currentGen.next();\n      if(res.done){\n        logOperation('done');\n        if(res.value && res.value.array) renderArrayView(res.value.array);\n        clearInterval(runInterval); runInterval = null; currentGen = null;\n        updateCountersDisplay();\n      } else handleEvent(res.value);\n    } catch(e){\n      logOperation('error: ' + e);\n      clearInterval(runInterval); runInterval = null; currentGen = null;\n    }\n  }, Math.max(1, 1000 - speed)); // speed slider: higher is faster\n});\n\npauseBtn.addEventListener('click', function(){\n  if(runInterval){ clearInterval(runInterval); runInterval = null; }\n});\n\nresetBtn.addEventListener('click', function(){\n  currentArray = originalArray.slice();\n  resetExecution();\n  renderArrayView(currentArray);\n});\n\nguessBtn.addEventListener('click', function(){\n  var alg = algoSelect.value;\n  var expected = ALGO_MAP[alg].theory;\n  var guess = guessInput.value.toLowerCase();\n  var ok = false;\n  // crude matching: look for terms\n  function norm(s){ return s.replace(/[^a-z0-9\\s\\^\\*\\+\\-]/g,''); }\n  var e = (expected.avg || expected.worst || expected.best).toLowerCase();\n  var ng = norm(guess);\n  var ne = norm(e);\n  // Accept several equivalent notations\n  var check = function(g, target){\n    if(g.indexOf('log')>=0 && target.indexOf('log')>=0) return true;\n    if(/\\bn\\b/.test(g) && /\\bn\\b/.test(target) && g.indexOf('^2')>=0 === (target.indexOf('^2')>=0)) {\n      // both poly; relax\n    }\n    // match simpler tokens\n    var tokens = ['n^3','n^2','n log n','n','log n','1','n^0'];\n    for(var t of tokens){\n      if(g.indexOf(t)>=0 && target.indexOf(t)>=0) return true;\n    }\n    // fallback iterate basic forms\n    if(g.indexOf('n^2')>=0 && target.indexOf('n^2')>=0) return true;\n    if(g.indexOf('n log')>=0 && target.indexOf('n log')>=0) return true;\n    if(g.indexOf('n')>=0 && target.indexOf('n')>=0 && target.indexOf('^2')<0 && target.indexOf('log')<0) return true;\n    if(g.indexOf('log')>=0 && target.indexOf('log')>=0) return true;\n    if(g.indexOf('1')>=0 && /^[^\\w]*$/.test(target) ) return true;\n    return false;\n  };\n  ok = check(ng, ne);\n  guessResult.textContent = ok ? '✔ Guess plausible for average case ('+e+')' : '✖ Guess does not match average case ('+e+')';\n});\n\n// Initialize with default array\ngenerateBtn.click();\n\n\n// -------------------- Benchmark Panel --------------------\nvar benchPanel = document.getElementById('benchPanel');\nvar benchAlgo = document.getElementById('benchAlgo');\nvar minN = document.getElementById('minN');\nvar maxN = document.getElementById('maxN');\nvar stepN = document.getElementById('stepN');\nvar trialsInput = document.getElementById('trials');\nvar runBenchBtn = document.getElementById('runBenchBtn');\nvar benchResults = document.getElementById('benchResults');\nvar modelResults = document.getElementById('modelResults');\nvar benchPattern = document.getElementById('benchPattern');\nvar copyCsv = document.getElementById('copyCsv');\n\nfunction sortNative(a){\n  return a.sort(function(x,y){ return x - y; });\n}\n\nfunction runAlgorithmById(id, arr){\n  var a = arr.slice();\n  if(id === 'selection'){\n    // simple selection sort implementation\n    for(var i=0;i<a.length-1;i++){\n      var min = i;\n      for(var j=i+1;j<a.length;j++) if(a[j] < a[min]) min = j;\n      var t = a[i]; a[i]=a[min]; a[min]=t;\n    }\n    return a;\n  } else if(id === 'insertion'){\n    for(var i=1;i<a.length;i++){\n      var key = a[i]; var j = i-1;\n      while(j>=0 && a[j] > key){ a[j+1]=a[j]; j--; }\n      a[j+1] = key;\n    }\n    return a;\n  } else if(id === 'merge'){\n    // basic merge sort\n    function ms(a){\n      if(a.length<=1) return a;\n      var m = Math.floor(a.length/2);\n      var l = ms(a.slice(0,m));\n      var r = ms(a.slice(m));\n      var i=0,j=0, res=[];\n      while(i<l.length || j<r.length){\n        if(i<l.length && j<r.length){\n          if(l[i] <= r[j]) res.push(l[i++]); else res.push(r[j++]);\n        } else if(i<l.length) res.push(l[i++]); else res.push(r[j++]);\n      }\n      return res;\n    }\n    return ms(a);\n  } else if(id === 'quick'){\n    function qs(a){\n      if(a.length<=1) return a;\n      var p = a[Math.floor(Math.random()*a.length)];\n      var left=[], mid=[], right=[];\n      for(var i=0;i<a.length;i++){\n        if(a[i] < p) left.push(a[i]);\n        else if(a[i] > p) right.push(a[i]);\n        else mid.push(a[i]);\n      }\n      return qs(left).concat(mid).concat(qs(right));\n    }\n    return qs(a);\n  } else if(id === 'native'){\n    return sortNative(a);\n  } else return arr;\n}\n\nfunction measureTimeAlgorithm(id, n, pattern){\n  var arr = makeArray(n, pattern);\n  var t0 = performance.now();\n  runAlgorithmById(id, arr);\n  var t1 = performance.now();\n  return t1 - t0;\n}\n\nrunBenchBtn.addEventListener('click', async function(){\n  benchResults.textContent = 'Running...';\n  modelResults.textContent = '';\n  var id = benchAlgo.value;\n  var mn = Number(minN.value), mx = Number(maxN.value), step = Number(stepN.value), trials = Number(trialsInput.value);\n  var pattern = benchPattern.value;\n  var results = [];\n  for(var n=mn; n<=mx; n+=step){\n    var times = [];\n    for(var t=0;t<trials;t++){\n      // try to yield to UI occasionally\n      await new Promise(function(resolve){ setTimeout(resolve, 0); });\n      var dt = measureTimeAlgorithm(id, n, pattern);\n      times.push(dt);\n    }\n    times.sort(function(a,b){return a-b;});\n    var median = times[Math.floor(times.length/2)];\n    results.push({n:n, median:median, raw:times});\n    benchResults.textContent = results.map(r => r.n + ', ' + r.median.toFixed(4)).join('\\n');\n  }\n  // Model comparison: fit against candidate functions\n  var models = [\n    {name:'O(1)', fn: function(n){ return 1; }},\n    {name:'O(log n)', fn: function(n){ return Math.log(n+1); }},\n    {name:'O(n)', fn: function(n){ return n; }},\n    {name:'O(n log n)', fn: function(n){ return n * Math.log(n+1); }},\n    {name:'O(n^2)', fn: function(n){ return n*n; }},\n    {name:'O(n^3)', fn: function(n){ return n*n*n; }}\n  ];\n  // build arrays\n  var xs = results.map(r => r.n);\n  var ys = results.map(r => r.median);\n  // normalize each model to scale by least squares linear fit (alpha * model(n) ~ t)\n  var modelScores = [];\n  for(var m of models){\n    var ms = xs.map(m.fn);\n    // solve alpha via least squares: alpha = sum(ms_i * ys_i) / sum(ms_i^2)\n    var num=0, den=0;\n    for(var i=0;i<ms.length;i++){ num += ms[i]*ys[i]; den += ms[i]*ms[i]; }\n    var alpha = den===0?0:(num/den);\n    // compute SSE\n    var sse=0;\n    for(var i=0;i<ms.length;i++){\n      var pred = alpha * ms[i];\n      var e = ys[i]-pred; sse += e*e;\n    }\n    modelScores.push({name:m.name, alpha:alpha, sse:sse});\n  }\n  modelScores.sort(function(a,b){return a.sse - b.sse;});\n  modelResults.textContent = modelScores.map(m => m.name + ' alpha=' + m.alpha.toFixed(6) + ' sse=' + m.sse.toFixed(6)).join('\\n');\n  // store last CSV in benchResults for copy\n  benchPanel._lastCsv = 'n,median\\n' + results.map(r => r.n + ',' + r.median).join('\\n');\n});\n\ncopyCsv.addEventListener('click', function(){\n  if(benchPanel._lastCsv){\n    navigator.clipboard && navigator.clipboard.writeText(benchPanel._lastCsv);\n    alert('CSV copied to clipboard');\n  } else alert('No CSV available');\n});\n\n// -------------------- Builder Panel --------------------\nvar builderPanel = document.getElementById('builderPanel');\nvar addLoopBtn = document.getElementById('addLoop');\nvar loopsList = document.getElementById('loopsList');\nvar clearLoops = document.getElementById('clearLoops');\nvar blockCost = document.getElementById('blockCost');\nvar addBlock = document.getElementById('addBlock');\nvar builtExpr = document.getElementById('builtExpr');\nvar builtBigO = document.getElementById('builtBigO');\n\nvar builderState = {sequence: []}; // each entry {type:'loop', expr: 'n'|'c'|'logn'|...} or {type:'block', expr:...}\n\nfunction renderBuilder(){\n  loopsList.innerHTML = '';\n  builderState.sequence.forEach(function(item, idx){\n    var div = document.createElement('div');\n    div.textContent = (idx+1) + '. ' + (item.type === 'loop' ? ('loop over ' + item.expr) : ('block cost ' + item.expr));\n    var del = document.createElement('button'); del.textContent = 'Delete';\n    del.addEventListener('click', function(){ builderState.sequence.splice(idx,1); renderBuilder(); computeBigO(); });\n    div.appendChild(del);\n    // allow nesting conversion: Add nested loop inside this index by inserting following\n    var nestBtn = document.createElement('button'); nestBtn.textContent = 'Nest after';\n    nestBtn.addEventListener('click', function(){ builderState.sequence.splice(idx+1,0,{type:'loop', expr:'n'}); renderBuilder(); computeBigO(); });\n    div.appendChild(nestBtn);\n    loopsList.appendChild(div);\n  });\n  computeBigO();\n}\n\naddLoopBtn.addEventListener('click', function(){\n  builderState.sequence.push({type:'loop', expr:'n'});\n  renderBuilder();\n});\nclearLoops.addEventListener('click', function(){ builderState.sequence = []; renderBuilder(); });\n\naddBlock.addEventListener('click', function(){\n  builderState.sequence.push({type:'block', expr:blockCost.value});\n  renderBuilder();\n});\n\nfunction computeBigO(){\n  // compute big-O: multiply nested consecutive loops; sum sequential blocks/loop-groups\n  var groups = [];\n  var i=0;\n  while(i<builderState.sequence.length){\n    if(builderState.sequence[i].type === 'loop'){\n      var mult = 1; var factors=[];\n      while(i<builderState.sequence.length && builderState.sequence[i].type === 'loop'){\n        factors.push(builderState.sequence[i].expr);\n        i++;\n      }\n      groups.push({type:'prod', factors:factors});\n    } else {\n      groups.push({type:'add', factor:builderState.sequence[i].expr});\n      i++;\n    }\n  }\n  // convert each group to symbolic string\n  var groupStr = groups.map(function(g){\n    if(g.type === 'prod'){\n      return g.factors.join(' * ');\n    } else return g.factor;\n  }).join(' + ');\n  builtExpr.textContent = groupStr || '1';\n  // Simplify to Big-O: transform expression by converting tokens\n  // For multiplication: count n factors exponent\n  function tokenToPower(tok){\n    if(tok === 'n') return {poly:1, log:0, const:1};\n    if(tok === 'logn') return {poly:0, log:1, const:1};\n    if(tok === 'nlogn') return {poly:1, log:1, const:1};\n    if(tok === 'n2' || tok === 'n^2') return {poly:2, log:0, const:1};\n    if(tok === 'n3' || tok === 'n^3') return {poly:3, log:0, const:1};\n    if(tok === '1') return {poly:0, log:0, const:1};\n    return {poly:0, log:0, const:1};\n  }\n  var terms = groups.map(function(g){\n    if(g.type === 'prod'){\n      var poly=0, log=0;\n      g.factors.forEach(function(f){ var t=tokenToPower(f); poly+=t.poly; log+=t.log; });\n      var s = 'n';\n      if(poly !== 1) s = 'n^' + poly;\n      if(poly === 0) s = '';\n      if(log>0) s += (s? ' log^'+log : 'log^'+log);\n      if(s==='') s='1';\n      return s;\n    } else {\n      var t = tokenToPower(g.factor);\n      var s = 'n';\n      if(t.poly !== 1) s = 'n^'+t.poly;\n      if(t.poly === 0) s = '';\n      if(t.log>0) s += (s? ' log^'+t.log : 'log^'+t.log);\n      if(s==='') s='1';\n      return s;\n    }\n  });\n  // Big-O is sum of terms -> dominant term with highest polynomial degree then logs\n  var best = terms[0] || '1';\n  var bestScore = -1;\n  terms.forEach(function(t){\n    var m = t.match(/n\\^(\\d+)/);\n    var poly = m ? Number(m[1]) : (t.indexOf('n')>=0 ? 1 : 0);\n    var lg = 0;\n    var lgm = t.match(/log\\^?(\\d+)/);\n    if(lgm) lg = Number(lgm[1]);\n    var score = poly*100 + lg;\n    if(score > bestScore){ bestScore = score; best = t; }\n  });\n  builtBigO.textContent = 'O(' + best + ')';\n}\n\nrenderBuilder();\n\n// -------------------- Master Theorem Panel --------------------\nvar masterPanelEl = document.getElementById('masterPanel');\nvar aVal = document.getElementById('aVal');\nvar bVal = document.getElementById('bVal');\nvar fSelect = document.getElementById('fSelect');\nvar solveMaster = document.getElementById('solveMaster');\nvar masterResult = document.getElementById('masterResult');\n\nsolveMaster.addEventListener('click', function(){\n  var a = Number(aVal.value), b = Number(bVal.value);\n  var f = fSelect.value;\n  // represent f(n) as n^c * log^k\n  var c=0,k=0;\n  if(f === '1') { c=0; k=0; }\n  if(f === 'n^0.5') { c=0.5; k=0; }\n  if(f === 'n') { c=1; k=0; }\n  if(f === 'n log n') { c=1; k=1; }\n  if(f === 'n^2') { c=2; k=0; }\n  if(f === 'n^3') { c=3; k=0; }\n  var log_b_a = Math.log(a) / Math.log(b);\n  var result = '';\n  result += 'Given T(n) = ' + a + ' T(n/' + b + ') + f(n), with f(n) ~ n^' + c + ' log^' + k + '\\n';\n  result += 'n^{log_b a} = n^' + (log_b_a.toFixed(6)) + '\\n';\n  if(c < log_b_a - 1e-9){\n    result += 'Case 1: f(n) = O(n^{log_b a - eps}). Solution: T(n) = Theta(n^{log_b a})\\n';\n  } else if(Math.abs(c - log_b_a) < 1e-9){\n    result += 'Case 2: f(n) = Theta(n^{log_b a} log^k n). Solution: T(n) = Theta(n^{log_b a} log^{k+1} n)\\n';\n  } else {\n    result += 'Case 3: f(n) = Omega(n^{log_b a + eps}). If regularity holds, T(n) = Theta(f(n))\\n';\n  }\n  masterResult.textContent = result;\n});\n\n// -------------------- Custom Pseudocode Parser --------------------\nvar pseudoInput = document.getElementById('pseudoInput');\nvar parsePseudo = document.getElementById('parsePseudo');\nvar pseudoResult = document.getElementById('pseudoResult');\nvar clearPseudo = document.getElementById('clearPseudo');\n\nparsePseudo.addEventListener('click', function(){\n  var txt = pseudoInput.value;\n  var lines = txt.split('\\n').map(l=>l.trim()).filter(l=>l.length>0);\n  // We'll parse a very small language: 'for n', 'for c', 'for logn', 'do n', 'do 1', 'end'\n  try {\n    var stack = [{type:'block', terms:[]}] ; // each block has terms array; nested loops multiply\n    lines.forEach(function(line){\n      if(line.startsWith('for ')){\n        var tok = line.slice(4).trim();\n        stack.push({type:'loop', tok:tok});\n      } else if(line.startsWith('do ')){\n        var tok = line.slice(3).trim();\n        // attach as a term to current block\n        var top = stack[stack.length-1];\n        if(top.type === 'loop'){\n          // convert loop to a block with inner term multiply\n          top.inner = top.inner || [];\n          top.inner.push({type:'do', tok:tok});\n        } else {\n          top.terms.push({type:'do', tok:tok});\n        }\n      } else if(line === 'end'){\n        var completed = stack.pop();\n        if(completed.type === 'loop'){\n          // translate loop to a composite term like tok * inner or tok * 1\n          var inner = completed.inner && completed.inner.length>0 ? completed.inner : [{type:'do', tok:'1'}];\n          // produce a single combined term for the enclosing block\n          var term = {type:'composite', loopTok:completed.tok, inner:inner};\n          stack[stack.length-1].terms.push(term);\n        } else {\n          // end of block - ignore\n        }\n      } else {\n        throw 'Unknown line: ' + line;\n      }\n    });\n    // Now reduce stack[0].terms into an expression and compute Big-O\n    function termToPower(t){\n      // returns {poly:power, log:power}\n      function tokToPow(tok){\n        if(tok==='n') return {poly:1, log:0};\n        if(tok==='logn') return {poly:0, log:1};\n        if(tok==='n^2' || tok==='n2') return {poly:2, log:0};\n        if(tok==='n^3' || tok==='n3') return {poly:3, log:0};\n        if(tok==='1' || tok==='c') return {poly:0, log:0};\n        return {poly:0, log:0};\n      }\n      if(t.type==='do'){\n        return tokToPow(t.tok);\n      } else if(t.type==='composite'){\n        var loopPow = tokToPow(t.loopTok);\n        var innerPow = {poly:0, log:0};\n        t.inner.forEach(function(it){\n          var p = (it.type==='do') ? tokToPow(it.tok) : {poly:0, log:0};\n          innerPow.poly += p.poly;\n          innerPow.log += p.log;\n        });\n        return {poly: loopPow.poly + innerPow.poly, log: loopPow.log + innerPow.log};\n      }\n      return {poly:0, log:0};\n    }\n    var terms = stack[0].terms.map(termToPower);\n    // choose dominant\n    var best = terms[0] || {poly:0, log:0};\n    var idx = 0;\n    for(var i=1;i<terms.length;i++){\n      var a = terms[i];\n      if(a.poly > best.poly || (a.poly===best.poly && a.log > best.log)){ best = a; idx=i; }\n    }\n    var s = 'O(';\n    if(best.poly === 0 && best.log === 0) s += '1';\n    else { if(best.poly>0) s += 'n' + (best.poly>1 ? '^'+best.poly : ''); if(best.log>0) s += (best.poly>0 ? ' log^'+best.log : 'log^'+best.log); }\n    s += ')';\n    pseudoResult.textContent = s;\n  } catch(e){\n    pseudoResult.textContent = 'Error parsing: ' + e;\n  }\n});\n\nclearPseudo.addEventListener('click', function(){ pseudoInput.value=''; pseudoResult.textContent=''; });\n\n// -------------------- Mode switching --------------------\nvar modeSelect = document.getElementById('modeSelect');\nmodeSelect.addEventListener('change', function(){\n  var m = modeSelect.value;\n  document.getElementById('algoPanel').classList.toggle('hidden', m !== 'algo');\n  document.getElementById('benchPanel').classList.toggle('hidden', m !== 'bench');\n  document.getElementById('builderPanel').classList.toggle('hidden', m !== 'builder');\n  document.getElementById('masterPanel').classList.toggle('hidden', m !== 'master');\n  document.getElementById('customPanel').classList.toggle('hidden', m !== 'custom');\n});\n\n// End of script\n</script>\n</body>\n</html>"
