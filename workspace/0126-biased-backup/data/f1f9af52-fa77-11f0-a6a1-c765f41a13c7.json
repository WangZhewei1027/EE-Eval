    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Asymmetric Cryptography — Visual Demonstration</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071028;\n    --glass: rgba(255,255,255,0.06);\n    --accent: #7dd3fc;\n    --accent-2: #a78bfa;\n    --gold: #f6c85f;\n    --muted: rgba(255,255,255,0.6);\n    --card: rgba(255,255,255,0.03);\n    --success: #6ee7b7;\n    --danger: #fb7185;\n    --glass-border: rgba(255,255,255,0.06);\n    color-scheme: dark;\n    font-family: -apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;\n  }\n\n  *{box-sizing:border-box}\n  html,body{height:100%;margin:0;background: radial-gradient(1200px 600px at 10% 10%, rgba(122,92,255,0.08), transparent),\n  radial-gradient(1000px 600px at 90% 90%, rgba(125,211,252,0.05), transparent), linear-gradient(180deg,var(--bg-1),var(--bg-2)); color:#e6eef8; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;}\n  .app{\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    gap:32px;\n  }\n\n  .card{\n    width:1120px;\n    max-width:100%;\n    border-radius:18px;\n    padding:28px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 12px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border: 1px solid var(--glass-border);\n    display:grid;\n    grid-template-columns: 48% 52%;\n    gap:28px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* subtle animated glare */\n  .card::before{\n    content:\"\";\n    position:absolute;\n    left:-20%;\n    top:-40%;\n    width:160%;\n    height:160%;\n    background: linear-gradient(120deg, rgba(167,139,250,0.06), rgba(125,211,252,0.04), transparent);\n    transform: rotate(-8deg);\n    animation: drift 12s linear infinite;\n    pointer-events:none;\n  }\n  @keyframes drift{\n    0%{transform: translateX(0) rotate(-8deg)}\n    50%{transform: translateX(-3%) rotate(-5deg)}\n    100%{transform: translateX(0) rotate(-8deg)}\n  }\n\n  /* Left column content (title & description) */\n  .meta{\n    padding:28px;\n    display:flex;\n    flex-direction:column;\n    justify-content:center;\n    gap:18px;\n    position:relative;\n    z-index:2;\n  }\n  h1{\n    margin:0;\n    font-size:30px;\n    letter-spacing:-0.02em;\n    background: linear-gradient(90deg,var(--accent),var(--accent-2));\n    -webkit-background-clip:text;\n    background-clip:text;\n    color:transparent;\n    font-weight:700;\n  }\n  p.lead{\n    margin:0;\n    color:var(--muted);\n    font-size:14px;\n    line-height:1.5;\n    max-width:36ch;\n  }\n\n  .controls{\n    margin-top:8px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    flex-wrap:wrap;\n  }\n  .btn{\n    -webkit-tap-highlight-color: transparent;\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    border-radius:12px;\n    padding:10px 14px;\n    font-size:13px;\n    cursor:pointer;\n    border:1px solid transparent;\n    transition: transform .18s cubic-bezier(.2,.9,.3,1), box-shadow .18s, opacity .18s;\n    user-select:none;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 6px 20px rgba(2,6,23,0.45);\n  }\n  .btn:active{ transform: translateY(1px) scale(.997) }\n  .btn.primary{\n    color:#051025;\n    background: linear-gradient(90deg,var(--accent),var(--accent-2));\n    border: 1px solid rgba(255,255,255,0.06);\n    font-weight:700;\n    padding:12px 18px;\n  }\n  .btn.ghost{\n    color:var(--accent);\n    background:transparent;\n    border:1px solid rgba(125,211,252,0.12);\n  }\n  .note{\n    color:rgba(255,255,255,0.38);\n    font-size:12px;\n    padding-top:6px;\n  }\n\n  /* Right visualization */\n  .stage{\n    position:relative;\n    padding:22px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    min-height:360px;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* network backdrop */\n  .network{\n    position:absolute;\n    inset:0;\n    opacity:0.85;\n    filter: blur(6px) contrast(1.05) saturate(1.05);\n    pointer-events:none;\n  }\n\n  /* central composition */\n  .canvas{\n    position:relative;\n    width:86%;\n    height:78%;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:18px;\n    z-index:2;\n  }\n\n  .node{\n    width:42%;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:14px;\n    transform-origin:center;\n  }\n\n  .device{\n    width:100%;\n    border-radius:14px;\n    padding:18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.028);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:12px;\n    position:relative;\n  }\n\n  .device .icon{\n    width:76px;\n    height:76px;\n    display:grid;\n    place-items:center;\n    border-radius:12px;\n    background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: inset 0 -6px 18px rgba(0,0,0,0.25);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  .label{\n    text-align:center;\n    font-size:13px;\n    color:var(--muted);\n  }\n  .key-visual{\n    display:flex;\n    flex-direction:column;\n    gap:8px;\n    align-items:center;\n  }\n  .key-graphic{\n    width:120px;\n    height:56px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  /* key SVG stylings */\n  .svg-key{\n    width:100%;\n    height:100%;\n  }\n\n  /* message bubble */\n  .bubble{\n    min-width:220px;\n    max-width:320px;\n    padding:12px 14px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:10px;\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n    font-size:13px;\n    text-align:center;\n  }\n\n  .cipher{\n    font-family: monospace;\n    font-size:12px;\n    color: #ffe8b3;\n    text-shadow: 0 1px 0 rgba(0,0,0,0.6);\n    letter-spacing:0.06em;\n    padding:8px 10px;\n    border-radius:8px;\n    background: linear-gradient(90deg, rgba(246,200,95,0.08), rgba(167,139,250,0.02));\n    border:1px solid rgba(246,200,95,0.06);\n  }\n\n  /* animated beam for encryption */\n  .beam{\n    position:absolute;\n    height:6px;\n    border-radius:999px;\n    background: linear-gradient(90deg, rgba(125,211,252,0.9), rgba(167,139,250,0.9));\n    box-shadow: 0 6px 24px rgba(125,211,252,0.08), 0 2px 10px rgba(167,139,250,0.06);\n    transform-origin:left center;\n    pointer-events:none;\n    opacity:0;\n  }\n\n  /* keys area bottom */\n  .keys{\n    width:100%;\n    display:flex;\n    gap:10px;\n    margin-top:8px;\n    justify-content:center;\n  }\n  .key-card{\n    padding:12px 14px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006));\n    border:1px solid rgba(255,255,255,0.03);\n    min-width:46%;\n    text-align:left;\n    font-size:12px;\n    color:var(--muted);\n  }\n  .key-title{font-size:11px; color:rgba(255,255,255,0.7); margin-bottom:8px; font-weight:700;}\n  .key-value{ font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,monospace; font-size:12px; color:rgba(255,255,255,0.9); word-break:break-all; line-height:1.6; }\n\n  .muted-small{ font-size:11px; color:rgba(255,255,255,0.38); margin-top:8px; text-align:center }\n\n  /* network svg small dots animation */\n  .dot{ fill: rgba(125,211,252,0.08); transition: fill .28s, r .28s; }\n  .dot.pulse{ animation: pulse 2.2s infinite; }\n  @keyframes pulse{\n    0%{ transform: scale(1); opacity:0.9 }\n    50%{ transform: scale(1.35); opacity:0.6 }\n    100%{ transform: scale(1); opacity:0.9 }\n  }\n\n  /* responsive */\n  @media (max-width:900px){\n    .card{ grid-template-columns: 1fr; padding:20px; gap:18px; }\n    .canvas{ flex-direction:column; align-items:center; justify-content:space-between; height:66%; }\n    .node{ width:100%; }\n    .device .icon{ width:64px; height:64px; }\n    .key-graphic{ width:96px; height:44px; }\n  }\n</style>\n</head>\n<body>\n<div class=\"app\" role=\"main\">\n  <div class=\"card\" role=\"region\" aria-label=\"Asymmetric Cryptography Visualization\">\n    <div class=\"meta\">\n      <h1>Asymmetric Cryptography</h1>\n      <p class=\"lead\">Aesthetic visualization of public-key cryptography: public & private keys, encryption flow, and the one-way magic that enables secure communication. This is an educational visualization — not a cryptographic implementation.</p>\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"genBtn\" class=\"btn primary\" aria-label=\"Generate key pair\">Generate Key Pair</button>\n        <button id=\"encBtn\" class=\"btn ghost\" aria-label=\"Encrypt sample message\" disabled>Encrypt Sample</button>\n      </div>\n      <div class=\"note\">Click \"Generate Key Pair\" to materialize a simulated key pair. Then \"Encrypt Sample\" to see the message traverse to the public key and become ciphertext.</div>\n      <div style=\"margin-top:18px;\">\n        <div class=\"muted-small\">Visualization only • Not a secure implementation</div>\n      </div>\n    </div>\n\n    <div class=\"stage\">\n      <!-- network background with SVG -->\n      <svg class=\"network\" viewBox=\"0 0 1200 720\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n        <defs>\n          <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7dd3fc\" stop-opacity=\"0.08\" />\n            <stop offset=\"1\" stop-color=\"#a78bfa\" stop-opacity=\"0.06\" />\n          </linearGradient>\n        </defs>\n\n        <!-- stylized faint grid paths / connections -->\n        <g stroke=\"url(#g1)\" stroke-width=\"1\" opacity=\"0.9\" fill=\"none\">\n          <path d=\"M120 180 C240 120 420 80 560 140\" stroke-linecap=\"round\" />\n          <path d=\"M840 520 C740 460 620 400 480 460\" stroke-linecap=\"round\" />\n          <path d=\"M220 540 C360 620 520 600 700 540\" stroke-linecap=\"round\" />\n          <path d=\"M980 120 C940 220 820 260 720 200\" stroke-linecap=\"round\" />\n        </g>\n\n        <!-- animated nodes -->\n        <g>\n          <circle class=\"dot pulse\" cx=\"120\" cy=\"180\" r=\"3.2\" />\n          <circle class=\"dot pulse\" cx=\"560\" cy=\"140\" r=\"3.6\" />\n          <circle class=\"dot pulse\" cx=\"840\" cy=\"520\" r=\"3.4\" />\n          <circle class=\"dot pulse\" cx=\"480\" cy=\"460\" r=\"3.2\" />\n          <circle class=\"dot pulse\" cx=\"220\" cy=\"540\" r=\"3.2\" />\n          <circle class=\"dot pulse\" cx=\"700\" cy=\"540\" r=\"3.6\" />\n          <circle class=\"dot pulse\" cx=\"980\" cy=\"120\" r=\"3.2\" />\n        </g>\n      </svg>\n\n      <div class=\"canvas\" aria-hidden=\"false\">\n        <!-- Sender -->\n        <div class=\"node\" id=\"sender\">\n          <div class=\"device\" aria-hidden=\"true\" style=\"transform: translateY(0); transition: transform .8s cubic-bezier(.2,.9,.3,1)\">\n            <div class=\"icon\" aria-hidden=\"true\">\n              <!-- stylized device icon -->\n              <svg width=\"36\" height=\"36\" viewBox=\"0 0 48 48\" fill=\"none\" class=\"svg-device\" xmlns=\"http://www.w3.org/2000/svg\">\n                <rect x=\"6\" y=\"8\" width=\"36\" height=\"28\" rx=\"5\" fill=\"url(#screen)\"/>\n                <rect x=\"14\" y=\"16\" width=\"20\" height=\"12\" rx=\"2\" fill=\"rgba(255,255,255,0.04)\"/>\n                <defs>\n                  <linearGradient id=\"screen\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#7dd3fc\" stop-opacity=\"0.08\"/>\n                    <stop offset=\"1\" stop-color=\"#a78bfa\" stop-opacity=\"0.06\"/>\n                  </linearGradient>\n                </defs>\n              </svg>\n            </div>\n\n            <div>\n              <div class=\"label\">Sender</div>\n              <div class=\"bubble\" id=\"plaintext\">\"Hello, Asymmetric World!\"</div>\n            </div>\n          </div>\n\n          <div class=\"key-visual\" style=\"margin-top:8px;\">\n            <div class=\"label\">Outgoing (plaintext)</div>\n          </div>\n        </div>\n\n        <!-- beam element -->\n        <div id=\"beam\" class=\"beam\" aria-hidden=\"true\"></div>\n\n        <!-- Receiver -->\n        <div class=\"node\" id=\"receiver\">\n          <div class=\"device\" aria-hidden=\"true\">\n            <div class=\"icon\" aria-hidden=\"true\">\n              <!-- lock / keyhole icon -->\n              <svg width=\"36\" height=\"36\" viewBox=\"0 0 48 48\" fill=\"none\" class=\"svg-lock\" xmlns=\"http://www.w3.org/2000/svg\">\n                <rect x=\"8\" y=\"16\" width=\"32\" height=\"20\" rx=\"4\" fill=\"url(#lockg)\"/>\n                <circle cx=\"24\" cy=\"26\" r=\"3.2\" fill=\"#f6c85f\"/>\n                <path d=\"M18 16c0-3.8 3.2-7 6-7s6 3.2 6 7\" stroke=\"#f6c85f\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n                <defs>\n                  <linearGradient id=\"lockg\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#f6c85f\" stop-opacity=\"0.06\"/>\n                    <stop offset=\"1\" stop-color=\"#f59e0b\" stop-opacity=\"0.06\"/>\n                  </linearGradient>\n                </defs>\n              </svg>\n            </div>\n\n            <div>\n              <div class=\"label\">Receiver</div>\n              <div class=\"cipher\" id=\"ciphertext\">—</div>\n            </div>\n          </div>\n\n          <div class=\"key-visual\" style=\"margin-top:8px;\">\n            <div class=\"label\">Incoming (ciphertext)</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- bottom keys display -->\n      <div style=\"position:absolute; bottom:18px; left:28px; right:28px; display:flex; justify-content:center; pointer-events:auto; z-index:3;\">\n        <div class=\"keys\" role=\"list\" aria-label=\"Key pair\">\n          <div class=\"key-card\" role=\"listitem\">\n            <div class=\"key-title\">Public Key</div>\n            <div id=\"pubKey\" class=\"key-value\">—</div>\n          </div>\n          <div class=\"key-card\" role=\"listitem\">\n            <div class=\"key-title\">Private Key (hidden)</div>\n            <div id=\"privKey\" class=\"key-value\">••••••••••••••••••••••••••••••••</div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Elements\n  const genBtn = document.getElementById('genBtn');\n  const encBtn = document.getElementById('encBtn');\n  const pubKeyEl = document.getElementById('pubKey');\n  const privKeyEl = document.getElementById('privKey');\n  const plaintextEl = document.getElementById('plaintext');\n  const ciphertextEl = document.getElementById('ciphertext');\n  const beam = document.getElementById('beam');\n  const sender = document.getElementById('sender');\n  const receiver = document.getElementById('receiver');\n\n  // State\n  let keys = null;\n\n  // Utility: random hex\n  function randomHex(bytes=32){\n    const arr = new Uint8Array(bytes);\n    crypto.getRandomValues(arr);\n    return Array.from(arr).map(b => b.toString(16).padStart(2,'0')).join('');\n  }\n\n  // Animate key reveal: produce keys and show them with polish\n  genBtn.addEventListener('click', async function(){\n    genBtn.disabled = true;\n    genBtn.innerText = 'Generating…';\n    await sleep(550);\n\n    // pseudo key generation (simulated)\n    const pub = randomHex(24).toUpperCase();\n    const priv = randomHex(40).toUpperCase();\n    keys = {pub, priv};\n\n    // animate device bounce\n    sender.style.transform = 'translateY(-6px)';\n    setTimeout(()=> sender.style.transform = 'translateY(0)', 520);\n\n    // display keys with staggered reveal\n    pubKeyEl.textContent = '—';\n    privKeyEl.textContent = '••••••••••••••••••••••••••••••••';\n    await sleep(260);\n\n    // reveal public key\n    pubKeyEl.style.opacity = 0;\n    pubKeyEl.textContent = formatKey(pub);\n    fadeIn(pubKeyEl, 360);\n\n    // reveal private key briefly masked then show masked state\n    await sleep(460);\n    privKeyEl.style.opacity = 0;\n    privKeyEl.textContent = formatKey(priv);\n    fadeIn(privKeyEl, 300);\n\n    // pause, then re-mask private key\n    await sleep(900);\n    // animate a mask covering the private key\n    privKeyEl.style.transition = 'opacity .28s';\n    privKeyEl.style.opacity = 0;\n    await sleep(280);\n    privKeyEl.textContent = '••••••••••••••••••••••••••••••••';\n    fadeIn(privKeyEl, 220);\n\n    encBtn.disabled = false;\n    genBtn.disabled = false;\n    genBtn.innerText = 'Generate Key Pair';\n  });\n\n  // encryption demonstration\n  encBtn.addEventListener('click', async function(){\n    if(!keys) return;\n    encBtn.disabled = true;\n\n    // Prepare positions\n    const sRect = sender.getBoundingClientRect();\n    const rRect = receiver.getBoundingClientRect();\n    const stageRect = beam.parentElement.getBoundingClientRect();\n\n    // determine start and end points relative to beam's container\n    const startX = sRect.right - stageRect.left - 12;\n    const startY = sRect.top + sRect.height/2 - stageRect.top;\n    const endX = rRect.left - stageRect.left + 16;\n    const endY = rRect.top + rRect.height/2 - stageRect.top;\n\n    // compute angle & distance\n    const dx = endX - startX;\n    const dy = endY - startY;\n    const dist = Math.sqrt(dx*dx + dy*dy);\n    const angle = Math.atan2(dy, dx) * 180 / Math.PI;\n\n    // style beam for animation\n    beam.style.width = (dist) + 'px';\n    beam.style.left = startX + 'px';\n    beam.style.top = (startY - 3) + 'px';\n    beam.style.transform = 'rotate(' + angle + 'deg) scaleX(0)';\n    beam.style.opacity = 1;\n\n    // animate beam growth\n    beam.animate([\n      { transform: 'rotate(' + angle + 'deg) scaleX(0)', opacity: 0 },\n      { transform: 'rotate(' + angle + 'deg) scaleX(1.05)', opacity: 1 },\n      { transform: 'rotate(' + angle + 'deg) scaleX(1)', opacity: 1 }\n    ], { duration: 800, easing: 'cubic-bezier(.2,.9,.3,1)'});\n\n    // message glow and move\n    const originalText = plaintextEl.textContent;\n    plaintextEl.animate([\n      { transform: 'translateY(0) scale(1)', boxShadow:'none', opacity:1 },\n      { transform: 'translateY(-8px) scale(.98)', boxShadow:'0 6px 30px rgba(125,211,252,0.06)', opacity:0.95 }\n    ], { duration: 420, easing: 'ease-out' });\n\n    // simulate encryption (simple transform for visualization)\n    await sleep(280);\n    const ct = simulateEncryption(originalText, keys.pub);\n\n    // reveal ciphertext progressively\n    ciphertextEl.textContent = '—';\n    ciphertextEl.style.opacity = 0;\n    await sleep(160);\n    fadeIn(ciphertextEl, 160);\n    // show progressive revealed ciphertext chunks\n    let displayed = '';\n    const parts = chunkString(ct, 8);\n    for(let i=0;i<parts.length;i++){\n      displayed += parts[i] + (i<parts.length-1 ? ' ' : '');\n      ciphertextEl.textContent = displayed;\n      await sleep(120);\n    }\n\n    // beam fade\n    beam.animate([\n      { opacity: 1, transform: 'rotate(' + angle + 'deg) scaleX(1)' },\n      { opacity: 0, transform: 'rotate(' + angle + 'deg) scaleX(1.08) translateY(-6px)' }\n    ], { duration: 620, easing: 'cubic-bezier(.2,.9,.3,1)'});\n    setTimeout(()=> beam.style.opacity = 0, 640);\n\n    // flash receiver icon & subtle ring\n    const receiverIcon = receiver.querySelector('.icon');\n    receiverIcon.animate([\n      { boxShadow: '0 0 0 0 rgba(167,139,250,0.12)' },\n      { boxShadow: '0 8px 30px 4px rgba(167,139,250,0.12)' },\n      { boxShadow: '0 0 0 0 rgba(167,139,250,0.0)' }\n    ], { duration: 700, easing: 'ease-out' });\n\n    // done\n    encBtn.disabled = false;\n  });\n\n  // helpers\n  function sleep(ms){ return new Promise(r => setTimeout(r, ms)); }\n\n  function formatKey(hex){\n    // group in 8-character blocks for readability\n    return hex.match(/.{1,8}/g).join(' ');\n  }\n\n  function fadeIn(el, ms=320){\n    el.style.transition = 'opacity ' + ms + 'ms cubic-bezier(.2,.9,.3,1)';\n    el.style.opacity = 1;\n  }\n\n  function chunkString(str, len){\n    const arr = [];\n    for (let i=0;i<str.length;i+=len) arr.push(str.substring(i,i+len));\n    return arr;\n  }\n\n  function simulateEncryption(plain, pub){\n    // For visualization only: produce a pseudo-ciphertext by combining base64-ish pattern and pub key salt.\n    // Not secure. Use subtle XOR-ish mapping for aesthetic ciphertext.\n    const text = String(plain);\n    const keyBytes = hexToBytes(pub.slice(0,32));\n    const data = new TextEncoder().encode(text);\n    const out = new Uint8Array(data.length);\n    for(let i=0;i<data.length;i++){\n      out[i] = (data[i] ^ keyBytes[i % keyBytes.length]) + ((i*i) % 13);\n    }\n    // produce hex-like base32-ish string\n    const map = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';\n    let s = '';\n    for(let b of out){\n      s += map[(b >> 3) & 31];\n      s += map[b & 31];\n    }\n    // append a short tag from pub key\n    s += '-' + pub.slice(0,6);\n    return s;\n  }\n\n  function hexToBytes(hex){\n    if(hex.length % 2) hex = '0' + hex;\n    const bytes = new Uint8Array(hex.length/2);\n    for(let i=0;i<hex.length;i+=2) bytes[i/2] = parseInt(hex.substr(i,2),16);\n    return bytes;\n  }\n\n  // chunk plaintext for progressive initial display\n  (function initSmallEffects(){\n    // slight float animation for icons\n    const icons = document.querySelectorAll('.icon');\n    icons.forEach((el, idx) => {\n      el.animate([\n        { transform: 'translateY(0px)' },\n        { transform: 'translateY(-6px)' },\n        { transform: 'translateY(0px)' }\n      ], { duration: 4200 + idx*400, iterations: Infinity, easing: 'ease-in-out', delay: idx*140 });\n    });\n  })();\n\n})();\n</script>\n</body>\n</html>"
  },
