  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Prim's Algorithm Interactive Demo</title>\n<style>\n/* Extremely minimal visual design: keep plain default styles */\nbody { font-family: sans-serif; margin: 8px; color: #000; background: #fff; }\n#container { display: flex; gap: 8px; }\n#controls { width: 360px; max-width: 40%; }\nsection { margin-bottom: 10px; padding: 6px; border: 1px solid #000; }\nlabel { display: block; margin-top: 6px; }\ninput[type=\"range\"] { width: 100%; }\nsvg { width: 800px; height: 600px; border: 1px solid #000; background: #fff; }\nbutton { margin: 2px 2px 2px 0; }\n.small { font-size: 12px; }\ntextarea { width: 100%; height: 100px; font-family: monospace; }\nselect { width: 100%; }\nkbd { background: #fff; border: 1px solid #000; padding: 1px 3px; }\n.panel-row { display: flex; gap: 6px; align-items: center; margin-top:6px; flex-wrap:wrap;}\n#log { height: 140px; overflow:auto; white-space: pre-wrap; font-family: monospace; font-size:12px; }\n#pqbox { font-family: monospace; font-size: 12px; height: 120px; overflow:auto; border:1px solid #000; padding:4px; }\ninput[type=\"number\"] { width: 70px; }\n#mode-indicator { font-weight: bold; }\n</style>\n</head>\n<body>\n<h2>Prim's Algorithm — Interactive Demonstration</h2>\n<div id=\"container\">\n  <div id=\"controls\">\n    <section>\n      <strong>Graph Construction</strong>\n      <div class=\"panel-row\">\n        <button id=\"addNodeBtn\">Add Node</button>\n        <button id=\"addNodeRandBtn\">Add Random Node</button>\n        <button id=\"clearGraphBtn\">Clear Graph</button>\n      </div>\n      <label>Random Graph\n        <div class=\"panel-row\">\n          Nodes: <input id=\"randNodes\" type=\"number\" value=\"8\" min=\"1\" max=\"60\">\n          Density (%): <input id=\"randDensity\" type=\"range\" min=\"0\" max=\"100\" value=\"35\">\n          <span id=\"randDensityVal\">35</span>\n        </div>\n        <div class=\"panel-row\">\n          Weight min: <input id=\"wmin\" type=\"number\" value=\"1\" min=\"0\"> max: <input id=\"wmax\" type=\"number\" value=\"20\" min=\"1\">\n          <button id=\"genRandBtn\">Generate Random</button>\n        </div>\n      </label>\n\n      <label>Edge / Node Modes\n        <div class=\"panel-row\">\n          <button id=\"edgeModeBtn\">Toggle Add-Edge Mode</button>\n          <button id=\"delModeBtn\">Toggle Delete Mode</button>\n          <button id=\"moveModeBtn\">Toggle Move Nodes</button>\n        </div>\n        <div class=\"panel-row small\">\n          In Add-Edge Mode: click two nodes to add an edge. After selecting two nodes the weight input appears.\n        </div>\n      </label>\n\n      <label>Selected Element\n        <div id=\"selectedInfo\">None</div>\n        <div class=\"panel-row\">\n          <button id=\"editWeightBtn\">Edit Weight</button>\n          <button id=\"deleteBtn\">Delete</button>\n          <input id=\"editWeightInput\" type=\"number\" style=\"display:none\" min=\"0\">\n          <button id=\"applyWeightBtn\" style=\"display:none\">Apply</button>\n        </div>\n      </label>\n    </section>\n\n    <section>\n      <strong>Prim Controls</strong>\n      <label>Start Node:\n        <select id=\"startNodeSelect\"></select>\n      </label>\n      <label>Tie-break:\n        <select id=\"tieBreak\">\n          <option value=\"id\">By Node ID</option>\n          <option value=\"random\">Random</option>\n        </select>\n      </label>\n      <label>Priority Queue Implementation:\n        <select id=\"pqImpl\">\n          <option value=\"binaryHeap\">Binary Heap</option>\n          <option value=\"simple\">Simple Array</option>\n        </select>\n      </label>\n      <label>Execution Controls\n        <div class=\"panel-row\">\n          <button id=\"initPrimBtn\">Init/Reset Algorithm</button>\n          <button id=\"stepBtn\">Step</button>\n          <button id=\"nextBtn\">Next (auto step)</button>\n          <button id=\"prevBtn\">Prev</button>\n          <button id=\"runBtn\">Run</button>\n          <button id=\"pauseBtn\">Pause</button>\n          <button id=\"completeBtn\">Complete</button>\n        </div>\n      </label>\n      <label>Speed (ms per step)\n        <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"500\">\n        <span id=\"speedVal\">500</span>\n      </label>\n      <label>Mode:\n        <div class=\"panel-row\">\n          <select id=\"execMode\">\n            <option value=\"auto\">Auto Trace</option>\n            <option value=\"manual\">Manual (pick next edge/node)</option>\n            <option value=\"inspect\">Inspect Only</option>\n          </select>\n          <div id=\"mode-indicator\">Mode: auto</div>\n        </div>\n      </label>\n\n      <div class=\"panel-row\">\n        <button id=\"computeMSTBtn\">Compute MST (full)</button>\n        <button id=\"compareKruskalBtn\">Compare with Kruskal</button>\n      </div>\n\n      <div class=\"panel-row small\"><strong>MST Weight:</strong> <span id=\"mstWeight\">0</span> <strong>Edges:</strong> <span id=\"mstEdgesCount\">0</span></div>\n    </section>\n\n    <section>\n      <strong>Trace Controls & PQ</strong>\n      <label>Priority Queue (live)</label>\n      <div id=\"pqbox\"></div>\n      <label>Log / Trace\n        <div id=\"log\"></div>\n        <div class=\"panel-row\">\n          <button id=\"clearLogBtn\">Clear Log</button>\n          <button id=\"saveSnapshotBtn\">Save Snapshot</button>\n          <button id=\"loadSnapshotBtn\">Load Snapshot</button>\n        </div>\n      </label>\n    </section>\n\n    <section>\n      <strong>Import / Export</strong>\n      <div class=\"panel-row\">\n        <button id=\"exportBtn\">Export JSON</button>\n        <button id=\"importBtn\">Import JSON</button>\n      </div>\n      <textarea id=\"jsonArea\" placeholder=\"Graph JSON appears here for export/import\"></textarea>\n    </section>\n\n    <section>\n      <strong>Undo / Redo & States</strong>\n      <div class=\"panel-row\">\n        <button id=\"undoBtn\">Undo</button>\n        <button id=\"redoBtn\">Redo</button>\n        <button id=\"snapshotListBtn\">List Snapshots</button>\n      </div>\n      <div id=\"snapshotsList\"></div>\n    </section>\n\n  </div>\n\n  <div id=\"visual\">\n    <svg id=\"svg\"></svg>\n    <div class=\"panel-row\" style=\"margin-top:6px;\">\n      <div><label><input id=\"showWeights\" type=\"checkbox\" checked> Show Weights</label></div>\n      <div><label><input id=\"showNodeIds\" type=\"checkbox\" checked> Show Node IDs</label></div>\n      <div><label><input id=\"showVisited\" type=\"checkbox\" checked> Show Visited</label></label></div>\n      <div><label><input id=\"showMSTEdgesOnly\" type=\"checkbox\"> Show MST overlay only</label></div>\n    </div>\n    <div style=\"margin-top:6px;\">\n      <label>Adjacency List / Matrix (toggle)\n        <div id=\"adjView\" style=\"font-family: monospace; white-space: pre; margin-top:6px;\"></div>\n      </label>\n    </div>\n  </div>\n</div>\n\n<script>\n/*\nPrim's Algorithm Interactive Demo\n- Minimal visual styling\n- Rich interactivity: graph editing, random generation, step-by-step Prim, manual choices,\n  PQ visualization, export/import, snapshots, undo/redo, compare with Kruskal.\n*/\n\n// Basic graph model\nlet Graph = {\n  nodes: [], // {id, x, y}\n  edges: [], // {id, u, v, w}\n  nextNodeId: 1,\n  nextEdgeId: 1\n};\n\nlet stateHistory = [];\nlet historyIndex = -1;\nlet snapshots = [];\n\nfunction saveHistory(label) {\n  // Keep deep copy\n  let copy = JSON.parse(JSON.stringify(Graph));\n  stateHistory = stateHistory.slice(0, historyIndex + 1);\n  stateHistory.push({graph: copy, label: label || ''});\n  historyIndex++;\n  updateSnapshotsUI();\n}\nfunction undo() {\n  if (historyIndex <= 0) return;\n  historyIndex--;\n  Graph = JSON.parse(JSON.stringify(stateHistory[historyIndex].graph));\n  rebuildAfterGraphChange();\n}\nfunction redo() {\n  if (historyIndex >= stateHistory.length - 1) return;\n  historyIndex++;\n  Graph = JSON.parse(JSON.stringify(stateHistory[historyIndex].graph));\n  rebuildAfterGraphChange();\n}\n\nfunction snapshotSave() {\n  snapshots.push(JSON.parse(JSON.stringify(Graph)));\n  updateSnapshotsUI();\n}\nfunction snapshotLoad(idx) {\n  if (idx < 0 || idx >= snapshots.length) return;\n  Graph = JSON.parse(JSON.stringify(snapshots[idx]));\n  rebuildAfterGraphChange();\n}\n\n// Basic DOM refs\nconst svg = document.getElementById('svg');\nconst addNodeBtn = document.getElementById('addNodeBtn');\nconst addNodeRandBtn = document.getElementById('addNodeRandBtn');\nconst clearGraphBtn = document.getElementById('clearGraphBtn');\nconst genRandBtn = document.getElementById('genRandBtn');\nconst randNodes = document.getElementById('randNodes');\nconst randDensity = document.getElementById('randDensity');\nconst randDensityVal = document.getElementById('randDensityVal');\nconst wmin = document.getElementById('wmin');\nconst wmax = document.getElementById('wmax');\nconst edgeModeBtn = document.getElementById('edgeModeBtn');\nconst delModeBtn = document.getElementById('delModeBtn');\nconst moveModeBtn = document.getElementById('moveModeBtn');\nconst selectedInfo = document.getElementById('selectedInfo');\nconst editWeightBtn = document.getElementById('editWeightBtn');\nconst deleteBtn = document.getElementById('deleteBtn');\nconst editWeightInput = document.getElementById('editWeightInput');\nconst applyWeightBtn = document.getElementById('applyWeightBtn');\n\nconst startNodeSelect = document.getElementById('startNodeSelect');\nconst tieBreak = document.getElementById('tieBreak');\nconst pqImpl = document.getElementById('pqImpl');\nconst initPrimBtn = document.getElementById('initPrimBtn');\nconst stepBtn = document.getElementById('stepBtn');\nconst nextBtn = document.getElementById('nextBtn');\nconst prevBtn = document.getElementById('prevBtn');\nconst runBtn = document.getElementById('runBtn');\nconst pauseBtn = document.getElementById('pauseBtn');\nconst completeBtn = document.getElementById('completeBtn');\nconst speed = document.getElementById('speed');\nconst speedVal = document.getElementById('speedVal');\nconst execMode = document.getElementById('execMode');\nconst modeIndicator = document.getElementById('mode-indicator');\nconst computeMSTBtn = document.getElementById('computeMSTBtn');\nconst compareKruskalBtn = document.getElementById('compareKruskalBtn');\n\nconst pqbox = document.getElementById('pqbox');\nconst logBox = document.getElementById('log');\nconst clearLogBtn = document.getElementById('clearLogBtn');\nconst saveSnapshotBtn = document.getElementById('saveSnapshotBtn');\nconst loadSnapshotBtn = document.getElementById('loadSnapshotBtn');\n\nconst exportBtn = document.getElementById('exportBtn');\nconst importBtn = document.getElementById('importBtn');\nconst jsonArea = document.getElementById('jsonArea');\n\nconst showWeights = document.getElementById('showWeights');\nconst showNodeIds = document.getElementById('showNodeIds');\nconst showVisited = document.getElementById('showVisited');\nconst showMSTEdgesOnly = document.getElementById('showMSTEdgesOnly');\nconst adjView = document.getElementById('adjView');\n\nconst mstWeightSpan = document.getElementById('mstWeight');\nconst mstEdgesCountSpan = document.getElementById('mstEdgesCount');\nconst pqImplSelect = pqImpl;\n\nconst undoBtn = document.getElementById('undoBtn');\nconst redoBtn = document.getElementById('redoBtn');\nconst snapshotListBtn = document.getElementById('snapshotListBtn');\nconst snapshotsList = document.getElementById('snapshotsList');\n\nrandDensity.addEventListener('input', ()=> randDensityVal.textContent = randDensity.value);\nspeed.addEventListener('input', ()=> speedVal.textContent = speed.value);\n\nlet mode = {\n  addEdge: false,\n  delete: false,\n  move: false\n};\n\nlet selection = {type: null, id: null}; // type 'node' or 'edge'\nlet addEdgeSelection = []; // selected node ids when in add-edge mode\n\n// Visualization state for algorithm\nlet algoState = null; // will hold algorithm simulation state object\nlet playTimer = null;\n\nfunction log(msg) {\n  let time = new Date().toISOString().slice(11,23);\n  logBox.textContent += \"[\" + time + \"] \" + msg + \"\\n\";\n  logBox.scrollTop = logBox.scrollHeight;\n}\n\n// Helper: find node/edge by id\nfunction getNodeById(id) { return Graph.nodes.find(n => n.id === id); }\nfunction getEdgeById(id) { return Graph.edges.find(e => e.id === id); }\n\n// Graph editing functions\nfunction addNode(x, y) {\n  const node = {id: Graph.nextNodeId++, x: x, y: y};\n  Graph.nodes.push(node);\n  saveHistory('addNode');\n  redraw();\n  return node;\n}\nfunction deleteNode(id) {\n  Graph.nodes = Graph.nodes.filter(n => n.id !== id);\n  Graph.edges = Graph.edges.filter(e => e.u !== id && e.v !== id);\n  saveHistory('deleteNode');\n  selection = {type:null, id:null};\n  rebuildAfterGraphChange();\n}\nfunction addEdge(u, v, w) {\n  if (u === v) return null;\n  // ensure undirected uniqueness: canonical ordering\n  let a = Math.min(u,v), b = Math.max(u,v);\n  if (Graph.edges.some(e => (Math.min(e.u,e.v)===a && Math.max(e.u,e.v)===b))) {\n    log(\"Edge already exists between \" + a + \" and \" + b);\n    return null;\n  }\n  const edge = {id: Graph.nextEdgeId++, u: u, v: v, w: w};\n  Graph.edges.push(edge);\n  saveHistory('addEdge');\n  redraw();\n  return edge;\n}\nfunction deleteEdge(id) {\n  Graph.edges = Graph.edges.filter(e => e.id !== id);\n  saveHistory('deleteEdge');\n  selection = {type:null, id:null};\n  redraw();\n}\nfunction setEdgeWeight(id, w) {\n  let e = getEdgeById(id);\n  if (!e) return;\n  e.w = Number(w);\n  saveHistory('setWeight');\n  redraw();\n}\n\nfunction clearGraph() {\n  Graph.nodes = [];\n  Graph.edges = [];\n  Graph.nextNodeId = 1;\n  Graph.nextEdgeId = 1;\n  saveHistory('clearGraph');\n  redraw();\n}\n\n// Random graph generator\nfunction generateRandomGraph(n, densityPercent, wMin, wMax, seed) {\n  // clear existing and create nodes positioned in grid-ish\n  Graph.nodes = [];\n  Graph.edges = [];\n  Graph.nextNodeId = 1;\n  Graph.nextEdgeId = 1;\n  // place nodes in SVG area\n  const W = svg.clientWidth, H = svg.clientHeight;\n  for (let i=0;i<n;i++) {\n    let x = 40 + (i%10) * Math.min(60, (W-80)/Math.min(9, n-1));\n    let y = 40 + Math.floor(i/10) * 60 + Math.random()*20;\n    if (i%10===0 && i!==0) x = 40 + Math.random()*20;\n    addNode(x + Math.random()*40, y + Math.random()*40);\n  }\n  // edges using probability\n  for (let i=0;i<n;i++){\n    for (let j=i+1;j<n;j++){\n      if (Math.random() < densityPercent/100) {\n        let w = wMin + Math.floor(Math.random() * (wMax - wMin + 1));\n        Graph.edges.push({id: Graph.nextEdgeId++, u: Graph.nodes[i].id, v: Graph.nodes[j].id, w: w});\n      }\n    }\n  }\n  saveHistory('genRandom');\n  rebuildAfterGraphChange();\n}\n\n// Redraw\nfunction redraw() {\n  // clear svg\n  while (svg.firstChild) svg.removeChild(svg.firstChild);\n\n  // Draw edges (lower z-order)\n  let edgesToDraw = Graph.edges.slice();\n  if (showMSTEdgesOnly.checked && algoState && algoState.mstEdges) {\n    // show only MST overlay edges but still draw silhouette for context minimal\n    edgesToDraw = Graph.edges.filter(e => algoState.mstEdges.some(me => me.id === e.id));\n  }\n  edgesToDraw.forEach(e => {\n    let u = getNodeById(e.u), v = getNodeById(e.v);\n    if (!u || !v) return;\n    let line = document.createElementNS('http://www.w3.org/2000/svg','line');\n    line.setAttribute('x1', u.x);\n    line.setAttribute('y1', u.y);\n    line.setAttribute('x2', v.x);\n    line.setAttribute('y2', v.y);\n    line.setAttribute('stroke','black');\n    line.setAttribute('stroke-width', (algoState && algoState.mstEdges && algoState.mstEdges.some(me => me.id === e.id))? 4 : 1);\n    line.setAttribute('data-edge-id', e.id);\n    line.addEventListener('click', svgEdgeClick);\n    svg.appendChild(line);\n\n    if (showWeights.checked) {\n      const tx = (u.x + v.x)/2;\n      const ty = (u.y + v.y)/2;\n      let text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('x', tx + 4);\n      text.setAttribute('y', ty - 4);\n      text.setAttribute('font-size','12');\n      text.textContent = e.w;\n      text.setAttribute('pointer-events','none');\n      svg.appendChild(text);\n    }\n  });\n\n  // Draw nodes on top\n  Graph.nodes.forEach(n => {\n    let group = document.createElementNS('http://www.w3.org/2000/svg','g');\n    group.setAttribute('transform', `translate(${n.x},${n.y})`);\n    group.setAttribute('data-node-id', n.id);\n\n    let circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    circle.setAttribute('r', 12);\n    circle.setAttribute('cx', 0);\n    circle.setAttribute('cy', 0);\n    circle.setAttribute('fill','none');\n    circle.setAttribute('stroke','black');\n    circle.setAttribute('stroke-width','1');\n    circle.addEventListener('mousedown', svgNodeDown);\n    circle.addEventListener('click', svgNodeClick);\n    group.appendChild(circle);\n\n    if (showNodeIds.checked) {\n      let text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('x', -6);\n      text.setAttribute('y', 4);\n      text.setAttribute('font-size','12');\n      text.textContent = n.id;\n      text.setAttribute('pointer-events','none');\n      group.appendChild(text);\n    }\n\n    if (algoState && algoState.visited && algoState.visited.has(n.id) && showVisited.checked) {\n      let small = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      small.setAttribute('r', 5);\n      small.setAttribute('cx', 12);\n      small.setAttribute('cy', -12);\n      small.setAttribute('fill','none');\n      small.setAttribute('stroke','black');\n      small.setAttribute('stroke-width','1');\n      group.appendChild(small);\n    }\n\n    svg.appendChild(group);\n  });\n\n  refreshUISelections();\n  updateStartNodeSelect();\n  updateAdjView();\n}\n\nfunction refreshUISelections() {\n  // Selected info panel\n  if (!selection.type) {\n    selectedInfo.textContent = 'None';\n    editWeightBtn.style.display = 'inline-block';\n    deleteBtn.style.display = 'inline-block';\n    editWeightInput.style.display = 'none';\n    applyWeightBtn.style.display = 'none';\n  } else if (selection.type === 'node') {\n    let n = getNodeById(selection.id);\n    if (n) {\n      selectedInfo.textContent = 'Node ' + n.id + ' (x:' + Math.round(n.x) + ' y:' + Math.round(n.y) + ')';\n    } else {\n      selection = {type:null, id:null};\n      selectedInfo.textContent = 'None';\n    }\n  } else if (selection.type === 'edge') {\n    let e = getEdgeById(selection.id);\n    if (e) {\n      selectedInfo.textContent = 'Edge ' + e.id + ' (' + e.u + ' - ' + e.v + ') weight: ' + e.w;\n    } else {\n      selection = {type:null, id:null};\n      selectedInfo.textContent = 'None';\n    }\n  }\n  // toggle vis mode buttons highlight (purely textual)\n  edgeModeBtn.textContent = mode.addEdge ? \"Add-Edge Mode: ON\" : \"Toggle Add-Edge Mode\";\n  delModeBtn.textContent = mode.delete ? \"Delete Mode: ON\" : \"Toggle Delete Mode\";\n  moveModeBtn.textContent = mode.move ? \"Move Nodes: ON\" : \"Toggle Move Nodes\";\n}\n\nfunction updateStartNodeSelect() {\n  const cur = startNodeSelect.value;\n  while (startNodeSelect.firstChild) startNodeSelect.removeChild(startNodeSelect.firstChild);\n  Graph.nodes.forEach(n => {\n    let opt = document.createElement('option');\n    opt.value = n.id;\n    opt.textContent = n.id;\n    startNodeSelect.appendChild(opt);\n  });\n  if (cur) startNodeSelect.value = cur;\n}\n\nfunction updateAdjView() {\n  // Show adjacency list and matrix (text)\n  let out = \"\";\n  let nmap = new Map();\n  Graph.nodes.forEach((n,i)=> nmap.set(n.id,i));\n  // adjacency list\n  out += \"Adjacency List:\\n\";\n  Graph.nodes.forEach(n => {\n    out += n.id + \": \";\n    let arr = Graph.edges.filter(e => e.u === n.id || e.v === n.id).map(e => {\n      let other = (e.u === n.id) ? e.v : e.u;\n      return \"(\" + other + \", w=\" + e.w + \")\";\n    });\n    out += arr.join(\", \") + \"\\n\";\n  });\n  // matrix small\n  out += \"\\nMatrix (rows/cols node ids):\\n  \";\n  out += Graph.nodes.map(n=>n.id).join(\" \");\n  out += \"\\n\";\n  Graph.nodes.forEach(r=>{\n    out += r.id + \" \";\n    Graph.nodes.forEach(c=>{\n      let e = Graph.edges.find(e2 => (e2.u===r.id && e2.v===c.id) || (e2.u===c.id && e2.v===r.id));\n      out += (e? e.w : \".\") + \" \";\n    });\n    out += \"\\n\";\n  });\n  adjView.textContent = out;\n}\n\n// SVG interactions\nlet dragState = null;\n\nfunction svgNodeDown(evt) {\n  let g = evt.target.parentNode;\n  let id = Number(g.getAttribute('data-node-id'));\n  if (!mode.move) return;\n  // start dragging\n  const pt = svg.createSVGPoint();\n  dragState = {nodeId: id};\n  window.addEventListener('mousemove', svgNodeMove);\n  window.addEventListener('mouseup', svgNodeUp);\n}\nfunction svgNodeMove(evt) {\n  if (!dragState) return;\n  let node = getNodeById(dragState.nodeId);\n  if (!node) return;\n  const rect = svg.getBoundingClientRect();\n  let x = evt.clientX - rect.left;\n  let y = evt.clientY - rect.top;\n  node.x = Math.max(20, Math.min(svg.clientWidth - 20, x));\n  node.y = Math.max(20, Math.min(svg.clientHeight - 20, y));\n  redraw();\n}\nfunction svgNodeUp(evt) {\n  if (!dragState) return;\n  saveHistory('moveNode');\n  dragState = null;\n  window.removeEventListener('mousemove', svgNodeMove);\n  window.removeEventListener('mouseup', svgNodeUp);\n}\n\nfunction svgNodeClick(evt) {\n  evt.stopPropagation();\n  let id = Number(evt.target.parentNode.getAttribute('data-node-id'));\n  if (mode.delete) {\n    deleteNode(id);\n    return;\n  }\n  if (mode.addEdge) {\n    addEdgeSelection.push(id);\n    log(\"Selected node \" + id + \" for edge creation.\");\n    if (addEdgeSelection.length === 2) {\n      let u = addEdgeSelection[0], v = addEdgeSelection[1];\n      let w = prompt(\"Edge weight between \" + u + \" and \" + v + \" (integer):\", \"1\");\n      if (w !== null) {\n        let wi = parseInt(w,10);\n        if (!isNaN(wi)) {\n          addEdge(u, v, wi);\n        }\n      }\n      addEdgeSelection = [];\n    }\n    return;\n  }\n  // selection\n  selection = {type: 'node', id: id};\n  refreshUISelections();\n}\nfunction svgEdgeClick(evt) {\n  evt.stopPropagation();\n  let id = Number(evt.target.getAttribute('data-edge-id'));\n  if (mode.delete) {\n    deleteEdge(id);\n    return;\n  }\n  selection = {type: 'edge', id: id};\n  refreshUISelections();\n}\n\nsvg.addEventListener('click', (evt) => {\n  // add node at click location\n  if (mode.addEdge || mode.delete) {\n    // clicking empty space cancels edge selection\n    addEdgeSelection = [];\n    return;\n  }\n  if (evt.target === svg) {\n    const rect = svg.getBoundingClientRect();\n    let x = evt.clientX - rect.left;\n    let y = evt.clientY - rect.top;\n    addNode(x, y);\n  }\n});\n\n// Buttons\naddNodeBtn.addEventListener('click', ()=> {\n  addNode(svg.clientWidth/2 + Math.random()*40-20, svg.clientHeight/2 + Math.random()*40-20);\n});\naddNodeRandBtn.addEventListener('click', ()=> {\n  addNode(40 + Math.random()*(svg.clientWidth-80), 40 + Math.random()*(svg.clientHeight-80));\n});\nclearGraphBtn.addEventListener('click', ()=> {\n  if (confirm(\"Clear entire graph?\")) clearGraph();\n});\ngenRandBtn.addEventListener('click', ()=> {\n  let n = Number(randNodes.value);\n  let dens = Number(randDensity.value);\n  let minw = Number(wmin.value);\n  let maxw = Number(wmax.value);\n  generateRandomGraph(n, dens, minw, maxw);\n});\nedgeModeBtn.addEventListener('click', ()=> {\n  mode.addEdge = !mode.addEdge;\n  mode.delete = false;\n  refreshUISelections();\n});\ndelModeBtn.addEventListener('click', ()=> {\n  mode.delete = !mode.delete;\n  if (mode.delete) mode.addEdge = false;\n  refreshUISelections();\n});\nmoveModeBtn.addEventListener('click', ()=> {\n  mode.move = !mode.move;\n  refreshUISelections();\n});\n\neditWeightBtn.addEventListener('click', ()=> {\n  if (selection.type === 'edge') {\n    let e = getEdgeById(selection.id);\n    editWeightInput.value = e.w;\n    editWeightInput.style.display = 'inline-block';\n    applyWeightBtn.style.display = 'inline-block';\n  } else {\n    alert(\"Select an edge first to edit weight.\");\n  }\n});\napplyWeightBtn.addEventListener('click', ()=> {\n  if (selection.type === 'edge') {\n    let v = Number(editWeightInput.value);\n    if (!isNaN(v)) {\n      setEdgeWeight(selection.id, v);\n      editWeightInput.style.display = 'none';\n      applyWeightBtn.style.display = 'none';\n    }\n  }\n});\ndeleteBtn.addEventListener('click', ()=> {\n  if (!selection.type) return;\n  if (selection.type === 'node') deleteNode(selection.id);\n  if (selection.type === 'edge') deleteEdge(selection.id);\n});\n\n// Export / Import\nexportBtn.addEventListener('click', ()=> {\n  jsonArea.value = JSON.stringify(Graph, null, 2);\n});\nimportBtn.addEventListener('click', ()=> {\n  try {\n    let g = JSON.parse(jsonArea.value);\n    // basic validation\n    if (!g.nodes || !g.edges) throw \"Invalid\";\n    Graph = g;\n    // ensure next ids\n    Graph.nextNodeId = Graph.nextNodeId || (Graph.nodes.reduce((m,n)=>Math.max(m,n.id),0)+1);\n    Graph.nextEdgeId = Graph.nextEdgeId || (Graph.edges.reduce((m,e)=>Math.max(m,e.id),0)+1);\n    saveHistory('import');\n    rebuildAfterGraphChange();\n  } catch (e) {\n    alert(\"Import failed: \" + e);\n  }\n});\n\n// Undo/Redo\nundoBtn.addEventListener('click', undo);\nredoBtn.addEventListener('click', redo);\nsaveSnapshotBtn.addEventListener('click', ()=> { snapshotSave(); log(\"Snapshot saved.\"); });\nloadSnapshotBtn.addEventListener('click', ()=> { if (snapshots.length) snapshotLoad(snapshots.length-1); });\n\nsnapshotListBtn.addEventListener('click', ()=> updateSnapshotsUI());\n\nfunction updateSnapshotsUI() {\n  snapshotsList.innerHTML = \"\";\n  let html = document.createElement('div');\n  snapshots.forEach((s, idx) => {\n    let btn = document.createElement('button');\n    btn.textContent = \"Load #\" + idx;\n    btn.addEventListener('click', ()=> snapshotLoad(idx));\n    html.appendChild(btn);\n  });\n  snapshotsList.appendChild(html);\n}\n\n// Clear log\nclearLogBtn.addEventListener('click', ()=> { logBox.textContent = \"\"; });\n\n// Algorithm Simulation\nfunction initPrim(startId) {\n  if (Graph.nodes.length === 0) {\n    alert(\"Graph empty.\");\n    return;\n  }\n  // ensure graph connectivity check optional: Prim can run on each component\n  let nodes = Graph.nodes.map(n=>n.id);\n  // init data structures\n  let dist = {};\n  let parent = {};\n  let visited = new Set();\n  nodes.forEach(id => { dist[id] = Infinity; parent[id] = null; });\n  if (!startId) startId = nodes[0];\n  dist[startId] = 0;\n\n  let actions = []; // action trace for step-by-step\n  // Implementation with chosen PQ style\n  if (pqImpl.value === 'binaryHeap') {\n    actions = primTraceWithHeap(startId, dist, parent);\n  } else {\n    actions = primTraceWithArray(startId, dist, parent);\n  }\n\n  algoState = {\n    startId: startId,\n    dist: dist,\n    parent: parent,\n    visited: visited,\n    actions: actions,\n    actionIndex: 0,\n    mstEdges: [],\n    mstWeight: 0\n  };\n  log(\"Prim initialized starting at node \" + startId + \". Actions: \" + actions.length);\n  redraw();\n  updatePQBox();\n  updateMSTMetrics();\n  return algoState;\n}\n\nfunction primTraceWithHeap(startId, distInit, parentInit) {\n  // We'll produce actions that describe the algorithm at a higher level.\n  // Action formats: {type: 'visit', u}, {type: 'relax', u, v, old, new, parent}, {type:'addMST', edgeId}\n  let edgesByNode = buildAdjList();\n  let nodes = Graph.nodes.map(n=>n.id);\n  let dist = Object.assign({}, distInit);\n  let parent = Object.assign({}, parentInit);\n  let visited = new Set();\n  let actions = [];\n\n  // simple binary heap implementing nodes keyed by dist\n  class Heap {\n    constructor() { this.a = []; }\n    push(key, id) { this.a.push({k:key,id:id}); this.bubbleUp(this.a.length-1); }\n    bubbleUp(i){ while(i>0){ let p=Math.floor((i-1)/2); if(this.a[p].k <= this.a[i].k) break; [this.a[p],this.a[i]]=[this.a[i],this.a[p]]; i=p; } }\n    pop(){ if(this.a.length===0) return null; let top=this.a[0]; let last=this.a.pop(); if(this.a.length){ this.a[0]=last; this.sink(0);} return top; }\n    sink(i){ while(true){ let l=2*i+1, r=2*i+2, smallest=i; if(l<this.a.length && this.a[l].k<this.a[smallest].k) smallest=l; if(r<this.a.length && this.a[r].k<this.a[smallest].k) smallest=r; if(smallest===i) break; [this.a[i],this.a[smallest]]=[this.a[smallest],this.a[i]]; i=smallest; } }\n    isEmpty(){ return this.a.length===0; }\n    dump(){ return this.a.map(x=>`${x.id}:${x.k}`).join(\", \"); }\n  }\n\n  let heap = new Heap();\n  heap.push(0, startId);\n\n  while (!heap.isEmpty()) {\n    let t = heap.pop();\n    let u = t.id;\n    if (visited.has(u)) continue;\n    actions.push({type:'visit', u:u});\n    visited.add(u);\n    if (parent[u] !== null) {\n      // find edge id between u and parent[u]\n      let e = Graph.edges.find(ed => (ed.u===u && ed.v===parent[u]) || (ed.v===u && ed.u===parent[u]));\n      if (e) actions.push({type:'addMST', edgeId: e.id});\n    }\n    // relax neighbors\n    for (let e of edgesByNode[u]) {\n      let v = (e.u === u ? e.v : e.u);\n      if (visited.has(v)) continue;\n      let old = dist[v];\n      if (e.w < old || (e.w === old && tieBreak.value === 'random' && Math.random()<0.5)) {\n        dist[v] = e.w;\n        parent[v] = u;\n        actions.push({type:'relax', u:u, v:v, edgeId:e.id, old: old, newVal: e.w, parent:u});\n        heap.push(dist[v], v);\n      }\n    }\n  }\n  return actions;\n}\n\nfunction primTraceWithArray(startId, distInit, parentInit) {\n  // Simple O(n^2) style trace: pick min unvisited by scanning\n  let edgesByNode = buildAdjList();\n  let nodes = Graph.nodes.map(n=>n.id);\n  let dist = Object.assign({}, distInit);\n  let parent = Object.assign({}, parentInit);\n  let visited = new Set();\n  let actions = [];\n  // initial\n  let n = nodes.length;\n  for (let iter=0; iter<n; iter++) {\n    // pick min\n    let minVal = Infinity; let minNode = null;\n    for (let id of nodes) {\n      if (!visited.has(id) && dist[id] < minVal) { minVal = dist[id]; minNode = id; }\n    }\n    if (minNode === null) break;\n    actions.push({type:'visit', u:minNode});\n    visited.add(minNode);\n    if (parent[minNode] !== null) {\n      let e = Graph.edges.find(ed => (ed.u===minNode && ed.v===parent[minNode]) || (ed.v===minNode && ed.u===parent[minNode]));\n      if (e) actions.push({type:'addMST', edgeId: e.id});\n    }\n    // relax\n    for (let e of edgesByNode[minNode]) {\n      let v = (e.u === minNode ? e.v : e.u);\n      if (visited.has(v)) continue;\n      let old = dist[v];\n      if (e.w < old || (e.w === old && tieBreak.value === 'random' && Math.random()<0.5)) {\n        dist[v] = e.w;\n        parent[v] = minNode;\n        actions.push({type:'relax', u:minNode, v:v, edgeId:e.id, old: old, newVal: e.w, parent:minNode});\n      }\n    }\n  }\n  return actions;\n}\n\n// Build adjacency list\nfunction buildAdjList() {\n  let adj = {};\n  Graph.nodes.forEach(n=> adj[n.id] = []);\n  Graph.edges.forEach(e=>{\n    if (!adj[e.u]) adj[e.u] = [];\n    if (!adj[e.v]) adj[e.v] = [];\n    adj[e.u].push(e);\n    adj[e.v].push(e);\n  });\n  return adj;\n}\n\n// Execution control\ninitPrimBtn.addEventListener('click', ()=> {\n  let start = Number(startNodeSelect.value) || (Graph.nodes[0] && Graph.nodes[0].id);\n  initPrim(start);\n});\nstepBtn.addEventListener('click', ()=> doStep());\nnextBtn.addEventListener('click', ()=> doStep());\nprevBtn.addEventListener('click', ()=> undoStep());\nrunBtn.addEventListener('click', ()=> startAutoRun());\npauseBtn.addEventListener('click', ()=> stopAutoRun());\ncompleteBtn.addEventListener('click', ()=> completeRun());\nexecMode.addEventListener('change', ()=> { modeIndicator.textContent = \"Mode: \" + execMode.value; });\n\nfunction doStep() {\n  if (!algoState) {\n    alert(\"Initialize algorithm first (Init/Reset).\");\n    return;\n  }\n  if (algoState.actionIndex >= algoState.actions.length) {\n    log(\"No more actions.\");\n    return;\n  }\n  let action = algoState.actions[algoState.actionIndex++];\n  applyAction(action);\n  updatePQBox();\n  redraw();\n  updateMSTMetrics();\n}\nfunction applyAction(action) {\n  if (action.type === 'visit') {\n    log(\"Visiting node \" + action.u);\n    algoState.visited.add(action.u);\n    // when visiting, if parent exists MST edge added handled by addMST action that follows\n  } else if (action.type === 'relax') {\n    log(\"Relax edge \" + action.edgeId + \" connecting \" + action.u + \" -> \" + action.v + \" (old:\" + action.old + \" new:\" + action.newVal + \")\");\n    algoState.dist[action.v] = action.newVal;\n    algoState.parent[action.v] = action.parent;\n    // PQ updated in updatePQBox\n  } else if (action.type === 'addMST') {\n    let e = getEdgeById(action.edgeId);\n    if (e && !algoState.mstEdges.some(me=>me.id===e.id)) {\n      algoState.mstEdges.push(e);\n      algoState.mstWeight += e.w;\n      log(\"Added edge \" + e.id + \" to MST (\" + e.u + \"-\" + e.v + \" w=\" + e.w + \")\");\n    }\n  } else {\n    log(\"Unknown action: \" + JSON.stringify(action));\n  }\n}\n\nfunction undoStep() {\n  if (!algoState) { alert(\"No algorithm state to undo.\"); return; }\n  if (algoState.actionIndex <= 0) { log(\"At beginning of trace.\"); return; }\n  // Recompute by replaying actions up to actionIndex-1\n  algoState.visited = new Set();\n  algoState.dist = {};\n  algoState.parent = {};\n  Graph.nodes.forEach(n => { algoState.dist[n.id] = Infinity; algoState.parent[n.id] = null; });\n  algoState.dist[algoState.startId] = 0;\n  algoState.mstEdges = [];\n  algoState.mstWeight = 0;\n  let target = algoState.actionIndex - 1;\n  for (let i=0;i<target;i++) {\n    let action = algoState.actions[i];\n    if (action.type === 'visit') {\n      algoState.visited.add(action.u);\n    } else if (action.type === 'relax') {\n      algoState.dist[action.v] = action.newVal;\n      algoState.parent[action.v] = action.parent;\n    } else if (action.type === 'addMST') {\n      let e = getEdgeById(action.edgeId);\n      if (e) { algoState.mstEdges.push(e); algoState.mstWeight += e.w; }\n    }\n  }\n  algoState.actionIndex = target;\n  redraw();\n  updatePQBox();\n  updateMSTMetrics();\n  log(\"Stepped back to action \" + algoState.actionIndex);\n}\n\nfunction startAutoRun() {\n  if (!algoState) { alert(\"Initialize algorithm first.\"); return; }\n  stopAutoRun();\n  playTimer = setInterval(()=> {\n    if (algoState.actionIndex >= algoState.actions.length) {\n      stopAutoRun();\n      log(\"Auto-run complete.\");\n      return;\n    }\n    if (execMode.value === 'manual') {\n      stopAutoRun();\n      log(\"Auto-run stopped because mode is manual.\");\n      return;\n    }\n    doStep();\n  }, Number(speed.value));\n  log(\"Auto-run started.\");\n}\nfunction stopAutoRun() {\n  if (playTimer) clearInterval(playTimer);\n  playTimer = null;\n  log(\"Auto-run paused.\");\n}\nfunction completeRun() {\n  if (!algoState) { alert(\"Initialize first.\"); return; }\n  while (algoState.actionIndex < algoState.actions.length) doStep();\n  log(\"Completed run.\");\n}\n\nfunction updatePQBox() {\n  if (!algoState) { pqbox.textContent = \"\"; return; }\n  // For visualization purposes, compute a snapshot of PQ according to chosen implementation\n  if (pqImpl.value === 'binaryHeap') {\n    // Reconstruct heap by simulating pushes during actions up to current index\n    // Simulate heap state by scanning relax actions so far and last visit pops\n    let pushed = [];\n    for (let i=0;i<algoState.actionIndex;i++) {\n      let action = algoState.actions[i];\n      if (action.type === 'relax') {\n        pushed.push({id: action.v, k: action.newVal});\n      } else if (action.type === 'visit') {\n        // remove visited if present; pop would remove etc -> we'll mark\n        pushed = pushed.filter(p => p.id !== action.u);\n      }\n    }\n    pqbox.textContent = pushed.map(p => p.id + \":\" + p.k).join(\", \");\n  } else {\n    // simple array: show current dist for unvisited\n    let arr = [];\n    for (let n of Graph.nodes) {\n      if (algoState.visited.has(n.id)) continue;\n      arr.push(n.id + \":\" + (algoState.dist[n.id]===Infinity ? \"Inf\" : algoState.dist[n.id]));\n    }\n    pqbox.textContent = arr.join(\", \");\n  }\n}\n\nfunction updateMSTMetrics() {\n  if (!algoState) {\n    mstWeightSpan.textContent = \"0\";\n    mstEdgesCountSpan.textContent = \"0\";\n  } else {\n    mstWeightSpan.textContent = algoState.mstWeight;\n    mstEdgesCountSpan.textContent = algoState.mstEdges.length;\n  }\n}\n\n// Compute MST full (one-shot)\ncomputeMSTBtn.addEventListener('click', ()=> {\n  if (Graph.nodes.length === 0) return;\n  let start = Number(startNodeSelect.value) || Graph.nodes[0].id;\n  initPrim(start);\n  completeRun();\n  redraw();\n  updateMSTMetrics();\n});\n\n// Compare with Kruskal\ncompareKruskalBtn.addEventListener('click', ()=> {\n  let kr = computeKruskal();\n  let prim = algoState ? {weight: algoState.mstWeight, edges: (algoState.mstEdges || []).map(e=>e.id)} : null;\n  alert(\"Kruskal MST weight: \" + kr.weight + \" edges: \" + kr.edges.map(e=>e.id).join(\", \"));\n  log(\"Kruskal produced weight \" + kr.weight + \".\");\n});\n\n// Kruskal implementation (for comparison)\nfunction computeKruskal() {\n  let edgesCopy = Graph.edges.slice().sort((a,b) => a.w - b.w);\n  let parent = {};\n  Graph.nodes.forEach(n => parent[n.id] = n.id);\n  function find(x){ return parent[x] === x ? x : (parent[x] = find(parent[x])); }\n  let mstEdges = [];\n  let weight = 0;\n  for (let e of edgesCopy) {\n    let ru = find(e.u), rv = find(e.v);\n    if (ru !== rv) {\n      parent[ru] = rv;\n      mstEdges.push(e);\n      weight += e.w;\n    }\n  }\n  return {edges: mstEdges, weight: weight};\n}\n\n// Misc: rebuild UI after Graph changes\nfunction rebuildAfterGraphChange() {\n  // ensure no selection invalid\n  if (selection.type === 'node' && !getNodeById(selection.id)) selection = {type:null,id:null};\n  if (selection.type === 'edge' && !getEdgeById(selection.id)) selection = {type:null,id:null};\n  redraw();\n  updateAdjView();\n  updateStartNodeSelect();\n  updatePQBox();\n}\n\n// Initialize default state\n(function init() {\n  // initial history\n  saveHistory('init');\n  redraw();\n  // Add sample graph\n  generateRandomGraph(7, 35, 1, 20);\n})();\n\n\n// Allow manual mode: pick next node/edge when execMode === 'manual'\nsvg.addEventListener('dblclick', (evt) => {\n  // in manual mode, allow selecting an edge to add to MST if it's valid next step\n  if (execMode.value !== 'manual') return;\n  if (!algoState) { alert(\"Initialize algorithm first.\"); return; }\n  // find nearest edge clicked\n  let target = evt.target;\n  if (target.tagName === 'line') {\n    let id = Number(target.getAttribute('data-edge-id'));\n    let e = getEdgeById(id);\n    if (!e) return;\n    // Manual rule:\n    // It's valid to add edge (u,v) if exactly one endpoint is in visited and the other is not,\n    // and the edge weight equals current dist of the outside node (i.e. it's the minimal connector).\n    let uVisited = algoState.visited.has(e.u);\n    let vVisited = algoState.visited.has(e.v);\n    if (uVisited === vVisited) {\n      alert(\"Edge must connect visited set with unvisited set.\");\n      return;\n    }\n    let outside = uVisited ? e.v : e.u;\n    if (algoState.dist[outside] !== e.w && algoState.dist[outside] !== Infinity) {\n      // Accept but warn: may not be minimal; user can force if they confirm\n      if (!confirm(\"Edge weight not equal to current best known distance (\"+algoState.dist[outside]+\"). Force add?\")) return;\n    }\n    // Add visit of outside node (simulate the corresponding visit and addMST)\n    // find the visit action index corresponding to outside being visited; but we can simply apply actions: mark visited, add edge\n    algoState.visited.add(outside);\n    algoState.mstEdges.push(e);\n    algoState.mstWeight += e.w;\n    log(\"Manual: added edge \" + e.id + \" connecting \" + e.u + \"-\" + e.v + \" to MST.\");\n    // After manual add, relax neighbors of the newly visited node by scanning edges\n    let edgesByNode = buildAdjList();\n    for (let edge of edgesByNode[outside]) {\n      let v = (edge.u === outside ? edge.v : edge.u);\n      if (algoState.visited.has(v)) continue;\n      if (edge.w < algoState.dist[v]) {\n        algoState.dist[v] = edge.w;\n        algoState.parent[v] = outside;\n        log(\"Manual: relaxed neighbor \" + v + \" via edge \" + edge.id + \" new dist \" + edge.w);\n      }\n    }\n    redraw();\n    updatePQBox();\n    updateMSTMetrics();\n  }\n});\n\n// Keyboard shortcuts\nwindow.addEventListener('keydown', (e) => {\n  if (e.key === ' ') { // space to toggle run/pause\n    if (playTimer) stopAutoRun(); else startAutoRun();\n    e.preventDefault();\n  }\n  if (e.key === 'ArrowRight') doStep();\n  if (e.key === 'ArrowLeft') undoStep();\n});\n\n// Provide a basic tour of advanced workflows for users via logs to encourage exploration\nsetTimeout(()=> {\n  log(\"Tip: Use 'Toggle Add-Edge Mode' to click two nodes and add an edge. Drag nodes by toggling 'Move Nodes'.\");\n  log(\"Tip: Press Space to start/pause auto-run. Double-click an edge in Manual mode to force-add it to the MST.\");\n  log(\"Tip: Export the graph JSON to save edits. Use Undo/Redo for state control. Compare Prim with Kruskal.\");\n}, 800);\n\n</script>\n</body>\n</html>"
