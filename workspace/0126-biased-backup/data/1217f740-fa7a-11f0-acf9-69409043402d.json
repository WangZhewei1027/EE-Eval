  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Authentication Exploration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre-wrap;\n  }\n  #log {\n    margin-top: 1em;\n    height: 200px;\n    overflow-y: scroll;\n    border: 1px solid black;\n    padding: 4px;\n    background: #fff;\n  }\n  label {\n    display: block;\n    margin: 0.3em 0 0 0;\n  }\n  button, input[type=\"text\"], input[type=\"password\"], select {\n    margin: 0.2em 0 0 0;\n  }\n</style>\n</head>\n<body>\n<h1>Authentication System Interactive Demo</h1>\n<p>\nThis demo simulates a rich, multi-step, multi-method authentication process.<br />\nYou can configure users, try multiple auth methods, adjust parameters and explore the workflows.\n</p>\n\n<div id=\"app\">\n\n  <fieldset>\n    <legend>User Setup / Management</legend>\n    <label for=\"newUsername\">Add New User (username):</label>\n    <input type=\"text\" id=\"newUsername\" />\n    <button id=\"addUserBtn\">Add User</button>\n\n    <label for=\"userList\">Existing Users:</label>\n    <select id=\"userList\" size=\"4\" style=\"width: 150px;\"></select>\n    <button id=\"deleteUserBtn\" disabled>Delete Selected User</button>\n\n    <div id=\"userDetails\" style=\"margin-top:1em;\"></div>\n  </fieldset>\n\n  <fieldset style=\"margin-top:1em;\">\n    <legend>Authentication Workflow Controls</legend>\n    <label for=\"authUserSelect\">Select User to Authenticate:</label>\n    <select id=\"authUserSelect\" style=\"width: 150px;\"></select>\n\n    <label for=\"authMethodSelect\">Choose Authentication Method:</label>\n    <select id=\"authMethodSelect\" style=\"width: 150px;\">\n      <option value=\"password\">Password</option>\n      <option value=\"totp\">TOTP (Time-based One-Time Password)</option>\n      <option value=\"securityQuestion\">Security Question</option>\n      <option value=\"emailCode\">Email Code (Simulated)</option>\n      <option value=\"captcha\">CAPTCHA</option>\n    </select>\n\n    <button id=\"startAuthBtn\">Start Authentication</button>\n  </fieldset>\n\n  <fieldset id=\"authStepFieldset\" style=\"margin-top:1em; display:none;\">\n    <legend>Authentication Step</legend>\n    <div id=\"authStepContent\"></div>\n    <button id=\"authBackBtn\" disabled>Back</button>\n    <button id=\"authNextBtn\" disabled>Next / Submit</button>\n  </fieldset>\n\n  <fieldset style=\"margin-top:1em;\">\n    <legend>Authentication Log & State</legend>\n    <button id=\"clearLogBtn\">Clear Log</button>\n    <div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n  </fieldset>\n\n</div>\n\n<script>\n// --- Data Structures ---\n\n// Each user has:\n// username: string\n// password: string (plaintext for demo, normally hashed)\n// totpSecret: string (for TOTP simulation)\n// securityQuestions: Array of {question:string, answer:string}\n// email: string (for email code simulation)\n// emailCode: string|null (current code, expires quickly)\n// captchaExpected: string (for CAPTCHA simulation)\n\n// For TOTP we'll simulate a 6-digit code incrementing every 30 seconds\n// For CAPTCHA we will generate random string user must enter\n\n// State tracking for authentication workflow:\nconst AuthStates = {\n  idle: 'idle',\n  inProgress: 'inProgress',\n  success: 'success',\n  failure: 'failure'\n};\n\nconst users = [];\n\nlet authSession = null;\n// authSession structure:\n// {\n//   user: userObject,\n//   method: string,\n//   step: number,\n//   history: Array of strings describing steps or inputs,\n//   tempData: {} - for storing OTP codes, email codes, captcha, attempts etc.\n// }\n\n// --- DOM Elements ---\nconst newUsernameInput = document.getElementById('newUsername');\nconst addUserBtn = document.getElementById('addUserBtn');\nconst userListSelect = document.getElementById('userList');\nconst deleteUserBtn = document.getElementById('deleteUserBtn');\nconst userDetailsDiv = document.getElementById('userDetails');\n\nconst authUserSelect = document.getElementById('authUserSelect');\nconst authMethodSelect = document.getElementById('authMethodSelect');\nconst startAuthBtn = document.getElementById('startAuthBtn');\n\nconst authStepFieldset = document.getElementById('authStepFieldset');\nconst authStepContent = document.getElementById('authStepContent');\nconst authBackBtn = document.getElementById('authBackBtn');\nconst authNextBtn = document.getElementById('authNextBtn');\n\nconst logDiv = document.getElementById('log');\nconst clearLogBtn = document.getElementById('clearLogBtn');\n\n// --- Logging ---\nfunction log(message) {\n  const time = new Date().toLocaleTimeString();\n  logDiv.textContent += `[${time}] ${message}\\n`;\n  logDiv.scrollTop = logDiv.scrollHeight;\n}\n\n// --- Utility Functions ---\nfunction generateTOTP(secret) {\n  // For demo: generate a 6-digit code based on current time & secret hash\n  // This is just simulated, not secure\n  const now = Math.floor(Date.now() / 30000);\n  let hash = 0;\n  for(let i = 0; i < secret.length; i++) {\n    hash = (hash * 31 + secret.charCodeAt(i)) & 0xffffffff;\n  }\n  const code = (now + hash) % 1000000;\n  return code.toString().padStart(6, '0');\n}\n\nfunction generateRandomCode(length = 6) {\n  let digits = '0123456789';\n  let code = '';\n  for(let i=0; i<length; i++) {\n    code += digits[Math.floor(Math.random() * digits.length)];\n  }\n  return code;\n}\n\nfunction generateCaptcha() {\n  // simple captcha: 5 letter uppercase string\n  const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';\n  let s = '';\n  for(let i=0; i<5; i++) {\n    s += letters[Math.floor(Math.random() * letters.length)];\n  }\n  return s;\n}\n\nfunction findUser(username) {\n  return users.find(u => u.username === username);\n}\n\nfunction refreshUserList() {\n  userListSelect.innerHTML = '';\n  users.forEach(user => {\n    const opt = document.createElement('option');\n    opt.value = user.username;\n    opt.textContent = user.username;\n    userListSelect.appendChild(opt);\n  });\n  deleteUserBtn.disabled = userListSelect.selectedIndex < 0;\n  refreshAuthUserSelect();\n  refreshUserDetails();\n}\nfunction refreshAuthUserSelect() {\n  authUserSelect.innerHTML = '';\n  users.forEach(user => {\n    const opt = document.createElement('option');\n    opt.value = user.username;\n    opt.textContent = user.username;\n    authUserSelect.appendChild(opt);\n  });\n}\n\nfunction refreshUserDetails() {\n  const selectedUser = userListSelect.value ? findUser(userListSelect.value) : null;\n  if (!selectedUser) {\n    userDetailsDiv.textContent = '(No user selected)';\n    deleteUserBtn.disabled = true;\n    return;\n  }\n  deleteUserBtn.disabled = false;\n\n  let details = `Username: ${selectedUser.username}\\n`;\n  details += `Password: ${selectedUser.password ? '(set)' : '(none)'}\\n`;\n  details += `Email: ${selectedUser.email ? selectedUser.email : '(none)'}\\n`;\n  details += `TOTP Secret: ${selectedUser.totpSecret ? selectedUser.totpSecret : '(none)'}\\n`;\n  details += `Security Questions (${selectedUser.securityQuestions.length}):\\n`;\n  selectedUser.securityQuestions.forEach((qa, idx) => {\n    details += `  Q${idx+1}: ${qa.question}\\n`;\n  });\n\n  userDetailsDiv.textContent = details;\n}\n\nfunction validateUsername(name) {\n  if (!name) return false;\n  if (users.some(u => u.username === name)) return false;\n  if (!/^[a-zA-Z0-9_]+$/.test(name)) return false;\n  return true;\n}\n\n// --- User Management ---\naddUserBtn.addEventListener('click', () => {\n  let username = newUsernameInput.value.trim();\n  if (!validateUsername(username)) {\n    alert('Invalid or duplicate username. Use alphanumeric and underscore only, unique.');\n    return;\n  }\n  // Add user with default empty fields\n  const newUser = {\n    username,\n    password: '',\n    totpSecret: '',\n    securityQuestions: [],\n    email: '',\n    emailCode: null,\n    captchaExpected: null\n  };\n  users.push(newUser);\n  log(`User added: '${username}'.`);\n\n  refreshUserList();\n  newUsernameInput.value = '';\n});\n\nuserListSelect.addEventListener('change', () => {\n  refreshUserDetails();\n});\n\ndeleteUserBtn.addEventListener('click', () => {\n  const selected = userListSelect.value;\n  if (!selected) return;\n  const idx = users.findIndex(u => u.username === selected);\n  if (idx >= 0) {\n    users.splice(idx,1);\n    log(`User deleted: '${selected}'.`);\n    refreshUserList();\n  }\n});\n\n// --- User Editing Interface ---\nuserDetailsDiv.addEventListener('click', () => {\n  // No editing here, it's display only\n});\n\n// Let's create a separate interface below user details for editing user parameters:\nfunction renderUserEditor() {\n  if (!userListSelect.value) {\n    return;\n  }\n  const user = findUser(userListSelect.value);\n  if (!user) {\n    return;\n  }\n  let html = '';\n  html += 'Edit User Fields:\\n';\n\n  html += 'Password (plain text): ';\n  html += '\\n';\n  html += '<input type=\"password\" id=\"editPwd\" value=\"' + (user.password || '') + '\" style=\"width:150px;\">\\n';\n\n  html += 'Email: ';\n  html += '\\n';\n  html += '<input type=\"text\" id=\"editEmail\" value=\"' + (user.email || '') + '\" style=\"width:200px;\">\\n';\n\n  html += 'TOTP Secret: ';\n  html += '\\n';\n  html += '<input type=\"text\" id=\"editTOTP\" value=\"' + (user.totpSecret || '') + '\" style=\"width:100px;\">\\n';\n\n  html += 'Security Questions (Add/Modify/Remove):';\n  html += '\\n';\n\n  html += '<div id=\"secQList\"></div>\\n';\n\n  html += '<button id=\"addSecQBtn\">Add Security Question</button>\\n';\n\n  userDetailsDiv.innerHTML = '';\n  // Create inputs via DOM for better interaction:\n  // We'll build a very basic form interface here.\n  // Clear previous content:\n  userDetailsDiv.innerHTML = '';\n\n  // Password input\n  const pwdLabel = document.createElement('label');\n  pwdLabel.textContent = 'Password (plain text):';\n  const pwdInput = document.createElement('input');\n  pwdInput.type = 'password';\n  pwdInput.value = user.password;\n  pwdInput.style.width = '150px';\n  pwdInput.id = 'editPwd';\n\n  // Email input\n  const emailLabel = document.createElement('label');\n  emailLabel.textContent = 'Email:';\n  const emailInput = document.createElement('input');\n  emailInput.type = 'text';\n  emailInput.value = user.email;\n  emailInput.style.width = '200px';\n  emailInput.id = 'editEmail';\n\n  // TOTP secret input\n  const totpLabel = document.createElement('label');\n  totpLabel.textContent = 'TOTP Secret:';\n  const totpInput = document.createElement('input');\n  totpInput.type = 'text';\n  totpInput.value = user.totpSecret;\n  totpInput.style.width = '100px';\n  totpInput.id = 'editTOTP';\n\n  // Security Questions container\n  const sqLabel = document.createElement('label');\n  sqLabel.textContent = 'Security Questions (Add/Modify/Remove):';\n  const sqList = document.createElement('div');\n  sqList.id = 'secQList';\n\n  // Add Security Question Button\n  const addSQBtn = document.createElement('button');\n  addSQBtn.textContent = 'Add Security Question';\n  addSQBtn.id = 'addSecQBtn';\n\n  userDetailsDiv.appendChild(pwdLabel);\n  userDetailsDiv.appendChild(document.createElement('br'));\n  userDetailsDiv.appendChild(pwdInput);\n\n  userDetailsDiv.appendChild(document.createElement('br'));\n  userDetailsDiv.appendChild(emailLabel);\n  userDetailsDiv.appendChild(document.createElement('br'));\n  userDetailsDiv.appendChild(emailInput);\n\n  userDetailsDiv.appendChild(document.createElement('br'));\n  userDetailsDiv.appendChild(totpLabel);\n  userDetailsDiv.appendChild(document.createElement('br'));\n  userDetailsDiv.appendChild(totpInput);\n\n  userDetailsDiv.appendChild(document.createElement('br'));\n  userDetailsDiv.appendChild(sqLabel);\n  userDetailsDiv.appendChild(document.createElement('br'));\n  userDetailsDiv.appendChild(sqList);\n\n  userDetailsDiv.appendChild(document.createElement('br'));\n  userDetailsDiv.appendChild(addSQBtn);\n\n  function renderSQList() {\n    sqList.innerHTML = '';\n    user.securityQuestions.forEach((qa, idx) => {\n      const qDiv = document.createElement('div');\n      qDiv.style.borderTop = '1px solid black';\n      qDiv.style.marginTop = '3px';\n      qDiv.style.paddingTop = '3px';\n\n      const qLabel = document.createElement('label');\n      qLabel.textContent = `Q${idx+1}:`;\n      const qInput = document.createElement('input');\n      qInput.type = 'text';\n      qInput.value = qa.question;\n      qInput.style.width = '250px';\n\n      const aLabel = document.createElement('label');\n      aLabel.textContent = `A${idx+1}:`;\n      aLabel.style.marginLeft = '10px';\n      const aInput = document.createElement('input');\n      aInput.type = 'text';\n      aInput.value = qa.answer;\n      aInput.style.width = '150px';\n\n      const remBtn = document.createElement('button');\n      remBtn.textContent = 'Remove';\n      remBtn.style.marginLeft = '10px';\n\n      // Change handlers\n      qInput.addEventListener('input', () => {\n        user.securityQuestions[idx].question = qInput.value;\n      });\n      aInput.addEventListener('input', () => {\n        user.securityQuestions[idx].answer = aInput.value;\n      });\n      remBtn.addEventListener('click', () => {\n        user.securityQuestions.splice(idx, 1);\n        renderSQList();\n        log(`Security question #${idx+1} removed from user '${user.username}'.`);\n      });\n\n      qDiv.appendChild(qLabel);\n      qDiv.appendChild(qInput);\n      qDiv.appendChild(aLabel);\n      qDiv.appendChild(aInput);\n      qDiv.appendChild(remBtn);\n\n      sqList.appendChild(qDiv);\n    });\n  }\n\n  renderSQList();\n\n  addSQBtn.addEventListener('click', () => {\n    user.securityQuestions.push({question:'', answer:''});\n    renderSQList();\n    log(`Added new security question slot for user '${user.username}'.`);\n  });\n\n  // Save on input changes for pwd,email,totp\n  pwdInput.addEventListener('input', () => {\n    user.password = pwdInput.value;\n  });\n  emailInput.addEventListener('input', () => {\n    user.email = emailInput.value;\n  });\n  totpInput.addEventListener('input', () => {\n    user.totpSecret = totpInput.value.toUpperCase().replace(/[^A-Z0-9]/g, '');\n  });\n\n}\nuserListSelect.addEventListener('change', renderUserEditor);\n\n// --- Authentication Process ---\nstartAuthBtn.addEventListener('click', () => {\n  const username = authUserSelect.value;\n  if (!username) {\n    alert('Select a user to authenticate.');\n    return;\n  }\n  const user = findUser(username);\n  if (!user) {\n    alert('Selected user not found.');\n    return;\n  }\n  const method = authMethodSelect.value;\n\n  // Initialize authSession\n  authSession = {\n    user,\n    method,\n    step: 0,\n    history: [],\n    tempData: {\n      attempts: 0,\n      emailCodeExpiresAt: null,\n      captcha: null,\n      captchaTries: 0,\n      lastInput: null,\n      totpCounter: 0\n    },\n    state: AuthStates.inProgress\n  };\n\n  log(`Authentication started for user '${user.username}' via method '${method}'.`);\n\n  authStepFieldset.style.display = 'block';\n  authBackBtn.disabled = true; // no going back at start\n  authNextBtn.disabled = false;\n\n  renderAuthStep();\n});\n\nauthBackBtn.addEventListener('click', () => {\n  if (!authSession) return;\n  if (authSession.step > 0) {\n    authSession.step--;\n    log(`Back to step ${authSession.step + 1} in authentication for '${authSession.user.username}'.`);\n    authNextBtn.disabled = false;\n    if (authSession.step === 0) {\n      authBackBtn.disabled = true;\n    }\n    renderAuthStep();\n  }\n});\n\nauthNextBtn.addEventListener('click', () => {\n  if (!authSession) return;\n\n  // Process input and validate current step\n  const currentStepResult = processAuthStepInput();\n\n  if (currentStepResult === false) {\n    // input invalid or failed, stay in step, do not increment\n    return;\n  }\n  if (authSession.state === AuthStates.success) {\n    // End workflow\n    authStepContent.innerHTML = 'Authentication Success! You are now logged in.';\n    authBackBtn.disabled = true;\n    authNextBtn.disabled = true;\n    log(`Authentication successful for user '${authSession.user.username}' using method '${authSession.method}'.`);\n    return;\n  }\n  if (authSession.state === AuthStates.failure) {\n    authStepContent.innerHTML = 'Authentication Failed. Please try again or start over.';\n    authBackBtn.disabled = true;\n    authNextBtn.disabled = true;\n    log(`Authentication failed for user '${authSession.user.username}' using method '${authSession.method}'.`);\n    return;\n  }\n\n  authSession.step++;\n  authBackBtn.disabled = false;\n  renderAuthStep();\n});\n\n// Clear log\nclearLogBtn.addEventListener('click', () => {\n  logDiv.textContent = '';\n});\n\n// --- Render Authentication Steps ---\n// Each method has its own workflow with multiple steps where applicable\n\nfunction renderAuthStep() {\n  if (!authSession) return;\n  const user = authSession.user;\n  const method = authSession.method;\n  const step = authSession.step;\n\n  // Clear previous content, will render new\n  authStepContent.innerHTML = '';\n\n  // We'll create inputs/buttons dynamically depending on method and step\n\n  if (method === 'password') {\n    // Single step: enter password\n\n    if (step === 0) {\n      const label = document.createElement('label');\n      label.textContent = 'Enter password:';\n      const pwdInput = document.createElement('input');\n      pwdInput.type = 'password';\n      pwdInput.id = 'authPasswordInput';\n\n      authStepContent.appendChild(label);\n      authStepContent.appendChild(document.createElement('br'));\n      authStepContent.appendChild(pwdInput);\n      pwdInput.focus();\n    } else {\n      // No further steps, success or failure handled in processAuthStepInput\n      authStepContent.textContent = 'No further steps.';\n    }\n\n  } else if (method === 'totp') {\n    // We simulate TOTP codes, 2 steps: enter secret or show code, then enter TOTP\n\n    // Steps:\n    // 0: If user has no totpSecret, ask to set it (can simulate secret entry)\n    // 1: Show current valid TOTP code (simulate), prompt for code entry\n    // 2: Validate code\n\n    if (step === 0) {\n      if (!user.totpSecret) {\n        const label = document.createElement('label');\n        label.textContent = 'No TOTP secret set. Enter a secret string for TOTP (alphanumeric):';\n        const secretInput = document.createElement('input');\n        secretInput.type = 'text';\n        secretInput.id = 'authTOTPSecretInput';\n        secretInput.value = '';\n\n        authStepContent.appendChild(label);\n        authStepContent.appendChild(document.createElement('br'));\n        authStepContent.appendChild(secretInput);\n        secretInput.focus();\n      } else {\n        // Skip to next step immediately\n        authSession.step++;\n        renderAuthStep();\n      }\n    } else if (step === 1) {\n      // Show current code (for demo) and ask user to enter code\n      authStepContent.textContent = `Current TOTP code (simulated): ${generateTOTP(user.totpSecret)}\\nEnter the 6-digit code:`;\n\n      const codeInput = document.createElement('input');\n      codeInput.type = 'text';\n      codeInput.id = 'authTOTPCodeInput';\n      codeInput.maxLength = 6;\n      codeInput.style.width = '50px';\n\n      authStepContent.appendChild(document.createElement('br'));\n      authStepContent.appendChild(codeInput);\n      codeInput.focus();\n\n    } else if (step === 2) {\n      // Wait for code validation (processAuthStepInput)\n      authStepContent.textContent = 'Validating code...';\n    }\n  } else if (method === 'securityQuestion') {\n    // Multiple questions, ask them one by one\n    const totalQ = user.securityQuestions.length;\n    if (totalQ === 0) {\n      authStepContent.textContent = 'User has no security questions configured.';\n      authNextBtn.disabled = true;\n      authBackBtn.disabled = false;\n      return;\n    }\n    if (step < totalQ) {\n      const q = user.securityQuestions[step].question || '(No question set)';\n      const label = document.createElement('label');\n      label.textContent = `Question ${(step + 1)}: ${q}`;\n      const ansInput = document.createElement('input');\n      ansInput.type = 'text';\n      ansInput.id = 'authSQAnswerInput';\n      authStepContent.appendChild(label);\n      authStepContent.appendChild(document.createElement('br'));\n      authStepContent.appendChild(ansInput);\n      ansInput.focus();\n\n    } else {\n      authStepContent.textContent = 'No more questions.';\n    }\n  } else if (method === 'emailCode') {\n    // Steps:\n    // 0: send email code (simulate), display sending message\n    // 1: enter the code\n    // 2: validate code\n\n    if (step === 0) {\n      if (!user.email) {\n        authStepContent.textContent = 'User has no email set for sending code.';\n        authNextBtn.disabled = true;\n        return;\n      }\n      const code = generateRandomCode();\n      user.emailCode = code;\n      authSession.tempData.emailCodeExpiresAt = Date.now() + 120 * 1000; // expire in 2 minutes\n      authStepContent.textContent = `Email code sent to ${user.email} (simulated): ${code}\\nClick Next to enter code.`;\n      authNextBtn.disabled = false;\n    } else if (step === 1) {\n      const label = document.createElement('label');\n      label.textContent = 'Enter the 6-digit code received in email:';\n      const codeInput = document.createElement('input');\n      codeInput.type = 'text';\n      codeInput.id = 'authEmailCodeInput';\n      codeInput.maxLength = 6;\n      codeInput.style.width = '60px';\n      authStepContent.appendChild(label);\n      authStepContent.appendChild(document.createElement('br'));\n      authStepContent.appendChild(codeInput);\n      codeInput.focus();\n    } else if (step === 2) {\n      authStepContent.textContent = 'Validating code...';\n    }\n  } else if (method === 'captcha') {\n    // Single step: show captcha and prompt to type it\n\n    if (step === 0) {\n      const captcha = generateCaptcha();\n      authSession.tempData.captcha = captcha;\n      authSession.tempData.captchaTries = 0;\n\n      const label = document.createElement('label');\n      label.textContent = 'CAPTCHA: Type the characters shown below:';\n\n      const captchaShow = document.createElement('div');\n      captchaShow.textContent = captcha;\n      captchaShow.style.fontWeight = 'bold';\n      captchaShow.style.letterSpacing = '0.3em';\n      captchaShow.style.userSelect = 'none';\n      captchaShow.style.marginTop = '2px';\n      captchaShow.style.marginBottom = '2px';\n\n      const input = document.createElement('input');\n      input.type = 'text';\n      input.id = 'authCaptchaInput';\n      input.maxLength = 5;\n      input.style.width = '80px';\n\n      authStepContent.appendChild(label);\n      authStepContent.appendChild(captchaShow);\n      authStepContent.appendChild(input);\n      input.focus();\n    } else if (step === 1) {\n      // Validate captcha result handled on Next; render a message waiting validation\n      authStepContent.textContent = 'Validating CAPTCHA...';\n    }\n  }\n}\n\n// Process user input from auth step, return true if proceed/advance, false if retry or error shown\nfunction processAuthStepInput() {\n  if (!authSession) return false;\n  const user = authSession.user;\n  const method = authSession.method;\n  const step = authSession.step;\n  const temp = authSession.tempData;\n\n  if (method === 'password') {\n    if (step === 0) {\n      const pwdInput = document.getElementById('authPasswordInput');\n      if (!pwdInput) return false;\n      const inputPwd = pwdInput.value;\n      authSession.history.push(`Entered password: ${inputPwd ? '(hidden)' : '(empty)'}`);\n\n      if (inputPwd === user.password && user.password !== '') {\n        authSession.state = AuthStates.success;\n        return true;\n      } else {\n        log(`Password incorrect for user '${user.username}'.`);\n        alert('Password incorrect.');\n        return false;\n      }\n    }\n  } else if (method === 'totp') {\n    if (step === 0) {\n      if (!user.totpSecret) {\n        const secretInput = document.getElementById('authTOTPSecretInput');\n        if (!secretInput) return false;\n        const secret = secretInput.value.trim().toUpperCase().replace(/[^A-Z0-9]/g, '');\n        if (!secret) {\n          alert('TOTP secret cannot be empty and must be alphanumeric.');\n          return false;\n        }\n        user.totpSecret = secret;\n        log(`Set TOTP secret for user '${user.username}': ${secret}`);\n        authSession.step++; // skip to showing code\n        renderAuthStep();\n        return false;\n      }\n    } else if (step === 1) {\n      const codeInput = document.getElementById('authTOTPCodeInput');\n      if (!codeInput) return false;\n      const code = codeInput.value.trim();\n      authSession.history.push(`Entered TOTP code: ${code}`);\n      if (code.length !== 6 || !/^\\d{6}$/.test(code)) {\n        alert('TOTP code must be 6 digit number.');\n        return false;\n      }\n      const expectedCode = generateTOTP(user.totpSecret);\n      if (code === expectedCode) {\n        authSession.state = AuthStates.success;\n        return true;\n      } else {\n        log(`TOTP code incorrect. Expected: ${expectedCode}, got: ${code}`);\n        alert('TOTP code incorrect.');\n        return false;\n      }\n    }\n  } else if (method === 'securityQuestion') {\n    const totalQ = user.securityQuestions.length;\n    if (step < totalQ) {\n      const ansInput = document.getElementById('authSQAnswerInput');\n      if (!ansInput) return false;\n      const answer = ansInput.value.trim();\n      authSession.history.push(`Answered Q${step+1}: '${answer}'`);\n\n      const correctAnswer = user.securityQuestions[step].answer.trim();\n      if (answer.toLowerCase() === correctAnswer.toLowerCase()) {\n        if (step + 1 === totalQ) {\n          authSession.state = AuthStates.success;\n          return true;\n        }\n        return true;\n      } else {\n        authSession.tempData.attempts++;\n        if (authSession.tempData.attempts >= 3) {\n          authSession.state = AuthStates.failure;\n          log(`Too many wrong answers for security questions for user '${user.username}'.`);\n          alert('Too many wrong answers. Authentication failed.');\n        } else {\n          alert(`Answer incorrect for question ${step + 1}. Attempts left: ${3 - authSession.tempData.attempts}`);\n          return false;\n        }\n      }\n    }\n  } else if (method === 'emailCode') {\n    if (step === 0) {\n      // email sent message shown, just proceed to enter code\n      return true;\n    } else if (step === 1) {\n      const codeInput = document.getElementById('authEmailCodeInput');\n      if (!codeInput) return false;\n      const code = codeInput.value.trim();\n      authSession.history.push(`Entered email code: ${code}`);\n\n      if (!user.emailCode || Date.now() > authSession.tempData.emailCodeExpiresAt) {\n        alert('Email code has expired. Restart authentication.');\n        authSession.state = AuthStates.failure;\n        return true;\n      }\n      if (code === user.emailCode) {\n        user.emailCode = null; // consume code\n        authSession.state = AuthStates.success;\n        return true;\n      } else {\n        temp.attempts = (temp.attempts || 0) + 1;\n        if (temp.attempts >= 3) {\n          authSession.state = AuthStates.failure;\n          log(`Too many wrong email code entries for user '${user.username}'.`);\n          alert('Too many wrong codes. Authentication failed.');\n          return true;\n        } else {\n          alert(`Incorrect code. Attempts left: ${3 - temp.attempts}`);\n          return false;\n        }\n      }\n    }\n  } else if (method === 'captcha') {\n    if (step === 0) {\n      const input = document.getElementById('authCaptchaInput');\n      if (!input) return false;\n      const val = input.value.trim().toUpperCase();\n      authSession.history.push(`Entered CAPTCHA: '${val}'`);\n      if (val === authSession.tempData.captcha) {\n        authSession.state = AuthStates.success;\n        return true;\n      } else {\n        authSession.tempData.captchaTries++;\n        if (authSession.tempData.captchaTries >= 3) {\n          authSession.state = AuthStates.failure;\n          alert('Too many failed CAPTCHA attempts.');\n          log(`CAPTCHA failed for user '${user.username}'.`);\n          return true;\n        } else {\n          alert(`CAPTCHA incorrect. Attempts left: ${3 - authSession.tempData.captchaTries}`);\n          return false;\n        }\n      }\n    }\n  }\n\n  return false;\n}\n\n// On page load, populate some data for deep exploration:\nfunction seedUsers() {\n  users.push(\n    {\n      username: 'alice',\n      password: 'password123',\n      totpSecret: 'ABCDEF123456',\n      securityQuestions: [\n        {question: 'Your mother\\'s maiden name?', answer: 'Smith'},\n        {question: 'Favorite color?', answer: 'Blue'}\n      ],\n      email: 'alice@example.com',\n      emailCode: null,\n      captchaExpected: null\n    },\n    {\n      username: 'bob',\n      password: 'b0bpwd',\n      totpSecret: '',\n      securityQuestions: [\n        {question: 'City you were born in?', answer: 'Paris'}\n      ],\n      email: 'bob@example.com',\n      emailCode: null,\n      captchaExpected: null\n    },\n    {\n      username: 'charlie',\n      password: '',\n      totpSecret: 'XYZ789',\n      securityQuestions: [],\n      email: '',\n      emailCode: null,\n      captchaExpected: null\n    }\n  );\n  refreshUserList();\n}\n\nseedUsers();\nrenderUserEditor();\n\n</script>\n</body>\n</html>"
