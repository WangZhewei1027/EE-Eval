    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Semaphore Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Semaphore Control System</h1>\n    <h2>Controls</h2>\n    <button id=\"btnRequest\">Request Access</button>\n    <button id=\"btnRelease\">Release Access</button>\n    <h3>Status</h3>\n    <div id=\"statusText\">Available: 1</div>\n    <h3>Count</h3>\n    <input type=\"number\" id=\"semaphoreCount\" value=\"1\" min=\"1\" step=\"1\">\n    <button id=\"setCount\">Set Semaphore Count</button>\n    \n    <h3>Users</h3>\n    <div id=\"userContainer\"></div>\n    <input type=\"text\" id=\"username\" placeholder=\"Enter username\">\n    <button id=\"addUser\">Add User</button>\n\n    <h3>User Actions</h3>\n    <select id=\"userSelect\"></select>\n    <button id=\"requestAccess\">Request Access</button>\n    <button id=\"releaseAccess\">Release Access</button>\n\n    <script>\n        let semaphoreCount = 1;\n        let availableCount = semaphoreCount;\n        let userStates = {};\n        let userList = [];\n        \n        document.getElementById(\"btnRequest\").onclick = requestAccess;\n        document.getElementById(\"btnRelease\").onclick = releaseAccess;\n        document.getElementById(\"setCount\").onclick = updateSemaphoreCount;\n        document.getElementById(\"addUser\").onclick = addUser;\n        document.getElementById(\"requestAccess\").onclick = userRequestAccess;\n        document.getElementById(\"releaseAccess\").onclick = userReleaseAccess;\n\n        function updateStatus() {\n            document.getElementById(\"statusText\").innerText = `Available: ${availableCount}`;\n        }\n\n        function requestAccess() {\n            if (availableCount > 0) {\n                availableCount--;\n                updateStatus();\n            } else {\n                alert(\"No available permits!\");\n            }\n        }\n\n        function releaseAccess() {\n            if (semaphoreCount > availableCount) {\n                availableCount++;\n                updateStatus();\n            } else {\n                alert(\"Cannot release more than available!\");\n            }\n        }\n\n        function updateSemaphoreCount() {\n            const newCount = parseInt(document.getElementById(\"semaphoreCount\").value);\n            if (newCount >= 1) {\n                semaphoreCount = newCount;\n                availableCount = semaphoreCount;\n                updateStatus();\n            } else {\n                alert(\"Count must be at least 1.\");\n            }\n        }\n\n        function addUser() {\n            const username = document.getElementById(\"username\").value;\n            if (username && !userList.includes(username)) {\n                userList.push(username);\n                userStates[username] = {hasAccess: false};\n                updateUserSelect();\n                document.getElementById(\"username\").value = \"\";\n            } else {\n                alert(\"Enter a valid username.\");\n            }\n        }\n\n        function updateUserSelect() {\n            const userSelect = document.getElementById(\"userSelect\");\n            userSelect.innerHTML = \"\";\n            userList.forEach(user => {\n                const option = document.createElement(\"option\");\n                option.value = user;\n                option.textContent = user;\n                userSelect.appendChild(option);\n            });\n        }\n\n        function userRequestAccess() {\n            const selectedUser = document.getElementById(\"userSelect\").value;\n            if (selectedUser && availableCount > 0) {\n                userStates[selectedUser].hasAccess = true;\n                availableCount--;\n                updateStatus();\n            } else if (!selectedUser) {\n                alert(\"Select a user.\");\n            } else {\n                alert(\"No available permits!\");\n            }\n        }\n\n        function userReleaseAccess() {\n            const selectedUser = document.getElementById(\"userSelect\").value;\n            if (selectedUser && userStates[selectedUser].hasAccess) {\n                userStates[selectedUser].hasAccess = false;\n                availableCount++;\n                updateStatus();\n            } else if (!selectedUser) {\n                alert(\"Select a user.\");\n            } else {\n                alert(\"User does not have access!\");\n            }\n        }\n\n        updateStatus();\n    </script>\n</body>\n</html>"
