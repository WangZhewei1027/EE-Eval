  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Compiler Playground</title>\n<style>\n/* Minimal styling only to make layout usable; visually plain otherwise */\nbody { margin: 12px; font-family: monospace; color: black; background: white; }\nsection { margin-bottom: 12px; }\nlabel { display: inline-block; margin-right: 8px; }\ntextarea { width: 100%; height: 160px; }\ninput[type=\"text\"], input[type=\"number\"] { width: 160px; }\nbutton { margin: 2px; }\nselect { width: 200px; }\npre { white-space: pre-wrap; word-wrap: break-word; border: 1px solid #ddd; padding: 6px; min-height: 40px; }\n.details { border: 1px solid #eee; padding: 6px; }\nul { margin: 4px 0 4px 20px; padding: 0; }\n</style>\n</head>\n<body>\n\n<h1>Compiler Playground</h1>\n\n<section>\n  <strong>Files</strong>\n  <div>\n    <label for=\"fileSelect\">Open file:</label>\n    <select id=\"fileSelect\"></select>\n    <button id=\"newFileBtn\">New File</button>\n    <button id=\"importFileBtn\">Import .txt</button>\n    <input type=\"file\" id=\"fileInput\" style=\"display:none\">\n    <button id=\"saveFileBtn\">Save Changes</button>\n    <button id=\"deleteFileBtn\">Delete File</button>\n    <button id=\"duplicateFileBtn\">Duplicate</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <label>Filename:</label><input type=\"text\" id=\"fileNameInput\">\n  </div>\n  <div style=\"margin-top:6px;\">\n    <label>Source:</label>\n    <textarea id=\"sourceArea\">// Try arithmetic, let bindings, if, while\nlet a = 2 + 3 * 4;\nlet b = a - 5;\nlet c = b * (a + 1);\nif (c > 20) {\n  let d = c + 1;\n  d = d + a;\n}\n</textarea>\n  </div>\n</section>\n\n<section>\n  <strong>Compiler Controls & Pipeline</strong>\n  <div>\n    <label>Optimization Level:</label>\n    <input id=\"optLevel\" type=\"range\" min=\"0\" max=\"3\" value=\"1\">\n    <span id=\"optLevelVal\">1</span>\n    <label style=\"margin-left:12px;\">Parser strict:</label>\n    <input id=\"strictParse\" type=\"checkbox\">\n    <label style=\"margin-left:12px;\">Verbose logs:</label>\n    <input id=\"verbose\" type=\"checkbox\">\n    <label style=\"margin-left:12px;\">Incremental compile:</label>\n    <input id=\"incremental\" type=\"checkbox\">\n  </div>\n\n  <div style=\"margin-top:8px;\">\n    <strong>Pass pipeline (reorderable)</strong>\n    <div id=\"passList\" class=\"details\"></div>\n    <button id=\"addPassBtn\">Add Pass</button>\n    <button id=\"resetPipelineBtn\">Reset Pipeline</button>\n  </div>\n\n  <div style=\"margin-top:8px;\">\n    <button id=\"lexBtn\">Lex</button>\n    <button id=\"parseBtn\">Parse</button>\n    <button id=\"irBtn\">Generate IR</button>\n    <button id=\"optStepBtn\">Optimize (one pass)</button>\n    <button id=\"optAllBtn\">Optimize (all)</button>\n    <button id=\"codegenBtn\">Codegen</button>\n    <button id=\"simulateBtn\">Simulate</button>\n    <button id=\"runBtn\">Run</button>\n    <button id=\"stepBtn\">Step</button>\n    <button id=\"resetBtn\">Reset State</button>\n  </div>\n\n  <div style=\"margin-top:6px;\">\n    <label>Breakpoint instruction #:</label><input id=\"breakInstr\" type=\"number\" min=\"0\" value=\"-1\">\n    <label style=\"margin-left:12px;\">Inject syntax error:</label><input id=\"injectError\" type=\"checkbox\">\n    <button id=\"fuzzBtn\" title=\"Generate random program\">Fuzz Generate</button>\n    <button id=\"loadSampleBtn\">Load Samples</button>\n    <select id=\"sampleSelect\"></select>\n  </div>\n</section>\n\n<section>\n  <strong>Interactive AST / IR Editor</strong>\n  <div>\n    <label>AST view (click nodes to edit/add/remove)</label>\n    <div id=\"astView\" class=\"details\"></div>\n  </div>\n\n  <div style=\"margin-top:8px;\">\n    <label>IR view (editable)</label>\n    <div id=\"irView\" class=\"details\"></div>\n    <button id=\"irAddInstr\">Add Instruction</button>\n    <button id=\"irApplyBtn\">Apply IR (rebuild codegen/sim)</button>\n  </div>\n</section>\n\n<section>\n  <strong>Outputs & Logs</strong>\n  <div style=\"display:block;\">\n    <label>Tokens:</label><pre id=\"tokensOut\"></pre>\n    <label>Generated Code:</label>\n    <select id=\"codeTarget\">\n      <option value=\"js\">JavaScript</option>\n      <option value=\"asm\">Assembly-like</option>\n    </select>\n    <pre id=\"codeOut\" class=\"details\"></pre>\n    <label>Simulator / Execution state:</label>\n    <pre id=\"simOut\" class=\"details\"></pre>\n    <label>Compiler Logs:</label>\n    <pre id=\"logOut\" class=\"details\"></pre>\n  </div>\n</section>\n\n<section>\n  <strong>Snapshots & History</strong>\n  <div>\n    <button id=\"saveSnapshot\">Save Snapshot</button>\n    <button id=\"listSnapshots\">List</button>\n    <button id=\"revertSnapshot\">Revert to Selected</button>\n    <select id=\"snapshotSelect\"></select>\n    <button id=\"diffSnapshot\">Diff with Current</button>\n    <pre id=\"snapshotOut\" class=\"details\"></pre>\n  </div>\n\n  <div style=\"margin-top:8px;\">\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n  </div>\n</section>\n\n<section>\n  <strong>Developer / Internal State (inspect)</strong>\n  <button id=\"dumpState\">Dump State (console)</button>\n  <pre id=\"stateOut\" class=\"details\"></pre>\n</section>\n\n<script>\n/*\n  Compiler Playground\n  - Minimal visual design\n  - Rich interactivity, many controls\n  - Simple language: let bindings, assignments, expressions, if, while\n  - Pipeline: lex -> parse -> IR -> optimize passes -> codegen -> simulate\n  - Editable AST and IR\n  - Snapshots, undo/redo, fuzz generator, pipeline reordering\n*/\n\n(function(){\n\n// ---------- State ----------\nconst state = {\n  files: {},\n  selectedFile: null,\n  tokens: [],\n  ast: null,\n  ir: [],\n  generatedCode: '',\n  simState: null,\n  logs: [],\n  passes: [\n    { id: genId(), name: 'const-fold', enabled: true, desc: 'Constant folding' },\n    { id: genId(), name: 'dead-code', enabled: true, desc: 'Dead code elimination' },\n    { id: genId(), name: 'copy-prop', enabled: true, desc: 'Copy propagation' },\n    { id: genId(), name: 'strength-reduce', enabled: false, desc: 'Strength reduction' }\n  ],\n  optLevel: 1,\n  strictParse: false,\n  verbose: false,\n  incremental: false,\n  history: [],\n  future: [],\n  snapshots: []\n};\n\nfunction genId(){ return 'p'+Math.random().toString(36).slice(2,9); }\n\n// ---------- Elements ----------\nconst fileSelect = document.getElementById('fileSelect');\nconst newFileBtn = document.getElementById('newFileBtn');\nconst importFileBtn = document.getElementById('importFileBtn');\nconst fileInput = document.getElementById('fileInput');\nconst saveFileBtn = document.getElementById('saveFileBtn');\nconst deleteFileBtn = document.getElementById('deleteFileBtn');\nconst duplicateFileBtn = document.getElementById('duplicateFileBtn');\nconst fileNameInput = document.getElementById('fileNameInput');\nconst sourceArea = document.getElementById('sourceArea');\n\nconst optLevel = document.getElementById('optLevel');\nconst optLevelVal = document.getElementById('optLevelVal');\nconst strictParse = document.getElementById('strictParse');\nconst verbose = document.getElementById('verbose');\nconst incremental = document.getElementById('incremental');\n\nconst passList = document.getElementById('passList');\nconst addPassBtn = document.getElementById('addPassBtn');\nconst resetPipelineBtn = document.getElementById('resetPipelineBtn');\n\nconst lexBtn = document.getElementById('lexBtn');\nconst parseBtn = document.getElementById('parseBtn');\nconst irBtn = document.getElementById('irBtn');\nconst optStepBtn = document.getElementById('optStepBtn');\nconst optAllBtn = document.getElementById('optAllBtn');\nconst codegenBtn = document.getElementById('codegenBtn');\nconst simulateBtn = document.getElementById('simulateBtn');\nconst runBtn = document.getElementById('runBtn');\nconst stepBtn = document.getElementById('stepBtn');\nconst resetBtn = document.getElementById('resetBtn');\n\nconst breakInstr = document.getElementById('breakInstr');\nconst injectError = document.getElementById('injectError');\nconst fuzzBtn = document.getElementById('fuzzBtn');\nconst loadSampleBtn = document.getElementById('loadSampleBtn');\nconst sampleSelect = document.getElementById('sampleSelect');\n\nconst astView = document.getElementById('astView');\nconst irView = document.getElementById('irView');\nconst irAddInstr = document.getElementById('irAddInstr');\nconst irApplyBtn = document.getElementById('irApplyBtn');\n\nconst tokensOut = document.getElementById('tokensOut');\nconst codeOut = document.getElementById('codeOut');\nconst simOut = document.getElementById('simOut');\nconst logOut = document.getElementById('logOut');\nconst codeTarget = document.getElementById('codeTarget');\n\nconst saveSnapshot = document.getElementById('saveSnapshot');\nconst listSnapshots = document.getElementById('listSnapshots');\nconst revertSnapshot = document.getElementById('revertSnapshot');\nconst snapshotSelect = document.getElementById('snapshotSelect');\nconst diffSnapshot = document.getElementById('diffSnapshot');\nconst snapshotOut = document.getElementById('snapshotOut');\n\nconst undoBtn = document.getElementById('undoBtn');\nconst redoBtn = document.getElementById('redoBtn');\n\nconst dumpStateBtn = document.getElementById('dumpState');\nconst stateOut = document.getElementById('stateOut');\n\n// ---------- Samples ----------\nconst samples = {\n  'simple-arith': `let x = 1 + 2 * 3;\nlet y = x + 4;\nx = x + y;`,\n  'loops': `let a = 0;\nlet i = 0;\nwhile (i < 5) {\n  a = a + i;\n  i = i + 1;\n}\na;`,\n  'if-example': `let n = 10;\nlet res = 0;\nif (n > 5) {\n  res = n * 2;\n} else {\n  res = n - 2;\n}\nres;`,\n  'dead-code-demo': `let x = 1;\nlet y = 2;\nx = 3;\nlet z = x + y;\nz;`,\n};\n\n// ---------- Utilities ----------\nfunction log(...args){ state.logs.push(args.map(String).join(' ')); if (state.logs.length > 500) state.logs.shift(); renderLogs(); }\nfunction renderLogs(){ logOut.textContent = state.logs.join('\\n'); }\nfunction pushHistory(snapshot){ state.history.push(JSON.stringify(snapshot)); if(state.history.length>100) state.history.shift(); state.future=[]; updateUndoRedo(); }\nfunction updateUndoRedo(){ undoBtn.disabled = state.history.length===0; redoBtn.disabled = state.future.length===0; }\nfunction saveHistoryForAction(name){ pushHistory(snapshotState()); log('Saved history:', name); }\nfunction snapshotState(){\n  return {\n    files: JSON.parse(JSON.stringify(state.files)),\n    selectedFile: state.selectedFile,\n    source: sourceArea.value,\n    tokens: state.tokens,\n    ast: state.ast,\n    ir: state.ir,\n    generatedCode: state.generatedCode,\n    simState: state.simState,\n    passes: JSON.parse(JSON.stringify(state.passes)),\n    optLevel: state.optLevel\n  };\n}\nfunction restoreSnapshot(snap){\n  state.files = JSON.parse(JSON.stringify(snap.files));\n  state.selectedFile = snap.selectedFile;\n  sourceArea.value = snap.source;\n  state.tokens = snap.tokens;\n  state.ast = snap.ast;\n  state.ir = snap.ir;\n  state.generatedCode = snap.generatedCode;\n  state.simState = snap.simState;\n  state.passes = snap.passes;\n  state.optLevel = snap.optLevel;\n  renderAll();\n}\nfunction simpleDiff(a,b){\n  let aa = (a||'').split(/\\n/);\n  let bb = (b||'').split(/\\n/);\n  let out = [];\n  let n = Math.max(aa.length, bb.length);\n  for(let i=0;i<n;i++){\n    let la = aa[i]||'';\n    let lb = bb[i]||'';\n    if(la===lb) out.push('  '+la);\n    else {\n      out.push('- '+la);\n      out.push('+ '+lb);\n    }\n  }\n  return out.join('\\n');\n}\n\n// ---------- File Management ----------\nfunction refreshFileList(){\n  fileSelect.innerHTML = '';\n  Object.keys(state.files).forEach(name=>{\n    let opt = document.createElement('option');\n    opt.value = name;\n    opt.textContent = name;\n    fileSelect.appendChild(opt);\n  });\n  if(!state.selectedFile){\n    let first = Object.keys(state.files)[0];\n    if(first) state.selectedFile = first;\n  }\n  fileSelect.value = state.selectedFile || '';\n  fileNameInput.value = state.selectedFile || '';\n}\nfunction newFile(name, content){\n  if(!name) name = 'file'+Object.keys(state.files).length+'.c';\n  let unique = name;\n  let i = 1;\n  while(state.files[unique]){ unique = name.replace(/(\\.\\w+)?$/, '') + '_' + i + ( /\\.\\w+$/.test(name)?RegExp.$1:'' ); i++; }\n  state.files[unique] = content||'';\n  state.selectedFile = unique;\n  refreshFileList();\n  renderAll();\n  saveHistoryForAction('new-file');\n}\nnewFile('main.c', sourceArea.value);\n\nfileSelect.addEventListener('change', ()=>{\n  state.selectedFile = fileSelect.value;\n  fileNameInput.value = state.selectedFile;\n  sourceArea.value = state.files[state.selectedFile] || '';\n});\n\nnewFileBtn.addEventListener('click', ()=>{\n  let name = prompt('Filename:', 'untitled.c');\n  if(name) newFile(name, '');\n});\n\nimportFileBtn.addEventListener('click', ()=> fileInput.click());\nfileInput.addEventListener('change', (e)=>{\n  let f = e.target.files[0];\n  if(!f) return;\n  let reader = new FileReader();\n  reader.onload = function(){ newFile(f.name, this.result); };\n  reader.readAsText(f);\n});\n\nsaveFileBtn.addEventListener('click', ()=>{\n  if(!state.selectedFile) return alert('No file selected');\n  state.files[fileNameInput.value || state.selectedFile] = sourceArea.value;\n  if(fileNameInput.value !== state.selectedFile){\n    // rename\n    delete state.files[state.selectedFile];\n    state.selectedFile = fileNameInput.value;\n  }\n  refreshFileList();\n  saveHistoryForAction('save-file');\n  log('Saved file', state.selectedFile);\n});\n\ndeleteFileBtn.addEventListener('click', ()=>{\n  if(!state.selectedFile) return;\n  if(!confirm('Delete '+state.selectedFile+'?')) return;\n  delete state.files[state.selectedFile];\n  state.selectedFile = Object.keys(state.files)[0] || null;\n  refreshFileList();\n  renderAll();\n  saveHistoryForAction('delete-file');\n});\n\nduplicateFileBtn.addEventListener('click', ()=>{\n  if(!state.selectedFile) return;\n  let newName = state.selectedFile.replace(/(\\.\\w+)?$/, '') + '_copy' + (/\\.\\w+$/.test(state.selectedFile)?RegExp.$1:'');\n  newFile(newName, state.files[state.selectedFile]);\n});\n\n// ---------- Pipeline / Passes ----------\nfunction renderPassList(){\n  passList.innerHTML = '';\n  state.passes.forEach((p, idx)=>{\n    let div = document.createElement('div');\n    let cb = document.createElement('input');\n    cb.type = 'checkbox'; cb.checked = !!p.enabled;\n    cb.addEventListener('change', ()=> { p.enabled = cb.checked; saveHistoryForAction('toggle-pass'); renderPassList(); });\n    let up = document.createElement('button'); up.textContent = '↑'; up.addEventListener('click', ()=>{\n      if(idx===0) return;\n      state.passes.splice(idx-1,0,state.passes.splice(idx,1)[0]);\n      saveHistoryForAction('move-pass-up');\n      renderPassList();\n    });\n    let down = document.createElement('button'); down.textContent = '↓'; down.addEventListener('click', ()=>{\n      if(idx===state.passes.length-1) return;\n      state.passes.splice(idx+1,0,state.passes.splice(idx,1)[0]);\n      saveHistoryForAction('move-pass-down');\n      renderPassList();\n    });\n    let edit = document.createElement('button'); edit.textContent = 'edit'; edit.addEventListener('click', ()=>{\n      let name = prompt('Pass name', p.name);\n      if(name) { p.name = name; saveHistoryForAction('edit-pass'); renderPassList(); }\n    });\n    let rm = document.createElement('button'); rm.textContent = 'rm'; rm.addEventListener('click', ()=>{\n      if(confirm('Remove pass '+p.name+'?')) { state.passes.splice(idx,1); saveHistoryForAction('rm-pass'); renderPassList(); }\n    });\n    div.appendChild(cb);\n    let span = document.createElement('span'); span.textContent = ' ' + p.name + ' - ' + (p.desc||''); div.appendChild(span);\n    div.appendChild(up); div.appendChild(down); div.appendChild(edit); div.appendChild(rm);\n    passList.appendChild(div);\n  });\n}\naddPassBtn.addEventListener('click', ()=>{\n  let name = prompt('Pass name','new-pass');\n  if(!name) return;\n  state.passes.push({id: genId(), name: name, enabled: true, desc: ''});\n  saveHistoryForAction('add-pass');\n  renderPassList();\n});\nresetPipelineBtn.addEventListener('click', ()=>{\n  if(!confirm('Reset pipeline to defaults?')) return;\n  state.passes = [\n    { id: genId(), name: 'const-fold', enabled: true, desc: 'Constant folding' },\n    { id: genId(), name: 'dead-code', enabled: true, desc: 'Dead code elimination' },\n    { id: genId(), name: 'copy-prop', enabled: true, desc: 'Copy propagation' },\n    { id: genId(), name: 'strength-reduce', enabled: false, desc: 'Strength reduction' }\n  ];\n  saveHistoryForAction('reset-pipeline');\n  renderPassList();\n});\n\n// ---------- Lexer ----------\nfunction makeLexer(code){\n  const tokenSpec = [\n    ['NUMBER', /^\\d+/],\n    ['IDENT', /^[A-Za-z_][A-Za-z0-9_]*/],\n    ['OP', /^[+\\-*/=<>!]+/],\n    ['LPAREN', /^\\(/],\n    ['RPAREN', /^\\)/],\n    ['LBRACE', /^\\{/],\n    ['RBRACE', /^\\}/],\n    ['SEMICOLON', /^;/],\n    ['COMMA', /^,/],\n    ['LET', /^let\\b/],\n    ['IF', /^if\\b/],\n    ['ELSE', /^else\\b/],\n    ['WHILE', /^while\\b/],\n    ['WS', /^\\s+/],\n    ['UNKNOWN', /^./]\n  ];\n  let pos = 0;\n  let tokens = [];\n  while(pos < code.length){\n    let slice = code.slice(pos);\n    let matched = false;\n    for(let [type, rx] of tokenSpec){\n      let m = rx.exec(slice);\n      if(m){\n        matched = true;\n        let val = m[0];\n        if(type !== 'WS'){\n          tokens.push({type: type, value: val, pos});\n        }\n        pos += val.length;\n        break;\n      }\n    }\n    if(!matched) break;\n  }\n  return tokens;\n}\n\n// ---------- Parser (rudimentary) ----------\nfunction parseTokens(tokens){\n  let idx = 0;\n  function peek(){ return tokens[idx]; }\n  function consume(expected){\n    let t = tokens[idx];\n    if(!t) throw new Error('Unexpected end, expected '+expected);\n    if(expected && t.type !== expected && !(expected instanceof Array && expected.includes(t.type))) throw new Error('Expected '+expected+' got '+t.type+' ('+t.value+') at pos '+t.pos);\n    idx++;\n    return t;\n  }\n  function parseProgram(){\n    let body = [];\n    while(idx < tokens.length){\n      body.push(parseStatement());\n    }\n    return {type:'Program', body};\n  }\n  function parseStatement(){\n    let t = peek();\n    if(!t) throw new Error('Unexpected end of input');\n    if(t.type === 'LET'){\n      consume('LET');\n      let id = consume('IDENT');\n      consume('OP'); // should be =\n      let expr = parseExpression();\n      consume('SEMICOLON');\n      return {type:'VarDecl', id:id.value, init:expr};\n    }\n    if(t.type === 'IF'){\n      consume('IF');\n      consume('LPAREN'); let test = parseExpression(); consume('RPAREN');\n      let consequent = parseBlockOrStatement();\n      let alternate = null;\n      if(peek() && peek().type === 'ELSE'){ consume('ELSE'); alternate = parseBlockOrStatement(); }\n      return {type:'If', test, consequent, alternate};\n    }\n    if(t.type === 'WHILE'){\n      consume('WHILE');\n      consume('LPAREN'); let test = parseExpression(); consume('RPAREN');\n      let body = parseBlockOrStatement();\n      return {type:'While', test, body};\n    }\n    // Assignment or expression-statement\n    let maybe = parseExpression();\n    if(peek() && peek().type === 'SEMICOLON') { consume('SEMICOLON'); return {type:'ExprStmt', expr: maybe}; }\n    // If we get here, maybe it's assign: IDENT = expr;\n    if(peek() && peek().type === 'OP' && peek().value === '='){\n      // previous must have been IDENT\n      if(maybe.type !== 'Identifier') throw new Error('Invalid assignment target');\n      consume('OP');\n      let expr = parseExpression();\n      consume('SEMICOLON');\n      return {type:'Assign', id: maybe.name, value: expr};\n    }\n    throw new Error('Unknown statement starting with '+t.type);\n  }\n  function parseBlockOrStatement(){\n    if(peek() && peek().type === 'LBRACE'){\n      consume('LBRACE');\n      let stmts = [];\n      while(peek() && peek().type !== 'RBRACE'){\n        stmts.push(parseStatement());\n      }\n      consume('RBRACE');\n      return {type:'Block', body: stmts};\n    } else {\n      return parseStatement();\n    }\n  }\n  function parseExpression(){\n    return parseBinary();\n  }\n  function parsePrimary(){\n    let t = peek();\n    if(!t) throw new Error('Unexpected end in primary');\n    if(t.type === 'NUMBER'){ consume('NUMBER'); return {type:'Literal', value: Number(t.value)}; }\n    if(t.type === 'IDENT'){ consume('IDENT'); return {type:'Identifier', name: t.value}; }\n    if(t.type === 'LPAREN'){ consume('LPAREN'); let e = parseExpression(); consume('RPAREN'); return e; }\n    throw new Error('Unexpected token in expression: '+t.type+' '+t.value);\n  }\n  function parseBinary(precedence = 0){\n    let left = parsePrimary();\n    while(true){\n      let t = peek();\n      if(!t || t.type !== 'OP') break;\n      let prec = getPrec(t.value);\n      if(prec < precedence) break;\n      let op = consume('OP').value;\n      let right = parseBinary(prec+1);\n      left = {type:'BinaryExpression', operator: op, left, right};\n    }\n    return left;\n  }\n  function getPrec(op){\n    if(op === '||') return 1;\n    if(op === '&&') return 2;\n    if(op === '==' || op === '!=') return 3;\n    if(op === '<' || op === '>' || op === '<=' || op === '>=') return 4;\n    if(op === '+' || op === '-') return 5;\n    if(op === '*' || op === '/') return 6;\n    return 0;\n  }\n\n  let prog = parseProgram();\n  return prog;\n}\n\n// ---------- IR Generation ----------\nlet tempId = 0;\nfunction newTemp(){ return 't'+(++tempId); }\nfunction generateIR(ast){\n  tempId = 0;\n  let ir = [];\n  let env = {};\n  function gen(node){\n    if(!node) return null;\n    switch(node.type){\n      case 'Program':\n        node.body.forEach(s=>gen(s));\n        break;\n      case 'VarDecl':\n        let v = node.id;\n        let r = gen(node.init);\n        ir.push({op:'mov', args:[r], dest:v, srcComment: 'decl'});\n        break;\n      case 'Assign':\n        let val = gen(node.value);\n        ir.push({op:'mov', args:[val], dest:node.id});\n        break;\n      case 'ExprStmt':\n        gen(node.expr);\n        break;\n      case 'If':\n        {\n          let test = gen(node.test);\n          let lthen = 'L'+Math.random().toString(36).slice(2,7);\n          let lend = 'L'+Math.random().toString(36).slice(2,7);\n          ir.push({op:'jz', args:[test], label:lthen});\n          // false -> jump to else (we use labels)\n          let saved = []\n          // then\n          let thenStart = 'LBL_'+lthen;\n          ir.push({op:'label', label:thenStart});\n          if(node.consequent.type==='Block') node.consequent.body.forEach(s=>gen(s)); else gen(node.consequent);\n          ir.push({op:'jmp', label:lend});\n          if(node.alternate){\n            let elseStart = 'LBL_else_'+lthen;\n            ir.push({op:'label', label:elseStart});\n            if(node.alternate.type==='Block') node.alternate.body.forEach(s=>gen(s)); else gen(node.alternate);\n          }\n          ir.push({op:'label', label:lend});\n        }\n        break;\n      case 'While':\n        {\n          let start = 'L'+Math.random().toString(36).slice(2,7);\n          let cond = 'COND_'+start;\n          ir.push({op:'label', label:cond});\n          let test = gen(node.test);\n          let end = 'END_'+start;\n          ir.push({op:'jz', args:[test], label:end});\n          if(node.body.type==='Block') node.body.body.forEach(s=>gen(s)); else gen(node.body);\n          ir.push({op:'jmp', label:cond});\n          ir.push({op:'label', label:end});\n        }\n        break;\n      case 'Literal':\n        let tmp = newTemp();\n        ir.push({op:'const', args:[node.value], dest:tmp});\n        return tmp;\n      case 'Identifier':\n        return node.name;\n      case 'BinaryExpression':\n        let l = gen(node.left);\n        let r = gen(node.right);\n        let t = newTemp();\n        let opName = node.operator;\n        ir.push({op: 'binop', opType:opName, args:[l,r], dest:t});\n        return t;\n      default:\n        if(state.verbose) log('Unhandled node in IR gen', node.type);\n    }\n    return null;\n  }\n  gen(ast);\n  return ir;\n}\n\n// ---------- Optimizations ----------\nfunction applyPass(ir, pass){\n  if(pass.name === 'const-fold'){\n    // find binops with const args\n    let changed=false;\n    for(let i=0;i<ir.length;i++){\n      let ins = ir[i];\n      if(ins.op==='binop' && ins.args.every(a=>isConstSource(ir,a))){\n        let left = constValue(ir, ins.args[0]);\n        let right = constValue(ir, ins.args[1]);\n        if(typeof left === 'number' && typeof right === 'number'){\n          let res = evalBinop(left, right, ins.opType);\n          ir[i] = {op:'const', args:[res], dest: ins.dest, folded:true};\n          changed=true;\n        }\n      }\n    }\n    if(state.verbose) log('const-fold changed=', changed);\n    return {ir, changed};\n  }\n  if(pass.name === 'dead-code'){\n    // remove mov to vars never used\n    let used = new Set();\n    ir.forEach(ins=>{\n      (ins.args||[]).forEach(a=>{ if(typeof a==='string') used.add(a); });\n      if(ins.dest) { /* dest will be used by others if referenced */ }\n    });\n    // detect dests that are never used later\n    let destUsed = new Set();\n    for(let i=0;i<ir.length;i++){\n      let ins = ir[i];\n      (ins.args||[]).forEach(a=>destUsed.add(a));\n    }\n    let newIr = [];\n    let removed = 0;\n    for(let ins of ir){\n      if(ins.dest && !destUsed.has(ins.dest) && ins.op==='mov' && ins.srcComment!=='decl'){\n        removed++;\n        continue;\n      }\n      newIr.push(ins);\n    }\n    if(state.verbose) log('dead-code removed',removed);\n    return {ir: newIr, changed: removed>0};\n  }\n  if(pass.name === 'copy-prop'){\n    // simple copy propagation: mov t = x ; then use t -> x if safe\n    let mapping = {};\n    let changed = false;\n    for(let i=0;i<ir.length;i++){\n      let ins = ir[i];\n      if(ins.op==='mov' && ins.args.length===1 && typeof ins.args[0] === 'string'){\n        mapping[ins.dest] = ins.args[0];\n      } else {\n        // replace args\n        if(ins.args && ins.args.length){\n          ins.args = ins.args.map(a=>{\n            if(typeof a === 'string' && mapping[a]) { changed=true; return mapping[a]; }\n            return a;\n          });\n        }\n      }\n    }\n    if(state.verbose) log('copy-prop changed', changed);\n    return {ir, changed};\n  }\n  if(pass.name === 'strength-reduce'){\n    // replace mul by 2 with add\n    let changed=false;\n    for(let i=0;i<ir.length;i++){\n      let ins = ir[i];\n      if(ins.op==='binop' && ins.opType==='*'){\n        if(ins.args[1]===2 || ins.args[0]===2){\n          let other = ins.args[0]===2?ins.args[1]:ins.args[0];\n          ir[i] = {op:'binop', opType:'+', args:[other, other], dest:ins.dest};\n          changed=true;\n        }\n      }\n    }\n    return {ir, changed};\n  }\n  return {ir, changed:false};\n}\nfunction isConstSource(ir, src){\n  if(typeof src === 'number') return true;\n  // find last defining instruction for src\n  for(let i=ir.length-1;i>=0;i--){\n    let ins = ir[i];\n    if(ins.dest === src){\n      if(ins.op === 'const') return true;\n      return false;\n    }\n  }\n  return false;\n}\nfunction constValue(ir, src){\n  if(typeof src === 'number') return src;\n  for(let i=ir.length-1;i>=0;i--){\n    let ins = ir[i];\n    if(ins.dest === src){\n      if(ins.op === 'const') return ins.args[0];\n      return undefined;\n    }\n  }\n  return undefined;\n}\nfunction evalBinop(a,b,op){\n  switch(op){\n    case '+': return a+b;\n    case '-': return a-b;\n    case '*': return a*b;\n    case '/': return Math.floor(a/b);\n    case '>': return a>b?1:0;\n    case '<': return a<b?1:0;\n    case '>=': return a>=b?1:0;\n    case '<=': return a<=b?1:0;\n    case '==': return a==b?1:0;\n    case '!=': return a!=b?1:0;\n    default: return 0;\n  }\n}\n\n// ---------- Codegen ----------\nfunction codegen(ir, target){\n  if(target === 'asm'){\n    return ir.map((ins,idx)=>{\n      if(ins.op === 'const') return `${idx}: ${ins.dest} = ${ins.args[0]}`;\n      if(ins.op === 'mov') return `${idx}: ${ins.dest} = ${ins.args[0]}`;\n      if(ins.op === 'binop') return `${idx}: ${ins.dest} = ${ins.args[0]} ${ins.opType} ${ins.args[1]}`;\n      if(ins.op === 'label') return `${ins.label}:`;\n      if(ins.op === 'jmp') return `${idx}: jmp ${ins.label}`;\n      if(ins.op === 'jz') return `${idx}: jz ${ins.args[0]} -> ${ins.label}`;\n      return `${idx}: ${JSON.stringify(ins)}`;\n    }).join('\\n');\n  } else {\n    // JS\n    let lines = [];\n    lines.push('(function(){');\n    lines.push('  let env = {};');\n    for(let ins of ir){\n      if(ins.op === 'const'){\n        lines.push(`  env[\"${ins.dest}\"] = ${JSON.stringify(ins.args[0])};`);\n      } else if(ins.op === 'mov'){\n        let src = (typeof ins.args[0] === 'string') ? `env[\"${ins.args[0]}\"]` : JSON.stringify(ins.args[0]);\n        lines.push(`  env[\"${ins.dest}\"] = ${src};`);\n      } else if(ins.op === 'binop'){\n        let a = (typeof ins.args[0] === 'string') ? `env[\"${ins.args[0]}\"]` : JSON.stringify(ins.args[0]);\n        let b = (typeof ins.args[1] === 'string') ? `env[\"${ins.args[1]}\"]` : JSON.stringify(ins.args[1]);\n        lines.push(`  env[\"${ins.dest}\"] = (${a}) ${ins.opType} (${b});`);\n      } else if(ins.op === 'label'){\n        lines.push(`  /* label ${ins.label} */`);\n      } else if(ins.op === 'jmp'){\n        lines.push(`  /* jmp ${ins.label} */`);\n      } else if(ins.op === 'jz'){\n        lines.push(`  /* jz ${ins.args[0]} -> ${ins.label} */`);\n      }\n    }\n    lines.push('  return env;');\n    lines.push('})();');\n    return lines.join('\\n');\n  }\n}\n\n// ---------- Simulator (interprets IR step by step) ----------\nfunction makeSimulator(ir){\n  let ip = 0;\n  let env = {};\n  let labels = {};\n  // map label positions\n  ir.forEach((ins, idx)=>{\n    if(ins.op === 'label'){\n      labels[ins.label] = idx;\n    }\n  });\n  function step(){\n    if(ip < 0 || ip >= ir.length) return {done:true};\n    let ins = ir[ip];\n    if(ins.op === 'const'){ env[ins.dest] = ins.args[0]; ip++; return {ip, ins}; }\n    if(ins.op === 'mov'){\n      let v = ins.args[0];\n      env[ins.dest] = (typeof v === 'string') ? env[v] : v;\n      ip++; return {ip, ins};\n    }\n    if(ins.op === 'binop'){\n      let a = (typeof ins.args[0] === 'string') ? env[ins.args[0]] : ins.args[0];\n      let b = (typeof ins.args[1] === 'string') ? env[ins.args[1]] : ins.args[1];\n      env[ins.dest] = evalBinop(a,b,ins.opType);\n      ip++; return {ip, ins};\n    }\n    if(ins.op === 'jz'){\n      let cond = (typeof ins.args[0] === 'string') ? env[ins.args[0]] : ins.args[0];\n      if(!cond) {\n        // jump to label index (we find next label matching)\n        let target = null;\n        // find label definition index\n        for(let i=0;i<ir.length;i++){\n          if(ir[i].op === 'label' && ir[i].label === ins.label){ target = i; break; }\n        }\n        if(target !== null) ip = target+1;\n        else ip++;\n      } else ip++;\n      return {ip, ins};\n    }\n    if(ins.op === 'jmp'){\n      let targetIdx = null;\n      for(let i=0;i<ir.length;i++){\n        if(ir[i].op === 'label' && ir[i].label === ins.label){ targetIdx = i; break; }\n      }\n      if(targetIdx !== null) ip = targetIdx+1; else ip++;\n      return {ip, ins};\n    }\n    if(ins.op === 'label'){ ip++; return {ip, ins}; }\n    ip++;\n    return {ip, ins};\n  }\n  return {step, getEnv: ()=>JSON.parse(JSON.stringify(env)), ipRef: ()=>ip, setIp: (n)=>{ip=n}, reset: ()=>{ ip=0; env={}; }};\n}\n\n// ---------- Rendering AST interactive ----------\nfunction renderASTView(){\n  astView.innerHTML = '';\n  if(!state.ast){ astView.textContent = '(no AST)'; return; }\n  function nodeToElement(node){\n    let el = document.createElement('div');\n    el.style.marginLeft = '8px';\n    let header = document.createElement('span');\n    header.textContent = node.type + (node.id?(' '+node.id):'') + (node.name?(' '+node.name):'');\n    el.appendChild(header);\n    let editBtn = document.createElement('button'); editBtn.textContent = 'edit'; editBtn.addEventListener('click', ()=>{\n      let keys = Object.keys(node).filter(k=>k!=='type' && k!=='body');\n      if(keys.length===0) return alert('No editable fields');\n      let key = keys[0];\n      let val = JSON.stringify(node[key]);\n      let nv = prompt('Edit '+key, val);\n      if(nv !== null){\n        try{ node[key] = JSON.parse(nv); } catch(e){ node[key] = nv; }\n        saveHistoryForAction('edit-ast');\n        renderASTView();\n      }\n    });\n    let addBtn = document.createElement('button'); addBtn.textContent = 'add-child'; addBtn.addEventListener('click', ()=>{\n      if(!node.body) node.body = [];\n      let sample = {type:'ExprStmt', expr:{type:'Literal', value:0}};\n      node.body.push(sample);\n      saveHistoryForAction('add-ast-node');\n      renderASTView();\n    });\n    let rmBtn = document.createElement('button'); rmBtn.textContent = 'rm'; rmBtn.addEventListener('click', ()=>{\n      if(!confirm('Remove this node?')) return;\n      // We cannot easily remove parentless node; inform user to remove via parent\n      alert('To remove, edit the parent node body manually (this demo keeps AST removal simple).');\n    });\n    el.appendChild(editBtn); el.appendChild(addBtn); el.appendChild(rmBtn);\n    // show children\n    if(node.body && Array.isArray(node.body)){\n      node.body.forEach(child=>{\n        el.appendChild(nodeToElement(child));\n      });\n    } else {\n      // show nested fields\n      Object.keys(node).forEach(k=>{\n        if(k==='type') return;\n        let v = node[k];\n        if(typeof v === 'object' && v !== null){\n          let child = nodeToElement(v);\n          let label = document.createElement('div'); label.textContent = k+':'; label.style.marginLeft='8px';\n          el.appendChild(label);\n          el.appendChild(child);\n        } else {\n          let li = document.createElement('div'); li.style.marginLeft='8px'; li.textContent = k+': '+JSON.stringify(v);\n          el.appendChild(li);\n        }\n      });\n    }\n    return el;\n  }\n  astView.appendChild(nodeToElement(state.ast));\n}\n\n// ---------- IR view editable ----------\nfunction renderIRView(){\n  irView.innerHTML = '';\n  if(!state.ir || state.ir.length===0){ irView.textContent='(no IR)'; return; }\n  state.ir.forEach((ins, idx)=>{\n    let div = document.createElement('div');\n    let txt = document.createElement('input'); txt.type='text'; txt.value = JSON.stringify(ins);\n    txt.style.width = '80%';\n    let apply = document.createElement('button'); apply.textContent='apply'; apply.addEventListener('click', ()=>{\n      try{\n        let obj = JSON.parse(txt.value);\n        state.ir[idx] = obj;\n        saveHistoryForAction('edit-ir');\n        renderIRView();\n      }catch(e){ alert('Invalid JSON'); }\n    });\n    let up = document.createElement('button'); up.textContent='↑'; up.addEventListener('click', ()=>{\n      if(idx>0){ state.ir.splice(idx-1,0,state.ir.splice(idx,1)[0]); saveHistoryForAction('move-ir'); renderIRView(); }\n    });\n    let down = document.createElement('button'); down.textContent='↓'; down.addEventListener('click', ()=>{\n      if(idx<state.ir.length-1){ state.ir.splice(idx+1,0,state.ir.splice(idx,1)[0]); saveHistoryForAction('move-ir'); renderIRView(); }\n    });\n    let rm = document.createElement('button'); rm.textContent='rm'; rm.addEventListener('click', ()=>{\n      if(confirm('Delete instruction?')){ state.ir.splice(idx,1); saveHistoryForAction('rm-ir'); renderIRView(); }\n    });\n    div.appendChild(txt); div.appendChild(apply); div.appendChild(up); div.appendChild(down); div.appendChild(rm);\n    irView.appendChild(div);\n  });\n}\nirAddInstr.addEventListener('click', ()=>{\n  let sample = {op:'const', args:[0], dest:'t'+(Math.random()*100|0)};\n  state.ir.push(sample);\n  saveHistoryForAction('add-ir');\n  renderIRView();\n});\nirApplyBtn.addEventListener('click', ()=>{\n  // apply IR edits -> regenerate code & sim\n  state.generatedCode = codegen(state.ir, codeTarget.value);\n  renderAll();\n  saveHistoryForAction('apply-ir');\n});\n\n// ---------- Actions ----------\noptLevel.addEventListener('input', ()=>{\n  state.optLevel = +optLevel.value;\n  optLevelVal.textContent = state.optLevel;\n});\nstrictParse.addEventListener('change', ()=> state.strictParse = strictParse.checked);\nverbose.addEventListener('change', ()=> state.verbose = verbose.checked);\nincremental.addEventListener('change', ()=> state.incremental = incremental.checked);\n\nlexBtn.addEventListener('click', ()=>{\n  try{\n    let code = sourceArea.value;\n    if(injectError.checked) code += ' @';\n    state.tokens = makeLexer(code);\n    tokensOut.textContent = state.tokens.map(t=>t.type+':'+t.value).join('\\n');\n    log('Lexed', state.tokens.length, 'tokens');\n    renderAll();\n    saveHistoryForAction('lex');\n  }catch(e){ log('Lex error', e.message); }\n});\nparseBtn.addEventListener('click', ()=>{\n  try{\n    if(state.tokens.length===0) state.tokens = makeLexer(sourceArea.value);\n    let ast = parseTokens(state.tokens);\n    state.ast = ast;\n    log('Parsed AST root', ast.type || '?');\n    renderASTView();\n    saveHistoryForAction('parse');\n  }catch(e){\n    log('Parse error:', e.message);\n    state.ast = null;\n  }\n});\nirBtn.addEventListener('click', ()=>{\n  try{\n    if(!state.ast) {\n      if(state.tokens.length===0) state.tokens = makeLexer(sourceArea.value);\n      state.ast = parseTokens(state.tokens);\n    }\n    state.ir = generateIR(state.ast);\n    log('Generated IR,', state.ir.length, 'instructions');\n    renderIRView();\n    saveHistoryForAction('irgen');\n  }catch(e){ log('IR gen error', e.message); }\n});\n\nlet lastPassIndex = 0;\noptStepBtn.addEventListener('click', ()=>{\n  if(!state.ir || state.ir.length===0) return alert('No IR');\n  // find next enabled pass\n  let start = lastPassIndex % state.passes.length;\n  let found = -1;\n  for(let i=0;i<state.passes.length;i++){\n    let idx = (start+i) % state.passes.length;\n    if(state.passes[idx].enabled){ found = idx; break; }\n  }\n  if(found === -1) return alert('No enabled passes');\n  let pass = state.passes[found];\n  let r = applyPass(state.ir, pass);\n  state.ir = r.ir;\n  log('Applied pass', pass.name, 'changed=', r.changed);\n  renderIRView();\n  lastPassIndex = found+1;\n  saveHistoryForAction('opt-step-'+pass.name);\n});\noptAllBtn.addEventListener('click', ()=>{\n  if(!state.ir || state.ir.length===0) return alert('No IR');\n  let changedAny=false;\n  for(let pass of state.passes){\n    if(!pass.enabled) continue;\n    let r = applyPass(state.ir, pass);\n    state.ir = r.ir;\n    changedAny = changedAny || r.changed;\n    if(state.verbose) log('Pass', pass.name, 'applied changed=', r.changed);\n  }\n  log('All passes applied, anyChange=', changedAny);\n  renderIRView();\n  saveHistoryForAction('opt-all');\n});\n\ncodegenBtn.addEventListener('click', ()=>{\n  try{\n    if(!state.ir || state.ir.length===0) {\n      if(state.ast) state.ir = generateIR(state.ast);\n      else state.ir = generateIR(parseTokens(makeLexer(sourceArea.value)));\n    }\n    state.generatedCode = codegen(state.ir, codeTarget.value);\n    codeOut.textContent = state.generatedCode;\n    log('Codegen done target', codeTarget.value);\n    saveHistoryForAction('codegen');\n  }catch(e){ log('Codegen error', e.message); }\n});\n\nlet sim = null;\nsimulateBtn.addEventListener('click', ()=>{\n  if(!state.ir || state.ir.length===0) return alert('No IR to simulate');\n  sim = makeSimulator(state.ir);\n  let steps = 0;\n  let history = [];\n  while(true){\n    if(steps++ > 1000) { log('Simulation aborted (max steps)'); break; }\n    let res = sim.step();\n    if(res.done) break;\n    history.push({ip: sim.ipRef(), env: sim.getEnv()});\n    if(typeof breakInstr.value === 'string' && +breakInstr.value >=0 && sim.ipRef() === +breakInstr.value){\n      log('Breakpoint hit at', sim.ipRef());\n      break;\n    }\n    if(sim.ipRef() >= state.ir.length) break;\n  }\n  state.simState = sim.getEnv();\n  simOut.textContent = JSON.stringify(state.simState, null, 2);\n  log('Simulation finished (steps:', steps, ')');\n  saveHistoryForAction('simulate');\n});\n\nrunBtn.addEventListener('click', ()=>{\n  // full automated run: lex->parse->ir->opt->codegen->simulate\n  try{\n    state.tokens = makeLexer(sourceArea.value);\n    state.ast = parseTokens(state.tokens);\n    state.ir = generateIR(state.ast);\n    for(let pass of state.passes){ if(pass.enabled) { let r = applyPass(state.ir, pass); state.ir = r.ir; } }\n    state.generatedCode = codegen(state.ir, codeTarget.value);\n    codeOut.textContent = state.generatedCode;\n    // simulate once\n    let s = makeSimulator(state.ir);\n    while(true){\n      let r = s.step();\n      if(r.done) break;\n      if(s.ipRef() > 10000) break;\n      if(typeof breakInstr.value === 'string' && +breakInstr.value >=0 && s.ipRef() === +breakInstr.value){ log('Breakpoint at', s.ipRef()); break; }\n    }\n    state.simState = s.getEnv();\n    simOut.textContent = JSON.stringify(state.simState, null, 2);\n    log('Run completed');\n    renderAll();\n    saveHistoryForAction('run');\n  }catch(e){ log('Run failed', e.message); }\n});\n\nstepBtn.addEventListener('click', ()=>{\n  // If sim exists, step; else create\n  if(!sim){\n    if(!state.ir || state.ir.length===0) return alert('No IR');\n    sim = makeSimulator(state.ir);\n  }\n  let r = sim.step();\n  state.simState = sim.getEnv();\n  simOut.textContent = JSON.stringify(state.simState, null, 2);\n  log('Stepped to ip', sim.ipRef());\n  saveHistoryForAction('step');\n});\nresetBtn.addEventListener('click', ()=>{\n  state.tokens = [];\n  state.ast = null;\n  state.ir = [];\n  state.generatedCode = '';\n  state.simState = null;\n  sim = null;\n  tokensOut.textContent = '';\n  codeOut.textContent = '';\n  simOut.textContent = '';\n  astView.textContent = '';\n  irView.textContent = '';\n  log('Reset state');\n  saveHistoryForAction('reset');\n  renderAll();\n});\n\n// ---------- Fuzz generator ----------\nfunction fuzzGenerate(){\n  let n = Math.floor(Math.random()*6)+2;\n  let lines = [];\n  for(let i=0;i<n;i++){\n    let kind = Math.random();\n    if(kind < 0.3) lines.push('let v'+i+' = '+(Math.floor(Math.random()*10))+';');\n    else if(kind < 0.6) lines.push('v'+i+' = v'+Math.floor(Math.random()*Math.max(1,i))+' + '+Math.floor(Math.random()*5)+';');\n    else lines.push('if (v'+Math.floor(Math.random()*Math.max(1,i))+' > '+Math.floor(Math.random()*10)+') { v'+i+' = '+Math.floor(Math.random()*10)+'; }');\n  }\n  sourceArea.value = lines.join('\\n');\n  log('Fuzz generated program');\n}\nfuzzBtn.addEventListener('click', fuzzGenerate);\n\n// ---------- Samples ----------\nloadSampleBtn.addEventListener('click', ()=>{\n  sampleSelect.innerHTML = '';\n  Object.keys(samples).forEach(k=>{\n    let o = document.createElement('option'); o.value=k; o.textContent=k; sampleSelect.appendChild(o);\n  });\n});\nsampleSelect.addEventListener('change', ()=>{\n  let k = sampleSelect.value;\n  if(!k) return;\n  sourceArea.value = samples[k];\n});\n\n// ---------- Snapshots & History ----------\nsaveSnapshot.addEventListener('click', ()=>{\n  let name = prompt('Snapshot name:', 'snap'+(state.snapshots.length+1));\n  if(!name) return;\n  let s = snapshotState(); s.name = name;\n  state.snapshots.push(s);\n  snapshotSelect.appendChild(new Option(name, state.snapshots.length-1));\n  log('Saved snapshot', name);\n  saveHistoryForAction('save-snap');\n});\nlistSnapshots.addEventListener('click', ()=>{\n  snapshotSelect.innerHTML = '';\n  state.snapshots.forEach((s,i)=>snapshotSelect.appendChild(new Option(s.name||('snap'+i), i)));\n});\nrevertSnapshot.addEventListener('click', ()=>{\n  let idx = +snapshotSelect.value;\n  if(isNaN(idx) || !state.snapshots[idx]) return alert('Select snapshot');\n  if(!confirm('Revert to snapshot '+state.snapshots[idx].name+ '?')) return;\n  restoreSnapshot(state.snapshots[idx]);\n  saveHistoryForAction('revert-snap');\n  log('Reverted snapshot', state.snapshots[idx].name);\n});\ndiffSnapshot.addEventListener('click', ()=>{\n  let idx = +snapshotSelect.value;\n  if(isNaN(idx) || !state.snapshots[idx]) return alert('Select snapshot');\n  let s = state.snapshots[idx];\n  let d = simpleDiff(s.source, sourceArea.value);\n  snapshotOut.textContent = d;\n  log('Diff shown for snapshot', s.name);\n});\n\n// ---------- Undo / Redo ----------\nundoBtn.addEventListener('click', ()=>{\n  if(state.history.length===0) return;\n  let last = state.history.pop();\n  state.future.push(JSON.stringify(snapshotState()));\n  let snap = JSON.parse(last);\n  restoreSnapshot(snap);\n  updateUndoRedo();\n  log('Undo');\n});\nredoBtn.addEventListener('click', ()=>{\n  if(state.future.length===0) return;\n  let f = state.future.pop();\n  state.history.push(JSON.stringify(snapshotState()));\n  let snap = JSON.parse(f);\n  restoreSnapshot(snap);\n  updateUndoRedo();\n  log('Redo');\n});\n\n// ---------- State dump ----------\ndumpStateBtn.addEventListener('click', ()=>{\n  console.log('State dump', JSON.parse(JSON.stringify(state)));\n  stateOut.textContent = JSON.stringify(state, null, 2);\n});\n\n// ---------- Misc render ----------\nfunction renderAll(){\n  refreshFileList();\n  renderPassList();\n  renderASTView();\n  renderIRView();\n  tokensOut.textContent = (state.tokens||[]).map(t=>t.type+':'+t.value).join('\\n');\n  codeOut.textContent = state.generatedCode || '';\n  simOut.textContent = JSON.stringify(state.simState || {}, null, 2);\n  renderLogs();\n  stateOut.textContent = JSON.stringify({\n    files: Object.keys(state.files).length,\n    selectedFile: state.selectedFile,\n    tokens: state.tokens.length,\n    ast: state.ast?state.ast.type:null,\n    ir: state.ir.length,\n    passes: state.passes.map(p=>p.name+'('+ (p.enabled?'on':'off') +')')\n  }, null, 2);\n}\n\n// ---------- Init ----------\nrenderAll();\noptLevelVal.textContent = state.optLevel;\nrenderPassList();\nloadSampleBtn.click();\n\n// ---------- Developer convenience: auto-run small compile when blurring source area ----------\nsourceArea.addEventListener('blur', ()=>{\n  if(state.incremental){\n    try{\n      state.tokens = makeLexer(sourceArea.value);\n      state.ast = parseTokens(state.tokens);\n      state.ir = generateIR(state.ast);\n      renderAll();\n      log('Incremental compile done on blur');\n    }catch(e){ log('Incremental compile failed', e.message); }\n  }\n});\n\n})(); // IIFE\n</script>\n\n</body>\n</html>"
