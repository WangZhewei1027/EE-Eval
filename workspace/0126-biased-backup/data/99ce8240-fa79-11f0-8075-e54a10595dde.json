    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Min Heap Interactive Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n    </style>\n    <script>\n        let minHeap = [];\n\n        function insert() {\n            const value = parseInt(document.getElementById('insertInput').value);\n            if (!isNaN(value)) {\n                minHeap.push(value);\n                buildMinHeap();\n                updateDisplay();\n                document.getElementById('insertInput').value = '';\n            }\n        }\n\n        function removeMin() {\n            if (minHeap.length > 0) {\n                minHeap[0] = minHeap[minHeap.length - 1];\n                minHeap.pop();\n                buildMinHeap();\n                updateDisplay();\n            }\n        }\n\n        function buildMinHeap() {\n            const length = minHeap.length;\n            for (let i = Math.floor(length / 2) - 1; i >= 0; i--) {\n                heapify(i, length);\n            }\n        }\n\n        function heapify(i, length) {\n            let smallest = i;\n            const left = 2 * i + 1;\n            const right = 2 * i + 2;\n\n            if (left < length && minHeap[left] < minHeap[smallest]) {\n                smallest = left;\n            }\n            if (right < length && minHeap[right] < minHeap[smallest]) {\n                smallest = right;\n            }\n            if (smallest !== i) {\n                [minHeap[i], minHeap[smallest]] = [minHeap[smallest], minHeap[i]];\n                heapify(smallest, length);\n            }\n        }\n\n        function updateDisplay() {\n            const heapDisplay = document.getElementById('heapDisplay');\n            heapDisplay.innerText = minHeap.length > 0 ? 'Heap: ' + minHeap.join(', ') : 'Heap is empty';\n        }\n\n        function clearHeap() {\n            minHeap = [];\n            updateDisplay();\n        }\n\n    </script>\n</head>\n<body>\n    <h1>Min Heap Interactive Demonstration</h1>\n    \n    <div>\n        <label for=\"insertInput\">Insert Value:</label>\n        <input type=\"number\" id=\"insertInput\" />\n        <button onclick=\"insert()\">Insert</button>\n    </div>\n\n    <div>\n        <button onclick=\"removeMin()\">Remove Min</button>\n        <button onclick=\"clearHeap()\">Clear Heap</button>\n    </div>\n\n    <h2 id=\"heapDisplay\">Heap is empty</h2>\n    \n    <h3>Current Min: <span id=\"currentMin\"></span></h3>\n    <script>\n        const updateCurrentMin = () => {\n            document.getElementById('currentMin').innerText = minHeap.length > 0 ? Math.min(...minHeap) : 'None';\n        }\n        \n        const updateDisplay = () => {\n            const heapDisplay = document.getElementById('heapDisplay');\n            heapDisplay.innerText = minHeap.length > 0 ? 'Heap: ' + minHeap.join(', ') : 'Heap is empty';\n            updateCurrentMin();\n        }\n        \n        document.addEventListener('DOMContentLoaded', function () {\n            updateDisplay();\n        });\n    </script>\n</body>\n</html>"
