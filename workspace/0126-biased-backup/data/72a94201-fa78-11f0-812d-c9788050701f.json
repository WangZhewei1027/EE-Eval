    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Min Heap Visualization</title>\n    <style>\n        :root {\n            --primary: #4361ee;\n            --secondary: #3f37c9;\n            --accent: #4895ef;\n            --light: #f8f9fa;\n            --dark: #212529;\n            --success: #4cc9f0;\n            --danger: #f72585;\n            --border-radius: 12px;\n            --box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);\n            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            line-height: 1.6;\n        }\n\n        .container {\n            width: 90%;\n            max-width: 1200px;\n            margin: 0 auto;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n        }\n\n        h1 {\n            font-size: 2.5rem;\n            font-weight: 800;\n            margin-bottom: 1rem;\n            color: var(--secondary);\n            position: relative;\n            display: inline-block;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n\n        h1::after {\n            content: '';\n            position: absolute;\n            bottom: -10px;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 100px;\n            height: 4px;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            border-radius: 2px;\n        }\n\n        .header-subtext {\n            font-size: 1.1rem;\n            color: #666;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n\n        .visualization {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-top: 2rem;\n        }\n\n        .heap-container {\n            position: relative;\n            width: 100%;\n            height: 500px;\n            margin-bottom: 2rem;\n        }\n\n        .tree {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 100%;\n            height: 100%;\n            display: flex;\n            justify-content: center;\n        }\n\n        .node {\n            position: absolute;\n            width: 70px;\n            height: 70px;\n            background: white;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: bold;\n            font-size: 1.5rem;\n            color: var(--dark);\n            box-shadow: var(--box-shadow);\n            transition: var(--transition);\n            border: 3px solid var(--accent);\n            transform: scale(1);\n            opacity: 1;\n            z-index: 2;\n        }\n\n        .node.active {\n            background: var(--accent);\n            color: white;\n            transform: scale(1.1);\n            box-shadow: 0 12px 20px rgba(67, 97, 238, 0.3);\n        }\n\n        .node.min {\n            background: var(--success);\n            color: white;\n            border-color: var(--success);\n            transform: scale(1.15);\n        }\n\n        .edge {\n            position: absolute;\n            background: var(--secondary);\n            height: 3px;\n            transform-origin: top left;\n            z-index: 1;\n            opacity: 0.6;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        .btn {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: var(--border-radius);\n            font-weight: 600;\n            cursor: pointer;\n            transition: var(--transition);\n            font-size: 1rem;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n            box-shadow: var(--box-shadow);\n        }\n\n        .btn-primary {\n            background: var(--primary);\n            color: white;\n        }\n\n        .btn-primary:hover {\n            background: var(--secondary);\n            transform: translateY(-2px);\n        }\n\n        .btn-secondary {\n            background: white;\n            color: var(--primary);\n            border: 2px solid var(--primary);\n        }\n\n        .btn-secondary:hover {\n            background: var(--light);\n        }\n\n        .legend {\n            display: flex;\n            gap: 1rem;\n            margin-top: 2rem;\n            justify-content: center;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n        }\n\n        .legend-text {\n            font-size: 0.9rem;\n        }\n\n        .explanation {\n            max-width: 800px;\n            margin: 3rem auto;\n            background: white;\n            padding: 2rem;\n            border-radius: var(--border-radius);\n            box-shadow: var(--box-shadow);\n        }\n\n        .explanation h2 {\n            color: var(--secondary);\n            margin-bottom: 1rem;\n            font-size: 1.5rem;\n        }\n\n        .explanation p {\n            margin-bottom: 1rem;\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.1); }\n            100% { transform: scale(1); }\n        }\n\n        .pulse {\n            animation: pulse 1.5s infinite;\n        }\n\n        .highlight {\n            background-color: rgba(73, 145, 239, 0.2);\n            padding: 0.2rem 0.5rem;\n            border-radius: 4px;\n            font-weight: 600;\n        }\n\n        footer {\n            margin-top: 4rem;\n            text-align: center;\n            color: #666;\n            font-size: 0.9rem;\n        }\n\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2rem;\n            }\n            \n            .header-subtext {\n                font-size: 1rem;\n            }\n            \n            .controls {\n                flex-direction: column;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Min Heap Visualization</h1>\n            <p class=\"header-subtext\">A complete binary tree where each node is smaller than or equal to all of its children</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"heap-container\">\n                <div class=\"tree\" id=\"heapTree\"></div>\n            </div>\n\n            <div class=\"controls\">\n                <button id=\"insertBtn\" class=\"btn btn-primary\">Insert Random Value</button>\n                <button id=\"extractBtn\" class=\"btn btn-secondary\">Extract Minimum</button>\n            </div>\n\n            <div class=\"legend\">\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background: var(--accent);\"></div>\n                    <span class=\"legend-text\">Regular Node</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background: var(--success);\"></div>\n                    <span class=\"legend-text\">Minimum Node</span>\n                </div>\n                <div class=\"legend-item\">\n                    <div class=\"legend-color\" style=\"background: white; border: 2px solid var(--accent);\"></div>\n                    <span class=\"legend-text\">Current Operation</span>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"explanation\">\n            <h2>About Min Heaps</h2>\n            <p>A <span class=\"highlight\">Min-Heap</span> is a binary tree where the value of each node is less than or equal to the values of its children. This property must be recursively true for all subtrees in the heap.</p>\n            <p>The minimum value is always at the root of the heap, making it efficient for priority queue implementations where we frequently need to access the minimum element.</p>\n            <p>Key operations include:</p>\n            <ul>\n                <li><span class=\"highlight\">Insert</span>: Adds a new element and restructures the heap to maintain the heap property</li>\n                <li><span class=\"highlight\">Extract Minimum</span>: Removes and returns the smallest element, then restructures the heap</li>\n            </ul>\n        </div>\n    </div>\n\n    <footer>\n        <p>© 2023 Min Heap Visualization | A visual demonstration of binary heap properties</p>\n    </footer>\n\n    <script>\n        class MinHeapVisualizer {\n            constructor(containerId) {\n                this.container = document.getElementById(containerId);\n                this.heap = [];\n                this.nodeElements = [];\n                this.edgeElements = [];\n                this.levelHeight = 100;\n                this.currentAnimations = [];\n                \n                this.init();\n            }\n            \n            init() {\n                this.generateRandomHeap();\n                this.renderHeap();\n                \n                document.getElementById('insertBtn').addEventListener('click', () => {\n                    this.insertRandomValue();\n                });\n                \n                document.getElementById('extractBtn').addEventListener('click', () => {\n                    this.extractMin();\n                });\n            }\n            \n            generateRandomHeap() {\n                const size = Math.floor(Math.random() * 3) + 5; // 5-7 elements\n                const values = Array.from({length: size}, () => Math.floor(Math.random() * 90) + 10);\n                values.sort((a, b) => a - b); // Ensure heap property\n                this.heap = values;\n            }\n            \n            renderHeap() {\n                this.clearVisualization();\n                \n                if (this.heap.length === 0) {\n                    this.container.innerHTML = '<p style=\"text-align: center; font-size: 1.2rem; color: #666;\">Heap is empty</p>';\n                    return;\n                }\n                \n                const levels = Math.ceil(Math.log2(this.heap.length + 1));\n                const maxNodes = Math.pow(2, levels - 1);\n                \n                for (let i = 0; i < this.heap.length; i++) {\n                    const value = this.heap[i];\n                    const level = Math.floor(Math.log2(i + 1));\n                    const nodesInLevel = Math.pow(2, level);\n                    const levelWidth = nodesInLevel * 100;\n                    const offset = (maxNodes * 100 - levelWidth) / 2;\n                    \n                    const positionInLevel = i + 1 - Math.pow(2, level);\n                    const x = offset + positionInLevel * (levelWidth / nodesInLevel);\n                    const y = 50 + level * this.levelHeight;\n                    \n                    const node = document.createElement('div');\n                    node.className = 'node';\n                    node.textContent = value;\n                    node.style.left = `${x}px`;\n                    node.style.top = `${y}px`;\n                    \n                    this.container.appendChild(node);\n                    this.nodeElements.push(node);\n                    \n                    // Draw edges to children\n                    const leftChildIdx = 2 * i + 1;\n                    const rightChildIdx = 2 * i + 2;\n                    \n                    if (leftChildIdx < this.heap.length) {\n                        this.drawEdge(i, leftChildIdx);\n                    }\n                    \n                    if (rightChildIdx < this.heap.length) {\n                        this.drawEdge(i, rightChildIdx);\n                    }\n                }\n                \n                // Highlight the min element (root)\n                if (this.heap.length > 0) {\n                    setTimeout(() => {\n                        this.nodeElements[0].classList.add('min');\n                    }, 300);\n                }\n            }\n            \n            drawEdge(parentIdx, childIdx) {\n                const parentNode = this.nodeElements[parentIdx];\n                const childNode = this.nodeElements[childIdx];\n                \n                const parentRect = parentNode.getBoundingClientRect();\n                const childRect = childNode.getBoundingClientRect();\n                \n                const containerRect = this.container.getBoundingClientRect();\n                \n                const parentX = parentRect.left - containerRect.left + parentRect.width / 2;\n                const parentY = parentRect.top - containerRect.top + parentRect.height / 2;\n                const childX = childRect.left - containerRect.left + childRect.width / 2;\n                const childY = childRect.top - containerRect.top + childRect.height / 2;\n                \n                const length = Math.sqrt(Math.pow(childX - parentX, 2) + Math.pow(childY - parentY, 2));\n                const angle = Math.atan2(childY - parentY, childX - parentX) * 180 / Math.PI;\n                \n                const edge = document.createElement('div');\n                edge.className = 'edge';\n                edge.style.width = `${length}px`;\n                edge.style.left = `${parentX}px`;\n                edge.style.top = `${parentY}px`;\n                edge.style.transform = `rotate(${angle}deg)`;\n                edge.style.opacity = '0';\n                \n                this.container.appendChild(edge);\n                this.edgeElements.push(edge);\n                \n                // Animate edge appearance\n                setTimeout(() => {\n                    edge.style.opacity = '0.6';\n                    edge.style.transition = 'opacity 0.5s ease-out';\n                }, 100 * childIdx);\n            }\n            \n            clearVisualization() {\n                this.nodeElements.forEach(el => el.remove());\n                this.edgeElements.forEach(el => el.remove());\n                this.nodeElements = [];\n                this.edgeElements = [];\n                \n                // Clear any pending animations\n                this.currentAnimations.forEach(timeout => clearTimeout(timeout));\n                this.currentAnimations = [];\n            }\n            \n            async insertRandomValue() {\n                const newValue = Math.floor(Math.random() * 90) + 10;\n                this.heap.push(newValue);\n                this.heapifyUp(this.heap.length - 1);\n                this.renderHeap();\n                \n                // Highlight the new node\n                const newNodeIdx = this.heap.length - 1;\n                await this.highlightNode(newNodeIdx, 'active');\n                \n                // If not root, show it settling into place\n                if (newNodeIdx > 0) {\n                    await this.animateHeapifyUp(newNodeIdx);\n                }\n                \n                // After settling, highlight the min if it changed\n                if (this.heap[0] === newValue) {\n                    this.nodeElements[0].classList.add('min');\n                }\n            }\n            \n            async extractMin() {\n                if (this.heap.length === 0) return;\n                \n                // Highlight root before removal\n                await this.highlightNode(0, 'active');\n                \n                if (this.heap.length === 1) {\n                    this.heap.pop();\n                    this.renderHeap();\n                    return;\n                }\n                \n                // Move last element to root\n                const lastValue = this.heap[this.heap.length - 1];\n                this.heap[0] = lastValue;\n                this.heap.pop();\n                \n                // Show last element moving to root\n                await this.animateExtractMin(lastValue);\n                \n                // Heapify down\n                await this.animateHeapifyDown(0);\n                \n                // Highlight new min\n                if (this.heap.length > 0) {\n                    this.nodeElements[0].classList.add('min');\n                }\n            }\n            \n            async highlightNode(index, className, duration = 1000) {\n                return new Promise(resolve => {\n                    if (index >= this.nodeElements.length) {\n                        resolve();\n                        return;\n                    }\n                    \n                    const node = this.nodeElements[index];\n                    node.classList.add(className);\n                    \n                    const timeout = setTimeout(() => {\n                        node.classList.remove(className);\n                        resolve();\n                    }, duration);\n                    \n                    this.currentAnimations.push(timeout);\n                });\n            }\n            \n            heapifyUp(index) {\n                while (index > 0) {\n                    const parentIndex = Math.floor((index - 1) / 2);\n                    if (this.heap[parentIndex] <= this.heap[index]) {\n                        break;\n                    }\n                    this.swap(parentIndex, index);\n                    index = parentIndex;\n                }\n            }\n            \n            heapifyDown(index) {\n                let smallest = index;\n                const left = 2 * index + 1;\n                const right = 2 * index + 2;\n                const length = this.heap.length;\n                \n                if (left < length && this.heap[left] < this.heap[smallest]) {\n                    smallest = left;\n                }\n                \n                if (right < length && this.heap[right] < this.heap[smallest]) {\n                    smallest = right;\n                }\n                \n                if (smallest !== index) {\n                    this.swap(index, smallest);\n                    this.heapifyDown(smallest);\n                }\n            }\n            \n            async animateHeapifyUp(index) {\n                let current = index;\n                \n                while (current > 0) {\n                    const parentIndex = Math.floor((current - 1) / 2);\n                    if (this.heap[parentIndex] <= this.heap[current]) {\n                        break;\n                    }\n                    \n                    // Highlight nodes being compared\n                    await this.highlightNode(parentIndex, 'active', 500);\n                    await this.highlightNode(current, 'active', 500);\n                    \n                    // Swap values\n                    this.swap(parentIndex, current);\n                    \n                    // Re-render with new positions\n                    this.renderHeap();\n                    \n                    // Find the new position of our element\n                    current = parentIndex;\n                    \n                    // Wait a bit before next step\n                    await new Promise(resolve => {\n                        const timeout = setTimeout(resolve, 800);\n                        this.currentAnimations.push(timeout);\n                    });\n                }\n            }\n            \n            async animateHeapifyDown(index) {\n                let current = index;\n                \n                while (true) {\n                    let smallest = current;\n                    const left = 2 * current + 1;\n                    const right = 2 * current + 2;\n                    const length = this.heap.length;\n                    \n                    // Find which child is smaller\n                    if (left < length && this.heap[left] < this.heap[smallest]) {\n                        smallest = left;\n                    }\n                    \n                    if (right < length && this.heap[right] < this.heap[smallest]) {\n                        smallest = right;\n                    }\n                    \n                    if (smallest === current) {\n                        break;\n                    }\n                    \n                    // Highlight nodes being compared\n                    await this.highlightNode(current, 'active', 500);\n                    await this.highlightNode(smallest, 'active', 500);\n                    \n                    // Swap values\n                    this.swap(current, smallest);\n                    \n                    // Re-render with new positions\n                    this.renderHeap();\n                    \n                    // Move to child\n                    current = smallest;\n                    \n                    // Wait a bit before next step\n                    await new Promise(resolve => {\n                        const timeout = setTimeout(resolve, 800);\n                        this.currentAnimations.push(timeout);\n                    });\n                }\n            }\n            \n            async animateExtractMin(lastValue) {\n                // Show last node moving to root position\n                const lastNodeIdx = this.heap.length - 1;\n                const lastNode = this.nodeElements[lastNodeIdx];\n                \n                if (!lastNode) {\n                    this.renderHeap();\n                    return;\n                }\n                \n                lastNode.classList.add('active');\n                lastNode.style.transition = 'all 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55)';\n                \n                // Get positions\n                const rootNode = this.nodeElements[0];\n                const containerRect = this.container.getBoundingClientRect();\n                const rootRect = rootNode.getBoundingClientRect();\n                \n                // Calculate relative position\n                const rootX = rootRect.left - containerRect.left;\n                const rootY = rootRect.top - containerRect.top;\n                \n                // Move node to root position\n                lastNode.style.left = `${rootX}px`;\n                lastNode.style.top = `${rootY}px`;\n                lastNode.style.zIndex = '10';\n                lastNode.textContent = lastValue;\n                \n                // After animation completes, re-render\n                return new Promise(resolve => {\n                    const timeout = setTimeout(() => {\n                        this.renderHeap();\n                        resolve();\n                    }, 1000);\n                    \n                    this.currentAnimations.push(timeout);\n                });\n            }\n            \n            swap(i, j) {\n                [this.heap[i], this.heap[j]] = [this.heap[j], this.heap[i]];\n            }\n        }\n        \n        // Initialize visualization when DOM is loaded\n        document.addEventListener('DOMContentLoaded', () => {\n            new MinHeapVisualizer('heapTree');\n        });\n    </script>\n</body>\n</html>"
