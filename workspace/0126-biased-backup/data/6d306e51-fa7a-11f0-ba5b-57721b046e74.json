    "content": "<html>\n<head>\n    <title>Interactive Monitor System</title>\n    <script>\n        // System state\n        let monitorState = {\n            power: false,\n            brightness: 50,\n            contrast: 50,\n            resolution: '1920x1080',\n            inputSource: 'HDMI',\n            colorProfile: 'sRGB',\n            aspectRatio: '16:9',\n            refreshRate: 60,\n            volume: 30,\n            isMenuOpen: false,\n            activeMenu: null,\n            presets: {\n                gaming: {brightness: 70, contrast: 80, refreshRate: 144},\n                movie: {brightness: 40, contrast: 60, refreshRate: 60},\n                office: {brightness: 50, contrast: 50, refreshRate: 60}\n            },\n            customSettings: []\n        };\n\n        // DOM elements\n        let elements = {};\n\n        // Initialize the app\n        function init() {\n            // Cache DOM elements\n            elements = {\n                powerBtn: document.getElementById('powerBtn'),\n                brightnessSlider: document.getElementById('brightnessSlider'),\n                contrastSlider: document.getElementById('contrastSlider'),\n                resolutionSelect: document.getElementById('resolutionSelect'),\n                inputSelect: document.getElementById('inputSelect'),\n                colorProfileSelect: document.getElementById('colorProfileSelect'),\n                aspectRatioSelect: document.getElementById('aspectRatioSelect'),\n                refreshRateSelect: document.getElementById('refreshRateSelect'),\n                volumeSlider: document.getElementById('volumeSlider'),\n                menuBtn: document.getElementById('menuBtn'),\n                presetsSelect: document.getElementById('presetsSelect'),\n                savePresetBtn: document.getElementById('savePresetBtn'),\n                resetBtn: document.getElementById('resetBtn'),\n                infoBtn: document.getElementById('infoBtn'),\n                statusDisplay: document.getElementById('statusDisplay'),\n                settingsPanel: document.getElementById('settingsPanel'),\n                menuPanel: document.getElementById('menuPanel'),\n                mainContent: document.getElementById('mainContent')\n            };\n\n            // Set up event listeners\n            setupEventListeners();\n            updateUI();\n        }\n\n        function setupEventListeners() {\n            elements.powerBtn.addEventListener('click', togglePower);\n            elements.brightnessSlider.addEventListener('input', updateBrightness);\n            elements.contrastSlider.addEventListener('input', updateContrast);\n            elements.resolutionSelect.addEventListener('change', updateResolution);\n            elements.inputSelect.addEventListener('change', updateInputSource);\n            elements.colorProfileSelect.addEventListener('change', updateColorProfile);\n            elements.aspectRatioSelect.addEventListener('change', updateAspectRatio);\n            elements.refreshRateSelect.addEventListener('change', updateRefreshRate);\n            elements.volumeSlider.addEventListener('input', updateVolume);\n            elements.menuBtn.addEventListener('click', toggleMenu);\n            elements.presetsSelect.addEventListener('change', applyPreset);\n            elements.savePresetBtn.addEventListener('click', saveCustomPreset);\n            elements.resetBtn.addEventListener('click', resetSettings);\n            elements.infoBtn.addEventListener('click', showSystemInfo);\n        }\n\n        // State update functions\n        function togglePower() {\n            monitorState.power = !monitorState.power;\n            if (monitorState.power) {\n                monitorState.isMenuOpen = false;\n            }\n            updateUI();\n        }\n\n        function updateBrightness() {\n            monitorState.brightness = elements.brightnessSlider.value;\n            updateStatus(`Brightness set to ${monitorState.brightness}`);\n            updateUI();\n        }\n\n        function updateContrast() {\n            monitorState.contrast = elements.contrastSlider.value;\n            updateStatus(`Contrast set to ${monitorState.contrast}`);\n            updateUI();\n        }\n\n        function updateResolution() {\n            monitorState.resolution = elements.resolutionSelect.value;\n            updateStatus(`Resolution set to ${monitorState.resolution}`);\n            updateUI();\n        }\n\n        function updateInputSource() {\n            monitorState.inputSource = elements.inputSelect.value;\n            updateStatus(`Input source set to ${monitorState.inputSource}`);\n            updateUI();\n        }\n\n        function updateColorProfile() {\n            monitorState.colorProfile = elements.colorProfileSelect.value;\n            updateStatus(`Color profile set to ${monitorState.colorProfile}`);\n            updateUI();\n        }\n\n        function updateAspectRatio() {\n            monitorState.aspectRatio = elements.aspectRatioSelect.value;\n            updateStatus(`Aspect ratio set to ${monitorState.aspectRatio}`);\n            updateUI();\n        }\n\n        function updateRefreshRate() {\n            monitorState.refreshRate = elements.refreshRateSelect.value;\n            updateStatus(`Refresh rate set to ${monitorState.refreshRate}Hz`);\n            updateUI();\n        }\n\n        function updateVolume() {\n            monitorState.volume = elements.volumeSlider.value;\n            updateStatus(`Volume set to ${monitorState.volume}`);\n            updateUI();\n        }\n\n        function toggleMenu() {\n            if (!monitorState.power) return;\n            monitorState.isMenuOpen = !monitorState.isMenuOpen;\n            updateUI();\n        }\n\n        function applyPreset() {\n            const presetName = elements.presetsSelect.value;\n            if (presetName === 'custom') return;\n            \n            const preset = monitorState.presets[presetName];\n            monitorState.brightness = preset.brightness;\n            monitorState.contrast = preset.contrast;\n            monitorState.refreshRate = preset.refreshRate;\n            \n            updateStatus(`Applied ${presetName} preset`);\n            updateUI();\n        }\n\n        function saveCustomPreset() {\n            const presetName = prompt('Enter name for new preset:');\n            if (!presetName) return;\n            \n            monitorState.presets[presetName] = {\n                brightness: monitorState.brightness,\n                contrast: monitorState.contrast,\n                refreshRate: monitorState.refreshRate\n            };\n            \n            // Update presets dropdown\n            const option = document.createElement('option');\n            option.value = presetName;\n            option.textContent = presetName;\n            elements.presetsSelect.appendChild(option);\n            \n            updateStatus(`Saved \"${presetName}\" preset`);\n        }\n\n        function resetSettings() {\n            if (confirm('Reset all settings to defaults?')) {\n                monitorState.brightness = 50;\n                monitorState.contrast = 50;\n                monitorState.resolution = '1920x1080';\n                monitorState.inputSource = 'HDMI';\n                monitorState.colorProfile = 'sRGB';\n                monitorState.aspectRatio = '16:9';\n                monitorState.refreshRate = 60;\n                monitorState.volume = 30;\n                updateStatus('Settings reset to defaults');\n                updateUI();\n            }\n        }\n\n        function showSystemInfo() {\n            const info = `Monitor Status:\nPower: ${monitorState.power ? 'ON' : 'OFF'}\nBrightness: ${monitorState.brightness}\nContrast: ${monitorState.contrast}\nResolution: ${monitorState.resolution}\nInput: ${monitorState.inputSource}\nRefresh Rate: ${monitorState.refreshRate}Hz\nColor Profile: ${monitorState.colorProfile}\nAspect Ratio: ${monitorState.aspectRatio}\nVolume: ${monitorState.volume}`;\n            \n            alert(info);\n        }\n\n        function updateStatus(message) {\n            elements.statusDisplay.textContent = message;\n            setTimeout(() => {\n                if (elements.statusDisplay.textContent === message) {\n                    elements.statusDisplay.textContent = '';\n                }\n            }, 3000);\n        }\n\n        // UI update function\n        function updateUI() {\n            // Update control states based on power\n            const controls = [\n                elements.brightnessSlider,\n                elements.contrastSlider,\n                elements.resolutionSelect,\n                elements.inputSelect,\n                elements.colorProfileSelect,\n                elements.aspectRatioSelect,\n                elements.refreshRateSelect,\n                elements.volumeSlider,\n                elements.menuBtn,\n                elements.presetsSelect,\n                elements.savePresetBtn,\n                elements.resetBtn,\n                elements.infoBtn\n            ];\n            \n            controls.forEach(control => {\n                control.disabled = !monitorState.power;\n            });\n\n            // Update control values\n            elements.brightnessSlider.value = monitorState.brightness;\n            elements.contrastSlider.value = monitorState.contrast;\n            elements.resolutionSelect.value = monitorState.resolution;\n            elements.inputSelect.value = monitorState.inputSource;\n            elements.colorProfileSelect.value = monitorState.colorProfile;\n            elements.aspectRatioSelect.value = monitorState.aspectRatio;\n            elements.refreshRateSelect.value = monitorState.refreshRate;\n            elements.volumeSlider.value = monitorState.volume;\n\n            // Update power button text\n            elements.powerBtn.textContent = monitorState.power ? 'Turn OFF' : 'Turn ON';\n\n            // Update menu visibility\n            elements.menuPanel.style.display = monitorState.isMenuOpen ? 'block' : 'none';\n            elements.mainContent.style.display = monitorState.isMenuOpen ? 'none' : 'block';\n\n            // Update monitor display simulation\n            const display = document.getElementById('monitorDisplay');\n            if (monitorState.power) {\n                display.style.backgroundColor = '#f0f0f0';\n                display.style.border = '1px solid #000';\n                display.innerHTML = `\n                    <div style=\"text-align:center;padding-top:20px;\">\n                        <div>${monitorState.inputSource} Input</div>\n                        <div>${monitorState.resolution} @ ${monitorState.refreshRate}Hz</div>\n                        <div>Brightness: ${monitorState.brightness}</div>\n                        <div>Contrast: ${monitorState.contrast}</div>\n                    </div>\n                `;\n            } else {\n                display.style.backgroundColor = '#000';\n                display.style.border = '1px solid #ccc';\n                display.innerHTML = '<div style=\"color:#fff;text-align:center;padding-top:20px;\">OFF</div>';\n            }\n        }\n    </script>\n</head>\n<body onload=\"init()\">\n    <h1>Interactive Monitor Control System</h1>\n    \n    <div id=\"monitorDisplay\" style=\"width:400px;height:250px;margin:20px auto;\"></div>\n    \n    <div id=\"statusDisplay\" style=\"height:20px;margin:10px;\"></div>\n    \n    <div id=\"displayControls\">\n        <button id=\"powerBtn\">Turn ON</button>\n        <button id=\"menuBtn\">Menu</button>\n        <button id=\"infoBtn\">System Info</button>\n    </div>\n    \n    <div id=\"mainContent\">\n        <div>\n            <label>Brightness: <input type=\"range\" id=\"brightnessSlider\" min=\"0\" max=\"100\" value=\"50\"></label>\n            <span id=\"brightnessValue\">50</span>\n        </div>\n        <div>\n            <label>Contrast: <input type=\"range\" id=\"contrastSlider\" min=\"0\" max=\"100\" value=\"50\"></label>\n            <span id=\"contrastValue\">50</span>\n        </div>\n        <div>\n            <label>Volume: <input type=\"range\" id=\"volumeSlider\" min=\"0\" max=\"100\" value=\"30\"></label>\n            <span id=\"volumeValue\">30</span>\n        </div>\n    </div>\n    \n    <div id=\"menuPanel\" style=\"display:none;\">\n        <h3>Monitor Settings</h3>\n        \n        <div>\n            <label>Resolution:\n                <select id=\"resolutionSelect\">\n                    <option value=\"1920x1080\">1920x1080 (Full HD)</option>\n                    <option value=\"2560x1440\">2560x1440 (QHD)</option>\n                    <option value=\"3840x2160\">3840x2160 (4K UHD)</option>\n                    <option value=\"1280x720\">1280x720 (HD)</option>\n                </select>\n            </label>\n        </div>\n        \n        <div>\n            <label>Input Source:\n                <select id=\"inputSelect\">\n                    <option value=\"HDMI\">HDMI</option>\n                    <option value=\"DisplayPort\">DisplayPort</option>\n                    <option value=\"DVI\">DVI</option>\n                    <option value=\"VGA\">VGA</option>\n                </select>\n            </label>\n        </div>\n        \n        <div>\n            <label>Color Profile:\n                <select id=\"colorProfileSelect\">\n                    <option value=\"sRGB\">sRGB</option>\n                    <option value=\"AdobeRGB\">AdobeRGB</option>\n                    <option value=\"DCI-P3\">DCI-P3</option>\n                    <option value=\"Custom\">Custom</option>\n                </select>\n            </label>\n        </div>\n        \n        <div>\n            <label>Aspect Ratio:\n                <select id=\"aspectRatioSelect\">\n                    <option value=\"16:9\">16:9</option>\n                    <option value=\"16:10\">16:10</option>\n                    <option value=\"4:3\">4:3</option>\n                    <option value=\"21:9\">21:9 (Ultrawide)</option>\n                </select>\n            </label>\n        </div>\n        \n        <div>\n            <label>Refresh Rate (Hz):\n                <select id=\"refreshRateSelect\">\n                    <option value=\"60\">60</option>\n                    <option value=\"75\">75</option>\n                    <option value=\"120\">120</option>\n                    <option value=\"144\">144</option>\n                    <option value=\"240\">240</option>\n                </select>\n            </label>\n        </div>\n        \n        <div>\n            <label>Presets:\n                <select id=\"presetsSelect\">\n                    <option value=\"gaming\">Gaming</option>\n                    <option value=\"movie\">Movie</option>\n                    <option value=\"office\">Office</option>\n                    <option value=\"custom\">Custom...</option>\n                </select>\n            </label>\n            <button id=\"savePresetBtn\">Save Current as Preset</button>\n        </div>\n        \n        <div>\n            <button id=\"resetBtn\">Reset to Defaults</button>\n        </div>\n    </div>\n    \n    <script>\n        // Update value displays in real-time\n        document.getElementById('brightnessSlider').addEventListener('input', function() {\n            document.getElementById('brightnessValue').textContent = this.value;\n        });\n        \n        document.getElementById('contrastSlider').addEventListener('input', function() {\n            document.getElementById('contrastValue').textContent = this.value;\n        });\n        \n        document.getElementById('volumeSlider').addEventListener('input', function() {\n            document.getElementById('volumeValue').textContent = this.value;\n        });\n    </script>\n</body>\n</html>"
