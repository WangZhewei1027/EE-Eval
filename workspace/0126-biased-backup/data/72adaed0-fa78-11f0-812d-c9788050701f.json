    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Means Clustering Visual</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:wght@400;700&display=swap');\n        \n        :root {\n            --primary: #6C63FF;\n            --secondary: #FF6584;\n            --tertiary: #4ECDC4;\n            --dark: #1A1A2E;\n            --light: #F8F9FA;\n            --transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background-color: var(--dark);\n            color: var(--light);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            overflow-x: hidden;\n        }\n        \n        header {\n            width: 100%;\n            padding: 2rem 0;\n            text-align: center;\n            background: linear-gradient(135deg, rgba(108, 99, 255, 0.1) 0%, rgba(255, 101, 132, 0.1) 100%);\n            backdrop-filter: blur(10px);\n            border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3rem;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-weight: 300;\n            letter-spacing: 0.1em;\n            text-transform: uppercase;\n            font-size: 0.9rem;\n            opacity: 0.8;\n        }\n        \n        .container {\n            width: 100%;\n            max-width: 1200px;\n            padding: 2rem;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        \n        .visualization {\n            position: relative;\n            width: 800px;\n            height: 600px;\n            margin: 2rem auto;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 16px;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);\n            backdrop-filter: blur(5px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            overflow: hidden;\n        }\n        \n        canvas {\n            width: 100%;\n            height: 100%;\n            transition: var(--transition);\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 1.5rem;\n        }\n        \n        button {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, var(--primary) 0%, var(--tertiary) 100%);\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            cursor: pointer;\n            font-weight: 600;\n            letter-spacing: 0.05em;\n            text-transform: uppercase;\n            font-size: 0.8rem;\n            transition: var(--transition);\n            box-shadow: 0 4px 15px rgba(108, 99, 255, 0.3);\n        }\n        \n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 6px 20px rgba(108, 99, 255, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .explanation {\n            max-width: 700px;\n            margin: 3rem auto;\n            line-height: 1.8;\n            font-weight: 300;\n            text-align: center;\n            font-size: 1.1rem;\n            opacity: 0.9;\n        }\n        \n        .cluster-info {\n            display: flex;\n            gap: 2rem;\n            margin-top: 2rem;\n            opacity: 0;\n            transform: translateY(20px);\n            transition: var(--transition);\n        }\n        \n        .cluster-info.visible {\n            opacity: 1;\n            transform: translateY(0);\n        }\n        \n        .cluster {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        \n        .cluster-color {\n            width: 24px;\n            height: 24px;\n            border-radius: 50%;\n            margin-bottom: 0.5rem;\n        }\n        \n        .cluster-count {\n            font-size: 0.9rem;\n            font-weight: 600;\n        }\n        \n        footer {\n            margin-top: auto;\n            padding: 2rem 0;\n            text-align: center;\n            width: 100%;\n            font-size: 0.8rem;\n            opacity: 0.6;\n        }\n        \n        @media (max-width: 900px) {\n            .visualization {\n                width: 95%;\n                height: 400px;\n            }\n            \n            h1 {\n                font-size: 2rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <div class=\"container\">\n            <h1>K-Means Clustering</h1>\n            <p class=\"subtitle\">Visualizing Machine Learning</p>\n        </div>\n    </header>\n    \n    <div class=\"container\">\n        <div class=\"visualization\">\n            <canvas id=\"canvas\"></canvas>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"resetBtn\">Reset Points</button>\n            <button id=\"clusterBtn\">Cluster Points</button>\n        </div>\n        \n        <div class=\"cluster-info\">\n            <div class=\"cluster\">\n                <div class=\"cluster-color\" style=\"background: #6C63FF;\"></div>\n                <div class=\"cluster-count\">Cluster 1: <span id=\"count1\">0</span></div>\n            </div>\n            <div class=\"cluster\">\n                <div class=\"cluster-color\" style=\"background: #FF6584;\"></div>\n                <div class=\"cluster-count\">Cluster 2: <span id=\"count2\">0</span></div>\n            </div>\n            <div class=\"cluster\">\n                <div class=\"cluster-color\" style=\"background: #4ECDC4;\"></div>\n                <div class=\"cluster-count\">Cluster 3: <span id=\"count3\">0</span></div>\n            </div>\n        </div>\n        \n        <div class=\"explanation\">\n            K-Means clustering is an unsupervised learning algorithm that groups similar data points together. \n            The algorithm partitions n observations into k clusters where each observation belongs to the cluster \n            with the nearest mean. This visualization demonstrates the process with beautiful aesthetics.\n        </div>\n    </div>\n    \n    <footer>\n        <p>An elegant visualization of machine learning concepts</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            // Canvas setup\n            const canvas = document.getElementById('canvas');\n            const ctx = canvas.getContext('2d');\n            canvas.width = canvas.offsetWidth;\n            canvas.height = canvas.offsetHeight;\n            \n            // Color palette\n            const colors = [\n                { fill: 'rgba(108, 99, 255, 0.7)', stroke: 'rgba(108, 99, 255, 1)' },\n                { fill: 'rgba(255, 101, 132, 0.7)', stroke: 'rgba(255, 101, 132, 1)' },\n                { fill: 'rgba(78, 205, 196, 0.7)', stroke: 'rgba(78, 205, 196, 1)' }\n            ];\n            \n            // Animation variables\n            let animationId = null;\n            let points = [];\n            let centroids = [];\n            let clusters = [];\n            let isClustering = false;\n            let iteration = 0;\n            \n            // UI elements\n            const resetBtn = document.getElementById('resetBtn');\n            const clusterBtn = document.getElementById('clusterBtn');\n            const clusterInfo = document.querySelector('.cluster-info');\n            const countElements = [\n                document.getElementById('count1'),\n                document.getElementById('count2'),\n                document.getElementById('count3')\n            ];\n            \n            // Initialize\n            function init() {\n                createRandomPoints(100);\n                createCentroids(3);\n                draw();\n            }\n            \n            // Create random data points\n            function createRandomPoints(count) {\n                points = [];\n                for (let i = 0; i < count; i++) {\n                    points.push({\n                        x: Math.random() * (canvas.width - 40) + 20,\n                        y: Math.random() * (canvas.height - 40) + 20,\n                        cluster: -1\n                    });\n                }\n            }\n            \n            // Create initial centroids\n            function createCentroids(count) {\n                centroids = [];\n                for (let i = 0; i < count; i++) {\n                    centroids.push({\n                        x: Math.random() * (canvas.width - 100) + 50,\n                        y: Math.random() * (canvas.height - 100) + 50,\n                        color: colors[i]\n                    });\n                }\n            }\n            \n            // Calculate Euclidean distance\n            function distance(p1, p2) {\n                return Math.sqrt(Math.pow(p2.x - p1.x, 2) + Math.pow(p2.y - p1.y, 2));\n            }\n            \n            // Assign points to nearest centroid\n            function assignClusters() {\n                clusters = Array(centroids.length).fill().map(() => []);\n                \n                points.forEach(point => {\n                    let minDist = Infinity;\n                    let closestCentroid = null;\n                    \n                    centroids.forEach((centroid, i) => {\n                        const dist = distance(point, centroid);\n                        if (dist < minDist) {\n                            minDist = dist;\n                            closestCentroid = i;\n                        }\n                    });\n                    \n                    point.cluster = closestCentroid;\n                    clusters[closestCentroid].push(point);\n                });\n                \n                // Update cluster counts in UI\n                clusters.forEach((cluster, i) => {\n                    countElements[i].textContent = cluster.length;\n                });\n                \n                // Show cluster info with animation\n                clusterInfo.classList.add('visible');\n            }\n            \n            // Update centroid positions\n            function updateCentroids() {\n                centroids.forEach((centroid, i) => {\n                    if (clusters[i].length > 0) {\n                        const sumX = clusters[i].reduce((sum, p) => sum + p.x, 0);\n                        const sumY = clusters[i].reduce((sum, p) => sum + p.y, 0);\n                        \n                        centroid.x = sumX / clusters[i].length;\n                        centroid.y = sumY / clusters[i].length;\n                    }\n                });\n            }\n            \n            // Perform one iteration of K-Means\n            function kMeansStep() {\n                assignClusters();\n                updateCentroids();\n                iteration++;\n                \n                if (iteration < 10) {\n                    setTimeout(() => {\n                        animationId = requestAnimationFrame(draw);\n                    }, 800);\n                } else {\n                    isClustering = false;\n                    clusterBtn.disabled = false;\n                }\n            }\n            \n            // Draw everything on canvas\n            function draw() {\n                ctx.clearRect(0, 0, canvas.width, canvas.height);\n                \n                // Draw points\n                points.forEach(point => {\n                    const centroid = centroids[point.cluster] || { color: { fill: 'rgba(255, 255, 255, 0.5)', stroke: 'rgba(255, 255, 255, 0.8)' } };\n                    \n                    ctx.beginPath();\n                    ctx.arc(point.x, point.y, 5, 0, Math.PI * 2);\n                    ctx.fillStyle = point.cluster === -1 ? 'rgba(255, 255, 255, 0.5)' : centroid.color.fill;\n                    ctx.fill();\n                    ctx.strokeStyle = point.cluster === -1 ? 'rgba(255, 255, 255, 0.8)' : centroid.color.stroke;\n                    ctx.stroke();\n                    \n                    // Draw line to centroid when clustered\n                    if (point.cluster !== -1 && isClustering) {\n                        ctx.beginPath();\n                        ctx.moveTo(point.x, point.y);\n                        ctx.lineTo(centroids[point.cluster].x, centroids[point.cluster].y);\n                        ctx.strokeStyle = centroid.color.stroke;\n                        ctx.globalAlpha = 0.3;\n                        ctx.stroke();\n                        ctx.globalAlpha = 1.0;\n                    }\n                });\n                \n                // Draw centroids\n                centroids.forEach(centroid => {\n                    ctx.beginPath();\n                    ctx.arc(centroid.x, centroid.y, 10, 0, Math.PI * 2);\n                    ctx.fillStyle = centroid.color.fill;\n                    ctx.fill();\n                    ctx.strokeStyle = centroid.color.stroke;\n                    ctx.lineWidth = 3;\n                    ctx.stroke();\n                    ctx.lineWidth = 1;\n                });\n                \n                // Continue clustering if in progress\n                if (isClustering) {\n                    kMeansStep();\n                }\n            }\n            \n            // Event listeners\n            resetBtn.addEventListener('click', () => {\n                cancelAnimationFrame(animationId);\n                isClustering = false;\n                iteration = 0;\n                clusterInfo.classList.remove('visible');\n                createRandomPoints(100);\n                createCentroids(3);\n                draw();\n                clusterBtn.disabled = false;\n            });\n            \n            clusterBtn.addEventListener('click', () => {\n                if (!isClustering) {\n                    isClustering = true;\n                    iteration = 0;\n                    clusterBtn.disabled = true;\n                    kMeansStep();\n                }\n            });\n            \n            // Handle window resize\n            window.addEventListener('resize', () => {\n                cancelAnimationFrame(animationId);\n                canvas.width = canvas.offsetWidth;\n                canvas.height = canvas.offsetHeight;\n                draw();\n            });\n            \n            // Start the visualization\n            init();\n        });\n    </script>\n</body>\n</html>"
