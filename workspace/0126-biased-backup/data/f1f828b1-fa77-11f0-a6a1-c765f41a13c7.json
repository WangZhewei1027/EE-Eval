  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>HTTP — Visual Guide</title>\n<style>\n  :root{\n    --bg-1:#0f1724;\n    --bg-2:#071125;\n    --glass: rgba(255,255,255,0.06);\n    --accent-1:#6ee7b7;\n    --accent-2:#7dd3fc;\n    --accent-3:#c084fc;\n    --muted: rgba(255,255,255,0.66);\n    --glass-2: rgba(255,255,255,0.03);\n    --card-shadow: 0 10px 30px rgba(2,6,23,0.7);\n    --glass-border: rgba(255,255,255,0.04);\n    font-synthesis: none;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n\n  /* Base layout */\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,58,237,0.14), transparent 10%),\n                radial-gradient(1000px 500px at 90% 90%, rgba(34,211,238,0.06), transparent 8%),\n                linear-gradient(180deg,var(--bg-1), var(--bg-2) 60%);\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    padding:48px;\n    box-sizing:border-box;\n    overflow-y:auto;\n  }\n\n  .wrap{\n    max-width:1100px;\n    margin:0 auto;\n  }\n\n  header{\n    display:flex;\n    align-items:center;\n    gap:20px;\n    margin-bottom:28px;\n  }\n\n  .brand{\n    display:flex;\n    gap:16px;\n    align-items:center;\n  }\n\n  .logo{\n    width:72px;\n    height:72px;\n    border-radius:16px;\n    background:linear-gradient(135deg,var(--accent-2),var(--accent-3));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 6px 28px rgba(124,58,237,0.22), inset 0 -6px 14px rgba(255,255,255,0.06);\n    transform: rotate(-8deg);\n  }\n\n  .logo svg{filter:drop-shadow(0 6px 14px rgba(0,0,0,0.35))}\n\n  h1{\n    font-size:28px;\n    line-height:1;\n    margin:0;\n    letter-spacing:-0.02em;\n    color: #ffffff;\n  }\n\n  p.lead{\n    margin:4px 0 0 0;\n    color:var(--muted);\n    font-size:14px;\n  }\n\n  /* CTA */\n  .controls{\n    margin-left:auto;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 16px;\n    border-radius:12px;\n    cursor:pointer;\n    font-weight:600;\n    font-size:14px;\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    transition:transform .18s ease, box-shadow .18s ease;\n    box-shadow: 0 6px 20px rgba(2,6,23,0.5);\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    color: #eaf7ff;\n    border:1px solid var(--glass-border);\n  }\n\n  .btn:active{transform:translateY(1px)}\n  .btn.primary{\n    background: linear-gradient(90deg,var(--accent-1),var(--accent-2));\n    color:#04212a;\n    box-shadow: 0 12px 30px rgba(99,102,241,0.12), 0 6px 22px rgba(34,211,238,0.06);\n    border: none;\n  }\n\n  .btn.ghost{\n    background:transparent;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.04);\n  }\n\n  /* Visualization area */\n  .visual{\n    margin-top:28px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:18px;\n    padding:26px;\n    box-shadow: var(--card-shadow);\n    border:1px solid var(--glass-border);\n    overflow:hidden;\n  }\n\n  .panel{\n    display:grid;\n    grid-template-columns: 1fr 340px;\n    gap:24px;\n    align-items:start;\n  }\n\n  .scene{\n    min-height:360px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n    border-radius:14px;\n    padding:22px;\n    position:relative;\n    overflow:visible;\n  }\n\n  /* Left browser & right server cards */\n  .node{\n    width:160px;\n    height:110px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    padding:12px;\n    display:flex;\n    flex-direction:column;\n    gap:8px;\n    box-shadow: 0 10px 30px rgba(2,6,23,0.45);\n  }\n\n  .browser .node-title, .server .node-title{\n    font-size:13px;\n    font-weight:700;\n    color: #e8fbff;\n  }\n  .node .node-sub{font-size:12px;color:var(--muted)}\n\n  .browser .window{\n    flex:1;\n    border-radius:8px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.006));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:var(--muted);\n    font-size:13px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  .server .rack{\n    flex:1;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:var(--muted);\n    gap:8px;\n  }\n\n  /* Middle network lane */\n  .lane{\n    position:absolute;\n    left:50%;\n    transform:translateX(-50%);\n    top:28px;\n    bottom:28px;\n    width:220px;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    pointer-events:none;\n  }\n\n  .wire{\n    width:6px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    border-radius:6px;\n    height:100%;\n    position:relative;\n    box-shadow: inset 0 0 18px rgba(255,255,255,0.02), 0 6px 24px rgba(2,6,23,0.4);\n    padding:18px 0;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:22px;\n    flex-direction:column;\n  }\n\n  .node-left{position:absolute; left:26px; top:30px}\n  .node-right{position:absolute; right:26px; top:30px}\n\n  /* moving packet */\n  .packet{\n    width:22px;\n    height:22px;\n    border-radius:999px;\n    background: linear-gradient(180deg,var(--accent-2), var(--accent-3));\n    box-shadow: 0 8px 24px rgba(124,58,237,0.28), 0 2px 6px rgba(0,0,0,0.45);\n    transform-origin:center;\n    position:relative;\n    z-index:6;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:#04212a;\n    font-weight:800;\n    font-size:11px;\n  }\n\n  .ghost-packet{\n    width:14px;\n    height:14px;\n    border-radius:999px;\n    background: linear-gradient(180deg,var(--accent-1), var(--accent-2));\n    opacity:0.12;\n    box-shadow: 0 6px 18px rgba(99,102,241,0.06);\n  }\n\n  .dot-trail{\n    position:absolute;\n    width:6px;\n    height:6px;\n    background: linear-gradient(90deg,var(--accent-1),var(--accent-2));\n    border-radius:3px;\n    opacity:0.12;\n    filter: blur(6px);\n  }\n\n  /* Pathing visual */\n  .path{\n    width:100%;\n    height:40%;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transform:translateY(-6px);\n    position:relative;\n    pointer-events:none;\n  }\n\n  .arc{\n    width:160px;\n    height:120px;\n    opacity:0.9;\n  }\n\n  /* Request / Response labels */\n  .bubble{\n    position:absolute;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border-radius:10px;\n    padding:8px 10px;\n    font-size:12px;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 10px 30px rgba(2,6,23,0.4);\n    transform-origin:center;\n    opacity:0;\n  }\n\n  .bubble.request{left:12px; top:36%;}\n  .bubble.response{right:12px; bottom:36%}\n\n  /* right panel info */\n  .info{\n    padding:18px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.016), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    min-height:360px;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n  }\n\n  .info h3{margin:0;font-size:14px;color:#f5fbff}\n  .chips{\n    display:flex;\n    gap:8px;\n    flex-wrap:wrap;\n    margin-top:6px;\n  }\n\n  .chip{\n    padding:8px 10px;\n    border-radius:999px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n    font-weight:600;\n    color:var(--muted);\n    font-size:12px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 8px 18px rgba(2,6,23,0.35);\n  }\n\n  .chip.method{background:linear-gradient(90deg,var(--accent-2), var(--accent-3)); color:#04212a}\n  .chip.status{background:linear-gradient(90deg,var(--accent-1), #34d399); color:#04212a}\n\n  .info .meta{font-size:13px;color:var(--muted); line-height:1.45}\n\n  /* smaller cards (below) */\n  .details{\n    margin-top:20px;\n    display:grid;\n    grid-template-columns:repeat(3,1fr);\n    gap:16px;\n  }\n\n  .card{\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n    padding:16px;\n    border-radius:12px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 8px 20px rgba(2,6,23,0.35);\n  }\n\n  .card h4{margin:0 0 8px 0;font-size:13px;color:#f6fdff}\n  .card p{margin:0;color:var(--muted);font-size:13px;line-height:1.45}\n\n  /* animations triggered */\n  .animate .packet{\n    animation: requestOut 2.1s cubic-bezier(.2,.9,.2,1) forwards, pulse .9s ease .4s;\n  }\n\n  .animate .packet.response{\n    animation: responseBack 2.1s cubic-bezier(.2,.9,.2,1) forwards 2.4s, pulse .9s ease 2.6s;\n  }\n\n  .animate .bubble.request{\n    animation: popIn .45s ease .18s forwards, floatUp 2.4s cubic-bezier(.2,.9,.2,1) .18s forwards;\n  }\n  .animate .bubble.response{\n    animation: popIn .45s ease 2.5s forwards, floatDown 2.4s cubic-bezier(.2,.9,.2,1) 2.5s forwards;\n  }\n\n  .animate .server-glow{\n    animation: glowPulse 1.6s ease .9s forwards;\n  }\n\n  .animate .status{\n    animation: statusPop 1s cubic-bezier(.2,.9,.2,1) 3.2s forwards;\n  }\n\n  @keyframes requestOut{\n    0%{transform:translateY(0) translateX(-12px) scale(1); opacity:1}\n    22%{transform:translateY(-14px) translateX(-6px) scale(1.05)}\n    60%{transform:translateY(-60px) translateX(120px) scale(.98)}\n    100%{transform:translateY(-120px) translateX(210px) scale(.9); opacity:0}\n  }\n\n  @keyframes responseBack{\n    0%{transform:translateY(120px) translateX(210px) scale(.92); opacity:0}\n    35%{opacity:1; transform:translateY(40px) translateX(60px) scale(1.02)}\n    100%{transform:translateY(0) translateX(-12px) scale(1); opacity:1}\n  }\n\n  @keyframes popIn{\n    0%{transform:scale(.9) translateY(6px); opacity:0}\n    100%{transform:scale(1) translateY(0); opacity:1}\n  }\n\n  @keyframes floatUp{\n    0%{transform:translateY(0); opacity:1}\n    100%{transform:translateY(-140px); opacity:0}\n  }\n\n  @keyframes floatDown{\n    0%{transform:translateY(0); opacity:1}\n    100%{transform:translateY(120px); opacity:0}\n  }\n\n  @keyframes glowPulse{\n    0%{box-shadow: 0 10px 30px rgba(2,6,23,0.45)}\n    40%{box-shadow: 0 18px 30px rgba(124,58,237,0.18), 0 6px 22px rgba(34,211,238,0.06)}\n    100%{box-shadow: 0 10px 30px rgba(2,6,23,0.45)}\n  }\n\n  @keyframes pulse{\n    0%{transform:scale(1)}\n    50%{transform:scale(1.08)}\n    100%{transform:scale(1)}\n  }\n\n  @keyframes statusPop{\n    0%{transform:translateY(6px) scale(.96); opacity:0}\n    100%{transform:translateY(0) scale(1); opacity:1}\n  }\n\n  /* responsive */\n  @media (max-width:980px){\n    .panel{grid-template-columns:1fr; gap:18px}\n    .lane{position:relative; transform:translateX(0); width:100%; top:auto; left:auto; margin-top:18px}\n    .node-left,.node-right{position:static}\n    .scene{min-height:420px}\n    .details{grid-template-columns:1fr}\n  }\n\n  /* tasteful footer */\n  footer{margin-top:26px;color:var(--muted); font-size:13px; text-align:center}\n</style>\n</head>\n<body>\n<div class=\"wrap\" aria-live=\"polite\">\n  <header>\n    <div class=\"brand\">\n      <div class=\"logo\" aria-hidden=\"true\">\n        <!-- Abstract H icon -->\n        <svg width=\"44\" height=\"44\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7dd3fc\"/><stop offset=\"1\" stop-color=\"#c084fc\"/></linearGradient>\n          </defs>\n          <rect x=\"1\" y=\"1\" width=\"22\" height=\"22\" rx=\"6\" fill=\"url(#g1)\" />\n          <path d=\"M7 7h3v10H7zM14 7h3v10h-3zM10.5 7h3v10h-3z\" fill=\"#04212a\" opacity=\"0.9\"/>\n        </svg>\n      </div>\n      <div>\n        <h1>HTTP — Hypertext Transfer Protocol</h1>\n        <p class=\"lead\">A visual demonstration of how requests and responses traverse the web.</p>\n      </div>\n    </div>\n\n    <div class=\"controls\" role=\"group\" aria-label=\"Controls\">\n      <button class=\"btn primary\" id=\"playBtn\" aria-pressed=\"false\">Send Request</button>\n      <button class=\"btn ghost\" id=\"resetBtn\">Reset</button>\n    </div>\n  </header>\n\n  <main class=\"visual\" role=\"main\">\n    <div class=\"panel\">\n      <div class=\"scene\" id=\"scene\" aria-hidden=\"false\">\n        <!-- Left node -->\n        <div class=\"node node-left browser\" style=\"top:28px; left:22px;\">\n          <div class=\"node-title\">Client</div>\n          <div class=\"node-sub\">Browser — initiates request</div>\n          <div class=\"window\" aria-hidden=\"true\">\n            <svg width=\"88\" height=\"48\" viewBox=\"0 0 160 96\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n              <defs>\n                <linearGradient id=\"bg\" x1=\"0\" x2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#071125\"/>\n                  <stop offset=\"1\" stop-color=\"#0b2330\"/>\n                </linearGradient>\n              </defs>\n              <rect x=\"2\" y=\"6\" width=\"156\" height=\"84\" rx=\"8\" fill=\"url(#bg)\" stroke=\"rgba(255,255,255,0.04)\"/>\n              <rect x=\"12\" y=\"18\" width=\"136\" height=\"8\" rx=\"4\" fill=\"#081826\"/>\n              <circle cx=\"26\" cy=\"33\" r=\"3\" fill=\"#f97316\"/>\n              <circle cx=\"36\" cy=\"33\" r=\"3\" fill=\"#f59e0b\"/>\n              <circle cx=\"46\" cy=\"33\" r=\"3\" fill=\"#10b981\"/>\n              <text x=\"20\" y=\"62\" fill=\"#9bd3f0\" font-size=\"12\" font-weight=\"700\">GET /index.html</text>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Right node -->\n        <div class=\"node node-right server\" style=\"top:28px; right:22px;\">\n          <div class=\"node-title\">Server</div>\n          <div class=\"node-sub\">Origin — hosts resource</div>\n          <div class=\"rack\" aria-hidden=\"true\">\n            <svg width=\"88\" height=\"48\" viewBox=\"0 0 160 96\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <rect x=\"2\" y=\"10\" width=\"156\" height=\"80\" rx=\"8\" fill=\"linear-gradient(180deg,#021124,#071829)\" stroke=\"rgba(255,255,255,0.03)\"/>\n              <g transform=\"translate(16,18)\" fill=\"#082a36\">\n                <rect x=\"0\" y=\"0\" width=\"64\" height=\"12\" rx=\"3\" fill=\"#071b26\"/>\n                <rect x=\"0\" y=\"18\" width=\"64\" height=\"12\" rx=\"3\" fill=\"#071b26\"/>\n                <rect x=\"0\" y=\"36\" width=\"64\" height=\"12\" rx=\"3\" fill=\"#071b26\"/>\n              </g>\n              <g transform=\"translate(100,24)\">\n                <rect x=\"0\" y=\"6\" width=\"34\" height=\"8\" rx=\"3\" fill=\"#06b6d4\"/>\n                <rect x=\"0\" y=\"26\" width=\"34\" height=\"8\" rx=\"3\" fill=\"#7c3aed\"/>\n              </g>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Middle lane -->\n        <div class=\"lane\" aria-hidden=\"true\">\n          <div class=\"wire\" role=\"img\" aria-label=\"Network wire\">\n            <div class=\"arc\" aria-hidden=\"true\">\n              <!-- SVG arc for visual path -->\n              <svg viewBox=\"0 0 200 120\" width=\"160\" height=\"120\">\n                <defs>\n                  <linearGradient id=\"gwire\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#7dd3fc\"/>\n                    <stop offset=\"1\" stop-color=\"#c084fc\"/>\n                  </linearGradient>\n                </defs>\n                <path d=\"M12 108 C48 64 152 64 188 108\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"6\" fill=\"none\" stroke-linecap=\"round\"/>\n                <path d=\"M12 108 C48 64 152 64 188 108\" id=\"pathGlow\" stroke=\"url(#gwire)\" stroke-width=\"2.2\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.9\"/>\n              </svg>\n            </div>\n\n            <!-- moving packets -->\n            <div class=\"packet\" id=\"packet\" title=\"Request\">\n              <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M3 12h18\" stroke=\"#04212a\" stroke-width=\"2.2\" stroke-linecap=\"round\"/></svg>\n            </div>\n\n            <div class=\"packet response\" id=\"packetResp\" style=\"opacity:0; transform:translateY(140px) translateX(210px) scale(.9);\" title=\"Response\">\n              <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 3v18\" stroke=\"#04212a\" stroke-width=\"2.2\" stroke-linecap=\"round\"/></svg>\n            </div>\n\n            <div class=\"ghost-packet\" style=\"margin-top:8px;\"></div>\n            <div class=\"ghost-packet\" style=\"margin-top:6px; transform:scale(.86)\"></div>\n\n            <!-- Bubbles for labels -->\n            <div class=\"bubble request\" id=\"bubbleReq\" aria-hidden=\"true\">\n              <div style=\"font-weight:700; color:#eafffb; font-size:13px\">GET /index.html</div>\n              <div style=\"font-size:11px; color:var(--muted); margin-top:6px;\">HTTP/1.1 • Host: example.com</div>\n            </div>\n\n            <div class=\"bubble response\" id=\"bubbleRes\" aria-hidden=\"true\">\n              <div style=\"font-weight:700; color:#eafffb; font-size:13px\">200 OK</div>\n              <div style=\"font-size:11px; color:var(--muted); margin-top:6px;\">Content-Type: text/html</div>\n            </div>\n          </div>\n        </div>\n\n        <!-- subtle status badge to show after animation -->\n        <div id=\"statusBadge\" style=\"position:absolute; left:50%; transform:translateX(-50%); bottom:20px; opacity:0;\">\n          <div class=\"chip status\" style=\"padding:12px 16px; font-size:13px;\" id=\"statusText\">200 • OK</div>\n        </div>\n      </div>\n\n      <aside class=\"info\" aria-hidden=\"false\">\n        <div>\n          <h3>Core Concepts</h3>\n          <div class=\"chips\" aria-hidden=\"true\">\n            <div class=\"chip method\">GET</div>\n            <div class=\"chip method\">POST</div>\n            <div class=\"chip\">Headers</div>\n            <div class=\"chip\">Status Codes</div>\n            <div class=\"chip\">TLS</div>\n          </div>\n        </div>\n\n        <div class=\"meta\" aria-hidden=\"true\">\n          <p style=\"margin:10px 0 0 0;\">HTTP is a stateless application-level protocol used to transfer hypermedia documents, such as HTML. A client sends a request; the server returns a response with a status code and content.</p>\n        </div>\n\n        <div style=\"margin-top:auto\">\n          <h3>Quick Reference</h3>\n          <div style=\"display:flex; gap:8px; margin-top:8px;\">\n            <div class=\"chip\" style=\"background:linear-gradient(90deg,#60a5fa,#7dd3fc); color:#04212a\">200 OK</div>\n            <div class=\"chip\" style=\"background:linear-gradient(90deg,#fb923c,#f97316); color:#04212a\">404 Not Found</div>\n            <div class=\"chip\" style=\"background:linear-gradient(90deg,#f472b6,#fb7185); color:#04212a\">500 Server Error</div>\n          </div>\n        </div>\n      </aside>\n    </div>\n\n    <div class=\"details\" aria-hidden=\"true\">\n      <div class=\"card\">\n        <h4>How it works</h4>\n        <p><strong>1.</strong> The client constructs an HTTP request with a method (GET/POST), target path and headers. <strong>2.</strong> The request travels over TCP/IP (often TLS). <strong>3.</strong> The server processes and responds with a status code and body.</p>\n      </div>\n\n      <div class=\"card\">\n        <h4>Request Example</h4>\n        <p style=\"font-family:monospace; font-size:12px; margin-top:6px\">GET /index.html HTTP/1.1<br>Host: example.com<br>User-Agent: Browser/1.0</p>\n      </div>\n\n      <div class=\"card\">\n        <h4>Response Example</h4>\n        <p style=\"font-family:monospace; font-size:12px; margin-top:6px\">HTTP/1.1 200 OK<br>Content-Type: text/html<br><span style=\"opacity:0.9\">...&lt;html&gt;...</span></p>\n      </div>\n    </div>\n  </main>\n\n  <footer>\n    Aesthetic demonstration — observe a single HTTP request/response. Minimal controls: Send Request / Reset.\n  </footer>\n</div>\n\n<script>\n  (function(){\n    const playBtn = document.getElementById('playBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const scene = document.getElementById('scene');\n    const packet = document.getElementById('packet');\n    const packetResp = document.getElementById('packetResp');\n    const bubbleReq = document.getElementById('bubbleReq');\n    const bubbleRes = document.getElementById('bubbleRes');\n    const statusBadge = document.getElementById('statusBadge');\n    const statusText = document.getElementById('statusText');\n\n    let running = false;\n    function startAnimation(){\n      if(running) return;\n      running = true;\n      playBtn.setAttribute('aria-pressed', 'true');\n      scene.classList.add('animate');\n\n      // Aria: announce start\n      const live = document.createElement('div');\n      live.setAttribute('aria-live','polite');\n      live.style.position='absolute';\n      live.style.left='-9999px';\n      live.textContent = 'Sending HTTP request';\n      document.body.appendChild(live);\n      setTimeout(()=>document.body.removeChild(live),1200);\n\n      // Show request bubble briefly\n      bubbleReq.style.opacity = 0;\n      bubbleRes.style.opacity = 0;\n      statusBadge.style.opacity = 0;\n\n      // After full sequence, reveal status\n      setTimeout(()=> {\n        statusBadge.style.opacity = 1;\n        statusBadge.querySelector('.chip').classList.add('status');\n      }, 3200);\n\n      // After sequence, set running false\n      setTimeout(()=> {\n        running = false;\n        playBtn.setAttribute('aria-pressed', 'false');\n      }, 4200);\n    }\n\n    function reset(){\n      running = false;\n      scene.classList.remove('animate');\n      // reset positions\n      packet.style.opacity = 1;\n      packet.style.transform = 'translateY(0) translateX(-12px) scale(1)';\n      packetResp.style.opacity = 0;\n      packetResp.style.transform = 'translateY(140px) translateX(210px) scale(.9)';\n      bubbleReq.style.opacity = 0;\n      bubbleReq.style.transform = 'scale(.9) translateY(6px)';\n      bubbleRes.style.opacity = 0;\n      bubbleRes.style.transform = 'scale(.9) translateY(6px)';\n      statusBadge.style.opacity = 0;\n      statusBadge.querySelector('.chip').classList.remove('status');\n    }\n\n    playBtn.addEventListener('click', startAnimation);\n    resetBtn.addEventListener('click', reset);\n\n    // Small enhancement: press Enter on play activates\n    playBtn.addEventListener('keyup', (e)=>{ if(e.key==='Enter') startAnimation(); });\n    resetBtn.addEventListener('keyup', (e)=>{ if(e.key==='Enter') reset(); });\n\n    // Initialize state\n    reset();\n\n    // Cosmetic: gentle pulsing on idle for packet\n    setInterval(()=> {\n      if(!scene.classList.contains('animate')){\n        packet.animate([{transform:'translateY(0) scale(1)'},{transform:'translateY(-6px) scale(1.03)'},{transform:'translateY(0) scale(1)'}],\n          {duration:2400, easing:'ease-in-out'});\n      }\n    }, 3000);\n\n  })();\n</script>\n</body>\n</html>"
