  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Type System Explorer</title>\n    <style>\n        body { font-family: monospace; margin: 20px; line-height: 1.5; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #000; padding: 10px; }\n        .row { display: flex; gap: 10px; margin-bottom: 10px; }\n        button, select, input { font-family: monospace; }\n        .output { min-height: 100px; border: 1px dashed #000; padding: 10px; }\n        .error { color: red; }\n        .type-example { cursor: pointer; text-decoration: underline; }\n        .type-details { margin-top: 10px; padding: 5px; border-left: 3px solid #000; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Type System Explorer</h1>\n        \n        <div class=\"panel\">\n            <h2>Type Creation</h2>\n            <div class=\"row\">\n                <select id=\"type-category\">\n                    <option value=\"primitive\">Primitive</option>\n                    <option value=\"composite\">Composite</option>\n                    <option value=\"function\">Function</option>\n                    <option value=\"generic\">Generic</option>\n                </select>\n                <input type=\"text\" id=\"type-name\" placeholder=\"Type name\">\n                <button id=\"create-type\">Create Type</button>\n            </div>\n            \n            <div id=\"type-config\" style=\"display: none;\">\n                <div id=\"primitive-config\" class=\"type-config\">\n                    <div class=\"row\">\n                        <label><input type=\"radio\" name=\"primitive-type\" value=\"number\" checked> Number</label>\n                        <label><input type=\"radio\" name=\"primitive-type\" value=\"string\"> String</label>\n                        <label><input type=\"radio\" name=\"primitive-type\" value=\"boolean\"> Boolean</label>\n                        <label><input type=\"radio\" name=\"primitive-type\" value=\"null\"> Null</label>\n                        <label><input type=\"radio\" name=\"primitive-type\" value=\"undefined\"> Undefined</label>\n                    </div>\n                </div>\n                \n                <div id=\"composite-config\" class=\"type-config\" style=\"display: none;\">\n                    <div class=\"row\">\n                        <select id=\"composite-type\">\n                            <option value=\"array\">Array</option>\n                            <option value=\"object\">Object</option>\n                            <option value=\"tuple\">Tuple</option>\n                            <option value=\"union\">Union</option>\n                            <option value=\"intersection\">Intersection</option>\n                        </select>\n                    </div>\n                    <div id=\"composite-details\"></div>\n                </div>\n                \n                <div id=\"function-config\" class=\"type-config\" style=\"display: none;\">\n                    <div class=\"row\">\n                        <div>\n                            <h4>Parameters</h4>\n                            <div id=\"function-params\">\n                                <div class=\"row\">\n                                    <input type=\"text\" placeholder=\"param name\" class=\"param-name\">\n                                    <select class=\"param-type\">\n                                        <option>number</option>\n                                        <option>string</option>\n                                        <option>boolean</option>\n                                    </select>\n                                    <button class=\"remove-param\">×</button>\n                                </div>\n                            </div>\n                            <button id=\"add-param\">Add Parameter</button>\n                        </div>\n                        <div>\n                            <h4>Return Type</h4>\n                            <select id=\"return-type\">\n                                <option>number</option>\n                                <option>string</option>\n                                <option>boolean</option>\n                                <option>void</option>\n                            </select>\n                        </div>\n                    </div>\n                </div>\n                \n                <div id=\"generic-config\" class=\"type-config\" style=\"display: none;\">\n                    <div class=\"row\">\n                        <input type=\"text\" id=\"generic-param\" placeholder=\"Type parameter (e.g., T)\">\n                        <button id=\"add-generic-param\">Add Parameter</button>\n                    </div>\n                    <div id=\"generic-params-list\"></div>\n                    <div class=\"row\">\n                        <select id=\"generic-base-type\">\n                            <option value=\"array\">Array&lt;T&gt;</option>\n                            <option value=\"function\">Function</option>\n                            <option value=\"object\">Object</option>\n                        </select>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Type Playground</h2>\n            <div class=\"row\">\n                <select id=\"selected-type\">\n                    <option value=\"\">Select a type...</option>\n                </select>\n                <input type=\"text\" id=\"value-input\" placeholder=\"Enter value\">\n                <button id=\"check-type\">Check Type</button>\n                <button id=\"infer-type\">Infer Type</button>\n            </div>\n            <div class=\"output\" id=\"type-result\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Type System Operations</h2>\n            <div class=\"row\">\n                <select id=\"type-op1\">\n                    <option>Select type...</option>\n                </select>\n                <select id=\"type-operation\">\n                    <option value=\"assignable\">Is Assignable To</option>\n                    <option value=\"union\">Union With</option>\n                    <option value=\"intersection\">Intersection With</option>\n                    <option value=\"extends\">Extends</option>\n                </select>\n                <select id=\"type-op2\">\n                    <option>Select type...</option>\n                </select>\n                <button id=\"perform-operation\">Perform Operation</button>\n            </div>\n            <div class=\"output\" id=\"operation-result\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Type Examples</h2>\n            <div id=\"type-examples\">\n                <p class=\"type-example\" data-type=\"number\">42</p>\n                <p class=\"type-example\" data-type=\"string\">\"Hello\"</p>\n                <p class=\"type-example\" data-type=\"boolean\">true</p>\n                <p class=\"type-example\" data-type=\"array\">[1, 2, 3]</p>\n                <p class=\"type-example\" data-type=\"object\">{ name: \"Alice\", age: 30 }</p>\n                <p class=\"type-example\" data-type=\"tuple\">[string, number]</p>\n                <p class=\"type-example\" data-type=\"union\">string | number</p>\n                <p class=\"type-example\" data-type=\"function\">(x: number) => string</p>\n                <p class=\"type-example\" data-type=\"generic\">Array&lt;T&gt;</p>\n            </div>\n            <div class=\"type-details\" id=\"example-details\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Type System Summary</h2>\n            <div id=\"type-summary\"></div>\n        </div>\n    </div>\n\n    <script>\n        // Type system state\n        const typeSystem = {\n            types: {\n                number: { kind: 'primitive', name: 'number' },\n                string: { kind: 'primitive', name: 'string' },\n                boolean: { kind: 'primitive', name: 'boolean' },\n                null: { kind: 'primitive', name: 'null' },\n                undefined: { kind: 'primitive', name: 'undefined' },\n                // More types will be added dynamically\n            },\n            createType(name, config) {\n                this.types[name] = config;\n                this.updateUI();\n            },\n            isAssignable(value, typeName) {\n                const type = this.types[typeName];\n                if (!type) return false;\n                \n                if (type.kind === 'primitive') {\n                    return typeof value === type.name || \n                           (type.name === 'null' && value === null) ||\n                           (type.name === 'undefined' && value === undefined);\n                }\n                \n                if (type.kind === 'array') {\n                    return Array.isArray(value) && \n                           (type.elementType ? value.every(item => this.isAssignable(item, type.elementType)) : true);\n                }\n                \n                if (type.kind === 'object') {\n                    if (typeof value !== 'object' || value === null) return false;\n                    for (const [prop, propType] of Object.entries(type.properties)) {\n                        if (!(prop in value) || !this.isAssignable(value[prop], propType)) {\n                            return false;\n                        }\n                    }\n                    return true;\n                }\n                \n                return false;\n            },\n            inferType(value) {\n                if (value === null) return 'null';\n                if (Array.isArray(value)) {\n                    if (value.length === 0) return 'any[]';\n                    const elementType = this.inferType(value[0]);\n                    return `Array<${elementType}>`;\n                }\n                if (typeof value === 'object') {\n                    const props = Object.entries(value).map(([k, v]) => `${k}: ${this.inferType(v)}`).join(', ');\n                    return `{ ${props} }`;\n                }\n                return typeof value;\n            },\n            updateUI() {\n                // Update type selectors\n                const typeSelectors = ['selected-type', 'type-op1', 'type-op2'];\n                typeSelectors.forEach(selector => {\n                    const select = document.getElementById(selector);\n                    const currentValue = select.value;\n                    select.innerHTML = `<option value=\"\">Select a type...</option>` +\n                        Object.keys(this.types).map(name => \n                            `<option value=\"${name}\" ${name === currentValue ? 'selected' : ''}>${name}</option>`\n                        ).join('');\n                });\n                \n                // Update type summary\n                const summary = document.getElementById('type-summary');\n                summary.innerHTML = Object.entries(this.types).map(([name, type]) => {\n                    let details = '';\n                    if (type.kind === 'primitive') details = `Primitive type`;\n                    if (type.kind === 'array') details = `Array of ${type.elementType || 'any'}`;\n                    if (type.kind === 'object') {\n                        details = `Object with properties: ${Object.entries(type.properties).map(([k, v]) => `${k}: ${v}`).join(', ')}`;\n                    }\n                    return `<div><strong>${name}</strong>: ${details}</div>`;\n                }).join('');\n            }\n        };\n\n        // UI Event Handlers\n        document.getElementById('type-category').addEventListener('change', function() {\n            document.querySelectorAll('.type-config').forEach(el => el.style.display = 'none');\n            document.getElementById('type-config').style.display = 'block';\n            document.getElementById(`${this.value}-config`).style.display = 'block';\n        });\n\n        document.getElementById('create-type').addEventListener('click', function() {\n            const name = document.getElementById('type-name').value.trim();\n            if (!name) {\n                alert('Please enter a type name');\n                return;\n            }\n            \n            const category = document.getElementById('type-category').value;\n            let config;\n            \n            if (category === 'primitive') {\n                const type = document.querySelector('input[name=\"primitive-type\"]:checked').value;\n                config = { kind: 'primitive', name: type };\n            }\n            else if (category === 'composite') {\n                const compositeType = document.getElementById('composite-type').value;\n                if (compositeType === 'array') {\n                    const elementType = prompt('Element type (e.g., number, string):', 'any');\n                    config = { kind: 'array', elementType: elementType || 'any' };\n                }\n                else if (compositeType === 'object') {\n                    const props = prompt('Enter properties (format: name:type, name:type):', 'age:number, name:string');\n                    const properties = {};\n                    if (props) {\n                        props.split(',').forEach(pair => {\n                            const [name, type] = pair.trim().split(':').map(s => s.trim());\n                            if (name && type) properties[name] = type;\n                        });\n                    }\n                    config = { kind: 'object', properties };\n                }\n                else if (compositeType === 'tuple') {\n                    const elements = prompt('Enter tuple element types (comma separated):', 'string, number');\n                    config = { kind: 'tuple', elements: elements ? elements.split(',').map(s => s.trim()) : [] };\n                }\n                else if (compositeType === 'union') {\n                    const types = prompt('Enter union types (separated by |):', 'string | number');\n                    config = { kind: 'union', types: types ? types.split('|').map(s => s.trim()) : [] };\n                }\n                else if (compositeType === 'intersection') {\n                    const types = prompt('Enter intersection types (separated by &):', 'A & B');\n                    config = { kind: 'intersection', types: types ? types.split('&').map(s => s.trim()) : [] };\n                }\n            }\n            else if (category === 'function') {\n                const params = Array.from(document.querySelectorAll('#function-params .row')).map(row => {\n                    return {\n                        name: row.querySelector('.param-name').value,\n                        type: row.querySelector('.param-type').value\n                    };\n                });\n                const returnType = document.getElementById('return-type').value;\n                config = { kind: 'function', params, returnType };\n            }\n            else if (category === 'generic') {\n                const params = Array.from(document.querySelectorAll('#generic-params-list .generic-param')).map(el => el.textContent);\n                const baseType = document.getElementById('generic-base-type').value;\n                config = { kind: 'generic', params, baseType };\n            }\n            \n            typeSystem.createType(name, config);\n        });\n\n        document.getElementById('check-type').addEventListener('click', function() {\n            const typeName = document.getElementById('selected-type').value;\n            const valueInput = document.getElementById('value-input').value;\n            let value;\n            \n            try {\n                value = eval(`(${valueInput})`);\n            } catch (e) {\n                document.getElementById('type-result').innerHTML = `<div class=\"error\">Invalid value syntax: ${e.message}</div>`;\n                return;\n            }\n            \n            const isValid = typeSystem.isAssignable(value, typeName);\n            document.getElementById('type-result').innerHTML = `\n                <div>Value: <code>${JSON.stringify(value)}</code></div>\n                <div>Type: <code>${typeName}</code></div>\n                <div>Result: <strong>${isValid ? 'Valid' : 'Invalid'}</strong></div>\n                <div>Actual type: ${typeSystem.inferType(value)}</div>\n            `;\n        });\n\n        document.getElementById('infer-type').addEventListener('click', function() {\n            const valueInput = document.getElementById('value-input').value;\n            let value;\n            \n            try {\n                value = eval(`(${valueInput})`);\n            } catch (e) {\n                document.getElementById('type-result').innerHTML = `<div class=\"error\">Invalid value syntax: ${e.message}</div>`;\n                return;\n            }\n            \n            const inferredType = typeSystem.inferType(value);\n            document.getElementById('type-result').innerHTML = `\n                <div>Value: <code>${JSON.stringify(value)}</code></div>\n                <div>Inferred Type: <strong>${inferredType}</strong></div>\n            `;\n        });\n\n        document.getElementById('perform-operation').addEventListener('click', function() {\n            const type1 = document.getElementById('type-op1').value;\n            const type2 = document.getElementById('type-op2').value;\n            const operation = document.getElementById('type-operation').value;\n            \n            if (!type1 || !type2) {\n                document.getElementById('operation-result').innerHTML = `<div class=\"error\">Please select both types</div>`;\n                return;\n            }\n            \n            let result;\n            if (operation === 'assignable') {\n                // Simplified check - in real system this would be more complex\n                result = type1 === type2 ? `${type1} is assignable to ${type2}` \n                                         : `${type1} is NOT assignable to ${type2}`;\n            }\n            else if (operation === 'union') {\n                result = `${type1} | ${type2}`;\n            }\n            else if (operation === 'intersection') {\n                result = `${type1} & ${type2}`;\n            }\n            else if (operation === 'extends') {\n                // Simplified check\n                result = type1 === type2 ? `${type1} extends ${type2}` \n                                         : `${type1} does not extend ${type2}`;\n            }\n            \n            document.getElementById('operation-result').innerHTML = `\n                <div>Operation: ${operation}</div>\n                <div>Type 1: ${type1}</div>\n                <div>Type 2: ${type2}</div>\n                <div>Result: <strong>${result}</strong></div>\n            `;\n        });\n\n        document.getElementById('add-param').addEventListener('click', function() {\n            const container = document.getElementById('function-params');\n            const div = document.createElement('div');\n            div.className = 'row';\n            div.innerHTML = `\n                <input type=\"text\" placeholder=\"param name\" class=\"param-name\">\n                <select class=\"param-type\">\n                    <option>number</option>\n                    <option>string</option>\n                    <option>boolean</option>\n                </select>\n                <button class=\"remove-param\">×</button>\n            `;\n            container.appendChild(div);\n            div.querySelector('.remove-param').addEventListener('click', function() {\n                container.removeChild(div);\n            });\n        });\n\n        document.getElementById('add-generic-param').addEventListener('click', function() {\n            const param = document.getElementById('generic-param').value.trim();\n            if (!param) return;\n            \n            const container = document.getElementById('generic-params-list');\n            const span = document.createElement('span');\n            span.className = 'generic-param';\n            span.textContent = param;\n            container.appendChild(span);\n            document.getElementById('generic-param').value = '';\n        });\n\n        document.querySelectorAll('.type-example').forEach(el => {\n            el.addEventListener('click', function() {\n                const type = this.getAttribute('data-type');\n                let details = '';\n                \n                if (type === 'number') details = 'Primitive numeric type. Examples: 42, 3.14, -1';\n                else if (type === 'string') details = 'Primitive string type. Examples: \"hello\", \\'world\\', `template`';\n                else if (type === 'boolean') details = 'Primitive boolean type. Values: true or false';\n                else if (type === 'array') details = 'Composite type representing an array of values. Example: number[] for array of numbers';\n                else if (type === 'object') details = 'Composite type representing an object with specific properties';\n                else if (type === 'tuple') details = 'Fixed-length array with specific types at each position';\n                else if (type === 'union') details = 'Type that can be one of several types';\n                else if (type === 'function') details = 'Function type with parameter types and return type';\n                else if (type === 'generic') details = 'Type that can work with multiple types using type parameters';\n                \n                document.getElementById('example-details').innerHTML = `\n                    <h3>${type}</h3>\n                    <p>${details}</p>\n                    <p>Example: <code>${this.textContent}</code></p>\n                `;\n            });\n        });\n\n        // Initialize\n        typeSystem.updateUI();\n    </script>\n</body>\n</html>"
  },
