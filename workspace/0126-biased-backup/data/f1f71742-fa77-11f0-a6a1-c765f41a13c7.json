    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Time Complexity — Visual Exploration</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #071029;\n      --bg-2: #0f1b2b;\n      --glass: rgba(255,255,255,0.06);\n      --muted: rgba(255,255,255,0.65);\n      --accent: #6ef0ff;\n      --accent-2: #a38bff;\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,var(--bg-1),var(--bg-2));font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    .stage{\n      min-height:100vh;\n      padding:48px;\n      display:flex;\n      gap:32px;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n      overflow:hidden;\n    }\n\n    /* Background decorative blobs */\n    .blob{\n      position:absolute;\n      filter: blur(60px) saturate(120%);\n      opacity:0.24;\n      transform-origin:center;\n      mix-blend-mode:screen;\n      pointer-events:none;\n      will-change:transform;\n    }\n    .blob.a{width:520px;height:520px;background:radial-gradient(circle at 30% 30%, #6ef0ff, transparent 40%), radial-gradient(circle at 70% 70%, #a38bff, transparent 30%); right:-120px; top:-80px; animation: floatA 18s ease-in-out infinite;}\n    .blob.b{width:420px;height:420px;background:radial-gradient(circle at 20% 70%, #ff9db7, transparent 30%), radial-gradient(circle at 80% 30%, #7ee7c7, transparent 30%); left:-120px; bottom:-140px; animation: floatB 22s ease-in-out infinite;}\n\n    @keyframes floatA {0%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-18px) rotate(12deg)}100%{transform:translateY(0) rotate(0deg)}}\n    @keyframes floatB {0%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(22px) rotate(-9deg)}100%{transform:translateY(0) rotate(0deg)}}\n\n    /* Glass card on left */\n    .card{\n      width:360px;\n      max-width:40%;\n      min-width:260px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);\n      border-radius:20px;\n      padding:28px;\n      color:var(--muted);\n      backdrop-filter: blur(8px) saturate(120%);\n      box-shadow: 0 8px 30px rgba(3,6,23,0.6);\n      position:relative;\n      z-index:10;\n      transition:transform 0.6s cubic-bezier(.2,.9,.2,1);\n    }\n\n    .title{\n      display:flex;\n      align-items:baseline;\n      gap:12px;\n    }\n    .title h1{\n      font-family: 'Playfair Display', serif;\n      font-weight:600;\n      color:#fff;\n      margin:0;\n      font-size:28px;\n      letter-spacing:-0.02em;\n    }\n    .subtitle{\n      margin-top:8px;\n      font-size:13px;\n      color:rgba(255,255,255,0.75);\n    }\n    .desc{\n      margin-top:18px;\n      color:rgba(255,255,255,0.6);\n      line-height:1.45;\n      font-size:14px;\n    }\n\n    .controls{\n      margin-top:20px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn{\n      background:linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n      border:1px solid rgba(255,255,255,0.06);\n      color:#fff;\n      padding:10px 14px;\n      border-radius:12px;\n      font-weight:600;\n      font-size:13px;\n      cursor:pointer;\n      transition:transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n      box-shadow:0 6px 18px rgba(3,6,23,0.45);\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n    }\n    .btn:active{transform:translateY(1px) scale(.998)}\n    .btn.secondary{background:transparent;border:1px solid rgba(255,255,255,0.06); color:var(--muted); font-weight:600; box-shadow:none;}\n    .btn .dot{\n      width:9px;height:9px;border-radius:50%;\n      background:linear-gradient(90deg,var(--accent),var(--accent-2));\n      box-shadow:0 6px 18px rgba(98,139,255,0.18), 0 0 24px rgba(162,139,255,0.09) inset;\n    }\n\n    .meta{\n      margin-top:18px;\n      font-size:12px;\n      color:rgba(255,255,255,0.45);\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n\n    /* Visualization area */\n    .visual{\n      flex:1;\n      height:620px;\n      min-height:420px;\n      border-radius:22px;\n      position:relative;\n      overflow:hidden;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:28px;\n      backdrop-filter: blur(4px);\n      z-index:5;\n    }\n\n    .panel{\n      width:100%;\n      height:100%;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:18px;\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 12px 40px rgba(2,6,20,0.6);\n      position:relative;\n      overflow:hidden;\n      padding:28px;\n    }\n\n    /* Graph area */\n    .graph-wrap{\n      width:100%;\n      height:100%;\n      position:relative;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n    .graph-top{\n      display:flex;\n      justify-content:space-between;\n      align-items:center;\n      color:rgba(255,255,255,0.75);\n      font-size:13px;\n      margin-bottom:6px;\n      padding:0 6px;\n    }\n    .graph-title{\n      display:flex;\n      align-items:center;\n      gap:12px;\n    }\n    .graph-title h2{\n      margin:0;\n      font-size:16px;\n      color:white;\n      font-weight:600;\n      letter-spacing:-0.01em;\n    }\n    .graph-caps{\n      color:rgba(255,255,255,0.45);\n      font-size:12px;\n    }\n\n    /* svg container */\n    .graph{\n      width:100%;\n      flex:1;\n      position:relative;\n    }\n    svg{width:100%;height:100%;display:block}\n\n    /* grid lines */\n    .grid-line{stroke:rgba(255,255,255,0.03); stroke-width:1}\n    .axis{stroke:rgba(255,255,255,0.06); stroke-width:1.5}\n\n    /* function strokes */\n    .curve{fill:none;stroke-linecap:round;stroke-linejoin:round;stroke-width:3.5;mix-blend-mode:screen}\n    .curve.constant{stroke:rgba(255,255,255,0.18);stroke-dasharray:8 10}\n    .curve.log{stroke:#6ef0ff;filter:drop-shadow(0 6px 22px rgba(110,240,255,0.06))}\n    .curve.linear{stroke:#7ee7c7;filter:drop-shadow(0 10px 30px rgba(126,231,199,0.04))}\n    .curve.nlogn{stroke:#ffd76b;filter:drop-shadow(0 10px 30px rgba(255,215,107,0.06))}\n    .curve.quad{stroke:#ff9db7;filter:drop-shadow(0 10px 30px rgba(255,157,183,0.06))}\n    .curve.exp{stroke:#a38bff;filter:drop-shadow(0 10px 30px rgba(163,139,255,0.08))}\n\n    /* markers */\n    .marker{fill:#fff; r:5; transform-origin:center; transition:transform .18s cubic-bezier(.2,.9,.2,1)}\n    .marker.glow{fill:transparent; stroke-width:0; filter:blur(6px); opacity:0.2}\n\n    /* label tags */\n    .labels{\n      position:absolute;\n      right:20px;\n      bottom:18px;\n      display:flex;\n      flex-direction:column;\n      gap:10px;\n      z-index:15;\n      transition:opacity .35s ease, transform .35s cubic-bezier(.2,.9,.2,1);\n      opacity:0; transform:translateY(12px);\n      pointer-events:none;\n    }\n    .show-labels .labels{opacity:1; transform:translateY(0)}\n    .label-pill{\n      display:flex;\n      align-items:center;\n      gap:10px;\n      padding:8px 12px;\n      border-radius:999px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      color:rgba(255,255,255,0.92);\n      font-weight:600;\n      font-size:13px;\n      backdrop-filter: blur(6px);\n      box-shadow: 0 6px 18px rgba(3,6,23,0.45);\n      white-space:nowrap;\n    }\n    .swatch{\n      width:10px;height:10px;border-radius:50%;\n      box-shadow:0 6px 14px rgba(0,0,0,0.32) inset;\n    }\n\n    /* tiny footer note */\n    .foot{\n      position:absolute;\n      left:26px; bottom:18px;\n      font-size:12px;color:rgba(255,255,255,0.35);\n    }\n\n    /* responsive */\n    @media (max-width:980px){\n      .stage{padding:22px;flex-direction:column;gap:18px}\n      .card{width:100%;max-width:unset}\n      .visual{width:100%}\n      .labels{right:12px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"stage\" id=\"stage\">\n    <div class=\"blob a\" aria-hidden=\"true\"></div>\n    <div class=\"blob b\" aria-hidden=\"true\"></div>\n\n    <div class=\"card\" role=\"region\" aria-label=\"Introduction\">\n      <div class=\"title\">\n        <h1>Time Complexity</h1>\n        <div style=\"color:var(--accent);font-weight:700;font-size:12px;background:rgba(110,240,255,0.06);padding:6px 10px;border-radius:10px\">Visual Guide</div>\n      </div>\n      <div class=\"subtitle\">How algorithm cost grows with input size (n)</div>\n      <div class=\"desc\">\n        This visualization paints common complexity families — constant, logarithmic, linear, n·log n, quadratic and exponential — across increasing input sizes. Watch how they diverge as n grows. Labels reveal intuitive names and colors.\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"toggle\" class=\"btn\" title=\"Play / Pause the animation\" aria-pressed=\"true\">\n          <span class=\"dot\"></span>\n          <span id=\"toggleLabel\">Pause</span>\n        </button>\n        <button id=\"labelsBtn\" class=\"btn secondary\" title=\"Toggle labels\">Show labels</button>\n      </div>\n\n      <div class=\"meta\">\n        <div>Smooth animated traces</div>\n        <div style=\"opacity:.6\">•</div>\n        <div>Compressed scale for clarity</div>\n      </div>\n    </div>\n\n    <div class=\"visual\">\n      <div class=\"panel\" id=\"panel\">\n        <div class=\"graph-wrap\" id=\"graphWrap\">\n          <div class=\"graph-top\">\n            <div class=\"graph-title\">\n              <h2>Growth curves</h2>\n              <div class=\"graph-caps\">n → input size · vertical scale is logarithmically compressed</div>\n            </div>\n            <div style=\"color:rgba(255,255,255,0.45);font-size:12px\">n ∈ [1, 200]</div>\n          </div>\n\n          <div class=\"graph\" id=\"graphArea\" aria-hidden=\"false\">\n            <svg id=\"svg\" viewBox=\"0 0 960 560\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Graph illustrating growth curves\">\n              <defs>\n                <linearGradient id=\"g1\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"0\">\n                  <stop offset=\"0\" stop-color=\"#6ef0ff\"></stop>\n                  <stop offset=\"1\" stop-color=\"#a38bff\"></stop>\n                </linearGradient>\n                <linearGradient id=\"g2\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"0\">\n                  <stop offset=\"0\" stop-color=\"#7ee7c7\"></stop>\n                  <stop offset=\"1\" stop-color=\"#6ef0ff\"></stop>\n                </linearGradient>\n                <linearGradient id=\"g3\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"0\">\n                  <stop offset=\"0\" stop-color=\"#ffd76b\"></stop>\n                  <stop offset=\"1\" stop-color=\"#ff9db7\"></stop>\n                </linearGradient>\n                <filter id=\"soft\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                  <feGaussianBlur stdDeviation=\"8\" result=\"b\"/>\n                  <feBlend in=\"SourceGraphic\" in2=\"b\" mode=\"screen\"/>\n                </filter>\n              </defs>\n\n              <!-- background grid -->\n              <g id=\"grid\">\n                <!-- vertical guide to anchor visual -->\n                <rect x=\"48\" y=\"32\" width=\"864\" height=\"496\" rx=\"12\" ry=\"12\" fill=\"transparent\" stroke=\"rgba(255,255,255,0.02)\"></rect>\n              </g>\n\n              <!-- axis -->\n              <g id=\"axes\" transform=\"translate(48,32)\">\n                <line class=\"axis\" x1=\"0\" y1=\"496\" x2=\"864\" y2=\"496\"></line>\n                <line class=\"axis\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"496\"></line>\n              </g>\n\n              <!-- plots group -->\n              <g id=\"plots\" transform=\"translate(48,32)\"></g>\n\n              <!-- markers group -->\n              <g id=\"markers\" transform=\"translate(48,32)\"></g>\n\n            </svg>\n\n            <div class=\"labels\" id=\"labelsRegion\" aria-hidden=\"true\">\n              <div class=\"label-pill\"><span class=\"swatch\" style=\"background:#ffffff33\"></span> O(1) constant</div>\n              <div class=\"label-pill\"><span class=\"swatch\" style=\"background:#6ef0ff\"></span> O(log n)</div>\n              <div class=\"label-pill\"><span class=\"swatch\" style=\"background:#7ee7c7\"></span> O(n)</div>\n              <div class=\"label-pill\"><span class=\"swatch\" style=\"background:#ffd76b\"></span> O(n log n)</div>\n              <div class=\"label-pill\"><span class=\"swatch\" style=\"background:#ff9db7\"></span> O(n²)</div>\n              <div class=\"label-pill\"><span class=\"swatch\" style=\"background:#a38bff\"></span> O(2ⁿ)</div>\n            </div>\n\n            <div class=\"foot\">Aesthetic visualization — for conceptual intuition, not precise benchmarks.</div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  const svg = document.getElementById('svg');\n  const plots = document.getElementById('plots');\n  const markersGroup = document.getElementById('markers');\n  const labelsBtn = document.getElementById('labelsBtn');\n  const toggleBtn = document.getElementById('toggle');\n  const toggleLabel = document.getElementById('toggleLabel');\n  const panel = document.getElementById('panel');\n  const stage = document.getElementById('stage');\n\n  let playing = true;\n  let showLabels = false;\n\n  // Parameters\n  const margin = {left:0, top:0};\n  const W = 864;\n  const H = 496;\n  const samples = 320;\n  const nMax = 200;\n\n  // Complexity functions (return raw values)\n  const families = [\n    {id:'constant', name:'O(1)', color:'#ffffff66', func: n => 1},\n    {id:'log', name:'O(log n)', color:'#6ef0ff', func: n => Math.log2(n + 1)},\n    {id:'linear', name:'O(n)', color:'#7ee7c7', func: n => n},\n    {id:'nlogn', name:'O(n log n)', color:'#ffd76b', func: n => n * Math.log2(n + 1)},\n    {id:'quad', name:'O(n²)', color:'#ff9db7', func: n => n * n},\n    // exponential scaled down to avoid numerical extremes: 2^(n/20)\n    {id:'exp', name:'O(2ⁿ)', color:'#a38bff', func: n => Math.pow(2, n / 20)}\n  ];\n\n  // compute sampled points, normalize with log compression\n  function sampleCurves(width, height){\n    const xs = [];\n    const allValues = [];\n    const pointsPerFam = [];\n\n    // sample n values exponentially spaced for more information in small n\n    const ns = [];\n    for (let i=0;i<samples;i++){\n      // smooth spacing bias toward small n\n      const t = i/(samples-1);\n      ns.push(1 + (Math.pow(t,1.2))*(nMax-1));\n    }\n\n    // compute raw values\n    families.forEach(f=>{\n      const vals = ns.map(n => Math.max(0, f.func(n)));\n      pointsPerFam.push(vals);\n      allValues.push(...vals);\n    });\n\n    // compression: use log scaling to keep differences visible\n    const maxVal = Math.max(1, ...allValues);\n    const denom = Math.log(1 + maxVal);\n\n    const curves = families.map((f,fi)=>{\n      const vals = pointsPerFam[fi];\n      const pts = vals.map((v,i)=>{\n        const t = i/(samples-1);\n        const x = Math.round(0 + t*(width));\n        const scaled = Math.log(1 + v) / denom; // 0..1\n        const y = Math.round(height - (scaled * height)); // invert for svg coords\n        return [x, y];\n      });\n      return {id:f.id, name:f.name, color:f.color, pts};\n    });\n\n    return curves;\n  }\n\n  // create smooth path from points (cubic smoothing)\n  function smoothPath(pts){\n    if (pts.length < 2) return '';\n    let d = `M ${pts[0][0]} ${pts[0][1]}`;\n    for (let i=1;i<pts.length;i++){\n      const prev = pts[i-1];\n      const cur = pts[i];\n      const midX = (prev[0] + cur[0]) / 2;\n      const midY = (prev[1] + cur[1]) / 2;\n      d += ` Q ${prev[0]} ${prev[1]} ${midX} ${midY}`;\n    }\n    // line to last\n    const last = pts[pts.length-1];\n    d += ` T ${last[0]} ${last[1]}`;\n    return d;\n  }\n\n  // render svg elements\n  let pathElements = [];\n  let markerElements = [];\n  function render(){\n    // clear\n    plots.innerHTML = '';\n    markersGroup.innerHTML = '';\n    pathElements = [];\n    markerElements = [];\n\n    const svgW = W;\n    const svgH = H;\n    // draw subtle horizontal grid lines\n    const gridGroup = document.createElementNS('http://www.w3.org/2000/svg','g');\n    gridGroup.setAttribute('transform','translate(0,0)');\n    for (let i=0;i<=6;i++){\n      const y = Math.round((svgH/6)*i);\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1',0);\n      line.setAttribute('x2',svgW);\n      line.setAttribute('y1',y);\n      line.setAttribute('y2',y);\n      line.setAttribute('class','grid-line');\n      line.style.opacity = (i%3===0)?0.045:0.025;\n      gridGroup.appendChild(line);\n    }\n    plots.appendChild(gridGroup);\n\n    // compute curves\n    const curves = sampleCurves(svgW, svgH);\n\n    // create defs for glow strokes\n    const defs = document.createElementNS('http://www.w3.org/2000/svg','defs');\n    // add small gradient\n    const grad = document.querySelector('#g1').cloneNode(true);\n    grad.id = 'g1-dup';\n    defs.appendChild(grad);\n    plots.appendChild(defs);\n\n    // draw each curve\n    curves.forEach((c, idx)=>{\n      const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n      const d = smoothPath(c.pts);\n      path.setAttribute('d', d);\n      path.setAttribute('class', `curve ${c.id}`);\n      path.style.stroke = c.color;\n      path.style.opacity = 0.96;\n      path.style.strokeWidth = (c.id==='constant'?2.5:3.5);\n      path.style.filter = 'url(#soft)';\n      path.style.vectorEffect = 'non-scaling-stroke';\n      // give it a faint dash shimmer by default\n      path.style.strokeDasharray = 0;\n      plots.appendChild(path);\n      pathElements.push(path);\n\n      // marker group for this curve\n      const mGroup = document.createElementNS('http://www.w3.org/2000/svg','g');\n      mGroup.setAttribute('class','marker-group');\n      // small glow circle\n      const glow = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      glow.setAttribute('class','marker glow');\n      glow.setAttribute('r', 9);\n      glow.style.fill = c.color;\n      glow.style.opacity = 0.16;\n      mGroup.appendChild(glow);\n\n      // solid marker\n      const mark = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      mark.setAttribute('class','marker');\n      mark.setAttribute('r', 4.6);\n      mark.style.fill = '#fff';\n      mark.style.stroke = c.color;\n      mark.style.strokeWidth = 1.6;\n      mark.style.opacity = 0.98;\n      mGroup.appendChild(mark);\n\n      // label near marker (appears when labels toggle)\n      const tag = document.createElementNS('http://www.w3.org/2000/svg','text');\n      tag.setAttribute('class','tag');\n      tag.setAttribute('x', 0);\n      tag.setAttribute('y', 0);\n      tag.setAttribute('font-size','12');\n      tag.setAttribute('fill','#ffffffee');\n      tag.setAttribute('font-weight','600');\n      tag.style.pointerEvents = 'none';\n      tag.style.opacity = 0;\n      tag.style.transition = 'opacity 0.28s, transform 0.28s';\n      tag.textContent = families[idx].name;\n      mGroup.appendChild(tag);\n\n      markersGroup.appendChild(mGroup);\n      markerElements.push({group:mGroup, glow, mark, tag, path});\n    });\n\n    // subtle axis label text on svg (n arrow)\n    const nx = document.createElementNS('http://www.w3.org/2000/svg','text');\n    nx.setAttribute('x', svgW - 6);\n    nx.setAttribute('y', svgH + 18);\n    nx.setAttribute('font-size','11');\n    nx.setAttribute('fill','rgba(255,255,255,0.45)');\n    nx.setAttribute('text-anchor','end');\n    nx.textContent = 'n →';\n    plots.appendChild(nx);\n\n    // small vertical scale label (top)\n    const ylab = document.createElementNS('http://www.w3.org/2000/svg','text');\n    ylab.setAttribute('x', -6);\n    ylab.setAttribute('y', -8);\n    ylab.setAttribute('font-size','11');\n    ylab.setAttribute('fill','rgba(255,255,255,0.45)');\n    ylab.setAttribute('text-anchor','end');\n    ylab.textContent = 'cost';\n    ylab.setAttribute('transform','rotate(-90 -6 -8)');\n    plots.appendChild(ylab);\n\n    // progressive stroke dash for shimmer effect\n    pathElements.forEach((p, i)=>{\n      const len = p.getTotalLength();\n      p.style.strokeDasharray = Math.max(10, len / 6) + ' ' + (len);\n      p.style.strokeDashoffset = len;\n    });\n  }\n\n  // Animation loop\n  let progress = 0;\n  let lastTime = performance.now();\n  const duration = 7000; // ms for a full sweep\n  function animate(now){\n    if (!playing) { lastTime = now; requestAnimationFrame(animate); return; }\n    const dt = now - lastTime;\n    lastTime = now;\n    progress += dt / duration;\n    if (progress > 1) progress = progress - Math.floor(progress);\n\n    // update markers and strokes\n    markerElements.forEach((m, idx)=>{\n      const path = markerElements[idx].path || m.path;\n      const total = path.getTotalLength();\n      const tLen = Math.max(1, total * progress);\n      const pt = path.getPointAtLength(tLen);\n      // position group\n      m.group.setAttribute('transform', `translate(${pt.x},${pt.y})`);\n      // subtle marker animation scale by family index\n      const r = 4.6 + 1.2*Math.sin((progress*2*Math.PI) + idx);\n      m.mark.setAttribute('r', r);\n      m.glow.setAttribute('r', r*2.6);\n      // update label position offset\n      m.tag.setAttribute('x', 12);\n      m.tag.setAttribute('y', -6 - (idx%2===0?0:4));\n      m.tag.style.opacity = showLabels ? 1 : 0;\n      m.tag.style.transform = showLabels ? 'translateX(0)' : 'translateX(6px)';\n\n      // animate stroke dashoffset to create a left-to-right shimmer\n      const len = total;\n      const dash = Math.max(8, len/6);\n      const newOffset = (len - (progress*len)) % (len+1);\n      path.style.strokeDashoffset = newOffset;\n    });\n\n    requestAnimationFrame(animate);\n  }\n\n  // initial render\n  render();\n  requestAnimationFrame(animate);\n\n  // toggles\n  toggleBtn.addEventListener('click', ()=>{\n    playing = !playing;\n    toggleLabel.textContent = playing ? 'Pause' : 'Play';\n    toggleBtn.setAttribute('aria-pressed', playing ? 'true' : 'false');\n    toggleBtn.querySelector('.dot').style.opacity = playing ? 1 : 0.3;\n  });\n\n  labelsBtn.addEventListener('click', ()=>{\n    showLabels = !showLabels;\n    stage.classList.toggle('show-labels', showLabels);\n    labelsBtn.textContent = showLabels ? 'Hide labels' : 'Show labels';\n    labelsBtn.setAttribute('aria-pressed', showLabels ? 'true' : 'false');\n    // toggle svg text labels\n    markerElements.forEach(m=>{\n      m.tag.style.opacity = showLabels ? 1 : 0;\n    });\n    // also reveal right legend region\n    const labelsRegion = document.getElementById('labelsRegion');\n    labelsRegion.style.opacity = showLabels ? 1 : 0;\n    labelsRegion.style.transform = showLabels ? 'translateY(0)' : 'translateY(12px)';\n  });\n\n  // Responsive: rebuild curves on window resize to adapt sample points\n  let resizeTimer = null;\n  window.addEventListener('resize', ()=>{\n    clearTimeout(resizeTimer);\n    resizeTimer = setTimeout(()=>{\n      // re-render using same svg viewBox dims\n      render();\n    }, 180);\n  });\n\n  // Gentle entrance animations\n  window.setTimeout(()=>{ document.querySelectorAll('.card')[0].style.transform = 'translateY(-4px)'} , 300);\n  window.setTimeout(()=>{ document.querySelectorAll('.panel')[0].style.transform = 'scale(1)' } , 400);\n\n  // Minor: pause animation when tab is not visible\n  document.addEventListener('visibilitychange', ()=>{\n    if (document.hidden){\n      playing = false;\n      toggleLabel.textContent = 'Play';\n    }\n  });\n\n})();\n</script>\n\n</body>\n</html>"
