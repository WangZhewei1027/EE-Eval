    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Indexing Interactive Explorer</title>\n<style>\n  /* Extremely minimal styling */\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    background: white;\n    color: black;\n  }\n  textarea, input, select, button {\n    font-family: monospace, monospace;\n    font-size: 14px;\n    margin: 2px 0;\n    padding: 2px 4px;\n    width: 100%;\n    box-sizing: border-box;\n  }\n  label {\n    display: block;\n    margin-top: 10px;\n    font-weight: normal;\n  }\n  #output {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    height: 150px;\n    overflow: auto;\n    padding: 4px;\n    margin-top: 8px;\n  }\n  #indexTable {\n    margin-top: 8px;\n    border-collapse: collapse;\n    width: 100%;\n  }\n  #indexTable th, #indexTable td {\n    border: 1px solid black;\n    padding: 2px 4px;\n    text-align: left;\n  }\n  #pathsLog {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    height: 150px;\n    overflow: auto;\n    margin-top: 8px;\n    padding: 4px;\n  }\n  #controls > * {\n    margin-top: 8px;\n  }\n</style>\n</head>\n<body>\n<h2>Indexing Interactive Explorer</h2>\n\n<label for=\"textInput\">Enter or paste text to index:</label>\n<textarea id=\"textInput\" rows=\"8\" placeholder=\"Type or paste any text here...\"></textarea>\n\n<div id=\"controls\">\n  <label for=\"indexType\">Select index type:</label>\n  <select id=\"indexType\">\n    <option value=\"word\">Word Index (case-insensitive)</option>\n    <option value=\"char\">Character Index (case-sensitive)</option>\n    <option value=\"phrase\">Phrase Index (custom phrase)</option>\n    <option value=\"regex\">Regex Index</option>\n  </select>\n\n  <div id=\"phraseControl\" style=\"display:none;\">\n    <label for=\"phraseInput\">Enter phrase to index (for Phrase Index):</label>\n    <input type=\"text\" id=\"phraseInput\" placeholder=\"e.g. data structures\" />\n  </div>\n\n  <div id=\"regexControl\" style=\"display:none;\">\n    <label for=\"regexInput\">Enter regular expression pattern:</label>\n    <input type=\"text\" id=\"regexInput\" placeholder=\"e.g. \\b\\w{4}\\b\" />\n    <label><input type=\"checkbox\" id=\"regexFlags_i\" /> Ignore case (i)</label>\n    <label><input type=\"checkbox\" id=\"regexFlags_g\" checked disabled /> Global (g, required)</label>\n    <label><input type=\"checkbox\" id=\"regexFlags_m\" /> Multiline (m)</label>\n  </div>\n\n  <label for=\"minLength\">Minimum length to index (for words/phrase):</label>\n  <input type=\"number\" id=\"minLength\" value=\"1\" min=\"1\" max=\"100\" />\n\n  <button id=\"buildIndex\">Build Index</button>\n  <button id=\"clearIndex\">Clear Index</button>\n</div>\n\n<h3>Index Summary</h3>\n<div id=\"summary\">No index built yet.</div>\n\n<h3>Indexed Items</h3>\n<table id=\"indexTable\">\n  <thead>\n    <tr><th>Item</th><th>Occurrences</th><th>Positions (0-based)</th></tr>\n  </thead>\n  <tbody></tbody>\n</table>\n\n<h3>Search Indexed Items</h3>\n<label for=\"searchInput\">Search indexed items (substring match):</label>\n<input type=\"text\" id=\"searchInput\" placeholder=\"Enter substring to filter items\" />\n<label for=\"caseSensitive\">Case sensitive:</label>\n<input type=\"checkbox\" id=\"caseSensitive\" />\n<button id=\"searchButton\">Search</button>\n\n<h3>Search Results</h3>\n<div id=\"searchResults\">No search done.</div>\n\n<h3>Position Explorer</h3>\n<p>\n  Enter a position (number) in the text to explore what indexed items appear at or near that position.\n</p>\n<label for=\"positionInput\">Position (0-based):</label>\n<input type=\"number\" id=\"positionInput\" min=\"0\" />\n<label for=\"contextRadius\">Context radius (characters before and after):</label>\n<input type=\"number\" id=\"contextRadius\" value=\"5\" min=\"0\" max=\"50\" />\n<button id=\"explorePosition\">Explore</button>\n<div id=\"positionOutput\">No position explored yet.</div>\n\n<h3>Indexing Workflow Log</h3>\n<div id=\"pathsLog\">(No interactions yet.)</div>\n\n<script>\n(() => {\n  const textInput = document.getElementById('textInput');\n  const indexType = document.getElementById('indexType');\n  const phraseControl = document.getElementById('phraseControl');\n  const phraseInput = document.getElementById('phraseInput');\n  const regexControl = document.getElementById('regexControl');\n  const regexInput = document.getElementById('regexInput');\n  const regexFlags_i = document.getElementById('regexFlags_i');\n  const regexFlags_g = document.getElementById('regexFlags_g');\n  const regexFlags_m = document.getElementById('regexFlags_m');\n  const minLength = document.getElementById('minLength');\n  const buildIndex = document.getElementById('buildIndex');\n  const clearIndex = document.getElementById('clearIndex');\n  const summary = document.getElementById('summary');\n  const indexTableBody = document.querySelector('#indexTable tbody');\n  const searchInput = document.getElementById('searchInput');\n  const searchButton = document.getElementById('searchButton');\n  const caseSensitiveCheckbox = document.getElementById('caseSensitive');\n  const searchResults = document.getElementById('searchResults');\n  const positionInput = document.getElementById('positionInput');\n  const contextRadius = document.getElementById('contextRadius');\n  const explorePositionBtn = document.getElementById('explorePosition');\n  const positionOutput = document.getElementById('positionOutput');\n  const pathsLog = document.getElementById('pathsLog');\n\n  // State management\n  let indexedData = null; \n  // Structure: { type:..., items: Map(item -> {count, positions: [pos]}), textLength: number }\n\n  // Workflow interaction log (tracks sequential user actions)\n  let interactionLog = [];\n\n  function logInteraction(action, details) {\n    const time = new Date().toISOString();\n    interactionLog.push({time, action, details});\n    updatePathsLog();\n  }\n  function updatePathsLog() {\n    const lines = interactionLog.map(({time,action,details},i) =>\n      `${i+1}. [${time}] ${action}${details ? \": \"+details : \"\"}`\n    );\n    if(lines.length === 0) {\n      pathsLog.textContent = \"(No interactions yet.)\";\n    } else {\n      pathsLog.textContent = lines.join('\\n');\n      pathsLog.scrollTop = pathsLog.scrollHeight;\n    }\n  }\n\n  // Show/hide controls based on index type\n  function onIndexTypeChange() {\n    const val = indexType.value;\n    phraseControl.style.display = 'none';\n    regexControl.style.display = 'none';\n    if(val === 'phrase') {\n      phraseControl.style.display = 'block';\n    } else if(val === 'regex') {\n      regexControl.style.display = 'block';\n    }\n  }\n\n  indexType.addEventListener('change', () => {\n    onIndexTypeChange();\n    logInteraction('Changed index type', indexType.value);\n  });\n\n  onIndexTypeChange();\n\n  // Clear index and related UI\n  function clearAll() {\n    indexedData = null;\n    summary.textContent = 'No index built yet.';\n    indexTableBody.textContent = '';\n    searchResults.textContent = 'No search done.';\n    positionOutput.textContent = 'No position explored yet.';\n    searchInput.value = '';\n    positionInput.value = '';\n    minLength.value = 1;\n    phraseInput.value = '';\n    regexInput.value = '';\n    regexFlags_i.checked = false;\n    regexFlags_m.checked = false;\n    // leave caseSensitive as is\n  }\n  clearIndex.addEventListener('click', () => {\n    clearAll();\n    logInteraction('Cleared all index and inputs');\n  });\n\n  // Utility: escape RegExp special characters for literal substring search\n  function escapeRegex(string) {\n    return string.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n  }\n\n  // Build index according to indexType\n  function buildIndexData() {\n    const text = textInput.value;\n    const type = indexType.value;\n    const minLen = Math.max(1, Math.floor(Number(minLength.value) || 1));\n    if (!text) {\n      alert('Input text is empty. Please enter some text.');\n      return null;\n    }\n\n    // Prepare variables\n    let items = new Map();\n    const textLength = text.length;\n\n    function addItem(item, position) {\n      if(item.length < minLen) return;\n      // Case normalization for word index only\n      let key = item;\n      if(type === 'word') key = item.toLowerCase();\n\n      if (!items.has(key)) {\n        items.set(key, {count:0, positions:[]});\n      }\n      const d = items.get(key);\n      d.count++;\n      d.positions.push(position);\n    }\n\n    if(type === 'word') {\n      // Word index is case-insensitive, tokenize by /\\b\\w+\\b/\n      // We record start positions of each word\n      const wordRegex = /\\b\\w+\\b/g;\n      let match;\n      while ((match = wordRegex.exec(text)) !== null) {\n        const word = match[0];\n        const pos = match.index;\n        addItem(word, pos);\n      }\n    } else if(type === 'char') {\n      // Character index case-sensitive, index every non-whitespace char and position\n      for(let i=0; i<text.length; i++) {\n        const c = text[i];\n        if(/\\s/.test(c)) continue;\n        addItem(c, i);\n      }\n    } else if(type === 'phrase') {\n      // Phrase index: find all occurrences of phrase in text (case-sensitive exact)\n      const phrase = phraseInput.value;\n      if(!phrase) {\n        alert('Please enter a phrase for Phrase Index.');\n        return null;\n      }\n      if(phrase.length < minLen) {\n        alert('Phrase length is less than minimum length.');\n        return null;\n      }\n      // Find all occurrences of phrase\n      let startAt = 0;\n      while(true) {\n        const pos = text.indexOf(phrase, startAt);\n        if(pos === -1) break;\n        addItem(phrase, pos);\n        startAt = pos+1;\n      }\n    } else if(type === 'regex') {\n      // Regex index, global match all occurrences' index 0 position and matched text\n      let flags = 'g';\n      if(regexFlags_i.checked) flags += 'i';\n      if(regexFlags_m.checked) flags += 'm';\n      let pattern = regexInput.value;\n      if(!pattern) {\n        alert('Please enter a regex pattern.');\n        return null;\n      }\n      let regex;\n      try {\n        regex = new RegExp(pattern, flags);\n      } catch(e) {\n        alert('Invalid regex pattern: ' + e.message);\n        return null;\n      }\n      let match;\n      while((match = regex.exec(text)) !== null) {\n        if(match[0].length < minLen) continue;\n        addItem(match[0], match.index);\n        if(match[0].length === 0) {\n          // Avoid empty match infinite loop\n          regex.lastIndex++;\n        }\n      }\n    } else {\n      alert('Unknown index type selected.');\n      return null;\n    }\n    if(items.size === 0) {\n      alert('No items found indexed with current parameters.');\n    }\n    return {type, items, textLength};\n  }\n\n  // Sort the items by count desc, then lex ascending\n  function sortedIndexedItems() {\n    if(!indexedData) return [];\n    return Array.from(indexedData.items.entries()).sort((a,b) => {\n      if(b[1].count !== a[1].count) return b[1].count - a[1].count;\n      return a[0] < b[0] ? -1 : (a[0] > b[0]?1:0);\n    });\n  }\n\n  function updateIndexTable() {\n    if(!indexedData) {\n      indexTableBody.textContent = '';\n      return;\n    }\n    const rows = [];\n    for(let [item,data] of sortedIndexedItems()) {\n      rows.push('<tr><td>' + escapeHtml(item) + '</td><td>' + data.count + '</td><td>' + data.positions.join(', ') + '</td></tr>');\n    }\n    indexTableBody.innerHTML = rows.join('\\n');\n  }\n\n  function escapeHtml(text) {\n    return text.replace(/[&<>\"']/g, c => {\n      switch(c) {\n        case '&': return '&amp;';\n        case '<': return '&lt;';\n        case '>': return '&gt;';\n        case '\"': return '&quot;';\n        case \"'\": return '&#39;';\n      }\n    });\n  }\n\n  buildIndex.addEventListener('click', () => {\n    logInteraction('Build index started');\n    const built = buildIndexData();\n    if(built) {\n      indexedData = built;\n      summary.textContent = `Indexed ${indexedData.items.size} unique items of type \"${indexedData.type}\" in text length ${indexedData.textLength}.`;\n      updateIndexTable();\n      searchResults.textContent = 'No search done.';\n      positionOutput.textContent = 'No position explored yet.';\n      logInteraction('Build index succeeded', `${indexedData.items.size} items indexed`);\n    } else {\n      summary.textContent = 'Index build failed or no results.';\n      indexTableBody.textContent = '';\n      indexedData = null;\n      logInteraction('Build index failed or no data');\n    }\n  });\n\n  // Search indexed items by substring with case-sensitive or insensitive opt\n  searchButton.addEventListener('click', () => {\n    if(!indexedData) {\n      alert('No index to search. Build index first.');\n      return;\n    }\n    const query = searchInput.value;\n    if(!query) {\n      alert('Please enter a search substring.');\n      return;\n    }\n    const cs = caseSensitiveCheckbox.checked;\n    const items = sortedIndexedItems();\n    let matched = items.filter(([item,]) => {\n      if(cs) {\n        return item.includes(query);\n      } else {\n        return item.toLowerCase().includes(query.toLowerCase());\n      }\n    });\n    if(matched.length === 0) {\n      searchResults.textContent = 'No matching indexed items found.';\n    } else {\n      // Show up to 50 matches\n      const lines = matched.slice(0,50).map(([item,data]) => {\n        return `${item} (count: ${data.count}, positions: ${data.positions.join(', ')})`;\n      });\n      searchResults.textContent = lines.join('\\n');\n      if(matched.length > 50) {\n        searchResults.textContent += `\\n...and ${matched.length-50} more matches.`;\n      }\n    }\n    logInteraction('Search indexed items', `query=\"${query}\", caseSensitive=${cs}, results=${matched.length}`);\n  });\n\n  // Explore position - what indexed items appear at or near position\n  explorePositionBtn.addEventListener('click', () => {\n    if(!indexedData) {\n      alert('No index built. Build index first.');\n      return;\n    }\n    const posRaw = positionInput.value;\n    const radiusRaw = contextRadius.value;\n    let pos = Number(posRaw);\n    let radius = Number(radiusRaw);\n    if(isNaN(pos) || pos < 0 || pos >= indexedData.textLength) {\n      alert(`Enter a valid position between 0 and ${indexedData.textLength - 1}.`);\n      return;\n    }\n    if(isNaN(radius) || radius < 0) radius = 0;\n\n    // Find items with positions falling within [pos - radius, pos + radius]\n    const minPos = Math.max(0, pos - radius);\n    const maxPos = Math.min(indexedData.textLength - 1, pos + radius);\n\n    // Find items that occur overlapping this range\n    // Overlap criteria depends on index type\n    // For word and phrase, items have a start index and length = item.length\n    // For character - length = 1\n    // For regex - items are matched text, length = item.length\n\n    // So for each item and its positions, check if any position interval overlaps [minPos,maxPos]\n\n    const results = [];\n\n    function positionRange(overlapStart, length) {\n      return [overlapStart, overlapStart + length - 1];\n    }\n    for(const [item, data] of indexedData.items.entries()) {\n      const len = item.length;\n      // For char type, length=1 guaranteed\n      // Data.positions is array of start positions\n      // find if any position range intersects [minPos,maxPos]\n      // We stop on first found occurrence per item (for brevity)\n      const foundPos = data.positions.find(p => {\n        const [start, end] = positionRange(p,len);\n        return !(end < minPos || start > maxPos);\n      });\n      if(foundPos !== undefined) {\n        results.push({\n          item,\n          count: data.count,\n          positions: data.positions,\n          firstPosInRange: foundPos,\n          length: len\n        });\n      }\n    }\n\n    if(results.length === 0) {\n      positionOutput.textContent = `No indexed items found overlapping position ${pos} ± ${radius}.`;\n      logInteraction('Explore position', `pos=${pos}, radius=${radius}, found=0 items`);\n      return;\n    }\n\n    // Sorting results by relevance: how close firstPosInRange is to pos, then count desc\n    results.sort((a,b) => {\n      const distA = Math.abs(a.firstPosInRange - pos);\n      const distB = Math.abs(b.firstPosInRange - pos);\n      if(distA !== distB) return distA - distB;\n      return b.count - a.count;\n    });\n\n    // Display context: show snippet of text around position and highlight found item near there\n    const snippetRadius = 15;\n    const fromIdx = Math.max(0, pos - snippetRadius);\n    const toIdx = Math.min(indexedData.textLength, pos + snippetRadius+1);\n    const snippet = textInput.value.slice(fromIdx,toIdx);\n\n    // Show results with first occurrence near pos position highlighted with |item|\n    // We'll mark the matched substrings inline with pipe |...| around first matched item found near pos\n\n    let snippetMarked = snippet;\n    const snippetOffset = fromIdx;\n\n    // Attempt to mark first detected item in snippet\n    // Find first item in results with a firstPosInRange inside snippet bounds\n    let markedOnce = false;\n\n    for(const r of results) {\n      if(markedOnce) break;\n      // For each position of this item, check if in snippet range and highlight the earliest one\n      const posInSnippet = r.positions.find(p => p >= fromIdx && p + r.length - 1 < toIdx);\n      if(posInSnippet !== undefined) {\n        // insert marks\n        const start = posInSnippet - snippetOffset;\n        const end = start + r.length;\n        snippetMarked =\n          snippetMarked.slice(0, start) +\n          '|' +\n          snippetMarked.slice(start, end) +\n          '|' +\n          snippetMarked.slice(end);\n        markedOnce = true;\n      }\n    }\n\n    let out = `Text snippet around position ${pos} (marked with |item|):\\n` +\n      snippetMarked + '\\n\\n';\n\n    out += `Found ${results.length} indexed items overlapping position:\\n`;\n    for(let i=0; i<Math.min(results.length,20); i++) {\n      const r = results[i];\n      out += `- \"${r.item}\" (count: ${r.count}), positions: ${r.positions.slice(0,10).join(', ')}${r.positions.length > 10 ? ' ...' : ''}\\n`;\n    }\n    if(results.length > 20) {\n      out += `... and ${results.length-20} more items.\\n`;\n    }\n    positionOutput.textContent = out;\n    logInteraction('Explore position', `pos=${pos}, radius=${radius}, found=${results.length} items`);\n  });\n\n  // Initial clear\n  clearAll();\n\n  // Extra: add keyboard shortcuts for frequent actions\n  document.addEventListener('keydown',function(e) {\n    if(e.key === 'Enter' && e.ctrlKey) {\n      e.preventDefault();\n      if(document.activeElement === searchInput) {\n        searchButton.click();\n      } else if(document.activeElement === positionInput) {\n        explorePositionBtn.click();\n      } else {\n        buildIndex.click();\n      }\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
