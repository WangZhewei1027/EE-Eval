    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Depth-First Search Visualization</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --text: #636e72;\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: var(--light);\n            color: var(--text);\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            color: var(--dark);\n            margin-bottom: 1rem;\n            background: linear-gradient(135deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            position: relative;\n            height: 500px;\n            background-color: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.05);\n            overflow: hidden;\n            margin-bottom: 3rem;\n        }\n\n        .tree-container {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 100%;\n            height: 100%;\n        }\n\n        .node {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            background-color: var(--primary);\n            color: white;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            font-size: 1.2rem;\n            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.3);\n            transition: all 0.3s ease;\n            z-index: 2;\n            opacity: 0;\n            transform: scale(0.8);\n        }\n\n        .node.active {\n            background-color: var(--accent);\n            transform: scale(1.1);\n            box-shadow: 0 15px 30px rgba(253, 121, 168, 0.4);\n        }\n\n        .node.visited {\n            background-color: var(--secondary);\n        }\n\n        .path {\n            position: absolute;\n            height: 3px;\n            background-color: var(--secondary);\n            transform-origin: 0 0;\n            z-index: 1;\n            opacity: 0;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 2rem;\n        }\n\n        button {\n            background-color: var(--primary);\n            color: white;\n            border: none;\n            padding: 1rem 2rem;\n            font-size: 1rem;\n            border-radius: 50px;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.3);\n            margin: 0 1rem;\n            font-weight: 500;\n            letter-spacing: 0.5px;\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 15px 30px rgba(108, 92, 231, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 2rem;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            margin: 0 1rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n            margin-right: 0.5rem;\n        }\n\n        .unvisited {\n            background-color: var(--primary);\n        }\n\n        .active-node {\n            background-color: var(--accent);\n        }\n\n        .visited {\n            background-color: var(--secondary);\n        }\n\n        .explanation {\n            max-width: 800px;\n            margin: 0 auto;\n            line-height: 1.8;\n            font-size: 1.1rem;\n            text-align: center;\n            opacity: 0;\n            transform: translateY(20px);\n            transition: all 0.5s ease;\n        }\n\n        .explanation.show {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        .footer {\n            text-align: center;\n            margin-top: 4rem;\n            color: var(--text);\n            font-size: 0.9rem;\n            opacity: 0.7;\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        .pulse {\n            animation: pulse 2s infinite;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Depth-First Search</h1>\n            <p class=\"subtitle\">A visual exploration of how DFS traverses through nodes by exploring as far as possible along each branch before backtracking.</p>\n        </header>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color unvisited\"></div>\n                <span>Unvisited</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color active-node\"></div>\n                <span>Active</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color visited\"></div>\n                <span>Visited</span>\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"startBtn\">Start Visualization</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n\n        <div class=\"visualization\">\n            <div class=\"tree-container\" id=\"treeContainer\">\n                <!-- Nodes and paths will be generated by JavaScript -->\n            </div>\n        </div>\n\n        <div class=\"explanation\" id=\"explanation\">\n            <h3>How Depth-First Search Works</h3>\n            <p>DFS starts at the root node (or an arbitrary node for a graph) and explores as far as possible along each branch before backtracking. It uses a stack data structure (either implicitly via recursion or explicitly) to keep track of the nodes to visit next.</p>\n            <p>The algorithm proceeds by visiting each unvisited adjacent node, marking it as visited, and repeating the process for each newly visited node. When it reaches a node with no unvisited neighbors, it backtracks to the previous node.</p>\n        </div>\n\n        <div class=\"footer\">\n            <p>DFS Visualization | Beautiful Algorithm Exploration</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const treeContainer = document.getElementById('treeContainer');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const explanation = document.getElementById('explanation');\n\n            // Binary tree structure (7 nodes for visualization)\n            const tree = {\n                value: 'A',\n                left: {\n                    value: 'B',\n                    left: {\n                        value: 'D',\n                        left: null,\n                        right: null\n                    },\n                    right: {\n                        value: 'E',\n                        left: null,\n                        right: null\n                    }\n                },\n                right: {\n                    value: 'C',\n                    left: {\n                        value: 'F',\n                        left: null,\n                        right: null\n                    },\n                    right: {\n                        value: 'G',\n                        left: null,\n                        right: null\n                    }\n                }\n            };\n\n            // Node positions (predefined for aesthetic layout)\n            const nodePositions = {\n                'A': { x: 50, y: 20 },\n                'B': { x: 20, y: 40 },\n                'C': { x: 80, y: 40 },\n                'D': { x: 10, y: 60 },\n                'E': { x: 30, y: 60 },\n                'F': { x: 70, y: 60 },\n                'G': { x: 90, y: 60 }\n            };\n\n            // Path connections\n            const paths = [\n                { from: 'A', to: 'B' },\n                { from: 'A', to: 'C' },\n                { from: 'B', to: 'D' },\n                { from: 'B', to: 'E' },\n                { from: 'C', to: 'F' },\n                { from: 'C', to: 'G' }\n            ];\n\n            // Create nodes and paths\n            function createTreeVisualization() {\n                // Create nodes\n                Object.keys(nodePositions).forEach(value => {\n                    const pos = nodePositions[value];\n                    const node = document.createElement('div');\n                    node.className = 'node';\n                    node.textContent = value;\n                    node.id = `node-${value}`;\n                    node.style.left = `${pos.x}%`;\n                    node.style.top = `${pos.y}%`;\n                    treeContainer.appendChild(node);\n\n                    // Animate node appearance\n                    setTimeout(() => {\n                        node.style.opacity = '1';\n                        node.style.transform = 'scale(1)';\n                    }, 100 * parseInt(value.charCodeAt(0) - 65)); // Spread out appearance\n                });\n\n                // Create paths\n                paths.forEach(path => {\n                    const fromPos = nodePositions[path.from];\n                    const toPos = nodePositions[path.to];\n                    \n                    // Calculate path position and dimensions\n                    const x1 = fromPos.x;\n                    const y1 = fromPos.y;\n                    const x2 = toPos.x;\n                    const y2 = toPos.y;\n                    \n                    const length = Math.sqrt(Math.pow(x2 - x1, 2) + Math.pow(y2 - y1, 2)) * 10;\n                    const angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI;\n                    \n                    const pathElement = document.createElement('div');\n                    pathElement.className = 'path';\n                    pathElement.id = `path-${path.from}-${path.to}`;\n                    pathElement.style.width = `${length}%`;\n                    pathElement.style.left = `${x1}%`;\n                    pathElement.style.top = `${y1}%`;\n                    pathElement.style.transform = `rotate(${angle}deg)`;\n                    \n                    treeContainer.appendChild(pathElement);\n\n                    // Animate path appearance\n                    setTimeout(() => {\n                        pathElement.style.opacity = '0.3';\n                    }, 300);\n                });\n            }\n\n            // Perform DFS with visualization\n            async function visualizeDFS() {\n                startBtn.disabled = true;\n                explanation.classList.add('show');\n\n                const visited = new Set();\n                const stack = [tree];\n\n                while (stack.length > 0) {\n                    const current = stack.pop();\n                    \n                    if (!current || visited.has(current.value)) continue;\n                    \n                    // Mark as visited\n                    visited.add(current.value);\n                    const currentNode = document.getElementById(`node-${current.value}`);\n                    currentNode.classList.add('active');\n                    currentNode.classList.remove('visited');\n\n                    // Highlight path from parent\n                    if (current !== tree) {\n                        // Find parent path (simplified for this demo)\n                        let parentPath = null;\n                        for (const path of paths) {\n                            if (path.to === current.value) {\n                                parentPath = document.getElementById(`path-${path.from}-${path.to}`);\n                                break;\n                            }\n                        }\n                        if (parentPath) {\n                            parentPath.style.opacity = '1';\n                            parentPath.style.backgroundColor = 'var(--accent)';\n                        }\n                    }\n\n                    // Wait for animation\n                    await new Promise(resolve => setTimeout(resolve, 800));\n\n                    // Mark as visited (but not active)\n                    currentNode.classList.remove('active');\n                    currentNode.classList.add('visited');\n\n                    // Push right first, then left to process left first (stack LIFO)\n                    if (current.right) stack.push(current.right);\n                    if (current.left) stack.push(current.left);\n                    \n                    // Brief pause between steps\n                    await new Promise(resolve => setTimeout(resolve, 400));\n                }\n\n                startBtn.disabled = false;\n            }\n\n            // Reset visualization\n            function resetVisualization() {\n                document.querySelectorAll('.node').forEach(node => {\n                    node.classList.remove('active', 'visited');\n                });\n                \n                document.querySelectorAll('.path').forEach(path => {\n                    path.style.opacity = '0.3';\n                    path.style.backgroundColor = 'var(--secondary)';\n                });\n\n                explanation.classList.remove('show');\n            }\n\n            // Event listeners\n            startBtn.addEventListener('click', visualizeDFS);\n            resetBtn.addEventListener('click', resetVisualization);\n\n            // Initialize tree visualization\n            createTreeVisualization();\n\n            // Animate title\n            const title = document.querySelector('h1');\n            setTimeout(() => {\n                title.classList.add('pulse');\n            }, 1000);\n        });\n    </script>\n</body>\n</html>"
