    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Static Typing Elegance</title>\n    <style>\n        :root {\n            --primary: #6366f1;\n            --primary-dark: #4f46e5;\n            --secondary: #f43f5e;\n            --bg: #f8fafc;\n            --text: #1e293b;\n            --text-light: #64748b;\n            --card-bg: #ffffff;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n            background-color: var(--bg);\n            color: var(--text);\n            line-height: 1.6;\n            padding: 2rem;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f2 100%);\n        }\n\n        @font-face {\n            font-family: 'Inter';\n            font-style: normal;\n            font-weight: 400;\n            font-display: swap;\n            src: url('https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfMZs.woff2') format('woff2');\n        }\n\n        .container {\n            max-width: 900px;\n            width: 100%;\n            margin: 0 auto;\n            padding: 0 1rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1s ease-out;\n        }\n\n        h1 {\n            font-size: 2.5rem;\n            font-weight: 700;\n            color: var(--primary-dark);\n            margin-bottom: 1rem;\n            letter-spacing: -0.025em;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n\n        .subtitle {\n            font-size: 1.125rem;\n            color: var(--text-light);\n            max-width: 600px;\n            margin: 0 auto;\n        }\n\n        .demo-container {\n            display: flex;\n            flex-direction: column;\n            gap: 2rem;\n            margin-bottom: 3rem;\n            animation: slideUp 0.8s ease-out;\n        }\n\n        .code-card {\n            background-color: var(--card-bg);\n            border-radius: 16px;\n            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n            padding: 2rem;\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n            border: 1px solid rgba(255, 255, 255, 0.2);\n        }\n\n        .code-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n        }\n\n        .code-card::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 6px;\n            height: 100%;\n            background: linear-gradient(to bottom, var(--primary), var(--secondary));\n        }\n\n        .card-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 1.5rem;\n        }\n\n        .card-title {\n            font-size: 1.25rem;\n            font-weight: 600;\n            color: var(--primary-dark);\n        }\n\n        .language-tag {\n            background-color: var(--primary);\n            color: white;\n            padding: 0.25rem 0.75rem;\n            border-radius: 9999px;\n            font-size: 0.75rem;\n            font-weight: 600;\n        }\n\n        pre {\n            background-color: #1e293b;\n            padding: 1.5rem;\n            border-radius: 8px;\n            overflow-x: auto;\n            font-family: 'SF Mono', 'Menlo', monospace;\n            font-size: 0.875rem;\n            line-height: 1.5;\n            color: #e2e8f0;\n            position: relative;\n            margin: 1rem 0;\n        }\n\n        .type-info {\n            display: flex;\n            flex-direction: column;\n            gap: 1rem;\n            margin-top: 1.5rem;\n            padding: 1rem;\n            background-color: #f1f5f9;\n            border-radius: 8px;\n            border-left: 4px solid var(--primary);\n        }\n\n        .type-row {\n            display: flex;\n            align-items: center;\n        }\n\n        .type-label {\n            font-weight: 600;\n            color: var(--primary);\n            min-width: 120px;\n        }\n\n        .type-value {\n            font-family: 'SF Mono', 'Menlo', monospace;\n            color: var(--secondary);\n        }\n\n        .visualization {\n            background-color: var(--card-bg);\n            border-radius: 16px;\n            padding: 2rem;\n            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n            margin-top: 1rem;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .type-visual {\n            display: flex;\n            flex-direction: column;\n            gap: 1rem;\n        }\n\n        .type-bar {\n            height: 24px;\n            border-radius: 12px;\n            background-color: #e2e8f0;\n            overflow: hidden;\n            position: relative;\n        }\n\n        .type-fill {\n            height: 100%;\n            border-radius: 12px;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            width: 0;\n            transition: width 1s ease-out;\n        }\n\n        .type-legend {\n            display: flex;\n            justify-content: space-between;\n            margin-top: 0.5rem;\n            font-size: 0.875rem;\n            color: var(--text-light);\n        }\n\n        .buttons {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        .btn {\n            padding: 0.75rem 1.5rem;\n            border-radius: 8px;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.2s ease;\n            border: none;\n            font-size: 0.875rem;\n        }\n\n        .btn-primary {\n            background-color: var(--primary);\n            color: white;\n        }\n\n        .btn-primary:hover {\n            background-color: var(--primary-dark);\n        }\n\n        .btn-secondary {\n            background-color: transparent;\n            color: var(--primary);\n            border: 1px solid var(--primary);\n        }\n\n        .btn-secondary:hover {\n            background-color: rgba(99, 102, 241, 0.1);\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(30px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes pulse {\n            0%, 100% {\n                opacity: 1;\n            }\n            50% {\n                opacity: 0.6;\n            }\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 3rem;\n            color: var(--text-light);\n            font-size: 0.875rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        .highlight {\n            position: relative;\n        }\n\n        .highlight::after {\n            content: '';\n            position: absolute;\n            bottom: -2px;\n            left: 0;\n            width: 100%;\n            height: 2px;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            transform: scaleX(0);\n            transform-origin: left;\n            transition: transform 0.3s ease;\n        }\n\n        .highlight:hover::after {\n            transform: scaleX(1);\n        }\n\n        .decorative-shapes {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            z-index: -1;\n            overflow: hidden;\n        }\n\n        .shape {\n            position: absolute;\n            border-radius: 50%;\n            opacity: 0.1;\n        }\n\n        .shape-1 {\n            width: 300px;\n            height: 300px;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            top: -100px;\n            right: -100px;\n            animation: float 20s infinite ease-in-out;\n        }\n\n        .shape-2 {\n            width: 200px;\n            height: 200px;\n            background: linear-gradient(45deg, var(--secondary), #f59e0b);\n            bottom: -50px;\n            left: -50px;\n            animation: float 25s infinite ease-in-out reverse;\n        }\n\n        @keyframes float {\n            0%, 100% {\n                transform: translate(0, 0);\n            }\n            50% {\n                transform: translate(20px, 20px);\n            }\n        }\n\n        .tooltip {\n            position: absolute;\n            background-color: var(--text);\n            color: white;\n            padding: 0.5rem 0.75rem;\n            border-radius: 6px;\n            font-size: 0.75rem;\n            pointer-events: none;\n            opacity: 0;\n            transition: opacity 0.2s ease;\n            z-index: 100;\n            white-space: nowrap;\n        }\n\n        .tooltip::after {\n            content: '';\n            position: absolute;\n            bottom: -5px;\n            left: 50%;\n            transform: translateX(-50%);\n            border-width: 5px 5px 0;\n            border-style: solid;\n            border-color: var(--text) transparent transparent;\n        }\n\n        .type-icon {\n            width: 24px;\n            height: 24px;\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            background-color: var(--primary);\n            color: white;\n            border-radius: 50%;\n            margin-right: 0.5rem;\n            font-size: 0.75rem;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"decorative-shapes\">\n        <div class=\"shape shape-1\"></div>\n        <div class=\"shape shape-2\"></div>\n    </div>\n\n    <div class=\"container\">\n        <header>\n            <h1>Static Typing Elegance</h1>\n            <p class=\"subtitle\">Discover the beauty of compile-time type safety through these visual examples</p>\n        </header>\n\n        <div class=\"demo-container\">\n            <div class=\"code-card\">\n                <div class=\"card-header\">\n                    <div class=\"card-title\">Type-Safe Function</div>\n                    <div class=\"language-tag\">TypeScript</div>\n                </div>\n                \n                <pre><code>function greet(name: string, age: number): string {\n    return `Hello ${name}, you are ${age} years old!`;\n}\n\n// Valid usage\nconst message = greet(\"Alice\", 28);\n\n// Invalid usage (would show compile error)\n// const error = greet(42, \"Bob\");</code></pre>\n\n                <div class=\"type-info\">\n                    <div class=\"type-row\">\n                        <div class=\"type-label\"><span class=\"type-icon\">f</span>Function</div>\n                        <div class=\"type-value\">greet(name: string, age: number): string</div>\n                    </div>\n                    <div class=\"type-row\">\n                        <div class=\"type-label\"><span class=\"type-icon\">p</span>Parameter 1</div>\n                        <div class=\"type-value\">name: string</div>\n                    </div>\n                    <div class=\"type-row\">\n                        <div class=\"type-label\"><span class=\"type-icon\">p</span>Parameter 2</div>\n                        <div class=\"type-value\">age: number</div>\n                    </div>\n                    <div class=\"type-row\">\n                        <div class=\"type-label\"><span class=\"type-icon\">r</span>Return</div>\n                        <div class=\"type-value\">string</div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"code-card\">\n                <div class=\"card-header\">\n                    <div class=\"card-title\">Type Inference</div>\n                    <div class=\"language-tag\">Swift</div>\n                </div>\n                \n                <pre><code>let username: String = \"dev_user\"\nlet score: Int = 95\nlet isActive: Bool = true\n\n// Type inference example\nlet inferredName = \"Alice\"  // Compiler knows this is String\nlet inferredAge = 30        // Compiler knows this is Int\n\n// Invalid operations caught at compile time\n// let total = username + score  // Error!</code></pre>\n\n                <div class=\"visualization\">\n                    <h3 class=\"card-title\" style=\"margin-bottom: 1rem;\">Type Safety Strength</h3>\n                    <div class=\"type-visual\">\n                        <div class=\"type-row\">\n                            <div class=\"type-label\">Runtime Safety</div>\n                            <div class=\"type-bar\">\n                                <div class=\"type-fill\" style=\"width: 60%;\"></div>\n                            </div>\n                            <div class=\"type-legend\">\n                                <span>Weak</span>\n                                <span>Strong</span>\n                            </div>\n                        </div>\n                        <div class=\"type-row\">\n                            <div class=\"type-label\">Compile-time Safety</div>\n                            <div class=\"type-bar\">\n                                <div class=\"type-fill\" style=\"width: 95%;\"></div>\n                            </div>\n                            <div class=\"type-legend\">\n                                <span>Weak</span>\n                                <span>Strong</span>\n                            </div>\n                        </div>\n                        <div class=\"type-row\">\n                            <div class=\"type-label\">Developer Experience</div>\n                            <div class=\"type-bar\">\n                                <div class=\"type-fill\" style=\"width: 85%;\"></div>\n                            </div>\n                            <div class=\"type-legend\">\n                                <span>Weak</span>\n                                <span>Strong</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"code-card\">\n                <div class=\"card-header\">\n                    <div class=\"card-title\">Custom Types</div>\n                    <div class=\"language-tag\">Rust</div>\n                </div>\n                \n                <pre><code>// Defining custom types\nstruct User {\n    id: u32,\n    username: String,\n    is_premium: bool,\n}\n\n// Using the type\nlet user = User {\n    id: 1,\n    username: String::from(\"rust_lover\"),\n    is_premium: true,\n};\n\n// Pattern matching with types\nmatch user.is_premium {\n    true => println!(\"Premium user!\"),\n    false => println!(\"Regular user\"),\n}</code></pre>\n\n                <div class=\"type-info\">\n                    <div class=\"type-row\">\n                        <div class=\"type-label\"><span class=\"type-icon\">s</span>Struct</div>\n                        <div class=\"type-value\">User</div>\n                    </div>\n                    <div class=\"type-row\">\n                        <div class=\"type-label\"><span class=\"type-icon\">f</span>Field 1</div>\n                        <div class=\"type-value\">id: u32</div>\n                    </div>\n                    <div class=\"type-row\">\n                        <div class=\"type-label\"><span class=\"type-icon\">f</span>Field 2</div>\n                        <div class=\"type-value\">username: String</div>\n                    </div>\n                    <div class=\"type-row\">\n                        <div class=\"type-label\"><span class=\"type-icon\">f</span>Field 3</div>\n                        <div class=\"type-value\">is_premium: bool</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"buttons\">\n            <button class=\"btn btn-primary\" id=\"animateBtn\">Animate Visualization</button>\n            <button class=\"btn btn-secondary\" id=\"toggleThemeBtn\">Toggle Dark Mode</button>\n        </div>\n    </div>\n\n    <footer>\n        <p>Static typing provides <span class=\"highlight\">compile-time safety</span> and <span class=\"highlight\">developer confidence</span></p>\n    </footer>\n\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <script>\n        // Simple animations and interactions\n        document.addEventListener('DOMContentLoaded', () => {\n            // Animate type bars on button click\n            const animateBtn = document.getElementById('animateBtn');\n            const typeFills = document.querySelectorAll('.type-fill');\n            \n            animateBtn.addEventListener('click', () => {\n                typeFills.forEach(fill => {\n                    fill.style.width = '0';\n                    setTimeout(() => {\n                        fill.style.width = fill.getAttribute('data-width') || '100%';\n                    }, 100);\n                });\n            });\n\n            // Set initial widths for bars\n            typeFills[0].setAttribute('data-width', '60%');\n            typeFills[1].setAttribute('data-width', '95%');\n            typeFills[2].setAttribute('data-width', '85%');\n\n            // Simple theme toggle (just for demo)\n            const toggleThemeBtn = document.getElementById('toggleThemeBtn');\n            let isDark = false;\n            \n            toggleThemeBtn.addEventListener('click', () => {\n                isDark = !isDark;\n                document.body.style.backgroundColor = isDark ? '#0f172a' : '#f8fafc';\n                document.body.style.color = isDark ? '#e2e8f0' : '#1e293b';\n            });\n\n            // Add hover tooltips to type labels\n            const typeLabels = document.querySelectorAll('.type-label');\n            const tooltip = document.getElementById('tooltip');\n            \n            typeLabels.forEach(label => {\n                label.addEventListener('mouseenter', (e) => {\n                    const rect = e.target.getBoundingClientRect();\n                    tooltip.textContent = e.target.textContent.trim();\n                    tooltip.style.left = `${rect.left + rect.width / 2}px`;\n                    tooltip.style.top = `${rect.top - 40}px`;\n                    tooltip.style.opacity = '1';\n                });\n                \n                label.addEventListener('mouseleave', () => {\n                    tooltip.style.opacity = '0';\n                });\n            });\n        });\n    </script>\n</body>\n</html>"
