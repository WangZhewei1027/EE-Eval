  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Depth-First Search (DFS) Interactive Explorer</title>\n</head>\n<body>\n<h1>Depth-First Search (DFS) Interactive Explorer</h1>\n\n<p>Plain, functional interface for exploring DFS with many interactive controls. Use the controls below to build a graph, choose options, run DFS step-by-step, and explore internal stacks, timestamps, and transitions. (No styling; black text on white background.)</p>\n\n<!-- Controls -->\n<div>\n  <fieldset>\n    <legend>Graph Editing Modes</legend>\n    <button id=\"modeSelectAddNode\">Toggle Add Node Mode (Click canvas)</button>\n    <button id=\"modeSelectAddEdge\">Toggle Add Edge Mode (Click two nodes)</button>\n    <button id=\"modeSelectDelete\">Toggle Delete Mode (Click node/edge)</button>\n    <span> Current Mode: <span id=\"currentMode\">Idle</span></span>\n    <br><br>\n    <label><input type=\"checkbox\" id=\"directedToggle\"> Directed graph</label>\n    <label style=\"margin-left:1em;\"><input type=\"checkbox\" id=\"autoLabel\"> Auto-label new nodes (N0, N1...)</label>\n    <br><br>\n    <label>Node label: <input type=\"text\" id=\"newNodeLabel\" placeholder=\"label for next node\"></label>\n    <button id=\"addNodeBtn\">Add Node at (100,100)</button>\n    <label style=\"margin-left:1em;\">X: <input type=\"number\" id=\"addX\" value=\"100\" style=\"width:60px\"></label>\n    <label>Y: <input type=\"number\" id=\"addY\" value=\"100\" style=\"width:60px\"></label>\n    <br><br>\n    <button id=\"clearGraphBtn\">Clear Graph</button>\n    <button id=\"randomGraphBtn\">Generate Random Graph</button>\n    <label> Nodes: <input type=\"number\" id=\"randN\" value=\"7\" style=\"width:60px\"></label>\n    <label> EdgeProb (0-1): <input type=\"number\" id=\"randP\" value=\"0.25\" step=\"0.05\" min=\"0\" max=\"1\" style=\"width:80px\"></label>\n    <label> Seed: <input type=\"text\" id=\"randSeed\" value=\"42\" style=\"width:80px\"></label>\n    <br><br>\n    <button id=\"saveGraphBtn\">Save Graph (JSON)</button>\n    <input type=\"file\" id=\"loadGraphFile\" accept=\"application/json\">\n    <button id=\"pasteLoadBtn\">Load from Paste</button>\n    <textarea id=\"pasteLoadArea\" placeholder=\"Paste JSON and click 'Load from Paste'\" rows=\"3\" cols=\"60\"></textarea>\n  </fieldset>\n</div>\n\n<br>\n\n<div>\n  <fieldset>\n    <legend>DFS Options & Control</legend>\n\n    <label>Implementation:\n      <select id=\"implSelect\">\n        <option value=\"recursive\">Recursive</option>\n        <option value=\"iterative\">Iterative (explicit stack)</option>\n      </select>\n    </label>\n\n    <label style=\"margin-left:1em;\">Start node:\n      <select id=\"startNodeSelect\"></select>\n    </label>\n\n    <label style=\"margin-left:1em;\">Target node (optional):\n      <select id=\"targetNodeSelect\"></select>\n    </label>\n\n    <label style=\"margin-left:1em;\">Neighbor order:\n      <select id=\"neighborOrder\">\n        <option value=\"asc\">Ascending id</option>\n        <option value=\"desc\">Descending id</option>\n        <option value=\"rand\">Random (seedable)</option>\n      </select>\n    </label>\n\n    <label style=\"margin-left:1em;\">Random seed: <input id=\"seedInput\" value=\"1\" style=\"width:60px\"></label>\n\n    <br><br>\n    <label>Depth limit (empty for none): <input id=\"depthLimit\" type=\"number\" style=\"width:60px\"></label>\n    <label style=\"margin-left:1em;\"><input type=\"checkbox\" id=\"stopOnTarget\"> Stop on finding target</label>\n    <label style=\"margin-left:1em;\"><input type=\"checkbox\" id=\"showTimestamps\" checked> Show discovery/finish times</label>\n\n    <br><br>\n    <button id=\"generateHistoryBtn\">Generate DFS Run (record steps)</button>\n    <button id=\"runAllBtn\">Run to Completion</button>\n    <button id=\"resetRunBtn\">Reset Run State (clear visits)</button>\n    <button id=\"clearHistoryBtn\">Clear Recorded History</button>\n\n    <br><br>\n    <button id=\"stepBackBtn\">Step Back</button>\n    <button id=\"stepForwardBtn\">Step Forward</button>\n    <button id=\"playPauseBtn\">Play</button>\n    <label style=\"margin-left:1em;\">Speed (ms per step): <input id=\"speedRange\" type=\"range\" min=\"50\" max=\"2000\" value=\"600\"></label>\n    <span id=\"speedValue\">600</span> ms\n\n    <br><br>\n    <button id=\"showAdjListBtn\">Show Adjacency List</button>\n    <button id=\"showAdjMatrixBtn\">Show Adjacency Matrix</button>\n    <button id=\"showParentPointers\">Show Parent Pointers</button>\n    <button id=\"exportHistoryBtn\">Export History (JSON)</button>\n  </fieldset>\n</div>\n\n<br>\n\n<!-- Canvas area -->\n<div>\n  <svg id=\"canvas\" width=\"800\" height=\"400\" style=\"border:1px solid #000;\"></svg>\n  <div>\n    <small>Instructions: Toggle Add Node mode to add nodes by clicking. Toggle Add Edge mode then click two nodes to add an edge. Delete mode removes nodes/edges by clicking. You can also add a node with the Add Node button. Use Run/Step controls to explore DFS.</small>\n  </div>\n</div>\n\n<br>\n\n<!-- Displays -->\n<div>\n  <fieldset>\n    <legend>Current Graph & DFS State</legend>\n    <div>\n      <strong>Graph Summary:</strong>\n      <div id=\"graphSummary\">Nodes: 0, Edges: 0</div>\n      <pre id=\"adjListDisplay\"></pre>\n      <pre id=\"adjMatrixDisplay\"></pre>\n    </div>\n\n    <div>\n      <strong>Node States (discovered/finished/status):</strong>\n      <pre id=\"nodeStatesDisplay\"></pre>\n    </div>\n\n    <div>\n      <strong>Stack / Call Frames:</strong>\n      <pre id=\"stackDisplay\"></pre>\n    </div>\n\n    <div>\n      <strong>Recorded History (actions):</strong>\n      <pre id=\"historyDisplay\" style=\"height:120px;overflow:auto;\"></pre>\n    </div>\n\n    <div>\n      <strong>Path to target (if found):</strong>\n      <pre id=\"foundPathDisplay\"></pre>\n    </div>\n\n  </fieldset>\n</div>\n\n<script>\n// Minimal, plain UI DFS explorer with many interactive controls.\n// No fancy styling; all black on white. Focus on interactivity and complexity.\n\n// Basic graph model\nlet nextNodeId = 0;\nlet nodes = []; // {id, label, x, y}\nlet edges = []; // {id, from, to}\nlet directed = false;\n\nlet mode = 'idle'; // 'idle', 'addNode', 'addEdge', 'delete'\nlet addEdgeBuffer = null;\n\n// DFS run state & history snapshots\nlet history = []; // array of snapshots\nlet historyIndex = -1;\nlet playing = false;\nlet playTimer = null;\n\n// Utility functions\nfunction $(id){ return document.getElementById(id); }\n\nfunction updateModeUI(){\n  $('currentMode').textContent = mode === 'idle' ? 'Idle' : mode;\n  $('modeSelectAddNode').textContent = (mode === 'addNode' ? 'Exit Add Node Mode' : 'Toggle Add Node Mode (Click canvas)');\n  $('modeSelectAddEdge').textContent = (mode === 'addEdge' ? 'Exit Add Edge Mode' : 'Toggle Add Edge Mode (Click two nodes)');\n  $('modeSelectDelete').textContent = (mode === 'delete' ? 'Exit Delete Mode' : 'Toggle Delete Mode (Click node/edge)');\n}\n\n// Graph manipulation\nfunction addNode(x,y,label){\n  const id = nextNodeId++;\n  const nodeLabel = label || ( $('autoLabel').checked ? 'N' + id : (label || ('v' + id)) );\n  nodes.push({id:id, label:nodeLabel, x:x, y:y});\n  updateGraphUI();\n  return id;\n}\n\nfunction removeNode(id){\n  nodes = nodes.filter(n => n.id !== id);\n  edges = edges.filter(e => e.from !== id && e.to !== id);\n  updateGraphUI();\n}\n\nfunction addEdge(from,to){\n  // prevent self duplicates\n  if (from === null || to === null) return;\n  // don't duplicate undirected duplicates\n  if (!directed){\n    if (edges.some(e => (e.from === from && e.to === to) || (e.from === to && e.to === from))) return;\n  } else {\n    if (edges.some(e => e.from === from && e.to === to)) return;\n  }\n  edges.push({id: 'e'+Math.random().toString(36).slice(2,9), from: from, to: to});\n  updateGraphUI();\n}\n\nfunction removeEdgeById(eid){\n  edges = edges.filter(e => e.id !== eid);\n  updateGraphUI();\n}\n\nfunction findNodeAt(x,y){\n  // simple radius hit test\n  for (let i=nodes.length-1;i>=0;i--){\n    const n = nodes[i];\n    const dx = x - n.x;\n    const dy = y - n.y;\n    if (dx*dx + dy*dy <= 14*14) return n;\n  }\n  return null;\n}\n\nfunction updateGraphUI(){\n  // Update canvas\n  const svg = $('canvas');\n  while (svg.firstChild) svg.removeChild(svg.firstChild);\n\n  // Draw edges as lines with simple text id if needed\n  edges.forEach(e => {\n    const a = nodes.find(n => n.id === e.from);\n    const b = nodes.find(n => n.id === e.to);\n    if (!a || !b) return;\n    const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n    line.setAttribute('x1', a.x);\n    line.setAttribute('y1', a.y);\n    line.setAttribute('x2', b.x);\n    line.setAttribute('y2', b.y);\n    line.setAttribute('stroke-width', '1');\n    line.setAttribute('id', e.id);\n    line.addEventListener('click', (ev) => {\n      ev.stopPropagation();\n      if (mode === 'delete'){\n        removeEdgeById(e.id);\n      }\n    });\n    svg.appendChild(line);\n    // Add directed arrow head minimal text marker\n    if (directed){\n      // small marker: a short line near target\n      const mx = a.x + (b.x - a.x) * 0.85;\n      const my = a.y + (b.y - a.y) * 0.85;\n      const arrow = document.createElementNS('http://www.w3.org/2000/svg','text');\n      arrow.setAttribute('x', mx);\n      arrow.setAttribute('y', my);\n      arrow.setAttribute('font-size','10');\n      arrow.textContent = '>';\n      svg.appendChild(arrow);\n    }\n  });\n\n  // Draw nodes as circles and labels\n  nodes.forEach(n => {\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('transform', `translate(${n.x},${n.y})`);\n    // circle\n    const circ = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    circ.setAttribute('cx', 0);\n    circ.setAttribute('cy', 0);\n    circ.setAttribute('r', 14);\n    circ.setAttribute('stroke','black');\n    circ.setAttribute('fill','white');\n    circ.setAttribute('id','node'+n.id);\n    circ.addEventListener('click', (ev) => {\n      ev.stopPropagation();\n      onNodeClicked(n.id);\n    });\n    g.appendChild(circ);\n    // label\n    const lab = document.createElementNS('http://www.w3.org/2000/svg','text');\n    lab.setAttribute('x', 0);\n    lab.setAttribute('y', 4);\n    lab.setAttribute('font-size','10');\n    lab.setAttribute('text-anchor','middle');\n    lab.textContent = n.label;\n    g.appendChild(lab);\n    svg.appendChild(g);\n  });\n\n  // Update summaries and selects\n  $('graphSummary').textContent = `Nodes: ${nodes.length}, Edges: ${edges.length}`;\n  populateNodeSelects();\n  updateAdjDisplays();\n  renderCurrentSnapshot(); // reflect node states if running\n}\n\nfunction populateNodeSelects(){\n  const s = $('startNodeSelect');\n  const t = $('targetNodeSelect');\n  [s,t].forEach(sel => {\n    const v = sel.value;\n    while (sel.firstChild) sel.removeChild(sel.firstChild);\n    nodes.forEach(n => {\n      const opt = document.createElement('option');\n      opt.value = n.id;\n      opt.text = `${n.label} (id:${n.id})`;\n      sel.appendChild(opt);\n    });\n    sel.value = v || (nodes[0] ? nodes[0].id : '');\n  });\n}\n\nfunction updateAdjDisplays(){\n  let adjText = '';\n  nodes.forEach(n => {\n    const neigh = [];\n    edges.forEach(e => {\n      if (e.from === n.id) neigh.push(e.to);\n      if (!directed && e.to === n.id) neigh.push(e.from);\n    });\n    adjText += `${n.label} (id:${n.id}) -> [${neigh.join(', ')}]\\n`;\n  });\n  $('adjListDisplay').textContent = adjText;\n\n  if (nodes.length>0){\n    const mapId = {};\n    nodes.forEach((n,i)=> mapId[n.id]=i);\n    const matrix = [];\n    for (let i=0;i<nodes.length;i++){ matrix[i]=Array(nodes.length).fill(0); }\n    edges.forEach(e=>{\n      const i = mapId[e.from], j = mapId[e.to];\n      if (i !== undefined && j !== undefined) matrix[i][j]=1;\n      if (!directed && i !== undefined && j !== undefined) matrix[j][i]=1;\n    });\n    let matText = 'Adjacency matrix (rows/cols in node order shown above):\\n';\n    matrix.forEach(row => matText += row.join(' ') + '\\n');\n    $('adjMatrixDisplay').textContent = matText;\n  } else {\n    $('adjMatrixDisplay').textContent = '';\n  }\n}\n\n// Canvas interaction handlers\n$('canvas').addEventListener('click', function(ev){\n  const rect = this.getBoundingClientRect();\n  const x = ev.clientX - rect.left;\n  const y = ev.clientY - rect.top;\n  if (mode === 'addNode'){\n    const label = $('autoLabel').checked ? null : ($('newNodeLabel').value || null);\n    addNode(x,y,label);\n  } else {\n    // empty canvas clicked - clear addEdgeBuffer\n    addEdgeBuffer = null;\n    updateModeUI();\n  }\n});\n\nfunction onNodeClicked(nodeId){\n  if (mode === 'addEdge'){\n    if (addEdgeBuffer === null){\n      addEdgeBuffer = nodeId;\n      // indicate selection in simple way by showing in summary\n      $('graphSummary').textContent = `Edge source selected: id ${nodeId}. Click target node to create edge.`;\n    } else {\n      if (addEdgeBuffer === nodeId){\n        // self-loop allowed\n        addEdge(addEdgeBuffer, nodeId);\n      } else {\n        addEdge(addEdgeBuffer, nodeId);\n      }\n      addEdgeBuffer = null;\n      updateGraphUI();\n    }\n  } else if (mode === 'delete'){\n    removeNode(nodeId);\n  } else {\n    // default: select node label to edit\n    const newLabel = prompt('Edit node label (empty to cancel):', nodes.find(n=>n.id===nodeId).label);\n    if (newLabel !== null && newLabel !== ''){\n      const n = nodes.find(n=>n.id===nodeId);\n      n.label = newLabel;\n      updateGraphUI();\n    }\n  }\n  updateModeUI();\n}\n\n// Mode toggle buttons\n$('modeSelectAddNode').addEventListener('click', () => {\n  mode = (mode === 'addNode') ? 'idle' : 'addNode';\n  addEdgeBuffer = null;\n  updateModeUI();\n});\n$('modeSelectAddEdge').addEventListener('click', () => {\n  mode = (mode === 'addEdge') ? 'idle' : 'addEdge';\n  addEdgeBuffer = null;\n  updateModeUI();\n});\n$('modeSelectDelete').addEventListener('click', () => {\n  mode = (mode === 'delete') ? 'idle' : 'delete';\n  addEdgeBuffer = null;\n  updateModeUI();\n});\n\n// Add node button\n$('addNodeBtn').addEventListener('click', () => {\n  const x = parseInt($('addX').value) || 100;\n  const y = parseInt($('addY').value) || 100;\n  const label = $('autoLabel').checked ? null : ($('newNodeLabel').value || null);\n  addNode(x,y,label);\n});\n\n// Clear / random / save / load\n$('clearGraphBtn').addEventListener('click', () => {\n  if (!confirm('Clear entire graph?')) return;\n  nodes = [];\n  edges = [];\n  nextNodeId = 0;\n  history = [];\n  historyIndex = -1;\n  updateGraphUI();\n  renderHistory();\n});\n$('randomGraphBtn').addEventListener('click', () => {\n  const n = parseInt($('randN').value) || 7;\n  const p = parseFloat($('randP').value) || 0.25;\n  const seed = $('randSeed').value || (Math.random()*100000|0);\n  // simple seeded RNG\n  function sfc32(a,b,c,d){\n    return function(){\n      a |= 0; b |= 0; c |= 0; d |= 0;\n      var t = (a + b | 0) + d | 0;\n      d = d + 1 | 0;\n      a = b ^ b >>> 9;\n      b = c + (c << 3) | 0;\n      c = c << 21 | c >>> 11;\n      c = c + t | 0;\n      return (t >>> 0) / 4294967296;\n    };\n  }\n  // create seed ints from seed string\n  let h1=0, h2=0, h3=0, h4=0;\n  for (let i=0;i<seed.length;i++){\n    const ch = seed.charCodeAt(i);\n    h1 = h1 + ch | 0;\n    h2 = h2 ^ (ch << ((i%4)*8));\n    h3 = (h3 + ch*31) | 0;\n    h4 = h4 ^ ((ch<<5) | (ch>>>27));\n  }\n  const rnd = sfc32(h1,h2,h3,h4);\n  nodes = [];\n  edges = [];\n  nextNodeId = 0;\n  for (let i=0;i<n;i++){\n    addNode(60 + (i%10)*60 + (rnd()*20-10), 50 + (Math.floor(i/10))*120 + (rnd()*20-10), 'v'+i);\n  }\n  // add edges probabilistically\n  for (let i=0;i<n;i++){\n    for (let j=0;j<n;j++){\n      if (i===j) continue;\n      if (rnd() < p){\n        if (directed) addEdge(i,j);\n        else if (i < j) addEdge(i,j);\n      }\n    }\n  }\n  updateGraphUI();\n});\n\n// Save graph\n$('saveGraphBtn').addEventListener('click', () => {\n  const payload = {nodes: nodes, edges: edges, directed: directed, nextNodeId: nextNodeId};\n  const dataStr = \"data:text/json;charset=utf-8,\" + encodeURIComponent(JSON.stringify(payload));\n  const a = document.createElement('a');\n  a.href = dataStr;\n  a.download = 'graph.json';\n  a.click();\n});\n\n// Load graph from file\n$('loadGraphFile').addEventListener('change', function(){\n  const file = this.files[0];\n  if (!file) return;\n  const reader = new FileReader();\n  reader.onload = function(e){\n    try {\n      const obj = JSON.parse(e.target.result);\n      nodes = obj.nodes || [];\n      edges = obj.edges || [];\n      directed = !!obj.directed;\n      nextNodeId = obj.nextNodeId || (nodes.length ? Math.max(...nodes.map(n=>n.id))+1 : 0);\n      $('directedToggle').checked = directed;\n      updateGraphUI();\n    } catch(err){\n      alert('Failed to parse JSON: ' + err);\n    }\n  };\n  reader.readAsText(file);\n});\n\n// Paste load\n$('pasteLoadBtn').addEventListener('click', () => {\n  try {\n    const obj = JSON.parse($('pasteLoadArea').value);\n    nodes = obj.nodes || [];\n    edges = obj.edges || [];\n    directed = !!obj.directed;\n    nextNodeId = obj.nextNodeId || (nodes.length ? Math.max(...nodes.map(n=>n.id))+1 : 0);\n    $('directedToggle').checked = directed;\n    updateGraphUI();\n  } catch(err){\n    alert('Invalid JSON: ' + err);\n  }\n});\n\n// Directed toggle\n$('directedToggle').addEventListener('change', function(){\n  directed = this.checked;\n  updateGraphUI();\n});\n\n// DFS generation & simulation\nfunction deepCloneState(snapshot){\n  // create safe deep clone of nodes, edges and runtime state\n  return JSON.parse(JSON.stringify(snapshot));\n}\n\nfunction buildAdjMap(){\n  const map = {};\n  nodes.forEach(n => map[n.id] = []);\n  edges.forEach(e => {\n    if (map[e.from]) map[e.from].push(e.to);\n    if (!directed && map[e.to]) map[e.to].push(e.from);\n  });\n  return map;\n}\n\nfunction neighborOrderFn(order,seed){\n  if (order === 'asc') return (arr) => arr.sort((a,b)=>a-b);\n  if (order === 'desc') return (arr) => arr.sort((a,b)=>b-a);\n  // random with seed\n  let s = 0;\n  for (let i=0;i<seed.length;i++) s = ((s<<5)-s) + seed.charCodeAt(i);\n  function rng(){\n    s = Math.imul(48271, (s % 2147483647)) | 0;\n    return Math.abs(s)/2147483647;\n  }\n  return (arr) => {\n    const copy = arr.slice();\n    for (let i=copy.length-1;i>0;i--){\n      const j = Math.floor(rng()*(i+1));\n      const tmp = copy[i]; copy[i]=copy[j]; copy[j]=tmp;\n    }\n    return copy;\n  };\n}\n\nfunction initialSnapshot(){\n  return {\n    nodes: nodes.map(n => ({...n})),\n    edges: edges.map(e => ({...e})),\n    nodeState: nodes.reduce((acc,n)=>{ acc[n.id] = {status: 'unvisited', disc: null, fin: null, parent: null}; return acc; }, {}),\n    stack: [],\n    frames: [], // for recursion explicit display\n    time: 0,\n    action: 'initial',\n    foundTarget: null\n  };\n}\n\nfunction recordSnapshot(snapshots, snap){\n  snapshots.push(deepCloneState(snap));\n}\n\n// Generate history snapshots for DFS run according to options\nfunction generateDFSHistory(){\n  if (nodes.length === 0){\n    alert('No nodes in graph.');\n    return;\n  }\n  const impl = $('implSelect').value;\n  const startId = parseInt($('startNodeSelect').value);\n  if (isNaN(startId)) { alert('Select a start node.'); return; }\n  const targetIdRaw = $('targetNodeSelect').value;\n  const targetId = (targetIdRaw === '' || targetIdRaw === undefined) ? null : parseInt(targetIdRaw);\n  const order = $('neighborOrder').value;\n  const seed = $('seedInput').value || '1';\n  const depthLimit = $('depthLimit').value === '' ? null : parseInt($('depthLimit').value);\n  const stopOnTarget = $('stopOnTarget').checked;\n  const showT = $('showTimestamps').checked;\n\n  const adj = buildAdjMap();\n  const orderFn = neighborOrderFn(order, seed);\n\n  const snapshots = [];\n  let snap = initialSnapshot();\n  recordSnapshot(snapshots, snap);\n\n  const visited = {};\n  nodes.forEach(n => visited[n.id] = false);\n  let time = 0;\n  let found = null;\n  const maxDepth = depthLimit === null ? Infinity : depthLimit;\n\n  function snapshotAction(action, extra){\n    snap = {\n      nodes: nodes.map(n => ({...n})),\n      edges: edges.map(e => ({...e})),\n      nodeState: JSON.parse(JSON.stringify(snap.nodeState || {})),\n      stack: (snap.stack || []).slice(),\n      frames: (snap.frames || []).slice(),\n      time: time,\n      action: action,\n      extra: extra || null,\n      foundTarget: found\n    };\n    recordSnapshot(snapshots, snap);\n  }\n\n  if (impl === 'recursive'){\n    function rec(u, depth){\n      if (found && stopOnTarget) return;\n      if (depth > maxDepth){\n        snapshotAction('depth-limit-reached', {at:u, depth:depth});\n        return;\n      }\n      // discover u\n      visited[u] = true;\n      time++;\n      snap.nodeState[u] = snap.nodeState[u] || {};\n      snap.nodeState[u].status = 'discovered';\n      if (showT) snap.nodeState[u].disc = time;\n      snapshotAction('discover', {node:u, depth:depth});\n\n      // check target\n      if (targetId !== null && u === targetId){\n        found = u;\n        snapshotAction('found-target', {node:u});\n        if (stopOnTarget) return;\n      }\n\n      // iterate neighbors\n      const neigh = adj[u] ? orderFn(adj[u].slice()) : [];\n      for (let v of neigh){\n        snapshotAction('consider-edge', {from:u, to:v});\n        if (!visited[v]){\n          // set parent\n          snap.nodeState[v] = snap.nodeState[v] || {};\n          snap.nodeState[v].parent = u;\n          snapshotAction('call', {from:u, to:v});\n          rec(v, depth+1);\n          snapshotAction('return', {to:u, from:v});\n          if (found && stopOnTarget) return;\n        } else {\n          snapshotAction('skip-visited', {from:u, to:v});\n        }\n      }\n\n      // finish u\n      time++;\n      snap.nodeState[u].status = 'finished';\n      if (showT) snap.nodeState[u].fin = time;\n      snapshotAction('finish', {node:u});\n    }\n    rec(startId, 0);\n    // if not all nodes or stopping early, we may optionally run DFS for other components - add UI option? For now, record that unvisited remain.\n    snapshotAction('complete', {});\n  } else {\n    // iterative explicit stack with frames storing neighbor iterator index\n    const stack = [];\n    // push start\n    stack.push({node:startId, nextIndex:0, depth:0});\n    snapshotAction('push-start', {node:startId});\n    while (stack.length > 0){\n      const frame = stack[stack.length-1];\n      const u = frame.node;\n      if (!visited[u]){\n        visited[u] = true;\n        time++;\n        snap.nodeState[u] = snap.nodeState[u] || {};\n        snap.nodeState[u].status = 'discovered';\n        if (showT) snap.nodeState[u].disc = time;\n        snapshotAction('discover', {node:u, depth:frame.depth});\n        if (targetId !== null && u === targetId){\n          found = u;\n          snapshotAction('found-target', {node:u});\n          if (stopOnTarget) break;\n        }\n      }\n      const neigh = adj[u] ? orderFn(adj[u].slice()) : [];\n      if (frame.nextIndex < neigh.length){\n        const v = neigh[frame.nextIndex++];\n        snapshotAction('consider-edge', {from:u, to:v});\n        if (!visited[v]){\n          snap.nodeState[v] = snap.nodeState[v] || {};\n          snap.nodeState[v].parent = u;\n          stack.push({node:v, nextIndex:0, depth: frame.depth+1});\n          snapshotAction('push', {node:v, from:u});\n          if (targetId !== null && v === targetId){\n            found = v;\n            snapshotAction('found-target', {node:v});\n            if (stopOnTarget) break;\n          }\n        } else {\n          snapshotAction('skip-visited', {from:u, to:v});\n        }\n      } else {\n        // finish u\n        time++;\n        snap.nodeState[u].status = 'finished';\n        if (showT) snap.nodeState[u].fin = time;\n        snapshotAction('finish', {node:u});\n        stack.pop();\n        snapshotAction('pop', {node:u});\n      }\n    }\n    snapshotAction('complete', {});\n  }\n\n  // store snapshots in global history (replace)\n  history = snapshots;\n  historyIndex = 0;\n  renderHistory();\n  renderCurrentSnapshot();\n  alert('DFS run recorded: ' + history.length + ' snapshots');\n}\n\n// UI for generating, stepping, playing\n$('generateHistoryBtn').addEventListener('click', generateDFSHistory);\n\nfunction renderHistory(){\n  const hd = $('historyDisplay');\n  hd.textContent = history.map((h,i) => `${i}: ${h.action}${h.extra ? ' '+JSON.stringify(h.extra) : ''}${h.foundTarget ? ' [found]':''}`).join('\\n');\n}\n\nfunction renderCurrentSnapshot(){\n  const idx = historyIndex;\n  if (idx < 0 || idx >= history.length){\n    // nothing to render\n    $('nodeStatesDisplay').textContent = '';\n    $('stackDisplay').textContent = '';\n    $('foundPathDisplay').textContent = '';\n    // still update nodes drawing\n    // but we also want to overlay statuses as text near nodes\n    overlayNodeStates(null);\n    return;\n  }\n  const snap = history[idx];\n  overlayNodeStates(snap.nodeState);\n  // node states display\n  let nsText = '';\n  nodes.forEach(n => {\n    const st = (snap.nodeState && snap.nodeState[n.id]) || {status:'unvisited', disc:null, fin:null, parent:null};\n    nsText += `${n.label} (id:${n.id}) - status:${st.status} parent:${st.parent} disc:${st.disc} fin:${st.fin}\\n`;\n  });\n  $('nodeStatesDisplay').textContent = nsText;\n\n  // stack / frames show if present\n  let stackText = '';\n  if (snap.stack && snap.stack.length>0){\n    stackText += 'Explicit stack: ' + JSON.stringify(snap.stack) + '\\n';\n  }\n  if (snap.frames && snap.frames.length>0){\n    stackText += 'Frames: ' + JSON.stringify(snap.frames) + '\\n';\n  }\n  // Build parent pointer tree or stack from parent pointers\n  stackText += `Time: ${snap.time}\\nAction: ${snap.action}${snap.extra ? ' ' + JSON.stringify(snap.extra) : ''}\\n`;\n  $('stackDisplay').textContent = stackText;\n\n  // if found target, reconstruct path\n  if (snap.foundTarget !== null){\n    const p = reconstructPath(snap, parseInt(snap.foundTarget));\n    $('foundPathDisplay').textContent = `Found target ${snap.foundTarget}. Path: ${p.map(id=>nodeLabelById(id)).join(' -> ')}`;\n  } else {\n    $('foundPathDisplay').textContent = '';\n  }\n  renderHistory();\n  highlightCurrentAction(idx);\n}\n\nfunction overlayNodeStates(nodeState){\n  // Remove existing status labels then add new simple text nodes showing [U]/[D]/[F] next to node\n  const svg = $('canvas');\n  // remove previous status text nodes (we used data-status attribute)\n  const prev = svg.querySelectorAll('text[data-status]');\n  prev.forEach(t => t.parentNode.removeChild(t));\n  nodes.forEach(n => {\n    const st = nodeState && nodeState[n.id] ? nodeState[n.id].status : 'unvisited';\n    const txt = document.createElementNS('http://www.w3.org/2000/svg','text');\n    txt.setAttribute('x', n.x + 18);\n    txt.setAttribute('y', n.y - 12);\n    txt.setAttribute('font-size','10');\n    txt.setAttribute('data-status', n.id);\n    let label = '[U]';\n    if (st === 'discovered') label = '[D]';\n    if (st === 'finished') label = '[F]';\n    txt.textContent = label;\n    svg.appendChild(txt);\n    // show discovery/finish times if present\n    const stObj = nodeState && nodeState[n.id] ? nodeState[n.id] : null;\n    if (stObj && (stObj.disc || stObj.fin)){\n      const tt = document.createElementNS('http://www.w3.org/2000/svg','text');\n      tt.setAttribute('x', n.x + 18);\n      tt.setAttribute('y', n.y + 4);\n      tt.setAttribute('font-size','8');\n      tt.setAttribute('data-status', n.id);\n      tt.textContent = `d:${stObj.disc||'-'} f:${stObj.fin||'-'}`;\n      svg.appendChild(tt);\n    }\n  });\n}\n\nfunction nodeLabelById(id){\n  const n = nodes.find(x=>x.id===id);\n  return n ? n.label : ('id'+id);\n}\n\nfunction highlightCurrentAction(idx){\n  // Provide simple textual emphasis by prepending action detail in history display area\n  const hd = $('historyDisplay');\n  const lines = history.map((h,i) => `${i}: ${h.action}${h.extra ? ' '+JSON.stringify(h.extra) : ''}${h.foundTarget ? ' [found]':''}`);\n  if (idx >= 0 && idx < lines.length){\n    lines[idx] = '>> ' + lines[idx];\n  }\n  hd.textContent = lines.join('\\n');\n}\n\n// Step controls\n$('stepForwardBtn').addEventListener('click', () => {\n  if (history.length === 0) return;\n  if (historyIndex < history.length-1) historyIndex++;\n  renderCurrentSnapshot();\n});\n$('stepBackBtn').addEventListener('click', () => {\n  if (history.length === 0) return;\n  if (historyIndex > 0) historyIndex--;\n  renderCurrentSnapshot();\n});\n\n$('playPauseBtn').addEventListener('click', () => {\n  if (!playing){\n    startPlaying();\n  } else {\n    stopPlaying();\n  }\n});\n\n$('speedRange').addEventListener('input', ()=>{\n  $('speedValue').textContent = $('speedRange').value;\n});\n\nfunction startPlaying(){\n  if (history.length === 0) { alert('No recorded history. Generate a DFS run first.'); return; }\n  playing = true;\n  $('playPauseBtn').textContent = 'Pause';\n  const step = () => {\n    if (historyIndex < history.length-1){\n      historyIndex++;\n      renderCurrentSnapshot();\n    } else {\n      stopPlaying();\n    }\n  };\n  playTimer = setInterval(step, parseInt($('speedRange').value) || 600);\n}\n\nfunction stopPlaying(){\n  playing = false;\n  $('playPauseBtn').textContent = 'Play';\n  if (playTimer) clearInterval(playTimer);\n  playTimer = null;\n}\n\n// Run to completion\n$('runAllBtn').addEventListener('click', () => {\n  if (history.length === 0) { alert('No recorded run. Generate DFS history first.'); return; }\n  historyIndex = history.length-1;\n  renderCurrentSnapshot();\n});\n\n// Reset run state (clear discovered/finished but keep graph)\n$('resetRunBtn').addEventListener('click', () => {\n  history = [];\n  historyIndex = -1;\n  // clear node state overlay\n  overlayNodeStates(null);\n  renderHistory();\n  renderCurrentSnapshot();\n});\n\n// Clear recorded history\n$('clearHistoryBtn').addEventListener('click', () => {\n  history = [];\n  historyIndex = -1;\n  renderHistory();\n  renderCurrentSnapshot();\n});\n\n// Display adjacency list/matrix in alerts\n$('showAdjListBtn').addEventListener('click', () => {\n  alert($('adjListDisplay').textContent);\n});\n$('showAdjMatrixBtn').addEventListener('click', () => {\n  alert($('adjMatrixDisplay').textContent || 'No matrix to show');\n});\n$('showParentPointers').addEventListener('click', () => {\n  if (historyIndex < 0) { alert('No snapshot selected'); return; }\n  const snap = history[historyIndex];\n  const lines = [];\n  for (let id in snap.nodeState){\n    const p = snap.nodeState[id].parent;\n    lines.push(`id ${id} parent: ${p}`);\n  }\n  alert(lines.join('\\n'));\n});\n\n// Export history JSON\n$('exportHistoryBtn').addEventListener('click', () => {\n  if (history.length === 0){ alert('No history to export.'); return; }\n  const dataStr = \"data:text/json;charset=utf-8,\" + encodeURIComponent(JSON.stringify(history));\n  const a = document.createElement('a');\n  a.href = dataStr;\n  a.download = 'dfs_history.json';\n  a.click();\n});\n\n// Reconstruct path from parent pointers in a snapshot\nfunction reconstructPath(snap, targetId){\n  const path = [];\n  let cur = targetId;\n  const visited = new Set();\n  while (cur !== null && cur !== undefined && snap.nodeState && snap.nodeState[cur] && !visited.has(cur)){\n    path.push(cur);\n    visited.add(cur);\n    cur = snap.nodeState[cur].parent;\n  }\n  return path.reverse();\n}\n\n// Initial empty UI update\nupdateModeUI();\nupdateGraphUI();\nrenderHistory();\nrenderCurrentSnapshot();\n\n</script>\n</body>\n</html>"
