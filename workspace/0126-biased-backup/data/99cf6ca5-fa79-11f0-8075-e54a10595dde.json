    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Big-O Notation Explorer</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .control { margin: 10px 0; }\n    </style>\n</head>\n<body>\n    <h1>Big-O Notation Explorer</h1>\n\n    <div class=\"control\">\n        <label for=\"size\">Input Size (n):</label>\n        <input type=\"number\" id=\"size\" value=\"10\" min=\"1\" max=\"100\" />\n    </div>\n    \n    <div class=\"control\">\n        <label for=\"algorithm\">Select Algorithm:</label>\n        <select id=\"algorithm\">\n            <option value=\"constant\">O(1) - Constant</option>\n            <option value=\"linear\">O(n) - Linear</option>\n            <option value=\"quadratic\">O(n^2) - Quadratic</option>\n            <option value=\"logarithmic\">O(log n) - Logarithmic</option>\n            <option value=\"exponential\">O(2^n) - Exponential</option>\n        </select>\n    </div>\n\n    <div class=\"control\" id=\"operations\"></div>\n\n    <button id=\"run\">Run Algorithm</button>\n    <button id=\"reset\">Reset</button>\n\n    <div class=\"control\">\n        <h3>Algorithm Complexity:</h3>\n        <p id=\"complexity\"></p>\n        <h3>Execution Time (simulated):</h3>\n        <p id=\"execution_time\"></p>\n    </div>\n\n    <script>\n        const algorithmSelect = document.getElementById('algorithm');\n        const inputSize = document.getElementById('size');\n        const runButton = document.getElementById('run');\n        const resetButton = document.getElementById('reset');\n        const complexityDisplay = document.getElementById('complexity');\n        const executionTimeDisplay = document.getElementById('execution_time');\n        const operationsDisplay = document.getElementById('operations');\n\n        const algorithms = {\n            \"constant\": function(n) { return 1; },\n            \"linear\": function(n) { return n; },\n            \"quadratic\": function(n) { return n * n; },\n            \"logarithmic\": function(n) { return Math.log2(n); },\n            \"exponential\": function(n) { return Math.pow(2, n); }\n        };\n\n        function getAlgorithmComplexity() {\n            const selectedAlgorithm = algorithmSelect.value;\n            complexityDisplay.textContent = selectedAlgorithm.toUpperCase();\n            getOperations(selectedAlgorithm);\n        }\n\n        function getOperations(selectedAlgorithm) {\n            const n = parseInt(inputSize.value);\n            operationsDisplay.innerHTML = \"\";\n            let operationsCount = algorithms[selectedAlgorithm](n);\n            operationsDisplay.textContent = \"Operation Count: \" + operationsCount;\n        }\n\n        function runAlgorithm() {\n            const n = parseInt(inputSize.value);\n            const selectedAlgorithm = algorithmSelect.value;\n            let operationsCount = algorithms[selectedAlgorithm](n);\n            let executionSimulatedTime = operationsCount / 1000; // simulate execution time in ms\n            executionTimeDisplay.textContent = executionSimulatedTime + \" ms\";\n        }\n\n        function reset() {\n            inputSize.value = 10;\n            algorithmSelect.value = 'constant';\n            complexityDisplay.textContent = '';\n            executionTimeDisplay.textContent = '';\n            operationsDisplay.innerHTML = '';\n        }\n\n        algorithmSelect.addEventListener('change', getAlgorithmComplexity);\n        inputSize.addEventListener('input', getAlgorithmComplexity);\n        runButton.addEventListener('click', runAlgorithm);\n        resetButton.addEventListener('click', reset);\n\n        // Initialize\n        getAlgorithmComplexity();\n    </script>\n</body>\n</html>"
