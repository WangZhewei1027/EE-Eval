    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Two Pointers</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .button-container {\n            margin-bottom: 20px;\n        }\n        .button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            background-color: #4CAF50;\n            color: #fff;\n            font-size: 16px;\n            transition: background-color 0.3s ease;\n        }\n        .button:hover {\n            background-color: #3e8e41;\n        }\n        .input-field {\n            padding: 10px;\n            margin-bottom: 10px;\n        }\n        .input-field input {\n            padding: 5px;\n            border: none;\n            border-radius: 5px;\n            font-size: 16px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Two Pointers</h1>\n        <button class=\"button\" id=\"start-button\">Start</button>\n        <button class=\"button\" id=\"reset-button\">Reset</button>\n        <div class=\"button-container\">\n            <button class=\"button\" id=\"save-button\">Save</button>\n            <button class=\"button\" id=\"load-button\">Load</button>\n        </div>\n        <div class=\"button-container\">\n            <button class=\"button\" id=\"next-button\">Next</button>\n            <button class=\"button\" id=\"previous-button\">Previous</button>\n        </div>\n        <div class=\"input-field\">\n            <label for=\"point1\">Point 1:</label>\n            <input type=\"number\" id=\"point1\" value=\"0\">\n            <label for=\"point2\">Point 2:</label>\n            <input type=\"number\" id=\"point2\" value=\"0\">\n            <button id=\"add-point-button\">Add Point</button>\n        </div>\n        <div class=\"input-field\">\n            <label for=\"points\">Points:</label>\n            <input type=\"number\" id=\"points\" value=\"0\">\n            <button id=\"reset-points-button\">Reset Points</button>\n        </div>\n    </div>\n\n    <script>\n        let points = 0;\n        let currentPoint = 0;\n        let pointsArray = [];\n\n        document.getElementById('start-button').addEventListener('click', function() {\n            points = parseInt(document.getElementById('point1').value);\n            document.getElementById('point1').value = '';\n            document.getElementById('point2').value = '';\n            document.getElementById('next-button').disabled = false;\n            document.getElementById('previous-button').disabled = false;\n            document.getElementById('add-point-button').disabled = false;\n        });\n\n        document.getElementById('reset-button').addEventListener('click', function() {\n            points = 0;\n            document.getElementById('point1').value = '0';\n            document.getElementById('point2').value = '0';\n            document.getElementById('next-button').disabled = true;\n            document.getElementById('previous-button').disabled = true;\n            document.getElementById('add-point-button').disabled = true;\n        });\n\n        document.getElementById('save-button').addEventListener('click', function() {\n            pointsArray.push(points);\n            document.getElementById('points').value = pointsArray.join(',');\n            document.getElementById('reset-points-button').disabled = true;\n        });\n\n        document.getElementById('load-button').addEventListener('click', function() {\n            let points = document.getElementById('points').value.split(',');\n            pointsArray = points.map(Number);\n            points = parseInt(points[0]);\n            currentPoint = 0;\n            document.getElementById('point1').value = pointsArray[0];\n            document.getElementById('point2').value = pointsArray[1];\n            document.getElementById('next-button').disabled = false;\n            document.getElementById('previous-button').disabled = false;\n            document.getElementById('add-point-button').disabled = false;\n        });\n\n        document.getElementById('next-button').addEventListener('click', function() {\n            if (currentPoint < pointsArray.length - 1) {\n                currentPoint++;\n            } else {\n                document.getElementById('next-button').disabled = true;\n            }\n        });\n\n        document.getElementById('previous-button').addEventListener('click', function() {\n            if (currentPoint > 0) {\n                currentPoint--;\n            } else {\n                document.getElementById('previous-button').disabled = true;\n            }\n        });\n\n        document.getElementById('add-point-button').addEventListener('click', function() {\n            points++;\n            document.getElementById('point1').value = points;\n            document.getElementById('point2').value = points;\n            document.getElementById('next-button').disabled = false;\n            document.getElementById('previous-button').disabled = false;\n            document.getElementById('add-point-button').disabled = false;\n        });\n\n        document.getElementById('reset-points-button').addEventListener('click', function() {\n            points = 0;\n            document.getElementById('point1').value = '0';\n            document.getElementById('point2').value = '0';\n            document.getElementById('next-button').disabled = true;\n            document.getElementById('previous-button').disabled = true;\n            document.getElementById('add-point-button').disabled = true;\n        });\n    </script>\n</body>\n</html>"
