    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>OSI Model | Visual Exploration</title>\n    <style>\n        :root {\n            --primary: #4a6fa5;\n            --secondary: #166088;\n            --accent: #4fc3f7;\n            --background: #f8f9fa;\n            --text: #333;\n            --layer1: #e3f2fd;\n            --layer2: #bbdefb;\n            --layer3: #90caf9;\n            --layer4: #64b5f6;\n            --layer5: #42a5f5;\n            --layer6: #2196f3;\n            --layer7: #1e88e5;\n            --highlight: #ff5252;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;\n        }\n\n        body {\n            background-color: var(--background);\n            color: var(--text);\n            line-height: 1.6;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 1s ease-out forwards;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            color: var(--secondary);\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: #666;\n            font-weight: 300;\n            margin-bottom: 1.5rem;\n        }\n\n        .osi-container {\n            display: flex;\n            justify-content: center;\n            perspective: 1000px;\n            margin: 3rem 0;\n            position: relative;\n        }\n\n        .osi-layers {\n            display: flex;\n            flex-direction: column;\n            width: 80%;\n            max-width: 600px;\n            transform-style: preserve-3d;\n        }\n\n        .layer {\n            padding: 1.5rem 2rem;\n            margin-bottom: 1px;\n            color: white;\n            position: relative;\n            cursor: pointer;\n            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            transform-origin: left center;\n            border-radius: 4px;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n            opacity: 0;\n            transform: translateX(-50px);\n        }\n\n        .layer::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 5px;\n            height: 100%;\n            background: rgba(255, 255, 255, 0.3);\n        }\n\n        .layer:hover {\n            transform: translateX(10px) !important;\n        }\n\n        .layer.active {\n            transform: translateX(0) scale(1.02);\n            z-index: 10;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);\n        }\n\n        .layer h2 {\n            font-size: 1.5rem;\n            font-weight: 400;\n            margin-bottom: 0.5rem;\n            display: flex;\n            justify-content: space-between;\n        }\n\n        .layer p {\n            font-size: 1rem;\n            line-height: 1.6;\n            opacity: 0.9;\n            max-height: 0;\n            overflow: hidden;\n            transition: max-height 0.5s ease, opacity 0.3s ease;\n        }\n\n        .layer.active p {\n            max-height: 200px;\n            opacity: 1;\n        }\n\n        .layer-number {\n            font-weight: 700;\n            opacity: 0.8;\n        }\n\n        .layer-7 { background-color: var(--layer7); animation: slideIn 0.6s 0.1s ease-out forwards; }\n        .layer-6 { background-color: var(--layer6); animation: slideIn 0.6s 0.2s ease-out forwards; }\n        .layer-5 { background-color: var(--layer5); animation: slideIn 0.6s 0.3s ease-out forwards; }\n        .layer-4 { background-color: var(--layer4); animation: slideIn 0.6s 0.4s ease-out forwards; }\n        .layer-3 { background-color: var(--layer3); animation: slideIn 0.6s 0.5s ease-out forwards; }\n        .layer-2 { background-color: var(--layer2); animation: slideIn 0.6s 0.6s ease-out forwards; }\n        .layer-1 { background-color: var(--layer1); color: var(--text); animation: slideIn 0.6s 0.7s ease-out forwards; }\n\n        .data-flow {\n            position: absolute;\n            right: 10%;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 300px;\n            height: 500px;\n            display: flex;\n            flex-direction: column;\n            justify-content: space-between;\n            align-items: center;\n            opacity: 0;\n            transition: opacity 0.5s ease;\n        }\n\n        .data-flow.active {\n            opacity: 1;\n        }\n\n        .flow-arrow {\n            width: 0; \n            height: 0; \n            border-left: 15px solid transparent;\n            border-right: 15px solid transparent;\n            border-top: 25px solid var(--accent);\n            margin: 10px 0;\n            position: relative;\n            opacity: 0;\n            transform: translateY(20px);\n            transition: all 0.4s ease;\n        }\n\n        .flow-arrow::after {\n            content: '';\n            position: absolute;\n            width: 30px;\n            height: 60px;\n            background: linear-gradient(to bottom, rgba(79, 195, 247, 0.2), transparent);\n            top: -85px;\n            left: -15px;\n            border-radius: 50% 50% 0 0;\n        }\n\n        .flow-text {\n            font-size: 0.9rem;\n            color: var(--secondary);\n            text-align: center;\n            width: 120px;\n            padding: 0.5rem;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);\n            opacity: 0;\n            transform: scale(0.8);\n            transition: all 0.4s ease;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 2rem;\n            gap: 1rem;\n        }\n\n        .btn {\n            padding: 0.8rem 1.5rem;\n            background: var(--primary);\n            color: white;\n            border: none;\n            border-radius: 30px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);\n            outline: none;\n        }\n\n        .btn:hover {\n            background: var(--secondary);\n            transform: translateY(-2px);\n            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);\n        }\n\n        .btn:active {\n            transform: translateY(0);\n        }\n\n        .explanation {\n            max-width: 800px;\n            margin: 3rem auto;\n            text-align: center;\n            padding: 2rem;\n            background: white;\n            border-radius: 10px;\n            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s 1.5s ease-out forwards;\n        }\n\n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes slideIn {\n            to {\n                opacity: 1;\n                transform: translateX(0);\n            }\n        }\n\n        .highlight {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            background: linear-gradient(90deg, rgba(255,255,255,0.1), rgba(255,255,255,0.3), rgba(255,255,255,0.1));\n            transform: translateX(-100%);\n        }\n\n        .layer:hover .highlight {\n            animation: shine 0.8s ease;\n        }\n\n        @keyframes shine {\n            100% {\n                transform: translateX(100%);\n            }\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            color: #666;\n            font-size: 0.9rem;\n            opacity: 0;\n            animation: fadeIn 1s 2s ease-out forwards;\n        }\n\n        @media (max-width: 900px) {\n            .osi-container {\n                flex-direction: column;\n                align-items: center;\n            }\n            \n            .data-flow {\n                position: relative;\n                right: auto;\n                top: auto;\n                transform: none;\n                margin: 2rem 0;\n                height: auto;\n                flex-direction: row;\n                width: 80%;\n                flex-wrap: wrap;\n                justify-content: center;\n            }\n            \n            .flow-arrow {\n                transform: rotate(90deg);\n                margin: 0 10px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>OSI Model</h1>\n            <p class=\"subtitle\">The 7 Layers of Network Communication</p>\n        </header>\n\n        <div class=\"osi-container\">\n            <div class=\"osi-layers\">\n                <div class=\"layer layer-7\" data-layer=\"7\">\n                    <h2><span>Application</span> <span class=\"layer-number\">Layer 7</span></h2>\n                    <p>Provides network services directly to end-user applications. This layer includes protocols like HTTP, FTP, SMTP, and DNS that enable user applications to access network services.</p>\n                    <div class=\"highlight\"></div>\n                </div>\n                <div class=\"layer layer-6\" data-layer=\"6\">\n                    <h2><span>Presentation</span> <span class=\"layer-number\">Layer 6</span></h2>\n                    <p>Responsible for data translation, encryption, and compression. This layer ensures that data sent from the application layer of one system can be read by the application layer of another system.</p>\n                    <div class=\"highlight\"></div>\n                </div>\n                <div class=\"layer layer-5\" data-layer=\"5\">\n                    <h2><span>Session</span> <span class=\"layer-number\">Layer 5</span></h2>\n                    <p>Establishes, manages, and terminates connections between applications. This layer controls the dialogues (connections) between computers, managing who can transmit data at a certain time and for how long.</p>\n                    <div class=\"highlight\"></div>\n                </div>\n                <div class=\"layer layer-4\" data-layer=\"4\">\n                    <h2><span>Transport</span> <span class=\"layer-number\">Layer 4</span></h2>\n                    <p>Provides reliable data transfer services to the upper layers. This layer includes protocols like TCP and UDP, which handle end-to-end communication, error recovery, and flow control.</p>\n                    <div class=\"highlight\"></div>\n                </div>\n                <div class=\"layer layer-3\" data-layer=\"3\">\n                    <h2><span>Network</span> <span class=\"layer-number\">Layer 3</span></h2>\n                    <p>Handles logical addressing and routing of data packets. This layer determines how data is sent from one network to another through devices like routers using IP addresses.</p>\n                    <div class=\"highlight\"></div>\n                </div>\n                <div class=\"layer layer-2\" data-layer=\"2\">\n                    <h2><span>Data Link</span> <span class=\"layer-number\">Layer 2</span></h2>\n                    <p>Provides node-to-node data transfer and error detection. This layer is divided into two sublayers: MAC (Media Access Control) and LLC (Logical Link Control), handling physical addressing and topology.</p>\n                    <div class=\"highlight\"></div>\n                </div>\n                <div class=\"layer layer-1\" data-layer=\"1\">\n                    <h2><span>Physical</span> <span class=\"layer-number\">Layer 1</span></h2>\n                    <p>Defines the physical characteristics of the network interface. This layer includes the cables, connectors, and electrical specifications that transmit raw bit streams over the physical medium.</p>\n                    <div class=\"highlight\"></div>\n                </div>\n            </div>\n\n            <div class=\"data-flow\">\n                <div class=\"flow-text\">User Data</div>\n                <div class=\"flow-arrow\"></div>\n                <div class=\"flow-text\">Application Header</div>\n                <div class=\"flow-arrow\"></div>\n                <div class=\"flow-text\">Presentation Header</div>\n                <div class=\"flow-arrow\"></div>\n                <div class=\"flow-text\">Session Header</div>\n                <div class=\"flow-arrow\"></div>\n                <div class=\"flow-text\">Transport Header</div>\n                <div class=\"flow-arrow\"></div>\n                <div class=\"flow-text\">Network Header</div>\n                <div class=\"flow-arrow\"></div>\n                <div class=\"flow-text\">Data Link Header & Trailer</div>\n                <div class=\"flow-arrow\"></div>\n                <div class=\"flow-text\">Bits</div>\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button class=\"btn\" id=\"showFlow\">Show Data Flow</button>\n            <button class=\"btn\" id=\"resetView\">Reset View</button>\n        </div>\n\n        <div class=\"explanation\">\n            <h3>How the OSI Model Works</h3>\n            <p>The Open Systems Interconnection (OSI) model is a conceptual framework that describes the functions of a networking system. Data flows downward through the layers when being sent from a source, with each layer adding its own header information. When received, the data flows upward through the layers with each layer stripping off its corresponding header information until the original user data is delivered to the destination application.</p>\n        </div>\n\n        <footer>\n            <p>Visual representation of the OSI (Open Systems Interconnection) model</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const layers = document.querySelectorAll('.layer');\n            const dataFlow = document.querySelector('.data-flow');\n            const flowArrows = document.querySelectorAll('.flow-arrow');\n            const flowTexts = document.querySelectorAll('.flow-text');\n            const showFlowBtn = document.getElementById('showFlow');\n            const resetBtn = document.getElementById('resetView');\n\n            // Layer click interaction\n            layers.forEach(layer => {\n                layer.addEventListener('click', function() {\n                    layers.forEach(l => l.classList.remove('active'));\n                    this.classList.add('active');\n                    \n                    // Highlight corresponding flow element\n                    const layerNum = this.dataset.layer;\n                    highlightFlowElement(8 - layerNum); // Reverse order\n                });\n            });\n\n            // Show data flow animation\n            showFlowBtn.addEventListener('click', function() {\n                dataFlow.classList.add('active');\n                \n                // Animate arrows and text\n                flowArrows.forEach((arrow, index) => {\n                    setTimeout(() => {\n                        arrow.style.opacity = '1';\n                        arrow.style.transform = 'translateY(0)';\n                    }, index * 200);\n                });\n                \n                flowTexts.forEach((text, index) => {\n                    setTimeout(() => {\n                        text.style.opacity = '1';\n                        text.style.transform = 'scale(1)';\n                    }, index * 200 + 100);\n                });\n            });\n\n            // Reset view\n            resetBtn.addEventListener('click', function() {\n                layers.forEach(l => l.classList.remove('active'));\n                dataFlow.classList.remove('active');\n                \n                flowArrows.forEach(arrow => {\n                    arrow.style.opacity = '0';\n                    arrow.style.transform = 'translateY(20px)';\n                });\n                \n                flowTexts.forEach(text => {\n                    text.style.opacity = '0';\n                    text.style.transform = 'scale(0.8)';\n                });\n            });\n\n            function highlightFlowElement(index) {\n                // Reset all flow elements\n                flowTexts.forEach(text => {\n                    text.style.backgroundColor = 'white';\n                    text.style.color = 'var(--secondary)';\n                });\n                \n                // Highlight the selected one\n                if (flowTexts[index]) {\n                    flowTexts[index].style.backgroundColor = 'var(--highlight)';\n                    flowTexts[index].style.color = 'white';\n                }\n            }\n        });\n    </script>\n</body>\n</html>"
