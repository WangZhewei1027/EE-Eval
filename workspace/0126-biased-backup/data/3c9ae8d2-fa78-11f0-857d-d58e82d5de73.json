    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Integration Testing — A Visual Journey</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter&display=swap');\n\n  /* Root colors for elegant, professional palette */\n  :root {\n    --color-bg: #111827;\n    --color-primary: #4f46e5;\n    --color-accent: #38bdf8;\n    --color-white: #f9fafb;\n    --color-gray-light: #6b7280;\n    --color-gray-dark: #374151;\n    --color-success: #10b981;\n    --color-warning: #f59e0b;\n  }\n\n  /* Reset and base */\n  * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n  }\n\n  body {\n    background: radial-gradient(circle at center, #1e293b 0%, #111827 80%);\n    font-family: 'Inter', sans-serif;\n    color: var(--color-white);\n    min-height: 100vh;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 2rem 5rem;\n    user-select: none;\n  }\n\n  header {\n    text-align: center;\n    margin-bottom: 3rem;\n    max-width: 720px;\n  }\n\n  header h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.25rem;\n    line-height: 1.1;\n    color: var(--color-primary);\n    letter-spacing: -0.02em;\n    text-shadow:\n      0 0 10px var(--color-primary),\n      0 0 20px var(--color-accent);\n    margin-bottom: 0.5rem;\n    transition: color 0.5s ease;\n  }\n\n  header p {\n    font-size: 1.125rem;\n    color: var(--color-gray-light);\n    max-width: 480px;\n    margin: 0 auto;\n    line-height: 1.6;\n    filter: drop-shadow(0 0 3px rgba(0,0,0,0.4));\n    user-select: text;\n  }\n\n  main {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n    gap: 2.5rem;\n    width: 100%;\n    max-width: 1280px;\n  }\n\n  .card {\n    background: linear-gradient(135deg, #1e293b 0%, #111827 95%);\n    border-radius: 1rem;\n    box-shadow:\n      inset 0 0 15px #4f46e5,\n      0 10px 20px rgba(79, 70, 229, 0.4);\n    padding: 2rem 2.5rem;\n    position: relative;\n    overflow: visible;\n    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1), box-shadow 0.4s ease;\n    will-change: transform, box-shadow;\n  }\n\n  .card:hover {\n    transform: translateY(-12px) scale(1.04);\n    box-shadow:\n      inset 0 0 30px #3b82f6,\n      0 20px 30px rgba(59, 130, 246, 0.5);\n    z-index: 10;\n  }\n\n  .card svg {\n    display: block;\n    margin: 0 auto 1.25rem;\n    width: 70px;\n    height: 70px;\n    stroke: var(--color-accent);\n    stroke-width: 2.5;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    fill: none;\n    filter:\n      drop-shadow(0 0 4px var(--color-accent));\n  }\n\n  .card h2 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 1.75rem;\n    color: var(--color-primary);\n    margin-bottom: 0.75rem;\n    text-align: center;\n  }\n\n  .card p {\n    font-size: 1rem;\n    line-height: 1.45;\n    color: var(--color-gray-light);\n    text-align: center;\n    user-select: none;\n  }\n\n  /* Complex integration flow diagram - subtle and elegant */\n  .diagram {\n    position: relative;\n    margin: 4rem auto 0;\n    max-width: 960px;\n    width: 100%;\n    height: 320px;\n  }\n\n  /* Nodes */\n  .node {\n    position: absolute;\n    background: linear-gradient(145deg, #4f46e5, #3b82f6);\n    border-radius: 1rem;\n    width: 140px;\n    height: 140px;\n    box-shadow:\n      0 8px 25px rgba(79, 70, 229, 0.5),\n      inset 0 0 15px #60a5fa;\n    color: var(--color-white);\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 1.2rem;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n    padding: 1.5rem 1rem;\n    transition: box-shadow 0.3s ease;\n    user-select: none;\n    outline-offset: 6px;\n  }\n\n  .node.is-active {\n    box-shadow:\n      0 8px 40px #60a5fa,\n      inset 0 0 28px #93c5fd,\n      0 0 8px #bfdbfe;\n  }\n\n  /* Positions of nodes for integration testing concept */\n  .node.requirements {\n    top: 0;\n    left: 50%;\n    transform: translateX(-50%);\n  }\n\n  .node.unit-tests {\n    top: 160px;\n    left: 12%;\n  }\n  .node.integration-tests {\n    top: 160px;\n    left: 50%;\n    transform: translateX(-50%);\n  }\n  .node.system-tests {\n    top: 160px;\n    right: 12%;\n  }\n\n  .node.deployment {\n    bottom: 0;\n    left: 50%;\n    transform: translateX(-50%);\n  }\n\n  /* Connecting lines */\n  svg.flow-lines {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    overflow: visible;\n  }\n\n  path.flow-path {\n    fill: none;\n    stroke: var(--color-accent);\n    stroke-width: 3;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 8px var(--color-accent));\n    transition: stroke-dashoffset 1.2s cubic-bezier(0.4,0,0.2,1);\n  }\n\n  /* Buttons: minimal but elegant */\n  .controls {\n    margin-top: 4rem;\n    display: flex;\n    gap: 1.75rem;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n\n  button {\n    background: linear-gradient(145deg, #3b82f6, #2563eb);\n    border-radius: 1.25rem;\n    padding: 0.75rem 2.2rem;\n    font-size: 1rem;\n    font-weight: 600;\n    font-family: 'Inter', sans-serif;\n    letter-spacing: 0.03em;\n    color: var(--color-white);\n    border: none;\n    cursor: pointer;\n    box-shadow:\n      0 6px 15px rgba(37, 99, 235, 0.7),\n      inset 0 -3px 8px rgba(147, 197, 253, 0.8);\n    transition:\n      background 0.45s ease,\n      box-shadow 0.4s ease,\n      transform 0.22s ease;\n    user-select: none;\n  }\n  button:focus-visible {\n    outline-offset: 3px;\n    outline: 3px solid var(--color-accent);\n  }\n  button:hover {\n    background: linear-gradient(145deg, #2563eb, #3b82f6);\n    box-shadow:\n      0 12px 24px rgba(37, 99, 235, 0.9),\n      inset 0 -4px 10px rgba(147, 197, 253, 0.9);\n    transform: translateY(-2px);\n  }\n  button:active {\n    transform: translateY(0);\n    box-shadow:\n      0 4px 10px rgba(37, 99, 235, 0.7),\n      inset 0 -2px 6px rgba(147, 197, 253, 0.8);\n  }\n\n  /* Tooltip style for nodes */\n  .tooltip {\n    position: absolute;\n    background: rgba(59, 130, 246, 0.9);\n    color: var(--color-white);\n    font-size: 0.875rem;\n    font-weight: 500;\n    padding: 0.4rem 0.85rem;\n    border-radius: 0.6rem;\n    pointer-events: none;\n    white-space: nowrap;\n    filter: drop-shadow(0 0 5px rgba(0,0,0,0.6));\n    opacity: 0;\n    transform: translateY(-5px);\n    transition: opacity 0.25s ease, transform 0.25s ease;\n    user-select: none;\n  }\n  .tooltip.visible {\n    opacity: 1;\n    transform: translateY(-12px);\n  }\n\n  /* Title fade and glow animation */\n  @keyframes glowPulse {\n    0%, 100% {\n      text-shadow:\n        0 0 8px var(--color-primary),\n        0 0 15px var(--color-accent);\n      color: var(--color-primary);\n    }\n    50% {\n      text-shadow:\n        0 0 18px var(--color-accent),\n        0 0 30px var(--color-primary);\n      color: var(--color-accent);\n    }\n  }\n\n  header h1 {\n    animation: glowPulse 5s ease-in-out infinite;\n  }\n\n</style>\n</head>\n<body>\n  <header role=\"banner\">\n    <h1>Integration Testing</h1>\n    <p>Explore the interplay between individual software components — bringing them together to verify harmonious functioning, reliability, and performance.</p>\n  </header>\n\n  <main role=\"main\" aria-label=\"Integration Testing Visualization\">  \n    <!-- Cards expounding core testing types -->\n    <section aria-label=\"Testing Types Overview\" style=\"grid-column: 1 / -1; display:flex; gap: 1.5rem; flex-wrap: wrap; justify-content: center;\">\n      <article class=\"card\" tabindex=\"0\" aria-describedby=\"desc-unit-tests\" aria-label=\"Unit Tests\">\n        <svg aria-hidden=\"true\" viewBox=\"0 0 64 64\" stroke=\"currentColor\" xmlns=\"http://www.w3.org/2000/svg\">\n          <circle cx=\"32\" cy=\"32\" r=\"30\" />\n          <path d=\"M20 32l8 8 16-16\" />\n        </svg>\n        <h2>Unit Tests</h2>\n        <p id=\"desc-unit-tests\">Verifying smallest components in isolation.</p>\n      </article>\n      <article class=\"card is-active\" tabindex=\"0\" aria-describedby=\"desc-integration-tests\" aria-label=\"Integration Tests\">\n        <svg aria-hidden=\"true\" viewBox=\"0 0 64 64\" stroke=\"currentColor\" xmlns=\"http://www.w3.org/2000/svg\">\n          <circle cx=\"12\" cy=\"24\" r=\"8\"/>\n          <circle cx=\"32\" cy=\"40\" r=\"12\"/>\n          <circle cx=\"52\" cy=\"24\" r=\"8\"/>\n          <path d=\"M20 29l7 5M44 29l-7 5\" />\n        </svg>\n        <h2>Integration Tests</h2>\n        <p id=\"desc-integration-tests\">Ensuring multiple components work seamlessly together.</p>\n      </article>\n      <article class=\"card\" tabindex=\"0\" aria-describedby=\"desc-system-tests\" aria-label=\"System Tests\">\n        <svg aria-hidden=\"true\" viewBox=\"0 0 64 64\" stroke=\"currentColor\" xmlns=\"http://www.w3.org/2000/svg\">\n          <rect x=\"12\" y=\"18\" width=\"40\" height=\"28\" rx=\"7\"/>\n          <path d=\"M12 24h40M32 18v28\" />\n        </svg>\n        <h2>System Tests</h2>\n        <p id=\"desc-system-tests\">Testing the entire application environment end-to-end.</p>\n      </article>\n    </section>\n\n    <!-- Integration Testing Flow Diagram -->\n    <section aria-label=\"Integration Testing Workflow Diagram\" class=\"diagram\" aria-live=\"polite\">\n      <div class=\"node requirements\" role=\"img\" aria-label=\"Requirements Gathering Node\" tabindex=\"0\" data-tooltip=\"Requirements Gathering — Foundations\">\n        Requirements\n      </div>\n      <div class=\"node unit-tests\" role=\"img\" aria-label=\"Unit Testing Node\" tabindex=\"0\" data-tooltip=\"Unit Testing — Components Validated\">\n        Unit Tests\n      </div>\n      <div class=\"node integration-tests is-active\" role=\"img\" aria-label=\"Integration Testing Node\" tabindex=\"0\" data-tooltip=\"Integration Testing — Components Combined\">\n        Integration Tests\n      </div>\n      <div class=\"node system-tests\" role=\"img\" aria-label=\"System Testing Node\" tabindex=\"0\" data-tooltip=\"System Testing — Full System Validated\">\n        System Tests\n      </div>\n      <div class=\"node deployment\" role=\"img\" aria-label=\"Deployment Node\" tabindex=\"0\" data-tooltip=\"Deployment — Delivering the Product\">\n        Deployment\n      </div>\n\n      <!-- SVG Flow Lines -->\n      <svg class=\"flow-lines\" aria-hidden=\"true\" viewBox=\"0 0 960 320\" preserveAspectRatio=\"none\">\n        <!-- Requirements to Unit Tests -->\n        <path id=\"path1\" class=\"flow-path\" d=\"M480 20 L180 160\" stroke-dasharray=\"300\" stroke-dashoffset=\"300\"/>\n        <!-- Requirements to Integration Tests -->\n        <path id=\"path2\" class=\"flow-path\" d=\"M480 20 L480 160\" stroke-dasharray=\"200\" stroke-dashoffset=\"200\"/>\n        <!-- Requirements to System Tests -->\n        <path id=\"path3\" class=\"flow-path\" d=\"M480 20 L780 160\" stroke-dasharray=\"300\" stroke-dashoffset=\"300\"/>\n        <!-- Unit Tests to Integration Tests -->\n        <path id=\"path4\" class=\"flow-path\" d=\"M180 160 Q320 190 480 160\" stroke-dasharray=\"220\" stroke-dashoffset=\"220\"/>\n        <!-- Integration Tests to System Tests -->\n        <path id=\"path5\" class=\"flow-path\" d=\"M480 160 Q640 190 780 160\" stroke-dasharray=\"220\" stroke-dashoffset=\"220\"/>\n        <!-- System Tests to Deployment -->\n        <path id=\"path6\" class=\"flow-path\" d=\"M780 160 L480 300\" stroke-dasharray=\"220\" stroke-dashoffset=\"220\"/>\n        <!-- Integration Tests to Deployment -->\n        <path id=\"path7\" class=\"flow-path\" d=\"M480 160 L480 300\" stroke-dasharray=\"160\" stroke-dashoffset=\"160\"/>\n      </svg>\n    </section>\n\n    <div class=\"controls\" aria-label=\"Integration testing controls\">\n      <button id=\"animateBtn\" type=\"button\" aria-pressed=\"false\" aria-label=\"Animate Integration Flow Pathlines\">Animate Flow</button>\n      <button id=\"resetBtn\" type=\"button\" aria-label=\"Reset Integration Flow Pathlines\">Reset</button>\n    </div>\n  </main>\n\n  <div id=\"tooltip\" class=\"tooltip\" role=\"tooltip\"></div>\n\n<script>\n  (() => {\n    const paths = [\n      document.getElementById('path1'),\n      document.getElementById('path2'),\n      document.getElementById('path3'),\n      document.getElementById('path4'),\n      document.getElementById('path5'),\n      document.getElementById('path6'),\n      document.getElementById('path7'),\n    ];\n\n    // Animate paths by stroke-dashoffset from full offset to 0\n    function animatePaths() {\n      paths.forEach((p, i) => {\n        const length = p.getTotalLength();\n        p.style.transition = 'none';\n        p.style.strokeDashoffset = length;\n        // Trigger reflow for transition to apply\n        // eslint-disable-next-line no-unused-expressions\n        p.getBoundingClientRect();\n        p.style.transition = 'stroke-dashoffset 1.5s ease-out';\n        setTimeout(() => {\n          p.style.strokeDashoffset = '0';\n        }, i * 250);\n      });\n    }\n\n    function resetPaths() {\n      paths.forEach((p) => {\n        const length = p.getTotalLength();\n        p.style.transition = 'stroke-dashoffset 0.5s ease-in';\n        p.style.strokeDashoffset = length;\n      });\n    }\n\n    const animateBtn = document.getElementById('animateBtn');\n    const resetBtn = document.getElementById('resetBtn');\n\n    animateBtn.addEventListener('click', () => {\n      animateBtn.setAttribute('aria-pressed', 'true');\n      animatePaths();\n    });\n    resetBtn.addEventListener('click', () => {\n      resetPaths();\n      animateBtn.setAttribute('aria-pressed', 'false');\n    });\n\n    // TOOLTIP LOGIC\n    const tooltip = document.getElementById('tooltip');\n    const nodes = document.querySelectorAll('.node');\n\n    nodes.forEach(node => {\n      node.addEventListener('mouseenter', event => {\n        const tip = event.currentTarget.dataset.tooltip;\n        if(tip) {\n          tooltip.textContent = tip;\n          const rect = event.currentTarget.getBoundingClientRect();\n          const scrollTop = window.pageYOffset || document.documentElement.scrollTop;\n          const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;\n          const top = rect.top + scrollTop - 42;\n          const left = rect.left + scrollLeft + rect.width / 2;\n          tooltip.style.top = `${top}px`;\n          tooltip.style.left = `${left}px`;\n          tooltip.classList.add('visible');\n        }\n      });\n      node.addEventListener('mouseleave', () => {\n        tooltip.classList.remove('visible');\n      });\n      // Keyboard accessibility: show tooltip on focus\n      node.addEventListener('focus', (event) => {\n        const tip = event.currentTarget.dataset.tooltip;\n        if(tip) {\n          tooltip.textContent = tip;\n          const rect = event.currentTarget.getBoundingClientRect();\n          const scrollTop = window.pageYOffset || document.documentElement.scrollTop;\n          const scrollLeft = window.pageXOffset || document.documentElement.scrollLeft;\n          const top = rect.top + scrollTop - 42;\n          const left = rect.left + scrollLeft + rect.width / 2;\n          tooltip.style.top = `${top}px`;\n          tooltip.style.left = `${left}px`;\n          tooltip.classList.add('visible');\n        }\n      });\n      node.addEventListener('blur', () => {\n        tooltip.classList.remove('visible');\n      });\n    });\n\n    // Initiate with all paths reset\n    resetPaths();\n\n  })();\n</script>\n</body>\n</html>"
