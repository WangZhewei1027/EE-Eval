    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Radix Sort Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #arrayDisplay { margin: 10px 0; }\n        #controls { margin-bottom: 10px; }\n    </style>\n</head>\n<body>\n    <h1>Radix Sort Interactive Demo</h1>\n    <div id=\"controls\">\n        <label for=\"arrayInput\">Enter array (comma-separated): </label>\n        <input type=\"text\" id=\"arrayInput\" value=\"170,45,75,90,802,24,2,66\">\n        <button id=\"sortButton\">Sort</button>\n        <button id=\"resetButton\">Reset</button>\n        <label for=\"delaySlider\">Delay (ms): </label>\n        <input type=\"range\" id=\"delaySlider\" min=\"50\" max=\"1000\" value=\"300\">\n        <span id=\"delayValue\">300</span>\n    </div>\n    <div id=\"arrayDisplay\"></div>\n    <script>\n        let array = [];\n        let delay = 300;\n\n        document.getElementById('sortButton').addEventListener('click', () => {\n            const input = document.getElementById('arrayInput').value;\n            array = input.split(',').map(Number);\n            delay = parseInt(document.getElementById('delaySlider').value);\n            document.getElementById('arrayDisplay').innerText = `Array: ${array.join(\", \")}`;\n            radixSort(array);\n        });\n\n        document.getElementById('delaySlider').addEventListener('input', (event) => {\n            delay = event.target.value;\n            document.getElementById('delayValue').innerText = delay;\n        });\n\n        document.getElementById('resetButton').addEventListener('click', () => {\n            array = [];\n            document.getElementById('arrayInput').value = '';\n            document.getElementById('arrayDisplay').innerText = '';\n        });\n\n        async function radixSort(arr) {\n            const max = Math.max(...arr);\n            const digits = max.toString().length;\n\n            for (let i = 0; i < digits; i++) {\n                await countingSort(arr, i);\n                document.getElementById('arrayDisplay').innerText = `Array: ${arr.join(\", \")}`;\n            }\n        }\n\n        async function countingSort(arr, exp) {\n            const output = new Array(arr.length);\n            const count = new Array(10).fill(0);\n\n            for (let i = 0; i < arr.length; i++) {\n                const index = Math.floor(arr[i] / Math.pow(10, exp)) % 10;\n                count[index]++;\n            }\n\n            for (let i = 1; i < count.length; i++) {\n                count[i] += count[i - 1];\n            }\n\n            for (let i = arr.length - 1; i >= 0; i--) {\n                const index = Math.floor(arr[i] / Math.pow(10, exp)) % 10;\n                output[count[index] - 1] = arr[i];\n                count[index]--;\n                await new Promise(resolve => setTimeout(resolve, delay));\n            }\n\n            for (let i = 0; i < arr.length; i++) {\n                arr[i] = output[i];\n            }\n        }\n    </script>\n</body>\n</html>"
