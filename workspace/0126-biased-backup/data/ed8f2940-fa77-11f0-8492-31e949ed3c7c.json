n            font-size: 1em;\n            line-height: 1.5;\n        }\n\n        .button-container {\n            text-align: center;\n            padding: 20px;\n        }\n\n        .info-button {\n            background-color: #42a5f5;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            padding: 15px 25px;\n            font-size: 1em;\n            cursor: pointer;\n            transition: background-color 0.3s;\n        }\n\n        .info-button:hover {\n            background-color: #1e88e5;\n        }\n\n        @media (max-width: 600px) {\n            .header h1 {\n                font-size: 2em;\n            }\n            .properties {\n                flex-direction: column;\n                align-items: center;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>ACID Properties</h1>\n            <p>A Concept in Transaction Management</p>\n        </div>\n        <div class=\"properties\">\n            <div class=\"property-card\">\n                <h2>Atomicity</h2>\n                <p>Ensures that all operations within a transaction are completed; if not, the transaction is aborted.</p>\n            </div>\n            <div class=\"property-card\">\n                <h2>Consistency</h2>\n                <p>Guarantees that a transaction will bring the database from one valid state to another.</p>\n            </div>\n            <div class=\"property-card\">\n                <h2>Isolation</h2>\n                <p>Allows transactions to operate independently without interference, ensuring correct results.</p>\n            </div>\n            <div class=\"property-card\">\n                <h2>Durability</h2>\n                <p>Once a transaction has been committed, it will remain so, even in the event of a system failure.</p>\n            </div>\n        </div>\n        <div class=\"button-container\">\n            <button class=\"info-button\" onclick=\"showAlert()\">Learn More</button>\n        </div>\n    </div>\n\n    <script>\n        function showAlert() {\n            alert('ACID Properties ensure reliable processing of database transactions.\\n\\nLearn more about database management systems for deeper insights.');\n        }\n    </script>\n</body>\n</html>"
