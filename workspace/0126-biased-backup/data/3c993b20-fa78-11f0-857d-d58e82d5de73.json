    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Deadlock Concept — Visualized</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n\n  /* Root and Reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0; padding: 0;\n    background: linear-gradient(135deg, #1e1f28, #2b3042);\n    font-family: 'Montserrat', sans-serif;\n    color: #e0e0e0;\n    overflow-x: hidden;\n  }\n\n  /* Container */\n  .container {\n    max-width: 900px;\n    margin: 3rem auto 5rem auto;\n    padding: 0 1.5rem;\n    text-align: center;\n  }\n\n  /* Title */\n  h1 {\n    font-weight: 700;\n    font-size: 3.5rem;\n    letter-spacing: 0.07em;\n    color: #c9d1ff;\n    margin-bottom: 0.25rem;\n    text-shadow:\n      0 0 12px #5964ff88,\n      0 0 35px #3949abcc;\n  }\n\n  /* Subtitle */\n  p.subtitle {\n    font-weight: 400;\n    font-size: 1.2rem;\n    color: #a5a5c7;\n    margin-bottom: 4rem;\n    letter-spacing: 0.04em;\n    user-select: none;\n  }\n\n  /* Visualization area */\n  .viz {\n    position: relative;\n    width: 820px;\n    height: 440px;\n    margin: 0 auto;\n    background: radial-gradient(circle at center, #2b3042 0%, #171920 95%);\n    border-radius: 24px;\n    box-shadow:\n      inset 0 0 32px #3949ab88,\n      0 20px 50px #14182fbb;\n    overflow: visible;\n  }\n\n  /* Legend Color Variables */\n  :root {\n    --color-process: #5e92f3; /* Blue */\n    --color-resource: #f48fb1; /* Pink */\n    --color-request: #fdd835; /* Yellow */\n    --color-hold: #4db6ac; /* Teal */\n    --color-deadlock: #ff5252; /* Red */\n  }\n\n  /* Circular Process Node Styles */\n  .process-node {\n    position: absolute;\n    width: 120px;\n    height: 120px;\n    background: linear-gradient(135deg, var(--color-process) 0%, #3a5ccf 100%);\n    border-radius: 50%;\n    border: 3.5px solid #7b9cff;\n    box-shadow:\n      0 0 20px var(--color-process),\n      inset 0 0 12px #dceaff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 700;\n    font-size: 1.7rem;\n    color: #e3eafc;\n    letter-spacing: 0.03em;\n    user-select: none;\n    transition: box-shadow 0.5s ease;\n  }\n\n  /* Circular Resource Node Styles */\n  .resource-node {\n    position: absolute;\n    width: 100px;\n    height: 100px;\n    background: linear-gradient(135deg, var(--color-resource) 0%, #d97ea0 98%);\n    border-radius: 50%;\n    border: 3px solid #f79ec4;\n    box-shadow:\n      0 0 18px var(--color-resource),\n      inset 0 0 14px #ffd1e2;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: 600;\n    font-size: 1.5rem;\n    color: #ffe9f1dd;\n    letter-spacing: 0.04em;\n    user-select: none;\n  }\n\n  /* Lines Container */\n  svg {\n    position: absolute;\n    top: 0; left: 0;\n    width: 820px;\n    height: 440px;\n    pointer-events: none;\n    overflow: visible;\n  }\n\n  /* Path styles */\n  path.hold {\n    stroke: var(--color-hold);\n    stroke-width: 3.5;\n    fill: none;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 2px var(--color-hold));\n    transition: stroke 0.5s ease;\n  }\n\n  path.request {\n    stroke: var(--color-request);\n    stroke-width: 3.5;\n    fill: none;\n    stroke-linecap: round;\n    stroke-dasharray: 12 12;\n    filter: drop-shadow(0 0 2px var(--color-request));\n    transition: stroke 0.5s ease;\n  }\n\n  /* Deadlock Lines highlight */\n  .deadlock-path {\n    stroke: var(--color-deadlock);\n    stroke-width: 5;\n    stroke-dasharray: 0;\n    filter:\n      drop-shadow(0 0 8px var(--color-deadlock));\n    animation: pulseDeadlock 2.5s ease-in-out infinite alternate;\n  }\n\n  @keyframes pulseDeadlock {\n    0% {\n      stroke-opacity: 1;\n      filter: drop-shadow(0 0 12px var(--color-deadlock));\n    }\n    100% {\n      stroke-opacity: 0.6;\n      filter: drop-shadow(0 0 4px var(--color-deadlock));\n    }\n  }\n\n  /* Arrow marker */\n  marker#arrowhead path {\n    fill: currentColor;\n  }\n\n  /* Legend Box */\n  .legend {\n    max-width: 780px;\n    margin: 3rem auto 0 auto;\n    padding: 1.5rem 2rem;\n    background: #262b43;\n    border-radius: 16px;\n    box-shadow:\n      0 0 25px #2a355faa;\n    display: flex;\n    justify-content: center;\n    gap: 3.2rem;\n    user-select: none;\n  }\n\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 0.8rem;\n    font-weight: 500;\n    font-size: 1rem;\n    color: #c0c5e3;\n  }\n\n  .legend-color {\n    width: 20px;\n    height: 20px;\n    border-radius: 5px;\n    box-shadow: 0 0 7px;\n  }\n\n  .legend-color.process { background: var(--color-process); box-shadow-color: var(--color-process); }\n  .legend-color.resource { background: var(--color-resource); }\n  .legend-color.request { background: var(--color-request); border-radius: 12px; }\n  .legend-color.hold { background: var(--color-hold); }\n  .legend-color.deadlock { background: var(--color-deadlock); }\n\n  /* Subtle glow color for legend */\n  .legend-color.process {\n    box-shadow:\n      0 0 10px var(--color-process);\n  }\n  .legend-color.resource {\n    box-shadow:\n      0 0 10px var(--color-resource);\n  }\n  .legend-color.request {\n    box-shadow:\n      0 0 10px var(--color-request);\n  }\n  .legend-color.hold {\n    box-shadow:\n      0 0 10px var(--color-hold);\n  }\n  .legend-color.deadlock {\n    box-shadow:\n      0 0 12px var(--color-deadlock);\n  }\n\n  /* Info Text Box */\n  .info {\n    max-width: 780px;\n    margin: 2rem auto;\n    font-size: 1.1rem;\n    line-height: 1.5;\n    color: #adb2e1cc;\n    font-weight: 400;\n  }\n\n  /* Control Buttons */\n  .controls {\n    margin: 2.8rem auto 0;\n    text-align: center;\n  }\n\n  button.toggle-btn {\n    cursor: pointer;\n    background: #3949ab;\n    border: none;\n    border-radius: 28px;\n    padding: 0.68rem 2.2rem;\n    font-size: 1rem;\n    font-weight: 600;\n    color: #e3eafc;\n    letter-spacing: 0.04em;\n    box-shadow:\n      0 0 16px #3949abee;\n    transition:\n      background-color 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.24s ease;\n    user-select: none;\n  }\n  button.toggle-btn:hover,\n  button.toggle-btn:focus {\n    background: #5e74f3;\n    box-shadow:\n      0 0 26px #5e74f3ff;\n    outline: none;\n    transform: scale(1.05);\n  }\n  button.toggle-btn:active {\n    transform: scale(0.95);\n  }\n\n  /* Ease fade transitions for paths */\n  path, polygon {\n    transition: stroke 0.45s ease, stroke-dashoffset 0.45s ease, filter 0.45s ease;\n  }\n\n  /* Show deadlock description when toggled */\n  .info.deadlock-active {\n    color: #ff6f6fdd;\n    font-weight: 600;\n    text-shadow:\n      0 0 8px #ff525299;\n    transition: color 0.8s ease;\n  }\n</style>\n</head>\n<body>\n  <main class=\"container\" role=\"main\" aria-label=\"Deadlock Concept Visualization\">\n    <h1>DEADLOCK</h1>\n    <p class=\"subtitle\">Visualizing Circular Wait in Operating Systems Resource Allocation</p>\n\n    <section class=\"viz\" aria-label=\"Deadlock Visualization Diagram\">\n      <!-- Process Nodes -->\n      <div class=\"process-node\" id=\"proc1\" style=\"top: 40px; left: 40px;\">P1</div>\n      <div class=\"process-node\" id=\"proc2\" style=\"top: 40px; right: 40px;\">P2</div>\n      <div class=\"process-node\" id=\"proc3\" style=\"bottom: 40px; right: 40px;\">P3</div>\n      <div class=\"process-node\" id=\"proc4\" style=\"bottom: 40px; left: 40px;\">P4</div>\n\n      <!-- Resource Nodes -->\n      <div class=\"resource-node\" id=\"resA\" style=\"top: 170px; left: 190px;\">R1</div>\n      <div class=\"resource-node\" id=\"resB\" style=\"top: 90px; right: 190px;\">R2</div>\n      <div class=\"resource-node\" id=\"resC\" style=\"bottom: 140px; right: 185px;\">R3</div>\n      <div class=\"resource-node\" id=\"resD\" style=\"bottom: 160px; left: 185px;\">R4</div>\n\n      <!-- SVG for edges / arrows -->\n      <svg aria-hidden=\"true\" width=\"820\" height=\"440\">\n        <defs>\n          <marker id=\"arrowhead\" markerWidth=\"12\" markerHeight=\"10\" refX=\"8\" refY=\"5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n            <path d=\"M0,0 L8,5 L0,10 z\" />\n          </marker>\n        </defs>\n\n        <!-- Hold edges: Resource allocated to Process -->\n        <path class=\"hold\" id=\"holdA-P1\" d=\"M230 220 Q190 120 100 100\" marker-end=\"url(#arrowhead)\" />\n        <path class=\"hold\" id=\"holdB-P2\" d=\"M610 150 Q630 120 730 100\" marker-end=\"url(#arrowhead)\" />\n        <path class=\"hold\" id=\"holdC-P3\" d=\"M610 300 Q630 290 730 310\" marker-end=\"url(#arrowhead)\" />\n        <path class=\"hold\" id=\"holdD-P4\" d=\"M230 280 Q190 335 100 300\" marker-end=\"url(#arrowhead)\" />\n\n        <!-- Request edges: Process waiting for Resource -->\n        <path class=\"request\" id=\"reqP1-A\" d=\"M90 160 Q130 180 180 210\" marker-end=\"url(#arrowhead)\" />\n        <path class=\"request\" id=\"reqP2-B\" d=\"M700 100 Q670 120 620 140\" marker-end=\"url(#arrowhead)\" />\n        <path class=\"request\" id=\"reqP3-C\" d=\"M700 320 Q670 300 620 290\" marker-end=\"url(#arrowhead)\" />\n        <path class=\"request\" id=\"reqP4-D\" d=\"M90 300 Q130 270 180 260\" marker-end=\"url(#arrowhead)\" />\n\n        <!-- Deadlock cycle highlight - Overlay paths for emphasis -->\n        <path class=\"deadlock-path\" id=\"deadlockHoldA-P1\" d=\"M230 220 Q190 120 100 100\" marker-end=\"url(#arrowhead)\" style=\"opacity:0\" />\n        <path class=\"deadlock-path\" id=\"deadlockReqP1-A\" d=\"M90 160 Q130 180 180 210\" marker-end=\"url(#arrowhead)\" style=\"opacity:0\" />\n\n        <path class=\"deadlock-path\" id=\"deadlockHoldB-P2\" d=\"M610 150 Q630 120 730 100\" marker-end=\"url(#arrowhead)\" style=\"opacity:0\" />\n        <path class=\"deadlock-path\" id=\"deadlockReqP2-B\" d=\"M700 100 Q670 120 620 140\" marker-end=\"url(#arrowhead)\" style=\"opacity:0\" />\n\n        <path class=\"deadlock-path\" id=\"deadlockHoldC-P3\" d=\"M610 300 Q630 290 730 310\" marker-end=\"url(#arrowhead)\" style=\"opacity:0\" />\n        <path class=\"deadlock-path\" id=\"deadlockReqP3-C\" d=\"M700 320 Q670 300 620 290\" marker-end=\"url(#arrowhead)\" style=\"opacity:0\" />\n\n        <path class=\"deadlock-path\" id=\"deadlockHoldD-P4\" d=\"M230 280 Q190 335 100 300\" marker-end=\"url(#arrowhead)\" style=\"opacity:0\" />\n        <path class=\"deadlock-path\" id=\"deadlockReqP4-D\" d=\"M90 300 Q130 270 180 260\" marker-end=\"url(#arrowhead)\" style=\"opacity:0\" />\n      </svg>\n\n    </section>\n\n    <div class=\"controls\" role=\"region\" aria-label=\"Controls for toggling deadlock highlight\">\n      <button type=\"button\" class=\"toggle-btn\" id=\"toggleDeadlockBtn\" aria-pressed=\"false\" aria-controls=\"infoText\">Show Deadlock Cycle</button>\n    </div>\n\n    <p class=\"info\" id=\"infoText\" aria-live=\"polite\" aria-atomic=\"true\">\n      This diagram illustrates the concept of <strong>deadlock</strong> through processes (blue circles) and resources (pink circles). Solid arrows represent resources <em>held by</em> processes; dashed arrows represent resources <em>requested</em> by processes.\n      <br><br>\n      When each process waits for a resource held by another in a circular chain, no process can proceed — a deadlock occurs.\n    </p>\n\n    <section class=\"legend\" aria-label=\"Legend describing diagram elements\">\n      <div class=\"legend-item\"><div class=\"legend-color process\" aria-hidden=\"true\"></div>Process</div>\n      <div class=\"legend-item\"><div class=\"legend-color resource\" aria-hidden=\"true\"></div>Resource</div>\n      <div class=\"legend-item\"><div class=\"legend-color hold\" aria-hidden=\"true\"></div>Resource Held</div>\n      <div class=\"legend-item\"><div class=\"legend-color request\" aria-hidden=\"true\"></div>Resource Requested</div>\n      <div class=\"legend-item\"><div class=\"legend-color deadlock\" aria-hidden=\"true\"></div>Deadlock Cycle</div>\n    </section>\n  </main>\n\n<script>\n  (() => {\n    // Toggle deadlock cycle highlight on/off\n    const toggleBtn = document.getElementById('toggleDeadlockBtn');\n    const infoText = document.getElementById('infoText');\n\n    // All deadlock paths (overlay colored red pulsating)\n    const deadlockPaths = Array.from(document.querySelectorAll('.deadlock-path'));\n\n    function setDeadlockVisible(visible) {\n      deadlockPaths.forEach(path => {\n        path.style.opacity = visible ? '1' : '0';\n      });\n      toggleBtn.setAttribute('aria-pressed', visible ? 'true' : 'false');\n      toggleBtn.textContent = visible ? 'Hide Deadlock Cycle' : 'Show Deadlock Cycle';\n      if(visible) {\n        infoText.classList.add('deadlock-active');\n        infoText.innerHTML =\n          `<strong>Deadlock Cycle Highlighted:</strong> Each process is waiting for a resource held by the next process, forming a cyclic wait. None can proceed, resulting in a deadlock.`;\n      } else {\n        infoText.classList.remove('deadlock-active');\n        infoText.innerHTML =\n          `This diagram illustrates the concept of <strong>deadlock</strong> through processes (blue circles) and resources (pink circles). Solid arrows represent resources <em>held by</em> processes; dashed arrows represent resources <em>requested</em> by processes.\n          <br><br>\n          When each process waits for a resource held by another in a circular chain, no process can proceed — a deadlock occurs.`;\n      }\n    }\n\n    toggleBtn.addEventListener('click', () => {\n      const visible = toggleBtn.getAttribute('aria-pressed') === 'true';\n      setDeadlockVisible(!visible);\n    });\n\n    // Initial state: no deadlock highlight\n    setDeadlockVisible(false);\n  })();\n</script>\n</body>\n</html>"
