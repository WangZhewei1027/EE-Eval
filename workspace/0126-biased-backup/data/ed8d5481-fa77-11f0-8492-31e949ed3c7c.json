    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Selection Sort Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #f3f4f6 30%, #d1d5db 100%);\n            color: #374151;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n        }\n        #container {\n            width: 80%;\n            height: 400px;\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            position: relative;\n            border-radius: 12px;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);\n            overflow: hidden;\n            background-color: #ffffff;\n        }\n        .bar {\n            width: 30px;\n            margin: 0 2px;\n            display: inline-block;\n            background-color: #4f46e5;\n            transition: height 0.5s ease, background-color 0.5s ease;\n        }\n        .active {\n            background-color: #f59e0b;\n        }\n        .sorted {\n            background-color: #22c55e;\n        }\n        #controls {\n            margin-top: 20px;\n            display: flex;\n            justify-content: center;\n        }\n        button {\n            background-color: #2563eb;\n            color: white;\n            border: none;\n            padding: 10px 20px;\n            border-radius: 8px;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n            font-size: 16px;\n        }\n        button:hover {\n            background-color: #1d4ed8;\n        }\n        button:disabled {\n            background-color: #9ca3af;\n            cursor: not-allowed;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\"></div>\n    <div id=\"controls\">\n        <button id=\"start\">Start Sorting</button>\n    </div>\n\n    <script>\n        const container = document.getElementById('container');\n        const startButton = document.getElementById('start');\n        const barCount = 15;\n        let array = Array.from({length: barCount}, () => Math.floor(Math.random() * 100) + 10);\n\n        function createBars(array) {\n            container.innerHTML = '';\n            array.forEach(height => {\n                const bar = document.createElement('div');\n                bar.classList.add('bar');\n                bar.style.height = height + 'px';\n                container.appendChild(bar);\n            });\n        }\n\n        async function selectionSort() {\n            for (let i = 0; i < array.length - 1; i++) {\n                let minIndex = i;\n                const bars = document.querySelectorAll('.bar');\n\n                // Highlight active selection\n                bars[i].classList.add('active');\n\n                for (let j = i + 1; j < array.length; j++) {\n                    if (array[j] < array[minIndex]) {\n                        minIndex = j;\n                    }\n                }\n\n                // Swap bars if necessary\n                if (minIndex !== i) {\n                    [array[i], array[minIndex]] = [array[minIndex], array[i]];\n                    createBars(array);\n                    bars[i].classList.remove('active');\n                    bars[minIndex].classList.add('active');\n                    await new Promise(requestAnimationFrame);\n                }\n\n                // Mark bar as sorted\n                bars[i].classList.add('sorted');\n            }\n            document.querySelectorAll('.bar').forEach(bar => bar.classList.add('sorted'));\n        }\n\n        startButton.addEventListener('click', async () => {\n            startButton.disabled = true;\n            createBars(array);\n            await selectionSort();\n            startButton.disabled = false;\n        });\n\n        createBars(array);\n    </script>\n</body>\n</html>"
