    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Dynamic Programming — Visual Elegance</title>\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071124;\n    --accent: #6ee7b7;\n    --accent-2: #7dd3fc;\n    --muted: rgba(255,255,255,0.12);\n    --glass: rgba(255,255,255,0.04);\n    --card: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n    --glass-border: rgba(255,255,255,0.06);\n    --glow: rgba(110,231,183,0.12);\n  }\n  * { box-sizing: border-box; }\n  html,body{height:100%;margin:0;font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; background: radial-gradient(1200px 600px at 10% 10%, rgba(125,211,252,0.06), transparent), radial-gradient(1000px 500px at 90% 90%, rgba(110,231,183,0.04), transparent), linear-gradient(180deg,var(--bg1),var(--bg2)); color:#e6eef6; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;}\n  .page {\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    gap:28px;\n  }\n  .card {\n    width:1180px;\n    max-width:calc(100% - 64px);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:18px;\n    box-shadow: 0 10px 40px rgba(2,6,23,0.6), inset 0 1px 0 var(--glass-border);\n    padding:28px;\n    display:flex;\n    gap:20px;\n    position:relative;\n    overflow:visible;\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n  .left {\n    width:64%;\n    min-height:520px;\n    padding:22px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n    border: 1px solid var(--glass-border);\n    position:relative;\n    overflow:hidden;\n  }\n  .right {\n    width:36%;\n    padding:22px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006));\n    border: 1px solid var(--glass-border);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    min-height:520px;\n  }\n  header {\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:12px;\n    margin-bottom:6px;\n  }\n  .title {\n    display:flex;\n    flex-direction:column;\n  }\n  h1 {\n    font-size:26px;\n    margin:0;\n    letter-spacing: -0.02em;\n    font-weight:700;\n    color: #eaf8f3;\n    text-shadow: 0 6px 28px rgba(13,66,82,0.06);\n  }\n  .subtitle {\n    font-size:13px;\n    margin-top:6px;\n    color: #a9c8cf;\n  }\n  .controls {\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    color: #cfeee2;\n    padding:10px 14px;\n    border-radius:10px;\n    cursor:pointer;\n    font-weight:600;\n    font-size:13px;\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    transition: transform .18s ease, box-shadow .18s ease, opacity .12s;\n  }\n  .btn:active{ transform: translateY(1px) }\n  .btn.secondary {\n    background: linear-gradient(180deg, rgba(255,255,255,0.006), rgba(255,255,255,0.002));\n    color:#9fc6d1;\n  }\n  .btn .dot {\n    width:10px;height:10px;border-radius:50%;\n    background: linear-gradient(90deg,var(--accent),var(--accent-2));\n    box-shadow:0 6px 18px rgba(124,220,210,0.12), 0 0 18px rgba(125,211,252,0.06) inset;\n  }\n\n  /* Visualization area */\n  .canvas {\n    position:relative;\n    width:100%;\n    height:460px;\n    overflow:visible;\n    border-radius:12px;\n  }\n\n  /* Recursion Tree Panel */\n  .panel-title {\n    font-weight:700;\n    font-size:13px;\n    color:#dff7ef;\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .panel-sub {\n    font-size:12px;color:#9fc6d1;margin-top:6px;\n  }\n\n  /* Right side cards */\n  .card-block {\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006));\n    border-radius:12px;\n    padding:14px;\n    border: 1px solid rgba(255,255,255,0.02);\n    box-shadow: 0 6px 24px rgba(2,6,23,0.5);\n    flex: 1;\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n  }\n  .legend {\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .legend .item {\n    display:flex;\n    gap:8px;align-items:center;font-size:13px;color:#bfeae1;\n  }\n  .swatch {\n    width:14px;height:14px;border-radius:4px;background:linear-gradient(90deg,var(--accent),var(--accent-2));box-shadow:0 6px 20px rgba(125,211,252,0.06);\n  }\n  .cache {\n    display:flex;\n    gap:8px;\n    flex-wrap:wrap;\n  }\n  .cell {\n    width:56px;height:56px;border-radius:10px;background:linear-gradient(180deg,rgba(255,255,255,0.01),rgba(255,255,255,0.006));\n    border:1px solid var(--glass-border);\n    display:flex;align-items:center;justify-content:center;font-weight:700;color:#dff7ef;font-size:16px;position:relative;\n    transition: transform .28s cubic-bezier(.2,.9,.2,1), box-shadow .28s;\n  }\n  .cell.empty { color:rgba(255,255,255,0.12); font-weight:600; font-size:13px; }\n  .cell.filled {\n    box-shadow: 0 10px 30px rgba(110,231,183,0.06);\n    background: linear-gradient(180deg, rgba(123,222,203,0.06), rgba(255,255,255,0.008));\n    border: 1px solid rgba(110,231,183,0.14);\n    color:#052821;\n  }\n  .cell .tag {\n    font-size:11px;color:#9fc6d1;position:absolute;left:8px;top:6px;font-weight:700;\n  }\n\n  /* SVG nodes */\n  svg { width:100%; height:100%; overflow:visible; display:block; }\n  .node {\n    cursor:default;\n    transition: transform .22s cubic-bezier(.2,.9,.2,1), opacity .28s;\n  }\n  .node circle {\n    fill: url(#nodeGradient);\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:1;\n    filter: drop-shadow(0 6px 22px rgba(5,26,32,0.45));\n    transition: r .18s ease, fill .18s ease;\n  }\n  .node .label {\n    font-size:13px;\n    fill: #062a29;\n    font-weight:700;\n    text-anchor:middle;\n    dominant-baseline:central;\n    pointer-events:none;\n  }\n  .node.dim circle { opacity:0.14; transform-origin:center; transform:scale(.92); }\n  .node.highlight circle { r:30; fill: url(#nodeGlow); filter: drop-shadow(0 14px 40px rgba(125,211,252,0.12)); }\n  .node.calling circle { stroke: rgba(255,255,255,0.12); stroke-width:1.6; }\n  .link { stroke: rgba(255,255,255,0.04); stroke-width:1.6; opacity:0.9; transition: stroke .18s; }\n  .link.dim { opacity:0.09; }\n  .mini-dot {\n    position:absolute;width:12px;height:12px;border-radius:50%;\n    background:linear-gradient(90deg,var(--accent),var(--accent-2));\n    box-shadow: 0 8px 28px rgba(125,211,252,0.10);\n    pointer-events:none;\n    transform:translate(-50%,-50%);\n    transition: transform .6s cubic-bezier(.2,.9,.2,1), opacity .3s;\n  }\n\n  /* Footer text */\n  .explain {\n    font-size:13px;color:#a9c8cf;\n    line-height:1.45;\n  }\n\n  /* subtle animated background elements */\n  .orb {\n    position:absolute;\n    width:420px;height:420px;border-radius:50%;\n    background: radial-gradient(circle at 35% 30%, rgba(125,211,252,0.06), transparent 30%), radial-gradient(circle at 75% 70%, rgba(110,231,183,0.03), transparent 20%);\n    filter: blur(28px);\n    pointer-events:none;\n    transform: translate3d(0,0,0);\n    mix-blend-mode:screen;\n    opacity:0.7;\n  }\n  .orb.one { right:-120px; top:-120px; }\n  .orb.two { left:-160px; bottom:-120px; opacity:0.55; transform:scale(.85); }\n\n  /* tiny animated grid shimmer */\n  .grid-shimmer {\n    position:absolute; inset:18px; border-radius:12px; pointer-events:none;\n    background-image: linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px), linear-gradient(180deg, rgba(255,255,255,0.01) 1px, transparent 1px);\n    background-size: 40px 40px, 40px 40px;\n    opacity:0.03; mix-blend-mode:overlay;\n  }\n\n  /* responsive tweaks */\n  @media (max-width:1100px){\n    .card{flex-direction:column;padding:18px;}\n    .left, .right { width:100%;}\n    .right { min-height:360px;}\n  }\n</style>\n</head>\n<body>\n<div class=\"page\">\n  <div class=\"card\" role=\"main\" aria-label=\"Dynamic Programming Visualization\">\n    <div class=\"left\">\n      <header>\n        <div class=\"title\">\n          <h1>Dynamic Programming</h1>\n          <div class=\"subtitle\">Overlapping subproblems • Optimal substructure — visualized with a recursion-to-memo transition</div>\n        </div>\n        <div class=\"controls\">\n          <button id=\"toggle\" class=\"btn\" title=\"Play animation\">\n            <span class=\"dot\" id=\"playDot\" style=\"box-shadow:0 10px 24px rgba(125,211,252,0.14)\"></span>\n            <span id=\"toggleText\">Animate</span>\n          </button>\n          <button id=\"reset\" class=\"btn secondary\" title=\"Reset view\">Reset</button>\n        </div>\n      </header>\n\n      <div class=\"canvas\" id=\"canvas\">\n        <div class=\"orb one\"></div>\n        <div class=\"orb two\"></div>\n        <div class=\"grid-shimmer\"></div>\n        <svg id=\"svg\" viewBox=\"0 0 1000 460\" preserveAspectRatio=\"xMidYMid meet\">\n          <defs>\n            <linearGradient id=\"nodeGradient\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#91f3da\"/>\n              <stop offset=\"100%\" stop-color=\"#7dd3fc\"/>\n            </linearGradient>\n            <linearGradient id=\"nodeGlow\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#8ff0d6\"/>\n              <stop offset=\"100%\" stop-color=\"#7dd3fc\"/>\n            </linearGradient>\n            <filter id=\"softShadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"12\" result=\"blur\"/>\n              <feBlend in=\"SourceGraphic\" in2=\"blur\"/>\n            </filter>\n          </defs>\n\n          <!-- Left: recursion tree group -->\n          <g id=\"treeGroup\" transform=\"translate(40,20)\"></g>\n\n          <!-- Right: memo & dp group -->\n          <g id=\"memoGroup\" transform=\"translate(560,28)\"></g>\n        </svg>\n        <div id=\"dot\" class=\"mini-dot\" style=\"opacity:0;\"></div>\n      </div>\n\n      <p class=\"explain\" style=\"margin-top:16px;\">\n        Observe a naive recursive evaluation of Fibonacci calls being folded into a small memo buffer: repeated subcalls merge into cached results. The animation illustrates how overlapping subproblems are reused, transforming exponential work into an efficient dynamic programming solution.\n      </p>\n    </div>\n\n    <div class=\"right\">\n      <div class=\"card-block\">\n        <div class=\"panel-title\">Memoization Cache</div>\n        <div class=\"panel-sub\">Top-down storage of computed values that prevents duplicate computation</div>\n\n        <div class=\"cache\" id=\"cacheCells\" style=\"margin-top:8px;\">\n          <!-- cells inserted by JS -->\n        </div>\n\n        <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:6px;\">\n          <div class=\"legend\">\n            <div class=\"item\"><div class=\"swatch\"></div> Cached value</div>\n            <div class=\"item\" style=\"opacity:0.8\"><div style=\"width:12px;height:12px;border-radius:4px;background:rgba(255,255,255,0.06)\"></div> Empty</div>\n          </div>\n          <div style=\"font-size:12px;color:#9fc6d1;\">n = 8 (visual)</div>\n        </div>\n      </div>\n\n      <div class=\"card-block\" style=\"align-items:flex-start;\">\n        <div class=\"panel-title\">Conceptual Notes</div>\n        <div class=\"panel-sub\">Dynamic Programming reduces repeated computation by caching subproblem solutions. The visualization shows calls (left) and memo cache population (right).</div>\n        <div style=\"font-size:13px;color:#cfeee2;margin-top:8px;line-height:1.5;\">\n          • Recursion tree expands exponentially without memoization.<br/>\n          • When a subproblem is computed once, subsequent calls reuse the cached result.<br/>\n          • Bottom-up DP fills table iteratively; memoization is its top-down twin.\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(() => {\n  // Configuration\n  const N = 8; // Fibonacci target (visual)\n  const svg = document.getElementById('svg');\n  const treeGroup = document.getElementById('treeGroup');\n  const memoGroup = document.getElementById('memoGroup');\n  const toggleBtn = document.getElementById('toggle');\n  const toggleText = document.getElementById('toggleText');\n  const resetBtn = document.getElementById('reset');\n  const playDot = document.getElementById('playDot');\n  const dot = document.getElementById('dot');\n  const cacheCells = document.getElementById('cacheCells');\n\n  let running = false;\n  let canceled = false;\n  let nodes = [];\n  let links = [];\n  let cache = new Array(N+1).fill(null);\n  let animPromise = null;\n\n  // Utility sleep with cancellation support\n  function sleep(ms){\n    return new Promise(res => {\n      const t = setTimeout(()=>{ res(); }, ms);\n      // we don't track timeouts individually for cancellation; will guard via 'canceled' flag\n    });\n  }\n\n  // Build recursion tree layout for fib(n)\n  let nodeId = 0;\n  function buildTree(n, depth=0, xIndexRef={v:0}, parent=null){\n    const id = nodeId++;\n    const node = { id, n, depth, parent, children:[], x:0, y:0 };\n    nodes.push(node);\n    if (n > 1) {\n      const left = buildTree(n-1, depth+1, xIndexRef, node);\n      const right = buildTree(n-2, depth+1, xIndexRef, node);\n      node.children.push(left, right);\n    }\n    return node;\n  }\n\n  function layoutTree(root){\n    // assign y positions by inorder traversal index & x by depth\n    let index = 0;\n    function dfsAssign(node){\n      if (node.children.length===2){\n        dfsAssign(node.children[0]);\n      }\n      node.y = index * 46;\n      index++;\n      if (node.children.length===2){\n        dfsAssign(node.children[1]);\n      } else if (node.children.length===1){\n        // leaf\n      }\n    }\n    dfsAssign(root);\n    // set x by depth\n    nodes.forEach(n => {\n      n.x = n.depth * 120;\n      // center vertically within view area initial offset\n      n.cx = 80 + n.x;\n      n.cy = 40 + n.y;\n    });\n  }\n\n  function clearSVG(){\n    while (treeGroup.firstChild) treeGroup.removeChild(treeGroup.firstChild);\n    while (memoGroup.firstChild) memoGroup.removeChild(memoGroup.firstChild);\n  }\n\n  function drawInitial(){\n    clearSVG();\n    nodes = []; links = []; cache = new Array(N+1).fill(null);\n    nodeId = 0;\n    const root = buildTree(N);\n    layoutTree(root);\n\n    // draw links\n    nodes.forEach(n => {\n      if (n.parent){\n        const p = n.parent;\n        const line = document.createElementNS('http://www.w3.org/2000/svg','path');\n        const sx = p.cx, sy = p.cy;\n        const tx = n.cx, ty = n.cy;\n        const dx = (tx - sx) * 0.36;\n        const d = `M ${sx} ${sy} C ${sx+dx} ${sy} ${tx-dx} ${ty} ${tx} ${ty}`;\n        line.setAttribute('d', d);\n        line.setAttribute('class', 'link dim');\n        treeGroup.appendChild(line);\n        links.push({el:line, from:p, to:n});\n      }\n    });\n\n    // draw nodes\n    nodes.forEach(n => {\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('class','node dim');\n      g.setAttribute('transform', `translate(${n.cx},${n.cy})`);\n      g.dataset.id = n.id;\n      g.dataset.n = n.n;\n\n      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      circle.setAttribute('r', 22);\n      circle.setAttribute('cx', 0);\n      circle.setAttribute('cy', 0);\n\n      const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('class','label');\n      text.setAttribute('x',0);\n      text.setAttribute('y',0);\n      text.textContent = `f(${n.n})`;\n\n      g.appendChild(circle);\n      g.appendChild(text);\n      treeGroup.appendChild(g);\n      n.el = g;\n      n.cxScreen = 0;\n      n.cyScreen = 0;\n    });\n\n    // draw memo cells (right)\n    // draw container rectangle label\n    const memoLabel = document.createElementNS('http://www.w3.org/2000/svg','text');\n    memoLabel.setAttribute('x', 0);\n    memoLabel.setAttribute('y', -8);\n    memoLabel.setAttribute('fill', '#bfeae1');\n    memoLabel.setAttribute('font-size','13');\n    memoLabel.setAttribute('font-weight','700');\n    memoLabel.textContent = 'Memo (cache)';\n    memoGroup.appendChild(memoLabel);\n\n    // cells positions\n    const cellSize = 56;\n    const gap = 8;\n    const startX = 0;\n    const startY = 12;\n    for (let i=0;i<=N;i++){\n      const cx = startX + (i % 2) * (cellSize + gap);\n      const cy = startY + Math.floor(i / 2) * (cellSize + gap);\n      // draw a visual outline in SVG for alignment (invisible; primary cells are DOM)\n      const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      rect.setAttribute('x', cx);\n      rect.setAttribute('y', cy);\n      rect.setAttribute('rx',10);\n      rect.setAttribute('ry',10);\n      rect.setAttribute('width',cellSize);\n      rect.setAttribute('height',cellSize);\n      rect.setAttribute('fill','transparent');\n      rect.setAttribute('stroke','rgba(255,255,255,0.02)');\n      rect.setAttribute('class','svccell');\n      memoGroup.appendChild(rect);\n      // also create DOM cell preview on right-side panel (cacheCells)\n    }\n\n    buildCacheDom();\n    updateScreenCoords();\n  }\n\n  function buildCacheDom(){\n    cacheCells.innerHTML = '';\n    for (let i=0;i<=N;i++){\n      const div = document.createElement('div');\n      div.className = 'cell empty';\n      div.id = 'cell-'+i;\n      const tag = document.createElement('div');\n      tag.className = 'tag';\n      tag.textContent = `f(${i})`;\n      div.appendChild(tag);\n      const val = document.createElement('div');\n      val.style.pointerEvents = 'none';\n      val.textContent = '';\n      div.appendChild(val);\n      cacheCells.appendChild(div);\n    }\n  }\n\n  function updateScreenCoords(){\n    // compute screen coords for tree nodes (relative to page)\n    const svgRect = svg.getBoundingClientRect();\n    nodes.forEach(n => {\n      const g = n.el;\n      const transform = g.getAttribute('transform'); // translate(x,y)\n      const match = /translate\\(([-0-9.]+),([\\-0-9.]+)\\)/.exec(transform);\n      if (match){\n        const x = parseFloat(match[1]);\n        const y = parseFloat(match[2]);\n        const pt = svg.createSVGPoint();\n        pt.x = x; pt.y = y;\n        const ctm = treeGroup.getCTM();\n        const globalPt = pt.matrixTransform(ctm);\n        n.cxScreen = globalPt.x + svgRect.left;\n        n.cyScreen = globalPt.y + svgRect.top;\n      }\n    });\n    // compute memo cell screen positions\n    for (let i=0;i<=N;i++){\n      const cell = document.getElementById('cell-'+i);\n      const rect = cell.getBoundingClientRect();\n      cell.dataset.cx = rect.left + rect.width/2;\n      cell.dataset.cy = rect.top + rect.height/2;\n    }\n  }\n\n  // Animation timeline\n  async function runAnimation(){\n    canceled = false;\n    running = true;\n    toggleText.textContent = 'Pause';\n    playDot.style.transform = 'scale(1.02)';\n    // step 1: light up recursion (traverse calls)\n    // We'll simulate evaluation order (preorder) with caching: if a value already cached, mark as reused.\n    const callOrder = [];\n    function traverse(node){\n      callOrder.push(node);\n      node.children.forEach(ch => traverse(ch));\n    }\n    // For a top-down memoized DFS, evaluation order is preorder but with caching effect; for visual we will simulate calls and mark first-time computes\n    traverse(nodes[0]);\n\n    // highlight recursion tree slowly\n    for (let i=0;i<callOrder.length;i++){\n      if (canceled) break;\n      const n = callOrder[i];\n      highlightNode(n, true);\n      await sleep(240);\n      // move a mini dot from node to its cache cell if not cached yet\n      if (cache[n.n] == null){\n        showDotMove(n, n.n);\n        // compute value (Fibonacci)\n        const val = fibCalc(n.n);\n        cache[n.n] = val;\n        await sleep(420);\n        fillCell(n.n, val);\n        // small pop on node\n        popNode(n);\n        await sleep(120);\n      } else {\n        // reused subproblem\n        markReused(n);\n        await sleep(220);\n      }\n      unhighlightNode(n);\n      await sleep(80);\n    }\n\n    if (!canceled){\n      // step 2: demonstrate bottom-up table fill wave\n      await sleep(420);\n      const bottomUpOrder = [...Array(N+1).keys()]; // 0..N\n      for (let i=0;i<bottomUpOrder.length;i++){\n        if (canceled) break;\n        const k = bottomUpOrder[i];\n        const cell = document.getElementById('cell-'+k);\n        cell.classList.add('filled');\n        cell.classList.remove('empty');\n        cell.querySelector('div:nth-child(2)').textContent = cache[k] != null ? cache[k] : fibCalc(k);\n        cell.style.transform = `translateY(-6px)`;\n        cell.style.boxShadow = `0 18px 40px rgba(125,211,252,0.06)`;\n        await sleep(110);\n        cell.style.transform = `translateY(0)`;\n        await sleep(40);\n      }\n    }\n\n    running = false;\n    toggleText.textContent = 'Animate';\n    playDot.style.transform = 'scale(1)';\n  }\n\n  function highlightNode(n, on){\n    if (!n || !n.el) return;\n    if (on){\n      n.el.classList.remove('dim');\n      n.el.classList.add('highlight','calling');\n      // brighten links to children\n      links.forEach(l => {\n        if (l.from === n){\n          l.el.classList.remove('dim');\n          l.el.style.stroke = 'rgba(125,211,252,0.18)';\n        }\n      });\n    } else {\n      n.el.classList.remove('highlight','calling');\n    }\n  }\n\n  function unhighlightNode(n){\n    if (!n || !n.el) return;\n    n.el.classList.add('dim');\n    // reset links\n    links.forEach(l => {\n      if (l.from === n){\n        l.el.classList.add('dim');\n        l.el.style.stroke = 'rgba(255,255,255,0.04)';\n      }\n    });\n  }\n\n  function popNode(n){\n    if (!n || !n.el) return;\n    n.el.style.transform = 'scale(1.06)';\n    setTimeout(()=>{ if (n.el) n.el.style.transform='scale(1)'; }, 300);\n  }\n\n  function markReused(n){\n    if (!n || !n.el) return;\n    n.el.classList.remove('dim');\n    n.el.style.opacity = '0.9';\n    n.el.querySelector('circle').style.fill = 'rgba(255,255,255,0.04)';\n    setTimeout(()=>{ if (n.el) { n.el.style.opacity = ''; n.el.querySelector('circle').style.fill=''; } }, 420);\n  }\n\n  function showDotMove(n, idx){\n    updateScreenCoords();\n    const startX = n.cxScreen;\n    const startY = n.cyScreen;\n    const targetCell = document.getElementById('cell-'+idx);\n    const tx = parseFloat(targetCell.dataset.cx);\n    const ty = parseFloat(targetCell.dataset.cy);\n    dot.style.opacity = 1;\n    dot.style.left = `${startX}px`;\n    dot.style.top = `${startY}px`;\n    dot.style.transform = `translate(-50%,-50%) scale(1)`;\n    // animate to target\n    requestAnimationFrame(()=>{\n      dot.style.transition = 'transform 700ms cubic-bezier(.2,.9,.2,1), left 700ms linear, top 700ms linear';\n      dot.style.left = `${tx}px`;\n      dot.style.top = `${ty}px`;\n      dot.style.transform = `translate(-50%,-50%) scale(1.05)`;\n    });\n    setTimeout(()=> {\n      dot.style.opacity = 0;\n      dot.style.transition = 'opacity 200ms linear';\n    }, 760);\n  }\n\n  function fillCell(i, val){\n    const cell = document.getElementById('cell-'+i);\n    cell.classList.remove('empty');\n    cell.classList.add('filled');\n    cell.querySelector('div:nth-child(2)').textContent = val;\n  }\n\n  // Simple Fibonacci for visuals (small N)\n  function fibCalc(n){\n    if (n <= 1) return n;\n    let a=0,b=1;\n    for (let i=2;i<=n;i++){\n      const c = a+b; a=b; b=c;\n    }\n    return b;\n  }\n\n  // Event handlers\n  toggleBtn.addEventListener('click', async ()=>{\n    if (running){\n      // pause/cancel\n      canceled = true;\n      running = false;\n      toggleText.textContent = 'Animate';\n      playDot.style.transform = 'scale(1)';\n      return;\n    }\n    // start animation\n    canceled = false;\n    animPromise = runAnimation();\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    canceled = true;\n    running = false;\n    toggleText.textContent = 'Animate';\n    playDot.style.transform = 'scale(1)';\n    // small visual reset\n    setTimeout(()=> {\n      buildFreshView();\n    }, 120);\n  });\n\n  // Build everything\n  function buildFreshView(){\n    nodes = []; links = []; cache = new Array(N+1).fill(null);\n    nodeId = 0;\n    clearSVG();\n    drawInitial();\n    // reset DOM cell visuals\n    for (let i=0;i<=N;i++){\n      const cell = document.getElementById('cell-'+i);\n      cell.className = 'cell empty';\n      cell.querySelector('div:nth-child(2)').textContent = '';\n      cell.style.transform = '';\n      cell.style.boxShadow = '';\n    }\n    dot.style.opacity = 0;\n    // subtle entrance animation for nodes\n    nodes.forEach((n,i)=>{\n      n.el.style.opacity = 0;\n      n.el.style.transform = 'translateY(-8px) scale(.98)';\n      setTimeout(()=> {\n        if (n.el){\n          n.el.style.transition = 'opacity 420ms ease, transform 420ms cubic-bezier(.2,.9,.2,1)';\n          n.el.style.opacity = 1;\n          n.el.style.transform = 'translateY(0) scale(1)';\n        }\n      }, 20 + i*20);\n    });\n  }\n\n  // initial build\n  drawInitial();\n\n  // Recompute coords on resize\n  window.addEventListener('resize', ()=> {\n    updateScreenCoords();\n  });\n\n  // quick entrance animation for the card\n  document.addEventListener('DOMContentLoaded', ()=>{\n    setTimeout(()=> {\n      const c = document.querySelector('.card');\n      c.style.transform = 'translateY(0)';\n    }, 100);\n  });\n\n})();\n</script>\n</body>\n</html>"
