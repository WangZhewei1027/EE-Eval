    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Greedy Algorithms Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Greedy Algorithms Interactive Demo</h1>\n\n<h2>1. Coin Change Problem</h2>\n<p>Enter amount and available coin denominations:</p>\n<input type=\"number\" id=\"amount\" placeholder=\"Amount\" />\n<input type=\"text\" id=\"denominations\" placeholder=\"Coin Denominations (comma separated)\" />\n<button onclick=\"calculateCoinChange()\">Calculate Coin Change</button>\n<div id=\"coinChangeResult\"></div>\n\n<h2>2. Activity Selection Problem</h2>\n<p>Enter activities (start, end) separated by commas:</p>\n<input type=\"text\" id=\"activities\" placeholder=\"Activities (e.g. 0,6; 1,4; 3,5; 5,7; 3,9; 5,9)\" />\n<button onclick=\"selectActivities()\">Select Activities</button>\n<div id=\"activityResult\"></div>\n\n<h2>3. Fractional Knapsack Problem</h2>\n<p>Enter weights and values of items:</p>\n<input type=\"text\" id=\"itemData\" placeholder=\"Weights and Values (e.g. 10,60; 20,100; 30,120)\" />\n<input type=\"number\" id=\"knapsackCapacity\" placeholder=\"Knapsack Capacity\" />\n<button onclick=\"fractionalKnapsack()\">Calculate Maximum Value</button>\n<div id=\"knapsackResult\"></div>\n\n<script>\n    function calculateCoinChange() {\n        const amount = parseInt(document.getElementById(\"amount\").value);\n        const denominations = document.getElementById(\"denominations\").value.split(',').map(Number);\n        const result = [];\n\n        denominations.sort((a, b) => b - a);\n        let remainingAmount = amount;\n\n        for (const coin of denominations) {\n            while (remainingAmount >= coin) {\n                remainingAmount -= coin;\n                result.push(coin);\n            }\n        }\n        document.getElementById(\"coinChangeResult\").innerText = `Coins used: ${result.join(\", \")}`;\n    }\n\n    function selectActivities() {\n        const activityInput = document.getElementById(\"activities\").value;\n        const activities = activityInput.split(';').map(item => item.split(',').map(Number));\n        activities.sort((a, b) => a[1] - b[1]);\n\n        let lastFinishTime = -1;\n        const chosenActivities = [];\n\n        for (const activity of activities) {\n            if (activity[0] >= lastFinishTime) {\n                chosenActivities.push(activity);\n                lastFinishTime = activity[1];\n            }\n        }\n        document.getElementById(\"activityResult\").innerText = `Selected Activities: ${chosenActivities.map(a => `[${a.join(',')}]`).join(\", \")}`;\n    }\n\n    function fractionalKnapsack() {\n        const itemData = document.getElementById(\"itemData\").value;\n        const capacity = parseInt(document.getElementById(\"knapsackCapacity\").value);\n        const items = itemData.split(';').map(item => {\n            const [weight, value] = item.split(',').map(Number);\n            return {weight, value, ratio: value / weight};\n        });\n\n        items.sort((a, b) => b.ratio - a.ratio);\n\n        let totalValue = 0;\n        let totalWeight = 0;\n        \n        for (const item of items) {\n            if (totalWeight + item.weight <= capacity) {\n                totalWeight += item.weight;\n                totalValue += item.value;\n            } else {\n                const remain = capacity - totalWeight;\n                totalValue += item.ratio * remain;\n                break;\n            }\n        }\n        document.getElementById(\"knapsackResult\").innerText = `Maximum Value: ${totalValue.toFixed(2)}`;\n    }\n</script>\n\n</body>\n</html>"
