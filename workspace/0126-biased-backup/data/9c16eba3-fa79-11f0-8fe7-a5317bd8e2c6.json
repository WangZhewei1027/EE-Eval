  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Neural Networks Interactive Sandbox</title>\n  <style>\n    /* Minimal styling: only to make layout readable. No colors, no animations. */\n    body { font-family: sans-serif; margin: 12px; color: black; background: white; }\n    section { margin-bottom: 12px; padding: 6px; border: 1px solid #00000020; }\n    label { display: inline-block; width: 140px; }\n    input[type=\"number\"] { width: 80px; }\n    textarea { width: 100%; height: 120px; }\n    canvas { border: 1px solid #000; display: block; margin-bottom: 6px; }\n    table { border-collapse: collapse; }\n    td, th { border: 1px solid #ccc; padding: 4px; }\n    .row { margin-bottom: 6px; }\n    .small { font-size: 12px; }\n  </style>\n</head>\n<body>\n\n<h1>Neural Networks Interactive Sandbox</h1>\n\n<section id=\"architecture\">\n  <strong>1) Network Architecture</strong>\n  <div class=\"row\">\n    <label>Layers (input first):</label>\n    <span id=\"layersList\"></span>\n  </div>\n  <div class=\"row\">\n    <label>Add layer neurons:</label>\n    <input id=\"newNeurons\" type=\"number\" value=\"4\" min=\"1\">\n    <label>Activation:</label>\n    <select id=\"newActivation\">\n      <option value=\"linear\">linear</option>\n      <option value=\"sigmoid\" selected>sigmoid</option>\n      <option value=\"tanh\">tanh</option>\n      <option value=\"relu\">relu</option>\n    </select>\n    <button id=\"addLayer\">Add Layer</button>\n    <button id=\"removeLayer\">Remove Last</button>\n  </div>\n  <div class=\"row\">\n    <button id=\"applyArchitecture\">Apply / Rebuild Network</button>\n    <button id=\"randomInit\">Random Init (normal)</button>\n    <button id=\"xavierInit\">Xavier Init</button>\n    <button id=\"zeroInit\">Zero Init</button>\n  </div>\n</section>\n\n<section id=\"dataset\">\n  <strong>2) Dataset</strong>\n  <div class=\"row\">\n    <label>Type:</label>\n    <select id=\"dataType\">\n      <option value=\"linear\">Linear Separable</option>\n      <option value=\"xor\">XOR</option>\n      <option value=\"circle\">Circle</option>\n      <option value=\"blobs\">Blobs</option>\n      <option value=\"custom\">Custom (manual points)</option>\n    </select>\n    <label>Points:</label>\n    <input id=\"numPoints\" type=\"number\" value=\"200\" min=\"4\">\n    <label>Noise:</label>\n    <input id=\"noise\" type=\"number\" value=\"0.1\" step=\"0.01\" min=\"0\">\n    <button id=\"generateData\">Generate</button>\n  </div>\n  <div class=\"row\">\n    <label>Canvas size:</label>\n    <input id=\"canvasSize\" type=\"number\" value=\"400\" min=\"100\">\n    <button id=\"resizeCanvas\">Resize</button>\n    <button id=\"drawDecision\">Draw Decision Grid</button>\n    <button id=\"clearCanvas\">Clear Canvas</button>\n  </div>\n  <canvas id=\"dataCanvas\" width=\"400\" height=\"400\"></canvas>\n  <div class=\"row\">\n    <label>Manual points (x,y,label per line):</label>\n    <textarea id=\"customPoints\" placeholder=\"0.1,0.2,0\"></textarea>\n    <div><button id=\"applyCustom\">Apply Custom Points</button></div>\n  </div>\n</section>\n\n<section id=\"training\">\n  <strong>3) Training & Controls</strong>\n  <div class=\"row\">\n    <label>Learning rate:</label>\n    <input id=\"lr\" type=\"number\" step=\"0.001\" value=\"0.1\" min=\"0.0001\">\n    <label>Momentum:</label>\n    <input id=\"momentum\" type=\"number\" step=\"0.01\" value=\"0.0\" min=\"0\">\n    <label>Weight decay:</label>\n    <input id=\"decay\" type=\"number\" step=\"0.0001\" value=\"0.0\" min=\"0\">\n  </div>\n  <div class=\"row\">\n    <label>Batch size:</label>\n    <input id=\"batchSize\" type=\"number\" value=\"16\" min=\"1\">\n    <label>Epochs:</label>\n    <input id=\"epochs\" type=\"number\" value=\"100\" min=\"1\">\n    <label>Loss:</label>\n    <select id=\"lossFunc\">\n      <option value=\"mse\">MSE</option>\n      <option value=\"bce\">Binary Cross-Entropy</option>\n    </select>\n  </div>\n  <div class=\"row\">\n    <label>Mode:</label>\n    <select id=\"trainMode\">\n      <option value=\"sgd\">SGD (sample)</option>\n      <option value=\"batch\">Batch</option>\n    </select>\n    <button id=\"trainAll\">Train Full</button>\n    <button id=\"trainStep\">Train Single Epoch</button>\n    <button id=\"stopTrain\">Stop</button>\n  </div>\n  <div class=\"row\">\n    <label>Auto-stop target loss:</label>\n    <input id=\"targetLoss\" type=\"number\" step=\"0.0001\" value=\"0.01\" min=\"0\">\n    <button id=\"trainUntil\">Train Until</button>\n  </div>\n  <div class=\"row\">\n    <label>Grid-search LR (comma):</label>\n    <input id=\"gridLR\" type=\"text\" value=\"0.1,0.01,0.001\">\n    <label>Decay list:</label>\n    <input id=\"gridDecay\" type=\"text\" value=\"0,0.0001\">\n    <button id=\"gridSearch\">Run Grid Search</button>\n  </div>\n\n  <div class=\"row\">\n    <label>Loss plot:</label>\n    <canvas id=\"lossCanvas\" width=\"600\" height=\"120\"></canvas>\n    <button id=\"clearLoss\">Clear Loss</button>\n  </div>\n\n  <div class=\"row\">\n    <label>Snapshot name:</label>\n    <input id=\"snapshotName\" type=\"text\" value=\"\">\n    <button id=\"saveSnapshot\">Save Snapshot</button>\n    <select id=\"snapshots\"></select>\n    <button id=\"loadSnapshot\">Load Snapshot</button>\n    <button id=\"deleteSnapshot\">Delete Snapshot</button>\n  </div>\n</section>\n\n<section id=\"inspect\">\n  <strong>4) Inspect / Manual Control</strong>\n  <div class=\"row\">\n    <label>Input values (comma):</label>\n    <input id=\"forwardInput\" type=\"text\" value=\"0.5,0.5\">\n    <button id=\"forwardRun\">Forward</button>\n    <label>Sample index:</label>\n    <input id=\"sampleIndex\" type=\"number\" value=\"0\" min=\"0\">\n    <button id=\"inspectSample\">Inspect Sample</button>\n  </div>\n  <div class=\"row\">\n    <label>Activations:</label>\n    <textarea id=\"activations\" readonly></textarea>\n  </div>\n  <div class=\"row\">\n    <label>Weights (editable):</label>\n    <div id=\"weightsTableWrap\"></div>\n    <button id=\"downloadNetwork\">Export JSON</button>\n    <button id=\"importNetwork\">Import JSON</button>\n    <textarea id=\"networkJSON\" placeholder=\"Paste JSON here to import\"></textarea>\n  </div>\n  <div class=\"row\">\n    <label>Manual Backprop Step:</label>\n    <button id=\"bpStepForward\">Step Forward</button>\n    <button id=\"bpComputeGrad\">Compute Gradients</button>\n    <button id=\"bpApply\">Apply Gradients</button>\n    <div class=\"small\">Use these to step through the backprop process manually for one sample.</div>\n  </div>\n</section>\n\n<section id=\"logs\">\n  <strong>5) Logs & History</strong>\n  <div class=\"row\">\n    <label>Console:</label>\n    <textarea id=\"logConsole\" readonly></textarea>\n    <div>\n      <button id=\"clearLog\">Clear Log</button>\n      <button id=\"downloadLog\">Download Log</button>\n    </div>\n  </div>\n</section>\n\n<script>\n/*\n  Neural Networks Interactive Sandbox\n  - Minimal visual styling\n  - Lots of interactive controls and workflows\n  - Plain JS implementation of small fully connected neural net\n*/\n\n/* Utility */\nfunction randn() {\n  // Box-Muller\n  let u = 0, v = 0;\n  while(u === 0) u = Math.random();\n  while(v === 0) v = Math.random();\n  return Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);\n}\nfunction zeros(n) { return Array(n).fill(0); }\nfunction range(n) { return Array.from({length:n}, (_,i)=>i); }\nfunction clone(obj) { return JSON.parse(JSON.stringify(obj)); }\nfunction nowStr() { return (new Date()).toISOString().replace('T',' ').split('.')[0]; }\n\n/* Logging */\nfunction log(msg) {\n  const ta = document.getElementById('logConsole');\n  ta.value += `[${nowStr()}] ${msg}\\n`;\n  ta.scrollTop = ta.scrollHeight;\n}\n\n/* Activation functions and derivatives */\nconst Activations = {\n  linear: {\n    f: x => x,\n    df: x => 1\n  },\n  sigmoid: {\n    f: x => 1 / (1 + Math.exp(-x)),\n    df: y => y * (1 - y) // expects y = sigmoid(x)\n  },\n  tanh: {\n    f: x => Math.tanh(x),\n    df: y => 1 - (y*y) // expects y = tanh(x)\n  },\n  relu: {\n    f: x => Math.max(0, x),\n    df: x => x > 0 ? 1 : 0 // expects raw pre-activation\n  }\n};\n\n/* Simple fully connected network representation */\nlet Net = {\n  layers: [], // each layer: { size, activation }\n  weights: [], // for l from 1..L-1 weights[l-1] = matrix size: layers[l].size x (layers[l-1].size + 1) including bias\n  velocities: [], // same shape for momentum\n  initialized: false\n};\n\nfunction createNetwork(sizes, activations) {\n  Net.layers = sizes.map((s,i)=>({size:s, activation: activations[i]||'linear'}));\n  Net.weights = [];\n  Net.velocities = [];\n  for (let l = 1; l < Net.layers.length; l++) {\n    let rows = Net.layers[l].size;\n    let cols = Net.layers[l-1].size + 1;\n    let W = Array.from({length:rows}, () => Array.from({length:cols}, ()=>0));\n    let V = Array.from({length:rows}, () => Array.from({length:cols}, ()=>0));\n    Net.weights.push(W);\n    Net.velocities.push(V);\n  }\n  Net.initialized = true;\n}\n\n/* Initialization */\nfunction randomInit(std=0.1, seed=null) {\n  for (let l = 0; l < Net.weights.length; l++) {\n    for (let i = 0; i < Net.weights[l].length; i++) {\n      for (let j = 0; j < Net.weights[l][i].length; j++) {\n        Net.weights[l][i][j] = randn() * std;\n        Net.velocities[l][i][j] = 0;\n      }\n    }\n  }\n}\n\nfunction xavierInit() {\n  for (let l = 0; l < Net.weights.length; l++) {\n    let inSize = Net.weights[l][0].length - 1;\n    let std = Math.sqrt(2 / (inSize + Net.weights[l].length));\n    for (let i = 0; i < Net.weights[l].length; i++) {\n      for (let j = 0; j < Net.weights[l][i].length; j++) {\n        Net.weights[l][i][j] = randn() * std;\n        Net.velocities[l][i][j] = 0;\n      }\n    }\n  }\n}\n\nfunction zeroInit() {\n  for (let l = 0; l < Net.weights.length; l++) {\n    for (let i = 0; i < Net.weights[l].length; i++) {\n      for (let j = 0; j < Net.weights[l][i].length; j++) {\n        Net.weights[l][i][j] = 0;\n        Net.velocities[l][i][j] = 0;\n      }\n    }\n  }\n}\n\n/* Forward pass for a single input */\nfunction forward(input) {\n  let activations = [input.slice()]; // no bias in stored activations\n  let preacts = [null];\n  for (let l = 1; l < Net.layers.length; l++) {\n    let W = Net.weights[l-1];\n    let prev = activations[l-1];\n    let row = [];\n    let zrow = [];\n    for (let i = 0; i < Net.layers[l].size; i++) {\n      let z = 0;\n      for (let j = 0; j < prev.length; j++) z += W[i][j] * prev[j];\n      let bias = W[i][W[i].length - 1];\n      z += bias;\n      zrow.push(z);\n      let actName = Net.layers[l].activation;\n      let a;\n      if (actName === 'relu') a = Activations.relu.f(z);\n      else if (actName === 'sigmoid') a = Activations.sigmoid.f(z);\n      else if (actName === 'tanh') a = Activations.tanh.f(z);\n      else a = z;\n      row.push(a);\n    }\n    preacts.push(zrow);\n    activations.push(row);\n  }\n  return {activations, preacts};\n}\n\n/* Compute loss and derivative */\nfunction computeLoss(pred, target, lossType='mse') {\n  if (lossType === 'mse') {\n    let s = 0;\n    for (let i = 0; i < pred.length; i++) s += 0.5 * Math.pow(pred[i] - target[i], 2);\n    return s;\n  } else if (lossType === 'bce') {\n    // binary cross entropy for single output assumed\n    let p = Math.min(Math.max(pred[0], 1e-12), 1-1e-12);\n    let t = target[0];\n    return -(t * Math.log(p) + (1-t) * Math.log(1-p));\n  }\n  return 0;\n}\n\n/* Backprop for a single sample -> returns gradients (same shape as weights) */\nfunction backprop(sampleInput, sampleTarget, lossType='mse') {\n  let {activations, preacts} = forward(sampleInput);\n  let L = Net.layers.length - 1;\n  // initialize gradients\n  let grads = Net.weights.map(layer => layer.map(row => row.map(_=>0)));\n  // output layer delta\n  let output = activations[L];\n  let delta = Array(output.length).fill(0);\n  if (lossType === 'mse') {\n    for (let i = 0; i < output.length; i++) {\n      let diff = output[i] - sampleTarget[i];\n      let actName = Net.layers[L].activation;\n      let dAct;\n      if (actName === 'sigmoid') dAct = Activations.sigmoid.df(output[i]);\n      else if (actName === 'tanh') dAct = Activations.tanh.df(output[i]);\n      else if (actName === 'relu') dAct = Activations.relu.df(preacts[L][i]);\n      else dAct = 1;\n      delta[i] = diff * dAct;\n    }\n  } else if (lossType === 'bce') {\n    // assuming single output\n    let p = output[0];\n    let t = sampleTarget[0];\n    let dLoss = (p - t) / (p * (1-p) + 1e-12); // derivative wrt pre-activation for sigmoid\n    let actName = Net.layers[L].activation;\n    let dAct;\n    if (actName === 'sigmoid') dAct = Activations.sigmoid.df(output[0]);\n    else if (actName === 'tanh') dAct = Activations.tanh.df(output[0]);\n    else if (actName === 'relu') dAct = Activations.relu.df(preacts[L][0]);\n    else dAct = 1;\n    delta[0] = dLoss * dAct;\n  }\n  // compute gradient for output layer\n  for (let i = 0; i < delta.length; i++) {\n    let prev = activations[L-1];\n    for (let j = 0; j < prev.length; j++) grads[L-1][i][j] = delta[i] * prev[j];\n    grads[L-1][i][prev.length] = delta[i] * 1; // bias\n  }\n  // propagate backward\n  for (let l = L-1; l >= 1; l--) {\n    let nextW = Net.weights[l]; // weights from layer l to l+1\n    let newdelta = Array(Net.layers[l].size).fill(0);\n    for (let i = 0; i < Net.layers[l].size; i++) {\n      let sum = 0;\n      for (let k = 0; k < nextW.length; k++) {\n        sum += nextW[k][i] * delta[k];\n      }\n      // derivative of activation at layer l\n      let actName = Net.layers[l].activation;\n      let dAct;\n      let a = activations[l][i];\n      if (actName === 'sigmoid') dAct = Activations.sigmoid.df(a);\n      else if (actName === 'tanh') dAct = Activations.tanh.df(a);\n      else if (actName === 'relu') dAct = Activations.relu.df(preacts[l][i]);\n      else dAct = 1;\n      newdelta[i] = sum * dAct;\n    }\n    delta = newdelta;\n    // gradients for layer l-1 parameters (weights[l-1])\n    for (let i = 0; i < delta.length; i++) {\n      let prev = activations[l-1];\n      for (let j = 0; j < prev.length; j++) grads[l-1][i][j] = delta[i] * prev[j];\n      grads[l-1][i][prev.length] = delta[i] * 1;\n    }\n  }\n  return grads;\n}\n\n/* Apply gradients with learning rate, momentum, decay */\nfunction applyGradients(grads, lr=0.1, momentum=0.0, decay=0.0) {\n  for (let l = 0; l < Net.weights.length; l++) {\n    for (let i = 0; i < Net.weights[l].length; i++) {\n      for (let j = 0; j < Net.weights[l][i].length; j++) {\n        // velocity update\n        Net.velocities[l][i][j] = momentum * Net.velocities[l][i][j] - lr * grads[l][i][j];\n        Net.weights[l][i][j] += Net.velocities[l][i][j];\n        // weight decay (L2)\n        if (decay) Net.weights[l][i][j] *= (1 - decay);\n      }\n    }\n  }\n}\n\n/* Dataset handling */\nlet Dataset = {\n  X: [], // array of input arrays\n  Y: []  // array of target arrays\n};\n\nfunction generateData(type, n=200, noise=0.1) {\n  let X = [], Y = [];\n  if (type === 'linear') {\n    for (let i = 0; i < n; i++) {\n      let x1 = Math.random()*2 - 1;\n      let x2 = Math.random()*2 - 1;\n      let label = (x1 + x2 + randn()*noise) > 0 ? 1 : 0;\n      X.push([x1, x2]);\n      Y.push([label]);\n    }\n  } else if (type === 'xor') {\n    // few clusters\n    for (let i = 0; i < n; i++) {\n      let sx = (Math.random() < 0.5) ? -1 : 1;\n      let sy = (Math.random() < 0.5) ? -1 : 1;\n      let x1 = sx*0.6 + randn()*noise;\n      let x2 = sy*0.6 + randn()*noise;\n      let label = (sx * sy) > 0 ? 0 : 1; // opposite quadrants\n      X.push([x1, x2]);\n      Y.push([label]);\n    }\n  } else if (type === 'circle') {\n    for (let i = 0; i < n; i++) {\n      let r = Math.random()*1.2;\n      let a = Math.random() * Math.PI * 2;\n      let x1 = Math.cos(a) * r + randn()*noise;\n      let x2 = Math.sin(a) * r + randn()*noise;\n      let label = (r < 0.6) ? 1 : 0;\n      X.push([x1, x2]);\n      Y.push([label]);\n    }\n  } else if (type === 'blobs') {\n    let centers = [[-0.6,-0.6],[0.6,0.6],[0.6,-0.6],[-0.6,0.6]];\n    for (let i = 0; i < n; i++) {\n      let c = centers[Math.floor(Math.random()*centers.length)];\n      let x1 = c[0] + randn()*noise;\n      let x2 = c[1] + randn()*noise;\n      let label = (centers.indexOf(c) % 2) === 0 ? 0 : 1;\n      X.push([x1,x2]);\n      Y.push([label]);\n    }\n  } else {\n    // custom; leave empty – handled separately\n  }\n  Dataset.X = X;\n  Dataset.Y = Y;\n  log(`Generated dataset: type=${type} size=${X.length}`);\n  drawData();\n}\n\n/* Canvas drawing utilities */\nconst dataCanvas = document.getElementById('dataCanvas');\nconst dataCtx = dataCanvas.getContext('2d');\n\nfunction toCanvasCoords(x,y) {\n  const size = dataCanvas.width;\n  // assume input range approx [-1.5, 1.5]\n  const range = 1.5;\n  const cx = Math.round(((x + range) / (2*range)) * size);\n  const cy = Math.round(((1 - (y + range) / (2*range))) * size);\n  return [cx, cy];\n}\n\nfunction drawData(clear=false) {\n  const ctx = dataCtx;\n  ctx.clearRect(0,0,dataCanvas.width,dataCanvas.height);\n  // draw points\n  for (let i = 0; i < Dataset.X.length; i++) {\n    let x = Dataset.X[i][0], y = Dataset.X[i][1];\n    let lab = Dataset.Y[i][0];\n    let [cx, cy] = toCanvasCoords(x,y);\n    ctx.beginPath();\n    if (lab === 0) {\n      ctx.rect(cx-3, cy-3, 6, 6);\n      ctx.stroke();\n    } else {\n      ctx.moveTo(cx-4, cy-4);\n      ctx.lineTo(cx+4, cy+4);\n      ctx.moveTo(cx+4, cy-4);\n      ctx.lineTo(cx-4, cy+4);\n      ctx.stroke();\n    }\n  }\n}\n\n/* Decision grid */\nfunction drawDecisionGrid(res=80, threshold=0.5) {\n  const ctx = dataCtx;\n  let size = dataCanvas.width;\n  let step = size / res;\n  for (let i = 0; i < res; i++) {\n    for (let j = 0; j < res; j++) {\n      // center of cell -> convert to x,y\n      let px = (i + 0.5) * step;\n      let py = (j + 0.5) * step;\n      // convert to coordinate space [-range,range]\n      let range = 1.5;\n      let x = (px / size) * 2*range - range;\n      let y = (1 - py / size) * 2*range - range;\n      if (!Net.initialized) continue;\n      let out = forward([x,y]).activations.slice(-1)[0][0];\n      // draw small filled rectangle scaled by output\n      ctx.beginPath();\n      let alpha = Math.max(0, Math.min(1, out));\n      // draw as grayscale by filling with black at varying alpha\n      ctx.globalAlpha = 0.08 + 0.84 * alpha; // visual; still monochrome\n      ctx.fillRect(i*step, j*step, step, step);\n      ctx.globalAlpha = 1.0;\n    }\n  }\n  // draw points on top\n  drawData();\n}\n\n/* Loss plotting */\nconst lossCanvas = document.getElementById('lossCanvas');\nconst lossCtx = lossCanvas.getContext('2d');\nlet lossHistory = [];\n\nfunction plotLoss() {\n  let ctx = lossCtx;\n  ctx.clearRect(0,0,lossCanvas.width, lossCanvas.height);\n  if (lossHistory.length === 0) return;\n  let w = lossCanvas.width, h = lossCanvas.height;\n  let maxL = Math.max(...lossHistory);\n  let minL = Math.min(...lossHistory);\n  if (maxL === minL) { maxL = minL + 1e-6; }\n  ctx.beginPath();\n  for (let i = 0; i < lossHistory.length; i++) {\n    let x = (i / (lossHistory.length - 1 || 1)) * w;\n    let y = h - ((lossHistory[i] - minL) / (maxL - minL)) * h;\n    if (i === 0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n  }\n  ctx.stroke();\n}\n\n/* Weights table */\nfunction renderWeightsTable() {\n  const wrap = document.getElementById('weightsTableWrap');\n  wrap.innerHTML = '';\n  if (!Net.initialized) { wrap.innerText = 'Network not initialized'; return; }\n  let table = document.createElement('table');\n  let headerRow = document.createElement('tr');\n  headerRow.appendChild(document.createElement('th')).innerText = 'Layer';\n  headerRow.appendChild(document.createElement('th')).innerText = 'Neuron';\n  headerRow.appendChild(document.createElement('th')).innerText = 'Weights (inputs...,bias)';\n  table.appendChild(headerRow);\n  for (let l = 0; l < Net.weights.length; l++) {\n    for (let i = 0; i < Net.weights[l].length; i++) {\n      let tr = document.createElement('tr');\n      let tdL = document.createElement('td'); tdL.innerText = `${l+1}`;\n      let tdN = document.createElement('td'); tdN.innerText = `${i}`;\n      let tdW = document.createElement('td');\n      for (let j = 0; j < Net.weights[l][i].length; j++) {\n        let inp = document.createElement('input');\n        inp.type = 'number';\n        inp.step = '0.0001';\n        inp.value = Net.weights[l][i][j].toFixed(6);\n        inp.dataset.layer = l;\n        inp.dataset.row = i;\n        inp.dataset.col = j;\n        inp.style.width = '90px';\n        inp.addEventListener('change', (ev)=>{\n          let L = parseInt(ev.target.dataset.layer);\n          let R = parseInt(ev.target.dataset.row);\n          let C = parseInt(ev.target.dataset.col);\n          Net.weights[L][R][C] = parseFloat(ev.target.value);\n          log(`Weight edited L${L} R${R} C${C} set to ${ev.target.value}`);\n        });\n        tdW.appendChild(inp);\n      }\n      tr.appendChild(tdL); tr.appendChild(tdN); tr.appendChild(tdW);\n      table.appendChild(tr);\n    }\n  }\n  wrap.appendChild(table);\n}\n\n/* Export / Import network */\nfunction exportNetworkJSON() {\n  let obj = {\n    layers: Net.layers,\n    weights: Net.weights\n  };\n  return JSON.stringify(obj, null, 2);\n}\nfunction importNetworkJSON(json) {\n  try {\n    let obj = JSON.parse(json);\n    Net.layers = obj.layers;\n    Net.weights = obj.weights;\n    Net.velocities = Net.weights.map(layer => layer.map(row => row.map(_=>0)));\n    Net.initialized = true;\n    renderLayersListUI();\n    renderWeightsTable();\n    log('Imported network JSON');\n  } catch (e) {\n    log('Import failed: ' + e.message);\n  }\n}\n\n/* Training loop management */\nlet training = { running: false, stopRequested: false };\n\nasync function trainFull(epochs, lr, batchSize, momentum, decay, mode='sgd', lossType='mse', onEpoch=null) {\n  training.running = true; training.stopRequested = false;\n  let N = Dataset.X.length;\n  for (let epoch = 0; epoch < epochs; epoch++) {\n    if (training.stopRequested) break;\n    // shuffle indices\n    let idx = range(N);\n    for (let i = N-1; i > 0; i--) {\n      let r = Math.floor(Math.random() * (i+1));\n      [idx[i], idx[r]] = [idx[r], idx[i]];\n    }\n    if (mode === 'sgd') {\n      for (let t = 0; t < N; t++) {\n        let i = idx[t];\n        let grads = backprop(Dataset.X[i], Dataset.Y[i], lossType);\n        applyGradients(grads, lr, momentum, decay);\n      }\n    } else if (mode === 'batch') {\n      // full batch gradient accumulate\n      let accum = Net.weights.map(layer => layer.map(row => row.map(_=>0)));\n      for (let t = 0; t < N; t++) {\n        let i = idx[t];\n        let g = backprop(Dataset.X[i], Dataset.Y[i], lossType);\n        // accumulate\n        for (let l = 0; l < accum.length; l++) {\n          for (let ii = 0; ii < accum[l].length; ii++) {\n            for (let j = 0; j < accum[l][ii].length; j++) {\n              accum[l][ii][j] += g[l][ii][j];\n            }\n          }\n        }\n      }\n      // average\n      for (let l = 0; l < accum.length; l++) {\n        for (let ii = 0; ii < accum[l].length; ii++) {\n          for (let j = 0; j < accum[l][ii].length; j++) {\n            accum[l][ii][j] /= N;\n          }\n        }\n      }\n      applyGradients(accum, lr, momentum, decay);\n    }\n    // compute epoch loss\n    let totalLoss = 0;\n    for (let i = 0; i < N; i++) {\n      let pred = forward(Dataset.X[i]).activations.slice(-1)[0];\n      totalLoss += computeLoss(pred, Dataset.Y[i], lossType);\n    }\n    let avgLoss = totalLoss / N;\n    lossHistory.push(avgLoss);\n    plotLoss();\n    if (onEpoch) onEpoch(epoch, avgLoss);\n    await new Promise(res => setTimeout(res, 1)); // allow UI update\n  }\n  training.running = false;\n  if (training.stopRequested) log('Training stopped by user.');\n  else log('Training finished.');\n}\n\n/* Grid search */\nasync function runGridSearch(lrList, decayList) {\n  log('Starting grid search');\n  let results = [];\n  let originalNet = { layers: clone(Net.layers), weights: clone(Net.weights) };\n  for (let lr of lrList) {\n    for (let dec of decayList) {\n      // restore\n      Net.layers = clone(originalNet.layers);\n      Net.weights = clone(originalNet.weights);\n      Net.velocities = Net.weights.map(layer => layer.map(row => row.map(_=>0)));\n      // quick train few epochs\n      await trainFull(30, lr, 16, 0.0, dec, 'sgd', document.getElementById('lossFunc').value, (ep,loss)=>{\n        // noop\n      });\n      // evaluate\n      let total = 0;\n      for (let i = 0; i < Dataset.X.length; i++) {\n        let pred = forward(Dataset.X[i]).activations.slice(-1)[0];\n        let l = computeLoss(pred, Dataset.Y[i], document.getElementById('lossFunc').value);\n        total += l;\n      }\n      let avg = total / Dataset.X.length;\n      results.push({lr:lr, decay:dec, loss:avg});\n      log(`Grid lr=${lr} decay=${dec} -> loss=${avg.toFixed(6)}`);\n    }\n  }\n  // restore original\n  Net.layers = originalNet.layers;\n  Net.weights = originalNet.weights;\n  Net.velocities = Net.weights.map(layer => layer.map(row => row.map(_=>0)));\n  renderWeightsTable();\n  log('Grid search finished');\n  // show results\n  let txt = 'LR,Decay,Loss\\n' + results.map(r=>`${r.lr},${r.decay},${r.loss}`).join('\\n');\n  alert('Grid search results:\\n' + txt);\n}\n\n/* UI wiring */\nfunction renderLayersListUI() {\n  const span = document.getElementById('layersList');\n  span.innerHTML = '';\n  if (!Net.initialized) {\n    span.innerText = 'Not built';\n    return;\n  }\n  for (let i = 0; i < Net.layers.length; i++) {\n    let s = document.createElement('span');\n    s.innerText = `[${i} ${Net.layers[i].size} ${Net.layers[i].activation}] `;\n    span.appendChild(s);\n  }\n}\n\n/* Snapshot store */\nlet Snapshots = {};\n\nfunction saveSnapshot(name) {\n  if (!name) name = nowStr();\n  Snapshots[name] = {\n    layers: clone(Net.layers),\n    weights: clone(Net.weights)\n  };\n  updateSnapshotsList();\n  log(`Saved snapshot: ${name}`);\n}\nfunction loadSnapshot(name) {\n  if (!Snapshots[name]) { log('Snapshot not found'); return; }\n  Net.layers = clone(Snapshots[name].layers);\n  Net.weights = clone(Snapshots[name].weights);\n  Net.velocities = Net.weights.map(layer => layer.map(row => row.map(_=>0)));\n  Net.initialized = true;\n  renderLayersListUI();\n  renderWeightsTable();\n  log(`Loaded snapshot: ${name}`);\n}\nfunction deleteSnapshot(name) {\n  delete Snapshots[name];\n  updateSnapshotsList();\n}\nfunction updateSnapshotsList() {\n  let sel = document.getElementById('snapshots');\n  sel.innerHTML = '';\n  for (let k of Object.keys(Snapshots)) {\n    let opt = document.createElement('option');\n    opt.value = k; opt.innerText = k;\n    sel.appendChild(opt);\n  }\n}\n\n/* UI events binding */\ndocument.getElementById('addLayer').addEventListener('click', ()=>{\n  let n = parseInt(document.getElementById('newNeurons').value) || 1;\n  let act = document.getElementById('newActivation').value;\n  if (!Net.initialized) {\n    // start with input layer default 2\n    createNetwork([2, n], ['linear', act]);\n  } else {\n    Net.layers.push({size:n, activation:act});\n    // add weight matrix from prev to new\n    let prev = Net.layers[Net.layers.length - 2].size;\n    let rows = n, cols = prev + 1;\n    let W = Array.from({length:rows}, ()=>Array.from({length:cols}, ()=>randn()*0.1));\n    let V = Array.from({length:rows}, ()=>Array.from({length:cols}, ()=>0));\n    Net.weights.push(W);\n    Net.velocities.push(V);\n  }\n  renderLayersListUI();\n  renderWeightsTable();\n});\ndocument.getElementById('removeLayer').addEventListener('click', ()=>{\n  if (!Net.initialized) return;\n  if (Net.layers.length <= 2) { log('Cannot remove: need at least input and output'); return; }\n  Net.layers.pop();\n  Net.weights.pop();\n  Net.velocities.pop();\n  renderLayersListUI();\n  renderWeightsTable();\n});\ndocument.getElementById('applyArchitecture').addEventListener('click', ()=>{\n  // build from displayed layers string? allow quick prompt to set sizes and activations\n  let promptStr = prompt('Enter layer sizes comma separated (e.g. 2,4,4,1):', Net.layers.length ? Net.layers.map(l=>l.size).join(',') : '2,4,1');\n  if (!promptStr) return;\n  let sizes = promptStr.split(',').map(s=>parseInt(s.trim())).filter(s=>!isNaN(s) && s>0);\n  if (sizes.length < 2) { alert('Need at least input and output'); return; }\n  // ask activations\n  let actsPrompt = prompt('Enter activations for each layer comma separated (optional). Example: linear,sigmoid,sigmoid', sizes.map((s,i)=> i===0?'linear':'sigmoid').join(','));\n  let acts = actsPrompt ? actsPrompt.split(',').map(s=>s.trim()) : sizes.map((s,i)=> i===0?'linear':'sigmoid');\n  createNetwork(sizes, acts);\n  randomInit(0.1);\n  renderLayersListUI();\n  renderWeightsTable();\n  log('Network rebuilt with sizes: ' + sizes.join(','));\n});\ndocument.getElementById('randomInit').addEventListener('click', ()=>{\n  randomInit(0.1);\n  renderWeightsTable();\n  log('Random init applied');\n});\ndocument.getElementById('xavierInit').addEventListener('click', ()=>{\n  xavierInit();\n  renderWeightsTable();\n  log('Xavier init applied');\n});\ndocument.getElementById('zeroInit').addEventListener('click', ()=>{\n  zeroInit();\n  renderWeightsTable();\n  log('Zero init applied');\n});\n\n/* Dataset UI */\ndocument.getElementById('generateData').addEventListener('click', ()=>{\n  let type = document.getElementById('dataType').value;\n  let n = parseInt(document.getElementById('numPoints').value);\n  let noise = parseFloat(document.getElementById('noise').value);\n  generateData(type, n, noise);\n});\ndocument.getElementById('resizeCanvas').addEventListener('click', ()=>{\n  let s = parseInt(document.getElementById('canvasSize').value);\n  dataCanvas.width = s; dataCanvas.height = s;\n  drawData();\n});\ndocument.getElementById('drawDecision').addEventListener('click', ()=>{\n  drawDecisionGrid();\n});\ndocument.getElementById('clearCanvas').addEventListener('click', ()=>{\n  dataCtx.clearRect(0,0,dataCanvas.width,dataCanvas.height);\n});\ndocument.getElementById('applyCustom').addEventListener('click', ()=>{\n  let txt = document.getElementById('customPoints').value.trim();\n  if (!txt) return;\n  let lines = txt.split('\\n');\n  let X=[], Y=[];\n  for (let ln of lines) {\n    let parts = ln.split(',').map(s=>s.trim());\n    if (parts.length < 3) continue;\n    let x = parseFloat(parts[0]), y = parseFloat(parts[1]), lab = parseFloat(parts[2]);\n    if (isNaN(x) || isNaN(y) || isNaN(lab)) continue;\n    X.push([x,y]); Y.push([lab]);\n  }\n  Dataset.X = X; Dataset.Y = Y;\n  drawData();\n  log('Applied custom dataset with ' + X.length + ' points');\n});\n\n/* Training UI */\ndocument.getElementById('trainAll').addEventListener('click', async ()=>{\n  if (!Net.initialized) { alert('Build network first'); return; }\n  if (Dataset.X.length === 0) { alert('Generate dataset first'); return; }\n  let lr = parseFloat(document.getElementById('lr').value);\n  let momentum = parseFloat(document.getElementById('momentum').value);\n  let decay = parseFloat(document.getElementById('decay').value);\n  let epochs = parseInt(document.getElementById('epochs').value);\n  let batch = parseInt(document.getElementById('batchSize').value);\n  let mode = document.getElementById('trainMode').value;\n  let loss = document.getElementById('lossFunc').value;\n  lossHistory = [];\n  plotLoss();\n  log(`Starting training: epochs=${epochs} lr=${lr} mode=${mode} loss=${loss}`);\n  training.stopRequested = false;\n  await trainFull(epochs, lr, batch, momentum, decay, mode, loss, (ep, avgLoss)=>{\n    log(`Epoch ${ep+1}/${epochs} loss=${avgLoss.toFixed(6)}`);\n    // update weights table occasionally\n    if ((ep + 1) % Math.max(1, Math.floor(epochs/10)) === 0) renderWeightsTable();\n  });\n  renderWeightsTable();\n});\ndocument.getElementById('trainStep').addEventListener('click', async ()=>{\n  if (!Net.initialized) { alert('Build network first'); return; }\n  if (Dataset.X.length === 0) { alert('Generate dataset first'); return; }\n  let lr = parseFloat(document.getElementById('lr').value);\n  let momentum = parseFloat(document.getElementById('momentum').value);\n  let decay = parseFloat(document.getElementById('decay').value);\n  let batch = parseInt(document.getElementById('batchSize').value);\n  let mode = document.getElementById('trainMode').value;\n  let loss = document.getElementById('lossFunc').value;\n  await trainFull(1, lr, batch, momentum, decay, mode, loss, (ep, lossVal)=>{\n    log(`Single epoch done loss=${lossVal.toFixed(6)}`);\n  });\n  renderWeightsTable();\n});\ndocument.getElementById('stopTrain').addEventListener('click', ()=>{\n  training.stopRequested = true;\n  log('Stop requested');\n});\ndocument.getElementById('trainUntil').addEventListener('click', async ()=>{\n  if (!Net.initialized) { alert('Build network first'); return; }\n  let target = parseFloat(document.getElementById('targetLoss').value);\n  let lr = parseFloat(document.getElementById('lr').value);\n  let momentum = parseFloat(document.getElementById('momentum').value);\n  let decay = parseFloat(document.getElementById('decay').value);\n  let mode = document.getElementById('trainMode').value;\n  let loss = document.getElementById('lossFunc').value;\n  let epochs = 10000;\n  lossHistory = [];\n  let reached = false;\n  training.stopRequested = false;\n  await trainFull(epochs, lr, parseInt(document.getElementById('batchSize').value), momentum, decay, mode, loss, (ep, avgLoss)=>{\n    if (avgLoss <= target) { training.stopRequested = true; reached = true; }\n  });\n  if (reached) log('Target loss reached.');\n  renderWeightsTable();\n});\ndocument.getElementById('gridSearch').addEventListener('click', async ()=>{\n  if (!Net.initialized) { alert('Build network first'); return; }\n  let lrs = document.getElementById('gridLR').value.split(',').map(s=>parseFloat(s.trim())).filter(s=>!isNaN(s));\n  let decs = document.getElementById('gridDecay').value.split(',').map(s=>parseFloat(s.trim())).filter(s=>!isNaN(s));\n  await runGridSearch(lrs, decs);\n});\ndocument.getElementById('clearLoss').addEventListener('click', ()=>{ lossHistory = []; plotLoss(); });\n\n/* Snapshot controls */\ndocument.getElementById('saveSnapshot').addEventListener('click', ()=>{\n  let name = document.getElementById('snapshotName').value || nowStr();\n  saveSnapshot(name);\n});\ndocument.getElementById('loadSnapshot').addEventListener('click', ()=>{\n  let sel = document.getElementById('snapshots');\n  if (!sel.value) { alert('Select snapshot'); return; }\n  loadSnapshot(sel.value);\n});\ndocument.getElementById('deleteSnapshot').addEventListener('click', ()=>{\n  let sel = document.getElementById('snapshots');\n  if (!sel.value) return;\n  deleteSnapshot(sel.value);\n});\n\n/* Inspect controls */\ndocument.getElementById('forwardRun').addEventListener('click', ()=>{\n  if (!Net.initialized) { alert('Build network first'); return; }\n  let txt = document.getElementById('forwardInput').value;\n  let parts = txt.split(',').map(s=>parseFloat(s.trim()));\n  let res = forward(parts);\n  document.getElementById('activations').value = JSON.stringify(res.activations, null, 2);\n  log('Forward run with input: ' + parts.join(','));\n});\ndocument.getElementById('inspectSample').addEventListener('click', ()=>{\n  let idx = parseInt(document.getElementById('sampleIndex').value);\n  if (isNaN(idx) || idx < 0 || idx >= Dataset.X.length) { alert('Invalid sample index'); return; }\n  let x = Dataset.X[idx], y = Dataset.Y[idx];\n  let res = forward(x);\n  document.getElementById('activations').value = 'Input: ' + JSON.stringify(x) + '\\nTarget: ' + JSON.stringify(y) + '\\nActivations:\\n' + JSON.stringify(res.activations, null, 2);\n  log('Inspected sample ' + idx);\n});\n\n/* Export / import */\ndocument.getElementById('downloadNetwork').addEventListener('click', ()=>{\n  let json = exportNetworkJSON();\n  document.getElementById('networkJSON').value = json;\n  log('Exported network JSON to textbox');\n});\ndocument.getElementById('importNetwork').addEventListener('click', ()=>{\n  let json = document.getElementById('networkJSON').value;\n  if (!json) { alert('Paste JSON into box'); return; }\n  importNetworkJSON(json);\n});\n\n/* Manual backprop stepping */\nlet manualState = {\n  sample: null,\n  forwardResult: null,\n  grads: null\n};\ndocument.getElementById('bpStepForward').addEventListener('click', ()=>{\n  let idx = parseInt(document.getElementById('sampleIndex').value);\n  if (isNaN(idx) || idx < 0 || idx >= Dataset.X.length) { alert('Invalid sample index'); return; }\n  manualState.sample = idx;\n  manualState.forwardResult = forward(Dataset.X[idx]);\n  manualState.grads = null;\n  document.getElementById('activations').value = 'Forward result:\\n' + JSON.stringify(manualState.forwardResult.activations, null, 2);\n  log('Manual forward for sample ' + idx);\n});\ndocument.getElementById('bpComputeGrad').addEventListener('click', ()=>{\n  if (manualState.sample === null) { alert('Run forward first'); return; }\n  manualState.grads = backprop(Dataset.X[manualState.sample], Dataset.Y[manualState.sample], document.getElementById('lossFunc').value);\n  document.getElementById('activations').value += '\\n\\nComputed gradients (first layer shown):\\n';\n  document.getElementById('activations').value += JSON.stringify(manualState.grads.slice(0,2), null, 2);\n  log('Computed gradients for sample ' + manualState.sample);\n});\ndocument.getElementById('bpApply').addEventListener('click', ()=>{\n  if (!manualState.grads) { alert('Compute gradients first'); return; }\n  let lr = parseFloat(document.getElementById('lr').value);\n  let momentum = parseFloat(document.getElementById('momentum').value);\n  let decay = parseFloat(document.getElementById('decay').value);\n  applyGradients(manualState.grads, lr, momentum, decay);\n  renderWeightsTable();\n  log('Applied manual gradients for sample ' + manualState.sample);\n});\n\n/* Logs controls */\ndocument.getElementById('clearLog').addEventListener('click', ()=>{ document.getElementById('logConsole').value = ''; });\ndocument.getElementById('downloadLog').addEventListener('click', ()=>{\n  let text = document.getElementById('logConsole').value;\n  let blob = new Blob([text], {type: 'text/plain'});\n  let url = URL.createObjectURL(blob);\n  let a = document.createElement('a');\n  a.href = url; a.download = 'nn_log.txt';\n  a.click();\n  URL.revokeObjectURL(url);\n});\n\n/* Misc initial setup */\n(function init() {\n  // default network\n  createNetwork([2,4,1], ['linear','sigmoid','sigmoid']);\n  randomInit(0.1);\n  renderLayersListUI();\n  renderWeightsTable();\n  // default dataset\n  generateData('xor', 200, 0.15);\n  plotLoss();\n  updateSnapshotsList();\n  log('Interactive sandbox ready.');\n})();\n\n</script>\n</body>\n</html>"
