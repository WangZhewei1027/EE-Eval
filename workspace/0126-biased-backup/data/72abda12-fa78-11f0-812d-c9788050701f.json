    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SQL Visual Elegance</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Source+Code+Pro:wght@300;400;600&display=swap');\n        \n        :root {\n            --primary: #2d3748;\n            --secondary: #4a5568;\n            --accent: #e2c044;\n            --light: #f8f9fa;\n            --dark: #1a202c;\n            --success: #48bb78;\n            --radius: 8px;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Playfair Display', serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n        }\n        \n        h1 {\n            font-size: 3.5rem;\n            margin-bottom: 1rem;\n            color: var(--primary);\n            position: relative;\n            display: inline-block;\n        }\n        \n        h1::after {\n            content: '';\n            position: absolute;\n            bottom: -10px;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 120px;\n            height: 4px;\n            background: var(--accent);\n            border-radius: 2px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--secondary);\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .sql-demo {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 2rem;\n            margin-bottom: 4rem;\n            opacity: 0;\n            transform: translateY(20px);\n            transition: all 0.8s ease;\n        }\n        \n        .sql-demo.visible {\n            opacity: 1;\n            transform: translateY(0);\n        }\n        \n        .code-panel {\n            background: var(--primary);\n            border-radius: var(--radius);\n            padding: 1.5rem;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .code-panel::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 4px;\n            height: 100%;\n            background: linear-gradient(to bottom, var(--accent), #f6ad55);\n        }\n        \n        .code-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 1rem;\n            color: var(--light);\n            font-family: 'Source Code Pro', monospace;\n            font-weight: 300;\n            font-size: 0.9rem;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n        }\n        \n        .code-content {\n            font-family: 'Source Code Pro', monospace;\n            color: #e2e8f0;\n            font-size: 0.95rem;\n            line-height: 1.6;\n            white-space: pre-wrap;\n            overflow-x: auto;\n            padding-right: 1rem;\n        }\n        \n        .keyword {\n            color: #f6ad55;\n            font-weight: 600;\n        }\n        \n        .function {\n            color: #63b3ed;\n        }\n        \n        .string {\n            color: #68d391;\n        }\n        \n        .number {\n            color: #b794f4;\n        }\n        \n        .result-panel {\n            background: white;\n            border-radius: var(--radius);\n            padding: 1.5rem;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);\n            position: relative;\n        }\n        \n        .result-header {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.1rem;\n            display: flex;\n            align-items: center;\n        }\n        \n        .result-header svg {\n            margin-right: 0.5rem;\n            fill: var(--success);\n        }\n        \n        table {\n            width: 100%;\n            border-collapse: collapse;\n            font-family: 'Source Code Pro', monospace;\n            font-size: 0.9rem;\n        }\n        \n        th {\n            background: var(--light);\n            text-align: left;\n            padding: 0.75rem 1rem;\n            font-weight: 600;\n            color: var(--primary);\n            border-bottom: 2px solid var(--secondary);\n        }\n        \n        td {\n            padding: 0.75rem 1rem;\n            border-bottom: 1px solid #e2e8f0;\n            color: var(--secondary);\n        }\n        \n        tr:last-child td {\n            border-bottom: none;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 3rem;\n        }\n        \n        .btn {\n            background: var(--primary);\n            color: white;\n            border: none;\n            padding: 0.8rem 2rem;\n            font-family: 'Playfair Display', serif;\n            font-size: 1rem;\n            border-radius: var(--radius);\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n            margin: 0 0.5rem;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);\n        }\n        \n        .btn::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);\n            transition: all 0.5s ease;\n        }\n        \n        .btn:hover::before {\n            left: 100%;\n        }\n        \n        .btn-accent {\n            background: var(--accent);\n            color: var(--dark);\n        }\n        \n        .concept-card {\n            background: white;\n            border-radius: var(--radius);\n            padding: 2rem;\n            margin-bottom: 2rem;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);\n            transition: all 0.4s ease;\n        }\n        \n        .concept-card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);\n        }\n        \n        .concept-title {\n            font-size: 1.5rem;\n            color: var(--primary);\n            margin-bottom: 1rem;\n            position: relative;\n            display: inline-block;\n        }\n        \n        .concept-title::after {\n            content: '';\n            position: absolute;\n            bottom: -5px;\n            left: 0;\n            width: 40px;\n            height: 3px;\n            background: var(--accent);\n        }\n        \n        .concept-desc {\n            color: var(--secondary);\n            line-height: 1.7;\n            margin-bottom: 1.5rem;\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            padding: 2rem 0;\n            color: var(--secondary);\n            font-size: 0.9rem;\n            border-top: 1px solid #e2e8f0;\n        }\n        \n        @keyframes float {\n            0% { transform: translateY(0px); }\n            50% { transform: translateY(-10px); }\n            100% { transform: translateY(0px); }\n        }\n        \n        .floating {\n            animation: float 3s ease-in-out infinite;\n        }\n        \n        @media (max-width: 768px) {\n            .sql-demo {\n                grid-template-columns: 1fr;\n            }\n            \n            h1 {\n                font-size: 2.5rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>SQL</h1>\n            <p class=\"subtitle\">The elegant language for managing and querying relational databases, presented with visual sophistication</p>\n        </header>\n        \n        <div class=\"controls\">\n            <button id=\"queryBtn\" class=\"btn btn-accent floating\">Execute Query</button>\n        </div>\n        \n        <div class=\"sql-demo\" id=\"queryDemo\">\n            <div class=\"code-panel\">\n                <div class=\"code-header\">\n                    <span>SQL QUERY</span>\n                    <span>MYSQL</span>\n                </div>\n                <div class=\"code-content\">\n<span class=\"keyword\">SELECT</span> customers.customer_id, \n       customers.first_name, \n       customers.last_name,\n       orders.order_id,\n       orders.order_date,\n       orders.total_amount\n<span class=\"keyword\">FROM</span> customers\n<span class=\"keyword\">INNER JOIN</span> orders \n<span class=\"keyword\">ON</span> customers.customer_id = orders.customer_id\n<span class=\"keyword\">WHERE</span> orders.order_date >= <span class=\"string\">'2023-01-01'</span>\n<span class=\"keyword\">ORDER BY</span> orders.total_amount <span class=\"keyword\">DESC</span>\n<span class=\"keyword\">LIMIT</span> <span class=\"number\">5</span>;\n                </div>\n            </div>\n            <div class=\"result-panel\">\n                <div class=\"result-header\">\n                    <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\">\n                        <path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z\"/>\n                    </svg>\n                    QUERY RESULTS\n                </div>\n                <table id=\"resultTable\">\n                    <thead>\n                        <tr>\n                            <th>customer_id</th>\n                            <th>first_name</th>\n                            <th>last_name</th>\n                            <th>order_id</th>\n                            <th>order_date</th>\n                            <th>total_amount</th>\n                        </tr>\n                    </thead>\n                    <tbody>\n                        <!-- Results will be inserted here -->\n                    </tbody>\n                </table>\n            </div>\n        </div>\n        \n        <div class=\"concept-card\">\n            <h3 class=\"concept-title\">Relational Foundation</h3>\n            <p class=\"concept-desc\">SQL operates on the mathematical concept of relational algebra, providing a declarative way to retrieve and manipulate data stored in tables. Its beauty lies in transforming complex data relationships into simple, readable statements.</p>\n        </div>\n        \n        <div class=\"concept-card\">\n            <h3 class=\"concept-title\">Elegant Syntax</h3>\n            <p class=\"concept-desc\">The SQL language combines mathematical precision with near-English readability. Its clauses (SELECT, FROM, WHERE, etc.) form a natural flow that mirrors how we think about data, while maintaining rigorous logical structure.</p>\n        </div>\n        \n        <footer>\n            <p>SQL: Structured Query Language | A Visual Presentation</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Show the demo with animation\n            setTimeout(() => {\n                document.getElementById('queryDemo').classList.add('visible');\n            }, 300);\n            \n            // Sample data for the demo\n            const sampleData = [\n                {\n                    customer_id: 1023,\n                    first_name: 'Eleanor',\n                    last_name: 'Rigby',\n                    order_id: 7891,\n                    order_date: '2023-03-15',\n                    total_amount: 1245.99\n                },\n                {\n                    customer_id: 1045,\n                    first_name: 'James',\n                    last_name: 'McCoy',\n                    order_id: 7823,\n                    order_date: '2023-02-28',\n                    total_amount: 899.50\n                },\n                {\n                    customer_id: 1011,\n                    first_name: 'Amélie',\n                    last_name: 'Poulain',\n                    order_id: 7912,\n                    order_date: '2023-01-17',\n                    total_amount: 765.25\n                },\n                {\n                    customer_id: 1078,\n                    first_name: 'Thomas',\n                    last_name: 'Anderson',\n                    order_id: 7955,\n                    order_date: '2023-03-22',\n                    total_amount: 542.80\n                },\n                {\n                    customer_id: 1034,\n                    first_name: 'Elizabeth',\n                    last_name: 'Bennet',\n                    order_id: 7888,\n                    order_date: '2023-02-05',\n                    total_amount: 432.99\n                }\n            ];\n            \n            // Button click handler\n            document.getElementById('queryBtn').addEventListener('click', function() {\n                const tableBody = document.querySelector('#resultTable tbody');\n                tableBody.innerHTML = '';\n                \n                // Add loading effect\n                this.textContent = 'Executing...';\n                this.classList.remove('floating');\n                \n                // Simulate query execution time\n                setTimeout(() => {\n                    // Populate table with data\n                    sampleData.forEach(row => {\n                        const tr = document.createElement('tr');\n                        \n                        Object.values(row).forEach(value => {\n                            const td = document.createElement('td');\n                            td.textContent = value;\n                            tr.appendChild(td);\n                        });\n                        \n                        tableBody.appendChild(tr);\n                    });\n                    \n                    // Restore button\n                    this.textContent = 'Query Executed';\n                    \n                    // Show animation for new rows\n                    const rows = document.querySelectorAll('#resultTable tbody tr');\n                    rows.forEach((row, index) => {\n                        row.style.opacity = '0';\n                        row.style.transform = 'translateX(20px)';\n                        \n                        setTimeout(() => {\n                            row.style.transition = 'all 0.4s ease';\n                            row.style.opacity = '1';\n                            row.style.transform = 'translateX(0)';\n                        }, 100 * index);\n                    });\n                    \n                    // Reset button after delay\n                    setTimeout(() => {\n                        this.textContent = 'Execute Query';\n                        this.classList.add('floating');\n                    }, 2000);\n                }, 800);\n            });\n        });\n    </script>\n</body>\n</html>"
