    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Linked List Explorer</title>\n  <style>\n    /* Extremely minimal styling: plain black text on white background, simple layout */\n    body { font-family: monospace; margin: 12px; color: black; background: white; }\n    .controls { display: block; margin-bottom: 12px; }\n    .controls > div { margin: 6px 0; }\n    button, input, select, textarea { font-family: monospace; }\n    #visual { white-space: nowrap; overflow-x: auto; padding: 6px; border: 1px solid #000000; }\n    .node { display: inline-block; padding: 6px; margin: 4px; border: 1px solid #000000; min-width: 40px; text-align: center; cursor: pointer; }\n    .arrow { display: inline-block; margin: 0 4px; vertical-align: middle; }\n    .bold { font-weight: bold; }\n    .inspector { white-space: pre-wrap; border: 1px solid #000000; padding: 6px; margin-top: 6px; }\n    .small { font-size: 12px; }\n    .inline { display: inline-block; margin-right: 8px; }\n    label { margin-right: 6px; }\n    #history { max-height: 160px; overflow-y: auto; border: 1px solid #000000; padding: 6px; white-space: pre-wrap; }\n  </style>\n</head>\n<body>\n  <h2>Linked List Explorer</h2>\n\n  <div class=\"controls\">\n    <div>\n      <label>List type:</label>\n      <select id=\"listType\">\n        <option value=\"singly\">Singly Linked List</option>\n        <option value=\"doubly\">Doubly Linked List</option>\n      </select>\n      <button id=\"clearBtn\">Clear</button>\n      <button id=\"copyBtn\">Clone List (push snapshot)</button>\n      <button id=\"randomFillBtn\">Random Fill</button>\n      <label class=\"small\">count:</label><input id=\"randomCount\" type=\"number\" value=\"6\" min=\"0\" style=\"width:60px\">\n    </div>\n\n    <div>\n      <label>Build from array (comma separated):</label>\n      <input id=\"buildInput\" style=\"width:420px\" value=\"A,B,C,D\">\n      <button id=\"buildBtn\">Build</button>\n      <button id=\"appendArrayBtn\">Append Array</button>\n    </div>\n\n    <div>\n      <label>Insert value:</label>\n      <input id=\"insertValue\" style=\"width:120px\" value=\"X\">\n      <label>position:</label>\n      <select id=\"insertPosition\">\n        <option value=\"head\">Head</option>\n        <option value=\"tail\">Tail</option>\n        <option value=\"index\">At index</option>\n      </select>\n      <label>index:</label><input id=\"insertIndex\" type=\"number\" value=\"0\" style=\"width:60px\">\n      <button id=\"insertBtn\">Insert</button>\n      <label class=\"small\">(index is 0-based)</label>\n    </div>\n\n    <div>\n      <label>Delete position:</label>\n      <select id=\"deletePosition\">\n        <option value=\"head\">Head</option>\n        <option value=\"tail\">Tail</option>\n        <option value=\"index\">At index</option>\n        <option value=\"value\">By value</option>\n      </select>\n      <input id=\"deleteIndex\" type=\"number\" value=\"0\" style=\"width:60px\">\n      <input id=\"deleteValue\" style=\"width:120px\" value=\"\">\n      <button id=\"deleteBtn\">Delete</button>\n    </div>\n\n    <div>\n      <label>Update index:</label>\n      <input id=\"updateIndex\" type=\"number\" value=\"0\" style=\"width:60px\">\n      <label>new value:</label>\n      <input id=\"updateValue\" style=\"width:120px\" value=\"\">\n      <button id=\"updateBtn\">Update</button>\n    </div>\n\n    <div>\n      <label>Search value:</label>\n      <input id=\"searchValue\" style=\"width:120px\" value=\"C\">\n      <button id=\"searchBtn\">Search (full)</button>\n      <button id=\"searchStepBtn\">Search (step-by-step)</button>\n      <button id=\"searchNext\">Next</button>\n      <button id=\"searchPrev\">Prev</button>\n      <label class=\"small\">current pos:</label><span id=\"searchPos\">-</span>\n    </div>\n\n    <div>\n      <button id=\"reverseBtn\">Reverse (full)</button>\n      <button id=\"reverseStepBtn\">Reverse (step-by-step)</button>\n      <button id=\"revNext\">Next</button>\n      <button id=\"revPrev\">Prev</button>\n    </div>\n\n    <div>\n      <label>Rotate:</label>\n      <input id=\"rotateK\" type=\"number\" value=\"1\" style=\"width:60px\">\n      <button id=\"rotateLeft\">Rotate Left</button>\n      <button id=\"rotateRight\">Rotate Right</button>\n    </div>\n\n    <div>\n      <label>Merge / Append list (comma separated):</label>\n      <input id=\"mergeInput\" style=\"width:300px\" value=\"1,2,3\">\n      <button id=\"mergeBtn\">Append</button>\n      <button id=\"mergeAsNewBtn\">Make New Merged List</button>\n    </div>\n\n    <div>\n      <button id=\"startTransaction\">Start Transaction</button>\n      <button id=\"commitTransaction\" disabled>Commit</button>\n      <button id=\"rollbackTransaction\" disabled>Rollback</button>\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n    </div>\n\n    <div>\n      <label>Save bookmark name:</label>\n      <input id=\"bookmarkName\" style=\"width:180px\" value=\"state1\">\n      <button id=\"saveBookmark\">Save</button>\n      <button id=\"listBookmarks\">List</button>\n      <select id=\"bookmarkList\" style=\"width:240px\"></select>\n      <button id=\"loadBookmark\">Load</button>\n      <button id=\"delBookmark\">Delete</button>\n    </div>\n\n    <div>\n      <label>Export JSON:</label>\n      <button id=\"exportBtn\">Export</button>\n      <label>Import JSON:</label>\n      <textarea id=\"importArea\" style=\"width:480px; height:60px\"></textarea>\n      <button id=\"importBtn\">Import (replace)</button>\n      <button id=\"importAppendBtn\">Import (append)</button>\n    </div>\n\n    <div>\n      <button id=\"showRawBtn\">Show Raw State</button>\n      <button id=\"inspectMemoryBtn\">Inspect Memory (nodes)</button>\n      <button id=\"logStateBtn\">Push to history log</button>\n    </div>\n  </div>\n\n  <div id=\"visual\" aria-live=\"polite\" tabindex=\"0\"></div>\n\n  <div class=\"inspector\" id=\"inspector\">Inspector: click a node to inspect it. Current cursor: none</div>\n\n  <h3>History / Debug</h3>\n  <div id=\"history\" class=\"small\"></div>\n\n  <script>\n    // Linked List Explorer - rich interactive single-file demo\n    // Minimal visuals. Many controls and complex state transitions.\n\n    // Internal representation:\n    // state = { type: 'singly'|'doubly', nodes: [ {id, value} ], cursorIndex: null, name: optional }\n    // For singly list, next is implicit by index. For doubly list, prev is implicit by index.\n    (function(){\n      // Utilities\n      let idCounter = 1;\n      function uniqueId(){ return 'n' + (idCounter++); }\n      function cloneState(s){\n        return { type: s.type, nodes: s.nodes.map(n=>({id:n.id, value: n.value})), cursorIndex: s.cursorIndex==null?null: s.cursorIndex };\n      }\n      function pushHistory(entry){ const h = document.getElementById('history'); h.textContent = entry + \"\\\\n\" + h.textContent; }\n\n      // State and stacks\n      let state = { type: 'singly', nodes: [], cursorIndex: null };\n      let undoStack = [];\n      let redoStack = [];\n      let transactionStack = [];\n      let bookmarks = {}; // name -> state clone\n      let algorithmStepper = null; // {generator, steps, index, type}\n      let stepSnapshot = null;\n\n      // DOM refs\n      const visual = document.getElementById('visual');\n      const inspector = document.getElementById('inspector');\n      const searchPosSpan = document.getElementById('searchPos');\n\n      // Save snapshot for undo\n      function snapshotPush(desc){\n        undoStack.push(cloneState(state));\n        redoStack = []; // clear redo on new action\n        pushHistory('ACTION: ' + desc);\n        render();\n      }\n\n      // Action helpers\n      function setType(t){\n        if(state.type !== t){\n          snapshotPush('Change type to ' + t);\n          state.type = t;\n          // nothing else changes\n          render();\n        }\n      }\n\n      function buildFromArray(arr, replace=true){\n        if(replace){\n          snapshotPush('Build from array: [' + arr.join(',') + ']');\n          state.nodes = arr.map(v=> ({ id: uniqueId(), value: v }) );\n          state.cursorIndex = null;\n        } else {\n          snapshotPush('Append array: [' + arr.join(',') + ']');\n          const newNodes = arr.map(v=> ({ id: uniqueId(), value: v }) );\n          state.nodes = state.nodes.concat(newNodes);\n        }\n        render();\n      }\n\n      function clearList(){\n        snapshotPush('Clear list');\n        state.nodes = [];\n        state.cursorIndex = null;\n        render();\n      }\n\n      function randomFill(n){\n        const arr = [];\n        for(let i=0;i<n;i++) arr.push(Math.random().toString(36).slice(2,4).toUpperCase());\n        buildFromArray(arr, true);\n      }\n\n      function insertAt(value, position, index){\n        if(position === 'head'){\n          snapshotPush('Insert ' + value + ' at head');\n          state.nodes.unshift({ id: uniqueId(), value: value });\n        } else if(position === 'tail'){\n          snapshotPush('Insert ' + value + ' at tail');\n          state.nodes.push({ id: uniqueId(), value: value });\n        } else {\n          const idx = Math.max(0, Math.min(state.nodes.length, index || 0));\n          snapshotPush('Insert ' + value + ' at index ' + idx);\n          state.nodes.splice(idx, 0, { id: uniqueId(), value: value });\n        }\n        render();\n      }\n\n      function deleteAt(position, index, value){\n        if(state.nodes.length === 0){\n          pushHistory('Delete attempted on empty list');\n          return;\n        }\n        if(position === 'head'){\n          snapshotPush('Delete head (' + state.nodes[0].value + ')');\n          state.nodes.shift();\n          if(state.cursorIndex!=null) state.cursorIndex = Math.max(0, state.cursorIndex-1);\n        } else if(position === 'tail'){\n          snapshotPush('Delete tail (' + state.nodes[state.nodes.length-1].value + ')');\n          state.nodes.pop();\n          if(state.cursorIndex!=null && state.cursorIndex >= state.nodes.length) state.cursorIndex = state.nodes.length-1;\n        } else if(position === 'index'){\n          const idx = index;\n          if(idx < 0 || idx >= state.nodes.length){ pushHistory('Delete index out of bounds'); return; }\n          snapshotPush('Delete at index ' + idx + ' (' + state.nodes[idx].value + ')');\n          state.nodes.splice(idx,1);\n          if(state.cursorIndex!=null){\n            if(state.cursorIndex === idx) state.cursorIndex = null;\n            else if(state.cursorIndex > idx) state.cursorIndex--;\n          }\n        } else if(position === 'value'){\n          // delete first matching\n          const idx = state.nodes.findIndex(n=> String(n.value) === String(value));\n          if(idx === -1){ pushHistory('Value not found for delete: ' + value); return; }\n          snapshotPush('Delete by value ' + value + ' at index ' + idx);\n          state.nodes.splice(idx,1);\n          if(state.cursorIndex!=null){\n            if(state.cursorIndex === idx) state.cursorIndex = null;\n            else if(state.cursorIndex > idx) state.cursorIndex--;\n          }\n        }\n        render();\n      }\n\n      function updateAt(index, newValue){\n        if(index < 0 || index >= state.nodes.length){\n          pushHistory('Update index out of bounds'); return;\n        }\n        snapshotPush('Update index ' + index + ' to ' + newValue);\n        state.nodes[index].value = newValue;\n        render();\n      }\n\n      function rotateLeft(k){\n        if(state.nodes.length === 0) return;\n        k = ((k % state.nodes.length) + state.nodes.length) % state.nodes.length;\n        if(k === 0) return;\n        snapshotPush('Rotate left by ' + k);\n        for(let i=0;i<k;i++){\n          const first = state.nodes.shift();\n          state.nodes.push(first);\n        }\n        render();\n      }\n\n      function rotateRight(k){\n        if(state.nodes.length === 0) return;\n        k = ((k % state.nodes.length) + state.nodes.length) % state.nodes.length;\n        if(k === 0) return;\n        snapshotPush('Rotate right by ' + k);\n        for(let i=0;i<k;i++){\n          const last = state.nodes.pop();\n          state.nodes.unshift(last);\n        }\n        render();\n      }\n\n      function mergeArray(arr, asNew){\n        if(asNew){\n          const merged = cloneState(state);\n          merged.nodes = merged.nodes.concat(arr.map(v=>({id: uniqueId(), value: v})));\n          snapshotPush('Make new merged list (keeps old) with [' + arr.join(',') + ']');\n          // replace current state with merged\n          state = merged;\n        } else {\n          snapshotPush('Append array [' + arr.join(',') + ']');\n          state.nodes = state.nodes.concat(arr.map(v=>({id: uniqueId(), value: v})));\n        }\n        render();\n      }\n\n      function cloneList(){\n        snapshotPush('Clone list (duplicate nodes)');\n        const original = cloneState(state);\n        // give new ids\n        original.nodes = original.nodes.map(n=>({id: uniqueId(), value: n.value}));\n        state = original;\n        render();\n      }\n\n      function exportJSON(){\n        const out = JSON.stringify(state, null, 2);\n        document.getElementById('importArea').value = out;\n        pushHistory('Exported JSON to import area');\n      }\n\n      function importJSON(replace){\n        try{\n          const txt = document.getElementById('importArea').value.trim();\n          if(!txt) { pushHistory('Import area empty'); return; }\n          const obj = JSON.parse(txt);\n          if(!Array.isArray(obj.nodes) || !obj.type) { pushHistory('Invalid JSON structure'); return; }\n          if(replace){\n            snapshotPush('Import and replace from JSON');\n            state = { type: obj.type || 'singly', nodes: obj.nodes.map(n=>({id: uniqueId(), value: n.value})), cursorIndex: obj.cursorIndex || null };\n          } else {\n            snapshotPush('Import and append from JSON');\n            const nodesToAdd = obj.nodes.map(n=>({id: uniqueId(), value: n.value}));\n            state.nodes = state.nodes.concat(nodesToAdd);\n          }\n          render();\n        } catch(e){\n          pushHistory('Import JSON error: ' + e.message);\n        }\n      }\n\n      // Bookmarks\n      function saveBookmark(name){\n        if(!name) { pushHistory('Bookmark name empty'); return; }\n        bookmarks[name] = cloneState(state);\n        pushHistory('Saved bookmark: ' + name);\n        refreshBookmarkList();\n      }\n\n      function loadBookmark(name){\n        if(!bookmarks[name]) { pushHistory('Bookmark not found: ' + name); return; }\n        snapshotPush('Load bookmark: ' + name);\n        state = cloneState(bookmarks[name]);\n        render();\n      }\n\n      function deleteBookmark(name){\n        delete bookmarks[name];\n        pushHistory('Deleted bookmark: ' + name);\n        refreshBookmarkList();\n      }\n\n      function refreshBookmarkList(){\n        const sel = document.getElementById('bookmarkList');\n        sel.innerHTML = '';\n        for(const k in bookmarks){\n          const opt = document.createElement('option');\n          opt.value = k; opt.textContent = k;\n          sel.appendChild(opt);\n        }\n      }\n\n      // Undo Redo\n      function undo(){\n        if(undoStack.length === 0) { pushHistory('Undo stack empty'); return; }\n        redoStack.push(cloneState(state));\n        state = undoStack.pop();\n        pushHistory('Undo performed');\n        render();\n      }\n\n      function redo(){\n        if(redoStack.length === 0) { pushHistory('Redo stack empty'); return; }\n        undoStack.push(cloneState(state));\n        state = redoStack.pop();\n        pushHistory('Redo performed');\n        render();\n      }\n\n      // Transactions\n      function startTransaction(){\n        transactionStack.push(cloneState(state));\n        document.getElementById('startTransaction').disabled = true;\n        document.getElementById('commitTransaction').disabled = false;\n        document.getElementById('rollbackTransaction').disabled = false;\n        pushHistory('Transaction started');\n      }\n\n      function commitTransaction(){\n        if(transactionStack.length === 0) return;\n        transactionStack.pop(); // finalizing\n        snapshotPush('Transaction committed');\n        document.getElementById('startTransaction').disabled = false;\n        document.getElementById('commitTransaction').disabled = true;\n        document.getElementById('rollbackTransaction').disabled = true;\n        pushHistory('Transaction committed');\n      }\n\n      function rollbackTransaction(){\n        if(transactionStack.length === 0) return;\n        state = transactionStack.pop();\n        // Rolling back should not appear in undo history as it restores previous - but we can push as action\n        pushHistory('Transaction rolled back');\n        document.getElementById('startTransaction').disabled = false;\n        document.getElementById('commitTransaction').disabled = true;\n        document.getElementById('rollbackTransaction').disabled = true;\n        render();\n      }\n\n      // Rendering\n      function render(){\n        // reflect type select\n        document.getElementById('listType').value = state.type;\n\n        // build visual nodes\n        visual.innerHTML = '';\n        if(state.nodes.length === 0){\n          visual.textContent = '(empty list)';\n        } else {\n          for(let i=0;i<state.nodes.length;i++){\n            const n = state.nodes[i];\n            const span = document.createElement('span');\n            span.className = 'node';\n            span.dataset.index = i;\n            span.dataset.id = n.id;\n            span.textContent = String(n.value);\n            if(i === state.cursorIndex){\n              span.classList.add('bold');\n            }\n            span.title = 'Index: ' + i + ' id: ' + n.id;\n            span.addEventListener('click', function(e){\n              const idx = Number(this.dataset.index);\n              state.cursorIndex = idx;\n              inspector.textContent = 'Inspector:\\\\nIndex: ' + idx + '\\\\nID: ' + n.id + '\\\\nValue: ' + n.value + '\\\\nType: ' + state.type;\n              render();\n            });\n            visual.appendChild(span);\n            // arrow\n            if(i !== state.nodes.length-1){\n              const arr = document.createElement('span');\n              arr.className = 'arrow';\n              arr.textContent = state.type === 'doubly' ? '<- ->' : '->';\n              visual.appendChild(arr);\n            }\n          }\n        }\n\n        // update inspector if needed\n        const cur = state.cursorIndex==null? 'none' : state.cursorIndex;\n        if(!inspector.textContent.startsWith('Inspector:')){\n          inspector.textContent = 'Inspector: click a node to inspect it. Current cursor: ' + cur;\n        } else {\n          // if previously had inspector showing some node, update the cursor line\n          if(inspector.textContent.indexOf('Current cursor:') === -1){\n            inspector.textContent += '\\\\nCurrent cursor: ' + cur;\n          } else {\n            const lines = inspector.textContent.split('\\\\n');\n            // replace last line with cursor info if present\n            if(lines[lines.length-1].startsWith('Current cursor:')) lines[lines.length-1] = 'Current cursor: ' + cur;\n            else lines.push('Current cursor: ' + cur);\n            inspector.textContent = lines.join('\\\\n');\n          }\n        }\n\n        // update search pos display if relevant\n        if(algorithmStepper && algorithmStepper.type === 'search'){\n          searchPosSpan.textContent = algorithmStepper.index >=0 ? (algorithmStepper.index) : '-';\n        } else {\n          searchPosSpan.textContent = '-';\n        }\n      }\n\n      // Search algorithm stepper (generator-like)\n      function createSearchStepper(value){\n        // steps: each step is index visited\n        const steps = state.nodes.map((n,i)=> ({index:i, value: n.value}) );\n        let idx = -1;\n        return {\n          type: 'search',\n          steps: steps,\n          index: -1,\n          value: value,\n          next: function(){\n            if(this.index < this.steps.length -1){\n              this.index++;\n              const s = this.steps[this.index];\n              state.cursorIndex = s.index;\n              pushHistory('Search step visited index ' + s.index + ' value ' + s.value);\n              render();\n              if(String(s.value) === String(this.value)){\n                pushHistory('Search: match found at index ' + s.index);\n              }\n              return true;\n            }\n            return false;\n          },\n          prev: function(){\n            if(this.index > 0){\n              this.index--;\n              const s = this.steps[this.index];\n              state.cursorIndex = s.index;\n              pushHistory('Search step back to index ' + s.index);\n              render();\n              return true;\n            } else if(this.index === 0){\n              this.index = -1;\n              state.cursorIndex = null;\n              render();\n              return true;\n            }\n            return false;\n          }\n        };\n      }\n\n      // Reverse stepper: reveal the common iterative reverse algorithm step by step\n      function createReverseStepper(){\n        // We'll simulate pointers: prev=null, curr=head (index 0), next = curr.next\n        // We'll maintain an array of nodes (values) and show the evolving links by showing cursor at current and bold those moved to reversed part.\n        // Implementation detail: we step through indexes and show which prefix is reversed.\n        const n = state.nodes.length;\n        let i = 0; // number of nodes moved to reversed part\n        return {\n          type: 'reverse',\n          index: -1,\n          next: function(){\n            if(i < n){\n              // move node at position 0 to reversed prefix end simulation\n              // We'll actually perform the mutation only at commit or at final step; but to allow visualization, we build a temporary snapshot on step.\n              // For simplicity we actually perform splicing in a step-snapshot area.\n              if(!this._working) this._working = state.nodes.map(x=>({id:x.id,value:x.value}));\n              // move first of working to front of reversed (simulate iterative reversal)\n              const node = this._working.shift();\n              this._working = [node].concat(this._working);\n              // But above just rotates; instead we want to show prefix reversed\n              // Build the intended reversed outcome after i+1 steps:\n              const prefix = state.nodes.slice(0, i+1).reverse();\n              const suffix = state.nodes.slice(i+1);\n              // produce visual snapshot\n              this._snapshot = prefix.concat(suffix);\n              i++;\n              this.index = i-1;\n              pushHistory('Reverse step ' + i + '/' + n);\n              // Render using snapshot overlay\n              renderSnapshot(this._snapshot, this.index, 'reverse');\n              return true;\n            }\n            // final commit: apply reversed nodes to state\n            if(i >= n && !this._committed){\n              snapshotPush('Reverse complete');\n              state.nodes = state.nodes.slice().reverse();\n              this._committed = true;\n              render();\n              return false;\n            }\n            return false;\n          },\n          prev: function(){\n            if(i > 0){\n              i--;\n              this.index = i-1;\n              // restore snapshot for previous i\n              const prefix = state.nodes.slice(0, i).reverse();\n              const suffix = state.nodes.slice(i);\n              this._snapshot = prefix.concat(suffix);\n              renderSnapshot(this._snapshot, this.index, 'reverse');\n              pushHistory('Reverse step back to ' + i + '/' + n);\n              return true;\n            } else {\n              // reset\n              i = 0;\n              this.index = -1;\n              render();\n              return false;\n            }\n          }\n        };\n      }\n\n      // Visualization for step snapshots: overlay content temporarily\n      function renderSnapshot(arrSnapshot, highlightIndex, mode){\n        visual.innerHTML = '';\n        if(arrSnapshot.length === 0){\n          visual.textContent = '(empty list)';\n          return;\n        }\n        for(let i=0;i<arrSnapshot.length;i++){\n          const n = arrSnapshot[i];\n          const span = document.createElement('span');\n          span.className = 'node';\n          span.textContent = String(n.value);\n          if(i === highlightIndex) span.classList.add('bold');\n          visual.appendChild(span);\n          if(i !== arrSnapshot.length-1){\n            const arr = document.createElement('span');\n            arr.className = 'arrow';\n            arr.textContent = state.type === 'doubly' ? '<- ->' : '->';\n            visual.appendChild(arr);\n          }\n        }\n        const label = document.createElement('div');\n        label.textContent = 'Mode: ' + mode + ' (snapshot visualization)';\n        visual.appendChild(document.createElement('br'));\n        visual.appendChild(label);\n      }\n\n      // Hook up buttons and inputs\n      document.getElementById('listType').addEventListener('change', function(){\n        setType(this.value);\n      });\n\n      document.getElementById('buildBtn').addEventListener('click', function(){\n        const raw = document.getElementById('buildInput').value;\n        const arr = parseCSV(raw);\n        buildFromArray(arr, true);\n      });\n\n      document.getElementById('appendArrayBtn').addEventListener('click', function(){\n        const raw = document.getElementById('buildInput').value;\n        const arr = parseCSV(raw);\n        buildFromArray(arr, false);\n      });\n\n      document.getElementById('clearBtn').addEventListener('click', function(){ clearList(); });\n\n      document.getElementById('randomFillBtn').addEventListener('click', function(){\n        const n = Number(document.getElementById('randomCount').value) || 0;\n        randomFill(n);\n      });\n\n      document.getElementById('insertBtn').addEventListener('click', function(){\n        const value = document.getElementById('insertValue').value;\n        const pos = document.getElementById('insertPosition').value;\n        const idx = Number(document.getElementById('insertIndex').value);\n        insertAt(value, pos, idx);\n      });\n\n      document.getElementById('deleteBtn').addEventListener('click', function(){\n        const pos = document.getElementById('deletePosition').value;\n        const idx = Number(document.getElementById('deleteIndex').value);\n        const val = document.getElementById('deleteValue').value;\n        deleteAt(pos, idx, val);\n      });\n\n      document.getElementById('updateBtn').addEventListener('click', function(){\n        const idx = Number(document.getElementById('updateIndex').value);\n        const val = document.getElementById('updateValue').value;\n        updateAt(idx, val);\n      });\n\n      document.getElementById('rotateLeft').addEventListener('click', function(){\n        const k = Number(document.getElementById('rotateK').value) || 0;\n        rotateLeft(k);\n      });\n      document.getElementById('rotateRight').addEventListener('click', function(){\n        const k = Number(document.getElementById('rotateK').value) || 0;\n        rotateRight(k);\n      });\n\n      document.getElementById('mergeBtn').addEventListener('click', function(){\n        const arr = parseCSV(document.getElementById('mergeInput').value);\n        mergeArray(arr, false);\n      });\n      document.getElementById('mergeAsNewBtn').addEventListener('click', function(){\n        const arr = parseCSV(document.getElementById('mergeInput').value);\n        mergeArray(arr, true);\n      });\n\n      document.getElementById('copyBtn').addEventListener('click', function(){ cloneList(); });\n\n      document.getElementById('exportBtn').addEventListener('click', exportJSON);\n      document.getElementById('importBtn').addEventListener('click', function(){ importJSON(true); });\n      document.getElementById('importAppendBtn').addEventListener('click', function(){ importJSON(false); });\n\n      document.getElementById('saveBookmark').addEventListener('click', function(){\n        const name = document.getElementById('bookmarkName').value;\n        saveBookmark(name);\n      });\n      document.getElementById('loadBookmark').addEventListener('click', function(){\n        const sel = document.getElementById('bookmarkList');\n        loadBookmark(sel.value);\n      });\n      document.getElementById('delBookmark').addEventListener('click', function(){\n        const sel = document.getElementById('bookmarkList');\n        deleteBookmark(sel.value);\n      });\n      document.getElementById('listBookmarks').addEventListener('click', refreshBookmarkList);\n\n      document.getElementById('undoBtn').addEventListener('click', undo);\n      document.getElementById('redoBtn').addEventListener('click', redo);\n\n      document.getElementById('startTransaction').addEventListener('click', startTransaction);\n      document.getElementById('commitTransaction').addEventListener('click', commitTransaction);\n      document.getElementById('rollbackTransaction').addEventListener('click', rollbackTransaction);\n\n      document.getElementById('showRawBtn').addEventListener('click', function(){\n        inspector.textContent = 'Raw state:\\\\n' + JSON.stringify(state, null, 2);\n      });\n      document.getElementById('inspectMemoryBtn').addEventListener('click', function(){\n        inspector.textContent = 'Memory (nodes):\\\\n' + state.nodes.map((n,i)=> i + ': id=' + n.id + ' val=' + n.value).join('\\\\n');\n      });\n      document.getElementById('logStateBtn').addEventListener('click', function(){\n        pushHistory('State pushed to history: ' + JSON.stringify(state));\n      });\n\n      // Search controls\n      document.getElementById('searchBtn').addEventListener('click', function(){\n        const v = document.getElementById('searchValue').value;\n        // full search\n        snapshotPush('Search full for ' + v);\n        const indices = [];\n        state.nodes.forEach((n,i)=>{ if(String(n.value) === String(v)) indices.push(i); });\n        if(indices.length === 0) pushHistory('Search: no matches for ' + v);\n        else pushHistory('Search: matches at ' + indices.join(', '));\n        // move cursor to first match if any\n        state.cursorIndex = indices.length>0?indices[0]:null;\n        render();\n      });\n\n      document.getElementById('searchStepBtn').addEventListener('click', function(){\n        const v = document.getElementById('searchValue').value;\n        algorithmStepper = createSearchStepper(v);\n        pushHistory('Initialized search stepper for value ' + v);\n        render();\n      });\n\n      document.getElementById('searchNext').addEventListener('click', function(){\n        if(algorithmStepper && algorithmStepper.type === 'search'){\n          if(!algorithmStepper.next()) pushHistory('Search stepper reached end');\n        } else pushHistory('No active search stepper');\n      });\n      document.getElementById('searchPrev').addEventListener('click', function(){\n        if(algorithmStepper && algorithmStepper.type === 'search'){\n          if(!algorithmStepper.prev()) pushHistory('Search stepper at beginning');\n        } else pushHistory('No active search stepper');\n      });\n\n      // Reverse controls\n      document.getElementById('reverseBtn').addEventListener('click', function(){\n        snapshotPush('Reverse full');\n        state.nodes = state.nodes.slice().reverse();\n        render();\n      });\n\n      document.getElementById('reverseStepBtn').addEventListener('click', function(){\n        algorithmStepper = createReverseStepper();\n        pushHistory('Initialized reverse stepper');\n        render();\n      });\n\n      document.getElementById('revNext').addEventListener('click', function(){\n        if(algorithmStepper && algorithmStepper.type === 'reverse'){\n          if(!algorithmStepper.next()) pushHistory('Reverse stepper finished or cannot proceed');\n        } else pushHistory('No active reverse stepper');\n      });\n      document.getElementById('revPrev').addEventListener('click', function(){\n        if(algorithmStepper && algorithmStepper.type === 'reverse'){\n          if(!algorithmStepper.prev()) pushHistory('Reverse stepper at beginning');\n        } else pushHistory('No active reverse stepper');\n      });\n\n      // History logging initialization\n      pushHistory('Linked List Explorer initialized');\n\n      // Parse CSV-like input\n      function parseCSV(raw){\n        if(raw == null) return [];\n        // split by comma, semicolon, whitespace; trim\n        const parts = raw.split(/[,;\\\\n]+/).map(s=>s.trim()).filter(s=>s.length>0);\n        return parts;\n      }\n\n      // Keyboard quick operations (small extras)\n      document.addEventListener('keydown', function(e){\n        if(e.ctrlKey && e.key === 'z'){ e.preventDefault(); undo(); }\n        if(e.ctrlKey && e.key === 'y'){ e.preventDefault(); redo(); }\n      });\n\n      // Initial render\n      render();\n\n      // Expose for debug in console (optional)\n      window.__LL = {\n        getState: ()=>state,\n        setState: s=>{ state = s; render(); },\n        pushHistory: pushHistory,\n        cloneState: cloneState\n      };\n    })();\n  </script>\n</body>\n</html>"
