    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Max Heap Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .heap-node { margin: 5px; }\n    </style>\n</head>\n<body>\n    <h1>Max Heap Interactive Demonstration</h1>\n    <div>\n        <label for=\"value-input\">Enter a value to insert into the heap:</label>\n        <input type=\"number\" id=\"value-input\">\n        <button id=\"insert-button\">Insert</button>\n    </div>\n    <div>\n        <button id=\"remove-button\">Remove Max</button>\n        <button id=\"peek-button\">Peek Max</button>\n    </div>\n    <div>\n        <h3>Current Max Heap:</h3>\n        <div id=\"heap-display\"></div>\n    </div>\n    <div>\n        <h3>Max Value:</h3>\n        <div id=\"max-value\"></div>\n    </div>\n\n    <script>\n        class MaxHeap {\n            constructor() {\n                this.heap = [];\n            }\n\n            insert(value) {\n                this.heap.push(value);\n                this.bubbleUp(this.heap.length - 1);\n                this.updateDisplay();\n            }\n\n            removeMax() {\n                if (this.heap.length === 0) return null;\n                const max = this.heap[0];\n                const end = this.heap.pop();\n                if (this.heap.length > 0) {\n                    this.heap[0] = end;\n                    this.bubbleDown(0);\n                }\n                this.updateDisplay();\n                return max;\n            }\n\n            peekMax() {\n                return this.heap[0] || null;\n            }\n\n            bubbleUp(index) {\n                let parentIdx = Math.floor((index - 1) / 2);\n                while (index > 0 && this.heap[index] > this.heap[parentIdx]) {\n                    [this.heap[index], this.heap[parentIdx]] = [this.heap[parentIdx], this.heap[index]];\n                    index = parentIdx;\n                    parentIdx = Math.floor((index - 1) / 2);\n                }\n            }\n\n            bubbleDown(index) {\n                let length = this.heap.length;\n                let leftChildIdx, rightChildIdx, largestIdx;\n\n                while (true) {\n                    leftChildIdx = 2 * index + 1;\n                    rightChildIdx = 2 * index + 2;\n                    largestIdx = index;\n\n                    if (leftChildIdx < length && this.heap[leftChildIdx] > this.heap[largestIdx]) {\n                        largestIdx = leftChildIdx;\n                    }\n                    if (rightChildIdx < length && this.heap[rightChildIdx] > this.heap[largestIdx]) {\n                        largestIdx = rightChildIdx;\n                    }\n                    if (largestIdx === index) break;\n\n                    [this.heap[index], this.heap[largestIdx]] = [this.heap[largestIdx], this.heap[index]];\n                    index = largestIdx;\n                }\n            }\n\n            updateDisplay() {\n                const heapDisplay = document.getElementById('heap-display');\n                heapDisplay.innerHTML = this.heap.map((value, index) => `<div class=\"heap-node\">Node ${index}: ${value}</div>`).join('');\n                const maxValueDisplay = document.getElementById('max-value');\n                maxValueDisplay.innerText = this.peekMax() !== null ? this.peekMax() : 'Heap is empty';\n            }\n        }\n\n        const maxHeap = new MaxHeap();\n        \n        document.getElementById('insert-button').onclick = function() {\n            const valueInput = document.getElementById('value-input');\n            const value = parseInt(valueInput.value);\n            if (!isNaN(value)) {\n                maxHeap.insert(value);\n                valueInput.value = '';\n            }\n        };\n\n        document.getElementById('remove-button').onclick = function() {\n            const removedValue = maxHeap.removeMax();\n            alert(removedValue !== null ? `Removed Max: ${removedValue}` : 'Heap is empty');\n        };\n\n        document.getElementById('peek-button').onclick = function() {\n            const maxValue = maxHeap.peekMax();\n            alert(maxValue !== null ? `Max Value: ${maxValue}` : 'Heap is empty');\n        };\n    </script>\n</body>\n</html>"
