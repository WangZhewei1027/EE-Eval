    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Red-Black Tree</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n    </style>\n</head>\n<body>\n\n<h1>Interactive Red-Black Tree</h1>\n\n<label for=\"value\">Enter a value: </label>\n<input type=\"number\" id=\"value\" min=\"1\" />\n<button onclick=\"insertValue()\">Insert</button>\n<button onclick=\"deleteValue()\">Delete</button>\n<button onclick=\"searchValue()\">Search</button>\n<button onclick=\"resetTree()\">Reset Tree</button>\n\n<h2>Tree Visualization</h2>\n<pre id=\"treeDisplay\"></pre>\n\n<h2>Tree Operations</h2>\n<button onclick=\"printTree()\">Print Tree</button>\n<button onclick=\"inOrderTraversal()\">In-order Traversal</button>\n<button onclick=\"preOrderTraversal()\">Pre-order Traversal</button>\n<button onclick=\"postOrderTraversal()\">Post-order Traversal</button>\n\n<script>\nclass Node {\n    constructor(value, color) {\n        this.value = value;\n        this.color = color; // 'R' for Red, 'B' for Black\n        this.left = null;\n        this.right = null;\n        this.parent = null;\n    }\n}\n\nclass RedBlackTree {\n    constructor() {\n        this.root = null;\n    }\n\n    insert(value) {\n        // Insert logic with balancing; simplified\n        let newNode = new Node(value, 'R');\n        // Your insertion logic goes here to maintain red-black properties\n        this.root = this._insertNode(this.root, newNode);\n        this.insertFixup(newNode);\n        this.updateDisplay();\n    }\n\n    _insertNode(root, node) {\n        if (root === null) return node;\n        if (node.value < root.value) {\n            root.left = this._insertNode(root.left, node);\n            root.left.parent = root;\n        } else {\n            root.right = this._insertNode(root.right, node);\n            root.right.parent = root;\n        }\n        return root;\n    }\n\n    insertFixup(node) {\n        // Your fix-up logic after insertion goes here\n    }\n\n    delete(value) {\n        // Simplified delete method; add balancing logic\n        // Your deletion logic goes here to maintain red-black properties\n        this.updateDisplay();\n    }\n\n    search(value) {\n        // Simplified search logic\n        return this._searchNode(this.root, value);\n    }\n\n    _searchNode(root, value) {\n        if (root === null) return false;\n        if (value === root.value) return true;\n        return value < root.value ? this._searchNode(root.left, value) : this._searchNode(root.right, value);\n    }\n\n    reset() {\n        this.root = null;\n        this.updateDisplay();\n    }\n\n    inOrderTraversal() {\n        return this._traverse(this.root, 'in-order');\n    }\n\n    preOrderTraversal() {\n        return this._traverse(this.root, 'pre-order');\n    }\n\n    postOrderTraversal() {\n        return this._traverse(this.root, 'post-order');\n    }\n\n    _traverse(node, type) {\n        if (!node) return [];\n        switch (type) {\n            case 'in-order':\n                return [...this._traverse(node.left, type), node.value, ...this._traverse(node.right, type)];\n            case 'pre-order':\n                return [node.value, ...this._traverse(node.left, type), ...this._traverse(node.right, type)];\n            case 'post-order':\n                return [...this._traverse(node.left, type), ...this._traverse(node.right, type), node.value];\n        }\n    }\n\n    updateDisplay() {\n        let display = this.visualize(this.root);\n        document.getElementById('treeDisplay').innerText = display;\n    }\n\n    visualize(node, depth = 0, prefix = \"\") {\n        if (!node) return \"\";\n        let result = prefix + node.value + \" (\" + node.color + \")\\n\";\n        result += this.visualize(node.left, depth + 1, prefix + \"  \");\n        result += this.visualize(node.right, depth + 1, prefix + \"  \");\n        return result;\n    }\n}\n\nconst redBlackTree = new RedBlackTree();\n\nfunction insertValue() {\n    const value = document.getElementById('value').value;\n    if (value) {\n        redBlackTree.insert(Number(value));\n    }\n}\n\nfunction deleteValue() {\n    const value = document.getElementById('value').value;\n    if (value) {\n        redBlackTree.delete(Number(value));\n    }\n}\n\nfunction searchValue() {\n    const value = document.getElementById('value').value;\n    if (value) {\n        const result = redBlackTree.search(Number(value));\n        alert(result ? \"Value found\" : \"Value not found\");\n    }\n}\n\nfunction resetTree() {\n    redBlackTree.reset();\n}\n\nfunction printTree() {\n    alert(redBlackTree.visualize(redBlackTree.root));\n}\n\nfunction inOrderTraversal() {\n    alert(redBlackTree.inOrderTraversal().join(\", \"));\n}\n\nfunction preOrderTraversal() {\n    alert(redBlackTree.preOrderTraversal().join(\", \"));\n}\n\nfunction postOrderTraversal() {\n    alert(redBlackTree.postOrderTraversal().join(\", \"));\n}\n</script>\n\n</body>\n</html>"
