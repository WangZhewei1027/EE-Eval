    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Trie Visualization</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #trie-node { margin: 10px; }\n    </style>\n</head>\n<body>\n\n<h1>Trie Interactive Demo</h1>\n<input type=\"text\" id=\"word-input\" placeholder=\"Enter a word\" />\n<button id=\"insert-button\">Insert</button>\n<button id=\"search-button\">Search</button>\n<button id=\"clear-button\">Clear Trie</button>\n\n<div id=\"trie-node\"></div>\n\n<script>\n    class TrieNode {\n        constructor() {\n            this.children = {};\n            this.isEndOfWord = false;\n        }\n    }\n\n    class Trie {\n        constructor() {\n            this.root = new TrieNode();\n        }\n\n        insert(word) {\n            let node = this.root;\n            for (let char of word) {\n                if (!node.children[char]) {\n                    node.children[char] = new TrieNode();\n                }\n                node = node.children[char];\n            }\n            node.isEndOfWord = true;\n        }\n\n        search(word) {\n            let node = this.root;\n            for (let char of word) {\n                if (!node.children[char]) {\n                    return false;\n                }\n                node = node.children[char];\n            }\n            return node.isEndOfWord;\n        }\n\n        clear() {\n            this.root = new TrieNode();\n        }\n    }\n\n    const trie = new Trie();\n\n    function displayTrie() {\n        const showNode = (node, prefix) => {\n            const div = document.createElement('div');\n            div.textContent = prefix + (node.isEndOfWord ? ' *' : '');\n            document.getElementById('trie-node').appendChild(div);\n            for (const char in node.children) {\n                showNode(node.children[char], prefix + char);\n            }\n        };\n\n        document.getElementById('trie-node').innerHTML = '';\n        showNode(trie.root, '');\n    }\n\n    document.getElementById('insert-button').onclick = () => {\n        const word = document.getElementById('word-input').value;\n        if (word) {\n            trie.insert(word);\n            displayTrie();\n            document.getElementById('word-input').value = '';\n        }\n    };\n\n    document.getElementById('search-button').onclick = () => {\n        const word = document.getElementById('word-input').value;\n        if (word) {\n            alert(`\"${word}\" ${trie.search(word) ? 'exists' : 'does not exist'} in the trie.`);\n            document.getElementById('word-input').value = '';\n        }\n    };\n\n    document.getElementById('clear-button').onclick = () => {\n        trie.clear();\n        displayTrie();\n    };\n</script>\n\n</body>\n</html>"
