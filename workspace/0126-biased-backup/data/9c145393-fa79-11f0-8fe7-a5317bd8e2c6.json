  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Bellman-Ford Algorithm Interactive Demo</title>\n  <style>\n    /* Extremely minimal styling: keep plain, black-on-white, simple layout */\n    html, body { margin: 8px; padding: 0; font-family: Arial, Helvetica, sans-serif; color: black; background: white; }\n    .row { display: flex; gap: 12px; margin-bottom: 8px; align-items: center; }\n    .col { display: flex; flex-direction: column; gap: 6px; }\n    label { font-size: 13px; }\n    input, button, select, textarea { font-size: 13px; }\n    button { cursor: pointer; }\n    table { border-collapse: collapse; font-size: 13px; }\n    td, th { padding: 4px 6px; border: 1px solid #000; }\n    canvas { border: 1px solid #000; background: white; }\n    pre { background: #fff; padding: 6px; border: 1px solid #000; white-space: pre-wrap; }\n  </style>\n</head>\n<body>\n  <h2>Bellman-Ford Algorithm — Interactive Demo (Plain UI)</h2>\n\n  <!-- Graph Construction Controls -->\n  <div class=\"row\">\n    <div class=\"col\" style=\"min-width:360px;\">\n      <div><strong>Graph Construction</strong></div>\n\n      <div class=\"row\">\n        <label>Number of nodes:</label>\n        <input id=\"nodeCount\" type=\"number\" min=\"1\" value=\"5\" style=\"width:60px;\">\n        <button id=\"generateNodesBtn\">Generate Nodes (grid layout)</button>\n        <button id=\"clearGraphBtn\">Clear Graph</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Add single node:</label>\n        <input id=\"addNodeLabel\" placeholder=\"Label (optional)\">\n        <button id=\"addNodeBtn\">Add Node</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Add edge:</label>\n        <select id=\"edgeFrom\"></select>\n        <select id=\"edgeTo\"></select>\n        <input id=\"edgeWeight\" type=\"number\" value=\"1\" style=\"width:70px;\">\n        <label><input id=\"edgeDirected\" type=\"checkbox\"> directed</label>\n        <button id=\"addEdgeBtn\">Add Edge</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Random graph:</label>\n        <input id=\"rndNodes\" type=\"number\" value=\"6\" min=\"1\" style=\"width:60px;\">\n        <label>Density (0-1):</label>\n        <input id=\"rndDensity\" type=\"number\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.4\" style=\"width:60px;\">\n        <label>Weight range:</label>\n        <input id=\"rndMin\" type=\"number\" value=\"-5\" style=\"width:60px;\">\n        <input id=\"rndMax\" type=\"number\" value=\"10\" style=\"width:60px;\">\n        <button id=\"rndBtn\">Generate Random</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Import / Export:</label>\n        <button id=\"exportGraphBtn\">Export Graph JSON</button>\n        <button id=\"importGraphBtn\">Load JSON from textarea</button>\n      </div>\n\n      <textarea id=\"importExportArea\" rows=\"6\" style=\"width:100%;\"></textarea>\n    </div>\n\n    <!-- Edge list and edit -->\n    <div class=\"col\" style=\"flex:1;\">\n      <div><strong>Edges (click to edit weight or delete)</strong></div>\n      <div id=\"edgesContainer\" style=\"max-height:240px; overflow:auto; border:1px solid #000; padding:4px;\">\n        <!-- Edge table inserted here -->\n      </div>\n\n      <div class=\"row\">\n        <label>Directed mode for new edges:</label>\n        <select id=\"defaultDirected\">\n          <option value=\"true\">Directed</option>\n          <option value=\"false\">Undirected</option>\n        </select>\n        <button id=\"autoLayoutBtn\">Auto Layout Nodes</button>\n        <button id=\"snapPositionsBtn\">Snap to Grid</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Graph state:</label>\n        <button id=\"saveStateBtn\">Save Full State JSON</button>\n        <button id=\"loadStateBtn\">Load State JSON from textarea</button>\n      </div>\n    </div>\n  </div>\n\n  <!-- Algorithm Controls -->\n  <div class=\"row\">\n    <div class=\"col\" style=\"min-width:360px;\">\n      <div><strong>Bellman-Ford Controls</strong></div>\n\n      <div class=\"row\">\n        <label>Source:</label>\n        <select id=\"sourceSelect\"></select>\n\n        <label>Mode:</label>\n        <select id=\"runMode\">\n          <option value=\"auto\">Auto iteration order</option>\n          <option value=\"manual\">Manual relax (click edge)</option>\n        </select>\n\n        <label>Preserve state on edit:</label>\n        <input id=\"preserveOnEdit\" type=\"checkbox\" checked>\n      </div>\n\n      <div class=\"row\">\n        <button id=\"initBtn\">Initialize / Reset Distances</button>\n        <button id=\"stepBtn\">Step (one edge relaxation)</button>\n        <button id=\"stepBackBtn\">Step Back</button>\n        <button id=\"runBtn\">Run to Completion</button>\n        <button id=\"autoRunBtn\">Auto Run</button>\n        <button id=\"pauseBtn\">Pause</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Speed (ms per step):</label>\n        <input id=\"speedRange\" type=\"range\" min=\"50\" max=\"2000\" step=\"50\" value=\"500\">\n        <span id=\"speedVal\">500</span> ms\n      </div>\n\n      <div class=\"row\">\n        <button id=\"detectNegBtn\">Check Negative Cycle (quick test)</button>\n        <button id=\"markNegCycleBtn\">Highlight Negative Cycle if detected</button>\n      </div>\n\n      <div class=\"row\">\n        <button id=\"undoBtn\">Undo</button>\n        <button id=\"redoBtn\">Redo</button>\n        <button id=\"clearHistoryBtn\">Clear History</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Explanation mode:</label>\n        <select id=\"explainLevel\">\n          <option value=\"none\">None</option>\n          <option value=\"brief\">Brief</option>\n          <option value=\"detailed\">Detailed</option>\n        </select>\n      </div>\n    </div>\n\n    <!-- Algorithm state display -->\n    <div class=\"col\" style=\"flex:1;\">\n      <div><strong>Current Algorithm State</strong></div>\n      <div class=\"row\">\n        <label>Iteration (k):</label>\n        <span id=\"iterationLabel\">0</span>\n        <label>Edge index (i):</label>\n        <span id=\"edgeIndexLabel\">0</span>\n        <label>Finished:</label>\n        <span id=\"finishedLabel\">false</span>\n      </div>\n\n      <div class=\"row\">\n        <label>Distances:</label>\n        <div id=\"distContainer\" style=\"flex:1;\"></div>\n      </div>\n\n      <div class=\"row\">\n        <label>Predecessors:</label>\n        <div id=\"predContainer\" style=\"flex:1;\"></div>\n      </div>\n\n      <div class=\"row\">\n        <label>Target for path reconstruction:</label>\n        <select id=\"targetSelect\"></select>\n        <button id=\"reconstructBtn\">Reconstruct Path</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Path:</label>\n        <div id=\"pathContainer\" style=\"flex:1;\"></div>\n      </div>\n\n    </div>\n  </div>\n\n  <!-- Canvas Visualization + Step Explanation -->\n  <div class=\"row\">\n    <div class=\"col\" style=\"min-width:560px;\">\n      <div><strong>Graph Visualization (click edges/nodes for actions)</strong></div>\n      <canvas id=\"graphCanvas\" width=\"720\" height=\"420\"></canvas>\n      <div class=\"row\">\n        <label>Canvas actions:</label>\n        <button id=\"canvasAddNodeBtn\">Add Node at center</button>\n        <button id=\"canvasCenterBtn\">Center Layout</button>\n        <button id=\"canvasClearPositionsBtn\">Clear Positions</button>\n      </div>\n    </div>\n\n    <div class=\"col\" style=\"flex:1;\">\n      <div><strong>Step Explanation / History</strong></div>\n      <div id=\"explainBox\" style=\"height:220px; overflow:auto; border:1px solid #000; padding:6px;\"></div>\n      <div><strong>History</strong></div>\n      <div id=\"historyBox\" style=\"height:180px; overflow:auto; border:1px solid #000; padding:6px;\"></div>\n    </div>\n  </div>\n\n  <script>\n/*\n  Bellman-Ford Interactive Demo\n  - Extremely minimal UI (black text on white)\n  - Rich controls for building graph, stepping algorithm, manual relax\n  - History, undo/redo, random generator, import/export, path reconstruction\n*/\n\n/* ----------- Data Model ----------- */\nlet state = {\n  nodes: [],        // {id, label, x, y}\n  edges: [],        // {id, u, v, w, directed}\n  nextNodeId: 1,\n  nextEdgeId: 1,\n  // Algorithm runtime variables\n  distances: {},\n  pred: {},\n  source: null,\n  iteration: 0,\n  edgeIndex: 0,\n  nIterations: 0,\n  finished: false,\n  negativeCycle: null, // array of node ids if detected\n};\n\n// History and undo/redo\nlet history = [];\nlet future = [];\n\n// Autoplay timer\nlet autoTimer = null;\n\n// Canvas and UI references\nconst canvas = document.getElementById('graphCanvas');\nconst ctx = canvas.getContext('2d');\n\nconst nodeCountInput = document.getElementById('nodeCount');\nconst generateNodesBtn = document.getElementById('generateNodesBtn');\nconst clearGraphBtn = document.getElementById('clearGraphBtn');\nconst addNodeBtn = document.getElementById('addNodeBtn');\nconst addNodeLabel = document.getElementById('addNodeLabel');\n\nconst edgeFrom = document.getElementById('edgeFrom');\nconst edgeTo = document.getElementById('edgeTo');\nconst edgeWeight = document.getElementById('edgeWeight');\nconst edgeDirected = document.getElementById('edgeDirected');\nconst addEdgeBtn = document.getElementById('addEdgeBtn');\n\nconst rndBtn = document.getElementById('rndBtn');\nconst rndNodes = document.getElementById('rndNodes');\nconst rndDensity = document.getElementById('rndDensity');\nconst rndMin = document.getElementById('rndMin');\nconst rndMax = document.getElementById('rndMax');\n\nconst edgesContainer = document.getElementById('edgesContainer');\nconst sourceSelect = document.getElementById('sourceSelect');\nconst initBtn = document.getElementById('initBtn');\nconst stepBtn = document.getElementById('stepBtn');\nconst stepBackBtn = document.getElementById('stepBackBtn');\nconst runBtn = document.getElementById('runBtn');\nconst autoRunBtn = document.getElementById('autoRunBtn');\nconst pauseBtn = document.getElementById('pauseBtn');\nconst speedRange = document.getElementById('speedRange');\nconst speedVal = document.getElementById('speedVal');\nconst runMode = document.getElementById('runMode');\nconst detectNegBtn = document.getElementById('detectNegBtn');\nconst markNegCycleBtn = document.getElementById('markNegCycleBtn');\nconst iterationLabel = document.getElementById('iterationLabel');\nconst edgeIndexLabel = document.getElementById('edgeIndexLabel');\nconst finishedLabel = document.getElementById('finishedLabel');\nconst distContainer = document.getElementById('distContainer');\nconst predContainer = document.getElementById('predContainer');\nconst reconstructBtn = document.getElementById('reconstructBtn');\nconst targetSelect = document.getElementById('targetSelect');\nconst pathContainer = document.getElementById('pathContainer');\nconst explainBox = document.getElementById('explainBox');\nconst historyBox = document.getElementById('historyBox');\nconst exportGraphBtn = document.getElementById('exportGraphBtn');\nconst importGraphBtn = document.getElementById('importGraphBtn');\nconst importExportArea = document.getElementById('importExportArea');\nconst saveStateBtn = document.getElementById('saveStateBtn');\nconst loadStateBtn = document.getElementById('loadStateBtn');\nconst undoBtn = document.getElementById('undoBtn');\nconst redoBtn = document.getElementById('redoBtn');\nconst clearHistoryBtn = document.getElementById('clearHistoryBtn');\nconst defaultDirected = document.getElementById('defaultDirected');\nconst autoLayoutBtn = document.getElementById('autoLayoutBtn');\nconst snapPositionsBtn = document.getElementById('snapPositionsBtn');\nconst preserveOnEdit = document.getElementById('preserveOnEdit');\nconst explainLevel = document.getElementById('explainLevel');\nconst detectNegBtnEl = detectNegBtn;\nconst markNegCycleBtnEl = markNegCycleBtn;\nconst canvasAddNodeBtn = document.getElementById('canvasAddNodeBtn');\nconst canvasCenterBtn = document.getElementById('canvasCenterBtn');\nconst canvasClearPositionsBtn = document.getElementById('canvasClearPositionsBtn');\nconst saveStateJSONBtn = saveStateBtn;\nconst loadStateJSONBtn = loadStateBtn;\nconst exportGraphJSONBtn = exportGraphBtn;\nconst importGraphJSONBtn = importGraphBtn;\n\n/* ----------- Utilities ----------- */\nfunction cloneStateForHistory() {\n  // store a serialized snapshot of relevant parts of state\n  return JSON.parse(JSON.stringify({\n    nodes: state.nodes,\n    edges: state.edges,\n    nextNodeId: state.nextNodeId,\n    nextEdgeId: state.nextEdgeId,\n    distances: state.distances,\n    pred: state.pred,\n    source: state.source,\n    iteration: state.iteration,\n    edgeIndex: state.edgeIndex,\n    finished: state.finished,\n    negativeCycle: state.negativeCycle\n  }));\n}\n\nfunction pushHistory(label) {\n  history.push({ label: label || 'action', snapshot: cloneStateForHistory() });\n  // limit history length to avoid huge memory use\n  if (history.length > 200) history.shift();\n  future = [];\n  renderHistory();\n}\n\nfunction applySnapshot(snapshot) {\n  state.nodes = JSON.parse(JSON.stringify(snapshot.nodes));\n  state.edges = JSON.parse(JSON.stringify(snapshot.edges));\n  state.nextNodeId = snapshot.nextNodeId;\n  state.nextEdgeId = snapshot.nextEdgeId;\n  state.distances = snapshot.distances;\n  state.pred = snapshot.pred;\n  state.source = snapshot.source;\n  state.iteration = snapshot.iteration;\n  state.edgeIndex = snapshot.edgeIndex;\n  state.finished = snapshot.finished;\n  state.negativeCycle = snapshot.negativeCycle;\n  updateAll();\n}\n\nfunction undo() {\n  if (history.length === 0) return;\n  const last = history.pop();\n  future.push({ label: last.label, snapshot: cloneStateForHistory() });\n  if (history.length > 0) {\n    const prev = history[history.length - 1].snapshot;\n    applySnapshot(prev);\n  } else {\n    // no history: clear\n    resetStateToEmpty();\n  }\n  renderHistory();\n}\n\nfunction redo() {\n  if (future.length === 0) return;\n  const next = future.pop();\n  pushHistory(next.label);\n  applySnapshot(next.snapshot);\n}\n\n/* ----------- Graph Editing ----------- */\nfunction resetStateToEmpty() {\n  state = {\n    nodes: [],\n    edges: [],\n    nextNodeId: 1,\n    nextEdgeId: 1,\n    distances: {},\n    pred: {},\n    source: null,\n    iteration: 0,\n    edgeIndex: 0,\n    nIterations: 0,\n    finished: false,\n    negativeCycle: null\n  };\n  history = [];\n  future = [];\n  updateAll();\n}\n\nfunction addNode(label, x, y) {\n  const id = state.nextNodeId++;\n  const node = { id: id.toString(), label: (label || ('v' + id)), x: (x || Math.random() * (canvas.width - 80) + 40), y: (y || Math.random() * (canvas.height - 80) + 40) };\n  state.nodes.push(node);\n  updateNodeSelects();\n  pushHistory('add node ' + node.label);\n  updateAll();\n  return node;\n}\n\nfunction removeNode(nodeId) {\n  // remove edges attached\n  state.edges = state.edges.filter(e => e.u !== nodeId && e.v !== nodeId);\n  state.nodes = state.nodes.filter(n => n.id !== nodeId);\n  if (state.source === nodeId) state.source = null;\n  updateNodeSelects();\n  pushHistory('remove node ' + nodeId);\n  updateAll();\n}\n\nfunction addEdge(u, v, w, directed) {\n  if (!u || !v) return null;\n  const id = (state.nextEdgeId++).toString();\n  const e = { id, u, v, w: Number(w), directed: Boolean(directed) };\n  state.edges.push(e);\n  pushHistory('add edge ' + id);\n  updateAll();\n  return e;\n}\n\nfunction removeEdge(edgeId) {\n  state.edges = state.edges.filter(e => e.id !== edgeId);\n  pushHistory('delete edge ' + edgeId);\n  updateAll();\n}\n\nfunction updateEdgeWeight(edgeId, newWeight) {\n  const e = state.edges.find(x => x.id === edgeId);\n  if (!e) return;\n  e.w = Number(newWeight);\n  pushHistory('edit weight ' + edgeId + ' -> ' + newWeight);\n  if (!preserveOnEdit.checked) {\n    initializeAlgorithm(false);\n  } else {\n    updateAll();\n  }\n}\n\n/* ----------- UI Synchronization ----------- */\nfunction updateNodeSelects() {\n  // Edge from/to, source, target selects\n  [edgeFrom, edgeTo, sourceSelect, targetSelect].forEach(sel => {\n    const old = sel.value;\n    sel.innerHTML = '';\n    state.nodes.forEach(n => {\n      const opt = document.createElement('option');\n      opt.value = n.id;\n      opt.textContent = n.label || n.id;\n      sel.appendChild(opt);\n    });\n    if (state.nodes.length > 0) {\n      if (sel === sourceSelect && state.source) {\n        sel.value = state.source;\n      } else if (old) {\n        if ([...sel.options].some(o => o.value === old)) sel.value = old;\n      }\n    }\n  });\n  renderEdgesList();\n}\n\nfunction renderEdgesList() {\n  // Render table of edges with inline edit\n  const table = document.createElement('table');\n  const header = document.createElement('tr');\n  ['ID','From','To','Weight','Directed','Actions'].forEach(t => {\n    const th = document.createElement('th'); th.textContent = t; header.appendChild(th);\n  });\n  table.appendChild(header);\n\n  state.edges.forEach(e => {\n    const tr = document.createElement('tr');\n    const fromNode = state.nodes.find(n => n.id === e.u);\n    const toNode = state.nodes.find(n => n.id === e.v);\n    const fromLabel = fromNode ? fromNode.label : e.u;\n    const toLabel = toNode ? toNode.label : e.v;\n\n    const tdId = document.createElement('td'); tdId.textContent = e.id; tr.appendChild(tdId);\n    const tdFrom = document.createElement('td'); tdFrom.textContent = fromLabel; tr.appendChild(tdFrom);\n    const tdTo = document.createElement('td'); tdTo.textContent = toLabel; tr.appendChild(tdTo);\n    const tdW = document.createElement('td');\n    const wInput = document.createElement('input'); wInput.type='number'; wInput.value=e.w; wInput.style.width='80px';\n    wInput.addEventListener('change', ()=> updateEdgeWeight(e.id, wInput.value));\n    tdW.appendChild(wInput); tr.appendChild(tdW);\n    const tdDir = document.createElement('td'); tdDir.textContent = e.directed ? 'yes' : 'no'; tr.appendChild(tdDir);\n    const tdAct = document.createElement('td');\n    const delBtn = document.createElement('button'); delBtn.textContent='Delete';\n    delBtn.addEventListener('click', ()=> removeEdge(e.id));\n    tdAct.appendChild(delBtn);\n    tr.appendChild(tdAct);\n    table.appendChild(tr);\n  });\n  edgesContainer.innerHTML = '';\n  edgesContainer.appendChild(table);\n}\n\n/* ----------- Algorithm Implementation ----------- */\n\nfunction initializeAlgorithm(pushHistoryFlag = true) {\n  // Setup distances and preds\n  state.distances = {};\n  state.pred = {};\n  state.nodes.forEach(n => { state.distances[n.id] = Infinity; state.pred[n.id] = null; });\n  if (!state.source && state.nodes.length > 0) {\n    state.source = state.nodes[0].id;\n  }\n  if (state.source) state.distances[state.source] = 0;\n  state.iteration = 0;\n  state.edgeIndex = 0;\n  state.finished = false;\n  state.negativeCycle = null;\n  state.nIterations = Math.max(0, state.nodes.length - 1);\n  if (pushHistoryFlag) pushHistory('initialize BF, source=' + state.source);\n  updateAll();\n}\n\nfunction relaxEdge(edge) {\n  // Attempt relax on edge {u,v,w,directed}\n  const u = edge.u, v = edge.v, w = Number(edge.w);\n  let applied = false;\n  if (state.distances[u] !== undefined && state.distances[u] !== Infinity) {\n    if (state.distances[u] + w < state.distances[v]) {\n      const old = state.distances[v];\n      state.distances[v] = state.distances[u] + w;\n      state.pred[v] = u;\n      applied = true;\n    }\n  }\n  // For undirected edges we also relax reverse as separate conceptual edge\n  return applied;\n}\n\nfunction stepBF() {\n  if (state.finished) {\n    explain('Algorithm already finished; run initialize to restart.');\n    return;\n  }\n  if (!state.source) {\n    explain('No source node selected.');\n    return;\n  }\n  if (runMode.value === 'manual') {\n    explain('Manual mode: Step will not automatically choose an edge. Click an edge in the canvas or in the edge list to relax it manually.');\n    return;\n  }\n  // auto mode: perform one relaxation for the current edgeIndex in current iteration\n  if (state.iteration >= state.nIterations) {\n    // after n-1 iterations, do final pass to detect negative cycles\n    const neg = detectNegativeCycleInternal();\n    state.negativeCycle = neg;\n    state.finished = true;\n    pushHistory('final negative cycle check');\n    updateAll();\n    explain('Completed main iterations. Negative cycle detection performed.');\n    return;\n  }\n  if (state.edgeIndex >= state.edges.length) {\n    // end of this iteration; move to next\n    state.iteration++;\n    state.edgeIndex = 0;\n    pushHistory('end iteration -> ' + state.iteration);\n    explain('Iteration advanced to ' + state.iteration);\n    updateAll();\n    return;\n  }\n  const edge = state.edges[state.edgeIndex];\n  const info = {\n    edgeId: edge.id,\n    u: edge.u,\n    v: edge.v,\n    w: edge.w,\n    preDistU: state.distances[edge.u],\n    preDistV: state.distances[edge.v]\n  };\n  // Attempt relax\n  const applied = relaxEdge(edge);\n  state.edgeIndex++;\n  pushHistory('relax edge ' + edge.id + (applied ? ' applied' : 'no change'));\n  updateAll();\n  explainRelax(info, applied);\n}\n\nfunction manualRelax(edgeId) {\n  if (state.finished) {\n    explain('Algorithm already finished.');\n    return;\n  }\n  const edge = state.edges.find(e => e.id === edgeId);\n  if (!edge) return;\n  const info = {\n    edgeId: edge.id,\n    u: edge.u,\n    v: edge.v,\n    w: edge.w,\n    preDistU: state.distances[edge.u],\n    preDistV: state.distances[edge.v]\n  };\n  const applied = relaxEdge(edge);\n  pushHistory('manual relax edge ' + edge.id + (applied ? ' applied' : 'no change'));\n  updateAll();\n  explainRelax(info, applied);\n}\n\nfunction explainRelax(info, applied) {\n  let text = '';\n  if (explainLevel.value === 'none') {\n    addExplain((applied ? 'Relaxed edge ' : 'No change for edge ') + info.edgeId);\n    return;\n  }\n  if (explainLevel.value === 'brief') {\n    text = (applied ? 'Relaxed: ' : 'No change: ') + 'edge ' + info.edgeId + ' (' + info.u + '->' + info.v + ' w=' + info.w + ')';\n  } else {\n    text = 'Processing edge ' + info.edgeId + ': ' + info.u + ' -> ' + info.v + ' with weight ' + info.w + '.\\n';\n    text += 'Distance(' + info.u + ') before = ' + (info.preDistU === Infinity ? '∞' : info.preDistU) + '. ';\n    text += 'Distance(' + info.v + ') before = ' + (info.preDistV === Infinity ? '∞' : info.preDistV) + '.\\n';\n    if (info.preDistU === Infinity) {\n      text += 'Cannot relax because source to ' + info.u + ' is unreachable.\\n';\n    } else {\n      const candidate = info.preDistU + Number(info.w);\n      text += 'Candidate distance for ' + info.v + ' = ' + candidate + '.\\n';\n      if (candidate < info.preDistV) {\n        text += 'Candidate is better -> relax and update predecessor.\\n';\n      } else {\n        text += 'Candidate not better -> no update.\\n';\n      }\n    }\n  }\n  addExplain(text);\n}\n\nfunction runToCompletion() {\n  if (state.finished) {\n    explain('Already finished.');\n    return;\n  }\n  while (!state.finished) {\n    // We simulate steps until finished, but push history for each step to preserve undo-able actions.\n    if (runMode.value === 'manual') {\n      explain('Switch to \"auto\" mode for automated run-to-completion or relax edges manually.');\n      return;\n    }\n    // Single iteration over edges\n    if (state.iteration >= state.nIterations) {\n      const neg = detectNegativeCycleInternal();\n      state.negativeCycle = neg;\n      state.finished = true;\n      pushHistory('final negative cycle check');\n      break;\n    }\n    if (state.edges.length === 0) {\n      // nothing to relax: just finish\n      state.iteration = state.nIterations;\n      state.finished = true;\n      pushHistory('no edges - finished');\n      break;\n    }\n    // Loop edges\n    for (; state.edgeIndex < state.edges.length; state.edgeIndex++) {\n      const e = state.edges[state.edgeIndex];\n      relaxEdge(e);\n      pushHistory('relax edge ' + e.id + ' (batch run)');\n    }\n    // end of iteration\n    state.iteration++;\n    state.edgeIndex = 0;\n    pushHistory('end iteration -> ' + state.iteration);\n  }\n  updateAll();\n  explain('Run to completion finished. Negative cycle: ' + (state.negativeCycle ? 'detected' : 'not detected'));\n}\n\nfunction autoRunStart() {\n  if (autoTimer) {\n    explain('Auto-run already active.');\n    return;\n  }\n  if (state.finished) {\n    explain('Already finished. Initialize to run again.');\n    return;\n  }\n  if (runMode.value === 'manual') {\n    explain('Auto-run works in auto mode. Switch run mode to \"auto\".');\n    return;\n  }\n  const speed = Number(speedRange.value);\n  autoTimer = setInterval(() => {\n    if (state.finished) {\n      clearInterval(autoTimer); autoTimer = null;\n      explain('Auto-run completed.');\n      return;\n    }\n    stepBF();\n  }, speed);\n  explain('Auto-run started at ' + speed + ' ms per step.');\n}\n\nfunction autoRunPause() {\n  if (autoTimer) {\n    clearInterval(autoTimer); autoTimer = null;\n    explain('Auto-run paused.');\n  } else {\n    explain('Auto-run is not active.');\n  }\n}\n\nfunction detectNegativeCycleInternal() {\n  // After n-1 iterations, perform one pass. If any distance can be reduced, negative cycle exists.\n  const n = state.nodes.length;\n  const snapshotDistances = Object.assign({}, state.distances);\n  for (const e of state.edges) {\n    if (snapshotDistances[e.u] !== undefined && snapshotDistances[e.u] !== Infinity) {\n      if (snapshotDistances[e.u] + e.w < snapshotDistances[e.v]) {\n        // found potential negative cycle; attempt to extract cycle by following preds\n        const cycle = findNegativeCycleNodes(e.v);\n        return cycle;\n      }\n    }\n  }\n  return null;\n}\n\nfunction findNegativeCycleNodes(start) {\n  // Use predecessor chain to detect repeating nodes; start from 'start' and walk up to n steps\n  let x = start;\n  const seen = {};\n  for (let i = 0; i < state.nodes.length; i++) {\n    if (!state.pred[x]) break;\n    x = state.pred[x];\n  }\n  // Now take n steps to capture cycle nodes\n  const cycleNodes = [];\n  let cur = x;\n  for (let i = 0; i < state.nodes.length + 5; i++) {\n    if (cycleNodes.includes(cur)) break;\n    cycleNodes.push(cur);\n    cur = state.pred[cur] || cur;\n  }\n  return cycleNodes;\n}\n\n/* ----------- Rendering / Canvas ----------- */\n\nfunction updateAll() {\n  // Refresh UI components and canvas\n  updateNodeSelects();\n  renderEdgesList();\n  updateLabels();\n  drawGraph();\n  renderDistances();\n}\n\nfunction updateLabels() {\n  iterationLabel.textContent = state.iteration;\n  edgeIndexLabel.textContent = state.edgeIndex;\n  finishedLabel.textContent = state.finished ? 'true' : 'false';\n}\n\nfunction renderDistances() {\n  // Show distances and predecessors as inline lists\n  distContainer.innerHTML = '';\n  predContainer.innerHTML = '';\n  const dl = document.createElement('div');\n  state.nodes.forEach(n => {\n    const span = document.createElement('div');\n    const d = state.distances[n.id];\n    span.textContent = (n.label || n.id) + ': ' + (d === Infinity ? '∞' : d);\n    dl.appendChild(span);\n  });\n  distContainer.appendChild(dl);\n\n  const pl = document.createElement('div');\n  state.nodes.forEach(n => {\n    const p = state.pred[n.id];\n    const span = document.createElement('div');\n    span.textContent = (n.label || n.id) + ': ' + (p ? (state.nodes.find(x=>x.id===p)?.label || p) : '-');\n    pl.appendChild(span);\n  });\n  predContainer.appendChild(pl);\n}\n\nfunction addExplain(text) {\n  const para = document.createElement('div');\n  para.textContent = text;\n  explainBox.insertBefore(para, explainBox.firstChild);\n}\n\nfunction explain(text) {\n  addExplain(text);\n}\n\nfunction renderHistory() {\n  historyBox.innerHTML = '';\n  for (let i = history.length - 1; i >= 0; i--) {\n    const item = history[i];\n    const div = document.createElement('div');\n    div.style.marginBottom = '4px';\n    const btn = document.createElement('button');\n    btn.textContent = 'Revert';\n    btn.addEventListener('click', () => {\n      applySnapshot(item.snapshot);\n      pushHistory('revert to ' + item.label);\n    });\n    div.appendChild(btn);\n    const span = document.createElement('span');\n    span.textContent = ' ' + item.label;\n    div.appendChild(span);\n    historyBox.appendChild(div);\n  }\n}\n\n/* Canvas drawing basics - minimal visual representation */\nfunction drawGraph() {\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  // Draw edges\n  for (const e of state.edges) {\n    const u = state.nodes.find(n => n.id === e.u);\n    const v = state.nodes.find(n => n.id === e.v);\n    if (!u || !v) continue;\n    // Draw line\n    ctx.beginPath();\n    ctx.moveTo(u.x, u.y);\n    ctx.lineTo(v.x, v.y);\n    ctx.strokeStyle = \"#000\";\n    ctx.lineWidth = (state.edgeIndex > 0 && state.edgeIndex <= state.edges.length && state.edges[state.edgeIndex-1]?.id === e.id) ? 3 : 1;\n    ctx.stroke();\n    // Arrow for directed\n    if (e.directed) {\n      drawArrowHead(u.x, u.y, v.x, v.y);\n    }\n    // Weight label at midpoint\n    const mx = (u.x + v.x) / 2;\n    const my = (u.y + v.y) / 2;\n    ctx.fillStyle = \"#000\";\n    ctx.font = \"12px sans-serif\";\n    ctx.fillText('w=' + e.w, mx + 6, my + 6);\n  }\n  // Draw nodes\n  for (const n of state.nodes) {\n    ctx.beginPath();\n    ctx.fillStyle = \"#fff\";\n    ctx.strokeStyle = \"#000\";\n    ctx.lineWidth = 1;\n    ctx.arc(n.x, n.y, 18, 0, Math.PI * 2);\n    ctx.fill();\n    ctx.stroke();\n    ctx.fillStyle = \"#000\";\n    ctx.font = \"12px sans-serif\";\n    ctx.textAlign = \"center\";\n    ctx.textBaseline = \"middle\";\n    const label = n.label || n.id;\n    ctx.fillText(label, n.x, n.y);\n    // Distance displayed below node\n    const d = state.distances[n.id];\n    ctx.font = \"11px sans-serif\";\n    ctx.fillText((d === Infinity ? '∞' : d), n.x, n.y + 26);\n    // Highlight source and negative cycle nodes if any\n    if (state.source === n.id) {\n      ctx.beginPath();\n      ctx.arc(n.x, n.y, 22, 0, Math.PI * 2);\n      ctx.stroke();\n    }\n  }\n}\n\nfunction drawArrowHead(x1, y1, x2, y2) {\n  // minimal arrowhead\n  const dx = x2 - x1;\n  const dy = y2 - y1;\n  const angle = Math.atan2(dy, dx);\n  const len = 10;\n  const hx = x2 - Math.cos(angle) * 20;\n  const hy = y2 - Math.sin(angle) * 20;\n  ctx.beginPath();\n  ctx.moveTo(hx, hy);\n  ctx.lineTo(hx - len * Math.cos(angle - Math.PI/6), hy - len * Math.sin(angle - Math.PI/6));\n  ctx.lineTo(hx - len * Math.cos(angle + Math.PI/6), hy - len * Math.sin(angle + Math.PI/6));\n  ctx.closePath();\n  ctx.fillStyle = \"#000\";\n  ctx.fill();\n}\n\n/* ----------- Path Reconstruction ----------- */\nfunction reconstructPathTo(targetId) {\n  if (!state.source) { pathContainer.textContent = 'No source'; return; }\n  const path = [];\n  let cur = targetId;\n  const visited = {};\n  while (cur && !visited[cur]) {\n    visited[cur] = true;\n    path.push(cur);\n    if (cur === state.source) break;\n    cur = state.pred[cur];\n    if (!cur) break;\n  }\n  if (path[path.length-1] !== state.source) {\n    pathContainer.textContent = 'No path from source to target.';\n    return;\n  }\n  path.reverse();\n  const labels = path.map(id => state.nodes.find(n=>n.id===id)?.label || id);\n  pathContainer.textContent = 'Path: ' + labels.join(' -> ') + '  (cost=' + state.distances[targetId] + ')';\n}\n\n/* ----------- Negative Cycle Highlighting ----------- */\nfunction markNegativeCycle() {\n  if (!state.negativeCycle || state.negativeCycle.length === 0) {\n    explain('No negative cycle recorded.');\n    return;\n  }\n  // We will highlight nodes of cycle by drawing small boxes in explanation\n  addExplain('Negative cycle nodes: ' + state.negativeCycle.join(', '));\n  // Visually indicate by slightly offsetting nodes - minimal: mark their labels in explain\n}\n\n/* ----------- Random Graph Generator ----------- */\nfunction generateRandomGraph(n, density, wmin, wmax) {\n  resetStateToEmpty();\n  for (let i = 0; i < n; i++) addNode('v' + (i+1));\n  // create edges with probability density between all ordered pairs\n  for (let i = 0; i < state.nodes.length; i++) {\n    for (let j = 0; j < state.nodes.length; j++) {\n      if (i === j) continue;\n      if (Math.random() < density) {\n        const w = Math.floor(Math.random() * (wmax - wmin + 1)) + wmin;\n        const directed = true;\n        addEdge(state.nodes[i].id, state.nodes[j].id, w, directed);\n      }\n    }\n  }\n  updateAll();\n  pushHistory('random graph generated');\n}\n\n/* ----------- Import / Export  ----------- */\nfunction exportGraphJSON() {\n  const out = {\n    nodes: state.nodes,\n    edges: state.edges\n  };\n  importExportArea.value = JSON.stringify(out, null, 2);\n}\n\nfunction importGraphJSON() {\n  if (!importExportArea.value) { explain('No JSON in textarea.'); return; }\n  try {\n    const obj = JSON.parse(importExportArea.value);\n    resetStateToEmpty();\n    // Basic validation\n    if (Array.isArray(obj.nodes)) {\n      obj.nodes.forEach(n => {\n        const id = (state.nextNodeId++).toString();\n        state.nodes.push({ id, label: n.label || n.id, x: n.x || Math.random() * canvas.width, y: n.y || Math.random() * canvas.height });\n      });\n    }\n    if (Array.isArray(obj.edges)) {\n      obj.edges.forEach(e => {\n        const u = e.u;\n        const v = e.v;\n        // find closest existing node by label if u/v not matching ids\n        const findNodeId = (val) => {\n          const found = state.nodes.find(n => n.label === val || n.id === val);\n          return found ? found.id : null;\n        };\n        const uid = findNodeId(e.u) || e.u;\n        const vid = findNodeId(e.v) || e.v;\n        addEdge(uid, vid, e.w || 0, e.directed !== undefined ? e.directed : true);\n      });\n    }\n    updateAll();\n    pushHistory('import graph JSON');\n  } catch (err) {\n    explain('Invalid JSON: ' + err.message);\n  }\n}\n\nfunction saveStateJSON() {\n  const snapshot = cloneStateForHistory();\n  importExportArea.value = JSON.stringify(snapshot, null, 2);\n}\n\nfunction loadStateJSON() {\n  if (!importExportArea.value) { explain('Textarea empty.'); return; }\n  try {\n    const obj = JSON.parse(importExportArea.value);\n    applySnapshot(obj);\n    pushHistory('load state JSON');\n  } catch (err) {\n    explain('Invalid JSON state: ' + err.message);\n  }\n}\n\n/* ----------- Canvas interactions (click to manual relax / move nodes) ----------- */\nlet draggingNodeId = null;\nlet dragOffset = {x:0,y:0};\n\ncanvas.addEventListener('mousedown', (ev) => {\n  const p = getCanvasCoords(ev);\n  // detect node hit first\n  const hitNode = state.nodes.find(n => distance(n.x,n.y,p.x,p.y) <= 18);\n  if (hitNode) {\n    // start dragging\n    draggingNodeId = hitNode.id;\n    dragOffset.x = p.x - hitNode.x;\n    dragOffset.y = p.y - hitNode.y;\n    return;\n  }\n  // detect edge click: approximate by checking distance to each segment\n  const hitEdge = state.edges.find(e => {\n    const u = state.nodes.find(n => n.id === e.u);\n    const v = state.nodes.find(n => n.id === e.v);\n    if (!u || !v) return false;\n    const d = distanceToSegment(p.x,p.y,u.x,u.y,v.x,v.y);\n    return d <= 6;\n  });\n  if (hitEdge) {\n    if (runMode.value === 'manual') {\n      manualRelax(hitEdge.id);\n    } else {\n      explain('Edge clicked: ' + hitEdge.id + '. Switch to manual mode to relax by click.');\n    }\n  }\n});\n\ncanvas.addEventListener('mousemove', (ev) => {\n  if (!draggingNodeId) return;\n  const p = getCanvasCoords(ev);\n  const node = state.nodes.find(n => n.id === draggingNodeId);\n  if (!node) return;\n  node.x = Math.max(20, Math.min(canvas.width - 20, p.x - dragOffset.x));\n  node.y = Math.max(20, Math.min(canvas.height - 20, p.y - dragOffset.y));\n  drawGraph();\n});\n\ncanvas.addEventListener('mouseup', ()=> { draggingNodeId = null; });\n\ncanvas.addEventListener('mouseleave', ()=> { draggingNodeId = null; });\n\nfunction getCanvasCoords(ev) {\n  const rect = canvas.getBoundingClientRect();\n  return { x: ev.clientX - rect.left, y: ev.clientY - rect.top };\n}\n\nfunction distance(x1,y1,x2,y2) {\n  return Math.hypot(x1-x2,y1-y2);\n}\n\nfunction distanceToSegment(px,py,x1,y1,x2,y2) {\n  // projection\n  const l2 = (x2-x1)*(x2-x1)+(y2-y1)*(y2-y1);\n  if (l2 === 0) return distance(px,py,x1,y1);\n  let t = ((px-x1)*(x2-x1)+(py-y1)*(y2-y1))/l2;\n  t = Math.max(0, Math.min(1,t));\n  const projx = x1 + t*(x2-x1);\n  const projy = y1 + t*(y2-y1);\n  return distance(px,py,projx,projy);\n}\n\n/* ----------- Misc Controls ----------- */\n\ngenerateNodesBtn.addEventListener('click', () => {\n  const n = Number(nodeCountInput.value) || 0;\n  resetStateToEmpty();\n  // grid layout\n  const cols = Math.ceil(Math.sqrt(n));\n  const rows = Math.ceil(n / cols);\n  const margin = 40;\n  const w = canvas.width - margin*2;\n  const h = canvas.height - margin*2;\n  for (let r = 0; r < rows; r++) {\n    for (let c = 0; c < cols; c++) {\n      if ((r*cols + c) >= n) break;\n      const x = margin + (c + 0.5) * (w / cols);\n      const y = margin + (r + 0.5) * (h / rows);\n      addNode('v' + (state.nextNodeId), x, y);\n    }\n  }\n  updateAll();\n  pushHistory('generate nodes ' + n);\n});\n\nclearGraphBtn.addEventListener('click', () => {\n  resetStateToEmpty();\n  updateAll();\n});\n\naddNodeBtn.addEventListener('click', () => {\n  addNode(addNodeLabel.value || undefined);\n});\n\naddEdgeBtn.addEventListener('click', () => {\n  const u = edgeFrom.value;\n  const v = edgeTo.value;\n  const w = Number(edgeWeight.value);\n  const d = edgeDirected.checked;\n  if (!u || !v) return;\n  addEdge(u, v, w, d);\n});\n\nrndBtn.addEventListener('click', () => {\n  const n = Number(rndNodes.value);\n  const d = Number(rndDensity.value);\n  const mn = Number(rndMin.value);\n  const mx = Number(rndMax.value);\n  generateRandomGraph(n, d, mn, mx);\n});\n\ninitBtn.addEventListener('click', () => {\n  state.source = sourceSelect.value || state.nodes[0]?.id || null;\n  initializeAlgorithm(true);\n});\n\nstepBtn.addEventListener('click', () => {\n  if (runMode.value === 'manual') {\n    explain('Manual mode: clicking edges will relax. Use manual clicks or switch to auto mode for step-by-step automatic edge order.');\n  } else {\n    stepBF();\n  }\n});\n\nstepBackBtn.addEventListener('click', () => {\n  undo();\n});\n\nrunBtn.addEventListener('click', () => {\n  runToCompletion();\n});\n\nautoRunBtn.addEventListener('click', () => {\n  autoRunStart();\n});\n\npauseBtn.addEventListener('click', () => {\n  autoRunPause();\n});\n\nspeedRange.addEventListener('input', () => {\n  speedVal.textContent = speedRange.value;\n  if (autoTimer) {\n    // restart timer with new speed\n    autoRunPause();\n    autoRunStart();\n  }\n});\n\ndetectNegBtn.addEventListener('click', () => {\n  const neg = detectNegativeCycleInternal();\n  state.negativeCycle = neg;\n  if (neg) addExplain('Negative cycle detected (nodes): ' + neg.join(', '));\n  else addExplain('No negative cycle detected on final check.');\n  updateAll();\n});\n\nmarkNegCycleBtn.addEventListener('click', () => {\n  markNegativeCycle();\n});\n\nreconstructBtn.addEventListener('click', () => {\n  const tid = targetSelect.value;\n  if (!tid) { pathContainer.textContent = 'No target selected'; return; }\n  reconstructPathTo(tid);\n});\n\nexportGraphJSONBtn.addEventListener('click', exportGraphJSON);\nimportGraphJSONBtn.addEventListener('click', importGraphJSON);\nsaveStateJSONBtn.addEventListener('click', saveStateJSON);\nloadStateJSONBtn.addEventListener('click', loadStateJSON);\n\nundoBtn.addEventListener('click', () => { undo(); });\nredoBtn.addEventListener('click', () => { redo(); });\nclearHistoryBtn.addEventListener('click', () => { history = []; future = []; renderHistory(); });\n\ndefaultDirected.addEventListener('change', () => { edgeDirected.checked = (defaultDirected.value === 'true'); });\n\nautoLayoutBtn.addEventListener('click', () => {\n  // simple circular layout\n  const n = state.nodes.length;\n  const cx = canvas.width / 2, cy = canvas.height / 2, r = Math.min(canvas.width, canvas.height)/3;\n  state.nodes.forEach((node, i) => {\n    node.x = cx + r * Math.cos(2 * Math.PI * i / n);\n    node.y = cy + r * Math.sin(2 * Math.PI * i / n);\n  });\n  pushHistory('auto layout');\n  updateAll();\n});\n\nsnapPositionsBtn.addEventListener('click', () => {\n  state.nodes.forEach(n => {\n    n.x = Math.round(n.x / 10) * 10;\n    n.y = Math.round(n.y / 10) * 10;\n  });\n  pushHistory('snap positions');\n  updateAll();\n});\n\ncanvasAddNodeBtn.addEventListener('click', () => {\n  addNode('v' + state.nextNodeId, canvas.width/2, canvas.height/2);\n});\n\ncanvasCenterBtn.addEventListener('click', () => {\n  // re-center nodes to canvas center by subtracting bounding box center\n  if (state.nodes.length === 0) return;\n  const xs = state.nodes.map(n=>n.x);\n  const ys = state.nodes.map(n=>n.y);\n  const minx = Math.min(...xs), maxx = Math.max(...xs);\n  const miny = Math.min(...ys), maxy = Math.max(...ys);\n  const cx = (minx + maxx)/2, cy = (miny + maxy)/2;\n  const dx = canvas.width/2 - cx, dy = canvas.height/2 - cy;\n  state.nodes.forEach(n => { n.x += dx; n.y += dy; });\n  pushHistory('center nodes');\n  updateAll();\n});\n\ncanvasClearPositionsBtn.addEventListener('click', () => {\n  state.nodes.forEach(n => { n.x = Math.random() * canvas.width; n.y = Math.random() * canvas.height; });\n  pushHistory('randomize positions');\n  updateAll();\n});\n\n/* Initialize UI */\n(function init() {\n  // Set default edgeDirected checkbox\n  edgeDirected.checked = (defaultDirected.value === 'true');\n\n  // Create some starter nodes for demo\n  resetStateToEmpty();\n  addNode('A', 120, 100);\n  addNode('B', 320, 80);\n  addNode('C', 520, 120);\n  addNode('D', 240, 260);\n  addNode('E', 440, 300);\n  addEdge(state.nodes[0].id, state.nodes[1].id, 6, true);\n  addEdge(state.nodes[0].id, state.nodes[3].id, 7, true);\n  addEdge(state.nodes[1].id, state.nodes[2].id, 5, true);\n  addEdge(state.nodes[1].id, state.nodes[3].id, 8, true);\n  addEdge(state.nodes[1].id, state.nodes[4].id, -4, true);\n  addEdge(state.nodes[3].id, state.nodes[1].id, -2, true);\n  addEdge(state.nodes[4].id, state.nodes[2].id, 7, true);\n  addEdge(state.nodes[3].id, state.nodes[4].id, 9, true);\n  updateAll();\n  pushHistory('initial demo graph');\n})();\n\n</script>\n\n</body>\n</html>"
