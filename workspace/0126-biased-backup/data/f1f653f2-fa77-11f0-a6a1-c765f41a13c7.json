    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Kruskal's Algorithm — Visual Elegance</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Fraunces:opsz,wght@8..144,600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #081028;\n      --accent: #8af7dd;\n      --accent-2: #9b8cff;\n      --muted: rgba(255,255,255,0.06);\n      --glass: rgba(255,255,255,0.03);\n      --success: #44f1a8;\n      --danger: #ff6b88;\n      --edge-default: rgba(255,255,255,0.08);\n      --text: rgba(255,255,255,0.92);\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(155,140,255,0.06), transparent),\n                  radial-gradient(800px 400px at 90% 90%, rgba(138,247,221,0.04), transparent),\n                  linear-gradient(180deg,var(--bg1),var(--bg2));\n      color:var(--text);\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Ambient animated gradients */\n    .ambient {\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      mix-blend-mode:screen;\n      opacity:0.65;\n      filter:blur(60px) saturate(120%);\n    }\n    .ambient::before, .ambient::after {\n      content:\"\";\n      position:absolute;\n      width:60vmax;\n      height:60vmax;\n      border-radius:50%;\n      transform:translate(-20%,-20%);\n      opacity:0.6;\n      animation:float 12s ease-in-out infinite alternate;\n    }\n    .ambient::before{background:linear-gradient(120deg,#7bcff3,#9b8cff); left:-10%; top:10%;}\n    .ambient::after{background:linear-gradient(125deg,#8af7dd,#7bb0ff); right:-20%; bottom:-10%; animation-duration:16s; animation-direction:alternate-reverse;}\n\n    @keyframes float { 0% { transform: translate(-10%,-10%) scale(1); } 100% { transform: translate(0%,-20%) scale(1.06); } }\n\n    /* Main frame */\n    .stage {\n      position:relative;\n      width:1100px;\n      max-width:96%;\n      height:720px;\n      margin:6vh auto;\n      display:flex;\n      gap:28px;\n      align-items:stretch;\n      justify-content:center;\n      padding:28px;\n      border-radius:20px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: 0 10px 40px rgba(3,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(6px) saturate(120%);\n    }\n\n    /* Left: Graph canvas */\n    .canvas {\n      flex:1.4;\n      min-width:580px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border-radius:16px;\n      padding:22px;\n      position:relative;\n      overflow:hidden;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n    .canvas .frame {\n      width:100%;\n      height:100%;\n      border-radius:12px;\n      position:relative;\n    }\n\n    /* Right: Info panel */\n    .info {\n      flex:0.7;\n      min-width:320px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:16px;\n      padding:20px;\n      display:flex;\n      flex-direction:column;\n      gap:16px;\n    }\n\n    .brand {\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-bottom:6px;\n    }\n    .logo {\n      width:52px; height:52px;\n      display:grid;\n      place-items:center;\n      border-radius:12px;\n      background:linear-gradient(180deg,var(--accent),var(--accent-2));\n      box-shadow: 0 6px 22px rgba(91,80,255,0.18), inset 0 -6px 18px rgba(255,255,255,0.06);\n      color:#061026;\n      font-weight:800;\n      font-family:Fraunces, serif;\n      font-size:20px;\n    }\n    h1 {\n      margin:0;\n      font-size:20px;\n      letter-spacing:-0.02em;\n      font-weight:700;\n      line-height:1;\n      color:var(--text);\n    }\n    p.lead {\n      margin:0;\n      color:rgba(255,255,255,0.7);\n      font-size:12px;\n      margin-top:6px;\n    }\n\n    .controls {\n      display:flex;\n      gap:12px;\n      margin-top:8px;\n    }\n    .btn {\n      border:0;\n      outline:0;\n      padding:11px 16px;\n      border-radius:10px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:var(--text);\n      font-weight:600;\n      cursor:pointer;\n      display:inline-flex;\n      align-items:center;\n      gap:8px;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n      transition:transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n      user-select:none;\n    }\n    .btn:active { transform:translateY(1px); }\n    .btn.secondary {\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.008));\n      color:rgba(255,255,255,0.86);\n    }\n    .btn.primary {\n      background: linear-gradient(180deg, var(--accent-2), #6bdcf0);\n      color:#051226;\n      box-shadow: 0 8px 30px rgba(107,220,240,0.16);\n    }\n\n    .panel {\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.0));\n      border-radius:12px;\n      padding:12px;\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n    .small {\n      font-size:12px;\n      color:rgba(255,255,255,0.8);\n    }\n\n    /* Edge list */\n    .edge-list {\n      margin-top:8px;\n      display:flex;\n      flex-direction:column;\n      gap:8px;\n      max-height:300px;\n      overflow:auto;\n      padding-right:6px;\n      padding-left:2px;\n    }\n    .edge-item {\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      padding:8px;\n      border-radius:10px;\n      transition:background .25s ease, transform .18s ease, box-shadow .18s ease;\n      background:transparent;\n      color:rgba(255,255,255,0.9);\n      font-weight:600;\n      font-size:13px;\n    }\n    .edge-item .meta{font-weight:500; font-size:12px; color:rgba(255,255,255,0.65);}\n    .edge-id {\n      display:inline-grid;\n      place-items:center;\n      min-width:36px;\n      height:36px;\n      border-radius:9px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01));\n      box-shadow: 0 6px 18px rgba(2,6,23,0.6), inset 0 -6px 18px rgba(255,255,255,0.02);\n      color:var(--accent-2);\n      font-weight:700;\n    }\n    .edge-weight {\n      padding:6px 10px;\n      border-radius:999px;\n      background:rgba(255,255,255,0.02);\n      color:var(--text);\n      font-weight:700;\n      font-size:12px;\n      display:inline-flex;\n      align-items:center;\n      gap:8px;\n    }\n    .edge-item.selected { background:linear-gradient(90deg, rgba(68,241,168,0.06), rgba(155,140,255,0.02)); box-shadow: inset 0 1px 0 rgba(255,255,255,0.02); }\n    .edge-item.rejected { opacity:0.7; filter:grayscale(0.1); text-decoration:line-through; color:rgba(255,255,255,0.55); }\n\n    /* legend */\n    .legend {\n      display:flex;\n      gap:10px;\n      flex-wrap:wrap;\n      align-items:center;\n      margin-top:auto;\n      font-size:12px;\n      color:rgba(255,255,255,0.75);\n    }\n    .chip { display:inline-flex; gap:8px; align-items:center; padding:8px 10px; border-radius:999px; background:rgba(255,255,255,0.02); }\n    .swatch { width:12px;height:12px;border-radius:6px; box-shadow: 0 2px 8px rgba(0,0,0,0.5); }\n    .sw-green{ background:linear-gradient(180deg,#44f1a8,#1bb87e); }\n    .sw-red{ background:linear-gradient(180deg,#ff6b88,#ff3b5e); }\n    .sw-edge{ background:linear-gradient(180deg,#cfcfff,#7abcfb); }\n\n    /* Footer small */\n    .footer {\n      margin-top:12px;\n      font-size:12px;\n      color:rgba(255,255,255,0.65);\n      display:flex;\n      justify-content:space-between;\n      align-items:center;\n      gap:8px;\n    }\n\n    /* SVG graph styles */\n    svg { width:100%; height:100%; display:block; }\n    .edge {\n      stroke:var(--edge-default);\n      stroke-width:2.4;\n      fill:none;\n      transition: stroke 420ms cubic-bezier(.2,.9,.24,1), stroke-width 420ms cubic-bezier(.2,.9,.24,1), filter 420ms ease, opacity 420ms ease;\n      opacity:0.9;\n      stroke-linecap:round;\n    }\n    .edge .label {\n      fill: rgba(255,255,255,0.95);\n      font-weight:700;\n      font-size:12px;\n      font-family:Inter, sans-serif;\n      pointer-events:none;\n      text-anchor:middle;\n    }\n    .edge.highlight { stroke: #b08bff; filter:drop-shadow(0 8px 18px rgba(138,139,255,0.14)); stroke-width:3; }\n    .edge.selected { stroke:var(--success); stroke-width:4.5; filter:drop-shadow(0 12px 30px rgba(68,241,168,0.12)); opacity:1; }\n    .edge.rejected { stroke:var(--danger); stroke-width:3; opacity:0.7; filter:drop-shadow(0 8px 24px rgba(255,107,136,0.09)); }\n    .edge.strike { opacity:0.5; }\n\n    .node {\n      cursor:default;\n      transition: transform .28s cubic-bezier(.2,.9,.24,1), filter .28s ease;\n      transform-origin:center;\n    }\n    .node .core {\n      fill: url(#gradNode);\n      stroke: rgba(255,255,255,0.06);\n      stroke-width:1.2;\n      filter: drop-shadow(0 8px 26px rgba(11,20,41,0.6));\n      transition: transform .28s cubic-bezier(.2,.9,.24,1), opacity .28s ease;\n    }\n    .node .label {\n      fill: rgba(2,6,23,0.95);\n      font-weight:700;\n      font-size:13px;\n      font-family:Fraunces, serif;\n      pointer-events:none;\n    }\n\n    .node.glow .core { filter: drop-shadow(0 12px 32px rgba(155,140,255,0.12)); transform:scale(1.06); }\n\n    /* weight bubble on edge */\n    .weight-bubble {\n      transition: transform .28s ease, opacity .28s ease;\n    }\n    .weight-bubble.bg { fill: rgba(255,255,255,0.06); stroke: none; }\n    .weight-bubble.txt { fill: rgba(255,255,255,0.95); font-weight:700; font-size:11px; font-family:Inter, sans-serif; text-anchor:middle; dominant-baseline:central; }\n\n    /* subtle timeline progress bar */\n    .progress {\n      position:relative;\n      height:8px;\n      border-radius:8px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      overflow:hidden;\n    }\n    .progress > i {\n      position:absolute;\n      left:0; top:0; bottom:0;\n      width:0%;\n      background: linear-gradient(90deg, #9b8cff, #8af7dd);\n      border-radius:8px;\n      transition:width 1000ms linear;\n      box-shadow: 0 6px 22px rgba(139,115,255,0.12);\n    }\n\n    /* responsiveness */\n    @media (max-width:980px){\n      .stage { flex-direction:column; height:auto; padding:18px; gap:18px; margin:4vh auto; }\n      .canvas { min-width:unset; min-height:420px; }\n      .info { min-width:unset; width:100%;}\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\" role=\"main\" aria-label=\"Kruskal Algorithm Visualization\">\n    <div class=\"canvas\">\n      <div class=\"frame panel\" aria-hidden=\"false\">\n        <!-- SVG Canvas -->\n        <svg id=\"svg\" viewBox=\"0 0 1000 640\" preserveAspectRatio=\"xMidYMid meet\" style=\"border-radius:10px;\">\n          <defs>\n            <linearGradient id=\"gradNode\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#fff\" stop-opacity=\"0.95\"/>\n              <stop offset=\"12%\" stop-color=\"#eaeefb\" stop-opacity=\"0.65\"/>\n              <stop offset=\"100%\" stop-color=\"#9b8cff\" stop-opacity=\"1\"/>\n            </linearGradient>\n            <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"10\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n            <filter id=\"soft\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n              <feDropShadow dx=\"0\" dy=\"8\" stdDeviation=\"16\" flood-color=\"#000\" flood-opacity=\"0.3\"/>\n            </filter>\n          </defs>\n\n          <!-- background grid subtle -->\n          <g opacity=\"0.04\">\n            <rect x=\"0\" y=\"0\" width=\"1000\" height=\"640\" fill=\"url(#grid)\"></rect>\n          </g>\n\n          <!-- edges container -->\n          <g id=\"edges\"></g>\n\n          <!-- nodes container -->\n          <g id=\"nodes\"></g>\n\n          <!-- labels overlay for current step -->\n          <g id=\"hud\"></g>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"info panel\">\n      <div class=\"brand\">\n        <div class=\"logo\">K</div>\n        <div>\n          <h1>Kruskal — Minimum Spanning Tree</h1>\n          <p class=\"lead\">Elegant demonstration of Kruskal's greedy algorithm — edges appear by increasing weight and the algorithm selects non-cyclic edges to form the MST.</p>\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:12px;align-items:center;\">\n        <div class=\"controls\">\n          <button id=\"btnPlay\" class=\"btn primary\" title=\"Play / Pause\">\n            <svg id=\"icPlay\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"#041025\"/></svg>\n            <span id=\"playLabel\">Pause</span>\n          </button>\n          <button id=\"btnReset\" class=\"btn secondary\" title=\"Restart\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M21 4v6h-6\" stroke=\"white\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M3 20a9 9 0 1 1 3  -17.7\" stroke=\"white\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n            Restart\n          </button>\n        </div>\n        <div style=\"flex:1;\">\n          <div class=\"progress\" aria-hidden=\"true\">\n            <i id=\"progressFill\"></i>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"panel small\" style=\"margin-top:6px;\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <div style=\"font-weight:700\">Edge Order</div>\n          <div style=\"font-size:12px;color:rgba(255,255,255,0.6)\">By weight (ascending)</div>\n        </div>\n\n        <div id=\"edgeList\" class=\"edge-list\" aria-hidden=\"false\"></div>\n      </div>\n\n      <div class=\"legend\">\n        <div class=\"chip\"><span class=\"swatch sw-edge\"></span><span>Pending</span></div>\n        <div class=\"chip\"><span class=\"swatch sw-green\"></span><span>Selected (MST)</span></div>\n        <div class=\"chip\"><span class=\"swatch sw-red\"></span><span>Rejected (cycle)</span></div>\n      </div>\n\n      <div class=\"footer\">\n        <div>Nodes: <strong id=\"nodeCount\">0</strong></div>\n        <div>MST Weight: <strong id=\"mstWeight\">0</strong></div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    /* Elegant Kruskal Visualization\n       Minimal interactivity: Play/Pause and Restart\n    */\n    (function(){\n      // Node positions (artfully arranged)\n      const nodes = [\n        { id: 0, label: \"A\", x: 160, y: 120 },\n        { id: 1, label: \"B\", x: 340, y: 90 },\n        { id: 2, label: \"C\", x: 540, y: 110 },\n        { id: 3, label: \"D\", x: 760, y: 150 },\n        { id: 4, label: \"E\", x: 200, y: 300 },\n        { id: 5, label: \"F\", x: 420, y: 320 },\n        { id: 6, label: \"G\", x: 660, y: 350 },\n        { id: 7, label: \"H\", x: 820, y: 260 },\n        { id: 8, label: \"I\", x: 520, y: 480 },\n      ];\n\n      // Edges with weights (undirected)\n      const edges = [\n        { a:0, b:1, w:4, id:\"e0\" },\n        { a:0, b:4, w:8, id:\"e1\" },\n        { a:1, b:2, w:6, id:\"e2\" },\n        { a:1, b:4, w:11, id:\"e3\" },\n        { a:2, b:3, w:1, id:\"e4\" },\n        { a:2, b:5, w:7, id:\"e5\" },\n        { a:3, b:6, w:3, id:\"e6\" },\n        { a:4, b:5, w:2, id:\"e7\" },\n        { a:5, b:6, w:5, id:\"e8\" },\n        { a:6, b:7, w:9, id:\"e9\" },\n        { a:5, b:8, w:12, id:\"e10\" },\n        { a:6, b:8, w:10, id:\"e11\" },\n        { a:3, b:7, w:14, id:\"e12\" },\n        { a:7, b:8, w:13, id:\"e13\" },\n      ];\n\n      // sort edges by weight for Kruskal\n      const sorted = edges.slice().sort((x,y) => x.w - y.w);\n\n      // DOM elements\n      const svg = document.getElementById('svg');\n      const edgesG = document.getElementById('edges');\n      const nodesG = document.getElementById('nodes');\n      const hud = document.getElementById('hud');\n      const edgeList = document.getElementById('edgeList');\n      const btnPlay = document.getElementById('btnPlay');\n      const btnReset = document.getElementById('btnReset');\n      const playLabel = document.getElementById('playLabel');\n      const progressFill = document.getElementById('progressFill');\n      const nodeCountEl = document.getElementById('nodeCount');\n      const mstWeightEl = document.getElementById('mstWeight');\n\n      nodeCountEl.textContent = nodes.length;\n\n      // create node visuals\n      function drawNodes(){\n        nodesG.innerHTML = '';\n        nodes.forEach(n => {\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          g.setAttribute('class','node');\n          g.setAttribute('transform',`translate(${n.x},${n.y})`);\n          g.setAttribute('data-id',n.id);\n\n          const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          circle.setAttribute('r','28');\n          circle.setAttribute('class','core');\n          g.appendChild(circle);\n\n          const labelBg = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          labelBg.setAttribute('r','18');\n          labelBg.setAttribute('fill','rgba(255,255,255,0.025)');\n          labelBg.setAttribute('cx','0');\n          labelBg.setAttribute('cy','28');\n          labelBg.setAttribute('opacity','0.9');\n          labelBg.setAttribute('transform','translate(0,22) scale(1)');\n          // subtle badge behind label\n          // g.appendChild(labelBg);\n\n          const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n          text.setAttribute('class','label');\n          text.setAttribute('y','6');\n          text.setAttribute('x','0');\n          text.setAttribute('text-anchor','middle');\n          text.textContent = n.label;\n          g.appendChild(text);\n\n          nodesG.appendChild(g);\n        });\n      }\n\n      // helper to make a curved path between two nodes\n      function makePath(a,b,curveOffset=0.12){\n        const dx = b.x - a.x;\n        const dy = b.y - a.y;\n        const mx = (a.x + b.x)/2;\n        const my = (a.y + b.y)/2;\n\n        // perpendicular offset for a graceful curve (based on distance)\n        const len = Math.sqrt(dx*dx + dy*dy);\n        const nx = -dy/len;\n        const ny = dx/len;\n        const d = Math.min(60, Math.max(14, len * curveOffset));\n        // vary sign for different edges to reduce overlap\n        const sign = ((a.id + b.id) % 2 === 0) ? 1 : -1;\n        const cx = mx + nx * d * sign;\n        const cy = my + ny * d * sign;\n\n        return `M ${a.x} ${a.y} Q ${cx} ${cy} ${b.x} ${b.y}`;\n      }\n\n      // create edges visuals\n      function drawEdges(){\n        edgesG.innerHTML = '';\n        sorted.forEach((e, i) => {\n          const a = nodes.find(n=>n.id===e.a);\n          const b = nodes.find(n=>n.id===e.b);\n\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          g.setAttribute('class','edgeWrap');\n          g.setAttribute('data-id',e.id);\n          g.setAttribute('data-index',i);\n\n          const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n          path.setAttribute('d', makePath(a,b));\n          path.setAttribute('class','edge');\n          path.setAttribute('stroke-linejoin','round');\n          path.setAttribute('id',e.id);\n\n          // for draw animation\n          path.style.strokeDasharray = path.getTotalLength();\n          path.style.strokeDashoffset = path.getTotalLength();\n\n          g.appendChild(path);\n\n          // weight bubble at midpoint of curve\n          const mid = path.getPointAtLength(path.getTotalLength()*0.52);\n          const bubble = document.createElementNS('http://www.w3.org/2000/svg','g');\n          bubble.setAttribute('class','weight-bubble');\n          bubble.setAttribute('transform',`translate(${mid.x},${mid.y}) scale(1)`);\n\n          const bg = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          bg.setAttribute('r','14');\n          bg.setAttribute('class','bg');\n          bg.setAttribute('fill','rgba(255,255,255,0.02)');\n          bubble.appendChild(bg);\n\n          const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n          text.setAttribute('class','txt');\n          text.setAttribute('y','0');\n          text.setAttribute('x','0');\n          text.textContent = e.w;\n          bubble.appendChild(text);\n\n          g.appendChild(bubble);\n\n          edgesG.appendChild(g);\n        });\n      }\n\n      // Build Edge list UI\n      function buildEdgeList(){\n        edgeList.innerHTML = '';\n        sorted.forEach((e,i) => {\n          const item = document.createElement('div');\n          item.className = 'edge-item';\n          item.id = 'edgeItem_' + e.id;\n\n          const idBox = document.createElement('div');\n          idBox.className = 'edge-id';\n          idBox.textContent = String.fromCharCode(65 + i); // aesthetic ID\n\n          const meta = document.createElement('div');\n          meta.className = 'meta';\n          meta.textContent = `${ nodes.find(n=>n.id===e.a).label } — ${ nodes.find(n=>n.id===e.b).label }`;\n\n          const weight = document.createElement('div');\n          weight.className = 'edge-weight';\n          weight.textContent = e.w;\n\n          item.appendChild(idBox);\n          item.appendChild(meta);\n          item.appendChild(weight);\n\n          edgeList.appendChild(item);\n        });\n      }\n\n      drawNodes();\n      drawEdges();\n      buildEdgeList();\n\n      // DSU (Union-Find)\n      class DSU {\n        constructor(n){ this.p = Array.from({length:n}, (_,i) => i); this.rank = new Array(n).fill(0); }\n        find(a){ if(this.p[a]===a) return a; this.p[a] = this.find(this.p[a]); return this.p[a]; }\n        union(a,b){ a=this.find(a); b=this.find(b); if(a===b) return false; if(this.rank[a]<this.rank[b]) this.p[a]=b; else if(this.rank[b]<this.rank[a]) this.p[b]=a; else { this.p[b]=a; this.rank[a]++; } return true; }\n      }\n\n      // Algorithm state\n      let iStep = 0;\n      let dsu = new DSU(nodes.length);\n      let playing = true;\n      let timer = null;\n      let mstEdges = [];\n      let mstWeight = 0;\n\n      function resetState(){\n        iStep = 0;\n        dsu = new DSU(nodes.length);\n        playing = true;\n        mstEdges = [];\n        mstWeight = 0;\n        mstWeightEl.textContent = '0';\n        // reset visuals\n        const allEdges = edgesG.querySelectorAll('.edge');\n        allEdges.forEach(path => {\n          path.classList.remove('selected','rejected','highlight','strike');\n          path.style.transition = 'none';\n          path.style.strokeDashoffset = path.getTotalLength();\n          path.style.strokeWidth = '';\n          path.style.opacity = '0.95';\n          // small delay to re-enable transitions\n          setTimeout(()=> path.style.transition = '', 40);\n        });\n        const items = edgeList.querySelectorAll('.edge-item');\n        items.forEach(it => it.classList.remove('selected','rejected'));\n        const nodesEls = nodesG.querySelectorAll('.node');\n        nodesEls.forEach(n => n.classList.remove('glow'));\n\n        updateProgress();\n      }\n\n      function updateProgress(){\n        const percent = Math.min(100, Math.round( (iStep / sorted.length) * 100 ));\n        progressFill.style.width = percent + '%';\n      }\n\n      function animateEdgeDraw(path, duration=700){\n        const len = path.getTotalLength();\n        path.style.transition = `stroke-dashoffset ${duration}ms cubic-bezier(.2,.9,.24,1)`;\n        path.style.strokeDashoffset = 0;\n      }\n\n      function stepOnce(){\n        if(iStep >= sorted.length || mstEdges.length >= nodes.length - 1) {\n          // complete\n          playing = false;\n          playLabel.textContent = 'Play';\n          btnPlay.classList.remove('primary');\n          btnPlay.classList.add('secondary');\n          return;\n        }\n        const e = sorted[iStep];\n        const edgePath = document.getElementById(e.id);\n        const item = document.getElementById('edgeItem_' + e.id);\n\n        // highlight current edge\n        edgePath.classList.add('highlight');\n        animateEdgeDraw(edgePath, 640);\n\n        // node glow\n        const na = nodesG.querySelector(`[data-id=\"${e.a}\"]`);\n        const nb = nodesG.querySelector(`[data-id=\"${e.b}\"]`);\n        if(na) na.classList.add('glow');\n        if(nb) nb.classList.add('glow');\n\n        // small label update in HUD\n        showHUD(`Considering edge ${nodes[e.a].label} — ${nodes[e.b].label} (weight ${e.w})`);\n\n        setTimeout(()=> {\n          // decide\n          const ok = dsu.union(e.a, e.b);\n          if(ok){\n            // select into MST\n            mstEdges.push(e);\n            mstWeight += e.w;\n            mstWeightEl.textContent = String(mstWeight);\n            edgePath.classList.remove('highlight');\n            edgePath.classList.add('selected');\n            animateEdgeDraw(edgePath, 220);\n            if(item){ item.classList.add('selected'); item.style.boxShadow = 'inset 0 -6px 18px rgba(68,241,168,0.06)'; }\n\n            // keep node glow persistent for joined nodes\n            if(na) na.classList.add('glow');\n            if(nb) nb.classList.add('glow');\n          } else {\n            // reject (creates cycle)\n            edgePath.classList.remove('highlight');\n            edgePath.classList.add('rejected','strike');\n            // draw as red and add strike animation\n            if(item){ item.classList.add('rejected'); }\n            // animate strike (dash offset back)\n            edgePath.style.transition = `stroke ${420}ms ease, stroke-width ${420}ms ease, opacity 420ms ease`;\n            edgePath.style.opacity = '0.55';\n            edgePath.style.strokeDashoffset = 0;\n          }\n\n          // reset temporary glows after slight delay\n          setTimeout(()=> {\n            if(na && !nodeInMST(e.a)) na.classList.remove('glow');\n            if(nb && !nodeInMST(e.b)) nb.classList.remove('glow');\n            iStep++;\n            updateProgress();\n\n            // continue if playing\n            if(playing) scheduleNext();\n            else {\n              // paused\n            }\n\n            // if finished by selecting enough edges, finalize\n            if(mstEdges.length >= nodes.length - 1){\n              finalizeMST();\n            }\n\n          }, 460);\n\n        }, 900);\n      }\n\n      function nodeInMST(nodeId){\n        // a node is in MST if any selected edge touches it\n        return mstEdges.some(e => e.a === nodeId || e.b === nodeId);\n      }\n\n      function scheduleNext(){\n        clearTimeout(timer);\n        timer = setTimeout(() => {\n          stepOnce();\n        }, 700);\n      }\n\n      function playPause(){\n        playing = !playing;\n        if(playing){\n          playLabel.textContent = 'Pause';\n          btnPlay.classList.remove('secondary');\n          btnPlay.classList.add('primary');\n          // if already finished, restart automatically\n          if(iStep >= sorted.length || mstEdges.length >= nodes.length -1){\n            resetState();\n            scheduleNext();\n          } else {\n            scheduleNext();\n          }\n        } else {\n          playLabel.textContent = 'Play';\n          btnPlay.classList.remove('primary');\n          btnPlay.classList.add('secondary');\n          clearTimeout(timer);\n        }\n      }\n\n      btnPlay.addEventListener('click', () => {\n        playPause();\n      });\n\n      btnReset.addEventListener('click', () => {\n        resetState();\n        // animate small refresh effect\n        const all = edgesG.querySelectorAll('.edge');\n        all.forEach((p, idx) => {\n          p.style.opacity = 0;\n          setTimeout(()=> p.style.opacity = 0.95, idx*30 + 40);\n        });\n        setTimeout(()=> {\n          // begin automatically\n          playing = true;\n          playLabel.textContent = 'Pause';\n          btnPlay.classList.remove('secondary');\n          btnPlay.classList.add('primary');\n          scheduleNext();\n        }, 220);\n      });\n\n      // HUD display\n      function showHUD(text){\n        hud.innerHTML = '';\n        const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n        const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n        rect.setAttribute('x',20);\n        rect.setAttribute('y',18);\n        rect.setAttribute('rx',10);\n        rect.setAttribute('ry',10);\n        rect.setAttribute('width',480);\n        rect.setAttribute('height',44);\n        rect.setAttribute('fill','rgba(6,8,16,0.6)');\n        rect.setAttribute('stroke','rgba(255,255,255,0.03)');\n        rect.setAttribute('style','filter:drop-shadow(0 8px 26px rgba(2,6,23,0.6));');\n\n        const txt = document.createElementNS('http://www.w3.org/2000/svg','text');\n        txt.setAttribute('x',40);\n        txt.setAttribute('y',48);\n        txt.setAttribute('fill','rgba(255,255,255,0.92)');\n        txt.setAttribute('font-size','13');\n        txt.setAttribute('font-weight','600');\n        txt.textContent = text;\n\n        g.appendChild(rect);\n        g.appendChild(txt);\n        hud.appendChild(g);\n\n        // animate fade\n        g.style.opacity = 0;\n        g.style.transition = 'opacity 220ms ease';\n        requestAnimationFrame(()=> g.style.opacity = 1);\n        // remove after short time\n        setTimeout(()=> {\n          g.style.opacity = 0;\n          setTimeout(()=> { if(hud.contains(g)) hud.removeChild(g); }, 300);\n        }, 1600);\n      }\n\n      function finalizeMST(){\n        // subtle final flourish\n        showHUD('Minimum Spanning Tree complete — graceful, minimal, connected.');\n        // highlight MST edges glow\n        mstEdges.forEach(e => {\n          const path = document.getElementById(e.id);\n          if(path){\n            path.classList.add('selected');\n            path.style.transition = 'stroke-width 420ms ease, filter 420ms ease';\n            path.style.strokeWidth = 5.2;\n          }\n        });\n      }\n\n      // Start auto-play on load\n      setTimeout(()=> {\n        scheduleNext();\n      }, 800);\n\n      // small initial UI tweaks\n      btnPlay.classList.add('primary');\n      playLabel.textContent = 'Pause';\n\n      // Prettify the edge list order: attribute mapping to match order\n      // Also make first draw animations subtle\n      updateProgress();\n\n    })();\n  </script>\n</body>\n</html>"
  },
