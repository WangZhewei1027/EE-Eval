    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Suffix Tree Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n        }\n        button {\n            padding: 5px 10px;\n        }\n        #tree-container {\n            font-family: monospace;\n            white-space: pre;\n            overflow-x: auto;\n        }\n        .node {\n            margin-left: 20px;\n        }\n        .edge-label {\n            color: #333;\n            font-weight: bold;\n        }\n        .suffix-link {\n            color: blue;\n            font-style: italic;\n        }\n        .active {\n            background-color: #f0f0f0;\n        }\n        .search-results {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Suffix Tree Interactive Demo</h1>\n        \n        <div class=\"control-group\">\n            <h3>Text Input</h3>\n            <textarea id=\"input-text\">banana$</textarea>\n            <button id=\"build-tree\">Build Suffix Tree</button>\n            <button id=\"random-text\">Random Text</button>\n            Length: <input type=\"range\" id=\"text-length\" min=\"1\" max=\"20\" value=\"6\">\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Tree Operations</h3>\n            <button id=\"expand-all\">Expand All</button>\n            <button id=\"collapse-all\">Collapse All</button>\n            <button id=\"show-links\">Toggle Suffix Links</button>\n            <button id=\"show-indices\">Toggle Suffix Indices</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Pattern Search</h3>\n            <input type=\"text\" id=\"search-pattern\" placeholder=\"Enter pattern\">\n            <button id=\"search\">Search</button>\n            <div class=\"search-results\" id=\"search-results\"></div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Tree Navigation</h3>\n            <button id=\"dfs\">DFS Traversal</button>\n            <button id=\"bfs\">BFS Traversal</button>\n            <button id=\"reset\">Reset Highlight</button>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Tree Statistics</h3>\n            <div id=\"stats\">\n                Nodes: <span id=\"node-count\">0</span> | \n                Edges: <span id=\"edge-count\">0</span> | \n                Height: <span id=\"tree-height\">0</span> | \n                Longest Repeat: <span id=\"longest-repeat\"></span>\n            </div>\n        </div>\n        \n        <h2>Suffix Tree Visualization</h2>\n        <div id=\"tree-container\">No tree built yet. Enter text and click \"Build Suffix Tree\".</div>\n    </div>\n\n    <script>\n        class SuffixTreeNode {\n            constructor() {\n                this.children = {};\n                this.suffixLink = null;\n                this.start = 0;\n                this.end = 0;\n                this.suffixIndex = -1;\n                this.isLeaf = false;\n            }\n        }\n\n        class SuffixTree {\n            constructor(text) {\n                this.text = text;\n                this.root = new SuffixTreeNode();\n                this.build();\n            }\n\n            build() {\n                this.root = new SuffixTreeNode();\n                this.activeNode = this.root;\n                this.activeEdge = -1;\n                this.activeLength = 0;\n                this.remaining = 0;\n                this.lastNewNode = null;\n                this.size = this.text.length;\n                \n                for (let i = 0; i < this.size; i++) {\n                    this.extend(i);\n                }\n                \n                this.setSuffixIndices(this.root, 0);\n            }\n\n            extend(pos) {\n                this.lastNewNode = null;\n                this.remaining++;\n                \n                while (this.remaining > 0) {\n                    if (this.activeLength === 0) {\n                        this.activeEdge = pos;\n                    }\n                    \n                    if (!this.activeNode.children[this.text[this.activeEdge]]) {\n                        this.activeNode.children[this.text[this.activeEdge]] = new SuffixTreeNode();\n                        this.activeNode.children[this.text[this.activeEdge]].start = pos;\n                        this.activeNode.children[this.text[this.activeEdge]].end = this.size - 1;\n                        this.activeNode.children[this.text[this.activeEdge]].isLeaf = true;\n                        \n                        if (this.lastNewNode !== null) {\n                            this.lastNewNode.suffixLink = this.activeNode;\n                            this.lastNewNode = null;\n                        }\n                    } else {\n                        const next = this.activeNode.children[this.text[this.activeEdge]];\n                        const edgeLength = next.end - next.start + 1;\n                        \n                        if (this.activeLength >= edgeLength) {\n                            this.activeEdge += edgeLength;\n                            this.activeLength -= edgeLength;\n                            this.activeNode = next;\n                            continue;\n                        }\n                        \n                        if (this.text[next.start + this.activeLength] === this.text[pos]) {\n                            if (this.lastNewNode !== null && this.activeNode !== this.root) {\n                                this.lastNewNode.suffixLink = this.activeNode;\n                                this.lastNewNode = null;\n                            }\n                            \n                            this.activeLength++;\n                            break;\n                        }\n                        \n                        const splitEnd = next.start + this.activeLength - 1;\n                        const splitNode = new SuffixTreeNode();\n                        splitNode.start = next.start;\n                        splitNode.end = splitEnd;\n                        \n                        this.activeNode.children[this.text[this.activeEdge]] = splitNode;\n                        splitNode.children[this.text[pos]] = new SuffixTreeNode();\n                        splitNode.children[this.text[pos]].start = pos;\n                        splitNode.children[this.text[pos]].end = this.size - 1;\n                        splitNode.children[this.text[pos]].isLeaf = true;\n                        \n                        next.start += this.activeLength;\n                        splitNode.children[this.text[next.start]] = next;\n                        \n                        if (this.lastNewNode !== null) {\n                            this.lastNewNode.suffixLink = splitNode;\n                        }\n                        \n                        this.lastNewNode = splitNode;\n                    }\n                    \n                    this.remaining--;\n                    \n                    if (this.activeNode === this.root && this.activeLength > 0) {\n                        this.activeLength--;\n                        this.activeEdge = pos - this.remaining + 1;\n                    } else if (this.activeNode !== this.root) {\n                        this.activeNode = this.activeNode.suffixLink || this.root;\n                    }\n                }\n            }\n\n            setSuffixIndices(node, labelHeight) {\n                if (!node) return;\n                \n                let isLeaf = true;\n                for (const child in node.children) {\n                    isLeaf = false;\n                    const childNode = node.children[child];\n                    this.setSuffixIndices(\n                        childNode,\n                        labelHeight + (childNode.end - childNode.start + 1)\n                    );\n                }\n                \n                if (isLeaf) {\n                    node.suffixIndex = this.size - labelHeight;\n                }\n            }\n\n            search(pattern) {\n                let node = this.root;\n                let patternIndex = 0;\n                const result = {\n                    found: false,\n                    positions: []\n                };\n                \n                while (patternIndex < pattern.length) {\n                    const currentChar = pattern[patternIndex];\n                    if (!node.children[currentChar]) {\n                        return result;\n                    }\n                    \n                    const child = node.children[currentChar];\n                    const edgeText = this.text.slice(child.start, child.end + 1);\n                    \n                    for (let i = 0; i < edgeText.length && patternIndex < pattern.length; i++) {\n                        if (edgeText[i] !== pattern[patternIndex]) {\n                            return result;\n                        }\n                        patternIndex++;\n                    }\n                    \n                    node = child;\n                }\n                \n                result.found = true;\n                this.collectSuffixIndices(node, result.positions);\n                return result;\n            }\n\n            collectSuffixIndices(node, positions) {\n                if (node.isLeaf) {\n                    positions.push(node.suffixIndex);\n                    return;\n                }\n                \n                for (const child in node.children) {\n                    this.collectSuffixIndices(node.children[child], positions);\n                }\n            }\n\n            getLongestRepeatedSubstring() {\n                let maxLength = 0;\n                let substring = '';\n                \n                const traverse = (node, currentLength, currentString) => {\n                    if (Object.keys(node.children).length === 0) return;\n                    \n                    for (const child in node.children) {\n                        const childNode = node.children[child];\n                        const edgeLength = childNode.end - childNode.start + 1;\n                        const newLength = currentLength + edgeLength;\n                        const newString = currentString + this.text.slice(childNode.start, childNode.end + 1);\n                        \n                        if (Object.keys(childNode.children).length > 1 && newLength > maxLength) {\n                            maxLength = newLength;\n                            substring = newString;\n                        }\n                        \n                        traverse(childNode, newLength, newString);\n                    }\n                };\n                \n                traverse(this.root, 0, '');\n                return substring;\n            }\n\n            getNodeCount() {\n                let count = 0;\n                const traverse = (node) => {\n                    if (!node) return;\n                    count++;\n                    for (const child in node.children) {\n                        traverse(node.children[child]);\n                    }\n                };\n                traverse(this.root);\n                return count;\n            }\n\n            getEdgeCount() {\n                let count = 0;\n                const traverse = (node) => {\n                    if (!node) return;\n                    for (const child in node.children) {\n                        count++;\n                        traverse(node.children[child]);\n                    }\n                };\n                traverse(this.root);\n                return count;\n            }\n\n            getHeight() {\n                const traverse = (node) => {\n                    if (!node || Object.keys(node.children).length === 0) return 0;\n                    let max = 0;\n                    for (const child in node.children) {\n                        const childHeight = node.children[child].end - node.children[child].start + 1;\n                        max = Math.max(max, childHeight + traverse(node.children[child]));\n                    }\n                    return max;\n                };\n                return traverse(this.root);\n            }\n        }\n\n        // UI State\n        let suffixTree = null;\n        let showSuffixLinks = false;\n        let showSuffixIndices = false;\n        let expandedNodes = new Set();\n\n        // DOM Elements\n        const inputText = document.getElementById('input-text');\n        const buildTreeBtn = document.getElementById('build-tree');\n        const randomTextBtn = document.getElementById('random-text');\n        const textLengthSlider = document.getElementById('text-length');\n        const expandAllBtn = document.getElementById('expand-all');\n        const collapseAllBtn = document.getElementById('collapse-all');\n        const showLinksBtn = document.getElementById('show-links');\n        const showIndicesBtn = document.getElementById('show-indices');\n        const searchInput = document.getElementById('search-pattern');\n        const searchBtn = document.getElementById('search');\n        const searchResults = document.getElementById('search-results');\n        const dfsBtn = document.getElementById('dfs');\n        const bfsBtn = document.getElementById('bfs');\n        const resetBtn = document.getElementById('reset');\n        const treeContainer = document.getElementById('tree-container');\n        const nodeCountSpan = document.getElementById('node-count');\n        const edgeCountSpan = document.getElementById('edge-count');\n        const treeHeightSpan = document.getElementById('tree-height');\n        const longestRepeatSpan = document.getElementById('longest-repeat');\n\n        // Event Listeners\n        buildTreeBtn.addEventListener('click', buildTree);\n        randomTextBtn.addEventListener('click', generateRandomText);\n        expandAllBtn.addEventListener('click', expandAllNodes);\n        collapseAllBtn.addEventListener('click', collapseAllNodes);\n        showLinksBtn.addEventListener('click', toggleSuffixLinks);\n        showIndicesBtn.addEventListener('click', toggleSuffixIndices);\n        searchBtn.addEventListener('click', searchPattern);\n        dfsBtn.addEventListener('click', traverseDFS);\n        bfsBtn.addEventListener('click', traverseBFS);\n        resetBtn.addEventListener('click', resetHighlight);\n\n        // Functions\n        function buildTree() {\n            const text = inputText.value.trim();\n            if (!text) return;\n            \n            suffixTree = new SuffixTree(text);\n            expandedNodes = new Set();\n            expandedNodes.add('root');\n            renderTree();\n            updateStats();\n        }\n\n        function generateRandomText() {\n            const length = parseInt(textLengthSlider.value);\n            const chars = 'abcdefghijklmnopqrstuvwxyz';\n            let result = '';\n            \n            for (let i = 0; i < length; i++) {\n                result += chars.charAt(Math.floor(Math.random() * chars.length));\n            }\n            \n            inputText.value = result + '$';\n            buildTree();\n        }\n\n        function toggleSuffixLinks() {\n            showSuffixLinks = !showSuffixLinks;\n            renderTree();\n        }\n\n        function toggleSuffixIndices() {\n            showSuffixIndices = !showSuffixIndices;\n            renderTree();\n        }\n\n        function expandAllNodes() {\n            if (!suffixTree) return;\n            expandedNodes = new Set();\n            traverseAndExpand(suffixTree.root, 'root');\n            renderTree();\n        }\n\n        function traverseAndExpand(node, path) {\n            expandedNodes.add(path);\n            for (const child in node.children) {\n                traverseAndExpand(node.children[child], `${path}-${child}`);\n            }\n        }\n\n        function collapseAllNodes() {\n            expandedNodes = new Set(['root']);\n            renderTree();\n        }\n\n        function searchPattern() {\n            if (!suffixTree) {\n                searchResults.textContent = 'No tree built yet.';\n                return;\n            }\n            \n            const pattern = searchInput.value.trim();\n            if (!pattern) {\n                searchResults.textContent = 'Please enter a search pattern.';\n                return;\n            }\n            \n            const result = suffixTree.search(pattern);\n            if (result.found) {\n                searchResults.textContent = `Pattern found at positions: ${result.positions.join(', ')}`;\n            } else {\n                searchResults.textContent = 'Pattern not found.';\n            }\n        }\n\n        function traverseDFS() {\n            if (!suffixTree) return;\n            \n            let delay = 0;\n            const traverse = (node, path) => {\n                setTimeout(() => {\n                    highlightNode(path);\n                }, delay * 500);\n                delay++;\n                \n                for (const child in node.children) {\n                    traverse(node.children[child], `${path}-${child}`);\n                }\n            };\n            \n            traverse(suffixTree.root, 'root');\n        }\n\n        function traverseBFS() {\n            if (!suffixTree) return;\n            \n            const queue = [{node: suffixTree.root, path: 'root'}];\n            let delay = 0;\n            \n            while (queue.length > 0) {\n                const current = queue.shift();\n                \n                setTimeout(() => {\n                    highlightNode(current.path);\n                }, delay * 500);\n                delay++;\n                \n                for (const child in current.node.children) {\n                    queue.push({\n                        node: current.node.children[child],\n                        path: `${current.path}-${child}`\n                    });\n                }\n            }\n        }\n\n        function highlightNode(path) {\n            const nodeElements = document.querySelectorAll('.node');\n            nodeElements.forEach(el => {\n                el.classList.remove('active');\n                if (el.dataset.path === path) {\n                    el.classList.add('active');\n                    el.scrollIntoView({behavior: 'smooth', block: 'center'});\n                }\n            });\n        }\n\n        function resetHighlight() {\n            document.querySelectorAll('.node').forEach(el => {\n                el.classList.remove('active');\n            });\n        }\n\n        function renderTree() {\n            if (!suffixTree) {\n                treeContainer.textContent = 'No tree built yet. Enter text and click \"Build Suffix Tree\".';\n                return;\n            }\n            \n            let output = '';\n            const traverse = (node, depth, path) => {\n                if (!node) return;\n                \n                const isExpanded = expandedNodes.has(path);\n                const hasChildren = Object.keys(node.children).length > 0;\n                const edgeText = suffixTree.text.slice(node.start, node.end + 1);\n                \n                output += `${'  '.repeat(depth)}`;\n                \n                if (path !== 'root') {\n                    if (hasChildren) {\n                        output += `<span class=\"node\" data-path=\"${path}\" onclick=\"toggleNode('${path}')\">`;\n                        output += `[${isExpanded ? '-' : '+'}] `;\n                    } else {\n                        output += `<span class=\"node\" data-path=\"${path}\">`;\n                        output += '  ';\n                    }\n                    \n                    output += `<span class=\"edge-label\">${edgeText}</span>`;\n                    \n                    if (node.isLeaf && showSuffixIndices) {\n                        output += ` (${node.suffixIndex})`;\n                    }\n                    \n                    if (showSuffixLinks && node.suffixLink && path.endsWith('root') === false) {\n                        output += ` <span class=\"suffix-link\">→ ${getNodePath(node.suffixLink)}</span>`;\n                    }\n                    \n                    output += '</span>\\n                }\n                \n                output += '\\n';\n                \n                if (isExpanded) {\n                    for (const child in node.children) {\n                        traverse(node.children[child], depth + 1, `${path}-${child}`);\n                    }\n                }\n            };\n            \n            traverse(suffixTree.root, 0, 'root');\n            treeContainer.innerHTML = output;\n        }\n\n        function toggleNode(path) {\n            if (expandedNodes.has(path)) {\n                expandedNodes.delete(path);\n            } else {\n                expandedNodes.add(path);\n            }\n            renderTree();\n        }\n\n        function getNodePath(node) {\n            if (node === suffixTree.root) return 'root';\n            \n            let current = node;\n            let path = '';\n            const stack = [];\n            \n            while (current && current !== suffixTree.root) {\n                let found = false;\n                for (const parent in suffixTree.root.children) {\n                    if (suffixTree.root.children[parent] === current) {\n                        stack.push(parent);\n                        found = true;\n                        break;\n                    }\n                }\n                \n                if (!found) {\n                    for (const parentKey in suffixTree.root.children) {\n                        const parentNode = suffixTree.root.children[parentKey];\n                        for (const child in parentNode.children) {\n                            if (parentNode.children[child] === current) {\n                                stack.push(child);\n                                current = parentNode;\n                                found = true;\n                                break;\n                            }\n                        }\n                        if (found) break;\n                    }\n                }\n                \n                if (!found) break;\n            }\n            \n            while (stack.length > 0) {\n                path += (path ? '-' : '') + stack.pop();\n            }\n            \n            return path || 'root';\n        }\n\n        function updateStats() {\n            if (!suffixTree) return;\n            \n            nodeCountSpan.textContent = suffixTree.getNodeCount();\n            edgeCountSpan.textContent = suffixTree.getEdgeCount();\n            treeHeightSpan.textContent = suffixTree.getHeight();\n            longestRepeatSpan.textContent = suffixTree.getLongestRepeatedSubstring() || 'None';\n        }\n\n        // Expose to global scope for onclick handlers\n        window.toggleNode = toggleNode;\n    </script>\n</body>\n</html>"
