    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Query Optimization – Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap');\n\n  /* Reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  } \n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Inter', sans-serif;\n    color: #e6ebf1;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.5rem;\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n    margin: 2rem 0 0.25rem 0;\n    text-align: center;\n    color: #a8d0ff;\n    text-shadow:\n      0 0 8px #a8d0ff, \n      0 0 25px #3a78ff;\n  }\n\n  h2 {\n    font-weight: 400;\n    font-size: 1.25rem;\n    color: #9ab8d9bb;\n    text-align: center;\n    margin: 0 0 3rem 0;\n    letter-spacing: 0.04em;\n  }\n\n  main {\n    max-width: 960px;\n    margin: auto;\n    padding: 0 1rem 4rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  /* Container of visualization */\n  .visualization {\n    position: relative;\n    width: 900px;\n    max-width: 90vw;\n    height: 600px;\n    background:\n      radial-gradient(ellipse at center, #1a3146 30%, transparent 70%),\n      linear-gradient(45deg, #16293b 0%, #1b3554 100%);\n    border-radius: 1.25rem;\n    box-shadow:\n      0 20px 40px rgba(10, 26, 43, 0.9),\n      inset 0 0 60px #274a7c,\n      inset 0 -10px 40px #1a2b41;\n    overflow: visible;\n    user-select: none;\n  }\n\n  /* Flow container */\n  .flow {\n    position: absolute;\n    top: 50px;\n    left: 50px;\n    right: 50px;\n    bottom: 50px;\n    pointer-events: none;\n  }\n\n  /* Query Input */\n  .query-input {\n    position: absolute;\n    top: 40px;\n    left: 60px;\n    width: 180px;\n    height: 100px;\n    background: #1e3a68e0;\n    border-radius: 14px;\n    box-shadow: \n      0 0 8px #5584ffaa,\n      inset 0 0 10px #446eace0;\n    border: 2px solid #4a77d1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    color: #a8c1ff;\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.08em;\n    text-align: center;\n    user-select: none;\n  }\n  .query-input span {\n    font-size: 1.8rem;\n    margin-bottom: 0.35rem;\n    color: #83aaffdb;\n  }\n  /* Parse stage */\n  .parse-stage {\n    position: absolute;\n    top: 200px;\n    left: 60px;\n    width: 180px;\n    height: 90px;\n    background: #222f54cc;\n    border-radius: 14px;\n    box-shadow:\n      0 0 15px #4867b9cc,\n      inset 0 2px 10px #1e2a4ecc;\n    border: 2px solid #3e57a8;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    color: #7da5f3;\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.04em;\n    text-align: center;\n    user-select: none;\n  }\n\n  /* Optimization stage */\n  .opt-stage {\n    position: absolute;\n    top: 200px;\n    left: calc(50% - 90px);\n    width: 180px;\n    height: 90px;\n    background: #27486eee;\n    border-radius: 14px;\n    box-shadow:\n      0 0 20px #5d93ffcc,\n      inset 0 0 15px #3d6ca2cc;\n    border: 2px solid #6fb0ff;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    color: #a2c5ff;\n    font-weight: 700;\n    font-size: 1.2rem;\n    letter-spacing: 0.04em;\n    text-align: center;\n    user-select: none;\n    filter: drop-shadow(0 0 10px #6fb0ff99);\n  }\n\n  /* Plan generation */\n  .plan-stage {\n    position: absolute;\n    top: 200px;\n    right: 60px;\n    width: 180px;\n    height: 90px;\n    background: #1a2b4aee;\n    border-radius: 14px;\n    box-shadow:\n      0 0 15px #4472adcc,\n      inset 0 0 14px #2a4478cc;\n    border: 2px solid #4c7bc1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    color: #91afff;\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.04em;\n    text-align: center;\n    user-select: none;\n  }\n\n  /* Execution stage */\n  .exec-stage {\n    position: absolute;\n    bottom: 60px;\n    left: calc(50% - 90px);\n    width: 180px;\n    height: 100px;\n    background: #0f316fdd;\n    border-radius: 14px;\n    box-shadow:\n      0 0 30px #2d65e0cc,\n      inset 0 4px 15px #134b8ecc;\n    border: 2px solid #4b7de2;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    color: #97bcff;\n    font-weight: 700;\n    font-size: 1.3rem;\n    letter-spacing: 0.06em;\n    text-align: center;\n    user-select: none;\n  }\n\n  /* Arrows - animated */\n\n  svg {\n    position: absolute;\n    pointer-events: none;\n    overflow: visible;\n  }\n\n  /* Arrow lines */\n  .arrow-line {\n    stroke: #6ea2ffcc;\n    stroke-width: 3;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 2px #5493ff99);\n    animation: dashmove 2.5s linear infinite;\n  }\n\n  .arrow-head {\n    fill: #7db3ffdd;\n    filter: drop-shadow(0 0 3px #7db3ffbb);\n    transition: fill 0.35s ease;\n  }\n\n  /* Animate dashed line */\n  @keyframes dashmove {\n    to {\n      stroke-dashoffset: -20;\n    }\n  }\n\n  /* Hover arrow highlight on optimize stage button hover */\n  #btnOptimize:hover ~ .flow svg .arrow-line,\n  #btnOptimize:hover ~ .flow svg .arrow-head {\n    stroke: #a4c8ff;\n    fill: #b3d0ff;\n    animation-play-state: paused;\n  }\n\n  /* Pulsing glow effect */\n  .pulse-glow {\n    animation: pulse 3s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% {\n      filter: drop-shadow(0 0 15px #6fb0ffcc);\n    }\n    50% {\n      filter: drop-shadow(0 0 30px #a4c8ffdd);\n    }\n  }\n\n  /* Control Buttons container */\n  .controls {\n    margin-top: 1.75rem;\n    display: flex;\n    gap: 1.1rem;\n    justify-content: center;\n  }\n  button {\n    background: #1e3a68cc;\n    border: 2.5px solid #4c7bc1;\n    color: #a8c1ffdd;\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.08em;\n    padding: 0.55rem 2.25rem;\n    border-radius: 12px;\n    cursor: pointer;\n    user-select: none;\n    transition:\n      background 0.4s ease,\n      border-color 0.3s ease,\n      color 0.35s ease,\n      box-shadow 0.7s ease;\n    box-shadow: 0 0 12px #4c7bc1aa;\n  }\n  button:hover {\n    background: #4c86f7ee;\n    border-color: #91b2ffcc;\n    color: #e3ecff;\n    box-shadow: 0 0 22px #a4c8ff99;\n  }\n  button:active {\n    background: #2d548dee;\n    border-color: #5c89ffcc;\n    box-shadow: 0 0 12px #5eb3ffbb;\n  }\n  button:focus-visible {\n    outline-offset: 2.5px;\n    outline: 2.7px solid #95b4ffcc;\n  }\n\n  /* Tooltip */\n  .tooltip {\n    position: absolute;\n    top: -0.85rem;\n    font-size: 0.85rem;\n    font-weight: 600;\n    letter-spacing: 0.06em;\n    color: #b1cfffdd;\n    user-select: none;\n    pointer-events: none;\n    text-shadow: 0 0 6px #000000cc;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n  }\n  button[data-tooltip]:hover::after {\n    content: attr(data-tooltip);\n    position: absolute;\n    top: -2.5rem;\n    left: 50%;\n    transform: translateX(-50%);\n    background: #274f94dd;\n    padding: 0.35rem 1rem;\n    border-radius: 10px;\n    color: #e0ebffdd;\n    font-weight: 600;\n    font-size: 0.85rem;\n    letter-spacing: 0.05em;\n    pointer-events: none;\n    opacity: 1;\n    white-space: nowrap;\n    box-shadow: 0 0 12px #2f63c8cc;\n    transition: opacity 0.35s ease;\n  }\n\n  /* Small subtle shine on stage boxes */\n  .stage-shine {\n    position: absolute;\n    top: 8px;\n    left: -10px;\n    width: 60px;\n    height: 150%;\n    background: linear-gradient(130deg, #9fc5ff44 0%, transparent 80%);\n    border-radius: 15px;\n    opacity: 0.15;\n    pointer-events: none;\n    mix-blend-mode: screen;\n    animation: shineMove 6s linear infinite;\n  }\n  .parse-stage > .stage-shine {\n    animation-delay: 0s;\n  }\n  .opt-stage > .stage-shine {\n    animation-delay: 1.5s;\n  }\n  .plan-stage > .stage-shine {\n    animation-delay: 3s;\n  }\n  .query-input > .stage-shine {\n    animation-delay: 4.2s;\n  }\n  .exec-stage > .stage-shine {\n    animation-delay: 5s;\n  }\n  @keyframes shineMove {\n    0% {\n      transform: translateX(-100%) skewX(-15deg);\n      opacity: 0.15;\n    }\n    50% {\n      opacity: 0.35;\n    }\n    100% {\n      transform: translateX(150%) skewX(-15deg);\n      opacity: 0.15;\n    }\n  }\n\n  /* Subtle floating animation for optimization stage */\n  .opt-stage.pulse-glow {\n    animation: pulse 3.5s ease-in-out infinite;\n  }\n  .opt-stage.float {\n    animation: floatUpDown 4s ease-in-out infinite;\n  }\n  @keyframes floatUpDown {\n    0%, 100% {\n      transform: translateY(0);\n      filter: drop-shadow(0 0 13px #6fb0ffcc);\n    }\n    50% {\n      transform: translateY(-8px);\n      filter: drop-shadow(0 0 30px #a4c8ffdd);\n    }\n  }\n\n  /* Footer text */\n  footer {\n    text-align: center;\n    font-size: 0.85rem;\n    margin: 3rem 1rem 2rem;\n    color: #5d7abfaa;\n    font-weight: 500;\n    letter-spacing: 0.06em;\n  }\n\n  /* Responsive adjustments */\n  @media (max-width: 620px) {\n    h1 {\n      font-size: 2.4rem;\n    }\n    h2 {\n      font-size: 1rem;\n    }\n    .visualization {\n      height: 480px;\n    }\n    .query-input,\n    .parse-stage,\n    .opt-stage,\n    .plan-stage,\n    .exec-stage {\n      width: 140px !important;\n      height: 75px !important;\n      font-size: 1rem !important;\n    }\n    main {\n      padding-bottom: 2rem;\n    }\n    .exec-stage {\n      height: 85px !important;\n    }\n  }\n</style>\n</head>\n<body>\n<main>\n  <h1>Query Optimization</h1>\n  <h2>Visualizing the flow of query transformation & execution</h2>\n\n  <section class=\"visualization\" aria-label=\"Query optimization flow diagram\">\n    <div class=\"flow\" aria-hidden=\"true\">\n\n      <!-- Query Input Block -->\n      <div class=\"query-input\" id=\"queryInput\">\n        <div class=\"stage-shine\"></div>\n        <span>SELECT</span>\n        query text\n      </div>\n\n      <!-- Parsing Stage -->\n      <div class=\"parse-stage\" id=\"parseStage\">\n        <div class=\"stage-shine\"></div>\n        <span>Parsing</span>\n        &amp; Syntax Check\n      </div>\n\n      <!-- Optimization Stage -->\n      <div class=\"opt-stage pulse-glow float\" id=\"optimizeStage\" tabindex=\"0\" aria-describedby=\"optStageDesc\">\n        <div class=\"stage-shine\"></div>\n        <span>Query</span>\n        <br />\n        <strong>Optimization</strong>\n        <br />\n        <small id=\"optStageDesc\" style=\"font-weight:400; font-size:80%; color:#7ea3dfff;letter-spacing:0.02em;\">\n          Analyze & improve plan\n        </small>\n      </div>\n\n      <!-- Plan Generation Stage -->\n      <div class=\"plan-stage\" id=\"planStage\">\n        <div class=\"stage-shine\"></div>\n        <span>Plan</span>\n        <br />\n        Generation\n      </div>\n\n      <!-- Execution Stage -->\n      <div class=\"exec-stage\" id=\"execStage\">\n        <div class=\"stage-shine\"></div>\n        <span>Execution</span>\n        <br />\n        Result Returned\n      </div>\n\n      <!-- Arrows connecting boxes -->\n      <svg width=\"800\" height=\"540\" style=\"top: 30px; left: 50px;\" >\n        <!-- Query Input → Parsing -->\n        <line class=\"arrow-line\" x1=\"180\" y1=\"80\" x2=\"180\" y2=\"185\" stroke-dasharray=\"10 10\" />\n        <polygon class=\"arrow-head\" points=\"176,185 184,185 180,195\" />\n\n        <!-- Parsing → Optimization -->\n        <line class=\"arrow-line\" x1=\"240\" y1=\"240\" x2=\"380\" y2=\"240\" stroke-dasharray=\"12 10\" />\n        <polygon class=\"arrow-head\" points=\"380,236 390,240 380,244\" />\n\n        <!-- Optimization → Plan -->\n        <line class=\"arrow-line\" x1=\"560\" y1=\"240\" x2=\"700\" y2=\"240\" stroke-dasharray=\"12 10\" />\n        <polygon class=\"arrow-head\" points=\"700,236 710,240 700,244\" />\n\n        <!-- Plan → Execution -->\n        <line class=\"arrow-line\" x1=\"620\" y1=\"290\" x2=\"450\" y2=\"460\" stroke-dasharray=\"10 10\" />\n        <polygon class=\"arrow-head\" points=\"455,460 446,468 455,471\" />\n\n        <!-- Optimization → Execution (Direct Improvement) -->\n        <line class=\"arrow-line\" x1=\"470\" y1=\"240\" x2=\"470\" y2=\"430\" stroke-dasharray=\"6 8\" stroke-opacity=\"0.55\" />\n        <polygon class=\"arrow-head\" points=\"466,430 474,430 470,440\" fill=\"#7db3ff80\" />\n      </svg>\n    </div>\n\n    <div class=\"controls\" aria-label=\"Control buttons for query optimization visualization\">\n      <button id=\"btnOptimize\" data-tooltip=\"Emphasize Optimization Stage\">Highlight Optimize</button>\n      <button id=\"btnReset\" data-tooltip=\"Reset Visualization\">Reset</button>\n    </div>\n  </section>\n</main>\n\n<footer>\n  &copy; 2024 • Conceptual Visualization by ChatGPT &nbsp;&bull;&nbsp; Query Optimization Flow\n</footer>\n\n<script>\n  (() => {\n    const btnOptimize = document.getElementById('btnOptimize');\n    const btnReset = document.getElementById('btnReset');\n    const optimizeStage = document.getElementById('optimizeStage');\n\n    btnOptimize.addEventListener('click', () => {\n      // Toggle strong highlight animation to emphasize optimization stage\n      if (optimizeStage.classList.contains('highlighted')) {\n        optimizeStage.classList.remove('highlighted');\n        optimizeStage.style.filter = '';\n        optimizeStage.style.transition = 'filter 1.5s ease';\n      } else {\n        optimizeStage.classList.add('highlighted');\n        optimizeStage.style.filter = 'drop-shadow(0 0 20px #2878ffcc) brightness(1.3)';\n        optimizeStage.style.transition = 'filter 1.5s ease';\n      }\n    });\n\n    btnReset.addEventListener('click', () => {\n      optimizeStage.classList.remove('highlighted');\n      optimizeStage.style.filter = '';\n      optimizeStage.style.transition = 'filter 1.5s ease';\n    });\n\n    // Accessibility: Allow keyboard focus for optimization box, gently bounce on focus\n    optimizeStage.addEventListener('focus', () => {\n      optimizeStage.style.animationPlayState = 'paused';\n      optimizeStage.style.filter = 'drop-shadow(0 0 30px #75aaffcc) brightness(1.3)';\n    });\n    optimizeStage.addEventListener('blur', () => {\n      optimizeStage.style.animationPlayState = '';\n      optimizeStage.style.filter = '';\n    });\n  })();\n</script>\n</body>\n</html>"
