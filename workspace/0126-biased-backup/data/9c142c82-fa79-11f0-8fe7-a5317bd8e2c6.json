  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Interpolation Search — Interactive Demo</title>\n  <style>\n    /* Minimal styling only for layout and readability, no colors or fancy visuals. */\n    body { font-family: Arial, sans-serif; margin: 12px; color: black; background: white; }\n    .controls { display: block; margin-bottom: 10px; }\n    .group { margin: 6px 0; padding: 6px 0; }\n    label { margin-right: 6px; }\n    input[type=\"range\"] { vertical-align: middle; }\n    .array { white-space: nowrap; margin: 8px 0; overflow-x: auto; padding: 6px 0; border-top: 1px solid #000; border-bottom: 1px solid #000; }\n    .cell { display: inline-block; padding: 4px 8px; margin: 0 2px; border: 1px solid #000; cursor: pointer; user-select: none; }\n    .marker { font-size: 10px; display: inline-block; width: 1px; text-align: center; margin-top: 2px; }\n    .info { margin-top: 8px; }\n    textarea { width: 100%; height: 60px; }\n    pre { white-space: pre-wrap; font-family: monospace; margin: 6px 0; }\n    button { margin-right: 4px; }\n    select, input[type=\"number\"], input[type=\"text\"] { width: auto; }\n    .stats { margin-top: 8px; font-size: 14px; }\n    .small { font-size: 12px; }\n    .hidden { display: none; }\n  </style>\n</head>\n<body>\n  <h2>Interpolation Search — Interactive Demo</h2>\n\n  <div class=\"controls\">\n\n    <div class=\"group\">\n      <strong>Array Generation</strong><br>\n      Size: <input id=\"sizeRange\" type=\"range\" min=\"2\" max=\"200\" value=\"20\"> <input id=\"sizeNumber\" type=\"number\" min=\"2\" max=\"200\" value=\"20\" style=\"width:60px;\">\n      Min: <input id=\"minVal\" type=\"number\" value=\"0\" style=\"width:80px;\"> Max: <input id=\"maxVal\" type=\"number\" value=\"100\" style=\"width:80px;\">\n      Decimals?: <input id=\"decimals\" type=\"number\" min=\"0\" max=\"6\" value=\"0\" style=\"width:40px;\">\n      Duplicates?: <input id=\"allowDup\" type=\"checkbox\" checked>\n      Distribution:\n      <select id=\"distribution\">\n        <option value=\"uniform\">Uniform</option>\n        <option value=\"linear\">Linear (increasing)</option>\n        <option value=\"clustered\">Clustered</option>\n        <option value=\"random\">Random (unsorted)</option>\n        <option value=\"custom\">Custom (use textarea)</option>\n      </select>\n      <button id=\"generateBtn\">Generate</button>\n      Sort?: <input id=\"sortChk\" type=\"checkbox\" checked>\n    </div>\n\n    <div id=\"customArea\" class=\"group hidden\">\n      <label>Custom array (comma separated):</label><br>\n      <textarea id=\"customArray\"></textarea>\n    </div>\n\n    <div class=\"group\">\n      <strong>Target</strong><br>\n      Target value: <input id=\"targetInput\" type=\"text\" style=\"width:120px;\">\n      Pick index: <input id=\"pickIndex\" type=\"range\" min=\"0\" max=\"19\" value=\"0\"><span id=\"pickIndexLabel\">0</span>\n      <button id=\"pickPresent\">Random Present</button>\n      <button id=\"pickAbsent\">Random Absent</button>\n      <button id=\"clearTarget\">Clear</button>\n      (Click an array element to set it as target)\n    </div>\n\n    <div class=\"group\">\n      <strong>Algorithm / Variant</strong><br>\n      Variant:\n      <select id=\"variant\">\n        <option value=\"interpolation\">Interpolation (standard)</option>\n        <option value=\"clipped\">Interpolation (clipped to bounds)</option>\n        <option value=\"fallback\">Interpolation (fallback to binary when estimate out of range)</option>\n        <option value=\"binary\">Binary Search (for comparison)</option>\n        <option value=\"linear\">Linear Search (for comparison)</option>\n      </select>\n      Rounding:\n      <select id=\"rounding\">\n        <option value=\"floor\">floor</option>\n        <option value=\"round\">round</option>\n        <option value=\"ceil\">ceil</option>\n      </select>\n      <button id=\"runAllBtn\">Run to Completion</button>\n      <button id=\"stepBtn\">Step</button>\n      <button id=\"backBtn\">Back</button>\n      <button id=\"playBtn\">Play</button>\n      <button id=\"pauseBtn\" disabled>Pause</button>\n      <button id=\"resetBtn\">Reset</button>\n      Speed (ms): <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\">\n      <span id=\"speedLabel\">400</span>\n    </div>\n\n    <div class=\"group\">\n      <strong>Display Options</strong><br>\n      Show calculations: <input id=\"showCalc\" type=\"checkbox\" checked>\n      Show history log: <input id=\"showHistory\" type=\"checkbox\" checked>\n      Show indices: <input id=\"showIndices\" type=\"checkbox\" checked>\n    </div>\n\n    <div class=\"group\">\n      <strong>Batch Trials</strong><br>\n      Trials: <input id=\"trialsInput\" type=\"number\" min=\"1\" max=\"10000\" value=\"100\" style=\"width:80px;\">\n      <button id=\"runTrialsBtn\">Run Trials</button>\n      Variant for trials: <select id=\"trialVariant\">\n        <option value=\"interpolation\">Interpolation</option>\n        <option value=\"clipped\">Clipped</option>\n        <option value=\"fallback\">Fallback</option>\n        <option value=\"binary\">Binary</option>\n      </select>\n    </div>\n\n  </div>\n\n  <div class=\"array\" id=\"arrayContainer\" title=\"Click a cell to set the target.\"></div>\n\n  <div class=\"info\">\n    <div class=\"small\">Markers: [L]=low [H]=high [M]=mid [T]=target selection</div>\n    <div id=\"stepInfo\" class=\"small\"></div>\n    <div class=\"stats\" id=\"stats\">\n      Comparisons: 0 | Probes: 0 | Steps: 0 | Found: N/A\n    </div>\n  </div>\n\n  <div class=\"group\">\n    <strong>Log / History</strong>\n    <pre id=\"log\" style=\"height:200px; overflow:auto;\"></pre>\n  </div>\n\n  <script>\n    // Minimal, plain JS implementation with many interactive controls.\n    (function(){\n      // Elements\n      const sizeRange = document.getElementById('sizeRange');\n      const sizeNumber = document.getElementById('sizeNumber');\n      const minVal = document.getElementById('minVal');\n      const maxVal = document.getElementById('maxVal');\n      const decimals = document.getElementById('decimals');\n      const allowDup = document.getElementById('allowDup');\n      const distribution = document.getElementById('distribution');\n      const generateBtn = document.getElementById('generateBtn');\n      const sortChk = document.getElementById('sortChk');\n      const customArea = document.getElementById('customArea');\n      const customArray = document.getElementById('customArray');\n\n      const arrayContainer = document.getElementById('arrayContainer');\n\n      const targetInput = document.getElementById('targetInput');\n      const pickIndex = document.getElementById('pickIndex');\n      const pickIndexLabel = document.getElementById('pickIndexLabel');\n      const pickPresent = document.getElementById('pickPresent');\n      const pickAbsent = document.getElementById('pickAbsent');\n      const clearTarget = document.getElementById('clearTarget');\n\n      const variant = document.getElementById('variant');\n      const rounding = document.getElementById('rounding');\n      const runAllBtn = document.getElementById('runAllBtn');\n      const stepBtn = document.getElementById('stepBtn');\n      const backBtn = document.getElementById('backBtn');\n      const playBtn = document.getElementById('playBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const speed = document.getElementById('speed');\n      const speedLabel = document.getElementById('speedLabel');\n\n      const showCalc = document.getElementById('showCalc');\n      const showHistory = document.getElementById('showHistory');\n      const showIndices = document.getElementById('showIndices');\n\n      const log = document.getElementById('log');\n      const stepInfo = document.getElementById('stepInfo');\n      const stats = document.getElementById('stats');\n\n      const trialsInput = document.getElementById('trialsInput');\n      const runTrialsBtn = document.getElementById('runTrialsBtn');\n      const trialVariant = document.getElementById('trialVariant');\n\n      // State\n      let arr = [];\n      let n = 0;\n      let target = null;\n      let history = []; // sequence of states\n      let historyIndex = -1; // current displayed state index in history\n      let running = false;\n      let playerTimer = null;\n      let comparisons = 0;\n      let probes = 0;\n      let steps = 0;\n\n      // Utility\n      function clamp(v,a,b){ return Math.max(a, Math.min(b, v)); }\n      function parseNumber(s){ if (s === '' || s === null || s === undefined) return NaN; return Number(s); }\n\n      // Sync size slider and number\n      sizeRange.addEventListener('input', ()=>{ sizeNumber.value = sizeRange.value; pickIndex.max = Number(sizeRange.value)-1; pickIndex.value = 0; pickIndexLabel.textContent = '0'; });\n      sizeNumber.addEventListener('change', ()=>{ let v = Number(sizeNumber.value); if (v < 2) v = 2; if (v > 200) v = 200; sizeNumber.value = v; sizeRange.value = v; pickIndex.max = v-1; });\n\n      speed.addEventListener('input', ()=>{ speedLabel.textContent = speed.value; });\n\n      distribution.addEventListener('change', ()=>{\n        customArea.classList.toggle('hidden', distribution.value !== 'custom');\n      });\n\n      // Generate array\n      function generateArray(){\n        const size = Number(sizeRange.value);\n        const min = Number(minVal.value);\n        const max = Number(maxVal.value);\n        const dec = Math.max(0, Math.min(6, Number(decimals.value) || 0));\n        const allowDuplicates = allowDup.checked;\n        const dist = distribution.value;\n        let a = [];\n\n        function rnd(minv, maxv){\n          const scale = Math.pow(10, dec);\n          return Math.round((Math.random()*(maxv-minv)+minv)*scale)/scale;\n        }\n\n        if (dist === 'custom'){\n          // parse custom array\n          const txt = customArray.value.trim();\n          if (txt === ''){\n            alert('Custom array is empty.');\n            return;\n          }\n          const parts = txt.split(',').map(s=>s.trim()).filter(s=>s.length>0).map(s=>Number(s));\n          if (parts.some(v=>isNaN(v))){\n            alert('Custom array contains non-numeric entries.');\n            return;\n          }\n          a = parts.slice();\n        } else if (dist === 'uniform'){\n          // uniform random across range\n          while (a.length < size){\n            a.push(rnd(min, max));\n          }\n        } else if (dist === 'linear'){\n          // steadily increasing values across range\n          for (let i=0;i<size;i++){\n            const t = i/(size-1);\n            a.push(Math.round((min + t*(max-min)) * Math.pow(10,dec))/Math.pow(10,dec));\n          }\n        } else if (dist === 'clustered'){\n          // cluster around several centers\n          const centers = Math.max(2, Math.floor(size/5));\n          const cpos = [];\n          for (let i=0;i<centers;i++) cpos.push(min + (i/(centers-1))*(max-min));\n          for (let i=0;i<size;i++){\n            const c = cpos[Math.floor(Math.random()*centers)];\n            const spread = (max-min)/Math.max(100, centers)*Math.random()*5;\n            a.push(Math.round((c + (Math.random()-0.5)*spread) * Math.pow(10,dec))/Math.pow(10,dec));\n          }\n        } else if (dist === 'random'){\n          while (a.length < size){\n            a.push(rnd(min, max));\n          }\n        }\n\n        // If duplicates are not allowed, slightly nudge duplicates\n        if (!allowDuplicates){\n          const seen = new Set();\n          for (let i=0;i<a.length;i++){\n            let v = a[i];\n            while (seen.has(v.toString())){\n              // nudge slightly\n              const perturb = (Math.random()*2-1) * (Math.max(1, Math.abs(a[i])||1)/1000);\n              v = Math.round((v + perturb)*Math.pow(10,dec))/Math.pow(10,dec);\n            }\n            seen.add(v.toString());\n            a[i] = v;\n          }\n        }\n\n        if (sortChk.checked && dist !== 'random' && dist !== 'custom'){\n          a.sort((x,y)=>x-y);\n        } else if (sortChk.checked && dist === 'random'){\n          a.sort((x,y)=>x-y);\n        } else if (sortChk.checked && dist === 'custom'){\n          a.sort((x,y)=>x-y);\n        }\n\n        arr = a.slice();\n        n = arr.length;\n        pickIndex.max = Math.max(0, n-1);\n        if (Number(pickIndex.value) > n-1) pickIndex.value = 0;\n        renderArray();\n        resetSearchState();\n      }\n\n      generateBtn.addEventListener('click', generateArray);\n\n      // Render array\n      function renderArray(){\n        arrayContainer.innerHTML = '';\n        for (let i=0;i<arr.length;i++){\n          const span = document.createElement('span');\n          span.className = 'cell';\n          span.dataset.index = i;\n          let text = arr[i];\n          if (showIndices.checked){\n            text = i + ': ' + text;\n          }\n          span.textContent = text;\n          span.addEventListener('click', ()=>{\n            target = arr[i];\n            targetInput.value = String(target);\n            logMessage('Target set to value at index '+i+': '+target);\n            // When clicking array, start a fresh run state\n            resetSearchState();\n            renderArray();\n            highlightCurrent();\n          });\n          arrayContainer.appendChild(span);\n        }\n        highlightCurrent();\n      }\n\n      // Highlight markers by updating rendered DOM text with markers appended (minimal styling)\n      function highlightCurrent(){\n        const children = arrayContainer.children;\n        if (!children) return;\n        for (let i=0;i<children.length;i++){\n          const el = children[i];\n          const idx = Number(el.dataset.index);\n          // Remove existing marker suffixes if any:\n          let base = String(arr[idx]);\n          if (showIndices.checked) base = idx + ': ' + arr[idx];\n          let suffix = '';\n          if (historyIndex >= 0 && history[historyIndex]){\n            const st = history[historyIndex];\n            if (st.low === idx) suffix += ' [L]';\n            if (st.high === idx) suffix += ' [H]';\n            if (st.mid === idx) suffix += ' [M]';\n            if (target !== null && !isNaN(target)){\n              // target match\n              if (Number(arr[idx]) === Number(target)) suffix += ' [T]';\n            }\n          } else {\n            // show only target marker if set\n            if (target !== null && !isNaN(target) && Number(arr[idx]) === Number(target)) suffix += ' [T]';\n          }\n          el.textContent = (showIndices.checked ? (idx + ': ' + arr[idx]) : arr[idx]) + suffix;\n        }\n      }\n\n      // Search state generator (lazy)\n      function createSearchIterator(settings){\n        // settings includes variant and rounding\n        const s = {\n          arr: arr,\n          n: arr.length,\n          target: target,\n          variant: settings.variant,\n          rounding: settings.rounding,\n        };\n\n        let low = 0, high = s.n - 1;\n        let finished = false;\n        let stepCount = 0;\n\n        function computeMid(){\n          // For binary search fallback, mid = floor((low+high)/2)\n          if (s.variant === 'binary'){\n            return Math.floor((low+high)/2);\n          }\n          if (s.variant === 'linear'){\n            // linear probing: just walk from low to high (mid increments)\n            return low; // special handling below\n          }\n          // Interpolation calculation\n          const loVal = s.arr[low];\n          const hiVal = s.arr[high];\n          let mid;\n          if (hiVal === loVal){\n            mid = low; // cannot interpolate; degenerate\n          } else {\n            const ratio = (Number(s.target) - Number(loVal)) / (Number(hiVal) - Number(loVal));\n            const estimate = low + (high - low) * ratio;\n            if (s.rounding === 'floor') mid = Math.floor(estimate);\n            else if (s.rounding === 'ceil') mid = Math.ceil(estimate);\n            else mid = Math.round(estimate);\n          }\n          return mid;\n        }\n\n        // We'll produce states as objects to be pushed into history.\n        return {\n          next: function(){\n            if (finished) return { done: true };\n            if (low > high){\n              // not found\n              finished = true;\n              stepCount++;\n              return { done: false, value: { type: 'end', result: 'notfound', low, high, mid: null, step: stepCount } };\n            }\n            // For linear variant do sequential probing\n            if (s.variant === 'linear'){\n              const mid = low;\n              const val = s.arr[mid];\n              stepCount++;\n              if (Number(val) === Number(s.target)){\n                finished = true;\n                return { done:false, value: { type:'compare', low, high, mid, val, cmp:0, result:'found', step: stepCount } };\n              } else {\n                low++;\n                if (low > high){\n                  finished = true;\n                  return { done:false, value: { type:'compare', low: low-1, high, mid, val, cmp:1, result:'notfound', step: stepCount } };\n                } else {\n                  return { done:false, value: { type:'compare', low, high, mid, val, cmp:1, result:'continue', step: stepCount } };\n                }\n              }\n            }\n\n            let mid = computeMid();\n\n            // If mid is NaN (e.g., target is NaN), finish\n            if (isNaN(mid) || mid === null || mid === undefined){\n              finished = true;\n              stepCount++;\n              return { done:false, value: { type:'error', message:'Invalid mid (NaN). Check inputs.', low, high, mid, step: stepCount } };\n            }\n\n            // If variant fallback and mid out of bounds, use binary mid\n            if (s.variant === 'fallback'){\n              if (mid < low || mid > high){\n                mid = Math.floor((low+high)/2);\n              }\n            }\n\n            // For clipped variant, clamp mid\n            if (s.variant === 'clipped'){\n              mid = clamp(mid, low, high);\n            }\n\n            // Ensure integer index within [low,high]\n            mid = Math.max(low, Math.min(high, Math.floor(mid)));\n\n            const val = s.arr[mid];\n            stepCount++;\n            if (Number(val) === Number(s.target)){\n              finished = true;\n              return { done:false, value: { type:'compare', low, high, mid, val, cmp:0, result:'found', step: stepCount } };\n            } else if (Number(val) < Number(s.target)){\n              const prevLow = low;\n              low = mid + 1;\n              return { done:false, value: { type:'compare', low: prevLow, high, mid, val, cmp:1, result:'left', step: stepCount } };\n            } else {\n              const prevHigh = high;\n              high = mid - 1;\n              return { done:false, value: { type:'compare', low, high: prevHigh, mid, val, cmp:-1, result:'right', step: stepCount } };\n            }\n          }\n        };\n      }\n\n      // State push and step control\n      function resetSearchState(){\n        history = [];\n        historyIndex = -1;\n        comparisons = 0; probes = 0; steps = 0;\n        running = false;\n        if (playerTimer) { clearInterval(playerTimer); playerTimer = null; }\n        pauseBtn.disabled = true;\n        playBtn.disabled = false;\n        log.textContent = '';\n        stepInfo.textContent = 'Ready. Target: ' + ( (target === null || target === '') ? 'N/A' : target );\n        stats.textContent = 'Comparisons: 0 | Probes: 0 | Steps: 0 | Found: N/A';\n        renderArray();\n      }\n\n      function logMessage(msg){\n        const ts = new Date().toLocaleTimeString();\n        log.textContent = ts + ' - ' + msg + '\\n' + log.textContent;\n      }\n\n      // Prepare iterator\n      let iterator = null;\n      function prepIterator(){\n        if (!arr || arr.length === 0){\n          alert('Array is empty. Generate first.');\n          return false;\n        }\n        if (target === null || target === '' || isNaN(Number(target))){\n          alert('Please set a numeric target.');\n          return false;\n        }\n        iterator = createSearchIterator({ variant: variant.value, rounding: rounding.value });\n        // reset history so new run begins from empty history\n        history = [];\n        historyIndex = -1;\n        comparisons = 0; probes = 0; steps = 0;\n        logMessage('Search prepared using variant: ' + variant.value + ', rounding: ' + rounding.value);\n        return true;\n      }\n\n      // Apply one step from iterator and push to history\n      function stepForward(){\n        if (!iterator){\n          if (!prepIterator()) return;\n        }\n        const res = iterator.next();\n        if (res.done){\n          // nothing\n          return;\n        }\n        const state = res.value;\n        // Record comparison/probe\n        if (state.type === 'compare') comparisons++;\n        probes++; steps++;\n        history.push(state);\n        historyIndex = history.length - 1;\n        renderHistoryState(state);\n        if (state.result === 'found' || state.result === 'notfound' || state.type === 'end' || state.type === 'error'){\n          // finished\n          if (state.result === 'found'){\n            logMessage('Found target at index ' + state.mid + ' after ' + steps + ' steps.');\n          } else if (state.type === 'end' || state.result === 'notfound'){\n            logMessage('Target not found after ' + steps + ' steps.');\n          } else if (state.type === 'error'){\n            logMessage('Error: ' + state.message);\n          }\n          // Stop automatic play if running\n          if (playerTimer){\n            clearInterval(playerTimer);\n            playerTimer = null;\n            running = false;\n            pauseBtn.disabled = true;\n            playBtn.disabled = false;\n          }\n        }\n      }\n\n      function renderHistoryState(state){\n        // Update markers and info\n        if (state.type === 'compare'){\n          stepInfo.textContent = 'Step: ' + state.step + ' | low=' + state.low + ' high=' + state.high + ' mid=' + state.mid + ' value=' + state.val + ' target=' + target + (showCalc.checked ? (' | cmp=' + state.cmp) : '');\n          stats.textContent = 'Comparisons: ' + comparisons + ' | Probes: ' + probes + ' | Steps: ' + steps + ' | Found: ' + (state.result === 'found' ? 'YES @'+state.mid : (state.result === 'notfound' ? 'NO' : 'SEARCHING'));\n        } else if (state.type === 'end' || state.type === 'error'){\n          stepInfo.textContent = state.type.toUpperCase() + ': ' + (state.message || state.result);\n          stats.textContent = 'Comparisons: ' + comparisons + ' | Probes: ' + probes + ' | Steps: ' + steps + ' | Found: ' + ((state.result==='notfound')?'NO':'N/A');\n        }\n        highlightCurrent();\n        if (showHistory.checked){\n          // Append readable line\n          if (state.type === 'compare'){\n            const line = 'Step ' + state.step + ': probe mid=' + state.mid + ' val=' + state.val + ' (low=' + state.low + ', high=' + state.high + ') -> ' + state.result;\n            logMessage(line);\n          } else if (state.type === 'end'){\n            logMessage('Search finished: ' + state.result);\n          } else if (state.type === 'error'){\n            logMessage('Error: ' + state.message);\n          }\n        }\n      }\n\n      function stepBackward(){\n        if (historyIndex <= -1) return;\n        historyIndex--;\n        if (historyIndex < 0){\n          // back to initial state\n          historyIndex = -1;\n          // Recompute simple stats\n          comparisons = 0; probes = 0; steps = 0;\n          for (let i=0;i<history.length;i++){\n            if (i <= historyIndex) {\n              if (history[i].type === 'compare') comparisons++;\n              probes++;\n              steps++;\n            }\n          }\n          stepInfo.textContent = 'Stepped back. Ready.';\n          stats.textContent = 'Comparisons: ' + comparisons + ' | Probes: ' + probes + ' | Steps: ' + steps + ' | Found: N/A';\n          highlightCurrent();\n          return;\n        }\n        // Recompute counts up to historyIndex\n        comparisons = 0; probes = 0; steps = 0;\n        for (let i=0;i<=historyIndex;i++){\n          const st = history[i];\n          if (st.type === 'compare') comparisons++;\n          probes++;\n          steps++;\n        }\n        const st = history[historyIndex];\n        renderHistoryState(st);\n      }\n\n      // Buttons\n      stepBtn.addEventListener('click', ()=>{ stepForward(); });\n      backBtn.addEventListener('click', ()=>{ stepBackward(); });\n\n      runAllBtn.addEventListener('click', ()=>{\n        if (!iterator){\n          if (!prepIterator()) return;\n        }\n        // run until finish\n        let safety = 1000000;\n        while (true){\n          const prevLen = history.length;\n          stepForward();\n          if (history.length === prevLen) break;\n          const st = history[history.length-1];\n          if (st.result === 'found' || st.result === 'notfound' || st.type === 'end' || st.type === 'error') break;\n          if (--safety <= 0) break;\n        }\n      });\n\n      playBtn.addEventListener('click', ()=>{\n        if (!iterator){\n          if (!prepIterator()) return;\n        }\n        if (playerTimer) return;\n        running = true;\n        playBtn.disabled = true;\n        pauseBtn.disabled = false;\n        const interval = Number(speed.value);\n        playerTimer = setInterval(()=>{\n          if (!iterator) { clearInterval(playerTimer); playerTimer = null; running=false; playBtn.disabled=false; pauseBtn.disabled=true; return; }\n          const prevLen = history.length;\n          stepForward();\n          if (history.length === prevLen){\n            clearInterval(playerTimer);\n            playerTimer = null;\n            running = false;\n            playBtn.disabled = false;\n            pauseBtn.disabled = true;\n          } else {\n            const last = history[history.length-1];\n            if (last.result === 'found' || last.result === 'notfound' || last.type === 'end' || last.type === 'error'){\n              clearInterval(playerTimer);\n              playerTimer = null;\n              running = false;\n              playBtn.disabled = false;\n              pauseBtn.disabled = true;\n            }\n          }\n        }, interval);\n      });\n\n      pauseBtn.addEventListener('click', ()=>{\n        if (playerTimer){\n          clearInterval(playerTimer);\n          playerTimer = null;\n          running = false;\n          pauseBtn.disabled = true;\n          playBtn.disabled = false;\n          logMessage('Playback paused.');\n        }\n      });\n\n      resetBtn.addEventListener('click', ()=>{\n        iterator = null;\n        resetSearchState();\n        logMessage('Search reset.');\n      });\n\n      // Target controls\n      pickIndex.addEventListener('input', ()=>{ pickIndexLabel.textContent = pickIndex.value; });\n      pickPresent.addEventListener('click', ()=>{\n        if (!arr || arr.length===0){ alert('Generate array first'); return; }\n        const idx = Math.floor(Math.random()*arr.length);\n        target = arr[idx];\n        targetInput.value = String(target);\n        resetSearchState();\n        renderArray();\n        logMessage('Random present target selected: index ' + idx + ' value ' + target);\n      });\n\n      pickAbsent.addEventListener('click', ()=>{\n        if (!arr || arr.length===0){ alert('Generate array first'); return; }\n        // pick a value outside the current set: either below min or above max or between absent\n        let val = null;\n        const minA = Math.min(...arr);\n        const maxA = Math.max(...arr);\n        if (Math.random() < 0.5){\n          val = minA - (Math.random()*5 + 1);\n        } else {\n          val = maxA + (Math.random()*5 + 1);\n        }\n        const dec = Number(decimals.value) || 0;\n        val = Math.round(val*Math.pow(10,dec))/Math.pow(10,dec);\n        target = val;\n        targetInput.value = String(target);\n        resetSearchState();\n        renderArray();\n        logMessage('Random absent target selected: ' + target);\n      });\n\n      clearTarget.addEventListener('click', ()=>{\n        target = null;\n        targetInput.value = '';\n        resetSearchState();\n        renderArray();\n      });\n\n      targetInput.addEventListener('change', ()=>{\n        const v = parseNumber(targetInput.value);\n        if (isNaN(v)){\n          alert('Target must be numeric');\n          return;\n        }\n        target = v;\n        resetSearchState();\n        renderArray();\n      });\n\n      // When user moves pickIndex slider to choose by index without clicking\n      pickIndex.addEventListener('change', ()=>{\n        const idx = Number(pickIndex.value);\n        if (!arr || idx < 0 || idx >= arr.length) return;\n        target = arr[idx];\n        targetInput.value = String(target);\n        resetSearchState();\n        renderArray();\n      });\n\n      // Batch trials\n      runTrialsBtn.addEventListener('click', ()=>{\n        const trials = Math.max(1, Math.min(100000, Number(trialsInput.value) || 1));\n        if (!arr || arr.length === 0){ alert('Generate an array first'); return; }\n        // Run trials across randomly selected targets and record steps/comparisons\n        const variantForTrials = trialVariant.value;\n        let totProbes = 0, totCmp = 0, foundCount = 0;\n        let maxSteps = 0;\n        // We'll run trials by choosing target present or absent randomly\n        const sampleTargets = [];\n        for (let t=0;t<trials;t++){\n          // pick present half the time\n          if (Math.random() < 0.5){\n            sampleTargets.push({ val: arr[Math.floor(Math.random()*arr.length)], present: true });\n          } else {\n            // pick an absent number near range\n            const minA = Math.min(...arr);\n            const maxA = Math.max(...arr);\n            const v = (Math.random()<0.5) ? (minA - (Math.random()*10+1)) : (maxA + (Math.random()*10+1));\n            sampleTargets.push({ val: v, present: false });\n          }\n        }\n        // Run sequentially\n        for (let i=0;i<sampleTargets.length;i++){\n          const t = sampleTargets[i];\n          const iter = createSearchIterator({ variant: variantForTrials, rounding: rounding.value });\n          // Override target in iterator closure by temporarily setting global target for createSearchIterator?\n          // Actually createSearchIterator reads target from outer; to pass, hack: set tempTarget variable\n          // For simplicity, call a local implementation of search that counts steps based on the same logic.\n          // Implement quick local trial run:\n          const local = (() => {\n            const sarr = arr;\n            let low = 0, high = sarr.length - 1;\n            let probesLocal = 0, cmpLocal = 0, stepLocal = 0, found = false;\n            const variantLocal = variantForTrials;\n            const round = rounding.value;\n            while (low <= high){\n              stepLocal++;\n              let mid;\n              if (variantLocal === 'linear'){\n                mid = low;\n              } else if (variantLocal === 'binary'){\n                mid = Math.floor((low+high)/2);\n              } else {\n                const loVal = sarr[low], hiVal = sarr[high];\n                if (hiVal === loVal){\n                  mid = low;\n                } else {\n                  const ratio = (Number(t.val) - 