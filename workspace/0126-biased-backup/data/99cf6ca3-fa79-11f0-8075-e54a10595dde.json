    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Sliding Window Maximum</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        input, button {\n            margin: 5px;\n        }\n        #output {\n            margin-top: 20px;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Sliding Window Maximum Demonstration</h1>\n\n<label for=\"arrayInput\">Enter numbers (comma-separated):</label><br>\n<input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 1,3,-1,-3,5,3,6,7\"/><br>\n\n<label for=\"windowSize\">Select window size:</label><br>\n<input type=\"number\" id=\"windowSize\" min=\"1\" value=\"3\"/><br>\n\n<button id=\"calculateButton\">Calculate Maximums</button>\n<button id=\"resetButton\">Reset</button>\n\n<h2>Output:</h2>\n<div id=\"output\"></div>\n\n<script>\n    document.getElementById('calculateButton').onclick = function() {\n        const input = document.getElementById('arrayInput').value;\n        const k = parseInt(document.getElementById('windowSize').value);\n        const outputDiv = document.getElementById('output');\n\n        if (!input || isNaN(k) || k <= 0) {\n            outputDiv.innerText = 'Please enter valid input and window size.';\n            return;\n        }\n\n        const nums = input.split(',').map(Number);\n        const result = slidingWindowMax(nums, k);\n        outputDiv.innerText = 'Maximums in each sliding window: ' + result.join(', ');\n    };\n\n    document.getElementById('resetButton').onclick = function() {\n        document.getElementById('arrayInput').value = '';\n        document.getElementById('windowSize').value = 3;\n        document.getElementById('output').innerText = '';\n    };\n\n    function slidingWindowMax(nums, k) {\n        const result = [];\n        const deque = [];\n        for (let i = 0; i < nums.length; i++) {\n            // Remove indices that are out of bound\n            if (deque.length && deque[0] < i - k + 1) {\n                deque.shift();\n            }\n            // Remove elements that are less than the current element\n            while (deque.length && nums[deque[deque.length - 1]] < nums[i]) {\n                deque.pop();\n            }\n            deque.push(i);\n            // The first window is ready\n            if (i >= k - 1) {\n                result.push(nums[deque[0]]);\n            }\n        }\n        return result;\n    }\n</script>\n\n</body>\n</html>"
