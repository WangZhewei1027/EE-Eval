    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>DNS - Domain Name System</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&family=Roboto+Mono&display=swap');\n\n  /* Root and Reset */\n  * {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e6f1;\n    overflow-x: hidden;\n    overscroll-behavior: none;\n  }\n\n  /* Container */\n  .container {\n    max-width: 900px;\n    margin: 4rem auto 6rem;\n    padding: 0 2rem;\n    text-align: center;\n  }\n\n  /* Heading */\n  h1 {\n    font-weight: 600;\n    font-size: 3.5rem;\n    letter-spacing: 0.06em;\n    color: #f0f5f9;\n    text-shadow: 0 0 12px rgba(255, 255, 255, 0.3);\n    margin-bottom: 0.2em;\n    user-select: none;\n  }\n  h2 {\n    font-weight: 300;\n    font-size: 1.25rem;\n    color: #a8b9cc;\n    letter-spacing: 0.12em;\n    margin-bottom: 3rem;\n    user-select: none;\n  }\n\n  /* Description Paragraph */\n  p.desc {\n    max-width: 600px;\n    margin: 0 auto 5rem;\n    font-weight: 300;\n    font-size: 1.15rem;\n    line-height: 1.6;\n    color: #cbd4e7;\n    user-select: none;\n  }\n\n  /* DNS Visualization Container */\n  .dns-visual {\n    position: relative;\n    width: 100%;\n    height: 520px;\n    margin: 0 auto 6rem;\n    perspective: 1300px;\n  }\n\n  /* Glossy Card Style */\n  .card {\n    background: linear-gradient(135deg, #194b78 0%, #1767a6 75%, #1a65bf 100%);\n    border-radius: 1.5rem;\n    box-shadow:\n      0 20px 40px rgba(2,42,73,0.55),\n      inset 0 2px 15px rgba(255, 255, 255, 0.12);\n    color: #d9e6fb;\n    font-weight: 600;\n    font-size: 1.15rem;\n    font-family: 'Roboto Mono', monospace;\n    padding: 1.8rem 2.5rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    transition: box-shadow 0.4s ease, transform 0.5s ease;\n    user-select: none;\n  }\n\n  .card:hover {\n    transform: translateY(-12px);\n    box-shadow:\n      0 30px 50px rgba(2,42,73,0.75),\n      inset 0 4px 25px rgba(255, 255, 255, 0.18);\n    cursor: default;\n  }\n\n  .card .title {\n    font-size: 1.35rem;\n    font-weight: 700;\n    margin-bottom: 0.5em;\n    color: #d0e9ff;\n    text-shadow: 0 0 8px #a9d1ffaa;\n  }\n\n  .card .ip {\n    font-size: 1.1rem;\n    color: #aadbff;\n    margin-bottom: 0.25em;\n    text-shadow: 0 0 4px #59a9ffaa;\n  }\n\n  /* Positions for cards in DNS chain */\n  /* We'll use absolute positioned cards layered on top inside .dns-visual for effect */\n\n  .card.root {\n    position: absolute;\n    top: 12%;\n    left: 50%;\n    width: 210px;\n    transform: translateX(-50%);\n    z-index: 5;\n  }\n\n  .card.tld {\n    position: absolute;\n    top: 40%;\n    left: 28%;\n    width: 180px;\n    transform: translate(-50%, -50%);\n    z-index: 4;\n  }\n\n  .card.authoritative {\n    position: absolute;\n    top: 40%;\n    right: 28%;\n    width: 180px;\n    transform: translate(50%, -50%);\n    z-index: 4;\n  }\n\n  .card.local {\n    position: absolute;\n    bottom: 12%;\n    left: 50%;\n    width: 210px;\n    transform: translateX(-50%);\n    z-index: 5;\n  }\n\n  /* Lines connecting cards */\n\n  svg.connection-lines {\n    position: absolute;\n    top: 0; left: 0; width: 100%; height: 100%;\n    pointer-events: none;\n    z-index: 2;\n  }\n\n  /* Animations for line drawing */\n  .line-path {\n    stroke: #4d8ee7cc;\n    stroke-width: 3;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    stroke-dasharray: 500;\n    stroke-dashoffset: 500;\n    animation: lineDraw 1.4s ease forwards;\n  }\n  .line-path.delay1 {\n    animation-delay: 0.2s;\n  }\n  .line-path.delay2 {\n    animation-delay: 0.65s;\n  }\n  .line-path.delay3 {\n    animation-delay: 1.1s;\n  }\n\n  @keyframes lineDraw {\n    to {\n      stroke-dashoffset: 0;\n    }\n  }\n\n  /* Example tooltip styling */\n\n  .tooltip {\n    position: absolute;\n    background: rgba(27, 48, 78, 0.9);\n    color: #c2d6ff;\n    padding: 0.45rem 0.75rem;\n    border-radius: 0.6rem;\n    font-size: 0.88rem;\n    pointer-events: none;\n    user-select: none;\n    box-shadow: 0 0 10px #80b2ff7d;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    white-space: nowrap;\n  }\n  \n  /* Button styles */\n  .btn-group {\n    display: inline-flex;\n    gap: 1rem;\n    margin-bottom: 1rem;\n  }\n  button {\n    background: #1f65bf;\n    border: 2px solid #4f8cec;\n    border-radius: 0.7rem;\n    padding: 0.5rem 1.5rem;\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    font-size: 1rem;\n    color: #c9ddff;\n    box-shadow: 0 4px 15px #1c5ac2b8;\n    cursor: pointer;\n    transition:\n      background-color 0.3s ease,\n      border-color 0.3s ease,\n      color 0.3s ease,\n      box-shadow 0.4s ease;\n    user-select: none;\n  }\n  button:hover, button:focus {\n    background-color: #3a82f0;\n    border-color: #acd4ff;\n    color: white;\n    box-shadow: 0 8px 25px #4f8ceccc;\n    outline: none;\n  }\n\n  /* Typing style for domain display */\n  .domain-display {\n    font-family: 'Roboto Mono', monospace;\n    font-weight: 600;\n    color: #aadbff;\n    font-size: 1.4rem;\n    letter-spacing: 0.12em;\n    margin-bottom: 0;\n    user-select: none;\n    text-shadow: 0 0 12px #2d88ffa8;\n  }\n\n  /* Fade text info on button press */\n  .info-text {\n    font-weight: 300;\n    font-size: 1rem;\n    max-width: 720px;\n    margin: 1rem auto 6rem;\n    color: #a9bde6cc;\n    line-height: 1.42;\n    user-select: none;\n    min-height: 3.5em;\n    transition: opacity 0.6s ease;\n  }\n  .hidden {\n    opacity: 0;\n    pointer-events: none;\n  }\n\n  /* Footer */\n  footer {\n    color: #6389bc88;\n    text-align: center;\n    font-weight: 300;\n    letter-spacing: 0.12em;\n    font-size: 0.9rem;\n    margin-bottom: 3rem;\n    user-select: none;\n  }\n\n  /* Custom subtle animated background circles behind cards */\n  .glow-circle {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(40px);\n    opacity: 0.2;\n    animation: pulseGlow 6s ease-in-out infinite;\n    pointer-events: none;\n    z-index: 1;\n  }\n  .glow-root {\n    width: 260px;\n    height: 260px;\n    background: #3a75d8;\n    top: 7%;\n    left: 50%;\n    transform: translateX(-50%);\n    animation-delay: 0s;\n  }\n  .glow-tld {\n    width: 180px;\n    height: 180px;\n    background: #2f9bee;\n    top: 39%;\n    left: 28%;\n    animation-delay: 2s;\n  }\n  .glow-authoritative {\n    width: 180px;\n    height: 180px;\n    background: #63b2ff;\n    top: 39%;\n    right: 28%;\n    animation-delay: 4s;\n  }\n  .glow-local {\n    width: 260px;\n    height: 260px;\n    background: #1b48aa;\n    bottom: 10%;\n    left: 50%;\n    transform: translateX(-50%);\n    animation-delay: 1s;\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {\n      opacity: 0.2;\n      transform: scale(1) translateX(0);\n    }\n    50% {\n      opacity: 0.35;\n      transform: scale(1.15) translateX(5px);\n    }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"container\" aria-label=\"DNS Visualization\">\n    <h1>DOMAIN NAME SYSTEM</h1>\n    <h2>Decoding the Internet’s Address Book</h2>\n    <p class=\"desc\">The Domain Name System (DNS) is a hierarchical and decentralized naming system for computers, services, or other resources connected to the internet or a private network. It translates human-friendly domain names like <code>example.com</code> into the numerical IP addresses needed for locating and identifying computer services and devices.</p>\n    \n    <div class=\"dns-visual\" aria-hidden=\"true\">\n      <!-- Glowing background circles -->\n      <div class=\"glow-circle glow-root\" aria-hidden=\"true\"></div>\n      <div class=\"glow-circle glow-tld\" aria-hidden=\"true\"></div>\n      <div class=\"glow-circle glow-authoritative\" aria-hidden=\"true\"></div>\n      <div class=\"glow-circle glow-local\" aria-hidden=\"true\"></div>\n\n      <!-- Cards representing DNS servers -->\n      <article class=\"card root\" tabindex=\"0\" aria-label=\"Root DNS Server\">\n        <div class=\"title\">Root Server</div>\n        <div class=\"ip\">a.root-servers.net</div>\n        <div class=\"ip\">198.41.0.4</div>\n      </article>\n      <article class=\"card tld\" tabindex=\"0\" aria-label=\"Top-Level Domain DNS Server\">\n        <div class=\"title\">TLD Server <span style=\"font-weight:400;color:#9fcfff;\">(.COM)</span></div>\n        <div class=\"ip\">com.gtld-servers.net</div>\n        <div class=\"ip\">192.26.92.30</div>\n      </article>\n      <article class=\"card authoritative\" tabindex=\"0\" aria-label=\"Authoritative DNS Server\">\n        <div class=\"title\">Authoritative Server</div>\n        <div class=\"ip\">ns1.example.com</div>\n        <div class=\"ip\">93.184.216.34</div>\n      </article>\n      <article class=\"card local\" tabindex=\"0\" aria-label=\"Local Recursive Resolver\">\n        <div class=\"title\">Local Resolver</div>\n        <div class=\"ip\">192.168.1.1</div>\n        <div style=\"font-size:1rem; color:#a0c8ff88; margin-top:4px; font-weight:400;\">Your ISP DNS</div>\n      </article>\n\n      <!-- SVG lines showing the DNS query path -->\n      <svg class=\"connection-lines\" role=\"presentation\" aria-hidden=\"true\" viewBox=\"0 0 900 520\" xmlns=\"http://www.w3.org/2000/svg\" >\n        <!-- From Local Resolver to Root Server -->\n        <path class=\"line-path delay1\" d=\"M450 460 L450 120\" />\n        <!-- From Root Server to TLD Server -->\n        <path class=\"line-path delay2\" d=\"M450 120 C370 120, 310 220, 280 210\" />\n        <!-- From Root Server to Authoritative Server -->\n        <path class=\"line-path delay3\" d=\"M450 120 C530 120, 590 220, 620 210\" />\n      </svg>\n    </div>\n\n    <div class=\"btn-group\" role=\"group\" aria-label=\"DNS information controls\">\n      <button type=\"button\" id=\"btnExplain\" aria-pressed=\"false\" aria-label=\"Toggle explanation text\">Show Explanation</button>\n    </div>\n\n    <div class=\"info-text hidden\" id=\"infoText\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n      <!-- Will be populated dynamically -->\n    </div>\n\n  </div>\n\n<footer>\n  &copy; 2024 — Crafted with care to illuminate DNS\n</footer>\n\n<script>\n  // Explanation text for the toggle button\n  const explanation = `\n    <strong>How DNS Works:</strong><br>\n    1. Your device asks a <em>Local Resolver</em> to find a domain’s IP.<br>\n    2. If unresolved, the resolver queries a <em>Root DNS Server</em>, which points to the appropriate <em>Top-Level Domain (TLD) Server</em>.<br>\n    3. The TLD Server then directs the query to the <em>Authoritative DNS Server</em> responsible for the specific domain.<br>\n    4. Finally, the Authoritative Server returns the IP address, enabling your browser to connect to the destination website.<br>\n    <br>\n    This process happens seamlessly within milliseconds, powering the internet's navigation experience.\n  `;\n\n  const btnExplain = document.getElementById('btnExplain');\n  const infoText = document.getElementById('infoText');\n\n  btnExplain.addEventListener('click', () => {\n    const expanded = btnExplain.getAttribute('aria-pressed') === 'true';\n    if (expanded) {\n      btnExplain.setAttribute('aria-pressed', 'false');\n      btnExplain.textContent = 'Show Explanation';\n      infoText.classList.add('hidden');\n      infoText.innerHTML = '';\n    } else {\n      btnExplain.setAttribute('aria-pressed', 'true');\n      btnExplain.textContent = 'Hide Explanation';\n      infoText.innerHTML = explanation;\n      infoText.classList.remove('hidden');\n      infoText.scrollIntoView({behavior: 'smooth', block: 'nearest'});\n    }\n  });\n</script>\n\n</body>\n</html>"
