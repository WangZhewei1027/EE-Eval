    "content": "<html>\n<head>\n    <title>Interactive Indexing Explorer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n        }\n        .control-group {\n            margin-bottom: 15px;\n        }\n        button, select, input {\n            margin-right: 10px;\n            margin-bottom: 10px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n        .hidden {\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Indexing Explorer</h1>\n        \n        <div class=\"panel\">\n            <h2>Index Creation</h2>\n            <div class=\"control-group\">\n                <label>Data Structure:</label>\n                <select id=\"dataStructure\">\n                    <option value=\"array\">Array</option>\n                    <option value=\"linkedlist\">Linked List</option>\n                    <option value=\"bst\">Binary Search Tree</option>\n                    <option value=\"hash\">Hash Table</option>\n                </select>\n                \n                <label>Index Type:</label>\n                <select id=\"indexType\">\n                    <option value=\"primary\">Primary</option>\n                    <option value=\"secondary\">Secondary</option>\n                    <option value=\"composite\">Composite</option>\n                    <option value=\"spatial\">Spatial</option>\n                </select>\n                \n                <button id=\"createIndex\">Create Index</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <label>Data Size:</label>\n                <input type=\"range\" id=\"dataSize\" min=\"5\" max=\"50\" value=\"10\">\n                <span id=\"dataSizeValue\">10</span>\n                \n                <label>Index Density:</label>\n                <input type=\"range\" id=\"indexDensity\" min=\"1\" max=\"10\" value=\"5\">\n                <span id=\"indexDensityValue\">5</span>\n            </div>\n            \n            <div id=\"compositeOptions\" class=\"hidden\">\n                <label>Composite Index Fields:</label>\n                <input type=\"checkbox\" id=\"field1\" checked> <label for=\"field1\">Field 1</label>\n                <input type=\"checkbox\" id=\"field2\"> <label for=\"field2\">Field 2</label>\n                <input type=\"checkbox\" id=\"field3\"> <label for=\"field3\">Field 3</label>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Index Operations</h2>\n            <div class=\"control-group\">\n                <button id=\"insertBtn\">Insert</button>\n                <button id=\"insertValue\" value=\"random\">Random Value</button>\n                <input type=\"number\" id=\"customValue\" placeholder=\"Custom value\">\n                \n                <button id=\"searchBtn\">Search</button>\n                <input type=\"number\" id=\"searchValue\" placeholder=\"Search value\">\n                \n                <button id=\"deleteBtn\">Delete</button>\n                <input type=\"number\" id=\"deleteValue\" placeholder=\"Delete value\">\n            </div>\n            \n            <div class=\"control-group\">\n                <button id=\"rangeQueryBtn\">Range Query</button>\n                <input type=\"number\" id=\"rangeStart\" placeholder=\"Start\">\n                <input type=\"number\" id=\"rangeEnd\" placeholder=\"End\">\n                \n                <button id=\"rebuildIndex\">Rebuild Index</button>\n                <button id=\"dropIndex\">Drop Index</button>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Index Visualization</h2>\n            <div class=\"control-group\">\n                <label>View Mode:</label>\n                <select id=\"viewMode\">\n                    <option value=\"structure\">Structure</option>\n                    <option value=\"performance\">Performance</option>\n                    <option value=\"memory\">Memory Usage</option>\n                </select>\n                \n                <button id=\"stepThrough\">Step Through Operations</button>\n                <button id=\"animate\">Animate</button>\n                <input type=\"range\" id=\"animationSpeed\" min=\"1\" max=\"10\" value=\"5\">\n            </div>\n            \n            <div id=\"visualization\">\n                <pre id=\"indexStructure\">No index created yet</pre>\n                <div id=\"performanceMetrics\" class=\"hidden\">\n                    <p>Performance Metrics:</p>\n                    <p>Search Time: <span id=\"searchTime\">0</span> ms</p>\n                    <p>Insert Time: <span id=\"insertTime\">0</span> ms</p>\n                    <p>Memory Usage: <span id=\"memoryUsage\">0</span> KB</p>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Index Statistics</h2>\n            <table id=\"statsTable\">\n                <thead>\n                    <tr>\n                        <th>Operation</th>\n                        <th>Count</th>\n                        <th>Avg Time</th>\n                        <th>Last Time</th>\n                    </tr>\n                </thead>\n                <tbody>\n                    <tr>\n                        <td>Search</td>\n                        <td id=\"searchCount\">0</td>\n                        <td id=\"avgSearchTime\">0</td>\n                        <td id=\"lastSearchTime\">0</td>\n                    </tr>\n                    <tr>\n                        <td>Insert</td>\n                        <td id=\"insertCount\">0</td>\n                        <td id=\"avgInsertTime\">0</td>\n                        <td id=\"lastInsertTime\">0</td>\n                    </tr>\n                    <tr>\n                        <td>Delete</td>\n                        <td id=\"deleteCount\">0</td>\n                        <td id=\"avgDeleteTime\">0</td>\n                        <td id=\"lastDeleteTime\">0</td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Query Analysis</h2>\n            <div class=\"control-group\">\n                <textarea id=\"queryInput\" rows=\"3\" cols=\"50\" placeholder=\"Enter your query here\"></textarea>\n                <button id=\"analyzeQuery\">Analyze Query</button>\n            </div>\n            <div id=\"queryPlan\" class=\"hidden\">\n                <h3>Query Execution Plan</h3>\n                <pre id=\"executionPlan\">No query analyzed yet</pre>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // State management\n        let index = {\n            type: null,\n            structure: null,\n            data: [],\n            stats: {\n                search: { count: 0, totalTime: 0, lastTime: 0 },\n                insert: { count: 0, totalTime: 0, lastTime: 0 },\n                delete: { count: 0, totalTime: 0, lastTime: 0 }\n            }\n        };\n        \n        // DOM elements\n        const elements = {\n            dataStructure: document.getElementById('dataStructure'),\n            indexType: document.getElementById('indexType'),\n            createIndex: document.getElementById('createIndex'),\n            dataSize: document.getElementById('dataSize'),\n            dataSizeValue: document.getElementById('dataSizeValue'),\n            indexDensity: document.getElementById('indexDensity'),\n            indexDensityValue: document.getElementById('indexDensityValue'),\n            compositeOptions: document.getElementById('compositeOptions'),\n            insertBtn: document.getElementById('insertBtn'),\n            insertValue: document.getElementById('insertValue'),\n            customValue: document.getElementById('customValue'),\n            searchBtn: document.getElementById('searchBtn'),\n            searchValue: document.getElementById('searchValue'),\n            deleteBtn: document.getElementById('deleteBtn'),\n            deleteValue: document.getElementById('deleteValue'),\n            rangeQueryBtn: document.getElementById('rangeQueryBtn'),\n            rangeStart: document.getElementById('rangeStart'),\n            rangeEnd: document.getElementById('rangeEnd'),\n            rebuildIndex: document.getElementById('rebuildIndex'),\n            dropIndex: document.getElementById('dropIndex'),\n            viewMode: document.getElementById('viewMode'),\n            stepThrough: document.getElementById('stepThrough'),\n            animate: document.getElementById('animate'),\n            animationSpeed: document.getElementById('animationSpeed'),\n            indexStructure: document.getElementById('indexStructure'),\n            performanceMetrics: document.getElementById('performanceMetrics'),\n            searchTime: document.getElementById('searchTime'),\n            insertTime: document.getElementById('insertTime'),\n            memoryUsage: document.getElementById('memoryUsage'),\n            searchCount: document.getElementById('searchCount'),\n            avgSearchTime: document.getElementById('avgSearchTime'),\n            lastSearchTime: document.getElementById('lastSearchTime'),\n            insertCount: document.getElementById('insertCount'),\n            avgInsertTime: document.getElementById('avgInsertTime'),\n            lastInsertTime: document.getElementById('lastInsertTime'),\n            deleteCount: document.getElementById('deleteCount'),\n            avgDeleteTime: document.getElementById('avgDeleteTime'),\n            lastDeleteTime: document.getElementById('lastDeleteTime'),\n            queryInput: document.getElementById('queryInput'),\n            analyzeQuery: document.getElementById('analyzeQuery'),\n            queryPlan: document.getElementById('queryPlan'),\n            executionPlan: document.getElementById('executionPlan')\n        };\n        \n        // Event listeners\n        elements.dataSize.addEventListener('input', () => {\n            elements.dataSizeValue.textContent = elements.dataSize.value;\n        });\n        \n        elements.indexDensity.addEventListener('input', () => {\n            elements.indexDensityValue.textContent = elements.indexDensity.value;\n        });\n        \n        elements.indexType.addEventListener('change', () => {\n            if (elements.indexType.value === 'composite') {\n                elements.compositeOptions.classList.remove('hidden');\n            } else {\n                elements.compositeOptions.classList.add('hidden');\n            }\n        });\n        \n        elements.viewMode.addEventListener('change', () => {\n            if (elements.viewMode.value === 'performance') {\n                elements.performanceMetrics.classList.remove('hidden');\n            } else {\n                elements.performanceMetrics.classList.add('hidden');\n            }\n        });\n        \n        elements.createIndex.addEventListener('click', createIndex);\n        elements.insertBtn.addEventListener('click', insertValue);\n        elements.insertValue.addEventListener('click', insertRandomValue);\n        elements.searchBtn.addEventListener('click', searchValue);\n        elements.deleteBtn.addEventListener('click', deleteValue);\n        elements.rangeQueryBtn.addEventListener('click', rangeQuery);\n        elements.rebuildIndex.addEventListener('click', rebuildIndex);\n        elements.dropIndex.addEventListener('click', dropIndex);\n        elements.analyzeQuery.addEventListener('click', analyzeQuery);\n        \n        // Core functions\n        function createIndex() {\n            const dataSize = parseInt(elements.dataSize.value);\n            const density = parseInt(elements.indexDensity.value);\n            \n            index.type = elements.indexType.value;\n            index.structure = elements.dataStructure.value;\n            \n            // Generate initial data\n            index.data = [];\n            for (let i = 0; i < dataSize; i++) {\n                index.data.push(Math.floor(Math.random() * 1000));\n            }\n            \n            // Sort data if needed\n            if (index.structure === 'array' || index.structure === 'bst') {\n                index.data.sort((a, b) => a - b);\n            }\n            \n            updateVisualization();\n            updateStatsDisplay();\n        }\n        \n        function insertValue() {\n            if (!index.structure) {\n                alert('Please create an index first');\n                return;\n            }\n            \n            let value;\n            if (elements.customValue.value) {\n                value = parseInt(elements.customValue.value);\n            } else {\n                value = Math.floor(Math.random() * 1000);\n            }\n            \n            const startTime = performance.now();\n            \n            // Simulate insert operation\n            if (index.structure === 'array') {\n                index.data.push(value);\n                index.data.sort((a, b) => a - b);\n            } else if (index.structure === 'linkedlist') {\n                index.data.push(value);\n            } else if (index.structure === 'bst') {\n                index.data.push(value);\n                index.data.sort((a, b) => a - b);\n            } else if (index.structure === 'hash') {\n                index.data.push(value);\n            }\n            \n            const endTime = performance.now();\n            const timeTaken = endTime - startTime;\n            \n            // Update stats\n            index.stats.insert.count++;\n            index.stats.insert.totalTime += timeTaken;\n            index.stats.insert.lastTime = timeTaken;\n            \n            updateVisualization();\n            updateStatsDisplay();\n        }\n        \n        function insertRandomValue() {\n            elements.customValue.value = '';\n            insertValue();\n        }\n        \n        function searchValue() {\n            if (!index.structure) {\n                alert('Please create an index first');\n                return;\n            }\n            \n            const value = parseInt(elements.searchValue.value);\n            if (isNaN(value)) {\n                alert('Please enter a valid number to search');\n                return;\n            }\n            \n            const startTime = performance.now();\n            let found = false;\n            \n            // Simulate search operation\n            if (index.structure === 'array') {\n                // Binary search for sorted array\n                let left = 0;\n                let right = index.data.length - 1;\n                \n                while (left <= right) {\n                    const mid = Math.floor((left + right) / 2);\n                    if (index.data[mid] === value) {\n                        found = true;\n                        break;\n                    } else if (index.data[mid] < value) {\n                        left = mid + 1;\n                    } else {\n                        right = mid - 1;\n                    }\n                }\n            } else {\n                // Linear search for others\n                found = index.data.includes(value);\n            }\n            \n            const endTime = performance.now();\n            const timeTaken = endTime - startTime;\n            \n            // Update stats\n            index.stats.search.count++;\n            index.stats.search.totalTime += timeTaken;\n            index.stats.search.lastTime = timeTaken;\n            \n            alert(found ? `Value ${value} found!` : `Value ${value} not found!`);\n            updateStatsDisplay();\n        }\n        \n        function deleteValue() {\n            if (!index.structure) {\n                alert('Please create an index first');\n                return;\n            }\n            \n            const value = parseInt(elements.deleteValue.value);\n            if (isNaN(value)) {\n                alert('Please enter a valid number to delete');\n                return;\n            }\n            \n            const startTime = performance.now();\n            const indexPos = index.data.indexOf(value);\n            let deleted = false;\n            \n            if (indexPos !== -1) {\n                index.data.splice(indexPos, 1);\n                deleted = true;\n            }\n            \n            const endTime = performance.now();\n            const timeTaken = endTime - startTime;\n            \n            // Update stats\n            index.stats.delete.count++;\n            index.stats.delete.totalTime += timeTaken;\n            index.stats.delete.lastTime = timeTaken;\n            \n            alert(deleted ? `Value ${value} deleted!` : `Value ${value} not found!`);\n            updateVisualization();\n            updateStatsDisplay();\n        }\n        \n        function rangeQuery() {\n            if (!index.structure) {\n                alert('Please create an index first');\n                return;\n            }\n            \n            const start = parseInt(elements.rangeStart.value);\n            const end = parseInt(elements.rangeEnd.value);\n            \n            if (isNaN(start) || isNaN(end)) {\n                alert('Please enter valid range values');\n                return;\n            }\n            \n            const results = [];\n            for (const value of index.data) {\n                if (value >= start && value <= end) {\n                    results.push(value);\n                }\n            }\n            \n            alert(`Range query results (${start}-${end}): ${results.join(', ') || 'No values found'}`);\n        }\n        \n        function rebuildIndex() {\n            if (!index.structure) {\n                alert('Please create an index first');\n                return;\n            }\n            \n            index.data.sort((a, b) => a - b);\n            updateVisualization();\n            alert('Index rebuilt');\n        }\n        \n        function dropIndex() {\n            index = {\n                type: null,\n                structure: null,\n                data: [],\n                stats: {\n                    search: { count: 0, totalTime: 0, lastTime: 0 },\n                    insert: { count: 0, totalTime: 0, lastTime: 0 },\n                    delete: { count: 0, totalTime: 0, lastTime: 0 }\n                }\n            };\n            \n            elements.indexStructure.textContent = 'No index created yet';\n            updateStatsDisplay();\n            alert('Index dropped');\n        }\n        \n        function analyzeQuery() {\n            const query = elements.queryInput.value.trim();\n            if (!query) {\n                alert('Please enter a query to analyze');\n                return;\n            }\n            \n            // Simple query parsing\n            const lowerQuery = query.toLowerCase();\n            let plan = '';\n            \n            if (lowerQuery.includes('select') && lowerQuery.includes('where')) {\n                plan = `Query Analysis:\n- Type: ${index.type}\n- Structure: ${index.structure}\n- Estimated Cost: ${Math.floor(Math.random() * 100)}\n- Operations:\n  1. Full scan: ${index.structure === 'hash' ? 'No' : 'Possible'}\n  2. Index lookup: ${index.structure === 'hash' ? 'Yes' : 'Conditional'}\n  3. Result projection: Yes`;\n            } else {\n                plan = `Query Analysis:\n- Type: ${index.type}\n- Structure: ${index.structure}\n- Estimated Cost: ${Math.floor(Math.random() * 50)}\n- Operations:\n  1. Full scan: Yes\n  2. Result projection: Yes`;\n            }\n            \n            elements.executionPlan.textContent = plan;\n            elements.queryPlan.classList.remove('hidden');\n        }\n        \n        function updateVisualization() {\n            if (!index.structure) return;\n            \n            let visualization = '';\n            \n            if (index.structure === 'array') {\n                visualization = `Array Index (${index.type}):\n[ ${index.data.join(', ')} ]`;\n            } else if (index.structure === 'linkedlist') {\n                visualization = `Linked List Index (${index.type}):\nHEAD -> ${index.data.join(' -> ')} -> NULL`;\n            } else if (index.structure === 'bst') {\n                visualization = `BST Index (${index.type}):\nIn-order traversal: ${index.data.join(', ')}`;\n            } else if (index.structure === 'hash') {\n                visualization = `Hash Table Index (${index.type}):\nBuckets: ${Math.ceil(index.data.length / 5)}\nValues: ${index.data.join(', ')}`;\n            }\n            \n            elements.indexStructure.textContent = visualization;\n            \n            // Update performance metrics\n            elements.searchTime.textContent = index.stats.search.lastTime.toFixed(2);\n            elements.insertTime.textContent = index.stats.insert.lastTime.toFixed(2);\n            elements.memoryUsage.textContent = (index.data.length * 4).toFixed(2);\n        }\n        \n        function updateStatsDisplay() {\n            elements.searchCount.textContent = index.stats.search.count;\n            elements.avgSearchTime.textContent = index.stats.search.count > 0 \n                ? (index.stats.search.totalTime / index.stats.search.count).toFixed(2) \n                : '0';\n            elements.lastSearchTime.textContent = index.stats.search.lastTime.toFixed(2);\n            \n            elements.insertCount.textContent = index.stats.insert.count;\n            elements.avgInsertTime.textContent = index.stats.insert.count > 0 \n                ? (index.stats.insert.totalTime / index.stats.insert.count).toFixed(2) \n                : '0';\n            elements.lastInsertTime.textContent = index.stats.insert.lastTime.toFixed(2);\n            \n            elements.deleteCount.textContent = index.stats.delete.count;\n            elements.avgDeleteTime.textContent = index.stats.delete.count > 0 \n                ? (index.stats.delete.totalTime / index.stats.delete.count).toFixed(2) \n                : '0';\n            elements.lastDeleteTime.textContent = index.stats.delete.lastTime.toFixed(2);\n        }\n    </script>\n</body>\n</html>"
