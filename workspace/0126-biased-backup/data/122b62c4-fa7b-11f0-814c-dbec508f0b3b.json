    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Selection Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .button-container {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 20px;\n        }\n        .button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Selection Sort</h1>\n        <p>Sort the array in ascending order using Selection Sort.</p>\n        <div class=\"button-container\">\n            <button id=\"start-button\">Start</button>\n            <button id=\"reset-button\">Reset</button>\n            <input id=\"array-size\" type=\"number\" placeholder=\"Array size\">\n            <label for=\"array-size\">Array size:</label>\n            <select id=\"sort-order\" placeholder=\"Sort order (asc/desc)\">\n                <option value=\"asc\">Ascending</option>\n                <option value=\"desc\">Descending</option>\n            </select>\n        </div>\n        <div id=\"output\"></div>\n    </div>\n\n    <script>\n        let arraySize = 10;\n        let array = Array.from({length: arraySize}, (_, i) => i);\n        let sortOrder = 'asc';\n\n        // Function to print the array\n        function printArray() {\n            console.log('Array:', array);\n        }\n\n        // Function to swap two elements\n        function swap(i, j) {\n            let temp = array[i];\n            array[i] = array[j];\n            array[j] = temp;\n        }\n\n        // Selection Sort function\n        function selectionSort(array) {\n            for (let i = 0; i < array.length - 1; i++) {\n                let minIndex = i;\n                for (let j = i + 1; j < array.length; j++) {\n                    if (array[j] < array[minIndex]) {\n                        minIndex = j;\n                    }\n                }\n                if (minIndex !== i) {\n                    swap(i, minIndex);\n                }\n            }\n        }\n\n        // Main function\n        function main() {\n            let startButton = document.getElementById('start-button');\n            let resetButton = document.getElementById('reset-button');\n            let arraySizeInput = document.getElementById('array-size');\n            let sortOrderSelect = document.getElementById('sort-order');\n            let outputDiv = document.getElementById('output');\n\n            startButton.addEventListener('click', () => {\n                arraySize = parseInt(arraySizeInput.value);\n                sortOrder = sortOrderSelect.value;\n                array = Array.from({length: arraySize}, (_, i) => i);\n                printArray();\n                selectionSort(array);\n                printArray();\n                outputDiv.textContent = 'Sorted array in ' + sortOrder + ' order: ';\n            });\n\n            resetButton.addEventListener('click', () => {\n                array = Array.from({length: arraySize}, (_, i) => i);\n                printArray();\n                outputDiv.textContent = 'Sorted array in ' + sortOrder + ' order: ';\n            });\n        }\n\n        main();\n    </script>\n</body>\n</html>"
