    "content": "<html>\n<head>\n    <title>Breadth-First Search (BFS)</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: white;\n        }\n        #graph {\n            border: 1px solid black;\n            padding: 10px;\n            margin: 10px;\n        }\n        input[type=\"number\"] {\n            width: 100px;\n        }\n        input[type=\"range\"] {\n            width: 100px;\n            height: 10px;\n        }\n        input[type=\"text\"] {\n            width: 100px;\n            height: 10px;\n        }\n        input[type=\"submit\"] {\n            width: 100px;\n            height: 10px;\n            background-color: black;\n            color: white;\n            border: none;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n    <h1>Breadth-First Search (BFS)</h1>\n    <p>Enter the number of vertices in the graph:</p>\n    <input type=\"number\" id=\"numVertices\" value=\"10\">\n    <button id=\"startButton\">Start</button>\n    <button id=\"resetButton\">Reset</button>\n    <div id=\"graph\"></div>\n    <script>\n        let numVertices = document.getElementById('numVertices').value;\n        let graph = document.getElementById('graph');\n        let startButton = document.getElementById('startButton');\n        let resetButton = document.getElementById('resetButton');\n\n        function drawGraph() {\n            graph.innerHTML = '';\n            for (let i = 0; i < numVertices; i++) {\n                graph.innerHTML += '<div style=\"width: 50px; height: 50px\"></div>';\n            }\n            let nodes = new Set();\n            let edges = new Set();\n            for (let i = 0; i < numVertices; i++) {\n                for (let j = i + 1; j < numVertices; j++) {\n                    let distance = bfs(i, j);\n                    if (distance !== -1) {\n                        let node = document.createElement('div');\n                        node.style.width = '50px';\n                        node.style.height = '50px';\n                        node.style.background = 'lightgreen';\n                        node.style.position = 'absolute';\n                        node.style.top = `${distance}px`;\n                        node.style.left = `${i * 50}px`;\n                        graph.appendChild(node);\n                        nodes.add(i);\n                        edges.add(`${i},${j}`);\n                    }\n                }\n            }\n        }\n\n        function bfs(source, destination) {\n            let visited = new Set();\n            let queue = [source];\n            visited.add(source);\n            while (queue.length > 0) {\n                let node = queue.shift();\n                for (let neighbor of graph.children[node]) {\n                    if (!visited.has(neighbor)) {\n                        visited.add(neighbor);\n                        queue.push(neighbor);\n                    }\n                }\n            }\n            return visited.has(destination) ? destination : -1;\n        }\n\n        startButton.addEventListener('click', drawGraph);\n        resetButton.addEventListener('click', () => {\n            graph.innerHTML = '';\n            for (let i = 0; i < numVertices; i++) {\n                let node = document.createElement('div');\n                node.style.width = '50px';\n                node.style.height = '50px';\n                node.style.background = 'lightgreen';\n                node.style.position = 'absolute';\n                node.style.top = `${i * 50}px`;\n                node.style.left = `${i * 50}px`;\n                graph.appendChild(node);\n            }\n        });\n    </script>\n</body>\n</html>"
