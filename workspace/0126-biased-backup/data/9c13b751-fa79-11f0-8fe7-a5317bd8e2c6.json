  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Graph (Directed) - Interactive Demo</title>\n  <style>\n    /* Extremely minimal styling - plain black text on white background */\n    html,body { height:100%; margin:0; font-family: sans-serif; color: black; background: white; }\n    #app { display:flex; height:100vh; }\n    #controls { width:360px; padding:8px; box-sizing:border-box; overflow:auto; border-right:1px solid #000; }\n    #canvasWrap { flex:1; display:flex; flex-direction:column; }\n    #toolbar { padding:6px; border-bottom:1px solid #000; }\n    #svgContainer { flex:1; position:relative; }\n    svg { width:100%; height:100%; display:block; background:white; }\n    button,input,select,textarea { margin:4px 0; display:block; width:100%; }\n    label { font-size:12px; margin-top:8px; display:block; }\n    .small { width:auto; display:inline-block; margin-right:6px; }\n    #log { height:140px; overflow:auto; border-top:1px solid #000; padding:6px; font-size:12px; }\n    #algControls { padding:6px; border-top:1px solid #000; }\n    .section { margin-bottom:12px; padding-bottom:6px; border-bottom:1px dashed #000; }\n    pre { white-space:pre-wrap; word-wrap:break-word; margin:4px 0; }\n  </style>\n</head>\n<body>\n  <div id=\"app\">\n    <div id=\"controls\">\n      <h3>Graph (Directed) - Controls</h3>\n\n      <div class=\"section\">\n        <label>Mode</label>\n        <button id=\"mode_add_node\">Add Node (click blank)</button>\n        <button id=\"mode_add_edge\">Add Edge (click source then target)</button>\n        <button id=\"mode_move\">Move Nodes (drag)</button>\n        <button id=\"mode_select\">Select</button>\n        <button id=\"mode_delete\">Delete (click)</button>\n        <div>\n          <label>Default new node label</label>\n          <input id=\"newNodeLabel\" value=\"N\" />\n          <label>Default edge weight</label>\n          <input id=\"newEdgeWeight\" value=\"1\" />\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <label>Edit Selected</label>\n        <div>\n          <label>Selected ID (read-only)</label>\n          <input id=\"selectedId\" readonly />\n          <label>Edit label</label>\n          <input id=\"editLabel\" />\n          <label>Edit weight (for selected edge)</label>\n          <input id=\"editWeight\" />\n          <button id=\"applyEdit\">Apply Edit</button>\n          <button id=\"reverseEdge\">Reverse Edge Direction</button>\n          <button id=\"duplicateNode\">Duplicate Node</button>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <label>Graph Operations</label>\n        <button id=\"clearGraph\">Clear Graph</button>\n        <button id=\"sampleGraph\">Load Sample Graph</button>\n        <label>Random graph</label>\n        <input id=\"rndN\" class=\"small\" type=\"number\" value=\"6\" /> nodes\n        <input id=\"rndP\" class=\"small\" type=\"number\" value=\"30\" /> % edge probability\n        <div>\n          <label><input id=\"rndWeighted\" type=\"checkbox\" /> Weighted edges</label>\n        </div>\n        <button id=\"generateRnd\">Generate Random Graph</button>\n      </div>\n\n      <div class=\"section\">\n        <label>Layout</label>\n        <button id=\"layout_circular\">Circular Layout</button>\n        <button id=\"layout_grid\">Grid Layout</button>\n        <button id=\"layout_random\">Randomize Positions</button>\n        <button id=\"layout_topo\">Layout by Topological Order</button>\n        <button id=\"layout_force\">Run Simple Force Layout</button>\n        <label>Force iterations</label>\n        <input id=\"forceIter\" type=\"number\" value=\"200\" />\n      </div>\n\n      <div class=\"section\">\n        <label>Undo/Redo / Clipboard</label>\n        <button id=\"undoBtn\">Undo</button>\n        <button id=\"redoBtn\">Redo</button>\n        <button id=\"copyBtn\">Copy JSON</button>\n        <button id=\"pasteBtn\">Paste JSON</button>\n        <textarea id=\"clipboard\" placeholder=\"Paste/import JSON here\" rows=\"4\"></textarea>\n        <button id=\"importBtn\">Import Graph JSON</button>\n        <button id=\"exportBtn\">Export Graph JSON</button>\n      </div>\n\n      <div class=\"section\">\n        <label>Adjacency Views</label>\n        <button id=\"showAdjList\">Show Adjacency List</button>\n        <button id=\"showAdjMatrix\">Show Adjacency Matrix</button>\n        <div id=\"adjOutput\" style=\"white-space:pre-wrap; font-size:12px;\"></div>\n      </div>\n\n      <div class=\"section\">\n        <label>Edge Tools</label>\n        <button id=\"flipAll\">Flip All Edges</button>\n        <button id=\"removeSelfLoops\">Remove Self-loops</button>\n        <button id=\"contractEdge\">Contract Selected Edge (merge nodes)</button>\n      </div>\n\n    </div>\n\n    <div id=\"canvasWrap\">\n      <div id=\"toolbar\">\n        <label>Zoom: mouse wheel (Ctrl+wheel for fine)</label>\n        <label>Pan: middle mouse drag or right drag</label>\n        <label>Nodes: click to select, double-click to edit label</label>\n      </div>\n      <div id=\"svgContainer\">\n        <svg id=\"svg\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <marker id=\"arrow\" markerWidth=\"10\" markerHeight=\"7\" refX=\"10\" refY=\"3.5\" orient=\"auto\" markerUnits=\"strokeWidth\">\n              <path d=\"M0,0 L10,3.5 L0,7 L2,3.5 z\" fill=\"black\" />\n            </marker>\n          </defs>\n          <g id=\"viewport\">\n            <rect id=\"bg\" x=\"0\" y=\"0\" width=\"100%\" height=\"100%\" fill=\"white\" />\n            <g id=\"edgesLayer\"></g>\n            <g id=\"nodesLayer\"></g>\n            <g id=\"tempLayer\"></g>\n          </g>\n        </svg>\n      </div>\n\n      <div id=\"algControls\">\n        <div class=\"section\">\n          <label>Algorithms</label>\n          <select id=\"algoSelect\">\n            <option value=\"bfs\">BFS</option>\n            <option value=\"dfs\">DFS</option>\n            <option value=\"dijkstra\">Dijkstra</option>\n            <option value=\"topo\">Topological Sort (Kahn)</option>\n            <option value=\"tarjan\">SCC (Tarjan)</option>\n          </select>\n          <label>Start node (id)</label>\n          <input id=\"algoStart\" />\n          <label>Target node (optional)</label>\n          <input id=\"algoTarget\" />\n          <label>Step speed (ms)</label>\n          <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"500\" />\n          <div>\n            <button id=\"runAlgo\">Run Algorithm</button>\n            <button id=\"stepBack\">Step Back</button>\n            <button id=\"stepNext\">Step Next</button>\n            <button id=\"playPause\">Play</button>\n            <button id=\"stopAlgo\">Stop/Reset</button>\n            <button id=\"highlightPath\">Show Shortest Path (Dijkstra)</button>\n          </div>\n          <div>\n            <label>Auto-play iterations per step (1..10)</label>\n            <input id=\"autoStepCount\" type=\"number\" value=\"1\" min=\"1\" max=\"10\" />\n          </div>\n        </div>\n        <div class=\"section\">\n          <label>Algorithm Log</label>\n          <div id=\"log\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n\n// Minimal, feature-rich directed graph editor and algorithm demonstrator.\n// No external libraries. Visuals intentionally plain (black on white).\n\n// Data structures\nlet graph = { nodes: [], edges: [] };\nlet stateHistory = [], redoHistory = [];\nlet selected = { type: null, id: null }; // type: 'node'|'edge'|null\nlet mode = 'select'; // modes: add_node, add_edge, move, select, delete\nlet nextNodeId = 1;\nlet nextEdgeId = 1;\n\nconst svg = document.getElementById('svg');\nconst viewport = document.getElementById('viewport');\nconst nodesLayer = document.getElementById('nodesLayer');\nconst edgesLayer = document.getElementById('edgesLayer');\nconst tempLayer = document.getElementById('tempLayer');\nconst bg = document.getElementById('bg');\n\nconst newNodeLabelInput = document.getElementById('newNodeLabel');\nconst newEdgeWeightInput = document.getElementById('newEdgeWeight');\n\nconst selectedIdInput = document.getElementById('selectedId');\nconst editLabelInput = document.getElementById('editLabel');\nconst editWeightInput = document.getElementById('editWeight');\n\nconst logEl = document.getElementById('log');\nconst adjOutput = document.getElementById('adjOutput');\n\nconst speedInput = document.getElementById('speed');\nconst algoSelect = document.getElementById('algoSelect');\nconst algoStart = document.getElementById('algoStart');\nconst algoTarget = document.getElementById('algoTarget');\n\nlet tempEdge = null;\nlet edgeCreateFrom = null;\n\n// Transform state (zoom/pan)\nlet transform = { x:0, y:0, k:1 };\nlet dragging = false;\nlet dragNode = null;\nlet dragType = null;\nlet panLast = null;\n\n// Algorithm step playback\nlet algSteps = []; // array of {desc, nodesState, edgesState}\nlet algIndex = -1;\nlet algPlaying = false;\nlet algPlayTimer = null;\n\n// Utility functions\nfunction cloneGraph(g) {\n  return {\n    nodes: g.nodes.map(n => ({...n})),\n    edges: g.edges.map(e => ({...e}))\n  };\n}\nfunction pushHistory() {\n  stateHistory.push(cloneGraph(graph));\n  if (stateHistory.length > 200) stateHistory.shift();\n  redoHistory = [];\n}\nfunction undo() {\n  if (!stateHistory.length) return;\n  redoHistory.push(cloneGraph(graph));\n  graph = stateHistory.pop();\n  refreshNextIds();\n  render();\n  log('Undo');\n}\nfunction redo() {\n  if (!redoHistory.length) return;\n  stateHistory.push(cloneGraph(graph));\n  graph = redoHistory.pop();\n  refreshNextIds();\n  render();\n  log('Redo');\n}\nfunction refreshNextIds(){\n  nextNodeId = graph.nodes.reduce((m,n)=>Math.max(m, n.id),0)+1;\n  nextEdgeId = graph.edges.reduce((m,e)=>Math.max(m, e.id),0)+1;\n}\n\nfunction log(msg) {\n  const p = document.createElement('div');\n  p.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;\n  logEl.appendChild(p);\n  logEl.scrollTop = logEl.scrollHeight;\n}\n\nfunction findNodeAt(pos) {\n  // find node under screen coords pos (clientX/clientY) -> convert to graph coords\n  const pt = screenToGraph(pos.x, pos.y);\n  for (let i = graph.nodes.length-1; i>=0; i--) {\n    const n = graph.nodes[i];\n    const r = n.r || 18;\n    if ((pt.x - n.x)**2 + (pt.y - n.y)**2 <= r*r) return n;\n  }\n  return null;\n}\nfunction findEdgeAt(pos) {\n  // naive: find nearest edge within threshold\n  const pt = screenToGraph(pos.x, pos.y);\n  let best = null;\n  let bestDist = 12;\n  for (const e of graph.edges) {\n    const from = graph.nodes.find(n=>n.id===e.from);\n    const to = graph.nodes.find(n=>n.id===e.to);\n    if (!from || !to) continue;\n    const d = pointToSegmentDistance(pt, from, to);\n    if (d < bestDist) { bestDist = d; best = e; }\n  }\n  return best;\n}\nfunction pointToSegmentDistance(p, a, b) {\n  const vx = b.x - a.x, vy = b.y - a.y;\n  const wx = p.x - a.x, wy = p.y - a.y;\n  const c = (vx*wx + vy*wy) / (vx*vx + vy*vy || 1);\n  const t = Math.max(0, Math.min(1, c));\n  const projx = a.x + vx*t, projy = a.y + vy*t;\n  return Math.hypot(p.x-projx, p.y-projy);\n}\nfunction graphToScreen(x,y) {\n  const bbox = svg.getBoundingClientRect();\n  return { x: (x*transform.k + transform.x) + bbox.left, y: (y*transform.k + transform.y) + bbox.top };\n}\nfunction screenToGraph(sx, sy) {\n  const bbox = svg.getBoundingClientRect();\n  const x = (sx - bbox.left - transform.x) / transform.k;\n  const y = (sy - bbox.top - transform.y) / transform.k;\n  return { x,y };\n}\n\n// Rendering\nfunction clearLayers() {\n  while (nodesLayer.firstChild) nodesLayer.removeChild(nodesLayer.firstChild);\n  while (edgesLayer.firstChild) edgesLayer.removeChild(edgesLayer.firstChild);\n  while (tempLayer.firstChild) tempLayer.removeChild(tempLayer.firstChild);\n}\nfunction render() {\n  clearLayers();\n  // set transform on viewport group (we keep bg unchanged)\n  viewport.setAttribute('transform', `translate(${transform.x},${transform.y}) scale(${transform.k})`);\n  // render edges\n  for (const e of graph.edges) {\n    const from = graph.nodes.find(n=>n.id===e.from);\n    const to = graph.nodes.find(n=>n.id===e.to);\n    if (!from || !to) continue;\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    const id = `edge-${e.id}`;\n    g.setAttribute('data-edge-id', e.id);\n    // compute path (simple straight line with offset to avoid node overlap)\n    const dx = to.x - from.x, dy = to.y - from.y;\n    const dist = Math.hypot(dx,dy) || 1;\n    const ux = dx/dist, uy = dy/dist;\n    const fromR = from.r||18;\n    const toR = to.r||18;\n    let startX = from.x + ux*fromR;\n    let startY = from.y + uy*fromR;\n    let endX = to.x - ux*toR;\n    let endY = to.y - uy*toR;\n    // if self-loop, draw a loop\n    let path;\n    if (from.id === to.id) {\n      const r = from.r||18;\n      path = `M ${from.x} ${from.y - r} C ${from.x + 40} ${from.y - 60} ${from.x + 40} ${from.y + 60} ${from.x} ${from.y + r}`;\n    } else {\n      path = `M ${startX} ${startY} L ${endX} ${endY}`;\n    }\n    const pathEl = document.createElementNS('http://www.w3.org/2000/svg','path');\n    pathEl.setAttribute('d', path);\n    pathEl.setAttribute('fill','none');\n    pathEl.setAttribute('stroke','black');\n    pathEl.setAttribute('stroke-width', e._strokeWidth ? e._strokeWidth : 1);\n    if (e._dash) pathEl.setAttribute('stroke-dasharray', e._dash);\n    pathEl.setAttribute('marker-end','url(#arrow)');\n    g.appendChild(pathEl);\n    // weight label\n    const midX = (startX + endX)/2, midY = (startY + endY)/2;\n    const wt = document.createElementNS('http://www.w3.org/2000/svg','text');\n    wt.setAttribute('x', midX);\n    wt.setAttribute('y', midY - 6);\n    wt.setAttribute('font-size', '12');\n    wt.setAttribute('text-anchor','middle');\n    wt.textContent = e.weight != null ? e.weight : '';\n    g.appendChild(wt);\n    edgesLayer.appendChild(g);\n  }\n\n  // render nodes\n  for (const n of graph.nodes) {\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('transform', `translate(${n.x},${n.y})`);\n    g.setAttribute('data-node-id', n.id);\n    const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    circle.setAttribute('r', n.r || 18);\n    circle.setAttribute('cx', 0);\n    circle.setAttribute('cy', 0);\n    circle.setAttribute('fill','white');\n    circle.setAttribute('stroke','black');\n    circle.setAttribute('stroke-width', n._strokeWidth ? n._strokeWidth : 1);\n    if (n._dash) circle.setAttribute('stroke-dasharray', n._dash);\n    g.appendChild(circle);\n    const txt = document.createElementNS('http://www.w3.org/2000/svg','text');\n    txt.setAttribute('x',0);\n    txt.setAttribute('y',4);\n    txt.setAttribute('text-anchor','middle');\n    txt.setAttribute('font-size','12');\n    txt.textContent = n.label != null ? n.label : n.id;\n    g.appendChild(txt);\n    nodesLayer.appendChild(g);\n  }\n\n  updateSelectedUI();\n}\n\nfunction updateSelectedUI() {\n  if (selected.type === 'node') {\n    selectedIdInput.value = 'node:'+selected.id;\n    const n = graph.nodes.find(x=>x.id===selected.id);\n    editLabelInput.value = n ? n.label : '';\n    editWeightInput.value = '';\n  } else if (selected.type === 'edge') {\n    selectedIdInput.value = 'edge:'+selected.id;\n    const e = graph.edges.find(x=>x.id===selected.id);\n    editLabelInput.value = '';\n    editWeightInput.value = e ? e.weight : '';\n  } else {\n    selectedIdInput.value = '';\n    editLabelInput.value = '';\n    editWeightInput.value = '';\n  }\n}\n\n// Mode controls\ndocument.getElementById('mode_add_node').addEventListener('click', ()=>{ mode='add_node'; log('Mode: Add Node'); });\ndocument.getElementById('mode_add_edge').addEventListener('click', ()=>{ mode='add_edge'; edgeCreateFrom=null; log('Mode: Add Edge'); });\ndocument.getElementById('mode_move').addEventListener('click', ()=>{ mode='move'; log('Mode: Move'); });\ndocument.getElementById('mode_select').addEventListener('click', ()=>{ mode='select'; log('Mode: Select'); });\ndocument.getElementById('mode_delete').addEventListener('click', ()=>{ mode='delete'; log('Mode: Delete'); });\n\n// Canvas interactions\nsvg.addEventListener('mousedown', function(e){\n  if (e.button === 1) { // middle mouse for panning\n    panLast = {x:e.clientX, y:e.clientY};\n    dragType = 'pan';\n    svg.style.cursor = 'move';\n    e.preventDefault();\n    return;\n  }\n  const pos = {x:e.clientX, y:e.clientY};\n  const node = findNodeAt(pos);\n  const edge = findEdgeAt(pos);\n  if (mode === 'add_node') {\n    const gpt = screenToGraph(e.clientX, e.clientY);\n    pushHistory();\n    const label = newNodeLabelInput.value || ('N'+nextNodeId);\n    const nodeObj = { id: nextNodeId++, label: label + (label.match(/\\d+$/)?'':'') , x:gpt.x, y:gpt.y, r:18 };\n    graph.nodes.push(nodeObj);\n    render();\n    log('Added node '+nodeObj.id);\n    return;\n  }\n  if (mode === 'add_edge') {\n    if (node) {\n      if (!edgeCreateFrom) {\n        edgeCreateFrom = node;\n        // temporary marker\n        tempEdge = document.createElementNS('http://www.w3.org/2000/svg','line');\n        tempEdge.setAttribute('x1', node.x);\n        tempEdge.setAttribute('y1', node.y);\n        tempEdge.setAttribute('x2', node.x);\n        tempEdge.setAttribute('y2', node.y);\n        tempEdge.setAttribute('stroke','black');\n        tempEdge.setAttribute('stroke-width','1');\n        tempLayer.appendChild(tempEdge);\n        log('Edge creation: source node '+node.id);\n      } else {\n        // create edge from edgeCreateFrom to node\n        pushHistory();\n        const w = parseFloat(newEdgeWeightInput.value) || 0;\n        const edgeObj = { id: nextEdgeId++, from: edgeCreateFrom.id, to: node.id, weight: w };\n        graph.edges.push(edgeObj);\n        tempLayer.removeChild(tempEdge);\n        tempEdge = null;\n        edgeCreateFrom = null;\n        render();\n        log('Added edge '+edgeObj.id+' '+edgeObj.from+' -> '+edgeObj.to);\n      }\n    } else {\n      // clicked blank: cancel\n      if (tempEdge) { tempLayer.removeChild(tempEdge); tempEdge=null; edgeCreateFrom=null; }\n      log('Edge creation canceled');\n    }\n    return;\n  }\n  if (mode === 'move') {\n    if (node) {\n      dragNode = node;\n      dragType = 'node';\n      dragging = true;\n      svg.style.cursor = 'grabbing';\n      e.preventDefault();\n    } else {\n      // pan via left drag too\n      panLast = {x:e.clientX, y:e.clientY};\n      dragType = 'pan';\n      svg.style.cursor = 'move';\n    }\n    return;\n  }\n  if (mode === 'select') {\n    if (node) {\n      selected = { type: 'node', id: node.id };\n      updateSelectedUI();\n      render();\n      log('Selected node '+node.id);\n    } else if (edge) {\n      selected = { type: 'edge', id: edge.id };\n      updateSelectedUI();\n      render();\n      log('Selected edge '+edge.id);\n    } else {\n      selected = { type:null, id:null };\n      updateSelectedUI();\n      render();\n      log('Cleared selection');\n    }\n    return;\n  }\n  if (mode === 'delete') {\n    if (node) {\n      pushHistory();\n      graph.nodes = graph.nodes.filter(n=>n.id!==node.id);\n      graph.edges = graph.edges.filter(e=>e.from!==node.id && e.to!==node.id);\n      selected = {type:null,id:null};\n      render();\n      log('Deleted node '+node.id);\n    } else if (edge) {\n      pushHistory();\n      graph.edges = graph.edges.filter(e=>e.id!==edge.id);\n      selected = {type:null,id:null};\n      render();\n      log('Deleted edge '+edge.id);\n    } else {\n      log('Delete clicked on blank');\n    }\n    return;\n  }\n});\n\nsvg.addEventListener('mousemove', function(e){\n  if (tempEdge && edgeCreateFrom) {\n    const gpt = screenToGraph(e.clientX, e.clientY);\n    tempEdge.setAttribute('x2', gpt.x);\n    tempEdge.setAttribute('y2', gpt.y);\n  }\n  if (dragType === 'pan' && panLast) {\n    transform.x += e.clientX - panLast.x;\n    transform.y += e.clientY - panLast.y;\n    panLast = {x:e.clientX, y:e.clientY};\n    render();\n  }\n  if (dragType === 'node' && dragNode) {\n    const gpt = screenToGraph(e.clientX, e.clientY);\n    dragNode.x = gpt.x;\n    dragNode.y = gpt.y;\n    render();\n  }\n});\n\nsvg.addEventListener('mouseup', function(e){\n  if (dragType === 'node') {\n    dragNode = null;\n    dragging = false;\n    dragType = null;\n    svg.style.cursor = 'default';\n    pushHistory();\n    log('Node moved and saved');\n  }\n  if (dragType === 'pan') {\n    panLast = null;\n    dragType = null;\n    svg.style.cursor = 'default';\n  }\n});\n\nsvg.addEventListener('dblclick', function(e){\n  // edit label quickly\n  const pos = {x:e.clientX, y:e.clientY};\n  const node = findNodeAt(pos);\n  if (node) {\n    const newLabel = prompt('Edit node label', node.label);\n    if (newLabel !== null) {\n      pushHistory();\n      node.label = newLabel;\n      render();\n      log('Node '+node.id+' label set to '+newLabel);\n    }\n  }\n});\n\n// Wheel zoom\nsvg.addEventListener('wheel', function(e){\n  e.preventDefault();\n  const speed = (e.ctrlKey ? 0.001 : 0.0025);\n  const delta = -e.deltaY * speed;\n  const factor = Math.exp(delta);\n  const pt = screenToGraph(e.clientX, e.clientY);\n  // zoom towards mouse point\n  transform.x = e.clientX - (pt.x * transform.k * factor);\n  transform.y = e.clientY - (pt.y * transform.k * factor);\n  transform.k *= factor;\n  render();\n});\n\n// Selection edits\ndocument.getElementById('applyEdit').addEventListener('click', ()=>{\n  if (!selected.type) return log('Nothing selected');\n  pushHistory();\n  if (selected.type === 'node') {\n    const n = graph.nodes.find(x=>x.id===selected.id);\n    if (n) {\n      n.label = editLabelInput.value;\n      render();\n      log('Node '+n.id+' label updated');\n    }\n  } else if (selected.type === 'edge') {\n    const e = graph.edges.find(x=>x.id===selected.id);\n    if (e) {\n      const w = parseFloat(editWeightInput.value);\n      if (!isNaN(w)) e.weight = w;\n      render();\n      log('Edge '+e.id+' weight updated');\n    }\n  }\n});\n\ndocument.getElementById('reverseEdge').addEventListener('click', ()=>{\n  if (selected.type !== 'edge') return log('Select an edge first');\n  pushHistory();\n  const e = graph.edges.find(x=>x.id===selected.id);\n  if (e) {\n    const t = e.from; e.from = e.to; e.to = t;\n    render();\n    log('Edge '+e.id+' reversed');\n  }\n});\n\ndocument.getElementById('duplicateNode').addEventListener('click', ()=>{\n  if (selected.type !== 'node') return log('Select a node first');\n  const n = graph.nodes.find(x=>x.id===selected.id);\n  if (!n) return;\n  pushHistory();\n  const copy = {...n, id: nextNodeId++, x: n.x+30, y: n.y+20};\n  graph.nodes.push(copy);\n  render();\n  log('Duplicated node '+n.id+' to '+copy.id);\n});\n\n// Graph operations\ndocument.getElementById('clearGraph').addEventListener('click', ()=>{\n  pushHistory();\n  graph = {nodes:[], edges:[]};\n  selected = {type:null,id:null};\n  render();\n  log('Cleared graph');\n});\n\ndocument.getElementById('sampleGraph').addEventListener('click', ()=>{\n  pushHistory();\n  graph = {\n    nodes: [\n      {id:1,label:'A',x:80,y:60,r:18},\n      {id:2,label:'B',x:220,y:40,r:18},\n      {id:3,label:'C',x:220,y:140,r:18},\n      {id:4,label:'D',x:360,y:100,r:18},\n      {id:5,label:'E',x:120,y:200,r:18}\n    ],\n    edges: [\n      {id:1,from:1,to:2,weight:2},\n      {id:2,from:2,to:3,weight:1},\n      {id:3,from:1,to:3,weight:4},\n      {id:4,from:3,to:4,weight:3},\n      {id:5,from:5,to:3,weight:1},\n      {id:6,from:4,to:2,weight:2}\n    ]\n  };\n  refreshNextIds();\n  render();\n  log('Loaded sample graph');\n});\n\ndocument.getElementById('generateRnd').addEventListener('click', ()=>{\n  pushHistory();\n  const n = Math.max(1, parseInt(document.getElementById('rndN').value)||6);\n  const p = Math.max(0, Math.min(100, parseInt(document.getElementById('rndP').value)||30));\n  const weighted = document.getElementById('rndWeighted').checked;\n  const nodes = [];\n  for (let i=0;i<n;i++){\n    nodes.push({id: nextNodeId++, label: 'N'+(i+1), x: 80 + Math.random()*560, y: 60 + Math.random()*360, r:18});\n  }\n  const edges = [];\n  for (let i=0;i<n;i++){\n    for (let j=0;j<n;j++){\n      if (i===j) continue;\n      if (Math.random()*100 < p) edges.push({id: nextEdgeId++, from: nodes[i].id, to: nodes[j].id, weight: weighted? Math.floor(Math.random()*9)+1 : 1});\n    }\n  }\n  graph = { nodes, edges };\n  render();\n  log('Generated random graph: '+n+' nodes, '+edges.length+' edges');\n});\n\n// Layouts\ndocument.getElementById('layout_circular').addEventListener('click', ()=>{\n  pushHistory();\n  const n = graph.nodes.length;\n  const cx = 300, cy = 220, R = Math.max(80, Math.min(200, 60 + n*8));\n  graph.nodes.forEach((node,i)=>{ node.x = cx + R*Math.cos(2*Math.PI*i/n); node.y = cy + R*Math.sin(2*Math.PI*i/n); });\n  render();\n  log('Applied circular layout');\n});\ndocument.getElementById('layout_grid').addEventListener('click', ()=>{\n  pushHistory();\n  const cols = Math.ceil(Math.sqrt(graph.nodes.length));\n  const spacingX = 120, spacingY = 80;\n  graph.nodes.forEach((n,i)=>{ n.x = 80 + (i%cols)*spacingX; n.y = 80 + Math.floor(i/cols)*spacingY; });\n  render();\n  log('Applied grid layout');\n});\ndocument.getElementById('layout_random').addEventListener('click', ()=>{\n  pushHistory();\n  graph.nodes.forEach(n=>{ n.x += (Math.random()-0.5)*160; n.y += (Math.random()-0.5)*120; });\n  render();\n  log('Randomized positions');\n});\ndocument.getElementById('layout_topo').addEventListener('click', ()=>{\n  pushHistory();\n  const order = kahnSort(graph);\n  if (!order) {\n    log('Graph has cycle — cannot topologically sort');\n    return;\n  }\n  for (let i=0;i<order.length;i++){\n    const id = order[i];\n    const n = graph.nodes.find(x=>x.id===id);\n    if (n) { n.x = 80 + i*100; n.y = 120; }\n  }\n  render();\n  log('Laid out nodes by topological order');\n});\ndocument.getElementById('layout_force').addEventListener('click', ()=>{\n  pushHistory();\n  const iter = parseInt(document.getElementById('forceIter').value) || 200;\n  simpleForceLayout(graph, iter, ()=>{}); // synchronous\n  render();\n  log('Ran simple force layout '+iter+' iterations');\n});\n\n// Undo/Redo/Clipboard\ndocument.getElementById('undoBtn').addEventListener('click', undo);\ndocument.getElementById('redoBtn').addEventListener('click', redo);\n\ndocument.getElementById('copyBtn').addEventListener('click', ()=>{\n  const j = JSON.stringify(graph, null, 2);\n  document.getElementById('clipboard').value = j;\n  log('Copied JSON to clipboard textarea');\n});\ndocument.getElementById('pasteBtn').addEventListener('click', ()=>{\n  const t = document.getElementById('clipboard').value;\n  if (!t) { log('Clipboard empty'); return; }\n  try {\n    const parsed = JSON.parse(t);\n    // basic validation\n    if (!parsed.nodes || !parsed.edges) throw new Error('Invalid graph JSON');\n    pushHistory();\n    graph = parsed;\n    refreshNextIds();\n    render();\n    log('Pasted/imported graph from textarea');\n  } catch (err) {\n    log('Import error: '+err.message);\n  }\n});\ndocument.getElementById('importBtn').addEventListener('click', ()=>{\n  const t = document.getElementById('clipboard').value;\n  if (!t) { log('Clipboard empty'); return; }\n  try {\n    const parsed = JSON.parse(t);\n    if (!parsed.nodes || !parsed.edges) throw new Error('Invalid graph JSON');\n    pushHistory();\n    graph = parsed;\n    refreshNextIds();\n    render();\n    log('Imported graph from textarea');\n  } catch (err) {\n    log('Import error: '+err.message);\n  }\n});\ndocument.getElementById('exportBtn').addEventListener('click', ()=>{\n  const j = JSON.stringify(graph, null, 2);\n  document.getElementById('clipboard').value = j;\n  log('Exported graph JSON to textarea');\n});\n\n// Adjacency views\ndocument.getElementById('showAdjList').addEventListener('click', ()=>{\n  const map = {};\n  graph.nodes.forEach(n=>map[n.id]=[]);\n  graph.edges.forEach(e=> (map[e.from]||[]).push({to:e.to, weight:e.weight}));\n  let txt = '';\n  for (const id of Object.keys(map)) {\n    txt += id + ': ' + map[id].map(x=>x.to + (x.weight!=null?('('+x.weight+')'):'')).join(', ') + '\\n';\n  }\n  adjOutput.textContent = txt;\n  log('Displayed adjacency list');\n});\ndocument.getElementById('showAdjMatrix').addEventListener('click', ()=>{\n  const ids = graph.nodes.map(n=>n.id);\n  const idToIdx = {};\n  ids.forEach((id,i)=>idToIdx[id]=i);\n  let mat = Array.from({length:ids.length}, ()=>Array(ids.length).fill(0));\n  graph.edges.forEach(e=>{\n    const i=idToIdx[e.from], j=idToIdx[e.to];\n    if (i!=null && j!=null) mat[i][j] = 1;\n  });\n  let txt = '   ' + ids.join(' ') + '\\n';\n  for (let i=0;i<ids.length;i++){\n    txt += ids[i] + ' ' + mat[i].join(' ') + '\\n';\n  }\n  adjOutput.textContent = txt;\n  log('Displayed adjacency matrix');\n});\n\n// Edge tools\ndocument.getElementById('flipAll').addEventListener('click', ()=>{\n  pushHistory();\n  graph.edges.forEach(e=>{ const t=e.from; e.from=e.to; e.to=t; });\n  render();\n  log('Flipped all edges');\n});\ndocument.getElementById('removeSelfLoops').addEventListener('click', ()=>{\n  pushHistory();\n  graph.edges = graph.edges.filter(e=> e.from!==e.to );\n  render();\n  log('Removed self-loops');\n});\ndocument.getElementById('contractEdge').addEventListener('click', ()=>{\n  if (selected.type !== 'edge') return log('Select an edge to contract');\n  const e = graph.edges.find(x=>x.id===selected.id);\n  if (!e) return;\n  const a = graph.nodes.find(n=>n.id===e.from);\n  const b = graph.nodes.find(n=>n.id===e.to);\n  if (!a||!b) return;\n  pushHistory();\n  // merge b into a: remove b node, update edges\n  graph.nodes = graph.nodes.filter(n=>n.id!==b.id);\n  graph.edges = graph.edges.map(ed=>{\n    let from = ed.from===b.id? a.id : ed.from;\n    let to = ed.to===b.id? a.id : ed.to;\n    return { ...ed, from, to };\n  }).filter((ed,i,self)=> {\n    // remove duplicates and self-loops\n    return !(ed.from===ed.to) && self.findIndex(x=>x.from===ed.from && x.to===ed.to && x.id!==ed.id)===i;\n  });\n  render();\n  log('Contracted edge '+e.id+' merging node '+b.id+' into '+a.id);\n});\n\n// Algorithms: produce steps arrays and step through\nfunction resetAlgState() {\n  algSteps = [];\n  algIndex = -1;\n  algPlaying = false;\n  if (algPlayTimer) { clearInterval(algPlayTimer); algPlayTimer=null; }\n  // clear visual statuses\n  graph.nodes.forEach(n=>{ delete n._strokeWidth; delete n._dash; delete n._meta; });\n  graph.edges.forEach(e=>{ delete e._strokeWidth; delete e._dash; delete e._meta; });\n  render();\n}\ndocument.getElementById('stopAlgo').addEventListener('click', resetAlgState);\n\ndocument.getElementById('runAlgo').addEventListener('click', ()=>{\n  resetAlgState();\n  const algo = algoSelect.value;\n  const startId = algoStart.value ? parseInt(algoStart.value) : null;\n  const targetId = algoTarget.value ? parseInt(algoTarget.value) : null;\n  if (algo === 'bfs') runBFS(startId, targetId);\n  else if (algo === 'dfs') runDFS(startId, targetId);\n  else if (algo === 'dijkstra') runDijkstra(startId, targetId);\n  else if (algo === 'topo') runTopo();\n  else if (algo === 'tarjan') runTarjan();\n  else log('Unknown algorithm');\n});\n\n// Step controls\ndocument.getElementById('stepNext').addEventListener('click', ()=>{ algStep(1); });\ndocument.getElementById('stepBack').addEventListener('click', ()=>{ algStep(-1); });\n\ndocument.getElementById('playPause').addEventListener('click', ()=>{\n  if (algPlaying) {\n    algPlaying = false; clearInterval(algPlayTimer); algPlayTimer=null; document.getElementById('playPause').textContent='Play';\n  } else {\n    if (algIndex >= algSteps.length-1) algIndex = -1;\n    algPlaying = true;\n    document.getElementById('playPause').textContent='Pause';\n    const interval = parseInt(speedInput.value) || 500;\n    algPlayTimer = setInterval(()=>{ algStep(1); if (algIndex>=algSteps.length-1) { clearInterval(algPlayTimer); algPlaying=false; document.getElementById('playPause').textContent='Play'; } }, interval);\n  }\n});\n\nfunction algStep(direction) {\n  if (algSteps.length === 0) { log('No algorithm running'); return; }\n  if (direction > 0) {\n    const count = Math.max(1, parseInt(document.getElementById('autoStepCount').value)||1);\n    for (let i=0;i<count;i++){\n      if (algIndex < algSteps.length-1) algIndex++;\n    }\n  } else {\n    algIndex = Math.max(-1, algIndex-1);\n  }\n  if (algIndex === -1) {\n    // reset visuals\n    graph.nodes.forEach(n=>{ delete n._strokeWidth; delete n._dash; delete n._meta; });\n    graph.edges.forEach(e=>{ delete e._strokeWidth; delete e._dash; delete e._meta; });\n    render();\n    log('Algorithm reset to start');\n    return;\n  }\n  const step = algSteps[algIndex];\n  // apply statuses\n  graph.nodes.forEach(n=>{ delete n._strokeWidth; delete n._dash; delete n._meta; });\n  graph.edges.forEach(e=>{ delete e._strokeWidth; delete e._dash; delete e._meta; });\n  if (step.nodesState) {\n    for (const [id,st] of Object.entries(step.nodesState)) {\n      const n = graph.nodes.find(x=>x.id==id);\n      if (!n) continue;\n      if (st === 'current') n._strokeWidth = 5;\n      else if (st === 'visited') n._strokeWidth = 3;\n      else if (st === 'inqueue') { n._dash = '4 2'; n._strokeWidth = 2; }\n      else if (st.startsWith('comp')) n._strokeWidth = 2;\n      else if (st === 'finished') n._strokeWidth = 2;\n    }\n  }\n  if (step.edgesState) {\n    for (const [id,st] of Object.entries(step.edgesState)) {\n      const e = graph.edges.find(x=>x.id==id);\n      if (!e) continue;\n      if (st === 'traversed') { e._strokeWidth = 3; e._dash='4 2'; }\n      else if (st === 'relaxed') e._strokeWidth = 4;\n    }\n  }\n  render();\n  log('Step '+(algIndex+1)+'/'+algSteps.length+': '+(step.desc||''));\n}\n\n// Algorithm implementations that produce step records\nfunction runBFS(startId, targetId) {\n  if (!startId) return log('Provide start node id for BFS');\n  const nodesMap = new Map(graph.nodes.map(n=>[n.id, n]));\n  if (!nodesMap.has(startId)) return log('Start node not found');\n  const q = [];\n  const visited = new Set();\n  const parent = new Map();\n  q.push(startId);\n  visited.add(startId);\n  algSteps.push({desc:'Enqueue start '+startId, nodesState: {[startId]:'inqueue'} });\n  while (q.length) {\n    const u = q.shift();\n    algSteps.push({desc:'Dequeue '+u, nodesState: {[u]:'current'} , edgesState:{}});\n    if (u === targetId) { algSteps.push({desc:'Found target '+targetId}); break; }\n    for (const e of graph.edges.filter(ed=>ed.from===u)) {\n      const v = e.to;\n      if (!visited.has(v)) {\n        visited.add(v);\n        parent.set(v,u);\n        q.push(v);\n        const nodesState = {}; nodesState[v] = 'inqueue'; nodesState[u] = 'visited';\n        const edgesState = {}; edgesState[e.id] = 'traversed';\n        algSteps.push({desc:'Discover '+v+' via edge '+e.id, nodesState, edgesState});\n      } else {\n        const edgesState={}; edgesState[e.id]='traversed';\n        algSteps.push({desc:'Already visited '+v+' via edge '+e.id, edgesState});\n      }\n    }\n    algSteps.push({desc:'Finished exploring '+u, nodesState: {[u]:'finished'}});\n  }\n  log('BFS produced '+algSteps.length+' steps');\n  algIndex = -1;\n  algStep(1);\n}\n\nfunction runDFS(startId, targetId) {\n  if (!startId) return log('Provide start node id for DFS');\n  const nodesMap = new Map(graph.nodes.map(n=>[n.id, n]));\n  if (!nodesMap.has(startId)) return log('Start node not found');\n  const visited = new Set();\n  const parent = new Map();\n  function dfs(u) {\n    visited.add(u);\n    algSteps.push({desc:'Visit '+u, nodesState: {[u]:'current'}});\n    if (u === targetId) { algSteps.push({desc:'Found target '+u}); return true; }\n    for (const e of graph.edges.filter(ed=>ed.from===u)) {\n      const v = e.to;\n      algSteps.push({desc:'Explore edge '+e.id+' to '+v, edgesState: {[e.id]:'traversed'}});\n      if (!visited.has(v)) {\n        parent.set(v,u);\n        if (dfs(v)) return true;\n      } else {\n        algSteps.push({desc:'Already visited '+v});\n      }\n    }\n    algSteps.push({desc:'Finish '+u, nodesState: {[u]:'finished'}});\n    return false;\n  }\n  dfs(startId);\n  log('DFS produced '+algSteps.length+' steps');\n  algIndex = -1;\n  algStep(1);\n}\n\nfunction runDijkstra(startId, targetId) {\n  if (!startId) return log('Provide start node id for Dijkstra');\n  const nodes = graph.nodes.map(n=>n.id);\n  const dist = {}; const prev = {};\n  nodes.forEach(id=>dist[id]=Infinity); dist[startId]=0;\n  const Q = new Set(nodes);\n  algSteps.push({desc:'Initialize distances', nodesState: Object.fromEntries(nodes.map(id=>[id, 'unvisited']))});\n  while (Q.size) {\n    let u = null; let best = Infinity;\n    for (const id of Q) if (dist[id] < best) { best = dist[id]; u = id; }\n    if (u===null) break;\n    Q.delete(u);\n    algSteps.push({desc:'Extract min '+u+' dist='+dist[u], nodesState: {[u]:'current'}});\n    if (u === targetId) { algSteps.push({desc:'Reached target '+u}); break; }\n    for (const e of graph.edges.filter(ed=>ed.from===u)) {\n      const v = e.to;\n      const w = isFinite(e.weight)?e.weight:1;\n      const alt = dist[u] + w;\n      const edgesState = {}; edgesState[e.id] = 'relaxed';\n      if (alt < dist[v]) {\n        dist[v] = alt; prev[v]=u;\n        algSteps.push({desc:'Relax edge '+e.id+' improve '+v+' to '+alt, nodesState: {[v]:'inqueue'}, edgesState});\n      } else {\n        algSteps.push({desc:'Consider edge '+e.id+' no improvement', edgesState});\n      }\n    }\n    algSteps.push({desc:'Mark finished '+u, nodesState: {[u]:'finished'}});\n  }\n  // Final state: annotate distances\n  const finalNodes = {};\n  for (const id of nodes) finalNodes[id] = (dist[id]===Infinity)?'unreachable':'finished';\n  algSteps.push({desc:'Dijkstra complete. Distances: '+JSON.stringify(dist), nodesState: finalNodes});\n  log('Dijkstra produced '+algSteps.length+' steps');\n  algIndex = -1;\n  algStep(1);\n}\n\nfunction runTopo() {\n  const res = kahnSortWithSteps(graph);\n  if (!res) {\n    algSteps.push({desc:'Graph has cycle; topological order impossible'});\n    log('Topological sort failed due to cycle');\n  } else {\n    for (const s of res.steps) algSteps.push(s);\n    algSteps.push({desc:'Topological order: '+res.order.join(',')});\n    log('Topological sort produced '+algSteps.length+' steps');\n  }\n  algIndex = -1;\n  algStep(1);\n}\n\nfunction runTarjan() {\n  // Tarjan algorithm with steps\n  const index = {}, low = {}, onstack = {};\n  const st = [];\n  let idx = 0;\n  const nodes = graph.nodes.map(n=>n.id);\n  function dfs(v) {\n    index[v]=low[v]=++idx;\n    st.push(v); onstack[v]=true;\n    algSteps.push({desc:'Push '+v+' index='+index[v], nodesState:{[v]:'current'}});\n    for (const e of graph.edges.filter(ed=>ed.from===v)) {\n      const w = e.to;\n      if (!index[w]) {\n        dfs(w);\n        low[v] = Math.min(low[v], low[w]);\n      } else if (onstack[w]) {\n        low[v] = Math.min(low[v], index[w]);\n      }\n    }\n    if (low[v] === index[v]) {\n      const comp = [];\n      let w;\n      do {\n        w = st.pop(); onstack[w]=false; comp.push(w);\n      } while (w !== v);\n      algSteps.push({desc:'Found SCC: '+comp.join(','), nodesState: Object.fromEntries(comp.map(id=>[id, 'comp'+idx]))});\n    }\n  }\n  for (const v of nodes) if (!index[v]) dfs(v);\n  algSteps.push({desc:'Tarjan complete'});\n  log('Tarjan produced '+algSteps.length+' steps');\n  algIndex = -1;\n  algStep(1);\n}\n\n// Helper: Kahn's algorithm producing steps\nfunction kahnSortWithSteps(g) {\n  const indeg = {}; g.nodes.forEach(n=>indeg[n.id]=0);\n  g.edges.forEach(e=> indeg[e.to] = (indeg[e.to]||0) + 1);\n  const S = [];\n  for (const id in indeg) if (indeg[id]===0) S.push(parseInt(id));\n  const order = [];\n  const steps = [];\n  steps.push({desc:'Initial zero indegree nodes: '+S.join(',') , nodesState: Object.fromEntries(Object.keys(indeg).map(id=>[id,'unvisited']))});\n  while (S.length) {\n    const n = S.shift();\n    order.push(n);\n    steps.push({desc:'Remove node '+n, nodesState: {[n]:'current'}});\n    for (const e of g.edges.filter(ed=>ed.from===n)) {\n      indeg[e.to]--;\n      steps.push({desc:'Decrease indegree of '+e.to+' via edge '+e.id, edgesState: {[e.id]:'traversed'}});\n      if (indeg[e.to] === 0) { S.push(e.to); steps.push({desc:'Node '+e.to+' now zero indegree', nodesState: {[e.to]:'inqueue'}}); }\n    }\n    steps.push({desc:'Append '+n+' to order'});\n  }\n  if (order.length !== g.nodes.length) return null;\n  return {order, steps};\n}\n\nfunction kahnSort(g) {\n  const indeg = {}; g.nodes.forEach(n=>indeg[n.id]=0);\n  g.edges.forEach(e=> indeg[e.to] = (indeg[e.to]||0) + 1);\n  const S = [];\n  for (const id in indeg) if (indeg[id]===0) S.push(parseInt(id));\n  const order = [];\n  while (S.length) {\n    const n = S.shift();\n    order.push(n);\n    for (const e of g.edges.filter(ed=>ed.from===n)) {\n      indeg[e.to]--;\n      if (indeg[e.to] === 0) S.push(e.to);\n    }\n  }\n  if (order.length !== g.nodes.length) return null;\n  return order;\n}\n\n// Shortest path highlight\ndocument.getElementById('highlightPath').addEventListener('click', ()=>{\n  const startId = parseInt(algoStart.value);\n  const targetId = parseInt(algoTarget.value);\n  if (!startId || !targetId) return log('Provide start and target IDs');\n  const res = dijkstraPath(graph, startId, targetId);\n  if (!res.found) return log('No path found');\n  // Highlight path edges and nodes\n  graph.nodes.forEach(n=>{ delete n._strokeWidth; delete n._dash; });\n  graph.edges.forEach(e=>{ delete e._strokeWidth; delete e._dash; });\n  for (const id of res.pathNodes) {\n    const n = graph.nodes.find(x=>x.id===id); if (n) n._strokeWidth=3;\n  }\n  for (const id of res.pathEdges) {\n    const e = graph.edges.find(x=>x.id===id); if (e) e._strokeWidth=4;\n  }\n  render();\n  log('Highlighted path: nodes '+res.pathNodes.join('->')+' cost='+res.cost);\n});\n\n// Dijkstra helper for path retrieval\nfunction dijkstraPath(g, startId, targetId) {\n  const nodes = g.nodes.map(n=>n.id);\n  const dist = {}; const prev = {};\n  nodes.forEach(id=>dist[id]=Infinity); dist[startId]=0;\n  const Q = new Set(nodes);\n  while (Q.size) {\n    let u = null; let best = Infinity;\n    for (const id of Q) if (dist[id]<best) { best = dist[id]; u = id; }\n    if (u===null || dist[u]===Infinity) break;\n    Q.delete(u);\n    if (u===targetId) break;\n    for (const e of g.edges.filter(ed=>ed.from===u)) {\n      const v = e.to, w = isFinite(e.weight)?e.weight:1;\n      const alt = dist[u] + w;\n      if (alt < dist[v]) { dist[v] = alt; prev[v]= {node:u, edge:e.id}; }\n    }\n  }\n  if (!prev[targetId] && startId !== targetId) return {found:false};\n  const pathNodes = [];\n  const pathEdges = [];\n  let cur = targetId;\n  while (cur !== undefined) {\n    pathNodes.unshift(cur);\n    const p = prev[cur];\n    if (!p) break;\n    pathEdges.unshift(p.edge);\n    cur = p.node;\n  }\n  return {found:true, pathNodes, pathEdges, cost: dist[targetId]};\n}\n\n// Simple force layout (very basic)\nfunction simpleForceLayout(g, iterations, onTick) {\n  const nodes = g.nodes;\n  const edges = g.edges;\n  const area = 1000;\n  const k = Math.sqrt(area / Math.max(1,nodes.length));\n  for (let it=0; it<iterations; it++){\n    const disp = nodes.map(()=>({x:0,y:0}));\n    // repulsion\n    for (let i=0;i<nodes.length;i++){\n      for (let j=i+1;j<nodes.length;j++){\n        const dx = nodes[j].x - nodes[i].x, dy = nodes[j].y - nodes[i].y;\n        let d = Math.hypot(dx,dy) || 0.01;\n        const force = (k*k)/d;\n        const fx = force * (dx/d), fy = force * (dy/d);\n        disp[i].x -= fx; disp[i].y -= fy;\n        disp[j].x += fx; disp[j].y += fy;\n      }\n    }\n    // attraction (edges)\n    for (const e of edges){\n      const u = nodes.find(n=>n.id===e.from);\n      const v = nodes.find(n=>n.id===e.to);\n      if (!u||!v) continue;\n      const dx = v.x - u.x, dy = v.y - u.y;\n      let d = Math.hypot(dx,dy) || 0.01;\n      const force = (d*d)/k;\n      const fx = (dx/d) * force, fy = (dy/d)*force;\n      const ui = nodes.indexOf(u), vi = nodes.indexOf(v);\n      disp[ui].x += fx; disp[ui].y += fy;\n      disp[vi].x -= fx; disp[vi].y -= fy;\n    }\n    // apply\n    for (let i=0;i<nodes.length;i++){\n      nodes[i].x += Math.max(-5, Math.min(5, disp[i].x));\n      nodes[i].y += Math.max(-5, Math.min(5, disp[i].y));\n    }\n    if (it % 20 === 0) onTick(it);\n  }\n}\n\n// Misc utilities\nfunction point(e){ return {x:e.clientX, y:e.clientY}; }\nfunction round(n){ return Math.round(n*100)/100; }\n\n// Export/Import done earlier\n\n// Delete key handler\ndocument.addEventListener('keydown', function(e){\n  if (e.key === 'Delete') {\n    if (selected.type === 'node') {\n      pushHistory();\n      const id = selected.id;\n      graph.nodes = graph.nodes.filter(n=>n.id!==id);\n      graph.edges = graph.edges.filter(ed=>ed.from!==id && ed.to!==id);\n      selected = {type:null,id:null};\n      render();\n      log('Deleted node '+id+' via Delete key');\n    } else if (selected.type === 'edge') {\n      pushHistory();\n      const id = selected.id;\n      graph.edges = graph.edges.filter(ed=>ed.id!==id);\n      selected = {type:null,id:null};\n      render();\n      log('Deleted edge '+id+' via Delete key');\n    }\n  }\n});\n\n// Initialization\n(function init(){\n  // small default graph\n  graph = { nodes:[], edges:[] };\n  pushHistory();\n  document.getElementById('mode_select').click();\n  render();\n  log('Ready. Use modes to build and explore directed graphs. Many features available.');\n})();\n\n})(); // end IIFE\n</script>\n</body>\n</html>"
