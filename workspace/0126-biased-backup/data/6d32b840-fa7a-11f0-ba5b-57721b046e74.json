    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Linear Regression</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n            margin-bottom: 20px;\n            min-width: 300px;\n        }\n        canvas {\n            border: 1px solid #000;\n            margin-top: 10px;\n        }\n        input, button, select {\n            margin: 5px;\n        }\n        .data-point {\n            cursor: pointer;\n        }\n        table {\n            border-collapse: collapse;\n            margin-top: 10px;\n        }\n        td, th {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        tr:nth-child(even) {\n            background-color: #f2f2f2;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interactive Linear Regression</h1>\n    \n    <div class=\"container\">\n        <div class=\"panel\">\n            <h2>Data Points</h2>\n            <canvas id=\"scatterPlot\" width=\"400\" height=\"400\"></canvas>\n            <div>\n                <button id=\"addRandom\">Add Random Point</button>\n                <button id=\"clearPoints\">Clear All Points</button>\n                <button id=\"addLinePoint\">Add Point on Line</button>\n                <button id=\"addNoisyPoint\">Add Noisy Point</button>\n            </div>\n            <div>\n                <label>Click on canvas to add points</label>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Regression Controls</h2>\n            <div>\n                <button id=\"calculateRegression\">Calculate Regression</button>\n                <button id=\"resetLine\">Reset Line</button>\n            </div>\n            <div>\n                <label>Manual Line Adjustment:</label>\n                <div>\n                    <label>Slope: </label>\n                    <input type=\"range\" id=\"sliderSlope\" min=\"-5\" max=\"5\" step=\"0.1\" value=\"1\">\n                    <span id=\"slopeValue\">1.0</span>\n                </div>\n                <div>\n                    <label>Intercept: </label>\n                    <input type=\"range\" id=\"sliderIntercept\" min=\"-200\" max=\"200\" step=\"1\" value=\"0\">\n                    <span id=\"interceptValue\">0</span>\n                </div>\n            </div>\n            <div>\n                <label>Learning Rate: </label>\n                <input type=\"range\" id=\"learningRate\" min=\"0.0001\" max=\"0.1\" step=\"0.0001\" value=\"0.01\">\n                <span id=\"learningRateValue\">0.01</span>\n            </div>\n            <div>\n                <button id=\"gradientDescent\">Run Gradient Descent</button>\n                <button id=\"stopGradient\">Stop</button>\n                <input type=\"number\" id=\"iterations\" value=\"100\" min=\"1\" max=\"10000\">\n                <label>iterations</label>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Statistics</h2>\n            <div id=\"stats\">\n                <p>Number of points: <span id=\"pointCount\">0</span></p>\n                <p>Current slope: <span id=\"currentSlope\">0</span></p>\n                <p>Current intercept: <span id=\"currentIntercept\">0</span></p>\n                <p>R-squared: <span id=\"rSquared\">0</span></p>\n                <p>Mean Squared Error: <span id=\"mse\">0</span></p>\n            </div>\n            <table id=\"dataTable\">\n                <thead>\n                    <tr>\n                        <th>X</th>\n                        <th>Y</th>\n                        <th>Action</th>\n                    </tr>\n                </thead>\n                <tbody id=\"tableBody\">\n                </tbody>\n            </table>\n        </div>\n    </div>\n\n    <script>\n        // Canvas setup\n        const canvas = document.getElementById('scatterPlot');\n        const ctx = canvas.getContext('2d');\n        const rect = canvas.getBoundingClientRect();\n        \n        // Data storage\n        let points = [];\n        let currentSlope = 1;\n        let currentIntercept = 0;\n        let isDragging = false;\n        let dragIndex = -1;\n        let gradientDescentRunning = false;\n        let animationId = null;\n        \n        // Initialize canvas\n        function initCanvas() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            drawGrid();\n            drawRegressionLine();\n            drawPoints();\n        }\n        \n        // Draw grid\n        function drawGrid() {\n            ctx.strokeStyle = '#ddd';\n            ctx.lineWidth = 1;\n            \n            // Vertical lines\n            for (let x = 0; x <= canvas.width; x += canvas.width / 10) {\n                ctx.beginPath();\n                ctx.moveTo(x, 0);\n                ctx.lineTo(x, canvas.height);\n                ctx.stroke();\n            }\n            \n            // Horizontal lines\n            for (let y = 0; y <= canvas.height; y += canvas.height / 10) {\n                ctx.beginPath();\n                ctx.moveTo(0, y);\n                ctx.lineTo(canvas.width, y);\n                ctx.stroke();\n            }\n            \n            // Axes\n            ctx.strokeStyle = '#000';\n            ctx.lineWidth = 2;\n            ctx.beginPath();\n            ctx.moveTo(0, canvas.height / 2);\n            ctx.lineTo(canvas.width, canvas.height / 2);\n            ctx.stroke();\n            \n            ctx.beginPath();\n            ctx.moveTo(canvas.width / 2, 0);\n            ctx.lineTo(canvas.width / 2, canvas.height);\n            ctx.stroke();\n        }\n        \n        // Draw regression line\n        function drawRegressionLine() {\n            ctx.strokeStyle = '#f00';\n            ctx.lineWidth = 2;\n            \n            const x1 = 0;\n            const y1 = currentIntercept + currentSlope * (-canvas.width / 2);\n            const x2 = canvas.width;\n            const y2 = currentIntercept + currentSlope * (canvas.width / 2);\n            \n            ctx.beginPath();\n            ctx.moveTo(x1, canvas.height / 2 - y1);\n            ctx.lineTo(x2, canvas.height / 2 - y2);\n            ctx.stroke();\n        }\n        \n        // Draw points\n        function drawPoints() {\n            ctx.fillStyle = '#00f';\n            \n            points.forEach((point, index) => {\n                ctx.beginPath();\n                ctx.arc(\n                    canvas.width / 2 + point.x, \n                    canvas.height / 2 - point.y, \n                    5, 0, Math.PI * 2\n                );\n                ctx.fill();\n                \n                // Add index label\n                ctx.fillStyle = '#000';\n                ctx.font = '10px Arial';\n                ctx.fillText(index, canvas.width / 2 + point.x + 8, canvas.height / 2 - point.y + 3);\n                ctx.fillStyle = '#00f';\n            });\n        }\n        \n        // Add point\n        function addPoint(x, y) {\n            // Convert canvas coordinates to data coordinates\n            const dataX = x - canvas.width / 2;\n            const dataY = canvas.height / 2 - y;\n            \n            points.push({ x: dataX, y: dataY });\n            updateTable();\n            updateStats();\n            initCanvas();\n        }\n        \n        // Add random point\n        function addRandomPoint() {\n            const x = (Math.random() - 0.5) * canvas.width - 20;\n            const y = (Math.random() - 0.5) * canvas.height - 20;\n            addPoint(x + canvas.width / 2, canvas.height / 2 - y);\n        }\n        \n        // Add point on current line\n        function addPointOnLine() {\n            if (points.length === 0) return;\n            \n            const x = (Math.random() - 0.5) * canvas.width - 20;\n            const y = currentSlope * x + currentIntercept;\n            addPoint(x + canvas.width / 2, canvas.height / 2 - y);\n        }\n        \n        // Add noisy point near current line\n        function addNoisyPoint() {\n            if (points.length === 0) return;\n            \n            const x = (Math.random() - 0.5) * canvas.width - 20;\n            const y = currentSlope * x + currentIntercept + (Math.random() - 0.5) * 50;\n            addPoint(x + canvas.width / 2, canvas.height / 2 - y);\n        }\n        \n        // Clear all points\n        function clearPoints() {\n            points = [];\n            updateTable();\n            updateStats();\n            initCanvas();\n        }\n        \n        // Calculate linear regression\n        function calculateRegression() {\n            if (points.length < 2) return;\n            \n            let sumX = 0, sumY = 0, sumXY = 0, sumXX = 0;\n            const n = points.length;\n            \n            points.forEach(point => {\n                sumX += point.x;\n                sumY += point.y;\n                sumXY += point.x * point.y;\n                sumXX += point.x * point.x;\n            });\n            \n            const slope = (n * sumXY - sumX * sumY) / (n * sumXX - sumX * sumX);\n            const intercept = (sumY - slope * sumX) / n;\n            \n            currentSlope = slope;\n            currentIntercept = intercept;\n            \n            document.getElementById('sliderSlope').value = slope;\n            document.getElementById('slopeValue').textContent = slope.toFixed(2);\n            document.getElementById('sliderIntercept').value = intercept;\n            document.getElementById('interceptValue').textContent = intercept.toFixed(2);\n            \n            updateStats();\n            initCanvas();\n        }\n        \n        // Update statistics\n        function updateStats() {\n            document.getElementById('pointCount').textContent = points.length;\n            document.getElementById('currentSlope').textContent = currentSlope.toFixed(4);\n            document.getElementById('currentIntercept').textContent = currentIntercept.toFixed(4);\n            \n            if (points.length < 2) {\n                document.getElementById('rSquared').textContent = 'N/A';\n                document.getElementById('mse').textContent = 'N/A';\n                return;\n            }\n            \n            // Calculate R-squared\n            let sumY = 0;\n            points.forEach(point => {\n                sumY += point.y;\n            });\n            const meanY = sumY / points.length;\n            \n            let ssTotal = 0, ssResidual = 0;\n            points.forEach(point => {\n                ssTotal += Math.pow(point.y - meanY, 2);\n                const predictedY = currentSlope * point.x + currentIntercept;\n                ssResidual += Math.pow(point.y - predictedY, 2);\n            });\n            \n            const rSquared = 1 - (ssResidual / ssTotal);\n            document.getElementById('rSquared').textContent = rSquared.toFixed(4);\n            \n            // Calculate MSE\n            const mse = ssResidual / points.length;\n            document.getElementById('mse').textContent = mse.toFixed(4);\n        }\n        \n        // Update data table\n        function updateTable() {\n            const tableBody = document.getElementById('tableBody');\n            tableBody.innerHTML = '';\n            \n            points.forEach((point, index) => {\n                const row = document.createElement('tr');\n                row.className = 'data-point';\n                row.dataset.index = index;\n                \n                const xCell = document.createElement('td');\n                xCell.textContent = point.x.toFixed(2);\n                \n                const yCell = document.createElement('td');\n                yCell.textContent = point.y.toFixed(2);\n                \n                const actionCell = document.createElement('td');\n                const deleteBtn = document.createElement('button');\n                deleteBtn.textContent = 'Delete';\n                deleteBtn.onclick = function() {\n                    points.splice(index, 1);\n                    updateTable();\n                    updateStats();\n                    initCanvas();\n                };\n                \n                actionCell.appendChild(deleteBtn);\n                row.appendChild(xCell);\n                row.appendChild(yCell);\n                row.appendChild(actionCell);\n                tableBody.appendChild(row);\n            });\n        }\n        \n        // Gradient descent\n        function gradientDescent(iterations, learningRate) {\n            if (points.length < 2) return;\n            \n            let slope = currentSlope;\n            let intercept = currentIntercept;\n            const n = points.length;\n            \n            for (let i = 0; i < iterations && gradientDescentRunning; i++) {\n                let slopeGradient = 0;\n                let interceptGradient = 0;\n                \n                points.forEach(point => {\n                    const predicted = slope * point.x + intercept;\n                    const error = predicted - point.y;\n                    slopeGradient += (2/n) * point.x * error;\n                    interceptGradient += (2/n) * error;\n                });\n                \n                slope -= learningRate * slopeGradient;\n                intercept -= learningRate * interceptGradient;\n                \n                currentSlope = slope;\n                currentIntercept = intercept;\n                \n                document.getElementById('sliderSlope').value = slope;\n                document.getElementById('slopeValue').textContent = slope.toFixed(4);\n                document.getElementById('sliderIntercept').value = intercept;\n                document.getElementById('interceptValue').textContent = intercept.toFixed(4);\n                \n                updateStats();\n                initCanvas();\n                \n                // If we're animating, break after one iteration\n                if (animationId !== null) {\n                    animationId = requestAnimationFrame(() => {\n                        gradientDescent(1, learningRate);\n                    });\n                    return;\n                }\n            }\n        }\n        \n        // Event listeners\n        canvas.addEventListener('click', function(e) {\n            const x = e.clientX - rect.left;\n            const y = e.clientY - rect.top;\n            addPoint(x, y);\n        });\n        \n        canvas.addEventListener('mousedown', function(e) {\n            const x = e.clientX - rect.left;\n            const y = e.clientY - rect.top;\n            \n            // Check if clicking on a point\n            for (let i = 0; i < points.length; i++) {\n                const point = points[i];\n                const distance = Math.sqrt(\n                    Math.pow(x - (canvas.width / 2 + point.x), 2) + \n                    Math.pow(y - (canvas.height / 2 - point.y), 2)\n                );\n                \n                if (distance <= 5) {\n                    isDragging = true;\n                    dragIndex = i;\n                    return;\n                }\n            }\n        });\n        \n        canvas.addEventListener('mousemove', function(e) {\n            if (!isDragging || dragIndex === -1) return;\n            \n            const x = e.clientX - rect.left;\n            const y = e.clientY - rect.top;\n            \n            points[dragIndex].x = x - canvas.width / 2;\n            points[dragIndex].y = canvas.height / 2 - y;\n            \n            updateTable();\n            updateStats();\n            initCanvas();\n        });\n        \n        canvas.addEventListener('mouseup', function() {\n            isDragging = false;\n            dragIndex = -1;\n        });\n        \n        canvas.addEventListener('mouseleave', function() {\n            isDragging = false;\n            dragIndex = -1;\n        });\n        \n        document.getElementById('addRandom').addEventListener('click', addRandomPoint);\n        document.getElementById('clearPoints').addEventListener('click', clearPoints);\n        document.getElementById('addLinePoint').addEventListener('click', addPointOnLine);\n        document.getElementById('addNoisyPoint').addEventListener('click', addNoisyPoint);\n        document.getElementById('calculateRegression').addEventListener('click', calculateRegression);\n        document.getElementById('resetLine').addEventListener('click', function() {\n            currentSlope = 1;\n            currentIntercept = 0;\n            document.getElementById('sliderSlope').value = 1;\n            document.getElementById('slopeValue').textContent = '1.0';\n            document.getElementById('sliderIntercept').value = 0;\n            document.getElementById('interceptValue').textContent = '0';\n            updateStats();\n            initCanvas();\n        });\n        \n        document.getElementById('sliderSlope').addEventListener('input', function() {\n            currentSlope = parseFloat(this.value);\n            document.getElementById('slopeValue').textContent = currentSlope.toFixed(2);\n            updateStats();\n            initCanvas();\n        });\n        \n        document.getElementById('sliderIntercept').addEventListener('input', function() {\n            currentIntercept = parseFloat(this.value);\n            document.getElementById('interceptValue').textContent = currentIntercept.toFixed(2);\n            updateStats();\n            initCanvas();\n        });\n        \n        document.getElementById('learningRate').addEventListener('input', function() {\n            document.getElementById('learningRateValue').textContent = this.value;\n        });\n        \n        document.getElementById('gradientDescent').addEventListener('click', function() {\n            const iterations = parseInt(document.getElementById('iterations').value);\n            const learningRate = parseFloat(document.getElementById('learningRate').value);\n            gradientDescentRunning = true;\n            if (animationId === null) {\n                gradientDescent(iterations, learningRate);\n            }\n        });\n        \n        document.getElementById('stopGradient').addEventListener('click', function() {\n            gradientDescentRunning = false;\n            if (animationId !== null) {\n                cancelAnimationFrame(animationId);\n                animationId = null;\n            }\n        });\n        \n        // Initialize\n        initCanvas();\n    </script>\n</body>\n</html>"
  },
