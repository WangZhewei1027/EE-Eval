    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>HTTP Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea, input[type=text], select {\n    width: 100%;\n    box-sizing: border-box;\n    font-family: monospace, monospace;\n  }\n  label {\n    display: block;\n    margin-top: 1em;\n  }\n  button {\n    margin-top: 0.5em;\n  }\n  pre {\n    white-space: pre-wrap;\n    word-wrap: break-word;\n    border: 1px solid black;\n    padding: 0.5em;\n    max-height: 300px;\n    overflow-y: auto;\n  }\n</style>\n</head>\n<body>\n<h1>HTTP Interactive Explorer</h1>\n\n<p>This tool lets you build, send, and inspect HTTP requests and responses in multiple stages with deep exploration of HTTP concepts.<br>\nYou can create requests, send them, view responses, modify parts, add headers or body data, switch HTTP methods, simulate redirects, and more.</p>\n\n<hr/>\n\n<label for=\"urlInput\">Request URL:</label>\n<input type=\"text\" id=\"urlInput\" placeholder=\"https://example.com/path?query=1\" />\n\n<label for=\"methodSelect\">HTTP Method:</label>\n<select id=\"methodSelect\">\n  <option>GET</option>\n  <option>POST</option>\n  <option>PUT</option>\n  <option>DELETE</option>\n  <option>HEAD</option>\n  <option>OPTIONS</option>\n  <option>PATCH</option>\n</select>\n\n<label for=\"httpVersionSelect\">HTTP Version:</label>\n<select id=\"httpVersionSelect\">\n  <option>HTTP/1.1</option>\n  <option>HTTP/1.0</option>\n  <option>HTTP/2.0 (simulated)</option>\n</select>\n\n<label for=\"headerCountInput\">Number of Headers:</label>\n<input type=\"number\" id=\"headerCountInput\" min=\"0\" max=\"20\" value=\"2\" />\n\n<div id=\"headersArea\"></div>\n\n<label for=\"bodyInput\">Request Body (optional):</label>\n<textarea id=\"bodyInput\" rows=\"6\" placeholder=\"Enter request body here...\"></textarea>\n\n<button id=\"buildRequestBtn\">Build Raw HTTP Request</button>\n<button id=\"sendRequestBtn\">Send Request (simulated)</button>\n<button id=\"clearLogsBtn\">Clear Logs</button>\n\n<h2>Raw HTTP Request</h2>\n<pre id=\"rawRequestView\" tabindex=\"0\"></pre>\n\n<h2>Raw HTTP Response</h2>\n<pre id=\"rawResponseView\" tabindex=\"0\">(No response yet)</pre>\n\n<h2>Response Insights and Controls</h2>\n<div id=\"responseControls\" style=\"display:none;\">\n  <label for=\"followRedirectToggle\"><input type=\"checkbox\" id=\"followRedirectToggle\" checked> Auto-follow Redirects</label>\n  <label for=\"maxRedirectsInput\">Max Redirects:</label>\n  <input type=\"number\" id=\"maxRedirectsInput\" min=\"0\" max=\"10\" value=\"3\" />\n\n  <button id=\"viewParsedHeadersBtn\">View Parsed Headers</button>\n  <button id=\"viewCookiesBtn\">View Response Cookies</button>\n  <button id=\"viewStatusCodeBtn\">View Status Code Info</button>\n</div>\n\n<div id=\"parsedHeadersArea\" style=\"display:none;\">\n  <h3>Parsed Response Headers</h3>\n  <pre id=\"parsedHeadersPre\"></pre>\n</div>\n\n<div id=\"cookiesArea\" style=\"display:none;\">\n  <h3>Cookies from Response</h3>\n  <pre id=\"cookiesPre\"></pre>\n</div>\n\n<div id=\"statusCodeInfoArea\" style=\"display:none;\">\n  <h3>Status Code Information</h3>\n  <pre id=\"statusCodeInfoPre\"></pre>\n</div>\n\n<hr />\n\n<h2>Interactive HTTP Concepts Explorer</h2>\n\n<p>Try these interactive explorations:</p>\n\n<button id=\"simulateRedirectBtn\">Simulate Complex Redirect Chain</button>\n<button id=\"simulateErrorBtn\">Simulate HTTP Error Response</button>\n<button id=\"simulateChunkedBtn\">Simulate Chunked Transfer Encoding</button>\n<button id=\"simulateAuthBtn\">Simulate HTTP Basic Auth</button>\n<button id=\"simulateCacheBtn\">Simulate Cache-Control and Conditional Requests</button>\n<button id=\"simulateCompressionBtn\">Simulate Compressed Response (gzip)</button>\n\n<div id=\"simulationOutput\" style=\"white-space: pre-wrap; max-height: 400px; overflow-y: auto; border: 1px solid black; margin-top:1em; padding:0.5em;\">\n</div>\n\n<script>\n(() => {\n  // Utilities\n  function escapeHtml(text) {\n    return text.replace(/[&<>\"']/g, m => ({\n      '&':'&amp;',\n      '<':'&lt;',\n      '>':'&gt;',\n      '\"':'&quot;',\n      \"'\":'&#39;',\n    }[m]));\n  }\n\n  // Elements\n  const urlInput = document.getElementById('urlInput');\n  const methodSelect = document.getElementById('methodSelect');\n  const httpVersionSelect = document.getElementById('httpVersionSelect');\n  const headerCountInput = document.getElementById('headerCountInput');\n  const headersArea = document.getElementById('headersArea');\n  const bodyInput = document.getElementById('bodyInput');\n  const buildRequestBtn = document.getElementById('buildRequestBtn');\n  const sendRequestBtn = document.getElementById('sendRequestBtn');\n  const clearLogsBtn = document.getElementById('clearLogsBtn');\n  const rawRequestView = document.getElementById('rawRequestView');\n  const rawResponseView = document.getElementById('rawResponseView');\n  const responseControls = document.getElementById('responseControls');\n  const followRedirectToggle = document.getElementById('followRedirectToggle');\n  const maxRedirectsInput = document.getElementById('maxRedirectsInput');\n  const viewParsedHeadersBtn = document.getElementById('viewParsedHeadersBtn');\n  const parsedHeadersArea = document.getElementById('parsedHeadersArea');\n  const parsedHeadersPre = document.getElementById('parsedHeadersPre');\n  const viewCookiesBtn = document.getElementById('viewCookiesBtn');\n  const cookiesArea = document.getElementById('cookiesArea');\n  const cookiesPre = document.getElementById('cookiesPre');\n  const viewStatusCodeBtn = document.getElementById('viewStatusCodeBtn');\n  const statusCodeInfoArea = document.getElementById('statusCodeInfoArea');\n  const statusCodeInfoPre = document.getElementById('statusCodeInfoPre');\n  const simulateRedirectBtn = document.getElementById('simulateRedirectBtn');\n  const simulateErrorBtn = document.getElementById('simulateErrorBtn');\n  const simulateChunkedBtn = document.getElementById('simulateChunkedBtn');\n  const simulateAuthBtn = document.getElementById('simulateAuthBtn');\n  const simulateCacheBtn = document.getElementById('simulateCacheBtn');\n  const simulateCompressionBtn = document.getElementById('simulateCompressionBtn');\n  const simulationOutput = document.getElementById('simulationOutput');\n\n  // State\n  let headersInputs = [];\n  let currentRawRequest = '';\n  let currentRawResponse = '';\n  let currentParsedResponseHeaders = {};\n  let currentCookies = [];\n  let currentStatusCode = 0;\n  let currentResponseBody = '';\n  let accumulatedRedirects = 0;\n\n  // Status code info database (simplified)\n  const statusCodeInfoDB = {\n    100: 'Continue: The server has received the request headers, and the client should proceed to send the request body.',\n    200: 'OK: The request has succeeded.',\n    201: 'Created: The request has been fulfilled and resulted in a new resource being created.',\n    204: 'No Content: The server successfully processed the request but is not returning any content.',\n    301: 'Moved Permanently: The requested resource has been assigned a new permanent URI.',\n    302: 'Found: The requested resource resides temporarily under a different URI.',\n    303: 'See Other: The response can be found under another URI using a GET method.',\n    304: 'Not Modified: The resource has not been modified since last requested.',\n    400: 'Bad Request: The request could not be understood by the server due to malformed syntax.',\n    401: 'Unauthorized: The request requires user authentication.',\n    403: 'Forbidden: The server understood the request, but refuses to authorize it.',\n    404: 'Not Found: The server has not found anything matching the Request-URI.',\n    500: 'Internal Server Error: The server encountered an unexpected condition.',\n    502: 'Bad Gateway: The server received an invalid response from the upstream server.',\n    503: 'Service Unavailable: The server is currently unable to handle the request due to maintenance or overload.',\n  };\n\n  // Functions\n  function buildHeadersInputs(num) {\n    headersArea.innerHTML = '';\n    headersInputs = [];\n    for(let i=0; i<num; i++) {\n      const headerDiv = document.createElement('div');\n      headerDiv.style.marginBottom = '0.3em';\n      const nameInput = document.createElement('input');\n      nameInput.type = 'text';\n      nameInput.placeholder = `Header name #${i+1}`;\n      nameInput.style.width = '40%';\n      const valueInput = document.createElement('input');\n      valueInput.type = 'text';\n      valueInput.placeholder = `Header value #${i+1}`;\n      valueInput.style.width = '55%';\n      headerDiv.appendChild(nameInput);\n      headerDiv.appendChild(document.createTextNode(' : '));\n      headerDiv.appendChild(valueInput);\n      headersArea.appendChild(headerDiv);\n      headersInputs.push({nameInput, valueInput});\n    }\n  }\n\n  function getHeadersObject() {\n    const headers = {};\n    for(const {nameInput, valueInput} of headersInputs) {\n      const n = nameInput.value.trim();\n      if(n) {\n        let v = valueInput.value.trim();\n        if(headers[n]) {\n          // Multiple same headers concatenated with comma if repeated?\n          headers[n] = headers[n]+', '+v;\n        } else {\n          headers[n] = v;\n        }\n      }\n    }\n    return headers;\n  }\n\n  function buildRawRequest() {\n    const urlStr = urlInput.value.trim();\n    if(!urlStr) {\n      alert('Please enter a URL');\n      return '';\n    }\n    let urlObj;\n    try {\n      urlObj = new URL(urlStr);\n    } catch(e) {\n      alert('Invalid URL');\n      return '';\n    }\n    const method = methodSelect.value;\n    const httpVersion = httpVersionSelect.value;\n    const pathAndQuery = urlObj.pathname + (urlObj.search||'');\n    let raw = `${method} ${pathAndQuery} ${httpVersion}\\r\\n`;\n\n    // Host header mandatory for HTTP/1.1\n    const headers = getHeadersObject();\n    if(!headers['Host']) {\n      raw += `Host: ${urlObj.host}\\r\\n`;\n    }\n\n    // Add other headers\n    for(const hName in headers) {\n      raw += `${hName}: ${headers[hName]}\\r\\n`;\n    }\n\n    // Content-Length for methods with body and if body exists\n    const body = bodyInput.value;\n    if(body && ['POST','PUT','PATCH','DELETE'].includes(method)) {\n      // Only add content-length if it's not already sent\n      if(!headers['Content-Length']) {\n        raw += `Content-Length: ${new Blob([body]).size}\\r\\n`;\n      }\n    }\n\n    raw += `\\r\\n`;\n    if(body && ['POST','PUT','PATCH','DELETE'].includes(method)) {\n      raw += body;\n    }\n    return raw;\n  }\n\n  function parseRawResponse(raw) {\n    // Basic parser for raw HTTP response text\n    // Split header and body by first double CRLF sequence\n    const splitIndex = raw.indexOf('\\r\\n\\r\\n');\n    if(splitIndex === -1) {\n      return {statusLine: '', headers: {}, body: ''};\n    }\n    const headerPart = raw.substring(0, splitIndex);\n    let bodyPart = raw.substring(splitIndex+4);\n\n    const headerLines = headerPart.split('\\r\\n');\n    const statusLine = headerLines[0];\n\n    const headers = {};\n    for(let i=1; i<headerLines.length; i++) {\n      const line = headerLines[i];\n      const sepIndex = line.indexOf(':');\n      if(sepIndex > 0) {\n        const name = line.substring(0, sepIndex).trim();\n        const value = line.substring(sepIndex+1).trim();\n        const lname = name.toLowerCase();\n        if(headers[lname]) {\n          headers[lname] += ', ' + value;\n        } else {\n          headers[lname] = value;\n        }\n      }\n    }\n\n    return {statusLine, headers, body: bodyPart};\n  }\n\n  function extractStatusCode(statusLine) {\n    // e.g. HTTP/1.1 200 OK\n    const parts = statusLine.split(' ');\n    if(parts.length < 2) return 0;\n    return parseInt(parts[1], 10) || 0;\n  }\n\n  function parseCookies(setCookieHeader) {\n    // Accepts single string or array of strings\n    if(!setCookieHeader) return [];\n    const cookies = [];\n    if(typeof setCookieHeader === 'string') {\n      setCookieHeader = [setCookieHeader];\n    }\n    for(const sc of setCookieHeader) {\n      // Parse cookie string\n      // e.g. sessionId=abc123; Path=/; HttpOnly\n      const parts = sc.split(';').map(s=>s.trim());\n      const [nameVal, ...attr] = parts;\n      const eqIdx = nameVal.indexOf('=');\n      if(eqIdx<0) continue;\n      const name = nameVal.substring(0, eqIdx);\n      const value = nameVal.substring(eqIdx+1);\n      const attributes = {};\n      for(const a of attr) {\n        const [k,v] = a.split('=').map(x=>x.trim());\n        attributes[k.toLowerCase()] = v===undefined ? true : v;\n      }\n      cookies.push({name,value,attributes});\n    }\n    return cookies;\n  }\n\n  function updateResponseControlsVisibility(show) {\n    responseControls.style.display = show ? '' : 'none';\n    parsedHeadersArea.style.display = 'none';\n    cookiesArea.style.display = 'none';\n    statusCodeInfoArea.style.display = 'none';\n  }\n\n  function displayParsedHeaders() {\n    parsedHeadersPre.textContent = '';\n    const h = currentParsedResponseHeaders;\n    const lines = [];\n    for(const k in h) {\n      lines.push(`${k}: ${h[k]}`);\n    }\n    parsedHeadersPre.textContent = lines.join('\\n');\n    parsedHeadersArea.style.display = '';\n  }\n\n  function displayCookies() {\n    cookiesPre.textContent = '';\n    if(currentCookies.length === 0) {\n      cookiesPre.textContent = '(No cookies)';\n    } else {\n      const lines = currentCookies.map(c => {\n        let attrStr = '';\n        for(const a in c.attributes) {\n          attrStr += '; ' + a + (c.attributes[a]===true ? '' : '='+c.attributes[a]);\n        }\n        return `${c.name}=${c.value}${attrStr}`;\n      });\n      cookiesPre.textContent = lines.join('\\n');\n    }\n    cookiesArea.style.display = '';\n  }\n\n  function displayStatusCodeInfo() {\n    const info = statusCodeInfoDB[currentStatusCode] || 'Unknown status code or no info available.';\n    statusCodeInfoPre.textContent = `${currentStatusCode} - ${info}`;\n    statusCodeInfoArea.style.display = '';\n  }\n\n  // Event handlers\n  headerCountInput.addEventListener('change', () => {\n    let n = parseInt(headerCountInput.value, 10);\n    if(Number.isNaN(n) || n<0) n=0;\n    if(n>20) n=20;\n    headerCountInput.value = n;\n    buildHeadersInputs(n);\n  });\n\n  buildRequestBtn.addEventListener('click', () => {\n    accumulatedRedirects = 0;\n    const raw = buildRawRequest();\n    if(raw) {\n      currentRawRequest = raw;\n      rawRequestView.textContent = raw;\n      rawResponseView.textContent = '(No response yet)';\n      updateResponseControlsVisibility(false);\n      simulationOutput.textContent = '';\n    }\n  });\n\n  // Simulate sending requests - since no real network, simulate common HTTP responses\n  sendRequestBtn.addEventListener('click', () => {\n    if(!currentRawRequest) {\n      alert('Build the request first.');\n      return;\n    }\n    accumulatedRedirects = 0;\n    simulationOutput.textContent = '';\n    simulateSendRequest(currentRawRequest, followRedirectToggle.checked, parseInt(maxRedirectsInput.value,10)||3);\n  });\n\n  clearLogsBtn.addEventListener('click', () => {\n    rawRequestView.textContent = '';\n    rawResponseView.textContent = '(No response yet)';\n    parsedHeadersArea.style.display = 'none';\n    cookiesArea.style.display = 'none';\n    statusCodeInfoArea.style.display = 'none';\n    responseControls.style.display = 'none';\n    simulationOutput.textContent = '';\n    currentRawRequest = '';\n    currentRawResponse = '';\n    currentParsedResponseHeaders = {};\n    currentCookies = [];\n    currentStatusCode = 0;\n    currentResponseBody = '';\n    accumulatedRedirects = 0;\n  });\n\n  viewParsedHeadersBtn.addEventListener('click', () => {\n    if(!currentRawResponse) return;\n    displayParsedHeaders();\n  });\n\n  viewCookiesBtn.addEventListener('click', () => {\n    if(!currentRawResponse) return;\n    displayCookies();\n  });\n\n  viewStatusCodeBtn.addEventListener('click', () => {\n    if(!currentRawResponse) return;\n    displayStatusCodeInfo();\n  });\n\n  // Simulation Explorers\n\n  // Helper: simulate sending request and receiving responses with redirects if enabled\n  function simulateSendRequest(rawRequest, autoRedirect=true, maxRedirects=3) {\n    // Parse request\n    // Basic: parse first line for method and URL path\n    const requestLines = rawRequest.split('\\r\\n');\n    if(requestLines.length<1) return;\n    const requestLine = requestLines[0];\n    const [method, path] = requestLine.split(' ');\n    if(!method || !path) return;\n\n    // For simulation: We'll emulate some basic URL-path based responses\n    // Extract host header from request headers\n    let host = null;\n    for(let i=1;i<requestLines.length;i++) {\n      const l = requestLines[i];\n      if(!l) break; // end headers\n      const idx = l.indexOf(':');\n      if(idx>0) {\n        const hn = l.substring(0, idx).trim().toLowerCase();\n        const hv = l.substring(idx+1).trim();\n        if(hn === 'host') {\n          host = hv;\n          break;\n        }\n      }\n    }\n    if(!host) host = 'example.com';\n\n    // For simulation: base URL = http://host\n    const fullURL = 'http://' + host + path;\n\n    simulationOutput.textContent = 'Sending request to ' + fullURL + '\\n';\n\n    // Simulation logic: several paths\n    function createResponse(statusCode, statusText, headers, body, httpVer) {\n      httpVer = httpVer || 'HTTP/1.1';\n      let resp = `${httpVer} ${statusCode} ${statusText}\\r\\n`;\n      for(const k in headers) {\n        resp += `${k}: ${headers[k]}\\r\\n`;\n      }\n      resp += `\\r\\n`;\n      resp += body;\n      return resp;\n    }\n\n    // Simulated servers and behaviors\n    const serverResponses = {\n      '/': () => createResponse(200, 'OK', {'Content-Type': 'text/plain'}, 'Welcome to the root page.', 'HTTP/1.1'),\n      '/redirect1': () => createResponse(301, 'Moved Permanently', {'Location': '/redirect2'}, 'Redirecting to /redirect2'),\n      '/redirect2': () => createResponse(302, 'Found', {'Location': '/redirect3'}, 'Redirecting to /redirect3'),\n      '/redirect3': () => createResponse(303, 'See Other', {'Location': '/'}, 'Redirecting to /'),\n      '/error400': () => createResponse(400, 'Bad Request', {'Content-Type': 'text/plain'}, 'Bad Request error simulated.'),\n      '/error404': () => createResponse(404, 'Not Found', {'Content-Type': 'text/plain'}, 'Page not found.'),\n      '/error500': () => createResponse(500, 'Internal Server Error', {'Content-Type': 'text/plain'}, 'Something went wrong.'),\n      '/auth': () => {\n        // Check Authorization header\n        let authHeader = null;\n        for(let i=1;i<requestLines.length;i++) {\n          let l = requestLines[i];\n          if(!l) break;\n          let idx = l.indexOf(':');\n          if(idx>0) {\n            let hn = l.substring(0,idx).trim().toLowerCase();\n            let hv = l.substring(idx+1).trim();\n            if(hn === 'authorization') {\n              authHeader = hv;\n              break;\n            }\n          }\n        }\n        if(authHeader === 'Basic dXNlcjpwYXNz') { // user:pass base64\n          return createResponse(200, 'OK', {'Content-Type': 'text/plain'}, 'Authorized content here.');\n        } else {\n          return createResponse(401, 'Unauthorized', {'WWW-Authenticate': 'Basic realm=\"User Visible Realm\"'}, 'Authentication required.');\n        }\n      },\n      '/chunked': () => {\n        // Simulate chunked transfer encoding (simple text chunks)\n        let resp = 'HTTP/1.1 200 OK\\r\\nContent-Type: text/plain\\r\\nTransfer-Encoding: chunked\\r\\n\\r\\n';\n        resp += 'A\\r\\nHello World\\r\\n';\n        resp += '5\\r\\n12345\\r\\n';\n        resp += '0\\r\\n\\r\\n';\n        return resp;\n      },\n      '/cache': () => {\n        // Return ETag and Cache-Control headers\n        return createResponse(200, 'OK', {\n          'Content-Type': 'text/plain',\n          'Cache-Control': 'max-age=30',\n          'ETag': '\"123456789\"',\n        }, 'Cached content with ETag.');\n      },\n      '/gzip': () => {\n        // Simulate compressed response (fake content for demo)\n        return createResponse(200, 'OK', {\n          'Content-Type': 'text/plain',\n          'Content-Encoding': 'gzip',\n        }, '(\\u001f\\u008b\\u0008\\u0000\\u0000\\u0000\\u0000\\u0000\\u0000\\u0003'); // truncated binary-like content\n      },\n    };\n\n    // Extract path without query\n    let pathOnly = path.split('?')[0];\n\n    let responseRaw = null;\n    if(serverResponses[pathOnly]) {\n      responseRaw = serverResponses[pathOnly]();\n    } else {\n      responseRaw = createResponse(404, 'Not Found', {'Content-Type': 'text/plain'}, 'No simulation for this path.');\n    }\n\n    // Parse response for redirects\n    const respParsed = parseRawResponse(responseRaw);\n    currentRawResponse = responseRaw;\n    currentParsedResponseHeaders = respParsed.headers;\n    currentStatusCode = extractStatusCode(respParsed.statusLine);\n    currentResponseBody = respParsed.body;\n    currentCookies = parseCookies(respParsed.headers['set-cookie'] || respParsed.headers['Set-Cookie']);\n\n    rawResponseView.textContent = responseRaw;\n    updateResponseControlsVisibility(true);\n\n    simulationOutput.textContent += `Received response: ${respParsed.statusLine}\\n`;\n\n    function isRedirect(code) {\n      return [301,302,303,307,308].includes(code);\n    }\n\n    if(autoRedirect && isRedirect(currentStatusCode) && currentParsedResponseHeaders.location) {\n      if(accumulatedRedirects >= maxRedirects) {\n        simulationOutput.textContent += 'Maximum redirects reached, stopping.\\n';\n        return;\n      }\n      accumulatedRedirects++;\n      const loc = currentParsedResponseHeaders.location;\n      simulationOutput.textContent += `Redirect ${accumulatedRedirects}: following Location header to ${loc}\\n`;\n\n      // Build new raw request for redirected location using GET and HTTP/1.1 (standard behavior for 301/302/303)\n      const newMethod = (currentStatusCode === 303) ? 'GET' : method;\n      // For simplicity, keep HTTP/1.1 version for all\n      const newUrl = new URL(loc, fullURL).href;\n\n      urlInput.value = newUrl;\n      methodSelect.value = newMethod;\n      httpVersionSelect.value = 'HTTP/1.1';\n      bodyInput.value = '';\n\n      const rebuiltRaw = buildRawRequest();\n      currentRawRequest = rebuiltRaw;\n      rawRequestView.textContent = rebuiltRaw;\n\n      // Recursively send the new request with updated request\n      setTimeout(() => simulateSendRequest(rebuiltRaw, autoRedirect, maxRedirects), 500);\n    }\n  }\n\n  // Interactive Simulations below\n\n  simulateRedirectBtn.addEventListener('click', () => {\n    simulationOutput.textContent = '';\n    accumulatedRedirects = 0;\n    // Start with /redirect1 which chains to /redirect2, /redirect3 and back to /\n    urlInput.value = 'http://example.com/redirect1';\n    methodSelect.value = 'GET';\n    httpVersionSelect.value = 'HTTP/1.1';\n    headerCountInput.value = 0;\n    buildHeadersInputs(0);\n    bodyInput.value = '';\n    buildRequestBtn.click();\n    simulateSendRequest(currentRawRequest, true, 10);\n  });\n\n  simulateErrorBtn.addEventListener('click', () => {\n    simulationOutput.textContent = 'Simulating various HTTP error responses:\\n\\n';\n    const errorPaths = ['/error400', '/error404', '/error500'];\n    let idx = 0;\n    function next() {\n      if(idx >= errorPaths.length) {\n        simulationOutput.textContent += '\\nFinished error simulation.\\n';\n        return;\n      }\n      const p = errorPaths[idx++];\n      urlInput.value = 'http://example.com' + p;\n      methodSelect.value = 'GET';\n      httpVersionSelect.value = 'HTTP/1.1';\n      headerCountInput.value = 0;\n      buildHeadersInputs(0);\n      bodyInput.value = '';\n      buildRequestBtn.click();\n      simulationOutput.textContent += `Sending request to ${urlInput.value}\\n`;\n      simulateSendRequest(currentRawRequest, false, 0);\n      simulationOutput.textContent += `${rawResponseView.textContent}\\n\\n`;\n      setTimeout(next, 700);\n    }\n    next();\n  });\n\n  simulateChunkedBtn.addEventListener('click', () => {\n    simulationOutput.textContent = 'Simulating chunked transfer encoding response:\\n\\n';\n    urlInput.value = 'http://example.com/chunked';\n    methodSelect.value = 'GET';\n    httpVersionSelect.value = 'HTTP/1.1';\n    headerCountInput.value = 0;\n    buildHeadersInputs(0);\n    bodyInput.value = '';\n    buildRequestBtn.click();\n    simulateSendRequest(currentRawRequest, false, 0);\n  });\n\n  simulateAuthBtn.addEventListener('click', () => {\n    simulationOutput.textContent = 'Simulate HTTP Basic Authentication flow:\\n\\n';\n    const makeRequest = (auth) => {\n      urlInput.value = 'http://example.com/auth';\n      methodSelect.value = 'GET';\n      httpVersionSelect.value = 'HTTP/1.1';\n      headerCountInput.value = auth ? 1 : 0;\n      buildHeadersInputs(auth?1:0);\n      if(auth) {\n        headersInputs[0].nameInput.value = 'Authorization';\n        headersInputs[0].valueInput.value = 'Basic dXNlcjpwYXNz'; // \"user:pass\" base64 encoded\n      }\n      bodyInput.value = '';\n      buildRequestBtn.click();\n      simulateSendRequest(currentRawRequest, false, 0);\n    };\n    simulationOutput.textContent += 'Sending unauthenticated request...\\n';\n    makeRequest(false);\n    setTimeout(() => {\n      simulationOutput.textContent += '\\nSending authenticated request with Basic Auth header...\\n';\n      makeRequest(true);\n    }, 1500);\n  });\n\n  simulateCacheBtn.addEventListener('click', () => {\n    simulationOutput.textContent = 'Simulate Cache-Control and Conditional Requests:\\n\\n';\n    // Step 1: fetch resource with ETag, Cache-Control\n    urlInput.value = 'http://example.com/cache';\n    methodSelect.value = 'GET';\n    httpVersionSelect.value = 'HTTP/1.1';\n    headerCountInput.value = 0;\n    buildHeadersInputs(0);\n    bodyInput.value = '';\n    buildRequestBtn.click();\n    simulateSendRequest(currentRawRequest, false, 0);\n\n    setTimeout(() => {\n      simulationOutput.textContent += '\\nNow simulate client sends conditional GET with If-None-Match header\\n';\n      headerCountInput.value = 1;\n      buildHeadersInputs(1);\n      headersInputs[0].nameInput.value = 'If-None-Match';\n      headersInputs[0].valueInput.value = '\"123456789\"';\n      bodyInput.value = '';\n      buildRequestBtn.click();\n\n      // Override simulateSendRequest for conditional GET to simulate 304 Not Modified\n      function simulateConditionalGet(rawRequest) {\n        const resp304 = [\n          'HTTP/1.1 304 Not Modified',\n          'Cache-Control: max-age=30',\n          'ETag: \"123456789\"',\n          '\\r\\n'\n        ].join('\\r\\n');\n        currentRawResponse = resp304;\n        rawResponseView.textContent = resp304;\n        const parsed = parseRawResponse(resp304);\n        currentParsedResponseHeaders = parsed.headers;\n        currentStatusCode = extractStatusCode(parsed.statusLine);\n        currentResponseBody = parsed.body;\n        currentCookies = [];\n        updateResponseControlsVisibility(true);\n        simulationOutput.textContent += 'Received 304 Not Modified response, client should use cached content.\\n';\n      }\n\n      simulateConditionalGet(currentRawRequest);\n    }, 2000);\n  });\n\n  simulateCompressionBtn.addEventListener('click', () => {\n    simulationOutput.textContent = 'Simulate GZIP compressed response:\\n\\n';\n    urlInput.value = 'http://example.com/gzip';\n    methodSelect.value = 'GET';\n    httpVersionSelect.value = 'HTTP/1.1';\n    headerCountInput.value = 0;\n    buildHeadersInputs(0);\n    bodyInput.value = '';\n    buildRequestBtn.click();\n    simulateSendRequest(currentRawRequest, false, 0);\n\n    simulationOutput.textContent += '\\nNote: actual decompression not performed. Content-Encoding header shows \"gzip\".\\n';\n  });\n\n  // Initialize default headers inputs\n  buildHeadersInputs(2);\n\n})();\n</script>\n\n</body>\n</html>"
