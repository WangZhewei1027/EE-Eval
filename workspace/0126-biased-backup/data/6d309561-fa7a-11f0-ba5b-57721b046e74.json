    "content": "<html>\n<head>\n    <title>Interactive Paging System</title>\n    <script>\n        let currentPage = 1;\n        let totalPages = 10;\n        let pageSize = 10;\n        let data = [];\n        \n        function init() {\n            generateData();\n            renderPagination();\n            renderData();\n            updateControls();\n        }\n        \n        function generateData() {\n            data = [];\n            for (let i = 1; i <= 100; i++) {\n                data.push(`Item ${i} - Data content for demonstration of paging functionality`);\n            }\n        }\n        \n        function renderData() {\n            const start = (currentPage - 1) * pageSize;\n            const end = start + pageSize;\n            const pageData = data.slice(start, end);\n            \n            const dataContainer = document.getElementById('data-container');\n            dataContainer.innerHTML = '';\n            \n            pageData.forEach(item => {\n                const div = document.createElement('div');\n                div.textContent = item;\n                dataContainer.appendChild(div);\n            });\n        }\n        \n        function renderPagination() {\n            const pagination = document.getElementById('pagination');\n            pagination.innerHTML = '';\n            \n            // First page\n            addPageButton(pagination, '<<', 1, currentPage === 1);\n            \n            // Previous page\n            addPageButton(pagination, '<', currentPage - 1, currentPage === 1);\n            \n            // Page numbers\n            const maxVisiblePages = 5;\n            let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));\n            let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);\n            \n            if (endPage - startPage + 1 < maxVisiblePages) {\n                startPage = Math.max(1, endPage - maxVisiblePages + 1);\n            }\n            \n            if (startPage > 1) {\n                const ellipsis = document.createElement('span');\n                ellipsis.textContent = '...';\n                pagination.appendChild(ellipsis);\n            }\n            \n            for (let i = startPage; i <= endPage; i++) {\n                addPageButton(pagination, i, i, i === currentPage);\n            }\n            \n            if (endPage < totalPages) {\n                const ellipsis = document.createElement('span');\n                ellipsis.textContent = '...';\n                pagination.appendChild(ellipsis);\n            }\n            \n            // Next page\n            addPageButton(pagination, '>', currentPage + 1, currentPage === totalPages);\n            \n            // Last page\n            addPageButton(pagination, '>>', totalPages, currentPage === totalPages);\n        }\n        \n        function addPageButton(container, text, page, disabled) {\n            const button = document.createElement('button');\n            button.textContent = text;\n            button.onclick = () => goToPage(page);\n            button.disabled = disabled;\n            container.appendChild(button);\n        }\n        \n        function goToPage(page) {\n            if (page < 1 || page > totalPages) return;\n            currentPage = page;\n            renderData();\n            renderPagination();\n            updateControls();\n        }\n        \n        function updateControls() {\n            document.getElementById('current-page').value = currentPage;\n            document.getElementById('page-info').textContent = `Page ${currentPage} of ${totalPages} (${data.length} total items)`;\n        }\n        \n        function changePageSize() {\n            const newSize = parseInt(document.getElementById('page-size').value);\n            if (newSize > 0) {\n                pageSize = newSize;\n                totalPages = Math.ceil(data.length / pageSize);\n                if (currentPage > totalPages) {\n                    currentPage = totalPages;\n                }\n                renderData();\n                renderPagination();\n                updateControls();\n            }\n        }\n        \n        function jumpToPage() {\n            const pageInput = document.getElementById('current-page');\n            const page = parseInt(pageInput.value);\n            if (page >= 1 && page <= totalPages) {\n                goToPage(page);\n            } else {\n                pageInput.value = currentPage;\n            }\n        }\n        \n        function searchData() {\n            const query = document.getElementById('search-input').value.toLowerCase();\n            if (query === '') {\n                generateData();\n            } else {\n                data = data.filter(item => item.toLowerCase().includes(query));\n            }\n            totalPages = Math.ceil(data.length / pageSize);\n            currentPage = 1;\n            renderData();\n            renderPagination();\n            updateControls();\n        }\n    </script>\n</head>\n<body onload=\"init()\">\n    <h1>Interactive Paging System</h1>\n    \n    <div>\n        <h2>Data Display</h2>\n        <div id=\"data-container\"></div>\n    </div>\n    \n    <div>\n        <h2>Pagination Controls</h2>\n        <div id=\"pagination\"></div>\n        <div id=\"page-info\"></div>\n    </div>\n    \n    <div>\n        <h2>Configuration</h2>\n        <div>\n            <label>Items per page:\n                <input id=\"number-of-pages\" type=\"number\" min=\"1\" max=\"100\" value=\"10\" onchange=\"changePageSize()\">\n            </label>\n        </div>\n    </div>\n    \n    <div>\n        <h2>Navigation</h2>\n        <div>\n            <label>Go to page:\n                <input id=\"current-page\" type=\"number\" min=\"1\" onchange=\"jumpToPage()\">\n            </label>\n        </div>\n    </div>\n    \n    <div>\n        <h2>Search</h2>\n        <div>\n            <input id=\"search-input\" type=\"text\" placeholder=\"Search data...\">\n            <button onclick=\"searchData()\">Search</button>\n            <button onclick=\"document.getElementById('search-input').value=''; searchData();\">Clear</button>\n        </div>\n    </div>\n    \n    <div>\n        <h2>Advanced Controls</h2>\n        <div>\n            <button onclick=\"totalPages = Math.ceil(data.length / pageSize); goToPage(1)\">Reset to First Page</button>\n            <button onclick=\"goToPage(Math.floor(totalPages / 2))\">Go to Middle Page</button>\n            <button onclick=\"goToPage(totalPages)\">Go to Last Page</button>\n        </div>\n        <div>\n            <label>Jump to random page:\n                <button onclick=\"goToPage(Math.floor(Math.random() * totalPages) + 1)\">Random</button>\n            </label>\n        </div>\n    </div>\n</body>\n</html>"
