    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Bucket Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        .array-display {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 5px;\n            margin: 10px 0;\n            min-height: 50px;\n        }\n        .bucket-container {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 20px;\n            margin-top: 20px;\n        }\n        .bucket {\n            border: 1px solid #000;\n            padding: 10px;\n            min-width: 100px;\n        }\n        .bucket-title {\n            font-weight: bold;\n            margin-bottom: 5px;\n        }\n        .bucket-items {\n            display: flex;\n            flex-direction: column;\n            gap: 3px;\n        }\n        .item {\n            border: 1px solid #999;\n            padding: 3px;\n            text-align: center;\n        }\n        .step-info {\n            margin: 10px 0;\n            font-weight: bold;\n        }\n        .slider-container {\n            width: 300px;\n        }\n        button {\n            padding: 5px 10px;\n        }\n        input[type=\"text\"] {\n            padding: 5px;\n            width: 200px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Bucket Sort</h1>\n        \n        <div class=\"control-group\">\n            <h3>Array Configuration</h3>\n            <div>\n                <label for=\"arrayInput\">Enter numbers (comma separated):</label>\n                <input type=\"text\" id=\"arrayInput\" value=\"29,25,3,49,9,37,21,43\">\n                <button id=\"setArray\">Set Array</button>\n            </div>\n            <div>\n                <label for=\"randomArray\">Generate Random Array:</label>\n                <input type=\"range\" id=\"arraySize\" min=\"5\" max=\"30\" value=\"10\">\n                <span id=\"arraySizeValue\">10</span> elements\n                <button id=\"generateRandom\">Generate</button>\n            </div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Bucket Sort Parameters</h3>\n            <div>\n                <label for=\"bucketCount\">Number of Buckets:</label>\n                <input type=\"range\" id=\"bucketCount\" min=\"2\" max=\"10\" value=\"5\">\n                <span id=\"bucketCountValue\">5</span>\n            </div>\n            <div>\n                <label for=\"minValue\">Minimum Value:</label>\n                <input type=\"number\" id=\"minValue\" value=\"0\" min=\"0\" max=\"100\">\n            </div>\n            <div>\n                <label for=\"maxValue\">Maximum Value:</label>\n                <input type=\"number\" id=\"maxValue\" value=\"50\" min=\"10\" max=\"100\">\n            </div>\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Sorting Controls</h3>\n            <button id=\"startSort\">Start Bucket Sort</button>\n            <button id=\"nextStep\">Next Step</button>\n            <button id=\"autoStep\">Auto Step (500ms)</button>\n            <button id=\"reset\">Reset</button>\n            <button id=\"showPseudocode\">Show Pseudocode</button>\n        </div>\n        \n        <div class=\"step-info\" id=\"stepDescription\">\n            Click \"Start Bucket Sort\" to begin the visualization.\n        </div>\n        \n        <div>\n            <h3>Original Array:</h3>\n            <div class=\"array-display\" id=\"originalArray\"></div>\n        </div>\n        \n        <div id=\"bucketsSection\" style=\"display: none;\">\n            <h3>Buckets:</h3>\n            <div class=\"bucket-container\" id=\"bucketsContainer\"></div>\n        </div>\n        \n        <div id=\"sortedArraySection\" style=\"display: none;\">\n            <h3>Sorted Array:</h3>\n            <div class=\"array-display\" id=\"sortedArray\"></div>\n        </div>\n        \n        <div id=\"pseudocode\" style=\"display: none; margin-top: 20px; border: 1px solid #ccc; padding: 10px;\">\n            <h3>Bucket Sort Pseudocode:</h3>\n            <pre>\nfunction bucketSort(array, bucketCount, min, max) {\n    // 1. Create empty buckets\n    let buckets = new Array(bucketCount);\n    for (let i = 0; i < bucketCount; i++) {\n        buckets[i] = [];\n    }\n    \n    // 2. Calculate range for each bucket\n    let range = (max - min) / bucketCount;\n    \n    // 3. Scatter: Put array elements into buckets\n    for (let num of array) {\n        let bucketIndex = Math.floor((num - min) / range);\n        if (bucketIndex >= bucketCount) bucketIndex = bucketCount - 1;\n        buckets[bucketIndex].push(num);\n    }\n    \n    // 4. Sort each bucket (using insertion sort)\n    for (let bucket of buckets) {\n        insertionSort(bucket);\n    }\n    \n    // 5. Gather: Concatenate all buckets\n    let sorted = [];\n    for (let bucket of buckets) {\n        sorted.push(...bucket);\n    }\n    \n    return sorted;\n}\n            </pre>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let originalArray = [];\n        let buckets = [];\n        let sortedArray = [];\n        let currentStep = 0;\n        let autoStepInterval = null;\n        let maxValue = 50;\n        let minValue = 0;\n        let bucketCount = 5;\n        \n        // DOM elements\n        const arrayInput = document.getElementById('arrayInput');\n        const arraySize = document.getElementById('arraySize');\n        const arraySizeValue = document.getElementById('arraySizeValue');\n        const bucketCountInput = document.getElementById('bucketCount');\n        const bucketCountValue = document.getElementById('bucketCountValue');\n        const minValueInput = document.getElementById('minValue');\n        const maxValueInput = document.getElementById('maxValue');\n        const originalArrayDisplay = document.getElementById('originalArray');\n        const bucketsContainer = document.getElementById('bucketsContainer');\n        const sortedArrayDisplay = document.getElementById('sortedArray');\n        const stepDescription = document.getElementById('stepDescription');\n        const pseudocodeDiv = document.getElementById('pseudocode');\n        const bucketsSection = document.getElementById('bucketsSection');\n        const sortedArraySection = document.getElementById('sortedArraySection');\n        \n        // Event listeners\n        document.getElementById('setArray').addEventListener('click', setArrayFromInput);\n        document.getElementById('generateRandom').addEventListener('click', generateRandomArray);\n        document.getElementById('startSort').addEventListener('click', startBucketSort);\n        document.getElementById('nextStep').addEventListener('click', nextStep);\n        document.getElementById('autoStep').addEventListener('click', toggleAutoStep);\n        document.getElementById('reset').addEventListener('click', reset);\n        document.getElementById('showPseudocode').addEventListener('click', togglePseudocode);\n        \n        arraySize.addEventListener('input', () => {\n            arraySizeValue.textContent = arraySize.value;\n        });\n        \n        bucketCountInput.addEventListener('input', () => {\n            bucketCountValue.textContent = bucketCountInput.value;\n        });\n        \n        minValueInput.addEventListener('change', () => {\n            if (parseInt(minValueInput.value) >= parseInt(maxValueInput.value)) {\n                minValueInput.value = parseInt(maxValueInput.value) - 1;\n            }\n        });\n        \n        maxValueInput.addEventListener('change', () => {\n            if (parseInt(maxValueInput.value) <= parseInt(minValueInput.value)) {\n                maxValueInput.value = parseInt(minValueInput.value) + 1;\n            }\n        });\n        \n        // Initialize\n        updateOriginalArrayDisplay();\n        \n        // Functions\n        function setArrayFromInput() {\n            const input = arrayInput.value.trim();\n            originalArray = input.split(',').map(num => parseInt(num.trim()));\n            updateOriginalArrayDisplay();\n            resetSortState();\n        }\n        \n        function generateRandomArray() {\n            const size = parseInt(arraySize.value);\n            minValue = parseInt(minValueInput.value);\n            maxValue = parseInt(maxValueInput.value);\n            \n            originalArray = [];\n            for (let i = 0; i < size; i++) {\n                originalArray.push(Math.floor(Math.random() * (maxValue - minValue + 1)) + minValue);\n            }\n            \n            arrayInput.value = originalArray.join(',');\n            updateOriginalArrayDisplay();\n            resetSortState();\n        }\n        \n        function updateOriginalArrayDisplay() {\n            originalArrayDisplay.innerHTML = '';\n            originalArray.forEach(num => {\n                const item = document.createElement('div');\n                item.className = 'item';\n                item.textContent = num;\n                originalArrayDisplay.appendChild(item);\n            });\n        }\n        \n        function startBucketSort() {\n            if (originalArray.length === 0) {\n                alert('Please set an array first');\n                return;\n            }\n            \n            bucketCount = parseInt(bucketCountInput.value);\n            minValue = parseInt(minValueInput.value);\n            maxValue = parseInt(maxValueInput.value);\n            \n            // Initialize buckets\n            buckets = Array(bucketCount).fill().map(() => []);\n            currentStep = 1;\n            stepDescription.textContent = 'Step 1: Created empty buckets';\n            \n            // Show buckets section\n            bucketsSection.style.display = 'block';\n            sortedArraySection.style.display = 'none';\n            updateBucketsDisplay();\n        }\n        \n        function nextStep() {\n            if (currentStep) {\n                currentStep++;\n                \n                if (currentStep === 2) {\n                    // Scatter elements into buckets\n                    const range = (maxValue - minValue) / bucketCount;\n                    originalArray.forEach(num => {\n                        let bucketIndex = Math.floor((num - minValue) / range);\n                        if (bucketIndex >= bucketCount) bucketIndex = bucketCount - 1;\n                        buckets[bucketIndex].push(num);\n                    });\n                    stepDescription.textContent = `Step 2: Scattered elements into buckets based on range (${minValue}-${maxValue})`;\n                }\n                else if (currentStep === 3) {\n                    // Sort each bucket\n                    buckets.forEach(bucket => {\n                        insertionSort(bucket);\n                    });\n                    stepDescription.textContent = 'Step 3: Sorted each bucket (using insertion sort)';\n                }\n                else if (currentStep === 4) {\n                    // Concatenate buckets\n                    sortedArray = [];\n                    buckets.forEach(bucket => {\n                        sortedArray.push(...bucket);\n                    });\n                    stepDescription.textContent = 'Step 4: Concatenated all buckets to form sorted array';\n                    sortedArraySection.style.display = 'block';\n                    updateSortedArrayDisplay();\n                }\n                else if (currentStep > 4) {\n                    stepDescription.textContent = 'Sorting complete!';\n                    currentStep = 0;\n                    return;\n                }\n                \n                updateBucketsDisplay();\n            }\n        }\n        \n        function insertionSort(arr) {\n            for (let i = 1; i < arr.length; i++) {\n                let key = arr[i];\n                let j = i - 1;\n                \n                while (j >= 0 && arr[j] > key) {\n                    arr[j + 1] = arr[j];\n                    j--;\n                }\n                \n                arr[j + 1] = key;\n            }\n        }\n        \n        function updateBucketsDisplay() {\n            bucketsContainer.innerHTML = '';\n            \n            const range = (maxValue - minValue) / bucketCount;\n            \n            buckets.forEach((bucket, index) => {\n                const bucketDiv = document.createElement('div');\n                bucketDiv.className = 'bucket';\n                \n                const title = document.createElement('div');\n                title.className = 'bucket-title';\n                const lowerBound = minValue + index * range;\n                const upperBound = minValue + (index + 1) * range;\n                title.textContent = `Bucket ${index + 1}: ${lowerBound.toFixed(1)}-${upperBound.toFixed(1)}`;\n                bucketDiv.appendChild(title);\n                \n                const itemsDiv = document.createElement('div');\n                itemsDiv.className = 'bucket-items';\n                \n                bucket.forEach(num => {\n                    const item = document.createElement('div');\n                    item.className = 'item';\n                    item.textContent = num;\n                    itemsDiv.appendChild(item);\n                });\n                \n                bucketDiv.appendChild(itemsDiv);\n                bucketsContainer.appendChild(bucketDiv);\n            });\n        }\n        \n        function updateSortedArrayDisplay() {\n            sortedArrayDisplay.innerHTML = '';\n            sortedArray.forEach(num => {\n                const item = document.createElement('div');\n                item.className = 'item';\n                item.textContent = num;\n                sortedArrayDisplay.appendChild(item);\n            });\n        }\n        \n        function toggleAutoStep() {\n            if (autoStepInterval) {\n                clearInterval(autoStepInterval);\n                autoStepInterval = null;\n                document.getElementById('autoStep').textContent = 'Auto Step (500ms)';\n            } else {\n                if (currentStep === 0) {\n                    startBucketSort();\n                }\n                autoStepInterval = setInterval(() => {\n                    nextStep();\n                    if (currentStep === 0) {\n                        clearInterval(autoStepInterval);\n                        autoStep.textContent = 'Auto Step (500ms)';\n                    }\n                }, 500);\n                document.getElementById('autoStep').textContent = 'Stop Auto Step';\n            }\n        }\n        \n        function reset() {\n            clearInterval(autoStepInterval);\n            autoStepInterval = null;\n            document.getElementById('autoStep').textContent = 'Auto Step (500ms)';\n            \n            currentStep = 0;\n            buckets = [];\n            sortedArray = [];\n            \n            bucketsSection.style.display = 'none';\n            sortedArraySection.style.display = 'none';\n            stepDescription.textContent = 'Click \"Start Bucket Sort\" to begin the visualization.';\n            \n            updateOriginalArrayDisplay();\n        }\n        \n        function resetSortState() {\n            clearInterval(autoStepInterval);\n            autoStepInterval = null;\n            document.getElementById('autoStep').textContent = 'Auto Step (500ms)';\n            \n            currentStep = 0;\n            buckets = [];\n            sortedArray = [];\n            \n            bucketsSection.style.display = 'none';\n            sortedArraySection.style.display = 'none';\n            stepDescription.textContent = 'Click \"Start Bucket Sort\" to begin the visualization.';\n        }\n        \n        function togglePseudocode() {\n            if (pseudocodeDiv.style.display === 'none') {\n                pseudocodeDiv.style.display = 'block';\n                document.getElementById('showPseudocode').textContent = 'Hide Pseudocode';\n            } else {\n                pseudocodeDiv.style.display = 'none';\n                document.getElementById('showPseudocode').textContent = 'Show Pseudocode';\n            }\n        }\n    </script>\n</body>\n</html>"
  },
