    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Compiler Explorer - Interactive Demonstration</title>\n<style>\n  body {\n    background: white;\n    color: black;\n    font-family: monospace, monospace;\n    margin: 1em;\n  }\n  textarea, input, select, button {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    margin: 0.2em 0;\n  }\n  textarea {\n    width: 100%;\n    height: 8em;\n  }\n  select, input[type=number] {\n    width: auto;\n  }\n  fieldset {\n    margin-top: 1em;\n    padding: 0.5em;\n  }\n  legend {\n    font-weight: bold;\n  }\n  .output-area {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    padding: 0.5em;\n    height: 10em;\n    overflow: auto;\n  }\n  label {\n    display: block;\n    margin-top: 0.5em;\n  }\n</style>\n</head>\n<body>\n<h1>Compiler Interactive Demonstration</h1>\n\n<!-- The core concept here is to allow user to input code, apply multiple compiler phases, explore options per phase, and see results stepwise -->\n\n<!-- Section 1: Source Code Input -->\n<fieldset>\n  <legend>1. Enter Source Code (Mini Language)</legend>\n  <textarea id=\"sourceCode\" aria-label=\"Source code input\" spellcheck=\"false\">\n// Sample program:\n// let x = 10;\n// let y = 20;\n// let z = x + y;\nlet x = 5;\nlet y = 10;\nlet z = x + y * 2;\nprint(z);\n  </textarea>\n</fieldset>\n\n<!-- Section 2: Choose Compiler Frontend Language / Options -->\n<fieldset>\n  <legend>2. Select Frontend Language Flavor</legend>\n  <select id=\"frontendSelect\" aria-label=\"Select frontend language flavor\">\n    <option value=\"mini\">MiniLang Basic (let, print only)</option>\n    <option value=\"mini-extended\">MiniLang Extended (with comments, arithmetic)</option>\n  </select>\n  <label>\n    <input type=\"checkbox\" id=\"enableComments\" />\n    Enable comment stripping\n  </label>\n</fieldset>\n\n<!-- Section 3: Lexical Analysis Options -->\n<fieldset>\n  <legend>3. Lexical Analysis (Tokenizer) Options</legend>\n  <label>\n    Max token length:\n    <input type=\"number\" id=\"maxTokenLength\" min=\"1\" max=\"50\" value=\"20\" />\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"showTokens\" checked />\n    Show tokens after lexing\n  </label>\n  <button id=\"runLex\">Run Lexical Analysis</button>\n  <div id=\"lexOutput\" class=\"output-area\" aria-live=\"polite\" aria-relevant=\"additions\"></div>\n</fieldset>\n\n<!-- Section 4: Parsing Options -->\n<fieldset>\n  <legend>4. Parsing Options</legend>\n  <label>\n    Select parser type:\n    <select id=\"parserType\">\n      <option value=\"topdown\">Top-Down Recursive Descent</option>\n      <option value=\"bottomup\">Bottom-Up Shift-Reduce</option>\n    </select>\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"showParseTree\" checked />\n    Show simplified parse tree output\n  </label>\n  <button id=\"runParse\" disabled>Run Parsing</button>\n  <div id=\"parseOutput\" class=\"output-area\" aria-live=\"polite\"></div>\n</fieldset>\n\n<!-- Section 5: Semantic Analysis Options -->\n<fieldset>\n  <legend>5. Semantic Analysis / Name Binding</legend>\n  <label>\n    <input type=\"checkbox\" id=\"enableTypeCheck\" checked />\n    Enable simple type checking (ints only)\n  </label><br/>\n  <label>\n    <input type=\"checkbox\" id=\"showSemantic\" checked />\n    Show semantic analysis messages\n  </label><br/>\n  <button id=\"runSemantic\" disabled>Run Semantic Analysis</button>\n  <div id=\"semanticOutput\" class=\"output-area\" aria-live=\"polite\"></div>\n</fieldset>\n\n<!-- Section 6: Intermediate Representation (IR) Generation -->\n<fieldset>\n  <legend>6. Generate Intermediate Representation (IR)</legend>\n  <label>\n    IR Level:\n    <select id=\"irLevel\">\n      <option value=\"ast\">AST (Abstract Syntax Tree)</option>\n      <option value=\"threeaddr\">3-Address Code</option>\n    </select>\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"showIR\" checked />\n    Show IR output\n  </label><br/>\n  <button id=\"runIR\" disabled>Generate IR</button>\n  <div id=\"irOutput\" class=\"output-area\" aria-live=\"polite\"></div>\n</fieldset>\n\n<!-- Section 7: Optimization Options -->\n<fieldset>\n  <legend>7. Optimization Passes</legend>\n  <label>\n    <input type=\"checkbox\" id=\"optConstFold\" />\n    Constant Folding\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"optDeadCode\" />\n    Dead Code Elimination\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"optCopyProp\" />\n    Copy Propagation\n  </label><br/>\n  <button id=\"runOptimize\" disabled>Run Optimization</button>\n  <div id=\"optOutput\" class=\"output-area\" aria-live=\"polite\"></div>\n</fieldset>\n\n<!-- Section 8: Code Generation Options -->\n<fieldset>\n  <legend>8. Code Generation</legend>\n  <label>\n    Target assembly:\n    <select id=\"codeGenTarget\">\n      <option value=\"pseudoasm\">Pseudo Assembly</option>\n      <option value=\"js\">JavaScript</option>\n    </select>\n  </label><br/>\n  <button id=\"runCodeGen\" disabled>Generate Code</button>\n  <div id=\"codeGenOutput\" class=\"output-area\" aria-live=\"polite\"></div>\n</fieldset>\n\n<!-- Section 9: Interactive Workflow Control -->\n<fieldset>\n  <legend>9. Interactive Workflow Controls</legend>\n  <button id=\"resetAll\">Reset All</button>\n  <button id=\"stepAll\">Run Full Compile Pipeline</button><br/>\n  <label>\n    Auto-Step Delay (ms):\n    <input type=\"number\" id=\"autoStepDelay\" min=\"100\" max=\"5000\" value=\"700\" />\n  </label>\n</fieldset>\n\n<!-- Section 10: Detailed Logs / Diagnostics -->\n<fieldset>\n  <legend>10. Diagnostics & Logs</legend>\n  <label>\n    <input type=\"checkbox\" id=\"logTokens\" />\n    Log tokenization steps\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"logParseSteps\" />\n    Log parsing steps\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"logSemanticSteps\" />\n    Log semantic analysis steps\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"logIROptimize\" />\n    Log optimization steps\n  </label>\n  <label>\n    <input type=\"checkbox\" id=\"logCodeGen\" />\n    Log code generation steps\n  </label>\n  <button id=\"showLog\">Show Current Compilation Logs</button>\n  <div id=\"logOutput\" class=\"output-area\" aria-live=\"polite\" style=\"height:12em; overflow:auto;\"></div>\n</fieldset>\n\n<script>\n(() => {\n  // Basic mini language lexical tokens and structures\n  // Minimal lexer, parser, semantic analyzer and codegen for demonstration\n  // Will support let statements, arithmetic expressions with + and * and print statements\n\n  // State storage for each phase\n  const state = {\n    tokens: null,\n    parseTree: null,\n    semanticInfo: null,\n    ir: null,\n    optimizedIr: null,\n    generatedCode: null,\n    logs: [],\n    partialCode: ''\n  };\n\n  // Utility Logging\n  function log(phase, msg) {\n    const doLog = {\n      lex: document.getElementById('logTokens').checked,\n      parse: document.getElementById('logParseSteps').checked,\n      semantic: document.getElementById('logSemanticSteps').checked,\n      optimize: document.getElementById('logIROptimize').checked,\n      codegen: document.getElementById('logCodeGen').checked,\n    };\n    if(doLog[phase]) {\n      state.logs.push(`[${phase.toUpperCase()}] ${msg}`);\n    }\n  }\n\n  // Clear logs except if user wants to preserve\n  function clearLogs() {\n    state.logs = [];\n  }\n\n  // PHASE 1: Lexical Analysis\n  // Simple tokenizer: splits input into tokens (identifiers, numbers, operators, keywords, punctuation)\n  // Supports comments if enabled\n\n  function lex(sourceCode, options) {\n    clearLogs();\n    const enableComments = options.enableComments;\n    const maxTokenLength = options.maxTokenLength || 20;\n    let tokens = [];\n    let pos = 0;\n    let line = 1;\n    let col = 1;\n\n    function isLetter(c) {\n      return /^[A-Za-z_]$/.test(c);\n    }\n    function isDigit(c) {\n      return /^[0-9]$/.test(c);\n    }\n    function isWhitespace(c) {\n      return c === ' ' || c === '\\t' || c === '\\n' || c === '\\r';\n    }\n\n    while (pos < sourceCode.length) {\n      let ch = sourceCode[pos];\n      // Skip whitespace, track line/col\n      if(isWhitespace(ch)) {\n        if(ch === '\\n') {\n          line++;\n          col = 1;\n        } else {\n          col++;\n        }\n        pos++;\n        continue;\n      }\n      // Comments: if enableComments is true, strip from // to end of line\n      if(enableComments && ch === '/' && sourceCode[pos+1] === '/') {\n        while(pos < sourceCode.length && sourceCode[pos] !== '\\n') pos++;\n        continue;\n      }\n\n      // Identify token type\n      // Keywords: let, print\n      // Identifiers: letter followed by letter/digit/_\n      // Numbers: digit+\n      // Operators: +, *, =, (, ), ;, -\n\n      if(isLetter(ch)) {\n        let start = pos;\n        let val = ch;\n        pos++; col++;\n        while(pos < sourceCode.length && /[A-Za-z0-9_]/.test(sourceCode[pos])) {\n          val += sourceCode[pos];\n          pos++; col++;\n          if(val.length > maxTokenLength) break;\n        }\n        let kind = 'IDENT';\n        if(val === 'let') kind = 'LET';\n        else if(val === 'print') kind = 'PRINT';\n        tokens.push({type: kind, value: val, line, col: col - val.length});\n        log('lex', `Tokenized keyword/ident: ${val} (${kind}) at line ${line}, col ${col - val.length}`);\n        continue;\n      }\n      if(isDigit(ch)) {\n        let val = ch;\n        pos++; col++;\n        while(pos < sourceCode.length && isDigit(sourceCode[pos])) {\n          val += sourceCode[pos];\n          pos++; col++;\n          if(val.length > maxTokenLength) break;\n        }\n        tokens.push({type:'NUMBER', value: val, line, col: col - val.length});\n        log('lex', `Tokenized number: ${val} at line ${line}, col ${col - val.length}`);\n        continue;\n      }\n      // Operators and punctuation\n      const singleCharTokens = {\n        '+': 'PLUS',\n        '*': 'MULT',\n        '=': 'EQUAL',\n        '(': 'LPAREN',\n        ')': 'RPAREN',\n        ';': 'SEMICOLON',\n        '-': 'MINUS'\n      };\n      if(singleCharTokens.hasOwnProperty(ch)) {\n        tokens.push({type: singleCharTokens[ch], value: ch, line, col});\n        log('lex', `Tokenized operator: ${ch} (${singleCharTokens[ch]}) at line ${line}, col ${col}`);\n        pos++; col++;\n        continue;\n      }\n      // Unknown character\n      tokens.push({type:'UNKNOWN', value: ch, line, col});\n      log('lex', `Unknown char token: '${ch}' at line ${line}, col ${col}`);\n      pos++; col++;\n    }\n    return tokens;\n  }\n\n  // PHASE 2: Parsing\n  // Minimal parser to build AST for statements:\n  // Program -> StatementList\n  // StatementList -> Statement*\n  // Statement -> LetStatement | PrintStatement\n  // LetStatement -> 'let' IDENT '=' Expression ';'\n  // PrintStatement -> 'print' '(' Expression ')' ';'\n  // Expression -> Term (( '+' | '-' ) Term)*\n  // Term -> Factor ( '*' Factor)*\n  // Factor -> NUMBER | IDENT | '(' Expression ')'\n\n  // We'll implement both \"topdown\" and \"bottomup\" parsers in minimal forms\n  // For bottom-up, simulate simpler shift-reduce logic, mostly same AST but different internal approach (for demo)\n  // For both, produce a tree structure with line/col info for output\n\n  class Parser {\n    constructor(tokens, type) {\n      this.tokens = tokens;\n      this.pos = 0;\n      this.type = type || 'topdown';\n      this.logs = [];\n    }\n\n    current() {\n      return this.tokens[this.pos] || null;\n    }\n    advance() {\n      this.pos++;\n    }\n    match(type) {\n      const tok = this.current();\n      if(tok && tok.type === type) {\n        this.advance();\n        return tok;\n      }\n      return null;\n    }\n    error(expected) {\n      const cur = this.current();\n      const at = cur ? `line ${cur.line}, col ${cur.col}` : 'end of input';\n      throw new Error(`Parse error: expected ${expected} but found ${cur ? cur.type : 'EOF'} at ${at}`);\n    }\n    log(msg) {\n      this.logs.push(msg);\n    }\n\n    parseProgram() {\n      let stmts = [];\n      try {\n        while(this.pos < this.tokens.length) {\n          const stmt = this.parseStatement();\n          if(stmt) {\n            stmts.push(stmt);\n          } else {\n            // Avoid infinite loop on parsing failure\n            this.error('statement');\n          }\n        }\n      } catch(e) {\n        return {error: e.message, logs: this.logs};\n      }\n      return {type:'Program', body: stmts, logs: this.logs};\n    }\n\n    parseStatement() {\n      const tok = this.current();\n      if(!tok) return null;\n      if(tok.type === 'LET') return this.parseLetStatement();\n      else if(tok.type === 'PRINT') return this.parsePrintStatement();\n      else this.error('statement');\n    }\n\n    parseLetStatement() {\n      this.log(`Parsing LetStatement at pos ${this.pos}`);\n      this.match('LET') || this.error(\"'let'\");\n      const ident = this.match('IDENT') || this.error('identifier');\n      this.match('EQUAL') || this.error(\"'='\");\n      const expr = this.parseExpression();\n      this.match('SEMICOLON') || this.error(\"';'\");\n      return {type:'LetStatement', id: ident.value, expr, line: ident.line, col: ident.col};\n    }\n\n    parsePrintStatement() {\n      this.log(`Parsing PrintStatement at pos ${this.pos}`);\n      this.match('PRINT') || this.error(\"'print'\");\n      this.match('LPAREN') || this.error(\"'('\");\n      const expr = this.parseExpression();\n      this.match('RPAREN') || this.error(\"')'\");\n      this.match('SEMICOLON') || this.error(\"';'\");\n      return {type:'PrintStatement', expr, line: expr.line || 0, col: expr.col || 0};\n    }\n\n    parseExpression() {\n      this.log(`Parsing Expression at pos ${this.pos}`);\n      let node = this.parseTerm();\n      while(true) {\n        let tok = this.current();\n        if(tok && (tok.type === 'PLUS' || tok.type === 'MINUS')) {\n          this.advance();\n          let right = this.parseTerm();\n          node = {type:'BinaryOp', operator: tok.value, left: node, right, line: tok.line, col: tok.col};\n        } else break;\n      }\n      return node;\n    }\n\n    parseTerm() {\n      this.log(`Parsing Term at pos ${this.pos}`);\n      let node = this.parseFactor();\n      while(true) {\n        let tok = this.current();\n        if(tok && tok.type === 'MULT') {\n          this.advance();\n          let right = this.parseFactor();\n          node = {type:'BinaryOp', operator: '*', left: node, right, line: tok.line, col: tok.col};\n        } else break;\n      }\n      return node;\n    }\n\n    parseFactor() {\n      this.log(`Parsing Factor at pos ${this.pos}`);\n      let tok = this.current();\n      if(!tok) this.error('factor');\n      if(tok.type === 'NUMBER') {\n        this.advance();\n        return {type:'NumberLiteral', value: Number(tok.value), line: tok.line, col: tok.col};\n      }\n      if(tok.type === 'IDENT') {\n        this.advance();\n        return {type:'Identifier', name: tok.value, line: tok.line, col: tok.col};\n      }\n      if(tok.type === 'LPAREN') {\n        this.advance();\n        let expr = this.parseExpression();\n        this.match('RPAREN') || this.error(\"')'\");\n        return expr;\n      }\n      this.error('factor');\n    }\n  }\n\n  // Bottom-up parser minimal simulation (shift-reduce with manual stack)\n  // For demonstration, we parse statements one by one\n  // We will produce the same AST as topdown parser for simplicity\n  function bottomUpParse(tokens) {\n    // Very basic and naïve implementation: since the language is small, just call topdown parser here\n    // In real life, this would be a full LR parser\n    // We'll emulate different logs for demonstration\n    const logs = [];\n    let pos = 0;\n    const advancedTokens = tokens.slice();\n\n    function log(msg) { logs.push(msg); }\n\n    log(\"Bottom-Up Parser: Starting\");\n\n    // We'll just call the topdown parser since full bottom-up parser is complex\n    try {\n      const parser = new Parser(advancedTokens, 'bottomup');\n      const result = parser.parseProgram();\n      logs.push(...parser.logs);\n      return {ast: result, logs};\n    } catch(e) {\n      logs.push(\"Error: \" + e.message);\n      return {error: e.message, logs};\n    }\n  }\n\n  // PHASE 3: Semantic Analysis\n  // Simple semantic checks:\n  // - Variables must be declared before use\n  // - Types are all integers (only numbers)\n  // - Error on unknown identifiers or duplicate declaration\n  // We'll build a symbol table\n\n  function semanticAnalysis(ast, options) {\n    const enableTypeCheck = options.enableTypeCheck;\n    const showMessages = options.showSemantic;\n    let messages = [];\n    let symtab = new Map();\n\n    // Helper to traverse AST\n    function checkNode(node, scope) {\n      if(!node) return;\n\n      switch(node.type) {\n        case 'Program':\n          node.body.forEach(s => checkNode(s, scope));\n          break;\n        case 'LetStatement':\n          if(symtab.has(node.id)) {\n            messages.push(`Error: Duplicate declaration of variable '${node.id}' at line ${node.line}`);\n          }\n          symtab.set(node.id, 'int');\n          checkNode(node.expr, scope);\n          break;\n        case 'PrintStatement':\n          checkNode(node.expr, scope);\n          break;\n        case 'BinaryOp':\n          checkNode(node.left, scope);\n          checkNode(node.right, scope);\n          break;\n        case 'Identifier':\n          if(!symtab.has(node.name)) {\n            messages.push(`Error: Undeclared variable '${node.name}' at line ${node.line}`);\n          }\n          break;\n        case 'NumberLiteral':\n          // always int\n          break;\n        default:\n          messages.push(`Warning: Unknown node type '${node.type}'`);\n      }\n    }\n    checkNode(ast);\n    if(enableTypeCheck && messages.length === 0) {\n      messages.push(\"Semantic analysis passed without errors.\");\n    }\n    if(showMessages === false) {\n      messages.length = 0;\n    }\n    return {messages, symbolTable: symtab};\n  }\n\n  // PHASE 4: Intermediate Representation Generation\n  // Generate either:\n  // a) AST (for output)\n  // b) 3-Address Code (basic representation)\n\n  function generateIR(ast, level) {\n    // For AST, we just output the AST converted to formatted string\n    // For 3-address code, we traverse AST and generate instructions\n\n    if(level === 'ast') {\n      return JSON.stringify(ast, null, 2);\n    }\n\n    const instructions = [];\n    let tempCount = 0;\n\n    function newTemp() {\n      return `t${tempCount++}`;\n    }\n\n    // We'll compile expressions to 3-address code\n    // Statement => 3AC instructions\n\n    function irExpr(node) {\n      switch(node.type) {\n        case 'NumberLiteral':\n          return {code: [], place: node.value.toString()};\n        case 'Identifier':\n          return {code: [], place: node.name};\n        case 'BinaryOp': {\n          const left = irExpr(node.left);\n          const right = irExpr(node.right);\n          const temp = newTemp();\n          const code = [...left.code, ...right.code];\n          code.push(`${temp} = ${left.place} ${node.operator} ${right.place}`);\n          return {code, place: temp};\n        }\n        default:\n          throw new Error(`IR generation unknown node type ${node.type}`);\n      }\n    }\n\n    // Generate instructions for the statements of the program\n    ast.body.forEach(stmt => {\n      switch(stmt.type) {\n        case 'LetStatement': {\n          const exprResult = irExpr(stmt.expr);\n          instructions.push(...exprResult.code);\n          instructions.push(`${stmt.id} = ${exprResult.place}`);\n          break;\n        }\n        case 'PrintStatement': {\n          const exprResult = irExpr(stmt.expr);\n          instructions.push(...exprResult.code);\n          instructions.push(`print ${exprResult.place}`);\n          break;\n        }\n        default:\n          instructions.push(`// Unknown statement type in IR generation: ${stmt.type}`);\n      }\n    });\n    return instructions.join('\\n');\n  }\n\n  // PHASE 5: Optimizations\n  // Implement basic optimizations:\n  // - Constant Folding\n  // - Dead Code Elimination (simple elimination of assignments to vars never used afterwards)\n  // - Copy Propagation (very basic)\n\n  // For 3-address code optimization, we'll parse instructions and apply transforms\n  // Note: this is a rudimentary demo, not a production optimizer\n\n  function optimize3AddrCode(code, options) {\n    if (!code) return \"\";\n\n    const lines = code.split('\\n').map(l => l.trim()).filter(l => l !== '');\n    let logs = [];\n\n    // Parse lines into instructions: var = expr   or print var\n    // We'll track var usage to assist dead code elimination\n\n    const assignments = []; // {var, expr, lineIndex}\n    const prints = [];\n    const varUses = new Map(); // var -> usage count\n\n    // First pass: parse and count uses\n    lines.forEach((line, i) => {\n      if(line.startsWith('print ')) {\n        const v = line.slice(6).trim();\n        prints.push({var: v, lineIndex: i});\n        varUses.set(v, (varUses.get(v)||0) + 1);\n      } else {\n        // assignment\n        // e.g. t0 = x + y\n        const m = line.match(/^(\\w+)\\s*=\\s*(.+)$/);\n        if(m) {\n          const lhs = m[1];\n          const rhs = m[2];\n          assignments.push({var: lhs, expr: rhs, lineIndex: i});\n          // Find vars used in rhs\n          const varsInRhs = rhs.match(/\\b[a-zA-Z_]\\w*\\b/g) || [];\n          varsInRhs.forEach(v => {\n            if(v !== lhs) {\n              varUses.set(v, (varUses.get(v)||0) +1);\n            }\n          });\n          // Init lhs usage count if not already\n          if(!varUses.has(lhs)) varUses.set(lhs, 0);\n        } else {\n          logs.push(`Unrecognized instruction '${line}'`);\n        }\n      }\n    });\n\n    // Optimization 1: Constant Folding\n    // Find assignments where expr is constant operations and evaluate them\n\n    if(options.optConstFold) {\n      logs.push('Applying constant folding...');\n      const consts = new Map();\n      let changed;\n      do {\n        changed = false;\n        for(const assign of assignments) {\n          let val = null;\n          // Try to parse expr for simple constant expressions: num op num\n          // supports +, -, *\n          let m = assign.expr.match(/^(\\d+|\\w+)\\s*([\\+\\-\\*])\\s*(\\d+|\\w+)$/);\n          if(m) {\n            function valOf(token) {\n              if(/\\d+/.test(token)) return Number(token);\n              if(consts.has(token)) return consts.get(token);\n              return null;\n            }\n            let v1 = valOf(m[1]);\n            let op = m[2];\n            let v2 = valOf(m[3]);\n            if(v1 !== null && v2 !== null) {\n              switch(op) {\n                case '+': val = v1 + v2; break;\n                case '-': val = v1 - v2; break;\n                case '*': val = v1 * v2; break;\n              }\n            }\n          } else if(/^\\d+$/.test(assign.expr)) {\n            val = Number(assign.expr);\n          } else if(consts.has(assign.expr)) {\n            val = consts.get(assign.expr);\n          }\n          if(val !== null && (!consts.has(assign.var) || consts.get(assign.var) !== val)) {\n            consts.set(assign.var, val);\n            changed = true;\n            logs.push(`Constant folded ${assign.var} = ${val}`);\n          }\n        }\n      } while(changed);\n      // Rebuild code with constants substituted\n      for(let i=0;i<lines.length;i++) {\n        let line = lines[i];\n        let m = line.match(/^(\\w+)\\s*=\\s*(.+)$/);\n        if(m) {\n          let lhs = m[1];\n          let rhs = m[2];\n          // Replace any variable in rhs with const if present\n          rhs = rhs.replace(/\\b([a-zA-Z_]\\w*)\\b/g, (match, p1) => {\n            return consts.has(p1) ? consts.get(p1).toString() : p1;\n          });\n          lines[i] = `${lhs} = ${rhs}`;\n        } else if(line.startsWith('print ')) {\n          let v = line.slice(6).trim();\n          if(consts.has(v)) {\n            lines[i] = `print ${consts.get(v)}`;\n          }\n        }\n      }\n    }\n\n    // Optimization 2: Dead Code Elimination\n    if(options.optDeadCode) {\n      logs.push('Applying dead code elimination...');\n      // Remove assignments to variables never used (usage count zero)\n      assignments.forEach(({var: v, lineIndex}) => {\n        if(varUses.get(v) === 0) {\n          logs.push(`Eliminating dead assignment to '${v}' at line ${lineIndex +1}`);\n          lines[lineIndex] = `// (dead code eliminated)`;\n        }\n      });\n    }\n\n    // Optimization 3: Copy Propagation\n    if(options.optCopyProp) {\n      logs.push('Applying copy propagation...');\n      // copy propagation of simple assignments: t = x; replace all occurrences of t with x\n      // We'll do a simple one pass here.\n\n      // build copy map var->var\n      let copyMap = new Map();\n      assignments.forEach(({var:v, expr, lineIndex}) => {\n        let m = expr.match(/^(\\w+)$/);\n        if(m) {\n          let src = m[1];\n          copyMap.set(v, src);\n          logs.push(`Copy detected: ${v} = ${src}`);\n        }\n      });\n      // propagate copies transitively\n      let changed;\n      do {\n        changed = false;\n        copyMap.forEach( (val,key) => {\n          if(copyMap.has(val) && copyMap.get(val) !== val) {\n            copyMap.set(key, copyMap.get(val));\n            changed = true;\n          }\n        });\n      } while(changed);\n\n      // substitute occurrences\n      lines = lines.map(line => {\n        if(line.startsWith('//')) return line;\n        return line.replace(/\\b([a-zA-Z_]\\w*)\\b/g, (match, p1) => {\n          let rep = copyMap.get(p1);\n          return rep && rep !== p1 ? rep : p1;\n        });\n      });\n    }\n\n    return {code: lines.join('\\n'), logs};\n  }\n\n  // PHASE 6: Code Generation\n  // Two targets: Pseudo Assembly or JavaScript\n  // Pseudo Assembly: simple 3AC style instructions mapped to assembly-like lines\n  // JavaScript: translate code into JS statements\n\n  function generateCode(irCode, target, options) {\n    let lines = irCode.split('\\n').filter(l => !l.startsWith('//') && l.trim() !== '');\n    let logs = [];\n    if(target === 'pseudoasm') {\n      // Map to very simple pseudo assembly instructions\n      // tX = a + b  => LOAD a; ADD b; STORE tX\n      // let x = tX => MOV tX, x\n      // Using stack machine simulation is too complex here, keep it basic\n\n      let asmLines = [];\n\n      lines.forEach(line => {\n        let m = line.match(/^(\\w+)\\s*=\\s*(.+)$/);\n        if(m) {\n          let dst = m[1];\n          let rhs = m[2];\n          let binOp = rhs.match(/^(\\w+)\\s*([\\+\\-\\*])\\s*(\\w+)$/);\n          if(binOp) {\n            // arithmetic operation\n            asmLines.push(`LOAD ${binOp[1]}`);\n            switch(binOp[2]) {\n              case '+': asmLines.push(`ADD ${binOp[3]}`); break;\n              case '-': asmLines.push(`SUB ${binOp[3]}`); break;\n              case '*': asmLines.push(`MUL ${binOp[3]}`); break;\n            }\n            asmLines.push(`STORE ${dst}`);\n            logs.push(`Generated asm for '${line}'`);\n          } else {\n            // direct assign\n            asmLines.push(`MOV ${rhs} ${dst}`);\n            logs.push(`Generated asm for '${line}'`);\n          }\n        } else if(line.startsWith('print ')) {\n          let v = line.slice(6).trim();\n          asmLines.push(`PRINT ${v}`);\n          logs.push(`Generated asm print for '${line}'`);\n        }\n      });\n      return {code: asmLines.join('\\n'), logs};\n    } else if(target === 'js') {\n      // Generate JS code\n      // print expr => console.log(expr);\n\n      let jsLines = [];\n      lines.forEach(line => {\n        if(line.startsWith('print ')) {\n          let v = line.slice(6).trim();\n          jsLines.push(`console.log(${v});`);\n          logs.push(`Generated JS console.log for '${line}'`);\n        } else {\n          let m = line.match(/^(\\w+)\\s*=\\s*(.+)$/);\n          if(m) {\n            let dst = m[1];\n            let rhs = m[2];\n            jsLines.push(`let ${dst} = ${rhs};`);\n            logs.push(`Generated JS assignment for '${line}'`);\n          }\n        }\n      });\n      return {code: jsLines.join('\\n'), logs};\n    }\n    return {code:'', logs};\n  }\n\n  // DOM elements references for interaction\n  const sourceCodeEl = document.getElementById('sourceCode');\n  const frontendSelectEl = document.getElementById('frontendSelect');\n  const enableCommentsEl = document.getElementById('enableComments');\n  const maxTokenLengthEl = document.getElementById('maxTokenLength');\n  const showTokensEl = document.getElementById('showTokens');\n  const lexOutputEl = document.getElementById('lexOutput');\n  const runLexBtn = document.getElementById('runLex');\n\n  const parserTypeEl = document.getElementById('parserType');\n  const showParseTreeEl = document.getElementById('showParseTree');\n  const runParseBtn = document.getElementById('runParse');\n\n  const enableTypeCheckEl = document.getElementById('enableTypeCheck');\n  const showSemanticEl = document.getElementById('showSemantic');\n  const runSemanticBtn = document.getElementById('runSemantic');\n  const semanticOutputEl = document.getElementById('semanticOutput');\n\n  const irLevelEl = document.getElementById('irLevel');\n  const showIREl = document.getElementById('showIR');\n  const runIRBtn = document.getElementById('runIR');\n  const irOutputEl = document.getElementById('irOutput');\n\n  const optConstFoldEl = document.getElementById('optConstFold');\n  const optDeadCodeEl = document.getElementById('optDeadCode');\n  const optCopyPropEl = document.getElementById('optCopyProp');\n  const runOptimizeBtn = document.getElementById('runOptimize');\n  const optOutputEl = document.getElementById('optOutput');\n\n  const codeGenTargetEl = document.getElementById('codeGenTarget');\n  const runCodeGenBtn = document.getElementById('runCodeGen');\n  const codeGenOutputEl = document.getElementById('codeGenOutput');\n\n  const resetAllBtn = document.getElementById('resetAll');\n  const stepAllBtn = document.getElementById('stepAll');\n  const autoStepDelayEl = document.getElementById('autoStepDelay');\n\n  const logTokensEl = document.getElementById('logTokens');\n  const logParseStepsEl = document.getElementById('logParseSteps');\n  const logSemanticStepsEl = document.getElementById('logSemanticSteps');\n  const logIROptimizeEl = document.getElementById('logIROptimize');\n  const logCodeGenEl = document.getElementById('logCodeGen');\n  const showLogBtn = document.getElementById('showLog');\n  const logOutputEl = document.getElementById('logOutput');\n\n  // Enable/disable buttons dependent on previous phase completion\n  function updateButtonStates() {\n    runParseBtn.disabled = !state.tokens;\n    runSemanticBtn.disabled = !state.parseTree || state.parseTree.error;\n    runIRBtn.disabled = !state.semanticInfo || (state.semanticInfo.messages && state.semanticInfo.messages.some(msg => msg.startsWith('Error')));\n    runOptimizeBtn.disabled = !state.ir;\n    runCodeGenBtn.disabled = !state.optimizedIr && !state.ir;\n  }\n\n  // Display tokens nicely\n  function displayTokens(tokens) {\n    if(!tokens) return '';\n    return tokens.map(t => `${t.type} ('${t.value}') at line ${t.line}, col ${t.col}`).join('\\n');\n  }\n\n  // Display parse tree simplified\n  function simpleTreeString(node, indent='') {\n    if(!node) return '';\n    if(typeof node !== 'object') return indent + node + \"\\n\";\n    let s = indent + (node.type || 'UNKNOWN') + ' ';\n    if(node.id) s += node.id;\n    if(node.name) s += node.name;\n    if(node.value !== undefined) s += node.value;\n    s += '\\n';\n    Object.keys(node).forEach(k => {\n      if(k !== 'type' && k !== 'id' && k !== 'name' && k !== 'value' && k !== 'line' && k !== 'col') {\n        const child = node[k];\n        if(Array.isArray(child)) {\n          s += indent + '  ' + k + ':\\n';\n          child.forEach(c => { s += simpleTreeString(c, indent + '    '); });\n        } else if(typeof child === 'object') {\n          s += indent + '  ' + k + ':\\n' + simpleTreeString(child, indent + '    ');\n        }\n      }\n    });\n    return s;\n  }\n\n  // Button event handlers\n\n  runLexBtn.addEventListener('click', () => {\n    const source = sourceCodeEl.value;\n    const frontend = frontendSelectEl.value;\n    const enableComments = enableCommentsEl.checked;\n    const maxTokenLength = Number(maxTokenLengthEl.value);\n\n    state.tokens = lex(source, {enableComments, maxTokenLength});\n    state.parseTree = null;\n    state.semanticInfo = null;\n    state.ir = null;\n    state.optimizedIr = null;\n    state.generatedCode = null;\n\n    updateButtonStates();\n\n    if(showTokensEl.checked) {\n      lexOutputEl.textContent = displayTokens(state.tokens);\n    } else {\n      lexOutputEl.textContent = `[${state.tokens.length}] tokens generated.`;\n    }\n  });\n\n  runParseBtn.addEventListener('click', () => {\n    if(!state.tokens) {\n      alert('Please run lexical analysis first.');\n      return;\n    }\n    const parserType = parserTypeEl.value;\n    if(parserType === 'topdown') {\n      try {\n        const parser = new Parser(state.tokens, 'topdown');\n        const result = parser.parseProgram();\n        state.parseTree = result.error ? null : result;\n        let out = '';\n        if(showParseTreeEl.checked && !result.error) {\n          out = simpleTreeString(state.parseTree);\n        } else if(result.error) {\n          out = 'Parse Error: ' + result.error;\n        } else {\n          out = 'Parsing succeeded, parse tree not shown.';\n        }\n        parseOutputEl.textContent = out;\n      } catch(e) {\n        parseOutputEl.textContent = 'Parse Exception: ' + e.message;\n        state.parseTree = null;\n      }\n    } else if(parserType === 'bottomup') {\n      // run bottom up parser simulation\n      const result = bottomUpParse(state.tokens);\n      if(result.ast.error) {\n        parseOutputEl.textContent = 'Parse Error: ' + result.ast.error;\n        state.parseTree = null;\n      } else {\n        state.parseTree = result.ast;\n        let out = '';\n        if(showParseTreeEl.checked){\n          out = simpleTreeString(state.parseTree);\n        } else {\n          out = 'Parsing succeeded, parse tree not shown.';\n        }\n        parseOutputEl.textContent = out + '\\n\\n[Logs]\\n' + result.logs.join('\\n');\n      }\n    }\n    state.semanticInfo = null;\n    state.ir = null;\n    state.optimizedIr = null;\n    state.generatedCode = null;\n    updateButtonStates();\n  });\n\n  runSemanticBtn.addEventListener('click', () => {\n    if(!state.parseTree) {\n      alert('Please run parsing first.');\n      return;\n    }\n    const enableTypeCheck = enableTypeCheckEl.checked;\n    const showSemantic = showSemanticEl.checked;\n    const result = semanticAnalysis(state.parseTree, {enableTypeCheck, showSemantic});\n    state.semanticInfo = result;\n    semanticOutputEl.textContent = result.messages.join('\\n');\n    state.ir = null;\n    state.optimizedIr = null;\n    state.generatedCode = null;\n    updateButtonStates();\n  });\n\n  runIRBtn.addEventListener('click', () => {\n    if(!state.semanticInfo) {\n      alert('Please run semantic analysis first.');\n      return;\n    }\n    // Check errors\n    if(state.semanticInfo.messages.some(m => m.startsWith('Error'))) {\n      alert('Semantic errors present, cannot generate IR.');\n      return;\n    }\n    const irLevel = irLevelEl.value;\n    const irString = generateIR(state.parseTree, irLevel);\n    state.ir = irString;\n    irOutputEl.textContent = showIREl.checked ? irString : `[IR generated, length ${irString.length} chars]`;\n    state.optimizedIr = null;\n    state.generatedCode = null;\n    updateButtonStates();\n  });\n\n  runOptimizeBtn.addEventListener('click', () => {\n    if(!state.ir) {\n      alert('Please generate IR first.');\n      return;\n    }\n    const optConstFold = optConstFoldEl.checked;\n    const optDeadCode = optDeadCodeEl.checked;\n    const optCopyProp = optCopyPropEl.checked;\n    const opts = {\n      optConstFold, optDeadCode, optCopyProp\n    };\n    const res = optimize3AddrCode(state.ir, opts);\n    state.optimizedIr = res.code;\n    optOutputEl.textContent = res.code + (res.logs.length ? '\\n\\nLogs:\\n' + res.logs.join('\\n') : '');\n    state.generatedCode = null;\n    updateButtonStates();\n  });\n\n  runCodeGenBtn.addEventListener('click', () => {\n    if(!state.ir && !state.optimizedIr) {\n      alert('Please generate IR or optimized IR first.');\n      return;\n    }\n    const target = codeGenTargetEl.value;\n    const irCode = state.optimizedIr || state.ir;\n    const res = generateCode(irCode, target, {});\n    state.generatedCode = res.code;\n    codeGenOutputEl.textContent = res.code + (res.logs.length ? '\\n\\nLogs:\\n' + res.logs.join('\\n') : '');\n  });\n\n  resetAllBtn.addEventListener('click', () => {\n    state.tokens = null;\n    state.parseTree = null;\n    state.semanticInfo = null;\n    state.ir = null;\n    state.optimizedIr = null;\n    state.generatedCode = null;\n    state.logs = [];\n    lexOutputEl.textContent = '';\n    parseOutputEl.textContent = '';\n    semanticOutputEl.textContent = '';\n    irOutputEl.textContent = '';\n    optOutputEl.textContent = '';\n    codeGenOutputEl.textContent = '';\n    logOutputEl.textContent = '';\n    updateButtonStates();\n  });\n\n  showLogBtn.addEventListener('click', () => {\n    logOutputEl.textContent = state.logs.length ? state.logs.join('\\n') : '[No logs available]';\n  });\n\n  // Full pipeline runner with step delay and interruptible\n  stepAllBtn.addEventListener('click', () => {\n    const delay = Number(autoStepDelayEl.value);\n    resetAllBtn.click();\n    const source = sourceCodeEl.value;\n    const enableComments = enableCommentsEl.checked;\n    const maxTokenLength = Number(maxTokenLengthEl.value);\n    const parserType = parserTypeEl.value;\n    const enableTypeCheck = enableTypeCheckEl.checked;\n    const showSemantic = showSemanticEl.checked;\n    const irLevel = irLevelEl.value;\n    const optConstFold = optConstFoldEl.checked;\n    const optDeadCode = optDeadCodeEl.checked;\n    const optCopyProp = optCopyPropEl.checked;\n    const target = codeGenTargetEl.value;\n\n    async function stepRun() {\n      lexOutputEl.textContent = 'Lexing...';\n      await new Promise(r => setTimeout(r, delay));\n      state.tokens = lex(source, {enableComments,maxTokenLength});\n      if(showTokensEl.checked) lexOutputEl.textContent = displayTokens(state.tokens);\n      else lexOutputEl.textContent = `[${state.tokens.length}] tokens generated.`;\n      updateButtonStates();\n\n      await new Promise(r => setTimeout(r, delay));\n      parseOutputEl.textContent = 'Parsing...';\n      await new Promise(r => setTimeout(r, delay));\n      if(parserType === 'topdown') {\n        try {\n          const parser = new Parser(state.tokens, 'topdown');\n          const result = parser.parseProgram();\n          state.parseTree = result.error ? null : result;\n          if(showParseTreeEl.checked && !result.error) {\n            parseOutputEl.textContent = simpleTreeString(state.parseTree);\n          } else if(result.error) {\n            parseOutputEl.textContent = 'Parse Error: ' + result.error;\n          } else {\n            parseOutputEl.textContent = 'Parsing succeeded, parse tree not shown.';\n          }\n        } catch(e) {\n          parseOutputEl.textContent = e.message;\n          state.parseTree = null;\n        }\n      } else {\n        const result = bottomUpParse(state.tokens);\n        if(result.ast.error) {\n          parseOutputEl.textContent = 'Parse Error: ' + result.ast.error;\n          state.parseTree = null;\n        } else {\n          state.parseTree = result.ast;\n          if(showParseTreeEl.checked) {\n            parseOutputEl.textContent = simpleTreeString(state.parseTree);\n          } else {\n            parseOutputEl.textContent = 'Parsing succeeded, parse tree not shown.';\n          }\n        }\n      }\n      updateButtonStates();\n      await new Promise(r => setTimeout(r, delay));\n      semanticOutputEl.textContent = 'Semantic analysis...';\n      if(state.parseTree){\n        const result = semanticAnalysis(state.parseTree, {enableTypeCheck, showSemantic});\n        state.semanticInfo = result;\n        semanticOutputEl.textContent = result.messages.join('\\n');\n      } else {\n        semanticOutputEl.textContent = 'Semantic analysis skipped due to parse error.';\n      }\n      updateButtonStates();\n      await new Promise(r => setTimeout(r, delay));\n      if(state.semanticInfo && !state.semanticInfo.messages.some(m => m.startsWith('Error'))) {\n        irOutputEl.textContent = 'Generating IR...';\n        await new Promise(r => setTimeout(r, delay));\n        const irString = generateIR(state.parseTree, irLevel);\n        state.ir = irString;\n        irOutputEl.textContent = showIREl.checked ? irString : `[IR generated, length ${irString.length} chars]`;\n        updateButtonStates();\n      } else {\n        irOutputEl.textContent = 'IR generation skipped due to semantic errors.';\n      }\n      await new Promise(r => setTimeout(r, delay));\n      if(state.ir) {\n        optOutputEl.textContent = 'Running optimizations...';\n        await new Promise(r => setTimeout(r, delay));\n        const opts = {optConstFold, optDeadCode, optCopyProp};\n        const res = optimize3AddrCode(state.ir, opts);\n        state.optimizedIr = res.code;\n        optOutputEl.textContent = res.code + (res.logs.length ? '\\n\\nLogs:\\n' + res.logs.join('\\n') : '');\n        updateButtonStates();\n      } else {\n        optOutputEl.textContent = 'Optimization skipped due to missing IR.';\n      }\n      await new Promise(r => setTimeout(r, delay));\n      if(state.optimizedIr) {\n        codeGenOutputEl.textContent = 'Generating code...';\n        await new Promise(r => setTimeout(r, delay));\n        const res = generateCode(state.optimizedIr, target, {});\n        state.generatedCode = res.code;\n        codeGenOutputEl.textContent = res.code + (res.logs.length ? '\\n\\nLogs:\\n' + res.logs.join('\\n') : '');\n      } else if(state.ir){\n        codeGenOutputEl.textContent = 'Generating code (from unoptimized IR)...';\n        await new Promise(r => setTimeout(r, delay));\n        const res = generateCode(state.ir, target, {});\n        state.generatedCode = res.code;\n        codeGenOutputEl.textContent = res.code + (res.logs.length ? '\\n\\nLogs:\\n' + res.logs.join('\\n') : '');\n      } else {\n        codeGenOutputEl.textContent = 'Code generation skipped due to missing IR.';\n      }\n    }\n    stepRun();\n  });\n\n  // Initial button states\n  updateButtonStates();\n\n  // Accessibility: set aria labels dynamically or states\n  sourceCodeEl.setAttribute('aria-multiline', 'true');\n})();\n</script>\n</body>\n</html>"
