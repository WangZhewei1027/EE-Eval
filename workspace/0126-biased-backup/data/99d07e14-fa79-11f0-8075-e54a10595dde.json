    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Socket Programming Demo</title>\n    <script>\n        let socket;\n        \n        function initSocket() {\n            socket = new WebSocket('ws://localhost:8080');\n\n            socket.onopen = function() {\n                updateStatus(\"Socket connected.\");\n            };\n\n            socket.onmessage = function(event) {\n                updateResponse(event.data);\n            };\n\n            socket.onclose = function() {\n                updateStatus(\"Socket disconnected.\");\n            };\n            \n            socket.onerror = function(error) {\n                updateStatus(\"Socket error: \" + error.message);\n            };\n        }\n\n        function updateStatus(status) {\n            document.getElementById('status').innerText = status;\n        }\n\n        function updateResponse(response) {\n            const responseContainer = document.getElementById('response');\n            responseContainer.innerText += response + '\\n';\n        }\n\n        function sendMessage() {\n            const messageInput = document.getElementById('messageInput');\n            const message = messageInput.value;\n            if (message && socket) {\n                socket.send(message);\n                messageInput.value = '';\n                updateResponse('You: ' + message);\n            }\n        }\n\n        function closeSocket() {\n            if (socket) {\n                socket.close();\n            }\n        }\n\n        function setCustomMessage() {\n            const customMessage = document.getElementById('customMessageInput').value;\n            document.getElementById('messageInput').value = customMessage;\n        }\n\n        function changeMessagePriority() {\n            const priorityLevel = document.getElementById('prioritySlider').value;\n            document.getElementById('priorityDisplay').innerText = \"Priority Level: \" + priorityLevel;\n            const message = `Priority Level: ${priorityLevel}`;\n            if (socket && socket.readyState === WebSocket.OPEN) {\n                socket.send(message);\n                updateResponse(`Sent: ${message}`);\n            }\n        }\n\n        window.onload = function() {\n            initSocket();\n        }\n    </script>\n</head>\n<body>\n    <h1>Socket Programming Demo</h1>\n    <div id=\"status\">Socket not connected.</div>\n    <textarea id=\"response\" rows=\"10\" cols=\"30\" readonly></textarea><br/>\n    <input type=\"text\" id=\"messageInput\" placeholder=\"Type your message\"/>\n    <button onclick=\"sendMessage()\">Send Message</button><br/>\n    \n    <h2>Custom Message Control</h2>\n    <input type=\"text\" id=\"customMessageInput\" placeholder=\"Set custom message\"/>\n    <button onclick=\"setCustomMessage()\">Set Custom Message</button><br/>\n  \n    <h2>Priority Control</h2>\n    <input type=\"range\" id=\"prioritySlider\" min=\"1\" max=\"10\" onchange=\"changeMessagePriority()\"/>\n    <div id=\"priorityDisplay\">Priority Level: 5</div><br/>\n\n    <button onclick=\"closeSocket()\">Close Socket</button>\n</body>\n</html>"
