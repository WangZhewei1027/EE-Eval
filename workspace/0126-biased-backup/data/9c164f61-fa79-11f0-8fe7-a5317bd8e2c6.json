  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Refactoring Playground</title>\n<style>\n/* Minimal styling just to provide basic layout; visual design is intentionally plain */\nhtml,body { height:100%; margin:8px; font-family: monospace; color: black; background: white; }\n.container { display:flex; gap:8px; height: calc(100% - 16px); }\n.panel { border: 1px solid #000; padding:6px; box-sizing:border-box; overflow:auto; background: white; }\n.left { width: 18%; min-width:200px; }\n.center { width: 46%; min-width:360px; display:flex; flex-direction:column; }\n.right { width: 36%; min-width:320px; }\ntextarea { width:100%; height:320px; box-sizing:border-box; font-family: monospace; font-size:12px; }\ninput[type=\"text\"], input[type=\"number\"], select { width:100%; box-sizing:border-box; font-family: monospace; margin-top:4px; margin-bottom:4px;}\nbutton { margin:2px 0; display:block; width:100%; }\n.smallbtn { width:auto; display:inline-block; margin-right:4px; }\n.flexrow { display:flex; gap:6px; align-items:center; }\n.kv { margin:2px 0; }\n.mini { font-size:11px; }\n.diff { white-space: pre; font-family: monospace; font-size:12px; border:1px solid #000; padding:4px; }\n.history-list { max-height:180px; overflow:auto; border:1px solid #000; padding:4px; }\n.op-queue { max-height:160px; overflow:auto; border:1px solid #000; padding:4px; }\n.note { font-size:12px; margin-top:6px; }\n</style>\n</head>\n<body>\n<h2>Refactoring Playground (Minimal UI)</h2>\n<p class=\"note\">This is an interactive sandbox to explore refactoring operations: rename, extract, inline, split/merge files, branches, snapshots, diffs, suggestions, tests, and transformation scripting. Use the controls to manipulate files and apply refactors. The UI is intentionally plain.</p>\n<div class=\"container\">\n  <div class=\"panel left\">\n    <h3>Files</h3>\n    <div id=\"fileList\"></div>\n    <div class=\"kv\">\n      <button id=\"newFileBtn\">New File</button>\n      <button id=\"cloneFileBtn\">Clone File</button>\n      <button id=\"deleteFileBtn\">Delete File</button>\n      <button id=\"renameFileBtn\">Rename File</button>\n    </div>\n    <div class=\"kv\">\n      <label>Open file version (snapshot id, optional):</label>\n      <input type=\"text\" id=\"openSnapshotId\" placeholder=\"leave empty for current branch\">\n      <button id=\"openSnapshotBtn\">Open Snapshot File View</button>\n    </div>\n\n    <h3>Branches & Snapshots</h3>\n    <div class=\"kv\">\n      <input type=\"text\" id=\"branchNameInput\" placeholder=\"branch name\">\n      <button id=\"createBranchBtn\">Create Branch</button>\n      <button id=\"switchBranchBtn\">Switch Branch</button>\n    </div>\n    <div class=\"kv\">\n      <button id=\"saveSnapshotBtn\">Save Snapshot</button>\n      <button id=\"listSnapshotsBtn\">List Snapshots</button>\n    </div>\n    <div class=\"kv\">\n      <label>Merge branch into current:</label>\n      <select id=\"mergeBranchSelect\"></select>\n      <button id=\"mergeBtn\">Merge</button>\n    </div>\n    <h4>Snapshot History</h4>\n    <div id=\"snapshots\" class=\"history-list\"></div>\n  </div>\n\n  <div class=\"panel center\">\n    <h3>Editor</h3>\n    <div class=\"flexrow\">\n      <label>Open: <span id=\"currentFileLabel\"></span></label>\n      <div style=\"flex:1\"></div>\n      <button id=\"saveBtn\" class=\"smallbtn\">Save</button>\n      <button id=\"revertBtn\" class=\"smallbtn\">Revert</button>\n    </div>\n    <textarea id=\"editor\" spellcheck=\"false\"></textarea>\n    <div class=\"flexrow\">\n      <label>Selection lines:</label>\n      <span id=\"selInfo\" style=\"width:120px\"></span>\n      <button id=\"selectLinesBtn\" class=\"smallbtn\">Describe Selection</button>\n      <button id=\"commentSelectionBtn\" class=\"smallbtn\">Toggle Comment</button>\n    </div>\n\n    <h3>Operation Queue (Plan & Replay)</h3>\n    <div>\n      <select id=\"opType\">\n        <option value=\"rename\">Rename Symbol</option>\n        <option value=\"extract\">Extract Function</option>\n        <option value=\"inline\">Inline Variable</option>\n        <option value=\"replace\">Regex Replace</option>\n        <option value=\"split\">Split File</option>\n        <option value=\"mergeFiles\">Merge Files Into New</option>\n      </select>\n      <button id=\"prepareOpBtn\" class=\"smallbtn\">Prepare Operation</button>\n      <button id=\"applyNextOpBtn\" class=\"smallbtn\">Apply Next</button>\n      <button id=\"applyAllOpsBtn\" class=\"smallbtn\">Apply All</button>\n      <button id=\"clearOpsBtn\" class=\"smallbtn\">Clear Queue</button>\n    </div>\n    <div id=\"opQueue\" class=\"op-queue\"></div>\n    <div class=\"flexrow\">\n      <button id=\"undoBtn\" class=\"smallbtn\">Undo</button>\n      <button id=\"redoBtn\" class=\"smallbtn\">Redo</button>\n      <button id=\"replayBtn\" class=\"smallbtn\">Replay Timeline</button>\n    </div>\n  </div>\n\n  <div class=\"panel right\">\n    <h3>Refactor Tools</h3>\n\n    <div>\n      <h4>Rename Symbol</h4>\n      <label>Old name:</label>\n      <input id=\"renameOld\" type=\"text\">\n      <label>New name:</label>\n      <input id=\"renameNew\" type=\"text\">\n      <label>Scope:\n        <select id=\"renameScope\">\n          <option value=\"file\">Current File</option>\n          <option value=\"project\">Entire Project</option>\n          <option value=\"function\">Current Function</option>\n        </select>\n      </label>\n      <button id=\"previewRenameBtn\">Preview Rename</button>\n      <button id=\"applyRenameBtn\">Apply Rename</button>\n      <div id=\"previewRenameDiff\" class=\"diff\"></div>\n    </div>\n\n    <div>\n      <h4>Extract Function</h4>\n      <label>New function name:</label>\n      <input id=\"extractName\" type=\"text\" placeholder=\"extractedFunc\">\n      <label>Destination file:</label>\n      <select id=\"extractDest\"></select>\n      <button id=\"previewExtractBtn\">Preview Extract</button>\n      <button id=\"applyExtractBtn\">Apply Extract</button>\n      <div id=\"previewExtractDiff\" class=\"diff\"></div>\n    </div>\n\n    <div>\n      <h4>Inline Variable</h4>\n      <label>Variable name to inline:</label>\n      <input id=\"inlineVar\" type=\"text\">\n      <label>Scope:</label>\n      <select id=\"inlineScope\">\n        <option value=\"file\">Current File</option>\n        <option value=\"project\">Project-wide</option>\n      </select>\n      <button id=\"previewInlineBtn\">Preview Inline</button>\n      <button id=\"applyInlineBtn\">Apply Inline</button>\n      <div id=\"previewInlineDiff\" class=\"diff\"></div>\n    </div>\n\n    <div>\n      <h4>Find Duplicates & Suggestions</h4>\n      <label>Minimum block lines:</label>\n      <input id=\"dupMinLines\" type=\"number\" value=\"3\">\n      <button id=\"runAnalysisBtn\">Run Analysis</button>\n      <div id=\"analysisOutput\" class=\"diff\"></div>\n    </div>\n\n    <div>\n      <h4>Split / Merge</h4>\n      <label>Split at line (current file):</label>\n      <input id=\"splitLineNo\" type=\"number\" value=\"10\">\n      <label>New file name:</label>\n      <input id=\"splitNewName\" type=\"text\" placeholder=\"part.js\">\n      <button id=\"previewSplitBtn\">Preview Split</button>\n      <button id=\"applySplitBtn\">Apply Split</button>\n      <div id=\"previewSplitDiff\" class=\"diff\"></div>\n    </div>\n\n    <div>\n      <h4>Transformation Script</h4>\n      <label>Simple DSL (one command per line):</label>\n      <textarea id=\"transformScript\" style=\"height:80px;\">replace util.js /console\\.log\\(/console.info(/g\nreplace app.js /foo\\(/bar(/g</textarea>\n      <button id=\"runScriptBtn\">Run Script (Preview)</button>\n      <button id=\"applyScriptBtn\">Apply Script</button>\n      <div id=\"scriptPreview\" class=\"diff\"></div>\n    </div>\n\n    <h3>Merge Conflict Resolver</h3>\n    <div>\n      <label>Conflict editor (choose lines to keep):</label>\n      <div id=\"mergeEditor\" class=\"diff\" contenteditable=\"true\"></div>\n      <div class=\"flexrow\">\n        <button id=\"useLeftBtn\" class=\"smallbtn\">Use Left</button>\n        <button id=\"useRightBtn\" class=\"smallbtn\">Use Right</button>\n        <button id=\"acceptMergeBtn\" class=\"smallbtn\">Accept Merge</button>\n      </div>\n    </div>\n\n    <h3>Tests</h3>\n    <div>\n      <label>Test name:</label>\n      <input id=\"testName\" type=\"text\" placeholder=\"contains foo\">\n      <label>File to check:</label>\n      <select id=\"testFileSelect\"></select>\n      <label>Type:</label>\n      <select id=\"testType\">\n        <option value=\"contains\">Contains substring</option>\n        <option value=\"regex\">Regex match</option>\n        <option value=\"runjs\">Run JS (return true/false)</option>\n      </select>\n      <label>Pattern/code:</label>\n      <input id=\"testPattern\" type=\"text\" placeholder=\"pattern or JS\">\n      <button id=\"addTestBtn\">Add Test</button>\n      <button id=\"runTestsBtn\">Run Tests</button>\n      <div id=\"testsOutput\" class=\"diff\"></div>\n    </div>\n  </div>\n</div>\n\n<script>\n// Project state\nlet project = {\n  branches: { master: { currentSnapshot: null, head: null, name: 'master' } },\n  currentBranch: 'master',\n  snapshots: {}, // id: {id, parent, branch, files}\n  nextSnapshotId: 1\n};\n\nlet working = {\n  files: {}, // filename: content\n  fileOrder: [],\n  currentFile: null,\n  history: [], // undo stack per branch; we'll maintain keyed by branch name\n  redo: []\n};\n\nlet opQueue = []; // planned refactor operations for current branch\nlet timeline = []; // sequence of applied operations (for replay)\n// Initialize a sample project\nfunction initSample() {\n  working.files = {\n    \"util.js\": [\n      \"function log(msg) {\",\n      \"  console.log(msg);\",\n      \"}\",\n      \"\",\n      \"function flatten(arr) {\",\n      \"  var res = [];\",\n      \"  for (var i=0;i<arr.length;i++) {\",\n      \"    if (Array.isArray(arr[i])) res = res.concat(flatten(arr[i]));\",\n      \"    else res.push(arr[i]);\",\n      \"  }\",\n      \"  return res;\",\n      \"}\"\n    ].join(\"\\n\"),\n    \"math.js\": [\n      \"function add(a,b) { return a+b; }\",\n      \"function mul(a,b) { return a*b; }\",\n      \"function factorial(n) {\",\n      \"  if (n <= 1) return 1;\",\n      \"  return n * factorial(n-1);\",\n      \"}\"\n    ].join(\"\\n\"),\n    \"app.js\": [\n      \"function main() {\",\n      \"  var x = add(2,3);\",\n      \"  console.log('x', x);\",\n      \"  var vals = [1, [2,3], 4];\",\n      \"  var flat = flatten(vals);\",\n      \"  console.log(flat);\",\n      \"}\",\n      \"\",\n      \"main();\"\n    ].join(\"\\n\")\n  };\n  working.fileOrder = [\"util.js\",\"math.js\",\"app.js\"];\n  working.currentFile = \"app.js\";\n  project.branches['master'].head = null;\n  project.branches['master'].currentSnapshot = null;\n  project.currentBranch = 'master';\n  project.nextSnapshotId = 1;\n  project.snapshots = {};\n  project.branches = { master: { name: 'master', head: null, currentSnapshot: null } };\n  saveSnapshot(\"Initial sample\");\n  pushHistorySnapshot(); // set initial undo state\n}\ninitSample();\n\n// Utilities\nfunction getCurrentFileContent() { return working.files[working.currentFile] ?? \"\"; }\nfunction setCurrentFileContent(text) {\n  working.files[working.currentFile] = text;\n  updateEditor();\n}\nfunction updateEditor() {\n  document.getElementById('editor').value = getCurrentFileContent();\n  document.getElementById('currentFileLabel').textContent = working.currentFile || \"(none)\";\n  populateSelects();\n}\nfunction populateSelects() {\n  let fileList = document.getElementById('fileList');\n  fileList.innerHTML = '';\n  working.fileOrder.forEach(fn=>{\n    let btn = document.createElement('button');\n    btn.textContent = fn;\n    btn.onclick = ()=>{ working.currentFile = fn; updateEditor(); };\n    fileList.appendChild(btn);\n  });\n  // populate some selects\n  let extractDest = document.getElementById('extractDest');\n  let testFile = document.getElementById('testFileSelect');\n  let mergeBranchSelect = document.getElementById('mergeBranchSelect');\n  extractDest.innerHTML = ''; testFile.innerHTML = ''; mergeBranchSelect.innerHTML = '';\n  working.fileOrder.forEach(fn=>{\n    let o1=document.createElement('option'); o1.value=fn; o1.textContent=fn; extractDest.appendChild(o1);\n    let o2=document.createElement('option'); o2.value=fn; o2.textContent=fn; testFile.appendChild(o2);\n  });\n  Object.keys(project.branches).forEach(b=>{\n    let o=document.createElement('option'); o.value=b; o.textContent=b; mergeBranchSelect.appendChild(o);\n  });\n  populateSnapshotList();\n}\nfunction populateSnapshotList() {\n  let cont = document.getElementById('snapshots'); cont.innerHTML = '';\n  let ids = Object.keys(project.snapshots).map(Number).sort((a,b)=>b-a);\n  ids.forEach(id=>{\n    let s = project.snapshots[id];\n    let d=document.createElement('div'); d.textContent = `#${id} (${s.branch}) - ${s.message || ''}`; d.style.cursor='pointer';\n    d.onclick = ()=>{ alert('Snapshot ' + id + ' details:\\\\n' + Object.keys(s.files).join('\\\\n')); };\n    cont.appendChild(d);\n  });\n}\n\n// Snapshot / Branching\nfunction saveSnapshot(message) {\n  let id = project.nextSnapshotId++;\n  let snap = { id, parent: project.branches[project.currentBranch].currentSnapshot, branch: project.currentBranch, files: JSON.parse(JSON.stringify(working.files)), message: message || ('snapshot '+id), time: Date.now() };\n  project.snapshots[id]=snap;\n  project.branches[project.currentBranch].currentSnapshot = id;\n  project.branches[project.currentBranch].head = id;\n  populateSelects();\n  return id;\n}\nfunction pushHistorySnapshot() {\n  // store a shallow undo state keyed by branch\n  let b = project.currentBranch;\n  project.branches[b].history = project.branches[b].history || [];\n  project.branches[b].redo = project.branches[b].redo || [];\n  project.branches[b].history.push(JSON.parse(JSON.stringify(working.files)));\n  if (project.branches[b].history.length>100) project.branches[b].history.shift();\n  project.branches[b].redo = [];\n}\nfunction undo() {\n  let b = project.currentBranch;\n  let H = project.branches[b].history || [];\n  if (H.length<=1) { alert('Nothing to undo'); return; }\n  let last = H.pop();\n  project.branches[b].redo = project.branches[b].redo || [];\n  project.branches[b].redo.push(last);\n  let prev = H[H.length-1];\n  working.files = JSON.parse(JSON.stringify(prev));\n  working.fileOrder = Object.keys(working.files);\n  working.currentFile = working.fileOrder[0] || null;\n  updateEditor();\n}\nfunction redo() {\n  let b = project.currentBranch;\n  let R = project.branches[b].redo || [];\n  if (!R || R.length===0) { alert('Nothing to redo'); return; }\n  let state = R.pop();\n  project.branches[b].history.push(JSON.parse(JSON.stringify(state)));\n  working.files = JSON.parse(JSON.stringify(state));\n  working.fileOrder = Object.keys(working.files);\n  working.currentFile = working.fileOrder[0] || null;\n  updateEditor();\n}\nfunction createBranch(name) {\n  if (!name) { alert('Provide branch name'); return; }\n  if (project.branches[name]) { alert('Branch exists'); return; }\n  project.branches[name] = { name, head: project.branches[project.currentBranch].head, currentSnapshot: project.branches[project.currentBranch].currentSnapshot, history: [], redo: [] };\n  populateSelects();\n  alert('Branch created: ' + name);\n}\nfunction switchBranch(name) {\n  if (!project.branches[name]) { alert('No such branch'); return; }\n  // load head snapshot if exists\n  project.currentBranch = name;\n  let snapId = project.branches[name].currentSnapshot;\n  if (snapId && project.snapshots[snapId]) {\n    working.files = JSON.parse(JSON.stringify(project.snapshots[snapId].files));\n    working.fileOrder = Object.keys(working.files);\n    working.currentFile = working.fileOrder[0] || null;\n    project.branches[name].history = project.branches[name].history || [];\n    project.branches[name].redo = project.branches[name].redo || [];\n  } else {\n    // start with empty workspace if branch new\n    working.files = {}; working.fileOrder = []; working.currentFile = null;\n  }\n  updateEditor();\n}\nfunction findCommonAncestor(aId,bId) {\n  let visited = new Set();\n  while (aId) { visited.add(aId); aId = project.snapshots[aId] ? project.snapshots[aId].parent : null; }\n  while (bId) {\n    if (visited.has(bId)) return bId;\n    bId = project.snapshots[bId] ? project.snapshots[bId].parent : null;\n  }\n  return null;\n}\nfunction mergeBranchIntoCurrent(sourceBranch) {\n  if (sourceBranch === project.currentBranch) { alert('Cannot merge same branch'); return; }\n  if (!project.branches[sourceBranch]) { alert('No such branch'); return; }\n  let dest = project.currentBranch;\n  let A = project.branches[dest].currentSnapshot;\n  let B = project.branches[sourceBranch].currentSnapshot;\n  let ancestor = findCommonAncestor(A,B);\n  if (!ancestor) ancestor = null;\n  // create merged files starting from ancestor\n  let base = ancestor ? project.snapshots[ancestor].files : {};\n  let left = A ? project.snapshots[A].files : {};\n  let right = B ? project.snapshots[B].files : {};\n  let conflicts = [];\n  let merged = JSON.parse(JSON.stringify(base));\n  let allFiles = new Set([...Object.keys(base), ...Object.keys(left), ...Object.keys(right)]);\n  allFiles.forEach(fn=>{\n    let baseC = base[fn] ?? null;\n    let leftC = left[fn] ?? null;\n    let rightC = right[fn] ?? null;\n    if (leftC === rightC) {\n      merged[fn] = leftC ?? rightC;\n    } else if (leftC === baseC) {\n      merged[fn] = rightC;\n    } else if (rightC === baseC) {\n      merged[fn] = leftC;\n    } else {\n      // conflict!\n      conflicts.push({file:fn,left:leftC,right:rightC,base:baseC});\n    }\n  });\n  if (conflicts.length===0) {\n    // accept merge\n    pushHistorySnapshot();\n    working.files = merged;\n    working.fileOrder = Object.keys(working.files);\n    saveSnapshot(`merge ${sourceBranch} into ${dest}`);\n    alert('Merged cleanly');\n    updateEditor();\n  } else {\n    // show first conflict in merge editor for manual resolution\n    let c = conflicts[0];\n    document.getElementById('mergeEditor').textContent = `<<<<<<< LEFT (${sourceBranch})\\n${c.left ?? ''}\\n=======\\n${c.right ?? ''}\\n>>>>>>> RIGHT (${dest})`;\n    // store conflict state for resolution\n    pendingMerge = { conflicts, index:0, destBranch:dest, sourceBranch, base, left, right };\n    alert('Merge conflict detected. Use the resolver to resolve first conflict.');\n  }\n}\nlet pendingMerge = null;\nfunction acceptMergeResolution(resolvedText) {\n  if (!pendingMerge) { alert('No pending merge'); return; }\n  let c = pendingMerge.conflicts[pendingMerge.index];\n  let mergedFiles = JSON.parse(JSON.stringify(pendingMerge.base));\n  // start from left and right and replace conflicts with resolution chosen + others as earlier logic\n  Object.keys(pendingMerge.left || {}).forEach(fn=>{ mergedFiles[fn] = pendingMerge.left[fn]; });\n  Object.keys(pendingMerge.right || {}).forEach(fn=>{ \n    if (mergedFiles[fn] && mergedFiles[fn] !== pendingMerge.left[fn]) {\n      // if conflict we will replace below\n    } else {\n      mergedFiles[fn] = pendingMerge.right[fn];\n    }\n  });\n  // apply resolution for this conflict\n  mergedFiles[c.file] = resolvedText;\n  // remove this conflict and continue merging remaining ones using simple rule: favor left for others\n  pendingMerge.conflicts.splice(pendingMerge.index,1);\n  if (pendingMerge.conflicts.length===0) {\n    // finish merge\n    pushHistorySnapshot();\n    working.files = mergedFiles;\n    working.fileOrder = Object.keys(working.files);\n    saveSnapshot(`merge ${pendingMerge.sourceBranch} into ${pendingMerge.destBranch} (manual resolve)`);\n    pendingMerge = null;\n    alert('Merge completed after conflict resolution.');\n    updateEditor();\n  } else {\n    pendingMerge.index = 0;\n    let next = pendingMerge.conflicts[0];\n    document.getElementById('mergeEditor').textContent = `<<<<<<< LEFT (${pendingMerge.sourceBranch})\\n${next.left ?? ''}\\n=======\\n${next.right ?? ''}\\n>>>>>>> RIGHT (${pendingMerge.destBranch})`;\n    alert('Next conflict presented.');\n  }\n}\n\n// Diffs (simple line-by-line)\nfunction simpleDiff(a,b) {\n  let A = (a||'').split('\\n');\n  let B = (b||'').split('\\n');\n  let out = [];\n  let max = Math.max(A.length,B.length);\n  for (let i=0;i<max;i++) {\n    if (A[i]===B[i]) out.push(' '+(A[i]||''));\n    else {\n      if (A[i]!==undefined) out.push('-'+(A[i]||''));\n      if (B[i]!==undefined) out.push('+'+(B[i]||''));\n    }\n  }\n  return out.join('\\n');\n}\n\n// Editor events\ndocument.getElementById('editor').addEventListener('select', updateSelectionInfo);\ndocument.getElementById('editor').addEventListener('keyup', updateSelectionInfo);\nfunction updateSelectionInfo() {\n  let ta = document.getElementById('editor');\n  let selStart = ta.selectionStart;\n  let selEnd = ta.selectionEnd;\n  let text = ta.value;\n  let before = text.slice(0, selStart);\n  let sel = text.slice(selStart, selEnd);\n  let startLine = before.split('\\n').length;\n  let endLine = sel.length ? startLine + sel.split('\\n').length - 1 : startLine;\n  document.getElementById('selInfo').textContent = `${startLine}:${endLine} chars ${sel.length}`;\n}\ndocument.getElementById('selectLinesBtn').onclick = ()=>{\n  updateSelectionInfo();\n  alert('Selection described above.');\n}\n\n// File actions\ndocument.getElementById('newFileBtn').onclick = ()=>{\n  let name = prompt('New file name:','newfile.js');\n  if (!name) return;\n  if (working.files[name]) { alert('File exists'); return; }\n  pushHistorySnapshot();\n  working.files[name] = '// new file';\n  working.fileOrder.push(name);\n  working.currentFile = name;\n  updateEditor();\n};\ndocument.getElementById('cloneFileBtn').onclick = ()=>{\n  let name = prompt('New clone name:','clone.js');\n  if (!name) return;\n  if (!working.currentFile) { alert('No current file'); return; }\n  if (working.files[name]) { alert('File exists'); return; }\n  pushHistorySnapshot();\n  working.files[name] = working.files[working.currentFile];\n  working.fileOrder.push(name);\n  working.currentFile = name;\n  updateEditor();\n};\ndocument.getElementById('deleteFileBtn').onclick = ()=>{\n  if (!working.currentFile) { alert('No file'); return; }\n  if (!confirm('Delete '+working.currentFile+'?')) return;\n  pushHistorySnapshot();\n  delete working.files[working.currentFile];\n  working.fileOrder = working.fileOrder.filter(f=>f!==working.currentFile);\n  working.currentFile = working.fileOrder[0] || null;\n  updateEditor();\n};\ndocument.getElementById('renameFileBtn').onclick = ()=>{\n  if (!working.currentFile) { alert('No file'); return; }\n  let newName = prompt('New name:', working.currentFile);\n  if (!newName) return;\n  if (working.files[newName]) { alert('Name exists'); return; }\n  pushHistorySnapshot();\n  working.files[newName] = working.files[working.currentFile];\n  delete working.files[working.currentFile];\n  working.fileOrder = working.fileOrder.map(fn=>fn===working.currentFile?newName:fn);\n  working.currentFile = newName;\n  updateEditor();\n};\ndocument.getElementById('saveBtn').onclick = ()=>{\n  pushHistorySnapshot();\n  working.files[working.currentFile] = document.getElementById('editor').value;\n  updateEditor();\n};\ndocument.getElementById('revertBtn').onclick = ()=>{\n  if (!confirm('Revert unsaved changes to last saved?')) return;\n  updateEditor();\n};\n\n// Snapshot / Branch UI\ndocument.getElementById('saveSnapshotBtn').onclick = ()=> {\n  let msg = prompt('Snapshot message:','manual save');\n  saveSnapshot(msg);\n  alert('Snapshot saved.');\n};\ndocument.getElementById('listSnapshotsBtn').onclick = ()=>{\n  populateSnapshotList();\n  alert('Snapshots listed.');\n};\ndocument.getElementById('createBranchBtn').onclick = ()=>{\n  let name = document.getElementById('branchNameInput').value.trim();\n  createBranch(name);\n};\ndocument.getElementById('switchBranchBtn').onclick = ()=>{\n  let name = document.getElementById('branchNameInput').value.trim();\n  if (!name) { alert('Enter branch to switch to'); return; }\n  switchBranch(name);\n};\ndocument.getElementById('mergeBtn').onclick = ()=>{\n  let src = document.getElementById('mergeBranchSelect').value;\n  mergeBranchIntoCurrent(src);\n};\ndocument.getElementById('openSnapshotBtn').onclick = ()=>{\n  let id = document.getElementById('openSnapshotId').value.trim();\n  if (!id) { alert('No id'); return; }\n  let s = project.snapshots[id];\n  if (!s) { alert('No snapshot'); return; }\n  alert('Snapshot files:\\\\n' + Object.keys(s.files).join('\\\\n'));\n};\n\n// Undo/Redo\ndocument.getElementById('undoBtn').onclick = ()=>undo();\ndocument.getElementById('redoBtn').onclick = ()=>redo();\n\n// Operation Queue\ndocument.getElementById('prepareOpBtn').onclick = ()=> {\n  let type = document.getElementById('opType').value;\n  let op = { type, file: working.currentFile, id: Date.now()+'-'+Math.random().toString(36).slice(2) };\n  // collect parameters\n  if (type==='rename') {\n    op.old = document.getElementById('renameOld').value;\n    op.new = document.getElementById('renameNew').value;\n    op.scope = document.getElementById('renameScope').value;\n  } else if (type==='extract') {\n    op.name = document.getElementById('extractName').value || 'extracted';\n    op.dest = document.getElementById('extractDest').value;\n    let ta = document.getElementById('editor');\n    op.sel = { start: ta.selectionStart, end: ta.selectionEnd, file: working.currentFile };\n  } else if (type==='inline') {\n    op.var = document.getElementById('inlineVar').value;\n    op.scope = document.getElementById('inlineScope').value;\n  } else if (type==='replace') {\n    let script = document.getElementById('transformScript').value.split('\\n')[0] || '';\n    op.scriptLine = script;\n  } else if (type==='split') {\n    op.line = Number(document.getElementById('splitLineNo').value||0);\n    op.newname = document.getElementById('splitNewName').value || ('split_'+Date.now()+'.js');\n  } else if (type==='mergeFiles') {\n    // prompt for two files\n    let f1 = prompt('File 1:','util.js');\n    let f2 = prompt('File 2:','app.js');\n    if (!f1 || !f2) return;\n    op.f1=f1; op.f2=f2; op.newfile = prompt('New filename:','merged.js');\n  }\n  opQueue.push(op);\n  renderOpQueue();\n};\nfunction renderOpQueue() {\n  let el = document.getElementById('opQueue');\n  el.innerHTML = '';\n  opQueue.forEach((op,i)=>{\n    let d = document.createElement('div');\n    d.textContent = `${i+1}. ${op.type} ${op.file || ''} ${op.name || ''} ${op.var||''}`;\n    let up = document.createElement('button'); up.textContent='↑'; up.className='smallbtn'; up.onclick=()=>{\n      if (i>0) { [opQueue[i-1],opQueue[i]]=[opQueue[i],opQueue[i-1]]; renderOpQueue(); }\n    };\n    let down = document.createElement('button'); down.textContent='↓'; down.className='smallbtn'; down.onclick=()=>{\n      if (i<opQueue.length-1) { [opQueue[i+1],opQueue[i]]=[opQueue[i],opQueue[i+1]]; renderOpQueue(); }\n    };\n    let del = document.createElement('button'); del.textContent='Delete'; del.className='smallbtn'; del.onclick=()=>{\n      opQueue.splice(i,1); renderOpQueue();\n    };\n    d.appendChild(up); d.appendChild(down); d.appendChild(del);\n    el.appendChild(d);\n  });\n}\ndocument.getElementById('applyNextOpBtn').onclick = ()=>{ if (opQueue.length===0) { alert('No ops'); return;} applyOperation(opQueue.shift()); renderOpQueue(); };\ndocument.getElementById('applyAllOpsBtn').onclick = ()=>{ while(opQueue.length) { applyOperation(opQueue.shift()); } renderOpQueue(); };\ndocument.getElementById('clearOpsBtn').onclick = ()=>{ opQueue=[]; renderOpQueue(); };\ndocument.getElementById('replayBtn').onclick = ()=>{ replayTimeline(); };\n\nfunction applyOperation(op) {\n  // dispatch by type\n  pushHistorySnapshot();\n  if (op.type==='rename') doRename(op);\n  else if (op.type==='extract') doExtract(op);\n  else if (op.type==='inline') doInline(op);\n  else if (op.type==='replace') { applyScriptLine(op.scriptLine); }\n  else if (op.type==='split') doSplit(op);\n  else if (op.type==='mergeFiles') {\n    let content = (working.files[op.f1]||'') + '\\n' + (working.files[op.f2]||'');\n    working.files[op.newfile] = content;\n    if (!working.fileOrder.includes(op.newfile)) working.fileOrder.push(op.newfile);\n  }\n  saveSnapshot(`op ${op.type}`);\n  timeline.push(op);\n  updateEditor();\n}\n\n// Rename symbol functions (naive)\nfunction previewRename(oldName,newName,scope) {\n  let diffs = {};\n  let filesToCheck = [];\n  if (scope==='file') filesToCheck = [working.currentFile];\n  else filesToCheck = Object.keys(working.files);\n  filesToCheck.forEach(fn=>{\n    let txt = working.files[fn] || '';\n    let replaced = txt.split(oldName).join(newName);\n    if (replaced !== txt) diffs[fn] = simpleDiff(txt,replaced);\n  });\n  return diffs;\n}\nfunction doRename(op) {\n  let diffs = previewRename(op.old,op.new,op.scope);\n  Object.keys(diffs).forEach(fn=>{\n    working.files[fn] = working.files[fn].split(op.old).join(op.new);\n  });\n}\n\n// Extract function (naive)\nfunction previewExtract(name,dest,sel) {\n  let diffs = {};\n  let file = sel.file;\n  let text = working.files[file]||'';\n  let before = text.slice(0, sel.start);\n  let selection = text.slice(sel.start, sel.end);\n  let after = text.slice(sel.end);\n  let call = `${name}();`;\n  // detect return in selection\n  let willReturn = /return\\s+/.test(selection);\n  let fnDecl = `function ${name}() {\\n${selection}\\n}`;\n  if (willReturn) {\n    // if selection includes return, keep as-is\n  }\n  let newSourceFile = (working.files[dest]||'') + '\\n\\n' + fnDecl;\n  diffs[file] = simpleDiff(working.files[file], before + call + after);\n  diffs[dest] = simpleDiff(working.files[dest]||'', newSourceFile);\n  return diffs;\n}\nfunction doExtract(op) {\n  let sel = op.sel;\n  let file = sel.file;\n  let text = working.files[file] || '';\n  let before = text.slice(0, sel.start);\n  let selection = text.slice(sel.start, sel.end);\n  let after = text.slice(sel.end);\n  let call = `${op.name}();`;\n  working.files[file] = before + call + after;\n  let fnDecl = `function ${op.name}() {\\n${selection}\\n}`;\n  working.files[op.dest] = (working.files[op.dest]||'') + '\\n\\n' + fnDecl;\n  if (!working.fileOrder.includes(op.dest)) working.fileOrder.push(op.dest);\n}\n\n// Inline variable\nfunction previewInline(varName, scope) {\n  let diffs = {};\n  let files = scope==='project' ? Object.keys(working.files) : [working.currentFile];\n  files.forEach(fn=>{\n    let txt = working.files[fn] || '';\n    // naive: find assignment like \"varName = expr;\" or \"var varName = expr;\" or \"let varName = expr;\" or \"const varName = expr;\"\n    let m = txt.match(new RegExp('(?:var|let|const)?\\\\s*'+escapeRegExp(varName)+'\\\\s*=\\\\s*([^;\\\\n]+);'));\n    if (m) {\n      let expr = m[1].trim();\n      let replaced = txt.replace(new RegExp('\\\\b'+escapeRegExp(varName)+'\\\\b','g'), `(${expr})`);\n      // but avoid replacing the declaration; remove the declaration line\n      replaced = replaced.replace(new RegExp('(?:var|let|const)?\\\\s*'+escapeRegExp(varName)+'\\\\s*=\\\\s*[^;\\\\n]+;\\\\s*'), '');\n      if (replaced !== txt) diffs[fn] = simpleDiff(txt,replaced);\n    }\n  });\n  return diffs;\n}\nfunction doInline(op) {\n  let diffs = previewInline(op.var, op.scope);\n  Object.keys(diffs).forEach(fn=>{\n    // apply similar logic as preview\n    let txt = working.files[fn];\n    let m = txt.match(new RegExp('(?:var|let|const)?\\\\s*'+escapeRegExp(op.var)+'\\\\s*=\\\\s*([^;\\\\n]+);'));\n    if (!m) return;\n    let expr = m[1].trim();\n    let replaced = txt.replace(new RegExp('\\\\b'+escapeRegExp(op.var)+'\\\\b','g'), `(${expr})`);\n    replaced = replaced.replace(new RegExp('(?:var|let|const)?\\\\s*'+escapeRegExp(op.var)+'\\\\s*=\\\\s*[^;\\\\n]+;\\\\s*'), '');\n    working.files[fn] = replaced;\n  });\n}\n\n// Replace via simple script line\nfunction applyScriptLine(line) {\n  // DSL: replace <file> /pattern/replace/flags\n  let parts = line.split(' ');\n  if (parts[0] === 'replace') {\n    let file = parts[1];\n    let rest = line.slice(line.indexOf(parts[2]));\n    // parse /pattern/replacement/flags\n    let m = rest.match(/^\\/(.+)\\/(.*)\\/([gimuy]*)$/);\n    if (!m) { alert('Bad replace syntax'); return; }\n    let pattern = m[1];\n    let replacement = m[2];\n    let flags = m[3];\n    let re = new RegExp(pattern, flags || 'g');\n    if (!working.files[file]) { alert('File not found: '+file); return; }\n    let old = working.files[file];\n    working.files[file] = old.replace(re, replacement);\n  }\n}\nfunction applyScript(script) {\n  pushHistorySnapshot();\n  let lines = script.split('\\n').map(s=>s.trim()).filter(Boolean);\n  lines.forEach(line=>applyScriptLine(line));\n  saveSnapshot('script applied');\n  updateEditor();\n}\n\n// Split file\nfunction previewSplit(lineNo,newname) {\n  let file = working.currentFile;\n  let text = working.files[file] || '';\n  let lines = text.split('\\n');\n  let a = lines.slice(0,lineNo).join('\\n');\n  let b = lines.slice(lineNo).join('\\n');\n  let diffs = {};\n  diffs[file] = simpleDiff(text,a);\n  diffs[newname] = simpleDiff('',b);\n  return diffs;\n}\nfunction doSplit(op) {\n  let file = working.currentFile;\n  let text = working.files[file] || '';\n  let lines = text.split('\\n');\n  let a = lines.slice(0,op.line).join('\\n');\n  let b = lines.slice(op.line).join('\\n');\n  working.files[file] = a;\n  working.files[op.newname] = b;\n  if (!working.fileOrder.includes(op.newname)) working.fileOrder.push(op.newname);\n}\n\n// Analysis\nfunction runAnalysis(minLines) {\n  let out = [];\n  Object.keys(working.files).forEach(fn=>{\n    let text = working.files[fn];\n    let lines = text.split('\\n');\n    // long functions naive: find function ... { ... } blocks\n    let funcs = text.match(/function\\s+[a-zA-Z0-9_]*\\s*\\([^)]*\\)\\s*\\{[\\s\\S]*?\\}/g) || [];\n    funcs.forEach(f=>{\n      let ll = f.split('\\n').length;\n      if (ll >= minLines) out.push(`${fn}: long function of ${ll} lines -> consider extract/simplify`);\n    });\n    // duplicates: we'll do simple repeated blocks detection below separately\n  });\n  // duplicate detection across files and within file\n  let blocks = {}; // block text -> occurrences\n  Object.keys(working.files).forEach(fn=>{\n    let lines = working.files[fn].split('\\n');\n    for (let i=0;i<lines.length;i++){\n      for (let size=2; size<=Math.min(12, lines.length-i); size++){\n        let block = lines.slice(i,i+size).join('\\n').trim();\n        if (block.split('\\n').length < minLines) continue;\n        if (!block) continue;\n        blocks[block] = blocks[block] || [];\n        blocks[block].push({file:fn,line:i+1});\n      }\n    }\n  });\n  Object.keys(blocks).forEach(b=>{\n    if (blocks[b].length>1) {\n      out.push(`Duplicate block (${blocks[b].length} occurrences) starting at ${blocks[b].map(x=>x.file+':'+x.line).join(', ')}`);\n    }\n  });\n  return out.join('\\n') || 'No suggestions';\n}\n\n// Rename UI handlers\ndocument.getElementById('previewRenameBtn').onclick = ()=>{\n  let oldName = document.getElementById('renameOld').value;\n  let newName = document.getElementById('renameNew').value;\n  let scope = document.getElementById('renameScope').value;\n  if (!oldName || !newName) { alert('Enter names'); return; }\n  let diffs = previewRename(oldName,newName,scope);\n  let out = Object.keys(diffs).map(fn=>`=== ${fn} ===\\n${diffs[fn]}`).join('\\n\\n');\n  document.getElementById('previewRenameDiff').textContent = out || 'No changes';\n};\ndocument.getElementById('applyRenameBtn').onclick = ()=>{\n  let oldName = document.getElementById('renameOld').value;\n  let newName = document.getElementById('renameNew').value;\n  let scope = document.getElementById('renameScope').value;\n  if (!oldName || !newName) { alert('Enter names'); return; }\n  pushHistorySnapshot();\n  doRename({old:oldName,new:newName,scope});\n  saveSnapshot(`rename ${oldName} -> ${newName}`);\n  updateEditor();\n};\n\n// Extract UI\ndocument.getElementById('previewExtractBtn').onclick = ()=>{\n  let name = document.getElementById('extractName').value || 'extracted';\n  let dest = document.getElementById('extractDest').value;\n  let ta = document.getElementById('editor');\n  let sel = {start: ta.selectionStart, end: ta.selectionEnd, file: working.currentFile};\n  if (!sel.start || sel.start===sel.end) {\n    // allow extracting entire current function if no selection\n    alert('Select the code to extract in the editor first.');\n    return;\n  }\n  let diffs = previewExtract(name,dest,sel);\n  let out = Object.keys(diffs).map(fn=>`=== ${fn} ===\\n${diffs[fn]}`).join('\\n\\n');\n  document.getElementById('previewExtractDiff').textContent = out;\n};\ndocument.getElementById('applyExtractBtn').onclick = ()=>{\n  let name = document.getElementById('extractName').value || 'extracted';\n  let dest = document.getElementById('extractDest').value;\n  let ta = document.getElementById('editor');\n  let sel = {start: ta.selectionStart, end: ta.selectionEnd, file: working.currentFile};\n  if (!sel.start || sel.start===sel.end) { alert('Select code first.'); return; }\n  pushHistorySnapshot();\n  doExtract({name,dest,sel});\n  saveSnapshot(`extract ${name}`);\n  updateEditor();\n};\n\n// Inline UI\ndocument.getElementById('previewInlineBtn').onclick = ()=>{\n  let v = document.getElementById('inlineVar').value;\n  let scope = document.getElementById('inlineScope').value;\n  if (!v) { alert('Enter var'); return; }\n  let diffs = previewInline(v,scope);\n  document.getElementById('previewInlineDiff').textContent = Object.keys(diffs).map(fn=>`=== ${fn} ===\\n${diffs[fn]}`).join('\\n\\n') || 'No inlining candidates';\n};\ndocument.getElementById('applyInlineBtn').onclick = ()=>{\n  let v = document.getElementById('inlineVar').value;\n  let scope = document.getElementById('inlineScope').value;\n  if (!v) return;\n  pushHistorySnapshot();\n  doInline({var:v,scope});\n  saveSnapshot(`inline ${v}`);\n  updateEditor();\n};\n\n// Analysis\ndocument.getElementById('runAnalysisBtn').onclick = ()=>{\n  let min = Number(document.getElementById('dupMinLines').value||3);\n  let out = runAnalysis(min);\n  document.getElementById('analysisOutput').textContent = out;\n};\n\n// Split UI\ndocument.getElementById('previewSplitBtn').onclick = ()=>{\n  let ln = Number(document.getElementById('splitLineNo').value||0);\n  let name = document.getElementById('splitNewName').value || ('split_'+Date.now()+'.js');\n  let diffs = previewSplit(ln,name);\n  document.getElementById('previewSplitDiff').textContent = Object.keys(diffs).map(fn=>`=== ${fn} ===\\n${diffs[fn]}`).join('\\n\\n');\n};\ndocument.getElementById('applySplitBtn').onclick = ()=>{\n  let ln = Number(document.getElementById('splitLineNo').value||0);\n  let name = document.getElementById('splitNewName').value || ('split_'+Date.now()+'.js');\n  pushHistorySnapshot();\n  doSplit({line:ln,newname:name});\n  saveSnapshot('split file');\n  updateEditor();\n};\n\n// Transformation script\ndocument.getElementById('runScriptBtn').onclick = ()=>{\n  let script = document.getElementById('transformScript').value;\n  let lines = script.split('\\n').map(s=>s.trim()).filter(Boolean);\n  let preview = [];\n  lines.forEach(line=>{\n    try {\n      let tmp = JSON.parse(JSON.stringify(working.files));\n      // apply line on tmp using same logic\n      let parts = line.split(' ');\n      if (parts[0] === 'replace') {\n        let file = parts[1];\n        let rest = line.slice(line.indexOf(parts[2]));\n        let m = rest.match(/^\\/(.+)\\/(.*)\\/([gimuy]*)$/);\n        if (!m) { preview.push('Bad line: '+line); return; }\n        let re = new RegExp(m[1], m[3] || 'g');\n        tmp[file] = (tmp[file]||'').replace(re, m[2]);\n        preview.push(`Line: ${line}\\nPreview diff for ${file}:\\n${simpleDiff(working.files[file]||'', tmp[file]||'')}`);\n      } else preview.push('Unknown command: '+line);\n    } catch(e){ preview.push('Error processing: '+line+' -> '+e.message); }\n  });\n  document.getElementById('scriptPreview').textContent = preview.join('\\n\\n');\n};\ndocument.getElementById('applyScriptBtn').onclick = ()=>{\n  let script = document.getElementById('transformScript').value;\n  applyScript(script);\n};\n\n// Merge resolver controls\ndocument.getElementById('useLeftBtn').onclick = ()=>{\n  let me = document.getElementById('mergeEditor');\n  let content = me.textContent;\n  // take left part\n  let m = content.match(/<<<<<<< LEFT[\\\\s\\\\S]*?\\\\n([\\\\s\\\\S]*?)\\\\n=======/);\n  if (m) me.textContent = m[1];\n};\ndocument.getElementById('useRightBtn').onclick = ()=>{\n  let me = document.getElementById('mergeEditor');\n  let content = me.textContent;\n  let m = content.match(/=======\\\\n([\\\\s\\\\S]*?)\\\\n>>>>>>>/);\n  if (m) me.textContent = m[1];\n};\ndocument.getElementById('acceptMergeBtn').onclick = ()=>{\n  let resolved = document.getElementById('mergeEditor').textContent;\n  acceptMergeResolution(resolved);\n};\n\n// Tests\nlet tests = [];\ndocument.getElementById('addTestBtn').onclick = ()=>{\n  let name = document.getElementById('testName').value || ('test'+(tests.length+1));\n  let file = document.getElementById('testFileSelect').value;\n  let type = document.getElementById('testType').value;\n  let pattern = document.getElementById('testPattern').value;\n  tests.push({name,file,type,pattern});\n  document.getElementById('testsOutput').textContent = 'Added test: '+name;\n};\ndocument.getElementById('runTestsBtn').onclick = ()=>{\n  let out = [];\n  tests.forEach(t=>{\n    let content = working.files[t.file] || '';\n    if (t.type==='contains') {\n      out.push(`${t.name}: ${content.includes(t.pattern) ? 'PASS' : 'FAIL'}`);\n    } else if (t.type==='regex') {\n      let re = new RegExp(t.pattern);\n      out.push(`${t.name}: ${re.test(content) ? 'PASS' : 'FAIL'}`);\n    } else if (t.type==='runjs') {\n      // Evaluate code: concatenate all files and then run test.code\n      try {\n        let all = Object.keys(working.files).map(k=>working.files[k]).join('\\n');\n        let fn = new Function(all + '\\nreturn ('+t.pattern+');');\n        let res = fn();\n        out.push(`${t.name}: ${res ? 'PASS' : 'FAIL'}`);\n      } catch(e) { out.push(`${t.name}: ERROR - ${e.message}`); }\n    }\n  });\n  document.getElementById('testsOutput').textContent = out.join('\\n');\n};\n\n// Simple utility functions\nfunction escapeRegExp(s) { return s.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&'); }\n\n// Script apply button mapping\ndocument.getElementById('runScriptBtn');\ndocument.getElementById('applyScriptBtn');\n\n// Analysis run\ndocument.getElementById('runAnalysisBtn');\n\n// Open & save preview diffs for operations queue too (not required but available via previews above)\n\n// Replay timeline\nfunction replayTimeline() {\n  if (timeline.length===0) { alert('No timeline'); return; }\n  let copyProject = JSON.parse(JSON.stringify(project));\n  let copyWorking = JSON.parse(JSON.stringify(working));\n  // start from snapshot at beginning (initial)\n  let i = 0;\n  // allow stepping\n  let step = confirm('Replay timeline stepwise? OK for stepwise, Cancel to apply all quickly.');\n  if (!step) {\n    // quick replay: just reapply recorded ops in a fresh copy of initial snapshot\n    alert('Quick replay will reapply operations on current workspace as a simulation.');\n    let simulated = JSON.parse(JSON.stringify(copyWorking));\n    timeline.forEach(op=>{\n      try {\n        // naive simulation: only apply a few op types\n        if (op.type==='rename') {\n          Object.keys(simulated.files).forEach(fn=> simulated.files[fn] = simulated.files[fn].split(op.old).join(op.new));\n        } else if (op.type==='extract') {\n          // ignore if selection invalid\n        } else if (op.type==='inline') {\n          // ignore\n        }\n      } catch(e){}\n    });\n    alert('Replay complete (simulation).');\n  } else {\n    // interactive step-through\n    let idx = 0;\n    function doStep() {\n      if (idx>=timeline.length) { alert('Replay finished'); return; }\n      let op = timeline[idx];\n      if (!confirm(`Apply op ${idx+1}/${timeline.length}: ${op.type} ?`)) { alert('Replay halted'); return; }\n      applyOperation(op);\n      idx++;\n      setTimeout(doStep,0);\n    }\n    doStep();\n  }\n}\n\n// Simple initialization of UI\nupdateEditor();\nrenderOpQueue();\n\n// Other UI wiring\ndocument.getElementById('runAnalysisBtn').onclick = ()=> {\n  let out = runAnalysis(Number(document.getElementById('dupMinLines').value || 3));\n  document.getElementById('analysisOutput').textContent = out;\n};\n\n// Expose some functions for quick console debugging (not necessary but helpful)\nwindow._project = project;\nwindow._working = working;\nwindow._saveSnapshot = saveSnapshot;\nwindow._pushHistory = pushHistorySnapshot;\n\n</script>\n</body>\n</html>"
