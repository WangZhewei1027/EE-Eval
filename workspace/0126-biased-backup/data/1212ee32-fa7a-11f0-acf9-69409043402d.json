  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Multiset Interactive Demonstration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  input[type=number] {\n    width: 4em;\n  }\n  pre {\n    white-space: pre-wrap;\n  }\n  button, input, select {\n    font-family: monospace, monospace;\n    margin: 0 0.2em 0.5em 0.2em;\n  }\n</style>\n</head>\n<body>\n<h1>Multiset Interactive Demonstration</h1>\n<p>\n  A <b>Multiset</b> is a collection like a set but allows multiple occurrences of the same element.<br />\n  Elements have counts/frequencies. Here you can add, remove, query, and combine multisets.\n</p>\n\n<section id=\"multiset-builder\">\n  <h2>1. Build & Modify Your Multiset</h2>\n  <label for=\"elem-input\">Element (string): </label>\n  <input id=\"elem-input\" type=\"text\" aria-label=\"Element input\" />\n  <label for=\"count-input\">Count (integer ≥ 1): </label>\n  <input id=\"count-input\" type=\"number\" min=\"1\" value=\"1\" aria-label=\"Count input\" />\n  <button id=\"add-btn\">Add Element</button>\n  <button id=\"remove-btn\">Remove Element</button>\n  <button id=\"set-btn\">Set Element Count</button>\n  <button id=\"clear-btn\">Clear Multiset</button>\n  <div>\n    <label for=\"show-format\">Show format: </label>\n    <select id=\"show-format\" aria-label=\"Choose display format\">\n      <option value=\"list\">List (elements repeated)</option>\n      <option value=\"counts\" selected>Counts (element: count)</option>\n      <option value=\"sorted\">Sorted List (asc)</option>\n      <option value=\"sorted-desc\">Sorted List (desc)</option>\n      <option value=\"json\">JSON Object</option>\n    </select>\n  </div>\n  <div>\n    <h3>Current Multiset:</h3>\n    <pre id=\"multiset-output\">(empty)</pre>\n  </div>\n</section>\n\n<hr />\n\n<section id=\"multiset-queries\">\n  <h2>2. Query Multiset</h2>\n  <label for=\"query-elem-input\">Element (string): </label>\n  <input id=\"query-elem-input\" type=\"text\" aria-label=\"Query element input\" />\n  <button id=\"count-query-btn\">Get Count</button>\n  <button id=\"contains-query-btn\">Contains?</button>\n  <button id=\"max-count-btn\">Get Max Count Element(s)</button>\n  <button id=\"min-count-btn\">Get Min Count Element(s)</button>\n  <button id=\"total-size-btn\">Total Size (sum of counts)</button>\n  <button id=\"distinct-count-btn\">Distinct Elements Count</button>\n  <div>\n    <h3>Query Result:</h3>\n    <pre id=\"query-output\">(no query yet)</pre>\n  </div>\n</section>\n\n<hr />\n\n<section id=\"multiset-operations\">\n  <h2>3. Inter-Multiset Operations</h2>\n  <p>\n    You can create and manipulate multiple multisets for operations (union, intersection, sum, difference).\n  </p>\n  <div>\n    <label for=\"ms-select1\">Select Multiset 1: </label>\n    <select id=\"ms-select1\" aria-label=\"Select first multiset\"></select>\n    <label for=\"ms-select2\">Select Multiset 2: </label>\n    <select id=\"ms-select2\" aria-label=\"Select second multiset\"></select>\n  </div>\n  <div>\n    <button id=\"union-btn\">Union (max counts)</button>\n    <button id=\"intersection-btn\">Intersection (min counts)</button>\n    <button id=\"sum-btn\">Sum (add counts)</button>\n    <button id=\"difference-btn\">Difference (ms1 - ms2)</button>\n  </div>\n  <div>\n    <label for=\"newms-name\">New Multiset Name: </label>\n    <input id=\"newms-name\" type=\"text\" aria-label=\"Name for new multiset\" />\n    <button id=\"create-ms-btn\">Create Multiset</button>\n    <button id=\"delete-ms-btn\">Delete Selected Multiset</button>\n  </div>\n  <div>\n    <h3>Multisets List (you can select):</h3>\n    <ul id=\"multisets-list\" style=\"max-height: 7em; overflow-y: auto; border: 1px solid black; padding-left: 1em;\"></ul>\n  </div>\n  <div>\n    <h3>Selected Multiset Details:</h3>\n    <pre id=\"multiset-detail-output\">(select a multiset above)</pre>\n  </div>\n</section>\n\n<hr />\n\n<section id=\"advanced-exploration\">\n  <h2>4. Advanced Exploration</h2>\n  <p>\n    Combine multisets and explore relations. Use filters and transformations.\n  </p>\n  <div>\n    <label for=\"adv-select-ms\">Select Multiset: </label>\n    <select id=\"adv-select-ms\" aria-label=\"Select multiset for advanced exploration\"></select>\n  </div>\n  <div>\n    <label for=\"filter-min-count\">Filter minimum count (≥0): </label>\n    <input id=\"filter-min-count\" type=\"number\" min=\"0\" value=\"0\" aria-label=\"Minimum filter count\" />\n    <label for=\"filter-max-count\">Filter maximum count (≥ min): </label>\n    <input id=\"filter-max-count\" type=\"number\" min=\"0\" value=\"100\" aria-label=\"Maximum filter count\" />\n    <button id=\"apply-filter-btn\">Apply Filter</button>\n  </div>\n  <div>\n    <label for=\"transform-select\">Transformation: </label>\n    <select id=\"transform-select\" aria-label=\"Select transformation\">\n      <option value=\"none\" selected>None</option>\n      <option value=\"increment\">Increment counts (+1)</option>\n      <option value=\"decrement\">Decrement counts (-1, min 1)</option>\n      <option value=\"double\">Double counts</option>\n      <option value=\"halve\">Halve counts (floor)</option>\n      <option value=\"remove-ones\">Remove elements with count = 1</option>\n      <option value=\"keep-even\">Keep elements with even counts</option>\n      <option value=\"keep-odd\">Keep elements with odd counts</option>\n    </select>\n    <button id=\"apply-transform-btn\">Apply Transformation</button>\n  </div>\n  <div>\n    <button id=\"reset-adv-output-btn\">Reset Output</button>\n  </div>\n  <div>\n    <h3>Advanced Output:</h3>\n    <pre id=\"adv-output\">(no advanced exploration yet)</pre>\n  </div>\n</section>\n\n<hr />\n\n<script>\n(() => {\n  // Multiset implementation (Map of element => count (integer))\n  class Multiset {\n    constructor(name = '') {\n      this.name = name;\n      this.map = new Map();\n    }\n    clone() {\n      const ms = new Multiset(this.name);\n      for (const [k,v] of this.map.entries()) {\n        ms.map.set(k, v);\n      }\n      return ms;\n    }\n    add(element, count = 1) {\n      count = Math.floor(count);\n      if (count < 1) return;\n      const oldCount = this.map.get(element) || 0;\n      this.map.set(element, oldCount + count);\n    }\n    remove(element, count = 1) {\n      count = Math.floor(count);\n      if(count < 1) return;\n      if(!this.map.has(element)) return;\n      const oldCount = this.map.get(element);\n      if (oldCount <= count) {\n        this.map.delete(element);\n      } else {\n        this.map.set(element, oldCount - count);\n      }\n    }\n    setCount(element, count = 0) {\n      count = Math.floor(count);\n      if (count <= 0) {\n        this.map.delete(element);\n      } else {\n        this.map.set(element, count);\n      }\n    }\n    count(element) {\n      return this.map.get(element) || 0;\n    }\n    contains(element) {\n      return this.map.has(element);\n    }\n    elements() {\n      return Array.from(this.map.keys());\n    }\n    distinctCount() {\n      return this.map.size;\n    }\n    totalSize() {\n      let sum = 0;\n      for (const c of this.map.values()) {\n        sum += c;\n      }\n      return sum;\n    }\n    maxCountElements() {\n      if (this.map.size === 0) return [];\n      let maxc = 0;\n      for (const c of this.map.values()) {\n        if (c > maxc) maxc = c;\n      }\n      const res = [];\n      for (const [e,c] of this.map.entries()) {\n        if(c === maxc) res.push({element:e,count:c});\n      }\n      return res;\n    }\n    minCountElements() {\n      if (this.map.size === 0) return [];\n      let minc = Infinity;\n      for (const c of this.map.values()) {\n        if (c < minc) minc = c;\n      }\n      const res = [];\n      for (const [e,c] of this.map.entries()) {\n        if(c === minc) res.push({element:e,count:c});\n      }\n      return res;\n    }\n    toList() {\n      let arr = [];\n      for (const [e,c] of this.map.entries()) {\n        for(let i=0; i<c; i++) arr.push(e);\n      }\n      return arr;\n    }\n    toSortedList(desc=false) {\n      return this.toList().sort((a,b) => {\n        if(a < b) return desc ? 1 : -1;\n        if(a > b) return desc ? -1 : 1;\n        return 0;\n      });\n    }\n    toCounts() {\n      let parts = [];\n      for (const [e,c] of this.map.entries()) {\n        parts.push(e + ': ' + c);\n      }\n      return parts.join(', ');\n    }\n    toJSONObj() {\n      const obj = {};\n      for (const [e,c] of this.map.entries()) obj[e] = c;\n      return obj;\n    }\n    equals(other) {\n      if (!(other instanceof Multiset)) return false;\n      if (this.map.size !== other.map.size) return false;\n      for(const [k,v] of this.map.entries()){\n        if(other.count(k) !== v) return false;\n      }\n      return true;\n    }\n    union(other) {\n      // max counts\n      let result = new Multiset();\n      for (const [e,c] of this.map.entries()) {\n        result.setCount(e, c);\n      }\n      for (const [e,c] of other.map.entries()) {\n        const c0 = result.count(e);\n        if (c > c0) result.setCount(e, c);\n      }\n      return result;\n    }\n    intersection(other) {\n      // min counts of common elements\n      let result = new Multiset();\n      for (const [e,c] of this.map.entries()) {\n        if (other.contains(e)) {\n          result.setCount(e, Math.min(c, other.count(e)));\n        }\n      }\n      return result;\n    }\n    sum(other) {\n      // add counts\n      let result = this.clone();\n      for (const [e,c] of other.map.entries()) {\n        result.add(e,c);\n      }\n      return result;\n    }\n    difference(other) {\n      // subtract counts of other from this, no negative counts\n      let result = this.clone();\n      for (const [e,c] of other.map.entries()) {\n        result.remove(e,c);\n      }\n      return result;\n    }\n    filterByCount(minc=0, maxc=Infinity) {\n      let result = new Multiset();\n      for(const [e,c] of this.map.entries()) {\n        if(c >= minc && c <= maxc) result.setCount(e, c);\n      }\n      return result;\n    }\n    transform(type) {\n      let result = new Multiset();\n      switch(type) {\n        case 'none':\n          return this.clone();\n        case 'increment':\n          for(const [e,c] of this.map.entries()) {\n            result.setCount(e, c+1);\n          }\n          break;\n        case 'decrement':\n          for(const [e,c] of this.map.entries()) {\n            if(c > 1) result.setCount(e, c-1);\n          }\n          break;\n        case 'double':\n          for(const [e,c] of this.map.entries()) {\n            result.setCount(e, c*2);\n          }\n          break;\n        case 'halve':\n          for(const [e,c] of this.map.entries()) {\n            let newc = Math.floor(c/2);\n            if(newc > 0) result.setCount(e,newc);\n          }\n          break;\n        case 'remove-ones':\n          for(const [e,c] of this.map.entries()) {\n            if(c > 1) result.setCount(e,c);\n          }\n          break;\n        case 'keep-even':\n          for(const [e,c] of this.map.entries()) {\n            if(c % 2 === 0) result.setCount(e,c);\n          }\n          break;\n        case 'keep-odd':\n          for(const [e,c] of this.map.entries()) {\n            if(c % 2 === 1) result.setCount(e,c);\n          }\n          break;\n        default:\n          return this.clone();\n      }\n      return result;\n    }\n    isEmpty() {\n      return this.map.size === 0;\n    }\n  }\n\n  // Global state\n  const multisets = {};\n  let currentMSName = 'default';\n  multisets[currentMSName] = new Multiset('default');\n\n  // Utility functions for DOM\n  function $(id) { return document.getElementById(id); }\n\n  // Display current multiset according to selected format\n  function updateCurrentMultisetOutput() {\n    const ms = multisets[currentMSName];\n    if(!ms) {\n      $('multiset-output').textContent = \"(no multiset selected)\";\n      return;\n    }\n    const format = $('show-format').value;\n    let out = '';\n    switch(format) {\n      case 'list':\n        const arr = ms.toList();\n        out = arr.length ? arr.join(', ') : '(empty)';\n        break;\n      case 'counts':\n        out = ms.toCounts() || '(empty)';\n        break;\n      case 'sorted':\n        out = ms.toSortedList(false).join(', ') || '(empty)';\n        break;\n      case 'sorted-desc':\n        out = ms.toSortedList(true).join(', ') || '(empty)';\n        break;\n      case 'json':\n        out = JSON.stringify(ms.toJSONObj(), null, 2) || '{}';\n        break;\n    }\n    $('multiset-output').textContent = out;\n  }\n\n  // Populate multisets dropdowns & list in inter-multiset operations section\n  function updateMultisetSelectors() {\n    const sel1 = $('ms-select1');\n    const sel2 = $('ms-select2');\n    const advSelect = $('adv-select-ms');\n    [sel1, sel2, advSelect].forEach(sel => {\n      const oldVal = sel.value;\n      sel.innerHTML = '';\n      for (const k in multisets) {\n        const option = document.createElement('option');\n        option.value = k;\n        option.textContent = k;\n        sel.appendChild(option);\n      }\n      if (oldVal && Object.hasOwn(multisets, oldVal)) sel.value = oldVal;\n    });\n    updateMultisetList();\n    updateAdvancedOutputReset();\n  }\n\n  // Update multisets list textual display, clickable to select multiset for detail view\n  function updateMultisetList() {\n    const ul = $('multisets-list');\n    ul.innerHTML = '';\n    for (const k in multisets) {\n      const li = document.createElement('li');\n      li.textContent = k + (k === currentMSName ? \" (selected)\" : '');\n      li.style.cursor = \"pointer\";\n      li.tabIndex = 0;\n      li.setAttribute('role','button');\n      li.setAttribute('aria-pressed', k === currentMSName ? 'true' : 'false');\n      li.addEventListener('click', () => {\n        currentMSName = k;\n        updateCurrentMultisetOutput();\n        updateMultisetDetailOutput();\n        updateMultisetList();\n      });\n      li.addEventListener('keydown', (e) => {\n        if(e.key === 'Enter' || e.key === ' ') {\n          e.preventDefault();\n          li.click();\n        }\n      });\n      ul.appendChild(li);\n    }\n  }\n\n  // Update multisets detail output for currentMSName\n  function updateMultisetDetailOutput() {\n    const out = $('multiset-detail-output');\n    if(!(currentMSName in multisets)) {\n      out.textContent = \"(no multiset selected)\";\n      return;\n    }\n    const ms = multisets[currentMSName];\n    if(ms.isEmpty()) {\n      out.textContent = \"(empty multiset)\";\n      return;\n    }\n    let detail = 'Multiset \"' + ms.name + '\" details:\\n';\n    detail += 'Distinct elements: ' + ms.distinctCount() + '\\n';\n    detail += 'Total size (sum of counts): ' + ms.totalSize() + '\\n';\n    detail += 'Elements and counts:\\n';\n    for(const [e,c] of ms.map.entries()) {\n      detail += '  \"' + e + '\": ' + c + '\\n';\n    }\n    out.textContent = detail;\n  }\n\n  // Query handlers\n  function doCountQuery() {\n    const elem = $('query-elem-input').value.trim();\n    if(!elem) {\n      $('query-output').textContent = \"Please enter an element to query.\";\n      return;\n    }\n    const ms = multisets[currentMSName];\n    if(!ms) {\n      $('query-output').textContent = \"No multiset selected.\";\n      return;\n    }\n    const count = ms.count(elem);\n    $('query-output').textContent = `\"${elem}\" occurs ${count} time${count !== 1 ? 's' : ''}.`;\n  }\n  function doContainsQuery() {\n    const elem = $('query-elem-input').value.trim();\n    if(!elem) {\n      $('query-output').textContent = \"Please enter an element to query.\";\n      return;\n    }\n    const ms = multisets[currentMSName];\n    if(!ms) {\n      $('query-output').textContent = \"No multiset selected.\";\n      return;\n    }\n    const contains = ms.contains(elem);\n    $('query-output').textContent = contains ? `\"${elem}\" is in the multiset.` : `\"${elem}\" is NOT in the multiset.`;\n  }\n  function doMaxCountQuery() {\n    const ms = multisets[currentMSName];\n    if(!ms) {\n      $('query-output').textContent = \"No multiset selected.\";\n      return;\n    }\n    if(ms.isEmpty()) {\n      $('query-output').textContent = \"Multiset is empty.\";\n      return;\n    }\n    const maxElems = ms.maxCountElements();\n    const s = maxElems.map(e => `\"${e.element}\" (${e.count})`).join(', ');\n    $('query-output').textContent = \"Max count element(s): \" + s + '.';\n  }\n  function doMinCountQuery() {\n    const ms = multisets[currentMSName];\n    if(!ms) {\n      $('query-output').textContent = \"No multiset selected.\";\n      return;\n    }\n    if(ms.isEmpty()) {\n      $('query-output').textContent = \"Multiset is empty.\";\n      return;\n    }\n    const minElems = ms.minCountElements();\n    const s = minElems.map(e => `\"${e.element}\" (${e.count})`).join(', ');\n    $('query-output').textContent = \"Min count element(s): \" + s + '.';\n  }\n  function doTotalSizeQuery() {\n    const ms = multisets[currentMSName];\n    if(!ms) {\n      $('query-output').textContent = \"No multiset selected.\";\n      return;\n    }\n    $('query-output').textContent = 'Total size (sum of counts): ' + ms.totalSize() + '.';\n  }\n  function doDistinctCountQuery() {\n    const ms = multisets[currentMSName];\n    if(!ms) {\n      $('query-output').textContent = \"No multiset selected.\";\n      return;\n    }\n    $('query-output').textContent = 'Distinct elements count: ' + ms.distinctCount() + '.';\n  }\n\n  // Builder handlers\n  function addElementToCurrent() {\n    const elem = $('elem-input').value.trim();\n    const count = parseInt($('count-input').value);\n    if(!elem) {\n      alert('Please enter an element string.');\n      return;\n    }\n    if(isNaN(count) || count < 1) {\n      alert('Please enter a valid count (integer ≥ 1).');\n      return;\n    }\n    const ms = multisets[currentMSName];\n    ms.add(elem, count);\n    updateCurrentMultisetOutput();\n    updateMultisetDetailOutput();\n  }\n  function removeElementFromCurrent() {\n    const elem = $('elem-input').value.trim();\n    const count = parseInt($('count-input').value);\n    if(!elem) {\n      alert('Please enter an element string.');\n      return;\n    }\n    if(isNaN(count) || count < 1) {\n      alert('Please enter a valid count (integer ≥ 1).');\n      return;\n    }\n    const ms = multisets[currentMSName];\n    ms.remove(elem, count);\n    updateCurrentMultisetOutput();\n    updateMultisetDetailOutput();\n  }\n  function setCountElementCurrent() {\n    const elem = $('elem-input').value.trim();\n    let count = parseInt($('count-input').value);\n    if(!elem) {\n      alert('Please enter an element string.');\n      return;\n    }\n    if(isNaN(count) || count < 0) {\n      alert('Please enter a valid count (integer ≥ 0).');\n      return;\n    }\n    const ms = multisets[currentMSName];\n    ms.setCount(elem, count);\n    updateCurrentMultisetOutput();\n    updateMultisetDetailOutput();\n  }\n  function clearCurrentMultiset() {\n    if(!confirm('Are you sure you want to clear the current multiset?')) return;\n    const ms = multisets[currentMSName];\n    ms.map.clear();\n    updateCurrentMultisetOutput();\n    updateMultisetDetailOutput();\n  }\n  function updateShowFormat() {\n    updateCurrentMultisetOutput();\n  }\n\n  // Inter-Multiset operations handlers\n  function createNewMultisetFromOperation(resultMS, name) {\n    if(!name) {\n      alert(\"Enter a name for the new multiset.\");\n      return null;\n    }\n    if(name in multisets) {\n      if(!confirm(`Multiset \"${name}\" exists. Overwrite?`)) return null;\n    }\n    resultMS.name = name;\n    multisets[name] = resultMS;\n    updateMultisetSelectors();\n    currentMSName = name;\n    updateCurrentMultisetOutput();\n    updateMultisetDetailOutput();\n    return resultMS;\n  }\n\n  function getSelectedMultisetsForOperation() {\n    const n1 = $('ms-select1').value;\n    const n2 = $('ms-select2').value;\n    if(!(n1 in multisets) || !(n2 in multisets)) {\n      alert('Select valid multisets in both selectors.');\n      return null;\n    }\n    return [multisets[n1], multisets[n2]];\n  }\n\n  function opUnion() {\n    const sel = getSelectedMultisetsForOperation();\n    if(!sel) return;\n    const [ms1, ms2] = sel;\n    const result = ms1.union(ms2);\n    $('adv-output').textContent = '(result of union shown here)';\n    return result;\n  }\n  function opIntersection() {\n    const sel = getSelectedMultisetsForOperation();\n    if(!sel) return;\n    const [ms1, ms2] = sel;\n    const result = ms1.intersection(ms2);\n    $('adv-output').textContent = '(result of intersection shown here)';\n    return result;\n  }\n  function opSum() {\n    const sel = getSelectedMultisetsForOperation();\n    if(!sel) return;\n    const [ms1, ms2] = sel;\n    const result = ms1.sum(ms2);\n    $('adv-output').textContent = '(result of sum shown here)';\n    return result;\n  }\n  function opDifference() {\n    const sel = getSelectedMultisetsForOperation();\n    if(!sel) return;\n    const [ms1, ms2] = sel;\n    const result = ms1.difference(ms2);\n    $('adv-output').textContent = '(result of difference shown here)';\n    return result;\n  }\n\n  // Perform operation and create new multiset\n  function performOperationAndCreate(opFunc) {\n    const name = $('newms-name').value.trim();\n    if(!name) {\n      alert(\"Enter a name for the new multiset.\");\n      return;\n    }\n    const result = opFunc();\n    if(!result) return;\n    createNewMultisetFromOperation(result, name);\n    $('newms-name').value = '';\n  }\n\n  // Delete multiset handler\n  function deleteSelectedMultiset() {\n    if(currentMSName === 'default') {\n      alert('Cannot delete the default multiset.');\n      return;\n    }\n    if(!confirm(`Are you sure you want to delete multiset \"${currentMSName}\"?`)) return;\n    delete multisets[currentMSName];\n    const keys = Object.keys(multisets);\n    currentMSName = keys.length ? keys[0] : 'default';\n    if(!(currentMSName in multisets)) {\n      multisets[currentMSName] = new Multiset(currentMSName);\n    }\n    updateMultisetSelectors();\n    updateCurrentMultisetOutput();\n    updateMultisetDetailOutput();\n  }\n\n  // Advanced exploration handlers\n  function applyFilter() {\n    const msName = $('adv-select-ms').value;\n    if(!(msName in multisets)) {\n      alert(\"Select a valid multiset for advanced exploration.\");\n      return null;\n    }\n    let minc = parseInt($('filter-min-count').value);\n    let maxc = parseInt($('filter-max-count').value);\n    if(isNaN(minc) || minc < 0) minc = 0;\n    if(isNaN(maxc) || maxc < minc) maxc = minc;\n    const ms = multisets[msName];\n    const filtered = ms.filterByCount(minc, maxc);\n    return filtered;\n  }\n  function applyTransformation() {\n    const ms = lastAdvOutputMultiset;\n    if(!ms) {\n      alert(\"No multiset available for transformation. Apply a filter first.\");\n      return;\n    }\n    const t = $('transform-select').value;\n    if(t === 'none') {\n      advSetOutput(ms.clone());\n    } else {\n      advSetOutput(ms.transform(t));\n    }\n  }\n  // Display the advanced output multiset\n  function advSetOutput(ms) {\n    lastAdvOutputMultiset = ms;\n    if(ms.isEmpty()) {\n      $('adv-output').textContent = '(result is empty multiset)';\n      return;\n    }\n    let out = 'Multiset \"' + ms.name + '\" (advanced output):\\n';\n    out += 'Distinct elements: ' + ms.distinctCount() + '\\n';\n    out += 'Total size (sum counts): ' + ms.totalSize() + '\\n';\n    out += 'Elements (element: count):\\n';\n    for(const [e,c] of ms.map.entries()) {\n      out += '  \"' + e + '\": ' + c + '\\n';\n    }\n    $('adv-output').textContent = out;\n  }\n  function resetAdvancedOutput() {\n    lastAdvOutputMultiset = null;\n    $('adv-output').textContent = '(no advanced exploration yet)';\n  }\n\n  let lastAdvOutputMultiset = null;\n\n  // Initial setup and attaching handlers\n\n  // Builder buttons\n  $('add-btn').onclick = addElementToCurrent;\n  $('remove-btn').onclick = removeElementFromCurrent;\n  $('set-btn').onclick = setCountElementCurrent;\n  $('clear-btn').onclick = clearCurrentMultiset;\n  $('show-format').onchange = updateShowFormat;\n\n  // Query buttons\n  $('count-query-btn').onclick = doCountQuery;\n  $('contains-query-btn').onclick = doContainsQuery;\n  $('max-count-btn').onclick = doMaxCountQuery;\n  $('min-count-btn').onclick = doMinCountQuery;\n  $('total-size-btn').onclick = doTotalSizeQuery;\n  $('distinct-count-btn').onclick = doDistinctCountQuery;\n\n  // Operations buttons\n  $('union-btn').onclick = () => performOperationAndCreate(opUnion);\n  $('intersection-btn').onclick = () => performOperationAndCreate(opIntersection);\n  $('sum-btn').onclick = () => performOperationAndCreate(opSum);\n  $('difference-btn').onclick = () => performOperationAndCreate(opDifference);\n  $('create-ms-btn').onclick = () => {\n    const name = $('newms-name').value.trim();\n    if(!name) {\n      alert('Enter a name for the new empty multiset.');\n      return;\n    }\n    if(name in multisets) {\n      alert('Multiset with that name already exists.');\n      return;\n    }\n    multisets[name] = new Multiset(name);\n    currentMSName = name;\n    updateMultisetSelectors();\n    updateCurrentMultisetOutput();\n    updateMultisetDetailOutput();\n    $('newms-name').value = '';\n  };\n  $('delete-ms-btn').onclick = deleteSelectedMultiset;\n\n  // Advanced exploration buttons\n  $('apply-filter-btn').onclick = () => {\n    const filtered = applyFilter();\n    if(filtered) advSetOutput(filtered);\n  };\n  $('apply-transform-btn').onclick = applyTransformation;\n  $('reset-adv-output-btn').onclick = resetAdvancedOutput;\n\n  // On multiset select change in advanced exploration, reset advanced output\n  $('adv-select-ms').onchange = resetAdvancedOutput;\n\n  // Initialize\n  updateMultisetSelectors();\n  updateCurrentMultisetOutput();\n  updateMultisetDetailOutput();\n})();\n</script>\n</body>\n</html>"
