    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Paging</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        \n        .container {\n            max-width: 600px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        \n        .button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        \n        .button:hover {\n            background-color: #3e8e41;\n        }\n        \n        .input-field {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        \n        .input-field input[type=\"number\"] {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        \n        .button-container {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 20px;\n        }\n        \n        .button-container button {\n            margin-right: 10px;\n        }\n        \n        .button-container input[type=\"button\"] {\n            padding: 10px 20px;\n            cursor: pointer;\n        }\n        \n        .button-container input[type=\"submit\"] {\n            padding: 10px 20px;\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        \n        .button-container input[type=\"submit\"]:hover {\n            background-color: #3e8e41;\n        }\n        \n        .pagination {\n            margin-top: 20px;\n            text-align: center;\n        }\n        \n        .pagination button {\n            padding: 10px 20px;\n            cursor: pointer;\n        }\n        \n        .pagination button:hover {\n            background-color: #3e8e41;\n        }\n        \n        .pagination a {\n            padding: 10px 20px;\n            cursor: pointer;\n        }\n        \n        .pagination a:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Paging</h1>\n        <input type=\"number\" id=\"amount\" value=\"10\" />\n        <button id=\"clear-button\">Clear</button>\n        <button id=\"next-button\">Next</button>\n        <button id=\"previous-button\">Previous</button>\n        <div class=\"pagination\">\n            <button id=\"prev-button\">Prev</button>\n            <button id=\"current-button\">1</button>\n            <button id=\"next-button\">2</button>\n            <button id=\"end-button\">End</button>\n        </div>\n    </div>\n\n    <script>\n        let currentAmount = 10;\n        let currentPage = 1;\n        let prevButtonPressed = false;\n        let nextButtonPressed = false;\n        let endButtonPressed = false;\n\n        document.getElementById('clear-button').addEventListener('click', function() {\n            document.getElementById('amount').value = '10';\n            document.getElementById('current-button').textContent = '1';\n            prevButtonPressed = false;\n            nextButtonPressed = false;\n            endButtonPressed = false;\n        });\n\n        document.getElementById('next-button').addEventListener('click', function() {\n            if (prevButtonPressed) {\n                document.getElementById('next-button').style.display = 'none';\n                document.getElementById('prev-button').style.display = 'none';\n                document.getElementById('current-button').style.display = 'none';\n                document.getElementById('next-button').style.display = 'none';\n                document.getElementById('prev-button').style.display = 'none';\n                document.getElementById('end-button').style.display = 'none';\n                document.getElementById('clear-button').style.display = 'none';\n                document.getElementById('current-button').textContent = '1';\n                document.getElementById('prev-button').textContent = 'Prev';\n                document.getElementById('next-button').textContent = 'Next';\n                document.getElementById('end-button').textContent = 'End';\n                prevButtonPressed = false;\n                nextButtonPressed = false;\n                endButtonPressed = false;\n            } else {\n                document.getElementById('current-button').textContent = currentPage;\n                currentAmount = parseInt(document.getElementById('amount').value);\n                document.getElementById('next-button').style.display = 'block';\n                document.getElementById('prev-button').style.display = 'block';\n                document.getElementById('end-button').style.display = 'block';\n                endButtonPressed = true;\n            }\n        });\n\n        document.getElementById('previous-button').addEventListener('click', function() {\n            if (currentAmount > 1) {\n                document.getElementById('current-button').textContent = currentPage - 1;\n                currentAmount = parseInt(document.getElementById('amount').value);\n                document.getElementById('next-button').style.display = 'block';\n                document.getElementById('prev-button').style.display = 'block';\n                document.getElementById('end-button').style.display = 'block';\n                endButtonPressed = true;\n            } else {\n                endButtonPressed = false;\n            }\n        });\n\n        document.getElementById('end-button').addEventListener('click', function() {\n            if (currentAmount <= 9) {\n                document.getElementById('current-button').textContent = currentPage;\n                document.getElementById('next-button').style.display = 'block';\n                document.getElementById('prev-button').style.display = 'block';\n                document.getElementById('end-button').style.display = 'none';\n                endButtonPressed = true;\n            } else {\n                endButtonPressed = false;\n            }\n        });\n\n        document.getElementById('next-button').addEventListener('click', function() {\n            if (prevButtonPressed) {\n                document.getElementById('next-button').style.display = 'none';\n                document.getElementById('prev-button').style.display = 'none';\n                document.getElementById('current-button').style.display = 'none';\n                document.getElementById('next-button').style.display = 'none';\n                document.getElementById('prev-button').style.display = 'none';\n                document.getElementById('end-button').style.display = 'none';\n                document.getElementById('clear-button').style.display = 'none';\n                document.getElementById('current-button').textContent = '1';\n                document.getElementById('prev-button').textContent = 'Prev';\n                document.getElementById('next-button').textContent = 'Next';\n                document.getElementById('end-button').textContent = 'End';\n                prevButtonPressed = false;\n                nextButtonPressed = false;\n                endButtonPressed = false;\n            } else {\n                document.getElementById('current-button').textContent = currentPage;\n                currentAmount = parseInt(document.getElementById('amount').value);\n                document.getElementById('next-button').style.display = 'block';\n                document.getElementById('prev-button').style.display = 'block';\n                document.getElementById('end-button').style.display = 'block';\n                endButtonPressed = true;\n            }\n        });\n    </script>\n</body>\n</html>"
