    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Linear Regression — Visual Concept</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #071028;\n      --accent-1: #7de3ff;\n      --accent-2: #93ffcb;\n      --muted: rgba(255,255,255,0.08);\n      --glass: rgba(255,255,255,0.04);\n      --glass-2: rgba(255,255,255,0.02);\n      --card-shadow: 0 10px 30px rgba(2,6,23,0.6);\n      --glass-border: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%;}\n    body{\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color: #e7f5ff;\n      background: radial-gradient(1200px 600px at 10% 15%, rgba(14,180,255,0.06), transparent 6%),\n                  radial-gradient(900px 450px at 90% 85%, rgba(147,255,203,0.04), transparent 8%),\n                  linear-gradient(180deg, var(--bg-1), var(--bg-2));\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding:40px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      min-height:100vh;\n    }\n\n    .stage{\n      width:1100px;\n      max-width:95vw;\n      display:grid;\n      grid-template-columns: 1fr 520px;\n      gap:32px;\n      align-items:center;\n    }\n\n    .panel{\n      padding:36px;\n      border-radius:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: var(--card-shadow);\n      border: 1px solid rgba(255,255,255,0.03);\n      backdrop-filter: blur(8px) saturate(120%);\n      position:relative;\n      overflow:hidden;\n    }\n\n    .intro{\n      padding:48px 36px;\n      border-radius:16px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.016), rgba(255,255,255,0.006));\n      box-shadow: 0 8px 30px rgba(2,6,23,0.45);\n    }\n\n    h1{\n      font-family:'Playfair Display', serif;\n      font-size:48px;\n      line-height:1;\n      margin:0 0 8px 0;\n      letter-spacing: -0.02em;\n      color: #f7fcff;\n      text-shadow: 0 6px 22px rgba(10,20,30,0.6);\n    }\n\n    .subtitle{\n      font-weight:600;\n      color: rgba(235,250,255,0.88);\n      margin-bottom:18px;\n      font-size:15px;\n      opacity:0.95;\n    }\n\n    p.lead{\n      margin:0 0 18px 0;\n      color: rgba(230,244,255,0.85);\n      line-height:1.6;\n      font-size:15px;\n    }\n\n    .decor{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-top:18px;\n    }\n\n    .pill{\n      background: linear-gradient(90deg, rgba(125,227,255,0.12), rgba(147,255,203,0.06));\n      color: var(--accent-1);\n      padding:8px 12px;\n      border-radius:999px;\n      font-weight:600;\n      font-size:13px;\n      border:1px solid rgba(125,227,255,0.06);\n      backdrop-filter: blur(6px);\n      box-shadow: 0 6px 20px rgba(7,18,32,0.45);\n    }\n\n    .small{\n      color: rgba(235,250,255,0.7);\n      font-size:13px;\n      margin-left:auto;\n      opacity:0.9;\n    }\n\n    /* Graph card */\n    .graph-card{\n      padding:28px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      align-items:stretch;\n      justify-content:center;\n      min-height:460px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.008));\n      border-radius:14px;\n      border:1px solid rgba(255,255,255,0.03);\n    }\n\n    .graph-wrap{\n      position:relative;\n      width:100%;\n      height:380px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    svg.graph{\n      width:100%;\n      height:100%;\n      overflow:visible;\n      display:block;\n      user-select:none;\n    }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      justify-content:space-between;\n      margin-top:6px;\n    }\n\n    .buttons{\n      display:flex;\n      gap:12px;\n    }\n\n    .btn{\n      appearance:none;\n      border:0;\n      padding:10px 16px;\n      border-radius:12px;\n      font-weight:600;\n      cursor:pointer;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color: #dff8ff;\n      border: 1px solid rgba(255,255,255,0.04);\n      transition: all 220ms cubic-bezier(.2,.9,.25,1);\n      box-shadow: 0 6px 18px rgba(3,9,20,0.35);\n      display:inline-flex;\n      align-items:center;\n      gap:10px;\n    }\n\n    .btn:active{ transform:translateY(1px) scale(.998); }\n    .btn.primary{\n      background: linear-gradient(90deg, #53e3ff, #93ffcb);\n      color: #00232b;\n      font-weight:700;\n      box-shadow: 0 12px 30px rgba(83,227,255,0.14);\n      border: 1px solid rgba(255,255,255,0.06);\n    }\n\n    .btn.ghost{\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.04);\n      color: rgba(230,246,255,0.9);\n    }\n\n    .stats{\n      display:flex;\n      gap:14px;\n      align-items:center;\n    }\n\n    .stat{\n      padding:10px 12px;\n      border-radius:10px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006));\n      border:1px solid rgba(255,255,255,0.02);\n      min-width:88px;\n      text-align:center;\n    }\n\n    .stat .val{\n      font-weight:700;\n      font-size:16px;\n      color:#eafff5;\n    }\n    .stat .lbl{\n      font-size:12px;\n      color:rgba(235,250,255,0.7);\n      margin-top:6px;\n    }\n\n    /* subtle animated background elements */\n    .orb{\n      position:absolute;\n      border-radius:50%;\n      filter: blur(36px);\n      opacity:0.12;\n      pointer-events:none;\n      mix-blend-mode: screen;\n    }\n    .orb.one{ width:360px; height:360px; left:-80px; top:-60px; background: linear-gradient(120deg,#53e3ff,#7de3ff); }\n    .orb.two{ width:260px; height:260px; right:-60px; bottom:-80px; background: linear-gradient(120deg,#93ffcb,#7de3ff); }\n\n    /* Responsive */\n    @media (max-width:980px){\n      .stage{ grid-template-columns: 1fr; gap:20px; }\n      .graph-card{ order:-1; }\n      h1{ font-size:38px; }\n      .graph-wrap{ height:320px; }\n    }\n\n    /* Small labels on axes */\n    .axis-label{\n      font-size:12px;\n      fill: rgba(230,244,255,0.7);\n      font-weight:600;\n    }\n\n    /* point animations */\n    .point {\n      transform-origin:center;\n      transition: transform 520ms cubic-bezier(.2,.95,.2,1), opacity 520ms;\n      opacity:0;\n    }\n\n    .point.show{ opacity:1; transform: translateY(0) scale(1); filter: drop-shadow(0 4px 16px rgba(4,18,30,0.45)); }\n    .point.hidden{ transform: translateY(18px) scale(.88); opacity:0; }\n\n    /* line glow */\n    .fit-line{\n      stroke-linecap:round;\n      stroke-width:3;\n      filter: drop-shadow(0 8px 24px rgba(83,227,255,0.12));\n      transition: stroke 320ms;\n    }\n\n    /* residual style */\n    .residual{\n      stroke: rgba(255,255,255,0.12);\n      stroke-width:2;\n      stroke-dasharray:4 4;\n      transition: opacity 320ms;\n    }\n\n    .legend{\n      display:flex;\n      gap:10px;\n      align-items:center;\n      font-size:13px;\n      color: rgba(230,244,255,0.78);\n      margin-top:6px;\n    }\n\n    .legend .swatch{\n      width:12px;height:12px;border-radius:3px;display:inline-block;\n      box-shadow: 0 6px 18px rgba(0,0,0,0.6);\n    }\n\n    .swatch.points{ background: linear-gradient(90deg,#006cff,#7de3ff); }\n    .swatch.line{ background: linear-gradient(90deg,#7de3ff,#93ffcb); }\n\n    footer.credit{\n      margin-top:22px;\n      font-size:12px;\n      color: rgba(230,244,255,0.62);\n    }\n  </style>\n</head>\n<body>\n  <div class=\"stage\" role=\"main\" aria-label=\"Linear Regression Visualization\">\n\n    <div class=\"panel intro\" aria-hidden=\"false\">\n      <div style=\"display:flex;align-items:center;gap:18px;\">\n        <div style=\"flex:1\">\n          <h1>Linear Regression</h1>\n          <div class=\"subtitle\">Understanding the best-fit line</div>\n          <p class=\"lead\">Linear regression finds the straight line that best explains the relationship between two variables. Here, points represent observations — the line minimizes the overall vertical error (least squares).</p>\n        </div>\n        <div style=\"width:96px;height:96px;border-radius:16px;background:linear-gradient(180deg,#032033, #052334);display:flex;align-items:center;justify-content:center;box-shadow:0 8px 30px rgba(5,20,30,0.6);border:1px solid rgba(255,255,255,0.03)\">\n          <svg width=\"64\" height=\"64\" viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7de3ff\"/>\n                <stop offset=\"1\" stop-color=\"#93ffcb\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"6\" y=\"42\" width=\"52\" height=\"10\" rx=\"2\" fill=\"rgba(255,255,255,0.03)\"></rect>\n            <path d=\"M12 38 L22 28 L34 34 L48 20\" fill=\"none\" stroke=\"url(#g1)\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n            <circle cx=\"22\" cy=\"28\" r=\"2.2\" fill=\"#7de3ff\"></circle>\n            <circle cx=\"34\" cy=\"34\" r=\"2.2\" fill=\"#93ffcb\"></circle>\n          </svg>\n        </div>\n      </div>\n\n      <div class=\"decor\" style=\"margin-top:18px\">\n        <div class=\"pill\">Least squares • Slope & Intercept</div>\n        <div class=\"small\">Visual-only demo — press play to animate</div>\n      </div>\n\n      <div style=\"display:flex;gap:16px;align-items:center;margin-top:20px;flex-wrap:wrap\">\n        <div style=\"max-width:520px\">\n          <p style=\"font-size:13px;color:rgba(235,250,255,0.7);margin:0\">\n            The line is estimated analytically using the formula:\n          </p>\n          <p style=\"font-family:Inter, monospace;font-weight:600;font-size:13px;margin:8px 0;color:#e7fffb;background:linear-gradient(90deg, rgba(125,227,255,0.04), rgba(147,255,203,0.02));padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.02)\">\n            slope = cov(x,y) / var(x) • intercept = mean(y) − slope × mean(x)\n          </p>\n          <div class=\"legend\" style=\"margin-top:6px\">\n            <span class=\"swatch points\" aria-hidden=\"true\"></span><span>observations</span>\n            <span class=\"swatch line\" aria-hidden=\"true\" style=\"margin-left:12px\"></span><span>best-fit line</span>\n          </div>\n        </div>\n      </div>\n\n      <footer class=\"credit\">Designed for clarity • Smooth, minimal interaction</footer>\n    </div>\n\n    <div class=\"panel graph-card\" role=\"region\" aria-label=\"Graph showing scatter points and linear fit\">\n      <div class=\"graph-wrap\">\n        <div class=\"orb one\" aria-hidden=\"true\"></div>\n        <div class=\"orb two\" aria-hidden=\"true\"></div>\n\n        <svg class=\"graph\" viewBox=\"0 0 720 520\" preserveAspectRatio=\"xMidYMid meet\" id=\"viz\" aria-hidden=\"false\" role=\"img\">\n          <defs>\n            <linearGradient id=\"lineGrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0\" stop-color=\"#7de3ff\" stop-opacity=\"1\"/>\n              <stop offset=\"1\" stop-color=\"#93ffcb\" stop-opacity=\"1\"/>\n            </linearGradient>\n            <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"6\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- background grid -->\n          <g id=\"grid\" fill=\"none\" stroke=\"rgba(255,255,255,0.02)\" stroke-width=\"1\">\n            <!-- vertical lines -->\n            <g id=\"vlines\"></g>\n            <g id=\"hlines\"></g>\n          </g>\n\n          <!-- axes minimal -->\n          <g id=\"axes\" transform=\"translate(60,40)\">\n            <path d=\"M0 420 L600 420\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.5\" />\n            <path d=\"M0 420 L0 0\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.5\" />\n            <g id=\"xlabels\"></g>\n            <g id=\"ylabels\"></g>\n          </g>\n\n          <!-- data points -->\n          <g id=\"points\" transform=\"translate(60,40)\"></g>\n\n          <!-- residuals -->\n          <g id=\"residuals\" transform=\"translate(60,40)\"></g>\n\n          <!-- fit line -->\n          <g transform=\"translate(60,40)\">\n            <line id=\"fitLine\" class=\"fit-line\" x1=\"0\" y1=\"0\" x2=\"600\" y2=\"0\" stroke=\"url(#lineGrad)\" stroke-width=\"3.6\" stroke-linecap=\"round\" style=\"opacity:0.98;filter:url(#glow)\"></line>\n          </g>\n\n          <!-- overlay text -->\n          <g transform=\"translate(36,12)\">\n            <text x=\"0\" y=\"12\" class=\"axis-label\" style=\"font-family:Inter, sans-serif;font-weight:700\">Observations vs Prediction</text>\n          </g>\n\n        </svg>\n      </div>\n\n      <div class=\"controls\">\n        <div class=\"buttons\" role=\"group\" aria-label=\"Controls\">\n          <button class=\"btn primary\" id=\"playBtn\" title=\"Play Animation\" aria-pressed=\"false\">\n            ▶ Play\n          </button>\n          <button class=\"btn ghost\" id=\"resBtn\" title=\"Toggle Residuals\" aria-pressed=\"false\">\n            Residuals\n          </button>\n        </div>\n\n        <div class=\"stats\" aria-hidden=\"true\">\n          <div class=\"stat\">\n            <div class=\"val\" id=\"slopeVal\">—</div>\n            <div class=\"lbl\">slope (m)</div>\n          </div>\n          <div class=\"stat\">\n            <div class=\"val\" id=\"interceptVal\">—</div>\n            <div class=\"lbl\">intercept (b)</div>\n          </div>\n          <div class=\"stat\">\n            <div class=\"val\" id=\"r2Val\">—</div>\n            <div class=\"lbl\">R²</div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n  </div>\n\n  <script>\n    (function () {\n      // SETTINGS\n      const SVG_WIDTH = 600;\n      const SVG_HEIGHT = 420;\n      const MARGIN = {left:0, top:0};\n      const POINT_COUNT = 18;\n      const jitter = 0.9;\n\n      // DOM\n      const svg = document.getElementById('viz');\n      const pointsG = svg.querySelector('#points');\n      const residualsG = svg.querySelector('#residuals');\n      const vlinesG = svg.querySelector('#vlines');\n      const hlinesG = svg.querySelector('#hlines');\n      const xlabelsG = svg.querySelector('#xlabels');\n      const ylabelsG = svg.querySelector('#ylabels');\n      const fitLine = svg.querySelector('#fitLine');\n\n      const playBtn = document.getElementById('playBtn');\n      const resBtn = document.getElementById('resBtn');\n      const slopeVal = document.getElementById('slopeVal');\n      const interceptVal = document.getElementById('interceptVal');\n      const r2Val = document.getElementById('r2Val');\n\n      // Generate synthetic data\n      let data = generateData(POINT_COUNT);\n\n      // Draw grid and labels\n      drawGrid();\n\n      // Render points initially hidden\n      renderPoints(data, true);\n\n      // Initialize line at mean (horizontal)\n      let initial = { m: 0, b: meanY(data) };\n      let solution = computeLeastSquares(data);\n      updateStats(solution);\n      setLine(initial);\n\n      // residuals state\n      let showResiduals = false;\n\n      // Bind events\n      playBtn.addEventListener('click', playAnimation);\n      resBtn.addEventListener('click', toggleResiduals);\n\n      // slight entrance animation on load\n      setTimeout(()=> {\n        animatePointsIn();\n      }, 220);\n\n      // FUNCTIONS\n\n      function generateData(n){\n        // underlying true line\n        const trueM = 0.9;\n        const trueB = 18;\n        // x range roughly 10..90\n        const xs = [];\n        for(let i=0;i<n;i++){\n          xs.push(10 + i*(80/(n-1)) + (Math.random()-0.5)*3* (jitter));\n        }\n        const pts = xs.map((x,i)=>{\n          const noise = (Math.random()-0.5)*18;\n          const y = trueM * x + trueB + noise + (Math.random()-0.5)*8*(i%3===0?0.6:0.0);\n          return {x,y};\n        });\n        // subtle shuffle for visual distribution\n        for(let i=pts.length-1;i>0;i--){\n          const j = Math.floor(Math.random()*(i+1));\n          [pts[i],pts[j]] = [pts[j],pts[i]];\n        }\n        return pts;\n      }\n\n      function computeLeastSquares(points){\n        const n = points.length;\n        const xs = points.map(p=>p.x);\n        const ys = points.map(p=>p.y);\n        const meanx = xs.reduce((a,b)=>a+b,0)/n;\n        const meany = ys.reduce((a,b)=>a+b,0)/n;\n        let num=0, den=0;\n        for(let i=0;i<n;i++){\n          num += (xs[i]-meanx)*(ys[i]-meany);\n          den += (xs[i]-meanx)*(xs[i]-meanx);\n        }\n        const m = num/den;\n        const b = meany - m*meanx;\n        // R-squared\n        let ssTot = 0, ssRes = 0;\n        for(let i=0;i<n;i++){\n          const pred = m*xs[i] + b;\n          ssTot += (ys[i]-meany)*(ys[i]-meany);\n          ssRes += (ys[i]-pred)*(ys[i]-pred);\n        }\n        const r2 = 1 - (ssRes/ssTot);\n        return {m,b,r2};\n      }\n\n      function meanY(points){\n        return points.reduce((s,p)=>s+p.y,0)/points.length;\n      }\n\n      function drawGrid(){\n        // draw subtle grid 6x6\n        vlinesG.innerHTML = '';\n        hlinesG.innerHTML = '';\n        xlabelsG.innerHTML = '';\n        ylabelsG.innerHTML = '';\n        const cols = 6, rows = 6;\n        for(let i=0;i<=cols;i++){\n          const x = Math.round(i * (SVG_WIDTH/cols));\n          const path = document.createElementNS('http://www.w3.org/2000/svg','line');\n          path.setAttribute('x1', x);\n          path.setAttribute('y1', 0);\n          path.setAttribute('x2', x);\n          path.setAttribute('y2', SVG_HEIGHT);\n          path.setAttribute('stroke', 'rgba(255,255,255,' + (i%2===0?0.02:0.01) + ')');\n          path.setAttribute('stroke-width', i%2===0?1.2:0.8);\n          vlinesG.appendChild(path);\n        }\n        for(let j=0;j<=rows;j++){\n          const y = Math.round(j * (SVG_HEIGHT/rows));\n          const path = document.createElementNS('http://www.w3.org/2000/svg','line');\n          path.setAttribute('x1', 0);\n          path.setAttribute('y1', y);\n          path.setAttribute('x2', SVG_WIDTH);\n          path.setAttribute('y2', y);\n          path.setAttribute('stroke', 'rgba(255,255,255,' + (j%2===0?0.02:0.01) + ')');\n          path.setAttribute('stroke-width', j%2===0?1.2:0.6);\n          hlinesG.appendChild(path);\n        }\n\n        // labels: x 0..100, y 0..100\n        for(let i=0;i<=5;i++){\n          const x = Math.round(i*(SVG_WIDTH/5));\n          const t = document.createElementNS('http://www.w3.org/2000/svg','text');\n          t.setAttribute('x', x+MARGIN.left+4);\n          t.setAttribute('y', SVG_HEIGHT + 16);\n          t.setAttribute('class','axis-label');\n          t.textContent = Math.round(i*20);\n          xlabelsG.appendChild(t);\n        }\n        for(let j=0;j<=5;j++){\n          const y = Math.round(j*(SVG_HEIGHT/5));\n          const t = document.createElementNS('http://www.w3.org/2000/svg','text');\n          t.setAttribute('x', -34);\n          t.setAttribute('y', y+4);\n          t.setAttribute('class','axis-label');\n          t.textContent = Math.round(100 - j*20);\n          ylabelsG.appendChild(t);\n        }\n      }\n\n      function renderPoints(points, hidden=false){\n        pointsG.innerHTML = '';\n        points.forEach((p, idx) => {\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          g.setAttribute('transform', `translate(${scaleX(p.x)}, ${scaleY(p.y)})`);\n          g.setAttribute('class','point ' + (hidden? 'hidden':'show'));\n          // outer halo\n          const halo = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          halo.setAttribute('r', 10);\n          halo.setAttribute('fill', 'url(#haloGrad)');\n          halo.setAttribute('opacity', '0.12');\n          halo.setAttribute('class','halo');\n          // colored dot\n          const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          circle.setAttribute('r', 6.5);\n          circle.setAttribute('fill', idx%2===0? '#006cff' : '#7de3ff');\n          circle.setAttribute('stroke', 'rgba(255,255,255,0.06)');\n          circle.setAttribute('stroke-width', '1.2');\n          circle.setAttribute('cx', 0);\n          circle.setAttribute('cy', 0);\n\n          // slight bouncing initial transform\n          g.appendChild(halo);\n          g.appendChild(circle);\n\n          // subtle tiny label on hover (accessible, but interaction is limited)\n          g.title = `x: ${p.x.toFixed(1)}, y: ${p.y.toFixed(1)}`;\n\n          pointsG.appendChild(g);\n        });\n      }\n\n      function setLine(params){\n        const {m,b} = params;\n        // compute endpoints across x in [0, SVG_WIDTH]\n        const x1 = 0;\n        const y1 = m * invScaleX(x1) + b;\n        const x2 = SVG_WIDTH;\n        const y2 = m * invScaleX(x2) + b;\n        const sy1 = scaleY(y1);\n        const sy2 = scaleY(y2);\n        fitLine.setAttribute('x1', x1);\n        fitLine.setAttribute('y1', sy1);\n        fitLine.setAttribute('x2', x2);\n        fitLine.setAttribute('y2', sy2);\n      }\n\n      function animatePointsIn(){\n        const groups = Array.from(pointsG.querySelectorAll('.point'));\n        groups.forEach((g,i)=>{\n          setTimeout(()=> {\n            g.classList.remove('hidden');\n            g.classList.add('show');\n            g.style.transitionDelay = '0s';\n          }, 60*i);\n        });\n      }\n\n      function playAnimation(){\n        playBtn.disabled = true;\n        playBtn.setAttribute('aria-pressed','true');\n        playBtn.innerText = '⟳ Animating';\n        // generate new data for a slightly different aesthetic each replay\n        data = generateData(POINT_COUNT);\n        renderPoints(data, true);\n        residualsG.innerHTML = '';\n        // recompute solution for this dataset\n        solution = computeLeastSquares(data);\n        updateStats({m:0,b:0,r2:0}); // blank while animating\n        animatePointsIn();\n\n        // animate line from initial horizontal to solution\n        const start = {m:0, b: meanY(data)};\n        const end = {m: solution.m, b: solution.b};\n        const duration = 1600;\n        const startTime = performance.now();\n\n        const animate = (t) => {\n          const p = Math.min(1, (t - startTime)/duration);\n          const ease = easeOutCubic(p);\n          const cur = {\n            m: start.m + (end.m - start.m)*ease,\n            b: start.b + (end.b - start.b)*ease\n          };\n          setLine(cur);\n          if(p < 1){\n            requestAnimationFrame(animate);\n          } else {\n            // show final state\n            setLine(end);\n            updateStats(solution);\n            if(showResiduals) drawResiduals();\n            playBtn.disabled = false;\n            playBtn.setAttribute('aria-pressed','false');\n            playBtn.innerText = '▶ Play';\n          }\n        };\n        requestAnimationFrame(animate);\n      }\n\n      function toggleResiduals(){\n        showResiduals = !showResiduals;\n        resBtn.setAttribute('aria-pressed', String(showResiduals));\n        resBtn.classList.toggle('primary', showResiduals);\n        if(showResiduals) {\n          drawResiduals();\n        } else {\n          // fade out\n          residualsG.querySelectorAll('*').forEach(el=>{ el.style.opacity=0; });\n          setTimeout(()=> residualsG.innerHTML = '', 420);\n        }\n      }\n\n      function drawResiduals(){\n        residualsG.innerHTML = '';\n        // compute current fit (use solution)\n        const m = solution.m;\n        const b = solution.b;\n        data.forEach((p, idx) => {\n          const px = scaleX(p.x);\n          const py = scaleY(p.y);\n          const lineY = scaleY(m * p.x + b);\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          const path = document.createElementNS('http://www.w3.org/2000/svg','line');\n          path.setAttribute('x1', px);\n          path.setAttribute('x2', px);\n          path.setAttribute('y1', py);\n          path.setAttribute('y2', py);\n          path.setAttribute('class','residual');\n          path.setAttribute('stroke', 'rgba(255,255,255,0.12)');\n          path.setAttribute('stroke-width', 2);\n          path.style.opacity = 0;\n          g.appendChild(path);\n          residualsG.appendChild(g);\n\n          // animate to actual residual length\n          setTimeout(()=> {\n            path.setAttribute('y2', lineY);\n            path.style.opacity = 1;\n          }, idx * 40 + 180);\n        });\n      }\n\n      function updateStats(sol){\n        slopeVal.innerText = sol.m ? sol.m.toFixed(3) : '—';\n        interceptVal.innerText = sol.b ? sol.b.toFixed(2) : '—';\n        r2Val.innerText = sol.r2 ? sol.r2.toFixed(3) : '—';\n      }\n\n      // Scaling helpers: map data x in approximate [minX, maxX] to [0, SVG_WIDTH]\n      function scaleX(x){\n        const xs = data.map(d=>d.x);\n        const minX = Math.min(...xs) - 6;\n        const maxX = Math.max(...xs) + 6;\n        return ((x - minX) / (maxX - minX)) * SVG_WIDTH;\n      }\n      function invScaleX(px){\n        const xs = data.map(d=>d.x);\n        const minX = Math.min(...xs) - 6;\n        const maxX = Math.max(...xs) + 6;\n        return (px / SVG_WIDTH) * (maxX - minX) + minX;\n      }\n      function scaleY(y){\n        // want y values to map so that larger y -> smaller SVG y (top)\n        const ys = data.map(d=>d.y);\n        const minY = Math.min(...ys) - 10;\n        const maxY = Math.max(...ys) + 10;\n        // invert\n        return ((maxY - y) / (maxY - minY)) * SVG_HEIGHT;\n      }\n\n      // easing\n      function easeOutCubic(t){ return 1 - Math.pow(1 - t, 3); }\n\n      // initial subtle animation of orbs\n      const orbs = document.querySelectorAll('.orb');\n      orbs.forEach((o,i)=>{\n        o.animate([\n          { transform: 'translateY(0px) scale(1)', opacity: 0.14 },\n          { transform: 'translateY('+ (i%2===0? '-6px' : '8px') +') scale(1.04)', opacity: 0.08 },\n          { transform: 'translateY(0px) scale(1)', opacity: 0.14 }\n        ], { duration: 8000 + i*3000, iterations: Infinity, easing: 'ease-in-out', delay: 200*i });\n      });\n\n      // tiny entrance fades for panels\n      document.querySelectorAll('.panel').forEach((p, i)=>{\n        p.style.opacity = 0;\n        p.style.transform = 'translateY(8px) scale(.998)';\n        setTimeout(()=> {\n          p.style.transition = 'all 860ms cubic-bezier(.2,.9,.25,1)';\n          p.style.opacity = 1;\n          p.style.transform = 'translateY(0) scale(1)';\n        }, 220 + i*80);\n      });\n\n      // window resize => redraw points mapping\n      window.addEventListener('resize', () => {\n        // re-render points to reposition\n        renderPoints(data, false);\n        setLine(solution || {m:0,b:meanY(data)});\n      });\n\n    })();\n  </script>\n</body>\n</html>"
