    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Prim's Algorithm Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap');\n\n  :root {\n    --bg-gradient-start: #141e30;\n    --bg-gradient-end: #243b55;\n    --primary-color: #ff6f61;\n    --accent-color: #f9d423;\n    --text-color-light: #f0f4f8;\n    --shadow-light: rgba(255, 111, 97, 0.4);\n    --shadow-glow: 0 0 12px var(--primary-color);\n  }\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    height: 100vh;\n    background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-end));\n    display: flex;\n    flex-direction: column;\n    font-family: 'Montserrat', sans-serif;\n    color: var(--text-color-light);\n    overflow: hidden;\n    user-select: none;\n  }\n\n  header {\n    padding: 2rem 2rem 1rem 2rem;\n    text-align: center;\n    letter-spacing: 2px;\n    text-shadow: 0 0 8px rgba(255 111 97 / 0.6);\n  }\n  header h1 {\n    margin: 0;\n    font-weight: 700;\n    font-size: 2.8rem;\n    line-height: 1.1;\n  }\n  header p {\n    margin-top: 0.4rem;\n    font-size: 1.1rem;\n    font-weight: 400;\n    font-style: italic;\n    letter-spacing: 0.1em;\n    color: var(--accent-color);\n    text-shadow: 0 0 6px rgba(249, 212, 35, 0.7);\n  }\n\n  main {\n    flex: 1;\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 1rem 2rem 3rem 2rem;\n  }\n\n  /* Canvas area */\n  #primCanvas {\n    width: 700px;\n    max-width: 100vw;\n    height: 520px;\n    border-radius: 24px;\n    background: radial-gradient(circle at center, #1d2a48, #101a30);\n    box-shadow:\n      inset 0 0 60px rgba(255,111,97,0.2),\n      0 0 40px rgba(255,111,97,0.3);\n    cursor: default;\n    display: block;\n  }\n\n  /* Control panel */\n  #controls {\n    position: absolute;\n    bottom: 2rem;\n    left: 50%;\n    transform: translateX(-50%);\n    display: flex;\n    gap: 1.4rem;\n  }\n\n  button {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    background: linear-gradient(135deg, var(--primary-color), var(--accent-color));\n    border: none;\n    border-radius: 40px;\n    padding: 0.8rem 2.4rem;\n    color: var(--bg-gradient-start);\n    font-size: 1.1rem;\n    cursor: pointer;\n    box-shadow:\n      0 4px 15px var(--shadow-light);\n    transition: background 0.35s ease, box-shadow 0.35s ease, transform 0.2s ease;\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n    user-select: none;\n  }\n  button:hover {\n    background: linear-gradient(135deg, var(--accent-color), var(--primary-color));\n    box-shadow:\n      0 6px 25px var(--shadow-light),\n      var(--shadow-glow);\n    transform: scale(1.07);\n  }\n  button:active {\n    transform: scale(0.95);\n  }\n\n  /* Tooltip style */\n  #tooltip {\n    position: absolute;\n    pointer-events: none;\n    padding: 0.3rem 0.6rem;\n    background: rgba(249, 212, 35, 0.85);\n    color: #141e30;\n    font-weight: 600;\n    font-size: 0.82rem;\n    border-radius: 6px;\n    box-shadow: 0 0 6px rgba(249, 212, 35, 0.6);\n    white-space: nowrap;\n    user-select: none;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n    will-change: transform, opacity;\n  }\n</style>\n</head>\n<body>\n  <header>\n    <h1>Prim's Algorithm</h1>\n    <p>Minimum Spanning Tree Visualized</p>\n  </header>\n  <main>\n    <canvas id=\"primCanvas\" width=\"700\" height=\"520\" aria-label=\"Prim's Algorithm visualization\"></canvas>\n    <div id=\"controls\" aria-label=\"Controls\">\n      <button id=\"startBtn\" aria-pressed=\"false\" aria-label=\"Start Prim's Algorithm animation\">Start Animation</button>\n      <button id=\"resetBtn\" aria-label=\"Reset visualization\">Reset</button>\n    </div>\n    <div id=\"tooltip\" role=\"tooltip\"></div>\n  </main>\n  <script>\n    (() => {\n      const canvas = document.getElementById('primCanvas');\n      const ctx = canvas.getContext('2d');\n      const width = canvas.width;\n      const height = canvas.height;\n\n      const startBtn = document.getElementById('startBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const tooltip = document.getElementById('tooltip');\n\n      // Color references\n      const NODE_COLOR = '#ff6f61';\n      const NODE_ACTIVE_COLOR = '#f9d423';\n      const NODE_INACTIVE_COLOR = '#6e7986';\n      const EDGE_COLOR = '#4a5e7a';\n      const EDGE_ACTIVE_COLOR = '#f9d423';\n      const EDGE_INACTIVE_COLOR = '#263347';\n\n      // Node and graph parameters\n      const NODE_RADIUS = 14;\n      const ACTIVE_NODE_RADIUS = 18;\n\n      // Animation timing\n      const STEP_DURATION = 1200; // ms per step\n\n      // Graph nodes preset (positioned with aesthetic layout)\n      const nodes = [\n        { id: 0, x: 140, y: 140 },\n        { id: 1, x: 400, y: 90 },\n        { id: 2, x: 590, y: 170 },\n        { id: 3, x: 620, y: 400 },\n        { id: 4, x: 460, y: 440 },\n        { id: 5, x: 270, y: 440 },\n        { id: 6, x: 100, y: 340 },\n      ];\n\n      // Edges defined as pairs with weights, undirected graph\n      const edges = [\n        { id: 0, from: 0, to: 1, weight: 14 },\n        { id: 1, from: 0, to: 6, weight: 7 },\n        { id: 2, from: 0, to: 5, weight: 9 },\n        { id: 3, from: 1, to: 2, weight: 10 },\n        { id: 4, from: 1, to: 6, weight: 2 },\n        { id: 5, from: 2, to: 3, weight: 6 },\n        { id: 6, from: 3, to: 4, weight: 4 },\n        { id: 7, from: 4, to: 5, weight: 8 },\n        { id: 8, from: 5, to: 6, weight: 11 },\n        { id: 9, from: 2, to: 4, weight: 5 },\n      ];\n\n      // Graph adjacency list for quick access\n      const adjacency = nodes.map(() => []);\n      edges.forEach((e, i) => {\n        adjacency[e.from].push({ to: e.to, weight: e.weight, edgeId: i });\n        adjacency[e.to].push({ to: e.from, weight: e.weight, edgeId: i });\n      });\n\n      // State for visualization\n      let mstEdges = new Set();\n      let visited = new Set();\n      let animationSteps = [];\n      let animating = false;\n      let animationStartTime = null;\n      let currentStepIndex = 0;\n\n      // Utility functions\n      function lerp(a, b, t) {\n        return a + (b - a) * t;\n      }\n      // Draw helpers\n      function drawEdge(edge, highlight = false) {\n        const fromNode = nodes[edge.from];\n        const toNode = nodes[edge.to];\n        ctx.lineCap = 'round';\n        ctx.lineWidth = highlight ? 5 : 2;\n        ctx.strokeStyle = highlight ? EDGE_ACTIVE_COLOR : EDGE_INACTIVE_COLOR;\n        ctx.shadowColor = highlight ? EDGE_ACTIVE_COLOR : 'transparent';\n        ctx.shadowBlur = highlight ? 8 : 0;\n        ctx.beginPath();\n        ctx.moveTo(fromNode.x, fromNode.y);\n        ctx.lineTo(toNode.x, toNode.y);\n        ctx.stroke();\n\n        // Draw weight label at midpoint with slight offset\n        const mx = (fromNode.x + toNode.x) / 2;\n        const my = (fromNode.y + toNode.y) / 2;\n        ctx.fillStyle = highlight ? EDGE_ACTIVE_COLOR : EDGE_INACTIVE_COLOR;\n        ctx.font = '600 16px Montserrat';\n        ctx.textAlign = 'center';\n        ctx.textBaseline = 'middle';\n        ctx.shadowBlur = 6;\n        ctx.shadowColor = highlight ? EDGE_ACTIVE_COLOR : 'transparent';\n        ctx.fillText(edge.weight, mx, my - 16);\n        ctx.shadowBlur = 0;\n      }\n\n      function drawNode(node, highlight = false, active = false) {\n        ctx.shadowColor = highlight || active ? NODE_COLOR : 'transparent';\n        ctx.shadowBlur = highlight || active ? 10 : 0;\n\n        // Outer glow circle for active node\n        if (active) {\n          const gradient = ctx.createRadialGradient(node.x, node.y, NODE_RADIUS - 4, node.x, node.y, NODE_RADIUS + 36);\n          gradient.addColorStop(0, 'rgba(249, 212, 35, 0.8)');\n          gradient.addColorStop(1, 'rgba(249, 212, 35, 0)');\n          ctx.fillStyle = gradient;\n          ctx.beginPath();\n          ctx.arc(node.x, node.y, NODE_RADIUS + 36, 0, Math.PI * 2);\n          ctx.fill();\n        }\n\n        ctx.fillStyle = highlight ? NODE_ACTIVE_COLOR : NODE_COLOR;\n        ctx.beginPath();\n        ctx.arc(node.x, node.y, active ? ACTIVE_NODE_RADIUS : NODE_RADIUS, 0, Math.PI * 2);\n        ctx.fill();\n\n        // Inner glow circle for highlight\n        if (highlight) {\n          const innerGradient = ctx.createRadialGradient(node.x, node.y, 0, node.x, node.y, ACTIVE_NODE_RADIUS);\n          innerGradient.addColorStop(0, 'rgba(249, 212, 35, 0.85)');\n          innerGradient.addColorStop(1, 'rgba(255,111,97,0)');\n          ctx.fillStyle = innerGradient;\n          ctx.beginPath();\n          ctx.arc(node.x, node.y, ACTIVE_NODE_RADIUS, 0, Math.PI * 2);\n          ctx.fill();\n        }\n\n        // Node label (id + 1) centered\n        ctx.fillStyle = '#141e30';\n        ctx.font = '700 16px Montserrat';\n        ctx.textAlign = 'center';\n        ctx.textBaseline = 'middle';\n        ctx.shadowBlur = 8;\n        ctx.shadowColor = 'rgba(0,0,0,0.5)';\n        ctx.fillText(node.id + 1, node.x, node.y);\n        ctx.shadowBlur = 0;\n      }\n\n      // Clear canvas with subtle radial background\n      function clearCanvas() {\n        const grad = ctx.createRadialGradient(width / 2, height / 2, height / 10, width / 2, height / 2, height);\n        grad.addColorStop(0, '#1d2a48');\n        grad.addColorStop(1, '#101a30');\n        ctx.fillStyle = grad;\n        ctx.fillRect(0, 0, width, height);\n      }\n\n      // Draw full graph with MST edges highlighted\n      function drawGraph(currentNodeId = null, nextEdge = null) {\n        clearCanvas();\n\n        // Draw all edges dimmed\n        edges.forEach(edge => {\n          const inMST = mstEdges.has(edge.id);\n          const highlight = inMST;\n          drawEdge(edge, highlight);\n        });\n\n        // Draw the next edge tentative highlight for step animation\n        if (nextEdge !== null) {\n          const edge = edges[nextEdge];\n          drawEdge(edge, true);\n        }\n\n        // Draw nodes, highlight visited nodes and current active node\n        nodes.forEach(node => {\n          const isVisited = visited.has(node.id);\n          const isCurrent = (node.id === currentNodeId);\n          drawNode(node, isVisited, isCurrent);\n        });\n      }\n\n      // Prim's algorithm logic with animation steps prep\n      // We'll construct an array of steps: each step is selecting an edge to add to MST,\n      // and updating visited nodes accordingly.\n      // Steps format: { currentNode, chosenEdgeId }\n      function prepareAnimationSteps() {\n        // Reset state for the algorithm\n        mstEdges.clear();\n        visited.clear();\n        animationSteps = [];\n\n        const edgeCount = nodes.length - 1;\n\n        // Use arrays and standard Prim's algorithm with showing step-by-step\n        const key = Array(nodes.length).fill(Infinity);\n        const parent = Array(nodes.length).fill(null);\n        const inMST = Array(nodes.length).fill(false);\n\n        key[0] = 0;\n\n        for (let count = 0; count < nodes.length; count++) {\n          // Pick the minimum key not in MST\n          let u = -1;\n          let minKey = Infinity;\n          for (let v = 0; v < nodes.length; v++) {\n            if (!inMST[v] && key[v] < minKey) {\n              minKey = key[v];\n              u = v;\n            }\n          }\n          if (u === -1) break;\n          inMST[u] = true;\n          visited.add(u);\n\n          if (parent[u] !== null) {\n            // Find edge id for parent[u] <-> u\n            const edgeId = edges.find(e => {\n              return (e.from === u && e.to === parent[u]) || (e.to === u && e.from === parent[u]);\n            }).id;\n            animationSteps.push({ currentNode: u, chosenEdgeId: edgeId });\n          } else {\n            // Starting node, no edge chosen\n            animationSteps.push({ currentNode: u, chosenEdgeId: null });\n          }\n\n          // Update key values\n          adjacency[u].forEach(({ to, weight }) => {\n            if (!inMST[to] && weight < key[to]) {\n              key[to] = weight;\n              parent[to] = u;\n            }\n          });\n        }\n      }\n\n      // Animation loop variables\n      let animationFrameId = null;\n\n      function drawStep(stepIndex, progress = 1) {\n        if (stepIndex >= animationSteps.length) {\n          // Final draw with all edges visible\n          drawGraph();\n          return;\n        }\n        const step = animationSteps[stepIndex];\n        const currentNode = step.currentNode;\n        const edgeId = step.chosenEdgeId;\n\n        // Show MST edges up to stepIndex-1\n        mstEdges = new Set(animationSteps.slice(1, stepIndex).map(s => s.chosenEdgeId).filter(x => x !== null));\n        // Draw current MST edges\n        // Draw graph with current node highlighted\n        // Animate drawing of the chosenEdge\n        if (edgeId === null) {\n          // First node, just draw graph with it active\n          drawGraph(currentNode);\n        } else {\n          clearCanvas();\n\n          // Draw edges already in MST\n          edges.forEach(edge => {\n            const inMST = mstEdges.has(edge.id);\n            ctx.lineCap = 'round';\n            ctx.lineWidth = inMST ? 5 : 2;\n            ctx.strokeStyle = inMST ? EDGE_ACTIVE_COLOR : EDGE_INACTIVE_COLOR;\n            ctx.shadowColor = inMST ? EDGE_ACTIVE_COLOR : 'transparent';\n            ctx.shadowBlur = inMST ? 8 : 0;\n            ctx.beginPath();\n\n            if (edge.id === edgeId) {\n              // Animate edge drawing from parent to current node\n              const fromNode = nodes[edge.from];\n              const toNode = nodes[edge.to];\n              const t = progress; // progress 0 to 1\n\n              let startX, startY, endX, endY;\n              // Determine edge direction by parent/u definition:\n              // Highlight from parent to current node for animation\n              const step = animationSteps[stepIndex];\n\n              if (toNode.id === currentNode) {\n                startX = fromNode.x;\n                startY = fromNode.y;\n                endX = lerp(fromNode.x, toNode.x, t);\n                endY = lerp(fromNode.y, toNode.y, t);\n              } else {\n                startX = toNode.x;\n                startY = toNode.y;\n                endX = lerp(toNode.x, fromNode.x, t);\n                endY = lerp(toNode.y, fromNode.y, t);\n              }\n              ctx.moveTo(startX, startY);\n              ctx.lineTo(endX, endY);\n              ctx.stroke();\n\n              // Draw partial edge weight label near end point\n              ctx.fillStyle = EDGE_ACTIVE_COLOR;\n              ctx.font = '600 16px Montserrat';\n              ctx.textAlign = 'center';\n              ctx.textBaseline = 'middle';\n              ctx.shadowBlur = 6;\n              ctx.shadowColor = EDGE_ACTIVE_COLOR;\n              const labelX = lerp(fromNode.x, toNode.x, t);\n              const labelY = lerp(fromNode.y, toNode.y, t) - 16;\n              ctx.fillText(edges[edgeId].weight, labelX, labelY);\n              ctx.shadowBlur = 0;\n\n            } else {\n              // Draw full edge but dimmed\n              const fromNode = nodes[edge.from];\n              const toNode = nodes[edge.to];\n              ctx.moveTo(fromNode.x, fromNode.y);\n              ctx.lineTo(toNode.x, toNode.y);\n              ctx.stroke();\n\n              // Weight label dim\n              const mx = (fromNode.x + toNode.x) / 2;\n              const my = (fromNode.y + toNode.y) / 2;\n              ctx.fillStyle = EDGE_INACTIVE_COLOR;\n              ctx.font = '600 16px Montserrat';\n              ctx.textAlign = 'center';\n              ctx.textBaseline = 'middle';\n              ctx.fillText(edge.weight, mx, my - 16);\n            }\n          });\n\n          // Draw nodes with visited and current highlight\n          nodes.forEach(node => {\n            const visitedUntilNow = new Set(animationSteps.slice(0, stepIndex).map(s => s.currentNode));\n            const isVisited = visitedUntilNow.has(node.id);\n            const isCurrent = (node.id === currentNode);\n            drawNode(node, isVisited, isCurrent);\n          });\n        }\n      }\n\n      function animate(timestamp) {\n        if (!animationStartTime) animationStartTime = timestamp;\n        const elapsed = timestamp - animationStartTime;\n        const step = Math.floor(elapsed / STEP_DURATION);\n        const progress = (elapsed % STEP_DURATION) / STEP_DURATION;\n\n        if (step !== currentStepIndex && step < animationSteps.length) {\n          currentStepIndex = step;\n        }\n        if (currentStepIndex < animationSteps.length) {\n          drawStep(currentStepIndex, progress);\n          animationFrameId = requestAnimationFrame(animate);\n        } else {\n          // End animation draw final\n          drawStep(animationSteps.length);\n          animating = false;\n          startBtn.disabled = false;\n          startBtn.setAttribute('aria-pressed', 'false');\n        }\n      }\n\n      // Rounded shadow glow for canvas edges\n      function applyCanvasGlow() {\n        canvas.style.boxShadow =\n          '0 0 30px 4px rgba(255,111,97,0.6), inset 0 0 15px rgba(249, 212, 35, 0.4)';\n      }\n\n      // Tooltip for nodes and edges to show info on hover (optional subtle effect)\n      function handlePointerMove(e) {\n        const rect = canvas.getBoundingClientRect();\n        const mx = e.clientX - rect.left;\n        const my = e.clientY - rect.top;\n        const proximity = 22;\n\n        // Check nodes proximity first\n        let showTooltip = false;\n        for (const node of nodes) {\n          const dx = mx - node.x;\n          const dy = my - node.y;\n          if (dx * dx + dy * dy < proximity * proximity) {\n            tooltip.innerText = `Node ${node.id + 1}`;\n            tooltip.style.left = `${node.x + 18}px`;\n            tooltip.style.top = `${node.y - 18}px`;\n            tooltip.style.opacity = '1';\n            showTooltip = true;\n            return;\n          }\n        }\n        // Check edges proximity (approximate with distance to closest point on line)\n        for (const edge of edges) {\n          const fromNode = nodes[edge.from];\n          const toNode = nodes[edge.to];\n          const dist = pointLineDistance(mx, my, fromNode.x, fromNode.y, toNode.x, toNode.y);\n          if (dist < 14) {\n            tooltip.innerText = `Edge (${edge.from + 1}, ${edge.to + 1}) Weight: ${edge.weight}`;\n            const midX = (fromNode.x + toNode.x) / 2;\n            const midY = (fromNode.y + toNode.y) / 2;\n            tooltip.style.left = `${midX + 10}px`;\n            tooltip.style.top = `${midY - 24}px`;\n            tooltip.style.opacity = '1';\n            showTooltip = true;\n            return;\n          }\n        }\n        if (!showTooltip) {\n          tooltip.style.opacity = '0';\n        }\n      }\n      // Distance from point (px,py) to line segment (x1,y1)-(x2,y2)\n      function pointLineDistance(px, py, x1, y1, x2, y2) {\n        const A = px - x1;\n        const B = py - y1;\n        const C = x2 - x1;\n        const D = y2 - y1;\n\n        const dot = A * C + B * D;\n        const lenSq = C * C + D * D;\n        let param = -1;\n        if (lenSq !== 0) param = dot / lenSq;\n\n        let xx, yy;\n\n        if (param < 0) {\n          xx = x1;\n          yy = y1;\n        } else if (param > 1) {\n          xx = x2;\n          yy = y2;\n        } else {\n          xx = x1 + param * C;\n          yy = y1 + param * D;\n        }\n\n        const dx = px - xx;\n        const dy = py - yy;\n        return Math.sqrt(dx * dx + dy * dy);\n      }\n\n      // Initial draw\n      function initialDraw() {\n        mstEdges.clear();\n        visited.clear();\n        drawGraph();\n      }\n\n      // Button handlers\n      function onStartClick() {\n        if (animating) return;\n        animating = true;\n        startBtn.disabled = true;\n        startBtn.setAttribute('aria-pressed', 'true');\n        currentStepIndex = 0;\n        animationStartTime = null;\n        visited.clear();\n        mstEdges.clear();\n\n        prepareAnimationSteps();\n        animationFrameId = requestAnimationFrame(animate);\n      }\n      function onResetClick() {\n        if (animating) {\n          cancelAnimationFrame(animationFrameId);\n          animating = false;\n          startBtn.disabled = false;\n          startBtn.setAttribute('aria-pressed', 'false');\n        }\n        initialDraw();\n        tooltip.style.opacity = '0';\n      }\n\n      // Accessibility: Enable keyboard button focus outlines elegantly\n      function handleFocusVisible(e){\n        if(e.target.matches('button')){\n          e.target.style.outline = '2px solid var(--accent-color)';\n          e.target.style.outlineOffset = '3px';\n        }\n      }\n      function handleBlurVisible(e){\n        if(e.target.matches('button')){\n          e.target.style.outline = 'none';\n        }\n      }\n\n      // Attach event listeners\n      startBtn.addEventListener('click', onStartClick);\n      resetBtn.addEventListener('click', onResetClick);\n      canvas.addEventListener('pointermove', handlePointerMove);\n      canvas.addEventListener('pointerleave', () => tooltip.style.opacity = '0');\n      window.addEventListener('focus', () => { if(animating) animationFrameId = requestAnimationFrame(animate); });\n      window.addEventListener('blur', () => { if(animating) cancelAnimationFrame(animationFrameId); });\n\n      document.addEventListener('focusin', handleFocusVisible);\n      document.addEventListener('focusout', handleBlurVisible);\n\n      applyCanvasGlow();\n      initialDraw();\n    })();\n  </script>\n</body>\n</html>"
