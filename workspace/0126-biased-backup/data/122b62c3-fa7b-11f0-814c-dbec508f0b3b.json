    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bubble Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: white;\n        }\n        input, button {\n            padding: 5px;\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Bubble Sort</h1>\n    <form>\n        <label for=\"array-size\">Array Size:</label>\n        <input type=\"number\" id=\"array-size\" value=\"10\" min=\"1\">\n        <button id=\"sort-button\">Sort</button>\n        <button id=\"clear-button\">Clear</button>\n        <button id=\"reset-button\">Reset</button>\n        <div id=\"output\"></div>\n    </form>\n\n    <script>\n        let arraySize = 10;\n        let array = new Array(arraySize);\n        let sorted = false;\n        let swapped = false;\n\n        function bubbleSort() {\n            if (swapped) return;\n            swapped = false;\n            for (let i = 0; i < arraySize - 1; i++) {\n                if (array[i] > array[i + 1]) {\n                    [array[i], array[i + 1]] = [array[i + 1], array[i]];\n                    swapped = true;\n                }\n            }\n            if (!swapped) {\n                console.log(\"Sorted array:\");\n                console.log(array);\n                sorted = true;\n            }\n        }\n\n        function clearArray() {\n            array = new Array(arraySize);\n            console.log(\"Array cleared.\");\n        }\n\n        function resetArray() {\n            array = new Array(arraySize);\n            sorted = false;\n            swapped = false;\n            console.log(\"Array reset.\");\n        }\n\n        document.getElementById(\"sort-button\").addEventListener(\"click\", bubbleSort);\n        document.getElementById(\"clear-button\").addEventListener(\"click\", clearArray);\n        document.getElementById(\"reset-button\").addEventListener(\"click\", resetArray);\n\n        document.getElementById(\"output\").innerHTML = \"Unsorted array: <pre>\" + array.join(\", \") + \"</pre>\";\n\n        let intervalId = setInterval(() => {\n            if (sorted) {\n                clearInterval(intervalId);\n                console.log(\"Sorted array:\");\n                console.log(array);\n                bubbleSort();\n            }\n        }, 100);\n    </script>\n</body>\n</html>"
