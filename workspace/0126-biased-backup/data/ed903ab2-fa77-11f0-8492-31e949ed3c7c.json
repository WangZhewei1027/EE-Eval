sform: translateY(-50%);\n            transition: transform 0.3s;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Support Vector Machine Visualization</h1>\n        <div class=\"chart\" id=\"chart\">\n            <div class=\"line\" id=\"decisionBoundary\"></div>\n        </div>\n        <button class=\"button\" onclick=\"animatePoints()\">Visualize SVM</button>\n        <div id=\"info\" style=\"margin-top: 1rem; color: #4a5568;\">Watch as the Support Vector Machine classifies data points!</div>\n    </div>\n\n    <script>\n        function getRandomPosition() {\n            return Math.floor(Math.random() * 300) + 50; // Generate random position within bounds\n        }\n\n        function createPoints() {\n            const chart = document.getElementById('chart');\n            const numPoints = 20;\n            const points = [];\n            for (let i = 0; i < numPoints; i++) {\n                const dot = document.createElement('div');\n                dot.className = 'dot';\n                dot.style.width = '10px';\n                dot.style.height = '10px';\n                dot.style.background = Math.random() > 0.5 ? '#4a5568' : '#e53e3e'; // Change color based on class\n                dot.style.left = getRandomPosition() + 'px';\n                dot.style.top = getRandomPosition() + 'px';\n                chart.appendChild(dot);\n                points.push(dot);\n            }\n            return points;\n        }\n\n        function animatePoints() {\n            const points = createPoints();\n            let counter = 0;\n            const interval = setInterval(() => {\n                if (counter >= points.length) {\n                    clearInterval(interval);\n                } else {\n                    points[counter].style.transform = 'scale(1.5)';\n                    counter++;\n                }\n            }, 500);\n        }\n    </script>\n</body>\n</html>"
