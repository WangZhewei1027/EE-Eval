  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Circular Linked List Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 1000px;\n            margin: 0 auto;\n        }\n        .controls {\n            margin-bottom: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n        .control-group {\n            margin-bottom: 10px;\n        }\n        button, input, select {\n            margin: 5px;\n            padding: 5px;\n        }\n        .visualization {\n            min-height: 200px;\n            border: 1px solid #ccc;\n            padding: 20px;\n            position: relative;\n            overflow-x: auto;\n        }\n        .node {\n            display: inline-block;\n            border: 1px solid black;\n            padding: 10px;\n            margin: 5px;\n            position: relative;\n        }\n        .data {\n            font-weight: bold;\n        }\n        .next-pointer {\n            font-size: 20px;\n            margin: 0 5px;\n        }\n        .highlight {\n            background-color: #f0f0f0;\n        }\n        .stats {\n            margin-top: 20px;\n            border: 1px solid #ccc;\n            padding: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Circular Linked List Interactive Demo</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>List Operations</h3>\n                <input type=\"text\" id=\"nodeValue\" placeholder=\"Enter value\">\n                <button onclick=\"insertAtBeginning()\">Insert at Beginning</button>\n                <button onclick=\"insertAtEnd()\">Insert at End</button>\n                <button onclick=\"insertAfterNode()\">Insert After Node</button>\n                <button onclick=\"deleteNode()\">Delete Node</button>\n                <button onclick=\"searchNode()\">Search Node</button>\n                <button onclick=\"reverseList()\">Reverse List</button>\n                <button onclick=\"clearList()\">Clear List</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Traversal Controls</h3>\n                <button onclick=\"startTraversal()\">Start Traversal</button>\n                <button onclick=\"stopTraversal()\">Stop Traversal</button>\n                <button onclick=\"stepForward()\">Step Forward</button>\n                <button onclick=\"stepBackward()\">Step Backward</button>\n                <span>Speed:</span>\n                <input type=\"range\" id=\"traversalSpeed\" min=\"100\" max=\"2000\" value=\"500\" onchange=\"updateTraversalSpeed()\">\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>List Configuration</h3>\n                <span>Max Nodes:</span>\n                <input type=\"number\" id=\"maxNodes\" min=\"1\" max=\"20\" value=\"10\">\n                <span>Randomize Data:</span>\n                <input type=\"checkbox\" id=\"randomData\" checked>\n                <button onclick=\"generateRandomList()\">Generate Random List</button>\n            </div>\n        </div>\n        \n        <div class=\"visualization\" id=\"listVisualization\">\n            <!-- List will be rendered here -->\n        </div>\n        \n        <div class=\"stats\">\n            <h3>List Statistics</h3>\n            <div>Length: <span id=\"listLength\">0</span></div>\n            <div>Current Node: <span id=\"currentNode\">None</span></div>\n            <div>Head Node: <span id=\"headNode\">None</span></div>\n            <div>Tail Node: <span id=\"tailNode\">None</span></div>\n            <div>Traversal Status: <span id=\"traversalStatus\">Inactive</span></div>\n        </div>\n        \n        <div class=\"controls\">\n            <h3>Debug Information</h3>\n            <button onclick=\"showListStructure()\">Show List Structure</button>\n            <button onclick=\"exportList()\">Export List</button>\n            <button onclick=\"importList()\">Import List</button>\n            <div id=\"debugInfo\"></div>\n        </div>\n    </div>\n\n    <script>\n        // Circular Linked List implementation\n        class Node {\n            constructor(data) {\n                this.data = data;\n                this.next = null;\n            }\n        }\n\n        class CircularLinkedList {\n            constructor() {\n                this.head = null;\n                this.tail = null;\n                this.length = 0;\n                this.current = null;\n                this.traversalInterval = null;\n                this.traversalSpeed = 500;\n                this.traversalDirection = 1; // 1 for forward, -1 for backward\n                this.isTraversing = false;\n            }\n\n            insertAtBeginning(data) {\n                const newNode = new Node(data);\n                \n                if (!this.head) {\n                    this.head = newNode;\n                    this.tail = newNode;\n                    newNode.next = newNode;\n                } else {\n                    newNode.next = this.head;\n                    this.head = newNode;\n                    this.tail.next = newNode;\n                }\n                \n                this.length++;\n                this.current = newNode;\n                return newNode;\n            }\n\n            insertAtEnd(data) {\n                const newNode = new Node(data);\n                \n                if (!this.head) {\n                    return this.insertAtBeginning(data);\n                }\n                \n                newNode.next = this.head;\n                this.tail.next = newNode;\n                this.tail = newNode;\n                this.length++;\n                return newNode;\n            }\n\n            insertAfter(nodeData, newData) {\n                if (!this.head) return null;\n                \n                let current = this.head;\n                do {\n                    if (current.data === nodeData) {\n                        const newNode = new Node(newData);\n                        newNode.next = current.next;\n                        current.next = newNode;\n                        \n                        if (current === this.tail) {\n                            this.tail = newNode;\n                        }\n                        \n                        this.length++;\n                        return newNode;\n                    }\n                    current = current.next;\n                } while (current !== this.head);\n                \n                return null;\n            }\n\n            deleteNode(data) {\n                if (!this.head) return null;\n                \n                let current = this.head;\n                let prev = this.tail;\n                do {\n                    if (current.data === data) {\n                        if (current === this.head) {\n                            this.head === this.head.next ? this.head = null : this.head = this.head.next;\n                            this.tail.next = this.head;\n                        } else {\n                            prev.next = current.next;\n                            if (current === this.tail) {\n                                this.tail = prev;\n                            }\n                        }\n                        \n                        if (this.current === current) {\n                            this.current = prev;\n                        }\n                        \n                        this.length--;\n                        if (this.length === 0) {\n                            this.head = null;\n                            this.tail = null;\n                            this.current = null;\n                        }\n                        return current;\n                    }\n                    prev = current;\n                    current = current.next;\n                } while (current !== this.head);\n                \n                return null;\n            }\n\n            search(data) {\n                if (!this.head) return null;\n                \n                let current = this.head;\n                do {\n                    if (current.data === data) {\n                        return current;\n                    }\n                    current = current.next;\n                } while (current !== this.head);\n                \n                return null;\n            }\n\n            reverse() {\n                if (!this.head || this.head.next === this.head) return;\n                \n                let prev = this.tail;\n                let current = this.head;\n                let next = null;\n                \n                do {\n                    next = current.next;\n                    current.next = prev;\n                    prev = current;\n                    current = next;\n                } while (current !== this.head);\n                \n                this.head = prev;\n                this.tail = current;\n            }\n\n            clear() {\n                this.head = null;\n                this.tail = null;\n                this.current = null;\n                this.length = 0;\n                clearInterval(this.traversalInterval);\n                this.isTraversing = false;\n            }\n\n            traverseForward() {\n                this.current = this.current ? this.current.next : this.head;\n                return this.current;\n            }\n\n            traverseBackward() {\n                if (!this.current) return null;\n                \n                let node = this.head;\n                while (node.next !== this.current) {\n                    node = node.next;\n                }\n                this.current = node;\n                return this.current;\n            }\n\n            startTraversal(direction = 1) {\n                if (this.isTraversing) return;\n                if (!this.head) return;\n                \n                this.traversalDirection = direction;\n                this.isTraversing = true;\n                \n                this.traversalInterval = setInterval(() => {\n                    if (this.traversalDirection === 1) {\n                        this.traverseForward();\n                    } else {\n                        this.traverseBackward();\n                    }\n                    renderList();\n                }, this.traversalSpeed);\n            }\n\n            stopTraversal() {\n                if (!this.isTraversing) return;\n                \n                clearInterval(this.traversalInterval);\n                this.isTraversing = false;\n            }\n\n            setTraversalSpeed(speed) {\n                this.traversalSpeed = speed;\n                if (this.isTraversing) {\n                    this.stopTraversal();\n                    this.startTraversal(this.traversalDirection);\n                }\n            }\n\n            getListAsArray() {\n                const result = [];\n                if (!this.head) return result;\n                \n                let current = this.head;\n                do {\n                    result.push(current.data);\n                    current = current.next;\n                } while (current !== this.head);\n                \n                return result;\n            }\n\n            getStructure() {\n                const result = [];\n                if (!this.head) return result;\n                \n                let current = this.head;\n                do {\n                    result.push({\n                        data: current.data,\n                        next: current.next ? current.next.data : null\n                    });\n                    current = current.next;\n                } while (current !== this.head);\n                \n                return result;\n            }\n        }\n\n        // Create a new circular linked list\n        const cll = new CircularLinkedList();\n\n        // DOM manipulation functions\n        function renderList() {\n            const visualization = document.getElementById('listVisualization');\n            visualization.innerHTML = '';\n            \n            if (!cll.head) {\n                visualization.textContent = 'List is empty';\n                updateStats();\n                return;\n            }\n            \n            let current = cll.head;\n            do {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = 'node';\n                if (current === cll.current) {\n                    nodeElement.classList.add('highlight');\n                }\n                \n                nodeElement.innerHTML = `\n                    <div class=\"data\">${current.data}</div>\n                    <div class=\"next-pointer\">→</div>\n                `;\n                \n                visualization.appendChild(nodeElement);\n                current = current.next;\n            } while (current !== cll.head);\n            \n            // Add circular connection indicator\n            const circularIndicator = document.createElement('div');\n            circularIndicator.textContent = '↻ (circular)';\n            circularIndicator.style.marginTop = '10px';\n            circularIndicator.style.fontStyle = 'italic';\n            visualization.appendChild(circularIndicator);\n            \n            updateStats();\n        }\n\n        function updateStats() {\n            document.getElementById('listLength').textContent = cll.length;\n            document.getElementById('currentNode').textContent = cll.current ? cll.current.data : 'None';\n            document.getElementById('headNode').textContent = cll.head ? cll.head.data : 'None';\n            document.getElementById('tailNode').textContent = cll.tail ? cll.tail.data : 'None';\n            document.getElementById('traversalStatus').textContent = cll.isTraversing ? \n                `Active (${cll.traversalDirection === 1 ? 'Forward' : 'Backward'})` : 'Inactive';\n        }\n\n        // Operation functions\n        function getInputValue() {\n            const input = document.getElementById('nodeValue');\n            const value = input.value.trim();\n            input.value = '';\n            return value;\n        }\n\n        function insertAtBeginning() {\n            const value = getInputValue();\n            if (!value) return;\n            \n            cll.insertAtBeginning(value);\n            renderList();\n        }\n\n        function insertAtEnd() {\n            const value = getInputValue();\n            if (!value) return;\n            \n            cll.insertAtEnd(value);\n            renderList();\n        }\n\n        function insertAfterNode() {\n            const value = getInputValue();\n            if (!value) return;\n            \n            const afterValue = prompt('Enter the node value after which to insert:');\n            if (!afterValue) return;\n            \n            const result = cll.insertAfter(afterValue, value);\n            if (result) {\n                renderList();\n            } else {\n                alert(`Node with value ${afterValue} not found`);\n            }\n        }\n\n        function deleteNode() {\n            const value = getInputValue();\n            if (!value) return;\n            \n            const result = cll.deleteNode(value);\n            if (result) {\n                renderList();\n            } else {\n                alert(`Node with value ${value} not found`);\n            }\n        }\n\n        function searchNode() {\n            const value = getInputValue();\n            if (!value) return;\n            \n            const result = cll.search(value);\n            if (result) {\n                cll.current = result;\n                renderList();\n            } else {\n                alert(`Node with value ${value} not found`);\n            }\n        }\n\n        function reverseList() {\n            cll.reverse();\n            renderList();\n        }\n\n        function clearList() {\n            cll.clear();\n            renderList();\n        }\n\n        function startTraversal() {\n            cll.startTraversal();\n            renderList();\n        }\n\n        function stopTraversal() {\n            cll.stopTraversal();\n            renderList();\n        }\n\n        function stepForward() {\n            cll.traverseForward();\n            renderList();\n        }\n\n        function stepBackward() {\n            cll.traverseBackward();\n            renderList();\n        }\n\n        function updateTraversalSpeed() {\n            const speed = parseInt(document.getElementById('traversalSpeed').value);\n            cll.setTraversalSpeed(speed);\n        }\n\n        function generateRandomList() {\n            cll.clear();\n            \n            const maxNodes = parseInt(document.getElementById('maxNodes').value);\n            const useRandomData = document.getElementById('randomData').checked;\n            \n            for (let i = 0; i < maxNodes; i++) {\n                const value = useRandomData ? \n                    Math.floor(Math.random() * 100) : \n                    `Node ${i + 1}`;\n                \n                cll.insertAtEnd(value);\n            }\n            \n            renderList();\n        }\n\n        function showListStructure() {\n            const structure = cll.getStructure();\n            const debugInfo = document.getElementById('debugInfo');\n            \n            if (structure.length === 0) {\n                debugInfo.textContent = 'List is empty';\n                return;\n            }\n            \n            let output = 'List Structure:\\n';\n            structure.forEach(node => {\n                output += `[Data: ${node.data}, Next: ${node.next}]\\n`;\n            });\n            \n            debugInfo.textContent = output;\n        }\n\n        function exportList() {\n            const listData = cll.getListAsArray();\n            const dataStr = JSON.stringify(listData);\n            const dataUri = 'data:application/json;charset=utf-8,' + encodeURIComponent(dataStr);\n            \n            const exportName = 'circular_list_export.json';\n            \n            const linkElement = document.createElement('a');\n            linkElement.setAttribute('href', dataUri);\n            linkElement.setAttribute('download', exportName);\n            linkElement.click();\n        }\n\n        function importList() {\n            const input = document.createElement('input');\n            input.type = 'file';\n            input.accept = '.json';\n            \n            input.onchange = e => {\n                const file = e.target.files[0];\n                const reader = new FileReader();\n                \n                reader.onload = event => {\n                    try {\n                        const data = JSON.parse(event.target.result);\n                        if (!Array.isArray(data)) {\n                            throw new Error('Invalid data format');\n                        }\n                        \n                        cll.clear();\n                        data.forEach(item => {\n                            cll.insertAtEnd(item);\n                        });\n                        \n                        renderList();\n                    } catch (error) {\n                        alert('Error importing list: ' + error.message);\n                    }\n                };\n                \n                reader.readAsText(file);\n            };\n            \n            input.click();\n        }\n\n        // Initialize\n        renderList();\n    </script>\n</body>\n</html>"
  },
