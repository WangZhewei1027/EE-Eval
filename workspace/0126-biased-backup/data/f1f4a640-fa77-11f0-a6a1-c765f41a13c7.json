    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Deque — Double-Ended Queue (Visual Demo)</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@600;700&family=Inter:wght@300;400;600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071028;\n    --glass: rgba(255,255,255,0.04);\n    --accent1: #8be9d7;\n    --accent2: #7c4dff;\n    --muted: rgba(255,255,255,0.12);\n    --card: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    --glassBorder: rgba(255,255,255,0.06);\n    --white: #eaf2ff;\n    --shadow: 0 8px 30px rgba(2,6,23,0.6);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,77,255,0.12), transparent),\n                radial-gradient(900px 500px at 90% 80%, rgba(139,233,215,0.06), transparent),\n                linear-gradient(180deg, var(--bg1), var(--bg2));\n    font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color:var(--white);\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n  }\n\n  /* Soft animated blobs */\n  .blob{\n    position:fixed;\n    width:520px;\n    height:520px;\n    filter: blur(60px);\n    opacity:0.14;\n    border-radius:50%;\n    z-index:0;\n    transform:translate3d(0,0,0);\n    animation: floaty 12s ease-in-out infinite;\n    mix-blend-mode:screen;\n    pointer-events:none;\n  }\n  .blob.b1{ left: -8%; top: -6%; background: linear-gradient(135deg, rgba(124,77,255,0.85), rgba(124,77,255,0.55)); animation-duration:18s; }\n  .blob.b2{ right:-6%; bottom:-10%; background: linear-gradient(135deg, rgba(139,233,215,0.9), rgba(124,77,255,0.18)); animation-duration:16s; opacity:0.09 }\n  @keyframes floaty{\n    0%{ transform: translateY(0) scale(1) rotate(0deg); }\n    50%{ transform: translateY(-24px) scale(1.06) rotate(6deg); }\n    100%{ transform: translateY(0) scale(1) rotate(0deg); }\n  }\n\n  /* Card */\n  .stage{\n    position:relative;\n    width:1100px;\n    max-width:98vw;\n    border-radius:20px;\n    padding:36px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow);\n    border: 1px solid var(--glassBorder);\n    backdrop-filter: blur(8px);\n    z-index:2;\n    overflow:hidden;\n  }\n\n  .header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:16px;\n    margin-bottom:20px;\n  }\n  .title{\n    display:flex;\n    align-items:center;\n    gap:18px;\n  }\n  .logo{\n    width:72px;\n    height:72px;\n    border-radius:14px;\n    background: linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02), 0 6px 18px rgba(7,10,25,0.6);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    overflow:visible;\n  }\n  .logo svg{ width:62px; height:62px; transform:translateY(-2px); }\n  h1{\n    font-family: \"Poppins\", sans-serif;\n    font-size:20px;\n    letter-spacing:0.2px;\n    margin:0;\n    color:var(--white);\n  }\n  .sub{\n    font-size:12px;\n    color:var(--muted);\n    margin-top:4px;\n    opacity:0.9;\n  }\n\n  /* Play/Pause button */\n  .controls{\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .playBtn{\n    --size:44px;\n    width:var(--size);\n    height:var(--size);\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    cursor:pointer;\n    transition:transform .18s ease, box-shadow .18s;\n    box-shadow: 0 6px 20px rgba(12,16,28,0.45);\n    position:relative;\n  }\n  .playBtn:hover{ transform:translateY(-4px) }\n  .playBtn:active{ transform:translateY(-1px) }\n\n  .playBtn .icon{\n    width:18px; height:18px; display:block;\n    color:var(--accent1);\n    filter:drop-shadow(0 4px 12px rgba(139,233,215,0.12));\n  }\n\n  .status{\n    font-size:13px;\n    color:var(--muted);\n    display:flex;\n    flex-direction:column;\n    align-items:flex-end;\n  }\n  .status strong{ color:var(--white); font-weight:600; font-size:13px }\n  .status span{ font-size:11px; color:var(--muted) }\n\n  /* Main visual area */\n  .visual{\n    display:flex;\n    gap:28px;\n    align-items:center;\n    justify-content:space-between;\n    margin-top:12px;\n  }\n\n  .railWrap{\n    flex:1;\n    min-width:480px;\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.008));\n    border: 1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:visible;\n    box-shadow: 0 12px 40px rgba(3,6,18,0.55);\n  }\n\n  /* Decorative polish - central ring */\n  .railWrap:before{\n    content:\"\";\n    position:absolute;\n    left:50%; top:-60px;\n    transform:translateX(-50%);\n    width:420px; height:180px;\n    background: radial-gradient(closest-side, rgba(124,77,255,0.06), transparent 70%);\n    filter: blur(20px);\n    pointer-events:none;\n    z-index:0;\n  }\n\n  /* Deque visual */\n  .rack{\n    position:relative;\n    height:140px;\n    display:block;\n    margin:12px auto;\n    width:calc(100% - 120px);\n    max-width:860px;\n  }\n\n  .slot{\n    position:absolute;\n    top:50%;\n    transform:translateY(-50%);\n    width:96px;\n    height:66px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.014), rgba(255,255,255,0.006));\n    border:1px dashed rgba(255,255,255,0.03);\n    box-shadow: 0 6px 18px rgba(4,8,24,0.55);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:var(--muted);\n    font-size:12px;\n    letter-spacing:0.6px;\n    transition:box-shadow 300ms, transform 300ms, border-color 300ms;\n    z-index:1;\n    overflow:visible;\n  }\n\n  .slot.empty{\n    opacity:0.45;\n    backdrop-filter: blur(2px);\n  }\n\n  .slot.front{\n    box-shadow: 0 10px 30px rgba(124,77,255,0.12), 0 4px 12px rgba(0,0,0,0.36);\n    border-style:solid;\n    border-color: rgba(124,77,255,0.24);\n  }\n  .slot.back{\n    box-shadow: 0 10px 30px rgba(139,233,215,0.10), 0 4px 12px rgba(0,0,0,0.36);\n    border-style:solid;\n    border-color: rgba(139,233,215,0.12);\n  }\n\n  .piece{\n    position:absolute;\n    width:84px;\n    height:46px;\n    border-radius:10px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:rgba(10,10,23,0.98);\n    font-weight:600;\n    font-size:15px;\n    box-shadow: 0 8px 30px rgba(2,6,23,0.6);\n    transition: transform 550ms cubic-bezier(.2,.9,.25,1), opacity 360ms;\n    will-change:transform,opacity;\n    z-index:10;\n    pointer-events:none;\n    border:1px solid rgba(255,255,255,0.04);\n    text-shadow: 0 1px 0 rgba(255,255,255,0.06);\n  }\n\n  .piece.small{\n    width:70px; height:42px; font-size:13px;\n  }\n\n  /* Colors for pieces */\n  .c1{ background: linear-gradient(135deg, #7c4dff, #5e2dd6); color:white; }\n  .c2{ background: linear-gradient(135deg, #8be9d7, #36d1d1); color:#032132; }\n  .c3{ background: linear-gradient(135deg, #ffc86b, #ff7a7a); color:#2b0f0f; }\n  .c4{ background: linear-gradient(135deg, #83a4ff, #4b66ff); color:white; }\n  .c5{ background: linear-gradient(135deg, #b1ff7a, #58d68d); color:#04210f; }\n\n  /* small labels for ends */\n  .end-label{\n    position:absolute;\n    top:8px;\n    font-size:11px;\n    color:var(--muted);\n    display:flex;\n    gap:8px;\n    align-items:center;\n    transform:translateY(-6px);\n  }\n  .end-label .dot{ width:10px; height:10px; border-radius:50%; background:var(--accent2); box-shadow: 0 8px 18px rgba(124,77,255,0.12); }\n\n  .front-label{ left:24px; }\n  .back-label{ right:24px; }\n\n  /* Operation banner */\n  .opBanner{\n    position:absolute;\n    right:28px;\n    top:24px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    padding:10px 14px;\n    border-radius:12px;\n    font-size:13px;\n    color:var(--muted);\n    display:flex;\n    gap:12px;\n    align-items:center;\n    z-index:12;\n    box-shadow: 0 12px 32px rgba(3,6,18,0.5);\n  }\n\n  .opBanner .label{\n    font-weight:600;\n    color:var(--white);\n    font-family: \"Poppins\", sans-serif;\n  }\n\n  /* Footer info area */\n  .info{\n    width:320px;\n    min-width:240px;\n    display:flex;\n    flex-direction:column;\n    gap:16px;\n    margin-left:18px;\n  }\n  .card{\n    border-radius:12px;\n    padding:18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006));\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n    font-size:13px;\n  }\n  .code{\n    font-family: monospace;\n    background: rgba(0,0,0,0.04);\n    padding:10px;\n    border-radius:8px;\n    color:var(--white);\n    font-size:12px;\n    overflow:hidden;\n    box-shadow: inset 0 -6px 12px rgba(0,0,0,0.18);\n  }\n\n  /* tiny legend */\n  .legend{\n    display:flex;\n    gap:8px;\n    align-items:center;\n    color:var(--muted);\n    font-size:12px;\n    margin-top:6px;\n  }\n  .legend .pill{ display:inline-block; width:10px; height:10px; border-radius:4px; }\n\n  /* small animations */\n  .pulse{\n    animation: pulse 1600ms ease-in-out infinite;\n  }\n  @keyframes pulse{\n    0%{ transform:scale(1); opacity:1; }\n    50%{ transform:scale(1.06); opacity:0.85; }\n    100%{ transform:scale(1); opacity:1; }\n  }\n\n  /* responsiveness */\n  @media (max-width:920px){\n    .visual{ flex-direction:column; gap:18px }\n    .info{ width:100%; margin-left:0 }\n    .rack{ height:120px }\n  }\n\n  /* subtle glowing line under title */\n  .accentLine{\n    height:3px;\n    width:140px;\n    border-radius:10px;\n    background: linear-gradient(90deg, rgba(124,77,255,0.9), rgba(139,233,215,0.9));\n    box-shadow: 0 8px 40px rgba(124,77,255,0.12);\n    margin-top:12px;\n  }\n\n  /* tiny footer */\n  .credit{\n    margin-top:18px;\n    font-size:12px;\n    color:var(--muted);\n    text-align:center;\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"blob b1\"></div>\n  <div class=\"blob b2\"></div>\n\n  <div class=\"stage\" role=\"main\" aria-label=\"Deque visual demonstration\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <!-- abstract deque emblem -->\n          <svg viewBox=\"0 0 80 80\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7c4dff\"/>\n                <stop offset=\"1\" stop-color=\"#36d1d1\"/>\n              </linearGradient>\n            </defs>\n            <rect x=\"6\" y=\"14\" rx=\"9\" ry=\"9\" width=\"68\" height=\"52\" fill=\"url(#g1)\" opacity=\"0.14\"/>\n            <g transform=\"translate(8,12)\">\n              <rect x=\"0\" y=\"6\" rx=\"6\" ry=\"6\" width=\"24\" height=\"36\" fill=\"#7c4dff\" opacity=\"0.95\"/>\n              <rect x=\"26\" y=\"6\" rx=\"6\" ry=\"6\" width=\"28\" height=\"36\" fill=\"#8be9d7\" opacity=\"0.95\"/>\n              <rect x=\"56\" y=\"6\" rx=\"6\" ry=\"6\" width=\"16\" height=\"36\" fill=\"#ffc86b\" opacity=\"0.95\"/>\n            </g>\n          </svg>\n        </div>\n        <div>\n          <h1>Deque — Double‑Ended Queue</h1>\n          <div class=\"sub\">Items may be added or removed from both front and back — visualized with graceful motion.</div>\n          <div class=\"accentLine\"></div>\n        </div>\n      </div>\n\n      <div class=\"controls\" role=\"group\" aria-label=\"Controls\">\n        <div class=\"status\" aria-hidden=\"true\">\n          <strong id=\"modeLabel\">Auto Demo</strong>\n          <span id=\"stateLabel\">Playing</span>\n        </div>\n        <button class=\"playBtn\" id=\"playPause\" aria-pressed=\"false\" title=\"Play / Pause demo\">\n          <svg class=\"icon\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <g id=\"playIcon\">\n              <path d=\"M7 6v12l10-6L7 6z\" fill=\"currentColor\"></path>\n            </g>\n            <g id=\"pauseIcon\" style=\"display:none\">\n              <rect x=\"6\" y=\"6\" width=\"4\" height=\"12\" rx=\"1\" fill=\"currentColor\"></rect>\n              <rect x=\"14\" y=\"6\" width=\"4\" height=\"12\" rx=\"1\" fill=\"currentColor\"></rect>\n            </g>\n          </svg>\n        </button>\n      </div>\n    </div>\n\n    <div class=\"visual\">\n      <div class=\"railWrap\" aria-hidden=\"false\">\n        <div class=\"opBanner\" id=\"opBanner\" aria-live=\"polite\">\n          <span style=\"opacity:0.6\">Operation</span>\n          <span class=\"label\" id=\"opLabel\">Initializing…</span>\n        </div>\n\n        <div class=\"end-label front-label pulse\" title=\"Front\">\n          <div class=\"dot\" style=\"background:linear-gradient(90deg,#7c4dff,#b78cff)\"></div>\n          <div style=\"font-size:12px;color:var(--muted)\">Front</div>\n        </div>\n\n        <div class=\"end-label back-label pulse\" title=\"Back\">\n          <div style=\"font-size:12px;color:var(--muted)\">Back</div>\n          <div class=\"dot\" style=\"background:linear-gradient(90deg,#8be9d7,#36d1d1)\"></div>\n        </div>\n\n        <div class=\"rack\" id=\"rack\" aria-hidden=\"true\"></div>\n\n        <div style=\"position:absolute; left:20px; bottom:18px; color:var(--muted); font-size:12px;\">\n          <div style=\"font-weight:600; color:var(--white); margin-bottom:6px;\">Concept</div>\n          <div style=\"max-width:520px; line-height:1.35;\">A deque (double‑ended queue) allows fast insertion and removal at both ends. Watch items glide in and out from front and back while indices adjust smoothly.</div>\n        </div>\n\n      </div>\n\n      <div class=\"info\" aria-hidden=\"true\">\n        <div class=\"card\">\n          <div style=\"font-weight:600; color:var(--white); margin-bottom:8px\">Key operations</div>\n          <div class=\"legend\">\n            <div><span class=\"pill\" style=\"background:#7c4dff\"></span> push_front</div>\n            <div style=\"margin-left:10px\"><span class=\"pill\" style=\"background:#8be9d7\"></span> push_back</div>\n            <div style=\"margin-left:10px\"><span class=\"pill\" style=\"background:#ffc86b\"></span> pop (remove)</div>\n          </div>\n          <div style=\"margin-top:12px; font-size:13px; color:var(--muted)\">\n            The visual demonstrates a persistent deque where elements slide and reflow with minimal disruption.\n          </div>\n        </div>\n\n        <div class=\"card\">\n          <div style=\"font-weight:600; color:var(--white); margin-bottom:8px\">Pseudo-code</div>\n          <div class=\"code\" id=\"codeArea\">\n            push_back(x)  // place x at back\n            push_front(y) // place y at front\n            pop_front()   // remove from front\n            pop_back()    // remove from back\n          </div>\n        </div>\n\n        <div style=\"text-align:center; color:var(--muted); font-size:12px\">\n          <div style=\"font-weight:600; color:var(--white)\">Observing sequence</div>\n          <div style=\"margin-top:6px\">Auto demo runs a curated sequence of deque operations — press Play/Pause to toggle.</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"credit\">Elegant data structures • Visualized with intention</div>\n  </div>\n\n<script>\n/*\n  Deque visual demo\n  Extremely limited interactivity: only Play/Pause button (single button).\n  The demo runs a curated sequence of operations automatically.\n*/\n\n(() => {\n  const rackEl = document.getElementById('rack');\n  const opLabel = document.getElementById('opLabel');\n  const codeArea = document.getElementById('codeArea');\n  const playBtn = document.getElementById('playPause');\n  const playIcon = playBtn.querySelector('#playIcon');\n  const pauseIcon = playBtn.querySelector('#pauseIcon');\n  const stateLabel = document.getElementById('stateLabel');\n  const modeLabel = document.getElementById('modeLabel');\n\n  // Configuration\n  const SLOT_COUNT = 9; // visual grid slots\n  const visibleIndexStart = 0;\n  let isPlaying = true;\n  let timer = null;\n  let stepDelay = 1500; // ms between operations\n  const rackRect = { width: 0 };\n\n  // Deque data (stores pieces)\n  class Piece {\n    constructor(id, label, cls) {\n      this.id = id;\n      this.label = label;\n      this.cls = cls;\n      this.el = null;\n      this.index = null; // logical index in deque (0..n-1)\n      this.colorClass = cls;\n    }\n  }\n  let deque = [];\n\n  // Scene state\n  let pieces = []; // active piece objects\n  let nextId = 1;\n\n  // Build slots positions\n  const slots = [];\n  function computeSlots() {\n    const rect = rackEl.getBoundingClientRect();\n    const width = rect.width;\n    const height = rect.height;\n    const slotW = 96;\n    const gap = (width - slotW) / (SLOT_COUNT - 1);\n    slots.length = 0;\n    for (let i=0;i<SLOT_COUNT;i++){\n      slots.push({\n        x: rackEl.offsetLeft + (i * gap) + rackEl.clientLeft + 6,\n        y: rect.top + height/2 - 23\n      });\n    }\n    rackRect.width = width;\n    // Position slot elements visuals\n    // Clear existing slot marks and recreate for polish\n    const existing = rackEl.querySelectorAll('.slot');\n    existing.forEach(n=>n.remove());\n    for (let i=0;i<SLOT_COUNT;i++){\n      const s = document.createElement('div');\n      s.className = 'slot empty';\n      s.style.left = `${(i * gap)}px`;\n      s.dataset.index = i;\n      s.style.width = '96px';\n      // mark center slot slightly different\n      if (i===Math.floor(SLOT_COUNT/2)){\n        s.style.transform = 'translateY(-50%) scale(1.02)';\n        s.style.boxShadow = '0 12px 40px rgba(12,15,30,0.45)';\n      }\n      rackEl.appendChild(s);\n    }\n  }\n\n  // Create a piece element for DOM\n  function createPieceEl(piece){\n    const el = document.createElement('div');\n    el.className = `piece ${piece.colorClass}`;\n    el.textContent = piece.label;\n    el.setAttribute('data-id', piece.id);\n    rackEl.appendChild(el);\n    piece.el = el;\n    el.style.opacity = '0';\n    el.style.transform = 'translate3d(0,20px,0) scale(.98)';\n    requestAnimationFrame(()=> {\n      el.style.opacity = '1';\n      el.style.transform = 'translate3d(0,0,0) scale(1)';\n    });\n    return el;\n  }\n\n  // Compute pixel positions for logical index mapping to slot index\n  function logicalToSlotIndex(logicalIndex, dequeLength){\n    // center the deque in the slot array\n    const mid = Math.floor(SLOT_COUNT/2);\n    const start = mid - Math.floor(dequeLength/2);\n    return start + logicalIndex;\n  }\n\n  // Reflow pieces: compute transforms to slot coords\n  function reflowPieces(animated=true){\n    const rect = rackEl.getBoundingClientRect();\n    const gap = (rect.width - 96) / (SLOT_COUNT -1);\n    pieces.forEach((p, idx) => {\n      if (!p.el) return;\n      const slotIndex = logicalToSlotIndex(idx, pieces.length);\n      const x = slotIndex * gap;\n      const y = rect.height/2 - 46/2; // center vertical\n      p.el.style.transition = animated ? 'transform 600ms cubic-bezier(.2,.9,.25,1), opacity 280ms' : 'none';\n      p.el.style.left = `${x + 6}px`;\n      p.el.style.top = `${y}px`;\n    });\n\n    // update slot empty/front/back visuals\n    const slotEls = rackEl.querySelectorAll('.slot');\n    slotEls.forEach(s=> s.classList.add('empty'));\n    const frontSlot = logicalToSlotIndex(0, pieces.length);\n    const backSlot = logicalToSlotIndex(Math.max(0,pieces.length-1), pieces.length);\n    if (slotEls[frontSlot]){ slotEls[frontSlot].classList.remove('empty'); slotEls[frontSlot].classList.add('front') }\n    if (slotEls[backSlot]){ slotEls[backSlot].classList.remove('empty'); slotEls[backSlot].classList.add('back') }\n  }\n\n  // Insert functions animate from left or right\n  function pushBack(label){\n    const p = new Piece(nextId++, label, randomColorClass());\n    pieces.push(p);\n    createPieceEl(p);\n    // initial transform: beyond right edge\n    const rect = rackEl.getBoundingClientRect();\n    const startX = rect.width + 120;\n    p.el.style.left = `${startX}px`;\n    p.el.style.top = `${rect.height/2 - 46/2}px`;\n    p.el.style.opacity = '0';\n    // animate into slots\n    requestAnimationFrame(()=> {\n      p.el.style.transition = 'transform 700ms cubic-bezier(.2,.9,.25,1), opacity 420ms, left 700ms';\n      p.el.style.opacity = '1';\n      reflowPieces(true);\n    });\n  }\n\n  function pushFront(label){\n    const p = new Piece(nextId++, label, randomColorClass());\n    pieces.unshift(p);\n    createPieceEl(p);\n    const rect = rackEl.getBoundingClientRect();\n    const startX = -160;\n    p.el.style.left = `${startX}px`;\n    p.el.style.top = `${rect.height/2 - 46/2}px`;\n    p.el.style.opacity = '0';\n    requestAnimationFrame(()=> {\n      p.el.style.transition = 'transform 700ms cubic-bezier(.2,.9,.25,1), opacity 420ms, left 700ms';\n      p.el.style.opacity = '1';\n      reflowPieces(true);\n    });\n  }\n\n  function popFront(){\n    if (!pieces.length) return;\n    // animate the front piece out left\n    const p = pieces.shift();\n    if (!p || !p.el) return;\n    const el = p.el;\n    el.style.transition = 'transform 640ms cubic-bezier(.2,.9,.25,1), opacity 360ms, left 640ms';\n    el.style.left = `-240px`;\n    el.style.opacity = '0';\n    setTimeout(()=> { el.remove(); reflowPieces(true); }, 700);\n  }\n\n  function popBack(){\n    if (!pieces.length) return;\n    const p = pieces.pop();\n    if (!p || !p.el) return;\n    const el = p.el;\n    el.style.transition = 'transform 640ms cubic-bezier(.2,.9,.25,1), opacity 360ms, left 640ms';\n    el.style.left = `${rackRect.width + 240}px`;\n    el.style.opacity = '0';\n    setTimeout(()=> { el.remove(); reflowPieces(true); }, 700);\n  }\n\n  function randomColorClass(){\n    const arr = ['c1','c2','c3','c4','c5'];\n    return arr[Math.floor(Math.random()*arr.length)];\n  }\n\n  // Demo operations sequence (curated)\n  const demoOps = [\n    {op:'push_back', val:'A'},\n    {op:'push_back', val:'B'},\n    {op:'push_front', val:'C'},\n    {op:'push_back', val:'D'},\n    {op:'push_front', val:'E'},\n    {op:'pop_back'},\n    {op:'pop_front'},\n    {op:'push_back', val:'F'},\n    {op:'push_front', val:'G'},\n    {op:'pop_front'},\n    {op:'push_back', val:'H'},\n    {op:'pop_back'},\n    {op:'pop_front'},\n    {op:'push_back', val:'I'},\n  ];\n  let demoIndex = 0;\n\n  function updateOpBanner(text){\n    opLabel.textContent = text;\n  }\n\n  function performNext(){\n    if (!isPlaying) return;\n    const op = demoOps[demoIndex % demoOps.length];\n    demoIndex++;\n    // update code area highlight\n    codeArea.innerHTML = generatePseudo(op);\n    switch(op.op){\n      case 'push_back':\n        updateOpBanner(`push_back(\"${op.val}\")`);\n        pushBack(op.val);\n        break;\n      case 'push_front':\n        updateOpBanner(`push_front(\"${op.val}\")`);\n        pushFront(op.val);\n        break;\n      case 'pop_front':\n        updateOpBanner('pop_front()');\n        popFront();\n        break;\n      case 'pop_back':\n        updateOpBanner('pop_back()');\n        popBack();\n        break;\n      default:\n        updateOpBanner('…');\n    }\n    // schedule next\n    if (isPlaying){\n      timer = setTimeout(performNext, stepDelay + Math.max(0, 700 - (pieces.length*20)));\n    }\n  }\n\n  function generatePseudo(op){\n    // small highlighted snippet\n    const map = {\n      push_back: `push_back(${op.val})  // add to back`,\n      push_front: `push_front(${op.val}) // add to front`,\n      pop_front: `pop_front()           // remove front`,\n      pop_back: `pop_back()            // remove back`,\n    };\n    return `<div style=\"opacity:0.9\">${map[op.op] || op.op}</div>`;\n  }\n\n  // Play/pause control\n  playBtn.addEventListener('click', ()=>{\n    isPlaying = !isPlaying;\n    playBtn.setAttribute('aria-pressed', String(!isPlaying));\n    togglePlayIcon(!isPlaying);\n    if (isPlaying){\n      stateLabel.textContent = 'Playing';\n      timer = setTimeout(performNext, 420);\n    } else {\n      stateLabel.textContent = 'Paused';\n      clearTimeout(timer);\n      timer = null;\n    }\n  });\n\n  function togglePlayIcon(showPlay){\n    if (showPlay){\n      playIcon.style.display = 'none';\n      pauseIcon.style.display = '';\n    }else{\n      playIcon.style.display = '';\n      pauseIcon.style.display = 'none';\n    }\n  }\n\n  // Initialization\n  function init(){\n    computeSlots();\n    window.addEventListener('resize', ()=> {\n      computeSlots();\n      reflowPieces(false);\n    });\n    // seed with a couple of elements for a pleasing start\n    pushBack('1'); pushBack('2'); pushBack('3');\n    setTimeout(()=> { pushFront('0'); }, 380);\n    setTimeout(()=> {\n      // start auto demo after intro\n      timer = setTimeout(performNext, 1400);\n    }, 1100);\n    // subtle parallax for rack on mouse move (purely aesthetic)\n    document.addEventListener('pointermove', (e)=>{\n      const bx = e.clientX / window.innerWidth - 0.5;\n      const by = e.clientY / window.innerHeight - 0.5;\n      rackEl.style.transform = `translate3d(${bx*8}px, ${by*6}px, 0)`;\n    });\n  }\n\n  // run\n  init();\n\n})();\n</script>\n</body>\n</html>"
