  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Bucket Sort Interactive Explorer</title>\n<style>\n  /* Extremely minimal styling to aid layout only. No colors, no animations. */\n  html,body { margin:8px; padding:0; font-family: monospace; font-size:13px; color:black; background:white; }\n  .row { display:flex; gap:8px; align-items:center; margin-bottom:8px; }\n  .col { display:flex; flex-direction:column; gap:6px; }\n  label { font-size:12px; }\n  input[type=\"text\"], textarea, select { font-family: monospace; font-size:13px; }\n  button { font-size:13px; }\n  .buckets { display:flex; gap:8px; flex-wrap:wrap; }\n  .bucket { border:1px solid black; padding:6px; min-width:80px; max-width:220px; }\n  .bucket-header { font-size:12px; margin-bottom:4px; }\n  .tokens { display:flex; flex-wrap:wrap; gap:4px; }\n  .token { border:1px solid black; padding:2px 4px; cursor:pointer; user-select:none; }\n  .panel { border:1px solid black; padding:8px; min-width:160px; }\n  .log { border:1px solid black; padding:6px; height:240px; overflow:auto; font-size:12px; white-space:pre-wrap; }\n  .array-view { border:1px solid black; padding:6px; min-height:28px; }\n  .small { font-size:12px; }\n  .controls { display:flex; gap:6px; flex-wrap:wrap; align-items:center; }\n  .timeline { width:400px; }\n</style>\n</head>\n<body>\n  <h2>Bucket Sort — Interactive Explorer</h2>\n\n  <div class=\"row\">\n    <div class=\"col\" style=\"flex:1\">\n      <div class=\"panel\">\n        <div><strong>Input array (numbers, comma or space separated)</strong></div>\n        <textarea id=\"inputArrayText\" rows=\"3\" style=\"width:100%;\">29, 25, 3, 49, 9, 37, 21, 43, 23, -5, 2, 2.5</textarea>\n        <div class=\"row small\">\n          <label>Elements: <input id=\"nSlider\" type=\"range\" min=\"2\" max=\"100\" value=\"12\" style=\"width:160px\"></label>\n          <input id=\"nValue\" type=\"number\" value=\"12\" style=\"width:60px\">\n          <button id=\"genRandom\">Generate random</button>\n          <label style=\"margin-left:8px\">min <input id=\"randMin\" type=\"number\" value=\"-10\" style=\"width:80px\"></label>\n          <label>max <input id=\"randMax\" type=\"number\" value=\"50\" style=\"width:80px\"></label>\n        </div>\n        <div class=\"row small\">\n          <button id=\"applyArray\">Apply array text</button>\n          <button id=\"shuffleBtn\">Shuffle</button>\n          <button id=\"sortInputBtn\">Sort input ascending</button>\n          <button id=\"clearBtn\">Clear</button>\n        </div>\n      </div>\n\n      <div class=\"panel\" style=\"margin-top:8px;\">\n        <div><strong>Bucket configuration</strong></div>\n        <div class=\"row small\">\n          <label>Bucket count <input id=\"bucketCount\" type=\"number\" min=\"1\" max=\"50\" value=\"5\" style=\"width:60px\"></label>\n          <label>Auto-range <input id=\"autoRange\" type=\"checkbox\" checked></label>\n          <label>Min <input id=\"rangeMin\" type=\"number\" style=\"width:80px\"></label>\n          <label>Max <input id=\"rangeMax\" type=\"number\" style=\"width:80px\"></label>\n        </div>\n        <div class=\"row small\">\n          <label>Internal sort:\n            <select id=\"internalSort\">\n              <option value=\"insertion\">Insertion (stepwise)</option>\n              <option value=\"bubble\">Bubble (stepwise)</option>\n              <option value=\"native\">Native JS sort (instant)</option>\n            </select>\n          </label>\n          <label>Stable <input id=\"stableSort\" type=\"checkbox\" checked></label>\n        </div>\n        <div class=\"row small\">\n          <label>Custom boundaries (optional, comma-separated; defines bucket edges left-to-right)</label>\n        </div>\n        <div class=\"row\">\n          <input id=\"customBoundaries\" type=\"text\" style=\"width:60%\">\n          <button id=\"applyBoundaries\">Apply boundaries</button>\n          <button id=\"clearBoundaries\">Clear</button>\n        </div>\n        <div class=\"row small\" style=\"margin-top:6px;\">\n          <label>Click tokens to select then click target bucket to move item (Manual move mode) <input id=\"manualMode\" type=\"checkbox\"></label>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"col\" style=\"width:420px;\">\n      <div class=\"panel\">\n        <div><strong>Execution controls</strong></div>\n        <div class=\"controls\">\n          <button id=\"prepareBtn\">Prepare steps</button>\n          <button id=\"resetBtn\">Reset</button>\n          <button id=\"stepBackBtn\">Step Back</button>\n          <button id=\"stepForwardBtn\">Step Forward</button>\n          <button id=\"playBtn\">Play</button>\n          <button id=\"pauseBtn\" disabled>Pause</button>\n          <label>Speed <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\"></label>\n          <label class=\"small\">Repeat <input id=\"autoRepeat\" type=\"checkbox\"></label>\n        </div>\n\n        <div class=\"row small\" style=\"margin-top:6px;\">\n          <label>Timeline:\n            <input id=\"timeline\" type=\"range\" min=\"0\" max=\"0\" value=\"0\" class=\"timeline\">\n          </label>\n          <div id=\"stepLabel\" class=\"small\">Step 0 / 0</div>\n        </div>\n\n        <div style=\"margin-top:6px;\">\n          <div class=\"small\"><strong>Phase controls</strong>: use these to run only one phase at a time (Prepares if required)</div>\n          <div class=\"row small\" style=\"margin-top:6px;\">\n            <button id=\"onlyDistribute\">Distribute only</button>\n            <button id=\"onlySort\">Sort buckets only</button>\n            <button id=\"onlyGather\">Gather only</button>\n            <button id=\"fullRun\">Full run (all phases)</button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"panel\" style=\"margin-top:8px;\">\n        <div><strong>Current status</strong></div>\n        <div class=\"small\">Phase: <span id=\"phaseDisplay\">idle</span></div>\n        <div class=\"small\">Actions prepared: <span id=\"actionsCount\">0</span></div>\n        <div class=\"small\">History steps: <span id=\"historyCount\">1</span></div>\n        <div class=\"small\">Selected token: <span id=\"selectedToken\">none</span></div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"row\">\n    <div class=\"col\" style=\"flex:1\">\n      <div class=\"panel\">\n        <div><strong>Buckets view</strong></div>\n        <div id=\"buckets\" class=\"buckets\"></div>\n      </div>\n\n      <div class=\"panel\" style=\"margin-top:8px;\">\n        <div><strong>Source array (items show processed state)</strong></div>\n        <div id=\"sourceView\" class=\"array-view\"></div>\n        <div style=\"margin-top:6px;\" class=\"small\">Use \"Prepare steps\" to plan algorithm execution. You can also edit array and reprepare.</div>\n      </div>\n    </div>\n\n    <div style=\"width:420px;\">\n      <div class=\"panel\">\n        <div><strong>Output / Gathered array</strong></div>\n        <div id=\"outputView\" class=\"array-view\"></div>\n        <div style=\"margin-top:8px;\"><strong>Log / Steps</strong></div>\n        <div id=\"log\" class=\"log\"></div>\n      </div>\n\n      <div class=\"panel\" style=\"margin-top:8px;\">\n        <div><strong>Explore controls</strong></div>\n        <div class=\"row small\">\n          <label>Manual add value: <input id=\"manualValue\" type=\"text\" style=\"width:80px\"></label>\n          <button id=\"manualAdd\">Add</button>\n          <button id=\"manualRemove\">Remove last</button>\n          <button id=\"manualCommit\">Commit changes (reprepare)</button>\n        </div>\n        <div class=\"row small\" style=\"margin-top:6px;\">\n          <button id=\"exportState\">Export state (JSON)</button>\n          <button id=\"importState\">Import state (paste JSON)</button>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  Bucket Sort Interactive Explorer\n  - Minimal UI but many interactive controls.\n  - Stepwise engine with prepared actions and history snapshots.\n  - Supports insertion and bubble stepwise sorts; native JS sort instant.\n  - Manual editing resets prepared actions (commit required).\n*/\n\n(function(){\n\n// Helpers\nfunction $(id){ return document.getElementById(id); }\nfunction clone(obj){ return JSON.parse(JSON.stringify(obj)); }\nfunction logLine(s){ prependLog(s); }\n\n// State containers\nlet state = null; // current runtime state\nlet actions = []; // prepared actions to apply\nlet history = []; // snapshots of state after each action (index 0 initial)\nlet historyIndex = 0; // current snapshot index into history\nlet actionPointer = 0; // next action to apply (equals history.length-1 normally)\nlet playTimer = null;\n\n// UI elements\nconst inputArrayText = $('inputArrayText');\nconst nSlider = $('nSlider');\nconst nValue = $('nValue');\nconst genRandom = $('genRandom');\nconst randMin = $('randMin');\nconst randMax = $('randMax');\nconst applyArray = $('applyArray');\nconst shuffleBtn = $('shuffleBtn');\nconst sortInputBtn = $('sortInputBtn');\nconst clearBtn = $('clearBtn');\n\nconst bucketCountInput = $('bucketCount');\nconst autoRangeInput = $('autoRange');\nconst rangeMinInput = $('rangeMin');\nconst rangeMaxInput = $('rangeMax');\nconst customBoundariesInput = $('customBoundaries');\nconst applyBoundariesBtn = $('applyBoundaries');\nconst clearBoundariesBtn = $('clearBoundaries');\n\nconst internalSortSelect = $('internalSort');\nconst stableSortCheck = $('stableSort');\nconst manualModeCheck = $('manualMode');\n\nconst prepareBtn = $('prepareBtn');\nconst resetBtn = $('resetBtn');\nconst stepBackBtn = $('stepBackBtn');\nconst stepForwardBtn = $('stepForwardBtn');\nconst playBtn = $('playBtn');\nconst pauseBtn = $('pauseBtn');\nconst speedInput = $('speed');\nconst autoRepeatCheck = $('autoRepeat');\n\nconst timeline = $('timeline');\nconst stepLabel = $('stepLabel');\nconst phaseDisplay = $('phaseDisplay');\nconst actionsCountSpan = $('actionsCount');\nconst historyCountSpan = $('historyCount');\nconst selectedTokenSpan = $('selectedToken');\n\nconst onlyDistributeBtn = $('onlyDistribute');\nconst onlySortBtn = $('onlySort');\nconst onlyGatherBtn = $('onlyGather');\nconst fullRunBtn = $('fullRun');\n\nconst bucketsDiv = $('buckets');\nconst sourceView = $('sourceView');\nconst outputView = $('outputView');\nconst logDiv = $('log');\n\nconst manualValue = $('manualValue');\nconst manualAdd = $('manualAdd');\nconst manualRemove = $('manualRemove');\nconst manualCommit = $('manualCommit');\nconst exportStateBtn = $('exportState');\nconst importStateBtn = $('importState');\n\nnSlider.addEventListener('input', ()=>{ nValue.value = nSlider.value; });\nnValue.addEventListener('change', ()=>{ nSlider.value = nValue.value; });\n\nfunction parseInputArrayText(){\n  const txt = inputArrayText.value.trim();\n  if(!txt) return [];\n  // split by commas or whitespace\n  const parts = txt.split(/[\\s,]+/).filter(p=>p.length);\n  const nums = parts.map(p=>Number(p)).filter(x=>!Number.isNaN(x));\n  return nums;\n}\n\nfunction applyInputTextToState(){\n  const nums = parseInputArrayText();\n  initializeStateFromArray(nums);\n}\n\nfunction initializeStateFromArray(arr){\n  // create initial state object: sourceArray items with processed flag\n  state = {\n    sourceArray: arr.map(v=>({value: v, processed:false})),\n    buckets: [], // array of arrays\n    output: [],\n    bucketCount: Number(bucketCountInput.value) || 1,\n    boundaries: parseCustomBoundaries(customBoundariesInput.value),\n    useCustomBoundaries: (customBoundariesInput.value.trim().length>0),\n    range: {min:null, max:null},\n    phase: 'idle',\n    selectedToken: null\n  };\n  recomputeRange();\n  // empty buckets\n  for(let i=0;i<state.bucketCount;i++) state.buckets.push([]);\n  // reset history/actions\n  actions = [];\n  history = [clone(state)];\n  historyIndex = 0;\n  actionPointer = 0;\n  renderAll();\n}\n\nfunction recomputeRange(){\n  if(state.useCustomBoundaries && state.boundaries && state.boundaries.length>1){\n    // boundaries provided; min/max derived\n    state.range.min = Math.min(...state.boundaries);\n    state.range.max = Math.max(...state.boundaries);\n    rangeMinInput.value = state.range.min;\n    rangeMaxInput.value = state.range.max;\n    return;\n  }\n  if(autoRangeInput.checked){\n    const vals = state.sourceArray.map(it=>it.value);\n    if(vals.length==0){ state.range.min = 0; state.range.max = 0; }\n    else {\n      state.range.min = Math.min(...vals);\n      state.range.max = Math.max(...vals);\n    }\n    rangeMinInput.value = state.range.min;\n    rangeMaxInput.value = state.range.max;\n  } else {\n    state.range.min = Number(rangeMinInput.value) || 0;\n    state.range.max = Number(rangeMaxInput.value) || 0;\n  }\n}\n\nfunction parseCustomBoundaries(text){\n  const t = text.trim();\n  if(!t) return null;\n  const parts = t.split(/[\\s,]+/).filter(p=>p.length).map(x=>Number(x)).filter(y=>!Number.isNaN(y));\n  if(parts.length<2) return null;\n  // sort unique\n  const u = Array.from(new Set(parts)).sort((a,b)=>a-b);\n  return u;\n}\n\nfunction prepareActionsFromState(phaseFilter /* optional: 'distribute'|'sort'|'gather' or null for full */){\n  // Constructs the full sequence of actions based on current input state and settings.\n  actions = [];\n  // ensure range/boundaries up to date\n  state.bucketCount = Number(bucketCountInput.value) || 1;\n  state.boundaries = parseCustomBoundaries(customBoundariesInput.value);\n  state.useCustomBoundaries = (customBoundariesInput.value.trim().length>0);\n  recomputeRange();\n\n  const sourceValues = state.sourceArray.map(it=>it.value);\n  const bcount = state.bucketCount;\n  // compute bucket index function\n  function bucketIndexForValue(v){\n    if(state.useCustomBoundaries && state.boundaries && state.boundaries.length>1){\n      const b = state.boundaries;\n      // bucket intervals are [b[i], b[i+1]) except last includes end\n      for(let i=0;i<b.length-1;i++){\n        if(i===b.length-2){\n          if(v>=b[i] && v<=b[i+1]) return i;\n        } else {\n          if(v>=b[i] && v<b[i+1]) return i;\n        }\n      }\n      // if outside, clamp to ends\n      if(v < b[0]) return 0;\n      return b.length-2;\n    } else {\n      const min = state.range.min;\n      const max = state.range.max;\n      if(max===min) return 0;\n      const t = (v - min) / (max - min);\n      let idx = Math.floor(t * bcount);\n      if(idx<0) idx=0;\n      if(idx>=bcount) idx=bcount-1;\n      return idx;\n    }\n  }\n\n  // Phase: distribution\n  const distrActions = [];\n  for(let i=0;i<sourceValues.length;i++){\n    const v = sourceValues[i];\n    const b = bucketIndexForValue(v);\n    distrActions.push({type:'distribute', index:i, value:v, bucket:b, note:`Place ${v} into bucket ${b}`});\n  }\n\n  // compute bucket contents after distribution for generating sort actions\n  const bucketsAfterDistribution = [];\n  for(let i=0;i<bcount;i++) bucketsAfterDistribution.push([]);\n  for(let i=0;i<sourceValues.length;i++){\n    const v = sourceValues[i];\n    const b = bucketIndexForValue(v);\n    bucketsAfterDistribution[b].push(v);\n  }\n\n  // Sorting actions per bucket\n  const sortActions = [];\n  const algo = internalSortSelect.value;\n  const stable = stableSortCheck.checked;\n\n  for(let bi=0; bi<bcount; bi++){\n    const arr = bucketsAfterDistribution[bi].slice();\n    if(arr.length<=1){\n      // nothing to do but we still add a single 'sorted' note to reflect completion\n      sortActions.push({type:'sorted', bucket:bi, bucketArray: arr.slice(), note:`Bucket ${bi} sorted (trivial)`});\n      continue;\n    }\n    if(algo==='native'){\n      // native sort - single action (stable selection attempted by using stable flag; JS sort is not reliably stable across engines but we'll apply numeric compar)\n      const sorted = arr.slice().sort((a,b)=>a-b);\n      sortActions.push({type:'sorted', bucket:bi, bucketArray: sorted, note:`Bucket ${bi} sorted by native sort`});\n    } else if(algo==='insertion'){\n      // stepwise insertion: produce an action after each insertion iteration\n      const work = arr.slice();\n      for(let i=1;i<work.length;i++){\n        const key = work[i];\n        let j = i-1;\n        while(j>=0 && work[j] > key){ work[j+1] = work[j]; j--; }\n        work[j+1] = key;\n        sortActions.push({type:'bucketStep', bucket:bi, bucketArray: work.slice(), note:`Insertion: placed ${key} into position ${j+1} in bucket ${bi}`});\n      }\n      sortActions.push({type:'sorted', bucket:bi, bucketArray: work.slice(), note:`Bucket ${bi} finished insertion sort`});\n    } else if(algo==='bubble'){\n      // bubble sort stepwise: push action after each swap\n      const work = arr.slice();\n      let n = work.length;\n      for(let i=0;i<n;i++){\n        let swapped=false;\n        for(let j=0;j<n-i-1;j++){\n          if(work[j] > work[j+1]){\n            const tmp = work[j]; work[j]=work[j+1]; work[j+1]=tmp;\n            swapped = true;\n            sortActions.push({type:'bucketStep', bucket:bi, bucketArray: work.slice(), note:`Bubble: swap in bucket ${bi} at positions ${j} and ${j+1}`});\n          }\n        }\n        if(!swapped) break;\n      }\n      sortActions.push({type:'sorted', bucket:bi, bucketArray: work.slice(), note:`Bucket ${bi} finished bubble sort`});\n    } else {\n      // fallback to native\n      const sorted = arr.slice().sort((a,b)=>a-b);\n      sortActions.push({type:'sorted', bucket:bi, bucketArray: sorted, note:`Bucket ${bi} sorted (fallback)`});\n    }\n  }\n\n  // Gathering actions: take from bucket 0..k-1 left-to-right\n  const gatherActions = [];\n  for(let bi=0; bi<bcount; bi++){\n    const arr = bucketsAfterDistribution[bi];\n    for(let j=0;j<arr.length;j++){\n      gatherActions.push({type:'gather', bucket:bi, value:arr[j], note:`Gather ${arr[j]} from bucket ${bi}`});\n    }\n  }\n\n  // Combine phases based on filter\n  if(!phaseFilter || phaseFilter==='distribute' || phaseFilter==='full'){\n    actions = actions.concat(distrActions);\n  }\n  if(!phaseFilter || phaseFilter==='sort' || phaseFilter==='full'){\n    actions = actions.concat(sortActions);\n  }\n  if(!phaseFilter || phaseFilter==='gather' || phaseFilter==='full'){\n    actions = actions.concat(gatherActions);\n  }\n\n  // set counters\n  actionsCountSpan.textContent = actions.length;\n  return actions;\n}\n\n// Apply a single action to 'state'\nfunction applyAction(act){\n  if(!act) return;\n  if(act.type==='distribute'){\n    // mark source processed and push into bucket\n    const idx = act.index;\n    if(idx>=0 && idx < state.sourceArray.length){\n      state.sourceArray[idx].processed = true;\n      ensureBucketsCount();\n      state.buckets[act.bucket].push(act.value);\n      state.phase = 'distributing';\n      logLine(act.note || `Distribute ${act.value} -> bucket ${act.bucket}`);\n    }\n  } else if(act.type==='bucketStep' || act.type==='sorted'){\n    // replace bucket contents with snapshot\n    ensureBucketsCount();\n    state.buckets[act.bucket] = act.bucketArray.slice();\n    state.phase = 'sorting';\n    logLine(act.note || `Sort step for bucket ${act.bucket}`);\n  } else if(act.type==='gather'){\n    ensureBucketsCount();\n    // remove element from bucket (first occurrence) and push to output\n    const b = act.bucket;\n    const val = act.value;\n    // attempt to remove first matching value in bucket (to reflect stable removal)\n    const idx = state.buckets[b].indexOf(val);\n    if(idx>=0){\n      state.buckets[b].splice(idx,1);\n    } else {\n      // fallback: if empty or mismatch, try shift\n      if(state.buckets[b].length>0) state.buckets[b].shift();\n    }\n    state.output.push(val);\n    state.phase = 'gathering';\n    logLine(act.note || `Gather ${val} from bucket ${b}`);\n  } else if(act.type==='manual'){\n    // manual action done via UI — state already modified; just log\n    logLine(act.note || 'Manual change');\n  }\n  // clear selected token when applying actions\n  state.selectedToken = null;\n}\n\n// Ensure bucket arrays exist for configured count\nfunction ensureBucketsCount(){\n  const desired = Number(bucketCountInput.value) || 1;\n  while(state.buckets.length < desired) state.buckets.push([]);\n  while(state.buckets.length > desired) state.buckets.pop();\n}\n\n// History management and stepping\nfunction snapshotStateAndPush(){\n  // push a deep clone of state to history after an action applied\n  const snap = clone(state);\n  history.push(snap);\n  historyIndex = history.length - 1;\n  actionPointer = history.length - 1; // pointer to next action equals number of actions applied\n  updateTimelineUI();\n  renderAll();\n}\n\nfunction stepForward(){\n  // If we are behind existing history (i.e., can advance without applying new action), do that.\n  if(historyIndex < history.length - 1){\n    historyIndex++;\n    state = clone(history[historyIndex]);\n    actionPointer = historyIndex;\n    updateTimelineUI();\n    renderAll();\n    return;\n  }\n  // else we apply next prepared action\n  if(actionPointer < actions.length){\n    const act = actions[actionPointer];\n    applyAction(act);\n    snapshotStateAndPush();\n    actionPointer++;\n    return;\n  }\n  // finished all actions\n  if(autoRepeatCheck.checked){\n    resetToPreparedInitial();\n    playOnceOrContinue();\n  } else {\n    // no more actions\n    state.phase = 'done';\n    renderAll();\n    stopPlay();\n  }\n}\n\nfunction stepBack(){\n  if(historyIndex > 0){\n    historyIndex--;\n    state = clone(history[historyIndex]);\n    actionPointer = historyIndex;\n    updateTimelineUI();\n    renderAll();\n  }\n}\n\nfunction resetToPreparedInitial(){\n  // set state to the initial prepared snapshot (history[0])\n  state = clone(history[0]);\n  history = [clone(state)];\n  historyIndex = 0;\n  actionPointer = 0;\n  renderAll();\n  updateTimelineUI();\n}\n\nfunction prepareAndReset(phaseFilter){\n  // parse current input and prepare actions\n  const arr = parseInputArrayText();\n  initializeStateFromArray(arr);\n  // prepare actions based on state\n  prepareActionsFromState(phaseFilter || 'full');\n  // keep initial snapshot only\n  history = [clone(state)];\n  historyIndex = 0;\n  actionPointer = 0;\n  updateTimelineUI();\n  renderAll();\n}\n\nfunction play(){\n  if(playTimer) return;\n  playBtn.disabled = true;\n  pauseBtn.disabled = false;\n  const interval = Number(speedInput.value) || 400;\n  playTimer = setInterval(()=>{ stepForward(); }, interval);\n}\n\nfunction pause(){\n  stopPlay();\n}\n\nfunction stopPlay(){\n  if(playTimer){\n    clearInterval(playTimer);\n    playTimer = null;\n  }\n  playBtn.disabled = false;\n  pauseBtn.disabled = true;\n}\n\n// When replaying after autoRepeat: allow continuous\nfunction playOnceOrContinue(){\n  if(playTimer) return;\n  play();\n}\n\nfunction updateTimelineUI(){\n  timeline.max = Math.max(0, history.length - 1);\n  timeline.value = historyIndex;\n  stepLabel.textContent = `Step ${historyIndex} / ${history.length - 1}`;\n  historyCountSpan.textContent = history.length;\n  actionsCountSpan.textContent = actions.length;\n  phaseDisplay.textContent = state.phase || 'idle';\n  selectedTokenSpan.textContent = (state.selectedToken!==null ? JSON.stringify(state.selectedToken) : 'none');\n}\n\nfunction jumpToHistoryIndex(idx){\n  const i = Math.max(0, Math.min(history.length-1, Number(idx)));\n  historyIndex = i;\n  state = clone(history[historyIndex]);\n  actionPointer = historyIndex;\n  updateTimelineUI();\n  renderAll();\n}\n\n// UI rendering\nfunction renderAll(){\n  // source view\n  sourceView.innerHTML = '';\n  state.sourceArray.forEach((it, idx)=>{\n    const span = document.createElement('span');\n    span.textContent = String(it.value);\n    span.className = 'token';\n    if(it.processed) span.style.opacity = '0.5';\n    span.dataset.index = idx;\n    // clicking tokens in source does selection (for manual move)\n    span.addEventListener('click',(e)=>{\n      if(manualModeCheck.checked){\n        state.selectedToken = {from:'source', index: idx, value: it.value};\n        selectedTokenSpan.textContent = JSON.stringify(state.selectedToken);\n      } else {\n        // highlight nothing\n      }\n      renderAll();\n    });\n    sourceView.appendChild(span);\n    sourceView.appendChild(document.createTextNode(' '));\n  });\n\n  // buckets view\n  bucketsDiv.innerHTML = '';\n  for(let i=0;i<state.bucketCount;i++){\n    const bdiv = document.createElement('div');\n    bdiv.className = 'bucket';\n    const header = document.createElement('div');\n    header.className = 'bucket-header';\n    header.textContent = `Bucket ${i}`;\n    bdiv.appendChild(header);\n    const tokens = document.createElement('div');\n    tokens.className = 'tokens';\n    const arr = (state.buckets[i] || []);\n    arr.forEach((v, idx)=>{\n      const t = document.createElement('span');\n      t.className = 'token';\n      t.textContent = String(v);\n      t.dataset.bucket = i;\n      t.dataset.index = idx;\n      t.addEventListener('click',(e)=>{\n        if(manualModeCheck.checked){\n          // select token for moving\n          state.selectedToken = {from:'bucket', bucket:i, index:idx, value:v};\n          selectedTokenSpan.textContent = JSON.stringify(state.selectedToken);\n          renderAll();\n        } else {\n          // allow selecting to inspect but not move\n        }\n      });\n      tokens.appendChild(t);\n    });\n    bdiv.appendChild(tokens);\n\n    // bucket click acts as drop target if manual move mode and an item selected\n    bdiv.addEventListener('click',(e)=>{\n      if(manualModeCheck.checked && state.selectedToken){\n        // perform manual move: if selected from source -> remove processed flag and put into bucket; or if from bucket -> move between buckets\n        const sel = state.selectedToken;\n        if(sel.from === 'source'){\n          // when moving from source to bucket:\n          // mark source processed and add to bucket\n          if(sel.index>=0 && sel.index < state.sourceArray.length){\n            state.sourceArray[sel.index].processed = true;\n            ensureBucketsCount();\n            state.buckets[i].push(sel.value);\n            logLine(`Manual: moved ${sel.value} from source index ${sel.index} to bucket ${i}`);\n            // commit manual change: reset prepared actions/hist\n            commitManualChange();\n          }\n        } else if(sel.from === 'bucket'){\n          // move from one bucket to clicked bucket\n          if(sel.bucket === i){\n            // same bucket -> no-op\n            state.selectedToken = null;\n            selectedTokenSpan.textContent = 'none';\n            renderAll();\n            return;\n          }\n          // remove from old bucket index in state.buckets\n          const old = sel.bucket;\n          const idx = sel.index;\n          if(state.buckets[old] && idx>=0 && idx < state.buckets[old].length){\n            const val = state.buckets[old].splice(idx,1)[0];\n            // append to target bucket\n            ensureBucketsCount();\n            state.buckets[i].push(val);\n            logLine(`Manual: moved ${val} from bucket ${old} -> bucket ${i}`);\n            commitManualChange();\n          }\n        }\n      }\n    });\n\n    bucketsDiv.appendChild(bdiv);\n  }\n\n  // output view\n  outputView.innerHTML = '';\n  state.output.forEach((v)=>{\n    const s = document.createElement('span');\n    s.className = 'token';\n    s.textContent = String(v);\n    outputView.appendChild(s);\n    outputView.appendChild(document.createTextNode(' '));\n  });\n\n  updateTimelineUI();\n}\n\n// Logging\nfunction prependLog(s){\n  const time = new Date().toLocaleTimeString();\n  logDiv.textContent = `${time} - ${s}\\n` + logDiv.textContent;\n}\n\n// Manual commit: when user makes manual edits, we treat current layout as new initial state and re-generate actions\nfunction commitManualChange(){\n  // snapshot current state as initial and clear prepared actions/history\n  state.phase = 'idle';\n  state.useCustomBoundaries = (customBoundariesInput.value.trim().length>0);\n  recomputeRange();\n  // Remove processed markings: keep them as-is (they can reflect manual move)\n  const newSource = state.sourceArray.map(it=>({value: it.value, processed: it.processed}));\n  state.sourceArray = newSource;\n  // ensure bucket count\n  ensureBucketsCount();\n  // save new snapshot and prepare actions\n  history = [clone(state)];\n  historyIndex = 0;\n  actionPointer = 0;\n  prepareActionsFromState(); // default full\n  updateTimelineUI();\n  renderAll();\n}\n\n// UI event wiring\nprepareBtn.addEventListener('click',()=>{ prepareAndReset('full'); prependLog('Prepared full sequence of actions'); });\nresetBtn.addEventListener('click',()=>{ initializeStateFromArray(parseInputArrayText()); prependLog('Reset state to initial input'); });\nstepBackBtn.addEventListener('click',()=>{ stopPlay(); stepBack(); });\nstepForwardBtn.addEventListener('click',()=>{ stopPlay(); stepForward(); });\nplayBtn.addEventListener('click',()=>{ play(); prependLog('Play started'); });\npauseBtn.addEventListener('click',()=>{ pause(); prependLog('Play paused'); });\n\nspeedInput.addEventListener('change',()=>{\n  if(playTimer){\n    clearInterval(playTimer);\n    playTimer = setInterval(()=>{ stepForward(); }, Number(speedInput.value));\n  }\n});\n\ntimeline.addEventListener('input',(e)=>{ stopPlay(); jumpToHistoryIndex(e.target.value); });\n\nonlyDistributeBtn.addEventListener('click',()=>{ prepareAndReset('distribute'); prependLog('Prepared distribution-only actions'); });\nonlySortBtn.addEventListener('click',()=>{ prepareAndReset('sort'); prependLog('Prepared sorting-only actions'); });\nonlyGatherBtn.addEventListener('click',()=>{ prepareAndReset('gather'); prependLog('Prepared gathering-only actions'); });\nfullRunBtn.addEventListener('click',()=>{ prepareAndReset('full'); prependLog('Prepared full run'); });\n\n// Input array control events\napplyArray.addEventListener('click', ()=>{ applyInputTextToState(); prependLog('Applied array text to state'); });\ngenRandom.addEventListener('click', ()=>{\n  const n = Number(nValue.value) || Number(nSlider.value) || 10;\n  const min = Number(randMin.value) || 0;\n  const max = Number(randMax.value) || 100;\n  const arr = [];\n  for(let i=0;i<n;i++){\n    const r = Math.random()*(max-min)+min;\n    // random int or float occasionally\n    arr.push(Math.random()<0.6? Math.round(r) : Number(r.toFixed(2)));\n  }\n  inputArrayText.value = arr.join(', ');\n  applyInputTextToState();\n  prependLog('Generated random array');\n});\nshuffleBtn.addEventListener('click', ()=>{\n  const arr = parseInputArrayText();\n  for(let i=arr.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [arr[i],arr[j]]=[arr[j],arr[i]]; }\n  inputArrayText.value = arr.join(', ');\n  applyInputTextToState();\n  prependLog('Shuffled input');\n});\nsortInputBtn.addEventListener('click', ()=>{\n  const arr = parseInputArrayText();\n  arr.sort((a,b)=>a-b);\n  inputArrayText.value = arr.join(', ');\n  applyInputTextToState();\n  prependLog('Sorted input ascending');\n});\nclearBtn.addEventListener('click', ()=>{\n  inputArrayText.value = '';\n  initializeStateFromArray([]);\n  prependLog('Cleared input');\n});\n\n// Bucket controls\napplyBoundariesBtn.addEventListener('click', ()=>{\n  const b = parseCustomBoundaries(customBoundariesInput.value);\n  if(!b){ prependLog('Invalid boundaries (need at least two numeric values)'); return; }\n  // apply and reprepare\n  prepareAndReset('full');\n  prependLog('Applied custom boundaries and prepared actions');\n});\nclearBoundariesBtn.addEventListener('click', ()=>{\n  customBoundariesInput.value = '';\n  prepareAndReset('full');\n  prependLog('Cleared custom boundaries');\n});\n\n// Manual add / remove / commit\nmanualAdd.addEventListener('click', ()=>{\n  const s = manualValue.value.trim();\n  if(s==='') return;\n  const v = Number(s);\n  const val = Number.isNaN(v) ? s : v;\n  // append to source array unprocessed\n  if(!state) initializeStateFromArray([]);\n  state.sourceArray.push({value: val, processed:false});\n  inputArrayText.value = state.sourceArray.map(it=>String(it.value)).join(', ');\n  renderAll();\n  prependLog(`Manual added value ${val}`);\n});\nmanualRemove.addEventListener('click', ()=>{\n  if(!state) return;\n  state.sourceArray.pop();\n  inputArrayText.value = state.sourceArray.map(it=>String(it.value)).join(', ');\n  renderAll();\n  prependLog('Manual removed last value');\n});\nmanualCommit.addEventListener('click', ()=>{\n  commitManualChange();\n  prependLog('Manual changes committed and actions prepared');\n});\n\n// Export / import state\nexportStateBtn.addEventListener('click', ()=>{\n  const dump = JSON.stringify({state: state, actions: actions, history: history}, null, 2);\n  prompt('Copy the state JSON:', dump);\n});\nimportStateBtn.addEventListener('click', ()=>{\n  const txt = prompt('Paste state JSON to import:');\n  if(!txt) return;\n  try{\n    const obj = JSON.parse(txt);\n    if(obj && obj.state){\n      state = obj.state;\n      actions = obj.actions || [];\n      history = obj.history || [clone(state)];\n      historyIndex = history.length - 1;\n      actionPointer = historyIndex;\n      inputArrayText.value = state.sourceArray.map(it=>String(it.value)).join(', ');\n      renderAll();\n      prependLog('Imported state JSON');\n    } else {\n      prependLog('Invalid imported JSON');\n    }\n  } catch(e){\n    prependLog('Error parsing JSON');\n  }\n});\n\n// Prepare state on load\ninitializeStateFromArray(parseInputArrayText());\nprepareActionsFromState();\nupdateTimelineUI();\nrenderAll();\n\n// Utility for stepping via interval with dynamic speed\nfunction playButtonToggle(){\n  if(playTimer) stopPlay(); else play();\n}\n\n// Reset button\nresetBtn.addEventListener('click', ()=>{\n  initializeStateFromArray(parseInputArrayText());\n  prependLog('State reset to initial input (no actions prepared)');\n});\n\n// Clicking on log entries to jump: not implemented as separate elements; but we allow timeline slider to jump.\n// Convenience: clicking log will not break\n\n// Ensure timeline update when history changes\nfunction ensureUIConsistency(){\n  updateTimelineUI();\n  renderAll();\n}\n\n// Make step functions available via console for power users\nwindow._bucketExplorer = {\n  stepForward, stepBack, prepareActionsFromState, applyAction, state, actions, history\n};\n\n})(); // end closure\n</script>\n</body>\n</html>"
