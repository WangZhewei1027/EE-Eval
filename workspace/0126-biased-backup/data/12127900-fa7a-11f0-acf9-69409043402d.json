  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Doubly Linked List Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 10px;\n    line-height: 1.3em;\n  }\n  #listDisplay {\n    white-space: pre;\n    font-family: monospace, monospace;\n  }\n  input[type=\"number\"] {\n    width: 80px;\n  }\n  input[type=\"text\"] {\n    width: 100px;\n  }\n  button {\n    margin: 2px 6px 6px 0;\n  }\n  label {\n    font-weight: bold;\n  }\n  fieldset {\n    margin-top: 12px;\n    padding: 8px;\n  }\n  .horizontal-group > * {\n    display: inline-block;\n    vertical-align: middle;\n  }\n</style>\n</head>\n<body>\n<h1>Doubly Linked List Interactive Demo</h1>\n\n<p><b>Overview:</b> This demo lets you create and manipulate a doubly linked list by inserting, removing, searching, and traversing nodes. Each node stores an integer value or string label. You can navigate forwards and backwards, view the current node, and perform advanced operations like reversing the list or inserting after/before a given node. Use the controls below to explore the list structure dynamically.</p>\n\n<div>\n  <label for=\"newNodeValue\">Node Value (text): </label>\n  <input type=\"text\" id=\"newNodeValue\" placeholder=\"e.g. 42 or hello\" />\n</div>\n\n<fieldset>\n  <legend>Basic Operations</legend>\n  <div class=\"horizontal-group\">\n    <button id=\"insertHeadBtn\">Insert at Head</button>\n    <button id=\"insertTailBtn\">Insert at Tail</button>\n    <button id=\"removeHeadBtn\">Remove Head</button>\n    <button id=\"removeTailBtn\">Remove Tail</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <label for=\"removeValueInput\">Remove by Value:</label>\n    <input type=\"text\" id=\"removeValueInput\" placeholder=\"value to remove\" />\n    <button id=\"removeValueBtn\">Remove Node(s)</button>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Insert Relative to Existing Node</legend>\n  <div>\n    <label for=\"targetValueInput\">Target Node Value:</label>\n    <input type=\"text\" id=\"targetValueInput\" placeholder=\"target value\" />\n  </div>\n  <div style=\"margin-top:6px;\" class=\"horizontal-group\">\n    <button id=\"insertBeforeBtn\">Insert Before Target</button>\n    <button id=\"insertAfterBtn\">Insert After Target</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <small><i>(Use this to insert a new node relative to a node with a specific value. If multiple nodes have the same value, first found will be used.)</i></small>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Traversal Controls</legend>\n  <div class=\"horizontal-group\">\n    <button id=\"traverseHeadBtn\">Go To Head</button>\n    <button id=\"traversePrevBtn\">Previous Node</button>\n    <button id=\"traverseNextBtn\">Next Node</button>\n    <button id=\"traverseTailBtn\">Go To Tail</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <label for=\"jumpIndexInput\">Jump to Index:</label>\n    <input type=\"number\" min=\"0\" id=\"jumpIndexInput\" value=\"0\" />\n    <button id=\"jumpIndexBtn\">Jump</button>\n    <small><i>(Indexing starts at 0 for Head.)</i></small>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Search and State</legend>\n  <div>\n    <label for=\"searchValueInput\">Search Value:</label>\n    <input type=\"text\" id=\"searchValueInput\" placeholder=\"value to search\" />\n    <button id=\"searchBtn\">Search</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <button id=\"showAllBtn\">Show Entire List</button>\n    <button id=\"reverseListBtn\">Reverse List</button>\n    <button id=\"clearListBtn\">Clear List</button>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>User Info and List Status</legend>\n  <div>\n    <b>List Size:</b> <span id=\"listSize\">0</span> nodes\n  </div>\n  <div>\n    <b>Current Node Index:</b> <span id=\"currentIndex\">-</span>\n  </div>\n  <div>\n    <b>Current Node Value:</b> <span id=\"currentValue\">-</span>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <b>List Forward:</b>\n    <pre id=\"listDisplayForward\" style=\"white-space:pre-wrap; max-height:60px; overflow-y:auto;\"></pre>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <b>List Backward:</b>\n    <pre id=\"listDisplayBackward\" style=\"white-space:pre-wrap; max-height:60px; overflow-y:auto;\"></pre>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Advanced Info & Debug</legend>\n  <div>\n    <label for=\"stepDelayInput\">Auto-Traverse Delay (ms): </label>\n    <input type=\"number\" id=\"stepDelayInput\" min=\"100\" value=\"1000\" />\n  </div>\n  <div style=\"margin-top:6px;\" class=\"horizontal-group\">\n    <button id=\"autoNextBtn\">Auto Next × 10</button>\n    <button id=\"autoPrevBtn\">Auto Prev × 10</button>\n    <button id=\"autoStopBtn\">Stop Auto-Traversal</button>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <button id=\"toggleVerboseBtn\">Toggle Verbose Mode (Off)</button>\n  </div>\n  <div id=\"verboseOutput\" style=\"white-space: pre-wrap; max-height:150px; overflow-y:auto; border: 1px solid black; margin-top:8px; padding:2px; display:none;\"></div>\n</fieldset>\n\n<script>\n(() => {\n  // Node Constructor\n  class Node {\n    constructor(value) {\n      this.value = value;\n      this.prev = null;\n      this.next = null;\n    }\n  }\n\n  // Doubly Linked List Implementation\n  class DoublyLinkedList {\n    constructor() {\n      this.head = null;\n      this.tail = null;\n      this._size = 0;\n    }\n\n    size() {\n      return this._size;\n    }\n\n    isEmpty() {\n      return this._size === 0;\n    }\n\n    insertAtHead(value) {\n      const node = new Node(value);\n      if (this.head === null) {\n        this.head = this.tail = node;\n      } else {\n        node.next = this.head;\n        this.head.prev = node;\n        this.head = node;\n      }\n      this._size++;\n      return node;\n    }\n\n    insertAtTail(value) {\n      const node = new Node(value);\n      if (this.tail === null) {\n        this.head = this.tail = node;\n      } else {\n        node.prev = this.tail;\n        this.tail.next = node;\n        this.tail = node;\n      }\n      this._size++;\n      return node;\n    }\n\n    removeHead() {\n      if (!this.head) return null;\n      const removed = this.head;\n      if (this.head === this.tail) {\n        this.head = this.tail = null;\n      } else {\n        this.head = this.head.next;\n        if(this.head) this.head.prev = null;\n      }\n      this._size--;\n      removed.next = null;\n      removed.prev = null;\n      return removed;\n    }\n\n    removeTail() {\n      if (!this.tail) return null;\n      const removed = this.tail;\n      if (this.head === this.tail) {\n        this.head = this.tail = null;\n      } else {\n        this.tail = this.tail.prev;\n        if(this.tail) this.tail.next = null;\n      }\n      this._size--;\n      removed.next = null;\n      removed.prev = null;\n      return removed;\n    }\n\n    find(value) {\n      let curr = this.head;\n      while (curr) {\n        if (curr.value === value) return curr;\n        curr = curr.next;\n      }\n      return null;\n    }\n\n    findAll(value) {\n      const results = [];\n      let curr = this.head;\n      while (curr) {\n        if (curr.value === value) results.push(curr);\n        curr = curr.next;\n      }\n      return results;\n    }\n\n    insertBefore(targetNode, value) {\n      if (!targetNode) return null;\n      if (targetNode === this.head) return this.insertAtHead(value);\n      const node = new Node(value);\n\n      const prevNode = targetNode.prev;\n      prevNode.next = node;\n      node.prev = prevNode;\n\n      node.next = targetNode;\n      targetNode.prev = node;\n\n      this._size++;\n      return node;\n    }\n\n    insertAfter(targetNode, value) {\n      if (!targetNode) return null;\n      if (targetNode === this.tail) return this.insertAtTail(value);\n      const node = new Node(value);\n\n      const nextNode = targetNode.next;\n      targetNode.next = node;\n      node.prev = targetNode;\n\n      node.next = nextNode;\n      nextNode.prev = node;\n\n      this._size++;\n      return node;\n    }\n\n    removeByValue(value) {\n      // Remove all nodes matching value, return count removed\n      let count = 0;\n      let curr = this.head;\n      while (curr) {\n        if (curr.value === value) {\n          const toRemove = curr;\n          curr = curr.next;\n          this._removeNode(toRemove);\n          count++;\n        } else {\n          curr = curr.next;\n        }\n      }\n      return count;\n    }\n\n    _removeNode(node) {\n      if (!node) return false;\n      if (node === this.head && node === this.tail) { // single node\n        this.head = this.tail = null;\n      } else if (node === this.head) {\n        this.head = node.next;\n        if(this.head) this.head.prev = null;\n      } else if (node === this.tail) {\n        this.tail = node.prev;\n        if(this.tail) this.tail.next = null;\n      } else {\n        const prevN = node.prev;\n        const nextN = node.next;\n        if(prevN) prevN.next = nextN;\n        if(nextN) nextN.prev = prevN;\n      }\n      this._size--;\n      node.next = null;\n      node.prev = null;\n      return true;\n    }\n\n    *forwardIterator() {\n      let curr = this.head;\n      while (curr) {\n        yield curr;\n        curr = curr.next;\n      }\n    }\n\n    *backwardIterator() {\n      let curr = this.tail;\n      while (curr) {\n        yield curr;\n        curr = curr.prev;\n      }\n    }\n\n    toArrayForward() {\n      const arr = [];\n      let curr = this.head;\n      while (curr) {\n        arr.push(curr.value);\n        curr = curr.next;\n      }\n      return arr;\n    }\n\n    toArrayBackward() {\n      const arr = [];\n      let curr = this.tail;\n      while (curr) {\n        arr.push(curr.value);\n        curr = curr.prev;\n      }\n      return arr;\n    }\n\n    clear() {\n      this.head = null;\n      this.tail = null;\n      this._size = 0;\n    }\n\n    getNodeByIndex(index) {\n      if (index < 0 || index >= this._size) return null;\n      let curr = this.head;\n      let i = 0;\n      while (curr && i < index) {\n        curr = curr.next;\n        i++;\n      }\n      return curr;\n    }\n\n    reverse() {\n      let curr = this.head;\n      let temp = null;\n      while (curr) {\n        temp = curr.prev;\n        curr.prev = curr.next;\n        curr.next = temp;\n        curr = curr.prev;\n      }\n      // Swap head and tail\n      temp = this.head;\n      this.head = this.tail;\n      this.tail = temp;\n    }\n  }\n\n  // UI Logic\n  const dll = new DoublyLinkedList();\n\n  // Current node for traversal state\n  let currentNode = null;\n\n  // Verbose logging\n  let verboseMode = false;\n  const verboseEl = document.getElementById('verboseOutput');\n\n  function logVerbose(msg) {\n    if (!verboseMode) return;\n    let dt = new Date();\n    verboseEl.textContent += `[${dt.toLocaleTimeString()}] ${msg}\\n`;\n    verboseEl.scrollTop = verboseEl.scrollHeight;\n  }\n\n  function updateListInfo() {\n    document.getElementById('listSize').textContent = dll.size();\n\n    if (!currentNode) {\n      document.getElementById('currentIndex').textContent = '-';\n      document.getElementById('currentValue').textContent = '-';\n    } else {\n      // Find index of current node\n      let idx = 0;\n      let found = false;\n      let node = dll.head;\n      while (node) {\n        if (node === currentNode) {\n          found = true;\n          break;\n        }\n        idx++;\n        node = node.next;\n      }\n      document.getElementById('currentIndex').textContent = found ? idx : '-';\n      document.getElementById('currentValue').textContent = found ? currentNode.value : '-';\n    }\n\n    document.getElementById('listDisplayForward').textContent = dll.toArrayForward().join(' <-> ');\n    document.getElementById('listDisplayBackward').textContent = dll.toArrayBackward().join(' <-> ');\n  }\n\n  function resetCurrentToHeadIfNull() {\n    if (!currentNode && !dll.isEmpty()) {\n      currentNode = dll.head;\n      logVerbose('Current node reset to head.');\n    }\n  }\n\n  // Insert Head\n  document.getElementById('insertHeadBtn').addEventListener('click', () => {\n    const val = document.getElementById('newNodeValue').value.trim();\n    if (val === '') {\n      alert('Please enter a value to insert.');\n      return;\n    }\n    const node = dll.insertAtHead(val);\n    currentNode = node;\n    logVerbose(`Inserted node with value \"${val}\" at head.`);\n    updateListInfo();\n  });\n\n  // Insert Tail\n  document.getElementById('insertTailBtn').addEventListener('click', () => {\n    const val = document.getElementById('newNodeValue').value.trim();\n    if (val === '') {\n      alert('Please enter a value to insert.');\n      return;\n    }\n    const node = dll.insertAtTail(val);\n    currentNode = node;\n    logVerbose(`Inserted node with value \"${val}\" at tail.`);\n    updateListInfo();\n  });\n\n  // Remove Head\n  document.getElementById('removeHeadBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is empty, no head to remove.');\n      return;\n    }\n    const removed = dll.removeHead();\n    if (removed) {\n      logVerbose(`Removed head node with value \"${removed.value}\".`);\n      if (currentNode === removed) {\n        currentNode = dll.head;\n      }\n      updateListInfo();\n    }\n  });\n\n  // Remove Tail\n  document.getElementById('removeTailBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is empty, no tail to remove.');\n      return;\n    }\n    const removed = dll.removeTail();\n    if (removed) {\n      logVerbose(`Removed tail node with value \"${removed.value}\".`);\n      if (currentNode === removed) {\n        currentNode = dll.tail;\n      }\n      updateListInfo();\n    }\n  });\n\n  // Remove By Value\n  document.getElementById('removeValueBtn').addEventListener('click', () => {\n    const val = document.getElementById('removeValueInput').value.trim();\n    if (val === '') {\n      alert('Please enter a value to remove.');\n      return;\n    }\n    let removedCount = dll.removeByValue(val);\n    if (removedCount === 0) {\n      alert(`No nodes with value \"${val}\" found.`);\n      logVerbose(`Remove by value: no nodes with value \"${val}\" found.`);\n    } else {\n      logVerbose(`Removed ${removedCount} node(s) with value \"${val}\".`);\n      // If currentNode removed, reset to head if exists, else null\n      if (currentNode && currentNode.value === val) {\n        currentNode = dll.head;\n      }\n      updateListInfo();\n    }\n  });\n\n  // Insert Before Target\n  document.getElementById('insertBeforeBtn').addEventListener('click', () => {\n    const val = document.getElementById('newNodeValue').value.trim();\n    const targetVal = document.getElementById('targetValueInput').value.trim();\n    if (val === '') {\n      alert('Please enter a value for the new node.');\n      return;\n    }\n    if (targetVal === '') {\n      alert('Please enter the target node value.');\n      return;\n    }\n    const targetNode = dll.find(targetVal);\n    if (!targetNode) {\n      alert(`Target node with value \"${targetVal}\" not found.`);\n      return;\n    }\n    const inserted = dll.insertBefore(targetNode, val);\n    if (inserted) {\n      currentNode = inserted;\n      logVerbose(`Inserted node with value \"${val}\" before node with value \"${targetVal}\".`);\n      updateListInfo();\n    }\n  });\n\n  // Insert After Target\n  document.getElementById('insertAfterBtn').addEventListener('click', () => {\n    const val = document.getElementById('newNodeValue').value.trim();\n    const targetVal = document.getElementById('targetValueInput').value.trim();\n    if (val === '') {\n      alert('Please enter a value for the new node.');\n      return;\n    }\n    if (targetVal === '') {\n      alert('Please enter the target node value.');\n      return;\n    }\n    const targetNode = dll.find(targetVal);\n    if (!targetNode) {\n      alert(`Target node with value \"${targetVal}\" not found.`);\n      return;\n    }\n    const inserted = dll.insertAfter(targetNode, val);\n    if (inserted) {\n      currentNode = inserted;\n      logVerbose(`Inserted node with value \"${val}\" after node with value \"${targetVal}\".`);\n      updateListInfo();\n    }\n  });\n\n  // Traverse - Go to Head\n  document.getElementById('traverseHeadBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is empty.');\n      return;\n    }\n    currentNode = dll.head;\n    logVerbose('Traversal: Moved to head.');\n    updateListInfo();\n  });\n\n  // Traverse - Previous Node\n  document.getElementById('traversePrevBtn').addEventListener('click', () => {\n    if (!currentNode) {\n      if (dll.isEmpty()) {\n        alert('List is empty.');\n        return;\n      }\n      currentNode = dll.tail;\n      logVerbose('Traversal: Current node was null, set to tail.');\n      updateListInfo();\n      return;\n    }\n    if (currentNode.prev) {\n      currentNode = currentNode.prev;\n      logVerbose('Traversal: Moved to previous node.');\n    } else {\n      alert('Already at head (no previous node).');\n      logVerbose('Traversal: At head, cannot move to previous node.');\n    }\n    updateListInfo();\n  });\n\n  // Traverse - Next Node\n  document.getElementById('traverseNextBtn').addEventListener('click', () => {\n    if (!currentNode) {\n      if (dll.isEmpty()) {\n        alert('List is empty.');\n        return;\n      }\n      currentNode = dll.head;\n      logVerbose('Traversal: Current node was null, set to head.');\n      updateListInfo();\n      return;\n    }\n    if (currentNode.next) {\n      currentNode = currentNode.next;\n      logVerbose('Traversal: Moved to next node.');\n    } else {\n      alert('Already at tail (no next node).');\n      logVerbose('Traversal: At tail, cannot move to next node.');\n    }\n    updateListInfo();\n  });\n\n  // Traverse - Go to Tail\n  document.getElementById('traverseTailBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is empty.');\n      return;\n    }\n    currentNode = dll.tail;\n    logVerbose('Traversal: Moved to tail.');\n    updateListInfo();\n  });\n\n  // Jump to Index\n  document.getElementById('jumpIndexBtn').addEventListener('click', () => {\n    const idx = Number(document.getElementById('jumpIndexInput').value);\n    if (isNaN(idx) || idx < 0 || idx >= dll.size()) {\n      alert(`Invalid index. Must be between 0 and ${dll.size() - 1}`);\n      return;\n    }\n    currentNode = dll.getNodeByIndex(idx);\n    if (currentNode) {\n      logVerbose(`Jumped to node index ${idx} with value \"${currentNode.value}\".`);\n    } else {\n      logVerbose(`Failed to jump to index ${idx} (node not found).`);\n    }\n    updateListInfo();\n  });\n\n  // Search\n  document.getElementById('searchBtn').addEventListener('click', () => {\n    const val = document.getElementById('searchValueInput').value.trim();\n    if (val === '') {\n      alert('Enter a value to search.');\n      return;\n    }\n    const node = dll.find(val);\n    if (node) {\n      currentNode = node;\n      alert(`Found node with value \"${val}\". Current node updated.`);\n      logVerbose(`Search: Found node with value \"${val}\" and set current node.`);\n    } else {\n      alert(`No node found with value \"${val}\".`);\n      logVerbose(`Search: No node found with value \"${val}\".`);\n    }\n    updateListInfo();\n  });\n\n  // Show Entire List (focus will just highlight the list display by updating it)\n  document.getElementById('showAllBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is empty.');\n      return;\n    }\n    alert(\"List (Head to Tail):\\n\" + dll.toArrayForward().join(\" <-> \"));\n    logVerbose(\"Displayed entire list from Head to Tail.\");\n  });\n\n  // Reverse List\n  document.getElementById('reverseListBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is empty, cannot reverse.');\n      return;\n    }\n    dll.reverse();\n    // Reset currentNode to head (new head after reverse)\n    currentNode = dll.head;\n    logVerbose('List reversed. Current node reset to head.');\n    updateListInfo();\n  });\n\n  // Clear List\n  document.getElementById('clearListBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is already empty.');\n      return;\n    }\n    if (!confirm('Are you sure you want to clear the entire list?')) return;\n    dll.clear();\n    currentNode = null;\n    logVerbose('Cleared entire list.');\n    updateListInfo();\n  });\n\n  // Auto-Traversal Variables and Functions\n  let autoTraverseInterval = null;\n  let autoTraverseCount = 0;\n  function startAutoTraverse(direction, times, delay) {\n    if (autoTraverseInterval) {\n      alert('Auto traversal already running. Please stop it first.');\n      return;\n    }\n    autoTraverseCount = 0;\n    autoTraverseInterval = setInterval(() => {\n      if (autoTraverseCount >= times) {\n        stopAutoTraverse();\n        return;\n      }\n      if (!currentNode) {\n        if (dll.isEmpty()) {\n          stopAutoTraverse();\n          alert('List is empty. Stopping auto traversal.');\n          return;\n        }\n        currentNode = direction === 'next' ? dll.head : dll.tail;\n      } else {\n        if (direction === 'next') {\n          if (currentNode.next) {\n            currentNode = currentNode.next;\n          } else {\n            // reached tail, stop early\n            stopAutoTraverse();\n            alert('Reached tail. Stopping auto traversal.');\n            return;\n          }\n        } else {\n          if (currentNode.prev) {\n            currentNode = currentNode.prev;\n          } else {\n            // reached head, stop early\n            stopAutoTraverse();\n            alert('Reached head. Stopping auto traversal.');\n            return;\n          }\n        }\n      }\n      updateListInfo();\n      autoTraverseCount++;\n      logVerbose(`Auto traversal (${direction}): step ${autoTraverseCount}.`);\n    }, delay);\n  }\n  function stopAutoTraverse() {\n    if (autoTraverseInterval) {\n      clearInterval(autoTraverseInterval);\n      autoTraverseInterval = null;\n      logVerbose('Stopped auto traversal.');\n    }\n  }\n\n  document.getElementById('autoNextBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is empty, cannot auto traverse.');\n      return;\n    }\n    const delay = Number(document.getElementById('stepDelayInput').value);\n    if (isNaN(delay) || delay < 100) {\n      alert('Please enter a valid delay >= 100 ms.');\n      return;\n    }\n    startAutoTraverse('next', 10, delay);\n  });\n\n  document.getElementById('autoPrevBtn').addEventListener('click', () => {\n    if (dll.isEmpty()) {\n      alert('List is empty, cannot auto traverse.');\n      return;\n    }\n    const delay = Number(document.getElementById('stepDelayInput').value);\n    if (isNaN(delay) || delay < 100) {\n      alert('Please enter a valid delay >= 100 ms.');\n      return;\n    }\n    startAutoTraverse('prev', 10, delay);\n  });\n\n  document.getElementById('autoStopBtn').addEventListener('click', () => {\n    stopAutoTraverse();\n  });\n\n  // Verbose Mode Toggle\n  document.getElementById('toggleVerboseBtn').addEventListener('click', () => {\n    verboseMode = !verboseMode;\n    const btn = document.getElementById('toggleVerboseBtn');\n    verboseEl.style.display = verboseMode ? 'block' : 'none';\n    btn.textContent = `Toggle Verbose Mode (${verboseMode ? 'On' : 'Off'})`;\n    if (verboseMode) {\n      logVerbose('Verbose mode enabled.');\n    } else {\n      logVerbose('Verbose mode disabled.');\n    }\n  });\n\n  // Initialize display at start\n  updateListInfo();\n\n  // Allow Enter key to trigger insert at tail for convenience\n  document.getElementById('newNodeValue').addEventListener('keydown', (e) => {\n    if (e.key === 'Enter') {\n      document.getElementById('insertTailBtn').click();\n    }\n  });\n\n  // Also allow Enter on removeValueInput to trigger removal\n  document.getElementById('removeValueInput').addEventListener('keydown', (e) => {\n    if (e.key === 'Enter') {\n      document.getElementById('removeValueBtn').click();\n    }\n  });\n\n  // Safety: warn user if leaving page with active auto traversal\n  window.addEventListener('beforeunload', (e) => {\n    if (autoTraverseInterval !== null) {\n      e.preventDefault();\n      e.returnValue = '';\n    }\n  });\n})();\n</script>\n\n</body>\n</html>"
  },
