    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Type System Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        input, button, select { margin: 5px; }\n    </style>\n</head>\n<body>\n\n<h1>Type System Demo</h1>\n\n<div>\n    <label for=\"dataType\">Select Data Type:</label>\n    <select id=\"dataType\">\n        <option value=\"string\">String</option>\n        <option value=\"number\">Number</option>\n        <option value=\"boolean\">Boolean</option>\n    </select>\n</div>\n\n<div>\n    <label for=\"inputValue\">Input Value:</label>\n    <input type=\"text\" id=\"inputValue\">\n    <button id=\"submitBtn\">Submit</button>\n</div>\n\n<div id=\"output\"></div>\n\n<h2>Variable Manipulation</h2>\n<div>\n    <button id=\"increaseBtn\">Increase Number</button>\n    <button id=\"decreaseBtn\">Decrease Number</button>\n    <button id=\"resetBtn\">Reset</button>\n</div>\n<div>\n    Current Value: <span id=\"currentValue\">0</span>\n</div>\n\n<h2>Boolean States</h2>\n<div>\n    <label for=\"booleanToggle\">Boolean Switch:</label>\n    <input type=\"checkbox\" id=\"booleanToggle\">\n</div>\n<div>\n    <span id=\"booleanOutput\">Boolean is OFF</span>\n</div>\n\n<script>\n    const dataTypeSelect = document.getElementById('dataType');\n    const inputValue = document.getElementById('inputValue');\n    const submitBtn = document.getElementById('submitBtn');\n    const outputDiv = document.getElementById('output');\n\n    const increaseBtn = document.getElementById('increaseBtn');\n    const decreaseBtn = document.getElementById('decreaseBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const currentValueSpan = document.getElementById('currentValue');\n    \n    const booleanToggle = document.getElementById('booleanToggle');\n    const booleanOutput = document.getElementById('booleanOutput');\n\n    let currentValue = 0;\n\n    dataTypeSelect.addEventListener('change', () => {\n        inputValue.value = '';\n        outputDiv.innerHTML = '';\n    });\n\n    submitBtn.addEventListener('click', () => {\n        const selectedType = dataTypeSelect.value;\n        const value = inputValue.value;\n\n        if (selectedType === 'string') {\n            outputDiv.innerHTML = `You entered a string: ${value}`;\n        } else if (selectedType === 'number') {\n            const numValue = parseFloat(value);\n            if (!isNaN(numValue)) {\n                outputDiv.innerHTML = `You entered a number: ${numValue}`;\n            } else {\n                outputDiv.innerHTML = `Invalid number!`;\n            }\n        } else if (selectedType === 'boolean') {\n            if (value.toLowerCase() === \"true\") {\n                outputDiv.innerHTML = `You entered a boolean: true`;\n            } else if (value.toLowerCase() === \"false\") {\n                outputDiv.innerHTML = `You entered a boolean: false`;\n            } else {\n                outputDiv.innerHTML = `Invalid boolean!`;\n            }\n        }\n    });\n\n    increaseBtn.addEventListener('click', () => {\n        currentValue++;\n        currentValueSpan.innerText = currentValue;\n    });\n\n    decreaseBtn.addEventListener('click', () => {\n        currentValue--;\n        currentValueSpan.innerText = currentValue;\n    });\n\n    resetBtn.addEventListener('click', () => {\n        currentValue = 0;\n        currentValueSpan.innerText = currentValue;\n    });\n\n    booleanToggle.addEventListener('change', () => {\n        booleanOutput.innerText = booleanToggle.checked ? 'Boolean is ON' : 'Boolean is OFF';\n    });\n</script>\n\n</body>\n</html>"
