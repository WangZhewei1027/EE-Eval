  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Interactive Big-Theta Explorer</title>\n  <style>\n    /* Keep visuals extremely minimal and basic. */\n    body { font-family: monospace; margin: 10px; }\n    input, button, select, textarea { font-family: monospace; font-size: 13px; }\n    canvas { border: 1px solid #000; display: block; }\n    .row { margin: 6px 0; }\n    .col { display: inline-block; vertical-align: top; margin-right: 12px; }\n    label { display: inline-block; width: 70px; }\n    textarea { width: 98%; height: 160px; }\n    .small { width: 70px; }\n  </style>\n</head>\n<body>\n  <h2>Big-Theta Notation — Interactive Explorer</h2>\n\n  <div class=\"row\">\n    <div class=\"col\">\n      <div><label>f(n) =</label><input id=\"fexpr\" size=\"40\" value=\"n^2 + 5*n + 3\"></div>\n      <div class=\"row\">\n        Templates for f: \n        <button id=\"f_poly\">n^2</button>\n        <button id=\"f_nlogn\">n log(n)</button>\n        <button id=\"f_log\">log(n)</button>\n        <button id=\"f_exp\">2^n</button>\n        <button id=\"f_fact\">n!</button>\n        <button id=\"f_rand\">Random</button>\n      </div>\n      <div class=\"row\"><label>g(n) =</label><input id=\"gexpr\" size=\"40\" value=\"n^2\"></div>\n      <div class=\"row\">\n        Templates for g:\n        <button id=\"g_poly\">n^2</button>\n        <button id=\"g_nlogn\">n log(n)</button>\n        <button id=\"g_log\">log(n)</button>\n        <button id=\"g_exp\">2^n</button>\n        <button id=\"g_fact\">n!</button>\n        <button id=\"g_rand\">Random</button>\n      </div>\n      <div class=\"row\">\n        <label>max n</label><input id=\"maxn\" class=\"small\" type=\"number\" value=\"200\">\n        <label>samples</label><input id=\"samples\" class=\"small\" type=\"number\" value=\"200\">\n        <label>scale</label>\n        <select id=\"scale\">\n          <option value=\"linear\">linear</option>\n          <option value=\"log\">log-log</option>\n        </select>\n      </div>\n      <div class=\"row\">\n        <button id=\"plot\">Plot</button>\n        <button id=\"showTable\">Show Value Table</button>\n        <button id=\"clearLog\">Clear Log</button>\n      </div>\n      <div class=\"row\">\n        Bounding guess: c1<input id=\"c1\" class=\"small\" type=\"number\" step=\"any\" value=\"0.5\">\n        c2<input id=\"c2\" class=\"small\" type=\"number\" step=\"any\" value=\"2\">\n        n0<input id=\"n0\" class=\"small\" type=\"number\" value=\"10\">\n        <button id=\"checkTheta\">Check Θ</button>\n      </div>\n      <div class=\"row\">\n        <button id=\"searchConstants\">Search c1,c2,n0 (brute)</button>\n        <button id=\"stepSearch\">Stepwise Search</button>\n        <button id=\"autoFindLimit\">Estimate lim f/g</button>\n      </div>\n      <div class=\"row\">\n        Modes:\n        <button id=\"modeTheta\">Θ</button>\n        <button id=\"modeO\">O</button>\n        <button id=\"modeOmega\">Ω</button>\n        <span id=\"modeLabel\">Mode: Θ</span>\n      </div>\n      <div class=\"row\">\n        Extra analysis:\n        <button id=\"classify\">Classify Growth</button>\n        <button id=\"genCounter\">Find Counterexample</button>\n        <button id=\"simplify\">Asymptotic Simplify</button>\n      </div>\n    </div>\n\n    <div class=\"col\">\n      <canvas id=\"plotCanvas\" width=\"600\" height=\"360\"></canvas>\n      <div class=\"row\">\n        Plot options:\n        <button id=\"togglePoints\">Toggle Points/Lines</button>\n        <button id=\"showBounds\">Toggle Show Bounds</button>\n        <button id=\"exportCSV\">Export CSV</button>\n      </div>\n      <div class=\"row\">\n        Proof steps controls:\n        <button id=\"startProof\">Start Proof Workflow</button>\n        <button id=\"nextStep\">Next Step</button>\n        <button id=\"prevStep\">Prev Step</button>\n        <button id=\"accept\">Accept Current</button>\n        <button id=\"reject\">Reject</button>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"row\">\n    Logs and analysis:\n    <textarea id=\"log\" readonly></textarea>\n  </div>\n\n<script>\n/*\n  Big-Theta Interactive Explorer\n  - Extremely functional, minimal visuals.\n  - Many controls and interactive workflows.\n*/\n\n/* ---------- Utilities and Expression Handling ---------- */\n\nfunction logAppend(s) {\n  const t = document.getElementById('log');\n  const time = new Date().toLocaleTimeString();\n  t.value = \"[\" + time + \"] \" + s + \"\\\\n\" + t.value;\n}\n\nfunction cleanExpr(str) {\n  if (!str) return \"\";\n  let s = str.trim();\n  // Replace common tokens with Math.* equivalents and exponent operator\n  s = s.replace(/\\\\^/g, \"**\");\n  // Replace word log with Math.log, but keep log10 or similar if provided explicitly\n  s = s.replace(/\\\\bexp\\\\b/g, \"Math.exp\");\n  s = s.replace(/\\\\bln\\\\b/g, \"Math.log\");\n  s = s.replace(/\\\\blog\\\\b/g, \"Math.log\");\n  s = s.replace(/\\\\bsqrt\\\\b/g, \"Math.sqrt\");\n  s = s.replace(/\\\\babs\\\\b/g, \"Math.abs\");\n  s = s.replace(/\\\\bceil\\\\b/g, \"Math.ceil\");\n  s = s.replace(/\\\\bfloor\\\\b/g, \"Math.floor\");\n  s = s.replace(/\\\\bmax\\\\b/g, \"Math.max\");\n  s = s.replace(/\\\\bmin\\\\b/g, \"Math.min\");\n  s = s.replace(/\\\\be\\\\b/g, \"Math.E\");\n  // allow function n! via factorial(n)\n  s = s.replace(/(\\\\d+)!/g, function(_, m){ return \"factorial(\" + m + \")\"; });\n  // allow n! as factorial(n)\n  s = s.replace(/\\\\b(n)\\\\!/g, \"factorial($1)\");\n  // allow implicit multiplication like 'n log(n)' -> 'n*Math.log(n)'\n  s = s.replace(/(\\\\d|n)\\\\s+(Math\\\\.)?([a-zA-Z_][a-zA-Z0-9_]*(\\\\([^)]*\\\\))?)/g, function(_, a, b, c){ \n    if (b) return a + \" \" + c;\n    return a + \"*\"+(c.indexOf(\"(\")===-1?(\"Math.\"+c):(\"Math.\"+c));\n  });\n  // Ensure bare 'log(' becomes Math.log(\n  s = s.replace(/\\\\blog\\\\s*\\\\(/g, \"Math.log(\");\n  // Ensure bare function names like sin, cos get Math.\n  s = s.replace(/\\\\b(sin|cos|tan|asin|acos|atan|pow)\\\\s*\\\\(/g, function(_, f){ return \"Math.\"+f+\"(\"; });\n  // Final safety: replace any remaining 'n' with 'n' (kept as variable)\n  return s;\n}\n\nfunction makeEval(expr) {\n  // returns function(n) -> number or NaN\n  const s = cleanExpr(expr);\n  // Build function that also has factorial helper\n  const body = \"function factorial(k){ if(!isFinite(k) || k<0) return NaN; k = Math.floor(k); var r=1; for(var i=2;i<=k;i++) r*=i; return r;} return (\" + s + \");\";\n  try {\n    // Using new Function with Math in scope via referenced names inside\n    const f = new Function('n', body);\n    // Test compile by calling with n=1 (catch errors)\n    try { f(1); } catch(e) {}\n    return f;\n  } catch(e) {\n    return function(){ return NaN; };\n  }\n}\n\nfunction safeNum(x) {\n  if (!isFinite(x)) return NaN;\n  if (Math.abs(x) > 1e300) return (x>0?Infinity:-Infinity);\n  return x;\n}\n\n/* ---------- Global State ---------- */\n\nconst state = {\n  fexpr: document.getElementById('fexpr').value,\n  gexpr: document.getElementById('gexpr').value,\n  ffun: null,\n  gfun: null,\n  maxn: parseInt(document.getElementById('maxn').value,10),\n  samples: parseInt(document.getElementById('samples').value,10),\n  scale: document.getElementById('scale').value,\n  pointsMode: true,\n  showBounds: true,\n  mode: 'theta', // 'theta', 'o', 'omega'\n  proofSteps: [],\n  currentStep: -1,\n  lastSearchResult: null\n};\n\n/* ---------- UI Wiring ---------- */\n\nfunction updateStateFromInputs() {\n  state.fexpr = document.getElementById('fexpr').value;\n  state.gexpr = document.getElementById('gexpr').value;\n  state.maxn = Math.max(1, parseInt(document.getElementById('maxn').value,10) || 200);\n  state.samples = Math.max(10, parseInt(document.getElementById('samples').value,10) || 200);\n  state.scale = document.getElementById('scale').value;\n  state.ffun = makeEval(state.fexpr);\n  state.gfun = makeEval(state.gexpr);\n}\n\ndocument.getElementById('plot').addEventListener('click', function(){ updateStateFromInputs(); drawPlot(); logAppend(\"Plot requested: f=\"+state.fexpr+\" g=\"+state.gexpr); });\ndocument.getElementById('showTable').addEventListener('click', function(){ updateStateFromInputs(); showTable(); });\ndocument.getElementById('clearLog').addEventListener('click', function(){ document.getElementById('log').value = \"\"; });\n\nfunction setF(expr) { document.getElementById('fexpr').value = expr; updateStateFromInputs(); }\nfunction setG(expr) { document.getElementById('gexpr').value = expr; updateStateFromInputs(); }\n\ndocument.getElementById('f_poly').addEventListener('click', function(){ setF(\"n^2\"); });\ndocument.getElementById('f_nlogn').addEventListener('click', function(){ setF(\"n*log(n)\"); });\ndocument.getElementById('f_log').addEventListener('click', function(){ setF(\"log(n)\"); });\ndocument.getElementById('f_exp').addEventListener('click', function(){ setF(\"2^n\"); });\ndocument.getElementById('f_fact').addEventListener('click', function(){ setF(\"factorial(n)\"); });\ndocument.getElementById('f_rand').addEventListener('click', function(){ setF(randomExpression()); });\n\ndocument.getElementById('g_poly').addEventListener('click', function(){ setG(\"n^2\"); });\ndocument.getElementById('g_nlogn').addEventListener('click', function(){ setG(\"n*log(n)\"); });\ndocument.getElementById('g_log').addEventListener('click', function(){ setG(\"log(n)\"); });\ndocument.getElementById('g_exp').addEventListener('click', function(){ setG(\"2^n\"); });\ndocument.getElementById('g_fact').addEventListener('click', function(){ setG(\"factorial(n)\"); });\ndocument.getElementById('g_rand').addEventListener('click', function(){ setG(randomExpression()); });\n\ndocument.getElementById('togglePoints').addEventListener('click', function(){ state.pointsMode = !state.pointsMode; drawPlot(); logAppend(\"Toggled points/lines. Points mode = \"+state.pointsMode); });\ndocument.getElementById('showBounds').addEventListener('click', function(){ state.showBounds = !state.showBounds; drawPlot(); logAppend(\"Toggled show bounds. showBounds = \"+state.showBounds); });\n\ndocument.getElementById('modeTheta').addEventListener('click', function(){ state.mode='theta'; document.getElementById('modeLabel').innerText = \"Mode: Θ\"; logAppend(\"Mode set to Θ\"); });\ndocument.getElementById('modeO').addEventListener('click', function(){ state.mode='o'; document.getElementById('modeLabel').innerText = \"Mode: O\"; logAppend(\"Mode set to O\"); });\ndocument.getElementById('modeOmega').addEventListener('click', function(){ state.mode='omega'; document.getElementById('modeLabel').innerText = \"Mode: Ω\"; logAppend(\"Mode set to Ω\"); });\n\ndocument.getElementById('checkTheta').addEventListener('click', function(){\n  updateStateFromInputs();\n  const c1 = parseFloat(document.getElementById('c1').value);\n  const c2 = parseFloat(document.getElementById('c2').value);\n  const n0 = parseInt(document.getElementById('n0').value,10);\n  const result = checkInequality(c1,c2,n0);\n  if (result.ok) {\n    logAppend(\"Inequality holds for all sampled n >= \"+n0+\" with c1=\"+c1+\", c2=\"+c2+\". Result: PASS.\");\n  } else {\n    logAppend(\"Inequality FAILED at n=\"+result.counterexample+\" (value f=\"+result.fval+\" g=\"+result.gval+\" )\");\n  }\n  drawPlot(c1,c2,n0);\n});\n\ndocument.getElementById('searchConstants').addEventListener('click', function(){\n  updateStateFromInputs();\n  bruteForceSearch();\n});\n\ndocument.getElementById('stepSearch').addEventListener('click', function(){\n  updateStateFromInputs();\n  stepwiseSearchInit();\n});\n\ndocument.getElementById('autoFindLimit').addEventListener('click', function(){\n  updateStateFromInputs();\n  const r = estimateLimit();\n  logAppend(\"Estimated limit of f(n)/g(n) as n→∞ ≈ \" + r.summary + \" (numerical samples: \" + r.values.slice(0,6).join(\", \") + (r.values.length>6?\" ...\":\"\") + \")\");\n});\n\ndocument.getElementById('classify').addEventListener('click', function(){\n  updateStateFromInputs();\n  const cls = classifyGrowth();\n  logAppend(\"Classification: \" + cls);\n});\n\ndocument.getElementById('genCounter').addEventListener('click', function(){\n  updateStateFromInputs();\n  const cnt = findCounterexample();\n  if (cnt) {\n    logAppend(\"Counterexample found at n=\"+cnt.n+\"; f=\"+cnt.f+\" g=\"+cnt.g);\n  } else logAppend(\"No counterexample found in sampled range.\");\n});\n\ndocument.getElementById('simplify').addEventListener('click', function(){\n  updateStateFromInputs();\n  const simp = asymptoticSimplify();\n  logAppend(\"Asymptotic simplification guesses: f ~ \"+simp.f +\"; g ~ \"+simp.g);\n});\n\ndocument.getElementById('exportCSV').addEventListener('click', function(){\n  updateStateFromInputs();\n  exportCSV();\n});\n\n/* ---------- Canvas Plotting ---------- */\n\nconst canvas = document.getElementById('plotCanvas');\nconst ctx = canvas.getContext('2d');\n\nfunction drawPlot(c1=null,c2=null,n0=null) {\n  updateStateFromInputs();\n  const W = canvas.width, H = canvas.height;\n  ctx.clearRect(0,0,W,H);\n  ctx.font = \"10px monospace\";\n  // compute sample points\n  const maxn = state.maxn;\n  const samples = state.samples;\n  const xs = [];\n  for (let i=0;i<samples;i++){\n    const t = i/(samples-1);\n    let n = 1 + Math.floor(t*(maxn-1));\n    xs.push(n);\n  }\n  const fvals = xs.map(n=>safeNum(state.ffun(n)));\n  const gvals = xs.map(n=>safeNum(state.gfun(n)));\n  // Determine plotting bounds\n  let allvals = fvals.concat(gvals).filter(v => isFinite(v) && !isNaN(v) && v>0);\n  if (allvals.length===0) {\n    // try allow negatives by absolute\n    allvals = fvals.concat(gvals).filter(v => isFinite(v) && !isNaN(v));\n  }\n  if (allvals.length===0) {\n    ctx.fillText(\"No finite sample values to plot\",10,20);\n    return;\n  }\n  let minv = Math.min.apply(null, allvals);\n  let maxv = Math.max.apply(null, allvals);\n  if (minv<=0 && state.scale==='log') minv = 1e-9;\n  if (minv===maxv) { maxv = minv * 10 + 1; }\n  // scale functions\n  function yMap(v){\n    if (!isFinite(v) || isNaN(v)) return NaN;\n    if (state.scale === 'log') {\n      const lv = Math.log(Math.max(1e-12, Math.abs(v)));\n      const ymin = Math.log(Math.max(1e-12,minv));\n      const ymax = Math.log(Math.max(1e-12,maxv));\n      return H - 20 - (lv - ymin)/(ymax-ymin) * (H-40);\n    } else {\n      return H - 20 - ( (v - minv) / (maxv - minv) ) * (H-40);\n    }\n  }\n  function xMap(n){ return 40 + (n-1)/(state.maxn-1) * (W-60); }\n\n  // axes\n  ctx.strokeStyle = \"#000\";\n  ctx.beginPath();\n  ctx.moveTo(35,10);\n  ctx.lineTo(35,H-20);\n  ctx.lineTo(W-10,H-20);\n  ctx.stroke();\n  ctx.fillText(\"n\", W-30, H-22);\n  ctx.fillText(\"value\", 0, 12);\n\n  // draw bounds region if provided\n  if (state.showBounds && c1!==null && c2!==null && n0!==null) {\n    ctx.fillStyle = \"rgba(0,0,0,0.05)\";\n    ctx.globalAlpha = 0.08;\n    for (let i=0;i<xs.length;i++){\n      const n = xs[i];\n      if (n < n0) continue;\n      const gv = gvals[i];\n      if (!isFinite(gv)) continue;\n      const up = c2*gv;\n      const lo = c1*gv;\n      const y1 = yMap(up), y2 = yMap(lo);\n      if (!isNaN(y1) && !isNaN(y2)){\n        const x = xMap(n);\n        ctx.fillRect(x-1, Math.min(y1,y2), 2, Math.abs(y1-y2) || 2);\n      }\n    }\n    ctx.globalAlpha = 1.0;\n  }\n\n  // draw g as dashed\n  ctx.beginPath();\n  ctx.strokeStyle = \"#000\";\n  for (let i=0;i<xs.length;i++){\n    const x = xMap(xs[i]), y = yMap(gvals[i]);\n    if (i===0) ctx.moveTo(x,y);\n    else ctx.lineTo(x,y);\n  }\n  if (state.pointsMode) {\n    for (let i=0;i<xs.length;i++){\n      const x = xMap(xs[i]), y = yMap(gvals[i]);\n      if (isFinite(y)) ctx.fillRect(x-1,y-1,2,2);\n    }\n  } else ctx.stroke();\n  ctx.fillText(\"g(n)\", 45, 30);\n\n  // draw f as solid line\n  ctx.beginPath();\n  ctx.strokeStyle = \"#000\";\n  for (let i=0;i<xs.length;i++){\n    const x = xMap(xs[i]), y = yMap(fvals[i]);\n    if (i===0) ctx.moveTo(x,y);\n    else ctx.lineTo(x,y);\n  }\n  if (state.pointsMode) {\n    for (let i=0;i<xs.length;i++){\n      const x = xMap(xs[i]), y = yMap(fvals[i]);\n      if (isFinite(y)) ctx.fillRect(x-1,y-1,2,2);\n    }\n  } else ctx.stroke();\n  ctx.fillText(\"f(n)\", 45, 42);\n\n  // optionally draw bounding lines\n  if (state.showBounds && c1!==null && c2!==null) {\n    ctx.beginPath();\n    ctx.strokeStyle = \"#000\";\n    for (let i=0;i<xs.length;i++){\n      const x = xMap(xs[i]);\n      const gv = gvals[i];\n      let ylo = yMap(c1*gv);\n      let yup = yMap(c2*gv);\n      if (i===0) { ctx.moveTo(x,ylo); } else ctx.lineTo(x,ylo);\n    }\n    ctx.stroke();\n    ctx.beginPath();\n    for (let i=0;i<xs.length;i++){\n      const x = xMap(xs[i]);\n      const gv = gvals[i];\n      let yup = yMap(c2*gv);\n      if (i===0) { ctx.moveTo(x,yup); } else ctx.lineTo(x,yup);\n    }\n    ctx.stroke();\n    ctx.fillText(\"c1*g, c2*g (bounds)\", 45, 54);\n  }\n\n  // annotate some sample points values\n  for (let i=0;i<Math.min(6,xs.length);i++){\n    const n = xs[Math.floor(i*(xs.length-1)/5)];\n    const x = xMap(n);\n    const yf = yMap(state.ffun(n));\n    const yg = yMap(state.gfun(n));\n    if (isFinite(yf)) ctx.fillText(\"n=\"+n+\" f=\"+formatNum(state.ffun(n)), x+4, yf-4);\n    if (isFinite(yg)) ctx.fillText(\"g=\"+formatNum(state.gfun(n)), x+4, yg+12);\n  }\n}\n\nfunction formatNum(x) {\n  if (!isFinite(x)) return String(x);\n  if (Math.abs(x) >= 1e6 || Math.abs(x) < 1e-3 && x!==0) return x.toExponential(3);\n  return Number(x.toFixed(6)).toString();\n}\n\n/* ---------- Table and CSV ---------- */\n\nfunction showTable() {\n  updateStateFromInputs();\n  const maxn = state.maxn;\n  const samples = state.samples;\n  const rows = [];\n  for (let i=0;i<samples;i++){\n    const t = i/(samples-1);\n    let n = 1 + Math.floor(t*(maxn-1));\n    const f = state.ffun(n);\n    const g = state.gfun(n);\n    rows.push({n, f, g});\n  }\n  let text = \"n,f(n),g(n)\\\\n\";\n  for (const r of rows) text += r.n + \",\" + formatNum(r.f) + \",\" + formatNum(r.g) + \"\\\\n\";\n  logAppend(\"Value table (first 20 rows):\\\\n\" + rows.slice(0,20).map(r => r.n + \" f=\"+formatNum(r.f)+\" g=\"+formatNum(r.g)).join(\"\\\\n\"));\n}\n\nfunction exportCSV() {\n  updateStateFromInputs();\n  const maxn = state.maxn;\n  const samples = state.samples;\n  const rows = [];\n  for (let i=0;i<samples;i++){\n    const t = i/(samples-1);\n    let n = 1 + Math.floor(t*(maxn-1));\n    const f = state.ffun(n);\n    const g = state.gfun(n);\n    rows.push(n + \",\" + formatNum(f) + \",\" + formatNum(g));\n  }\n  const csv = \"n,f(n),g(n)\\\\n\" + rows.join(\"\\\\n\");\n  // create a downloadable blob\n  const blob = new Blob([csv], {type:'text/csv'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = \"theta_export.csv\";\n  a.textContent = \"download\";\n  a.click();\n  URL.revokeObjectURL(url);\n  logAppend(\"CSV exported for sampled values.\");\n}\n\n/* ---------- Theta Checking and Searches ---------- */\n\nfunction checkInequality(c1, c2, n0) {\n  // checks in sample range for all n >= n0 whether inequality holds depending on mode\n  const maxn = state.maxn;\n  for (let n = n0; n <= maxn; n++) {\n    const f = state.ffun(n), g = state.gfun(n);\n    if (!isFinite(f) || !isFinite(g)) {\n      return { ok: false, counterexample: n, fval: f, gval: g };\n    }\n    if (state.mode === 'theta') {\n      if (!(c1 * g <= f + 1e-12 && f <= c2 * g + 1e-12)) return { ok:false, counterexample:n, fval:f, gval:g };\n    } else if (state.mode === 'o') {\n      if (!(f <= c2 * g + 1e-12)) return { ok:false, counterexample:n, fval:f, gval:g };\n    } else if (state.mode === 'omega') {\n      if (!(c1 * g <= f + 1e-12)) return { ok:false, counterexample:n, fval:f, gval:g };\n    }\n  }\n  return { ok:true };\n}\n\nasync function bruteForceSearch() {\n  // Search for small integer/floating c1, c2 and n0 that satisfy Theta (in sampled range)\n  const maxn = state.maxn;\n  const mode = state.mode;\n  logAppend(\"Brute-force search starting (this may take a moment)...\");\n  // We'll search c1 in geometric grid (0.01 to 10) and c2 in 1..100, n0 from 1..maxn\n  const c1Candidates = [];\n  for (let p=-4;p<=2;p++) for (let k=1;k<=9;k++){\n    c1Candidates.push(k*Math.pow(10,p));\n  }\n  const c2Candidates = [];\n  for (let p=-1;p<=4;p++) for (let k=1;k<=9;k++){\n    c2Candidates.push(k*Math.pow(10,p));\n  }\n  // Guarantee c1 < c2\n  for (const c1 of c1Candidates) {\n    for (const c2 of c2Candidates) {\n      if (c2 <= c1) continue;\n      for (let n0 = 1; n0 <= Math.min(maxn, 200); n0++) {\n        const res = checkInequality(c1,c2,n0);\n        if (res.ok) {\n          logAppend(\"Found candidate: c1=\"+c1+\" c2=\"+c2+\" n0=\"+n0+\" (mode=\"+mode+\")\");\n          state.lastSearchResult = {c1,c2,n0};\n          document.getElementById('c1').value = c1;\n          document.getElementById('c2').value = c2;\n          document.getElementById('n0').value = n0;\n          drawPlot(c1,c2,n0);\n          return;\n        }\n      }\n    }\n  }\n  logAppend(\"Brute-force search: No candidate found in grid.\");\n}\n\n/* Stepwise search: explore gradually with manual steps recorded */\nfunction stepwiseSearchInit() {\n  logAppend(\"Stepwise search initiated. Use Next Step to try candidate triplets.\");\n  const c1start = 0.1;\n  state.proofSteps = [];\n  // Setup initial grid of plausible picks\n  const cs = [0.1, 0.25, 0.5, 1, 2, 5];\n  const n0s = [1,2,5,10,20,50];\n  for (const c1 of cs) for (const c2 of cs) for (const n0 of n0s) {\n    if (c2 <= c1) continue;\n    state.proofSteps.push({c1,c2,n0, tried:false});\n  }\n  state.currentStep = -1;\n  logAppend(\"Prepared \"+state.proofSteps.length+\" candidate steps.\");\n}\n\ndocument.getElementById('startProof').addEventListener('click', function(){\n  updateStateFromInputs();\n  state.proofSteps = [];\n  state.currentStep = -1;\n  logAppend(\"Proof workflow reset. Press Stepwise Search to prepare steps.\");\n});\ndocument.getElementById('nextStep').addEventListener('click', function(){\n  if (!state.proofSteps || state.proofSteps.length===0) { logAppend(\"No proof steps prepared. Click Stepwise Search first.\"); return; }\n  state.currentStep = Math.min(state.currentStep+1, state.proofSteps.length-1);\n  const step = state.proofSteps[state.currentStep];\n  step.tried = true;\n  document.getElementById('c1').value = step.c1;\n  document.getElementById('c2').value = step.c2;\n  document.getElementById('n0').value = step.n0;\n  const result = checkInequality(step.c1, step.c2, step.n0);\n  if (result.ok) {\n    logAppend(\"Step \"+(state.currentStep+1)+\": Candidate PASSED c1=\"+step.c1+\" c2=\"+step.c2+\" n0=\"+step.n0);\n    drawPlot(step.c1, step.c2, step.n0);\n  } else {\n    logAppend(\"Step \"+(state.currentStep+1)+\": Candidate FAILED at n=\"+result.counterexample+\" c1=\"+step.c1+\" c2=\"+step.c2+\" n0=\"+step.n0);\n    drawPlot(step.c1, step.c2, step.n0);\n  }\n});\ndocument.getElementById('prevStep').addEventListener('click', function(){\n  if (!state.proofSteps || state.proofSteps.length===0) return;\n  state.currentStep = Math.max(0, state.currentStep-1);\n  const step = state.proofSteps[state.currentStep];\n  document.getElementById('c1').value = step.c1;\n  document.getElementById('c2').value = step.c2;\n  document.getElementById('n0').value = step.n0;\n  logAppend(\"Moved to previous step \"+(state.currentStep+1));\n  drawPlot(step.c1, step.c2, step.n0);\n});\ndocument.getElementById('accept').addEventListener('click', function(){\n  const c1 = parseFloat(document.getElementById('c1').value);\n  const c2 = parseFloat(document.getElementById('c2').value);\n  const n0 = parseInt(document.getElementById('n0').value,10);\n  logAppend(\"User accepted candidate c1=\"+c1+\" c2=\"+c2+\" n0=\"+n0+\". Marking proof complete.\");\n});\ndocument.getElementById('reject').addEventListener('click', function(){\n  logAppend(\"User rejected current candidate. Continue searching.\");\n});\n\n/* ---------- Limit estimation and simplification ---------- */\n\nfunction estimateLimit() {\n  // Sample f/g for increasing n and see trend\n  const maxn = state.maxn;\n  const points = [];\n  const steps = [10,20,50,100,200,500,1000];\n  let nprev = Math.max(10, Math.floor(maxn/10));\n  for (let k=0;k<Math.min(8, steps.length);k++){\n    const n = Math.min(maxn, steps[k]);\n    const val = state.gfun(n);\n    const fv = state.ffun(n);\n    const ratio = (isFinite(fv) && isFinite(val) && val!==0)? fv/val : NaN;\n    points.push(Number.isFinite(ratio)?ratio:NaN);\n  }\n  // Also sample geometric progression\n  const extra = [];\n  for (let i=1;i<=6;i++){\n    const n = Math.min(maxn, Math.floor(Math.pow(10, Math.log10(Math.max(2,maxn))/6 * i)));\n    const fv = state.ffun(n);\n    const gv = state.gfun(n);\n    const ratio = (isFinite(fv) && isFinite(gv) && gv!==0)? fv/gv : NaN;\n    extra.push(ratio);\n  }\n  const vals = points.concat(extra).filter(x=>isFinite(x));\n  let summary = \"insufficient data\";\n  if (vals.length>0) {\n    const last = vals[vals.length-1];\n    const avg = vals.reduce((a,b)=>a+b,0)/vals.length;\n    if (Math.abs(last) < 1e-6) summary = \"0 (f is smaller than g)\";\n    else if (!isFinite(last) || Math.abs(last) > 1e9) summary = \"∞ (f grows much faster than g)\";\n    else summary = \"≈ \" + last.toExponential(3) + \" (avg \" + avg.toExponential(3) + \")\";\n  }\n  return {values: vals, summary};\n}\n\nfunction classifyGrowth() {\n  // crude classification based on sample slopes in log-log if possible\n  const samples = [];\n  const maxn = state.maxn;\n  for (let i=1;i<=20;i++){\n    const n = Math.max(1, Math.floor(i/20 * (maxn-1)) + 1);\n    const fv = state.ffun(n);\n    if (!isFinite(fv) || fv<=0) continue;\n    samples.push({n, fv});\n  }\n  if (samples.length<3) return \"Not enough positive samples to classify.\";\n  // compute slope of log(f) vs log(n)\n  const logn = samples.map(s=>Math.log(s.n));\n  const logf = samples.map(s=>Math.log(Math.abs(s.fv)));\n  const avgx = logn.reduce((a,b)=>a+b,0)/logn.length;\n  const avgy = logf.reduce((a,b)=>a+b,0)/logf.length;\n  let num=0, den=0;\n  for (let i=0;i<logn.length;i++){\n    num += (logn[i]-avgx)*(logf[i]-avgy);\n    den += (logn[i]-avgx)*(logn[i]-avgx);\n  }\n  const slope = num/den;\n  if (slope>4) return \"Superpolynomial growth (slope ~ \"+slope.toFixed(2)+\")\";\n  if (slope>1.5) return \"Polynomial of degree ~\"+slope.toFixed(2);\n  if (slope>0.4) return \"Between linear and quadratic (slope ~\"+slope.toFixed(2)+\")\";\n  if (slope>0.1) return \"Near-linear (slope ~\"+slope.toFixed(2)+\")\";\n  if (slope>-0.5 && slope<=0.1) return \"Polylogarithmic or logarithmic growth (slope ~\"+slope.toFixed(2)+\")\";\n  if (slope<=-0.5) return \"Decaying or sub-log growth (slope ~\"+slope.toFixed(2)+\")\";\n  return \"Unclear classification (slope ~\"+slope.toFixed(2)+\")\";\n}\n\n/* Asymptotic simplify: try to guess leading term among polynomial/log/exp */\nfunction asymptoticSimplify() {\n  // Try to detect polynomial degree by evaluating ratio n^k\n  function guess(exprfun) {\n    // try polynomial degree up to 6\n    for (let deg=6; deg>=0; deg--) {\n      // test ratio f / n^deg converging to constant\n      const vals = [];\n      for (const n of [10,50,200,500,1000]) {\n        if (n>state.maxn) continue;\n        const f = exprfun(n);\n        const denom = Math.pow(n,deg);\n        if (!isFinite(f) || denom===0) { vals.push(NaN); continue; }\n        vals.push(f/denom);\n      }\n      const finite = vals.filter(v=>isFinite(v));\n      if (finite.length>=3) {\n        const ratioChange = Math.max.apply(null, finite)/Math.min.apply(null, finite);\n        if (ratioChange < 100) {\n          return (deg===0?\"constant or log-like\":\"n^\"+deg+\" * Theta(1)\");\n        }\n      }\n    }\n    // test exponential: f( n ) ~ a^n ?\n    const r1 = exprfun(20), r2 = exprfun(21);\n    if (isFinite(r1)&&isFinite(r2)&&r1>0&&r2>0) {\n      const approx = r2/r1;\n      if (approx>1.2) return \"Exponential growth ~\"+approx.toFixed(3)+\"^n\";\n    }\n    // fallback: sample slopes\n    return \"Unknown (use numeric limit estimate)\";\n  }\n  const fguess = guess(state.ffun);\n  const gguess = guess(state.gfun);\n  return {f:fguess, g:gguess};\n}\n\n/* Counterexample search: tries to find n where inequality fails for provided c's */\nfunction findCounterexample() {\n  const c1 = parseFloat(document.getElementById('c1').value);\n  const c2 = parseFloat(document.getElementById('c2').value);\n  const n0 = parseInt(document.getElementById('n0').value,10);\n  const maxn = state.maxn;\n  for (let n=1;n<=maxn;n++){\n    const f = state.ffun(n), g = state.gfun(n);\n    if (!isFinite(f) || !isFinite(g)) continue;\n    if (n>=n0) {\n      if (!(c1 * g <= f + 1e-12 && f <= c2 * g + 1e-12)) return {n,f,g};\n    }\n  }\n  return null;\n}\n\n/* ---------- Random expression generator ---------- */\n\nfunction randomExpression() {\n  const choices = [\n    \"n^3 + 4*n^2 + 7\",\n    \"n^2 + 5*n + 3\",\n    \"n*log(n) + n\",\n    \"log(n) + 2\",\n    \"2^n + n^3\",\n    \"n^2 * log(n)\",\n    \"factorial(n)\",\n    \"n^1.5 + 100*n\",\n    \"n*sqrt(n) + 20\",\n    \"n*log(n)^2\",\n    \"10*n + 100\",\n    \"n^4 + 2^n\",\n    \"n\"\n  ];\n  return choices[Math.floor(Math.random()*choices.length)];\n}\n\n/* ---------- Proof workflow placeholders (complex state transitions) ---------- */\n\n// We'll create a multi-step \"proof assistant\" that records attempts, counters, refinement actions.\nfunction createProofWorkflow() {\n  // Not used directly but the UI allows stepwise interaction\n}\n\n/* ---------- Initialization ---------- */\n\nupdateStateFromInputs();\ndrawPlot();\nlogAppend(\"Interactive Big-Theta Explorer loaded. Edit f(n) and g(n), then Plot, Search, or Check Θ.\");\n\n/* ---------- Extra: allow keyboard shortcuts for convenience (minimal) ---------- */\ndocument.addEventListener('keydown', function(e){\n  if (e.key === \"p\" && e.ctrlKey) { e.preventDefault(); updateStateFromInputs(); drawPlot(); logAppend(\"Plot (shortcut).\"); }\n});\n\n/* ---------- End of script ---------- */\n</script>\n\n</body>\n</html>"
