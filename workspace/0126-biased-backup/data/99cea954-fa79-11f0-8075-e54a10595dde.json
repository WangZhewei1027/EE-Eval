    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Merge Sort Visualizer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #arrayDisplay {\n            margin-top: 20px;\n            white-space: pre;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Merge Sort Visualizer</h1>\n\n<label for=\"sizeInput\">Array Size (2-20):</label>\n<input type=\"number\" id=\"sizeInput\" min=\"2\" max=\"20\" value=\"10\">\n<button id=\"generateArray\">Generate Array</button>\n<button id=\"startSort\">Start Merge Sort</button>\n\n<div id=\"arrayDisplay\"></div>\n\n<script>\n    let array = [];\n\n    function displayArray() {\n        const arrayDisplay = document.getElementById('arrayDisplay');\n        arrayDisplay.textContent = array.join(', ');\n    }\n\n    function generateRandomArray(size) {\n        array = Array.from({ length: size }, () => Math.floor(Math.random() * 100));\n        displayArray();\n    }\n\n    async function mergeSort(arr) {\n        if (arr.length <= 1) return arr;\n\n        const mid = Math.floor(arr.length / 2);\n        const left = await mergeSort(arr.slice(0, mid));\n        const right = await mergeSort(arr.slice(mid));\n\n        return await merge(left, right);\n    }\n\n    async function merge(left, right) {\n        const result = [];\n        let leftIndex = 0, rightIndex = 0;\n\n        while (leftIndex < left.length && rightIndex < right.length) {\n            if (left[leftIndex] < right[rightIndex]) {\n                result.push(left[leftIndex]);\n                leftIndex++;\n            } else {\n                result.push(right[rightIndex]);\n                rightIndex++;\n            }\n            displayArray();\n            await new Promise(resolve => setTimeout(resolve, 500)); // Pause for visualization\n        }\n\n        return result.concat(left.slice(leftIndex)).concat(right.slice(rightIndex));\n    }\n\n    document.getElementById('generateArray').addEventListener('click', () => {\n        const size = parseInt(document.getElementById('sizeInput').value, 10);\n        generateRandomArray(size);\n    });\n\n    document.getElementById('startSort').addEventListener('click', async () => {\n        array = await mergeSort(array);\n        displayArray();\n    });\n\n    // Initialize with a random array on page load\n    window.onload = () => generateRandomArray(10);\n</script>\n\n</body>\n</html>"
