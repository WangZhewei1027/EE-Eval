  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Heap (Min) Interactive Explorer</title>\n  <style>\n    /* Extremely minimal visual styling - keep it plain and basic */\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color: black; background: white; margin: 12px; }\n    h1, h2, h3 { margin: 6px 0; font-weight: normal; }\n    .row { margin: 6px 0; }\n    input[type=\"text\"], input[type=\"number\"], select { margin-right: 6px; }\n    button { margin-right: 6px; }\n    pre { background: white; border: 1px solid #ccc; padding: 8px; white-space: pre-wrap; }\n    .arrayView { margin-top:8px; white-space:nowrap; font-family: monospace; }\n    .controls { margin-bottom:12px; }\n    .section { margin-bottom:14px; padding:6px 0; border-top:1px solid #eee; }\n    label { margin-right:6px; }\n  </style>\n</head>\n<body>\n\n<h1>Heap (Min) Interactive Explorer</h1>\n\n<div>\n  This tool demonstrates a binary heap (default: Min Heap) with extensive interactive controls. You can insert values, extract the minimum, build the heap step-by-step (heapify), run heap sort, change keys, delete elements, undo/redo, play steps automatically, and inspect array or tree views. All visualization is plain text and minimal by design.\n</div>\n\n<div class=\"controls\">\n  <div class=\"section\">\n    <h2>Basic Heap Operations</h2>\n    <div class=\"row\">\n      <label>Value to insert:</label>\n      <input id=\"insertValue\" type=\"number\" value=\"5\">\n      <button id=\"btnInsert\">Insert</button>\n      <label>Bulk CSV:</label>\n      <input id=\"bulkCSV\" type=\"text\" placeholder=\"e.g. 4,1,7,3\">\n      <button id=\"btnBulkInsert\">Bulk Insert</button>\n    </div>\n    <div class=\"row\">\n      <button id=\"btnPeek\">Peek (min)</button>\n      <button id=\"btnExtract\">Extract Min</button>\n      <label>Delete index:</label>\n      <input id=\"deleteIndex\" type=\"number\" value=\"0\" style=\"width:60px;\">\n      <button id=\"btnDeleteIndex\">Delete</button>\n    </div>\n    <div class=\"row\">\n      <label>Change key at index:</label>\n      <input id=\"changeIndex\" type=\"number\" value=\"0\" style=\"width:60px;\">\n      <input id=\"changeValue\" type=\"number\" value=\"0\" style=\"width:80px;\">\n      <button id=\"btnChangeKey\">Change Key (dec/inc)</button>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <h2>Build / Heapify (step-by-step)</h2>\n    <div class=\"row\">\n      <label>Array (CSV):</label>\n      <input id=\"buildArray\" type=\"text\" value=\"7,3,10,1,5,2\">\n      <button id=\"btnLoadArray\">Load Array (no heapify)</button>\n      <button id=\"btnBuildHeap\">Build Heap (immediate)</button>\n      <button id=\"btnGenerateSteps\">Generate Heapify Steps</button>\n    </div>\n    <div class=\"row\">\n      <button id=\"stepBack\">Step Back</button>\n      <button id=\"stepForward\">Step Forward</button>\n      <label>Auto-play:</label>\n      <input id=\"autoPlay\" type=\"checkbox\">\n      <label>Speed (ms):</label>\n      <input id=\"speed\" type=\"range\" min=\"100\" max=\"2000\" step=\"100\" value=\"600\">\n      <span id=\"speedLabel\">600</span>\n      <button id=\"btnStopAuto\">Stop</button>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <h2>Heap Sort (step-by-step)</h2>\n    <div class=\"row\">\n      <button id=\"btnHeapSortAsc\">Heap Sort (ascending) - step generator</button>\n      <button id=\"btnHeapSortDesc\">Heap Sort (descending)</button>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <h2>Modes, Indexing & Utilities</h2>\n    <div class=\"row\">\n      <label>Comparator:</label>\n      <select id=\"comparatorMode\">\n        <option value=\"min\" selected>Min-Heap (default)</option>\n        <option value=\"max\">Max-Heap (switch to explore)</option>\n      </select>\n      <label>Array indexing:</label>\n      <select id=\"indexingMode\">\n        <option value=\"0\" selected>0-based</option>\n        <option value=\"1\">1-based</option>\n      </select>\n      <button id=\"btnRebuildOnMode\">Rebuild (apply mode)</button>\n      <label>Random size:</label>\n      <input id=\"randSize\" type=\"number\" value=\"8\" style=\"width:60px;\">\n      <button id=\"btnRandomize\">Randomize</button>\n    </div>\n    <div class=\"row\">\n      <button id=\"btnValidate\">Validate Heap Property</button>\n      <button id=\"btnReset\">Reset (clear)</button>\n      <button id=\"btnExport\">Export JSON</button>\n      <button id=\"btnImport\">Import JSON</button>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <h2>History / Navigation</h2>\n    <div class=\"row\">\n      <button id=\"btnUndo\">Undo</button>\n      <button id=\"btnRedo\">Redo</button>\n      <label>Jump to step:</label>\n      <input id=\"jumpStep\" type=\"number\" value=\"0\" style=\"width:80px;\">\n      <button id=\"btnJump\">Go</button>\n      <label>Snapshot description (for manual save):</label>\n      <input id=\"snapshotDesc\" type=\"text\" placeholder=\"description\">\n      <button id=\"btnSaveSnapshot\">Save Snapshot</button>\n    </div>\n    <div class=\"row\">\n      <label>History length:</label>\n      <span id=\"historyInfo\">0 steps</span>\n    </div>\n  </div>\n\n</div>\n\n<div class=\"section\">\n  <h2>Visualization</h2>\n  <div class=\"row\">\n    <label>View:</label>\n    <select id=\"viewMode\">\n      <option value=\"array\" selected>Array</option>\n      <option value=\"tree\">Tree (text)</option>\n      <option value=\"both\">Both</option>\n    </select>\n    <label>Highlight type:</label>\n    <select id=\"highlightMode\">\n      <option value=\"none\">None</option>\n      <option value=\"indices\">Show compared/swapped indices</option>\n      <option value=\"counts\">Show counts</option>\n    </select>\n  </div>\n  <div class=\"row\">\n    <div id=\"visualization\">\n      <div id=\"arrayArea\" class=\"arrayView\"></div>\n      <pre id=\"treeArea\"></pre>\n    </div>\n  </div>\n\n  <div class=\"row\">\n    <label>Comparisons:</label> <span id=\"compCount\">0</span>\n    <label style=\"margin-left:12px;\">Swaps:</label> <span id=\"swapCount\">0</span>\n  </div>\n</div>\n\n<div class=\"section\">\n  <h2>Detailed Log / Steps</h2>\n  <pre id=\"logArea\"></pre>\n</div>\n\n<script>\n(function(){\n  // Minimal UI - rich interactivity implemented in JS.\n  // Internal state and history snapshots.\n  let state = {\n    arr: [],\n    comparatorMode: 'min', // min or max\n    indexingBase: 0, // 0 or 1\n    compCount: 0,\n    swapCount: 0\n  };\n\n  // Snapshot history for stepping and undo/redo.\n  let history = [];\n  let currentStep = -1; // index into history\n  let autoTimer = null;\n\n  // For step generators (heapify / heapsort) store generated step sequence of snapshot objects\n  // Each snapshot: {arr:[], type:'compare'|'swap'|'info', indices:[i,j], desc: '...'}\n  // Those are appended to history with saveSnapshot.\n  const elements = {\n    insertValue: document.getElementById('insertValue'),\n    btnInsert: document.getElementById('btnInsert'),\n    bulkCSV: document.getElementById('bulkCSV'),\n    btnBulkInsert: document.getElementById('btnBulkInsert'),\n    btnPeek: document.getElementById('btnPeek'),\n    btnExtract: document.getElementById('btnExtract'),\n    deleteIndex: document.getElementById('deleteIndex'),\n    btnDeleteIndex: document.getElementById('btnDeleteIndex'),\n    changeIndex: document.getElementById('changeIndex'),\n    changeValue: document.getElementById('changeValue'),\n    btnChangeKey: document.getElementById('btnChangeKey'),\n    buildArray: document.getElementById('buildArray'),\n    btnLoadArray: document.getElementById('btnLoadArray'),\n    btnBuildHeap: document.getElementById('btnBuildHeap'),\n    btnGenerateSteps: document.getElementById('btnGenerateSteps'),\n    stepBack: document.getElementById('stepBack'),\n    stepForward: document.getElementById('stepForward'),\n    autoPlay: document.getElementById('autoPlay'),\n    speed: document.getElementById('speed'),\n    speedLabel: document.getElementById('speedLabel'),\n    btnStopAuto: document.getElementById('btnStopAuto'),\n    btnHeapSortAsc: document.getElementById('btnHeapSortAsc'),\n    btnHeapSortDesc: document.getElementById('btnHeapSortDesc'),\n    comparatorMode: document.getElementById('comparatorMode'),\n    indexingMode: document.getElementById('indexingMode'),\n    btnRebuildOnMode: document.getElementById('btnRebuildOnMode'),\n    randSize: document.getElementById('randSize'),\n    btnRandomize: document.getElementById('btnRandomize'),\n    btnValidate: document.getElementById('btnValidate'),\n    btnReset: document.getElementById('btnReset'),\n    btnExport: document.getElementById('btnExport'),\n    btnImport: document.getElementById('btnImport'),\n    btnUndo: document.getElementById('btnUndo'),\n    btnRedo: document.getElementById('btnRedo'),\n    jumpStep: document.getElementById('jumpStep'),\n    btnJump: document.getElementById('btnJump'),\n    snapshotDesc: document.getElementById('snapshotDesc'),\n    btnSaveSnapshot: document.getElementById('btnSaveSnapshot'),\n    historyInfo: document.getElementById('historyInfo'),\n    viewMode: document.getElementById('viewMode'),\n    highlightMode: document.getElementById('highlightMode'),\n    arrayArea: document.getElementById('arrayArea'),\n    treeArea: document.getElementById('treeArea'),\n    compCount: document.getElementById('compCount'),\n    swapCount: document.getElementById('swapCount'),\n    logArea: document.getElementById('logArea')\n  };\n\n  // Utilities\n  function cloneArr(a){ return a.slice(); }\n  function cmp(a,b){\n    if(state.comparatorMode === 'min') return a - b;\n    else return b - a;\n  }\n  function parent(i){ return Math.floor((i-1)/2); }\n  function left(i){ return 2*i + 1; }\n  function right(i){ return 2*i + 2; }\n\n  function saveSnapshot(desc, special){\n    // Truncate history if we are not at the end (branching)\n    if(currentStep < history.length - 1){\n      history = history.slice(0, currentStep+1);\n    }\n    const snap = {\n      arr: cloneArr(state.arr),\n      compCount: state.compCount,\n      swapCount: state.swapCount,\n      desc: desc || '',\n      special: special || null,\n      comparatorMode: state.comparatorMode,\n      indexingBase: state.indexingBase\n    };\n    history.push(snap);\n    currentStep = history.length - 1;\n    updateHistoryInfo();\n  }\n\n  function restoreSnapshot(idx){\n    if(idx < 0 || idx >= history.length) return;\n    const snap = history[idx];\n    state.arr = cloneArr(snap.arr);\n    state.compCount = snap.compCount;\n    state.swapCount = snap.swapCount;\n    state.comparatorMode = snap.comparatorMode;\n    state.indexingBase = snap.indexingBase;\n    currentStep = idx;\n    render();\n  }\n\n  function updateHistoryInfo(){\n    elements.historyInfo.textContent = history.length + \" steps (current: \" + (currentStep+1) + \")\";\n    elements.jumpStep.value = currentStep;\n    elements.jumpStep.max = history.length - 1;\n    elements.logArea.textContent = history.map((s,i)=> (i===currentStep?\"> \":\"   \") + i + \": \" + (s.desc||\"(no desc)\") + \" [\"+s.arr.join(\", \")+\"]\").join(\"\\n\");\n  }\n\n  // Rendering\n  function render(){\n    // Render array view\n    const base = state.indexingBase;\n    const arr = state.arr;\n    let arrText = \"\";\n    for(let i=0;i<arr.length;i++){\n      const idx = i + base;\n      arrText += \"[\" + idx + \"]:\" + arr[i] + \"  \";\n    }\n    if(arr.length === 0) arrText = \"(empty)\";\n    elements.arrayArea.textContent = arrText;\n\n    // Tree text rendering simple lines per level\n    elements.treeArea.textContent = renderTreeText(arr, base);\n\n    // Counters\n    elements.compCount.textContent = state.compCount;\n    elements.swapCount.textContent = state.swapCount;\n\n    updateHistoryInfo();\n  }\n\n  function renderTreeText(arr, base){\n    if(arr.length === 0) return \"(empty tree)\";\n    const levels = [];\n    let level = 0;\n    let index = 0;\n    while(index < arr.length){\n      const levelCount = Math.pow(2, level);\n      const items = [];\n      for(let j=0;j<levelCount && index < arr.length; j++){\n        items.push(\"[\" + (index + base) + \"]:\" + arr[index]);\n        index++;\n      }\n      levels.push(items.join(\" \"));\n      level++;\n    }\n    return levels.map((l,i)=> \"L\"+i+\": \"+l).join(\"\\n\");\n  }\n\n  // Basic heap operations with snapshot logging\n  function siftUp(index, recordSteps){\n    if(!recordSteps) recordSteps = false;\n    while(index > 0){\n      const p = parent(index);\n      state.compCount++;\n      if(recordSteps) saveInternalStep('compare', [index,p], \"compare index \"+index+\" and \"+p);\n      if(cmp(state.arr[index], state.arr[p]) < 0){\n        swap(index,p, recordSteps);\n        index = p;\n      } else break;\n    }\n  }\n\n  function siftDown(index, heapSize, recordSteps){\n    if(typeof heapSize === 'undefined') heapSize = state.arr.length;\n    if(!recordSteps) recordSteps = false;\n    while(true){\n      const l = left(index);\n      const r = right(index);\n      let smallest = index;\n      if(l < heapSize){\n        state.compCount++;\n        if(recordSteps) saveInternalStep('compare', [l, smallest], \"compare left \"+l+\" and \"+smallest);\n        if(cmp(state.arr[l], state.arr[smallest]) < 0) smallest = l;\n      }\n      if(r < heapSize){\n        state.compCount++;\n        if(recordSteps) saveInternalStep('compare', [r, smallest], \"compare right \"+r+\" and \"+smallest);\n        if(cmp(state.arr[r], state.arr[smallest]) < 0) smallest = r;\n      }\n      if(smallest !== index){\n        swap(index, smallest, recordSteps);\n        index = smallest;\n      } else break;\n    }\n  }\n\n  function swap(i,j, recordSteps){\n    state.swapCount++;\n    const tmp = state.arr[i];\n    state.arr[i] = state.arr[j];\n    state.arr[j] = tmp;\n    if(recordSteps) saveInternalStep('swap', [i,j], \"swap \"+i+\" and \"+j);\n  }\n\n  // Specialized: save an internal step to history as fine-grained snapshot (used for step-by-step)\n  function saveInternalStep(type, indices, desc){\n    // Create a special snapshot carrying type and indices so visualization can highlight.\n    const snap = {\n      arr: cloneArr(state.arr),\n      compCount: state.compCount,\n      swapCount: state.swapCount,\n      desc: desc || '',\n      special: {type: type, indices: indices ? indices.slice() : []},\n      comparatorMode: state.comparatorMode,\n      indexingBase: state.indexingBase\n    };\n    if(currentStep < history.length - 1){\n      history = history.slice(0, currentStep+1);\n    }\n    history.push(snap);\n    currentStep = history.length - 1;\n  }\n\n  // Operations triggered by UI\n  function opInsert(val, recordSteps){\n    if(val === null || val === undefined || isNaN(val)) return;\n    state.arr.push(Number(val));\n    if(recordSteps){\n      saveInternalStep('info', [], \"insert \"+val);\n      siftUp(state.arr.length - 1, true);\n    } else {\n      saveSnapshot(\"insert \"+val);\n    }\n    render();\n  }\n\n  function opBulkInsertFromCSV(csv){\n    if(!csv) return;\n    const parts = csv.split(',').map(s=> s.trim()).filter(s=> s.length>0);\n    for(const p of parts){\n      const n = Number(p);\n      if(!isNaN(n)) opInsert(n, false);\n    }\n    saveSnapshot(\"bulk insert\");\n    render();\n  }\n\n  function opPeek(){\n    if(state.arr.length === 0){ alert(\"Heap is empty\"); return; }\n    alert(\"Peek: \" + state.arr[0]);\n  }\n\n  function opExtract(recordSteps){\n    if(state.arr.length === 0){ alert(\"Heap empty\"); return; }\n    const val = state.arr[0];\n    if(recordSteps){\n      saveInternalStep('info', [], \"extract \"+val);\n      // replace root with last\n      const last = state.arr.pop();\n      if(state.arr.length > 0){\n        state.arr[0] = last;\n        saveInternalStep('swap', [0, state.arr.length], \"move last to root\");\n        siftDown(0, state.arr.length, true);\n      } else {\n        // removed only element, state already updated\n        saveInternalStep('info', [], \"heap empty after extract\");\n      }\n    } else {\n      const last = state.arr.pop();\n      if(state.arr.length > 0){\n        state.arr[0] = last;\n        siftDown(0);\n      }\n      saveSnapshot(\"extract min \"+val);\n    }\n    render();\n    return val;\n  }\n\n  function opDeleteAt(index, recordSteps){\n    if(index < 0 || index >= state.arr.length){\n      alert(\"Index out of range\");\n      return;\n    }\n    const removed = state.arr[index];\n    if(recordSteps){\n      saveInternalStep('info', [], \"delete index \" + index + \" value \" + removed);\n      const last = state.arr.pop();\n      if(index < state.arr.length){\n        state.arr[index] = last;\n        saveInternalStep('swap', [index, state.arr.length], \"move last to \"+index);\n        // try siftDown then siftUp\n        siftDown(index, state.arr.length, true);\n        siftUp(index, true);\n      }\n    } else {\n      const last = state.arr.pop();\n      if(index < state.arr.length){\n        state.arr[index] = last;\n        siftDown(index);\n        siftUp(index);\n      }\n      saveSnapshot(\"delete index \"+index+\" removed \"+removed);\n    }\n    render();\n  }\n\n  function opChangeKey(index, newValue, recordSteps){\n    if(index < 0 || index >= state.arr.length){\n      alert(\"Index out of range\");\n      return;\n    }\n    const old = state.arr[index];\n    state.arr[index] = Number(newValue);\n    if(recordSteps){\n      saveInternalStep('info', [], \"change index \"+index+\" from \"+old+\" to \"+newValue);\n      if(cmp(state.arr[index], old) < 0){\n        // decreased (for min-heap smaller is higher priority)\n        siftUp(index, true);\n      } else {\n        siftDown(index, state.arr.length, true);\n      }\n    } else {\n      // non-step version\n      if(cmp(state.arr[index], old) < 0) siftUp(index);\n      else siftDown(index, state.arr.length);\n      saveSnapshot(\"change key at \"+index+\" from \"+old+\" to \"+newValue);\n    }\n    render();\n  }\n\n  function opBuildHeapImmediate(){\n    // bottom-up heapify\n    const n = state.arr.length;\n    for(let i = Math.floor((n-2)/2); i >= 0; i--){\n      siftDown(i);\n    }\n    saveSnapshot(\"build heap immediate\");\n    render();\n  }\n\n  function generateHeapifyDetailed(arrInput){\n    // Replace current array with arrInput and generate detailed snapshots for each compare/swap\n    state.arr = arrInput.slice();\n    state.compCount = 0;\n    state.swapCount = 0;\n    saveInternalStep('info', [], \"start heapify\");\n    const n = state.arr.length;\n    for(let i = Math.floor((n-2)/2); i >= 0; i--){\n      // perform siftDown with logging already using saveInternalStep & swap\n      siftDown(i, n, true);\n    }\n    saveInternalStep('info', [], \"heapify complete\");\n    render();\n  }\n\n  function generateHeapSortDetailed(descending){\n    // We'll perform heap sort using current comparator mode and generate detailed steps.\n    // For min-heap, extracting min repeatedly produces ascending array.\n    // For heapsort in-place using heapify+swap: typical algorithm uses max-heap to get ascending by swapping root with end.\n    // We'll implement a safe method: build a heap (according to current comparator), then repeatedly extract to result array and log steps.\n    const originalArr = state.arr.slice();\n    const originalComp = state.compCount;\n    const originalSwap = state.swapCount;\n    // Build heap detailed\n    saveInternalStep('info', [], \"start heap sort build\");\n    const n = state.arr.length;\n    for(let i = Math.floor((n-2)/2); i >= 0; i--){\n      siftDown(i, n, true);\n    }\n    // Repeatedly extract root to a result array (not in-place), logging each extraction\n    const result = [];\n    for(let i = 0; i < n; i++){\n      if(state.arr.length === 0) break;\n      const val = opExtract(true); // opExtract with recordSteps logs the move\n      // After extraction, opExtract already modified arr. We append extracted val to result for clarity.\n      result.push(val);\n      saveInternalStep('info', [], \"extracted to result: [\" + result.join(\",\") + \"]\");\n    }\n\n    if(descending){\n      saveInternalStep('info', [], \"heap sort completed (descending requested) - reversing output preview\");\n      // final step showing reversed\n      saveInternalStep('info', [], \"sorted (descending): [\" + result.slice().reverse().join(\",\") + \"]\");\n    } else {\n      saveInternalStep('info', [], \"sorted (ascending by repeated extract): [\" + result.join(\",\") + \"]\");\n    }\n    // Restore heap state to original (but history captured the detailed steps)\n    state.arr = originalArr.slice();\n    state.compCount = originalComp;\n    state.swapCount = originalSwap;\n    saveSnapshot(\"heap sort simulated (history contains steps)\");\n    render();\n  }\n\n  // Validation\n  function validateHeap(){\n    for(let i=0;i<state.arr.length;i++){\n      const l = left(i);\n      const r = right(i);\n      if(l < state.arr.length && cmp(state.arr[l], state.arr[i]) < 0) return false;\n      if(r < state.arr.length && cmp(state.arr[r], state.arr[i]) < 0) return false;\n    }\n    return true;\n  }\n\n  // Randomization\n  function randomize(n){\n    n = Math.max(0, Math.floor(n));\n    state.arr = [];\n    for(let i=0;i<n;i++) state.arr.push(Math.floor(Math.random()*100));\n    state.compCount = 0;\n    state.swapCount = 0;\n    saveSnapshot(\"randomize size \"+n);\n    render();\n  }\n\n  // Export/Import\n  function exportJSON(){\n    const payload = {\n      arr: state.arr,\n      comparatorMode: state.comparatorMode,\n      indexingBase: state.indexingBase,\n      compCount: state.compCount,\n      swapCount: state.swapCount,\n      history: history\n    };\n    const text = JSON.stringify(payload);\n    prompt(\"Copy this JSON to save:\", text);\n  }\n  function importJSON(){\n    const txt = prompt(\"Paste JSON to import:\");\n    if(!txt) return;\n    try{\n      const payload = JSON.parse(txt);\n      if(Array.isArray(payload.arr)){\n        state.arr = payload.arr.slice();\n        if(payload.comparatorMode) state.comparatorMode = payload.comparatorMode;\n        if(typeof payload.indexingBase !== 'undefined') state.indexingBase = payload.indexingBase;\n        state.compCount = payload.compCount || 0;\n        state.swapCount = payload.swapCount || 0;\n        saveSnapshot(\"imported state\");\n        render();\n      } else {\n        alert(\"Invalid JSON\");\n      }\n    }catch(e){ alert(\"Error parsing JSON\"); }\n  }\n\n  // Undo/Redo\n  function undo(){\n    if(currentStep > 0){\n      restoreSnapshot(currentStep - 1);\n    }\n  }\n  function redo(){\n    if(currentStep < history.length - 1){\n      restoreSnapshot(currentStep + 1);\n    }\n  }\n\n  // Jump\n  function jumpTo(n){\n    n = Math.floor(Number(n));\n    if(isNaN(n) || n < 0 || n >= history.length){\n      alert(\"Invalid step\");\n      return;\n    }\n    restoreSnapshot(n);\n  }\n\n  // Auto-play control\n  function startAutoPlay(){\n    stopAutoPlay();\n    if(!elements.autoPlay.checked) return;\n    const ms = Number(elements.speed.value) || 600;\n    elements.speedLabel.textContent = ms;\n    autoTimer = setInterval(()=>{\n      if(currentStep < history.length - 1){\n        restoreSnapshot(currentStep + 1);\n      } else {\n        stopAutoPlay();\n      }\n    }, ms);\n  }\n  function stopAutoPlay(){\n    if(autoTimer) { clearInterval(autoTimer); autoTimer = null; }\n    elements.autoPlay.checked = false;\n  }\n\n  // UI wiring\n  elements.btnInsert.addEventListener('click', function(){\n    const val = Number(elements.insertValue.value);\n    opInsert(val, true);\n    render();\n  });\n  elements.btnBulkInsert.addEventListener('click', function(){\n    opBulkInsertFromCSV(elements.bulkCSV.value);\n    render();\n  });\n  elements.btnPeek.addEventListener('click', function(){ opPeek(); });\n  elements.btnExtract.addEventListener('click', function(){ opExtract(true); render(); });\n  elements.btnDeleteIndex.addEventListener('click', function(){ opDeleteAt(Number(elements.deleteIndex.value), true); render(); });\n  elements.btnChangeKey.addEventListener('click', function(){\n    opChangeKey(Number(elements.changeIndex.value), Number(elements.changeValue.value), true);\n    render();\n  });\n\n  elements.btnLoadArray.addEventListener('click', function(){\n    const csv = elements.buildArray.value.trim();\n    const parts = csv.split(',').map(s=> s.trim()).filter(s=> s.length>0);\n    state.arr = parts.map(p=> Number(p)).filter(n=> !isNaN(n));\n    state.compCount = 0;\n    state.swapCount = 0;\n    saveSnapshot(\"load array\");\n    render();\n  });\n\n  elements.btnBuildHeap.addEventListener('click', function(){\n    opBuildHeapImmediate();\n  });\n\n  elements.btnGenerateSteps.addEventListener('click', function(){\n    const csv = elements.buildArray.value.trim();\n    const parts = csv.split(',').map(s=> s.trim()).filter(s=> s.length>0);\n    const arrInput = parts.map(p=> Number(p)).filter(n=> !isNaN(n));\n    generateHeapifyDetailed(arrInput);\n    render();\n  });\n\n  elements.stepBack.addEventListener('click', function(){\n    if(currentStep > 0) restoreSnapshot(currentStep - 1);\n  });\n\n  elements.stepForward.addEventListener('click', function(){\n    if(currentStep < history.length - 1) restoreSnapshot(currentStep + 1);\n  });\n\n  elements.autoPlay.addEventListener('change', function(){\n    if(elements.autoPlay.checked) startAutoPlay();\n    else stopAutoPlay();\n  });\n\n  elements.speed.addEventListener('input', function(){\n    elements.speedLabel.textContent = elements.speed.value;\n    if(autoTimer) { startAutoPlay(); }\n  });\n\n  elements.btnStopAuto.addEventListener('click', function(){ stopAutoPlay(); });\n\n  elements.btnHeapSortAsc.addEventListener('click', function(){\n    generateHeapSortDetailed(false);\n    render();\n  });\n  elements.btnHeapSortDesc.addEventListener('click', function(){\n    generateHeapSortDetailed(true);\n    render();\n  });\n\n  elements.comparatorMode.addEventListener('change', function(){\n    state.comparatorMode = elements.comparatorMode.value;\n  });\n  elements.indexingMode.addEventListener('change', function(){\n    state.indexingBase = Number(elements.indexingMode.value);\n  });\n  elements.btnRebuildOnMode.addEventListener('click', function(){\n    // Rebuild current data into heap with new comparator\n    opBuildHeapImmediate();\n  });\n\n  elements.btnRandomize.addEventListener('click', function(){\n    randomize(Number(elements.randSize.value));\n  });\n\n  elements.btnValidate.addEventListener('click', function(){\n    const ok = validateHeap();\n    alert(ok ? \"Heap property holds\" : \"Heap property violated\");\n  });\n\n  elements.btnReset.addEventListener('click', function(){\n    state.arr = [];\n    state.compCount = 0;\n    state.swapCount = 0;\n    history = [];\n    currentStep = -1;\n    saveSnapshot(\"reset\");\n    render();\n  });\n\n  elements.btnExport.addEventListener('click', function(){ exportJSON(); });\n  elements.btnImport.addEventListener('click', function(){ importJSON(); });\n\n  elements.btnUndo.addEventListener('click', function(){ undo(); });\n  elements.btnRedo.addEventListener('click', function(){ redo(); });\n\n  elements.btnJump.addEventListener('click', function(){ jumpTo(Number(elements.jumpStep.value)); });\n  elements.btnSaveSnapshot.addEventListener('click', function(){\n    saveSnapshot(elements.snapshotDesc.value || \"(manual snapshot)\");\n    render();\n  });\n\n  // Additional convenience: clicking array view copies array to load field\n  elements.arrayArea.addEventListener('click', function(){\n    elements.buildArray.value = state.arr.join(',');\n  });\n\n  // Initialize with empty snapshot\n  saveSnapshot(\"initial empty\");\n  render();\n\n  // Provide keyboard shortcuts for navigation and operations (basic)\n  window.addEventListener('keydown', function(e){\n    if(e.key === 'ArrowRight'){\n      if(currentStep < history.length - 1) restoreSnapshot(currentStep + 1);\n    } else if(e.key === 'ArrowLeft'){\n      if(currentStep > 0) restoreSnapshot(currentStep - 1);\n    } else if(e.key === 'u' && (e.ctrlKey || e.metaKey)){\n      undo();\n    } else if(e.key === 'r' && (e.ctrlKey || e.metaKey)){\n      redo();\n    }\n  });\n\n  // Enhance rendering to indicate special snapshot highlights if present\n  // Monkey-patch updateHistoryInfo to show specials in visualization\n  function renderSpecialSnapshotView(){\n    if(currentStep < 0 || currentStep >= history.length) return;\n    const snap = history[currentStep];\n    if(!snap) return;\n    const special = snap.special;\n    // default rendering done\n    render();\n    if(special && elements.viewMode.value !== 'array'){ /* tree view still shows array; we will annotate log */}\n    // Show highlight info in array area in a minimal way: append markers\n    if(special && elements.highlightMode.value === 'indices'){\n      // annotate indices in array text with parentheses or braces\n      const base = state.indexingBase;\n      const arr = snap.arr;\n      let text = \"\";\n      for(let i=0;i<arr.length;i++){\n        const idx = i + base;\n        let entry = \"[\"+idx+\"]:\"+arr[i];\n        if(special.indices && special.indices.indexOf(i) !== -1){\n          if(special.type === 'compare') entry = \"(\" + entry + \")\";\n          else if(special.type === 'swap') entry = \"{\" + entry + \"}\";\n          else entry = \"[\" + entry + \"]\";\n        }\n        text += entry + \"  \";\n      }\n      elements.arrayArea.textContent = text;\n    }\n    // Also append special description to log area top\n    if(special){\n      elements.logArea.textContent = \">> \" + (snap.desc || '') + \"\\n\" + elements.logArea.textContent;\n    }\n  }\n\n  // Override restoreSnapshot to call renderSpecialSnapshotView after regular rendering\n  const origRestore = restoreSnapshot;\n  restoreSnapshot = function(idx){\n    origRestore(idx);\n    renderSpecialSnapshotView();\n  };\n\n  // Also call renderSpecialSnapshotView after saveSnapshot operations\n  const origSave = saveSnapshot;\n  saveSnapshot = function(desc, special){\n    origSave(desc, special);\n    renderSpecialSnapshotView();\n  };\n\n  // Final initial render special\n  renderSpecialSnapshotView();\n\n})();\n</script>\n\n</body>\n</html>"
