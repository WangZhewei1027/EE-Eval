    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>K-Means Clustering — Visualized Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Reset & base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0; padding: 0;\n    height: 100vh;\n    background: linear-gradient(135deg, #2c3e50 0%, #4ca1af 100%);\n    font-family: 'Poppins', sans-serif;\n    color: #f0f4f8;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    user-select: none;\n    overflow: hidden;\n  }\n  h1 {\n    margin-top: 1.5rem;\n    font-weight: 600;\n    font-size: 2.75rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    text-align: center;\n    color: #e1e8f0;\n    text-shadow:\n      0 0 8px rgba(255 255 255 / 0.25),\n      0 8px 30px rgba(58 188 212 / 0.6);\n  }\n  p.subtitle {\n    margin: 0.25rem 0 1.75rem;\n    font-weight: 300;\n    font-size: 1.1rem;\n    color: #dce6f1cc;\n    max-width: 520px;\n    text-align: center;\n    letter-spacing: 0.05em;\n    font-style: italic;\n    user-select: none;\n  }\n\n  #canvas-container {\n    position: relative;\n    width: 90vmin;\n    height: 90vmin;\n    max-width: 700px;\n    max-height: 700px;\n    border-radius: 1.25rem;\n    background:\n      radial-gradient(circle at center, #1c2a36 40%, #16232c 98%);\n    box-shadow:\n      inset 0 0 80px #144559aa,\n      0 30px 60px -15px rgba(15 88 122 / 0.5),\n      0 15px 30px -15px rgba(10 61 90 / 0.3);\n    overflow: hidden;\n  }\n  canvas {\n    width: 100%;\n    height: 100%;\n    display: block;\n    border-radius: 1.25rem;\n  }\n\n  /* Controls container */\n  #controls {\n    margin: 1.5rem 0 3rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.25rem;\n  }\n  \n  button {\n    background: linear-gradient(135deg, #26a0da, #314755);\n    border: none;\n    border-radius: 30px;\n    padding: 0.75rem 2.25rem;\n    font-size: 1.15rem;\n    font-weight: 600;\n    color: #d2e6f2;\n    letter-spacing: 0.04em;\n    cursor: pointer;\n    box-shadow:\n      0 3px 10px #21a7e0cc,\n      0 0 8px 1.5px #27b0f2cc;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.2s ease;\n    user-select: none;\n  }\n  button:hover,\n  button:focus {\n    background: linear-gradient(135deg, #3196ff, #3f6171);\n    box-shadow:\n      0 5px 20px #3cb1ffdd,\n      0 0 12px 2px #51baffdd;\n    transform: translateY(-3px);\n    outline: none;\n  }\n\n  button:active {\n    transform: translateY(0);\n    box-shadow:\n      0 2px 7px #2498d1cc,\n      0 0 6px 1px #279ddacc;\n  }\n\n  /* Legend style */\n  #legend {\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n    margin-bottom: 3.25rem;\n    user-select: none;\n  }\n\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 0.75rem;\n    font-weight: 600;\n    font-size: 1rem;\n    color: #cde4f4cc;\n    letter-spacing: 0.05em;\n  }\n  .legend-color {\n    width: 20px;\n    height: 20px;\n    border-radius: 50%;\n    box-shadow: 0 0 10px 1.5px;\n  }\n  .centroid-legend {\n    border: 2.5px solid #fff;\n    box-shadow:\n      0 0 14px 2.7px #f3f9ffdd,\n      0 0 14px 7px #2ca6e0cc;\n  }\n\n  /* Animated subtle stars background */\n  #stars {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    z-index: 0;\n  }\n</style>\n</head>\n<body>\n\n<h1>K-MEANS<br>CLUSTERING</h1>\n<p class=\"subtitle\">Visualizing iterative classification of data points with elegant clusters</p>\n\n<section id=\"canvas-container\" aria-label=\"K-Means Clustering Visualization\">\n  <canvas id=\"kmeansCanvas\" width=\"700\" height=\"700\"></canvas>\n  <canvas id=\"stars\" width=\"700\" height=\"700\" aria-hidden=\"true\"></canvas>\n</section>\n\n<div id=\"legend\" aria-label=\"Color Legend\">\n  <div class=\"legend-item\"><div class=\"legend-color\" style=\"background:#e27d60;\"></div> Cluster 1</div>\n  <div class=\"legend-item\"><div class=\"legend-color\" style=\"background:#85dcb6;\"></div> Cluster 2</div>\n  <div class=\"legend-item\"><div class=\"legend-color\" style=\"background:#fcab64;\"></div> Cluster 3</div>\n  <div class=\"legend-item\"><div class=\"legend-color centroid-legend\" style=\"background:#ffffff;\"></div> Centroids</div>\n</div>\n\n<div id=\"controls\" role=\"region\" aria-label=\"Controls\">\n  <button id=\"simulateBtn\" aria-pressed=\"false\" aria-label=\"Start or pause clustering simulation\">Start Simulation</button>\n  <button id=\"resetBtn\" aria-label=\"Reset clustering visualization\">Reset</button>\n</div>\n\n<script>\n(() => {\n  // Canvas & contexts\n  const container = document.getElementById('canvas-container');\n  const canvas = document.getElementById('kmeansCanvas');\n  const ctx = canvas.getContext('2d');\n  const starsCanvas = document.getElementById('stars');\n  const starsCtx = starsCanvas.getContext('2d');\n\n  // Dimensions\n  const WIDTH = canvas.width;\n  const HEIGHT = canvas.height;\n\n  // Styles and colors for clusters\n  const clusterColors = [\n    '#e27d60', // coral red-ish\n    '#85dcb6', // pastel teal\n    '#fcab64', // warm orange\n  ];\n  const centroidColor = '#ffffff';\n\n  // Data points and centroids\n  // Generate 150 points in a smooth random distributed cluster-like way\n  const NUM_POINTS = 150;\n  const K = 3;\n\n  // Points will be in form: {x, y, clusterIndex}\n  let points = [];\n\n  // Centroids will be in form {x,y}\n  let centroids = [];\n\n  // Assign initial centroids randomly selected from points\n  function initializeCentroids() {\n    const chosenIndices = new Set();\n    while(chosenIndices.size < K) {\n      chosenIndices.add(Math.floor(Math.random() * points.length));\n    }\n    centroids = Array.from(chosenIndices).map(i => ({x: points[i].x, y: points[i].y}));\n  }\n  \n  // Initialize points spread around 3 clusters for visual allure\n  function generatePoints() {\n    points = [];\n    // Use Gaussian clusters with centers and radii chosen for best visual effect\n    // Cluster centers (x,y) roughly spaced well\n    const centers = [\n      {x: WIDTH * 0.28, y: HEIGHT * 0.33},\n      {x: WIDTH * 0.65, y: HEIGHT * 0.45},\n      {x: WIDTH * 0.45, y: HEIGHT * 0.75},\n    ];\n    const radius = WIDTH * 0.1;\n\n    function gaussianRandom(mean = 0, stdev = 1) {\n      // using Box-Muller Transform\n      let u = 0, v = 0;\n      while(u === 0) u = Math.random(); // Converting [0,1) to (0,1)\n      while(v === 0) v = Math.random();\n      let num = Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);\n      return num * stdev + mean;\n    }\n\n    const pointsPerCluster = Math.floor(NUM_POINTS / K);\n    for(let i=0; i<K; i++) {\n      for(let j=0; j<pointsPerCluster; j++) {\n        // Generate points with gaussian around the center\n        let x = centers[i].x + gaussianRandom(0, radius * 0.35);\n        let y = centers[i].y + gaussianRandom(0, radius * 0.35);\n        // Clamp inside boundaries with nice padding\n        x = Math.min(WIDTH - 20, Math.max(20, x));\n        y = Math.min(HEIGHT - 20, Math.max(20, y));\n        points.push({x, y, cluster: -1});\n      }\n    }\n\n    // If NUM_POINTS isn't divisible by K, add remaining points randomly but near centered clusters\n    for(let i=points.length; i < NUM_POINTS; i++) {\n      const c = Math.floor(Math.random() * K);\n      let x = centers[c].x + gaussianRandom(0, radius * 0.4);\n      let y = centers[c].y + gaussianRandom(0, radius * 0.4);\n      x = Math.min(WIDTH - 20, Math.max(20, x));\n      y = Math.min(HEIGHT - 20, Math.max(20, y));\n      points.push({x, y, cluster: -1});\n    }\n  }\n\n\n  // Assign points to closest centroid\n  function assignClusters() {\n    let changed = false;\n    points.forEach(p => {\n      let minDistSq = Infinity;\n      let assignedCluster = -1;\n      centroids.forEach((cent, idx) => {\n        let dx = p.x - cent.x;\n        let dy = p.y - cent.y;\n        let distSq = dx*dx + dy*dy;\n        if(distSq < minDistSq) {\n          minDistSq = distSq;\n          assignedCluster = idx;\n        }\n      });\n      if(p.cluster !== assignedCluster) changed = true;\n      p.cluster = assignedCluster;\n    });\n    return changed;\n  }\n\n  // Move centroids towards mean of assigned points\n  function updateCentroids() {\n    let moved = false;\n    for(let i=0; i<K; i++){\n      const assignedPoints = points.filter(p => p.cluster === i);\n      if(assignedPoints.length === 0) continue; // avoid division by zero\n      const meanX = assignedPoints.reduce((acc,p) => acc + p.x, 0) / assignedPoints.length;\n      const meanY = assignedPoints.reduce((acc,p) => acc + p.y, 0) / assignedPoints.length;\n      // Smooth transition toward mean for aesthetics\n      let cx = centroids[i].x;\n      let cy = centroids[i].y;\n      const ease = 0.08;\n      const newX = cx + (meanX - cx) * ease;\n      const newY = cy + (meanY - cy) * ease;\n      if(Math.abs(newX - cx) > 0.1 || Math.abs(newY - cy) > 0.1) moved = true;\n      centroids[i].x = newX;\n      centroids[i].y = newY;\n    }\n    return moved;\n  }\n\n  // Draw points and centroids on canvas\n  function draw() {\n    // Clear canvas with slight transparent fill to create smooth motion trails\n    ctx.clearRect(0, 0, WIDTH, HEIGHT);\n\n    // Draw cluster backgrounds (subtle blurred glows)\n    centroids.forEach((cent, i) => {\n      let gradient = ctx.createRadialGradient(cent.x, cent.y, 10, cent.x, cent.y, 120);\n      gradient.addColorStop(0, clusterColors[i] + 'bb');\n      gradient.addColorStop(1, clusterColors[i] + '10');\n      ctx.fillStyle = gradient;\n      ctx.beginPath();\n      ctx.ellipse(cent.x, cent.y + 10, 120, 80, Math.sin(Date.now()/3000 + i)*0.3, 0, 2 * Math.PI);\n      ctx.fill();\n    });\n\n    // Draw points softly glowing colored by cluster\n    points.forEach(p => {\n      const color = p.cluster !== -1 ? clusterColors[p.cluster] : '#77777788';\n      // Subtle glow effect with shadowBlur\n      ctx.shadowColor = color;\n      ctx.shadowBlur = 10;\n      ctx.fillStyle = color;\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, 5, 0, 2 * Math.PI);\n      ctx.fill();\n\n      // Inner bright dot for crispness\n      ctx.shadowBlur = 0;\n      ctx.fillStyle = '#f0f5f9ee';\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, 2, 0, 2 * Math.PI);\n      ctx.fill();\n    });\n\n    // Draw centroid markers\n    centroids.forEach((cent, i) => {\n      // Outer glowing halo\n      ctx.shadowColor = '#eef9ffcc';\n      ctx.shadowBlur = 18;\n      ctx.fillStyle = centroidColor;\n      ctx.beginPath();\n      ctx.arc(cent.x, cent.y, 11, 0, 2 * Math.PI);\n      ctx.fill();\n\n      // Inner solid circle with stroke\n      ctx.shadowBlur = 0;\n      ctx.fillStyle = centroidColor;\n      ctx.beginPath();\n      ctx.arc(cent.x, cent.y, 7, 0, 2 * Math.PI);\n      ctx.fill();\n\n      ctx.lineWidth = 2.5;\n      ctx.strokeStyle = clusterColors[i];\n      ctx.stroke();\n    });\n  }\n\n  // MAIN iterative simulation using requestAnimationFrame\n  let running = false;\n  let animationId = null;\n\n  function step() {\n    // 1) Assign clusters\n    assignClusters();\n    // 2) Move centroids smoothly toward cluster means\n    updateCentroids();\n    draw();\n\n    if(running) {\n      animationId = requestAnimationFrame(step);\n    }\n  }\n\n  // INTERACTIVITY: start/pause & reset\n  const simulateBtn = document.getElementById('simulateBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  simulateBtn.addEventListener('click', () => {\n    running = !running;\n    if(running){\n      simulateBtn.textContent = 'Pause Simulation';\n      simulateBtn.setAttribute('aria-pressed', 'true');\n      step();\n    } else {\n      simulateBtn.textContent = 'Start Simulation';\n      simulateBtn.setAttribute('aria-pressed', 'false');\n      if(animationId) cancelAnimationFrame(animationId);\n    }\n  });\n\n  resetBtn.addEventListener('click', () => {\n    running = false;\n    simulateBtn.textContent = 'Start Simulation';\n    simulateBtn.setAttribute('aria-pressed', 'false');\n    if(animationId) cancelAnimationFrame(animationId);\n\n    generatePoints();\n    initializeCentroids();\n    draw();\n  });\n\n  // Starfield subtle background animation behind main canvas\n\n  class Star {\n    constructor(width, height){\n      this.width = width;\n      this.height = height;\n      this.reset();\n    }\n    reset(){\n      this.x = Math.random() * this.width;\n      this.y = Math.random() * this.height;\n      this.radius = Math.random() * 1.2 + 0.2;\n      this.alpha = Math.random() * 0.5 + 0.3;\n      this.alphaChange = (Math.random() * 0.002 + 0.001) * (Math.random() > 0.5 ? 1 : -1);\n    }\n    update(){\n      this.alpha += this.alphaChange;\n      if(this.alpha > 0.8 || this.alpha < 0.3){\n        this.alphaChange = -this.alphaChange;\n      }\n    }\n    draw(ctx) {\n      ctx.beginPath();\n      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);\n      ctx.fillStyle = `rgba(255,255,255,${this.alpha})`;\n      ctx.shadowColor = 'rgba(255, 255, 255, 0.7)';\n      ctx.shadowBlur = this.radius * 4;\n      ctx.fill();\n    }\n  }\n\n  // Create stars\n  let stars = [];\n  const NUM_STARS = 120;\n  function createStars() {\n    stars = [];\n    for(let i=0; i<NUM_STARS; i++){\n      stars.push(new Star(WIDTH, HEIGHT));\n    }\n  }\n\n  function animateStars() {\n    starsCtx.clearRect(0, 0, WIDTH, HEIGHT);\n    stars.forEach(star => {\n      star.update();\n      star.draw(starsCtx);\n    });\n    requestAnimationFrame(animateStars);\n  }\n\n\n  // INIT\n\n  // Setup retina scaling for crispness\n  function fixDPI() {\n    let dpi = window.devicePixelRatio || 1;\n    [canvas, starsCanvas].forEach(canv => {\n      let style_height = +getComputedStyle(canv).getPropertyValue(\"height\").slice(0,-2);\n      let style_width = +getComputedStyle(canv).getPropertyValue(\"width\").slice(0,-2);\n      canv.width = style_width * dpi;\n      canv.height = style_height * dpi;\n      const context = canv.getContext('2d');\n      context.scale(dpi, dpi);\n    });\n  }\n  fixDPI();\n\n  generatePoints();\n  initializeCentroids();\n  draw();\n  createStars();\n  animateStars();\n\n  // Resize Handling - keep canvases sharp and sized\n  window.addEventListener('resize', () => {\n    fixDPI();\n    draw();\n  });\n})();\n</script>\n\n</body>\n</html>"
