    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Heap Sort Visualization — Elegant Algorithm Art</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600&display=swap');\n\n  /* Root & Reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #232526, #1c1c1c);\n    color: #f0f0f7;\n    font-family: 'Montserrat', sans-serif;\n    overflow-x: hidden;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: start;\n    padding: 2rem 1rem 4rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 2.75rem;\n    letter-spacing: 0.15em;\n    margin-bottom: 0.1em;\n    color: #e0e8ff;\n    text-shadow:\n      0 0 8px #5060ff88,\n      0 0 20px #3f4cffcc,\n      0 0 30px #3049d6cc;\n  }\n  h2 {\n    margin: 0 0 2rem 0;\n    font-weight: 300;\n    font-size: 1.125rem;\n    color: #bbc9ffcc;\n    letter-spacing: 0.06em;\n  }\n\n  /* Container for heap & array */\n  #visualizer {\n    position: relative;\n    width: 100%;\n    max-width: 900px;\n    min-height: 420px;\n    margin: 0 auto 2.5rem auto;\n    background: linear-gradient(145deg, #1e2233, #151820);\n    border-radius: 2rem;\n    box-shadow:\n      inset 0 0 60px 2px #3f4cff88,\n      0 12px 30px rgba(56, 80, 255, 0.3);\n    padding: 2rem 3rem 3rem 3rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    user-select: none;\n  }\n\n  /* Heap Binary Tree Canvas (SVG) */\n  svg#heapTree {\n    width: 100%;\n    max-width: 900px;\n    height: 280px;\n    overflow: visible;\n    filter: drop-shadow(0 0 6px #4a5affcc);\n  }\n\n  /* Nodes styling */\n  circle.node {\n    fill: #3b46e6;\n    filter:\n      drop-shadow(0 0 3px #7189ffcc);\n    transition: fill 0.4s ease, transform 0.5s ease;\n    cursor: default;\n  }\n  circle.node.highlighted {\n    fill: #ffc857;\n    filter:\n      drop-shadow(0 0 15px #ffc857dd);\n    transform: scale(1.2);\n    transition: fill 0.3s ease, transform 0.3s ease;\n    z-index: 10;\n  }\n\n  text.node-label {\n    fill: #e0e8ffee;\n    font-weight: 600;\n    font-size: 1.1rem;\n    text-shadow:\n      0 0 2px #203dbfdd;\n    pointer-events: none;\n    user-select: none;\n    transition: fill 0.3s ease;\n  }\n  text.node-label.highlighted {\n    fill: #301a00ee;\n    filter: drop-shadow(0 0 6px #f9c346cc);\n  }\n\n  /* Edges styling */\n  line.edge {\n    stroke: #6789ffcc;\n    stroke-width: 3px;\n    filter: drop-shadow(0 0 2px #3f4cffaa);\n    transition: stroke 0.4s ease;\n  }\n  line.edge.highlighted {\n    stroke: #ffc857;\n    stroke-width: 5px;\n    filter: drop-shadow(0 0 12px #ffc857bb);\n    transition: stroke 0.3s ease;\n  }\n\n  /* Array display */\n  #arrayContainer {\n    margin-top: 1.8rem;\n    width: 100%;\n    max-width: 900px;\n    display: flex;\n    justify-content: center;\n    gap: 0.9rem;\n    flex-wrap: wrap;\n    user-select: none;\n  }\n\n  .array-bar {\n    background: linear-gradient(145deg, #5562f0, #414df0);\n    width: 36px;\n    height: 80px;\n    border-radius: 0.7rem;\n    box-shadow:\n      inset 0 0 6px #2933bfcc,\n      0 6px 8px rgba(87, 97, 252, 0.8);\n    font-weight: 700;\n    font-size: 1.05rem;\n    color: #e0e8ffdd;\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n    padding-bottom: 0.7rem;\n    position: relative;\n    transition:\n      background 0.35s ease,\n      box-shadow 0.35s ease,\n      height 0.7s cubic-bezier(0.4,0,0.2,1),\n      transform 0.5s ease;\n    cursor: default;\n  }\n  .array-bar.highlighted {\n    background: linear-gradient(145deg, #ffbf56, #ffb33e);\n    box-shadow:\n      inset 0 0 14px #e67e22cc,\n      0 10px 12px #f0911fbb;\n    color: #301a00ee;\n    height: 96px;\n    transform: scale(1.05);\n    transition:\n      background 0.3s ease,\n      box-shadow 0.3s ease,\n      height 0.6s ease,\n      transform 0.4s ease;\n    z-index: 10;\n  }\n  .array-bar::after {\n    content: attr(data-index);\n    position: absolute;\n    bottom: -22px;\n    font-size: 0.7rem;\n    color: #9abaffcc;\n    font-weight: 400;\n    letter-spacing: 0.04em;\n  }\n\n  /* Controls Panel */\n  #controls {\n    width: 100%;\n    max-width: 900px;\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n  }\n  button.control-btn {\n    border: none;\n    border-radius: 2rem;\n    padding: 0.6rem 2.4rem;\n    font-size: 1.1rem;\n    font-weight: 600;\n    font-family: 'Montserrat', sans-serif;\n    background: linear-gradient(145deg, #3f4cff, #5364f5);\n    color: #e0e8ff;\n    cursor: pointer;\n    box-shadow:\n      0 4px 8px rgba(80, 96, 255, 0.6);\n    transition: background 0.3s ease, box-shadow 0.3s ease, transform 0.15s ease;\n    user-select: none;\n  }\n  button.control-btn:active {\n    transform: scale(0.95);\n  }\n  button.control-btn:disabled {\n    background: #27308b;\n    box-shadow: none;\n    cursor: default;\n    color: #9abaffaa;\n  }\n\n  /* Footer Text */\n  footer {\n    margin-top: 3rem;\n    font-weight: 300;\n    font-size: 0.9rem;\n    color: #7986ffb2;\n    letter-spacing: 0.1em;\n  }\n\n  /* Tooltip for nodes */\n  .tooltip {\n    position: absolute;\n    pointer-events: none;\n    background: #3546a3cc;\n    color: #e0e8ffdd;\n    padding: 0.3rem 0.7rem;\n    border-radius: 0.5rem;\n    font-weight: 500;\n    font-size: 0.9rem;\n    white-space: nowrap;\n    text-shadow: 0 0 5px #283ec8aa;\n    user-select: none;\n    opacity: 0;\n    transition: opacity 0.25s ease;\n    z-index: 50;\n  }\n  .tooltip.visible {\n    opacity: 1;\n  }\n</style>\n</head>\n<body>\n\n<h1>HEAP SORT</h1>\n<h2>An elegant in-place comparison sorting algorithm</h2>\n\n<div id=\"visualizer\" aria-label=\"Heap Sort Visualization\">\n  <svg id=\"heapTree\" aria-hidden=\"true\" focusable=\"false\"></svg>\n  <div id=\"arrayContainer\" aria-label=\"Array elements visualization\"></div>\n</div>\n\n<div id=\"controls\" aria-label=\"Heap Sort Controls\">\n  <button id=\"startBtn\" class=\"control-btn\" aria-pressed=\"false\" aria-label=\"Start Heap Sort Animation\">Start</button>\n  <button id=\"resetBtn\" class=\"control-btn\" aria-label=\"Reset Visualization\">Reset</button>\n</div>\n\n<footer>Visualizing data structure meets art &amp; science — &copy; 2024</footer>\n\n<script>\n(() => {\n  const svgNS = \"http://www.w3.org/2000/svg\";\n\n  // Data Initialization\n  let array = [];\n  const maxElements = 15;\n  const minValue = 10;\n  const maxValue = 99;\n\n  // Visual & DOM Elements\n  const heapTreeSVG = document.getElementById('heapTree');\n  const arrayContainer = document.getElementById('arrayContainer');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Animation & State\n  let animations = [];\n  let animationIndex = 0;\n  let animationRunning = false;\n\n  // Visual parameters for tree layout\n  const levelHeight = 70;\n  const nodeRadius = 22;\n  const svgWidth = 900;  // match CSS max-width approx\n  const marginX = 60;\n\n  // Tooltip for nodes\n  const tooltip = document.createElement('div');\n  tooltip.className = 'tooltip';\n  document.body.appendChild(tooltip);\n\n  // Generate a random array with unique values between min and max\n  function generateRandomArray(size, min, max) {\n    const set = new Set();\n    while (set.size < size) {\n      set.add(Math.floor(Math.random() * (max - min + 1)) + min);\n    }\n    return Array.from(set);\n  }\n\n  // Clear the SVG\n  function clearSVG() {\n    while (heapTreeSVG.firstChild) {\n      heapTreeSVG.removeChild(heapTreeSVG.firstChild);\n    }\n  }\n\n  // Positions of nodes in SVG for given index\n  function getNodePosition(i, n = array.length) {\n    if(i < 0 || i >= n) return {x: 0, y: 0};\n    const level = Math.floor(Math.log2(i + 1));\n    const maxNodesAtLevel = 2 ** level;\n    const indexAtLevel = i + 1 - maxNodesAtLevel;\n\n    const levelWidth = svgWidth - 2 * marginX;\n    const spacing = levelWidth / maxNodesAtLevel;\n    const x = marginX + spacing * (indexAtLevel + 0.5);\n    const y = levelHeight * level + nodeRadius + 8;\n    return {x, y};\n  }\n\n  // Draw edges of the binary heap tree\n  function drawEdges() {\n    clearEdges();\n    for(let i = 0; i < array.length; i++) {\n      const leftChild = 2 * i + 1;\n      const rightChild = 2 * i + 2;\n      const posParent = getNodePosition(i);\n      if(leftChild < array.length) {\n        const posLeft = getNodePosition(leftChild);\n        drawEdge(posParent, posLeft, i, leftChild);\n      }\n      if(rightChild < array.length) {\n        const posRight = getNodePosition(rightChild);\n        drawEdge(posParent, posRight, i, rightChild);\n      }\n    }\n  }\n\n  // Draw an edge line between two points with data attributes\n  function drawEdge(p1, p2, parentIdx, childIdx) {\n    const line = document.createElementNS(svgNS, 'line');\n    line.setAttribute('x1', p1.x);\n    line.setAttribute('y1', p1.y);\n    line.setAttribute('x2', p2.x);\n    line.setAttribute('y2', p2.y);\n    line.classList.add('edge');\n    line.dataset.parent = parentIdx;\n    line.dataset.child = childIdx;\n    heapTreeSVG.appendChild(line);\n  }\n\n  // Clear only edges\n  function clearEdges() {\n    [...heapTreeSVG.querySelectorAll('line.edge')].forEach(e => e.remove());\n  }\n\n  // Draw nodes circles and their labels\n  function drawNodes() {\n    clearCircles();\n    for(let i=0; i<array.length; i++) {\n      const {x, y} = getNodePosition(i);\n      // circle\n      const circle = document.createElementNS(svgNS, 'circle');\n      circle.setAttribute('cx', x);\n      circle.setAttribute('cy', y);\n      circle.setAttribute('r', nodeRadius);\n      circle.classList.add('node');\n      circle.dataset.index = i;\n      circle.dataset.value = array[i];\n      // label\n      const label = document.createElementNS(svgNS, 'text');\n      label.setAttribute('x', x);\n      label.setAttribute('y', y + 6);\n      label.setAttribute('text-anchor', 'middle');\n      label.classList.add('node-label');\n      label.textContent = array[i];\n      label.dataset.index = i;\n\n      heapTreeSVG.appendChild(circle);\n      heapTreeSVG.appendChild(label);\n    }\n  }\n\n  // Clear only nodes\n  function clearCircles() {\n    [...heapTreeSVG.querySelectorAll('circle.node, text.node-label')].forEach(e => e.remove());\n  }\n\n  // Draw the entire tree anew\n  function drawTree() {\n    clearSVG();\n    drawEdges();\n    drawNodes();\n  }\n\n  // Draw array bars below the tree\n  function drawArray() {\n    arrayContainer.innerHTML = '';\n    array.forEach((v, i) => {\n      const bar = document.createElement('div');\n      bar.classList.add('array-bar');\n      bar.style.height = `${v * 1.4 + 12}px`; // scaled height\n      bar.textContent = v;\n      bar.dataset.index = i;\n      arrayContainer.appendChild(bar);\n    });\n  }\n\n  // Highlight node and corresponding array bar\n  function highlight(index, type = 'heap') {\n    clearHighlights();\n    if(index == null) return;\n    if(type === 'heap') {\n      const circles = heapTreeSVG.querySelectorAll('circle.node');\n      const labels = heapTreeSVG.querySelectorAll('text.node-label');\n      const nodeCircle = [...circles].find(c => +c.dataset.index === index);\n      const nodeLabel = [...labels].find(l => +l.dataset.index === index);\n      if(nodeCircle) nodeCircle.classList.add('highlighted');\n      if(nodeLabel) nodeLabel.classList.add('highlighted');\n    }\n    if(type === 'array') {\n      const bars = arrayContainer.querySelectorAll('.array-bar');\n      if(bars[index]) bars[index].classList.add('highlighted');\n    }\n  }\n  // Clear all highlights\n  function clearHighlights() {\n    heapTreeSVG.querySelectorAll('.highlighted').forEach(el => el.classList.remove('highlighted'));\n    arrayContainer.querySelectorAll('.highlighted').forEach(el => el.classList.remove('highlighted'));\n  }\n\n  // Show a smooth swap animation between two nodes and bars\n  function swap(index1, index2) {\n    // Swap in data representation\n    [array[index1], array[index2]] = [array[index2], array[index1]];\n\n    // Animate array bars\n    const bars = arrayContainer.querySelectorAll('.array-bar');\n    const bar1 = bars[index1];\n    const bar2 = bars[index2];\n\n    // Animate tree nodes and edge labels on next redraw\n  }\n\n  // Heap Sort Algorithm with step recording (Heapify, Swap, etc)\n  // Generate a sequence of animation steps to play\n\n  // Animation step types:\n  // 'highlight' : {indices: [i,j,...], type: 'heap'|'array'}\n  // 'swap'      : {indices: [i,j]}\n  // 'unhighlight' : no data\n\n  function heapSortSteps(arr) {\n    const steps = [];\n    const n = arr.length;\n    const arrayCopy = arr.slice();\n\n    function swapInArr(i, j) {\n      [arrayCopy[i], arrayCopy[j]] = [arrayCopy[j], arrayCopy[i]];\n      steps.push({action: 'swap', indices:[i,j]});\n    }\n\n    // maxHeapify downwards from i to n\n    function heapify(n, i) {\n      let largest = i;\n      let l = 2 * i + 1;\n      let r = 2 * i + 2;\n\n      steps.push({action:'highlight', indices:[i], type:'heap'});\n      if(l < n) steps.push({action:'highlight', indices:[l], type:'heap'});\n      if(r < n) steps.push({action:'highlight', indices:[r], type:'heap'});\n\n      if(l < n && arrayCopy[l] > arrayCopy[largest]) largest = l;\n      if(r < n && arrayCopy[r] > arrayCopy[largest]) largest = r;\n      \n      if(largest !== i) {\n        swapInArr(i, largest);\n        steps.push({action:'unhighlight'});\n        heapify(n, largest);\n      } else {\n        steps.push({action:'unhighlight'});\n      }\n    }\n\n    // Build max heap\n    for(let i = Math.floor(n/2) -1; i >= 0; i--) {\n      heapify(n, i);\n    }\n\n    // Heap sort extraction\n    for(let end = n -1; end > 0; end--) {\n      steps.push({action:'highlight', indices:[0, end], type:'array'});\n      swapInArr(0, end);\n      steps.push({action:'unhighlight'});\n      heapify(end, 0);\n    }\n    return steps;\n  }\n\n  // Animate steps sequentially\n  let animDelay = 700; // milliseconds per step\n  async function playAnimations(steps) {\n    animationRunning = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n    for(animationIndex=0; animationIndex<steps.length; animationIndex++) {\n      const step = steps[animationIndex];\n      if(step.action === 'highlight') {\n        clearHighlights();\n        step.indices.forEach(i => highlight(i, step.type));\n      } else if(step.action === 'swap') {\n        clearHighlights();\n        const [i, j] = step.indices;\n        highlight(i, 'array');\n        highlight(j, 'array');\n        highlight(i, 'heap');\n        highlight(j, 'heap');\n\n        // Swap elements visually in the array bars\n        await animateSwap(i, j);\n        // Swap data and redraw tree & array\n        [array[i], array[j]] = [array[j], array[i]];\n        drawTree();\n        drawArray();\n      } else if(step.action === 'unhighlight') {\n        clearHighlights();\n      }\n      await sleep(animDelay * 0.85);\n    }\n    clearHighlights();\n    animationRunning = false;\n    startBtn.disabled = false;\n    resetBtn.disabled = false;\n  }\n\n  // Sleep helper\n  function sleep(ms) {\n    return new Promise(r => setTimeout(r, ms));\n  }\n\n  // Animate swap between two array bars (translate)\n  async function animateSwap(i, j) {\n    const bars = arrayContainer.querySelectorAll('.array-bar');\n    if(!bars[i] || !bars[j]) return;\n\n    const bar1 = bars[i];\n    const bar2 = bars[j];\n\n    const rect1 = bar1.getBoundingClientRect();\n    const rect2 = bar2.getBoundingClientRect();\n\n    const deltaX = rect2.left - rect1.left;\n\n    // Animate horizontal movement by transform\n    bar1.style.transition = 'transform 0.45s cubic-bezier(0.4,0,0.2,1)';\n    bar2.style.transition = 'transform 0.45s cubic-bezier(0.4,0,0.2,1)';\n    bar1.style.zIndex = 20;\n    bar2.style.zIndex = 20;\n\n    bar1.style.transform = `translateX(${deltaX}px) scale(1.1)`;\n    bar2.style.transform = `translateX(${-deltaX}px) scale(1.1)`;\n\n    await sleep(460);\n\n    // Reset transformations for next state (new position after actual swap)\n    bar1.style.transition = '';\n    bar2.style.transition = '';\n    bar1.style.transform = '';\n    bar2.style.transform = '';\n    bar1.style.zIndex = '';\n    bar2.style.zIndex = '';\n  }\n\n  // Initialize the visualization (initial draw)\n  function initialize() {\n    array = generateRandomArray(maxElements, minValue, maxValue);\n    drawTree();\n    drawArray();\n    clearHighlights();\n    animations = [];\n    animationIndex = 0;\n    animationRunning = false;\n    startBtn.disabled = false;\n  }\n\n  // Handle Start button click\n  async function onStart() {\n    if(animationRunning) return;\n    animations = heapSortSteps(array);\n    await playAnimations(animations);\n  }\n\n  // Handle Reset button click\n  function onReset() {\n    if(animationRunning) return;\n    initialize();\n  }\n\n  // Tooltip positioning and content for heap nodes on mouseover strongest subtle interaction\n  function onNodeHover(e) {\n    if(!e.target.classList.contains('node')) return;\n    const idx = +e.target.dataset.index;\n    const val = array[idx];\n    const pos = e.target.getBoundingClientRect();\n    tooltip.textContent = `Heap Index: ${idx} | Value: ${val}`;\n    tooltip.style.left = `${pos.left + pos.width / 2}px`;\n    tooltip.style.top = `${pos.top - 34}px`;\n    tooltip.classList.add('visible');\n  }\n  function onNodeLeave() {\n    tooltip.classList.remove('visible');\n  }\n\n  // Events\n  startBtn.addEventListener('click', onStart);\n  resetBtn.addEventListener('click', onReset);\n  heapTreeSVG.addEventListener('mousemove', onNodeHover);\n  heapTreeSVG.addEventListener('mouseleave', onNodeLeave);\n\n  // Initialize on load\n  initialize();\n\n})();\n</script>\n</body>\n</html>"
