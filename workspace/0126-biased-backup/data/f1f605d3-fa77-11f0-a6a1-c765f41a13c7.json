    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Exponential Search — Visual Exploration</title>\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #071129;\n      --accent: #7cf1d1;\n      --accent-2: #8aa7ff;\n      --muted: rgba(255,255,255,0.08);\n      --glass: rgba(255,255,255,0.04);\n      --glass-2: rgba(255,255,255,0.02);\n      --card: rgba(255,255,255,0.03);\n      --success: #45d08a;\n      --danger: #ff7b88;\n      --text: rgba(255,255,255,0.94);\n      --sub: rgba(255,255,255,0.65);\n      font-synthesis: none;\n      -webkit-font-smoothing: antialiased;\n      -moz-osx-font-smoothing: grayscale;\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      background:\n        radial-gradient(800px 400px at 10% 10%, rgba(124,241,209,0.06), transparent 10%),\n        radial-gradient(500px 300px at 90% 90%, rgba(138,167,255,0.06), transparent 10%),\n        linear-gradient(180deg,var(--bg1), var(--bg2) 70%);\n      color:var(--text);\n      font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:40px;\n      box-sizing:border-box;\n    }\n\n    /* Subtle animated background blobs */\n    .bg-blob{\n      position:fixed;\n      inset:auto;\n      pointer-events:none;\n      opacity:0.08;\n      filter:blur(40px);\n      mix-blend-mode: screen;\n      z-index:0;\n    }\n    .blob1{ width:500px; height:500px; right:-120px; top:-80px; background:linear-gradient(140deg,#7cf1d1,#8aa7ff); border-radius:50%; transform:rotate(10deg); animation: drift 18s ease-in-out infinite alternate; }\n    .blob2{ width:420px; height:420px; left:-140px; bottom:-100px; background:linear-gradient(140deg,#8aa7ff,#7cf1d1); border-radius:50%; transform:rotate(-10deg); animation: drift 22s ease-in-out infinite alternate-reverse; }\n    @keyframes drift { to { transform: translateY(30px) scale(1.05) rotate(6deg); } }\n\n    .stage{\n      position:relative;\n      width:min(1200px,95vw);\n      max-width:1200px;\n      z-index:2;\n      display:grid;\n      grid-template-columns: 420px 1fr;\n      gap:28px;\n      align-items:start;\n      padding:28px;\n      border-radius:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: 0 10px 40px rgba(3,8,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(8px) saturate(120%);\n      overflow:hidden;\n    }\n\n    /* Left card - Info */\n    .panel{\n      padding:26px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.03);\n      display:flex;\n      flex-direction:column;\n      gap:14px;\n      min-height:360px;\n    }\n\n    .title{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .logo{\n      width:56px;height:56px;border-radius:12px;\n      background: linear-gradient(135deg, rgba(124,241,209,0.12), rgba(138,167,255,0.12));\n      display:flex;align-items:center;justify-content:center;\n      font-weight:700;color:var(--accent);\n      box-shadow: 0 6px 18px rgba(12,18,32,0.5), inset 0 -6px 18px rgba(255,255,255,0.02);\n      font-size:20px;\n    }\n    h1{ font-size:20px;margin:0; letter-spacing:-0.2px; color:var(--text); }\n    p.lead{ margin:0; color:var(--sub); font-size:13px; line-height:1.45; }\n\n    .meta{\n      display:flex; gap:10px; margin-top:8px; flex-wrap:wrap;\n    }\n    .badge{\n      padding:8px 12px; border-radius:999px; font-weight:600; font-size:13px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.03);\n      color:var(--sub);\n    }\n\n    .stat-grid{\n      display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:12px;\n    }\n    .stat{\n      padding:12px; border-radius:10px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border:1px solid rgba(255,255,255,0.02);\n      display:flex; flex-direction:column;\n    }\n    .stat strong{ font-size:18px; color:var(--accent); }\n    .stat span{ font-size:12px; color:var(--sub); margin-top:6px; }\n\n    .controls{\n      display:flex; gap:12px; margin-top:16px;\n    }\n    .btn{\n      padding:10px 14px; border-radius:10px; cursor:pointer; border: none;\n      font-weight:700; letter-spacing:0.2px; color:var(--text); background:linear-gradient(90deg,#0b2030, #0b2133);\n      box-shadow: 0 6px 18px rgba(3,8,23,0.6);\n      transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms;\n      display:inline-flex;align-items:center;gap:8px;\n    }\n    .btn:active{ transform:translateY(1px); }\n    .btn.primary{\n      background: linear-gradient(90deg, rgba(124,241,209,0.12), rgba(138,167,255,0.08));\n      border: 1px solid rgba(124,241,209,0.14);\n      color: var(--text);\n      box-shadow: 0 8px 36px rgba(30,60,70,0.24);\n    }\n    .btn.ghost{\n      background: transparent;\n      border: 1px dashed rgba(255,255,255,0.04);\n      color:var(--sub);\n    }\n    .small{ font-size:13px; padding:8px 12px; }\n\n    .info{\n      margin-top:12px; padding:14px; border-radius:10px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n      border:1px solid rgba(255,255,255,0.02);\n      color:var(--sub); font-size:13px; line-height:1.45;\n    }\n\n    /* Right visualization area */\n    .viz{\n      padding:22px; border-radius:14px;\n      min-height:360px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.008));\n      border:1px solid rgba(255,255,255,0.02);\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      align-items:stretch;\n      justify-content:flex-start;\n      position:relative;\n      overflow:hidden;\n    }\n    .array-wrap{\n      display:flex; gap:12px;\n      padding:18px;\n      align-items:center;\n      justify-content:flex-start;\n      overflow-x:auto;\n      scroll-behavior:smooth;\n    }\n    .cell{\n      min-width:72px;\n      height:92px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.008));\n      border: 1px solid rgba(255,255,255,0.03);\n      display:flex; flex-direction:column; align-items:center; justify-content:center;\n      gap:6px;\n      transition: transform 350ms cubic-bezier(.2,.9,.2,1), box-shadow 300ms, background 250ms, border-color 220ms;\n      box-shadow: 0 6px 18px rgba(5,10,20,0.45);\n      color:var(--sub);\n      position:relative;\n      flex: 0 0 auto;\n    }\n    .cell .num{ font-weight:800; font-size:20px; color:var(--text); letter-spacing:0.2px; }\n    .cell .idx{ font-size:11px; color:var(--sub); }\n    .cell:hover{ transform: translateY(-6px); }\n\n    .cell.checked{\n      transform: translateY(-12px) scale(1.02);\n      border-color: rgba(124,241,209,0.36);\n      box-shadow: 0 18px 45px rgba(124,241,209,0.06), 0 4px 12px rgba(3,8,23,0.55);\n      background: linear-gradient(180deg, rgba(124,241,209,0.04), rgba(138,167,255,0.02));\n    }\n    .cell.pulse::after{\n      content:'';\n      position:absolute;\n      inset: -22px;\n      border-radius:18px;\n      box-shadow: 0 0 0 6px rgba(124,241,209,0.06);\n      animation: ring 900ms ease-out;\n      pointer-events:none;\n    }\n    @keyframes ring { from{ transform:scale(.7); opacity:0.9 } to{ transform:scale(1.6); opacity:0 } }\n\n    .cell.found{\n      transform: translateY(-6px) scale(1.04);\n      border-color: rgba(69,208,138,0.9);\n      background: linear-gradient(180deg, rgba(69,208,138,0.07), rgba(124,241,209,0.035));\n      box-shadow: 0 20px 60px rgba(69,208,138,0.06), 0 4px 12px rgba(3,8,23,0.6);\n      color: white;\n    }\n    .cell.skip{\n      opacity:0.28; transform: scale(.98); filter:grayscale(.5);\n    }\n    .tag{\n      position:absolute; top:8px; right:8px; font-size:11px; padding:6px 8px; border-radius:8px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid rgba(255,255,255,0.02); color:var(--sub);\n    }\n\n    .controls-row{\n      display:flex; align-items:center; justify-content:space-between; gap:18px;\n    }\n    .explain{\n      flex:1; color:var(--sub); font-size:13px;\n      display:flex; gap:10px; align-items:center;\n    }\n\n    .progress-bar{\n      height:8px; background:var(--glass-2); border-radius:999px; overflow:hidden;\n      width:280px;\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .progress-inner{\n      height:100%; width:0%; background:linear-gradient(90deg,var(--accent),var(--accent-2)); transition:width 600ms cubic-bezier(.2,.9,.2,1);\n    }\n\n    .legend{\n      font-size:12px; color:var(--sub); display:flex; gap:8px; align-items:center; flex-wrap:wrap;\n    }\n    .legend .item{ display:flex; gap:8px; align-items:center; }\n    .sw{ width:14px; height:14px; border-radius:4px; border:1px solid rgba(255,255,255,0.03); box-shadow: 0 6px 18px rgba(3,8,23,0.4); }\n\n    .overlay-range{\n      position:absolute; left:0; top:0; bottom:0; pointer-events:none;\n    }\n    /* Bracket visuals */\n    .bracket-start, .bracket-end{\n      position:absolute; width:2px; background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      top:0; bottom:0; border-radius:2px; opacity:0.95; transform-origin:center;\n      box-shadow: 0 8px 30px rgba(12,16,30,0.5);\n    }\n    .range-label{\n      position:absolute; padding:8px 10px; border-radius:8px; background: linear-gradient(90deg, rgba(124,241,209,0.06), rgba(138,167,255,0.04));\n      font-weight:700; color:var(--text); border:1px solid rgba(124,241,209,0.08); transform:translateY(-48px);\n      box-shadow: 0 12px 40px rgba(9,14,24,0.6);\n    }\n\n    .footer-note{ color:var(--sub); font-size:12px; margin-top:6px; }\n\n    /* Responsive */\n    @media (max-width:940px){\n      .stage{ grid-template-columns: 1fr; }\n      .array-wrap{ justify-content:flex-start; }\n      .panel{ order:2; }\n      .viz{ order:1; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"bg-blob blob1\"></div>\n  <div class=\"bg-blob blob2\"></div>\n\n  <main class=\"stage\" role=\"main\" aria-labelledby=\"title\">\n    <section class=\"panel\" aria-hidden=\"false\">\n      <div class=\"title\">\n        <div class=\"logo\">ES</div>\n        <div>\n          <h1 id=\"title\">Exponential Search</h1>\n          <p class=\"lead\">A visually rich demonstration of Exponential Search, where we exponentially expand the probe interval then apply Binary Search inside the found range.</p>\n        </div>\n      </div>\n\n      <div class=\"meta\">\n        <div class=\"badge\">Complexities: O(log i) for probe, then O(log n)</div>\n        <div class=\"badge\">Array: Sorted | Static Visualization</div>\n      </div>\n\n      <div class=\"stat-grid\">\n        <div class=\"stat\">\n          <strong id=\"stat-size\">n = 25</strong>\n          <span>Number of elements</span>\n        </div>\n        <div class=\"stat\">\n          <strong id=\"stat-target\">target = —</strong>\n          <span>Current target value</span>\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:12px;margin-top:12px;align-items:center;\">\n        <div class=\"controls\">\n          <button id=\"startBtn\" class=\"btn primary\">Start</button>\n          <button id=\"resetBtn\" class=\"btn ghost small\">Reset</button>\n        </div>\n      </div>\n\n      <div class=\"info\" id=\"explainBox\">\n        Press Start to watch the algorithm. The animation will probe indices in powers of two (1,2,4,8...) to find a range where the target could exist, then run Binary Search within that interval. The visualization emphasizes the probe points, range brackets, and the narrowing binary search.\n      </div>\n\n      <div style=\"margin-top:auto;\">\n        <div class=\"legend\" style=\"margin-top:10px;\">\n          <div class=\"item\"><span class=\"sw\" style=\"background:linear-gradient(90deg,#0b2030,#0b2133)\"></span><span style=\"color:var(--sub)\">Untouched</span></div>\n          <div class=\"item\"><span class=\"sw\" style=\"background:linear-gradient(90deg,rgba(124,241,209,0.12),rgba(138,167,255,0.08)); border-color:rgba(124,241,209,0.14)\"></span><span style=\"color:var(--sub)\">Probed / Checked</span></div>\n          <div class=\"item\"><span class=\"sw\" style=\"background:linear-gradient(90deg, rgba(69,208,138,0.07), rgba(124,241,209,0.035)); border-color:rgba(69,208,138,0.9)\"></span><span style=\"color:var(--sub)\">Found</span></div>\n        </div>\n        <div class=\"footer-note\">Designed for clarity and aesthetics — minimal controls, maximum polish.</div>\n      </div>\n    </section>\n\n    <section class=\"viz\" aria-hidden=\"false\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n        <div style=\"display:flex;flex-direction:column;\">\n          <div style=\"font-weight:700;font-size:14px;\">Array Visualization</div>\n          <div style=\"font-size:12px;color:var(--sub);margin-top:6px;\">Watch the probe grow exponentially, then observe the binary narrowing inside the bracket.</div>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:12px;\">\n          <div class=\"explain\">\n            <div id=\"stepLabel\">Ready</div>\n          </div>\n          <div class=\"progress-bar\" aria-hidden=\"true\">\n            <div class=\"progress-inner\" id=\"progressInner\"></div>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"position:relative;\">\n        <div class=\"array-wrap\" id=\"arrayWrap\" aria-live=\"polite\"></div>\n\n        <!-- Overlay for range brackets -->\n        <div class=\"overlay-range\" id=\"overlayRange\" aria-hidden=\"true\"></div>\n\n      </div>\n\n      <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n        <div style=\"color:var(--sub);font-size:13px;\" id=\"detailBox\">Awaiting action.</div>\n        <div style=\"display:flex;gap:8px;align-items:center;\">\n          <div style=\"font-size:12px;color:var(--sub)\">Steps</div>\n          <div style=\"font-weight:800;color:var(--accent);font-size:14px\" id=\"stepsCount\">0</div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <script>\n    // Polished, self-contained Exponential Search visualizer.\n    (() => {\n      const startBtn = document.getElementById('startBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const arrayWrap = document.getElementById('arrayWrap');\n      const statSize = document.getElementById('stat-size');\n      const statTarget = document.getElementById('stat-target');\n      const stepLabel = document.getElementById('stepLabel');\n      const detailBox = document.getElementById('detailBox');\n      const progressInner = document.getElementById('progressInner');\n      const overlayRange = document.getElementById('overlayRange');\n      const stepsCount = document.getElementById('stepsCount');\n\n      let arr = [];\n      let cells = [];\n      let targetIndex = null;\n      let targetVal = null;\n      let animating = false;\n      let stepCounter = 0;\n      let controller = { abort: false };\n\n      const config = {\n        n: 25,\n        delayProbe: 900,\n        delayShort: 520,\n        panelPadding: 18,\n      };\n\n      function randSortedArray(n){\n        const base = Math.floor(Math.random()*6) + 2;\n        let a = [];\n        let cur = base;\n        for(let i=0;i<n;i++){\n          cur += Math.floor(Math.random()*5) + 1;\n          a.push(cur);\n        }\n        return a;\n      }\n\n      function buildArrayView(){\n        arrayWrap.innerHTML = '';\n        cells = [];\n        arr.forEach((v,i)=>{\n          const el = document.createElement('div');\n          el.className = 'cell';\n          el.dataset.idx = i;\n          el.innerHTML = `<div class=\"idx\">[${i}]</div><div class=\"num\">${v}</div>`;\n          arrayWrap.appendChild(el);\n          cells.push(el);\n        });\n      }\n\n      function resetState(){\n        controller.abort = true;\n        setTimeout(()=>controller = { abort:false }, 50);\n        arr = randSortedArray(config.n);\n        buildArrayView();\n        stepCounter = 0;\n        stepsCount.textContent = '0';\n        statSize.textContent = `n = ${arr.length}`;\n        targetIndex = Math.floor(Math.random()*arr.length);\n        targetVal = arr[targetIndex];\n        statTarget.textContent = `target = ${targetVal}`;\n        stepLabel.textContent = 'Ready';\n        detailBox.textContent = 'Press Start to begin the visual walk-through.';\n        progressInner.style.width = '0%';\n        overlayRange.innerHTML = '';\n        animating = false;\n        startBtn.disabled = false;\n        startBtn.textContent = 'Start';\n        cells.forEach(c => { c.classList.remove('checked','found','skip','pulse'); c.style.opacity = ''; });\n      }\n\n      // Utility: sleep with abort support\n      function sleep(ms){\n        return new Promise((resolve, reject)=>{\n          let t = setTimeout(()=> resolve(), ms);\n          const check = () => {\n            if (controller.abort) { clearTimeout(t); reject('aborted'); }\n            else setTimeout(check, 50);\n          };\n          check();\n        });\n      }\n\n      // Scroll cell into view center\n      function revealCell(idx, instant=false){\n        const el = cells[idx];\n        if (!el) return;\n        const rect = el.getBoundingClientRect();\n        const wrapRect = arrayWrap.getBoundingClientRect();\n        const offset = rect.left - wrapRect.left - (wrapRect.width/2) + (rect.width/2);\n        if (instant) arrayWrap.scrollLeft += offset;\n        else arrayWrap.scrollBy({ left: offset, behavior: 'smooth' });\n      }\n\n      // Draw brackets around range [l..r]\n      function drawRange(l, r){\n        overlayRange.innerHTML = '';\n        if (l<0) l=0;\n        if (r>=cells.length) r = cells.length-1;\n        const leftEl = cells[l];\n        const rightEl = cells[r];\n        if (!leftEl || !rightEl) return;\n        const wrapRect = arrayWrap.getBoundingClientRect();\n        const lRect = leftEl.getBoundingClientRect();\n        const rRect = rightEl.getBoundingClientRect();\n\n        const startX = lRect.left - wrapRect.left + arrayWrap.scrollLeft;\n        const endX = rRect.left - wrapRect.left + arrayWrap.scrollLeft + rRect.width;\n\n        // Compute overlay relative to arrayWrap\n        const rangeDiv = document.createElement('div');\n        rangeDiv.style.position = 'absolute';\n        rangeDiv.style.left = startX + 'px';\n        rangeDiv.style.top = '0px';\n        rangeDiv.style.bottom = '0px';\n        rangeDiv.style.width = (endX - startX) + 'px';\n        rangeDiv.style.pointerEvents = 'none';\n        overlayRange.appendChild(rangeDiv);\n\n        // left bracket\n        const bL = document.createElement('div');\n        bL.className = 'bracket-start';\n        bL.style.left = '0px';\n        bL.style.top = '10px';\n        bL.style.bottom = '10px';\n        bL.style.width = '3px';\n        rangeDiv.appendChild(bL);\n\n        // right bracket\n        const bR = document.createElement('div');\n        bR.className = 'bracket-end';\n        bR.style.right = '0px';\n        bR.style.left = '';\n        bR.style.top = '10px';\n        bR.style.bottom = '10px';\n        bR.style.width = '3px';\n        rangeDiv.appendChild(bR);\n\n        // label\n        const lbl = document.createElement('div');\n        lbl.className = 'range-label';\n        lbl.innerHTML = `Search Range: [${l} .. ${r}]`;\n        lbl.style.left = ( (endX - startX) / 2 - 70) + 'px';\n        rangeDiv.appendChild(lbl);\n      }\n\n      async function animateProbe(idx, reason='probe'){\n        if (controller.abort) throw 'aborted';\n        revealCell(idx);\n        const el = cells[idx];\n        el.classList.remove('skip','found');\n        el.classList.add('checked','pulse');\n        stepCounter++;\n        stepsCount.textContent = stepCounter;\n        stepLabel.textContent = `Probing index ${idx}`;\n        detailBox.textContent = `Checking A[${idx}] = ${arr[idx]} …`;\n        progressInner.style.width = Math.min(100, (stepCounter * 6)) + '%';\n        try{ await sleep(config.delayProbe); } catch(e){ throw e; }\n        el.classList.remove('pulse');\n        return el;\n      }\n\n      async function animateBinaryMid(idx, direction=null){\n        if (controller.abort) throw 'aborted';\n        revealCell(idx);\n        const el = cells[idx];\n        el.classList.remove('skip','found');\n        el.classList.add('checked','pulse');\n        stepCounter++;\n        stepsCount.textContent = stepCounter;\n        stepLabel.textContent = `Binary probe at ${idx}`;\n        detailBox.textContent = `Mid: A[${idx}] = ${arr[idx]} ${direction? '→ narrowing ' + direction : ''}`;\n        progressInner.style.width = Math.min(100, (50 + stepCounter * 2)) + '%';\n        try{ await sleep(config.delayShort); } catch(e){ throw e; }\n        el.classList.remove('pulse');\n        return el;\n      }\n\n      // Main algorithm orchestrator\n      async function runExponentialSearch(){\n        if (animating) return;\n        animating = true;\n        startBtn.disabled = true;\n        startBtn.textContent = 'Running…';\n        try{\n          controller.abort = false;\n          stepLabel.textContent = 'Starting exponential probing';\n          detailBox.textContent = `Target = ${targetVal}. We'll probe indices 1,2,4,8... until we find a value >= target or exceed the array.`;\n          await sleep(700);\n\n          // Special-case index 0\n          let i = 0;\n          // Probe index 0 quickly\n          await animateProbe(0);\n          if (arr[0] === targetVal){\n            cells[0].classList.add('found');\n            stepLabel.textContent = 'Target found at index 0';\n            detailBox.textContent = `Found A[0] = ${targetVal} immediately.`;\n            progressInner.style.width = '100%';\n            animating = false;\n            startBtn.disabled = false;\n            startBtn.textContent = 'Start';\n            return;\n          }\n\n          // Exponential probing: 1, 2, 4, 8...\n          let bound = 1;\n          let prev = 0;\n          while (bound < arr.length && arr[bound] < targetVal){\n            prev = bound;\n            await animateProbe(bound);\n            stepLabel.textContent = `Expanding to ${bound * 2}`;\n            detailBox.textContent = `A[${bound}] = ${arr[bound]} < ${targetVal}, doubling...`;\n            bound = bound * 2;\n          }\n\n          if (bound >= arr.length){\n            // cap bound\n            prev = Math.floor(bound/2);\n            bound = arr.length - 1;\n            stepLabel.textContent = `Reached end of array`;\n            detailBox.textContent = `Bounding range to end: [${prev} .. ${bound}]`;\n            await sleep(650);\n          } else {\n            // Probe the candidate bound (if not yet probed)\n            await animateProbe(bound);\n            detailBox.textContent = `A[${bound}] = ${arr[bound]} >= ${targetVal}`;\n            await sleep(580);\n          }\n\n          // Determine search range [prev..bound]\n          drawRange(prev, bound);\n          // Dim outside elements\n          cells.forEach((c, idx) => {\n            if (idx < prev || idx > bound) c.classList.add('skip');\n            else c.classList.remove('skip');\n          });\n\n          // Binary search within [prev..bound]\n          let l = prev, r = bound;\n          stepLabel.textContent = `Binary search in [${l} .. ${r}]`;\n          detailBox.textContent = `Now applying binary search within the found bracket.`;\n          await sleep(700);\n\n          let found = -1;\n          while (l <= r){\n            const mid = Math.floor((l + r) / 2);\n            const midEl = await animateBinaryMid(mid);\n            const val = arr[mid];\n            if (val === targetVal){\n              midEl.classList.add('found');\n              stepLabel.textContent = `Found at index ${mid}`;\n              detailBox.textContent = `A[${mid}] = ${val}. Search complete.`;\n              progressInner.style.width = '100%';\n              found = mid;\n              break;\n            } else if (val < targetVal){\n              // move right\n              stepLabel.textContent = `A[${mid}] = ${val} < ${targetVal} → move right`;\n              detailBox.textContent = `Narrowing range: [${mid+1} .. ${r}]`;\n              // visually mark left half as skipped\n              for(let k=l;k<=mid;k++){ cells[k].classList.add('skip'); }\n              l = mid + 1;\n              drawRange(l, r);\n              await sleep(360);\n            } else {\n              stepLabel.textContent = `A[${mid}] = ${val} > ${targetVal} → move left`;\n              detailBox.textContent = `Narrowing range: [${l} .. ${mid-1}]`;\n              for(let k=mid;k<=r;k++){ cells[k].classList.add('skip'); }\n              r = mid - 1;\n              drawRange(l, r);\n              await sleep(360);\n            }\n          }\n\n          if (found === -1){\n            // not found\n            stepLabel.textContent = 'Value not in array';\n            detailBox.textContent = `Target ${targetVal} is not present in the array.`;\n            // flash a gentle red on the whole range\n            overlayRange.innerHTML = '';\n            progressInner.style.width = '100%';\n            // highlight nearest candidate\n          }\n\n        } catch(e){\n          if (e === 'aborted'){\n            stepLabel.textContent = 'Reset';\n            detailBox.textContent = 'Animation aborted.';\n          } else {\n            console.error(e);\n          }\n        } finally {\n          animating = false;\n          startBtn.disabled = false;\n          startBtn.textContent = 'Start';\n        }\n      }\n\n      // Wire up controls\n      startBtn.addEventListener('click', async ()=>{\n        if (animating) return;\n        try{\n          await runExponentialSearch();\n        } catch(e){\n          // ignore\n        }\n      });\n\n      resetBtn.addEventListener('click', ()=>{\n        resetState();\n      });\n\n      // Initialize\n      resetState();\n\n      // Accessibility: allow keyboard start\n      document.addEventListener('keydown', (e)=>{\n        if (e.key === ' ' && !animating){\n          e.preventDefault();\n          startBtn.click();\n        }\n      });\n    })();\n  </script>\n</body>\n</html>"
