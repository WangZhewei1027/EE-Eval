  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Routing Demo</title>\n<style>\n  /* Minimal styling for layout only */\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  #path, #params, #history, #controls {\n    margin-bottom: 1em;\n  }\n  input[type=\"text\"] {\n    width: 300px;\n  }\n  button, input[type=\"text\"], select {\n    font-size: 1rem;\n    margin: 0 0.2em 0.2em 0;\n  }\n  label {\n    margin-right: 0.5em;\n  }\n  fieldset {\n    margin-bottom: 1em;\n  }\n</style>\n</head>\n<body>\n<h1>Routing with MAXIMUM Interactivity</h1>\n<div id=\"description\">\n  <p>\n    This demo simulates a router with dynamic routes, parameters, query strings, and nested routes.\n    Use the controls below to navigate, edit routes and parameters, and explore state transitions.\n  </p>\n</div>\n\n<section id=\"navigation\">\n  <fieldset>\n    <legend>Current Route Information</legend>\n    <div>\n      <label for=\"current-path\">Path:</label>\n      <input type=\"text\" id=\"current-path\" readonly aria-label=\"Current Path\" />\n    </div>\n    <div>\n      <label for=\"current-params\">Route Parameters (JSON):</label><br />\n      <textarea id=\"current-params\" rows=\"4\" cols=\"50\" readonly aria-label=\"Route Parameters\"></textarea>\n    </div>\n    <div>\n      <label for=\"current-query\">Query Parameters (JSON):</label><br />\n      <textarea id=\"current-query\" rows=\"3\" cols=\"50\" readonly aria-label=\"Query Parameters\"></textarea>\n    </div>\n  </fieldset>\n</section>\n\n<section id=\"controls\">\n  <fieldset>\n    <legend>Navigate / Change Route</legend>\n    <div>\n      <label for=\"input-route\">Enter Route Path:</label>\n      <input type=\"text\" id=\"input-route\" placeholder=\"/users/:userId/posts/:postId\" aria-label=\"Route Input\" />\n      <button id=\"btn-navigate\">Navigate</button>\n    </div>\n    <div>\n      <label for=\"input-query\">Query String (e.g. ?tab=summary&page=2):</label>\n      <input type=\"text\" id=\"input-query\" placeholder=\"?tab=summary&page=2\" aria-label=\"Query String Input\" />\n    </div>\n    <div>\n      <label for=\"input-params\">Route Parameters JSON (optional):</label><br />\n      <textarea id=\"input-params\" rows=\"3\" cols=\"50\" placeholder='{\"userId\": \"123\", \"postId\": \"456\"}' aria-label=\"Route Parameters Input\"></textarea>\n    </div>\n    <div>\n      <button id=\"btn-apply-params\">Apply Route Parameters</button>\n      <button id=\"btn-apply-query\">Apply Query Parameters</button>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Modify Path Tokens</legend>\n    <div>\n      <label for=\"token-select\">Select Token to Modify:</label>\n      <select id=\"token-select\" aria-label=\"Token Selector\">\n        <option value=\"\">--No tokens--</option>\n      </select>\n      <input type=\"text\" id=\"token-value\" placeholder=\"New value\" aria-label=\"Token Value\" />\n      <button id=\"btn-update-token\">Update Token</button>\n      <button id=\"btn-remove-token\">Remove Token</button>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Query Parameters Controls</legend>\n    <div>\n      <label for=\"query-key\">Key:</label>\n      <input type=\"text\" id=\"query-key\" placeholder=\"key\" aria-label=\"Query Key\" />\n      <label for=\"query-value\">Value:</label>\n      <input type=\"text\" id=\"query-value\" placeholder=\"value\" aria-label=\"Query Value\" />\n      <button id=\"btn-add-query\">Add/Update Query Param</button>\n      <button id=\"btn-remove-query\">Remove Query Param</button>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>History & State Management</legend>\n    <div>\n      <button id=\"btn-back\">Back</button>\n      <button id=\"btn-forward\">Forward</button>\n      <button id=\"btn-reset\">Reset Router</button>\n    </div>\n    <div>\n      <label for=\"history-index\">Jump to History Index:</label>\n      <input type=\"number\" id=\"history-index\" min=\"0\" aria-label=\"History Index\" />\n      <button id=\"btn-jump-history\">Jump</button>\n    </div>\n  </fieldset>\n</section>\n\n<section id=\"history-area\">\n  <fieldset>\n    <legend>Navigation History (most recent last)</legend>\n    <textarea id=\"history-log\" rows=\"8\" cols=\"80\" readonly aria-label=\"Navigation History Log\"></textarea>\n  </fieldset>\n</section>\n\n<section id=\"routing-explorer\">\n  <fieldset>\n    <legend>Deep Route Exploration & Workflow Steps</legend>\n    <div>\n      <label for=\"workflow-select-step\">Select Workflow Step:</label>\n      <select id=\"workflow-select-step\" aria-label=\"Workflow Step Select\">\n        <option value=\"\">--Select Step--</option>\n      </select>\n      <button id=\"btn-go-step\">Go To Step</button>\n    </div>\n    <div id=\"workflow-step-controls\" style=\"margin-top: 0.5em;\">\n      <button id=\"btn-next-step\">Next Step &gt;</button>\n      <button id=\"btn-prev-step\">&lt; Prev Step</button>\n      <button id=\"btn-new-branch\">Create Branch from Current Step</button>\n    </div>\n    <div style=\"margin-top:0.5em;\">\n      <label for=\"branch-name\">Branch Name:</label>\n      <input type=\"text\" id=\"branch-name\" placeholder=\"New branch name\" />\n      <button id=\"btn-switch-branch\">Switch Branch</button>\n      <button id=\"btn-show-branches\">Show Branches</button>\n    </div>\n    <div id=\"branches-list\" style=\"white-space: pre-wrap; max-height: 8em; overflow-y: auto; border: 1px solid #999; margin-top: 0.5em;\"></div>\n  </fieldset>\n</section>\n\n<script>\n(function(){\n// The router state and functionality\n\n/** ROUTING MODEL\n *\n * Router state contains:\n * - currentPath: string, e.g. \"/users/123/posts/456\"\n * - routeTemplate: string, e.g. \"/users/:userId/posts/:postId\"\n * - params: object, { userId: \"123\", postId: \"456\" }\n * - query: object, { tab: \"summary\", page: \"2\" }\n * - history: array of router states (including current)\n * - historyIndex: current index in history\n *\n * The demo allows:\n * - Navigating to paths with templates & parameters\n * - Editing parameters\n * - Editing query string\n * - History back/forward/jump\n * - Maintaining a workflow model with steps and branches\n *\n * The workflow model simulates multi-step forms or nested routes\n * with ability to create branches and jump between workflow steps.\n */\n\n// ---------------------------\n// UTILS\n\nfunction parseQueryString(qs) {\n  const obj = {};\n  if (!qs) return obj;\n  if (qs[0] === '?') qs = qs.slice(1);\n  qs.split('&').forEach(pair=>{\n    if (!pair) return;\n    const [k,v=''] = pair.split('=').map(decodeURIComponent);\n    if (k) obj[k] = v;\n  });\n  return obj;\n}\n\nfunction buildQueryString(obj) {\n  const parts = [];\n  for (const k in obj) {\n    if (obj[k] == null || obj[k] === '') continue;\n    parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(obj[k]));\n  }\n  return parts.length ? '?' + parts.join('&') : '';\n}\n\n// Parse route template (e.g. \"/users/:userId/posts/:postId\") into tokens array\n// tokens: array of { type: \"static\"|\"param\", value: string }\nfunction parseRouteTemplate(template) {\n  if (!template) return [];\n  if (template[0]!=='/') template = '/' + template;\n  const parts = template.split('/').slice(1); // skip first empty \"\"\n  return parts.map(p=>{\n    if (p.startsWith(':')) return {type:'param', value:p.slice(1)};\n    return {type:'static', value:p};\n  });\n}\n\n// Build path string from template and params\nfunction buildPathFromTemplate(template, params) {\n  const tokens = parseRouteTemplate(template);\n  let result = '';\n  for (const t of tokens) {\n    result += '/';\n    if (t.type === 'param') {\n      let val = params && params[t.value];\n      if (val == null) val = ':'+t.value;\n      result += val;\n    } else {\n      result += t.value;\n    }\n  }\n  if (result === '') result = '/';\n  return result;\n}\n\n// Extract parameters from path based on template tokens\nfunction extractParamsFromPath(template, path) {\n  const tokens = parseRouteTemplate(template);\n  if (!path.startsWith('/')) path = '/' + path;\n  const parts = path.split('/').slice(1);\n  const params = {};\n  for (let i=0; i<tokens.length; i++){\n    const token = tokens[i];\n    const part = parts[i];\n    if (!part) continue;\n    if (token.type === 'param') {\n      params[token.value] = part;\n    } else {\n      if (token.value !== part) {\n        // static part mismatch, no valid params\n        // but still accept partial\n      }\n    }\n  }\n  return params;\n}\n\n// Update URL-like string with query parameters (updates or adds)\nfunction updatePathWithQuery(path, queryObject) {\n  // strip existing query\n  const [p] = path.split('?');\n  const qstr = buildQueryString(queryObject);\n  return p + qstr;\n}\n\nfunction safeJsonParse(s) {\n  try {\n    return JSON.parse(s);\n  } catch(e) {\n    return null;\n  }\n}\nfunction safeJsonStringify(o) {\n  try {\n    return JSON.stringify(o, null, 2);\n  } catch(e) {\n    return '';\n  }\n}\n// ---------------------------\n// ROUTER STATE\n\nconst Router = {\n  current: {\n    routeTemplate: '/home',\n    params: {},\n    query: {},\n    path: '/home',\n  },\n  history: [],\n  historyIndex: -1,\n\n  // Workflow steps and branches\n  workflow: {\n    steps: [], // array of { id, routeTemplate, params, query }\n    currentStepIndex: 0,\n    branches: {\n      main: {name:'main', steps:[], currentStepIndex: 0},\n    },\n    currentBranch: 'main',\n  },\n\n  // Initialize with /home route\n  init() {\n    this.navigate('/home');\n  },\n\n  generateStepId() {\n    return 'step_' + Math.random().toString(36).substr(2,8);\n  },\n  saveStep(routeTemplate, params, query) {\n    return { id:this.generateStepId(), routeTemplate, params:{...params}, query:{...query} };\n  },\n\n  navigate(pathInput, paramsInput, queryInput) {\n    // pathInput might be a string or empty/null\n    // If string includes params, parse them accordingly\n    let path = pathInput || '/home';\n    // detect if pathInput is a full path or a template\n    // We try to keep routeTemplate if paramsInput exists, else infer template from path\n\n    // Normalize\n    if (!path.startsWith('/')) path = '/'+path;\n\n    let routeTemplate = '';\n    let params = {};\n    let query = {};\n\n    if (paramsInput && typeof paramsInput === 'object') {\n      params = {...paramsInput};\n    }\n    if (queryInput && typeof queryInput === 'object') {\n      query = {...queryInput};\n    }\n\n    // Try to detect routeTemplate from path by treating pathInput as template if containing :\n    // or if params provided, use pathInput as template\n    if (path.includes(':')) {\n      routeTemplate = path;\n      path = buildPathFromTemplate(routeTemplate, params);\n    }\n    else if (Object.keys(params).length > 0) {\n      routeTemplate = path;\n      path = buildPathFromTemplate(routeTemplate, params);\n    } else {\n      // no params\n      // Try to find param tokens (\":\") in path? If not, routeTemplate = path\n      routeTemplate = path;\n      params = extractParamsFromPath(routeTemplate, path);\n    }\n\n    // Apply query string if any\n    path = updatePathWithQuery(path, query);\n\n    // Save current state\n    this.current = {routeTemplate, params, query, path};\n\n    // Add to history, discard forward history\n    this.history.splice(this.historyIndex+1);\n    this.history.push({...this.current});\n    this.historyIndex = this.history.length -1;\n\n    // For workflow integration, add step on new normal navigation (not back/forward)\n    this.workflowAddStep(this.current);\n\n    this.refreshUI();\n  },\n\n  updateParams(newParams) {\n    const params = {...this.current.params, ...newParams};\n    const routeTemplate = this.current.routeTemplate;\n    let path = buildPathFromTemplate(routeTemplate, params);\n    path = updatePathWithQuery(path, this.current.query);\n    this.current.params = params;\n    this.current.path = path;\n\n    // Save to history\n    this.history.splice(this.historyIndex+1);\n    this.history.push({...this.current});\n    this.historyIndex = this.history.length-1;\n\n    this.workflowAddStep(this.current);\n    this.refreshUI();\n  },\n\n  updateQuery(newQuery) {\n    const query = {...this.current.query, ...newQuery};\n    const routeTemplate = this.current.routeTemplate;\n    const params = this.current.params;\n    let path = buildPathFromTemplate(routeTemplate, params);\n    path = updatePathWithQuery(path, query);\n    this.current.query = query;\n    this.current.path = path;\n\n    this.history.splice(this.historyIndex+1);\n    this.history.push({...this.current});\n    this.historyIndex = this.history.length-1;\n\n    this.workflowAddStep(this.current);\n    this.refreshUI();\n  },\n\n  removeParam(paramKey) {\n    if (!(paramKey in this.current.params)) return;\n    const params = {...this.current.params};\n    delete params[paramKey];\n    this.updateParams(params);\n  },\n\n  removeQueryParam(qKey) {\n    if (!(qKey in this.current.query)) return;\n    const query = {...this.current.query};\n    delete query[qKey];\n    this.updateQuery(query);\n  },\n\n  back() {\n    if (this.historyIndex > 0) {\n      this.historyIndex--;\n      this.current = {...this.history[this.historyIndex]};\n      this.workflowJumpStepByRoute(this.current);\n      this.refreshUI();\n    }\n  },\n\n  forward() {\n    if (this.historyIndex < this.history.length - 1) {\n      this.historyIndex++;\n      this.current = {...this.history[this.historyIndex]};\n      this.workflowJumpStepByRoute(this.current);\n      this.refreshUI();\n    }\n  },\n\n  jumpToHistory(index) {\n    if (index < 0 || index >= this.history.length) return;\n    this.historyIndex = index;\n    this.current = {...this.history[this.historyIndex]};\n    this.workflowJumpStepByRoute(this.current);\n    this.refreshUI();\n  },\n\n  reset() {\n    this.current = {\n      routeTemplate: '/home',\n      params: {},\n      query: {},\n      path: '/home',\n    };\n    this.history = [ {...this.current} ];\n    this.historyIndex = 0;\n    this.workflow = {\n      steps: [],\n      currentStepIndex: 0,\n      branches: {\n        main: {name:'main', steps:[], currentStepIndex: 0}\n      },\n      currentBranch: 'main',\n    };\n    this.workflowAddStep(this.current);\n    this.refreshUI();\n  },\n\n  /* --------------------\n   * WORKFLOW modeling\n   * -------------------- */\n\n  workflowAddStep(routeState) {\n    // Add step to current branch if differs from last\n    let branch = this.workflow.branches[this.workflow.currentBranch];\n    if (!branch) {\n      branch = {name:this.workflow.currentBranch, steps:[], currentStepIndex:0};\n      this.workflow.branches[this.workflow.currentBranch] = branch;\n    }\n\n    // Check last step in branch\n    if(branch.steps.length === 0) {\n      branch.steps.push({...routeState, id:this.generateStepId()});\n      branch.currentStepIndex = branch.steps.length -1;\n      this.workflow.currentStepIndex = branch.currentStepIndex;\n      this.workflow.steps = branch.steps;\n      return;\n    }\n\n    const lastStep = branch.steps[branch.steps.length-1];\n    function equalSteps(s1,s2) {\n      if(s1.routeTemplate !== s2.routeTemplate) return false;\n      if(JSON.stringify(s1.params) !== JSON.stringify(s2.params)) return false;\n      if(JSON.stringify(s1.query) !== JSON.stringify(s2.query)) return false;\n      return true;\n    }\n    if (!equalSteps(lastStep, routeState)) {\n      branch.steps.push({...routeState, id:this.generateStepId()});\n      branch.currentStepIndex = branch.steps.length -1;\n      this.workflow.currentStepIndex = branch.currentStepIndex;\n      this.workflow.steps = branch.steps;\n    }\n  },\n\n  workflowGoToStep(index) {\n    const branch = this.workflow.branches[this.workflow.currentBranch];\n    if (!branch) return;\n    if(index < 0 || index >= branch.steps.length) return;\n    branch.currentStepIndex = index;\n    this.workflow.currentStepIndex = index;\n    this.workflow.steps = branch.steps;\n    const step = branch.steps[index];\n    if(step) {\n      // Update current state and history\n      this.current = {\n        routeTemplate: step.routeTemplate,\n        params: {...step.params},\n        query: {...step.query},\n        path: buildPathFromTemplate(step.routeTemplate, step.params),\n      };\n      this.current.path = updatePathWithQuery(this.current.path, this.current.query);\n\n      // Add to history\n      this.history.splice(this.historyIndex+1);\n      this.history.push({...this.current});\n      this.historyIndex = this.history.length -1;\n\n      this.refreshUI();\n    }\n  },\n\n  workflowNextStep() {\n    const branch = this.workflow.branches[this.workflow.currentBranch];\n    if (!branch) return;\n    let idx = branch.currentStepIndex;\n    if (idx < branch.steps.length-1) idx++;\n    this.workflowGoToStep(idx);\n  },\n  workflowPrevStep() {\n    const branch = this.workflow.branches[this.workflow.currentBranch];\n    if (!branch) return;\n    let idx = branch.currentStepIndex;\n    if (idx > 0) idx--;\n    this.workflowGoToStep(idx);\n  },\n\n  workflowCreateBranch(branchName) {\n    // Create branch from current branch's current step onward\n    if (!branchName) return false;\n    if (this.workflow.branches[branchName]) return false; // already exists\n\n    const currentBranch = this.workflow.branches[this.workflow.currentBranch];\n    if (!currentBranch) return false;\n    const startingIndex = currentBranch.currentStepIndex;\n    const newSteps = currentBranch.steps.slice(0, startingIndex + 1).map(s => ({...s}));\n    this.workflow.branches[branchName] = {\n      name: branchName,\n      steps: newSteps,\n      currentStepIndex: newSteps.length - 1,\n    };\n    this.workflow.currentBranch = branchName;\n    this.workflow.steps = newSteps;\n    this.workflow.currentStepIndex = newSteps.length -1;\n    this.refreshUI();\n    return true;\n  },\n\n  workflowSwitchBranch(branchName) {\n    if (!this.workflow.branches[branchName]) return false;\n    this.workflow.currentBranch = branchName;\n    const branch = this.workflow.branches[branchName];\n    this.workflow.steps = branch.steps;\n    this.workflow.currentStepIndex = branch.currentStepIndex;\n\n    const step = branch.steps[branch.currentStepIndex];\n    if(step) {\n      this.current = {\n        routeTemplate: step.routeTemplate,\n        params: {...step.params},\n        query: {...step.query},\n        path: buildPathFromTemplate(step.routeTemplate, step.params),\n      };\n      this.current.path = updatePathWithQuery(this.current.path, this.current.query);\n\n      this.history.splice(this.historyIndex+1);\n      this.history.push({...this.current});\n      this.historyIndex = this.history.length-1;\n    }\n\n    this.refreshUI();\n    return true;\n  },\n\n  workflowJumpStepByRoute(routeState) {\n    // Try to find step index in current branch matching routeState\n    const branch = this.workflow.branches[this.workflow.currentBranch];\n    if (!branch) return;\n    // find step equal\n    function equalSteps(s1,s2) {\n      if(s1.routeTemplate !== s2.routeTemplate) return false;\n      if(JSON.stringify(s1.params) !== JSON.stringify(s2.params)) return false;\n      if(JSON.stringify(s1.query) !== JSON.stringify(s2.query)) return false;\n      return true;\n    }\n    const idx = branch.steps.findIndex(s => equalSteps(s, routeState));\n    if (idx >= 0) {\n      branch.currentStepIndex = idx;\n      this.workflow.currentStepIndex = idx;\n      this.workflow.steps = branch.steps;\n    }\n  },\n\n  // ---------------------------\n  // UI REFRESH and EVENT HOOKS\n\n  refreshUI() {\n    // current path input\n    const inputCurrentPath = document.getElementById('current-path');\n    const taCurrentParams = document.getElementById('current-params');\n    const taCurrentQuery = document.getElementById('current-query');\n    const tokenSelect = document.getElementById('token-select');\n    const taInputParams = document.getElementById('input-params');\n    const inputInputRoute = document.getElementById('input-route');\n    const inputInputQuery = document.getElementById('input-query');\n\n    inputCurrentPath.value = this.current.path;\n    try {\n      taCurrentParams.value = JSON.stringify(this.current.params, null, 2);\n    } catch(e) {\n      taCurrentParams.value = String(this.current.params);\n    }\n    try {\n      taCurrentQuery.value = JSON.stringify(this.current.query, null, 2);\n    } catch(e) {\n      taCurrentQuery.value = String(this.current.query);\n    }\n\n    // Update token-select options:\n    const tokens = parseRouteTemplate(this.current.routeTemplate).filter(t => t.type==='param');\n    while(tokenSelect.firstChild){\n      tokenSelect.removeChild(tokenSelect.firstChild);\n    }\n    if (tokens.length === 0) {\n      const opt = document.createElement('option');\n      opt.value = '';\n      opt.textContent = '--No tokens--';\n      tokenSelect.appendChild(opt);\n      tokenSelect.disabled = true;\n    } else {\n      tokenSelect.disabled = false;\n      tokens.forEach(t=>{\n        const opt = document.createElement('option');\n        opt.value = t.value;\n        opt.textContent = t.value + (this.current.params[t.value] ? ' = \"'+this.current.params[t.value]+'\"' : ' (unset)');\n        tokenSelect.appendChild(opt);\n      });\n    }\n\n    // Update history log\n    const taHistoryLog = document.getElementById('history-log');\n    const historyStrings = this.history.map((h,i) => {\n      const marker = (i === this.historyIndex) ? '>' : ' ';\n      return marker + ' [' + i + '] ' + h.path;\n    });\n    taHistoryLog.value = historyStrings.join('\\n');\n\n    // Update workflow step selector\n    const workflowStepSelect = document.getElementById('workflow-select-step');\n    while(workflowStepSelect.firstChild) workflowStepSelect.removeChild(workflowStepSelect.firstChild);\n    const emptyOpt = document.createElement('option');\n    emptyOpt.value = '';\n    emptyOpt.textContent = '--Select Step--';\n    workflowStepSelect.appendChild(emptyOpt);\n\n    const branch = this.workflow.branches[this.workflow.currentBranch];\n    if (branch && branch.steps.length > 0) {\n      branch.steps.forEach((step, i) => {\n        const opt = document.createElement('option');\n        opt.value = i;\n        let label = `Step ${i}: ${step.routeTemplate}`;\n        const paramsString = JSON.stringify(step.params);\n        const queryString = JSON.stringify(step.query);\n        label += ` Params: ${paramsString}`;\n        label += ` Query: ${queryString}`;\n        if (i === branch.currentStepIndex) label += ' [CURRENT]';\n        opt.textContent = label;\n        workflowStepSelect.appendChild(opt);\n      });\n      workflowStepSelect.value = branch.currentStepIndex;\n    }\n\n    // Update branches list display\n    const branchesListEl = document.getElementById('branches-list');\n    let branchesText = 'Branches:\\n';\n    for (const bname in this.workflow.branches) {\n      let marker = (bname === this.workflow.currentBranch) ? ' *' : '  ';\n      const b = this.workflow.branches[bname];\n      branchesText += `${marker} ${bname} (Steps: ${b.steps.length}, CurrentStep: ${b.currentStepIndex})\\n`;\n    }\n    branchesListEl.textContent = branchesText;\n\n    // Update history-index input max\n    const inputHistoryIndex = document.getElementById('history-index');\n    inputHistoryIndex.max = this.history.length -1;\n    inputHistoryIndex.value = this.historyIndex;\n  },\n\n  setupEventListeners() {\n    const btnNavigate = document.getElementById('btn-navigate');\n    const inputRoute = document.getElementById('input-route');\n    const taInputParams = document.getElementById('input-params');\n    const inputQuery = document.getElementById('input-query');\n\n    btnNavigate.addEventListener('click', ()=>{\n      const routeStr = inputRoute.value.trim();\n      const paramsRaw = taInputParams.value.trim();\n      const paramsObj = safeJsonParse(paramsRaw) || {};\n      const queryStr = inputQuery.value.trim();\n      const queryObj = parseQueryString(queryStr);\n      if (routeStr) {\n        Router.navigate(routeStr, paramsObj, queryObj);\n      }\n    });\n\n    const btnApplyParams = document.getElementById('btn-apply-params');\n    btnApplyParams.addEventListener('click', () => {\n      const paramsRaw = taInputParams.value.trim();\n      const paramsObj = safeJsonParse(paramsRaw);\n      if (paramsObj && typeof paramsObj === 'object') {\n        Router.updateParams(paramsObj);\n      }\n    });\n\n    const btnApplyQuery = document.getElementById('btn-apply-query');\n    btnApplyQuery.addEventListener('click', () => {\n      const queryStr = inputQuery.value.trim();\n      const queryObj = parseQueryString(queryStr);\n      Router.updateQuery(queryObj);\n    });\n\n    // Modify tokens controls\n    const tokenSelect = document.getElementById('token-select');\n    const tokenValueInput = document.getElementById('token-value');\n    const btnUpdateToken = document.getElementById('btn-update-token');\n    const btnRemoveToken = document.getElementById('btn-remove-token');\n\n    btnUpdateToken.addEventListener('click', () => {\n      const token = tokenSelect.value;\n      const val = tokenValueInput.value.trim();\n      if (token) {\n        Router.updateParams({[token]: val});\n        tokenValueInput.value = '';\n      }\n    });\n    btnRemoveToken.addEventListener('click', () => {\n      const token = tokenSelect.value;\n      if (token) {\n        Router.removeParam(token);\n        tokenValueInput.value = '';\n      }\n    });\n\n    // Query param controls\n    const inputQueryKey = document.getElementById('query-key');\n    const inputQueryValue = document.getElementById('query-value');\n    const btnAddQuery = document.getElementById('btn-add-query');\n    const btnRemoveQuery = document.getElementById('btn-remove-query');\n\n    btnAddQuery.addEventListener('click', () => {\n      const key = inputQueryKey.value.trim();\n      const val = inputQueryValue.value.trim();\n      if (key) {\n        const newQuery = {};\n        newQuery[key] = val;\n        Router.updateQuery(newQuery);\n        inputQueryKey.value = '';\n        inputQueryValue.value = '';\n      }\n    });\n    btnRemoveQuery.addEventListener('click', () => {\n      const key = inputQueryKey.value.trim();\n      if (key) {\n        Router.removeQueryParam(key);\n        inputQueryKey.value = '';\n        inputQueryValue.value = '';\n      }\n    });\n\n    // History controls\n    const btnBack = document.getElementById('btn-back');\n    const btnForward = document.getElementById('btn-forward');\n    const btnReset = document.getElementById('btn-reset');\n    const inputHistoryIndex = document.getElementById('history-index');\n    const btnJumpHistory = document.getElementById('btn-jump-history');\n\n    btnBack.addEventListener('click', () => Router.back());\n    btnForward.addEventListener('click', () => Router.forward());\n    btnReset.addEventListener('click', () => Router.reset());\n    btnJumpHistory.addEventListener('click', () => {\n      const val = parseInt(inputHistoryIndex.value,10);\n      if (!isNaN(val)) Router.jumpToHistory(val);\n    });\n\n    // Workflow controls\n    const workflowStepSelect = document.getElementById('workflow-select-step');\n    const btnGoStep = document.getElementById('btn-go-step');\n    const btnNextStep = document.getElementById('btn-next-step');\n    const btnPrevStep = document.getElementById('btn-prev-step');\n    const btnNewBranch = document.getElementById('btn-new-branch');\n    const inputBranchName = document.getElementById('branch-name');\n    const btnSwitchBranch = document.getElementById('btn-switch-branch');\n    const btnShowBranches = document.getElementById('btn-show-branches');\n\n    btnGoStep.addEventListener('click', () => {\n      const idx = parseInt(workflowStepSelect.value, 10);\n      if (!isNaN(idx)) {\n        Router.workflowGoToStep(idx);\n      }\n    });\n    btnNextStep.addEventListener('click', () => Router.workflowNextStep());\n    btnPrevStep.addEventListener('click', () => Router.workflowPrevStep());\n    btnNewBranch.addEventListener('click', () => {\n      const bname = inputBranchName.value.trim();\n      if (bname) {\n        if (Router.workflowCreateBranch(bname)) {\n          inputBranchName.value = '';\n          Router.refreshUI();\n        } else {\n          alert('Branch name exists or invalid');\n        }\n      }\n    });\n    btnSwitchBranch.addEventListener('click', () => {\n      const bname = inputBranchName.value.trim();\n      if (bname) {\n        if (!Router.workflowSwitchBranch(bname)) {\n          alert('Branch not found');\n        } else {\n          inputBranchName.value = '';\n        }\n      }\n    });\n    btnShowBranches.addEventListener('click', () => {\n      const names = Object.keys(Router.workflow.branches);\n      alert('Branches:\\n' + names.join('\\n'));\n    });\n\n  }\n};\n\n// Initialize and start app\nRouter.init();\nRouter.setupEventListeners();\n\nwindow.Router = Router; // expose for debugging\n})();\n</script>\n</body>\n</html>"
