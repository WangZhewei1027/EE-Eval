    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Trie — Elegant Visual Demonstration</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071029;\n    --card-bg: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.65);\n    --accent-1: #7c5cff;\n    --accent-2: #00d4ff;\n    --accent-3: #ff7ab6;\n    --glass: rgba(255,255,255,0.06);\n    --glass-2: rgba(255,255,255,0.03);\n    --success: #6ee7b7;\n    --danger: #ff8a8a;\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    font-synthesis: none;\n  }\n\n  /* Background */\n  html,body{\n    height:100%;\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.14), transparent 8%),\n                radial-gradient(900px 400px at 90% 90%, rgba(0,212,255,0.08), transparent 8%),\n                linear-gradient(180deg,var(--bg-1) 0%, var(--bg-2) 100%);\n    font-family: \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, system-ui, -apple-system;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    color: #eaf0ff;\n    overflow:hidden;\n  }\n\n  /* Subtle animated texture */\n  .grain {\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    mix-blend-mode:overlay;\n    opacity:0.06;\n    background-image: radial-gradient(rgba(255,255,255,0.08) 1px, transparent 1px);\n    background-size: 3px 3px;\n    animation: drift linear 30s infinite;\n    filter: blur(0.2px);\n  }\n  @keyframes drift{\n    from { transform: translate3d(0,0,0); }\n    to   { transform: translate3d(-200px,120px,0); }\n  }\n\n  /* Container */\n  .stage {\n    max-width:1200px;\n    margin:48px auto;\n    padding:36px;\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow);\n    display:grid;\n    grid-template-columns: 430px 1fr;\n    gap:28px;\n    align-items:stretch;\n    position:relative;\n    backdrop-filter: blur(8px) saturate(120%);\n    -webkit-backdrop-filter: blur(8px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n\n  /* Left panel (info & controls) */\n  .panel {\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n  }\n\n  h1 {\n    margin:0;\n    font-size:26px;\n    letter-spacing:-0.02em;\n    font-weight:700;\n    color: #f7f9ff;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  .logo {\n    width:54px;\n    height:54px;\n    border-radius:12px;\n    display:grid;\n    place-items:center;\n    background: linear-gradient(135deg,var(--accent-1), var(--accent-2));\n    box-shadow: 0 8px 24px rgba(12,8,40,0.6), inset 0 1px 0 rgba(255,255,255,0.08);\n    flex-shrink:0;\n  }\n  .logo svg { filter: drop-shadow(0 6px 18px rgba(124,92,255,0.18)); }\n\n  .subtitle {\n    margin:0;\n    font-size:13px;\n    color:var(--muted);\n    line-height:1.4;\n  }\n\n  .description{\n    font-size:13px;\n    color:rgba(234,240,255,0.78);\n    line-height:1.5;\n    margin-top:6px;\n  }\n\n  .controls {\n    display:flex;\n    gap:12px;\n    margin-top:8px;\n  }\n\n  .btn {\n    --b: 1px;\n    appearance:none;\n    border: none;\n    cursor:pointer;\n    padding:12px 16px;\n    border-radius:12px;\n    font-weight:600;\n    font-size:13px;\n    color:white;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 6px 18px rgba(2,6,23,0.5);\n    transition: transform 220ms cubic-bezier(.2,.9,.3,1), box-shadow 220ms;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn:active{ transform: translateY(1px) scale(.997); }\n  .btn.primary {\n    background: linear-gradient(90deg,var(--accent-1), var(--accent-2));\n    box-shadow: 0 10px 30px rgba(124,92,255,0.2), 0 2px 8px rgba(0,0,0,0.4);\n  }\n  .btn.ghost {\n    background: transparent;\n    border: 1px solid rgba(255,255,255,0.06);\n    color: var(--accent-2);\n    padding:10px 12px;\n  }\n\n  .meta {\n    margin-top:auto;\n    font-size:12px;\n    color:var(--muted);\n    display:flex;\n    gap:8px;\n    align-items:center;\n    justify-content:space-between;\n  }\n\n  .words {\n    display:flex;\n    gap:8px;\n    flex-wrap:wrap;\n    margin-top:10px;\n  }\n  .chip {\n    padding:8px 10px;\n    border-radius:999px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  /* Right panel (visualization) */\n  .canvas {\n    position:relative;\n    overflow:hidden;\n    border-radius:14px;\n    background:\n      radial-gradient(600px 300px at 85% 10%, rgba(124,92,255,0.06), transparent 6%),\n      linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    padding:22px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    min-height:500px;\n  }\n\n  svg.trie {\n    width:100%;\n    height:100%;\n    overflow:visible;\n  }\n\n  /* Node style */\n  .node {\n    transform-origin:center;\n    transition: transform 420ms cubic-bezier(.15,.9,.25,1), opacity 420ms, filter 420ms;\n    opacity:1;\n    filter: drop-shadow(0 12px 24px rgba(6,10,30,0.6));\n  }\n\n  .node.hidden {\n    opacity:0;\n    transform: translateY(20px) scale(.86);\n    filter: blur(2px) drop-shadow(0 0 0 rgba(0,0,0,0));\n    pointer-events:none;\n  }\n\n  .node circle {\n    fill: url(#gradNode);\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:1;\n    transition: r 340ms, filter 320ms;\n    filter: drop-shadow(0 6px 16px rgba(124,92,255,0.12));\n  }\n\n  .node .label {\n    font-size:14px;\n    font-weight:700;\n    fill: white;\n    paint-order:stroke;\n    stroke: rgba(0,0,0,0.3);\n    stroke-width: 0.4px;\n    pointer-events:none;\n  }\n\n  .node .sub {\n    font-size:10px;\n    fill: rgba(255,255,255,0.75);\n    font-weight:600;\n  }\n\n  .node.active circle {\n    filter: drop-shadow(0 18px 28px rgba(124,92,255,0.26)) saturate(140%) brightness(1.02);\n    transform-origin:center;\n  }\n\n  .node.recent circle {\n    animation: pop 420ms cubic-bezier(.2,.9,.2,1);\n  }\n  @keyframes pop {\n    0% { transform: scale(.2) translateY(8px); opacity:0; }\n    60% { transform: scale(1.08); opacity:1; }\n    100% { transform: scale(1); }\n  }\n\n  /* Link style */\n  .edge {\n    fill:none;\n    stroke: url(#gradEdge);\n    stroke-width:2.6;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n    opacity:0.95;\n    filter: drop-shadow(0 6px 18px rgba(0,0,0,0.5));\n    transition: stroke-dashoffset 800ms cubic-bezier(.15,.9,.25,1), opacity 420ms;\n  }\n  .edge.hidden {\n    opacity:0;\n  }\n  .edge.drawn {\n    opacity:1;\n  }\n\n  /* small badge for terminal nodes */\n  .terminal {\n    fill: url(#gradTerm);\n    stroke: rgba(255,255,255,0.04);\n  }\n\n  /* info overlay text */\n  .status {\n    position:absolute;\n    left:28px;\n    bottom:22px;\n    font-size:13px;\n    color:var(--muted);\n    display:flex;\n    gap:12px;\n    align-items:center;\n    padding:10px 12px;\n    border-radius:10px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.02);\n  }\n\n  /* footer minimal */\n  .note {\n    font-size:12px;\n    color: rgba(255,255,255,0.6);\n  }\n\n  /* Responsive */\n  @media (max-width:1000px){\n    .stage { grid-template-columns: 1fr; padding:20px; gap:18px; margin:20px; }\n    .canvas { min-height:420px; }\n  }\n</style>\n</head>\n<body>\n<div class=\"grain\" aria-hidden=\"true\"></div>\n\n<div class=\"stage\" role=\"main\" aria-label=\"Trie visualization\">\n  <div class=\"panel\">\n    <div style=\"display:flex; gap:12px; align-items:center\">\n      <div class=\"logo\" aria-hidden=\"true\">\n        <svg width=\"34\" height=\"34\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"lg\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#FFD5FF\"/>\n              <stop offset=\"1\" stop-color=\"#7C5CFF\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"2.4\" y=\"2.4\" width=\"19.2\" height=\"19.2\" rx=\"5.4\" fill=\"url(#lg)\" opacity=\"0.95\"/>\n          <path d=\"M8 15V9c0-.6.4-1 1-1h6\" stroke=\"white\" stroke-opacity=\"0.98\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <circle cx=\"12\" cy=\"8\" r=\"1.4\" fill=\"white\"/>\n        </svg>\n      </div>\n      <div>\n        <h1>Trie — elegant visual demonstration</h1>\n        <p class=\"subtitle\">A beautiful, minimal animation showing how a Trie (prefix tree) grows as words are inserted.</p>\n      </div>\n    </div>\n\n    <p class=\"description\">Observe the construction: each circle is a node holding a character. Shared prefixes reuse nodes — watch how edges are drawn and nodes appear with graceful motion. This view emphasizes aesthetics and clarity over interactive complexity.</p>\n\n    <div style=\"display:flex; flex-direction:column; gap:8px; margin-top:6px;\">\n      <div style=\"display:flex; gap:8px; align-items:center;\">\n        <div class=\"chip\" title=\"Words inserted during the demo\">Words inserted</div>\n        <div class=\"words\" aria-hidden=\"true\">\n          <div class=\"chip\">art</div>\n          <div class=\"chip\">arrow</div>\n          <div class=\"chip\">arch</div>\n          <div class=\"chip\">bat</div>\n          <div class=\"chip\">ball</div>\n          <div class=\"chip\">banana</div>\n          <div class=\"chip\">cat</div>\n          <div class=\"chip\">car</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"controls\" aria-hidden=\"false\">\n      <button id=\"btnPlay\" class=\"btn primary\" title=\"Animate the insertion sequence\">\n        ▶︎ Animate\n      </button>\n      <button id=\"btnReset\" class=\"btn ghost\" title=\"Reset the visualization\">\n        ⟲ Reset\n      </button>\n    </div>\n\n    <div style=\"display:flex; gap:12px; margin-top:10px;\">\n      <div style=\"flex:1\">\n        <div class=\"note\"><strong style=\"color:var(--accent-2)\">Concept</strong> — a Trie stores prefixes. Shared prefixes reuse the same nodes, so look for collapses and reused subtrees.</div>\n      </div>\n    </div>\n\n    <div class=\"meta\" style=\"margin-top:12px;\">\n      <div class=\"note\">Visually focused • Minimal controls</div>\n      <div class=\"note\">Sequence-driven animation</div>\n    </div>\n  </div>\n\n  <div class=\"canvas\" aria-hidden=\"false\">\n    <svg class=\"trie\" viewBox=\"0 0 1000 640\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Trie visualization canvas\">\n      <defs>\n        <linearGradient id=\"gradNode\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n          <stop offset=\"0\" stop-color=\"#ffffff\" stop-opacity=\"0.06\"/>\n          <stop offset=\"0.28\" stop-color=\"#7c5cff\" stop-opacity=\"0.12\"/>\n          <stop offset=\"1\" stop-color=\"#00d4ff\" stop-opacity=\"0.14\"/>\n        </linearGradient>\n        <linearGradient id=\"gradEdge\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n          <stop offset=\"0.5\" stop-color=\"#00d4ff\"/>\n          <stop offset=\"1\" stop-color=\"#ff7ab6\"/>\n        </linearGradient>\n        <linearGradient id=\"gradTerm\" x1=\"0\" x2=\"1\">\n          <stop offset=\"0\" stop-color=\"#6ee7b7\"/>\n          <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n        </linearGradient>\n        <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n          <feGaussianBlur stdDeviation=\"6\" result=\"b\"/>\n          <feBlend in=\"SourceGraphic\" in2=\"b\"/>\n        </filter>\n      </defs>\n\n      <!-- Edges inserted dynamically -->\n      <g id=\"edges\" />\n\n      <!-- Nodes inserted dynamically -->\n      <g id=\"nodes\" />\n\n      <!-- Terminal markers -->\n      <g id=\"terms\" />\n    </svg>\n\n    <div class=\"status\" id=\"status\">\n      <div id=\"statusText\">Ready • Press \"Animate\" to begin</div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n(function(){\n  // Minimal interactivity: Animate + Reset\n  const words = [\"art\",\"arrow\",\"arch\",\"bat\",\"ball\",\"banana\",\"cat\",\"car\"];\n  const insertDelay = 520; // time per letter step\n  const traverseDelay = 320;\n  const extraPauseAfterWord = 400;\n\n  // Build trie and record creation sequence\n  let nodeIdCounter = 0;\n  function createNode(letter, parent=null, depth=0){\n    return {\n      id: ++nodeIdCounter,\n      letter: letter,\n      parent: parent, // id or null\n      children: {},\n      depth: depth,\n      createdAt: null, // sequence number of creation\n      x:0, y:0,\n      subtreeWidth: 0\n    };\n  }\n\n  // Build insertion plan\n  let root, steps, creationSeq;\n  function prepareTrie(){\n    nodeIdCounter = 0;\n    root = createNode(\"•\", null, 0);\n    root.createdAt = 0; // root visible\n    creationSeq = 0;\n    steps = [];\n    words.forEach((w, wi) => {\n      let cur = root;\n      for(let i=0;i<w.length;i++){\n        const ch = w[i];\n        if(!cur.children[ch]){\n          // create new node\n          const n = createNode(ch, cur.id, cur.depth+1);\n          n.createdAt = ++creationSeq;\n          cur.children[ch] = n;\n          steps.push({ type: 'create', nodeId: n.id, letter: ch, depth: n.depth, wordIndex:wi, letterIndex:i });\n          cur = n;\n        } else {\n          // traverse existing\n          cur = cur.children[ch];\n          steps.push({ type: 'traverse', nodeId: cur.id, letter: ch, depth: cur.depth, wordIndex:wi, letterIndex:i });\n        }\n      }\n      // Mark terminal – we will add small badge but node already exists\n      steps.push({ type:'terminal', nodeId: cur.id, wordIndex:wi });\n    });\n\n    // Build map for easy lookup (by id)\n    const map = {};\n    function walk(n){\n      map[n.id] = n;\n      for(const k in n.children) walk(n.children[k]);\n    }\n    walk(root);\n\n    // Convert children from objects to map of ids for layout convenience\n    // But we'll keep direct references\n    // Compute subtree widths\n    function computeWidth(n){\n      if(Object.keys(n.children).length===0){ n.subtreeWidth = 1; return 1; }\n      let s = 0; for(const k in n.children) s += computeWidth(n.children[k]);\n      n.subtreeWidth = s || 1; return n.subtreeWidth;\n    }\n    computeWidth(root);\n\n    // Layout positions: top-down\n    const startX = 100; const endX = 900;\n    const totalWidth = endX - startX;\n    function assignPos(n, xOffset, widthUnit){\n      // center for this node: at xOffset + half of its subtree * widthUnit\n      const centerX = xOffset + (n.subtreeWidth * widthUnit)/2;\n      n.x = centerX;\n      n.y = 60 + n.depth * 92;\n      // iterate children\n      let curX = xOffset;\n      for(const k in n.children){\n        const child = n.children[k];\n        const w = child.subtreeWidth * widthUnit;\n        assignPos(child, curX, widthUnit);\n        curX += w;\n      }\n    }\n    const widthUnit = totalWidth / root.subtreeWidth;\n    assignPos(root, startX, widthUnit);\n\n    return { root, steps, map };\n  }\n\n  // Render trie skeleton (nodes hidden)\n  const svg = document.querySelector('svg.trie');\n  const gNodes = svg.querySelector('#nodes');\n  const gEdges = svg.querySelector('#edges');\n  const gTerms = svg.querySelector('#terms');\n  const statusText = document.getElementById('statusText');\n  let map = {};\n  let running = false;\n  let animationHandle = null;\n\n  function clearSVG(){\n    gNodes.innerHTML = '';\n    gEdges.innerHTML = '';\n    gTerms.innerHTML = '';\n  }\n\n  function renderSkeleton(data){\n    map = data.map;\n    clearSVG();\n    // First edges (we will hide them then draw)\n    for(const id in map){\n      const node = map[id];\n      if(node.parent){\n        // find parent's coordinates\n        const parent = map[node.parent];\n        const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n        const dx = node.x - parent.x;\n        const dy = node.y - parent.y;\n        const cx1 = parent.x;\n        const cy1 = parent.y + 18;\n        const cx2 = node.x;\n        const cy2 = node.y - 18;\n        const d = `M ${cx1} ${cy1} C ${cx1} ${cy1+28}, ${cx2} ${cy2-28}, ${cx2} ${cy2}`;\n        path.setAttribute('d', d);\n        path.setAttribute('class','edge hidden');\n        path.setAttribute('id','edge-'+node.id);\n        // prepare stroke length for draw animation\n        gEdges.appendChild(path);\n      }\n    }\n\n    // Nodes\n    for(const id in map){\n      const node = map[id];\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform', `translate(${node.x}, ${node.y})`);\n      g.setAttribute('class','node');\n      g.setAttribute('id','node-'+node.id);\n\n      // circle\n      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      circle.setAttribute('r', 22);\n      circle.setAttribute('cx', 0);\n      circle.setAttribute('cy', 0);\n      g.appendChild(circle);\n\n      // label (letter)\n      const lab = document.createElementNS('http://www.w3.org/2000/svg','text');\n      lab.setAttribute('class','label');\n      lab.setAttribute('x', 0);\n      lab.setAttribute('y', 6);\n      lab.setAttribute('text-anchor','middle');\n      lab.textContent = node.letter === '•' ? '' : node.letter.toUpperCase();\n      g.appendChild(lab);\n\n      // small subtext showing depth for subtlety\n      const sub = document.createElementNS('http://www.w3.org/2000/svg','text');\n      sub.setAttribute('class','sub');\n      sub.setAttribute('x', 0);\n      sub.setAttribute('y', 36);\n      sub.setAttribute('text-anchor','middle');\n      sub.textContent = node.depth === 0 ? 'root' : '';\n      g.appendChild(sub);\n\n      // attach to nodes group\n      gNodes.appendChild(g);\n      // terminal badge (hidden until terminal step)\n      const term = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      term.setAttribute('class','terminal');\n      term.setAttribute('r',6);\n      term.setAttribute('cx', node.x + 28);\n      term.setAttribute('cy', node.y - 6);\n      term.setAttribute('id','term-'+node.id);\n      term.style.opacity = 0;\n      gTerms.appendChild(term);\n\n      // initial state: hide if node.createdAt > 0\n      if(node.createdAt && node.createdAt > 0){\n        g.classList.add('hidden');\n      }\n    }\n\n    // For each edge, set stroke dash to full length for draw animation\n    // compute lengths after appended\n    const edges = gEdges.querySelectorAll('path');\n    edges.forEach(p => {\n      const len = p.getTotalLength();\n      p.style.strokeDasharray = len + ' ' + len;\n      p.style.strokeDashoffset = len;\n      // edges hidden remain with dashoffset = len\n      p.classList.add('hidden');\n    });\n  }\n\n  // Utility to set active class for brief highlight\n  function pulseNode(nodeId, cls='active', t=350){\n    const g = document.getElementById('node-'+nodeId);\n    if(!g) return;\n    g.classList.add(cls);\n    setTimeout(()=> g.classList.remove(cls), t);\n  }\n\n  // Animate sequence\n  async function animateSequence(data){\n    if(running) return;\n    running = true;\n    document.getElementById('btnPlay').disabled = true;\n    document.getElementById('btnReset').disabled = true;\n    statusText.textContent = 'Animating insertions...';\n    const nodesGroup = gNodes;\n    const edgesGroup = gEdges;\n    const termsGroup = gTerms;\n\n    // Helper to reveal node with pop\n    function revealNode(node){\n      const g = document.getElementById('node-'+node.id);\n      if(!g) return;\n      g.classList.remove('hidden');\n      g.classList.add('recent');\n      // small bounce effect removed after\n      setTimeout(()=> g.classList.remove('recent'), 900);\n    }\n\n    // Helper to draw edge\n    function drawEdge(node){\n      const p = document.getElementById('edge-'+node.id);\n      if(!p) return;\n      p.classList.remove('hidden');\n      // animate dashoffset to 0\n      const len = p.getTotalLength();\n      // Cancel transitions by forcing style and then animating\n      p.style.transition = 'none';\n      p.style.strokeDashoffset = len;\n      requestAnimationFrame(()=>{\n        p.style.transition = 'stroke-dashoffset 640ms cubic-bezier(.2,.9,.25,1), opacity 300ms';\n        p.style.strokeDashoffset = 0;\n        p.classList.add('drawn');\n      });\n    }\n\n    // Helper to show terminal marker\n    function showTerminal(node){\n      const t = document.getElementById('term-'+node.id);\n      if(!t) return;\n      t.style.transition = 'opacity 420ms cubic-bezier(.2,.9,.25,1), transform 420ms';\n      t.style.opacity = 1;\n      t.style.transform = 'translateY(-4px)';\n    }\n\n    // Run through steps\n    for(let i=0;i<data.steps.length;i++){\n      const st = data.steps[i];\n      if(!running) break;\n      if(st.type === 'traverse'){\n        pulseNode(st.nodeId, 'active', traverseDelay - 60);\n        statusText.textContent = `Traversing \"${words[st.wordIndex]}\" — letter \"${st.letter.toUpperCase()}\"`;\n        await wait(traverseDelay);\n      } else if(st.type === 'create'){\n        // reveal node and its connecting edge\n        const node = data.map[st.nodeId];\n        // first draw edge from parent\n        drawEdge(node);\n        // little delay then reveal node\n        await wait(120);\n        revealNode(node);\n        pulseNode(st.nodeId, 'active', 420);\n        statusText.textContent = `Inserting \"${words[st.wordIndex]}\" — creating \"${st.letter.toUpperCase()}\"`;\n        await wait(insertDelay);\n      } else if(st.type === 'terminal'){\n        // mark terminal\n        const node = data.map[st.nodeId];\n        showTerminal(node);\n        statusText.textContent = `Word \"${words[st.wordIndex]}\" inserted`;\n        await wait(extraPauseAfterWord);\n      }\n    }\n\n    statusText.textContent = 'Completed • All words inserted';\n    running = false;\n    document.getElementById('btnPlay').disabled = false;\n    document.getElementById('btnReset').disabled = false;\n  }\n\n  function wait(ms){\n    return new Promise(res => {\n      const id = setTimeout(()=>{ clearTimeout(id); res(); }, ms);\n    });\n  }\n\n  // Initialize\n  let prepared = prepareTrie();\n  renderSkeleton(prepared);\n\n  // Buttons\n  const btnPlay = document.getElementById('btnPlay');\n  const btnReset = document.getElementById('btnReset');\n\n  btnPlay.addEventListener('click', async function(){\n    if(running) return;\n    // refresh prepared data to ensure consistent creation times\n    prepared = prepareTrie();\n    renderSkeleton(prepared);\n    animateSequence(prepared);\n  });\n\n  btnReset.addEventListener('click', function(){\n    // stop running animation\n    if(running){\n      // practical approach: just reload initial skeleton after small cancel\n      running = false;\n      setTimeout(()=> {\n        prepared = prepareTrie();\n        renderSkeleton(prepared);\n        statusText.textContent = 'Reset • Ready';\n      }, 60);\n    } else {\n      prepared = prepareTrie();\n      renderSkeleton(prepared);\n      statusText.textContent = 'Reset • Ready';\n    }\n  });\n\n  // Make initial tiny breathing animation on root node\n  (function breatheRoot(){\n    const rootNode = document.getElementById('node-1');\n    if(!rootNode) return;\n    rootNode.classList.remove('hidden');\n    rootNode.style.transition = 'transform 1200ms ease-in-out';\n    let dir = 0;\n    setInterval(()=> {\n      if(!rootNode) return;\n      rootNode.style.transform = `translate(${0}px, ${0}px) scale(${1 + 0.008 * (dir?1:-1)})`;\n      dir = 1-dir;\n    }, 2200);\n  })();\n\n})();\n</script>\n</body>\n</html>"
