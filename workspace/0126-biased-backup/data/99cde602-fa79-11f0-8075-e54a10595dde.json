    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Circular Linked List Demonstration</title>\n</head>\n<body>\n\n<h1>Circular Linked List Demonstration</h1>\n\n<div>\n    <h2>Controls</h2>\n    <input type=\"text\" id=\"nodeInput\" placeholder=\"Enter node value\">\n    <button onclick=\"addNode()\">Add Node</button>\n    <button onclick=\"deleteNode()\">Delete Node</button>\n    <button onclick=\"viewList()\">View List</button>\n    <button onclick=\"traverseList()\">Traverse List</button>\n    <input type=\"number\" id=\"traverseCount\" placeholder=\"Steps to traverse\">\n</div>\n\n<div>\n    <h2>List Operations</h2>\n    <p id=\"listOutput\"></p>\n</div>\n\n<script>\n    class Node {\n        constructor(data) {\n            this.data = data;\n            this.next = null;\n        }\n    }\n\n    class CircularLinkedList {\n        constructor() {\n            this.head = null;\n            this.tail = null;\n        }\n\n        addNode(data) {\n            const newNode = new Node(data);\n            if (!this.head) {\n                this.head = newNode;\n                this.tail = newNode;\n                newNode.next = newNode; // Point to itself\n            } else {\n                this.tail.next = newNode;\n                newNode.next = this.head;\n                this.tail = newNode;\n            }\n        }\n\n        deleteNode() {\n            if (!this.head) return; // List is empty\n            if (this.head === this.tail) {\n                this.head = null;\n                this.tail = null;\n                return;\n            }\n            this.tail.next = this.head.next;\n            this.head = this.head.next;\n        }\n\n        traverse(steps) {\n            if (!this.head) return \"\";\n            let current = this.head;\n            let output = '';\n            for (let i = 0; i < steps; i++) {\n                output += current.data + \" \";\n                current = current.next;\n            }\n            return output.trim();\n        }\n\n        viewList() {\n            if (!this.head) return \"List is empty\";\n            let output = [];\n            let current = this.head;\n            do {\n                output.push(current.data);\n                current = current.next;\n            } while (current !== this.head);\n            return output.join(\" -> \");\n        }\n    }\n\n    const circularList = new CircularLinkedList();\n\n    function addNode() {\n        const value = document.getElementById('nodeInput').value;\n        if (value) {\n            circularList.addNode(value);\n            document.getElementById('nodeInput').value = '';\n            alert(\"Node added: \" + value);\n        }\n    }\n\n    function deleteNode() {\n        circularList.deleteNode();\n        alert(\"Node deleted.\");\n    }\n\n    function viewList() {\n        const output = circularList.viewList();\n        document.getElementById('listOutput').innerText = \"List: \" + output;\n    }\n\n    function traverseList() {\n        const steps = parseInt(document.getElementById('traverseCount').value) || 0;\n        const output = circularList.traverse(steps);\n        document.getElementById('listOutput').innerText = \"Traversed: \" + output;\n    }\n</script>\n</body>\n</html>"
