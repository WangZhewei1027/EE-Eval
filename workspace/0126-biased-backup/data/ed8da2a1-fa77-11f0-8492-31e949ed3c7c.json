    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #181818;\n            color: #F0F0F0;\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n        }\n\n        .container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            text-align: center;\n        }\n\n        h1 {\n            font-size: 2.5em;\n            margin-bottom: 0.5em;\n            color: #00FFC3;\n        }\n\n        p {\n            font-size: 1.2em;\n            margin-bottom: 1.5em;\n            max-width: 600px;\n        }\n\n        .graph-container {\n            display: flex;\n            align-items: flex-end;\n            justify-content: center;\n            width: 80%;\n            height: 300px;\n            position: relative;\n            overflow: hidden;\n            border: 2px solid #00FFC3;\n            border-radius: 10px;\n            background-color: rgba(0, 0, 0, 0.5);\n        }\n\n        .bar {\n            width: 30px;\n            margin: 0 5px;\n            background-color: #00FFC3;\n            transition: height 0.5s ease, background-color 0.5s ease;\n        }\n\n        .bar.active {\n            background-color: #FF6F61;\n        }\n\n        .bar.selected {\n            background-color: #FFCE54;\n            height: 100%;\n        }\n\n        button {\n            padding: 10px 20px;\n            margin-top: 20px;\n            font-size: 1em;\n            color: #181818;\n            background-color: #00FFC3;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n        }\n\n        button:hover {\n            background-color: #00695C;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <h1>Binary Search Visualization</h1>\n        <p>Observe the binary search algorithm in action as it finds the target value in a sorted array. Click \"Start\"\n            to see the effect!</p>\n        <div class=\"graph-container\" id=\"graph-container\"></div>\n        <button id=\"start-btn\">Start</button>\n    </div>\n\n    <script>\n        const array = [3, 6, 9, 12, 15, 18, 21, 24, 27, 30, 33, 36, 39];\n        const target = 21;\n        let left = 0;\n        let right = array.length - 1;\n\n        const graphContainer = document.getElementById('graph-container');\n\n        function createBars() {\n            graphContainer.innerHTML = '';\n            array.forEach(num => {\n                const bar = document.createElement('div');\n                bar.className = 'bar';\n                bar.style.height = `${(num / 39) * 100}%`;\n                graphContainer.appendChild(bar);\n            });\n        }\n\n        function highlightActive(index) {\n            const bars = document.querySelectorAll('.bar');\n            bars.forEach((bar, i) => {\n                bar.classList.remove('active');\n                if (i === index) {\n                    bar.classList.add('active');\n                }\n            });\n        }\n\n        async function binarySearch() {\n            while (left <= right) {\n                const mid = Math.floor((left + right) / 2);\n                highlightActive(mid);\n                \n                if (array[mid] === target) {\n                    const bars = document.querySelectorAll('.bar');\n                    bars[mid].classList.add('selected');\n                    return;\n                } else if (array[mid] < target) {\n                    left = mid + 1;\n                } else {\n                    right = mid - 1;\n                }\n\n                await new Promise(resolve => setTimeout(resolve, 1000)); // wait for a second\n            }\n        }\n\n        document.getElementById('start-btn').addEventListener('click', () => {\n            createBars();\n            binarySearch();\n        });\n    </script>\n</body>\n\n</html>"
