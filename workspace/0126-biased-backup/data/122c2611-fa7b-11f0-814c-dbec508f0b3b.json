                grid[i][j] = 1;\n                    }\n                }\n            }\n            let x = start[0];\n            let y = start[1];\n            let path = [];\n            while (x !== end[0] || y !== end[1]) {\n                path.push([x, y]);\n                let dx = Math.abs(x - end[0]);\n                let dy = Math.abs(y - end[1]);\n                let dx2 = Math.min(dx, dy);\n                dx /= dx2;\n                dy /= dx2;\n                let nx = x + dx * dx2;\n                let ny = y + dy * dx2;\n                if (nx >= 0 && nx < grid.length && ny >= 0 && ny < grid[0].length && grid[nx][ny] !== -1) {\n                    x = nx;\n                    y = ny;\n                } else {\n                    x = end[0];\n                    y = end[1];\n                }\n            }\n            for (let i = 0; i < grid.length; i++) {\n                for (let j = 0; j < grid[0].length; j++) {\n                    if (grid[i][j] === -1) {\n                        grid[i][j] = 1;\n                    }\n                }\n            }\n            updatePath();\n        }\n        function updatePath() {\n            let x = start[0];\n            let y = start[1];\n            while (x !== end[0] || y !== end[1]) {\n                path.push([x, y]);\n                let dx = Math.abs(x - end[0]);\n                let dy = Math.abs(y - end[1]);\n                let dx2 = Math.min(dx, dy);\n                dx /= dx2;\n                dy /= dx2;\n                let nx = x + dx * dx2;\n                let ny = y + dy * dx2;\n                if (nx >= 0 && nx < grid.length && ny >= 0 && ny < grid[0].length && grid[nx][ny] !== -1) {\n                    x = nx;\n                    y = ny;\n                } else {\n                    x = end[0];\n                    y = end[1];\n                }\n            }\n            for (let i = 0; i < grid.length; i++) {\n                for (let j = 0; j < grid[0].length; j++) {\n 