    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Breadth-First Search | Visual Elegance</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --highlight: #00cec9;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 2rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            color: var(--primary);\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization-container {\n            width: 90%;\n            max-width: 1000px;\n            height: 500px;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 30px 60px -12px rgba(50, 50, 93, 0.25),\n                        0 18px 36px -18px rgba(0, 0, 0, 0.3);\n            position: relative;\n            overflow: hidden;\n            margin: 2rem 0;\n            padding: 2rem;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n\n        .graph {\n            width: 100%;\n            height: 100%;\n            position: relative;\n        }\n\n        .node {\n            position: absolute;\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background: var(--primary);\n            color: white;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: bold;\n            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.3);\n            cursor: default;\n            transition: all 0.3s ease;\n            z-index: 10;\n        }\n\n        .edge {\n            position: absolute;\n            height: 3px;\n            background: var(--secondary);\n            transform-origin: left center;\n            z-index: 1;\n            opacity: 0.7;\n        }\n\n        .visited {\n            background: var(--highlight);\n            box-shadow: 0 10px 20px rgba(0, 206, 201, 0.3);\n            transform: scale(1.1);\n        }\n\n        .current {\n            background: var(--accent);\n            box-shadow: 0 10px 20px rgba(253, 121, 168, 0.3);\n            transform: scale(1.2);\n        }\n\n        .queue-display {\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            display: flex;\n            align-items: center;\n            background: rgba(255, 255, 255, 0.9);\n            padding: 1rem 2rem;\n            border-radius: 50px;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);\n        }\n\n        .queue-title {\n            margin-right: 1rem;\n            font-weight: 600;\n            color: var(--primary);\n        }\n\n        .queue-item {\n            width: 30px;\n            height: 30px;\n            border-radius: 50%;\n            background: var(--primary);\n            color: white;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            margin: 0 5px;\n            font-size: 0.8rem;\n            transition: all 0.3s ease;\n        }\n\n        .queue-item.current {\n            background: var(--accent);\n            transform: scale(1.2);\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 1rem;\n        }\n\n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: var(--primary);\n            color: white;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.6);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button.secondary {\n            background: var(--light);\n            color: var(--primary);\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            margin-bottom: 0.5rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n            margin-right: 0.5rem;\n        }\n\n        .legend-text {\n            font-size: 0.9rem;\n            color: var(--dark);\n            opacity: 0.8;\n        }\n\n        .explanation {\n            max-width: 800px;\n            margin: 2rem auto;\n            padding: 2rem;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n            line-height: 1.6;\n            animation: fadeIn 2s ease-out;\n        }\n\n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-weight: 400;\n        }\n\n        .explanation p {\n            margin-bottom: 1rem;\n            color: var(--dark);\n            opacity: 0.9;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.1); }\n            100% { transform: scale(1); }\n        }\n\n        .pulse {\n            animation: pulse 1.5s infinite;\n        }\n\n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            color: var(--dark);\n            opacity: 0.6;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Breadth-First Search</h1>\n        <p class=\"subtitle\">A visual journey through graph traversal that explores all neighbors at the present depth before moving on to nodes at the next depth level.</p>\n    </header>\n\n    <div class=\"visualization-container\">\n        <div class=\"graph\" id=\"graph\"></div>\n        <div class=\"queue-display\" id=\"queue\">\n            <span class=\"queue-title\">Queue:</span>\n            <!-- Queue items will be added here dynamically -->\n        </div>\n    </div>\n\n    <div class=\"controls\">\n        <button id=\"startBtn\">Start Visualization</button>\n        <button id=\"resetBtn\" class=\"secondary\">Reset</button>\n    </div>\n\n    <div class=\"legend\">\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: var(--primary);\"></div>\n            <span class=\"legend-text\">Unvisited Node</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: var(--highlight);\"></div>\n            <span class=\"legend-text\">Visited Node</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: var(--accent);\"></div>\n            <span class=\"legend-text\">Current Node</span>\n        </div>\n    </div>\n\n    <div class=\"explanation\">\n        <h2>Understanding Breadth-First Search</h2>\n        <p>Breadth-First Search (BFS) is an algorithm for traversing or searching tree or graph data structures. It starts at the tree root (or some arbitrary node of a graph) and explores all of the neighbor nodes at the present depth prior to moving on to nodes at the next depth level.</p>\n        <p>The algorithm uses a queue to keep track of which nodes to visit next. When a node is visited, its unvisited neighbors are added to the queue. This ensures that nodes are visited in the order they were discovered, resulting in a level-by-level traversal.</p>\n        <p>BFS is particularly useful for finding the shortest path in unweighted graphs and for discovering all connected components in a graph.</p>\n    </div>\n\n    <footer>\n        <p>© 2023 BFS Visualization | Designed with elegance</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Graph configuration\n            const graph = {\n                nodes: [\n                    { id: 'A', x: 200, y: 150 },\n                    { id: 'B', x: 350, y: 100 },\n                    { id: 'C', x: 350, y: 200 },\n                    { id: 'D', x: 500, y: 70 },\n                    { id: 'E', x: 500, y: 150 },\n                    { id: 'F', x: 500, y: 230 },\n                    { id: 'G', x: 650, y: 150 }\n                ],\n                edges: [\n                    { from: 'A', to: 'B' },\n                    { from: 'A', to: 'C' },\n                    { from: 'B', to: 'D' },\n                    { from: 'B', to: 'E' },\n                    { from: 'C', to: 'E' },\n                    { from: 'C', to: 'F' },\n                    { from: 'E', to: 'G' },\n                    { from: 'D', to: 'G' }\n                ]\n            };\n\n            // DOM elements\n            const graphContainer = document.getElementById('graph');\n            const queueDisplay = document.getElementById('queue');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n\n            // State variables\n            let animationInterval;\n            let visitedNodes = new Set();\n            let queue = [];\n            let isRunning = false;\n\n            // Initialize the graph\n            function initGraph() {\n                // Clear previous graph\n                graphContainer.innerHTML = '';\n                queueDisplay.innerHTML = '<span class=\"queue-title\">Queue:</span>';\n\n                // Create edges\n                graph.edges.forEach(edge => {\n                    const fromNode = graph.nodes.find(n => n.id === edge.from);\n                    const toNode = graph.nodes.find(n => n.id === edge.to);\n\n                    const edgeElement = document.createElement('div');\n                    edgeElement.className = 'edge';\n\n                    // Calculate edge position and length\n                    const length = Math.sqrt(\n                        Math.pow(toNode.x - fromNode.x, 2) + \n                        Math.pow(toNode.y - fromNode.y, 2)\n                    );\n                    const angle = Math.atan2(\n                        toNode.y - fromNode.y, \n                        toNode.x - fromNode.x\n                    ) * 180 / Math.PI;\n\n                    edgeElement.style.width = `${length}px`;\n                    edgeElement.style.left = `${fromNode.x}px`;\n                    edgeElement.style.top = `${fromNode.y + 25}px`;\n                    edgeElement.style.transform = `rotate(${angle}deg)`;\n\n                    graphContainer.appendChild(edgeElement);\n                });\n\n                // Create nodes\n                graph.nodes.forEach(node => {\n                    const nodeElement = document.createElement('div');\n                    nodeElement.className = 'node';\n                    nodeElement.id = `node-${node.id}`;\n                    nodeElement.textContent = node.id;\n                    nodeElement.style.left = `${node.x - 25}px`;\n                    nodeElement.style.top = `${node.y - 25}px`;\n\n                    graphContainer.appendChild(nodeElement);\n                });\n\n                // Reset state\n                visitedNodes.clear();\n                queue = [];\n                isRunning = false;\n            }\n\n            // Visualize BFS\n            function visualizeBFS() {\n                if (isRunning) return;\n                isRunning = true;\n                startBtn.disabled = true;\n\n                // Start with node A\n                queue.push('A');\n                updateQueueDisplay();\n\n                let step = 0;\n                animationInterval = setInterval(() => {\n                    if (queue.length === 0) {\n                        clearInterval(animationInterval);\n                        isRunning = false;\n                        startBtn.disabled = false;\n                        return;\n                    }\n\n                    // Get current node\n                    const currentNode = queue.shift();\n                    visitedNodes.add(currentNode);\n                    updateQueueDisplay();\n\n                    // Highlight current node\n                    const nodeElement = document.getElementById(`node-${currentNode}`);\n                    nodeElement.classList.remove('visited');\n                    nodeElement.classList.add('current');\n\n                    // After delay, mark as visited and explore neighbors\n                    setTimeout(() => {\n                        nodeElement.classList.remove('current');\n                        nodeElement.classList.add('visited');\n\n                        // Find and add unvisited neighbors to queue\n                        const neighbors = graph.edges\n                            .filter(edge => edge.from === currentNode)\n                            .map(edge => edge.to)\n                            .concat(\n                                graph.edges\n                                .filter(edge => edge.to === currentNode)\n                                .map(edge => edge.from)\n                            )\n                            .filter(node => !visitedNodes.has(node) && !queue.includes(node));\n\n                        neighbors.forEach(neighbor => {\n                            queue.push(neighbor);\n                        });\n\n                        updateQueueDisplay();\n                    }, 1000);\n\n                    step++;\n                }, 1500);\n            }\n\n            // Update queue display\n            function updateQueueDisplay() {\n                // Clear existing queue items\n                while (queueDisplay.children.length > 1) {\n                    queueDisplay.removeChild(queueDisplay.lastChild);\n                }\n\n                // Add current queue items\n                queue.forEach((node, index) => {\n                    const queueItem = document.createElement('div');\n                    queueItem.className = 'queue-item';\n                    if (index === 0) queueItem.classList.add('current');\n                    queueItem.textContent = node;\n                    queueDisplay.appendChild(queueItem);\n                });\n            }\n\n            // Event listeners\n            startBtn.addEventListener('click', visualizeBFS);\n            resetBtn.addEventListener('click', () => {\n                clearInterval(animationInterval);\n                initGraph();\n                startBtn.disabled = false;\n                isRunning = false;\n            });\n\n            // Initialize\n            initGraph();\n        });\n    </script>\n</body>\n</html>"
