    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>OSI Model Interactive Explorer</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .section { margin: 20px 0; }\n        button { margin: 5px; }\n    </style>\n</head>\n<body>\n\n<h1>OSI Model Interactive Explorer</h1>\n\n<div class=\"section\">\n    <h2>OSI Layers</h2>\n    <button onclick=\"selectLayer(1)\">Physical Layer</button>\n    <button onclick=\"selectLayer(2)\">Data Link Layer</button>\n    <button onclick=\"selectLayer(3)\">Network Layer</button>\n    <button onclick=\"selectLayer(4)\">Transport Layer</button>\n    <button onclick=\"selectLayer(5)\">Session Layer</button>\n    <button onclick=\"selectLayer(6)\">Presentation Layer</button>\n    <button onclick=\"selectLayer(7)\">Application Layer</button>\n</div>\n\n<div class=\"section\" id=\"details\">\n    <h2>Layer Details</h2>\n    <p id=\"layerInfo\">Select a layer to see details.</p>\n</div>\n\n<div class=\"section\">\n    <h2>Simulate Data Transmission</h2>\n    <label for=\"dataInput\">Enter Data: </label>\n    <input type=\"text\" id=\"dataInput\">\n    <button onclick=\"transmitData()\">Transmit</button>\n</div>\n\n<div class=\"section\">\n    <h2>Data at Each Layer</h2>\n    <p id=\"layerData\">Data will appear here as it passes through layers.</p>\n</div>\n\n<script>\n    const layerDetails = {\n        1: \"Physical Layer: Transmits raw bits over a physical medium.\",\n        2: \"Data Link Layer: Provides node-to-node data transfer and error detection.\",\n        3: \"Network Layer: Handles the routing of data between devices.\",\n        4: \"Transport Layer: Ensures complete data transfer with flow control.\",\n        5: \"Session Layer: Manages sessions and controls the dialogues.\",\n        6: \"Presentation Layer: Translates data formats for the application layer.\",\n        7: \"Application Layer: Provides network services to the end user.\"\n    };\n\n    function selectLayer(layer) {\n        document.getElementById('layerInfo').innerText = layerDetails[layer];\n    }\n\n    function transmitData() {\n        let data = document.getElementById('dataInput').value;\n        if (!data) {\n            alert(\"Please enter some data to transmit.\");\n            return;\n        }\n        let processingData = data;\n        let result = [];\n        for (let i = 1; i <= 7; i++) {\n            processingData = `Layer ${i}: ${processingData}`;\n            result.push(processingData);\n        }\n        document.getElementById('layerData').innerText = result.join(\"\\n\");\n    }\n</script>\n\n</body>\n</html>"
