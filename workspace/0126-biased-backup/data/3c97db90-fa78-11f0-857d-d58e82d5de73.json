    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Kruskal’s Algorithm — Elegant Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n  /* Reset & base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  html, body {\n    margin:0; padding:0; height:100%;\n    background: linear-gradient(135deg, #1e2024, #272b35);\n    font-family: 'Poppins', sans-serif;\n    color: #f4f5f7;\n    overflow: hidden;\n    user-select: none;\n  }\n  body {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 2rem 1rem 3rem;\n    min-height: 100vh;\n  }\n  h1 {\n    font-weight: 600;\n    font-size: 3.2rem;\n    margin: 0 0 1rem 0;\n    letter-spacing: 0.04em;\n    text-align: center;\n    text-shadow:\n      0 0 10px #6ee7b7cc,\n      0 0 20px #3bcf99cc;\n  }\n  h2 {\n    font-weight: 300;\n    font-size: 1.15rem;\n    letter-spacing: 0.06em;\n    margin: 0 0 3rem 0;\n    color: #9ca3afcc;\n    text-align: center;\n  }\n  #container {\n    position: relative;\n    width: 720px;\n    max-width: 90vw;\n    aspect-ratio: 1 / 1;\n    background: radial-gradient(ellipse at center, #15171b, #22272f);\n    border-radius: 1.5rem;\n    box-shadow:\n      inset 0 0 50px #3bcf9980,\n      0 0 40px #3bcf9970;\n    padding: 2rem;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  svg {\n    width: 100%;\n    height: 100%;\n    overflow: visible;\n  }\n  /* Nodes and edges */\n  circle.node {\n    fill: #272e38;\n    stroke: #3bcf99;\n    stroke-width: 3px;\n    filter: drop-shadow(0 0 4px #3bcf99aa);\n    transition: fill 0.4s ease, stroke-width 0.4s ease;\n    cursor: default;\n  }\n  circle.node.active {\n    fill: #6ee7b7;\n    stroke-width: 6px;\n    filter: drop-shadow(0 0 16px #6ee7b7dd);\n  }\n  text.node-label {\n    font-weight: 600;\n    font-size: 1.2rem;\n    fill: #a5f3d1;\n    pointer-events: none;\n    filter: drop-shadow(0 0 2px #095235cc);\n    user-select: none;\n  }\n  line.edge {\n    stroke: #475762;\n    stroke-width: 2.5px;\n    filter: drop-shadow(0 0 3px #475762bb);\n    transition: stroke 0.6s ease, stroke-width 0.6s ease, filter 0.6s ease;\n    vector-effect: non-scaling-stroke;\n  }\n  line.edge.selected {\n    stroke: #6ee7b7;\n    stroke-width: 4.5px;\n    filter:\n      drop-shadow(0 0 15px #6ee7b7cc)\n      drop-shadow(0 0 8px #3bcf99cc);\n  }\n  /* Button */\n  #controls {\n    margin-top: 2.5rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.5rem;\n  }\n  button {\n    background: linear-gradient(145deg, #1b4739, #54d1a7);\n    border: none;\n    border-radius: 9999px;\n    padding: 0.75rem 2.25rem;\n    font-weight: 600;\n    letter-spacing: 0.06em;\n    font-size: 1rem;\n    color: #f0fdf9;\n    box-shadow:\n      0 6px 16px #235d45cc,\n      inset 0 -3px 12px #70f0b8cc;\n    cursor: pointer;\n    user-select: none;\n    transition:\n      box-shadow 0.3s ease,\n      transform 0.2s ease,\n      background 0.3s ease;\n  }\n  button:hover {\n    background: linear-gradient(145deg, #3bcf99, #87eac0);\n    box-shadow:\n      0 8px 28px #37b57edd,\n      inset 0 -4px 14px #a4fefbcc;\n    transform: translateY(-2px);\n  }\n  button:disabled {\n    cursor: default;\n    opacity: 0.4;\n    box-shadow: none;\n  }\n  /* Footer text */\n  footer {\n    position: fixed;\n    bottom: 1rem;\n    width: 100%;\n    font-size: 0.85rem;\n    text-align: center;\n    color: #3bcf9977;\n    font-weight: 300;\n    letter-spacing: 0.07em;\n    filter: drop-shadow(0 0 3px #235d45bb);\n  }\n  /* Animations */\n  @keyframes pulseGlow {\n    0%, 100% {\n      filter: drop-shadow(0 0 14px #6ee7b7cc);\n    }\n    50% {\n      filter: drop-shadow(0 0 24px #3bcf99ff);\n    }\n  }\n</style>\n</head>\n<body>\n<h1>Kruskal’s Algorithm</h1>\n<h2>Minimum Spanning Tree Visualization</h2>\n<div id=\"container\" aria-label=\"Visualization of Kruskal’s algorithm on a weighted graph\">\n  <svg viewBox=\"0 0 720 720\" aria-hidden=\"true\" role=\"img\" >\n    <!-- Edges -->\n    <line class=\"edge\" data-index=\"0\" x1=\"150\" y1=\"130\" x2=\"580\" y2=\"140\" />\n    <line class=\"edge\" data-index=\"1\" x1=\"150\" y1=\"130\" x2=\"390\" y2=\"560\" />\n    <line class=\"edge\" data-index=\"2\" x1=\"580\" y1=\"140\" x2=\"390\" y2=\"560\" />\n    <line class=\"edge\" data-index=\"3\" x1=\"580\" y1=\"140\" x2=\"440\" y2=\"390\" />\n    <line class=\"edge\" data-index=\"4\" x1=\"390\" y1=\"560\" x2=\"440\" y2=\"390\" />\n    <line class=\"edge\" data-index=\"5\" x1=\"150\" y1=\"130\" x2=\"240\" y2=\"350\" />\n    <line class=\"edge\" data-index=\"6\" x1=\"240\" y1=\"350\" x2=\"440\" y2=\"390\" />\n    <line class=\"edge\" data-index=\"7\" x1=\"240\" y1=\"350\" x2=\"390\" y2=\"560\" />\n    <line class=\"edge\" data-index=\"8\" x1=\"440\" y1=\"390\" x2=\"580\" y2=\"140\" />\n    <line class=\"edge\" data-index=\"9\" x1=\"240\" y1=\"350\" x2=\"580\" y2=\"140\" />\n    <!-- Weights (edges labels) -->\n    <text class=\"edge-weight\" x=\"370\" y=\"110\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">7</text>\n    <text class=\"edge-weight\" x=\"280\" y=\"380\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">6</text>\n    <text class=\"edge-weight\" x=\"480\" y=\"360\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">10</text>\n    <text class=\"edge-weight\" x=\"500\" y=\"270\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">9</text>\n    <text class=\"edge-weight\" x=\"410\" y=\"480\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">4</text>\n    <text class=\"edge-weight\" x=\"200\" y=\"300\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">3</text>\n    <text class=\"edge-weight\" x=\"370\" y=\"380\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">2</text>\n    <text class=\"edge-weight\" x=\"320\" y=\"480\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">8</text>\n    <text class=\"edge-weight\" x=\"520\" y=\"190\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">5</text>\n    <text class=\"edge-weight\" x=\"380\" y=\"300\" fill=\"#55dca9\" font-weight=\"600\" font-size=\"1rem\" filter=\"drop-shadow(0 0 1px #09391f)\">11</text>\n    <!-- Nodes -->\n    <g class=\"node-group\" transform=\"translate(150 130)\">\n      <circle class=\"node\" r=\"20\" />\n      <text class=\"node-label\" text-anchor=\"middle\" alignment-baseline=\"middle\">A</text>\n    </g>\n    <g class=\"node-group\" transform=\"translate(580 140)\">\n      <circle class=\"node\" r=\"20\" />\n      <text class=\"node-label\" text-anchor=\"middle\" alignment-baseline=\"middle\">B</text>\n    </g>\n    <g class=\"node-group\" transform=\"translate(240 350)\">\n      <circle class=\"node\" r=\"20\" />\n      <text class=\"node-label\" text-anchor=\"middle\" alignment-baseline=\"middle\">C</text>\n    </g>\n    <g class=\"node-group\" transform=\"translate(440 390)\">\n      <circle class=\"node\" r=\"20\" />\n      <text class=\"node-label\" text-anchor=\"middle\" alignment-baseline=\"middle\">D</text>\n    </g>\n    <g class=\"node-group\" transform=\"translate(390 560)\">\n      <circle class=\"node\" r=\"20\" />\n      <text class=\"node-label\" text-anchor=\"middle\" alignment-baseline=\"middle\">E</text>\n    </g>\n  </svg>\n</div>\n\n<div id=\"controls\" role=\"region\" aria-label=\"Kruskal algorithm controls\">\n  <button id=\"startBtn\" aria-live=\"polite\" aria-pressed=\"false\">Start Visualization</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n\n<footer>\n  Inspired by Kruskal’s algorithm for Minimum Spanning Tree (MST)\n</footer>\n\n<script>\n(() => {\n  'use strict';\n  // Edge data: index matches line element data-index attribute\n  // Format: {u: nodeId, v: nodeId, weight: number}\n  // Node ids 0:A,1:B,2:C,3:D,4:E\n  // Map node id to letter for semantics\n  const nodesMap = ['A','B','C','D','E'];\n\n  // Edge data consistent with svg edges and weights\n  const edgesData = [\n    {u: 0, v:1, weight:7},\n    {u: 0, v:4, weight:6},\n    {u: 1, v:4, weight:10},\n    {u: 1, v:3, weight:9},\n    {u: 4, v:3, weight:4},\n    {u: 0, v:2, weight:3},\n    {u: 2, v:3, weight:2},\n    {u: 2, v:4, weight:8},\n    {u: 3, v:1, weight:5},\n    {u: 2, v:1, weight:11}\n  ];\n\n  // Get svg elements for edges\n  const edgeElements = [...document.querySelectorAll('line.edge')];\n\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Disjoint Set Union (Union Find) for cycle detection\n  class DSU {\n    constructor(n) {\n      this.parent = new Array(n);\n      this.rank = new Array(n);\n      for(let i=0;i<n;i++){\n        this.parent[i] = i;\n        this.rank[i] = 0;\n      }\n    }\n    find(x) {\n      if(this.parent[x] !== x)\n        this.parent[x] = this.find(this.parent[x]);\n      return this.parent[x];\n    }\n    union(a,b) {\n      a = this.find(a);\n      b = this.find(b);\n      if(a===b) return false;\n      if(this.rank[a]<this.rank[b]) {\n        this.parent[a] = b;\n      } else if(this.rank[b]<this.rank[a]) {\n        this.parent[b] = a;\n      } else {\n        this.parent[b] = a;\n        this.rank[a]++;\n      }\n      return true;\n    }\n  }\n\n  // Globals for animation state\n  let animationInProgress = false;\n  let animStep = 0;\n  let animationTimer = null;\n\n  // Sort edges by weight ascending for Kruskal\n  const sortedEdges = [...edgesData].sort((a,b)=>a.weight-b.weight);\n\n  // Clear selections\n  function resetVisualization(){\n    animationInProgress = false;\n    animStep = 0;\n    if(animationTimer) {\n      clearTimeout(animationTimer);\n      animationTimer = null;\n    }\n    // Reset edges style\n    edgeElements.forEach(e => {\n      e.classList.remove('selected');\n      e.style.transition = 'none';\n      e.style.stroke = '';\n      e.style.strokeWidth = '';\n      e.style.filter = '';\n    });\n    // Reset nodes style\n    const nodeCircles = document.querySelectorAll('circle.node');\n    nodeCircles.forEach(n=>{\n      n.classList.remove('active');\n      n.style.transition = 'none';\n      n.style.fill = '';\n      n.style.strokeWidth = '';\n      n.style.filter = '';\n    });\n    startBtn.disabled = false;\n    startBtn.setAttribute('aria-pressed', 'false');\n    resetBtn.disabled = true;\n  }\n\n  // Animate choosing edges & building MST step by step\n  // We highlight each edge considered, then select it or skip it.\n  function animateKruskal(){\n    if(animStep>=sortedEdges.length){\n      // Finish\n      animationInProgress = false;\n      startBtn.disabled = true;\n      resetBtn.disabled = false;\n      startBtn.setAttribute('aria-pressed', 'true');\n      return;\n    }\n    const dsu = new DSU(nodesMap.length);\n\n    // Determine MST edges that have been selected so far\n    // We'll keep track of selected edges in an array to animate.\n    // But animation is one edge per step.\n    // So we keep global MST state for animation to highlight edges cumulatively.\n    if(!animateKruskal.selectedEdges) {\n      animateKruskal.selectedEdges = [];\n    }\n\n    // We try to select edges one by one in sorted order if no cycle\n    for(let i=0; i<animStep; i++){\n      dsu.union(sortedEdges[i].u, sortedEdges[i].v);\n    }\n\n    // Edge currently considered\n    const curEdge = sortedEdges[animStep];\n    const curIndex = edgesData.findIndex(e => e.u === curEdge.u && e.v === curEdge.v && e.weight === curEdge.weight)\n                    !== -1 ? edgesData.findIndex(e => e.u === curEdge.u && e.v === curEdge.v && e.weight === curEdge.weight)\n                    : edgesData.findIndex(e => e.u === curEdge.v && e.v === curEdge.u && e.weight === curEdge.weight);\n\n    // Remove highlight from previous (except selected edges)\n    edgeElements.forEach((el,i)=>{\n      if(!animateKruskal.selectedEdges.includes(i)) {\n        el.classList.remove('selected');\n      }\n    });\n\n    // Highlight current edge with pulse glow\n    const curEdgeEl = edgeElements[curIndex];\n    curEdgeEl.classList.add('selected');\n    curEdgeEl.style.transition = 'stroke 0.8s ease, stroke-width 0.8s ease, filter 0.8s ease';\n    curEdgeEl.style.animation = 'pulseGlow 1.8s ease-in-out';\n    setTimeout(()=>{\n      curEdgeEl.style.animation = '';\n    },1800);\n\n    // After a pause, decide to include or exclude edge from MST\n    setTimeout(() => {\n      const u = curEdge.u;\n      const v = curEdge.v;\n      // If no cycle, union and keep edge selected\n      if(dsu.find(u)!==dsu.find(v)) {\n        dsu.union(u,v);\n        animateKruskal.selectedEdges.push(curIndex);\n\n        // Make the edge glow permanently\n        curEdgeEl.classList.add('selected');\n        curEdgeEl.style.transition = 'stroke 1s ease, stroke-width 1s ease, filter 1s ease';\n\n        // Also highlight connected nodes softly\n        highlightNodes([u,v]);\n\n      } else {\n        // If cycle, edge deselect with a subtle fade\n        curEdgeEl.classList.remove('selected');\n        curEdgeEl.style.stroke = '#6b7280'; // cool gray\n        curEdgeEl.style.strokeWidth = '2px';\n        curEdgeEl.style.filter = 'drop-shadow(0 0 3px #6b728033)';\n        dimNodes([curEdge.u, curEdge.v]);\n      }\n      animStep++;\n      setTimeout(() => {\n        animateKruskal();\n      }, 1700);\n    }, 2200);\n  }\n\n  function highlightNodes(nodeIds){\n    const nodeCircles = document.querySelectorAll('circle.node');\n    nodeCircles.forEach((c,i)=>{\n      if(nodeIds.includes(i)){\n        c.classList.add('active');\n        c.style.animation = 'pulseGlow 2.4s ease-in-out infinite';\n      }\n    });\n  }\n  function dimNodes(nodeIds) {\n    const nodeCircles = document.querySelectorAll('circle.node');\n    nodeCircles.forEach((c,i)=>{\n      if(nodeIds.includes(i)){\n        c.classList.remove('active');\n        c.style.fill = '#35434d';\n        c.style.strokeWidth = '2px';\n        c.style.filter = 'drop-shadow(0 0 2px #223236cc)';\n        c.style.transition = 'fill 0.8s ease, stroke-width 0.8s ease, filter 0.8s ease';\n      }\n    });\n  }\n\n  startBtn.addEventListener('click', () => {\n    if(animationInProgress) return;\n    animationInProgress = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n    resetBtn.setAttribute('aria-disabled', 'true');\n    animateKruskal.selectedEdges = [];\n    animStep = 0;\n    animateKruskal();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    resetVisualization();\n  });\n\n  // Initial reset to style nodes consistently\n  resetVisualization();\n})();\n</script>\n</body>\n</html>"
