  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Asymmetric Cryptography Interactive Demo</title>\n</head>\n<body>\n<h1>Asymmetric Cryptography Interactive Demo</h1>\n\n<p>This demo helps you explore how asymmetric cryptography works step-by-step, with control over key generation, message encryption, decryption, and signature workflows. Use the controls below to experiment with keys, messages, encrypt/decrypt/sign/verify methods and watch internal data update dynamically.</p>\n\n<section id=\"keygen-section\">\n  <h2>1. Key Generation</h2>\n  <label for=\"keytype\">Key Type:</label>\n  <select id=\"keytype\">\n    <option value=\"RSA\">RSA (1024, 2048, 4096 bits)</option>\n    <option value=\"ECDSA\">ECDSA (P-256, P-384, P-521)</option>\n  </select>\n  <label for=\"keysize-rsa\">Key Size (RSA only):</label>\n  <select id=\"keysize-rsa\">\n    <option value=\"1024\">1024</option>\n    <option value=\"2048\" selected>2048</option>\n    <option value=\"4096\">4096</option>\n  </select>\n  <label for=\"eccurve\">Curve (ECDSA only):</label>\n  <select id=\"eccurve\" disabled>\n    <option value=\"P-256\" selected>P-256</option>\n    <option value=\"P-384\">P-384</option>\n    <option value=\"P-521\">P-521</option>\n  </select>\n  <button id=\"gen-keys-button\">Generate Key Pair</button>\n  <p><b>Key Generation Status:</b> <span id=\"keygen-status\">No keys generated yet.</span></p>\n  <textarea id=\"public-key-text\" rows=\"6\" cols=\"80\" readonly placeholder=\"Public key (PEM format) will appear here\"></textarea><br />\n  <textarea id=\"private-key-text\" rows=\"10\" cols=\"80\" readonly placeholder=\"Private key (PEM format) will appear here\"></textarea>\n</section>\n\n<hr />\n\n<section id=\"workflow-selection\">\n  <h2>2. Select Workflow</h2>\n  <p><input type=\"radio\" name=\"workflow\" id=\"workflow-encrypt\" value=\"encrypt\" checked><label for=\"workflow-encrypt\"> Encryption / Decryption (Confidentiality)</label></p>\n  <p><input type=\"radio\" name=\"workflow\" id=\"workflow-sign\" value=\"sign\"><label for=\"workflow-sign\"> Signing / Verification (Integrity & Authentication)</label></p>\n  <p><input type=\"radio\" name=\"workflow\" id=\"workflow-both\" value=\"both\"><label for=\"workflow-both\"> Combined Encrypt & Sign Workflow</label></p>\n</section>\n\n<hr />\n\n<section id=\"encryption-section\">\n  <h2>3. Encryption / Decryption</h2>\n  <label for=\"plaintext-input\">Plaintext Message:</label><br />\n  <textarea id=\"plaintext-input\" rows=\"4\" cols=\"80\" placeholder=\"Type your message here\"></textarea><br />\n  <button id=\"encrypt-button\" disabled>Encrypt with Public Key</button><br />\n  <label for=\"ciphertext-output\">Encrypted Message (base64):</label><br />\n  <textarea id=\"ciphertext-output\" rows=\"6\" cols=\"80\" readonly placeholder=\"Encrypted message will appear here\"></textarea><br />\n  <button id=\"decrypt-button\" disabled>Decrypt with Private Key</button><br />\n  <label for=\"decryptedtext-output\">Decrypted Message:</label><br />\n  <textarea id=\"decryptedtext-output\" rows=\"4\" cols=\"80\" readonly placeholder=\"Decrypted message will appear here\"></textarea><br />\n</section>\n\n<hr />\n\n<section id=\"signing-section\" style=\"display:none;\">\n  <h2>3. Signing / Verification</h2>\n  <label for=\"sign-message-input\">Message to Sign:</label><br />\n  <textarea id=\"sign-message-input\" rows=\"4\" cols=\"80\" placeholder=\"Type message to sign\"></textarea><br />\n  <button id=\"sign-button\" disabled>Sign with Private Key</button><br />\n  <label for=\"signature-output\">Signature (base64):</label><br />\n  <textarea id=\"signature-output\" rows=\"6\" cols=\"80\" readonly placeholder=\"Signature will appear here\"></textarea><br />\n  <label for=\"verify-message-input\">Message to Verify:</label><br />\n  <textarea id=\"verify-message-input\" rows=\"4\" cols=\"80\" placeholder=\"Paste or type message to verify\"></textarea><br />\n  <label for=\"signature-input\">Signature to Verify (base64):</label><br />\n  <textarea id=\"signature-input\" rows=\"6\" cols=\"80\" placeholder=\"Paste signature here\"></textarea><br />\n  <button id=\"verify-button\" disabled>Verify Signature with Public Key</button><br />\n  <p><b>Verification Result:</b> <span id=\"verify-result\">No verification performed yet.</span></p>\n</section>\n\n<hr />\n\n<section id=\"combined-section\" style=\"display:none;\">\n  <h2>3. Combined Encrypt & Sign Workflow</h2>\n  <label for=\"combined-plaintext\">Plaintext Message:</label><br />\n  <textarea id=\"combined-plaintext\" rows=\"4\" cols=\"80\" placeholder=\"Type your message here\"></textarea><br />\n  <button id=\"combined-encrypt-sign-button\" disabled>Encrypt with Public Key & Sign with Private Key</button><br />\n  <label for=\"combined-cipher-sign\">Encrypted Message & Signature (JSON base64):</label><br />\n  <textarea id=\"combined-cipher-sign\" rows=\"8\" cols=\"80\" readonly placeholder='Will contain JSON with ciphertext and signature'></textarea><br />\n  <button id=\"combined-verify-decrypt-button\" disabled>Verify Signature & Decrypt Message</button><br />\n  <label for=\"combined-verify-result\">Verification Result:</label>\n  <span id=\"combined-verify-result\">No verification done yet.</span><br />\n  <label for=\"combined-decrypted-output\">Decrypted Message:</label><br />\n  <textarea id=\"combined-decrypted-output\" rows=\"4\" cols=\"80\" readonly placeholder=\"Decrypted message will appear here\"></textarea>\n</section>\n\n<hr />\n\n<section id=\"debug-section\">\n  <h2>4. Internal Data & Info</h2>\n  <button id=\"show-keys-raw\">Show Raw Keys Object (JavaScript)</button><br />\n  <pre id=\"raw-keys-display\" style=\"white-space: pre-wrap; max-height: 200px; overflow-y: auto;\"></pre>\n  <button id=\"show-last-error\">Show Last Error (if any)</button><br />\n  <pre id=\"last-error-display\" style=\"white-space: pre-wrap; max-height: 100px; overflow-y: auto;\"></pre>\n</section>\n\n<script>\n\"use strict\";\n\nlet keyPair = null; // holds CryptoKeyPair\nlet lastError = null;\n\nconst keyTypeSelect = document.getElementById(\"keytype\");\nconst keySizeSelect = document.getElementById(\"keysize-rsa\");\nconst ecCurveSelect = document.getElementById(\"eccurve\");\nconst genKeysButton = document.getElementById(\"gen-keys-button\");\nconst keygenStatusSpan = document.getElementById(\"keygen-status\");\nconst publicKeyTextArea = document.getElementById(\"public-key-text\");\nconst privateKeyTextArea = document.getElementById(\"private-key-text\");\n\nconst workflowRadios = document.getElementsByName(\"workflow\");\n// Encryption UI\nconst plaintextInput = document.getElementById(\"plaintext-input\");\nconst encryptButton = document.getElementById(\"encrypt-button\");\nconst ciphertextOutput = document.getElementById(\"ciphertext-output\");\nconst decryptButton = document.getElementById(\"decrypt-button\");\nconst decryptedTextOutput = document.getElementById(\"decryptedtext-output\");\n\n// Signing UI\nconst signingSection = document.getElementById(\"signing-section\");\nconst signMessageInput = document.getElementById(\"sign-message-input\");\nconst signButton = document.getElementById(\"sign-button\");\nconst signatureOutput = document.getElementById(\"signature-output\");\nconst verifyMessageInput = document.getElementById(\"verify-message-input\");\nconst signatureInput = document.getElementById(\"signature-input\");\nconst verifyButton = document.getElementById(\"verify-button\");\nconst verifyResultSpan = document.getElementById(\"verify-result\");\n\n// Combined section\nconst combinedSection = document.getElementById(\"combined-section\");\nconst combinedPlaintext = document.getElementById(\"combined-plaintext\");\nconst combinedEncryptSignButton = document.getElementById(\"combined-encrypt-sign-button\");\nconst combinedCipherSign = document.getElementById(\"combined-cipher-sign\");\nconst combinedVerifyDecryptButton = document.getElementById(\"combined-verify-decrypt-button\");\nconst combinedVerifyResultSpan = document.getElementById(\"combined-verify-result\");\nconst combinedDecryptedOutput = document.getElementById(\"combined-decrypted-output\");\n\n// Debug section\nconst showKeysRawBtn = document.getElementById(\"show-keys-raw\");\nconst rawKeysDisplay = document.getElementById(\"raw-keys-display\");\nconst showLastErrorBtn = document.getElementById(\"show-last-error\");\nconst lastErrorDisplay = document.getElementById(\"last-error-display\");\n\n// Utility functions for base64 <-> ArrayBuffer\nfunction arrayBufferToBase64(buffer) {\n  const bytes = new Uint8Array(buffer);\n  let binary = '';\n  for(let i=0;i<bytes.byteLength;i++){\n    binary += String.fromCharCode(bytes[i]);\n  }\n  return btoa(binary);\n}\nfunction base64ToArrayBuffer(base64) {\n  const binary = atob(base64);\n  const buffer = new Uint8Array(binary.length);\n  for(let i=0;i<binary.length;i++){\n    buffer[i] = binary.charCodeAt(i);\n  }\n  return buffer.buffer;\n}\n\nfunction bufferToString(buffer) {\n  return new TextDecoder().decode(buffer);\n}\nfunction stringToBuffer(str) {\n  return new TextEncoder().encode(str);\n}\n\nfunction clearError() {\n  lastError = null;\n  lastErrorDisplay.textContent = \"\";\n}\nfunction recordError(err) {\n  lastError = err;\n  lastErrorDisplay.textContent = err.toString();\n}\n\n// Enable/disable key size and curve selectors depending on key type\nfunction updateKeyTypeInputs() {\n  const type = keyTypeSelect.value;\n  if (type === \"RSA\") {\n    keySizeSelect.disabled = false;\n    ecCurveSelect.disabled = true;\n  } else if (type === \"ECDSA\") {\n    keySizeSelect.disabled = true;\n    ecCurveSelect.disabled = false;\n  }\n}\nkeyTypeSelect.addEventListener(\"change\", () => {\n  updateKeyTypeInputs();\n});\nupdateKeyTypeInputs(); // initialize\n\n// Export CryptoKey to PEM format string (spki for public, pkcs8 for private)\nasync function exportPublicKeyToPEM(key) {\n  try {\n    const spki = await window.crypto.subtle.exportKey(\"spki\", key);\n    const b64 = arrayBufferToBase64(spki);\n    const pem = [\"-----BEGIN PUBLIC KEY-----\"];\n    for(let i=0; i < b64.length; i+=64){\n      pem.push(b64.substring(i,i+64));\n    }\n    pem.push(\"-----END PUBLIC KEY-----\");\n    return pem.join(\"\\n\");\n  } catch(e) {\n    recordError(e);\n    return \"Failed to export public key.\";\n  }\n}\nasync function exportPrivateKeyToPEM(key) {\n  try {\n    const pkcs8 = await window.crypto.subtle.exportKey(\"pkcs8\", key);\n    const b64 = arrayBufferToBase64(pkcs8);\n    const pem = [\"-----BEGIN PRIVATE KEY-----\"];\n    for(let i=0; i < b64.length; i+=64){\n      pem.push(b64.substring(i,i+64));\n    }\n    pem.push(\"-----END PRIVATE KEY-----\");\n    return pem.join(\"\\n\");\n  } catch(e) {\n    recordError(e);\n    return \"Failed to export private key.\";\n  }\n}\n\n// Generate keys based on user selection\ngenKeysButton.addEventListener(\"click\", async () => {\n  clearError();\n  keygenStatusSpan.textContent = \"Generating keys...\";\n  publicKeyTextArea.value = \"\";\n  privateKeyTextArea.value = \"\";\n  keyPair = null;\n\n  const keyType = keyTypeSelect.value;\n  try {\n    if (keyType === \"RSA\") {\n      const modulusLength = parseInt(keySizeSelect.value,10);\n      // Generate RSA-OAEP and RSA-PSS keys for encrypt/decrypt and sign/verify respectively.\n      // For this demo, we will generate one RSA key pair usable for both encrypt (RSA-OAEP) and sign (RSASSA-PKCS1-v1_5).\n      // But Web Crypto requires different algorithms for usage, so generate one RSA key pair for encryption and signing.\n      // We'll use RSA-OAEP for encryption and RSASSA-PKCS1-v1_5 for signing but with the same keys? Not possible directly.\n      // So we'll generate for encryption first, then for signing we can use the same keys but Web Crypto expects usage to be specified.\n      // We'll generate a single RSA key pair with key usages: ['encrypt','decrypt','sign','verify'] - this is allowed.\n      // Note: Some environments may forbid combined usage; if so, generate separate keys.\n\n      keyPair = await window.crypto.subtle.generateKey(\n        {\n          name: \"RSA-OAEP\",\n          modulusLength,\n          publicExponent: new Uint8Array([0x01, 0x00, 0x01]),\n          hash: \"SHA-256\",\n        },\n        true,\n        [\"encrypt\", \"decrypt\"] // encrypt/decrypt usage only\n      );\n      // To support signing we'll generate a separate key pair with RSASSA-PKCS1-v1_5:\n      const signKeyPair = await window.crypto.subtle.generateKey(\n        {\n          name: \"RSASSA-PKCS1-v1_5\",\n          modulusLength,\n          publicExponent: new Uint8Array([0x01, 0x00, 0x01]),\n          hash: \"SHA-256\",\n        },\n        true,\n        [\"sign\", \"verify\"]\n      );\n\n      // We'll keep both key pairs in keyPair object:\n      keyPair.encrypt = keyPair;\n      keyPair.sign = signKeyPair;\n\n      const pubPemEnc = await exportPublicKeyToPEM(keyPair.encrypt.publicKey);\n      const privPemEnc = await exportPrivateKeyToPEM(keyPair.encrypt.privateKey);\n      // For sign keys:\n      const pubPemSign = await exportPublicKeyToPEM(keyPair.sign.publicKey);\n      const privPemSign = await exportPrivateKeyToPEM(keyPair.sign.privateKey);\n\n      publicKeyTextArea.value = \"=== Encryption Key (Public - RSA-OAEP) ===\\n\" + pubPemEnc + \"\\n\\n\" +\n                               \"=== Signing Key (Public - RSASSA-PKCS1-v1_5) ===\\n\" + pubPemSign;\n      privateKeyTextArea.value = \"=== Encryption Key (Private - RSA-OAEP) ===\\n\" + privPemEnc + \"\\n\\n\" +\n                                \"=== Signing Key (Private - RSASSA-PKCS1-v1_5) ===\\n\" + privPemSign;\n\n    } else if (keyType === \"ECDSA\") {\n      const namedCurve = ecCurveSelect.value;\n      // For ECDSA keys: used for signing/verification only.\n      keyPair = await window.crypto.subtle.generateKey(\n        {\n          name: \"ECDSA\",\n          namedCurve,\n        },\n        true,\n        [\"sign\", \"verify\"]\n      );\n      // For encryption with ECDSA keys there's no direct method, so for encryption we'll generate ephemeral ECDH keys instead.\n      // We'll generate ECDH separately for encrypt/decrypt purpose:\n      const ecdhKeyPair = await window.crypto.subtle.generateKey(\n        {\n          name: \"ECDH\",\n          namedCurve,\n        },\n        true,\n        [\"deriveKey\", \"deriveBits\"]\n      );\n      keyPair.sign = keyPair;\n      keyPair.ecdh = ecdhKeyPair;\n\n      const pubPemSign = await exportPublicKeyToPEM(keyPair.sign.publicKey);\n      const privPemSign = await exportPrivateKeyToPEM(keyPair.sign.privateKey);\n      const pubPemEcdh = await exportPublicKeyToPEM(keyPair.ecdh.publicKey);\n      const privPemEcdh = await exportPrivateKeyToPEM(keyPair.ecdh.privateKey);\n\n      publicKeyTextArea.value = \"=== Signing Key (Public - ECDSA) ===\\n\" + pubPemSign + \"\\n\\n\" +\n                               \"=== Encryption Key (Public - ECDH) ===\\n\" + pubPemEcdh;\n\n      privateKeyTextArea.value = \"=== Signing Key (Private - ECDSA) ===\\n\" + privPemSign + \"\\n\\n\" +\n                                \"=== Encryption Key (Private - ECDH) ===\\n\" + privPemEcdh;\n\n    }\n    keygenStatusSpan.textContent = \"Keys generated successfully.\";\n  } catch(e) {\n    recordError(e);\n    keygenStatusSpan.textContent = \"Key generation FAILED: \" + e.toString();\n    keyPair = null;\n  }\n  updateUIStates();\n});\n\nfunction getSelectedWorkflow(){\n  for (const r of workflowRadios) {\n    if (r.checked) return r.value;\n  }\n  return \"encrypt\";\n}\nfunction updateWorkflowSections() {\n  const w = getSelectedWorkflow();\n  if (w === \"encrypt\") {\n    document.getElementById(\"encryption-section\").style.display = \"block\";\n    signingSection.style.display = \"none\";\n    combinedSection.style.display = \"none\";\n  } else if (w === \"sign\") {\n    document.getElementById(\"encryption-section\").style.display = \"none\";\n    signingSection.style.display = \"block\";\n    combinedSection.style.display = \"none\";\n  } else if (w === \"both\") {\n    document.getElementById(\"encryption-section\").style.display = \"none\";\n    signingSection.style.display = \"none\";\n    combinedSection.style.display = \"block\";\n  }\n  updateUIStates();\n}\nfor(const r of workflowRadios){\n  r.addEventListener(\"change\", () => {\n    updateWorkflowSections();\n  });\n}\nupdateWorkflowSections();\n\nfunction updateUIStates() {\n  const keysReady = keyPair !== null;\n  // Encryption buttons enabled only if keys ready and message input not empty\n  encryptButton.disabled = !keysReady || plaintextInput.value.trim() === \"\";\n  decryptButton.disabled = !keysReady || ciphertextOutput.value.trim() === \"\";\n\n  // Signing buttons enabled only if keys ready and message present\n  signButton.disabled = !keysReady || signMessageInput.value.trim() === \"\";\n  verifyButton.disabled = !keysReady || signatureInput.value.trim() === \"\" || verifyMessageInput.value.trim() === \"\";\n\n  // Combined buttons enabled only if keys ready and input present\n  combinedEncryptSignButton.disabled = !keysReady || combinedPlaintext.value.trim() === \"\";\n  combinedVerifyDecryptButton.disabled = !keysReady || combinedCipherSign.value.trim() === \"\";\n}\nplaintextInput.addEventListener(\"input\", updateUIStates);\nciphertextOutput.addEventListener(\"input\", updateUIStates);\nsignMessageInput.addEventListener(\"input\", updateUIStates);\nsignatureInput.addEventListener(\"input\", updateUIStates);\nverifyMessageInput.addEventListener(\"input\", updateUIStates);\ncombinedPlaintext.addEventListener(\"input\", updateUIStates);\ncombinedCipherSign.addEventListener(\"input\", updateUIStates);\n\n// Encryption section logic\nencryptButton.addEventListener(\"click\", async () => {\n  clearError();\n  ciphertextOutput.value = \"\";\n  decryptedTextOutput.value = \"\";\n  if (!keyPair || !keyPair.encrypt) {\n    alert(\"Encryption key pair not generated or unavailable.\");\n    return;\n  }\n  const utf8msg = stringToBuffer(plaintextInput.value);\n  try {\n    const encryptedBuffer = await window.crypto.subtle.encrypt(\n      {\n        name: \"RSA-OAEP\"\n      },\n      keyPair.encrypt.publicKey,\n      utf8msg\n    );\n    const b64cipher = arrayBufferToBase64(encryptedBuffer);\n    ciphertextOutput.value = b64cipher;\n    decryptButton.disabled = false;\n  } catch(e) {\n    recordError(e);\n    alert(\"Encryption failed: \" + e.toString());\n  }\n});\ndecryptButton.addEventListener(\"click\", async () => {\n  clearError();\n  decryptedTextOutput.value = \"\";\n  if (!keyPair || !keyPair.encrypt) {\n    alert(\"Encryption key pair not generated or unavailable.\");\n    return;\n  }\n  try {\n    const ciphertextB64 = ciphertextOutput.value.trim();\n    const ciphertextBuffer = base64ToArrayBuffer(ciphertextB64);\n    const decryptedBuffer = await window.crypto.subtle.decrypt(\n      {\n        name: \"RSA-OAEP\"\n      },\n      keyPair.encrypt.privateKey,\n      ciphertextBuffer\n    );\n    const decryptedText = bufferToString(decryptedBuffer);\n    decryptedTextOutput.value = decryptedText;\n  } catch(e) {\n    recordError(e);\n    alert(\"Decryption failed: \" + e.toString());\n  }\n});\n\n// Signing section logic\nsignButton.addEventListener(\"click\", async () => {\n  clearError();\n  signatureOutput.value = \"\";\n  verifyResultSpan.textContent = \"No verification performed yet.\";\n  if (!keyPair || !keyPair.sign) {\n    alert(\"Signing key pair not generated or unavailable.\");\n    return;\n  }\n  const msgBuffer = stringToBuffer(signMessageInput.value);\n  try {\n    let signatureBuffer;\n    if (keyTypeSelect.value === \"RSA\") {\n      signatureBuffer = await window.crypto.subtle.sign(\n        {\n          name: \"RSASSA-PKCS1-v1_5\",\n          hash: {name: \"SHA-256\"}\n        },\n        keyPair.sign.privateKey,\n        msgBuffer\n      );\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      signatureBuffer = await window.crypto.subtle.sign(\n        {\n          name: \"ECDSA\",\n          hash: {name: \"SHA-256\"}\n        },\n        keyPair.sign.privateKey,\n        msgBuffer\n      );\n    }\n    const sigB64 = arrayBufferToBase64(signatureBuffer);\n    signatureOutput.value = sigB64;\n  } catch(e) {\n    recordError(e);\n    alert(\"Signing failed: \" + e.toString());\n  }\n});\nverifyButton.addEventListener(\"click\", async () => {\n  clearError();\n  verifyResultSpan.textContent = \"\";\n  if (!keyPair || !keyPair.sign) {\n    alert(\"Signing key pair not generated or unavailable.\");\n    return;\n  }\n  try {\n    const msgBuffer = stringToBuffer(verifyMessageInput.value);\n    const signatureB64 = signatureInput.value.trim();\n    const signatureBuffer = base64ToArrayBuffer(signatureB64);\n    let valid = false;\n    if (keyTypeSelect.value === \"RSA\") {\n      valid = await window.crypto.subtle.verify(\n        {\n          name: \"RSASSA-PKCS1-v1_5\",\n          hash: {name: \"SHA-256\"}\n        },\n        keyPair.sign.publicKey,\n        signatureBuffer,\n        msgBuffer\n      );\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      valid = await window.crypto.subtle.verify(\n        {\n          name: \"ECDSA\",\n          hash: {name: \"SHA-256\"}\n        },\n        keyPair.sign.publicKey,\n        signatureBuffer,\n        msgBuffer\n      );\n    }\n    verifyResultSpan.textContent = valid ? \"Signature is VALID.\" : \"Signature is INVALID.\";\n  } catch(e) {\n    recordError(e);\n    verifyResultSpan.textContent = \"Verification FAILED: \" + e.toString();\n  }\n});\n\n// Combined workflow: encrypt with public key + sign with private key; then verify signature and decrypt\ncombinedEncryptSignButton.addEventListener(\"click\", async () => {\n  clearError();\n  combinedCipherSign.value = \"\";\n  combinedVerifyResultSpan.textContent = \"No verification done yet.\";\n  combinedDecryptedOutput.value = \"\";\n  if (!keyPair) {\n    alert(\"Key pair not generated or unavailable.\");\n    return;\n  }\n  try {\n    const message = combinedPlaintext.value;\n    const msgBuffer = stringToBuffer(message);\n\n    // Encrypt message\n    let encryptedBuffer;\n    if (keyTypeSelect.value === \"RSA\") {\n      if (!keyPair.encrypt) {\n        alert(\"Encryption keys not available for RSA.\");\n        return;\n      }\n      encryptedBuffer = await window.crypto.subtle.encrypt(\n        {\n          name: \"RSA-OAEP\"\n        },\n        keyPair.encrypt.publicKey,\n        msgBuffer\n      );\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      // ECDSA keys cannot encrypt. Use ECDH to derive a symmetric key and encrypt message symmetrically\n      // Generate ephemeral ECDH key for sender\n      if (!keyPair.ecdh) {\n        alert(\"ECDH keys not available for encryption in ECDSA mode.\");\n        return;\n      }\n      // Derive a shared secret between ephemeral private key and recipient's public key (simulate)\n      // For demo, generate ephemeral key for sender, derive shared secret with keyPair.ecdh.publicKey as target:\n      const ephemeralKeyPair = await window.crypto.subtle.generateKey(\n        {\n          name: \"ECDH\",\n          namedCurve: ecCurveSelect.value,\n        },\n        true,\n        [\"deriveKey\", \"deriveBits\"]\n      );\n      // Derive shared secret to use for symmetric encryption\n      // Derive AES key from shared secret\n      // Input: ephemeralKeyPair.privateKey, recipient public key = keyPair.ecdh.publicKey\n      const sharedSecret = await window.crypto.subtle.deriveKey(\n        {\n          name: \"ECDH\",\n          public: keyPair.ecdh.publicKey\n        },\n        ephemeralKeyPair.privateKey,\n        {\n          name: \"AES-GCM\",\n          length: 256,\n        },\n        false,\n        [\"encrypt\",\"decrypt\"]\n      );\n      // Encrypt message symmetrically with AES-GCM with a random iv\n      const iv = window.crypto.getRandomValues(new Uint8Array(12));\n      const encrypted = await window.crypto.subtle.encrypt(\n        {\n          name: \"AES-GCM\",\n          iv,\n        },\n        sharedSecret,\n        msgBuffer\n      );\n      // We need to send ephemeral public key + iv + encrypted ciphertext\n      // Export ephemeral public key to raw format\n      const ephemeralPublicKeyRaw = await window.crypto.subtle.exportKey(\"raw\", ephemeralKeyPair.publicKey);\n\n      // Pack these into base64 strings for JSON\n      // Format:\n      // {\n      //   \"ephemeralPublicKey\": base64,\n      //   \"iv\": base64,\n      //   \"ciphertext\": base64\n      // }\n      const payloadObj = {\n        ephemeralPublicKey: arrayBufferToBase64(ephemeralPublicKeyRaw),\n        iv: arrayBufferToBase64(iv.buffer),\n        ciphertext: arrayBufferToBase64(encrypted)\n      };\n      encryptedBuffer = JSON.stringify(payloadObj);\n    }\n\n    // Sign the encrypted message (or stringified JSON)\n    let toSignBuffer;\n    if (keyTypeSelect.value === \"RSA\") {\n      toSignBuffer = encryptedBuffer instanceof ArrayBuffer ? encryptedBuffer : stringToBuffer(encryptedBuffer);\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      toSignBuffer = stringToBuffer(encryptedBuffer);\n    }\n\n    let signatureBuffer;\n    if (keyTypeSelect.value === \"RSA\") {\n      if (!keyPair.sign) {\n        alert(\"Signing keys not available for RSA.\");\n        return;\n      }\n      signatureBuffer = await window.crypto.subtle.sign(\n        {\n          name: \"RSASSA-PKCS1-v1_5\",\n          hash: {name: \"SHA-256\"}\n        },\n        keyPair.sign.privateKey,\n        toSignBuffer\n      );\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      signatureBuffer = await window.crypto.subtle.sign(\n        {\n          name: \"ECDSA\",\n          hash: {name: \"SHA-256\"}\n        },\n        keyPair.sign.privateKey,\n        toSignBuffer\n      );\n    }\n\n    // Prepare JSON containing ciphertext and signature\n    let outputJSON;\n    if (keyTypeSelect.value === \"RSA\") {\n      outputJSON = JSON.stringify({\n        ciphertext: arrayBufferToBase64(encryptedBuffer),\n        signature: arrayBufferToBase64(signatureBuffer),\n      }, null, 2);\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      outputJSON = JSON.stringify({\n        ciphertext: encryptedBuffer, // JSON stringified inner already\n        signature: arrayBufferToBase64(signatureBuffer),\n      }, null, 2);\n    }\n    combinedCipherSign.value = outputJSON;\n    combinedVerifyDecryptButton.disabled = false;\n  } catch(e) {\n    recordError(e);\n    alert(\"Encrypt & sign failed: \" + e.toString());\n  }\n});\n\ncombinedVerifyDecryptButton.addEventListener(\"click\", async () => {\n  clearError();\n  combinedVerifyResultSpan.textContent = \"\";\n  combinedDecryptedOutput.value = \"\";\n  try {\n    if (!keyPair) {\n      alert(\"Key pair not generated or unavailable.\");\n      return;\n    }\n    const jsonStr = combinedCipherSign.value.trim();\n    if (!jsonStr) {\n      alert(\"No encrypted & signed data to verify and decrypt.\");\n      return;\n    }\n    const obj = JSON.parse(jsonStr);\n    const signatureBuffer = base64ToArrayBuffer(obj.signature);\n    let ciphertextDecoded;\n    if (keyTypeSelect.value === \"RSA\") {\n      ciphertextDecoded = base64ToArrayBuffer(obj.ciphertext);\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      ciphertextDecoded = obj.ciphertext; // JSON stringified inner\n    }\n    // Verify signature\n    let valid = false;\n    if (keyTypeSelect.value === \"RSA\") {\n      valid = await window.crypto.subtle.verify(\n        {\n          name: \"RSASSA-PKCS1-v1_5\",\n          hash: {name: \"SHA-256\"}\n        },\n        keyPair.sign.publicKey,\n        signatureBuffer,\n        ciphertextDecoded\n      );\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      valid = await window.crypto.subtle.verify(\n        {\n          name: \"ECDSA\",\n          hash: {name: \"SHA-256\"}\n        },\n        keyPair.sign.publicKey,\n        signatureBuffer,\n        stringToBuffer(ciphertextDecoded)\n      );\n    }\n    combinedVerifyResultSpan.textContent = valid ? \"Signature is VALID.\" : \"Signature is INVALID.\";\n\n    if (!valid) {\n      combinedDecryptedOutput.value = \"\";\n      return;\n    }\n\n    // Decrypt message\n    if (keyTypeSelect.value === \"RSA\") {\n      if (!keyPair.encrypt) {\n        alert(\"Encryption keys not available.\");\n        return;\n      }\n      const decryptedBuffer = await window.crypto.subtle.decrypt(\n        {\n          name: \"RSA-OAEP\"\n        },\n        keyPair.encrypt.privateKey,\n        ciphertextDecoded\n      );\n      combinedDecryptedOutput.value = bufferToString(decryptedBuffer);\n    } else if (keyTypeSelect.value === \"ECDSA\") {\n      const payloadObj = JSON.parse(ciphertextDecoded);\n      // ephemeralPublicKey, iv, ciphertext base64\n      const ephemeralPublicKeyRaw = base64ToArrayBuffer(payloadObj.ephemeralPublicKey);\n      const iv = base64ToArrayBuffer(payloadObj.iv);\n      const ciphertext = base64ToArrayBuffer(payloadObj.ciphertext);\n\n      // Import ephemeralPublicKeyRaw as CryptoKey\n      const ephemeralPublicKey = await window.crypto.subtle.importKey(\n        \"raw\",\n        ephemeralPublicKeyRaw,\n        {\n          name: \"ECDH\",\n          namedCurve: ecCurveSelect.value\n        },\n        true,\n        []\n      );\n      // Derive shared secret from ephemeral public key and our private key (keyPair.ecdh.privateKey)\n      const sharedSecret = await window.crypto.subtle.deriveKey(\n        {\n          name: \"ECDH\",\n          public: ephemeralPublicKey\n        },\n        keyPair.ecdh.privateKey,\n        {\n          name: \"AES-GCM\",\n          length: 256\n        },\n        false,\n        [\"decrypt\"]\n      );\n\n      // Decrypt ciphertext with AES-GCM and iv\n      const decryptedBuffer = await window.crypto.subtle.decrypt(\n        {\n          name: \"AES-GCM\",\n          iv: new Uint8Array(iv)\n        },\n        sharedSecret,\n        ciphertext\n      );\n      combinedDecryptedOutput.value = bufferToString(decryptedBuffer);\n    }\n  } catch(e) {\n    recordError(e);\n    alert(\"Verify & decrypt failed: \" + e.toString());\n  }\n});\n\n// Debug buttons\nshowKeysRawBtn.addEventListener(\"click\", () => {\n  if (!keyPair) {\n    rawKeysDisplay.textContent = \"No keys generated.\";\n    return;\n  }\n  // Serialize keyPair structure names and describe usages\n  function describeKey(k) {\n    if (!k) return \"null\";\n    return `{type:${k.type},algorithm:${JSON.stringify(k.algorithm)},extractable:${k.extractable},usages:[${k.usages.join(\",\")}]}`;\n  }\n  // Compose string\n  let out = \"KeyPair object details:\\n\";\n  if (\"encrypt\" in keyPair) {\n    out += \"encrypt:\\n\" + \"  publicKey: \" + describeKey(keyPair.encrypt.publicKey) + \"\\n\" +\n           \"  privateKey: \" + describeKey(keyPair.encrypt.privateKey) + \"\\n\";\n  }\n  if (\"sign\" in keyPair) {\n    out += \"sign:\\n\" + \"  publicKey: \" + describeKey(keyPair.sign.publicKey) + \"\\n\" +\n           \"  privateKey: \" + describeKey(keyPair.sign.privateKey) + \"\\n\";\n  }\n  if (\"ecdh\" in keyPair) {\n    out += \"ecdh:\\n\" + \"  publicKey: \" + describeKey(keyPair.ecdh.publicKey) + \"\\n\" +\n           \"  privateKey: \" + describeKey(keyPair.ecdh.privateKey) + \"\\n\";\n  }\n  rawKeysDisplay.textContent = out;\n});\nshowLastErrorBtn.addEventListener(\"click\", () => {\n  if (!lastError) {\n    lastErrorDisplay.textContent = \"No errors recorded.\";\n  } else {\n    lastErrorDisplay.textContent = lastError.toString();\n  }\n});\n\n// Keep UI states synced\nupdateUIStates();\n</script>\n\n</body>\n</html>"
