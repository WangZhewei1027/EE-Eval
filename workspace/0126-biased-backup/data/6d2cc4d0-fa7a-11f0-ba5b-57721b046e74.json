    "content": "<html>\n<head>\n    <title>Interactive Hash Table</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n            margin-bottom: 10px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 15px;\n        }\n        button, input, select {\n            padding: 5px 10px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        .bucket {\n            background-color: #f9f9f9;\n        }\n        .collision {\n            background-color: #ffebee;\n        }\n        .highlight {\n            background-color: #e3f2fd;\n        }\n        .stats {\n            margin-top: 20px;\n        }\n        .visualization {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 5px;\n            margin-bottom: 20px;\n        }\n        .bucket-vis {\n            border: 1px solid #000;\n            padding: 5px;\n            min-width: 50px;\n            min-height: 30px;\n        }\n        .entry {\n            border: 1px solid #999;\n            margin: 2px;\n            padding: 2px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Hash Table Explorer</h1>\n        \n        <div class=\"panel\">\n            <h2>Hash Table Configuration</h2>\n            <div class=\"controls\">\n                <div>\n                    <label>Table Size: <span id=\"sizeValue\">10</span></label>\n                    <input type=\"range\" id=\"tableSize\" min=\"1\" max=\"20\" value=\"10\">\n                </div>\n                <div>\n                    <label>Hash Function:</label>\n                    <select id=\"hashFunction\">\n                        <option value=\"simple\">Simple Modulo</option>\n                        <option value=\"multiplicative\">Multiplicative</option>\n                        <option value=\"djb2\">DJB2 (String)</option>\n                    </select>\n                </div>\n                <div>\n                    <label>Collision Resolution:</label>\n                    <select id=\"collisionMethod\">\n                        <option value=\"chaining\">Chaining</option>\n                        <option value=\"linear\">Linear Probing</option>\n                        <option value=\"quadratic\">Quadratic Probing</option>\n                    </select>\n                </div>\n                <button id=\"resetTable\">Reset Table</button>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Operations</h2>\n            <div class=\"controls\">\n                <input type=\"text\" id=\"keyInput\" placeholder=\"Key\">\n                <input type=\"text\" id=\"valueInput\" placeholder=\"Value\">\n                <button id=\"insertBtn\">Insert</button>\n                <button id=\"searchBtn\">Search</button>\n                <button id=\"deleteBtn\">Delete</button>\n                <button id=\"randomData\">Add Random Data</button>\n                <input type=\"number\" id=\"randomCount\" min=\"1\" max=\"20\" value=\"5\" style=\"width: 50px;\">\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Visualization</h2>\n            <div id=\"hashVisualization\" class=\"visualization\"></div>\n            <div>\n                <label>Animation Speed: </label>\n                <input type=\"range\" id=\"speedControl\" min=\"100\" max=\"1000\" value=\"500\">\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Detailed View</h2>\n            <table id=\"hashTableDetail\">\n                <thead>\n                    <tr>\n                        <th>Index</th>\n                        <th>Key</th>\n                        <th>Value</th>\n                        <th>Hash</th>\n                        <th>Probes</th>\n                    </tr>\n                </thead>\n                <tbody id=\"hashTableBody\">\n                </tbody>\n            </table>\n        </div>\n        \n        <div class=\"panel stats\">\n            <h2>Statistics</h2>\n            <div>\n                <p>Load Factor: <span id=\"loadFactor\">0</span></p>\n                <p>Total Collisions: <span id=\"totalCollisions\">0</span></p>\n                <p>Average Probes: <span id=\"avgProbes\">0</span></p>\n                <p>Operations: <span id=\"operationCount\">0</span></p>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Hash Function Details</h2>\n            <div id=\"hashCalculation\">\n                <p>Enter a key to see hash calculation steps:</p>\n                <input type=\"text\" id=\"hashTestKey\">\n                <button id=\"calcHashBtn\">Calculate Hash</button>\n                <div id=\"hashSteps\"></div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        class HashTable {\n            constructor(size = 10, hashFn = 'simple', collisionMethod = 'chaining') {\n                this.size = size;\n                this.hashFn = hashFn;\n                this.collisionMethod = collisionMethod;\n                this.table = Array(size).fill().map(() => []);\n                this.collisions = 0;\n                this.operations = 0;\n                this.totalProbes = 0;\n            }\n            \n            hash(key) {\n                if (this.hashFn === 'simple') {\n                    return this.simpleHash(key);\n                } else if (this.hashFn === 'multiplicative') {\n                    return this.multiplicativeHash(key);\n                } else if (this.hashFn === 'djb2') {\n                    return this.djb2Hash(key);\n                }\n            }\n            \n            simpleHash(key) {\n                if (typeof key === 'string') {\n                    let sum = 0;\n                    for (let i = 0; i < key.length; i++) {\n                        sum += key.charCodeAt(i);\n                    }\n                    return sum % this.size;\n                }\n                return key % this.size;\n            }\n            \n            multiplicativeHash(key) {\n                const A = 0.6180339887; // Golden ratio\n                if (typeof key === 'string') {\n                    let numericKey = 0;\n                    for (let i = 0; i < key.length; i++) {\n                        numericKey = numericKey * 31 + key.charCodeAt(i);\n                    }\n                    key = numericKey;\n                }\n                const product = key * A;\n                return Math.floor(this.size * (product - Math.floor(product)));\n            }\n            \n            djb2Hash(key) {\n                if (typeof key !== 'string') key = key.toString();\n                let hash = 5381;\n                for (let i = 0; i < key.length; i++) {\n                    hash = (hash * 33) ^ key.charCodeAt(i);\n                }\n                return (hash >>> 0) % this.size; // Ensure positive number\n            }\n            \n            insert(key, value) {\n                this.operations++;\n                const originalHash = this.hash(key);\n                let index = originalHash;\n                let probes = 0;\n                \n                if (this.collisionMethod === 'chaining') {\n                    // Check if key already exists in chain\n                    const existingIndex = this.table[index].findIndex(item => item.key === key);\n                    if (existingIndex >= 0) {\n                        this.table[index][existingIndex].value = value;\n                    } else {\n                        if (this.table[index].length > 0) this.collisions++;\n                        this.table[index].push({ key, value, hash: originalHash, probes });\n                        this.totalProbes += probes;\n                    }\n                    return { index, probes };\n                }\n                \n                // Open addressing methods\n                let i = 0;\n                while (true) {\n                    probes++;\n                    if (i >= this.size) {\n                        throw new Error(\"Hash table is full\");\n                    }\n                    \n                    if (this.collisionMethod === 'linear') {\n                        index = (originalHash + i) % this.size;\n                    } else if (this.collisionMethod === 'quadratic') {\n                        index = (originalHash + i*i) % this.size;\n                    }\n                    \n                    if (this.table[index].length === 0) {\n                        this.table[index].push({ key, value, hash: originalHash, probes });\n                        this.totalProbes += probes;\n                        return { index, probes };\n                    } else if (this.table[index][0].key === key) {\n                        this.table[index][0].value = value;\n                        return { index, probes };\n                    } else {\n                        this.collisions++;\n                        i++;\n                    }\n                }\n            }\n            \n            search(key) {\n                this.operations++;\n                const originalHash = this.hash(key);\n                let index = originalHash;\n                let probes = 0;\n                \n                if (this.collisionMethod === 'chaining') {\n                    const bucket = this.table[index];\n                    for (let i = 0; i < bucket.length; i++) {\n                        probes++;\n                        if (bucket[i].key === key) {\n                            this.totalProbes += probes;\n                            return { index, item: bucket[i], probes };\n                        }\n                    }\n                    return { index, item: null, probes };\n                }\n                \n                // Open addressing methods\n                let i = 0;\n                while (true) {\n                    probes++;\n                    if (i >= this.size) {\n                        return { index: -1, item: null, probes };\n                    }\n                    \n                    if (this.collisionMethod === 'linear') {\n                        index = (originalHash + i) % this.size;\n                    } else if (this.collisionMethod === 'quadratic') {\n                        index = (originalHash + i*i) % this.size;\n                    }\n                    \n                    if (this.table[index].length === 0) {\n                        return { index: -1, item: null, probes };\n                    } else if (this.table[index][0].key === key) {\n                        this.totalProbes += probes;\n                        return { index, item: this.table[index][0], probes };\n                    } else {\n                        i++;\n                    }\n                }\n            }\n            \n            delete(key) {\n                this.operations++;\n                const originalHash = this.hash(key);\n                let index = originalHash;\n                let probes = 0;\n                \n                if (this.collisionMethod === 'chaining') {\n                    const bucket = this.table[index];\n                    for (let i = 0; i < bucket.length; i++) {\n                        probes++;\n                        if (bucket[i].key === key) {\n                            this.totalProbes += probes;\n                            return { index, item: bucket.splice(i, 1)[0], probes };\n                        }\n                    }\n                    return { index, item: null, probes };\n                }\n                \n                // Open addressing methods\n                let i = 0;\n                while (true) {\n                    probes++;\n                    if (i >= this.size) {\n                        return { index: -1, item: null, probes };\n                    }\n                    \n                    if (this.collisionMethod === 'linear') {\n                        index = (originalHash + i) % this.size;\n                    } else if (this.collisionMethod === 'quadratic') {\n                        index = (originalHash + i*i) % this.size;\n                    }\n                    \n                    if (this.table[index].length === 0) {\n                        return { index: -1, item: null, probes };\n                    } else if (this.table[index][0].key === key) {\n                        this.totalProbes += probes;\n                        return { index, item: this.table[index].pop(), probes };\n                    } else {\n                        i++;\n                    }\n                }\n            }\n            \n            getLoadFactor() {\n                let count = 0;\n                for (const bucket of this.table) {\n                    count += bucket.length;\n                }\n                return count / this.size;\n            }\n            \n            getAvgProbes() {\n                return this.operations > 0 ? (this.totalProbes / this.operations).toFixed(2) : 0;\n            }\n        }\n\n        // UI Implementation\n        let hashTable = new HashTable();\n        let animationSpeed = 500;\n        let highlightedCells = [];\n        \n        function updateUI() {\n            // Update visualization\n            const visContainer = document.getElementById('hashVisualization');\n            visContainer.innerHTML = '';\n            \n            for (let i = 0; i < hashTable.size; i++) {\n                const bucketDiv = document.createElement('div');\n                bucketDiv.className = 'bucket-vis';\n                bucketDiv.textContent = i;\n                \n                if (highlightedCells.includes(i)) {\n                    bucketDiv.classList.add('highlight');\n                }\n                \n                const entries = hashTable.table[i];\n                if (entries.length > 0) {\n                    if (hashTable.collisionMethod === 'chaining' && entries.length > 1) {\n                        bucketDiv.classList.add('collision');\n                    }\n                    \n                    entries.forEach(entry => {\n                        const entryDiv = document.createElement('div');\n                        entryDiv.className = 'entry';\n                        entryDiv.textContent = `${entry.key}:${entry.value}`;\n                        bucketDiv.appendChild(entryDiv);\n                    });\n                }\n                \n                visContainer.appendChild(bucketDiv);\n            }\n            \n            // Update detailed table\n            const tableBody = document.getElementById('hashTableBody');\n            tableBody.innerHTML = '';\n            \n            for (let i = 0; i < hashTable.size; i++) {\n                const row = document.createElement('tr');\n                if (highlightedCells.includes(i)) {\n                    row.classList.add('highlight');\n                }\n                \n                const indexCell = document.createElement('td');\n                indexCell.textContent = i;\n                row.appendChild(indexCell);\n                \n                const entries = hashTable.table[i];\n                if (entries.length === 0) {\n                    row.appendChild(document.createElement('td'));\n                    row.appendChild(document.createElement('td'));\n                    row.appendChild(document.createElement('td'));\n                    row.appendChild(document.createElement('td'));\n                } else {\n                    if (hashTable.collisionMethod === 'chaining') {\n                        // For chaining, show all entries in the row\n                        const keyCell = document.createElement('td');\n                        const valueCell = document.createElement('td');\n                        const hashCell = document.createElement('td');\n                        const probesCell = document.createElement('td');\n                        \n                        keyCell.textContent = entries.map(e => e.key).join(', ');\n                        valueCell.textContent = entries.map(e => e.value).join(', ');\n                        hashCell.textContent = entries[0]?.hash ?? '';\n                        probesCell.textContent = entries.map(e => e.probes).join(', ');\n                        \n                        row.appendChild(keyCell);\n                        row.appendChild(valueCell);\n                        row.appendChild(hashCell);\n                        row.appendChild(probesCell);\n                    } else {\n                        // For open addressing, one entry per row\n                        const entry = entries[0];\n                        const keyCell = document.createElement('td');\n                        const valueCell = document.createElement('td');\n                        const hashCell = document.createElement('td');\n                        const probesCell = document.createElement('td');\n                        \n                        keyCell.textContent = entry.key;\n                        valueCell.textContent = entry.value;\n                        hashCell.textContent = entry.hash;\n                        probesCell.textContent = entry.probes;\n                        \n                        row.appendChild(keyCell);\n                        row.appendChild(valueCell);\n                        row.appendChild(hashCell);\n                        row.appendChild(probesCell);\n                    }\n                }\n                \n                tableBody.appendChild(row);\n            }\n            \n            // Update stats\n            document.getElementById('loadFactor').textContent = hashTable.getLoadFactor().toFixed(2);\n            document.getElementById('totalCollisions').textContent = hashTable.collisions;\n            document.getElementById('avgProbes').textContent = hashTable.getAvgProbes();\n            document.getElementById('operationCount').textContent = hashTable.operations;\n        }\n        \n        function highlightCell(index, duration = 1000) {\n            highlightedCells.push(index);\n            updateUI();\n            \n            setTimeout(() => {\n                highlightedCells = highlightedCells.filter(i => i !== index);\n                updateUI();\n            }, duration);\n        }\n        \n        function animateOperation(steps, finalAction) {\n            let stepIndex = 0;\n            \n            function nextStep() {\n                if (stepIndex < steps.length) {\n                    const step = steps[stepIndex];\n                    if (step.highlight !== undefined) {\n                        highlightedCells = [step.highlight];\n                    }\n                    updateUI();\n                    stepIndex++;\n                    setTimeout(nextStep, animationSpeed);\n                } else {\n                    highlightedCells = [];\n                    finalAction();\n                    updateUI();\n                }\n            }\n            \n            nextStep();\n        }\n        \n        // Event Listeners\n        document.getElementById('tableSize').addEventListener('input', function() {\n            document.getElementById('sizeValue').textContent = this.value;\n        });\n        \n        document.getElementById('resetTable').addEventListener('click', function() {\n            const size = parseInt(document.getElementById('tableSize').value);\n            const hashFn = document.getElementById('hashFunction').value;\n            const collisionMethod = document.getElementById('collisionMethod').value;\n            \n            hashTable = new HashTable(size, hashFn, collisionMethod);\n            updateUI();\n        });\n        \n        document.getElementById('insertBtn').addEventListener('click', function() {\n            const key = document.getElementById('keyInput').value;\n            const value = document.getElementById('valueInput').value;\n            \n            if (!key) {\n                alert(\"Please enter a key\");\n                return;\n            }\n            \n            const originalHash = hashTable.hash(key);\n            const steps = [\n                { message: `Calculating hash for key \"${key}\"...` },\n                { highlight: originalHash, message: `Initial hash index: ${originalHash}` }\n            ];\n            \n            if (hashTable.collisionMethod !== 'chaining') {\n                // For open addressing, show probing steps\n                let i = 0;\n                let index = originalHash;\n                while (i < hashTable.size) {\n                    if (hashTable.collisionMethod === 'linear') {\n                        index = (originalHash + i) % hashTable.size;\n                    } else if (hashTable.collisionMethod === 'quadratic') {\n                        index = (originalHash + i*i) % hashTable.size;\n                    }\n                    \n                    steps.push({ highlight: index, message: `Probing index ${index}...` });\n                    \n                    if (hashTable.table[index].length === 0) {\n                        break;\n                    } else if (hashTable.table[index][0].key === key) {\n                        break;\n                    }\n                    \n                    i++;\n                }\n            }\n            \n            animateOperation(steps, () => {\n                const result = hashTable.insert(key, value);\n                highlightCell(result.index);\n            });\n        });\n        \n        document.getElementById('searchBtn').addEventListener('click', function() {\n            const key = document.getElementById('keyInput').value;\n            \n            if (!key) {\n                alert(\"Please enter a key\");\n                return;\n            }\n            \n            const originalHash = hashTable.hash(key);\n            const steps = [\n                { message: `Calculating hash for key \"${key}\"...` },\n                { highlight: originalHash, message: `Initial hash index: ${originalHash}` }\n            ];\n            \n            if (hashTable.collisionMethod === 'chaining') {\n                // For chaining, just show the bucket\n                steps.push({ highlight: originalHash, message: `Searching chain at index ${originalHash}...` });\n            } else {\n                // For open addressing, show probing steps\n                let i = 0;\n                let index = -1;\n                while (i < hashTable.size) {\n                    if (hashTable.collisionMethod === 'linear') {\n                        index = (originalHash + i) % hashTable.size;\n                    } else if (hashTable.collisionMethod === 'quadratic') {\n                        index = (originalHash + i*i) % hashTable.size;\n                    }\n                    \n                    steps.push({ highlight: index, message: `Probing index ${index}...` });\n                    \n                    if (hashTable.table[index].length === 0) {\n                        break;\n                    } else if (hashTable.table[index][0].key === key) {\n                        break;\n                    }\n                    \n                    i++;\n                }\n            }\n            \n            animateOperation(steps, () => {\n                const result = hashTable.search(key);\n                if (result.item) {\n                    alert(`Found key \"${key}\" with value \"${result.item.value}\" at index ${result.index} (${result.probes} probes)`);\n                    highlightCell(result.index);\n                } else {\n                    alert(`Key \"${key}\" not found (${result.probes} probes)`);\n                }\n            });\n        });\n        \n        document.getElementById('deleteBtn').addEventListener('click', function() {\n            const key = document.getElementById('keyInput').value;\n            \n            if (!key) {\n                alert(\"Please enter a key\");\n                return;\n            }\n            \n            const originalHash = hashTable.hash(key);\n            const steps = [\n                { message: `Calculating hash for key \"${key}\"...` },\n                { highlight: originalHash, message: `Initial hash index: ${originalHash}` }\n            ];\n            \n            if (hashTable.collisionMethod === 'chaining') {\n                steps.push({ highlight: originalHash, message: `Searching chain at index ${originalHash} for deletion...` });\n            } else {\n                let i = 0;\n                let index = -1;\n                while (i < hashTable.size) {\n                    if (hashTable.collisionMethod === 'linear') {\n                        index = (originalHash + i) % hashTable.size;\n                    } else if (hashTable.collisionMethod === 'quadratic') {\n                        index = (originalHash + i*i) % hashTable.size;\n                    }\n                    \n                    steps.push({ highlight: index, message: `Probing index ${index} for deletion...` });\n                    \n                    if (hashTable.table[index].length === 0) {\n                        break;\n                    } else if (hashTable.table[index][0].key === key) {\n                        break;\n                    }\n                    \n                    i++;\n                }\n            }\n            \n            animateOperation(steps, () => {\n                const result = hashTable.delete(key);\n                if (result.item) {\n                    alert(`Deleted key \"${key}\" from index ${result.index} (${result.probes} probes)`);\n                    highlightCell(result.index);\n                } else {\n                    alert(`Key \"${key}\" not found for deletion (${result.probes} probes)`);\n                }\n            });\n        });\n        \n        document.getElementById('randomData').addEventListener('click', function() {\n            const count = parseInt(document.getElementById('randomCount').value);\n            const keys = new Set();\n            \n            while (keys.size < count) {\n                const randomKey = Math.random() > 0.5 ? \n                    Math.floor(Math.random() * 100) : \n                    Math.random().toString(36).substring(2, 5);\n                keys.add(randomKey);\n            }\n            \n            Array.from(keys).forEach((key, i) => {\n                setTimeout(() => {\n                    const value = `val${i+1}`;\n                    hashTable.insert(key, value);\n                    updateUI();\n                }, i * 300);\n            });\n        });\n        \n        document.getElementById('speedControl').addEventListener('input', function() {\n            animationSpeed = 1100 - this.value; // Invert so slider left is faster\n        });\n        \n        document.getElementById('calcHashBtn').addEventListener('click', function() {\n            const key = document.getElementById('hashTestKey').value;\n            const hashFn = document.getElementById('hashFunction').value;\n            const stepsDiv = document.getElementById('hashSteps');\n            stepsDiv.innerHTML = '';\n            \n            if (!key) {\n                stepsDiv.textContent = 'Please enter a key';\n                return;\n            }\n            \n            let steps = [];\n            let hash;\n            \n            if (hashFn === 'simple') {\n                if (typeof key === 'string') {\n                    steps.push(`Calculating simple hash for string \"${key}\":`);\n                    let sum = 0;\n                    steps.push(`Initialize sum = 0`);\n                    for (let i = 0; i < key.length; i++) {\n                        const code = key.charCodeAt(i);\n                        sum += code;\n                        steps.push(`Add char '${key[i]}' (ASCII ${code}): sum = ${sum}`);\n                    }\n                    hash = sum % hashTable.size;\n                    steps.push(`Final hash = sum % ${hashTable.size} = ${hash}`);\n                } else {\n                    steps.push(`Calculating simple hash for number ${key}:`);\n                    hash = key % hashTable.size;\n                    steps.push(`Final hash = ${key} % ${hashTable.size} = ${hash}`);\n                }\n            } else if (hashFn === 'multiplicative') {\n                steps.push(`Calculating multiplicative hash (using golden ratio):`);\n                let numericKey;\n                if (typeof key === 'string') {\n                    steps.push(`Converting string \"${key}\" to numeric value:`);\n                    numericKey = 0;\n                    for (let i = 0; i < key.length; i++) {\n                        numericKey = numericKey * 31 + key.charCodeAt(i);\n                        steps.push(`After char '${key[i]}': ${numericKey}`);\n                    }\n                } else {\n                    numericKey = key;\n                }\n                steps.push(`Numeric key: ${numericKey}`);\n                const A = 0.6180339887;\n                const product = numericKey * A;\n                steps.push(`Multiply by golden ratio (${A}): ${product}`);\n                const fractional = product - Math.floor(product);\n                steps.push(`Fractional part: ${fractional}`);\n                hash = Math.floor(hashTable.size * fractional);\n                steps.push(`Multiply by table size (${hashTable.size}): ${hashTable.size * fractional}`);\n                steps.push(`Floor to get final hash: ${hash}`);\n            } else if (hashFn === 'djb2') {\n                if (typeof key !== 'string') key = key.toString();\n                steps.push(`Calculating DJB2 hash for \"${key}\":`);\n                let hash = 5381;\n                steps.push(`Initial hash: ${hash}`);\n                for (let i = 0; i < key.length; i++) {\n                    const code = key.charCodeAt(i);\n                    hash = (hash * 33) ^ code;\n                    steps.push(`After char '${key[i]}' (ASCII ${code}): hash = ${hash}`);\n                }\n                hash = (hash >>> 0) % hashTable.size;\n                steps.push(`Ensure positive number: ${hash >>> 0}`);\n                steps.push(`Final hash = ${hash >>> 0} % ${hashTable.size} = ${hash}`);\n            }\n            \n            steps.forEach(step => {\n                const p = document.createElement('p');\n                p.textContent = step;\n                stepsDiv.appendChild(p);\n            });\n        });\n        \n        // Initialize\n        updateUI();\n    </script>\n</body>\n</html>"
