    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Ternary Search Visualization</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 2rem;\n            animation: fadeIn 1s ease-out;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 0.5rem;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n        }\n\n        .visualization-container {\n            width: 90%;\n            max-width: 1000px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            margin-bottom: 2rem;\n            position: relative;\n            overflow: hidden;\n            animation: slideUp 0.8s ease-out;\n        }\n\n        .visualization-container::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 10px;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n        }\n\n        .array-container {\n            display: flex;\n            justify-content: center;\n            margin: 2rem 0;\n            position: relative;\n            height: 200px;\n        }\n\n        .array-element {\n            width: 40px;\n            height: 40px;\n            background: var(--secondary);\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            margin: 0 5px;\n            transition: all 0.3s ease;\n            position: relative;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n        }\n\n        .array-element.highlight {\n            transform: scale(1.3);\n            background: var(--primary);\n            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.4);\n            z-index: 10;\n        }\n\n        .array-element.found {\n            background: var(--success);\n            transform: scale(1.5);\n            box-shadow: 0 10px 20px rgba(0, 184, 148, 0.4);\n        }\n\n        .array-element.partition {\n            background: var(--accent);\n        }\n\n        .array-element::after {\n            content: attr(data-index);\n            position: absolute;\n            bottom: -25px;\n            font-size: 0.8rem;\n            color: var(--dark);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n\n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            color: white;\n            font-weight: bold;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);\n        }\n\n        button:disabled {\n            opacity: 0.5;\n            transform: none;\n            box-shadow: none;\n            cursor: not-allowed;\n        }\n\n        .explanation {\n            max-width: 800px;\n            line-height: 1.6;\n            text-align: center;\n            margin-bottom: 2rem;\n            animation: fadeIn 1s ease-out 0.5s both;\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-bottom: 2rem;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 50%;\n        }\n\n        .status {\n            text-align: center;\n            font-size: 1.2rem;\n            margin-bottom: 1rem;\n            min-height: 2rem;\n            color: var(--primary);\n            font-weight: 500;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(30px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        .search-path {\n            position: absolute;\n            height: 2px;\n            background: var(--accent);\n            top: 50%;\n            transform: translateY(-50%);\n            z-index: -1;\n            transition: all 0.5s ease;\n        }\n\n        .complexity {\n            background: white;\n            border-radius: 20px;\n            padding: 1.5rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n            max-width: 600px;\n            margin-top: 1rem;\n            animation: fadeIn 1s ease-out 0.7s both;\n        }\n\n        .complexity h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            text-align: center;\n        }\n\n        .complexity-item {\n            display: flex;\n            justify-content: space-between;\n            padding: 0.5rem 0;\n            border-bottom: 1px solid rgba(0, 0, 0, 0.1);\n        }\n\n        .complexity-item:last-child {\n            border-bottom: none;\n        }\n\n        .complexity-name {\n            font-weight: bold;\n        }\n\n        .complexity-value {\n            color: var(--primary);\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Ternary Search</h1>\n        <p class=\"subtitle\">A visually stunning demonstration of divide and conquer</p>\n    </header>\n\n    <div class=\"visualization-container\">\n        <div class=\"status\" id=\"status\">Ready to search</div>\n        \n        <div class=\"array-container\" id=\"array-container\">\n            <!-- Array elements will be inserted here by JavaScript -->\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"start-btn\">Start Search</button>\n            <button id=\"reset-btn\" disabled>Reset</button>\n        </div>\n    </div>\n\n    <div class=\"explanation\">\n        <p>Ternary search is a divide-and-conquer search algorithm that divides the search space into three parts instead of two (like binary search). It determines which part might contain the target value and recursively searches that part.</p>\n    </div>\n\n    <div class=\"legend\">\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: #a29bfe;\"></div>\n            <span>Array Element</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: #6c5ce7;\"></div>\n            <span>Current Comparison</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: #fd79a8;\"></div>\n            <span>Partition Points</span>\n        </div>\n        <div class=\"legend-item\">\n            <div class=\"legend-color\" style=\"background: #00b894;\"></div>\n            <span>Found Target</span>\n        </div>\n    </div>\n\n    <div class=\"complexity\">\n        <h2>Algorithm Complexity</h2>\n        <div class=\"complexity-item\">\n            <span class=\"complexity-name\">Time Complexity (Best Case):</span>\n            <span class=\"complexity-value\">O(1)</span>\n        </div>\n        <div class=\"complexity-item\">\n            <span class=\"complexity-name\">Time Complexity (Average Case):</span>\n            <span class=\"complexity-value\">O(log₃ n)</span>\n        </div>\n        <div class=\"complexity-item\">\n            <span class=\"complexity-name\">Time Complexity (Worst Case):</span>\n            <span class=\"complexity-value\">O(log₃ n)</span>\n        </div>\n        <div class=\"complexity-item\">\n            <span class=\"complexity-name\">Space Complexity:</span>\n            <span class=\"complexity-value\">O(1)</span>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const arrayContainer = document.getElementById('array-container');\n            const startBtn = document.getElementById('start-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            const statusEl = document.getElementById('status');\n            \n            // Create a sorted array of 20 elements\n            const arr = Array.from({length: 20}, (_, i) => i + 1);\n            const target = 13; // The value we're searching for\n            let animationQueue = [];\n            let isAnimating = false;\n            \n            // Initialize the array visualization\n            function initArray() {\n                arrayContainer.innerHTML = '';\n                arr.forEach((val, idx) => {\n                    const element = document.createElement('div');\n                    element.className = 'array-element';\n                    element.textContent = val;\n                    element.dataset.index = idx;\n                    element.dataset.value = val;\n                    arrayContainer.appendChild(element);\n                });\n            }\n            \n            // Highlight elements with animation\n            function highlightElements(indexes, className, duration = 800) {\n                return new Promise(resolve => {\n                    const elements = document.querySelectorAll('.array-element');\n                    \n                    // Reset all highlights first\n                    elements.forEach(el => {\n                        el.classList.remove('highlight', 'partition', 'found');\n                    });\n                    \n                    // Apply new highlights\n                    indexes.forEach(idx => {\n                        elements[idx].classList.add(className);\n                    });\n                    \n                    setTimeout(resolve, duration);\n                });\n            }\n            \n            // Show search path\n            function showSearchPath(from, to, duration = 500) {\n                return new Promise(resolve => {\n                    const elements = document.querySelectorAll('.array-element');\n                    const fromEl = elements[from];\n                    const toEl = elements[to];\n                    \n                    const path = document.createElement('div');\n                    path.className = 'search-path';\n                    \n                    const fromRect = fromEl.getBoundingClientRect();\n                    const toRect = toEl.getBoundingClientRect();\n                    const containerRect = arrayContainer.getBoundingClientRect();\n                    \n                    const left = fromRect.left + fromRect.width/2 - containerRect.left;\n                    const width = toRect.left + toRect.width/2 - fromRect.left - fromRect.width/2;\n                    \n                    path.style.left = `${left}px`;\n                    path.style.width = `${width}px`;\n                    \n                    arrayContainer.appendChild(path);\n                    \n                    setTimeout(() => {\n                        path.style.opacity = '0';\n                        setTimeout(() => {\n                            path.remove();\n                            resolve();\n                        }, 300);\n                    }, duration);\n                });\n            }\n            \n            // Ternary search algorithm\n            async function ternarySearch(left, right) {\n                if (left > right) return -1;\n                \n                const mid1 = left + Math.floor((right - left) / 3);\n                const mid2 = right - Math.floor((right - left) / 3);\n                \n                await highlightElements([mid1, mid2], 'partition');\n                await showSearchPath(left, right);\n                await highlightElements([mid1, mid2], 'highlight');\n                \n                statusEl.textContent = `Comparing ${arr[mid1]} and ${arr[mid2]} with target ${target}`;\n                \n                if (arr[mid1] === target) {\n                    await highlightElements([mid1], 'found');\n                    statusEl.textContent = `Found target ${target} at index ${mid1}`;\n                    return mid1;\n                }\n                \n                if (arr[mid2] === target) {\n                    await highlightElements([mid2], 'found');\n                    statusEl.textContent = `Found target ${target} at index ${mid2}`;\n                    return mid2;\n                }\n                \n                if (target < arr[mid1]) {\n                    statusEl.textContent = `Target ${target} is in the first third (left of ${arr[mid1]})`;\n                    return await ternarySearch(left, mid1 - 1);\n                } else if (target > arr[mid2]) {\n                    statusEl.textContent = `Target ${target} is in the last third (right of ${arr[mid2]})`;\n                    return await ternarySearch(mid2 + 1, right);\n                } else {\n                    statusEl.textContent = `Target ${target} is between ${arr[mid1]} and ${arr[mid2]}`;\n                    return await ternarySearch(mid1 + 1, mid2 - 1);\n                }\n            }\n            \n            // Start the search\n            startBtn.addEventListener('click', async function() {\n                if (isAnimating) return;\n                \n                isAnimating = true;\n                startBtn.disabled = true;\n                resetBtn.disabled = true;\n                \n                statusEl.textContent = \"Starting ternary search...\";\n                await new Promise(resolve => setTimeout(resolve, 1000));\n                \n                const result = await ternarySearch(0, arr.length - 1);\n                \n                if (result === -1) {\n                    statusEl.textContent = `Target ${target} not found in the array`;\n                }\n                \n                resetBtn.disabled = false;\n                isAnimating = false;\n            });\n            \n            // Reset the visualization\n            resetBtn.addEventListener('click', function() {\n                initArray();\n                statusEl.textContent = \"Ready to search\";\n                startBtn.disabled = false;\n                resetBtn.disabled = true;\n            });\n            \n            // Initialize\n            initArray();\n        });\n    </script>\n</body>\n</html>"
