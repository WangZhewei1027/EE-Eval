    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Refactoring Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>Refactoring Interactive Demo</h1>\n\n<h2>Settings</h2>\n<button id=\"add\">Add Entry</button>\n<button id=\"clear\">Clear All</button>\n<input type=\"text\" id=\"inputField\" placeholder=\"Enter text\" />\n<button id=\"submit\">Submit</button>\n\n<h2>Entries</h2>\n<ul id=\"entriesList\"></ul>\n\n<h2>Metrics</h2>\n<p>Total Entries: <span id=\"totalEntries\">0</span></p>\n<p>Current Input Length: <span id=\"currentInputLength\">0</span></p>\n<p>Max Length: <span id=\"maxLength\">0</span></p>\n\n<h2>Adjust Max Length</h2>\n<input type=\"range\" id=\"maxLengthSlider\" min=\"1\" max=\"100\" value=\"10\" />\n<span id=\"maxLengthValue\">10</span>\n\n<h2>Refactor Entry</h2>\n<label for=\"refactorIndex\">Entry Index:</label>\n<input type=\"number\" id=\"refactorIndex\" min=\"0\" />\n<input type=\"text\" id=\"refactorValue\" placeholder=\"New Value\" />\n<button id=\"refactor\">Refactor</button>\n\n<div id=\"output\"></div>\n\n<script>\n    let entries = [];\n    let maxLength = 10;\n\n    document.getElementById('add').addEventListener('click', () => {\n        const entry = prompt('Enter new entry:');\n        if (entry && entry.length <= maxLength) {\n            entries.push(entry);\n            updateEntriesList();\n        } else {\n            alert(`Entry must be less than or equal to ${maxLength} characters.`);\n        }\n    });\n\n    document.getElementById('clear').addEventListener('click', () => {\n        entries = [];\n        updateEntriesList();\n    });\n\n    document.getElementById('submit').addEventListener('click', () => {\n        const textValue = document.getElementById('inputField').value;\n        if (textValue.length > 0 && textValue.length <= maxLength) {\n            entries.push(textValue);\n            updateEntriesList();\n            document.getElementById('inputField').value = '';\n        } else if (textValue.length > maxLength) {\n            alert(`Input exceeds max length of ${maxLength}`);\n        }\n    });\n\n    document.getElementById('maxLengthSlider').addEventListener('input', (event) => {\n        maxLength = event.target.value;\n        document.getElementById('maxLengthValue').innerText = maxLength;\n    });\n\n    document.getElementById('refactor').addEventListener('click', () => {\n        const index = parseInt(document.getElementById('refactorIndex').value, 10);\n        const newValue = document.getElementById('refactorValue').value;\n        if (index >= 0 && index < entries.length) {\n            entries[index] = newValue;\n            updateEntriesList();\n            document.getElementById('refactorIndex').value = '';\n            document.getElementById('refactorValue').value = '';\n        } else {\n            alert(\"Invalid index\");\n        }\n    });\n\n    function updateEntriesList() {\n        const list = document.getElementById('entriesList');\n        list.innerHTML = '';\n        entries.forEach((entry, index) => {\n            const listItem = document.createElement('li');\n            listItem.textContent = `${index}: ${entry}`;\n            list.appendChild(listItem);\n        });\n        document.getElementById('totalEntries').innerText = entries.length;\n        document.getElementById('currentInputLength').innerText = document.getElementById('inputField').value.length;\n        document.getElementById('maxLength').innerText = maxLength;\n    }\n\n    document.getElementById('inputField').addEventListener('input', (event) => {\n        document.getElementById('currentInputLength').innerText = event.target.value.length;\n    });\n</script>\n\n</body>\n</html>"
