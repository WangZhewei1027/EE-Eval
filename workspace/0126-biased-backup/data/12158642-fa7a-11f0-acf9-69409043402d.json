  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Deadlock Demonstration and Exploration</title>\n<style>\n  /* Minimal styling: only for layout */\n  body {\n    font-family: monospace, monospace;\n    margin: 20px;\n    background: white;\n    color: black;\n  }\n  label, button {\n    cursor: pointer;\n  }\n  input[type=\"number\"] {\n    width: 4em;\n  }\n  textarea {\n    width: 100%;\n    height: 8em;\n    font-family: monospace, monospace;\n  }\n  fieldset {\n    margin-bottom: 12px;\n  }\n  select {\n    font-family: monospace, monospace;\n  }\n</style>\n</head>\n<body>\n<h1>Deadlock Concept Interactive Simulator</h1>\n<p>\nThis tool simulates a system with multiple processes and resources to explore deadlocks.\nYou can create processes, define resource requests and allocations, simulate step-by-step execution,\nand experiment with different scheduling / resource granting policies to see deadlock conditions arise or get resolved.\n</p>\n\n<fieldset>\n<legend>Create/Reset System</legend>\n<label for=\"processCount\">Number of Processes (1-10): </label>\n<input id=\"processCount\" type=\"number\" min=\"1\" max=\"10\" value=\"3\" />\n<label for=\"resourceCount\">Number of Resource Types (1-6): </label>\n<input id=\"resourceCount\" type=\"number\" min=\"1\" max=\"6\" value=\"2\" />\n<button id=\"initSystemBtn\">Initialize System</button>\n<p>Click Initialize after changing values above to reset system state.</p>\n</fieldset>\n\n<fieldset id=\"resourcesFieldset\" style=\"display:none;\">\n<legend>Available Resources</legend>\n<div id=\"resourceInputsContainer\">\n<!-- Dynamically generated resource count inputs -->\n</div>\n<button id=\"setAvailableBtn\">Set Available Resources</button>\n</fieldset>\n\n<hr />\n\n<fieldset id=\"processControls\" style=\"display:none;\">\n<legend>Processes and Resource Requests / Allocations</legend>\n<table id=\"processTable\" border=\"1\" cellpadding=\"3\" cellspacing=\"0\">\n<thead>\n<tr>\n<th>Process ID</th>\n<th>Request Vector (resources)</th>\n<th>Allocation Vector (resources)</th>\n<th>Actions</th>\n</tr>\n</thead>\n<tbody>\n<!-- dynamically generated process rows -->\n</tbody>\n</table>\n<p>Note: Request vector means resources the process is waiting to acquire before proceeding.<br />\nAllocation vector means resources currently held by the process.</p>\n<button id=\"autoFillRequestsBtn\">Auto-Fill Random Requests</button>\n<button id=\"autoFillAllocationsBtn\">Auto-Fill Random Allocations</button>\n</fieldset>\n\n<hr />\n\n<fieldset id=\"simulationControls\" style=\"display:none;\">\n<legend>Simulation Controls</legend>\n<label for=\"policySelect\">Scheduling/Granting Policy:</label>\n<select id=\"policySelect\" title=\"Choose resource granting strategy\">\n  <option value=\"fifo\">FIFO (Grant request in order)</option>\n  <option value=\"roundrobin\">Round-Robin Scheduling</option>\n  <option value=\"banker\">Banker’s Algorithm (Safe State Only)</option>\n  <option value=\"random\">Random Granting</option>\n</select>\n<br /><br />\n<button id=\"stepBtn\">Step Simulation</button>\n<button id=\"runBtn\">Run Continuously</button>\n<button id=\"pauseBtn\" disabled>Pause</button>\n<button id=\"detectDeadlockBtn\">Detect Deadlock Now</button>\n<button id=\"resolveDeadlockBtn\">Attempt Deadlock Resolution</button>\n<label for=\"resolutionStrategy\">Resolution Strategy: </label>\n<select id=\"resolutionStrategy\" title=\"Choose how to resolve deadlock\">\n  <option value=\"abortOne\">Abort One Process</option>\n  <option value=\"abortAllBlocked\">Abort All Deadlocked</option>\n  <option value=\"preemptResources\">Preempt Resources and Retry</option>\n</select>\n</fieldset>\n\n<hr />\n\n<fieldset>\n<legend>Simulation Log & Status</legend>\n<textarea id=\"simulationLog\" readonly></textarea>\n</fieldset>\n\n<script>\n(() => {\n  // State variables\n  let processCount = 0;\n  let resourceCount = 0;\n  let available = []; // available resources vector\n  let processes = []; // Array of objects {id, request[], allocation[], state}\n  // state values: \"running\", \"waiting\", \"terminated\", \"blocked\"\n\n  // Simulation control\n  let simulationRunning = false;\n  let simulationInterval = null;\n\n  // Elements references\n  const processCountInput = document.getElementById('processCount');\n  const resourceCountInput = document.getElementById('resourceCount');\n  const initSystemBtn = document.getElementById('initSystemBtn');\n\n  const resourcesFieldset = document.getElementById('resourcesFieldset');\n  const resourceInputsContainer = document.getElementById('resourceInputsContainer');\n  const setAvailableBtn = document.getElementById('setAvailableBtn');\n\n  const processControls = document.getElementById('processControls');\n  const processTableBody = document.querySelector('#processTable tbody');\n  const autoFillRequestsBtn = document.getElementById('autoFillRequestsBtn');\n  const autoFillAllocationsBtn = document.getElementById('autoFillAllocationsBtn');\n\n  const simulationControls = document.getElementById('simulationControls');\n  const policySelect = document.getElementById('policySelect');\n  const stepBtn = document.getElementById('stepBtn');\n  const runBtn = document.getElementById('runBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const detectDeadlockBtn = document.getElementById('detectDeadlockBtn');\n  const resolveDeadlockBtn = document.getElementById('resolveDeadlockBtn');\n  const resolutionStrategySelect = document.getElementById('resolutionStrategy');\n  \n  const simulationLog = document.getElementById('simulationLog');\n\n  // Initialize system setup inputs after clicking init\n  initSystemBtn.addEventListener('click', () => {\n    const pCount = parseInt(processCountInput.value, 10);\n    const rCount = parseInt(resourceCountInput.value, 10);\n    if (\n      isNaN(pCount) || pCount < 1 || pCount > 10 ||\n      isNaN(rCount) || rCount < 1 || rCount > 6\n    ) {\n      alert('Process count must be 1-10 and Resource count must be 1-6.');\n      return;\n    }\n    processCount = pCount;\n    resourceCount = rCount;\n    resetSystemState();\n  });\n\n  function resetSystemState() {\n    // Reset all state\n    available = new Array(resourceCount).fill(0);\n    processes = [];\n    for (let i = 0; i < processCount; i++) {\n      processes.push({\n        id: i,\n        request: new Array(resourceCount).fill(0),\n        allocation: new Array(resourceCount).fill(0),\n        state: 'waiting' // assume all start waiting for resources\n      });\n    }\n    simulationRunning = false;\n    if (simulationInterval !== null) {\n      clearInterval(simulationInterval);\n      simulationInterval = null;\n    }\n    pauseBtn.disabled = true;\n    runBtn.disabled = false;\n    stepBtn.disabled = false;\n\n    logClear();\n    log(`System initialized with ${processCount} processes and ${resourceCount} resource types.`);\n\n    generateResourceInputs();\n    generateProcessTable();\n    resourcesFieldset.style.display = 'block';\n    processControls.style.display = 'block';\n    simulationControls.style.display = 'block';\n  }\n\n  // Generate inputs for resource available vector\n  function generateResourceInputs() {\n    resourceInputsContainer.innerHTML = '';\n    for (let r = 0; r < resourceCount; r++) {\n      const label = document.createElement('label');\n      label.textContent = `Resource R${r}: `;\n      const input = document.createElement('input');\n      input.type = 'number';\n      input.min = '0';\n      input.value = '0';\n      input.dataset.resourceIndex = r.toString();\n      input.size = 3;\n      label.appendChild(input);\n      resourceInputsContainer.appendChild(label);\n      resourceInputsContainer.appendChild(document.createTextNode(' '));\n    }\n  }\n\n  // Set available resources from inputs when user clicks setAvailableBtn\n  setAvailableBtn.addEventListener('click', () => {\n    const inputs = resourceInputsContainer.querySelectorAll('input[type=number]');\n    let sumAvailable = 0;\n    for (let i = 0; i < inputs.length; i++) {\n      let val = parseInt(inputs[i].value, 10);\n      if (isNaN(val) || val < 0) {\n        alert('Available resources must be non-negative integers.');\n        return;\n      }\n      available[i] = val;\n    }\n    log(`Available resource vector set to: [${available.join(', ')}]`);\n    generateProcessTable();\n  });\n\n  // Generate process table rows dynamically\n  function generateProcessTable() {\n    processTableBody.innerHTML = '';\n    processes.forEach((proc, idx) => {\n      const tr = document.createElement('tr');\n\n      // Process ID\n      const tdId = document.createElement('td');\n      tdId.textContent = `P${proc.id}`;\n      tr.appendChild(tdId);\n\n      // Request vector input fields\n      const tdRequest = document.createElement('td');\n      for (let r = 0; r < resourceCount; r++) {\n        const input = document.createElement('input');\n        input.type = 'number';\n        input.min = '0';\n        input.value = proc.request[r];\n        input.dataset.pid = proc.id;\n        input.dataset.type = 'request';\n        input.dataset.resourceIndex = r.toString();\n        input.size = 3;\n        input.addEventListener('change', onProcessResourceInputChange);\n        tdRequest.appendChild(input);\n        if (r < resourceCount - 1) tdRequest.appendChild(document.createTextNode(','));\n      }\n      tr.appendChild(tdRequest);\n\n      // Allocation vector input fields\n      const tdAllocation = document.createElement('td');\n      for (let r = 0; r < resourceCount; r++) {\n        const input = document.createElement('input');\n        input.type = 'number';\n        input.min = '0';\n        input.value = proc.allocation[r];\n        input.dataset.pid = proc.id;\n        input.dataset.type = 'allocation';\n        input.dataset.resourceIndex = r.toString();\n        input.size = 3;\n        input.addEventListener('change', onProcessResourceInputChange);\n        tdAllocation.appendChild(input);\n        if (r < resourceCount - 1) tdAllocation.appendChild(document.createTextNode(','));\n      }\n      tr.appendChild(tdAllocation);\n\n      // Actions\n      const tdActions = document.createElement('td');\n      // Terminate button\n      const terminateBtn = document.createElement('button');\n      terminateBtn.textContent = 'Terminate';\n      terminateBtn.dataset.pid = proc.id;\n      terminateBtn.addEventListener('click', () => {\n        terminateProcess(proc.id);\n      });\n      tdActions.appendChild(terminateBtn);\n\n      // Reset vectors button\n      const resetBtn = document.createElement('button');\n      resetBtn.textContent = 'Reset Req/Alloc';\n      resetBtn.dataset.pid = proc.id;\n      resetBtn.addEventListener('click', () => {\n        resetProcessVectors(proc.id);\n      });\n      tdActions.appendChild(document.createTextNode(' '));\n      tdActions.appendChild(resetBtn);\n\n      // Show state\n      const stateSpan = document.createElement('span');\n      stateSpan.textContent = ` State: ${proc.state}`;\n      stateSpan.style.whiteSpace = 'pre';\n      tdActions.appendChild(document.createTextNode(' '));\n      tdActions.appendChild(stateSpan);\n\n      tr.appendChild(tdActions);\n\n      processTableBody.appendChild(tr);\n    });\n  }\n\n  // Input handler to update process vectors\n  function onProcessResourceInputChange(e) {\n    const input = e.target;\n    const pid = parseInt(input.dataset.pid, 10);\n    const vecType = input.dataset.type; // 'request' or 'allocation'\n    const rIndex = parseInt(input.dataset.resourceIndex, 10);\n    let val = parseInt(input.value, 10);\n    if (isNaN(val) || val < 0) {\n      alert('Values must be non-negative integers.');\n      // reset to previous value\n      updateProcessTableInputs();\n      return;\n    }\n    const proc = processes.find(p => p.id === pid);\n    if (!proc) return;\n    if (vecType === 'request') {\n      proc.request[rIndex] = val;\n      if (proc.state === 'terminated') proc.state = 'waiting';\n    } else if (vecType === 'allocation') {\n      proc.allocation[rIndex] = val;\n      if (proc.state === 'terminated') proc.state = 'waiting';\n    }\n  }\n\n  // Update all process vector inputs from processes state (to correct any invalid inputs)\n  function updateProcessTableInputs() {\n    const inputs = processTableBody.querySelectorAll('input[type=number]');\n    inputs.forEach(input => {\n      const pid = parseInt(input.dataset.pid, 10);\n      const vecType = input.dataset.type;\n      const rIndex = parseInt(input.dataset.resourceIndex, 10);\n      const proc = processes.find(p => p.id === pid);\n      if (!proc) return;\n      if (vecType === 'request') {\n        if (input.value != proc.request[rIndex]) input.value = proc.request[rIndex];\n      } else if (vecType === 'allocation') {\n        if (input.value != proc.allocation[rIndex]) input.value = proc.allocation[rIndex];\n      }\n    });\n  }\n\n  // Terminate a process (freeing all resources allocated)\n  function terminateProcess(pid) {\n    const proc = processes.find(p => p.id === pid);\n    if (!proc) return;\n    if (proc.state === 'terminated') {\n      log(`Process P${pid} is already terminated.`);\n      return;\n    }\n    // Release resources back to available\n    for (let r = 0; r < resourceCount; r++) {\n      available[r] += proc.allocation[r];\n      proc.allocation[r] = 0;\n      proc.request[r] = 0;\n    }\n    proc.state = 'terminated';\n    updateProcessTableInputs();\n    log(`Process P${pid} terminated. Its allocated resources released back to available.`);\n  }\n\n  // Reset request and allocation vectors of a process to zero\n  function resetProcessVectors(pid) {\n    const proc = processes.find(p => p.id === pid);\n    if (!proc) return;\n    for(let r=0;r<resourceCount;r++){\n      proc.request[r] = 0;\n      proc.allocation[r] = 0;\n    }\n    if(proc.state === 'terminated') proc.state = 'waiting';\n    updateProcessTableInputs();\n    log(`Process P${pid}'s request and allocation vectors reset.`);\n  }\n\n  // Auto fill requests randomly (bounded by available resources + allocations)\n  autoFillRequestsBtn.addEventListener('click', () => {\n    processes.forEach(proc => {\n      if(proc.state === 'terminated') return;\n      for (let r = 0; r < resourceCount; r++) {\n        // can request up to (total system resources of Rr - currently allocated)\n        // But we don't have total system resource vector. Assume available + sum allocations = total system amount\n        let total = available[r];\n        processes.forEach(p => {\n          total += p.allocation[r];\n        });\n        // Request between 0 and (total - current allocation)\n        const maxReq = Math.max(0, total - proc.allocation[r]);\n        proc.request[r] = Math.floor(Math.random() * (maxReq + 1));\n      }\n    });\n    log('Random requests filled for all processes.');\n    updateProcessTableInputs();\n  });\n\n  // Auto fill allocations randomly (bounded by available + process request to keep it consistent)\n  autoFillAllocationsBtn.addEventListener('click', () => {\n    // We try to keep allocation <= (total system resources), and <= request + allocated to avoid absurd states\n    processes.forEach(proc => {\n      if(proc.state === 'terminated') return;\n      for (let r = 0; r < resourceCount; r++) {\n        // total resources for Rr\n        let total = available[r];\n        processes.forEach(p => {\n          total += p.allocation[r];\n        });\n        // Allocate a random number between 0 and total\n        // But ensure allocation + request doesn't exceed total\n        const maxAlloc = Math.min(total, proc.allocation[r] + proc.request[r]) || 0;\n        proc.allocation[r] = Math.floor(Math.random() * (maxAlloc + 1));\n        // If allocation exceeds total (rare), clamp\n        if(proc.allocation[r] > total) proc.allocation[r] = total;\n      }\n    });\n    log('Random allocations filled for all processes.');\n    updateProcessTableInputs();\n  });\n\n  // Simulation stepping\n  stepBtn.addEventListener('click', () => {\n    stepSimulation();\n  });\n\n  runBtn.addEventListener('click', () => {\n    if(simulationRunning) return;\n    simulationRunning = true;\n    runBtn.disabled = true;\n    pauseBtn.disabled = false;\n    stepBtn.disabled = true;\n    simulationInterval = setInterval(() => {\n      if(!simulationRunning) return;\n      const progress = stepSimulation();\n      if(progress === false){\n        // no progress, auto pause\n        log('No progress possible, simulation paused.');\n        pauseSimulation();\n      }\n    }, 1000);\n  });\n\n  pauseBtn.addEventListener('click', () => {\n    pauseSimulation();\n  });\n\n  function pauseSimulation() {\n    simulationRunning = false;\n    runBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n    if(simulationInterval !== null){\n      clearInterval(simulationInterval);\n      simulationInterval = null;\n    }\n    log('Simulation paused.');\n  }\n\n  // Step simulation return true if any progress made, else false\n  function stepSimulation() {\n    // Apply scheduling policy and try grant requests if possible\n    const policy = policySelect.value;\n    log(`Simulation step under policy: ${policy}`);\n    switch(policy){\n      case 'fifo': return stepFIFO();\n      case 'roundrobin': return stepRoundRobin();\n      case 'banker': return stepBanker();\n      case 'random': return stepRandomGrant();\n      default: log('Unknown policy selected.'); return false;\n    }\n  }\n\n  // Returns true if any allocation change happened or process terminated; else false\n  function stepFIFO() {\n    // Grant requests in process order if possible\n    let progress = false;\n    for(let proc of processes){\n      if(proc.state === 'terminated') continue;\n      if(canGrantRequest(proc)){\n        grantResources(proc);\n        progress = true;\n        // After granting, check if process can terminate (all requests fulfilled)\n        if(isRequestFulfilled(proc)) {\n          terminateProcess(proc.id);\n          progress = true;\n        } else {\n          proc.state = 'running'; // running since granted resources\n        }\n      } else {\n        proc.state = 'waiting';\n      }\n    }\n    generateProcessTable();\n    return progress;\n  }\n\n  // Round-robin index state:\n  let rrIndex = 0;\n  function stepRoundRobin() {\n    if(processes.length === 0) return false;\n    let progress = false;\n    let count = 0;\n    // Try each process once in round robin order\n    while(count < processes.length) {\n      let proc = processes[rrIndex];\n      rrIndex = (rrIndex + 1) % processes.length;\n      if(proc.state === 'terminated'){\n        count++;\n        continue;\n      }\n      if(canGrantRequest(proc)){\n        grantResources(proc);\n        progress = true;\n        if(isRequestFulfilled(proc)) {\n          terminateProcess(proc.id);\n          progress = true;\n        } else {\n          proc.state = 'running';\n        }\n        break; // grant one per step\n      } else {\n        proc.state = 'waiting';\n      }\n      count++;\n    }\n    generateProcessTable();\n    return progress;\n  }\n\n  // Banker Algorithm: only grant if system remains in safe state after grant\n  function stepBanker() {\n    let grantedAny = false;\n    for(let proc of processes){\n      if(proc.state === 'terminated') continue;\n      if(canGrantRequest(proc)){\n        // simulate grant temporarily\n        const backupAvailable = available.slice();\n        for(let r=0;r<resourceCount;r++) {\n          available[r] -= proc.request[r];\n          proc.allocation[r] += proc.request[r];\n          proc.request[r] = 0;\n        }\n        // Check if safe state\n        if(isSafeState()){\n          grantedAny = true;\n          proc.state = 'running';\n          if(isRequestFulfilled(proc)){\n            terminateProcess(proc.id);\n          }\n          generateProcessTable();\n          log(`Process P${proc.id} granted safely under banker’s algorithm.`);\n          return true; // grant one process per step\n        } else {\n          // revert grant\n          available = backupAvailable;\n          for(let r=0;r<resourceCount;r++) {\n            proc.allocation[r] -= proc.request[r];\n            // proc.request[r] unchanged since revert\n          }\n          proc.state = 'waiting';\n        }\n      } else {\n        proc.state = 'waiting';\n      }\n    }\n    generateProcessTable();\n    return grantedAny;\n  }\n\n  // Random grant some process request which fits available\n  function stepRandomGrant(){\n    // collect candidates\n    const candidates = processes.filter(proc => proc.state !== 'terminated' && canGrantRequest(proc));\n    if(candidates.length === 0) {\n      // no progress\n      processes.forEach(p => {\n        if(p.state !== 'terminated') p.state = 'waiting';\n      });\n      generateProcessTable();\n      return false;\n    }\n    // Randomly pick one\n    const proc = candidates[Math.floor(Math.random()*candidates.length)];\n    grantResources(proc);\n    proc.state = 'running';\n    if(isRequestFulfilled(proc)){\n      terminateProcess(proc.id);\n    }\n    generateProcessTable();\n    log(`Process P${proc.id} randomly granted its request.`);\n    return true;\n  }\n\n  // Check if all request resources can be fulfilled with available\n  function canGrantRequest(proc) {\n    if(proc.state === 'terminated') return false;\n    for(let r=0;r<resourceCount;r++) {\n      if(proc.request[r] > available[r]) return false;\n    }\n    return true;\n  }\n\n  // Grant requested resources to process\n  function grantResources(proc) {\n    for(let r=0;r<resourceCount;r++){\n      available[r] -= proc.request[r];\n      proc.allocation[r] += proc.request[r];\n      proc.request[r] = 0;\n    }\n    log(`Resources granted to process P${proc.id}.`);\n  }\n\n  // Check if request vector is all zero (fulfilled)\n  function isRequestFulfilled(proc) {\n    return proc.request.every(v => v === 0);\n  }\n\n  // Banker Algorithm helper - check if system is in safe state:\n  function isSafeState() {\n    // Work vector copy of available\n    const work = available.slice();\n    const finish = processes.map(p => p.state === 'terminated');\n    let changed;\n\n    do {\n      changed = false;\n      for (let i = 0; i < processes.length; i++){\n        if(finish[i]) continue;\n        const p = processes[i];\n        let canFinish = true;\n        for(let r = 0; r < resourceCount; r++){\n          if(p.request[r] > work[r]){\n            canFinish = false;\n            break;\n          }\n        }\n        if(canFinish){\n          for(let r = 0; r < resourceCount; r++){\n            work[r] += p.allocation[r];\n          }\n          finish[i] = true;\n          changed = true;\n        }\n      }\n    } while(changed);\n\n    return finish.every(f => f);\n  }\n\n  // Deadlock detection (Coffman conditions) - Returns list of deadlocked processes by ID\n  function detectDeadlock() {\n    // Basic deadlock detection:\n    // Construct wait-for graph or use deadlock detection algorithm: If some processes cannot finish due to waiting circularly for resources.\n\n    // Work vector copy\n    const work = available.slice();\n    const finish = processes.map(p => p.state === 'terminated');\n    let changed;\n\n    do {\n      changed = false;\n      for (let i = 0; i < processes.length; i++){\n        if(finish[i]) continue;\n        const p = processes[i];\n        let canFinish = true;\n        for(let r = 0; r < resourceCount; r++){\n          if(p.request[r] > work[r]){\n            canFinish = false;\n            break;\n          }\n        }\n        if(canFinish){\n          for(let r = 0; r < resourceCount; r++){\n            work[r] += p.allocation[r];\n          }\n          finish[i] = true;\n          changed = true;\n        }\n      }\n    } while(changed);\n\n    // Processes not finished and not terminated are deadlocked\n    let deadlocked = [];\n    for(let i=0; i < processes.length; i++){\n      if(!finish[i] && processes[i].state !== 'terminated'){\n        deadlocked.push(processes[i].id);\n      }\n    }\n    return deadlocked;\n  }\n\n  // Detect deadlock button handler\n  detectDeadlockBtn.addEventListener('click', () => {\n    const deadlocked = detectDeadlock();\n    if(deadlocked.length === 0){\n      log('No deadlock detected.');\n    } else {\n      log(`Deadlock detected! Deadlocked processes: ${deadlocked.map(id => 'P'+id).join(', ')}`);\n    }\n  });\n\n  // Deadlock resolution strategies\n  resolveDeadlockBtn.addEventListener('click', () => {\n    const deadlocked = detectDeadlock();\n    if(deadlocked.length === 0){\n      log('No deadlock detected, no actions needed.');\n      return;\n    }\n    const strategy = resolutionStrategySelect.value;\n    log(`Attempting to resolve deadlock using strategy: ${strategy}`);\n    switch(strategy){\n      case 'abortOne': {\n        // Abort one process (lowest ID)\n        deadlocked.sort((a,b)=>a-b);\n        const pid = deadlocked[0];\n        abortProcess(pid);\n        break;\n      }\n      case 'abortAllBlocked': {\n        // Abort all deadlocked processes\n        deadlocked.forEach(pid => abortProcess(pid));\n        break;\n      }\n      case 'preemptResources': {\n        // Preempt resources from deadlocked processes forcibly back to available, clearing allocations and requests, then reset them to waiting\n        deadlocked.forEach(pid => preemptProcess(pid));\n        break;\n      }\n      default:\n        log('Unknown deadlock resolution strategy.');\n        break;\n    }\n    generateProcessTable();\n    log('Deadlock resolution attempted.');\n  });\n\n  // Abort a process forcibly (free all alloc and set terminated)\n  function abortProcess(pid){\n    const proc = processes.find(p => p.id === pid);\n    if(!proc) return;\n    for(let r=0;r<resourceCount;r++){\n      available[r] += proc.allocation[r];\n      proc.allocation[r] = 0;\n      proc.request[r] = 0;\n    }\n    proc.state = 'terminated';\n    log(`Process P${pid} aborted to resolve deadlock.`);\n  }\n\n  // Preempt a process (free all allocated resources forcibly, reset requests, but keep it waiting)\n  function preemptProcess(pid){\n    const proc = processes.find(p => p.id === pid);\n    if(!proc) return;\n    for(let r=0;r<resourceCount;r++){\n      available[r] += proc.allocation[r];\n      proc.allocation[r] = 0;\n      proc.request[r] = 0;\n    }\n    proc.state = 'waiting';\n    log(`Resources preempted from process P${pid}. Process reset to waiting.`);\n  }\n\n  // Logging functions\n  function log(msg){\n    const timestamp = new Date().toLocaleTimeString();\n    simulationLog.value += `[${timestamp}] ${msg}\\n`;\n    simulationLog.scrollTop = simulationLog.scrollHeight;\n  }\n\n  function logClear(){\n    simulationLog.value = '';\n  }\n\n  // Initialize on load\n  resetSystemState();\n})();\n</script>\n</body>\n</html>"
  },
