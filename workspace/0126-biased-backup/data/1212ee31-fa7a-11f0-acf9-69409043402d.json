  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Set Exploration</title>\n<style>\n  /* Minimal styling - only basic layout */\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n  }\n  button, input[type=\"text\"], input[type=\"number\"] {\n    margin: 0.2em 0.4em 0.2em 0;\n  }\n  hr {\n    margin: 1em 0;\n  }\n  textarea {\n    width: 100%;\n    height: 6em;\n  }\n  pre {\n    white-space: pre-wrap;\n    word-break: break-word;\n  }\n  label {\n    display: block;\n    margin-bottom: 0.2em;\n  }\n</style>\n</head>\n<body>\n<h1>Set Theory Interactive Explorer</h1>\n\n<!-- Section 1: Create and Modify Sets -->\n<section id=\"set-creation\">\n  <h2>1. Create / Modify Sets</h2>\n  <label for=\"set-name-input\">Set Name (unique, required):</label>\n  <input type=\"text\" id=\"set-name-input\" placeholder=\"e.g. A\" maxlength=\"20\" />\n  <br />\n  <label for=\"set-elements-input\">Elements (comma-separated strings):</label>\n  <input type=\"text\" id=\"set-elements-input\" placeholder=\"e.g. 1,2,a,b\" />\n  <br />\n  <button id=\"create-set-btn\">Create Set</button>\n  <button id=\"update-set-btn\" disabled>Update Set</button>\n  <button id=\"delete-set-btn\" disabled>Delete Set</button>\n  <br />\n  <label for=\"select-set\">Select Existing Set:</label>\n  <select id=\"select-set\" size=\"5\" style=\"width: 12em;\"></select>\n  <br />\n  <div id=\"set-status\" aria-live=\"polite\" style=\"min-height:1.5em;\"></div>\n</section>\n\n<hr />\n\n<!-- Section 2: View Set Elements & Membership -->\n<section id=\"set-view\">\n  <h2>2. View Set Elements & Membership</h2>\n  <label for=\"view-set-select\">Choose Set to View:</label>\n  <select id=\"view-set-select\" style=\"width: 12em;\"></select>\n  <button id=\"view-elements-btn\" disabled>Show Elements</button>\n  <div id=\"elements-output\" style=\"white-space: pre-wrap; margin-top: 0.5em;\"></div>\n  <br />\n  <label for=\"membership-element-input\">Check if element is in selected set:</label>\n  <input type=\"text\" id=\"membership-element-input\" placeholder=\"Element to check\" />\n  <button id=\"check-membership-btn\" disabled>Check Membership</button>\n  <div id=\"membership-result\" style=\"margin-top: 0.5em;\"></div>\n</section>\n\n<hr />\n\n<!-- Section 3: Set Operations -->\n<section id=\"set-operations\">\n  <h2>3. Set Operations (Select Sets and Operate)</h2>\n  <label for=\"op-set1\">Set 1:</label>\n  <select id=\"op-set1\" style=\"width: 12em;\"></select>\n  <label for=\"op-set2\">Set 2:</label>\n  <select id=\"op-set2\" style=\"width: 12em;\"></select>\n  <br />\n  <button id=\"union-btn\" disabled>Union (Set1 ∪ Set2)</button>\n  <button id=\"intersection-btn\" disabled>Intersection (Set1 ∩ Set2)</button>\n  <button id=\"difference-btn\" disabled>Difference (Set1 \\ Set2)</button>\n  <button id=\"symmetric-diff-btn\" disabled>Symmetric Difference</button>\n  <button id=\"cartesian-prod-btn\" disabled>Cartesian Product</button>\n  <br />\n  <label for=\"result-set-name\">Save Result as New Set (optional name):</label>\n  <input type=\"text\" id=\"result-set-name\" placeholder=\"e.g. C\" maxlength=\"20\" />\n  <button id=\"save-result-btn\" disabled>Save Result</button>\n  <br />\n  <div id=\"operation-result\" style=\"white-space: pre-wrap; margin-top: 0.5em;\"></div>\n</section>\n\n<hr />\n\n<!-- Section 4: Advanced Operations -->\n<section id=\"advanced-operations\">\n  <h2>4. Advanced Set Operations & Workflows</h2>\n  <label for=\"adv-set-select\">Choose Set:</label>\n  <select id=\"adv-set-select\" style=\"width: 12em;\"></select>\n  <br />\n  <button id=\"power-set-btn\" disabled>Power Set</button>\n  <button id=\"cartesian-power-btn\" disabled>Cartesian Power (Set^n)</button>\n  <input type=\"number\" id=\"cartesian-power-n\" value=\"2\" min=\"1\" max=\"6\" style=\"width: 4em;\" />\n  <br />\n  <label for=\"subset-test-a\">Subset Test - Set A:</label>\n  <select id=\"subset-test-a\" style=\"width: 12em;\"></select>\n  <label for=\"subset-test-b\">Set B:</label>\n  <select id=\"subset-test-b\" style=\"width: 12em;\"></select>\n  <button id=\"subset-test-btn\" disabled>Is A ⊆ B?</button>\n  <div id=\"advanced-result\" style=\"white-space: pre-wrap; margin-top: 0.5em;\"></div>\n  <br />\n\n  <label for=\"element-filter-input\">Filter elements of a set by condition (JavaScript expression):</label>\n  <input type=\"text\" id=\"element-filter-input\" placeholder=\"e.g. el.startsWith('a') || +el > 10\" style=\"width: 50%;\" />\n  <button id=\"filter-elements-btn\" disabled>Filter Elements</button>\n  <br />\n  <label for=\"filter-set-select\">Set to Filter:</label>\n  <select id=\"filter-set-select\" style=\"width: 12em;\"></select>\n  <div id=\"filter-result\" style=\"white-space: pre-wrap; margin-top: 0.5em;\"></div>\n</section>\n\n<hr />\n\n<!-- Section 5: Workflow - Build Complex Set Expressions -->\n<section id=\"expression-builder\">\n  <h2>5. Build and Evaluate Complex Set Expressions</h2>\n  <p>\n    Use set names separated by operators (∪, ∩, \\, Δ for symmetric difference, × for cartesian product).\n    Parentheses supported.<br />\n    Example: (A ∪ B) \\ C\n  </p>\n  <label for=\"expr-input\">Expression:</label><br />\n  <input type=\"text\" id=\"expr-input\" style=\"width: 100%;\" placeholder=\"e.g. (A ∪ B) \\ C\" />\n  <button id=\"eval-expr-btn\">Evaluate Expression</button>\n  <div id=\"expr-result\" style=\"white-space: pre-wrap; margin-top: 0.5em;\"></div>\n  <br />\n  <label for=\"expr-save-name\">Save result set as (optional):</label>\n  <input type=\"text\" id=\"expr-save-name\" maxlength=\"20\" />\n  <button id=\"expr-save-btn\" disabled>Save Result Set</button>\n</section>\n\n<script>\n(() => {\n  // Storage for sets: object with keys as set names, values as Sets of strings\n  const sets = {};\n\n  // Utilities\n  function parseElements(str) {\n    // Split by comma, trim whitespace, ignore empty strings\n    return new Set(str.split(',').map(s => s.trim()).filter(s => s.length > 0));\n  }\n\n  function setToString(set) {\n    return '{ ' + Array.from(set).sort().join(', ') + ' }';\n  }\n\n  // Deep clone set\n  function cloneSet(set) {\n    return new Set(set);\n  }\n\n  // Set operations\n  function union(setA, setB) {\n    return new Set([...setA, ...setB]);\n  }\n  function intersection(setA, setB) {\n    return new Set([...setA].filter(x => setB.has(x)));\n  }\n  function difference(setA, setB) {\n    return new Set([...setA].filter(x => !setB.has(x)));\n  }\n  function symmetricDifference(setA, setB) {\n    return union(difference(setA, setB), difference(setB, setA));\n  }\n  function cartesianProduct(setA, setB) {\n    const result = new Set();\n    for (const a of setA) {\n      for (const b of setB) {\n        result.add('(' + a + ',' + b + ')');\n      }\n    }\n    return result;\n  }\n\n  // Power set (returns a Set of string representations of subsets)\n  function powerSet(set) {\n    const arr = Array.from(set);\n    const powerSetSize = 1 << arr.length;\n    const result = new Set();\n    for (let mask = 0; mask < powerSetSize; mask++) {\n      const subset = [];\n      for (let i = 0; i < arr.length; i++) {\n        if ((mask & (1 << i)) !== 0) {\n          subset.push(arr[i]);\n        }\n      }\n      result.add('{ ' + subset.join(', ') + ' }');\n    }\n    return result;\n  }\n\n  // Cartesian power Set^n\n  function cartesianPower(set, n) {\n    if (n <= 0) return new Set();\n    if (n === 1) return cloneSet(set);\n\n    let result = cloneSet(set);\n    for (let i = 1; i < n; i++) {\n      result = cartesianProduct(result, set);\n    }\n    return result;\n  }\n\n  function isSubset(setA, setB) {\n    for (const el of setA) {\n      if (!setB.has(el)) return false;\n    }\n    return true;\n  }\n\n  // Manage UI elements references\n  const setNameInput = document.getElementById('set-name-input');\n  const setElementsInput = document.getElementById('set-elements-input');\n  const createSetBtn = document.getElementById('create-set-btn');\n  const updateSetBtn = document.getElementById('update-set-btn');\n  const deleteSetBtn = document.getElementById('delete-set-btn');\n  const selectSet = document.getElementById('select-set');\n  const setStatus = document.getElementById('set-status');\n\n  const viewSetSelect = document.getElementById('view-set-select');\n  const viewElementsBtn = document.getElementById('view-elements-btn');\n  const elementsOutput = document.getElementById('elements-output');\n  const membershipElementInput = document.getElementById('membership-element-input');\n  const checkMembershipBtn = document.getElementById('check-membership-btn');\n  const membershipResult = document.getElementById('membership-result');\n\n  const opSet1 = document.getElementById('op-set1');\n  const opSet2 = document.getElementById('op-set2');\n  const unionBtn = document.getElementById('union-btn');\n  const intersectionBtn = document.getElementById('intersection-btn');\n  const differenceBtn = document.getElementById('difference-btn');\n  const symmetricDiffBtn = document.getElementById('symmetric-diff-btn');\n  const cartesianProdBtn = document.getElementById('cartesian-prod-btn');\n  const resultSetNameInput = document.getElementById('result-set-name');\n  const saveResultBtn = document.getElementById('save-result-btn');\n  const operationResult = document.getElementById('operation-result');\n\n  const advSetSelect = document.getElementById('adv-set-select');\n  const powerSetBtn = document.getElementById('power-set-btn');\n  const cartesianPowerBtn = document.getElementById('cartesian-power-btn');\n  const cartesianPowerNInput = document.getElementById('cartesian-power-n');\n  const subsetTestASelect = document.getElementById('subset-test-a');\n  const subsetTestBSelect = document.getElementById('subset-test-b');\n  const subsetTestBtn = document.getElementById('subset-test-btn');\n  const advancedResult = document.getElementById('advanced-result');\n  const elementFilterInput = document.getElementById('element-filter-input');\n  const filterElementsBtn = document.getElementById('filter-elements-btn');\n  const filterSetSelect = document.getElementById('filter-set-select');\n  const filterResult = document.getElementById('filter-result');\n\n  const exprInput = document.getElementById('expr-input');\n  const evalExprBtn = document.getElementById('eval-expr-btn');\n  const exprResult = document.getElementById('expr-result');\n  const exprSaveName = document.getElementById('expr-save-name');\n  const exprSaveBtn = document.getElementById('expr-save-btn');\n\n  // Update all selects with current set names\n  function refreshAllSelects() {\n    const names = Object.keys(sets).sort();\n\n    function fillSelect(select) {\n      const oldVal = select.value;\n      select.innerHTML = '';\n      for (const name of names) {\n        const opt = document.createElement('option');\n        opt.value = name;\n        opt.textContent = name;\n        select.appendChild(opt);\n      }\n      if (names.includes(oldVal)) {\n        select.value = oldVal;\n      } else {\n        if (select.options.length > 0) select.selectedIndex = 0;\n        else select.value = '';\n      }\n    }\n\n    fillSelect(selectSet);\n    fillSelect(viewSetSelect);\n    fillSelect(opSet1);\n    fillSelect(opSet2);\n    fillSelect(advSetSelect);\n    fillSelect(subsetTestASelect);\n    fillSelect(subsetTestBSelect);\n    fillSelect(filterSetSelect);\n  }\n\n  function setButtonsState() {\n    const selName = selectSet.value;\n    const hasSel = selName && sets[selName];\n    updateSetBtn.disabled = !hasSel;\n    deleteSetBtn.disabled = !hasSel;\n\n    const viewSel = viewSetSelect.value;\n    viewElementsBtn.disabled = !viewSel;\n    checkMembershipBtn.disabled = !viewSel || membershipElementInput.value.trim() === '';\n\n    const op1 = opSet1.value;\n    const op2 = opSet2.value;\n    const bothSelected = op1 && sets[op1] && op2 && sets[op2];\n\n    unionBtn.disabled = !bothSelected;\n    intersectionBtn.disabled = !bothSelected;\n    differenceBtn.disabled = !bothSelected;\n    symmetricDiffBtn.disabled = !bothSelected;\n    cartesianProdBtn.disabled = !bothSelected;\n\n    saveResultBtn.disabled = !operationResult.textContent || !operationResult.textContent.includes('{');\n\n    powerSetBtn.disabled = !advSetSelect.value;\n    cartesianPowerBtn.disabled =\n      !advSetSelect.value || !(parseInt(cartesianPowerNInput.value) >= 1 && parseInt(cartesianPowerNInput.value) <= 6);\n\n    const subA = subsetTestASelect.value;\n    const subB = subsetTestBSelect.value;\n    subsetTestBtn.disabled = !(subA && sets[subA] && subB && sets[subB]);\n\n    filterElementsBtn.disabled = !filterSetSelect.value || !elementFilterInput.value.trim();\n\n    evalExprBtn.disabled = exprInput.value.trim() === '';\n    exprSaveBtn.disabled = !(exprResult.textContent && exprResult.textContent.includes('{'));\n  }\n\n  // Helper: show status message\n  function showSetStatus(msg) {\n    setStatus.textContent = msg;\n    setTimeout(() => {\n      if (setStatus.textContent === msg) setStatus.textContent = '';\n    }, 7000);\n  }\n\n  // Create Set Button Handler\n  createSetBtn.addEventListener('click', () => {\n    const name = setNameInput.value.trim();\n    if (!name) {\n      showSetStatus('ERROR: Set name cannot be empty.');\n      return;\n    }\n    if (sets.hasOwnProperty(name)) {\n      showSetStatus('ERROR: Set \"' + name + '\" already exists.');\n      return;\n    }\n    const elements = parseElements(setElementsInput.value);\n    // Allow empty set\n    sets[name] = elements;\n    refreshAllSelects();\n    showSetStatus('Set \"' + name + '\" created with ' + elements.size + ' element(s).');\n    selectSet.value = name;\n    setButtonsState();\n  });\n\n  // When selectSet changes, fill inputs\n  selectSet.addEventListener('change', () => {\n    const sel = selectSet.value;\n    if (sel && sets.hasOwnProperty(sel)) {\n      setNameInput.value = sel;\n      setElementsInput.value = Array.from(sets[sel]).join(', ');\n      updateSetBtn.disabled = false;\n      deleteSetBtn.disabled = false;\n    } else {\n      setNameInput.value = '';\n      setElementsInput.value = '';\n      updateSetBtn.disabled = true;\n      deleteSetBtn.disabled = true;\n    }\n    setButtonsState();\n  });\n\n  // Update Set Button Handler\n  updateSetBtn.addEventListener('click', () => {\n    const oldName = selectSet.value;\n    if (!oldName || !sets.hasOwnProperty(oldName)) {\n      showSetStatus('ERROR: No set selected to update.');\n      return;\n    }\n    const newName = setNameInput.value.trim();\n    if (!newName) {\n      showSetStatus('ERROR: Set name cannot be empty.');\n      return;\n    }\n    if (newName !== oldName && sets.hasOwnProperty(newName)) {\n      showSetStatus('ERROR: Set name \"' + newName + '\" already exists.');\n      return;\n    }\n    const elements = parseElements(setElementsInput.value);\n    if (newName !== oldName) {\n      // Rename\n      sets[newName] = elements;\n      delete sets[oldName];\n      // Update all references for selects\n      refreshAllSelects();\n      selectSet.value = newName;\n\n      // Also update selects based on old name, best effort: not automatable fully\n      // But we can keep it synced by refreshing selects.\n    } else {\n      // Just update elements\n      sets[oldName] = elements;\n    }\n    showSetStatus('Set \"' + newName + '\" updated with ' + elements.size + ' element(s).');\n    setButtonsState();\n  });\n\n  // Delete Set Button Handler\n  deleteSetBtn.addEventListener('click', () => {\n    const name = selectSet.value;\n    if (!name || !sets.hasOwnProperty(name)) {\n      showSetStatus('ERROR: No set selected to delete.');\n      return;\n    }\n    if (!confirm('Delete set \"' + name + '\"? This action cannot be undone.')) return;\n    delete sets[name];\n    refreshAllSelects();\n    setNameInput.value = '';\n    setElementsInput.value = '';\n    showSetStatus('Set \"' + name + '\" deleted.');\n    setButtonsState();\n  });\n\n  // View Elements Button handler\n  viewSetSelect.addEventListener('change', () => {\n    viewElementsBtn.disabled = !viewSetSelect.value;\n    checkMembershipBtn.disabled = true;\n    membershipResult.textContent = '';\n    elementsOutput.textContent = '';\n    setButtonsState();\n  });\n\n  membershipElementInput.addEventListener('input', () => {\n    checkMembershipBtn.disabled = membershipElementInput.value.trim() === '' || !viewSetSelect.value;\n    membershipResult.textContent = '';\n    setButtonsState();\n  });\n\n  viewElementsBtn.addEventListener('click', () => {\n    const name = viewSetSelect.value;\n    if (!name || !sets.hasOwnProperty(name)) {\n      elementsOutput.textContent = 'No set selected or set does not exist.';\n      return;\n    }\n    const elms = sets[name];\n    elementsOutput.textContent = 'Set ' + name + ' elements (' + elms.size + '):\\n' + setToString(elms);\n  });\n\n  checkMembershipBtn.addEventListener('click', () => {\n    const name = viewSetSelect.value;\n    const el = membershipElementInput.value.trim();\n    if (!name || !sets[name]) {\n      membershipResult.textContent = 'Set not selected or does not exist.';\n      return;\n    }\n    if (!el) {\n      membershipResult.textContent = 'Enter an element to check.';\n      return;\n    }\n    const isMember = sets[name].has(el);\n    membershipResult.textContent = 'Element \"' + el + '\" is ' + (isMember ? '' : 'NOT ') + 'in set \"' + name + '\".';\n  });\n\n  // Update op-set selects initial state\n  function opSetsChanged() {\n    const valid = opSet1.value && opSet2.value && sets[opSet1.value] && sets[opSet2.value];\n    unionBtn.disabled = !valid;\n    intersectionBtn.disabled = !valid;\n    differenceBtn.disabled = !valid;\n    symmetricDiffBtn.disabled = !valid;\n    cartesianProdBtn.disabled = !valid;\n    operationResult.textContent = '';\n    saveResultBtn.disabled = true;\n    resultSetNameInput.value = '';\n  }\n  opSet1.addEventListener('change', opSetsChanged);\n  opSet2.addEventListener('change', opSetsChanged);\n  resultSetNameInput.addEventListener('input', () => {\n    saveResultBtn.disabled = operationResult.textContent === '' || resultSetNameInput.value.trim() === '';\n  });\n\n  function displayOperationResult(set) {\n    operationResult.textContent = 'Result (' + set.size + ' elements):\\n' + setToString(set);\n    saveResultBtn.disabled = false;\n  }\n\n  unionBtn.addEventListener('click', () => {\n    const s1 = sets[opSet1.value];\n    const s2 = sets[opSet2.value];\n    displayOperationResult(union(s1, s2));\n  });\n\n  intersectionBtn.addEventListener('click', () => {\n    const s1 = sets[opSet1.value];\n    const s2 = sets[opSet2.value];\n    displayOperationResult(intersection(s1, s2));\n  });\n\n  differenceBtn.addEventListener('click', () => {\n    const s1 = sets[opSet1.value];\n    const s2 = sets[opSet2.value];\n    displayOperationResult(difference(s1, s2));\n  });\n\n  symmetricDiffBtn.addEventListener('click', () => {\n    const s1 = sets[opSet1.value];\n    const s2 = sets[opSet2.value];\n    displayOperationResult(symmetricDifference(s1, s2));\n  });\n\n  cartesianProdBtn.addEventListener('click', () => {\n    const s1 = sets[opSet1.value];\n    const s2 = sets[opSet2.value];\n    displayOperationResult(cartesianProduct(s1, s2));\n  });\n\n  saveResultBtn.addEventListener('click', () => {\n    const name = resultSetNameInput.value.trim();\n    if (!name) {\n      operationResult.textContent = 'ERROR: Provide a name to save result.';\n      return;\n    }\n    if (sets.hasOwnProperty(name)) {\n      operationResult.textContent = 'ERROR: Set name \"' + name + '\" already exists.';\n      return;\n    }\n    let resultText = operationResult.textContent;\n    if (!resultText.startsWith('Result (')) {\n      operationResult.textContent = 'ERROR: No result to save.';\n      return;\n    }\n    // Extract elements from result string\n    const idx = resultText.indexOf('\\n');\n    if (idx < 0) return;\n    let elementsText = resultText.slice(idx + 1).trim();\n    // Parse elementsText \"{ a, b, (1,2) }\"\n    if (elementsText[0] !== '{' || elementsText[elementsText.length - 1] !== '}') {\n      operationResult.textContent = 'ERROR: Result format invalid.';\n      return;\n    }\n    elementsText = elementsText.slice(1, -1).trim();\n    const elements = new Set();\n    if (elementsText.length > 0) {\n      // Split on comma but respecting parentheses group? For this minimal iface, just split on comma and everything else is string\n      // Accept elements like (1,2)\n      let buf = '';\n      let parenCount = 0;\n      const parts = [];\n      for (const c of elementsText) {\n        if (c === ',' && parenCount === 0) {\n          parts.push(buf.trim());\n          buf = '';\n        } else {\n          buf += c;\n          if (c === '(') parenCount++;\n          else if (c === ')') parenCount--;\n        }\n      }\n      if (buf.trim() !== '') parts.push(buf.trim());\n      for (const p of parts) {\n        if (p.length > 0) elements.add(p);\n      }\n    }\n    sets[name] = elements;\n    refreshAllSelects();\n    setStatus.textContent = 'Set \"' + name + '\" saved with ' + elements.size + ' element(s).';\n    setButtonsState();\n    saveResultBtn.disabled = true;\n    resultSetNameInput.value = '';\n  });\n\n  // Advanced Operations handlers\n  advSetSelect.addEventListener('change', () => {\n    powerSetBtn.disabled = !advSetSelect.value;\n    cartesianPowerBtn.disabled =\n      !advSetSelect.value || !(parseInt(cartesianPowerNInput.value) >= 1 && parseInt(cartesianPowerNInput.value) <= 6);\n    advancedResult.textContent = '';\n    setButtonsState();\n  });\n\n  cartesianPowerNInput.addEventListener('input', () => {\n    cartesianPowerBtn.disabled =\n      !advSetSelect.value || !(parseInt(cartesianPowerNInput.value) >= 1 && parseInt(cartesianPowerNInput.value) <= 6);\n    setButtonsState();\n  });\n\n  powerSetBtn.addEventListener('click', () => {\n    const name = advSetSelect.value;\n    if (!name || !sets[name]) {\n      advancedResult.textContent = 'Set not selected or does not exist.';\n      return;\n    }\n    const ps = powerSet(sets[name]);\n    advancedResult.textContent = 'Power set of \"' + name + '\" (' + ps.size + ' subsets):\\n' + Array.from(ps).join('\\n');\n  });\n\n  cartesianPowerBtn.addEventListener('click', () => {\n    const name = advSetSelect.value;\n    if (!name || !sets[name]) {\n      advancedResult.textContent = 'Set not selected or does not exist.';\n      return;\n    }\n    const n = parseInt(cartesianPowerNInput.value, 10);\n    if (!(n >= 1 && n <= 6)) {\n      advancedResult.textContent = 'Enter n between 1 and 6.';\n      return;\n    }\n    const cp = cartesianPower(sets[name], n);\n    advancedResult.textContent =\n      'Cartesian power ' + name + '^' + n + ' (' + cp.size + ' elements):\\n' + setToString(cp);\n  });\n\n  subsetTestASelect.addEventListener('change', () => {\n    subsetTestBtn.disabled =\n      !(subsetTestASelect.value && subsetsHas(subsetTestASelect.value) && subsetTestBSelect.value && subsetsHas(subsetTestBSelect.value));\n    advancedResult.textContent = '';\n    setButtonsState();\n  });\n  subsetTestBSelect.addEventListener('change', () => {\n    subsetTestBtn.disabled =\n      !(subsetTestASelect.value && subsetsHas(subsetTestASelect.value) && subsetTestBSelect.value && subsetsHas(subsetTestBSelect.value));\n    advancedResult.textContent = '';\n    setButtonsState();\n  });\n\n  function subsetsHas(name) {\n    return name && sets[name];\n  }\n\n  subsetTestBtn.addEventListener('click', () => {\n    const A = subsetTestASelect.value;\n    const B = subsetTestBSelect.value;\n    if (!sets[A] || !sets[B]) {\n      advancedResult.textContent = 'Selected sets do not exist.';\n      return;\n    }\n    const res = isSubset(sets[A], sets[B]);\n    advancedResult.textContent = 'Is \"' + A + '\" ⊆ \"' + B + '\"? ' + (res ? 'YES' : 'NO');\n  });\n\n  filterSetSelect.addEventListener('change', () => {\n    filterResult.textContent = '';\n    setButtonsState();\n  });\n  elementFilterInput.addEventListener('input', () => {\n    filterResult.textContent = '';\n    setButtonsState();\n  });\n\n  filterElementsBtn.addEventListener('click', () => {\n    const setName = filterSetSelect.value;\n    if (!sets[setName]) {\n      filterResult.textContent = 'Selected set does not exist.';\n      return;\n    }\n    const condition = elementFilterInput.value.trim();\n    if (!condition) {\n      filterResult.textContent = 'Enter a filter condition.';\n      return;\n    }\n    const originalSet = sets[setName];\n    // Use Function constructor to filter elements safely\n    // Each element value is string; allow user to reference it as \"el\"\n    let filterFunc;\n    try {\n      filterFunc = new Function('el', 'return ' + condition + ';');\n    } catch (e) {\n      filterResult.textContent = 'ERROR in condition: ' + e.message;\n      return;\n    }\n    const filtered = [];\n    try {\n      for (const el of originalSet) {\n        if (filterFunc(el)) filtered.push(el);\n      }\n    } catch (e) {\n      filterResult.textContent = 'ERROR while filtering elements: ' + e.message;\n      return;\n    }\n    filterResult.textContent =\n      'Filter result (' + filtered.length + ' elements from set \"' + setName + '\"):\\n{ ' + filtered.join(', ') + ' }';\n  });\n\n  // Expression parser and evaluator\n  // Supported operators: ∪ (union), ∩ (intersection), \\ (difference), Δ (symmetric diff), × (cartesian product)\n  // Parentheses allowed\n  // Expression must be in terms of known set names\n  // For simplicity, parsing uses simple tokenizing, shunting yard to RPN, then evaluate RPN\n\n  const operators = {\n    '∪': { precedence: 1, func: union, arity: 2, assoc: 'left' },\n    '∩': { precedence: 2, func: intersection, arity: 2, assoc: 'left' },\n    '\\\\': { precedence: 3, func: difference, arity: 2, assoc: 'left' },\n    'Δ': { precedence: 1, func: symmetricDifference, arity: 2, assoc: 'left' },\n    '×': { precedence: 4, func: cartesianProduct, arity: 2, assoc: 'left' }\n  };\n\n  function tokenize(expr) {\n    // Tokens: set names (alphanumeric+_). Operators ∪∩\\Δ×. Parentheses (). Spaces ignored.\n    const tokens = [];\n    let i = 0;\n    while (i < expr.length) {\n      const c = expr[i];\n      if (c === ' ' || c === '\\t' || c === '\\n') {\n        i++;\n        continue;\n      }\n      if (c === '(' || c === ')') {\n        tokens.push(c);\n        i++;\n        continue;\n      }\n      if (Object.keys(operators).includes(c)) {\n        tokens.push(c);\n        i++;\n        continue;\n      }\n      // Assume set names: letters, digits, _, starting with letter or underscore\n      if (/[A-Za-z_]/.test(c)) {\n        let start = i;\n        i++;\n        while (i < expr.length && /[A-Za-z0-9_]/.test(expr[i])) i++;\n        tokens.push(expr.slice(start, i));\n        continue;\n      }\n      throw new Error('Invalid character \"' + c + '\" at position ' + i);\n    }\n    return tokens;\n  }\n\n  function toRPN(tokens) {\n    const out = [];\n    const stack = [];\n\n    for (const token of tokens) {\n      if (Object.keys(operators).includes(token)) {\n        while (\n          stack.length > 0 &&\n          Object.keys(operators).includes(stack[stack.length - 1]) &&\n          ((operators[token].assoc === 'left' &&\n            operators[token].precedence <= operators[stack[stack.length - 1]].precedence) ||\n            (operators[token].assoc === 'right' &&\n              operators[token].precedence < operators[stack[stack.length - 1]].precedence))\n        ) {\n          out.push(stack.pop());\n        }\n        stack.push(token);\n      } else if (token === '(') {\n        stack.push(token);\n      } else if (token === ')') {\n        while (stack.length > 0 && stack[stack.length - 1] !== '(') {\n          out.push(stack.pop());\n        }\n        if (stack.length === 0) throw new Error('Mismatched parentheses');\n        stack.pop(); // Pop '('\n      } else {\n        // Operand (set name)\n        out.push(token);\n      }\n    }\n    while (stack.length > 0) {\n      const op = stack.pop();\n      if (op === '(' || op === ')') {\n        throw new Error('Mismatched parentheses');\n      }\n      out.push(op);\n    }\n    return out;\n  }\n\n  function evaluateRPN(rpn) {\n    const stack = [];\n    for (const token of rpn) {\n      if (Object.keys(operators).includes(token)) {\n        if (stack.length < 2) throw new Error('Invalid expression: insufficient operands for operator \"' + token + '\"');\n        const b = stack.pop();\n        const a = stack.pop();\n        const res = operators[token].func(a, b);\n        stack.push(res);\n      } else {\n        if (!sets[token]) throw new Error('Set \"' + token + '\" not defined.');\n        stack.push(sets[token]);\n      }\n    }\n    if (stack.length !== 1) throw new Error('Invalid expression: too many operands');\n    return stack[0];\n  }\n\n  evalExprBtn.addEventListener('click', () => {\n    const expr = exprInput.value.trim();\n    exprResult.textContent = '';\n    exprSaveBtn.disabled = true;\n    if (!expr) {\n      exprResult.textContent = 'Enter an expression to evaluate.';\n      return;\n    }\n    let tokens;\n    try {\n      tokens = tokenize(expr);\n    } catch (e) {\n      exprResult.textContent = 'ERROR tokenizing expression: ' + e.message;\n      return;\n    }\n    let rpn;\n    try {\n      rpn = toRPN(tokens);\n    } catch (e) {\n      exprResult.textContent = 'ERROR parsing expression: ' + e.message;\n      return;\n    }\n    let resSet;\n    try {\n      resSet = evaluateRPN(rpn);\n    } catch (e) {\n      exprResult.textContent = 'ERROR evaluating expression: ' + e.message;\n      return;\n    }\n    exprResult.textContent = 'Result (' + resSet.size + ' elements):\\n' + setToString(resSet);\n    exprSaveBtn.disabled = false;\n  });\n\n  exprSaveBtn.addEventListener('click', () => {\n    const name = exprSaveName.value.trim();\n    if (!exprResult.textContent || !exprResult.textContent.includes('{')) {\n      exprResult.textContent = 'No result to save.';\n      return;\n    }\n    if (!name) {\n      exprResult.textContent = 'Enter a name to save the result.';\n      return;\n    }\n    if (sets.hasOwnProperty(name)) {\n      exprResult.textContent = 'Set \"' + name + '\" already exists.';\n      return;\n    }\n    // Extract elements from exprResult.textContent\n    const idx = exprResult.textContent.indexOf('\\n');\n    if (idx < 0) return;\n    let elementsText = exprResult.textContent.slice(idx + 1).trim();\n    if (elementsText[0] !== '{' || elementsText[elementsText.length - 1] !== '}') {\n      exprResult.textContent = 'ERROR: Result format invalid.';\n      return;\n    }\n    elementsText = elementsText.slice(1, -1).trim();\n    const elements = new Set();\n    if (elementsText.length > 0) {\n      let buf = '';\n      let parenCount = 0;\n      const parts = [];\n      for (const c of elementsText) {\n        if (c === ',' && parenCount === 0) {\n          parts.push(buf.trim());\n          buf = '';\n        } else {\n          buf += c;\n          if (c === '(') parenCount++;\n          else if (c === ')') parenCount--;\n        }\n      }\n      if (buf.trim() !== '') parts.push(buf.trim());\n      for (const p of parts) {\n        if (p.length > 0) elements.add(p);\n      }\n    }\n    sets[name] = elements;\n    refreshAllSelects();\n    exprSaveName.value = '';\n    exprSaveBtn.disabled = true;\n    exprResult.textContent = 'Set \"' + name + '\" saved with ' + elements.size + ' element(s).';\n    setButtonsState();\n  });\n\n  // Initialize all selects empty\n  refreshAllSelects();\n  setButtonsState();\n\n  // Accessibility and focus + tab order intuitive due to HTML order\n\n})();\n</script>\n\n</body>\n</html>"
