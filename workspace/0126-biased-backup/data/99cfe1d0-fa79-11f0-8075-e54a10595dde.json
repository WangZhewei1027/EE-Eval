    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deadlock Simulation</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .control { margin: 10px; }\n    </style>\n</head>\n<body>\n\n<h1>Deadlock Simulation</h1>\n<p>This simulation illustrates the concept of a deadlock in a resource allocation scenario.</p>\n\n<div class=\"control\">\n    <label for=\"resourceA\">Resource A:</label>\n    <input type=\"number\" id=\"resourceA\" value=\"1\" min=\"0\" max=\"10\" />\n</div>\n<div class=\"control\">\n    <label for=\"resourceB\">Resource B:</label>\n    <input type=\"number\" id=\"resourceB\" value=\"1\" min=\"0\" max=\"10\" />\n</div>\n\n<div class=\"control\">\n    <button id=\"requestA\">Request Resource A for Process 1</button>\n    <button id=\"requestB\">Request Resource B for Process 2</button>\n    <button id=\"releaseA\">Release Resource A from Process 1</button>\n    <button id=\"releaseB\">Release Resource B from Process 2</button>\n</div>\n\n<div class=\"control\">\n    <h3>Deadlock State:</h3>\n    <p id=\"state\">No deadlock detected.</p>\n</div>\n\n<div class=\"control\">\n    <button id=\"reset\">Reset Simulation</button>\n</div>\n\n<script>\n    let resourceA = 1;\n    let resourceB = 1;\n    let allocatedA = 0;\n    let allocatedB = 0;\n\n    document.getElementById('requestA').onclick = function() {\n        if (resourceA > 0 && allocatedB < 1) {\n            allocatedA++;\n            resourceA--;\n            checkDeadlock();\n        } else {\n            alert(\"Process 1 cannot request Resource A.\");\n        }\n    };\n\n    document.getElementById('requestB').onclick = function() {\n        if (resourceB > 0 && allocatedA < 1) {\n            allocatedB++;\n            resourceB--;\n            checkDeadlock();\n        } else {\n            alert(\"Process 2 cannot request Resource B.\");\n        }\n    };\n\n    document.getElementById('releaseA').onclick = function() {\n        if (allocatedA > 0) {\n            allocatedA--;\n            resourceA++;\n            checkDeadlock();\n        } else {\n            alert(\"No Resource A allocated to release.\");\n        }\n    };\n\n    document.getElementById('releaseB').onclick = function() {\n        if (allocatedB > 0) {\n            allocatedB--;\n            resourceB++;\n            checkDeadlock();\n        } else {\n            alert(\"No Resource B allocated to release.\");\n        }\n    };\n\n    document.getElementById('reset').onclick = function() {\n        resourceA = 1;\n        resourceB = 1;\n        allocatedA = 0;\n        allocatedB = 0;\n        updateState(\"Simulation reset.\");\n    };\n\n    function checkDeadlock() {\n        if (allocatedA > 0 && allocatedB > 0) {\n            updateState(\"Deadlock detected between Process 1 and Process 2.\");\n        } else {\n            updateState(\"No deadlock detected.\");\n        }\n    }\n\n    function updateState(message) {\n        document.getElementById('state').innerText = message;\n    }\n</script>\n\n</body>\n</html>"
