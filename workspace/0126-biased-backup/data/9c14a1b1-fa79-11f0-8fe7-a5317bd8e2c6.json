  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Interactive PageRank Explorer</title>\n  <style>\n    /* Extremely minimal styling: plain black text on white background */\n    html,body { margin:8px; padding:0; font-family: Arial, Helvetica, sans-serif; color: black; background: white; }\n    .row { display:flex; gap:12px; align-items:flex-start; }\n    .panel { min-width:320px; max-width:420px; }\n    .controls { border:1px solid #000; padding:8px; }\n    label { display:block; margin-top:6px; font-size:13px; }\n    input[type=\"number\"], input[type=\"text\"], select, textarea { width:100%; box-sizing:border-box; }\n    button { margin-top:6px; display:inline-block; }\n    canvas { border:1px solid #000; cursor:crosshair; background: white; }\n    pre { white-space:pre-wrap; max-height:240px; overflow:auto; border:1px solid #000; padding:6px; }\n    small { color: #000; }\n  </style>\n</head>\n<body>\n  <h2>PageRank Explorer (Interactive)</h2>\n  <div class=\"row\">\n    <div class=\"panel controls\" id=\"controlPanel\">\n      <div>\n        <strong>Graph Construction</strong>\n      </div>\n      <label>\n        Node Label:\n        <input type=\"text\" id=\"nodeLabel\" placeholder=\"optional label (auto if blank)\">\n      </label>\n      <button id=\"addNodeBtn\">Add Node (random position)</button>\n      <button id=\"addNodeAtCenterBtn\">Add Node (center)</button>\n      <label>\n        Add Edge Mode:\n        <select id=\"edgeMode\">\n          <option value=\"click\">Click nodes (source then target)</option>\n          <option value=\"select\">Select from lists</option>\n        </select>\n      </label>\n      <div id=\"edgeSelectControls\" style=\"display:none;\">\n        <label>Source:\n          <select id=\"edgeSource\"></select>\n        </label>\n        <label>Target:\n          <select id=\"edgeTarget\"></select>\n      </label>\n      </div>\n      <label>\n        Edge Weight:\n        <input type=\"number\" id=\"edgeWeight\" value=\"1\" step=\"0.1\">\n      </label>\n      <label>\n        Directed:\n        <input type=\"checkbox\" id=\"directedToggle\" checked>\n      </label>\n      <div>\n        <button id=\"startAddEdgeBtn\">Start Add Edge</button>\n        <button id=\"finishAddEdgeBtn\">Cancel Edge</button>\n        <button id=\"delSelectedBtn\">Delete Selected Node</button>\n        <label>\n          Selected Node:\n          <select id=\"selectedNode\"></select>\n        </label>\n      </div>\n\n      <hr>\n      <div><strong>Random Graph Generator</strong></div>\n      <label>Nodes:\n        <input type=\"number\" id=\"randNodes\" value=\"10\" min=\"1\" max=\"200\">\n      </label>\n      <label>Edge Probability (0-1):\n        <input type=\"number\" id=\"randProb\" value=\"0.2\" min=\"0\" max=\"1\" step=\"0.01\">\n      </label>\n      <label>Weight Range:\n        <input type=\"text\" id=\"weightRange\" value=\"1,1\" placeholder=\"min,max\">\n      </label>\n      <label>Seed (optional, integer):\n        <input type=\"number\" id=\"randSeed\" placeholder=\"optional\">\n      </label>\n      <button id=\"genRandBtn\">Generate Random Graph (clears current)</button>\n\n      <hr>\n      <div><strong>PageRank Controls</strong></div>\n      <label>Damping factor (d):\n        <input type=\"number\" id=\"damping\" value=\"0.85\" step=\"0.01\" min=\"0\" max=\"0.999\">\n      </label>\n      <label>Personalization vector:\n        <select id=\"persMode\">\n          <option value=\"uniform\">Uniform</option>\n          <option value=\"selected\">Give selected node higher weight</option>\n          <option value=\"custom\">Custom vector (JSON)</option>\n        </select>\n      </label>\n      <div id=\"persCustom\" style=\"display:none;\">\n        <label>Custom personalization JSON (array length = nodes):\n          <textarea id=\"persJSON\" rows=\"3\">[]</textarea>\n        </label>\n      </div>\n      <label>Tolerance (convergence L1) :\n        <input type=\"number\" id=\"tol\" value=\"1e-6\" step=\"1e-6\">\n      </label>\n      <label>Max iterations:\n        <input type=\"number\" id=\"maxIter\" value=\"1000\" min=\"1\">\n      </label>\n      <label>Normalize by:\n        <select id=\"normMode\">\n          <option value=\"column\">Column-stochastic (standard PageRank)</option>\n          <option value=\"row\">Row-stochastic (alternate)</option>\n        </select>\n      </label>\n      <div style=\"margin-top:6px;\">\n        <button id=\"initPRBtn\">Initialize PageRank</button>\n        <button id=\"stepPRBtn\">Step</button>\n        <button id=\"runPRBtn\">Run</button>\n        <button id=\"pausePRBtn\">Pause</button>\n        <button id=\"resetPRBtn\">Reset</button>\n        <label style=\"display:inline-block;margin-left:8px;\">\n          Iter/sec:\n          <input type=\"number\" id=\"itersPerSec\" value=\"4\" min=\"1\" max=\"200\">\n        </label>\n      </div>\n      <label>Auto-stop on convergence:\n        <input type=\"checkbox\" id=\"autoStop\" checked>\n      </label>\n      <label>Sink handling:\n        <select id=\"sinkMode\">\n          <option value=\"teleport\">Teleport to personalization vector (standard)</option>\n          <option value=\"uniform\">Teleport to uniform</option>\n          <option value=\"selfloop\">Add self-loop</option>\n        </select>\n      </label>\n\n      <hr>\n      <div><strong>Advanced & Export</strong></div>\n      <button id=\"showMatrixBtn\">Toggle Matrices/View</button>\n      <button id=\"exportJSONBtn\">Export Graph + Settings (JSON)</button>\n      <button id=\"importJSONBtn\">Import JSON</button>\n      <input type=\"file\" id=\"importFile\" style=\"display:none;\">\n      <div style=\"margin-top:6px;\">\n        <label>Log / History (clearing will not affect current run):</label>\n        <button id=\"clearLogBtn\">Clear Log</button>\n      </div>\n      <div style=\"margin-top:6px;\">\n        <label>Extra Tools:</label>\n        <button id=\"rankSortBtn\">Sort Nodes by Rank Desc</button>\n        <button id=\"rescaleBtn\">Rescale Node Positions to Canvas</button>\n      </div>\n    </div>\n\n    <div style=\"flex:1\">\n      <div>\n        <canvas id=\"graphCanvas\" width=\"800\" height=\"520\"></canvas>\n      </div>\n      <div style=\"margin-top:8px;\">\n        <strong>Status/History</strong>\n        <div>\n          Iteration: <span id=\"iterCount\">0</span>\n          &nbsp; Last L1 change: <span id=\"lastChange\">-</span>\n          &nbsp; Running: <span id=\"runningFlag\">false</span>\n        </div>\n        <pre id=\"logArea\"></pre>\n      </div>\n\n      <div id=\"matrixView\" style=\"display:none; margin-top:8px;\">\n        <strong>Matrices & Details</strong>\n        <div>\n          <label>Adjacency list (from → to : weight)</label>\n          <pre id=\"adjListPre\"></pre>\n        </div>\n        <div>\n          <label>Stochastic transition matrix (columns sum = 1 if column-stochastic)</label>\n          <pre id=\"stochPre\"></pre>\n        </div>\n        <div>\n          <label>PageRank vector (current)</label>\n          <pre id=\"prPre\"></pre>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n PageRank Explorer - fully client-side single-file app\n - Minimal visual design\n - Rich interactivity: graph construction, random generation, step/run PageRank,\n   personalization, sink handling, matrices, export/import, draggable nodes, etc.\n*/\n\n// Utility: seeded PRNG (xorshift32)\nfunction makeSeededRandom(seed) {\n  let x = seed ? seed >>> 0 : Math.floor(Math.random()*0xFFFFFFFF);\n  if (x === 0) x = 123456789;\n  return function() {\n    // xorshift32\n    x ^= x << 13; x ^= x >>> 17; x ^= x << 5;\n    return (x >>> 0) / 0xFFFFFFFF;\n  };\n}\n\n// Graph model\nlet G = {\n  nodes: [], // {id: string, label: string, x,y}\n  edges: [], // {from: id, to: id, weight: number}\n  directed: true\n};\n\nlet state = {\n  // PageRank state\n  pr: [], // array aligned to nodes indices\n  prevPr: [],\n  personalization: [],\n  damping: 0.85,\n  tol: 1e-6,\n  maxIter: 1000,\n  iter: 0,\n  running: false,\n  intervalId: null,\n  itersPerSec: 4,\n  normMode: 'column',\n  sinkMode: 'teleport',\n  persMode: 'uniform'\n};\n\nconst canvas = document.getElementById('graphCanvas');\nconst ctx = canvas.getContext('2d');\n\nfunction idForIndex(i){ return (G.nodes[i] && G.nodes[i].id) || String(i); }\nfunction indexOfId(id){ return G.nodes.findIndex(n=>n.id===id); }\n\n// UI elements\nconst addNodeBtn = document.getElementById('addNodeBtn');\nconst addNodeAtCenterBtn = document.getElementById('addNodeAtCenterBtn');\nconst nodeLabelInput = document.getElementById('nodeLabel');\nconst edgeModeSelect = document.getElementById('edgeMode');\nconst startAddEdgeBtn = document.getElementById('startAddEdgeBtn');\nconst finishAddEdgeBtn = document.getElementById('finishAddEdgeBtn');\nconst edgeSourceSelect = document.getElementById('edgeSource');\nconst edgeTargetSelect = document.getElementById('edgeTarget');\nconst edgeSelectControls = document.getElementById('edgeSelectControls');\nconst edgeWeightInput = document.getElementById('edgeWeight');\nconst directedToggle = document.getElementById('directedToggle');\nconst addNodeCenterBtn = document.getElementById('addNodeAtCenterBtn');\nconst delSelectedBtn = document.getElementById('delSelectedBtn');\nconst selectedNodeSelect = document.getElementById('selectedNode');\nconst randNodesInput = document.getElementById('randNodes');\nconst randProbInput = document.getElementById('randProb');\nconst weightRangeInput = document.getElementById('weightRange');\nconst randSeedInput = document.getElementById('randSeed');\nconst genRandBtn = document.getElementById('genRandBtn');\nconst dampingInput = document.getElementById('damping');\nconst persModeSelect = document.getElementById('persMode');\nconst persCustomDiv = document.getElementById('persCustom');\nconst persJSONInput = document.getElementById('persJSON');\nconst tolInput = document.getElementById('tol');\nconst maxIterInput = document.getElementById('maxIter');\nconst normModeSelect = document.getElementById('normMode');\nconst initPRBtn = document.getElementById('initPRBtn');\nconst stepPRBtn = document.getElementById('stepPRBtn');\nconst runPRBtn = document.getElementById('runPRBtn');\nconst pausePRBtn = document.getElementById('pausePRBtn');\nconst resetPRBtn = document.getElementById('resetPRBtn');\nconst itersPerSecInput = document.getElementById('itersPerSec');\nconst autoStopCheckbox = document.getElementById('autoStop');\nconst sinkModeSelect = document.getElementById('sinkMode');\nconst showMatrixBtn = document.getElementById('showMatrixBtn');\nconst matrixView = document.getElementById('matrixView');\nconst adjListPre = document.getElementById('adjListPre');\nconst stochPre = document.getElementById('stochPre');\nconst prPre = document.getElementById('prPre');\nconst logArea = document.getElementById('logArea');\nconst iterCountSpan = document.getElementById('iterCount');\nconst lastChangeSpan = document.getElementById('lastChange');\nconst runningFlagSpan = document.getElementById('runningFlag');\nconst exportJSONBtn = document.getElementById('exportJSONBtn');\nconst importJSONBtn = document.getElementById('importJSONBtn');\nconst importFileInput = document.getElementById('importFile');\nconst clearLogBtn = document.getElementById('clearLogBtn');\nconst rankSortBtn = document.getElementById('rankSortBtn');\nconst rescaleBtn = document.getElementById('rescaleBtn');\nconst showMatrixToggleBtn = document.getElementById('showMatrixBtn');\n\n// Variables for interactive edge-adding\nlet addEdgeModeActive = false;\nlet pendingEdgeSourceId = null;\n\n// Canvas interaction\nlet draggingNode = null;\nlet dragOffset = {x:0,y:0};\nlet lastClickedNode = null;\n\n// Helpers to update selects\nfunction refreshNodeSelects(){\n  const lists = [edgeSourceSelect, edgeTargetSelect, selectedNodeSelect];\n  lists.forEach(sel=>{\n    sel.innerHTML = '';\n    const ph = document.createElement('option'); ph.value=''; ph.text = '(none)'; sel.appendChild(ph);\n    G.nodes.forEach(n=>{\n      const opt = document.createElement('option');\n      opt.value = n.id; opt.text = n.label || n.id;\n      sel.appendChild(opt);\n    });\n  });\n  updateEdgeListDisplay();\n}\n\nfunction updateEdgeListDisplay(){\n  // adjacency list text\n  let text = '';\n  G.edges.forEach(e=>{\n    text += `${e.from} → ${e.to} : ${e.weight}\\n`;\n    if (!G.directed){\n      // for undirected we still store edges; display both directions if necessary\n    }\n  });\n  adjListPre.textContent = text || '(no edges)';\n}\n\n// Node management\nfunction addNodeAt(x,y,label){\n  let idBase = label && label.trim()!= '' ? label.trim() : 'n';\n  let id = idBase;\n  let suffix = 0;\n  while (G.nodes.find(n=>n.id === id)) { suffix++; id = idBase + suffix; }\n  const node = {id: id, label: label && label.trim() !== '' ? label.trim() : id, x: x, y: y};\n  G.nodes.push(node);\n  refreshNodeSelects();\n  draw();\n  log(`Added node ${node.id}`);\n  return node;\n}\n\nfunction removeNodeById(id){\n  const idx = indexOfId(id);\n  if (idx === -1) return;\n  G.nodes.splice(idx,1);\n  // remove edges to/from\n  G.edges = G.edges.filter(e=> e.from !== id && e.to !== id);\n  refreshNodeSelects();\n  draw();\n  log(`Removed node ${id}`);\n}\n\nfunction addEdge(fromId, toId, w){\n  if (!fromId || !toId) return false;\n  if (!G.nodes.find(n=>n.id===fromId) || !G.nodes.find(n=>n.id===toId)) return false;\n  // allow parallel edges: accumulate weight if identical\n  const existing = G.edges.find(e=> e.from===fromId && e.to===toId);\n  if (existing){\n    existing.weight += w;\n  } else {\n    G.edges.push({from: fromId, to: toId, weight: w});\n  }\n  if (!G.directed){\n    // for undirected, also add reverse if not present\n    const rev = G.edges.find(e=> e.from===toId && e.to===fromId);\n    if (!rev) G.edges.push({from: toId, to: fromId, weight: w});\n  }\n  updateEdgeListDisplay();\n  draw();\n  log(`Added edge ${fromId} → ${toId} (w=${w})`);\n  return true;\n}\n\n// Random graph generator\nfunction generateRandomGraph(numNodes, p, weightRange, seedVal, directed){\n  const rand = makeSeededRandom(seedVal || Math.floor(Math.random()*0xFFFFFFFF));\n  G.nodes = [];\n  G.edges = [];\n  for (let i=0;i<numNodes;i++){\n    const x = 50 + (canvas.width - 100) * rand();\n    const y = 50 + (canvas.height - 100) * rand();\n    G.nodes.push({id: 'n'+i, label: 'n'+i, x:x, y:y});\n  }\n  for (let i=0;i<numNodes;i++){\n    for (let j=0;j<numNodes;j++){\n      if (i===j) continue;\n      if (rand() < p){\n        const w = weightRange[0] + (weightRange[1]-weightRange[0]) * rand();\n        G.edges.push({from: G.nodes[i].id, to: G.nodes[j].id, weight: w});\n      }\n    }\n  }\n  if (!directed){\n    // ensure symmetry: add reverse edges for each\n    const newEdges = [];\n    const seen = new Set();\n    G.edges.forEach(e=>{\n      const key = e.from + '|' + e.to;\n      const rkey = e.to + '|' + e.from;\n      if (!seen.has(key) && !seen.has(rkey)){\n        newEdges.push(e);\n        newEdges.push({from:e.to, to:e.from, weight:e.weight});\n        seen.add(key); seen.add(rkey);\n      }\n    });\n    G.edges = newEdges;\n  }\n  refreshNodeSelects();\n  updateEdgeListDisplay();\n  draw();\n  log(`Generated random graph with ${numNodes} nodes, p=${p}`);\n}\n\n\n// Drawing\nfunction draw(){\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  // draw edges\n  ctx.lineWidth = 1;\n  ctx.strokeStyle = 'black';\n  G.edges.forEach(e=>{\n    const i1 = indexOfId(e.from), i2 = indexOfId(e.to);\n    if (i1 === -1 || i2 === -1) return;\n    const n1 = G.nodes[i1], n2 = G.nodes[i2];\n    drawArrow(n1.x,n1.y,n2.x,n2.y);\n    // draw weight near midpoint\n    const mx = (n1.x + n2.x)/2;\n    const my = (n1.y + n2.y)/2;\n    ctx.font = \"11px sans-serif\";\n    ctx.fillStyle = 'black';\n    ctx.fillText(formatNumber(e.weight), mx+4, my+4);\n  });\n  // draw nodes\n  const prArr = state.pr && state.pr.length === G.nodes.length ? state.pr : null;\n  let maxPr = 0;\n  if (prArr) maxPr = Math.max(...prArr);\n  G.nodes.forEach((n,idx)=>{\n    const x = n.x, y = n.y;\n    let radius = 14;\n    if (prArr){\n      // scale radius between 8 and 28 based on rank\n      const rel = maxPr > 0 ? (prArr[idx] / maxPr) : 0;\n      radius = 8 + Math.round(rel * 20);\n    }\n    // circle\n    ctx.beginPath();\n    ctx.arc(x,y,radius,0,Math.PI*2);\n    ctx.stroke();\n    ctx.closePath();\n    // label and id\n    ctx.font = \"12px sans-serif\";\n    ctx.fillStyle = 'black';\n    const label = n.label || n.id;\n    ctx.fillText(label, x - radius + 4, y - radius - 2);\n    // rank value\n    if (prArr){\n      ctx.fillText(formatNumber(prArr[idx]), x - radius + 4, y + radius + 12);\n    }\n  });\n}\n\nfunction drawArrow(x1,y1,x2,y2){\n  ctx.beginPath();\n  ctx.moveTo(x1,y1);\n  ctx.lineTo(x2,y2);\n  ctx.stroke();\n  // draw simple arrowhead for directed edges\n  if (G.directed){\n    const dx = x2-x1, dy = y2-y1;\n    const len = Math.sqrt(dx*dx + dy*dy);\n    if (len > 0){\n      const ux = dx/len, uy = dy/len;\n      const hx = x2 - ux*10, hy = y2 - uy*10;\n      ctx.beginPath();\n      ctx.moveTo(x2,y2);\n      ctx.lineTo(hx - uy*4, hy + ux*4);\n      ctx.lineTo(hx + uy*4, hy - ux*4);\n      ctx.closePath();\n      ctx.stroke();\n      ctx.fillStyle = 'black';\n      ctx.fill();\n    }\n  }\n}\n\n// Format number\nfunction formatNumber(x){\n  if (x === undefined || isNaN(x)) return 'NaN';\n  if (Math.abs(x) < 1e-6) return '0';\n  return (Math.round(x*1e6)/1e6).toString();\n}\n\n// Canvas interactions\ncanvas.addEventListener('mousedown', (ev)=>{\n  const rect = canvas.getBoundingClientRect();\n  const x = ev.clientX - rect.left;\n  const y = ev.clientY - rect.top;\n  const hit = G.nodes.find(n=> Math.hypot(n.x-x, n.y-y) <= 16 );\n  if (hit){\n    // select node\n    lastClickedNode = hit;\n    // set select element\n    selectedNodeSelect.value = hit.id;\n    // start drag\n    draggingNode = hit;\n    dragOffset.x = x - hit.x;\n    dragOffset.y = y - hit.y;\n    draw();\n    if (addEdgeModeActive){\n      if (!pendingEdgeSourceId){\n        pendingEdgeSourceId = hit.id;\n        log(`Edge source selected: ${hit.id}. Click target node.`);\n      } else {\n        // create edge from pendingEdgeSourceId to hit.id\n        const w = parseFloat(edgeWeightInput.value) || 1;\n        addEdge(pendingEdgeSourceId, hit.id, w);\n        pendingEdgeSourceId = null;\n        if (!startAddEdgeBtn) {}\n      }\n    }\n  } else {\n    // not clicked a node -> maybe add node at click if ctrl pressed\n    if (ev.ctrlKey){\n      addNodeAt(x,y, nodeLabelInput.value);\n    }\n  }\n});\n\ncanvas.addEventListener('mousemove', (ev)=>{\n  if (!draggingNode) return;\n  const rect = canvas.getBoundingClientRect();\n  const x = ev.clientX - rect.left;\n  const y = ev.clientY - rect.top;\n  draggingNode.x = x - dragOffset.x;\n  draggingNode.y = y - dragOffset.y;\n  draw();\n});\n\ncanvas.addEventListener('mouseup', (ev)=>{\n  draggingNode = null;\n});\n\n// Buttons and controls\naddNodeBtn.addEventListener('click', ()=> {\n  const x = 40 + Math.random() * (canvas.width - 80);\n  const y = 40 + Math.random() * (canvas.height - 80);\n  addNodeAt(x,y,nodeLabelInput.value);\n});\n\naddNodeAtCenterBtn.addEventListener('click', ()=> {\n  addNodeAt(canvas.width/2, canvas.height/2, nodeLabelInput.value);\n});\n\nedgeModeSelect.addEventListener('change', ()=>{\n  const val = edgeModeSelect.value;\n  edgeSelectControls.style.display = val === 'select' ? 'block' : 'none';\n});\n\nstartAddEdgeBtn.addEventListener('click', ()=>{\n  addEdgeModeActive = true;\n  pendingEdgeSourceId = null;\n  log('Add Edge mode ON. Click source node (then target). Or use select lists in select mode.');\n});\n\nfinishAddEdgeBtn.addEventListener('click', ()=>{\n  addEdgeModeActive = false;\n  pendingEdgeSourceId = null;\n  log('Add Edge mode cancelled.');\n});\n\ndocument.getElementById('edgeSource').addEventListener('change', ()=>{\n  // when select mode, do nothing until add edge pressed\n});\n\ndocument.getElementById('edgeTarget').addEventListener('change', ()=>{ });\n\ndocument.getElementById('edgeSelectControls').addEventListener('click', ()=>{});\n\ndocument.getElementById('edgeSource').addEventListener('input', ()=>{});\ndocument.getElementById('edgeTarget').addEventListener('input', ()=>{});\n\ndocument.getElementById('edgeMode').addEventListener('change', ()=>{\n  if (edgeModeSelect.value === 'select'){\n    edgeSelectControls.style.display = 'block';\n  } else edgeSelectControls.style.display = 'none';\n});\n\ndocument.getElementById('edgeSource').addEventListener('change', ()=>{});\ndocument.getElementById('edgeTarget').addEventListener('change', ()=>{});\n\n// Add edge via select + button\nconst addEdgeSelectBtn = document.createElement('button');\naddEdgeSelectBtn.textContent = 'Add Edge (from selects)';\naddEdgeSelectBtn.addEventListener('click', ()=>{\n  const from = edgeSourceSelect.value;\n  const to = edgeTargetSelect.value;\n  const w = parseFloat(edgeWeightInput.value) || 1;\n  if (!from || !to){ alert('Choose both source and target'); return; }\n  addEdge(from,to,w);\n});\ndocument.getElementById('edgeSelectControls').appendChild(addEdgeSelectBtn);\n\n// Delete selected node\ndelSelectedBtn.addEventListener('click', ()=>{\n  const id = selectedNodeSelect.value;\n  if (!id){ alert('Select a node to delete'); return; }\n  removeNodeById(id);\n});\n\n// Directed toggle\ndirectedToggle.addEventListener('change', ()=>{\n  G.directed = directedToggle.checked;\n  // If switching to undirected, ensure symmetric edges exist\n  if (!G.directed){\n    const newEdges = [];\n    const seen = new Set();\n    G.edges.forEach(e=>{\n      const k1 = e.from + '|' + e.to, k2 = e.to + '|' + e.from;\n      if (!seen.has(k1) && !seen.has(k2)){\n        newEdges.push({from:e.from,to:e.to,weight:e.weight});\n        newEdges.push({from:e.to,to:e.from,weight:e.weight});\n        seen.add(k1); seen.add(k2);\n      }\n    });\n    G.edges = newEdges;\n  }\n  refreshNodeSelects();\n  draw();\n});\n\n// Random graph generation\ngenRandBtn.addEventListener('click', ()=>{\n  const n = parseInt(randNodesInput.value) || 10;\n  const p = Math.min(1, Math.max(0, parseFloat(randProbInput.value) || 0.2));\n  const wr = (weightRangeInput.value || '1,1').split(',').map(s=>parseFloat(s.trim())||0);\n  const seed = parseInt(randSeedInput.value) || undefined;\n  generateRandomGraph(n,p, [Math.min(wr[0],wr[1]||wr[0]), Math.max(wr[0],wr[1]||wr[0])], seed, directedToggle.checked);\n});\n\n// Pers mode toggle\npersModeSelect.addEventListener('change', ()=>{\n  state.persMode = persModeSelect.value;\n  persCustomDiv.style.display = state.persMode === 'custom' ? 'block' : 'none';\n});\n\n// Initialize PageRank\ninitPRBtn.addEventListener('click', ()=>{\n  initializePageRank();\n});\n\n// Step PageRank\nstepPRBtn.addEventListener('click', ()=>{\n  stepPageRank();\n});\n\n// Run PageRank\nrunPRBtn.addEventListener('click', ()=>{\n  if (state.running) return;\n  const itersPerSec = Math.max(1, parseInt(itersPerSecInput.value) || 4);\n  state.itersPerSec = itersPerSec;\n  const intervalMs = Math.round(1000 / itersPerSec);\n  state.running = true;\n  runningFlagSpan.textContent = 'true';\n  state.intervalId = setInterval(()=>{\n    stepPageRank();\n  }, intervalMs);\n  log('Started running PageRank');\n});\n\n// Pause\npausePRBtn.addEventListener('click', ()=>{\n  if (state.intervalId) clearInterval(state.intervalId);\n  state.intervalId = null;\n  state.running = false;\n  runningFlagSpan.textContent = 'false';\n  log('Paused PageRank run');\n});\n\n// Reset\nresetPRBtn.addEventListener('click', ()=>{\n  state.pr = [];\n  state.prevPr = [];\n  state.iter = 0;\n  iterCountSpan.textContent = '0';\n  lastChangeSpan.textContent = '-';\n  if (state.intervalId) { clearInterval(state.intervalId); state.intervalId = null; }\n  state.running = false;\n  runningFlagSpan.textContent = 'false';\n  draw();\n  log('PageRank reset');\n});\n\n// Show/hide matrix view\nshowMatrixBtn.addEventListener('click', ()=>{\n  matrixView.style.display = (matrixView.style.display === 'none') ? 'block' : 'none';\n  if (matrixView.style.display === 'block') updateMatricesDisplay();\n});\n\n// Export JSON\nexportJSONBtn.addEventListener('click', ()=>{\n  const dump = {\n    graph: G,\n    settings: {\n      damping: parseFloat(dampingInput.value),\n      tol: parseFloat(tolInput.value),\n      maxIter: parseInt(maxIterInput.value),\n      normMode: normModeSelect.value,\n      sinkMode: sinkModeSelect.value,\n      persMode: persModeSelect.value,\n      personalization: persJSONInput.value ? JSON.parse(persJSONInput.value||'[]') : []\n    }\n  };\n  const blob = new Blob([JSON.stringify(dump, null, 2)], {type:'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url; a.download = 'pagerank_graph.json';\n  document.body.appendChild(a); a.click(); a.remove();\n  URL.revokeObjectURL(url);\n  log('Exported graph and settings to JSON');\n});\n\n// Import JSON\nimportJSONBtn.addEventListener('click', ()=> importFileInput.click());\nimportFileInput.addEventListener('change', (ev)=>{\n  const f = ev.target.files[0];\n  if (!f) return;\n  const reader = new FileReader();\n  reader.onload = function(e){\n    try {\n      const obj = JSON.parse(e.target.result);\n      if (obj.graph){\n        G = obj.graph;\n        // ensure nodes have x,y; otherwise place them\n        G.nodes.forEach((n,i)=>{\n          if (n.x === undefined || n.y === undefined) { n.x = 50 + (i*37) % (canvas.width-100); n.y = 50 + ((i*13) % (canvas.height-100)); }\n        });\n        directedToggle.checked = !!G.directed;\n        refreshNodeSelects();\n        updateEdgeListDisplay();\n        draw();\n        log('Imported graph from JSON');\n      }\n      if (obj.settings){\n        dampingInput.value = obj.settings.damping || dampingInput.value;\n        tolInput.value = obj.settings.tol || tolInput.value;\n        maxIterInput.value = obj.settings.maxIter || maxIterInput.value;\n        normModeSelect.value = obj.settings.normMode || normModeSelect.value;\n        sinkModeSelect.value = obj.settings.sinkMode || sinkModeSelect.value;\n        persModeSelect.value = obj.settings.persMode || persModeSelect.value;\n        persJSONInput.value = JSON.stringify(obj.settings.personalization || []);\n        persModeSelect.dispatchEvent(new Event('change'));\n      }\n    } catch (err){\n      alert('Failed to import: ' + err);\n    }\n  };\n  reader.readAsText(f);\n});\n\n// Clear log\nclearLogBtn.addEventListener('click', ()=> { logArea.textContent = ''; });\n\n// Rank sort\nrankSortBtn.addEventListener('click', ()=>{\n  if (!state.pr || state.pr.length !== G.nodes.length) { alert('Initialize PageRank first'); return; }\n  // sort nodes by descending rank but keep positions\n  G.nodes.sort((a,b)=> {\n    const ia = indexOfId(a.id);\n    const ib = indexOfId(b.id);\n    return state.pr[ib] - state.pr[ia]; // descending\n  });\n  refreshNodeSelects();\n  draw();\n  log('Sorted nodes by current PageRank (descending)');\n});\n\n// Rescale positions to canvas\nrescaleBtn.addEventListener('click', ()=>{\n  if (G.nodes.length === 0) return;\n  const margin = 40;\n  const xs = G.nodes.map(n=>n.x), ys = G.nodes.map(n=>n.y);\n  let minx = Math.min(...xs), maxx = Math.max(...xs);\n  let miny = Math.min(...ys), maxy = Math.max(...ys);\n  const spanx = maxx - minx || 1; const spany = maxy - miny || 1;\n  G.nodes.forEach(n=>{\n    n.x = margin + ((n.x - minx) / spanx) * (canvas.width - margin*2);\n    n.y = margin + ((n.y - miny) / spany) * (canvas.height - margin*2);\n  });\n  draw();\n  log('Rescaled node positions to canvas');\n});\n\n// Logging\nfunction log(msg){\n  const t = new Date().toLocaleTimeString();\n  logArea.textContent = `[${t}] ${msg}\\n` + logArea.textContent;\n}\n\n// PageRank core\nfunction initializePageRank(){\n  state.damping = Math.max(0, Math.min(0.9999, parseFloat(dampingInput.value) || 0.85));\n  state.tol = Math.max(1e-12, parseFloat(tolInput.value) || 1e-6);\n  state.maxIter = Math.max(1, parseInt(maxIterInput.value) || 1000);\n  state.normMode = normModeSelect.value;\n  state.sinkMode = sinkModeSelect.value;\n  state.persMode = persModeSelect.value;\n  state.iter = 0;\n  // init pr vector\n  const n = G.nodes.length;\n  state.pr = new Array(n).fill(1/n);\n  state.prevPr = new Array(n).fill(0);\n  // personalization vector\n  state.personalization = computePersonalizationVector();\n  iterCountSpan.textContent = '0';\n  lastChangeSpan.textContent = '-';\n  draw();\n  updateMatricesDisplay();\n  log('Initialized PageRank (power iteration starting vector uniform)');\n}\n\n// Compute personalization vector based on mode\nfunction computePersonalizationVector(){\n  const n = G.nodes.length;\n  const vec = new Array(n).fill(0);\n  if (state.persMode === 'uniform' || n === 0){\n    for (let i=0;i<n;i++) vec[i] = 1/n;\n    return vec;\n  } else if (state.persMode === 'selected'){\n    const sel = selectedNodeSelect.value;\n    if (!sel){\n      for (let i=0;i<n;i++) vec[i] = 1/n;\n      return vec;\n    }\n    const idx = indexOfId(sel);\n    for (let i=0;i<n;i++) vec[i] = 0;\n    vec[idx] = 1;\n    // smooth to avoid zero everywhere: distribute small epsilon?\n    // Normalize:\n    const s = vec.reduce((a,b)=>a+b,0);\n    if (s === 0){ for (let i=0;i<n;i++) vec[i]=1/n; } else for (let i=0;i<n;i++) vec[i] /= s;\n    return vec;\n  } else if (state.persMode === 'custom'){\n    try {\n      const arr = JSON.parse(persJSONInput.value || '[]');\n      if (!Array.isArray(arr) || arr.length !== n){\n        alert('Custom personalization must be an array with length equal to number of nodes');\n        // fallback to uniform\n        for (let i=0;i<n;i++) vec[i]=1/n;\n        return vec;\n      }\n      let s = arr.reduce((a,b)=>a+(isFinite(b)?b:0),0);\n      if (s <= 0){ for (let i=0;i<n;i++) vec[i]=1/n; }\n      else for (let i=0;i<n;i++) vec[i] = arr[i]/s;\n      return vec;\n    } catch (e){\n      alert('Invalid JSON for personalization vector');\n      for (let i=0;i<n;i++) vec[i]=1/n;\n      return vec;\n    }\n  } else {\n    // default uniform\n    for (let i=0;i<n;i++) vec[i] = 1/n;\n    return vec;\n  }\n}\n\n// Build transition matrix M as column-stochastic matrix represented as array of columns (each column is array length n)\nfunction buildTransitionMatrix(){\n  const n = G.nodes.length;\n  const M = Array.from({length:n}, ()=> new Array(n).fill(0));\n  // outgoing sums for each node (out-degree weighted)\n  const outSums = new Array(n).fill(0);\n  G.edges.forEach(e=>{\n    const i = indexOfId(e.from), j = indexOfId(e.to);\n    if (i === -1 || j === -1) return;\n    outSums[i] += e.weight;\n  });\n  // fill M so that M[i][j] = prob from j -> i (column j)\n  for (let j=0;j<n;j++){\n    if (outSums[j] > 0){\n      // collect all edges from node j\n      G.edges.forEach(e=>{\n        if (e.from === G.nodes[j].id){\n          const i = indexOfId(e.to);\n          M[i][j] += e.weight / outSums[j];\n        }\n      });\n    } else {\n      // dangling node handling: column all zeros (will be handled in iteration)\n    }\n  }\n  return {M, outSums};\n}\n\n// Step iteration\nfunction stepPageRank(){\n  if (!state.pr || state.pr.length !== G.nodes.length) initializePageRank();\n  const n = G.nodes.length;\n  if (n === 0) return;\n  const damping = Math.max(0, Math.min(0.9999, parseFloat(dampingInput.value) || 0.85));\n  const pers = computePersonalizationVector();\n  state.damping = damping;\n  state.personalization = pers;\n  const {M, outSums} = buildTransitionMatrix();\n  // Compute dangling mass (nodes with no outlinks)\n  let danglingMass = 0;\n  for (let j=0;j<n;j++){\n    if (outSums[j] === 0){\n      danglingMass += state.pr[j];\n    }\n  }\n  // compute new pr: r_new = (1-d)*pers + d*M*r + d*danglingMass*sinkVec\n  const newPr = new Array(n).fill(0);\n  // M*r: column multiplication\n  for (let i=0;i<n;i++){\n    let s = 0;\n    for (let j=0;j<n;j++){\n      s += M[i][j] * state.pr[j];\n    }\n    newPr[i] = damping * s;\n  }\n  // dangling handling\n  if (state.sinkMode === 'teleport'){\n    // dangling mass redistributed to personalization vector\n    for (let i=0;i<n;i++){\n      newPr[i] += damping * danglingMass * pers[i];\n    }\n  } else if (state.sinkMode === 'uniform'){\n    for (let i=0;i<n;i++){\n      newPr[i] += damping * danglingMass * (1/n);\n    }\n  } else if (state.sinkMode === 'selfloop'){\n    // treat dangling as self-loop: add mass to same node\n    // but that was already zero in M; we add mass to those nodes proportional to their previous pr\n    for (let i=0;i<n;i++){\n      if (outSums[i] === 0) newPr[i] += damping * state.pr[i];\n    }\n  }\n  // teleportation (1-d)*pers\n  for (let i=0;i<n;i++){\n    newPr[i] += (1 - damping) * pers[i];\n  }\n  // Normalize to sum to 1 (numerical safety)\n  let sum = newPr.reduce((a,b)=>a+b,0);\n  if (sum <= 0) {\n    for (let i=0;i<n;i++) newPr[i] = 1/n;\n  } else {\n    for (let i=0;i<n;i++) newPr[i] /= sum;\n  }\n\n  // compute L1 change\n  let l1 = 0;\n  for (let i=0;i<n;i++) l1 += Math.abs(newPr[i] - state.pr[i]);\n  state.prevPr = state.pr.slice();\n  state.pr = newPr;\n  state.iter += 1;\n  iterCountSpan.textContent = state.iter;\n  lastChangeSpan.textContent = l1.toExponential(3);\n  draw();\n  updateMatricesDisplay();\n  log(`Iteration ${state.iter}: L1 change ${l1.toExponential(3)}`);\n\n  // convergence check\n  if (autoStopCheckbox.checked && l1 < state.tol){\n    if (state.intervalId) { clearInterval(state.intervalId); state.intervalId = null; }\n    state.running = false;\n    runningFlagSpan.textContent = 'false';\n    log(`Converged at iteration ${state.iter}, L1=${l1}`);\n  }\n  if (state.iter >= state.maxIter){\n    if (state.intervalId) { clearInterval(state.intervalId); state.intervalId = null; }\n    state.running = false;\n    runningFlagSpan.textContent = 'false';\n    log(`Stopped: reached max iterations ${state.maxIter}`);\n  }\n}\n\n// Update matrices display\nfunction updateMatricesDisplay(){\n  const n = G.nodes.length;\n  // adjacency info\n  let adj = '';\n  for (let i=0;i<n;i++){\n    const id = G.nodes[i].id;\n    const outs = G.edges.filter(e=>e.from === id).map(e=> `${e.to}:${formatNumber(e.weight)}`).join(', ');\n    adj += `${id} -> [${outs}]\\n`;\n  }\n  adjListPre.textContent = adj || '(empty)';\n  // stochastic matrix print\n  const {M, outSums} = buildTransitionMatrix();\n  let st = '';\n  if (n === 0) st = '(empty)';\n  else {\n    // header\n    st += '\\t' + G.nodes.map(n0=>n0.id).join('\\t') + '\\n';\n    for (let i=0;i<n;i++){\n      st += G.nodes[i].id + '\\t';\n      for (let j=0;j<n;j++){\n        st += (M[i][j] ? formatNumber(M[i][j]) : '0') + '\\t';\n      }\n      st += '\\n';\n    }\n  }\n  stochPre.textContent = st;\n  // pr vector\n  let prtext = '';\n  if (state.pr && state.pr.length === n){\n    for (let i=0;i<n;i++){\n      prtext += `${G.nodes[i].id}: ${formatNumber(state.pr[i])}\\n`;\n    }\n  } else prtext = '(not initialized)';\n  prPre.textContent = prtext;\n}\n\n// Utility: sort nodes by rank and list in log\nfunction listSortedRanks(){\n  if (!state.pr || state.pr.length !== G.nodes.length) {\n    log('PageRank not initialized.');\n    return;\n  }\n  const arr = G.nodes.map((n,i)=>({id:n.id, label:n.label, pr:state.pr[i]}));\n  arr.sort((a,b)=>b.pr - a.pr);\n  let s = 'Ranks (desc):\\n';\n  arr.forEach(a=> s += `${a.id} (${a.label}): ${formatNumber(a.pr)}\\n`);\n  log(s);\n}\n\n// Format and update selects on start\nrefreshNodeSelects();\n\n// Additional UI: a small button to add edge from selects was appended earlier;\n// ensure we show it now in case of initial state\nedgeModeSelect.dispatchEvent(new Event('change'));\n\n// Allow adding edge via explicit button created earlier (edgeSelectControls)\naddEdgeSelectBtn.style.marginTop = '6px';\n\n// Initial draw\ndraw();\n\n</script>\n</body>\n</html>"
  },
