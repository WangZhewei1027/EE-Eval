    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Selection Sort Visualization — Elegance in Motion</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display:ital,wght@1,700&display=swap');\n\n  /* Reset and base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #1e2749 0%, #28314d 40%, #618285 100%);\n    color: #f5f5f7;\n    font-family: 'Montserrat', sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: flex-start;\n    padding: 2.5rem 1rem 4rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.25rem;\n    margin: 0 0 0.125em 0;\n    letter-spacing: 0.04em;\n    text-align: center;\n    text-shadow:\n      0 0.1em 0 #a3c6ff44,\n      0 0.3em 0.35em #4279ffcc;\n    color: #e8f0ff;\n  }\n  h2 {\n    font-weight: 400;\n    font-family: 'Montserrat', sans-serif;\n    color: #abbbc9dd;\n    font-size: 1.125rem;\n    letter-spacing: 0.075em;\n    margin-top: -0.25em;\n    margin-bottom: 2.7rem;\n    text-align: center;\n  }\n\n  /* Container for visual */\n  main#container {\n    width: 100%;\n    max-width: 920px;\n    background: linear-gradient(145deg, #253450 0%, #1b233a 60%, #3a536f 100%);\n    border-radius: 2.25rem;\n    box-shadow:\n     0 0.3rem 0.8rem rgba(4, 18, 42, 0.6),\n     inset 0 0 1.8rem #7da3ff88;\n    padding: 3.25rem 3rem 4.5rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  /* Bar chart area */\n  section#visualization {\n    width: 100%;\n    display: flex;\n    justify-content: center;\n    align-items: end;\n    height: 320px;\n    gap: 20px;\n    padding-bottom: 1rem;\n    user-select: none;\n  }\n\n  .bar {\n    position: relative;\n    flex: 1 0 30px;\n    max-width: 45px;\n    background: linear-gradient(45deg, #4661ff, #2219ff);\n    border-radius: 0.6rem;\n    box-shadow:\n      0 0.15rem 0.5rem #1e2b8fcc,\n      inset 0 0.2rem 0.75rem #cacfdbcc;\n    cursor: default;\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n    transition: background 0.4s ease, transform 0.45s cubic-bezier(0.4,0,0.2,1);\n    color: #e3e9ffdd;\n    font-weight: 700;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 1.2rem;\n    user-select: none;\n    box-sizing: border-box;\n  }\n\n  /* Bar height text */\n  .bar > .label {\n    margin-bottom: 0.275rem;\n    filter: drop-shadow(0 0 2px #1a33ffcc);\n    user-select: none;\n  }\n\n  /* States styling */\n  .bar.current {\n    background: linear-gradient(135deg, #ff6e6e, #ff3131);\n    box-shadow:\n      0 0.3rem 0.7rem #ff3131cc,\n      inset 0 0.3rem 1.1rem #ff7171cc;\n    transform: scale(1.13);\n    z-index: 10;\n    color: #fff5f5;\n  }\n\n  .bar.min {\n    background: linear-gradient(135deg, #63ffa3, #0ddd80);\n    box-shadow:\n      0 0.3rem 1.1rem #00b35ecc,\n      inset 0 0.3rem 1.1rem #22ff8ecc;\n    transform: scale(1.11);\n    z-index: 9;\n    color: #e6fff5;\n  }\n\n  .bar.sorted {\n    background: linear-gradient(135deg, #ffc15e, #fe9d01);\n    box-shadow:\n      0 0.25rem 1.15rem #dd9206cc,\n      inset 0 0.3rem 1.1rem #ffb230cc;\n    color: #fff8e6;\n  }\n\n  /* Smooth height transition */\n  .bar {\n    transition-property: background, transform, height, color;\n    transition-duration: 0.5s;\n    transition-timing-function: cubic-bezier(0.4,0,0.2,1);\n  }\n\n  /* Buttons container */\n  footer#controls {\n    margin-top: 2.8rem;\n    display: flex;\n    gap: 2rem;\n  }\n\n  button {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 600;\n    font-size: 1rem;\n    background: linear-gradient(135deg, #4661ffcc 20%, #1f2e7a 90%);\n    border: none;\n    border-radius: 1.25rem;\n    padding: 0.9rem 2.4rem;\n    color: #e5eaffdd;\n    cursor: pointer;\n    box-shadow:\n      0 0.25rem 0.6rem #2b3a90cc,\n      inset 0 0.08rem 0.18rem #8ba3ffa2;\n    transform-style: preserve-3d;\n    user-select: none;\n    transition: background 0.35s ease, box-shadow 0.25s ease;\n    text-shadow: 0 0 2px #293faeaa;\n  }\n  button:focus-visible {\n    outline-offset: 0.2rem;\n    outline: 2px solid #7da3ffcc;\n  }\n  button:hover:not(:disabled) {\n    background: linear-gradient(135deg, #607afbcc 10%, #313fad 90%);\n    box-shadow: \n       0 0.3rem 1rem #394caecc,\n       inset 0 0.1rem 0.25rem #a3b1ffa8;\n    color: #f0f4ff;\n    text-shadow: 0 0 5px #4b6afecc;\n  }\n  button:disabled {\n    cursor: default;\n    background: #4a5b89aa;\n    box-shadow: none;\n    color: #afafafaa;\n    text-shadow: none;\n  }\n\n  /* Description panel */\n  section#description {\n    margin-top: 3rem;\n    max-width: 680px;\n    text-align: center;\n    font-size: 1.12rem;\n    line-height: 1.6;\n    color: #adb9cacc;\n    font-family: 'Montserrat', sans-serif;\n    user-select: none;\n    padding: 0 1rem;\n  }\n\n  /* Footer credit */\n  footer#credit {\n    margin-top: 4rem;\n    font-size: 0.82rem;\n    color: #4c5a75cc;\n    font-family: 'Montserrat', sans-serif;\n  }\n\n  /* Responsive */\n  @media (max-width: 640px) {\n    main#container {\n      padding: 2rem 1.5rem 3rem;\n    }\n    section#visualization {\n      height: 240px;\n      gap: 14px;\n    }\n    .bar {\n      font-size: 0.95rem;\n      max-width: 30px;\n    }\n    h1 {\n      font-size: 2.25rem;\n    }\n    h2 {\n      font-size: 1rem;\n      margin-bottom: 1.8rem;\n    }\n    #description {\n      font-size: 1rem;\n      margin-top: 2rem;\n    }\n  }\n</style>\n</head>\n<body>\n\n<h1>Selection Sort</h1>\n<h2>Elegance in Motion — Visualizing the Algorithm</h2>\n\n<main id=\"container\" role=\"main\" aria-label=\"Selection Sort Visualization\">\n  <section id=\"visualization\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n    <!-- Bars inserted from JS -->\n  </section>\n\n  <section id=\"description\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"text\">\n    Selection Sort iteratively selects the smallest remaining element and places it at the beginning of the unsorted portion,\n    gradually forming a fully sorted array. Watch as the current candidate and minimum are highlighted, and see the sorted portion glow warmly.\n  </section>\n\n  <footer id=\"controls\" role=\"region\" aria-label=\"Controls\">\n    <button id=\"btn-start\" type=\"button\" aria-describedby=\"desc-start\" aria-live=\"polite\" aria-atomic=\"true\">Start Visualization</button>\n    <button id=\"btn-reset\" type=\"button\" disabled aria-describedby=\"desc-reset\" aria-live=\"polite\" aria-atomic=\"true\">Reset</button>\n  </footer>\n</main>\n\n<footer id=\"credit\">\n  &copy; 2024 — Selection Sort Visualization by AI\n</footer>\n\n<script>\n  (() => {\n    const container = document.getElementById('visualization');\n    const btnStart = document.getElementById('btn-start');\n    const btnReset = document.getElementById('btn-reset');\n    const description = document.getElementById('description');\n\n    // Generate an array of 15 unique random integers 20-200 (height in px)\n    const totalBars = 15;\n    const minValue = 20;\n    const maxValue = 200;\n\n    function generateUniqueRandoms(count, min, max) {\n      const set = new Set();\n      while (set.size < count) {\n        const val = Math.floor(Math.random() * (max - min + 1)) + min;\n        set.add(val);\n      }\n      return Array.from(set);\n    }\n\n    // Create bars with given array\n    function createBars(array) {\n      container.innerHTML = '';\n      array.forEach((heightValue, idx) => {\n        const bar = document.createElement('div');\n        bar.classList.add('bar');\n        bar.style.height = `${heightValue}px`;\n        bar.setAttribute('data-index', idx);\n        bar.setAttribute('aria-label', `Value ${heightValue}`);\n        const label = document.createElement('span');\n        label.className = 'label';\n        label.textContent = heightValue;\n        bar.appendChild(label);\n        container.appendChild(bar);\n      });\n    }\n\n    // Swap bars visually by swapping heights and labels\n    function swapBars(array, i, j) {\n      const bars = container.querySelectorAll('.bar');\n      // Swap array values for reference\n      let temp = array[i];\n      array[i] = array[j];\n      array[j] = temp;\n      // Swap heights and labels visually\n      bars[i].style.height = `${array[i]}px`;\n      bars[i].querySelector('.label').textContent = array[i];\n      bars[j].style.height = `${array[j]}px`;\n      bars[j].querySelector('.label').textContent = array[j];\n    }\n\n    // Clear all highlight classes\n    function clearHighlight(bars) {\n      bars.forEach(b => b.classList.remove('current', 'min'));\n    }\n\n    // Highlight sorted bars\n    function highlightSorted(bars, endIndex) {\n      for (let i = 0; i <= endIndex; i++) {\n        bars[i].classList.add('sorted');\n      }\n    }\n\n    // Remove all sorted highlight classes\n    function clearSorted(bars) {\n      bars.forEach(b => b.classList.remove('sorted'));\n    }\n\n    // Promisified delay\n    const delay = ms => new Promise(resolve => setTimeout(resolve, ms));\n\n    // Main visualization async function\n    async function selectionSortVisual(array) {\n      const bars = Array.from(container.querySelectorAll('.bar'));\n      clearSorted(bars);\n      description.textContent = `Starting Selection Sort on an array of ${array.length} elements.`;\n      await delay(1200);\n      for (let i = 0; i < array.length - 1; i++) {\n        description.textContent = `Iteration ${i+1}: Selecting minimum element from unsorted portion...`;\n        let minIdx = i;\n        // Highlight current bar\n        bars[i].classList.add('current');\n        await delay(600);\n\n        for (let j = i + 1; j < array.length; j++) {\n          bars[j].classList.add('current');\n          description.textContent = `Comparing index ${j} (value ${array[j]}) with current minimum at index ${minIdx} (value ${array[minIdx]})`;\n          await delay(520);\n\n          if (array[j] < array[minIdx]) {\n            if (minIdx !== i) bars[minIdx].classList.remove('min');\n            minIdx = j;\n            bars[minIdx].classList.add('min');\n            description.textContent = `New minimum found at index ${minIdx} (value ${array[minIdx]})`;\n            await delay(850);\n          }\n          bars[j].classList.remove('current');\n        }\n\n        if (minIdx !== i) {\n          description.textContent = `Swapping elements at index ${i} (value ${array[i]}) and minimum index ${minIdx} (value ${array[minIdx]})`;\n          await delay(900);\n          swapBars(array, i, minIdx);\n        } else {\n          description.textContent = `Element at index ${i} (value ${array[i]}) is already the minimum; no swap needed.`;\n          await delay(700);\n        }\n\n        bars[minIdx].classList.remove('min');\n        bars[i].classList.remove('current');\n        bars[i].classList.add('sorted');\n\n        description.textContent = `Position ${i+1} sorted.`;\n        highlightSorted(bars, i);\n        await delay(900);\n      }\n\n      bars[array.length - 1].classList.add('sorted');\n      description.textContent = 'Array fully sorted. Visualization complete.';\n      await delay(500);\n\n      btnStart.disabled = false;\n      btnReset.disabled = false;\n    }\n\n    // Setup on page load\n    let dataArray = [];\n\n    function resetVisualization() {\n      btnStart.disabled = false;\n      btnReset.disabled = true;\n      description.textContent = `Selection Sort iteratively selects the smallest remaining element and places it at the beginning of the unsorted portion, gradually forming a fully sorted array. Watch as the current candidate and minimum are highlighted, and see the sorted portion glow warmly.`;\n\n      dataArray = generateUniqueRandoms(totalBars, minValue, maxValue);\n      createBars(dataArray);\n    }\n\n    btnStart.addEventListener('click', async () => {\n      btnStart.disabled = true;\n      btnReset.disabled = true;\n      await selectionSortVisual(dataArray);\n      btnReset.disabled = false;\n    });\n\n    btnReset.addEventListener('click', () => {\n      resetVisualization();\n    });\n\n    // Initialize\n    resetVisualization();\n\n  })();\n</script>\n\n</body>\n</html>"
