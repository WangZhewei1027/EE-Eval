    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Set — A Visual Elegy</title>\n<style>\n  :root{\n    --bg1:#0f1724;\n    --bg2:#071029;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.6);\n    --accent: #8be9fd;\n    --accent-2: #7c4dff;\n    --card-w: 140px;\n    --card-h: 190px;\n    --shadow: 0 8px 30px rgba(2,6,23,0.6);\n    --glass-border: rgba(255,255,255,0.06);\n    --glass-2: rgba(255,255,255,0.03);\n    color-scheme: dark;\n  }\n\n  /* page */\n  html,body{height:100%;margin:0;font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;background: radial-gradient(1200px 600px at 10% 10%, rgba(124,77,255,0.12), transparent 8%), radial-gradient(900px 500px at 90% 90%, rgba(139,233,253,0.06), transparent 8%), linear-gradient(180deg,var(--bg1),var(--bg2)); }\n\n  .wrap{\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    box-sizing:border-box;\n    gap:36px;\n  }\n\n  /* panel */\n  .panel{\n    width:760px;\n    max-width:calc(100% - 96px);\n    background: linear-gradient(180deg, rgba(255,255,255,0.024), rgba(255,255,255,0.012));\n    border: 1px solid var(--glass-border);\n    border-radius:18px;\n    padding:28px;\n    box-shadow: var(--shadow);\n    backdrop-filter: blur(8px) saturate(120%);\n    position:relative;\n    overflow:visible;\n  }\n\n  .topbar{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:16px;\n    margin-bottom:18px;\n  }\n\n  .brand{\n    display:flex;\n    gap:14px;\n    align-items:center;\n  }\n  .brand .logo{\n    width:64px;height:64px;border-radius:12px;\n    background: linear-gradient(135deg,var(--accent-2), #50e3c2 120%);\n    box-shadow: 0 6px 30px rgba(124,77,255,0.18), inset 0 -6px 12px rgba(255,255,255,0.03);\n    display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:20px;\n    transform: rotate(-8deg);\n  }\n  .brand h1{font-size:20px;margin:0;color:#fff;letter-spacing:-0.4px;}\n  .brand p{margin:0;font-size:12px;color:var(--muted);opacity:0.95;}\n\n  .controls{display:flex;gap:12px;align-items:center;}\n  .btn{\n    appearance:none;border:0;padding:10px 16px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n    color:var(--muted);font-weight:600;font-size:13px;cursor:pointer;box-shadow: 0 6px 18px rgba(2,6,23,0.5);\n    transition:all 220ms cubic-bezier(.2,.9,.3,1);backdrop-filter: blur(6px);\n    display:inline-flex;align-items:center;gap:10px;\n  }\n  .btn:hover{transform:translateY(-4px);box-shadow:0 20px 40px rgba(2,6,23,0.6);color:#fff;}\n  .btn.primary{\n    background:linear-gradient(90deg,var(--accent),var(--accent-2));\n    color:#071026;\n    box-shadow:0 12px 36px rgba(124,77,255,0.18), inset 0 -6px 20px rgba(255,255,255,0.08);\n  }\n\n  /* board */\n  .meta{\n    display:flex;gap:18px;align-items:center;margin-bottom:18px;\n  }\n  .meta .note{color:var(--muted);font-size:13px;}\n  .board{\n    display:grid;\n    grid-template-columns: repeat(6, 1fr);\n    gap:18px;\n    perspective:1200px;\n  }\n  @media (max-width:900px){\n    .board{grid-template-columns:repeat(4,1fr);}\n    .panel{padding:18px;}\n  }\n  .card{\n    width:var(--card-w);height:var(--card-h);\n    margin:0 auto;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    box-shadow: 0 10px 30px rgba(2,6,23,0.55);\n    display:flex;align-items:center;justify-content:center;\n    transition: transform 420ms cubic-bezier(.18,.9,.3,1), box-shadow 300ms;\n    transform-origin:center;\n    position:relative;\n    overflow:visible;\n    transform-style:preserve-3d;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .card .surface{\n    width:88%;height:85%;display:flex;align-items:center;justify-content:center;\n    border-radius:10px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: inset 0 -6px 24px rgba(2,6,23,0.12);\n  }\n\n  /* mount animation */\n  .card{opacity:0; transform: translateY(16px) rotateX(8deg) scale(.98);}\n  .card.visible{opacity:1; transform: translateY(0) rotateX(0) scale(1);}\n\n  .card:hover{transform: translateY(-10px) scale(1.02); box-shadow: 0 26px 60px rgba(2,6,23,0.65);}\n\n  /* highlight for a set */\n  .card.match{\n    outline: 2px solid rgba(255,255,255,0.08);\n    box-shadow: 0 16px 50px rgba(124,77,255,0.16), 0 2px 10px rgba(139,233,253,0.04);\n    transform: translateY(-12px) scale(1.04);\n  }\n  .pill{\n    position:absolute;left:50%;transform:translateX(-50%);bottom:-18px;padding:8px 14px;border-radius:999px;background:linear-gradient(90deg, rgba(124,77,255,0.14), rgba(139,233,253,0.06));color:#fff;font-weight:700;font-size:12px;backdrop-filter: blur(6px);box-shadow:0 6px 20px rgba(2,6,23,0.6);\n    opacity:0;transition:opacity 300ms, transform 300ms;\n  }\n  .card.match .pill{opacity:1; transform:translateX(-50%) translateY(0);}\n\n  /* subtle animated glow for matches */\n  .card.match::after{\n    content:\"\";\n    position:absolute;inset:-6px;border-radius:16px;\n    background: radial-gradient(400px 80px at 50% 0%, rgba(124,77,255,0.14), transparent 18%), linear-gradient(90deg, rgba(139,233,253,0.04), transparent 30%);\n    filter: blur(14px);\n    pointer-events:none;\n    animation: pulse 2.4s infinite;\n    z-index:0;\n    mix-blend-mode:screen;\n  }\n  @keyframes pulse{\n    0%{opacity:0.8;transform:scale(0.98);}\n    50%{opacity:1;transform:scale(1.02);}\n    100%{opacity:0.9;transform:scale(0.98);}\n  }\n\n  /* footer / info */\n  .info{\n    display:flex;align-items:center;justify-content:space-between;margin-top:18px;gap:12px;\n  }\n  .legend{\n    color:var(--muted);font-size:13px;line-height:1.3;\n    background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    padding:12px;border-radius:12px;border:1px solid var(--glass-2);\n  }\n\n  /* small decorative */\n  .halftone{\n    position:absolute;right:20px;top:20px;width:200px;height:200px;border-radius:50%;\n    background:radial-gradient(circle at 30% 30%, rgba(255,255,255,0.02), transparent 8%), conic-gradient(from 200deg, rgba(255,255,255,0.01), transparent 10%);\n    filter: blur(20px);opacity:0.7;pointer-events:none;\n  }\n\n  /* caption */\n  .caption{color:var(--muted);font-size:13px;margin-top:10px;}\n\n  /* tiny decorative shapes in header */\n  .tag{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    padding:6px 10px;border-radius:999px;font-size:12px;color:var(--muted);border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* status panel at bottom */\n  .status{\n    display:flex;align-items:center;gap:12px;color:var(--muted);font-size:13px;margin-top:14px;\n  }\n\n  /* tiny animations for the title */\n  .logo svg{transform:translateY(-2px);filter:drop-shadow(0 6px 18px rgba(0,0,0,0.4));}\n  .em{\n    color:transparent;background:linear-gradient(90deg,var(--accent),var(--accent-2));-webkit-background-clip:text;\n    font-weight:800;\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"panel\" role=\"region\" aria-label=\"Set demonstration\">\n    <div class=\"topbar\">\n      <div class=\"brand\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#50E3C2\"/><stop offset=\"1\" stop-color=\"#7C4DFF\"/></linearGradient>\n            </defs>\n            <rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"4\" fill=\"url(#g1)\"/>\n            <g transform=\"translate(3.5,3.5)\" stroke=\"#071026\" stroke-width=\"1.1\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.95\">\n              <path d=\"M6 1.7c1.7 0 1.7 3.6 3.4 3.6S11.1 1.7 12.8 1.7\" stroke=\"#071026\" stroke-opacity=\"0.25\"/>\n            </g>\n          </svg>\n        </div>\n        <div>\n          <h1>Set — The Game, Beautifully Rendered</h1>\n          <p>Visualizing the elegant rules of Set through refined design and motion</p>\n        </div>\n      </div>\n\n      <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n        <button id=\"revealBtn\" class=\"btn primary\" title=\"Reveal a valid set\">Reveal Set</button>\n        <button id=\"shuffleBtn\" class=\"btn\" title=\"Shuffle the board\">Shuffle Board</button>\n      </div>\n    </div>\n\n    <div class=\"meta\">\n      <div class=\"note\">\n        Observe a 12-card layout. Press \"Reveal Set\" to highlight a valid set. \"Shuffle Board\" regenerates a fresh layout with at least one set.\n      </div>\n      <div style=\"flex:1\"></div>\n      <div class=\"tag\">Rules: For each attribute — color, shape, number, shading — three cards must be all same or all different.</div>\n    </div>\n\n    <div id=\"board\" class=\"board\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n    <div class=\"info\">\n      <div class=\"legend\">\n        <strong style=\"display:block;color:#fff;margin-bottom:6px\">Legend — Visual Attributes</strong>\n        <div style=\"display:flex;gap:12px;align-items:center;\">\n          <div style=\"display:flex;gap:8px;align-items:center;\">\n            <svg width=\"44\" height=\"24\" viewBox=\"0 0 44 24\"><ellipse cx=\"22\" cy=\"12\" rx=\"12\" ry=\"8\" fill=\"#ff6b6b\"/></svg>\n            <small style=\"color:var(--muted)\">Ovals (rounded)</small>\n          </div>\n          <div style=\"display:flex;gap:8px;align-items:center;margin-left:4px;\">\n            <svg width=\"44\" height=\"24\" viewBox=\"0 0 44 24\"><path d=\"M4 12 L22 2 L40 12 L22 22 Z\" fill=\"#8be9fd\"/></svg>\n            <small style=\"color:var(--muted)\">Diamonds (geometric)</small>\n          </div>\n          <div style=\"display:flex;gap:8px;align-items:center;margin-left:6px;\">\n            <svg width=\"44\" height=\"24\" viewBox=\"0 0 44 24\"><path d=\"M2 10 q6 -8 12 0 t12 0 t12 0\" stroke=\"#A78BFA\" stroke-width=\"2.8\" fill=\"none\" stroke-linecap=\"round\"/></svg>\n            <small style=\"color:var(--muted)\">Squiggles (organic)</small>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"text-align:right;flex:1\">\n        <div id=\"status\" class=\"status\">\n          <div id=\"setCount\">Sets found: —</div>\n          <div style=\"width:10px\"></div>\n          <div id=\"boardSeed\" style=\"color:var(--muted)\">Seed: —</div>\n        </div>\n        <div class=\"caption\" id=\"caption\" style=\"margin-top:10px;color:var(--muted)\">\n          Tip: Try \"Reveal Set\" to cycle through the available valid sets. Visual emphasis and motion are primary here — interactivity is intentionally limited.\n        </div>\n      </div>\n    </div>\n\n    <div class=\"halftone\" aria-hidden=\"true\"></div>\n  </div>\n</div>\n\n<script>\n/*\n  A refined, minimally interactive visual demonstration of the game Set.\n  Two controls:\n    - Reveal Set: Highlight a valid set on the board (cycles through found sets)\n    - Shuffle Board: Create a new board (guaranteed to include at least one set)\n\n  Cards:\n    - Attributes: number (1-3), shape (0:oval,1:diamond,2:squiggle), color(0:red,1:teal,2:purple), fill(0:solid,1:striped,2:open)\n*/\n\n(function(){\n  const BOARD_SIZE = 12;\n  const boardEl = document.getElementById('board');\n  const revealBtn = document.getElementById('revealBtn');\n  const shuffleBtn = document.getElementById('shuffleBtn');\n  const setCountEl = document.getElementById('setCount');\n  const caption = document.getElementById('caption');\n  const boardSeedEl = document.getElementById('boardSeed');\n\n  // colors for shapes\n  const COLORS = ['#ff6b6b', '#50e3c2', '#9b8bff'];\n  // mapping labels for assistive text\n  const SHAPE_LABEL = ['Oval','Diamond','Squiggle'];\n  const FILL_LABEL = ['Solid','Striped','Outline'];\n\n  let currentBoard = [];\n  let foundSets = [];\n  let currentRevealIndex = -1;\n  let seed = Math.floor(Math.random()*1e9);\n\n  // deterministic-ish RNG with seed for reproducibility\n  function mulberry32(a) {\n    return function() {\n      var t = a += 0x6D2B79F5;\n      t = Math.imul(t ^ t >>> 15, t | 1);\n      t ^= t + Math.imul(t ^ t >>> 7, t | 61);\n      return ((t ^ t >>> 14) >>> 0) / 4294967296;\n    }\n  }\n\n  function shuffleArray(arr, rng){\n    for(let i = arr.length -1; i>0; i--){\n      const j = Math.floor(rng() * (i+1));\n      [arr[i], arr[j]] = [arr[j], arr[i]];\n    }\n  }\n\n  // generate random card set (attrs: n:0-2, shape:0-2, color:0-2, fill:0-2)\n  function randomCard(rng){\n    return {\n      n: Math.floor(rng()*3),\n      shape: Math.floor(rng()*3),\n      color: Math.floor(rng()*3),\n      fill: Math.floor(rng()*3),\n      id: Math.floor(rng()*1e9).toString(36) // unique-ish\n    };\n  }\n\n  // generate board with at least one set\n  function generateBoard(seedVal){\n    const rng = mulberry32(seedVal);\n    // produce a candidate pool of 12 unique cards; ensure at least one set\n    let pool = [];\n    // attempt strategy: create sets by hand then fill\n    // create at least one random set: pick first two cards randomly, compute third to complete set\n    const a = randomCard(rng);\n    const b = randomCard(rng);\n    const c = completeThird(a,b);\n    pool.push(a,b,c);\n\n    // fill rest with unique cards\n    const seen = new Set(pool.map(c=>serializeCard(c)));\n    while(pool.length < BOARD_SIZE){\n      const card = randomCard(rng);\n      const s = serializeCard(card);\n      if(!seen.has(s)){\n        seen.add(s);\n        pool.push(card);\n      }\n      // safety: break improbable infinite loop\n      if(seen.size > 1000) break;\n    }\n    // final shuffle\n    shuffleArray(pool, rng);\n    return pool;\n  }\n\n  function serializeCard(c){ return `${c.n}/${c.shape}/${c.color}/${c.fill}`; }\n\n  // complete third card for attributes: for each attribute if a==b then c==a else c is the remaining (0+1+2 - a - b)\n  function completeThird(a,b){\n    return {\n      n: a.n===b.n ? a.n : 3 - (a.n + b.n),\n      shape: a.shape===b.shape ? a.shape : 3 - (a.shape + b.shape),\n      color: a.color===b.color ? a.color : 3 - (a.color + b.color),\n      fill: a.fill===b.fill ? a.fill : 3 - (a.fill + b.fill),\n      id: 'set-' + Math.random().toString(36).slice(2,9)\n    };\n  }\n\n  // find all sets on the board\n  function findSets(board){\n    const sets = [];\n    const n = board.length;\n    for(let i=0;i<n;i++){\n      for(let j=i+1;j<n;j++){\n        for(let k=j+1;k<n;k++){\n          if(isSet(board[i], board[j], board[k])){\n            sets.push([i,j,k]);\n          }\n        }\n      }\n    }\n    return sets;\n  }\n\n  function isSet(a,b,c){\n    // for each attribute, all same or all different\n    return attrSet(a.n,b.n,c.n) &&\n           attrSet(a.shape,b.shape,c.shape) &&\n           attrSet(a.color,b.color,c.color) &&\n           attrSet(a.fill,b.fill,c.fill);\n  }\n  function attrSet(x,y,z){\n    return (x===y && y===z) || (x!==y && x!==z && y!==z);\n  }\n\n  // render SVG for a card's attributes\n  function renderCardSVG(card){\n    const w = 120, h = 140;\n    const cx = w/2;\n    const color = COLORS[card.color];\n    const fillStyle = card.fill; // 0 solid,1 striped,2 outline\n    const shapeType = card.shape;\n    const count = card.n + 1;\n    const spacing = 28;\n    const totalHeight = (count-1)*spacing;\n    const startY = (h/2) - totalHeight/2;\n    // striped pattern ID\n    const pid = `p-${card.id}`;\n    const strokeColor = color;\n    const strokeWidth = 2.6;\n\n    // shapes as SVG paths\n    function ovalPath(x,y){\n      return `<ellipse cx=\"${x}\" cy=\"${y}\" rx=\"22\" ry=\"10\"/>`;\n    }\n    function diamondPath(x,y){\n      return `<path d=\"M ${x} ${y-12} L ${x+18} ${y} L ${x} ${y+12} L ${x-18} ${y} Z\"/>`;\n    }\n    function squigglePath(x,y){\n      // a smooth wavy path\n      return `<path d=\"M ${x-22} ${y+4} C ${x-12} ${y-28}, ${x+12} ${y+28}, ${x+22} ${y+4} C ${x+10} ${y-10}, ${x-10} ${y+10}, ${x-22} ${y+4} Z\"/>`;\n    }\n\n    const shapes = [];\n    for(let i=0;i<count;i++){\n      const y = startY + i*spacing;\n      let inner;\n      if(shapeType===0) inner = ovalPath(cx,y);\n      else if(shapeType===1) inner = diamondPath(cx,y);\n      else inner = squigglePath(cx,y);\n      shapes.push({path:inner, y});\n    }\n\n    // shading: solid -> fill color; striped -> use mask pattern; outline -> stroke only\n    let defs = `<defs>\n      <pattern id=\"${pid}\" patternUnits=\"userSpaceOnUse\" width=\"6\" height=\"6\" patternTransform=\"rotate(20)\">\n        <rect width=\"6\" height=\"6\" fill=\"transparent\"></rect>\n        <path d=\"M0 0 L0 6\" stroke=\"${color}\" stroke-opacity=\"0.26\" stroke-width=\"2\"/>\n      </pattern>\n    </defs>`;\n\n    let content = `<svg viewBox=\"0 0 ${w} ${h}\" width=\"${w}\" height=\"${h}\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">` + defs;\n    // background subtle vignette\n    content += `<rect x=\"0\" y=\"0\" width=\"${w}\" height=\"${h}\" rx=\"12\" fill=\"transparent\"/>`;\n    shapes.forEach(s=>{\n      if(fillStyle===0){\n        // solid\n        content += `<g transform=\"translate(0,0)\">${s.path.replace(/\\/>/,' fill=\"'+color+'\" stroke=\"'+color+'\" stroke-width=\"'+strokeWidth+'\" stroke-opacity=\"0.02\"/>')}</g>`;\n      } else if(fillStyle===1){\n        // striped: stroke plus fill with pattern\n        content += `<g transform=\"translate(0,0)\">${s.path.replace(/\\/>/,' fill=\"url(#'+pid+')\" stroke=\"'+color+'\" stroke-width=\"'+strokeWidth+'\"/>').replace(/\\+pid\\+/g,pid)}</g>`;\n      } else {\n        // outline\n        content += `<g transform=\"translate(0,0)\">${s.path.replace(/\\/>/,' fill=\"none\" stroke=\"'+color+'\" stroke-width=\"'+strokeWidth+'\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>')}</g>`;\n      }\n    });\n    content += `</svg>`;\n    return content;\n  }\n\n  // render the board into DOM\n  function renderBoard(){\n    boardEl.innerHTML = '';\n    currentBoard.forEach((card, idx)=>{\n      const cardEl = document.createElement('div');\n      cardEl.className = 'card';\n      cardEl.dataset.index = idx;\n      cardEl.setAttribute('role','article');\n      cardEl.setAttribute('aria-label', `Card ${idx+1}: ${card.n+1} ${SHAPE_LABEL[card.shape]}, ${FILL_LABEL[card.fill]}, color ${card.color+1}`);\n      const inner = document.createElement('div');\n      inner.className = 'surface';\n      inner.innerHTML = renderCardSVG(card);\n      const pill = document.createElement('div');\n      pill.className='pill';\n      pill.textContent = `${card.n+1} ${SHAPE_LABEL[card.shape]}`;\n      cardEl.appendChild(inner);\n      cardEl.appendChild(pill);\n      boardEl.appendChild(cardEl);\n    });\n\n    // staggered entrance\n    const nodes = Array.from(boardEl.children);\n    nodes.forEach((node,i)=>{\n      setTimeout(()=>node.classList.add('visible'), 30*i);\n    });\n  }\n\n  // highlight a given set triple (indices)\n  function highlightSet(triple){\n    // clear previous\n    Array.from(boardEl.children).forEach((c, i)=>{\n      c.classList.remove('match');\n    });\n    if(!triple) return;\n    triple.forEach(i=>{\n      const el = boardEl.children[i];\n      if(el) el.classList.add('match');\n    });\n  }\n\n  function updateStatus(){\n    setCountEl.textContent = `Sets found: ${foundSets.length}`;\n    boardSeedEl.textContent = `Seed: ${seed}`;\n    if(foundSets.length === 0){\n      caption.textContent = 'No sets were found on this board (should be rare). Try Shuffle.';\n    } else {\n      caption.textContent = 'Reveal Set will cycle through the valid sets, highlighting them with a luminous accent.';\n    }\n  }\n\n  // initialize board with guaranteed at least one set\n  function init(newSeed){\n    seed = newSeed === undefined ? Math.floor(Math.random()*1e9) : newSeed;\n    currentBoard = generateBoard(seed);\n    foundSets = findSets(currentBoard);\n    currentRevealIndex = -1;\n    renderBoard();\n    updateStatus();\n    highlightSet(null);\n  }\n\n  // cycle reveal\n  function revealNext(){\n    if(foundSets.length === 0) return;\n    currentRevealIndex = (currentRevealIndex + 1) % foundSets.length;\n    const triple = foundSets[currentRevealIndex];\n    highlightSet(triple);\n    // update aria and caption with attributes\n    const cards = triple.map(i => currentBoard[i]);\n    const desc = `Set ${currentRevealIndex+1} of ${foundSets.length}: ` +\n      cards.map(c => `${c.n+1} ${SHAPE_LABEL[c.shape]} ${FILL_LABEL[c.fill]} in color ${COLORS[c.color]}`).join(' — ');\n    caption.textContent = 'Highlighted set: ' + desc;\n  }\n\n  // shuffle\n  function shuffleBoard(){\n    // new seed\n    init(Math.floor(Math.random()*1e9));\n  }\n\n  // Ensure initial board has at least one set: generate until foundSets > 0\n  function initEnsure(){\n    let tries = 0;\n    let s = seed;\n    while(true){\n      init(s);\n      if(foundSets.length > 0) break;\n      s = Math.floor(Math.random()*1e9);\n      tries++;\n      if(tries > 8) break;\n    }\n  }\n\n  // wire up buttons: limited interactivity\n  revealBtn.addEventListener('click', ()=>{\n    if(foundSets.length === 0){\n      caption.textContent = 'No sets to reveal. Try shuffling.';\n      return;\n    }\n    revealNext();\n    // subtle micro-interaction\n    revealBtn.animate([{transform:'translateY(0)'},{transform:'translateY(-4px)'},{transform:'translateY(0)'}],{duration:300,easing:'cubic-bezier(.2,.9,.3,1)'});\n  });\n\n  shuffleBtn.addEventListener('click', ()=>{\n    shuffleBtn.disabled = true;\n    shuffleBtn.style.opacity = '0.9';\n    // small animated rotation\n    boardEl.animate([{transform:'rotateX(0deg)'},{transform:'rotateX(15deg)'},{transform:'rotateX(0deg)'}],{duration:500,easing:'ease-in-out'});\n    setTimeout(()=>{\n      shuffleBoard();\n      shuffleBtn.disabled = false;\n      shuffleBtn.style.opacity = '1';\n    }, 420);\n  });\n\n  // initial seed from random\n  initEnsure();\n\n  // small accessibility: reveal first set after small delay to encourage observation\n  setTimeout(()=>{\n    if(foundSets.length>0){\n      revealNext();\n    }\n  }, 1200);\n\n})();\n</script>\n</body>\n</html>"
