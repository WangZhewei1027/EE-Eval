    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>HTTPS Demo</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #fff;\n            padding: 10px;\n            margin: 20px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        input[type=\"text\"], input[type=\"password\"] {\n            width: 100%;\n            height: 30px;\n            margin-bottom: 10px;\n            padding: 5px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        select {\n            width: 100%;\n            height: 30px;\n            margin-bottom: 10px;\n            padding: 5px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        button {\n            width: 100%;\n            height: 30px;\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 5px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n        .error {\n            color: #f44336;\n        }\n    </style>\n</head>\n<body>\n    <h1>HTTPS Demo</h1>\n    <form>\n        <label for=\"server\">Server:</label>\n        <input type=\"text\" id=\"server\" name=\"server\" value=\"example.com\">\n        <br>\n        <label for=\"port\">Port:</label>\n        <input type=\"text\" id=\"port\" name=\"port\" value=\"443\">\n        <br>\n        <label for=\"protocol\">Protocol:</label>\n        <input type=\"text\" id=\"protocol\" name=\"protocol\" value=\"https\">\n        <br>\n        <button id=\"submit\">Submit</button>\n    </form>\n    <p id=\"error\"></p>\n    <script>\n        const server = document.getElementById('server');\n        const port = document.getElementById('port');\n        const protocol = document.getElementById('protocol');\n        const submitButton = document.getElementById('submit');\n        const errorElement = document.getElementById('error');\n\n        submitButton.addEventListener('click', (e) => {\n            e.preventDefault();\n            const serverValue = server.value;\n            const portValue = port.value;\n            const protocolValue = protocol.value;\n\n            if (!serverValue || !portValue || !protocolValue) {\n                errorElement.textContent = 'Please fill in all fields';\n                return;\n            }\n\n            fetch(`https://${serverValue}:${portValue}/${protocolValue}/example`, {\n                method: 'GET'\n            })\n            .then((response) => {\n                if (response.ok) {\n                    console.log('Success!');\n                    errorElement.textContent = '';\n                } else {\n                    console.log('Error:', response.statusText);\n                    errorElement.textContent = 'Failed to connect to server';\n                }\n            })\n            .catch((error) => {\n                console.log('Error:', error);\n                errorElement.textContent = 'Failed to connect to server';\n            });\n        });\n    </script>\n</body>\n</html>"
