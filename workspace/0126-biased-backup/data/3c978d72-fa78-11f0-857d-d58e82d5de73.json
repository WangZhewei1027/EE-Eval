    "content": "<html lang=\"en\" >\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Dijkstra's Algorithm • Visualized</title>\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600&display=swap');\n\n    /* Reset and base */\n    * {\n      box-sizing: border-box;\n    }\n    html, body {\n      height: 100%;\n      margin: 0;\n      background: #0f172a; /* Dark slate background */\n      font-family: 'Montserrat', sans-serif;\n      color: #e0e6f3;\n      overflow: hidden;\n      -webkit-font-smoothing: antialiased;\n      -moz-osx-font-smoothing: grayscale;\n      user-select: none;\n    }\n\n    /* Container */\n    #app {\n      display: flex;\n      flex-direction: column;\n      height: 100vh;\n      justify-content: space-between;\n      background: linear-gradient(135deg, #152239 30%, #0b122e 80%);\n      padding: 2rem 3rem;\n    }\n\n    /* Header */\n    header {\n      text-align: center;\n      user-select: none;\n      margin-bottom: 1rem;\n      z-index: 10;\n    }\n    header h1 {\n      font-weight: 600;\n      font-size: 3.2rem;\n      letter-spacing: 0.1em;\n      color: #82c7e4; /* Soft electric blue */\n      text-shadow:\n        0 0 8px #82c7e4,\n        0 0 20px #4b9ecd,\n        0 0 30px #3b8ab9;\n      margin: 0 0 0.25rem 0;\n      line-height: 1.1;\n    }\n    header p {\n      font-weight: 300;\n      font-size: 1.1rem;\n      color: #a0acc8;\n      letter-spacing: 0.05em;\n      margin-top: 0;\n      user-select: none;\n    }\n\n    /* Graph Container */\n    #graph-container {\n      flex: 1;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      position: relative;\n      perspective: 1000px;\n    }\n\n    /* The graph SVG */\n    svg#graph {\n      width: 650px;\n      height: 520px;\n      background: #152943;\n      border-radius: 1.2rem;\n      filter:\n        drop-shadow(0 8px 12px rgba(0, 102, 163, 0.3));\n      box-shadow:\n        inset 0 0 45px #1f3c68,\n        0 0 20px rgba(31, 74, 122, 0.6);\n      user-select: none;\n      cursor: default;\n      transform-style: preserve-3d;\n      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n    }\n\n    /* Node styles */\n    .node {\n      cursor: default;\n    }\n\n    .node circle {\n      fill: #1f2a48;\n      stroke: #5f8bc4;\n      stroke-width: 3;\n      filter: drop-shadow(0 0 6px #4a8bd9cc);\n      transition: fill 0.4s ease, filter 0.4s ease;\n    }\n    .node text {\n      pointer-events: none;\n      fill: #a3b5d2;\n      font-weight: 600;\n      font-size: 0.9rem;\n      user-select: none;\n      text-shadow: 0 0 6px #375c99cc;\n      transition: fill 0.4s ease;\n    }\n\n    /* Labels inside nodes for distances */\n    .distance-label {\n      font-weight: 700;\n      font-size: 1rem;\n      fill: #82c7e4;\n      filter: drop-shadow(0 0 5px #82c7e4cc);\n      user-select: none;\n    }\n\n    /* Edge styles */\n    .edge {\n      fill: none;\n      stroke: #5c7aa0;\n      stroke-width: 2.6;\n      filter: drop-shadow(0 0 6px #3675aa88);\n      transition: stroke 0.5s ease;\n    }\n\n    /* Edge weight label */\n    .edge-label {\n      font-size: 0.75rem;\n      fill: #a2b8d9;\n      user-select: none;\n      text-shadow: 0 0 4px #2a4260bb;\n      font-weight: 500;\n    }\n\n    /* Highlights */\n\n    .node.visited circle {\n      fill: #4ea1e0;\n      stroke: #1b74d9;\n      filter:\n        drop-shadow(0 0 15px #4293dbbb)\n        drop-shadow(0 0 12px #1b74d9aa);\n      transition: all 0.5s ease;\n    }\n    .node.visited text,\n    .node.visited .distance-label {\n      fill: #d7ecff;\n      text-shadow: 0 0 10px #4da3e5cc;\n      transition: all 0.5s ease;\n    }\n\n    .node.current circle {\n      stroke: #ffc14c;\n      stroke-width: 4;\n      filter:\n        drop-shadow(0 0 18px #fdc84bcc);\n    }\n    .node.current text,\n    .node.current .distance-label {\n      fill: #ffe596;\n      text-shadow: 0 0 15px #ffdb67cc;\n    }\n\n    .edge.highlighted {\n      stroke: #f9b700;\n      stroke-width: 3.8;\n      filter:\n        drop-shadow(0 0 22px #ffcb47cc);\n      transition: all 0.6s ease;\n    }\n\n    .edge.highlighted ~ .edge-label {\n      fill: #ffdb50;\n      filter: drop-shadow(0 0 10px #ffdb50cc);\n      font-weight: 700;\n      transition: all 0.6s ease;\n    }\n\n    /* Controls */\n    #controls {\n      display: flex;\n      justify-content: center;\n      margin-top: 1.8rem;\n      gap: 2rem;\n      user-select: none;\n    }\n    button {\n      background: linear-gradient(145deg, #1f3160, #1a274f);\n      border: none;\n      padding: 0.85rem 2.5rem;\n      font-size: 1rem;\n      font-weight: 600;\n      color: #82c7e4;\n      border-radius: 12px;\n      cursor: pointer;\n      box-shadow:\n        6px 6px 15px #142343,\n        -6px -6px 15px #20395e;\n      transition: all 0.3s ease;\n      text-shadow: 0 0 6px #2a577f;\n      user-select:none;\n    }\n    button:focus {\n      outline: none;\n      box-shadow:\n        0 0 10px 2px #f9b700;\n      color: #ffd863;\n      text-shadow: 0 0 10px #ffde6d;\n    }\n    button:hover {\n      background: linear-gradient(145deg, #254376, #1f3c67);\n      box-shadow:\n        0 0 16px 3px #febf2fBB,\n        inset 0 0 8px #f9b700;\n      color: #ffe37f;\n      text-shadow: 0 0 12px #febf2fee;\n      transition: all 0.35s ease;\n    }\n    button:active {\n      box-shadow:\n        inset 3px 3px 8px #142343,\n        inset -3px -3px 8px #20395e;\n      color: #ffd33f;\n      text-shadow: 0 0 8px #ffa900cc;\n    }\n\n    /* Footer */\n    footer {\n      font-size: 0.75rem;\n      text-align: center;\n      color: #536484;\n      margin-top: 1rem;\n      user-select: none;\n      letter-spacing: 0.05em;\n    }\n\n    /* Animations for nodes & edges smoothly */\n    .animated-fade {\n      animation: fadeInScale 0.5s forwards ease-out;\n      opacity: 0;\n      transform-origin: center center;\n      transform: scale(0.8);\n    }\n    @keyframes fadeInScale {\n      to {\n        opacity: 1;\n        transform: scale(1);\n      }\n    }\n\n    /* Info box for explanation */\n    #explanation {\n      max-width: 630px;\n      margin: 0 auto;\n      font-weight: 300;\n      font-size: 1rem;\n      color: #a2b0d1;\n      line-height: 1.4;\n      letter-spacing: 0.03em;\n      font-style: italic;\n      text-align: center;\n      padding: 0 1rem;\n      user-select:none;\n      margin-top: 1rem;\n      opacity: 0.85;\n    }\n  </style>\n</head>\n<body>\n  <div id=\"app\">\n    <header>\n      <h1>Dijkstra's Algorithm</h1>\n      <p>Shortest Pathfinding Visualized</p>\n    </header>\n    <div id=\"graph-container\" aria-label=\"Graph visualization of Dijkstra's algorithm\">\n      <svg id=\"graph\" viewBox=\"0 0 650 520\" aria-hidden=\"true\" role=\"img\">\n        <!-- Edges will be inserted here by JS for clarity -->\n      </svg>\n    </div>\n    <div id=\"controls\" aria-label=\"Controls for animation\">\n      <button id=\"startBtn\" aria-pressed=\"false\" aria-label=\"Start the algorithm animation\">Start Animation</button>\n      <button id=\"resetBtn\" aria-label=\"Reset the visualization\" disabled>Reset</button>\n    </div>\n    <div id=\"explanation\">\n      Watch Dijkstra's algorithm illuminate the shortest path from <b>Start (A)</b> to <b>End (G)</b>.\n      Nodes glow as distances update, the current node pulses warmly, and edges highlight the fastest route.\n      This visualization elegantly unfolds the magic of weighted graphs and optimal routing.\n    </div>\n    <footer>\n      © 2024 • Designed & coded with passion\n    </footer>\n  </div>\n\n  <script>\n    (() => {\n      // Graph nodes and edges data representing a visually pleasing small weighted graph\n      const nodes = [\n        { id: 'A', x: 100, y: 400 },\n        { id: 'B', x: 220, y: 310 },\n        { id: 'C', x: 360, y: 380 },\n        { id: 'D', x: 490, y: 300 },\n        { id: 'E', x: 600, y: 420 },\n        { id: 'F', x: 490, y: 140 },\n        { id: 'G', x: 620, y: 180 }\n      ];\n\n      // Edges: undirected weighted edges between nodes\n      const edges = [\n        { from: 'A', to: 'B', weight: 7 },\n        { from: 'A', to: 'C', weight: 9 },\n        { from: 'A', to: 'F', weight: 14 },\n        { from: 'B', to: 'C', weight: 10 },\n        { from: 'B', to: 'D', weight: 15 },\n        { from: 'C', to: 'D', weight: 11 },\n        { from: 'C', to: 'F', weight: 2 },\n        { from: 'D', to: 'E', weight: 6 },\n        { from: 'E', to: 'F', weight: 9 },\n        { from: 'E', to: 'G', weight: 9 },\n        { from: 'F', to: 'G', weight: 9 }\n      ];\n\n      // Helper functions\n      const svgNS = \"http://www.w3.org/2000/svg\";\n\n      // Get the graph SVG\n      const graph = document.getElementById('graph');\n\n      // Render the edges as SVG lines + edge labels on midpoints\n      // Because undirected, draw line once from lower to higher id to avoid duplicates\n      // We'll store edge SVG elements for later highlight toggles\n\n      const edgeElements = [];\n      const nodeMap = new Map(nodes.map(n => [n.id, n]));\n\n      // For shortest path highlighting:\n      let highlightedEdges = [];\n\n      function createEdgeLine(edge) {\n        const fromNode = nodeMap.get(edge.from);\n        const toNode = nodeMap.get(edge.to);\n\n        const line = document.createElementNS(svgNS, 'line');\n        line.classList.add('edge');\n        line.setAttribute('x1', fromNode.x);\n        line.setAttribute('y1', fromNode.y);\n        line.setAttribute('x2', toNode.x);\n        line.setAttribute('y2', toNode.y);\n        line.setAttribute('aria-hidden', 'true');\n        graph.appendChild(line);\n\n        const label = document.createElementNS(svgNS, 'text');\n        label.classList.add('edge-label');\n        // Midpoint coordinates plus slight offset along normal to avoid overlap\n        const midX = (fromNode.x + toNode.x) / 2;\n        const midY = (fromNode.y + toNode.y) / 2;\n        // Calculate offset perpendicular to edge vector\n        const dx = toNode.x - fromNode.x;\n        const dy = toNode.y - fromNode.y;\n        const len = Math.sqrt(dx*dx + dy*dy);\n        const normX = -dy/len;\n        const normY = dx/len;\n\n        label.setAttribute('x', midX + normX * 14);\n        label.setAttribute('y', midY + normY * 16);\n        label.textContent = edge.weight;\n        graph.appendChild(label);\n\n        return { line, label };\n      }\n\n      // Render all edges and keep references\n      edges.forEach(edge => {\n        edgeElements.push({\n          edge,\n          ...(createEdgeLine(edge))\n        });\n      });\n\n      // Render nodes:\n      // Each node is a group <g> with circle and two text: id and distance label\n      // Distance starts as Infinity (∞), except start node at 0\n\n      const nodeElements = new Map();\n\n      nodes.forEach(node => {\n        const g = document.createElementNS(svgNS, 'g');\n        g.setAttribute('class', 'node animated-fade');\n        g.setAttribute('data-id', node.id);\n        g.setAttribute('transform', `translate(${node.x},${node.y})`);\n\n        const circle = document.createElementNS(svgNS, 'circle');\n        circle.setAttribute('r', 28);\n        circle.setAttribute('aria-hidden', 'true');\n        g.appendChild(circle);\n\n        const textId = document.createElementNS(svgNS, 'text');\n        textId.setAttribute('y', -6);\n        textId.setAttribute('text-anchor', 'middle');\n        textId.textContent = node.id;\n        g.appendChild(textId);\n\n        const textDist = document.createElementNS(svgNS, 'text');\n        textDist.setAttribute('class', 'distance-label');\n        textDist.setAttribute('y', 18);\n        textDist.setAttribute('text-anchor', 'middle');\n        textDist.setAttribute('aria-label', `Distance to node ${node.id}`);\n        // Distance label initial — infinity symbol\n        textDist.textContent = '∞';\n        g.appendChild(textDist);\n\n        graph.appendChild(g);\n\n        nodeElements.set(node.id, { group: g, circle, textId, textDist });\n      });\n\n      // Represent the graph in adjacency list for algorithm\n      // Undirected, so add edges both ways\n      const adjacency = new Map();\n      nodes.forEach(n => adjacency.set(n.id, []));\n\n      edges.forEach(({from, to, weight}) => {\n        adjacency.get(from).push({ node: to, weight });\n        adjacency.get(to).push({ node: from, weight });\n      });\n\n      // Algorithm & animation state\n\n      const startNodeId = 'A';\n      const endNodeId = 'G';\n\n      let animationFrame = null;\n\n      // We'll proceed stepwise:\n\n      // State variables for Dijkstra\n      let distances = new Map();\n      let previous = new Map();\n      let unvisited = new Set();\n\n      // Animation queue:\n      // Each step will highlight the current node, update neighbors' distances, and mark visited\n      // Smoothly animate changes with 900ms delay each step\n\n      // Reset all for new animation\n      function resetState() {\n        distances = new Map();\n        previous = new Map();\n        unvisited = new Set();\n        nodes.forEach(n => {\n          distances.set(n.id, Infinity);\n          previous.set(n.id, null);\n          unvisited.add(n.id);\n        });\n        distances.set(startNodeId, 0);\n\n        // Reset UI classes\n        nodeElements.forEach(({group, textDist}) => {\n          group.classList.remove('visited', 'current');\n          textDist.textContent = '∞';\n          textDist.setAttribute('aria-label', `Distance to node ${group.getAttribute('data-id')}: infinity`);\n        });\n        edgeElements.forEach(({line, label}) => {\n          line.classList.remove('highlighted');\n          label.style.fill = '';\n          label.style.filter = '';\n          label.style.fontWeight = '';\n        });\n        highlightedEdges = [];\n\n        updateAllDistancesUI();\n      }\n\n      // Update all distance labels UI\n      function updateAllDistancesUI() {\n        distances.forEach((dist, id) => {\n          const node = nodeElements.get(id);\n          const label = node.textDist;\n          if (dist === Infinity)\n            label.textContent = '∞';\n          else\n            label.textContent = dist;\n          label.setAttribute('aria-label', `Distance to node ${id}: ${dist === Infinity ? 'infinity' : dist}`);\n        });\n      }\n\n      // Select the unvisited node with the smallest distance\n      function getClosestUnvisited() {\n        let minDist = Infinity;\n        let minNode = null;\n        unvisited.forEach(node => {\n          const dist = distances.get(node);\n          if (dist < minDist) {\n            minDist = dist;\n            minNode = node;\n          }\n        });\n        return minNode;\n      }\n\n      // Animation control and timing\n\n      const stepDuration = 1200; // ms per step phase\n      let currentStep = 0;\n      let steps = [];\n\n      // Prepare steps of the algorithm for animation:\n      // Each step is an object representing highlighting a current node, updating neighbors\n      // and marking node visited in sequence\n\n      // Build steps array as {currentNode, updates: [{node, oldDist, newDist}], visitedNode}\n      function buildSteps() {\n        resetState();\n        let localDistances = new Map(distances);\n        let localPrevious = new Map(previous);\n        let localUnvisited = new Set(unvisited);\n\n        const steps = [];\n\n        while (localUnvisited.size) {\n          const u = (() => {\n            let minDistance = Infinity;\n            let minNode = null;\n            localUnvisited.forEach(v => {\n              if (localDistances.get(v) < minDistance) {\n                minDistance = localDistances.get(v);\n                minNode = v;\n              }\n            });\n            return minNode;\n          })();\n\n          if (u === null || localDistances.get(u) === Infinity) break;\n\n          // For this step, current node is u\n          const updates = [];\n\n          // Check neighbors to update\n          adjacency.get(u).forEach(({node: v, weight}) => {\n            if (!localUnvisited.has(v)) return;\n            const alt = localDistances.get(u) + weight;\n            if (alt < localDistances.get(v)) {\n              updates.push({\n                node: v,\n                oldDist: localDistances.get(v),\n                newDist: alt,\n              });\n              localDistances.set(v, alt);\n              localPrevious.set(v, u);\n            }\n          });\n\n          // This step objects\n          steps.push({\n            type: 'visit',\n            currentNode: u,\n            updates\n          });\n\n          localUnvisited.delete(u);\n\n          steps.push({\n            type: 'visited',\n            node: u\n          });\n\n          if (u === endNodeId) break; // Stop early if target reached\n        }\n\n        // Return steps and final previous map\n        return { steps, previous: localPrevious };\n      }\n\n      // Apply step animations sequentially with async-await timing\n\n      let isRunning = false;\n\n      async function runAnimation() {\n        if (isRunning) return;\n        isRunning = true;\n        startBtn.disabled = true;\n        resetBtn.disabled = true;\n        startBtn.setAttribute('aria-pressed', 'true');\n\n        // Clear previous highlights & classes\n        nodeElements.forEach(({group}) => {\n          group.classList.remove('visited', 'current');\n        });\n        edgeElements.forEach(({line, label}) => {\n          line.classList.remove('highlighted');\n          label.style.fill = '';\n          label.style.filter = '';\n          label.style.fontWeight = '';\n        });\n        highlightedEdges.forEach(({line,label}) => {\n          line.classList.remove('highlighted');\n          label.style.fill = '';\n          label.style.filter = '';\n          label.style.fontWeight = '';\n        });\n        highlightedEdges = [];\n\n        distances = new Map();\n        previous = new Map();\n        unvisited = new Set(nodes.map(n => n.id));\n\n        // Start distances at infinity (∞), 0 for start node\n        distances.set(startNodeId, 0);\n        nodes.forEach(n => {\n          if (!distances.has(n.id)) distances.set(n.id, Infinity);\n          previous.set(n.id, null);\n        });\n\n        updateAllDistancesUI();\n\n        // Get all steps\n        const result = buildSteps();\n        steps = result.steps;\n        previous = result.previous;\n\n        // Run through step animation frames\n        for (let i=0; i < steps.length; i++) {\n          const step = steps[i];\n          if (step.type === 'visit') {\n            // Highlight current node\n            await highlightCurrentNode(step.currentNode);\n            // Update neighbor distances visually\n            if (step.updates.length > 0) {\n              await animateDistanceUpdates(step.updates);\n            } else {\n              // Small pause if no updates\n              await pause(stepDuration * 0.7);\n            }\n          } else if (step.type === 'visited') {\n            markNodeVisited(step.node);\n            // Small pause\n            await pause(stepDuration * 0.5);\n          }\n        }\n\n        // Highlight shortest path edges from start to end using previous map\n        await animateShortestPath();\n\n        // Enable reset button\n        resetBtn.disabled = false;\n        isRunning = false;\n        startBtn.disabled = false;\n        startBtn.setAttribute('aria-pressed', 'false');\n      }\n\n      // Highlight current node (pulse yellow stroke)\n      async function highlightCurrentNode(id) {\n        nodeElements.forEach(({group}) => {\n          group.classList.remove('current');\n        });\n        const node = nodeElements.get(id);\n        if (!node) return;\n        node.group.classList.add('current');\n        // duration for highlight time, return a promise to await\n        return pause(stepDuration);\n      }\n\n      // Animate distance updates for neighbors\n      async function animateDistanceUpdates(updates) {\n        // Update distances one by one with brief delay\n        for (const {node: id, oldDist, newDist} of updates) {\n          if (newDist >= distances.get(id)) continue; // no improvement, skip\n\n          distances.set(id, newDist);\n          const node = nodeElements.get(id);\n          if (!node) continue;\n\n          // Animate distance label from old to new (fade out/in)\n          await fadeDistanceChange(node.textDist, oldDist, newDist);\n        }\n      }\n\n      // Fade old distance out, replace text, fade in new distance\n      function fadeDistanceChange(textElement, oldDist, newDist) {\n        return new Promise(resolve => {\n          const duration = 420;\n          // Animate to low opacity\n          textElement.style.transition = `opacity ${duration/1000}s ease`;\n          textElement.style.opacity = '0';\n          setTimeout(() => {\n            // Change text\n            textElement.textContent = newDist;\n            textElement.setAttribute('aria-label', `Distance updated to ${newDist}`);\n            // Fade back in\n            textElement.style.opacity = '1';\n            setTimeout(() => {\n              textElement.style.transition = '';\n              resolve();\n            }, duration);\n          }, duration);\n        });\n      }\n\n      // Mark node visited (blue fill)\n      function markNodeVisited(id) {\n        const node = nodeElements.get(id);\n        if (!node) return;\n        node.group.classList.remove('current');\n        node.group.classList.add('visited');\n        unvisited.delete(id);\n      }\n\n      // Short pause helper\n      function pause(ms) {\n        return new Promise(r => setTimeout(r, ms));\n      }\n\n      // Animate shortest path from end to start via previous map\n      async function animateShortestPath() {\n        // Build path by backtracking from endNodeId\n        let path = [];\n        let current = endNodeId;\n        while (current !== null) {\n          path.push(current);\n          current = previous.get(current);\n        }\n        path = path.reverse();\n\n        // Highlight edges along the path in sequence\n        for (let i=0; i < path.length-1; i++) {\n          const from = path[i];\n          const to = path[i+1];\n          await highlightEdgeBetween(from, to);\n          await pulseNodesAlongPath(path[i], path[i+1]);\n        }\n      }\n\n      async function highlightEdgeBetween(n1, n2) {\n        // Find edge element matching between n1 and n2 (undirected)\n        const edgeObj = edgeElements.find(({edge}) => \n          (edge.from === n1 && edge.to === n2) || (edge.from === n2 && edge.to === n1)\n        );\n        if (!edgeObj) return;\n        const {line, label} = edgeObj;\n        line.classList.add('highlighted');\n        label.style.fill = '#f9b700';\n        label.style.filter = 'drop-shadow(0 0 10px #f9b700cc)';\n        label.style.fontWeight = '700';\n\n        // Animate glow pulse on edge\n        line.animate([\n          { strokeWidth: '6', filter: 'drop-shadow(0 0 28px #fff046bb)' },\n          { strokeWidth: '3.8', filter: 'drop-shadow(0 0 14px #f9b700cc)' }\n        ], {\n          duration: 900,\n          easing: 'ease-in-out',\n         });\n        await pause(900);\n      }\n\n      async function pulseNodesAlongPath(...nodeIds) {\n        for (const id of nodeIds) {\n          const node = nodeElements.get(id);\n          if (!node) continue;\n          const pulse = node.group.animate([\n            { filter: 'drop-shadow(0 0 20px #f9b700cc)' },\n            { filter: 'drop-shadow(0 0 35px #fff046cc)' },\n            { filter: 'drop-shadow(0 0 20px #f9b700cc)' },\n          ], { duration: 800, easing: 'ease-in-out' });\n          await pulse.finished;\n        }\n      }\n\n      // Attach event listeners for buttons\n\n      const startBtn = document.getElementById('startBtn');\n      const resetBtn = document.getElementById('resetBtn');\n\n      startBtn.addEventListener('click', () => {\n        if (isRunning) return;\n        runAnimation();\n      });\n\n      resetBtn.addEventListener('click', () => {\n        if (isRunning) return;\n        resetState();\n        resetBtn.disabled = true;\n      });\n\n      // Initialize distances on load\n      resetState();\n      resetBtn.disabled = true;\n    })();\n  </script>\n</body>\n</html>"
  },
