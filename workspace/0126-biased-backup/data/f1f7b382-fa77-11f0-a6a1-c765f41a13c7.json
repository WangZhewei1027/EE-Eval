    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>SQL — Visual Demonstration</title>\n<style>\n  :root{\n    --bg1:#0f1724;\n    --bg2:#071029;\n    --glass: rgba(255,255,255,0.06);\n    --accent-1: #6EE7B7;\n    --accent-2: #60A5FA;\n    --muted: rgba(255,255,255,0.65);\n    --glass-2: rgba(255,255,255,0.03);\n    --card-shadow: 0 10px 30px rgba(2,6,23,0.6);\n    --glass-border: rgba(255,255,255,0.06);\n    --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Courier New\", monospace;\n    --ui: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n\n  /* Page background and mood */\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: var(--ui);\n    background:\n      radial-gradient(800px 400px at 10% 10%, rgba(96,165,250,0.08), transparent 10%),\n      radial-gradient(700px 350px at 90% 90%, rgba(110,231,183,0.05), transparent 10%),\n      linear-gradient(180deg, var(--bg1) 0%, var(--bg2) 100%);\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated particles */\n  .ambient{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n  }\n  .particle{\n    position:absolute;\n    width:18px;\n    height:18px;\n    background:linear-gradient(135deg, rgba(96,165,250,0.14), rgba(110,231,183,0.14));\n    border-radius:14px;\n    filter: blur(6px);\n    opacity:0.9;\n    animation: float 8s ease-in-out infinite;\n    mix-blend-mode: screen;\n  }\n  @keyframes float {\n    0%{ transform: translateY(0) scale(1); opacity:0.9; }\n    50%{ transform: translateY(-40px) scale(1.1); opacity:0.7; }\n    100%{ transform: translateY(0) scale(1); opacity:0.9;}\n  }\n\n  /* Center layout */\n  .wrap{\n    position:relative;\n    max-width:1100px;\n    margin:40px auto;\n    padding:36px;\n    display:grid;\n    grid-template-columns: 420px 1fr;\n    gap:28px;\n    align-items:stretch;\n  }\n\n  header{\n    grid-column: 1 / -1;\n    display:flex;\n    align-items:center;\n    gap:18px;\n    margin-bottom:6px;\n  }\n  .logo{\n    width:76px;\n    height:76px;\n    border-radius:14px;\n    background: linear-gradient(135deg, rgba(96,165,250,0.14), rgba(110,231,183,0.12));\n    box-shadow: 0 8px 30px rgba(8,10,20,0.6), inset 0 -6px 16px rgba(0,0,0,0.25);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    border: 1px solid rgba(255,255,255,0.04);\n    backdrop-filter: blur(6px) saturate(120%);\n  }\n  .logo svg{ width:56px; height:56px; transform:translateY(-2px); }\n\n  h1{\n    margin:0;\n    font-size:20px;\n    letter-spacing:0.6px;\n    color: #eaf6ff;\n  }\n  p.lead{\n    margin:4px 0 0 0;\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  /* Card style */\n  .card{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:16px;\n    padding:22px;\n    box-shadow: var(--card-shadow);\n    border: 1px solid var(--glass-border);\n    position:relative;\n    overflow:hidden;\n    min-height:420px;\n  }\n\n  /* Left column (schema + visuals) */\n  .schema{\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    height:100%;\n  }\n\n  .table-visual{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:14px;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .table-title{\n    display:flex;\n    align-items:center;\n    gap:10px;\n    font-weight:600;\n    color:#eaf6ff;\n    font-size:13px;\n    margin-bottom:10px;\n  }\n  .pill{\n    background: linear-gradient(90deg,var(--accent-1),var(--accent-2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color:transparent;\n    font-weight:700;\n    font-size:12px;\n  }\n\n  .schema-grid{\n    display:grid;\n    grid-template-columns:1fr 1fr;\n    gap:12px;\n  }\n  .mini-table{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    border-radius:10px;\n    padding:10px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    font-size:12px;\n    color:var(--muted);\n  }\n  .mini-table h4{\n    margin:0 0 8px 0;\n    font-size:12px;\n    color:#eaf6ff;\n    letter-spacing:0.3px;\n  }\n  .columns{\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n  }\n  .col{\n    display:flex;\n    justify-content:space-between;\n    gap:8px;\n    align-items:center;\n    color:var(--muted);\n  }\n  .col .type{\n    font-size:11px;\n    color: rgba(234,246,255,0.4);\n    background: rgba(255,255,255,0.02);\n    padding:4px 8px;\n    border-radius:999px;\n    border: 1px solid rgba(255,255,255,0.02);\n  }\n\n  /* Visual map */\n  .map{\n    position:relative;\n    height:130px;\n    margin-top:8px;\n  }\n  .db-node{\n    position:absolute;\n    padding:10px 12px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(0,0,0,0.15), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    gap:10px;\n    align-items:center;\n    color:#eaf6ff;\n    box-shadow: 0 6px 20px rgba(2,6,23,0.45);\n    font-size:13px;\n  }\n  .db-node small{ display:block; font-size:11px; color:var(--muted); opacity:0.9; }\n\n  .node-left{ left:12px; top:12px; width:150px; }\n  .node-right{ right:12px; top:12px; width:170px; justify-content:flex-end; text-align:right; }\n  .node-center{ left:50%; transform:translateX(-50%); bottom:12px; width:220px; justify-content:center; }\n\n  /* Middle decorative connection */\n  .connection{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n  }\n\n  /* Right column: query & results */\n  .panel{\n    display:flex;\n    flex-direction:column;\n    gap:16px;\n    height:100%;\n  }\n  .query{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.012));\n    border-radius:12px;\n    padding:16px;\n    border:1px solid rgba(255,255,255,0.03);\n    font-family: var(--mono);\n    font-size:13px;\n    color:#eaf6ff;\n    min-height:120px;\n    position:relative;\n    overflow:hidden;\n  }\n  .query .meta{\n    display:flex;\n    gap:10px;\n    align-items:center;\n    font-size:12px;\n    color:var(--muted);\n    margin-bottom:10px;\n  }\n  .code{\n    white-space:pre-wrap;\n    line-height:1.6;\n    letter-spacing:0.2px;\n  }\n  .kw{ color:#7fdbff; font-weight:700; }\n  .ident{ color:#a7ffcf; }\n  .num{ color:#ffc77a; }\n  .op{ color:#c7d2fe; }\n  .comment{ color: rgba(234,246,255,0.25); font-style:italic; font-weight:500; }\n\n  /* Result area */\n  .results{\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:18px;\n    border:1px solid rgba(255,255,255,0.03);\n    flex:1;\n    position:relative;\n    overflow:hidden;\n  }\n  .results-head{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n    margin-bottom:14px;\n  }\n  .results-title{ font-weight:700; color:#eaf6ff; font-size:13px; }\n  .results-sub{ font-size:12px; color:var(--muted); }\n\n  .grid{\n    display:grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap:10px;\n  }\n  .cell{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.015));\n    padding:12px;\n    border-radius:10px;\n    border:1px solid rgba(255,255,255,0.02);\n    color:var(--muted);\n    font-size:13px;\n    min-height:56px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    overflow:hidden;\n  }\n\n  .cell .value{\n    font-size:14px;\n    color:#eaf6ff;\n    font-weight:600;\n  }\n\n  /* Animated chips */\n  .chip{\n    position:absolute;\n    padding:8px 12px;\n    border-radius:999px;\n    background: linear-gradient(90deg, rgba(96,165,250,0.12), rgba(110,231,183,0.12));\n    border:1px solid rgba(255,255,255,0.04);\n    color:#eaf6ff;\n    font-family:var(--mono);\n    font-size:12px;\n    box-shadow: 0 10px 30px rgba(2,6,23,0.45);\n    transform-origin:center;\n    opacity:0;\n    transition: transform 700ms cubic-bezier(.2,.9,.2,1), opacity 350ms ease, filter 400ms ease;\n    backdrop-filter: blur(6px);\n  }\n\n  /* Buttons */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-top:8px;\n  }\n  .btn{\n    -webkit-tap-highlight-color: transparent;\n    border:0;\n    padding:10px 14px;\n    border-radius:10px;\n    cursor:pointer;\n    font-weight:700;\n    font-size:13px;\n    letter-spacing:0.6px;\n    color: #071029;\n    background:linear-gradient(90deg,var(--accent-1),var(--accent-2));\n    box-shadow: 0 8px 24px rgba(34,197,94,0.08), 0 2px 6px rgba(2,6,23,0.3);\n    transition: transform 220ms ease, box-shadow 220ms ease, filter 220ms ease;\n  }\n  .btn:active{ transform: translateY(1px); }\n  .btn.secondary{\n    background:transparent;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow:none;\n  }\n  .btn[disabled]{ opacity:0.5; cursor:default; pointer-events:none; transform:none; }\n\n  /* Small flourish */\n  .spark{\n    position:absolute;\n    right:-60px;\n    top:-60px;\n    width:220px;\n    height:220px;\n    background: radial-gradient(circle at 20% 30%, rgba(96,165,250,0.12), transparent 10%),\n                radial-gradient(circle at 80% 80%, rgba(110,231,183,0.08), transparent 8%);\n    filter: blur(60px);\n    transform: rotate(21deg);\n    opacity:0.95;\n    pointer-events:none;\n  }\n\n  /* Micro interactions: entry tween */\n  .fade-in{ animation: fadeUp 800ms cubic-bezier(.2,.9,.2,1) both; }\n  @keyframes fadeUp{\n    from{ transform: translateY(8px); opacity:0; }\n    to{ transform: translateY(0); opacity:1; }\n  }\n\n  /* Responsive */\n  @media (max-width:980px){\n    .wrap{ grid-template-columns: 1fr; padding:20px; }\n    .logo{ display:none; }\n    .node-left, .node-right, .node-center{ position:relative; left:auto; right:auto; transform:none; width:auto; top:auto; bottom:auto; }\n    .map{ height:160px; }\n  }\n\n  /* little highlighting effect for results */\n  .highlight{\n    animation: glow 900ms ease forwards;\n  }\n  @keyframes glow{\n    0%{ box-shadow: 0 0 0 rgba(110,231,183,0.0); transform: translateY(-6px); }\n    40%{ box-shadow: 0 14px 40px rgba(110,231,183,0.08); transform: translateY(0); }\n    100%{ box-shadow: none; transform:none; }\n  }\n\n  /* tiny footer note */\n  footer{\n    grid-column:1 / -1;\n    margin:10px auto 0;\n    text-align:center;\n    color:rgba(234,246,255,0.14);\n    font-size:12px;\n  }\n</style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\">\n    <div class=\"particle\" style=\"left:6%; top:12%; animation-delay:-1s; width:26px; height:26px;\"></div>\n    <div class=\"particle\" style=\"left:22%; top:30%; animation-delay:1s;\"></div>\n    <div class=\"particle\" style=\"left:80%; top:16%; animation-delay:2s; width:30px; height:30px;\"></div>\n    <div class=\"particle\" style=\"left:70%; top:74%; animation-delay:-2s; width:20px; height:20px;\"></div>\n    <div class=\"particle\" style=\"left:38%; top:58%; animation-delay:0.8s; width:18px; height:18px;\"></div>\n  </div>\n\n  <div class=\"wrap fade-in\" role=\"main\">\n    <header>\n      <div class=\"logo\" aria-hidden=\"true\">\n        <!-- stylized DB icon -->\n        <svg viewBox=\"0 0 64 64\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#60A5FA\"/>\n              <stop offset=\"1\" stop-color=\"#6EE7B7\"/>\n            </linearGradient>\n          </defs>\n          <ellipse cx=\"32\" cy=\"16\" rx=\"22\" ry=\"8\" fill=\"url(#g1)\" opacity=\"0.16\"/>\n          <path d=\"M10 16v12c0 4.4 9.9 8 22 8s22-3.6 22-8V16\" stroke=\"url(#g1)\" stroke-width=\"2.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.95\"/>\n          <path d=\"M10 28v12c0 4.4 9.9 8 22 8s22-3.6 22-8V28\" stroke=\"url(#g1)\" stroke-width=\"2.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.75\"/>\n        </svg>\n      </div>\n      <div>\n        <h1>SQL — Query Visualization</h1>\n        <p class=\"lead\">Aesthetically curated, minimal interaction demonstration of SELECT operations and result flow.</p>\n      </div>\n    </header>\n\n    <!-- Left: schema + visualization -->\n    <section class=\"card schema\" aria-label=\"Database schema and visualization\">\n      <div class=\"table-visual\">\n        <div class=\"table-title\"><span class=\"pill\">employees</span><small style=\"margin-left:8px; color:var(--muted);\">table • 248 rows</small></div>\n        <div class=\"schema-grid\">\n          <div class=\"mini-table\">\n            <h4>employees</h4>\n            <div class=\"columns\">\n              <div class=\"col\"><span>id</span><span class=\"type\">INT</span></div>\n              <div class=\"col\"><span>name</span><span class=\"type\">TEXT</span></div>\n              <div class=\"col\"><span>department</span><span class=\"type\">TEXT</span></div>\n              <div class=\"col\"><span>salary</span><span class=\"type\">INT</span></div>\n            </div>\n          </div>\n          <div class=\"mini-table\">\n            <h4>departments</h4>\n            <div class=\"columns\">\n              <div class=\"col\"><span>dept_id</span><span class=\"type\">INT</span></div>\n              <div class=\"col\"><span>name</span><span class=\"type\">TEXT</span></div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"map\" aria-hidden=\"true\">\n          <div class=\"db-node node-left\" id=\"node-table\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9;\">\n              <path d=\"M12 2C7.58 2 4 3.79 4 6s3.58 4 8 4 8-1.79 8-4-3.58-4-8-4z\" stroke=\"#a7ffcf\" stroke-opacity=\"0.9\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              <path d=\"M4 10v6c0 2.21 3.58 4 8 4s8-1.79 8-4v-6\" stroke=\"#60A5FA\" stroke-opacity=\"0.9\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n            <div>\n              <div style=\"font-weight:700; font-size:13px;\">employees</div>\n              <small>rows • 248</small>\n            </div>\n          </div>\n\n          <div class=\"db-node node-right\" id=\"node-dept\">\n            <div>\n              <div style=\"font-weight:700; font-size:13px;\">departments</div>\n              <small>rows • 12</small>\n            </div>\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"opacity:0.9;\">\n              <path d=\"M12 2C7.58 2 4 3.79 4 6s3.58 4 8 4 8-1.79 8-4-3.58-4-8-4z\" stroke=\"#a7ffcf\" stroke-opacity=\"0.9\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              <path d=\"M4 10v6c0 2.21 3.58 4 8 4s8-1.79 8-4v-6\" stroke=\"#60A5FA\" stroke-opacity=\"0.9\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </div>\n\n          <div class=\"db-node node-center\" style=\"pointer-events:none;\">\n            <div style=\"display:flex; align-items:center; gap:12px;\">\n              <svg width=\"36\" height=\"36\" viewBox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M3 7v10c0 2.21 3.58 4 8 4s8-1.79 8-4V7\" stroke=\"#c7d2fe\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                <path d=\"M3 11c4.42 2 9.58 2 14 0\" stroke=\"#6EE7B7\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n              </svg>\n              <div style=\"text-align:left;\">\n                <div style=\"font-weight:800; font-size:14px; color:#eaf6ff;\">Query Engine</div>\n                <small style=\"color:var(--muted)\">planner • optimizer • executor</small>\n              </div>\n            </div>\n          </div>\n\n          <svg class=\"connection\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" style=\"pointer-events:none;\">\n            <defs>\n              <linearGradient id=\"link\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#60A5FA\" stop-opacity=\"0.6\"/>\n                <stop offset=\"1\" stop-color=\"#6EE7B7\" stop-opacity=\"0.6\"/>\n              </linearGradient>\n            </defs>\n            <path d=\"M8 20 C 35 30, 65 30, 92 20\" stroke=\"url(#link)\" stroke-width=\"0.9\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.35\"/>\n            <path d=\"M8 50 C 35 62, 65 62, 92 50\" stroke=\"url(#link)\" stroke-width=\"0.9\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.25\"/>\n            <path d=\"M8 82 C 35 74, 65 74, 92 82\" stroke=\"url(#link)\" stroke-width=\"0.9\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.18\"/>\n          </svg>\n        </div>\n      </div>\n\n      <div class=\"spark\" aria-hidden=\"true\"></div>\n    </section>\n\n    <!-- Right: query and results -->\n    <section class=\"card panel\" aria-label=\"Query and results\">\n      <div class=\"query\" role=\"region\" aria-labelledby=\"query-title\">\n        <div class=\"meta\">\n          <div style=\"display:flex; gap:8px; align-items:center;\">\n            <div style=\"width:10px; height:10px; border-radius:50%; background:linear-gradient(90deg,var(--accent-1),var(--accent-2)); box-shadow:0 6px 18px rgba(96,165,250,0.12);\"></div>\n            <strong id=\"query-title\" style=\"font-size:13px; color:#eaf6ff;\">SELECT • simple filter & ordering</strong>\n          </div>\n          <div style=\"margin-left:auto; font-size:12px; color:var(--muted);\">Demo • Read-only</div>\n        </div>\n\n        <div class=\"code\" id=\"code-block\" aria-hidden=\"false\" style=\"pointer-events:none;\">\n          <span class=\"kw\">SELECT</span> <span class=\"ident\">name</span>, <span class=\"ident\">department</span> <span class=\"kw\">FROM</span> <span class=\"ident\">employees</span>\n          <br>\n          <span class=\"kw\">WHERE</span> <span class=\"ident\">salary</span> <span class=\"op\">&gt;</span> <span class=\"num\">90000</span>\n          <br>\n          <span class=\"kw\">ORDER BY</span> <span class=\"ident\">salary</span> <span class=\"kw\">DESC</span>\n          <br>\n          <span class=\"kw\">LIMIT</span> <span class=\"num\">5</span><span class=\"comment\">  -- top paid employees</span>\n        </div>\n\n        <div style=\"display:flex; justify-content:flex-end; margin-top:12px;\">\n          <div class=\"controls\" aria-hidden=\"false\">\n            <button id=\"execute\" class=\"btn\" title=\"Execute the query (visual)\">Execute Query</button>\n            <button id=\"reset\" class=\"btn secondary\" title=\"Reset visualization\">Reset</button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"results\" id=\"results\" role=\"region\" aria-labelledby=\"results-title\">\n        <div class=\"results-head\">\n          <div>\n            <div id=\"results-title\" class=\"results-title\">Results (5 rows)</div>\n            <div id=\"results-sub\" class=\"results-sub\">execution • scanned: 248 rows • returned: 5</div>\n          </div>\n          <div style=\"display:flex; gap:10px; align-items:center;\">\n            <svg width=\"42\" height=\"42\" viewBox=\"0 0 24 24\" fill=\"none\">\n              <path d=\"M4 6h16M4 12h10M4 18h16\" stroke=\"#60A5FA\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.95\"/>\n            </svg>\n            <div style=\"font-size:12px; color:var(--muted);\">visual • non-interactive</div>\n          </div>\n        </div>\n\n        <div class=\"grid\" id=\"grid\">\n          <div class=\"cell\" data-col=\"name\"><div class=\"value\" id=\"r1c1\">—</div></div>\n          <div class=\"cell\" data-col=\"department\"><div class=\"value\" id=\"r1c2\">—</div></div>\n          <div class=\"cell\" data-col=\"salary\"><div class=\"value\" id=\"r1c3\">—</div></div>\n\n          <div class=\"cell\"><div class=\"value\" id=\"r2c1\">—</div></div>\n          <div class=\"cell\"><div class=\"value\" id=\"r2c2\">—</div></div>\n          <div class=\"cell\"><div class=\"value\" id=\"r2c3\">—</div></div>\n\n          <div class=\"cell\"><div class=\"value\" id=\"r3c1\">—</div></div>\n          <div class=\"cell\"><div class=\"value\" id=\"r3c2\">—</div></div>\n          <div class=\"cell\"><div class=\"value\" id=\"r3c3\">—</div></div>\n\n          <div class=\"cell\"><div class=\"value\" id=\"r4c1\">—</div></div>\n          <div class=\"cell\"><div class=\"value\" id=\"r4c2\">—</div></div>\n          <div class=\"cell\"><div class=\"value\" id=\"r4c3\">—</div></div>\n\n          <div class=\"cell\"><div class=\"value\" id=\"r5c1\">—</div></div>\n          <div class=\"cell\"><div class=\"value\" id=\"r5c2\">—</div></div>\n          <div class=\"cell\"><div class=\"value\" id=\"r5c3\">—</div></div>\n        </div>\n\n        <!-- container for animated chips -->\n        <div id=\"chip-layer\" style=\"position:absolute; inset:18px; pointer-events:none;\"></div>\n      </div>\n    </section>\n\n    <footer>Design inspired by dataflow — this demo visually represents a SELECT pipeline. Minimal controls (execute/reset).</footer>\n  </div>\n\n<script>\n(function(){\n  // Demo data - top 5 salaries (static for visual demo)\n  const resultsData = [\n    { name: \"Alexandra Greene\", department: \"Research\", salary: 198000 },\n    { name: \"Marcus Rey\", department: \"Engineering\", salary: 174500 },\n    { name: \"Priya Kaur\", department: \"Finance\", salary: 165000 },\n    { name: \"Daniel Cho\", department: \"Design\", salary: 152500 },\n    { name: \"Lina Moreno\", department: \"Product\", salary: 149000 }\n  ];\n\n  const executeBtn = document.getElementById('execute');\n  const resetBtn = document.getElementById('reset');\n  const chipLayer = document.getElementById('chip-layer');\n  const grid = document.getElementById('grid');\n  const resultsTitle = document.getElementById('results-title');\n  const resultsSub = document.getElementById('results-sub');\n\n  let running = false;\n  let chips = [];\n\n  // Utility: get absolute position of an element relative to chipLayer container\n  function getOffset(el){\n    const parentRect = chipLayer.getBoundingClientRect();\n    const r = el.getBoundingClientRect();\n    return {\n      left: r.left - parentRect.left,\n      top: r.top - parentRect.top,\n      width: r.width,\n      height: r.height\n    };\n  }\n\n  // Create a chip representing a row scanning\n  function createChip(text, fromRect){\n    const chip = document.createElement('div');\n    chip.className = 'chip';\n    chip.textContent = text;\n    chip.style.left = (fromRect.left + fromRect.width/2 - 48) + 'px';\n    chip.style.top = (fromRect.top + fromRect.height/2 - 16) + 'px';\n    chip.style.opacity = '0';\n    chipLayer.appendChild(chip);\n    // force reflow then show\n    requestAnimationFrame(()=> {\n      chip.style.opacity = '1';\n      chip.style.transform = 'scale(.98)';\n    });\n    chips.push(chip);\n    return chip;\n  }\n\n  // Animate a chip to a target cell then settle\n  function animateChipTo(chip, targetRect, delay=0){\n    return new Promise(resolve=>{\n      const start = chip.getBoundingClientRect();\n      const parentRect = chipLayer.getBoundingClientRect();\n      const sx = start.left - parentRect.left;\n      const sy = start.top - parentRect.top;\n      const tx = targetRect.left;\n      const ty = targetRect.top;\n      const deltaX = tx - sx;\n      const deltaY = ty - sy;\n      // Use CSS transform for smoother motion\n      chip.style.transition = `transform 900ms cubic-bezier(.18,.9,.32,1) ${delay}ms, opacity 300ms linear ${delay}ms`;\n      chip.style.transform = `translate(${deltaX}px, ${deltaY}px) scale(1)`;\n      // little rotation & glow\n      chip.style.filter = 'brightness(1.04)';\n      setTimeout(()=> {\n        chip.style.opacity = '0';\n        setTimeout(()=> {\n          resolve();\n        }, 220);\n      }, 980 + delay);\n    });\n  }\n\n  // Fill results cells animated\n  function fillCell(row, data){\n    const nameCell = document.getElementById(`r${row}c1`);\n    const deptCell = document.getElementById(`r${row}c2`);\n    const salCell = document.getElementById(`r${row}c3`);\n    // animate text appearance\n    [nameCell, deptCell, salCell].forEach((el, idx) => {\n      el.style.opacity = '0';\n      setTimeout(()=> {\n        if(el === nameCell) el.textContent = data.name;\n        if(el === deptCell) el.textContent = data.department;\n        if(el === salCell) el.textContent = '$' + data.salary.toLocaleString();\n        el.parentElement.classList.add('highlight');\n        el.style.opacity = '1';\n        // remove highlight after a moment\n        setTimeout(()=> el.parentElement.classList.remove('highlight'), 900);\n      }, 220 * idx);\n    });\n  }\n\n  // Reset grid\n  function resetGrid(){\n    for(let r=1;r<=5;r++){\n      document.getElementById(`r${r}c1`).textContent = '—';\n      document.getElementById(`r${r}c2`).textContent = '—';\n      document.getElementById(`r${r}c3`).textContent = '—';\n    }\n    // clear chips\n    chips.forEach(c=> c.remove());\n    chips = [];\n    resultsTitle.textContent = 'Results (5 rows)';\n    resultsSub.textContent = 'execution • scanned: 248 rows • returned: 5';\n    executeBtn.disabled = false;\n  }\n\n  resetBtn.addEventListener('click', () => {\n    if(running) return;\n    resetGrid();\n  });\n\n  executeBtn.addEventListener('click', async () => {\n    if(running) return;\n    running = true;\n    executeBtn.disabled = true;\n    resetGrid(); // ensure cleared\n\n    // Visual: create chips from the employees node\n    const sourceNode = document.getElementById('node-table');\n    const sourceRect = getOffset(sourceNode);\n    const resultsRect = document.getElementById('results').getBoundingClientRect();\n    // We'll animate 5 chips (simulate scan -> filter -> top)\n    for(let i=0;i<resultsData.length;i++){\n      const chip = createChip('row • ' + (i+1), sourceRect);\n      // target cell (center of row cells)\n      const targetName = document.getElementById(`r${i+1}c1`).parentElement;\n      const targetRect = getOffset(targetName);\n      // offset to center of cell\n      const tLeft = targetRect.left + (targetRect.width/2 - 48);\n      const tTop = targetRect.top + (targetRect.height/2 - 12);\n      // animate to cell with stagger\n      animateChipTo(chip, {left: tLeft, top: tTop}, i*140).then(()=>{\n        // fill the data into the grid (with small stagger)\n        fillCell(i+1, resultsData[i]);\n      });\n      // small delay between chip creation for nice stagger\n      await new Promise(res => setTimeout(res, 120));\n    }\n\n    // After all animations, show a small success flourish\n    setTimeout(()=>{\n      resultsTitle.textContent = 'Results • Completed';\n      resultsSub.textContent = 'execution time: 12 ms • scanned: 248 rows • returned: 5';\n      // cleanup chips (ensure removed)\n      chips.forEach(c=> c.remove());\n      chips = [];\n      running = false;\n      executeBtn.disabled = false;\n    }, 1600 + resultsData.length*220);\n  });\n\n  // Initial micro animation: gently pulse engine node\n  (function pulseEngine(){\n    const engine = document.querySelector('.node-center');\n    let t = 0;\n    setInterval(()=> {\n      engine.style.transform = `translateX(-50%) scale(${1 + 0.01*Math.sin(t)})`;\n      t += 0.6;\n    }, 220);\n  })();\n\n  // Initial subtle fill of top title\n  setTimeout(()=> {\n    const lead = document.querySelector('.lead');\n    lead.style.opacity = '1';\n  }, 500);\n\n})();\n</script>\n</body>\n</html>"
  },
