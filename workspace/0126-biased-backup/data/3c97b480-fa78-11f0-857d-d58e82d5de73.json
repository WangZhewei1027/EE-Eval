    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Bellman-Ford Algorithm Visualization</title>\n<style>\n  /* Reset and base */\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n  * {\n    box-sizing: border-box;\n  }\n  html, body {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e6f0;\n    overflow: hidden;\n  }\n\n  /* Container */\n  .container {\n    display: flex;\n    flex-direction: column;\n    min-height: 100vh;\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 1.5rem 2rem 4rem;\n    user-select: none;\n  }\n\n  /* Header */\n  header {\n    text-align: center;\n    margin-bottom: 1.5rem;\n    letter-spacing: 2px;\n  }\n  header h1 {\n    font-weight: 600;\n    font-size: 3rem;\n    line-height: 1.1;\n    color: #a4cdfc;\n    text-shadow:\n      0 0 10px #83aefc,\n      0 0 20px #4178d4,\n      0 0 30px #1c348b;\n    margin-bottom: 0.1rem;\n  }\n  header p {\n    font-weight: 300;\n    font-size: 1.25rem;\n    color: #b8c7f9cc;\n    letter-spacing: 1px;\n  }\n\n  /* Canvas Container */\n  .canvas-wrapper {\n    flex-grow: 1;\n    position: relative;\n    border-radius: 24px;\n    box-shadow:\n      0 0 60px 10px rgba(69, 124, 255, 0.25);\n    background:\n      radial-gradient(circle at center, #15283d 60%, #0a1524 98%);\n    overflow: visible;\n  }\n\n  /* Control Bar */\n  .controls {\n    margin-top: 2rem;\n    text-align: center;\n  }\n  button {\n    background: linear-gradient(135deg, #3c70f3, #145cdf);\n    border: none;\n    border-radius: 30px;\n    padding: 0.75rem 2rem;\n    color: #f0f5ff;\n    font-weight: 600;\n    font-size: 1.1rem;\n    cursor: pointer;\n    box-shadow:\n      0 6px 15px rgba(60, 112, 243, 0.6);\n    transition:\n      background 0.4s ease,\n      transform 0.25s ease,\n      box-shadow 0.4s ease;\n  }\n  button:hover {\n    background: linear-gradient(135deg, #5488f7, #3370ee);\n    transform: scale(1.05);\n    box-shadow:\n      0 9px 25px rgba(60, 112, 243, 0.8);\n  }\n  button:active {\n    transform: scale(0.97);\n    box-shadow:\n      0 4px 10px rgba(60, 112, 243, 0.5);\n  }\n\n  /* Tooltip */\n  #tooltip {\n    position: absolute;\n    top: 10px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: rgba(29, 51, 102, 0.9);\n    padding: 0.75rem 1.4rem;\n    border-radius: 18px;\n    font-weight: 600;\n    color: #c3d0f8;\n    font-size: 1.15rem;\n    pointer-events: none;\n    text-shadow: 0 0 6px #1d3366;\n    user-select: none;\n    filter: drop-shadow(0 0 5px #1e3b85);\n  }\n\n  /* Footer credit */\n  footer {\n    margin-top: 2rem;\n    text-align: center;\n    color: #324060aa;\n    font-weight: 300;\n    font-size: 0.9rem;\n    user-select: none;\n  }\n\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <header>\n    <h1>Bellman-Ford Algorithm</h1>\n    <p>Shortest Path Detection in Graphs with Negative Weights</p>\n  </header>\n\n  <div class=\"canvas-wrapper\">\n    <canvas id=\"graphCanvas\"></canvas>\n    <div id=\"tooltip\"></div>\n  </div>\n\n  <div class=\"controls\" aria-label=\"Controls\">\n    <button id=\"stepBtn\" aria-live=\"polite\" aria-label=\"Step through algorithm\">Step ▶️</button>\n    <button id=\"resetBtn\" aria-label=\"Reset visualization\" style=\"margin-left:1rem; background: linear-gradient(135deg, #d9534f, #b73732); box-shadow: 0 6px 15px rgba(217,83,79,0.7);\">Reset ⟲</button>\n  </div>\n\n  <footer>\n    &copy; 2024 Bellman-Ford Visualization — Designed for elegance & clarity\n  </footer>\n</div>\n\n<script>\n(() => {\n  // Get canvas and context setup\n  const canvas = document.getElementById('graphCanvas');\n  const tooltip = document.getElementById('tooltip');\n  const stepBtn = document.getElementById('stepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  const dpr = window.devicePixelRatio || 1;\n  let width, height;\n\n  // Graph data for Bellman-Ford demonstration (small example)\n  // Nodes with IDs and positions\n  const nodes = [\n    {id: 0, label: 'A', x: 160, y: 140},\n    {id: 1, label: 'B', x: 520, y: 100},\n    {id: 2, label: 'C', x: 720, y: 220},\n    {id: 3, label: 'D', x: 420, y: 320},\n    {id: 4, label: 'E', x: 180, y: 300},\n  ];\n\n  /* Edges: from, to, weight */\n  // Includes a negative edge to show Bellman-Ford's capability\n  const edges = [\n    {from: 0, to: 1, weight: 6},\n    {from: 0, to: 4, weight: 7},\n    {from: 1, to: 2, weight: 5},\n    {from: 1, to: 3, weight: -4},\n    {from: 1, to: 4, weight: 8},\n    {from: 2, to: 1, weight: -2},\n    {from: 3, to: 2, weight: 7},\n    {from: 3, to: 0, weight: 2},\n    {from: 4, to: 3, weight: 9},\n  ];\n\n  /*\n  Distances array and predecessors initialized when starting algorithm.\n  Bellman-Ford performs |V| - 1 iterations of edge relaxation:\n  We will animate one edge relaxation at a time for clarity.\n  */\n\n  let ctx;\n  let dist = [];\n  let prev = [];\n  let currentStep = 0; // current edge relax step count\n  let relaxSteps = []; // all relaxation steps precomputed as sequence of {edgeIndex, relaxed: boolean, prevDist, newDist}\n\n  // Animation settings\n  const fps = 60;\n  const animationDuration = 700; // ms per step\n\n  // Graphical parameters\n  const nodeRadius = 28;\n  const fontNodeLabel = \"600 20px 'Poppins', sans-serif\";\n  const fontWeightDist = \"600 18px 'Poppins', sans-serif\";\n  const fontEdgeWeight = \"500 16px 'Poppins', sans-serif\";\n  const arrowSize = 12;\n  const colorNode = '#2c6be8';\n  const colorNodeActive = '#71a1f4';\n  const colorNodeRelaxed = '#98cffe';\n  const colorEdge = '#6389d0';\n  const colorEdgeRelaxed = '#a3c3ff';\n  const colorEdgeNegative = '#ff5656';\n  const colorDistText = '#e0e6f0';\n  const colorDistInfinity = '#546787cc';\n\n  // Variables for animation\n  let animationStartTime = null;\n  let animationActive = false;\n\n  // Current relaxation info for animation\n  let currentRelaxStepData = null;\n\n  // Initialize canvas size for HiDPI\n  function resizeCanvas() {\n    width = canvas.clientWidth;\n    height = canvas.clientHeight;\n    // fallback if clientWidth or clientHeight are zero\n    if (width === 0 || height === 0) {\n      width = window.innerWidth * 0.9;\n      height = window.innerHeight * 0.65;\n    }\n    canvas.width = width * dpr;\n    canvas.height = height * dpr;\n    canvas.style.width = width + 'px';\n    canvas.style.height = height + 'px';\n    ctx = canvas.getContext('2d');\n    ctx.setTransform(1, 0, 0, 1, 0, 0); // reset transforms\n    ctx.scale(dpr, dpr);\n  }\n\n  // Precompute relaxation steps for animation & state replay\n  function prepareRelaxSteps() {\n    dist = new Array(nodes.length).fill(Infinity);\n    prev = new Array(nodes.length).fill(null);\n    dist[0] = 0; // source = node 0 (A)\n\n    relaxSteps = [];\n\n    // Perform Bellman-Ford algorithm, record all edge relax attempts\n    for(let i=1; i < nodes.length; i++) {\n      for(let e=0; e < edges.length; e++) {\n        const edge = edges[e];\n        const from = edge.from, to = edge.to, weight = edge.weight;\n        let relaxed = false;\n        let prevDistance = dist[to];\n\n        if (dist[from] !== Infinity && dist[from] + weight < dist[to]) {\n          dist[to] = dist[from] + weight;\n          prev[to] = from;\n          relaxed = true;\n        }\n\n        relaxSteps.push({\n          edgeIndex: e,\n          relaxed: relaxed,\n          nodeDistPrev: prevDistance,\n          nodeDistNew: dist[to]\n        });\n      }\n    }\n  }\n\n  // Reset all to initial state\n  function reset() {\n    currentStep = 0;\n    dist = new Array(nodes.length).fill(Infinity);\n    dist[0] = 0;\n    prev = new Array(nodes.length).fill(null);\n    animationActive = false;\n    currentRelaxStepData = null;\n    stepBtn.textContent = \"Step ▶️\";\n    tooltip.textContent = \"Source node A set to 0. Press Step to start relaxation...\";\n    drawGraph();\n  }\n\n  // Draw arrow helper function\n  function drawArrow(ctx, fromX, fromY, toX, toY, color = '#6389d0') {\n    const headlen = arrowSize;\n    const dx = toX - fromX;\n    const dy = toY - fromY;\n    const angle = Math.atan2(dy, dx);\n\n    // shorten line so arrow head doesn't go inside node circle\n    const shortenFrom = nodeRadius;\n    const shortenTo = nodeRadius + arrowSize;\n\n    const startX = fromX + Math.cos(angle) * shortenFrom;\n    const startY = fromY + Math.sin(angle) * shortenFrom;\n    const endX = toX - Math.cos(angle) * shortenTo;\n    const endY = toY - Math.sin(angle) * shortenTo;\n\n    ctx.strokeStyle = color;\n    ctx.fillStyle = color;\n    ctx.lineWidth = 2.8;\n    ctx.lineCap = 'round';\n\n    ctx.beginPath();\n    ctx.moveTo(startX, startY);\n    ctx.lineTo(endX, endY);\n    ctx.stroke();\n\n    // Arrowhead\n    ctx.beginPath();\n    ctx.moveTo(endX, endY);\n    ctx.lineTo(endX - headlen * Math.cos(angle - Math.PI / 7), endY - headlen * Math.sin(angle - Math.PI / 7));\n    ctx.lineTo(endX - headlen * Math.cos(angle + Math.PI / 7), endY - headlen * Math.sin(angle + Math.PI / 7));\n    ctx.closePath();\n    ctx.fill();\n  }\n\n  // Draw nodes & edges & distances on canvas\n  function drawGraph(highlightEdgeIdx = null, highlightRelaxed = false, distProgress = null) {\n    ctx.clearRect(0, 0, width, height);\n\n    // Draw edges first under nodes\n    edges.forEach((edge, i) => {\n      const fromNode = nodes[edge.from];\n      const toNode = nodes[edge.to];\n\n      // Choose edge color - if edge is negative weight: warm red\n      const baseColor = edge.weight < 0 ? colorEdgeNegative : colorEdge;\n\n      // Highlight edge currently relaxed\n      let color = baseColor;\n      if (highlightEdgeIdx === i) {\n        color = highlightRelaxed ? colorEdgeRelaxed : '#ffff88';\n      }\n\n      // Draw curved edge for bidirectional edges overlapping, or straight otherwise\n      const reverseEdge = edges.findIndex(e => e.from === edge.to && e.to === edge.from) >= 0;\n\n      ctx.lineJoin = 'round';\n      ctx.lineCap = 'round';\n\n      ctx.strokeStyle = color;\n      ctx.fillStyle = color;\n      ctx.lineWidth = 2.8;\n\n      ctx.beginPath();\n\n      if (reverseEdge && edge.from < edge.to) {\n        // Draw a nice arc between nodes\n        const midX = (fromNode.x + toNode.x) / 2;\n        const midY = (fromNode.y + toNode.y) / 2;\n        const ctrlX = midX + (toNode.y - fromNode.y) * 0.3;\n        const ctrlY = midY - (toNode.x - fromNode.x) * 0.3;\n\n        ctx.moveTo(fromNode.x, fromNode.y);\n        ctx.quadraticCurveTo(ctrlX, ctrlY, toNode.x, toNode.y);\n\n        ctx.stroke();\n\n        // Draw arrowhead on quadratic curve\n        // Calculate point slightly before end\n        const t = 0.9;\n        // Quadratic Bezier formula\n        const cx = ctrlX, cy = ctrlY;\n        const x = (1-t)*(1-t)*fromNode.x + 2*(1-t)*t*cx + t*t*toNode.x;\n        const y = (1-t)*(1-t)*fromNode.y + 2*(1-t)*t*cy + t*t*toNode.y;\n        // Calculate tangent angle\n        const dx = 2*(1-t)*(cx - fromNode.x) + 2*t*(toNode.x - cx);\n        const dy = 2*(1-t)*(cy - fromNode.y) + 2*t*(toNode.y - cy);\n\n        const angle = Math.atan2(dy, dx);\n\n        // Draw arrowhead\n        ctx.beginPath();\n        const headlen = arrowSize;\n        ctx.fillStyle = color;\n        ctx.moveTo(x, y);\n        ctx.lineTo(x - headlen * Math.cos(angle - Math.PI / 7), y - headlen * Math.sin(angle - Math.PI / 7));\n        ctx.lineTo(x - headlen * Math.cos(angle + Math.PI / 7), y - headlen * Math.sin(angle + Math.PI / 7));\n        ctx.closePath();\n        ctx.fill();\n\n        // Edge weight label midpoint\n        const labelX = ctrlX;\n        const labelY = ctrlY - 12;\n\n        ctx.fillStyle = '#e0e6f0cc';\n        ctx.font = fontEdgeWeight;\n        ctx.textAlign = 'center';\n        ctx.textBaseline = 'middle';\n        ctx.fillText(edge.weight, labelX, labelY);\n      } else {\n        // Straight line edge\n        drawArrow(ctx, fromNode.x, fromNode.y, toNode.x, toNode.y, color);\n\n        // Midpoint for weight label with slight offset perpendicular to line\n        const dx = toNode.x - fromNode.x;\n        const dy = toNode.y - fromNode.y;\n        const mx = (fromNode.x + toNode.x) / 2;\n        const my = (fromNode.y + toNode.y) / 2;\n        const len = Math.sqrt(dx*dx + dy*dy);\n        const offsetX = -(dy / len) * 20;\n        const offsetY = (dx / len) * 20;\n\n        ctx.fillStyle = '#e0e6f0cc';\n        ctx.font = fontEdgeWeight;\n        ctx.textAlign = 'center';\n        ctx.textBaseline = 'middle';\n        ctx.fillText(edge.weight, mx + offsetX, my + offsetY);\n      }\n    });\n\n    // Draw nodes on top with shadow and highlight\n    nodes.forEach((node, i) => {\n      const isSource = i === 0;\n      // Highlight node if distance updated in current step\n      let highlight = false;\n\n      if(distProgress && distProgress.updatedNode === i) {\n        highlight = true;\n      }\n\n      // Node fill style\n      ctx.shadowColor = 'rgba(97,142,231,0.75)';\n      ctx.shadowBlur = highlight ? 20 : 8;\n\n      ctx.fillStyle = highlight ? colorNodeRelaxed : colorNode;\n      ctx.strokeStyle = '#0c2844';\n      ctx.lineWidth = 3;\n\n      ctx.beginPath();\n      ctx.ellipse(node.x, node.y, nodeRadius, nodeRadius, 0, 0, 2*Math.PI);\n      ctx.fill();\n      ctx.shadowBlur = 0;\n      ctx.stroke();\n\n      // Node label\n      ctx.fillStyle = '#cddbff';\n      ctx.font = fontNodeLabel;\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'middle';\n      ctx.fillText(node.label, node.x, node.y - 10);\n\n      // Distance display below node\n      ctx.font = fontWeightDist;\n      // Dist value text color - infinity = faded\n      if(distProgress && distProgress.dist[i] !== Infinity) {\n        ctx.fillStyle = colorDistText;\n        ctx.fillText(distProgress.dist[i], node.x, node.y + 22);\n      } else {\n        ctx.fillStyle = colorDistInfinity;\n        ctx.fillText('∞', node.x, node.y + 22);\n      }\n\n      // Source marker circle small\n      if(isSource) {\n        ctx.strokeStyle = '#73a9ff';\n        ctx.lineWidth = 2;\n        ctx.beginPath();\n        ctx.ellipse(node.x, node.y, nodeRadius + 6, nodeRadius + 4, 0, 0, 2*Math.PI);\n        ctx.stroke();\n      }\n    });\n  }\n\n  // Animate one step (edge relaxation)\n  function animateStep(relaxStepIdx) {\n    if(relaxStepIdx >= relaxSteps.length) {\n      tooltip.textContent = `Algorithm complete! No more edge relaxations.`;\n      animationActive = false;\n      stepBtn.textContent = \"✔️ Done\";\n      return;\n    }\n\n    animationActive = true;\n    currentRelaxStepData = relaxSteps[relaxStepIdx];\n    animationStartTime = performance.now();\n\n    // Prepare dist and prev snapshot for showing before this edge relaxation\n    // We replay dist and prev up to (relaxStepIdx-1)\n    const baseDist = new Array(nodes.length).fill(Infinity);\n    baseDist[0] = 0;\n    const basePrev = new Array(nodes.length).fill(null);\n\n    for(let i = 0; i < relaxStepIdx; i++) {\n      const step = relaxSteps[i];\n      if(step.relaxed) {\n        const edge = edges[step.edgeIndex];\n        baseDist[edge.to] = step.nodeDistNew;\n        basePrev[edge.to] = edge.from;\n      }\n    }\n\n    // We animate the current relaxation: from baseDist to new distance if relaxed\n    let animFrame;\n\n    function stepAnimation(time) {\n      let progress = (time - animationStartTime) / animationDuration;\n      if(progress > 1) progress = 1;\n\n      // Interpolate distance for the involved node if relaxed, else stay at baseDist\n      const edge = edges[currentRelaxStepData.edgeIndex];\n\n      // Clone dist for display\n      const animDist = [...baseDist];\n      if(currentRelaxStepData.relaxed) {\n        let fromVal = currentRelaxStepData.nodeDistPrev;\n        let toVal = currentRelaxStepData.nodeDistNew;\n\n        // Interpolate\n        let currentVal = fromVal + (toVal - fromVal) * progress;\n        // For visual clarity, round decimals nicely\n        currentVal = Math.round(currentVal * 100) / 100;\n\n        animDist[edge.to] = currentVal;\n      }\n\n      drawGraph(\n        currentRelaxStepData.edgeIndex,\n        currentRelaxStepData.relaxed,\n        {dist: animDist, updatedNode: currentRelaxStepData.relaxed ? edge.to : null}\n      );\n\n      // Tooltip text update with smooth fade in/out effect\n      if(progress < 1) {\n        tooltip.style.opacity = 1;\n        let baseMsg = `Relaxing edge <strong>${nodes[edge.from].label} → ${nodes[edge.to].label}</strong> with weight <strong>${edge.weight}</strong>`;\n        let distMsg = currentRelaxStepData.relaxed\n          ? `<br>Distance to <strong>${nodes[edge.to].label}</strong> updated: ${currentRelaxStepData.nodeDistPrev === Infinity ? '∞' : currentRelaxStepData.nodeDistPrev} → ${Math.round(currentRelaxStepData.nodeDistNew*100)/100}`\n          : `<br>No update: current distance ${currentRelaxStepData.nodeDistPrev === Infinity ? '∞' : currentRelaxStepData.nodeDistPrev}`;\n        tooltip.innerHTML = baseMsg + distMsg;\n      } else {\n        // End of animation (progress=1)\n        tooltip.style.opacity = 1;\n        if(currentRelaxStepData.relaxed) {\n          tooltip.innerHTML = `✔️ Edge <strong>${nodes[edge.from].label} → ${nodes[edge.to].label}</strong> relaxed. Distance updated to <strong>${currentRelaxStepData.nodeDistNew}</strong>.`;\n        } else {\n          tooltip.innerHTML = `✖️ Edge <strong>${nodes[edge.from].label} → ${nodes[edge.to].label}</strong> not relaxed.`;\n        }\n      }\n\n      if(progress < 1) {\n        animFrame = requestAnimationFrame(stepAnimation);\n      } else {\n        animationActive = false;\n        animFrame = null;\n        currentStep++;\n        stepBtn.textContent = currentStep < relaxSteps.length ? \"Step ▶️\" : \"✔️ Done\";\n      }\n    }\n\n    animFrame = requestAnimationFrame(stepAnimation);\n  }\n\n\n  // Event listeners\n  stepBtn.addEventListener('click', () => {\n    if(animationActive) return;\n    if(currentStep >= relaxSteps.length) {\n      // Finished - no op\n      tooltip.textContent = \"Algorithm has completed all relaxation steps.\";\n      return;\n    }\n    animateStep(currentStep);\n  });\n\n  resetBtn.addEventListener('click', () => {\n    if(animationActive) return;\n    prepareRelaxSteps();\n    reset();\n  });\n\n  // Initialize sizes and prepare algorithm on load\n  function init() {\n    resizeCanvas();\n    prepareRelaxSteps();\n    reset();\n  }\n\n  window.addEventListener('resize', () => {\n    if(animationActive) return;\n    resizeCanvas();\n    drawGraph();\n  });\n\n  // Initial call\n  init();\n\n})();\n</script>\n\n</body>\n</html>"
  },
