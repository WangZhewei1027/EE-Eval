  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Digital Signatures - Interactive Playground</title>\n<style>\n/* Minimal styling only to keep readable spacing. No colors, no animations. */\nbody { font-family: monospace; margin: 12px; }\nlabel { display:block; margin-top:8px; }\nsection { margin-bottom: 18px; padding:6px; border:1px solid #000; }\ntextarea { width:100%; height:80px; }\ninput[type=\"text\"], input[type=\"number\"], select { width:100%; }\nbutton { margin:4px 2px 4px 0; }\n.small { font-size:12px; }\npre { white-space: pre-wrap; word-break: break-word; }\n</style>\n</head>\n<body>\n<h1>Digital Signatures - Interactive Playground</h1>\n\n<section id=\"state\">\n<strong>State:</strong>\n<div id=\"stateText\">Idle</div>\n</section>\n\n<section>\n<strong>Message / Data</strong>\n<label for=\"message\">Text message to sign or hash:</label>\n<textarea id=\"message\">Hello, world!</textarea>\n\n<label for=\"randomLen\">Generate random message length (bytes): <span id=\"randomLenVal\">32</span></label>\n<input id=\"randomLen\" type=\"range\" min=\"1\" max=\"1024\" value=\"32\">\n<button id=\"genRandom\">Generate random bytes (base64)</button>\n<button id=\"clearMessage\">Clear</button>\n<label for=\"fileInput\">Or select a file to load as message:</label>\n<input id=\"fileInput\" type=\"file\">\n</section>\n\n<section>\n<strong>Algorithm & Key Controls</strong>\n\n<label for=\"algoSelect\">Signature Algorithm:</label>\n<select id=\"algoSelect\">\n  <option value=\"RSASSA-PKCS1-v1_5\">RSASSA-PKCS1-v1_5 (RSA)</option>\n  <option value=\"RSA-PSS\">RSA-PSS (RSA)</option>\n  <option value=\"ECDSA\">ECDSA (Elliptic Curve)</option>\n  <option value=\"HMAC\">HMAC (Message Authentication - deterministic)</option>\n</select>\n\n<label for=\"hashSelect\">Hash algorithm:</label>\n<select id=\"hashSelect\">\n  <option>SHA-1</option>\n  <option selected>SHA-256</option>\n  <option>SHA-384</option>\n  <option>SHA-512</option>\n</select>\n\n<label for=\"rsaSize\">RSA modulus length (bits): <span id=\"rsaSizeVal\">2048</span></label>\n<input id=\"rsaSize\" type=\"range\" min=\"1024\" max=\"4096\" step=\"256\" value=\"2048\">\n\n<label for=\"ecCurve\">EC Curve:</label>\n<select id=\"ecCurve\">\n  <option value=\"P-256\">P-256</option>\n  <option value=\"P-384\">P-384</option>\n  <option value=\"P-521\">P-521</option>\n</select>\n\n<label for=\"saltLen\">RSA-PSS saltLength (bytes): <span id=\"saltLenVal\">32</span></label>\n<input id=\"saltLen\" type=\"range\" min=\"0\" max=\"512\" step=\"1\" value=\"32\">\n\n<label for=\"hmacKeyLen\">HMAC key length (bits): <span id=\"hmacKeyLenVal\">256</span></label>\n<input id=\"hmacKeyLen\" type=\"range\" min=\"128\" max=\"512\" step=\"8\" value=\"256\">\n\n<div>\n<button id=\"generateKey\">Generate Key</button>\n<button id=\"importPemBtn\">Import PEM (paste)</button>\n<button id=\"exportPemPub\">Export Public PEM</button>\n<button id=\"exportPemPriv\">Export Private PEM (if allowed)</button>\n<button id=\"exportJwkPub\">Export Public JWK</button>\n<button id=\"exportJwkPriv\">Export Private JWK</button>\n</div>\n<div>\n<label for=\"pemArea\">PEM / JWK Input or Output:</label>\n<textarea id=\"pemArea\" placeholder=\"Paste PEM or JWK here for import or view exported keys...\"></textarea>\n</div>\n</section>\n\n<section>\n<strong>Sign / Verify / Hash</strong>\n<div>\n<button id=\"signBtn\">Sign Message</button>\n<button id=\"verifyBtn\">Verify Signature</button>\n<button id=\"hashBtn\">Compute Hash</button>\n<button id=\"hmacBtn\">Compute HMAC (if key available)</button>\n</div>\n\n<label for=\"sigEncoding\">Signature encoding display:</label>\n<select id=\"sigEncoding\">\n  <option value=\"base64\">Base64</option>\n  <option value=\"hex\">Hex</option>\n  <option value=\"b64url\">Base64URL</option>\n</select>\n\n<label for=\"sigArea\">Signature output (click to copy):</label>\n<textarea id=\"sigArea\" readonly></textarea>\n\n<label for=\"verifySigInput\">Signature input for verification (paste or use above):</label>\n<textarea id=\"verifySigInput\"></textarea>\n\n<label for=\"verifyOutput\">Verification result:</label>\n<div id=\"verifyOutput\">Not verified yet</div>\n\n<label for=\"tamperBtn\">Tamper controls (to explore verification failure):</label>\n<button id=\"flipByte\">Flip a byte in message</button>\n<button id=\"appendText\">Append text to message</button>\n<button id=\"replaceMessage\">Replace message with random</button>\n</section>\n\n<section>\n<strong>Low-level / Formats</strong>\n<label for=\"rawHashOutput\">Raw hash / signature / key bytes (hex):</label>\n<pre id=\"rawHex\">-</pre>\n\n<label>Conversions and utilities:</label>\n<div>\n<input id=\"textToHexIn\" type=\"text\" placeholder=\"Text to encode (UTF-8)\">\n<button id=\"textToHexBtn\">Text → Hex</button>\n<button id=\"hexToTextBtn\">Hex → Text</button>\n</div>\n\n<label>Session / History</label>\n<div>\n<button id=\"recordBtn\">Record Action</button>\n<button id=\"replayBtn\">Replay History</button>\n<button id=\"clearHistory\">Clear History</button>\n<button id=\"saveSession\">Save Session (download JSON)</button>\n<input id=\"loadSessionFile\" type=\"file\">\n</div>\n<pre id=\"historyArea\">[]</pre>\n</section>\n\n<section>\n<strong>Advanced: Import/Export & Compatibility</strong>\n<label>Import JWK / PEM / Raw key data (paste into PEM area then click Import):</label>\n<button id=\"importJwkBtn\">Import JWK</button>\n<button id=\"importSpkiBtn\">Import SPKI (public PEM -> key)</button>\n<button id=\"importPkcs8Btn\">Import PKCS8 (private PEM -> key)</button>\n\n<label>Verify with imported other public key:</label>\n<button id=\"importOtherFromPem\">Import OTHER public PEM from pemArea</button>\n<div>\n<button id=\"useOtherForVerify\">Use imported other key to verify current signature</button>\n</div>\n\n</section>\n\n<section>\n<strong>Notes / Tips</strong>\n<ul>\n<li>Use Generate Key, then Sign Message, then Verify Signature.</li>\n<li>Try RSA-PSS with varying salt lengths. Try ECDSA on different curves.</li>\n<li>Use HMAC to see deterministic MAC vs asymmetric non-deterministic signatures.</li>\n<li>You can export keys as PEM or JWK, re-import them, and test verification across keys.</li>\n<li>Record and replay sequences to explore state transitions.</li>\n</ul>\n</section>\n\n<script>\n/*\n  Digital Signatures Playground\n  - Uses WebCrypto API for RSA, ECDSA, HMAC\n  - Provides many interactive controls and complex workflows\n  - Minimal visual styling, feature-rich interactivity\n*/\n\nconst stateText = document.getElementById('stateText');\nfunction setState(s){ stateText.textContent = s; }\n\n// Helper: Encoding conversions\nfunction bufToHex(buf){\n  const bytes = new Uint8Array(buf);\n  return Array.from(bytes).map(b => b.toString(16).padStart(2,'0')).join('');\n}\nfunction bufToBase64(buf){\n  const bytes = new Uint8Array(buf);\n  let binary = '';\n  for (let i=0;i<bytes.byteLength;i++) binary += String.fromCharCode(bytes[i]);\n  return btoa(binary);\n}\nfunction bufToBase64Url(buf){\n  return bufToBase64(buf).replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=+$/,'');\n}\nfunction base64ToBuf(b64){\n  const binary = atob(b64);\n  const len = binary.length;\n  const bytes = new Uint8Array(len);\n  for (let i=0;i<len;i++) bytes[i] = binary.charCodeAt(i);\n  return bytes.buffer;\n}\nfunction hexToBuf(hex){\n  if(!hex) return new ArrayBuffer(0);\n  hex = hex.replace(/[^0-9a-fA-F]/g,'');\n  const len = hex.length/2;\n  const bytes = new Uint8Array(len);\n  for (let i=0;i<len;i++){\n    bytes[i] = parseInt(hex.substr(i*2,2),16);\n  }\n  return bytes.buffer;\n}\nfunction stringToBuf(str){\n  return new TextEncoder().encode(str).buffer;\n}\nfunction bufToString(buf){\n  return new TextDecoder().decode(new Uint8Array(buf));\n}\n\n// UI elements\nconst messageEl = document.getElementById('message');\nconst genRandomBtn = document.getElementById('genRandom');\nconst randomLen = document.getElementById('randomLen');\nconst randomLenVal = document.getElementById('randomLenVal');\nconst rsaSize = document.getElementById('rsaSize');\nconst rsaSizeVal = document.getElementById('rsaSizeVal');\nconst saltLen = document.getElementById('saltLen');\nconst saltLenVal = document.getElementById('saltLenVal');\nconst hmacKeyLen = document.getElementById('hmacKeyLen');\nconst hmacKeyLenVal = document.getElementById('hmacKeyLenVal');\nconst algoSelect = document.getElementById('algoSelect');\nconst hashSelect = document.getElementById('hashSelect');\nconst ecCurve = document.getElementById('ecCurve');\nconst generateKeyBtn = document.getElementById('generateKey');\nconst signBtn = document.getElementById('signBtn');\nconst verifyBtn = document.getElementById('verifyBtn');\nconst hashBtn = document.getElementById('hashBtn');\nconst hmacBtn = document.getElementById('hmacBtn');\nconst sigArea = document.getElementById('sigArea');\nconst sigEncoding = document.getElementById('sigEncoding');\nconst verifySigInput = document.getElementById('verifySigInput');\nconst verifyOutput = document.getElementById('verifyOutput');\nconst rawHex = document.getElementById('rawHex');\nconst pemArea = document.getElementById('pemArea');\nconst exportPemPub = document.getElementById('exportPemPub');\nconst exportPemPriv = document.getElementById('exportPemPriv');\nconst exportJwkPub = document.getElementById('exportJwkPub');\nconst exportJwkPriv = document.getElementById('exportJwkPriv');\nconst importPemBtn = document.getElementById('importPemBtn');\nconst importJwkBtn = document.getElementById('importJwkBtn');\nconst importSpkiBtn = document.getElementById('importSpkiBtn');\nconst importPkcs8Btn = document.getElementById('importPkcs8Btn');\nconst importOtherFromPem = document.getElementById('importOtherFromPem');\nconst useOtherForVerify = document.getElementById('useOtherForVerify');\nconst flipByteBtn = document.getElementById('flipByte');\nconst appendTextBtn = document.getElementById('appendText');\nconst replaceMessageBtn = document.getElementById('replaceMessage');\nconst fileInput = document.getElementById('fileInput');\nconst recordBtn = document.getElementById('recordBtn');\nconst replayBtn = document.getElementById('replayBtn');\nconst clearHistoryBtn = document.getElementById('clearHistory');\nconst saveSession = document.getElementById('saveSession');\nconst loadSessionFile = document.getElementById('loadSessionFile');\nconst historyArea = document.getElementById('historyArea');\nconst textToHexIn = document.getElementById('textToHexIn');\nconst textToHexBtn = document.getElementById('textToHexBtn');\nconst hexToTextBtn = document.getElementById('hexToTextBtn');\nconst pemImportBtn = document.getElementById('importPemBtn');\nconst rsaSizeSlider = rsaSize;\nconst saltLenSlider = saltLen;\nconst hmacKeyLenSlider = hmacKeyLen;\nconst verifyBtnEl = verifyBtn;\nconst importOtherBtn = importOtherFromPem;\n\nrandomLen.addEventListener('input', ()=> randomLenVal.textContent = randomLen.value);\nrsaSize.addEventListener('input', ()=> rsaSizeVal.textContent = rsaSize.value);\nsaltLen.addEventListener('input', ()=> saltLenVal.textContent = saltLen.value);\nhmacKeyLen.addEventListener('input', ()=> hmacKeyLenVal.textContent = hmacKeyLen.value);\n\n// State: current keys and last signature, history\nlet currentKeyPair = { publicKey: null, privateKey: null, jwkPub: null, jwkPriv: null, algo: null };\nlet otherImportedPublicKey = null;\nlet lastSignature = null; // ArrayBuffer\nlet lastMessageBytes = null; // ArrayBuffer\nlet history = [];\n\n// Utilities: PEM <-> ArrayBuffer for SPKI/PKCS8\nfunction arrayBufferToPem(buffer, label){\n  const base64 = bufToBase64(buffer);\n  let lines = base64.match(/.{1,64}/g) || [];\n  return `-----BEGIN ${label}-----\\n${lines.join('\\n')}\\n-----END ${label}-----`;\n}\nfunction pemToArrayBuffer(pem){\n  // Strip header/footer and line breaks\n  const b64 = pem.replace(/-----.*-----/g,'').replace(/\\s+/g,'');\n  return base64ToBuf(b64);\n}\n\n// Export CryptoKey to PEM or JWK\nasync function exportPublicKeyToPem(key){\n  const spki = await crypto.subtle.exportKey('spki', key);\n  return arrayBufferToPem(spki, 'PUBLIC KEY');\n}\nasync function exportPrivateKeyToPem(key){\n  const pkcs8 = await crypto.subtle.exportKey('pkcs8', key);\n  return arrayBufferToPem(pkcs8, 'PRIVATE KEY');\n}\nasync function exportKeyToJwk(key){\n  return await crypto.subtle.exportKey('jwk', key);\n}\n\n// Import public/private keys from PEM (spki/pkcs8) or JWK\nasync function importPublicKeyFromSpki(pem, algorithm){\n  const ab = pemToArrayBuffer(pem);\n  return await crypto.subtle.importKey('spki', ab, algorithm, true, ['verify']);\n}\nasync function importPrivateKeyFromPkcs8(pem, algorithm, usages=['sign']){\n  const ab = pemToArrayBuffer(pem);\n  return await crypto.subtle.importKey('pkcs8', ab, algorithm, true, usages);\n}\nasync function importJwkKey(jwk, algorithm, usages){\n  return await crypto.subtle.importKey('jwk', jwk, algorithm, true, usages);\n}\n\n// Helper to show raw hex area, and set lastMessageBytes for signing clarity\nfunction showRawHex(...buffers){\n  const joined = buffers.map(b => bufToHex(b || new ArrayBuffer(0))).join('\\n\\n---\\n\\n');\n  rawHex.textContent = joined || '-';\n}\n\n// Generate Key\ngenerateKeyBtn.addEventListener('click', async () => {\n  setState('Generating key...');\n  const algo = algoSelect.value;\n  try{\n    if(algo === 'RSASSA-PKCS1-v1_5' || algo === 'RSA-PSS'){\n      const modulusLength = parseInt(rsaSize.value);\n      const hash = { name: hashSelect.value };\n      const generateAlg = { name: algo, modulusLength, publicExponent: new Uint8Array([0x01,0x00,0x01]), hash };\n      const keyPair = await crypto.subtle.generateKey(generateAlg, true, ['sign','verify']);\n      currentKeyPair.publicKey = keyPair.publicKey;\n      currentKeyPair.privateKey = keyPair.privateKey;\n      currentKeyPair.algo = generateAlg;\n      currentKeyPair.jwkPub = await exportKeyToJwk(keyPair.publicKey);\n      currentKeyPair.jwkPriv = await exportKeyToJwk(keyPair.privateKey);\n      setState(`Generated RSA key (${modulusLength} bits) for ${algo}`);\n      addHistory({action:'generateKey', algo:algo, modulusLength});\n    } else if(algo === 'ECDSA'){\n      const namedCurve = ecCurve.value;\n      const generateAlg = { name: 'ECDSA', namedCurve };\n      const keyPair = await crypto.subtle.generateKey(generateAlg, true, ['sign','verify']);\n      currentKeyPair.publicKey = keyPair.publicKey;\n      currentKeyPair.privateKey = keyPair.privateKey;\n      currentKeyPair.algo = generateAlg;\n      currentKeyPair.jwkPub = await exportKeyToJwk(keyPair.publicKey);\n      currentKeyPair.jwkPriv = await exportKeyToJwk(keyPair.privateKey);\n      setState(`Generated EC key on ${namedCurve}`);\n      addHistory({action:'generateKey', algo:'ECDSA', namedCurve});\n    } else if(algo === 'HMAC'){\n      const length = parseInt(hmacKeyLen.value);\n      const generateAlg = { name: 'HMAC', hash: { name: hashSelect.value } };\n      const key = await crypto.subtle.generateKey({ name:'HMAC', hash: hashSelect.value, length: length }, true, ['sign','verify']);\n      currentKeyPair.publicKey = null;\n      currentKeyPair.privateKey = key;\n      currentKeyPair.algo = { name:'HMAC', length, hash: { name: hashSelect.value } };\n      try { currentKeyPair.jwkPriv = await exportKeyToJwk(key); } catch(e){}\n      setState(`Generated HMAC key, ${length} bits`);\n      addHistory({action:'generateKey', algo:'HMAC', length});\n    } else {\n      setState('Unknown algorithm for generation');\n    }\n  }catch(e){\n    setState('Key generation failed: ' + e.message);\n  }\n});\n\n// File input loads message\nfileInput.addEventListener('change', async (ev) => {\n  const f = ev.target.files[0];\n  if(!f) return;\n  const ab = await f.arrayBuffer();\n  messageEl.value = bufToBase64(ab); // indicate base64\n  setState(`Loaded file ${f.name} as base64`);\n  lastMessageBytes = ab;\n  showRawHex(ab);\n  addHistory({action:'loadFile', name:f.name, size:ab.byteLength});\n});\n\n// Generate random bytes and put as base64 in message\ngenRandomBtn.addEventListener('click', ()=> {\n  const len = parseInt(randomLen.value);\n  const arr = new Uint8Array(len);\n  crypto.getRandomValues(arr);\n  messageEl.value = bufToBase64(arr.buffer);\n  lastMessageBytes = arr.buffer;\n  setState(`Generated ${len} random bytes`);\n  showRawHex(arr.buffer);\n  addHistory({action:'genRandom', len});\n});\n\n// Sign message\nsignBtn.addEventListener('click', async ()=>{\n  setState('Signing...');\n  try{\n    const algo = algoSelect.value;\n    const encoding = sigEncoding.value;\n    let dataBuf = await normalizeMessageToArrayBuffer();\n    lastMessageBytes = dataBuf;\n    let signature;\n    if(algo === 'HMAC'){\n      if(!currentKeyPair.privateKey) throw new Error('No HMAC key available. Generate one.');\n      signature = await crypto.subtle.sign({name:'HMAC'}, currentKeyPair.privateKey, dataBuf);\n    } else if(algo === 'RSASSA-PKCS1-v1_5'){\n      if(!currentKeyPair.privateKey) throw new Error('No RSA private key available. Generate or import one.');\n      signature = await crypto.subtle.sign({name:'RSASSA-PKCS1-v1_5'}, currentKeyPair.privateKey, dataBuf);\n    } else if(algo === 'RSA-PSS'){\n      if(!currentKeyPair.privateKey) throw new Error('No RSA private key available. Generate or import one.');\n      const saltLenVal = parseInt(saltLen.value);\n      signature = await crypto.subtle.sign({name:'RSA-PSS', saltLength: saltLenVal}, currentKeyPair.privateKey, dataBuf);\n    } else if(algo === 'ECDSA'){\n      if(!currentKeyPair.privateKey) throw new Error('No EC private key available. Generate or import one.');\n      const hashName = hashSelect.value;\n      signature = await crypto.subtle.sign({name:'ECDSA', hash: {name: hashName}}, currentKeyPair.privateKey, dataBuf);\n    } else {\n      throw new Error('Unsupported algorithm');\n    }\n    lastSignature = signature;\n    displaySignature(signature, encoding);\n    showRawHex(signature, dataBuf);\n    setState('Signed successfully');\n    addHistory({action:'sign', algo, encoding});\n  }catch(e){\n    setState('Sign error: ' + e.message);\n  }\n});\n\n// Verify\nverifyBtn.addEventListener('click', async ()=>{\n  setState('Verifying...');\n  try{\n    const algo = algoSelect.value;\n    const sigInput = verifySigInput.value.trim() || sigArea.value.trim();\n    if(!sigInput) { setState('No signature provided'); return; }\n    const sigBuf = parseSigInput(sigInput);\n    let dataBuf = await normalizeMessageToArrayBuffer();\n    lastMessageBytes = dataBuf;\n    let ok = false;\n    if(algo === 'HMAC'){\n      if(!currentKeyPair.privateKey) throw new Error('No HMAC key to verify with.');\n      ok = await crypto.subtle.verify('HMAC', currentKeyPair.privateKey, sigBuf, dataBuf);\n    } else {\n      let keyToUse = otherImportedPublicKey || currentKeyPair.publicKey;\n      if(!keyToUse) throw new Error('No public key available to verify. Import or generate.');\n      if(algo === 'RSASSA-PKCS1-v1_5'){\n        ok = await crypto.subtle.verify({name:'RSASSA-PKCS1-v1_5'}, keyToUse, sigBuf, dataBuf);\n      } else if(algo === 'RSA-PSS'){\n        const sl = parseInt(saltLen.value);\n        ok = await crypto.subtle.verify({name:'RSA-PSS', saltLength: sl}, keyToUse, sigBuf, dataBuf);\n      } else if(algo === 'ECDSA'){\n        const hashName = hashSelect.value;\n        // Some browsers return DER-encoded ECDSA signatures, WebCrypto expects signature format produced by sign.\n        // We attempt to verify directly; if it fails but signature looks like DER, we try converting from DER to raw by extracting r and s.\n        try{\n          ok = await crypto.subtle.verify({name:'ECDSA', hash:{name:hashName}}, keyToUse, sigBuf, dataBuf);\n        }catch(e){\n          // Try DER -> raw conversion then verify\n          try {\n            const raw = derSigToPlain(sigBuf, keyToUse);\n            ok = await crypto.subtle.verify({name:'ECDSA', hash:{name:hashName}}, keyToUse, raw, dataBuf);\n          }catch(e2){\n            throw e;\n          }\n        }\n      } else {\n        throw new Error('Unsupported algorithm for verify');\n      }\n    }\n    verifyOutput.textContent = ok ? 'VALID signature' : 'INVALID signature';\n    setState('Verification done: ' + (ok ? 'VALID' : 'INVALID'));\n    addHistory({action:'verify', result:ok});\n  }catch(e){\n    setState('Verify error: ' + e.message);\n  }\n});\n\n// Compute hash\nhashBtn.addEventListener('click', async ()=>{\n  setState('Hashing...');\n  try{\n    const hashName = hashSelect.value;\n    const dataBuf = await normalizeMessageToArrayBuffer();\n    const digest = await crypto.subtle.digest({name: hashName}, dataBuf);\n    rawHex.textContent = bufToHex(digest);\n    sigArea.value = bufToBase64(digest);\n    setState('Hash computed: ' + hashName);\n    addHistory({action:'hash', hash:hashName});\n  }catch(e){\n    setState('Hash error: ' + e.message);\n  }\n});\n\n// HMAC compute\nhmacBtn.addEventListener('click', async ()=>{\n  setState('HMAC compute...');\n  try{\n    if(!currentKeyPair.privateKey) throw new Error('No HMAC key generated/imported');\n    const dataBuf = await normalizeMessageToArrayBuffer();\n    const mac = await crypto.subtle.sign('HMAC', currentKeyPair.privateKey, dataBuf);\n    lastSignature = mac;\n    sigArea.value = bufToBase64(mac);\n    rawHex.textContent = bufToHex(mac);\n    setState('HMAC computed');\n    addHistory({action:'hmac'});\n  }catch(e){\n    setState('HMAC error: ' + e.message);\n  }\n});\n\n// Export keys\nexportPemPub.addEventListener('click', async ()=>{\n  try{\n    if(!currentKeyPair.publicKey) throw new Error('No public key available');\n    const pem = await exportPublicKeyToPem(currentKeyPair.publicKey);\n    pemArea.value = pem;\n    setState('Exported public key as PEM');\n  }catch(e){\n    setState('Export public error: ' + e.message);\n  }\n});\nexportPemPriv.addEventListener('click', async ()=>{\n  try{\n    if(!currentKeyPair.privateKey) throw new Error('No private key available');\n    const pem = await exportPrivateKeyToPem(currentKeyPair.privateKey);\n    pemArea.value = pem;\n    setState('Exported private key as PEM');\n  }catch(e){\n    setState('Export private error: ' + e.message);\n  }\n});\nexportJwkPub.addEventListener('click', async ()=>{\n  try{\n    if(!currentKeyPair.publicKey) throw new Error('No public key');\n    const jwk = await exportKeyToJwk(currentKeyPair.publicKey);\n    pemArea.value = JSON.stringify(jwk, null, 2);\n    setState('Exported public JWK');\n  }catch(e){ setState('Export JWK pub err: '+e.message); }\n});\nexportJwkPriv.addEventListener('click', async ()=>{\n  try{\n    if(!currentKeyPair.privateKey) throw new Error('No private key');\n    const jwk = await exportKeyToJwk(currentKeyPair.privateKey);\n    pemArea.value = JSON.stringify(jwk, null, 2);\n    setState('Exported private JWK');\n  }catch(e){ setState('Export JWK priv err: '+e.message); }\n});\n\n// Import PEM (basic) - attempts to detect spki or pkcs8 or jwk\nimportPemBtn.addEventListener('click', async ()=>{\n  const text = pemArea.value.trim();\n  if(!text) { setState('PEM area empty'); return; }\n  setState('Attempting import...');\n  try{\n    if(text.startsWith('{')) {\n      // JWK\n      const jwk = JSON.parse(text);\n      if(jwk.kty === 'RSA' || jwk.kty === 'EC' || jwk.kty === 'OKP' || jwk.kty === 'oct'){\n        // Decide usages\n        let usages = [];\n        if(jwk.d) usages.push('sign'); // private\n        else usages.push('verify');\n        // Determine algorithm for import - user responsibility but try to deduce:\n        const alg = algoSelect.value === 'HMAC' ? {name:'HMAC', hash: hashSelect.value} : (algoSelect.value === 'ECDSA' ? {name:'ECDSA', namedCurve: ecCurve.value} : {name:algoSelect.value, hash: hashSelect.value});\n        const key = await importJwkKey(jwk, alg, usages);\n        if(jwk.d) { currentKeyPair.privateKey = key; currentKeyPair.jwkPriv = jwk; setState('Imported private JWK'); }\n        else { currentKeyPair.publicKey = key; currentKeyPair.jwkPub = jwk; setState('Imported public JWK'); }\n      } else throw new Error('Unsupported JWK type');\n      addHistory({action:'import', type:'jwk'});\n    } else if(text.includes('BEGIN PUBLIC KEY')){\n      // SPKI\n      const key = await importPublicKeyFromSpki(text, pickImportAlgorithmForCurrentSelection());\n      otherImportedPublicKey = key;\n      setState('Imported PUBLIC KEY (SPKI). Stored as \"other\" key for verify.');\n      addHistory({action:'importSpki'});\n    } else if(text.includes('BEGIN PRIVATE KEY') || text.includes('BEGIN RSA PRIVATE KEY')){\n      const key = await importPrivateKeyFromPkcs8(text, pickImportAlgorithmForCurrentSelection());\n      currentKeyPair.privateKey = key;\n      setState('Imported PRIVATE KEY (PKCS8).');\n      addHistory({action:'importPkcs8'});\n    } else {\n      throw new Error('Unknown format');\n    }\n  }catch(e){\n    setState('Import failed: ' + e.message);\n  }\n});\n\n// Import JWK button (explicit)\nimportJwkBtn.addEventListener('click', async ()=>{\n  try{\n    const jwk = JSON.parse(pemArea.value);\n    const alg = pickImportAlgorithmForCurrentSelection();\n    const usages = jwk.d ? ['sign'] : ['verify'];\n    const key = await importJwkKey(jwk, alg, usages);\n    if(jwk.d) { currentKeyPair.privateKey = key; currentKeyPair.jwkPriv = jwk; setState('Imported private JWK'); }\n    else { currentKeyPair.publicKey = key; currentKeyPair.jwkPub = jwk; setState('Imported public JWK'); }\n    addHistory({action:'importJwk'});\n  }catch(e){ setState('Import JWK failed: ' + e.message); }\n});\n\n// Import SPKI explicit\nimportSpkiBtn.addEventListener('click', async ()=>{\n  try{\n    const pem = pemArea.value.trim();\n    const key = await importPublicKeyFromSpki(pem, pickImportAlgorithmForCurrentSelection());\n    currentKeyPair.publicKey = key;\n    setState('Imported public SPKI into current key pair');\n    addHistory({action:'importSpkiIntoCurrent'});\n  }catch(e){ setState('Import SPKI failed: ' + e.message); }\n});\n\n// Import PKCS8 explicit\nimportPkcs8Btn.addEventListener('click', async ()=>{\n  try{\n    const pem = pemArea.value.trim();\n    const key = await importPrivateKeyFromPkcs8(pem, pickImportAlgorithmForCurrentSelection());\n    currentKeyPair.privateKey = key;\n    setState('Imported private PKCS8 into current key pair');\n    addHistory({action:'importPkcs8IntoCurrent'});\n  }catch(e){ setState('Import PKCS8 failed: ' + e.message); }\n});\n\n// Import other public key from PEM area explicitly\nimportOtherFromPem.addEventListener('click', async ()=>{\n  try{\n    const pem = pemArea.value.trim();\n    const key = await importPublicKeyFromSpki(pem, pickImportAlgorithmForCurrentSelection());\n    otherImportedPublicKey = key;\n    setState('Imported OTHER public key stored for verification');\n    addHistory({action:'importOther', note:'stored other public key'});\n  }catch(e){ setState('Import other public failed: '+e.message); }\n});\n\n// Use other imported public key to verify current signature (if any)\nuseOtherForVerify.addEventListener('click', async ()=>{\n  if(!otherImportedPublicKey) { setState('No other public key imported'); return; }\n  if(!lastSignature) { setState('No signature available in this session'); return; }\n  // Put signature into verify input and run verify\n  verifySigInput.value = bufToBase64(lastSignature);\n  setState('Using other key to verify last signature - click Verify to proceed');\n  addHistory({action:'useOtherForVerify'});\n});\n\n// Tamper controls\nflipByteBtn.addEventListener('click', ()=>{\n  // Flip a byte in message text area by treating it as UTF-8 bytes\n  const text = messageEl.value;\n  const buf = new Uint8Array(stringToBuf(text));\n  if(buf.length===0){ setState('Message empty, nothing to flip'); return; }\n  buf[0] = buf[0] ^ 0xFF;\n  messageEl.value = bufToBase64(buf.buffer);\n  setState('Flipped first byte of message (now base64 representation)');\n  addHistory({action:'tamper','type':'flipByte'});\n});\nappendTextBtn.addEventListener('click', ()=>{\n  messageEl.value += '\\nTampered at ' + new Date().toISOString();\n  setState('Appended text to message');\n  addHistory({action:'tamper','type':'appendText'});\n});\nreplaceMessageBtn.addEventListener('click', ()=>{\n  const arr = new Uint8Array(16);\n  crypto.getRandomValues(arr);\n  messageEl.value = bufToBase64(arr.buffer);\n  setState('Replaced message with random bytes (base64)');\n  addHistory({action:'tamper','type':'replace'});\n});\n\n// Simple conversions\ntextToHexBtn.addEventListener('click', ()=>{\n  const t = textToHexIn.value || messageEl.value || '';\n  const hex = bufToHex(stringToBuf(t));\n  pemArea.value = hex;\n  setState('Converted text to hex in PEM area');\n});\nhexToTextBtn.addEventListener('click', ()=>{\n  const hex = pemArea.value.trim();\n  try{\n    const buf = hexToBuf(hex);\n    const txt = bufToString(buf);\n    messageEl.value = txt;\n    setState('Converted hex to text and placed in message');\n  }catch(e){ setState('Hex->Text error: ' + e.message); }\n});\n\n// Copy signature on click\nsigArea.addEventListener('click', ()=> {\n  if(sigArea.value){ navigator.clipboard.writeText(sigArea.value); setState('Signature copied to clipboard'); }\n});\n\n// History recording and replay\nfunction addHistory(entry){\n  entry.timestamp = new Date().toISOString();\n  history.push(entry);\n  historyArea.textContent = JSON.stringify(history, null, 2);\n}\nrecordBtn.addEventListener('click', ()=>{\n  const snapshot = {\n    time: new Date().toISOString(),\n    algo: algoSelect.value,\n    message: messageEl.value,\n    signature: sigArea.value,\n    keyPresent: !!currentKeyPair.privateKey,\n    publicKeyPresent: !!currentKeyPair.publicKey\n  };\n  addHistory({action:'snapshot', snapshot});\n  setState('Recorded snapshot');\n});\nreplayBtn.addEventListener('click', async ()=>{\n  setState('Replaying history: simulating sequential actions...');\n  for (let i=0;i<history.length;i++){\n    const item = history[i];\n    // Provide a simple replay: if item has action sign or tamper or generateKey, we log to state\n    setState(`Replay step ${i+1}/${history.length}: ${item.action}`);\n    await new Promise(r=>setTimeout(r, 200)); // short delay to make visible\n  }\n  setState('Replay finished');\n});\nclearHistoryBtn.addEventListener('click', ()=> {\n  history = [];\n  historyArea.textContent = JSON.stringify(history, null, 2);\n  setState('History cleared');\n});\nsaveSession.addEventListener('click', ()=> {\n  const data = { history, currentKeyPair: { jwkPub: currentKeyPair.jwkPub, jwkPriv: currentKeyPair.jwkPriv}, lastSignature: lastSignature ? bufToBase64(lastSignature) : null, message: messageEl.value };\n  const blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url; a.download = 'signature-session.json'; document.body.appendChild(a); a.click(); a.remove();\n  URL.revokeObjectURL(url);\n  setState('Session downloaded');\n});\nloadSessionFile.addEventListener('change', async (ev)=>{\n  const f = ev.target.files[0];\n  if(!f) return;\n  const txt = await f.text();\n  try{\n    const data = JSON.parse(txt);\n    if(data.history) { history = data.history; historyArea.textContent = JSON.stringify(history, null, 2); }\n    if(data.message) messageEl.value = data.message;\n    if(data.lastSignature) { lastSignature = base64ToBuf(data.lastSignature); sigArea.value = data.lastSignature; }\n    setState('Session loaded (keys not auto-imported). You may import JWKs if present.');\n  }catch(e){ setState('Load session failed: ' + e.message); }\n});\n\n// Utility: normalize message content into ArrayBuffer for signing/hashing\nasync function normalizeMessageToArrayBuffer(){\n  const txt = messageEl.value.trim();\n  // Heuristics:\n  // - If looks like base64 and non-text bytes desired, decode base64\n  // - If looks like hex only, decode hex\n  // - Otherwise treat as plain UTF-8 text\n  if(!txt) return new ArrayBuffer(0);\n  if(/^[A-Za-z0-9+/=\\s]+$/.test(txt) && txt.length % 4 === 0){\n    // Maybe base64 - attempt decode\n    try{\n      return base64ToBuf(txt.replace(/\\s+/g,''));\n    }catch(e){}\n  }\n  if(/^[0-9a-fA-F\\s]+$/.test(txt) && txt.replace(/\\s+/g,'').length % 2 === 0){\n    try { return hexToBuf(txt); } catch(e){}\n  }\n  return stringToBuf(txt);\n}\n\n// Parse signature input in various encodings\nfunction parseSigInput(text){\n  text = text.trim();\n  // detect base64 or hex or b64url\n  if(/^[0-9a-fA-F]+$/.test(text.replace(/\\s+/g,''))){\n    return hexToBuf(text);\n  }\n  // b64url detection\n  if(/^[A-Za-z0-9\\-_]+$/.test(text) && (text.length % 4 !== 0)){\n    // convert to base64\n    const b64 = text.replace(/-/g,'+').replace(/_/g,'/');\n    return base64ToBuf(b64 + '='.repeat((4 - b64.length%4)%4));\n  }\n  // default assume base64\n  return base64ToBuf(text);\n}\n\n// Display signature in selected encoding\nfunction displaySignature(sigBuf, encoding){\n  if(encoding === 'base64') sigArea.value = bufToBase64(sigBuf);\n  else if(encoding === 'b64url') sigArea.value = bufToBase64Url(sigBuf);\n  else sigArea.value = bufToHex(sigBuf);\n  verifySigInput.value = sigArea.value;\n}\n\n// Determine import algorithm structure based on UI selection\nfunction pickImportAlgorithmForCurrentSelection(){\n  const algo = algoSelect.value;\n  if(algo === 'HMAC'){\n    return { name: 'HMAC', hash: hashSelect.value };\n  } else if(algo === 'ECDSA'){\n    return { name: 'ECDSA', namedCurve: ecCurve.value, hash: hashSelect.value };\n  } else if(algo === 'RSASSA-PKCS1-v1_5'){\n    return { name: 'RSASSA-PKCS1-v1_5', hash: { name: hashSelect.value } };\n  } else if(algo === 'RSA-PSS'){\n    return { name: 'RSA-PSS', hash: { name: hashSelect.value } };\n  } else {\n    return { name: algo, hash: { name: hashSelect.value } };\n  }\n}\n\n// DER-encoded ECDSA signature conversion helper: try to convert a DER to plain r||s\nfunction derSigToPlain(derBuf, pubKey){\n  // Parse ASN.1 DER sequence of two integers\n  const bytes = new Uint8Array(derBuf);\n  let idx = 0;\n  if(bytes[idx++] !== 0x30) throw new Error('Invalid DER signature (no sequence)');\n  const seqLen = bytes[idx++]; // assume short form\n  if(bytes[idx++] !== 0x02) throw new Error('Invalid DER signature (no int r)');\n  const rLen = bytes[idx++];\n  const r = bytes.slice(idx, idx + rLen); idx += rLen;\n  if(bytes[idx++] !== 0x02) throw new Error('Invalid DER signature (no int s)');\n  const sLen = bytes[idx++];\n  const s = bytes.slice(idx, idx + sLen); idx += sLen;\n  // Determine expected length of coordinate from public key curve\n  // Derive length from key's algorithm.namedCurve if provided\n  let coordLen = 32; // default for P-256\n  try{\n    if(pubKey && pubKey.namedCurve) {\n      const nm = pubKey.namedCurve || (pubKey.algorithm && pubKey.algorithm.namedCurve);\n      if(nm === 'P-256') coordLen = 32;\n      else if(nm === 'P-384') coordLen = 48;\n      else if(nm === 'P-521') coordLen = 66;\n    }\n  }catch(e){}\n  // r and s may have leading zero to mark positive integer; strip it and pad to coordLen\n  function trimAndPad(arr){\n    let a = arr;\n    while(a.length > 0 && a[0] === 0x00) a = a.slice(1);\n    if(a.length > coordLen) a = a.slice(-coordLen);\n    if(a.length < coordLen){\n      const padded = new Uint8Array(coordLen);\n      padded.set(a, coordLen - a.length);\n      return padded;\n    }\n    return a;\n  }\n  const rP = trimAndPad(r);\n  const sP = trimAndPad(s);\n  const out = new Uint8Array(rP.length + sP.length);\n  out.set(rP,0); out.set(sP,rP.length);\n  return out.buffer;\n}\n\n// Additional helpers to show keys and quick checks in console\nwindow._debugShowKeys = async function(){\n  console.log('currentKeyPair', currentKeyPair);\n  if(currentKeyPair.publicKey) console.log('public key algorithm', currentKeyPair.publicKey.algorithm);\n  if(currentKeyPair.privateKey) console.log('private key algorithm', currentKeyPair.privateKey.algorithm);\n};\n\n// Simple: clicking on history area copies it\nhistoryArea.addEventListener('click', ()=> { navigator.clipboard.writeText(historyArea.textContent); setState('History copied'); });\n\n// Initialize\nsetState('Idle - ready');\n\n</script>\n</body>\n</html>"
