    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Bellman-Ford Algorithm</title>\n    <script>\n        function runBellmanFord() {\n            const vertices = parseInt(document.getElementById('vertices').value);\n            const edges = getEdges();\n            const source = parseInt(document.getElementById('source').value);\n            const result = bellmanFord(vertices, edges, source);\n\n            if (result) {\n                displayResult(result);\n            } else {\n                alert(\"Error: Invalid graph input.\");\n            }\n        }\n\n        function getEdges() {\n            const edgeInputs = document.querySelectorAll('.edge-input');\n            const edges = [];\n            for (const input of edgeInputs) {\n                const values = input.value.split(',').map(x => parseInt(x));\n                if (values.length === 3) {\n                    edges.push({ source: values[0], destination: values[1], weight: values[2] });\n                }\n            }\n            return edges;\n        }\n\n        function bellmanFord(vertices, edges, source) {\n            const distances = Array(vertices).fill(Infinity);\n            distances[source] = 0;\n\n            for (let i = 0; i < vertices - 1; i++) {\n                for (const edge of edges) {\n                    if (distances[edge.source] !== Infinity && distances[edge.source] + edge.weight < distances[edge.destination]) {\n                        distances[edge.destination] = distances[edge.source] + edge.weight;\n                    }\n                }\n            }\n\n            for (const edge of edges) {\n                if (distances[edge.source] !== Infinity && distances[edge.source] + edge.weight < distances[edge.destination]) {\n                    return null; // Indicates negative weight cycle\n                }\n            }\n\n            return distances;\n        }\n\n        function displayResult(distances) {\n            const resultDiv = document.getElementById('result');\n            resultDiv.innerHTML = '<h3>Shortest Distances</h3>';\n            distances.forEach((d, index) => {\n                resultDiv.innerHTML += `Vertex ${index}: ${d === Infinity ? 'Infinity' : d}<br>`;\n            });\n        }\n\n        function addEdgeInput() {\n            const edgeInputDiv = document.createElement('div');\n            edgeInputDiv.className = 'edge-input';\n            edgeInputDiv.innerHTML = 'Edge (source,destination,weight): <input type=\"text\" class=\"edge-input\" /> <button onclick=\"removeEdgeInput(this)\">Remove</button>';\n            document.getElementById('edges').appendChild(edgeInputDiv);\n        }\n\n        function removeEdgeInput(button) {\n            button.parentElement.remove();\n        }\n\n        function reset() {\n            document.getElementById('vertices').value = '';\n            document.getElementById('source').value = '';\n            document.getElementById('edges').innerHTML = '';\n            document.getElementById('result').innerHTML = '';\n        }\n    </script>\n</head>\n<body>\n    <h1>Bellman-Ford Algorithm Interactive Demo</h1>\n    <label for=\"vertices\">Number of Vertices:</label>\n    <input type=\"number\" id=\"vertices\" min=\"1\" /><br />\n\n    <label for=\"source\">Source Vertex:</label>\n    <input type=\"number\" id=\"source\" min=\"0\" /><br />\n\n    <h3>Edges</h3>\n    <div id=\"edges\"></div>\n    <button onclick=\"addEdgeInput()\">Add Edge</button><br />\n\n    <button onclick=\"runBellmanFord()\">Run Bellman-Ford</button>\n    <button onclick=\"reset()\">Reset</button>\n\n    <div id=\"result\"></div>\n</body>\n</html>"
