    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>P vs NP — Visual Concept</title>\n\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap\" rel=\"stylesheet\">\n\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #0b1020;\n    --accent-a: #7ee7c7; /* teal */\n    --accent-b: #7ab7ff; /* blue */\n    --accent-c: #ff9fb1; /* coral */\n    --glass: rgba(255,255,255,0.04);\n    --glass-2: rgba(255,255,255,0.02);\n    --muted: rgba(255,255,255,0.65);\n  }\n\n  /* Reset & base */\n  * {box-sizing: border-box; margin: 0; padding: 0;}\n  html,body {height:100%;}\n  body{\n    font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: linear-gradient(160deg,var(--bg-1), var(--bg-2) 60%);\n    color: #eaf6ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow: hidden;\n  }\n\n  /* Subtle animated background layers */\n  .bg{\n    position: fixed;\n    inset:0;\n    z-index:0;\n    pointer-events:none;\n  }\n  .bg::before, .bg::after{\n    content:\"\";\n    position:absolute; inset:-10%;\n    background: radial-gradient(ellipse at 10% 20%, rgba(122,183,255,0.14), transparent 8%),\n                radial-gradient(ellipse at 90% 80%, rgba(255,159,177,0.08), transparent 12%);\n    transform: translate3d(0,0,0);\n    filter: blur(40px);\n    opacity:0.9;\n    animation: float 12s ease-in-out infinite alternate;\n  }\n  .bg::after{\n    background: radial-gradient(ellipse at 50% 40%, rgba(126,231,199,0.08), transparent 8%),\n                radial-gradient(ellipse at 20% 80%, rgba(122,183,255,0.06), transparent 10%);\n    filter: blur(60px);\n    animation-duration: 18s;\n    mix-blend-mode: screen;\n  }\n  @keyframes float{\n    from { transform: translateY(-8%) rotate(-2deg) }\n    to   { transform: translateY(8%) rotate(2deg) }\n  }\n\n  /* Main card */\n  .container{\n    position:relative;\n    z-index:2;\n    max-width:1200px;\n    margin:40px auto;\n    padding:36px;\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 10px 40px rgba(2,6,23,0.7), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(1.1);\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:28px;\n    margin-top:36px;\n    margin-bottom:36px;\n  }\n\n  header{\n    grid-column: 1 / -1;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:20px;\n  }\n\n  .title{\n    display:flex;\n    gap:18px;\n    align-items:center;\n  }\n  .logo{\n    width:68px; height:68px;\n    background: linear-gradient(135deg,var(--accent-b), var(--accent-a));\n    border-radius:14px;\n    box-shadow: 0 8px 30px rgba(42,116,255,0.12), inset 0 1px 0 rgba(255,255,255,0.12);\n    display:grid; place-items:center;\n    transform: rotate(-12deg);\n  }\n  .logo svg{ filter: drop-shadow(0 6px 18px rgba(0,0,0,0.5)); }\n\n  h1{\n    font-size:28px;\n    letter-spacing:-0.6px;\n    font-weight:800;\n    background: linear-gradient(90deg, var(--accent-b), var(--accent-a), var(--accent-c));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 6px 20px rgba(0,0,0,0.45);\n  }\n\n  .sub{\n    color:var(--muted);\n    font-weight:400;\n    font-size:13px;\n    max-width:640px;\n    line-height:1.45;\n  }\n\n  /* Panels layout */\n  .visual{\n    padding:28px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    box-shadow: 0 6px 30px rgba(3,8,20,0.55);\n    min-height:520px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  .sidebar{\n    padding:22px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.007));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n  }\n\n  /* center question badge */\n  .question{\n    position:absolute;\n    left:50%;\n    top:40%;\n    transform: translate(-50%,-50%);\n    text-align:center;\n    z-index:5;\n    pointer-events:none;\n  }\n  .question .bubble{\n    width:220px;\n    height:220px;\n    border-radius:50%;\n    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.03), rgba(255,255,255,0.01) 40%), linear-gradient(135deg, rgba(122,183,255,0.08), rgba(126,231,199,0.06));\n    box-shadow: 0 20px 60px rgba(22,40,80,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    display:grid; place-items:center;\n    transform-origin:center;\n    animation: pulse 3s ease-in-out infinite;\n  }\n  .question h2{\n    font-size:30px;\n    font-weight:800;\n    color:#fff;\n    text-shadow: 0 6px 24px rgba(30,40,70,0.6);\n    letter-spacing:-1px;\n  }\n  .question p{\n    margin-top:6px;\n    font-size:12px;\n    color:var(--muted);\n    font-weight:600;\n  }\n  @keyframes pulse{\n    0% { transform: scale(0.98) translateY(0); filter: blur(0px); }\n    50%{ transform: scale(1.03) translateY(-6px); filter: blur(0.6px); }\n    100%{ transform: scale(0.98) translateY(0); filter: blur(0px); }\n  }\n\n  /* left / right lanes for P and NP */\n  .lane{\n    position:absolute;\n    top:40px;\n    bottom:40px;\n    width:42%;\n    border-radius:12px;\n    padding:22px;\n    display:flex;\n    flex-direction:column;\n    gap:14px;\n  }\n  .lane.left{ left:40px; background: linear-gradient(180deg, rgba(122,183,255,0.02), rgba(126,231,199,0.01)); }\n  .lane.right{ right:40px; background: linear-gradient(180deg, rgba(255,159,177,0.02), rgba(122,183,255,0.01)); }\n\n  .lane .label{\n    display:flex; gap:12px; align-items:center;\n  }\n  .pill{\n    padding:8px 12px;\n    border-radius:999px;\n    font-weight:700;\n    font-size:13px;\n    letter-spacing:0.6px;\n    color:#092235;\n    background: linear-gradient(90deg, rgba(255,255,255,0.92), rgba(255,255,255,0.86));\n    box-shadow: 0 6px 20px rgba(10,20,40,0.15);\n  }\n\n  .lane .subtitle{\n    color: var(--muted);\n    font-size:13px;\n    font-weight:600;\n    margin-left:6px;\n  }\n\n  /* deterministic diagram (single solver) */\n  .deterministic{\n    flex:1;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n  }\n  .path{\n    width:86%;\n    height:160px;\n    border-radius:12px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    display:grid;\n    grid-template-columns: 1fr auto;\n    padding:12px;\n    gap:12px;\n    align-items:center;\n  }\n  .steps{\n    height:100%;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:8px;\n    position:relative;\n  }\n  .step-seq{\n    width:80%;\n    height:8px;\n    border-radius:999px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    position:relative;\n    overflow:visible;\n  }\n  .walker{\n    width:18px;height:18px;border-radius:50%;\n    background: linear-gradient(90deg,var(--accent-b), var(--accent-a));\n    position:absolute; top:-5px;\n    transform: translateX(-50%) rotate(-10deg);\n    box-shadow: 0 8px 20px rgba(34,80,200,0.18);\n    animation: walk linear infinite;\n  }\n  /* animation path speed controlled by JS by changing --walk-duration */\n  .path{ --walk-duration: 6s; }\n  @keyframes walk{\n    0% { left: 2%; transform: translateX(-50%) scale(0.98) rotate(-8deg); }\n    25%{ transform: translateX(-50%) scale(1.04) rotate(4deg); }\n    50% { left: 50%; transform: translateX(-50%) scale(1) rotate(2deg); }\n    75%{ transform: translateX(-50%) scale(1.03) rotate(-4deg); }\n    100% { left: 98%; transform: translateX(-50%) scale(1) rotate(0deg); }\n  }\n  .walker{ animation-duration: var(--walk-duration); }\n\n  .det-info{\n    width:96px;\n    text-align:center;\n    font-size:12px;\n    color:var(--muted);\n    font-weight:600;\n  }\n\n  /* nondeterministic diagram (many guesses) */\n  .nondet{\n    flex:1;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n  }\n  .forest{\n    width:86%;\n    height:160px;\n    border-radius:12px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    display:flex;\n    gap:10px;\n    padding:12px;\n    align-items:center;\n    overflow:hidden;\n  }\n  .branch-column{\n    flex:1;\n    height:100%;\n    display:flex;\n    flex-direction:column;\n    justify-content:space-between;\n    align-items:center;\n    padding:6px 2px;\n  }\n  .token{\n    width:18px;height:18px;border-radius:50%;\n    background: linear-gradient(90deg,var(--accent-c), #ffc8d0);\n    box-shadow: 0 8px 20px rgba(255,100,120,0.12);\n    transform-origin:center;\n    opacity:0.95;\n    animation: drift 4s ease-in-out infinite;\n  }\n  .token:nth-child(2){ animation-delay: 0.4s; }\n  .token:nth-child(3){ animation-delay: 0.8s; }\n  .token:nth-child(4){ animation-delay: 1.3s; }\n  @keyframes drift{\n    0%{ transform: translateY(0) scale(1); opacity:1; }\n    50%{ transform: translateY(-18px) scale(1.06); opacity:0.95; }\n    100%{ transform: translateY(0) scale(1); opacity:0.92; }\n  }\n\n  .verifier{\n    width:88px;\n    height:92px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.02));\n    display:grid;\n    place-items:center;\n    text-align:center;\n    font-weight:700;\n    color:var(--muted);\n    font-size:12px;\n    box-shadow: 0 10px 30px rgba(10,20,40,0.35);\n    padding:10px;\n  }\n\n  /* highlight / dim states */\n  .focus-P .lane.left{ box-shadow: 0 20px 60px rgba(26,91,255,0.12); transform: translateY(-6px) scale(1.01); }\n  .focus-P .lane.right{ opacity:0.28; filter:grayscale(40%); transform: scale(0.99); transition: all 0.6s cubic-bezier(.2,.9,.26,1); }\n  .focus-NP .lane.right{ box-shadow: 0 20px 60px rgba(255,110,140,0.12); transform: translateY(-6px) scale(1.01); }\n  .focus-NP .lane.left{ opacity:0.28; filter:grayscale(40%); transform: scale(0.99); transition: all 0.6s cubic-bezier(.2,.9,.26,1); }\n\n  /* subtle connecting animated arcs */\n  .connect{\n    position:absolute;\n    left:50%;\n    top:58%;\n    transform: translate(-50%,-50%);\n    pointer-events:none;\n    z-index:3;\n  }\n\n  /* sidebar info */\n  .meta{\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n  }\n  .meta h3{\n    font-size:15px;\n    font-weight:800;\n    letter-spacing:-0.2px;\n  }\n  .meta p{ color:var(--muted); font-size:13px; line-height:1.45; }\n\n  .controls{\n    display:flex;\n    gap:10px;\n    margin-top:6px;\n  }\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 14px;\n    border-radius:10px;\n    cursor:pointer;\n    font-weight:700;\n    font-size:13px;\n    letter-spacing:0.2px;\n    transition: transform .18s ease, box-shadow .18s ease;\n    box-shadow: 0 8px 20px rgba(4,10,30,0.24);\n  }\n  .btn:active{ transform: translateY(2px); }\n  .btn.ghost{\n    background:transparent;\n    color:var(--accent-b);\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n  .btn.primary{\n    background: linear-gradient(90deg,var(--accent-b), var(--accent-a));\n    color:#042036;\n  }\n\n  /* info overlay */\n  .overlay{\n    position:fixed;\n    right:32px;\n    bottom:32px;\n    width:380px;\n    max-width:90%;\n    background: linear-gradient(180deg, rgba(7,12,28,0.9), rgba(9,14,34,0.75));\n    border-radius:14px;\n    padding:16px;\n    box-shadow: 0 18px 60px rgba(2,6,23,0.7);\n    color: #e9fbff;\n    z-index: 999;\n    transform: translateY(20px) scale(.98);\n    transition: all .26s cubic-bezier(.2,.9,.26,1);\n    opacity:0;\n    pointer-events:none;\n  }\n  .overlay.visible{ opacity:1; transform: translateY(0) scale(1); pointer-events:auto; }\n\n  .overlay h4{ font-size:16px; margin-bottom:6px; font-weight:800; }\n  .overlay p{ color: rgba(255,255,255,0.82); font-size:13px; line-height:1.45; }\n\n  /* small footer note */\n  .note{\n    font-size:12px;\n    color:var(--muted);\n    margin-top:auto;\n    text-align:center;\n  }\n\n  /* responsive */\n  @media (max-width:1000px){\n    .container{ grid-template-columns: 1fr; padding:20px; gap:18px; }\n    .visual{ min-height:640px; }\n    .lane.left{ left:20px; right:auto; width:90%; top:120px; }\n    .lane.right{ right:20px; left:auto; width:90%; top:320px; }\n    .question{ top:44%; }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"bg\"></div>\n\n<div class=\"container\" id=\"app\">\n  <header>\n    <div class=\"title\">\n      <div class=\"logo\" aria-hidden=\"true\">\n        <svg width=\"42\" height=\"42\" viewBox=\"0 0 24 24\" fill=\"none\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#7ab7ff\"/><stop offset=\"1\" stop-color=\"#7ee7c7\"/></linearGradient>\n            <linearGradient id=\"g2\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#ff9fb1\"/><stop offset=\"1\" stop-color=\"#ffc8d0\"/></linearGradient>\n          </defs>\n          <path d=\"M3 12c0 4.418 3.582 8 8 8 1.657 0 3.183-.45 4.5-1.22L21 21V3l-5.5 2.22C14.183 4.45 12.657 4 11 4 6.582 4 3 7.582 3 12z\" fill=\"url(#g1)\"/>\n          <path d=\"M11 4v8l6 2V6.22L11 4z\" fill=\"url(#g2)\" opacity=\"0.95\"/>\n        </svg>\n      </div>\n      <div>\n        <h1>P vs NP</h1>\n        <div class=\"sub\">Aesthetic visualization of a deep theoretical computer science question — watch deterministic computation versus nondeterministic verification.</div>\n      </div>\n    </div>\n\n    <div style=\"text-align:right;\">\n      <div style=\"color:var(--muted); font-weight:700; font-size:12px\">Concept • Complexity Theory</div>\n      <div style=\"color:rgba(255,255,255,0.34); font-size:11px; margin-top:6px\">Polished visual explanation — limited interactivity</div>\n    </div>\n  </header>\n\n  <section class=\"visual\" id=\"visual\">\n    <!-- left lane (P) -->\n    <div class=\"lane left\" aria-hidden=\"true\">\n      <div class=\"label\">\n        <div class=\"pill\">P</div>\n        <div class=\"subtitle\">Deterministic, polynomial-time</div>\n      </div>\n\n      <div class=\"deterministic\">\n        <div class=\"path\" id=\"detPath\">\n          <div class=\"steps\" style=\"align-items:center;\">\n            <div class=\"step-seq\" aria-hidden=\"true\">\n              <div class=\"walker\" id=\"walker\"></div>\n            </div>\n          </div>\n          <div class=\"det-info\">\n            <div style=\"font-weight:900; font-size:20px; color:#cfeeff;\" id=\"stepCount\">n²</div>\n            <div style=\"font-size:11px; color:var(--muted); margin-top:6px;\">time complexity</div>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"display:flex; gap:10px;\">\n        <div style=\"flex:1; font-size:13px; color:var(--muted); line-height:1.4;\">\n          Solver advances step-by-step through a structured algorithm. The path is singular and predictable — polynomial growth of steps with input size.\n        </div>\n      </div>\n    </div>\n\n    <!-- right lane (NP) -->\n    <div class=\"lane right\" aria-hidden=\"true\">\n      <div class=\"label\">\n        <div class=\"pill\" style=\"background:linear-gradient(90deg,#ffd3dc,#fff2f4); color:#2b2b35;\">NP</div>\n        <div class=\"subtitle\">Nondeterministic / verifiable</div>\n      </div>\n\n      <div class=\"nondet\">\n        <div class=\"forest\" id=\"forest\">\n          <div class=\"branch-column\">\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n          </div>\n          <div class=\"branch-column\">\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n          </div>\n          <div class=\"branch-column\">\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n          </div>\n          <div class=\"branch-column\">\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n            <div class=\"token\"></div>\n          </div>\n        </div>\n\n        <div class=\"verifier\" id=\"verifier\">\n          <div style=\"font-size:11px; color:var(--muted);\">Verifier</div>\n          <div style=\"font-size:14px; color:#fff; margin-top:6px; font-weight:900;\">Check in P</div>\n        </div>\n      </div>\n\n      <div style=\"display:flex; gap:10px;\">\n        <div style=\"flex:1; font-size:13px; color:var(--muted); line-height:1.4;\">\n          Many candidate solutions (witnesses) may be explored in parallel. A solution, if presented, can be verified efficiently — that's the NP property.\n        </div>\n      </div>\n    </div>\n\n    <div class=\"question\" aria-hidden=\"true\">\n      <div class=\"bubble\" title=\"Open problem\">\n        <h2>P = NP?</h2>\n      </div>\n      <p>It is unknown whether every efficiently verifiable problem is also efficiently solvable.</p>\n    </div>\n\n    <!-- decorative connecting arcs SVG -->\n    <svg class=\"connect\" width=\"600\" height=\"280\" viewBox=\"0 0 600 280\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n      <defs>\n        <linearGradient id=\"arcGrad\" x1=\"0\" x2=\"1\">\n          <stop offset=\"0\" stop-color=\"#7ab7ff\" stop-opacity=\"0.9\"/>\n          <stop offset=\"1\" stop-color=\"#ff9fb1\" stop-opacity=\"0.9\"/>\n        </linearGradient>\n        <filter id=\"glow\">\n          <feGaussianBlur stdDeviation=\"8\" result=\"coloredBlur\"/>\n          <feMerge>\n            <feMergeNode in=\"coloredBlur\"/>\n            <feMergeNode in=\"SourceGraphic\"/>\n          </feMerge>\n        </filter>\n      </defs>\n      <path d=\"M50 200 C170 120, 430 120, 550 200\" stroke=\"url(#arcGrad)\" stroke-width=\"2.8\" fill=\"none\" opacity=\"0.9\" filter=\"url(#glow)\"></path>\n      <g id=\"pulses\">\n        <circle cx=\"50\" cy=\"200\" r=\"4\" fill=\"#7ab7ff\" opacity=\"0.95\"></circle>\n        <circle cx=\"300\" cy=\"160\" r=\"3.2\" fill=\"#7ee7c7\" opacity=\"0.9\"></circle>\n        <circle cx=\"550\" cy=\"200\" r=\"4.4\" fill=\"#ff9fb1\" opacity=\"0.95\"></circle>\n      </g>\n    </svg>\n\n  </section>\n\n  <aside class=\"sidebar\" aria-hidden=\"true\">\n    <div class=\"meta\">\n      <h3>What you are seeing</h3>\n      <p><strong>P:</strong> A single deterministic computation evolving in polynomial time. <strong>NP:</strong> A space of many candidate solutions whose correctness can be checked quickly.</p>\n    </div>\n\n    <div style=\"display:flex; gap:10px;\">\n      <div style=\"flex:1;\">\n        <div style=\"font-size:12px; color:var(--muted); font-weight:700; margin-bottom:8px;\">Focus</div>\n        <div style=\"display:flex; gap:8px;\">\n          <button class=\"btn ghost\" id=\"toggleView\" title=\"Toggle focus between P and NP\">Toggle View</button>\n          <button class=\"btn primary\" id=\"explainBtn\" title=\"Show short definitions\">Definitions</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"note\">Limited controls: Observe the visuals. The mathematical question \"Is P equal to NP?\" remains open.</div>\n  </aside>\n</div>\n\n<!-- Info overlay -->\n<div class=\"overlay\" id=\"overlay\" role=\"dialog\" aria-hidden=\"true\">\n  <h4>Formal snapshot</h4>\n  <p><strong>P</strong> — the class of decision problems solvable by a deterministic Turing machine in polynomial time. Example: sorting, shortest paths.</p>\n  <p style=\"margin-top:8px;\"><strong>NP</strong> — the problems for which a candidate solution (certificate) can be verified by a deterministic Turing machine in polynomial time. Example: SAT, Hamiltonian cycle.</p>\n  <p style=\"margin-top:8px; color:#9bdcff;\"><em>The central open problem: Does P = NP? It is unknown whether every efficiently verifiable problem is also efficiently solvable.</em></p>\n</div>\n\n<script>\n  (function(){\n    const app = document.getElementById('app');\n    const toggle = document.getElementById('toggleView');\n    const explain = document.getElementById('explainBtn');\n    const overlay = document.getElementById('overlay');\n\n    // initial state: neutral\n    let state = 'neutral'; // 'P' or 'NP'\n\n    // walker speed control and stepCount text\n    const walker = document.getElementById('walker');\n    const stepCount = document.getElementById('stepCount');\n\n    // connecting pulses animation\n    const pulses = document.querySelectorAll('#pulses circle');\n    pulses.forEach((c,i)=>{\n      c.style.opacity = 0;\n      c.animate([\n        { opacity: 0, transform: 'scale(0.6)' },\n        { opacity: 1, transform: 'scale(1.0)' },\n        { opacity: 0, transform: 'scale(1.6)' }\n      ],{\n        delay: i*260,\n        duration: 2200,\n        iterations: Infinity,\n      });\n    });\n\n    // tokens (NP)\n    const tokens = document.querySelectorAll('.token');\n    tokens.forEach((t,i)=>{\n      const offset = (Math.random()*140)-70;\n      t.animate([\n        { transform: `translateY(0px) translateX(0px)` },\n        { transform: `translateY(${offset}px) translateX(${(i%2?8:-8)}px)` },\n        { transform: `translateY(0px) translateX(0px)` }\n      ],{\n        duration: 4000 + (i*180),\n        delay: i*80,\n        iterations: Infinity,\n        easing: 'ease-in-out'\n      });\n    });\n\n    // initial visuals\n    function setNeutral(){\n      document.body.classList.remove('focus-P','focus-NP');\n      // neutral walker speed\n      walker.style.animationDuration = '6s';\n      stepCount.textContent = 'n²';\n    }\n\n    function setFocusP(){\n      document.body.classList.add('focus-P');\n      document.body.classList.remove('focus-NP');\n      // speed up deterministic solver, slow down nondet pulses\n      walker.style.animationDuration = '3.6s';\n      stepCount.textContent = 'poly(n)';\n    }\n\n    function setFocusNP(){\n      document.body.classList.add('focus-NP');\n      document.body.classList.remove('focus-P');\n      walker.style.animationDuration = '9s';\n      stepCount.textContent = 'poly(n)';\n      // add a brief shimmer to verifier to emphasize quick check\n      const verifier = document.getElementById('verifier');\n      verifier.animate([\n        { boxShadow: '0 10px 30px rgba(10,20,40,0.35)' },\n        { boxShadow: '0 30px 90px rgba(255,120,130,0.18)' },\n        { boxShadow: '0 10px 30px rgba(10,20,40,0.35)' }\n      ],{ duration: 1800, iterations: 1 });\n    }\n\n    // toggle handler\n    toggle.addEventListener('click', ()=>{\n      if(state === 'neutral' || state === 'NP'){\n        state = 'P';\n        setFocusP();\n        toggle.textContent = 'Focus: P';\n      } else {\n        state = 'NP';\n        setFocusNP();\n        toggle.textContent = 'Focus: NP';\n      }\n\n      // small micro-animation for toggle feedback\n      toggle.animate([\n        { transform: 'translateY(0) scale(1)' },\n        { transform: 'translateY(-6px) scale(1.03)' },\n        { transform: 'translateY(0) scale(1)' }\n      ],{ duration: 340, easing: 'cubic-bezier(.2,.9,.26,1)' });\n    });\n\n    // explain overlay\n    explain.addEventListener('click', ()=>{\n      overlay.classList.toggle('visible');\n      explain.animate([\n        { transform: 'translateY(0)' },\n        { transform: 'translateY(-4px)' },\n        { transform: 'translateY(0)' }\n      ],{ duration: 260, easing: 'ease-out' });\n    });\n\n    // Accessibility: hide overlay on Esc\n    window.addEventListener('keydown', (e)=>{\n      if(e.key === 'Escape' && overlay.classList.contains('visible')){\n        overlay.classList.remove('visible');\n      }\n    });\n\n    // initial call\n    setNeutral();\n\n    // subtle hint: auto-cycle focus every 9s for ambient animation (non-intrusive)\n    let auto = true;\n    let cycleIndex = 0;\n    const cycle = ['P','NP','neutral'];\n    setInterval(()=>{\n      if(!auto) return;\n      cycleIndex = (cycleIndex+1) % cycle.length;\n      const next = cycle[cycleIndex];\n      if(next === 'P'){ state='P'; setFocusP(); toggle.textContent='Focus: P'; }\n      else if(next === 'NP'){ state='NP'; setFocusNP(); toggle.textContent='Focus: NP'; }\n      else { state='neutral'; setNeutral(); toggle.textContent='Toggle View'; }\n    }, 9000);\n\n    // stop auto when user interacts with controls\n    [toggle, explain].forEach(el=>{\n      el.addEventListener('click', ()=>{ auto = false; });\n    });\n\n    // performance safeguard: pause heavy animations when tab hidden\n    document.addEventListener('visibilitychange', ()=>{\n      if(document.hidden){\n        document.querySelectorAll('*').forEach(el=>{\n          if(el.getAnimations){\n            el.getAnimations().forEach(a=>a.pause());\n          }\n        });\n      } else {\n        document.querySelectorAll('*').forEach(el=>{\n          if(el.getAnimations){\n            el.getAnimations().forEach(a=>a.play());\n          }\n        });\n      }\n    });\n\n  })();\n</script>\n\n</body>\n</html>"
