  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Heap Sort Interactive Demo</title>\n  <style>\n    /* Extremely minimal styling: plain black text on white background, basic layout */\n    body { font-family: Arial, sans-serif; color: black; background: white; margin: 12px; }\n    label { display: inline-block; margin: 4px 8px 4px 0; }\n    input[type=\"text\"], input[type=\"number\"], textarea, select { font: inherit; }\n    .controls { margin-bottom: 12px; }\n    .row { margin-bottom: 8px; }\n    .array-view { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }\n    .cell { padding: 6px 8px; border: 1px solid black; min-width: 28px; text-align: center; cursor: pointer; user-select: none; }\n    .cell.index { font-size: 11px; padding: 2px 6px; }\n    .cell.highlight { font-weight: bold; }\n    .info { margin-top: 8px; }\n    .panel { border-top: 1px dashed black; padding-top: 8px; margin-top: 8px; }\n    pre { white-space: pre-wrap; font-family: monospace; margin: 0; padding: 8px; border: 1px solid black; }\n    button { margin-right: 6px; }\n    .log { max-height: 180px; overflow: auto; border: 1px solid black; padding: 6px; }\n    .small { font-size: 12px; }\n    input[type=\"range\"] { vertical-align: middle; }\n    /* Very light visual hint for current step slider */\n  </style>\n</head>\n<body>\n  <h2>Heap Sort — Interactive Demo</h2>\n\n  <div class=\"controls\">\n    <div class=\"row\">\n      <label>Array size:\n        <input id=\"size\" type=\"range\" min=\"1\" max=\"60\" value=\"12\">\n      </label>\n      <span id=\"sizeVal\">12</span>\n      <label style=\"margin-left:12px;\">Min value:\n        <input id=\"minVal\" type=\"number\" value=\"1\" style=\"width:70px;\">\n      </label>\n      <label>Max value:\n        <input id=\"maxVal\" type=\"number\" value=\"99\" style=\"width:70px;\">\n      </label>\n      <label style=\"margin-left:12px;\">Seed:\n        <input id=\"seed\" type=\"text\" placeholder=\"optional seed\" style=\"width:120px;\">\n      </label>\n      <button id=\"randBtn\">Generate Random</button>\n      <button id=\"incBtn\">Increasing</button>\n      <button id=\"decBtn\">Decreasing</button>\n    </div>\n\n    <div class=\"row\">\n      <label>Custom array (comma separated):\n        <input id=\"customArray\" type=\"text\" style=\"width:420px;\">\n      </label>\n      <button id=\"setCustom\">Set Array</button>\n      <button id=\"clearArray\">Clear</button>\n    </div>\n\n    <div class=\"row\">\n      <label>Heap type:\n        <select id=\"heapType\">\n          <option value=\"max\">Max-Heap</option>\n          <option value=\"min\">Min-Heap</option>\n        </select>\n      </label>\n\n      <label style=\"margin-left:12px;\">Granularity:\n        <select id=\"granularity\">\n          <option value=\"swap\">Record swaps only</option>\n          <option value=\"compare\">Record comparisons and swaps</option>\n          <option value=\"call\">Record per heapify call</option>\n        </select>\n      </label>\n\n      <label style=\"margin-left:12px;\">Record comparisons:\n        <input id=\"recordCompares\" type=\"checkbox\" checked>\n      </label>\n\n      <label style=\"margin-left:12px;\">Show indices:\n        <input id=\"showIndices\" type=\"checkbox\" checked>\n      </label>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"buildTrace\">Build Trace</button>\n      <button id=\"goStart\">|&lt; Start</button>\n      <button id=\"stepBack\">&lt; Step</button>\n      <button id=\"play\">Play</button>\n      <button id=\"pause\">Pause</button>\n      <button id=\"stepFwd\">Step &gt;</button>\n      <button id=\"goEnd\">End &gt;|</button>\n      <button id=\"exportBtn\">Export Trace</button>\n      <button id=\"importBtn\">Import Trace</button>\n      <input id=\"importData\" type=\"file\" style=\"display:none;\">\n    </div>\n\n    <div class=\"row\">\n      <label>Speed:\n        <input id=\"speed\" type=\"range\" min=\"10\" max=\"2000\" value=\"300\">\n      </label>\n      <span id=\"speedVal\">300ms</span>\n\n      <label style=\"margin-left:12px;\">Step slider:\n        <input id=\"stepSlider\" type=\"range\" min=\"0\" max=\"0\" value=\"0\" style=\"width:240px;\">\n      </label>\n      <span id=\"stepInfo\">0 / 0</span>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"row\">\n      <div>\n        <strong>Array visualization (click element to edit):</strong>\n        <div id=\"arrayView\" class=\"array-view\"></div>\n      </div>\n    </div>\n\n    <div class=\"row info small\" id=\"currentInfo\">\n      Current action: <span id=\"curAction\">-</span> |\n      Heap size: <span id=\"curHeapSize\">-</span> |\n      Comparisons: <span id=\"curCompares\">0</span> |\n      Swaps: <span id=\"curSwaps\">0</span>\n    </div>\n\n    <div class=\"row\">\n      <div style=\"width:48%; display:inline-block; vertical-align:top;\">\n        <strong>Pseudocode (current line highlighted):</strong>\n        <pre id=\"pseudocode\"></pre>\n      </div>\n\n      <div style=\"width:48%; display:inline-block; vertical-align:top;\">\n        <strong>Event log (click to jump):</strong>\n        <div id=\"log\" class=\"log\"></div>\n      </div>\n    </div>\n\n    <div class=\"row\">\n      <strong>Binary heap tree (textual):</strong>\n      <pre id=\"treeView\"></pre>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"toggleTraceView\">Toggle Trace JSON</button>\n      <div id=\"traceJson\" style=\"display:none; border:1px solid black; padding:6px; margin-top:6px; max-height:300px; overflow:auto;\">\n        <pre id=\"traceJsonContent\"></pre>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Minimal but feature-rich interactive Heap Sort demo\n    (function(){\n      // Elements\n      const sizeEl = document.getElementById('size');\n      const sizeVal = document.getElementById('sizeVal');\n      const minValEl = document.getElementById('minVal');\n      const maxValEl = document.getElementById('maxVal');\n      const seedEl = document.getElementById('seed');\n      const randBtn = document.getElementById('randBtn');\n      const incBtn = document.getElementById('incBtn');\n      const decBtn = document.getElementById('decBtn');\n      const customArray = document.getElementById('customArray');\n      const setCustom = document.getElementById('setCustom');\n      const clearArray = document.getElementById('clearArray');\n      const buildTraceBtn = document.getElementById('buildTrace');\n      const heapTypeEl = document.getElementById('heapType');\n      const granularityEl = document.getElementById('granularity');\n      const recordComparesEl = document.getElementById('recordCompares');\n      const showIndicesEl = document.getElementById('showIndices');\n\n      const arrayView = document.getElementById('arrayView');\n      const curAction = document.getElementById('curAction');\n      const curHeapSize = document.getElementById('curHeapSize');\n      const curCompares = document.getElementById('curCompares');\n      const curSwaps = document.getElementById('curSwaps');\n      const pseudocodeEl = document.getElementById('pseudocode');\n      const logEl = document.getElementById('log');\n      const treeViewEl = document.getElementById('treeView');\n      const speedEl = document.getElementById('speed');\n      const speedVal = document.getElementById('speedVal');\n      const playBtn = document.getElementById('play');\n      const pauseBtn = document.getElementById('pause');\n      const stepFwdBtn = document.getElementById('stepFwd');\n      const stepBackBtn = document.getElementById('stepBack');\n      const goStartBtn = document.getElementById('goStart');\n      const goEndBtn = document.getElementById('goEnd');\n      const stepSlider = document.getElementById('stepSlider');\n      const stepInfo = document.getElementById('stepInfo');\n      const exportBtn = document.getElementById('exportBtn');\n      const importBtn = document.getElementById('importBtn');\n      const importData = document.getElementById('importData');\n      const toggleTraceView = document.getElementById('toggleTraceView');\n      const traceJson = document.getElementById('traceJson');\n      const traceJsonContent = document.getElementById('traceJsonContent');\n\n      // local state\n      let baseArray = []; // current array before trace\n      let history = []; // snapshots\n      let currentStep = 0;\n      let playInterval = null;\n      let compareCount = 0, swapCount = 0;\n      let pseudocodeLines = [];\n      let built = false;\n\n      // initialize size label\n      sizeVal.textContent = sizeEl.value;\n      sizeEl.addEventListener('input', ()=> {\n        sizeVal.textContent = sizeEl.value;\n        // update custom array placeholder\n        customArray.placeholder = 'e.g. 5,3,8... or leave blank to use generated array';\n      });\n\n      speedEl.addEventListener('input', ()=> {\n        speedVal.textContent = speedEl.value + 'ms';\n        if (playInterval) {\n          clearInterval(playInterval);\n          playInterval = setInterval(stepForwardAuto, speedEl.value);\n        }\n      });\n\n      // Pseudocode templates\n      const pseudocodeTemplate = {\n        max: [\n          \"HEAPSORT(A)\",\n          \"  build-max-heap(A)\",\n          \"  for i = A.length-1 downto 1\",\n          \"    swap A[0], A[i]\",\n          \"    heap-size = heap-size - 1\",\n          \"    max-heapify(A, 0)\",\n          \"\",\n          \"MAX-HEAPIFY(A, i)\",\n          \"  l = left(i)\",\n          \"  r = right(i)\",\n          \"  largest = i\",\n          \"  if l <= heap-size and A[l] > A[largest] then largest = l\",\n          \"  if r <= heap-size and A[r] > A[largest] then largest = r\",\n          \"  if largest != i then\",\n          \"    swap A[i], A[largest]\",\n          \"    MAX-HEAPIFY(A, largest)\"\n        ],\n        min: [\n          \"HEAPSORT(A) [min-heap variant]\",\n          \"  build-min-heap(A)\",\n          \"  for i = A.length-1 downto 1\",\n          \"    swap A[0], A[i]\",\n          \"    heap-size = heap-size - 1\",\n          \"    min-heapify(A, 0)\",\n          \"\",\n          \"MIN-HEAPIFY(A, i)\",\n          \"  l = left(i)\",\n          \"  r = right(i)\",\n          \"  smallest = i\",\n          \"  if l <= heap-size and A[l] < A[smallest] then smallest = l\",\n          \"  if r <= heap-size and A[r] < A[smallest] then smallest = r\",\n          \"  if smallest != i then\",\n          \"    swap A[i], A[smallest]\",\n          \"    MIN-HEAPIFY(A, smallest)\"\n        ]\n      };\n\n      function setPseudocode() {\n        const t = heapTypeEl.value === 'max' ? pseudocodeTemplate.max : pseudocodeTemplate.min;\n        pseudocodeLines = t;\n        renderPseudocode(null);\n      }\n\n      function renderPseudocode(highlightLine) {\n        let out = '';\n        for (let i=0;i<pseudocodeLines.length;i++){\n          const idx = i;\n          if (idx === highlightLine) {\n            out += '>> ' + pseudocodeLines[i] + '\\\\n';\n          } else {\n            out += '   ' + pseudocodeLines[i] + '\\\\n';\n          }\n        }\n        pseudocodeEl.textContent = out;\n      }\n\n      // Random functions with seed option\n      function seededRandom(seed) {\n        // simple LCG\n        let h = 2166136261 >>> 0;\n        for (let i = 0; i < seed.length; i++) {\n          h = Math.imul(h ^ seed.charCodeAt(i), 16777619) >>> 0;\n        }\n        return function() {\n          h += 0x6D2B79F5;\n          var t = Math.imul(h ^ (h >>> 15), 1 | h);\n          t = t + Math.imul(t ^ (t >>> 7), 61 | t) ^ t;\n          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n        };\n      }\n\n      function generateRandomArray() {\n        const n = parseInt(sizeEl.value, 10);\n        const min = parseInt(minValEl.value, 10);\n        const max = parseInt(maxValEl.value, 10);\n        const seed = seedEl.value.trim();\n        const prng = seed ? seededRandom(seed) : Math.random;\n        const out = [];\n        const low = Math.min(min, max);\n        const high = Math.max(min, max);\n        for (let i=0;i<n;i++){\n          const v = Math.floor(prng()*(high - low + 1)) + low;\n          out.push(v);\n        }\n        baseArray = out.slice();\n        built = false;\n        renderArrayView(baseArray);\n      }\n\n      function setArrayFromText() {\n        const text = customArray.value.trim();\n        if (!text) return;\n        const parts = text.split(',').map(x => x.trim()).filter(x => x !== '');\n        const parsed = [];\n        for (let p of parts) {\n          const n = Number(p);\n          if (Number.isNaN(n)) {\n            alert('Invalid number in custom array: ' + p);\n            return;\n          }\n          parsed.push(n);\n        }\n        baseArray = parsed.slice();\n        sizeEl.value = Math.max(1, parsed.length);\n        sizeVal.textContent = sizeEl.value;\n        built = false;\n        renderArrayView(baseArray);\n      }\n\n      function setIncreasing() {\n        const n = parseInt(sizeEl.value, 10);\n        const min = parseInt(minValEl.value, 10);\n        const max = parseInt(maxValEl.value, 10);\n        const low = Math.min(min, max);\n        const step = Math.max(1, Math.floor((Math.max(min,max) - low + 1)/Math.max(1,n)));\n        const arr = [];\n        for (let i=0;i<n;i++) arr.push(low + i*step);\n        baseArray = arr;\n        built = false;\n        renderArrayView(baseArray);\n      }\n\n      function setDecreasing() {\n        const n = parseInt(sizeEl.value, 10);\n        const min = parseInt(minValEl.value, 10);\n        const max = parseInt(maxValEl.value, 10);\n        const low = Math.min(min, max);\n        const high = Math.max(min, max);\n        const step = Math.max(1, Math.floor((high - low + 1)/Math.max(1,n)));\n        const arr = [];\n        for (let i=0;i<n;i++) arr.push(high - i*step);\n        baseArray = arr;\n        built = false;\n        renderArrayView(baseArray);\n      }\n\n      // Rendering array\n      function renderArrayView(arr, highlightIndices=[], heapSize=null, sortedFrom=null) {\n        arrayView.innerHTML = '';\n        const showIndices = showIndicesEl.checked;\n        for (let i=0;i<arr.length;i++){\n          const cell = document.createElement('div');\n          cell.className = 'cell';\n          cell.setAttribute('data-index', i);\n          let text = String(arr[i]);\n          if (showIndices) text = i + ': ' + text;\n          cell.textContent = text;\n          if (highlightIndices && highlightIndices.indexOf(i) !== -1) {\n            cell.classList.add('highlight');\n          }\n          // Mark sorted region by showing index in parentheses (no color)\n          if (typeof sortedFrom === 'number' && i >= sortedFrom) {\n            cell.title = 'Sorted';\n          }\n          cell.addEventListener('click', ()=> {\n            const val = prompt('Enter new value for element at index ' + i + ':', String(arr[i]));\n            if (val === null) return;\n            const n = Number(val);\n            if (Number.isNaN(n)) {\n              alert('Invalid number');\n              return;\n            }\n            baseArray[i] = n;\n            built = false;\n            renderArrayView(baseArray);\n          });\n          arrayView.appendChild(cell);\n        }\n      }\n\n      // Tree view textual\n      function buildTreeText(arr) {\n        if (!arr.length) return '(empty)';\n        let out = '';\n        for (let i=0;i<arr.length;i++){\n          const parent = Math.floor((i-1)/2);\n          const left = 2*i+1;\n          const right = 2*i+2;\n          out += 'i=' + i + ' value=' + arr[i];\n          out += (parent >=0 ? (' parent=' + parent) : ' root');\n          if (left < arr.length) out += ' left=' + left;\n          if (right < arr.length) out += ' right=' + right;\n          out += '\\\\n';\n        }\n        return out;\n      }\n\n      // Trace building\n      function cloneArray(a) { return a.slice(); }\n\n      function buildTrace(arr, options) {\n        // Returns history of snapshots.\n        const n = arr.length;\n        let A = cloneArray(arr);\n        const hist = [];\n        compareCount = 0;\n        swapCount = 0;\n        const recCompares = options.recordCompares;\n        const granularity = options.granularity; // 'swap','compare','call'\n        const isMax = options.heapType === 'max';\n\n        function pushState(action, info) {\n          // info: {highlight:[], heapSize:..., pseudoLine:..., description:...}\n          hist.push({\n            array: cloneArray(A),\n            action: action,\n            highlight: info && info.highlight ? info.highlight.slice() : [],\n            heapSize: typeof info.heapSize === 'number' ? info.heapSize : A.length,\n            description: info && info.description ? info.description : '',\n            pseudo: typeof info.pseudoLine==='number'?info.pseudoLine:null,\n            compares: compareCount,\n            swaps: swapCount\n          });\n        }\n\n        // initial state\n        pushState('start', {highlight:[], heapSize: n, description: 'start', pseudo:0});\n\n        function left(i){ return 2*i+1; }\n        function right(i){ return 2*i+2; }\n\n        // heapify iterative for recording control\n        function heapify(i, heapSizeLocal) {\n          pushState('heapify-call', {highlight:[i], heapSize: heapSizeLocal, description: 'heapify call at index ' + i, pseudo: isMax ? 7 : 7});\n          if (granularity === 'call') {\n            // record the start of the call then perform without recording internal compares/swaps\n            // but we'll still increment counts\n            let idx = i;\n            while(true) {\n              let l = left(idx), r = right(idx);\n              let chosen = idx;\n              if (l < heapSizeLocal) {\n                compareCount++;\n                if ((isMax && A[l] > A[chosen]) || (!isMax && A[l] < A[chosen])) {\n                  chosen = l;\n                }\n              }\n              if (r < heapSizeLocal) {\n                compareCount++;\n                if ((isMax && A[r] > A[chosen]) || (!isMax && A[r] < A[chosen])) {\n                  chosen = r;\n                }\n              }\n              if (chosen !== idx) {\n                swapCount++;\n                const t = A[idx]; A[idx] = A[chosen]; A[chosen] = t;\n                idx = chosen;\n              } else {\n                break;\n              }\n            }\n            pushState('heapify-return', {highlight:[], heapSize: heapSizeLocal, description: 'heapify finished at index ' + i, pseudo: isMax ? 14 : 14});\n            return;\n          }\n\n          // otherwise record internal steps\n          let idx = i;\n          while(true) {\n            let l = left(idx), r = right(idx);\n            let chosen = idx;\n            if (l < heapSizeLocal) {\n              compareCount++;\n              pushState('compare', {highlight:[idx,l], heapSize: heapSizeLocal, description: 'compare A['+l+'] with A['+chosen+']', pseudo: isMax ? 10 : 10});\n              if ((isMax && A[l] > A[chosen]) || (!isMax && A[l] < A[chosen])) {\n                chosen = l;\n                pushState('select', {highlight:[idx,l], heapSize: heapSizeLocal, description: 'selected '+l, pseudo: isMax ? 10 : 10});\n              }\n            }\n            if (r < heapSizeLocal) {\n              compareCount++;\n              pushState('compare', {highlight:[idx,r], heapSize: heapSizeLocal, description: 'compare A['+r+'] with A['+chosen+']', pseudo: isMax ? 11 : 11});\n              if ((isMax && A[r] > A[chosen]) || (!isMax && A[r] < A[chosen])) {\n                chosen = r;\n                pushState('select', {highlight:[idx,r], heapSize: heapSizeLocal, description: 'selected '+r, pseudo: isMax ? 11 : 11});\n              }\n            }\n            if (chosen !== idx) {\n              // swap\n              swapCount++;\n              pushState('swap', {highlight:[idx,chosen], heapSize: heapSizeLocal, description: 'swap A['+idx+'] and A['+chosen+']', pseudo: isMax ? 13 : 13});\n              const t = A[idx]; A[idx] = A[chosen]; A[chosen] = t;\n              pushState('after-swap', {highlight:[idx,chosen], heapSize: heapSizeLocal, description: 'after swap', pseudo: isMax ? 14 : 14});\n              idx = chosen;\n            } else {\n              pushState('heapify-done', {highlight:[idx], heapSize: heapSizeLocal, description: 'heapify done', pseudo: isMax ? 14 : 14});\n              break;\n            }\n          }\n        }\n\n        // build heap\n        pushState('build-start', {description: 'build heap start', heapSize: n, pseudo:1});\n        for (let i = Math.floor(n/2)-1; i >= 0; i--) {\n          heapify(i, n);\n        }\n        pushState('build-end', {description: 'build heap end', heapSize:n, pseudo:1});\n\n        // main sort loop\n        let heapSizeLocal = n;\n        for (let i = n-1; i >= 1; i--) {\n          // swap root with A[i]\n          swapCount++;\n          pushState('pre-swap-root', {highlight:[0,i], heapSize:heapSizeLocal, description: 'swap root with A['+i+']', pseudo:3});\n          const t = A[0]; A[0] = A[i]; A[i] = t;\n          pushState('post-swap-root', {highlight:[i], heapSize:heapSizeLocal, description: 'moved max to position '+i, pseudo:3});\n          heapSizeLocal--;\n          pushState('heap-reduce', {heapSize: heapSizeLocal, description: 'heap size reduced', pseudo:4});\n          heapify(0, heapSizeLocal);\n        }\n        pushState('sorted', {description: 'sorted complete', heapSize: 0, pseudo:0});\n        return hist;\n      }\n\n      // Render snapshot\n      function renderSnapshot(stepIndex) {\n        if (!history || history.length === 0) {\n          curAction.textContent = '-';\n          curHeapSize.textContent = '-';\n          curCompares.textContent = '0';\n          curSwaps.textContent = '0';\n          renderArrayView(baseArray);\n          treeViewEl.textContent = buildTreeText(baseArray);\n          logEl.innerHTML = '';\n          stepInfo.textContent = '0 / 0';\n          stepSlider.max = 0;\n          stepSlider.value = 0;\n          renderPseudocode(null);\n          return;\n        }\n        const s = history[stepIndex];\n        renderArrayView(s.array, s.highlight || [], s.heapSize, findSortedStartIndex(s));\n        curAction.textContent = s.description || s.action;\n        curHeapSize.textContent = s.heapSize;\n        curCompares.textContent = s.compares;\n        curSwaps.textContent = s.swaps;\n        treeViewEl.textContent = buildTreeText(s.array);\n        // pseudocode highlight\n        renderPseudocode(s.pseudo);\n        // log - render a few around current\n        renderLog(stepIndex);\n        // slider\n        stepInfo.textContent = (stepIndex) + ' / ' + (history.length - 1);\n        stepSlider.max = Math.max(0, history.length - 1);\n        stepSlider.value = stepIndex;\n      }\n\n      function findSortedStartIndex(snapshot) {\n        // Heuristic: sorted region is suffix where elements were moved to final positions.\n        // We can approximate by checking decreasing heapSize: sortedFrom = heapSize\n        if (!snapshot) return null;\n        return snapshot.heapSize;\n      }\n\n      // Log rendering\n      function renderLog(current) {\n        logEl.innerHTML = '';\n        for (let i=0;i<history.length;i++){\n          const item = history[i];\n          const line = document.createElement('div');\n          line.textContent = i + ': ' + (item.description || item.action) + ' (cmp:' + item.compares + ' sw:' + item.swaps + ')';\n          line.style.cursor = 'pointer';\n          if (i === current) line.style.fontWeight = 'bold';\n          (function(idx){\n            line.addEventListener('click', ()=> {\n              pauseAuto();\n              currentStep = idx;\n              renderSnapshot(currentStep);\n            });\n          })(i);\n          logEl.appendChild(line);\n        }\n      }\n\n      // playback controls\n      function stepForward() {\n        if (!history || !history.length) return;\n        if (currentStep < history.length - 1) {\n          currentStep++;\n          renderSnapshot(currentStep);\n        }\n      }\n      function stepBackward() {\n        if (!history || !history.length) return;\n        if (currentStep > 0) {\n          currentStep--;\n          renderSnapshot(currentStep);\n        }\n      }\n\n      function stepForwardAuto() {\n        if (!history || !history.length) return;\n        if (currentStep < history.length - 1) {\n          currentStep++;\n          renderSnapshot(currentStep);\n        } else {\n          pauseAuto();\n        }\n      }\n\n      function playAuto() {\n        if (playInterval) return;\n        playInterval = setInterval(stepForwardAuto, parseInt(speedEl.value, 10));\n      }\n      function pauseAuto() {\n        if (playInterval) {\n          clearInterval(playInterval);\n          playInterval = null;\n        }\n      }\n\n      // Build trace button handler\n      buildTraceBtn.addEventListener('click', ()=> {\n        if (!baseArray || !baseArray.length) {\n          alert('Array is empty. Generate or set an array first.');\n          return;\n        }\n        setPseudocode();\n        const options = {\n          recordCompares: recordComparesEl.checked,\n          granularity: granularityEl.value,\n          heapType: heapTypeEl.value\n        };\n        // build the trace (this could be heavy but acceptable)\n        history = buildTrace(baseArray, options);\n        currentStep = 0;\n        built = true;\n        renderSnapshot(currentStep);\n        traceJsonContent.textContent = JSON.stringify(history, null, 2);\n      });\n\n      // other UI hook ups\n      randBtn.addEventListener('click', generateRandomArray);\n      setCustom.addEventListener('click', setArrayFromText);\n      clearArray.addEventListener('click', ()=> { baseArray = []; renderArrayView(baseArray); built = false; });\n      incBtn.addEventListener('click', setIncreasing);\n      decBtn.addEventListener('click', setDecreasing);\n\n      playBtn.addEventListener('click', ()=> { playAuto(); });\n      pauseBtn.addEventListener('click', ()=> { pauseAuto(); });\n      stepFwdBtn.addEventListener('click', ()=> { pauseAuto(); stepForward(); });\n      stepBackBtn.addEventListener('click', ()=> { pauseAuto(); stepBackward(); });\n      goStartBtn.addEventListener('click', ()=> { pauseAuto(); currentStep = 0; renderSnapshot(currentStep); });\n      goEndBtn.addEventListener('click', ()=> { pauseAuto(); if (history && history.length) currentStep = history.length-1; renderSnapshot(currentStep); });\n\n      stepSlider.addEventListener('input', ()=> {\n        pauseAuto();\n        const v = parseInt(stepSlider.value, 10);\n        currentStep = v;\n        renderSnapshot(currentStep);\n      });\n\n      exportBtn.addEventListener('click', ()=> {\n        if (!history || !history.length) {\n          alert('No trace to export. Build trace first.');\n          return;\n        }\n        const blob = new Blob([JSON.stringify(history)], {type: 'application/json'});\n        const url = URL.createObjectURL(blob);\n        const a = document.createElement('a');\n        a.href = url;\n        a.download = 'heap_trace.json';\n        a.click();\n        URL.revokeObjectURL(url);\n      });\n\n      importBtn.addEventListener('click', ()=> {\n        importData.click();\n      });\n\n      importData.addEventListener('change', (ev)=> {\n        const file = ev.target.files[0];\n        if (!file) return;\n        const reader = new FileReader();\n        reader.onload = function(e) {\n          try {\n            const imported = JSON.parse(e.target.result);\n            if (!Array.isArray(imported)) throw new Error('Invalid trace format');\n            history = imported;\n            currentStep = 0;\n            built = true;\n            renderSnapshot(currentStep);\n            traceJsonContent.textContent = JSON.stringify(history, null, 2);\n          } catch (err) {\n            alert('Error importing trace: ' + err.message);\n          }\n        };\n        reader.readAsText(file);\n      });\n\n      toggleTraceView.addEventListener('click', ()=> {\n        if (traceJson.style.display === 'none') {\n          traceJson.style.display = 'block';\n        } else {\n          traceJson.style.display = 'none';\n        }\n      });\n\n      // keyboard shortcuts\n      document.addEventListener('keydown', (e)=> {\n        if (e.key === ' ') {\n          e.preventDefault();\n          if (playInterval) pauseAuto(); else playAuto();\n        } else if (e.key === 'ArrowRight') {\n          pauseAuto(); stepForward();\n        } else if (e.key === 'ArrowLeft') {\n          pauseAuto(); stepBackward();\n        }\n      });\n\n      // initial render\n      generateRandomArray();\n      setPseudocode();\n      renderSnapshot(0);\n\n      // Helper: allow to rebuild automatically if user edits baseArray after trace built\n      // Provide a minimal hot-rebuild: if built and baseArray changed then disable built flag\n      // Already set built=false in edit functions.\n\n      // Extra feature: allow double-click trace log to copy snapshot\n      logEl.addEventListener('dblclick', ()=> {\n        if (!history || !history.length) return;\n        const snapshot = history[currentStep];\n        const txt = JSON.stringify(snapshot.array);\n        navigator.clipboard && navigator.clipboard.writeText(txt);\n        alert('Array copied to clipboard: ' + txt);\n      });\n\n      // expose some debug functions for advanced exploration (user can type in console)\n      window.hs_debug = {\n        setArray: (arr) => { baseArray = arr.slice(); renderArrayView(baseArray); built=false; },\n        build: () => buildTraceBtn.click(),\n        play: () => playBtn.click(),\n        pause: () => pauseBtn.click(),\n        history: () => history\n      };\n\n    })();\n  </script>\n</body>\n</html>"
