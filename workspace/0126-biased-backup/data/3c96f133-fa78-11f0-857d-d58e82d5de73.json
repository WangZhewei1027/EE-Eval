    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Counting Sort Visualization — Aesthetic Demo</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700&family=JetBrains+Mono&display=swap');\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n    user-select: none;\n  }\n  body, html {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    color: #e0e6f0;\n    overflow: hidden;\n  }\n  /* Container */\n  .container {\n    max-width: 960px;\n    margin: 2.5rem auto 3rem;\n    padding: 0 1rem;\n  }\n  header {\n    text-align: center;\n    margin-bottom: 1.5rem;\n  }\n  header h1 {\n    font-weight: 700;\n    font-size: 3.2rem;\n    letter-spacing: 0.1em;\n    color: #ff897d;\n    text-shadow:\n      0 0 8px #ff897daa,\n      0 0 20px #ff5043cc,\n      0 0 30px #ff3022dd;\n    margin-bottom: 0.2rem;\n    user-select: none;\n  }\n  header p {\n    font-weight: 400;\n    font-style: italic;\n    font-size: 1.1rem;\n    color: #abc4ffdd;\n    letter-spacing: 0.05em;\n  }\n  /* Sort panel */\n  #visualizer {\n    background: #16292fdd;\n    border-radius: 24px;\n    box-shadow:\n      inset 0 0 60px 8px #1a3a4fcc,\n      0 0 40px 6px #ff584d88;\n    padding: 2rem 2.5rem 3rem;\n    display: flex;\n    flex-direction: column;\n    gap: 3.2rem;\n  }\n  /* Step labels */\n  .step-title {\n    font-weight: 700;\n    color: #ffaea3;\n    font-size: 1.3rem;\n    letter-spacing: 0.1em;\n    user-select: none;\n    margin-bottom: 1rem;\n    text-shadow:\n      0 0 5px #ffaea388,\n      0 0 15px #ff6a5bbb;\n  }\n  /* Number arrays container */\n  .array-row {\n    width: 100%;\n    display: flex;\n    justify-content: center;\n    gap: 0.8rem;\n  }\n  /* Individual array item */\n  .array-item {\n    flex: 1 1 0;\n    max-width: 40px;\n    height: 56px;\n    background: linear-gradient(145deg, #41607f, #344a5c);\n    box-shadow:\n      0 4px 8px rgba(0,0,0,0.35),\n      inset 0 0 14px #71a8c0aa;\n    border-radius: 12px;\n    color: #bbd7f8ee;\n    font-weight: 700;\n    font-size: 1.4rem;\n    line-height: 56px;\n    text-align: center;\n    transition: background 0.45s ease, color 0.45s ease, box-shadow 0.45s ease;\n    position: relative;\n    user-select: none;\n  }\n  .array-item.highlight {\n    background: linear-gradient(135deg, #ff5f66, #ff9a8b);\n    box-shadow:\n      0 0 24px 3px #ff7f70cc,\n      inset 0 14px 36px -6px #ff7f70dd;\n    color: #ffe6e2;\n    z-index: 10;\n    transform: scale(1.25);\n    transition: all 0.35s cubic-bezier(0.645, 0.045, 0.355, 1);\n  }\n  /* Counting bars container */\n  .count-bars {\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n  }\n  .count-bar-wrapper {\n    flex: 1 1 0;\n    max-width: 48px;\n    position: relative;\n  }\n  .count-bar {\n    background: linear-gradient(145deg, #4998c2, #297ab8);\n    border-radius: 16px;\n    box-shadow:\n      0 0 15px #3e81b1aa inset,\n      0 0 16px #6ca7db88;\n    width: 100%;\n    height: 0;\n    transition: height 0.45s cubic-bezier(0.77, 0, 0.175, 1), box-shadow 0.45s ease;\n    border-bottom-left-radius: 0;\n    border-bottom-right-radius: 0;\n    transform-origin: bottom;\n  }\n  .count-bar.highlight {\n    background: linear-gradient(180deg, #ff678e, #ff3850);\n    box-shadow:\n      0 0 22px #ff4356cc inset,\n      0 0 28px 6px #ff678ecc;\n    border-bottom-left-radius: 24px;\n    border-bottom-right-radius: 24px;\n  }\n  .count-label {\n    margin-top: 0.45rem;\n    color: #a2c7f2cc;\n    text-align: center;\n    font-weight: 600;\n    font-size: 0.95rem;\n    user-select: none;\n    letter-spacing: 0.03em;\n  }\n  /* Output row (sorted) */\n  #output-row {\n    justify-content: center;\n    gap: 1rem;\n  }\n  .output-item {\n    width: 48px;\n    height: 48px;\n    background: linear-gradient(145deg, #5781a6, #3c596f);\n    border-radius: 14px;\n    box-shadow:\n      0 8px 16px rgba(130, 160, 190, 0.4),\n      inset 0 4px 11px #8ab9e5cc;\n    color: #d1e5ffcc;\n    font-weight: 700;\n    font-size: 1.5rem;\n    line-height: 48px;\n    text-align: center;\n    user-select: none;\n    opacity: 0;\n    transform: translateY(18px);\n    transition: all 0.45s cubic-bezier(0.56, 0.04, 0.41, 0.99);\n  }\n  .output-item.show {\n    opacity: 1;\n    transform: translateY(0);\n  }\n  /* Controls */\n  .controls {\n    margin-top: 2rem;\n    text-align: center;\n  }\n  button {\n    background: linear-gradient(135deg, #ee7752, #e73c7e);\n    border: none;\n    padding: 0.85rem 2.1rem;\n    font-size: 1.3rem;\n    font-weight: 700;\n    color: white;\n    border-radius: 36px;\n    cursor: pointer;\n    text-shadow: 0 0 5px rgba(255, 110, 110, 0.95);\n    box-shadow:\n      0 6px 14px #d04166bb,\n      inset 0 -3px 8px #fa779bcc;\n    transition:\n      background 0.5s ease,\n      box-shadow 0.5s ease,\n      transform 0.2s ease;\n  }\n  button:hover {\n    background: linear-gradient(135deg, #eb4a67, #d71e63);\n    box-shadow:\n      0 6px 18px #ff5672cc,\n      inset 0 -5px 14px #ff7a9ccc;\n    transform: scale(1.06);\n  }\n  button:active {\n    transform: scale(0.95);\n    box-shadow:\n      0 3px 10px #ba3260cc,\n      inset 0 -2px 5px #dd5577cc;\n  }\n  /* Footer */\n  footer {\n    text-align: center;\n    color: #789cc5d8;\n    font-size: 0.87rem;\n    user-select: none;\n    letter-spacing: 0.05em;\n    margin-top: 5rem;\n    font-family: 'JetBrains Mono', monospace;\n  }\n  /* Scrollbar small styling */\n  ::-webkit-scrollbar {\n    width: 7px;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #647eafaa;\n    border-radius: 10px;\n  }\n</style>\n</head>\n<body>\n<main class=\"container\" aria-label=\"Counting Sort Visualization\">\n  <header>\n    <h1>Counting Sort</h1>\n    <p>Stable, Efficient Sorting Algorithm Visualized</p>\n  </header>\n  <section id=\"visualizer\" role=\"main\" aria-live=\"polite\" aria-atomic=\"true\">\n    <!-- Input Array -->\n    <div>\n      <div class=\"step-title\">1. Input Array</div>\n      <div id=\"input-row\" class=\"array-row\" aria-label=\"Input unsorted array\"></div>\n    </div>\n    <!-- Counting Process -->\n    <div>\n      <div class=\"step-title\">2. Counting Frequencies</div>\n      <div id=\"count-bars\" class=\"count-bars\" aria-label=\"Counting frequency bars\"></div>\n    </div>\n    <!-- Accumulated Count -->\n    <div>\n      <div class=\"step-title\">3. Accumulated Counts</div>\n      <div id=\"accumulated-bars\" class=\"count-bars\" aria-label=\"Accumulated frequency bars\"></div>\n    </div>\n    <!-- Output Array -->\n    <div>\n      <div class=\"step-title\">4. Output Sorted Array</div>\n      <div id=\"output-row\" class=\"array-row\" aria-label=\"Output sorted array\"></div>\n    </div>\n  </section>\n  <div class=\"controls\">\n    <button id=\"start-btn\" aria-label=\"Start Animation\">Start Sorting Animation</button>\n  </div>\n  <footer>\n    &copy; 2024 &mdash; Visual Demo by AI\n  </footer>\n</main>\n\n<script>\n  (() => {\n    // Data: Input array of integers 0-9 (small range for counting sort)\n    const inputArray = [3, 6, 4, 1, 7, 2, 5, 2, 0, 4, 6, 3, 7, 5];\n    const maxValue = 9; // max integer value considered\n    const delay = 650; // delay between animation steps (ms)\n\n    // Reference to DOM containers\n    const inputRow = document.getElementById('input-row');\n    const countBars = document.getElementById('count-bars');\n    const accBars = document.getElementById('accumulated-bars');\n    const outputRow = document.getElementById('output-row');\n    const startBtn = document.getElementById('start-btn');\n\n    // Utility to create array item elements for input/output\n    function createArrayItem(value) {\n      const el = document.createElement('div');\n      el.className = 'array-item';\n      el.textContent = value;\n      return el;\n    }\n    function createOutputItem(value) {\n      const el = document.createElement('div');\n      el.className = 'output-item';\n      el.textContent = value;\n      return el;\n    }\n    // Create count bar wrapper + column with label\n    function createCountBarWrapper(index) {\n      const wrapper = document.createElement('div');\n      wrapper.className = 'count-bar-wrapper';\n      wrapper.setAttribute('aria-label', 'Number ' + index + ' count bar');\n      const bar = document.createElement('div');\n      bar.className = 'count-bar';\n      bar.style.height = '0px';\n      const label = document.createElement('div');\n      label.className = 'count-label';\n      label.textContent = index;\n      wrapper.appendChild(bar);\n      wrapper.appendChild(label);\n      return {wrapper, bar};\n    }\n\n    // Initialize input array display\n    function initInput() {\n      inputRow.innerHTML = '';\n      for(const n of inputArray){\n        const item = createArrayItem(n);\n        inputRow.appendChild(item);\n      }\n    }\n    // Initialize count bars (freq and accumulated)\n    function initCountBars() {\n      countBars.innerHTML = '';\n      accBars.innerHTML = '';\n      for(let i=0; i <= maxValue; i++){\n        const c = createCountBarWrapper(i);\n        countBars.appendChild(c.wrapper);\n      }\n      for(let i=0; i <= maxValue; i++){\n        const c = createCountBarWrapper(i);\n        accBars.appendChild(c.wrapper);\n      }\n    }\n    // Animate function helpers\n    function sleep(ms){\n      return new Promise(res => setTimeout(res, ms));\n    }\n    // Set count bars heights with smooth transitions\n    function updateCountBars(countArray, container){\n      // countArray is integer counts\n      const maxCount = Math.max(...countArray, 1);\n      for(let i=0; i < countArray.length; i++){\n        const wrapper = container.children[i];\n        const bar = wrapper.querySelector('.count-bar');\n        const heightPct = (countArray[i]/maxCount)*120;\n        bar.style.height = heightPct + 'px';\n        // highlight bar if count > 0\n        if(countArray[i] > 0){\n          bar.classList.add('highlight');\n        } else {\n          bar.classList.remove('highlight');\n        }\n      }\n    }\n    // Clear all highlights\n    function clearHighlights(){\n      document.querySelectorAll('.array-item.highlight, .count-bar.highlight').forEach(el=>{\n        el.classList.remove('highlight');\n      });\n    }\n    // Core animation sequence\n    async function countingSortAnimation(){\n      startBtn.disabled = true;\n      // Step 1: Highlight input array values one by one as counted\n      clearHighlights();\n\n      // Frequency count array init\n      const count = Array(maxValue+1).fill(0);\n\n      // Show each input item highlight + count increment\n      for(let i=0; i < inputArray.length; i++){\n        clearHighlights();\n        const val = inputArray[i];\n        // Highlight current item\n        const inputItems = inputRow.children;\n        inputItems[i].classList.add('highlight');\n        // Increment count for value\n        count[val]++;\n        // Update count bars\n        updateCountBars(count, countBars);\n        await sleep(delay);\n      }\n      clearHighlights();\n\n      // Step 2: Show accumulated count (prefix sums)\n      let accumulated = count.slice();\n      for(let i=1; i <= maxValue; i++){\n        accumulated[i] += accumulated[i-1];\n      }\n      // Animate accumulated counts bar growing in\n      // Show zero highlight by default for animation\n      for(let i=0; i <= maxValue; i++){\n        const bar = accBars.children[i].querySelector('.count-bar');\n        bar.style.height = '0px';\n        bar.classList.remove('highlight');\n      }\n      await sleep(300);\n\n      // Animate accumulated bar heights increasing in steps\n      for(let i=0; i <= maxValue; i++){\n        clearHighlights();\n        accBars.children[i].querySelector('.count-bar').classList.add('highlight');\n        updateCountBars(accumulated, accBars);\n        await sleep(delay/1.4);\n      }\n      clearHighlights();\n\n      // Step 3: Place elements in output array in reverse order to maintain stability\n      outputRow.innerHTML = '';\n      for(let i=0; i < inputArray.length; i++){\n        const outputItem = createOutputItem('');\n        outputRow.appendChild(outputItem);\n      }\n\n      // Clone accumulated for placement index\n      const position = accumulated.slice();\n      // We place from right to left to maintain stability\n      for(let i=inputArray.length-1; i >= 0; i--){\n        const val = inputArray[i];\n        clearHighlights();\n        // Highlight input item & acc bar at val\n        inputRow.children[i].classList.add('highlight');\n        const accBar = accBars.children[val].querySelector('.count-bar');\n        accBar.classList.add('highlight');\n        // Decrement position for placing index\n        position[val]--;\n        const pos = position[val];\n        // Reveal output item at pos with value\n        const outputItem = outputRow.children[pos];\n        outputItem.textContent = val;\n        // Animate its showing\n        outputItem.classList.add('show');\n        await sleep(delay / 1.6);\n      }\n      clearHighlights();\n      startBtn.disabled = false;\n    }\n    // Initialization on page load\n    function init(){\n      initInput();\n      initCountBars();\n      outputRow.innerHTML = '';\n    }\n    init();\n\n    // Attach event handler\n    startBtn.addEventListener('click', () => {\n      countingSortAnimation();\n    });\n  })();\n</script>\n</body>\n</html>"
