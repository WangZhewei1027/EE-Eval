    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n        }\n\n        .bst-container {\n            max-width: 600px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .bst-header {\n            background-color: #333;\n            color: #fff;\n            padding: 10px;\n            border-bottom: 1px solid #ccc;\n        }\n\n        .bst-tree {\n            padding: 20px;\n        }\n\n        .bst-node {\n            background-color: #f7f7f7;\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .bst-node:hover {\n            background-color: #ddd;\n        }\n\n        .bst-node.selected {\n            background-color: #ccc;\n            color: #fff;\n        }\n\n        .bst-node.disabled {\n            background-color: #ccc;\n            color: #666;\n            cursor: not-allowed;\n        }\n\n        .bst-btn {\n            background-color: #333;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .bst-btn:hover {\n            background-color: #444;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"bst-container\">\n        <div class=\"bst-header\">Binary Search Tree</div>\n        <div class=\"bst-tree\">\n            <div class=\"bst-node\">\n                <span class=\"bst-node-text\">Node 1</span>\n                <span class=\"bst-node-value\">1</span>\n                <span class=\"bst-node-selected\"></span>\n                <span class=\"bst-node-disabled\"></span>\n            </div>\n            <div class=\"bst-node\">\n                <span class=\"bst-node-text\">Node 2</span>\n                <span class=\"bst-node-value\">2</span>\n                <span class=\"bst-node-selected\"></span>\n                <span class=\"bst-node-disabled\"></span>\n            </div>\n            <div class=\"bst-node\">\n                <span class=\"bst-node-text\">Node 3</span>\n                <span class=\"bst-node-value\">3</span>\n                <span class=\"bst-node-selected\"></span>\n                <span class=\"bst-node-disabled\"></span>\n            </div>\n        </div>\n        <div class=\"bst-btn\">Delete Node 1</div>\n        <div class=\"bst-btn\">Delete Node 2</div>\n        <div class=\"bst-btn\">Delete Node 3</div>\n    </div>\n\n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.selected = false;\n                this.disabled = false;\n            }\n        }\n\n        class BinarySearchTree {\n            constructor() {\n                this.root = null;\n            }\n\n            add(value) {\n                if (this.root === null) {\n                    this.root = new Node(value);\n                } else {\n                    this._addRecursive(this.root, value);\n                }\n            }\n\n            _addRecursive(node, value) {\n                if (value < node.value) {\n                    if (node.left === null) {\n                        node.left = new Node(value);\n                    } else {\n                        this._addRecursive(node.left, value);\n                    }\n                } else {\n                    if (node.right === null) {\n                        node.right = new Node(value);\n                    } else {\n                        this._addRecursive(node.right, value);\n                    }\n                }\n            }\n\n            _deleteRecursive(node, value) {\n                if (node === null) {\n                    return;\n                }\n                if (value < node.value) {\n                    if (node.left === null) {\n                        node.disabled = true;\n                    } else {\n                        this._deleteRecursive(node.left, value);\n                    }\n                } else if (value > node.value) {\n                    if (node.right === null) {\n                        node.disabled = true;\n                    } else {\n                        this._deleteRecursive(node.right, value);\n                    }\n                } else {\n                    if (node.disabled) {\n                        return;\n                    }\n                    if (node.left === null && node.right === null) {\n                        node.disabled = true;\n                    } else if (node.left === null) {\n                        node.disabled = true;\n                        node.value = null;\n                    } else if (node.right === null) {\n                        node.disabled = true;\n                        node.value = null;\n                    } else {\n                        let min = node.left;\n                        while (min.right !== null) {\n                            min = min.right;\n                        }\n                        min.disabled = true;\n                        node.value = min.value;\n                        node.left = null;\n                        node.right = null;\n                    }\n                }\n            }\n\n            deleteNode(value) {\n                this.root = this._deleteRecursive(this.root, value);\n            }\n\n            printTree() {\n                if (this.root === null) {\n                    return;\n                }\n                this._printRecursive(this.root);\n            }\n\n            _printRecursive(node) {\n                if (node !== null) {\n                    this._printRecursive(node.left);\n                    console.log(node.value);\n                    this._printRecursive(node.right);\n                }\n            }\n        }\n\n        let bst = new BinarySearchTree();\n        bst.add(5);\n        bst.add(3);\n        bst.add(7);\n        bst.add(2);\n        bst.add(4);\n        bst.add(6);\n        bst.add(8);\n\n        console.log(\"Before deleting Node 1:\");\n        bst.printTree();\n\n        bst.deleteNode(5);\n\n        console.log(\"After deleting Node 1:\");\n        bst.printTree();\n    </script>\n</body>\n</html>"
