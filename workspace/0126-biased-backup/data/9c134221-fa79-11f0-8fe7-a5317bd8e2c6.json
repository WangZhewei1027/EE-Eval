  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Set — Interactive Explorer</title>\n<style>\n/* Minimal CSS only to keep layout readable. No colors, no animations. */\nbody { font-family: sans-serif; margin: 12px; color: black; background: white; }\nbutton, input, select, textarea { font: inherit; }\n.card-button { width: 120px; height: 56px; white-space: pre-line; }\n.grid-table td { padding: 4px; vertical-align: top; }\n.small { font-size: 12px; }\n.controls { margin-bottom: 8px; }\n.panel { border: 1px solid #ccc; padding: 6px; margin-bottom: 8px; }\n.hidden { display: none; }\n</style>\n</head>\n<body>\n\n<h1>Set — Interactive Explorer</h1>\n\n<div class=\"controls panel\">\n  <div>\n    <button id=\"newGameBtn\">New Game (Seed)</button>\n    <input id=\"seedInput\" type=\"number\" placeholder=\"seed (optional)\" style=\"width:120px\">\n    <label>Start cards:\n      <input id=\"startCards\" type=\"number\" value=\"12\" min=\"3\" max=\"21\" style=\"width:60px\">\n    </label>\n    <label>Replace on set:\n      <input id=\"replaceOnSet\" type=\"checkbox\" checked>\n    </label>\n    <label>Auto-deal when no set:\n      <input id=\"autoDealWhenNoSet\" type=\"checkbox\" checked>\n    </label>\n    <label>Columns:\n      <input id=\"columns\" type=\"number\" value=\"4\" min=\"3\" max=\"7\" style=\"width:50px\">\n    </label>\n  </div>\n\n  <div style=\"margin-top:8px;\">\n    <button id=\"shuffleBtn\">Shuffle Deck</button>\n    <button id=\"deal3Btn\">Deal 3</button>\n    <button id=\"deal12Btn\">Deal 12</button>\n    <button id=\"clearSelectionsBtn\">Clear Selections</button>\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n    <label>Auto-play speed (ms):\n      <input id=\"autoPlaySpeed\" type=\"range\" min=\"100\" max=\"3000\" value=\"800\">\n      <span id=\"autoPlaySpeedLabel\">800</span>\n    </label>\n    <button id=\"autoPlayBtn\">Auto-remove sets</button>\n    <button id=\"stopAutoPlayBtn\" disabled>Stop Auto</button>\n  </div>\n\n  <div style=\"margin-top:8px;\">\n    <button id=\"findAllSetsBtn\">Find All Sets</button>\n    <button id=\"nextSetBtn\">Next Set</button>\n    <button id=\"prevSetBtn\">Prev Set</button>\n    <button id=\"hintBtn\">Hint (one card)</button>\n    <label>Hint level:\n      <select id=\"hintLevel\">\n        <option value=\"1\">Show one card of a set</option>\n        <option value=\"2\">Show two-card pair and missing card value</option>\n        <option value=\"3\">Highlight full set</option>\n      </select>\n    </label>\n    <button id=\"pairCompleteBtn\">Pair → Show third</button>\n  </div>\n\n  <div style=\"margin-top:8px;\">\n    <label>Monte Carlo trials:\n      <input id=\"mcTrials\" type=\"number\" value=\"1000\" min=\"10\" max=\"200000\" style=\"width:90px\">\n    </label>\n    <button id=\"runMcBtn\">Run Monte Carlo (probability table has set)</button>\n    <button id=\"stopMcBtn\" disabled>Stop MC</button>\n    <label>MC progress: <span id=\"mcProgress\">0/0</span></label>\n  </div>\n\n</div>\n\n<div class=\"panel\">\n  <div><strong>Game state</strong></div>\n  <div>Deck remaining: <span id=\"deckCount\">81</span></div>\n  <div>Cards on table: <span id=\"tableCount\">0</span></div>\n  <div>Selected: <span id=\"selectedCount\">0</span></div>\n  <div>Score: <span id=\"score\">0</span> | Streak: <span id=\"streak\">0</span> | Wrong tries: <span id=\"wrong\">0</span></div>\n  <div>Last action: <span id=\"lastAction\">---</span></div>\n  <div>Found sets on table: <span id=\"setsCount\">0</span></div>\n  <div>Mode: <span id=\"modeLabel\">Manual</span></div>\n</div>\n\n<div class=\"panel\">\n  <div><strong>Solver output / Controls</strong></div>\n  <div>\n    <button id=\"listAllSetsBtn\">List All Sets</button>\n    <button id=\"exportSetsBtn\">Export Sets JSON</button>\n    <button id=\"importSetsBtn\">Import & Filter Table (paste JSON)</button>\n    <textarea id=\"setsList\" rows=\"6\" style=\"width:100%\"></textarea>\n  </div>\n  <div style=\"margin-top:6px;\">\n    <label>Search table by attributes (use 1-3 or * for any). Order: number,shape,color,fill</label>\n    <input id=\"searchPattern\" type=\"text\" placeholder=\"e.g. 2,*,1,*\" style=\"width:240px\">\n    <button id=\"applySearchBtn\">Apply Filter (highlight matches)</button>\n    <button id=\"clearSearchBtn\">Clear Filter</button>\n  </div>\n</div>\n\n<div class=\"panel\">\n  <div><strong>Export / Import game state</strong></div>\n  <div>\n    <button id=\"exportStateBtn\">Export Game State (JSON)</button>\n    <button id=\"importStateBtn\">Import Game State (paste JSON)</button>\n    <textarea id=\"stateBox\" rows=\"6\" style=\"width:100%\"></textarea>\n  </div>\n</div>\n\n<div class=\"panel\">\n  <div><strong>Deck and card legend</strong></div>\n  <div class=\"small\">\n    Attributes order (left→right): number (1,2,3) • shape (O = oval, D = diamond, S = squiggle) • color (R = red, G = green, P = purple) • fill (F = solid, T = striped, O = open)\n    <br>\n    Card code example: \"2 D P T\" means number=2, shape=diamond, color=purple, fill=striped.\n  </div>\n</div>\n\n<div>\n  <strong>Cards on table (click to select/unselect)</strong>\n  <div id=\"cardsContainer\"></div>\n</div>\n\n<div class=\"panel\">\n  <div><strong>Log / History</strong></div>\n  <textarea id=\"log\" rows=\"8\" style=\"width:100%\" readonly></textarea>\n</div>\n\n<script>\n/*\n  Interactive Set game explorer.\n  - Standard Set deck: 4 attributes each with 3 values -> 81 unique cards.\n  - Rich controls: new game, shuffle, deal, solver, Monte Carlo, undo/redo, export/import, hints, auto-play.\n  - Visuals intentionally minimal.\n*/\n\n/* Utility helpers */\nfunction rng(seed) {\n  // simple seeded RNG (mulberry32)\n  let s = seed >>> 0;\n  return function() {\n    s += 0x6D2B79F5;\n    var t = Math.imul(s ^ s >>> 15, 1 | s);\n    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;\n    return ((t ^ t >>> 14) >>> 0) / 4294967296;\n  };\n}\n\nfunction shuffleArray(arr, seed) {\n  let random = seed == null ? Math.random : rng(seed);\n  for (let i = arr.length - 1; i > 0; i--) {\n    const j = Math.floor(random() * (i + 1));\n    [arr[i], arr[j]] = [arr[j], arr[i]];\n  }\n}\n\n/* Card representation */\nconst shapes = ['O', 'D', 'S']; // oval, diamond, squiggle\nconst colors = ['R', 'G', 'P']; // red, green, purple\nconst fills = ['F', 'T', 'O'];  // full/solid, striped, open\n\nfunction makeDeck() {\n  const deck = [];\n  for (let n = 1; n <= 3; n++) {\n    for (let s = 0; s < 3; s++) {\n      for (let c = 0; c < 3; c++) {\n        for (let f = 0; f < 3; f++) {\n          deck.push({n, s, c, f, id: `${n}${shapes[s]}${colors[c]}${fills[f]}`});\n        }\n      }\n    }\n  }\n  return deck;\n}\n\nfunction cardToText(card) {\n  return `${card.n} ${shapes[card.s]} ${colors[card.c]} ${fills[card.f]}`;\n}\n\nfunction clone(obj) {\n  return JSON.parse(JSON.stringify(obj));\n}\n\n/* Set rules */\nfunction thirdValue(a, b) {\n  if (a === b) return a;\n  // values are 0,1,2; third is the remaining one\n  return 0 ^ 1 ^ 2 ^ a ^ b;\n}\n\nfunction isSet(cards) {\n  if (!Array.isArray(cards) || cards.length !== 3) return false;\n  const [A, B, C] = cards;\n  return (\n    ((A.n === B.n && B.n === C.n) || (A.n !== B.n && A.n !== C.n && B.n !== C.n)) &&\n    ((A.s === B.s && B.s === C.s) || (A.s !== B.s && A.s !== C.s && B.s !== C.s)) &&\n    ((A.c === B.c && B.c === C.c) || (A.c !== B.c && A.c !== C.c && B.c !== C.c)) &&\n    ((A.f === B.f && B.f === C.f) || (A.f !== B.f && A.f !== C.f && B.f !== C.f))\n  );\n}\n\nfunction findSetsOnTable(table) {\n  const sets = [];\n  const n = table.length;\n  for (let i = 0; i < n - 2; i++) {\n    for (let j = i + 1; j < n - 1; j++) {\n      for (let k = j + 1; k < n; k++) {\n        if (isSet([table[i], table[j], table[k]])) {\n          sets.push([i, j, k]);\n        }\n      }\n    }\n  }\n  return sets;\n}\n\nfunction computeThirdFromTwo(a, b) {\n  // a and b are card objects\n  return {\n    n: (a.n === b.n ? a.n : (6 - (a.n + b.n))), // since n is 1..3, 1+2+3=6\n    s: thirdValue(a.s, b.s),\n    c: thirdValue(a.c, b.c),\n    f: thirdValue(a.f, b.f)\n  };\n}\n\n/* Game state */\nlet state = {\n  deck: [],\n  table: [],\n  selectedIndices: [],\n  score: 0,\n  streak: 0,\n  wrong: 0,\n  history: [], // for undo\n  future: [],  // redo\n  lastAction: '',\n  seed: null,\n  autoPlayTimer: null,\n  autoPlayRunning: false,\n  autoPlaySpeed: 800,\n  setsCache: []\n};\n\n/* DOM elements */\nconst cardsContainer = document.getElementById('cardsContainer');\nconst deckCountSpan = document.getElementById('deckCount');\nconst tableCountSpan = document.getElementById('tableCount');\nconst selectedCountSpan = document.getElementById('selectedCount');\nconst scoreSpan = document.getElementById('score');\nconst streakSpan = document.getElementById('streak');\nconst wrongSpan = document.getElementById('wrong');\nconst lastActionSpan = document.getElementById('lastAction');\nconst setsCountSpan = document.getElementById('setsCount');\nconst modeLabel = document.getElementById('modeLabel');\nconst logBox = document.getElementById('log');\nconst setsListBox = document.getElementById('setsList');\nconst stateBox = document.getElementById('stateBox');\nconst mcProgress = document.getElementById('mcProgress');\nconst autoPlaySpeedInput = document.getElementById('autoPlaySpeed');\nconst autoPlaySpeedLabel = document.getElementById('autoPlaySpeedLabel');\nconst stopAutoPlayBtn = document.getElementById('stopAutoPlayBtn');\n\n/* Initialization */\nfunction pushHistory(actionName) {\n  const snapshot = {\n    deck: clone(state.deck),\n    table: clone(state.table),\n    selectedIndices: clone(state.selectedIndices),\n    score: state.score,\n    streak: state.streak,\n    wrong: state.wrong,\n    lastAction: state.lastAction\n  };\n  state.history.push(snapshot);\n  // limit history size\n  if (state.history.length > 200) state.history.shift();\n  state.future = []; // clear redo\n  log(`Pushed history: ${actionName}`);\n}\n\nfunction undo() {\n  if (state.history.length === 0) return;\n  const snap = state.history.pop();\n  const redoSnap = {\n    deck: clone(state.deck),\n    table: clone(state.table),\n    selectedIndices: clone(state.selectedIndices),\n    score: state.score,\n    streak: state.streak,\n    wrong: state.wrong,\n    lastAction: state.lastAction\n  };\n  state.future.push(redoSnap);\n  state.deck = snap.deck;\n  state.table = snap.table;\n  state.selectedIndices = snap.selectedIndices;\n  state.score = snap.score;\n  state.streak = snap.streak;\n  state.wrong = snap.wrong;\n  state.lastAction = snap.lastAction;\n  updateUI();\n  log('Undo performed');\n}\n\nfunction redo() {\n  if (state.future.length === 0) return;\n  const snap = state.future.pop();\n  pushHistory('redo');\n  state.deck = snap.deck;\n  state.table = snap.table;\n  state.selectedIndices = snap.selectedIndices;\n  state.score = snap.score;\n  state.streak = snap.streak;\n  state.wrong = snap.wrong;\n  state.lastAction = snap.lastAction;\n  updateUI();\n  log('Redo performed');\n}\n\nfunction log(msg) {\n  const t = (new Date()).toLocaleTimeString();\n  logBox.value = `[${t}] ${msg}\\n` + logBox.value;\n}\n\nfunction updateUI() {\n  deckCountSpan.textContent = state.deck.length;\n  tableCountSpan.textContent = state.table.length;\n  selectedCountSpan.textContent = state.selectedIndices.length;\n  scoreSpan.textContent = state.score;\n  streakSpan.textContent = state.streak;\n  wrongSpan.textContent = state.wrong;\n  lastActionSpan.textContent = state.lastAction || '---';\n  setsCountSpan.textContent = state.setsCache.length;\n  modeLabel.textContent = state.autoPlayRunning ? 'Auto' : 'Manual';\n  renderTable();\n}\n\n/* Render table */\nfunction renderTable(highlight = {}) {\n  // highlight: { selected: Set(index), foundSet: [i,j,k], matches: Set(index), hint: Set(index) }\n  const cols = Math.max(3, Math.min(7, parseInt(document.getElementById('columns').value || 4, 10)));\n  const table = state.table;\n  const rows = Math.ceil(table.length / cols);\n  const tbl = document.createElement('table');\n  tbl.className = 'grid-table';\n  let idx = 0;\n  for (let r = 0; r < rows; r++) {\n    const tr = document.createElement('tr');\n    for (let c = 0; c < cols; c++) {\n      const td = document.createElement('td');\n      if (idx < table.length) {\n        const card = table[idx];\n        const btn = document.createElement('button');\n        btn.className = 'card-button';\n        btn.setAttribute('data-index', idx);\n        btn.textContent = cardToText(card);\n        // Minimal visual flags: we won't use color, but we can alter text labels with markers\n        let prefix = '';\n        if (state.selectedIndices.includes(idx)) prefix += '[S] ';\n        if (highlight.foundSet && highlight.foundSet.includes(idx)) prefix += '[SET] ';\n        if (highlight.matches && highlight.matches.has(idx)) prefix += '[M] ';\n        if (highlight.hint && highlight.hint.has(idx)) prefix += '[H] ';\n        btn.textContent = prefix + btn.textContent;\n        btn.onclick = () => onCardClick(idx);\n        td.appendChild(btn);\n      } else {\n        td.textContent = '';\n      }\n      tr.appendChild(td);\n      idx++;\n    }\n    tbl.appendChild(tr);\n  }\n  cardsContainer.innerHTML = '';\n  cardsContainer.appendChild(tbl);\n}\n\n/* Game actions */\nfunction newGame(seed = null, startCards = 12) {\n  pushHistory('newGame');\n  state.seed = seed != null ? Number(seed) : null;\n  state.deck = makeDeck();\n  if (seed != null && !isNaN(seed)) shuffleArray(state.deck, Number(seed));\n  else shuffleArray(state.deck, null);\n  state.table = [];\n  state.selectedIndices = [];\n  state.score = 0;\n  state.streak = 0;\n  state.wrong = 0;\n  state.lastAction = 'New game';\n  drawInitial(startCards);\n  state.setsCache = findSetsOnTable(state.table);\n  updateUI();\n  log(`New game started (seed=${state.seed})`);\n}\n\nfunction drawInitial(n) {\n  for (let i = 0; i < n && state.deck.length > 0; i++) {\n    state.table.push(state.deck.pop());\n  }\n}\n\nfunction shuffleDeck() {\n  pushHistory('shuffleDeck');\n  if (state.seed != null) shuffleArray(state.deck, state.seed + Math.floor(Math.random() * 1000));\n  else shuffleArray(state.deck, null);\n  state.lastAction = 'Deck shuffled';\n  updateUI();\n  log('Deck shuffled');\n}\n\nfunction deal3() {\n  pushHistory('deal3');\n  let added = 0;\n  for (let i = 0; i < 3 && state.deck.length > 0; i++) {\n    state.table.push(state.deck.pop());\n    added++;\n  }\n  state.lastAction = `Dealt ${added} card(s)`;\n  state.setsCache = findSetsOnTable(state.table);\n  updateUI();\n  log(`Dealt ${added} card(s)`);\n}\n\nfunction dealN(n) {\n  pushHistory('dealN');\n  let added = 0;\n  for (let i = 0; i < n && state.deck.length > 0; i++) {\n    state.table.push(state.deck.pop());\n    added++;\n  }\n  state.lastAction = `Dealt ${added} card(s)`;\n  state.setsCache = findSetsOnTable(state.table);\n  updateUI();\n  log(`Dealt ${added} card(s)`);\n}\n\nfunction onCardClick(index) {\n  // select/unselect\n  const sel = state.selectedIndices;\n  const pos = sel.indexOf(index);\n  if (pos >= 0) {\n    sel.splice(pos, 1);\n    state.lastAction = `Unselected card ${index}`;\n  } else {\n    sel.push(index);\n    state.lastAction = `Selected card ${index}`;\n  }\n  // if three are selected -> validate\n  if (sel.length === 3) {\n    const cards = sel.map(i => state.table[i]);\n    if (isSet(cards)) {\n      // valid set\n      pushHistory('removeSet');\n      state.score += 1;\n      state.streak += 1;\n      state.lastAction = `Removed set (${sel.join(',')})`;\n      // remove higher indices first\n      const removedIndices = sel.slice().sort((a,b)=>b-a);\n      const removedCards = [];\n      for (let idx of removedIndices) {\n        removedCards.push(state.table.splice(idx,1)[0]);\n      }\n      // replacement logic\n      if (document.getElementById('replaceOnSet').checked) {\n        for (let i = 0; i < removedIndices.length && state.deck.length > 0; i++) {\n          state.table.splice(removedIndices[i], 0, state.deck.pop());\n        }\n      }\n      state.selectedIndices = [];\n      state.setsCache = findSetsOnTable(state.table);\n      updateUI();\n      log(`Set removed. Score +1. Replaced? ${document.getElementById('replaceOnSet').checked}`);\n      // After removing, optionally auto-deal if no set and option enabled\n      if (state.setsCache.length === 0 && document.getElementById('autoDealWhenNoSet').checked) {\n        deal3();\n      }\n    } else {\n      // wrong\n      pushHistory('wrongTry');\n      state.wrong += 1;\n      state.streak = 0;\n      state.lastAction = `Wrong set attempt (${sel.join(',')})`;\n      state.selectedIndices = [];\n      updateUI();\n      log('Wrong attempt. Penalty recorded.');\n    }\n  } else {\n    updateUI();\n  }\n}\n\n/* Solver functions */\nlet solverIndex = 0;\nfunction findAllSets() {\n  state.setsCache = findSetsOnTable(state.table);\n  solverIndex = 0;\n  updateUI();\n  log(`Found ${state.setsCache.length} set(s)`);\n  return state.setsCache;\n}\n\nfunction listAllSets() {\n  const sets = findAllSets();\n  const lines = sets.map((s, idx) => {\n    const txt = s.map(i => cardToText(state.table[i])).join(' | ');\n    return `${idx+1}. (${s.join(',')}) -> ${txt}`;\n  });\n  setsListBox.value = lines.join('\\n');\n}\n\nfunction showNextSet() {\n  if (state.setsCache.length === 0) findAllSets();\n  if (state.setsCache.length === 0) {\n    log('No sets to show.');\n    return;\n  }\n  solverIndex = (solverIndex + 1) % state.setsCache.length;\n  const setIdx = solverIndex;\n  const trio = state.setsCache[setIdx];\n  renderTable({ foundSet: trio });\n  log(`Showing set ${setIdx+1} of ${state.setsCache.length}: indices ${trio.join(',')}`);\n}\n\nfunction showPrevSet() {\n  if (state.setsCache.length === 0) findAllSets();\n  if (state.setsCache.length === 0) {\n    log('No sets to show.');\n    return;\n  }\n  solverIndex = (solverIndex - 1 + state.setsCache.length) % state.setsCache.length;\n  const setIdx = solverIndex;\n  const trio = state.setsCache[setIdx];\n  renderTable({ foundSet: trio });\n  log(`Showing set ${setIdx+1} of ${state.setsCache.length}: indices ${trio.join(',')}`);\n}\n\nfunction hintOneCard() {\n  if (state.setsCache.length === 0) findAllSets();\n  if (state.setsCache.length === 0) {\n    log('No sets available for hint.');\n    return;\n  }\n  const trio = state.setsCache[0];\n  // reveal one card: choose the first index that is not selected\n  const hintSet = new Set([trio[0]]); // show first card\n  renderTable({ foundSet: [], hint: hintSet });\n  log(`Hint: one card at index ${trio[0]}`);\n}\n\nfunction pairComplete() {\n  if (state.selectedIndices.length !== 2) {\n    log('Select exactly two cards for pair completion.');\n    return;\n  }\n  const a = state.table[state.selectedIndices[0]];\n  const b = state.table[state.selectedIndices[1]];\n  const third = computeThirdFromTwo(a, b);\n  // find third on table\n  let found = -1;\n  for (let i = 0; i < state.table.length; i++) {\n    const c = state.table[i];\n    if (c.n === third.n && c.s === third.s && c.c === third.c && c.f === third.f) {\n      found = i; break;\n    }\n  }\n  if (found >= 0) {\n    renderTable({ hint: new Set([found]), matches: new Set([state.selectedIndices[0], state.selectedIndices[1], found]) });\n    log(`Third card found at index ${found} (${cardToText(state.table[found])})`);\n  } else {\n    log(`No matching third card on table. The third would be: ${third.n} ${shapes[third.s]} ${colors[third.c]} ${fills[third.f]}`);\n  }\n}\n\n/* Auto-play removal */\nfunction startAutoPlay() {\n  if (state.autoPlayRunning) return;\n  state.autoPlayRunning = true;\n  document.getElementById('autoPlayBtn').disabled = true;\n  stopAutoPlayBtn.disabled = false;\n  modeLabel.textContent = 'Auto';\n  log('Auto-play started');\n  function step() {\n    if (!state.autoPlayRunning) return;\n    state.setsCache = findSetsOnTable(state.table);\n    if (state.setsCache.length === 0) {\n      if (document.getElementById('autoDealWhenNoSet').checked && state.deck.length > 0) {\n        deal3();\n      } else {\n        log('No sets on table. Auto-play stopping.');\n        stopAutoPlay();\n        return;\n      }\n    }\n    // remove first set\n    state.setsCache = findSetsOnTable(state.table);\n    if (state.setsCache.length > 0) {\n      const trio = state.setsCache[0];\n      pushHistory('autoRemoveSet');\n      // remove by indices descending\n      for (let idx of trio.slice().sort((a,b)=>b-a)) {\n        state.table.splice(idx, 1);\n      }\n      // replace\n      if (document.getElementById('replaceOnSet').checked) {\n        for (let i = 0; i < 3 && state.deck.length > 0; i++) {\n          state.table.push(state.deck.pop());\n        }\n      }\n      state.score += 1;\n      state.streak += 1;\n      state.setsCache = findSetsOnTable(state.table);\n      state.lastAction = 'Auto removed a set';\n      updateUI();\n      log('Auto-removed a set');\n    } else {\n      log('No sets found this iteration.');\n    }\n    // schedule next\n    state.autoPlayTimer = setTimeout(step, Number(document.getElementById('autoPlaySpeed').value));\n  }\n  step();\n}\n\nfunction stopAutoPlay() {\n  state.autoPlayRunning = false;\n  if (state.autoPlayTimer) {\n    clearTimeout(state.autoPlayTimer);\n    state.autoPlayTimer = null;\n  }\n  document.getElementById('autoPlayBtn').disabled = false;\n  stopAutoPlayBtn.disabled = true;\n  modeLabel.textContent = 'Manual';\n  log('Auto-play stopped');\n}\n\n/* Monte Carlo simulation: probability that 12 random cards contain at least one set */\nlet mcRunning = false;\nfunction runMonteCarlo(trials) {\n  if (mcRunning) return;\n  mcRunning = true;\n  document.getElementById('runMcBtn').disabled = true;\n  document.getElementById('stopMcBtn').disabled = false;\n  mcProgress.textContent = `0/${trials}`;\n  let hits = 0;\n  let completed = 0;\n  const batch = 2000;\n  const baseDeck = makeDeck();\n  function iterationBatch() {\n    if (!mcRunning) return;\n    const limit = Math.min(batch, trials - completed);\n    for (let i = 0; i < limit; i++) {\n      // shuffle and pick first 12\n      shuffleArray(baseDeck, null);\n      const sample = baseDeck.slice(0, 12);\n      if (findSetsOnTable(sample).length > 0) hits++;\n    }\n    completed += limit;\n    mcProgress.textContent = `${completed}/${trials}`;\n    if (completed < trials) {\n      setTimeout(iterationBatch, 0);\n    } else {\n      mcRunning = false;\n      document.getElementById('runMcBtn').disabled = false;\n      document.getElementById('stopMcBtn').disabled = true;\n      mcProgress.textContent = `${completed}/${trials} — Probability ≈ ${(hits / trials).toFixed(5)} (${hits} hits)`;\n      log(`Monte Carlo completed: probability ≈ ${(hits / trials).toFixed(5)} from ${trials} trials`);\n    }\n  }\n  iterationBatch();\n}\n\nfunction stopMonteCarlo() {\n  mcRunning = false;\n  document.getElementById('runMcBtn').disabled = false;\n  document.getElementById('stopMcBtn').disabled = true;\n  log('Monte Carlo stopped by user');\n}\n\n/* Export / Import */\nfunction exportGameState() {\n  const exportObj = {\n    deck: state.deck,\n    table: state.table,\n    score: state.score,\n    streak: state.streak,\n    wrong: state.wrong,\n    lastAction: state.lastAction,\n    seed: state.seed\n  };\n  stateBox.value = JSON.stringify(exportObj, null, 2);\n  log('Game state exported to text box');\n}\n\nfunction importGameState() {\n  try {\n    const obj = JSON.parse(stateBox.value);\n    pushHistory('importState');\n    state.deck = obj.deck || [];\n    state.table = obj.table || [];\n    state.score = obj.score || 0;\n    state.streak = obj.streak || 0;\n    state.wrong = obj.wrong || 0;\n    state.lastAction = obj.lastAction || 'Imported';\n    state.seed = obj.seed || null;\n    state.setsCache = findSetsOnTable(state.table);\n    updateUI();\n    log('Game state imported');\n  } catch (e) {\n    log('Import failed: invalid JSON');\n  }\n}\n\n/* Export sets JSON */\nfunction exportSets() {\n  const sets = findAllSets().map(s => ({\n    indices: s,\n    cards: s.map(i => state.table[i])\n  }));\n  setsListBox.value = JSON.stringify(sets, null, 2);\n  log('Sets exported to box');\n}\n\n/* Import sets: attempt to re-build table from provided JSON array */\nfunction importSetsToFilter() {\n  try {\n    const obj = JSON.parse(setsListBox.value);\n    if (!Array.isArray(obj)) {\n      log('Import failed: expected array');\n      return;\n    }\n    // Attempt to interpret as list of sets: each element either indices or cards\n    // We'll gather unique cards and replace table with those cards\n    const cardMap = new Map();\n    for (let el of obj) {\n      if (el.indices) {\n        for (let idx of el.indices) {\n          const c = state.table[idx];\n          if (c) cardMap.set(c.id, c);\n        }\n      } else if (el.cards) {\n        for (let c of el.cards) {\n          cardMap.set(c.id, c);\n        }\n      } else if (el.id || el.n) {\n        // maybe direct card object\n        const key = el.id || `${el.n}${shapes[el.s]}${colors[el.c]}${fills[el.f]}`;\n        cardMap.set(key, el);\n      }\n    }\n    if (cardMap.size === 0) {\n      log('No usable cards found in import');\n      return;\n    }\n    pushHistory('importSetsToFilter');\n    state.table = Array.from(cardMap.values());\n    state.setsCache = findSetsOnTable(state.table);\n    updateUI();\n    log(`Imported ${state.table.length} unique cards into table`);\n  } catch (e) {\n    log('Import sets failed: JSON parse error');\n  }\n}\n\n/* Search table by pattern */\nfunction applySearchPattern() {\n  const pat = document.getElementById('searchPattern').value.trim();\n  if (!pat) {\n    log('Enter a search pattern like 2,*,1,*');\n    return;\n  }\n  const parts = pat.split(',').map(p => p.trim());\n  const matches = new Set();\n  for (let i = 0; i < state.table.length; i++) {\n    const c = state.table[i];\n    const vals = [String(c.n), shapes[c.s], colors[c.c], fills[c.f]];\n    let ok = true;\n    for (let j = 0; j < 4; j++) {\n      const q = parts[j] || '*';\n      if (q === '*') continue;\n      if (q.length === 1 && ['O','D','S','R','G','P','F','T','O'].includes(q)) {\n        if (vals[j] !== q) { ok = false; break; }\n      } else {\n        if (vals[j] !== q) { ok = false; break; }\n      }\n    }\n    if (ok) matches.add(i);\n  }\n  renderTable({ matches });\n  log(`Search pattern applied, matches: ${matches.size}`);\n}\n\nfunction clearSearch() {\n  renderTable({});\n  log('Search cleared');\n}\n\n/* Set up event listeners */\ndocument.getElementById('newGameBtn').addEventListener('click', () => {\n  const seedVal = document.getElementById('seedInput').value;\n  const startN = parseInt(document.getElementById('startCards').value, 10) || 12;\n  newGame(seedVal === '' ? null : Number(seedVal), startN);\n});\n\ndocument.getElementById('shuffleBtn').addEventListener('click', () => shuffleDeck());\ndocument.getElementById('deal3Btn').addEventListener('click', () => deal3());\ndocument.getElementById('deal12Btn').addEventListener('click', () => dealN(12));\ndocument.getElementById('clearSelectionsBtn').addEventListener('click', () => { state.selectedIndices = []; updateUI(); });\ndocument.getElementById('undoBtn').addEventListener('click', () => undo());\ndocument.getElementById('redoBtn').addEventListener('click', () => redo());\n\ndocument.getElementById('findAllSetsBtn').addEventListener('click', () => { findAllSets(); listAllSets(); });\ndocument.getElementById('listAllSetsBtn').addEventListener('click', () => listAllSets());\ndocument.getElementById('exportSetsBtn').addEventListener('click', () => exportSets());\ndocument.getElementById('importSetsBtn').addEventListener('click', () => importSetsToFilter());\ndocument.getElementById('nextSetBtn').addEventListener('click', () => showNextSet());\ndocument.getElementById('prevSetBtn').addEventListener('click', () => showPrevSet());\ndocument.getElementById('hintBtn').addEventListener('click', () => {\n  const level = document.getElementById('hintLevel').value;\n  if (level === '1') hintOneCard();\n  else if (level === '2') {\n    // show two cards and third description\n    if (state.setsCache.length === 0) findAllSets();\n    if (state.setsCache.length === 0) log('No sets for hint'); else {\n      const trio = state.setsCache[0];\n      const a = state.table[trio[0]], b = state.table[trio[1]];\n      const third = computeThirdFromTwo(a, b);\n      const hintSet = new Set([trio[0], trio[1]]);\n      renderTable({ matches: hintSet, hint: new Set([trio[0], trio[1]]) });\n      log(`Two-card hint: ${cardToText(a)} + ${cardToText(b)} -> third would be ${third.n} ${shapes[third.s]} ${colors[third.c]} ${fills[third.f]}`);\n    }\n  } else {\n    findAllSets();\n    if (state.setsCache.length === 0) log('No sets to highlight'); else {\n      renderTable({ foundSet: state.setsCache[0] });\n      log('Highlighted a full set');\n    }\n  }\n});\ndocument.getElementById('pairCompleteBtn').addEventListener('click', () => pairComplete());\n\ndocument.getElementById('autoPlayBtn').addEventListener('click', () => startAutoPlay());\nstopAutoPlayBtn.addEventListener('click', () => stopAutoPlay());\nautoPlaySpeedInput.addEventListener('input', () => {\n  autoPlaySpeedLabel.textContent = autoPlaySpeedInput.value;\n  state.autoPlaySpeed = Number(autoPlaySpeedInput.value);\n});\n\ndocument.getElementById('mcTrials').addEventListener('change', () => {\n  // noop\n});\ndocument.getElementById('runMcBtn').addEventListener('click', () => {\n  const t = Number(document.getElementById('mcTrials').value) || 1000;\n  runMonteCarlo(t);\n});\ndocument.getElementById('stopMcBtn').addEventListener('click', () => stopMonteCarlo());\n\ndocument.getElementById('exportStateBtn').addEventListener('click', () => exportGameState());\ndocument.getElementById('importStateBtn').addEventListener('click', () => importGameState());\n\ndocument.getElementById('applySearchBtn').addEventListener('click', () => applySearchPattern());\ndocument.getElementById('clearSearchBtn').addEventListener('click', () => clearSearch());\n\ndocument.getElementById('deal3Btn').addEventListener('dblclick', () => { dealN(3); });\ndocument.getElementById('columns').addEventListener('change', () => updateUI());\n\n/* Keyboard shortcuts */\ndocument.addEventListener('keydown', (e) => {\n  if (e.key === 'u' && (e.ctrlKey || e.metaKey)) { e.preventDefault(); undo(); }\n  if (e.key === 'r' && (e.ctrlKey || e.metaKey)) { e.preventDefault(); redo(); }\n  if (e.key === 'h') hintOneCard();\n  if (e.key === 'f') { findAllSets(); listAllSets(); }\n});\n\n/* Start a default new game */\nnewGame(null, 12);\n\n/* Additional exploration helpers: allow exporting current table to console, show pair-to-all mapping */\nfunction showPairToCompletion() {\n  const map = {};\n  for (let i = 0; i < state.table.length; i++) {\n    for (let j = i+1; j < state.table.length; j++) {\n      const third = computeThirdFromTwo(state.table[i], state.table[j]);\n      const key = `${i},${j}`;\n      // find if third exists on table\n      let found = -1;\n      for (let k = 0; k < state.table.length; k++) {\n        const c = state.table[k];\n        if (c.n === third.n && c.s === third.s && c.c === third.c && c.f === third.f) { found = k; break; }\n      }\n      map[key] = { third, found };\n    }\n  }\n  console.log('Pair -> completion map', map);\n  log('Pair-to-completion map logged to console');\n}\n\n/* Attach some utility buttons in log for advanced exploration */\nconst utilBtn = document.createElement('button');\nutilBtn.textContent = 'Log pair->completion (console)';\nutilBtn.addEventListener('click', showPairToCompletion);\ndocument.querySelector('.panel').appendChild(utilBtn);\n\n</script>\n\n</body>\n</html>"
