    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive SQL Explorer</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>Interactive SQL Explorer</h1>\n\n<div>\n    <label for=\"query\">SQL Query:</label>\n    <input type=\"text\" id=\"query\" placeholder=\"SELECT * FROM table_name\">\n    \n    <button onclick=\"executeQuery()\">Execute Query</button>\n</div>\n\n<div>\n    <label for=\"filter\">Filter Criteria:</label>\n    <input type=\"text\" id=\"filter\" placeholder=\"e.g., column_name=value\">\n\n    <button onclick=\"applyFilter()\">Apply Filter</button>\n</div>\n\n<div>\n    <label for=\"sort\">Sort By:</label>\n    <input type=\"text\" id=\"sort\" placeholder=\"e.g., column_name ASC|DESC\">\n\n    <button onclick=\"applySort()\">Apply Sort</button>\n</div>\n\n<div>\n    <label for=\"limit\">Limit:</label>\n    <input type=\"number\" id=\"limit\" placeholder=\"e.g., 10\">\n\n    <button onclick=\"applyLimit()\">Apply Limit</button>\n</div>\n\n<div>\n    <button onclick=\"resetFilters()\">Reset Filters</button>\n</div>\n\n<div id=\"output\"></div>\n\n<script>\n    let database = [\n        { id: 1, name: 'Alice', age: 30 },\n        { id: 2, name: 'Bob', age: 25 },\n        { id: 3, name: 'Charlie', age: 35 },\n        { id: 4, name: 'David', age: 40 }\n    ];\n\n    let filteredData = [...database];\n    let limit = null;\n    let currentQuery = \"\";\n\n    function executeQuery() {\n        currentQuery = document.getElementById('query').value;\n        updateOutput();\n    }\n\n    function applyFilter() {\n        const filterString = document.getElementById('filter').value;\n        const [key, value] = filterString.split('=');\n        filteredData = database.filter(item => item[key.trim()] == value.trim());\n        updateOutput();\n    }\n\n    function applySort() {\n        const sortString = document.getElementById('sort').value;\n        const [key, order] = sortString.split(' ');\n        filteredData.sort((a, b) => {\n            if (order.trim().toUpperCase() === 'ASC') return a[key.trim()] - b[key.trim()];\n            return b[key.trim()] - a[key.trim()];\n        });\n        updateOutput();\n    }\n\n    function applyLimit() {\n        limit = parseInt(document.getElementById('limit').value);\n        updateOutput();\n    }\n\n    function resetFilters() {\n        filteredData = [...database];\n        limit = null;\n        currentQuery = \"\";\n        document.getElementById('filter').value = '';\n        document.getElementById('sort').value = '';\n        document.getElementById('limit').value = '';\n        updateOutput();\n    }\n\n    function updateOutput() {\n        let resultData = currentQuery ? filteredData : database;\n        if (limit) {\n            resultData = resultData.slice(0, limit);\n        }\n        document.getElementById('output').innerText = JSON.stringify(resultData, null, 2);\n    }\n</script>\n\n</body>\n</html>"
  },
