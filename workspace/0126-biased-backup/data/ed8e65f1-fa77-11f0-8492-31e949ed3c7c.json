    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>NP-Completeness Visualized</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            padding: 0;\n            background-color: #282c34;\n            color: #f5f5f5;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n            animation: fadeIn 1s ease-in;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        h1 {\n            font-size: 2.5em;\n            margin-bottom: 0.5em;\n            text-align: center;\n            color: #61dafb;\n            animation: slideIn 0.5s ease-in;\n        }\n\n        @keyframes slideIn {\n            from { transform: translateY(-30px); opacity: 0; }\n            to { transform: translateY(0); opacity: 1; }\n        }\n\n        h2 {\n            font-size: 1.5em;\n            margin: 0.5em 0;\n            text-align: center;\n            color: #ffffff;\n        }\n\n        .canvas-container {\n            position: relative;\n            width: 80vw;\n            height: 60vh;\n            background-color: #20232a;\n            border-radius: 15px;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);\n            overflow: hidden;\n            animation: slideIn 0.75s ease-in;\n        }\n\n        canvas {\n            width: 100%;\n            height: 100%;\n        }\n\n        .button {\n            background-color: #61dafb;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            font-size: 1em;\n            padding: 10px 20px;\n            margin-top: 20px;\n            transition: background-color 0.3s;\n        }\n\n        .button:hover {\n            background-color: #21a1f1;\n            transform: scale(1.05);\n        }\n\n        .footer {\n            margin-top: auto;\n            padding: 10px;\n            font-size: 0.8em;\n            color: #777;\n            text-align: center;\n        }\n    </style>\n</head>\n<body>\n    <h1>Understanding NP-Completeness</h1>\n    <h2>Visualizing Complex Problems</h2>\n    \n    <div class=\"canvas-container\">\n        <canvas id=\"npCanvas\"></canvas>\n    </div>\n    \n    <button class=\"button\" id=\"startAnimation\">Start Animation</button>\n\n    <div class=\"footer\">Visual Design by OpenAI</div>\n    \n    <script>\n        const canvas = document.getElementById('npCanvas');\n        const ctx = canvas.getContext('2d');\n        canvas.width = canvas.clientWidth;\n        canvas.height = canvas.clientHeight;\n    \n        let animationId;\n        let phase = 0;\n\n        function draw() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            ctx.fillStyle = '#3b3f47';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n            const numPoints = 50;\n            const radius = 100;\n            const centerX = canvas.width / 2;\n            const centerY = canvas.height / 2;\n\n            ctx.fillStyle = '#61dafb';      \n            for(let i = 0; i < numPoints; i++) {\n                const angle = 2 * Math.PI * (i / numPoints + phase);\n                const x = centerX + radius * Math.cos(angle);\n                const y = centerY + radius * Math.sin(angle);\n                ctx.beginPath();\n                ctx.arc(x, y, 5, 0, Math.PI * 2);\n                ctx.fill();\n            }\n\n            phase += 0.01;\n            animationId = requestAnimationFrame(draw);\n        }\n\n        document.getElementById('startAnimation').addEventListener('click', () => {\n            if (!animationId) {\n                draw();\n            }\n        });\n    </script>\n</body>\n</html>"
