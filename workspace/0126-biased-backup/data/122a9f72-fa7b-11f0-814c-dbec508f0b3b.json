    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Circular Linked List</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        #input {\n            width: 100%;\n            height: 20px;\n            margin-bottom: 10px;\n            padding: 5px;\n            font-size: 16px;\n            border: none;\n            border-radius: 5px;\n        }\n        #button {\n            width: 100%;\n            height: 30px;\n            margin-bottom: 10px;\n            padding: 5px;\n            font-size: 16px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: #fff;\n            cursor: pointer;\n        }\n        #button:hover {\n            background-color: #3e8e41;\n        }\n        #output {\n            width: 100%;\n            height: 400px;\n            padding: 10px;\n            font-size: 16px;\n            overflow-y: auto;\n        }\n    </style>\n</head>\n<body>\n    <h1>Circular Linked List</h1>\n    <div id=\"input\"></div>\n    <div id=\"button\">\n        <button id=\"clear\">Clear</button>\n        <button id=\"append\">Append</button>\n        <button id=\"prev\">Prev</button>\n        <button id=\"next\">Next</button>\n    </div>\n    <div id=\"output\"></div>\n\n    <script>\n        let head = null;\n        let tail = null;\n        let headIndex = 0;\n        let tailIndex = 0;\n        let headSize = 0;\n\n        function append(value) {\n            const newNode = document.createElement('div');\n            newNode.textContent = value;\n            if (head == null) {\n                head = newNode;\n                headIndex = 0;\n            } else {\n                tail = newNode;\n                tailIndex = tailIndex + 1;\n                newNode.previous = tail;\n                tail.next = newNode;\n            }\n            headSize++;\n            updateOutput();\n        }\n\n        function prev() {\n            if (headIndex > 0) {\n                head = head.previous;\n                headIndex--;\n            }\n            updateOutput();\n        }\n\n        function next() {\n            if (tailIndex < headSize - 1) {\n                tail = tail.next;\n                tailIndex++;\n            }\n            updateOutput();\n        }\n\n        function clear() {\n            if (head != null) {\n                head = null;\n                headIndex = 0;\n                tail = null;\n                tailIndex = 0;\n                headSize = 0;\n            }\n            updateOutput();\n        }\n\n        function updateOutput() {\n            const output = document.getElementById('output');\n            output.innerHTML = '';\n            for (let i = 0; i < headSize; i++) {\n                if (i == 0) {\n                    output.appendChild(head);\n                } else {\n                    output.appendChild(head.next);\n                }\n            }\n        }\n\n        append(\"Head\");\n        append(\"Tail\");\n        append(\"Middle\");\n        append(\"End\");\n\n        const input = document.getElementById('input');\n        input.addEventListener('input', () => {\n            if (input.value.trim() != \"\") {\n                append(input.value.trim());\n            } else {\n                clear();\n            }\n        });\n\n        const button = document.getElementById('button');\n        button.addEventListener('click', () => {\n            if (button.id == 'clear') {\n                clear();\n            } else if (button.id == 'append') {\n                append(input.value.trim());\n            } else if (button.id == 'prev') {\n                prev();\n            } else if (button.id == 'next') {\n                next();\n            }\n        });\n    </script>\n</body>\n</html>"
