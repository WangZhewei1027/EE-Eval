    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Breadth-First Search Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #output {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Breadth-First Search (BFS) Interactive Demo</h1>\n    \n    <label for=\"nodes\">Enter number of nodes (0 to 20): </label>\n    <input type=\"number\" id=\"nodes\" min=\"0\" max=\"20\" value=\"5\"><br>\n    \n    <label for=\"edges\">Enter edges (format: u,v; etc.): </label>\n    <input type=\"text\" id=\"edges\" value=\"0,1; 0,2; 1,3; 1,4; 2,5\"><br>\n    \n    <label for=\"startNode\">Start Node (0 to 19): </label>\n    <input type=\"number\" id=\"startNode\" min=\"0\" max=\"19\" value=\"0\"><br>\n    \n    <button id=\"runBFS\">Run BFS</button>\n    \n    <h3>BFS Output:</h3>\n    <div id=\"output\"></div>\n    \n    <script>\n        document.getElementById('runBFS').onclick = function() {\n            const numNodes = parseInt(document.getElementById('nodes').value);\n            const edgesInput = document.getElementById('edges').value.split(\";\").map(e => e.trim());\n            const startNode = parseInt(document.getElementById('startNode').value);\n            const graph = Array.from({length: numNodes}, () => []);\n            \n            edgesInput.forEach(edge => {\n                const [u, v] = edge.split(\",\").map(Number);\n                if (u < numNodes && v < numNodes) {\n                    graph[u].push(v);\n                    graph[v].push(u); // Assuming undirected graph\n                }\n            });\n\n            const bfsResult = bfs(graph, startNode);\n            document.getElementById('output').innerText = bfsResult.join(' - ');\n        };\n        \n        function bfs(graph, start) {\n            const queue = [start];\n            const visited = Array(graph.length).fill(false);\n            const result = [];\n            \n            visited[start] = true;\n\n            while (queue.length > 0) {\n                const node = queue.shift();\n                result.push(node);\n\n                for (const neighbor of graph[node]) {\n                    if (!visited[neighbor]) {\n                        visited[neighbor] = true;\n                        queue.push(neighbor);\n                    }\n                }\n            }\n            return result;\n        }\n    </script>\n</body>\n</html>"
