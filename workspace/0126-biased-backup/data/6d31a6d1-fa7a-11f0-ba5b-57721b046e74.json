    "content": "<html>\n<head>\n    <title>REST API Explorer</title>\n    <script>\n        // Global state\n        let apiState = {\n            baseUrl: 'https://jsonplaceholder.typicode.com',\n            endpoints: [\n                { path: '/posts', method: 'GET', description: 'Get all posts' },\n                { path: '/posts/1', method: 'GET', description: 'Get post with ID 1' },\n                { path: '/posts', method: 'POST', description: 'Create new post' },\n                { path: '/posts/1', method: 'PUT', description: 'Update post with ID 1' },\n                { path: '/posts/1', method: 'PATCH', description: 'Partially update post with ID 1' },\n                { path: '/posts/1', method: 'DELETE', description: 'Delete post with ID 1' }\n            ],\n            currentEndpoint: null,\n            requestBody: '{\\n  \"title\": \"foo\",\\n  \"body\": \"bar\",\\n  \"userId\": 1\\n}',\n            response: null,\n            history: [],\n            customUrl: '',\n            customMethod: 'GET',\n            customHeaders: '{\\n  \"Content-Type\": \"application/json\"\\n}',\n            params: [{ key: '', value: '' }]\n        };\n\n        // Initialize the app\n        function init() {\n            renderEndpoints();\n            updateRequestPreview();\n            document.getElementById('requestBody').value = apiState.requestBody;\n            document.getElementById('customHeaders').value = apiState.customHeaders;\n        }\n\n        // Render available endpoints\n        function renderEndpoints() {\n            const container = document.getElementById('endpoints');\n            container.innerHTML = '';\n            \n            apiState.endpoints.forEach(endpoint => {\n                const div = document.createElement('div');\n                div.innerHTML = `\n                    <button onclick=\"selectEndpoint('${endpoint.path}', '${endpoint.method}')\">\n                        ${endpoint.method} ${endpoint.path}\n                    </button>\n                    <span>${endpoint.description}</span>\n                `;\n                container.appendChild(div);\n            });\n        }\n\n        // Select an endpoint\n        function selectEndpoint(path, method) {\n            apiState.currentEndpoint = { path, method };\n            document.getElementById('endpointInfo').innerText = `${method} ${apiState.baseUrl}${path}`;\n            updateRequestPreview();\n        }\n\n        // Update the request preview\n        function updateRequestPreview() {\n            let preview = '';\n            if (apiState.currentEndpoint) {\n                preview = `${apiState.currentEndpoint.method} ${apiState.baseUrl}${apiState.currentEndpoint.path}`;\n            } else if (apiState.customUrl) {\n                preview = `${apiState.customMethod} ${apiState.customUrl}`;\n            }\n            document.getElementById('requestPreview').innerText = preview;\n        }\n\n        // Execute the request\n        async function executeRequest() {\n            let url, method, body, headers;\n            \n            if (apiState.currentEndpoint) {\n                url = apiState.baseUrl + apiState.currentEndpoint.path;\n                method = apiState.currentEndpoint.method;\n            } else {\n                url = apiState.customUrl;\n                method = apiState.customMethod;\n            }\n            \n            // Add query params\n            const queryParams = apiState.params\n                .filter(p => p.key && p.value)\n                .map(p => `${encodeURIComponent(p.key)}=${encodeURIComponent(p.value)}`)\n                .join('&');\n            \n            if (queryParams) {\n                url += (url.includes('?') ? '&' : '?') + queryParams;\n            }\n            \n            try {\n                headers = JSON.parse(apiState.customHeaders);\n            } catch (e) {\n                alert('Invalid headers JSON');\n                return;\n            }\n            \n            if (method !== 'GET' && method !== 'DELETE') {\n                try {\n                    body = JSON.parse(apiState.requestBody);\n                } catch (e) {\n                    alert('Invalid request body JSON');\n                    return;\n                }\n            }\n            \n            const options = {\n                method,\n                headers: {\n                    'Content-Type': 'application/json',\n                    ...headers\n                }\n            };\n            \n            if (body) {\n                options.body = JSON.stringify(body);\n            }\n            \n            try {\n                document.getElementById('responseStatus').innerText = 'Loading...';\n                document.getElementById('responseBody').innerText = '';\n                \n                const startTime = Date.now();\n                const response = await fetch(url, options);\n                const responseTime = Date.now() - startTime;\n                \n                const responseData = await response.json();\n                \n                apiState.response = {\n                    status: response.status,\n                    statusText: response.statusText,\n                    headers: Object.fromEntries(response.headers.entries()),\n                    body: responseData,\n                    time: responseTime\n                };\n                \n                // Add to history\n                apiState.history.unshift({\n                    url,\n                    method,\n                    status: response.status,\n                    time: new Date().toLocaleTimeString()\n                });\n                renderHistory();\n                \n                displayResponse();\n            } catch (error) {\n                document.getElementById('responseStatus').innerText = 'Error: ' + error.message;\n            }\n        }\n\n        // Display the response\n        function displayResponse() {\n            const response = apiState.response;\n            if (!response) return;\n            \n            document.getElementById('responseStatus').innerText = \n                `${response.status} ${response.statusText} (${response.time}ms)`;\n            \n            document.getElementById('responseBody').innerText = \n                JSON.stringify(response.body, null, 2);\n            \n            let headersText = '';\n            for (const [key, value] of Object.entries(response.headers)) {\n                headersText += `${key}: ${value}\\n`;\n            }\n            document.getElementById('responseHeaders').innerText = headersText;\n        }\n\n        // Render history\n        function renderHistory() {\n            const container = document.getElementById('history');\n            container.innerHTML = '';\n            \n            apiState.history.slice(0, 10).forEach(item => {\n                const div = document.createElement('div');\n                div.innerHTML = `\n                    <span>[${item.time}]</span>\n                    <span>${item.method}</span>\n                    <span>${item.url}</span>\n                    <span>${item.status}</span>\n                    <button onclick=\"loadFromHistory('${item.url}', '${item.method}')\">Load</button>\n                `;\n                container.appendChild(div);\n            });\n        }\n\n        // Load from history\n        function loadFromHistory(url, method) {\n            apiState.currentEndpoint = null;\n            apiState.customUrl = url;\n            apiState.customMethod = method;\n            document.getElementById('customUrl').value = url;\n            document.getElementById('customMethod').value = method;\n            updateRequestPreview();\n        }\n\n        // Add a parameter\n        function addParam() {\n            apiState.params.push({ key: '', value: '' });\n            renderParams();\n        }\n\n        // Remove a parameter\n        function removeParam(index) {\n            apiState.params.splice(index, 1);\n            renderParams();\n        }\n\n        // Update a parameter\n        function updateParam(index, field, value) {\n            apiState.params[index][field] = value;\n        }\n\n        // Render parameters\n        function renderParams() {\n            const container = document.getElementById('paramsContainer');\n            container.innerHTML = '';\n            \n            apiState.params.forEach((param, index) => {\n                const div = document.createElement('div');\n                div.innerHTML = `\n                    <input type=\"text\" placeholder=\"Key\" value=\"${param.key}\" \n                        onchange=\"updateParam(${index}, 'key', this.value)\">\n                    <input type=\"text\" placeholder=\"Value\" value=\"${param.value}\" \n                        onchange=\"updateParam(${index}, 'value', this.value)\">\n                    <button onclick=\"removeParam(${index})\">Remove</button>\n                `;\n                container.appendChild(div);\n            });\n        }\n\n        // Toggle between endpoint and custom request\n        function toggleRequestType() {\n            const showCustom = document.getElementById('requestType').value === 'custom';\n            document.getElementById('endpointsSection').style.display = showCustom ? 'none' : 'block';\n            document.getElementById('customRequestSection').style.display = showCustom ? 'block' : 'none';\n            updateRequestPreview();\n        }\n\n        // Update custom URL\n        function updateCustomUrl() {\n            apiState.customUrl = document.getElementById('customUrl').value;\n            updateRequestPreview();\n        }\n\n        // Update custom method\n        function updateCustomMethod() {\n            apiState.customMethod = document.getElementById('customMethod').value;\n            updateRequestPreview();\n        }\n\n        // Update request body\n        function updateRequestBody() {\n            apiState.requestBody = document.getElementById('requestBody').value;\n        }\n\n        // Update custom headers\n        function updateCustomHeaders() {\n            apiState.customHeaders = document.getElementById('customHeaders').value;\n        }\n\n        // Format JSON\n        function formatJson(textareaId) {\n            try {\n                const json = JSON.parse(document.getElementById(textareaId).value);\n                document.getElementById(textareaId).value = JSON.stringify(json, null, 2);\n            } catch (e) {\n                alert('Invalid JSON: ' + e.message);\n            }\n        }\n    </script>\n</head>\n<body onload=\"init()\">\n    <h1>REST API Explorer</h1>\n    \n    <div>\n        <h2>Request Type</h2>\n        <select id=\"requestType\" onchange=\"toggleRequestType()\">\n            <option value=\"endpoint\">Predefined Endpoint</option>\n            <option value=\"custom\">Custom Request</option>\n        </select>\n    </div>\n    \n    <div id=\"endpointsSection\">\n        <h2>Available Endpoints</h2>\n        <div id=\"endpoints\"></div>\n        <div id=\"endpointInfo\"></div>\n    </div>\n    \n    <div id=\"customRequestSection\" style=\"display: none;\">\n        <h2>Custom Request</h2>\n        <div>\n            <select id=\"customMethod\" onchange=\"updateCustomMethod()\">\n                <option value=\"GET\">GET</option>\n                <option value=\"POST\">POST</option>\n                <option value=\"PUT\">PUT</option>\n                <option value=\"PATCH\">PATCH</option>\n                <option value=\"DELETE\">DELETE</option>\n            </select>\n            <input type=\"text\" id=\"customUrl\" placeholder=\"Enter URL\" onchange=\"updateCustomUrl()\">\n        </div>\n    </div>\n    \n    <div>\n        <h2>Query Parameters</h2>\n        <div id=\"paramsContainer\"></div>\n        <button onclick=\"addParam()\">Add Parameter</button>\n    </div>\n    \n    <div>\n        <h2>Request Headers</h2>\n        <textarea id=\"customHeaders\" rows=\"4\" cols=\"50\" onchange=\"updateCustomHeaders()\"></textarea>\n        <button onclick=\"formatJson('customHeaders')\">Format JSON</button>\n    </div>\n    \n    <div>\n        <h2>Request Body</h2>\n        <textarea id=\"requestBody\" rows=\"10\" cols=\"50\" onchange=\"updateRequestBody()\"></textarea>\n        <button onclick=\"formatJson('requestBody')\">Format JSON</button>\n    </div>\n    \n    <div>\n        <h2>Request Preview</h2>\n        <div id=\"requestPreview\"></div>\n        <button onclick=\"executeRequest()\">Send Request</button>\n    </div>\n    \n    <div>\n        <h2>Response</h2>\n        <div id=\"responseStatus\"></div>\n        <h3>Headers</h3>\n        <pre id=\"responseHeaders\"></pre>\n        <h3>Body</h3>\n        <pre id=\"responseBody\"></pre>\n    </div>\n    \n    <div>\n        <h2>History</h2>\n        <div id=\"history\"></div>\n    </div>\n</body>\n</html>"
