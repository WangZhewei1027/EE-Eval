    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>The Beauty of HTTPS</title>\n    <style>\n        :root {\n            --primary: #4a6fa5;\n            --secondary: #166088;\n            --accent: #4fc3f7;\n            --dark: #0a2463;\n            --light: #f8f9fa;\n            --success: #4caf50;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1s ease-out;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--secondary), var(--primary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            font-weight: 800;\n            letter-spacing: -1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--secondary);\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 2rem;\n            margin: 4rem 0;\n        }\n\n        .connection-path {\n            position: relative;\n            width: 100%;\n            height: 300px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .node {\n            width: 120px;\n            height: 120px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: relative;\n            z-index: 2;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n            transition: all 0.5s ease;\n            background: white;\n        }\n\n        .node img {\n            width: 60%;\n            height: 60%;\n            object-fit: contain;\n        }\n\n        .client {\n            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);\n        }\n\n        .server {\n            background: linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%);\n        }\n\n        .path-line {\n            position: absolute;\n            height: 8px;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            border-radius: 4px;\n            top: 50%;\n            transform: translateY(-50%);\n            z-index: 1;\n            transition: all 0.8s ease;\n            box-shadow: 0 5px 15px rgba(74, 111, 165, 0.3);\n        }\n\n        .encryption-badge {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            background-color: var(--success);\n            color: white;\n            padding: 0.5rem 1rem;\n            border-radius: 20px;\n            font-weight: bold;\n            opacity: 0;\n            transition: opacity 0.5s ease;\n            box-shadow: 0 5px 15px rgba(76, 175, 80, 0.4);\n            z-index: 3;\n        }\n\n        .lock-icon {\n            position: absolute;\n            top: -10px;\n            right: -10px;\n            background: var(--success);\n            width: 30px;\n            height: 30px;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-size: 0.8rem;\n            opacity: 0;\n            transition: opacity 0.5s ease;\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        button {\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 30px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .info-cards {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 2rem;\n            margin-top: 4rem;\n        }\n\n        .card {\n            background: white;\n            border-radius: 15px;\n            padding: 2rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            transition: transform 0.3s ease;\n        }\n\n        .card:hover {\n            transform: translateY(-10px);\n        }\n\n        .card h3 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.3rem;\n        }\n\n        .card p {\n            color: #555;\n            line-height: 1.6;\n        }\n\n        .card-icon {\n            font-size: 2rem;\n            margin-bottom: 1rem;\n            color: var(--accent);\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        .pulse {\n            animation: pulse 2s infinite;\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            padding: 2rem;\n            color: var(--secondary);\n            font-size: 0.9rem;\n        }\n\n        .highlight {\n            background: linear-gradient(to right, var(--accent), var(--primary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Secure Connections with HTTPS</h1>\n            <p class=\"subtitle\">A visual exploration of how HTTPS creates an encrypted tunnel between your browser and websites, protecting your data with cutting-edge cryptography.</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"connection-path\">\n                <div class=\"node client pulse\">\n                    <img src=\"data:image/svg+xml;base64,\" alt=\"Client\">\n                    <div class=\"lock-icon\">🔒</div>\n                </div>\n                <div class=\"path-line\" style=\"width: 0%; left: 50%;\"></div>\n                <div class=\"node server\">\n                    <img src=\"data:image/svg+xml;base64,\" alt=\"Server\">\n                    <div class=\"lock-icon\">🔒</div>\n                </div>\n                <div class=\"encryption-badge\">Encrypted Connection</div>\n            </div>\n\n            <div class=\"controls\">\n                <button id=\"connect-btn\">Establish Secure Connection</button>\n                <button id=\"reset-btn\" style=\"background: #f44336;\">Reset</button>\n            </div>\n        </div>\n\n        <div class=\"info-cards\">\n            <div class=\"card\">\n                <div class=\"card-icon\">🔐</div>\n                <h3>Encryption</h3>\n                <p>HTTPS uses <span class=\"highlight\">TLS/SSL encryption</span> to protect all communication between your browser and the website. This prevents eavesdroppers from reading sensitive information.</p>\n            </div>\n            <div class=\"card\">\n                <div class=\"card-icon\">📜</div>\n                <h3>Data Integrity</h3>\n                <p>HTTPS ensures that data cannot be modified or corrupted during transfer without being detected. This protects against <span class=\"highlight\">man-in-the-middle attacks</span>.</p>\n            </div>\n            <div class=\"card\">\n                <div class=\"card-icon\">✅</div>\n                <h3>Authentication</h3>\n                <p>HTTPS verifies that you're communicating with the intended website and not an imposter. This is done through <span class=\"highlight\">SSL certificates</span> issued by trusted authorities.</p>\n            </div>\n        </div>\n\n        <footer>\n            <p>HTTPS is the foundation of a secure internet. Always look for the lock icon 🔒 in your browser's address bar.</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const connectBtn = document.getElementById('connect-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            const pathLine = document.querySelector('.path-line');\n            const lockIcons = document.querySelectorAll('.lock-icon');\n            const encryptionBadge = document.querySelector('.encryption-badge');\n            const serverNode = document.querySelector('.server');\n            const clientNode = document.querySelector('.client');\n\n            connectBtn.addEventListener('click', function() {\n                // Animate the connection path\n                pathLine.style.width = '50%';\n                pathLine.style.left = '25%';\n\n                // Show lock icons after a delay\n                setTimeout(() => {\n                    lockIcons.forEach(icon => {\n                        icon.style.opacity = '1';\n                    });\n                }, 800);\n\n                // Show encryption badge after another delay\n                setTimeout(() => {\n                    encryptionBadge.style.opacity = '1';\n                    serverNode.classList.add('pulse');\n                    clientNode.classList.remove('pulse');\n                }, 1500);\n\n                // Change button state\n                connectBtn.disabled = true;\n                connectBtn.style.opacity = '0.7';\n                connectBtn.style.transform = 'none';\n                connectBtn.style.boxShadow = 'none';\n                connectBtn.textContent = 'Connection Secured';\n            });\n\n            resetBtn.addEventListener('click', function() {\n                // Reset all animations\n                pathLine.style.width = '0%';\n                pathLine.style.left = '50%';\n                \n                lockIcons.forEach(icon => {\n                    icon.style.opacity = '0';\n                });\n\n                encryptionBadge.style.opacity = '0';\n                serverNode.classList.remove('pulse');\n                clientNode.classList.add('pulse');\n\n                // Reset button state\n                connectBtn.disabled = false;\n                connectBtn.style.opacity = '1';\n                connectBtn.textContent = 'Establish Secure Connection';\n            });\n        });\n    </script>\n</body>\n</html>"
