    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Dynamic Typing — Visual Demo</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071027;\n    --glass: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.6);\n    --accent: #7c5cff;\n    --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Segoe UI Mono\", monospace;\n    --soft-radius: 16px;\n    --glass-gradient: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    --ease: cubic-bezier(.2,.9,.25,1);\n  }\n\n  /* Page layout */\n  * { box-sizing: border-box; }\n  html,body { height:100%; margin:0; background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.12), transparent),\n                                  radial-gradient(1000px 500px at 90% 90%, rgba(56,227,214,0.06), transparent),\n                                  linear-gradient(180deg,var(--bg-1),var(--bg-2)); color:#dbeafe; font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }\n\n  .canvas {\n    position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden;\n  }\n\n  /* animated ambient blobs */\n  .blob {\n    position:absolute; width:560px; height:560px; filter:blur(72px); opacity:0.12; transform-origin:center;\n    will-change:transform;\n  }\n  .blob--one { background: radial-gradient(circle at 30% 30%, rgba(124,92,255,0.9), rgba(124,92,255,0.6) 35%, transparent 60%); left:-10%; top:-20%; animation: driftA 18s var(--ease) infinite; }\n  .blob--two { background: radial-gradient(circle at 70% 70%, rgba(56,227,214,0.9), rgba(56,227,214,0.5) 35%, transparent 60%); right:-10%; bottom:-10%; animation: driftB 22s var(--ease) infinite; }\n  .blob--three { background: radial-gradient(circle at 50% 50%, rgba(255,179,64,0.9), rgba(255,120,120,0.4) 35%, transparent 60%); left:20%; bottom:5%; width:420px; height:420px; animation: driftC 20s var(--ease) infinite; opacity:0.08; }\n  @keyframes driftA { 0%{transform:translateY(0) rotate(0);} 50%{transform:translateY(40px) rotate(10deg);} 100%{transform:translateY(0) rotate(0);} }\n  @keyframes driftB { 0%{transform:translateY(0) rotate(0);} 50%{transform:translateY(-36px) rotate(-6deg);} 100%{transform:translateY(0) rotate(0);} }\n  @keyframes driftC { 0%{transform:translateY(0) rotate(0);} 50%{transform:translateY(28px) rotate(5deg);} 100%{transform:translateY(0) rotate(0);} }\n\n  /* subtle particle grid */\n  .grid {\n    position:absolute; inset:0; background-image:\n      radial-gradient(circle at 10% 20%, rgba(255,255,255,0.02) 1px, transparent 1px),\n      radial-gradient(circle at 80% 70%, rgba(255,255,255,0.012) 1px, transparent 1px);\n    background-size: 120px 120px, 200px 200px;\n    mix-blend-mode: overlay; opacity:0.6; transform:translateZ(0);\n  }\n\n  /* Center stage */\n  .stage {\n    position:relative; z-index:2; max-width:1100px; margin:6vh auto; padding:48px; display:flex; gap:32px; align-items:stretch;\n  }\n\n  .card {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px; box-shadow: 0 8px 40px rgba(2,6,23,0.6); border: 1px solid rgba(255,255,255,0.03);\n    padding:32px; flex:1; min-height:420px; backdrop-filter: blur(6px);\n  }\n\n  .brand {\n    display:flex; align-items:center; gap:16px; margin-bottom:18px;\n  }\n  .logo {\n    width:56px; height:56px; border-radius:12px; display:flex; align-items:center; justify-content:center; flex-shrink:0;\n    background: linear-gradient(135deg, rgba(124,92,255,0.95), rgba(56,227,214,0.95));\n    box-shadow: 0 6px 30px rgba(92,75,255,0.16), inset 0 -6px 20px rgba(255,255,255,0.06);\n    transform:rotate(-12deg);\n  }\n  .logo svg { filter: drop-shadow(0 6px 18px rgba(0,0,0,0.28)); }\n  h1 { margin:0; font-weight:700; letter-spacing:-0.01em; font-size:20px; color:#f8fafc; }\n  p.lead { margin:0; color:rgba(255,255,255,0.8); font-size:13px; margin-top:2px; }\n\n  /* layout inside card */\n  .content {\n    display:flex; gap:24px; align-items:stretch; margin-top:18px;\n  }\n  .panel {\n    flex:1; min-width:0;\n  }\n\n  /* Code window */\n  .code-window {\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.018));\n    border-radius:14px; padding:18px; border:1px solid rgba(255,255,255,0.03); box-shadow: inset 0 -20px 50px rgba(8,12,20,0.12);\n  }\n\n  .code-top {\n    display:flex; align-items:center; justify-content:space-between; gap:12px;\n  }\n  .tabs { display:flex; gap:8px; align-items:center; }\n  .dot { width:10px; height:10px; border-radius:50%; background:rgba(255,255,255,0.06); box-shadow: 0 1px 0 rgba(255,255,255,0.02) inset; }\n  .dot.red { background:#ff6b6b; box-shadow: none; }\n  .dot.yellow { background:#ffd166; }\n  .dot.green { background:#6beaa3; }\n\n  .code {\n    margin-top:14px; padding:20px; background: rgba(6,10,20,0.35); border-radius:12px; font-family:var(--mono); font-size:18px; color:#e6eef8;\n    min-height:140px; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden;\n  }\n\n  .typing {\n    display:flex; gap:18px; align-items:center;\n  }\n\n  .let {\n    color:rgba(255,255,255,0.9); font-weight:700; margin-right:6px; font-size:18px;\n  }\n  .xname { color: #8bd5ff; font-weight:700; font-size:18px; margin-right:6px; }\n  .equals { color: rgba(255,255,255,0.5); }\n\n  /* Value pill */\n  .value-pill {\n    transition: all 680ms var(--ease), background 540ms linear;\n    display:flex; align-items:center; justify-content:center;\n    padding:18px 28px; border-radius:48px; min-width:120px; height:64px; font-family:var(--mono);\n    font-size:20px; font-weight:700; color:#02212a; box-shadow: 0 10px 30px rgba(2,6,23,0.65);\n    transform-origin:center;\n  }\n\n  .meta {\n    margin-top:18px; display:flex; gap:12px; align-items:center; color:var(--muted); font-size:13px;\n  }\n\n  /* Inspector panel */\n  .inspector {\n    width:320px; background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015)); padding:18px; border-radius:14px; border:1px solid rgba(255,255,255,0.03);\n    display:flex; flex-direction:column; gap:14px; justify-content:flex-start;\n  }\n  .inspector h3 { margin:0; font-size:14px; color:#f8fafc; }\n  .inspector p { margin:0; color:var(--muted); font-size:13px; }\n\n  .type-badge {\n    display:inline-flex; gap:8px; align-items:center; padding:10px 12px; border-radius:999px; color:#03181b; font-weight:700;\n    font-family:var(--mono); transition:all 560ms var(--ease);\n  }\n\n  .memory {\n    margin-top:6px; display:flex; gap:12px; align-items:center; color:var(--muted);\n  }\n  .mem-box {\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02)); border-radius:10px; padding:10px; min-width:120px; min-height:64px; display:flex; align-items:center; justify-content:center; font-family:var(--mono); font-weight:700; font-size:13px; color:#dbeafe;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n\n  /* runtime timeline */\n  .timeline {\n    margin-top:8px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;\n  }\n  .timeline .chip {\n    font-family:var(--mono); font-size:12px; padding:8px 10px; background:rgba(255,255,255,0.02); border-radius:10px; color:var(--muted);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  /* controls */\n  .controls {\n    display:flex; gap:10px; margin-left:auto; align-items:center;\n  }\n  .btn {\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.04);\n    color:var(--muted); padding:8px 12px; border-radius:12px; font-weight:700; font-family:var(--mono); cursor:pointer; transition:all 280ms var(--ease); display:inline-flex; gap:8px; align-items:center;\n  }\n  .btn:hover { transform:translateY(-3px); box-shadow:0 12px 30px rgba(2,6,23,0.45); color:#fff; }\n  .btn:active { transform:translateY(-1px) scale(0.995); }\n\n  /* small decorative arrows and connectors */\n  .connector {\n    height:16px; width:100%; display:flex; align-items:center; justify-content:center; opacity:0.9;\n  }\n  .arrow {\n    width:120px; height:2px; background:linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    position:relative; border-radius:2px;\n  }\n  .arrow::after {\n    content:''; position:absolute; right:-6px; top:-5px; border-width:6px 6px 6px 0; border-style:solid; border-color: transparent rgba(255,255,255,0.06) transparent transparent; transform: rotate(0deg); opacity:0.9;\n  }\n\n  /* typographic accent */\n  .big-claim {\n    font-weight:800; font-size:40px; line-height:0.95; margin:0; color:#f8fafc; letter-spacing:-0.02em;\n    -webkit-font-smoothing:antialiased;\n  }\n  .sub-claim { color:rgba(255,255,255,0.75); margin:8px 0 0 0; font-size:15px; max-width:520px; }\n\n  /* minor responsive */\n  @media (max-width:980px){\n    .stage { flex-direction:column; margin:4vh auto; padding:20px; }\n    .inspector { width:100%; order:2; }\n    .card { order:1; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"canvas\" aria-hidden=\"true\">\n    <div class=\"blob blob--one\"></div>\n    <div class=\"blob blob--two\"></div>\n    <div class=\"blob blob--three\"></div>\n    <div class=\"grid\"></div>\n  </div>\n\n  <main class=\"stage\" role=\"main\">\n    <section class=\"card\" aria-labelledby=\"title\">\n      <div class=\"brand\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg width=\"34\" height=\"34\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M4 12c0-4.418 3.582-8 8-8\" stroke=\"#021124\" stroke-opacity=\"0.12\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n            <path d=\"M20 12c0 4.418-3.582 8-8 8\" stroke=\"#021124\" stroke-opacity=\"0.12\" stroke-width=\"6\" stroke-linecap=\"round\"/>\n            <path d=\"M8 8c2.4-2.4 5.6-2.4 8 0\" stroke=\"#fff\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.92\"/>\n            <path d=\"M8 16c2.4 2.4 5.6 2.4 8 0\" stroke=\"#fff\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.7\"/>\n          </svg>\n        </div>\n        <div>\n          <h1 id=\"title\">Dynamic Typing</h1>\n          <p class=\"lead\">Observe how a single variable transforms its type and shape at runtime — elegantly, instantly, and fluidly.</p>\n        </div>\n\n        <div style=\"margin-left:auto\" class=\"controls\" aria-hidden=\"false\">\n          <button id=\"toggle\" class=\"btn\" title=\"Play / Pause (Space)\">\n            <svg id=\"iconPlay\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"/></svg>\n            <span id=\"btnText\">Pause</span>\n          </button>\n        </div>\n      </div>\n\n      <div class=\"content\">\n        <div class=\"panel\">\n          <div class=\"big-claim\">One name, many forms.</div>\n          <div class=\"sub-claim\">In dynamically-typed languages a variable is not bound to a single type — it can hold a number one moment, a string the next, and even a whole function after that. Watch the value morph while the runtime keeps everything coherent.</div>\n\n          <div style=\"height:18px\"></div>\n\n          <div class=\"code-window\" aria-hidden=\"false\">\n            <div class=\"code-top\">\n              <div class=\"tabs\" aria-hidden=\"true\">\n                <div class=\"dot red\"></div>\n                <div class=\"dot yellow\"></div>\n                <div class=\"dot green\"></div>\n              </div>\n              <div style=\"display:flex; gap:12px; align-items:center;\">\n                <div style=\"font-family:var(--mono); font-size:12px; color:var(--muted);\">runtime → <span id=\"stepName\" style=\"color:#fff; font-weight:700; margin-left:8px;\">Number</span></div>\n              </div>\n            </div>\n\n            <div class=\"code\">\n              <div class=\"typing\" aria-live=\"polite\">\n                <div class=\"let\">let</div>\n                <div class=\"xname\">x</div>\n                <div class=\"equals\">=</div>\n                <div id=\"valueHolder\" class=\"value-pill\" role=\"status\" aria-atomic=\"true\">42</div>\n              </div>\n            </div>\n\n            <div class=\"meta\">\n              <div style=\"display:flex; gap:8px; align-items:center;\">\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 2v20M2 12h20\" stroke=\"rgba(255,255,255,0.18)\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n                <div style=\"font-size:13px; color:var(--muted)\">Type changes are instantaneous and reflected in the runtime inspector.</div>\n              </div>\n            </div>\n\n          </div>\n\n          <div style=\"height:14px\"></div>\n\n          <div style=\"display:flex; gap:12px; align-items:center;\">\n            <div class=\"connector\"><div class=\"arrow\" aria-hidden=\"true\"></div></div>\n            <div style=\"font-family:var(--mono); color:var(--muted); font-size:13px;\">Flow: source → runtime → memory</div>\n          </div>\n\n        </div>\n\n        <aside class=\"inspector\" aria-label=\"Runtime inspector\">\n          <h3>Runtime Inspector</h3>\n          <p>Shows the current value and how the engine perceives its type and storage.</p>\n\n          <div style=\"display:flex; gap:12px; align-items:center; justify-content:space-between;\">\n            <div>\n              <div style=\"font-size:12px; color:var(--muted)\">Current</div>\n              <div id=\"typeBadge\" class=\"type-badge\" style=\"background:#7c5cff; color:#fff; margin-top:8px;\">Number</div>\n            </div>\n            <div>\n              <div style=\"font-size:12px; color:var(--muted)\">Stored as</div>\n              <div class=\"mem-box\" id=\"memBox\" style=\"margin-top:8px;\">Primitive</div>\n            </div>\n          </div>\n\n          <div style=\"margin-top:6px;\">\n            <div style=\"font-size:12px; color:var(--muted);\">Timeline</div>\n            <div class=\"timeline\" id=\"timeline\">\n              <div class=\"chip\">Number</div>\n              <div class=\"chip\">String</div>\n              <div class=\"chip\">Array</div>\n              <div class=\"chip\">Object</div>\n              <div class=\"chip\">Function</div>\n              <div class=\"chip\">Boolean</div>\n              <div class=\"chip\">Null</div>\n              <div class=\"chip\">Symbol</div>\n            </div>\n          </div>\n\n          <div style=\"margin-top:6px;\">\n            <div style=\"font-size:12px; color:var(--muted);\">Memory snapshot</div>\n            <div style=\"display:flex; gap:10px; margin-top:10px;\">\n              <div class=\"mem-box\" id=\"memA\" style=\"width:84px; height:60px; display:flex; flex-direction:column; font-size:12px; gap:6px;\">\n                <div style=\"opacity:0.75;\">x</div>\n                <div id=\"memValA\" style=\"font-weight:800; font-size:14px;\">42</div>\n              </div>\n              <div class=\"mem-box\" id=\"memB\" style=\"width:84px; height:60px; display:flex; flex-direction:column; font-size:12px; gap:6px;\">\n                <div style=\"opacity:0.75;\">heap</div>\n                <div id=\"memValB\" style=\"font-weight:800; font-size:14px;\">—</div>\n              </div>\n            </div>\n          </div>\n\n          <div style=\"margin-top:auto; display:flex; gap:8px; align-items:center;\">\n            <button id=\"toggle2\" class=\"btn\" style=\"flex:1;\">Pause</button>\n            <div style=\"font-size:12px; color:var(--muted)\">Auto-play</div>\n          </div>\n        </aside>\n      </div>\n    </section>\n  </main>\n\n<script>\n  // Sequence of values representing dynamic typing transformations\n  const sequence = [\n    {\n      name: 'Number',\n      display: '42',\n      pill: {bg: 'linear-gradient(90deg,#ffd166,#ff8a00)', color: '#0b1320', width: 130, radius: 48, shadow: '0 12px 30px rgba(255,141,24,0.12)'},\n      mem: {type:'Primitive', heap:'—'}\n    },\n    {\n      name: 'String',\n      display: '\"hello\"',\n      pill: {bg: 'linear-gradient(90deg,#b794f4,#7c5cff)', color: '#fff', width: 170, radius: 40, shadow: '0 12px 30px rgba(124,92,255,0.12)'},\n      mem: {type:'Primitive', heap:'—'}\n    },\n    {\n      name: 'Array',\n      display: '[1, 2, 3]',\n      pill: {bg: 'linear-gradient(90deg,#56ccf2,#2f80ed)', color: '#021524', width: 210, radius: 14, shadow: '0 20px 40px rgba(47,128,237,0.12)'},\n      mem: {type:'Reference', heap:'Array@0x1a2b'}\n    },\n    {\n      name: 'Object',\n      display: '{ a: 1 }',\n      pill: {bg: 'linear-gradient(90deg,#5eead4,#06b6d4)', color: '#042024', width: 190, radius: 12, shadow: '0 20px 40px rgba(6,182,212,0.10)'},\n      mem: {type:'Reference', heap:'Object@0x3c5d'}\n    },\n    {\n      name: 'Function',\n      display: '() => {}',\n      pill: {bg: 'linear-gradient(90deg,#f093fb,#f5576c)', color: '#041018', width: 170, radius: 40, shadow: '0 18px 36px rgba(245,87,108,0.12)'},\n      mem: {type:'Reference', heap:'Function@0x8f2c'}\n    },\n    {\n      name: 'Boolean',\n      display: 'true',\n      pill: {bg: 'linear-gradient(90deg,#86efac,#20c997)', color: '#042014', width: 120, radius: 48, shadow: '0 12px 30px rgba(32,201,151,0.12)'},\n      mem: {type:'Primitive', heap:'—'}\n    },\n    {\n      name: 'Null',\n      display: 'null',\n      pill: {bg: 'linear-gradient(90deg,#94a3b8,#475569)', color: '#e6eef8', width: 120, radius: 48, shadow: '0 10px 26px rgba(20,35,56,0.18)'},\n      mem: {type:'Primitive (null)', heap:'—'}\n    },\n    {\n      name: 'Symbol',\n      display: \"Symbol('id')\",\n      pill: {bg: 'linear-gradient(90deg,#ffd6a5,#ffb4a2)', color: '#08141a', width: 200, radius: 40, shadow: '0 20px 36px rgba(255,156,116,0.12)'},\n      mem: {type:'Primitive', heap:'—'}\n    }\n  ];\n\n  // Elements\n  const valueHolder = document.getElementById('valueHolder');\n  const typeBadge = document.getElementById('typeBadge');\n  const memBox = document.getElementById('memBox');\n  const memValA = document.getElementById('memValA');\n  const memValB = document.getElementById('memValB');\n  const stepName = document.getElementById('stepName');\n  const btn = document.getElementById('toggle');\n  const btn2 = document.getElementById('toggle2');\n  const btnText = document.getElementById('btnText');\n\n  let idx = 0;\n  let playing = true;\n  let timer = null;\n\n  // Utility: smooth update of pill style and content\n  function applyState(state){\n    // content fade out/in\n    valueHolder.style.transition = 'opacity 260ms var(--ease), transform 640ms var(--ease), background 520ms linear, width 520ms var(--ease), border-radius 520ms var(--ease), color 520ms var(--ease), box-shadow 520ms var(--ease)';\n    valueHolder.style.opacity = '0';\n    valueHolder.style.transform = 'translateY(8px) scale(0.98)';\n\n    // update inspector little later so transitions occur smoothly\n    setTimeout(()=>{\n      // text content\n      valueHolder.textContent = state.display;\n      // style adjustments\n      valueHolder.style.background = state.pill.bg;\n      valueHolder.style.color = state.pill.color;\n      valueHolder.style.width = state.pill.width + 'px';\n      valueHolder.style.borderRadius = state.pill.radius + 'px';\n      valueHolder.style.boxShadow = state.pill.shadow;\n      // update inspector\n      typeBadge.textContent = state.name;\n      typeBadge.style.background = state.pill.bg;\n      typeBadge.style.color = state.pill.color;\n      memBox.textContent = state.mem.type;\n      memValA.textContent = state.display;\n      memValB.textContent = state.mem.heap;\n      stepName.textContent = state.name;\n    }, 220);\n\n    // fade back\n    setTimeout(()=> {\n      valueHolder.style.opacity = '1';\n      valueHolder.style.transform = 'translateY(0) scale(1)';\n    }, 360);\n  }\n\n  // cycle\n  function next(){\n    idx = (idx + 1) % sequence.length;\n    applyState(sequence[idx]);\n    highlightTimeline(idx);\n  }\n\n  function prev(){\n    idx = (idx - 1 + sequence.length) % sequence.length;\n    applyState(sequence[idx]);\n    highlightTimeline(idx);\n  }\n\n  // timeline highlight\n  function highlightTimeline(activeIdx){\n    const chips = document.querySelectorAll('.timeline .chip');\n    chips.forEach((c,i)=>{\n      if(i === activeIdx){\n        c.style.background = 'linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02))';\n        c.style.color = '#fff';\n        c.style.transform = 'translateY(-4px)';\n        c.style.boxShadow = '0 6px 20px rgba(0,0,0,0.35)';\n      } else {\n        c.style.background = 'rgba(255,255,255,0.02)';\n        c.style.color = 'var(--muted)';\n        c.style.transform = 'translateY(0)';\n        c.style.boxShadow = 'none';\n      }\n    });\n  }\n\n  // autoplay\n  function startLoop(){\n    if(timer) clearInterval(timer);\n    timer = setInterval(next, 2400);\n  }\n  function stopLoop(){\n    if(timer) clearInterval(timer);\n    timer = null;\n  }\n\n  // init\n  applyState(sequence[idx]);\n  highlightTimeline(idx);\n  startLoop();\n\n  // controls: single toggle button\n  function setPlaying(p){\n    playing = p;\n    if(playing){\n      startLoop();\n      btnText.textContent = 'Pause';\n      btn.querySelector('svg').innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"/>'; // play icon shown when playing? We'll keep Pause text\n      btn2.textContent = 'Pause';\n    } else {\n      stopLoop();\n      btnText.textContent = 'Play';\n      btn.querySelector('svg').innerHTML = '<path d=\"M6 5h4v14H6zM14 5h4v14h-4z\" fill=\"currentColor\"/>'; // pause icon\n      btn2.textContent = 'Play';\n    }\n  }\n\n  btn.addEventListener('click', ()=>{\n    setPlaying(!playing);\n  });\n  btn2.addEventListener('click', ()=>{\n    setPlaying(!playing);\n  });\n\n  // keyboard space toggles\n  window.addEventListener('keydown', (e)=>{\n    if(e.code === 'Space'){\n      e.preventDefault();\n      setPlaying(!playing);\n    } else if (e.code === 'ArrowRight'){\n      next();\n      if(playing){ setPlaying(false); }\n    } else if (e.code === 'ArrowLeft'){\n      prev();\n      if(playing){ setPlaying(false); }\n    }\n  });\n\n  // small decorative motion linking pill to blobs\n  // pulsate background blobs based on type changes\n  const blobs = document.querySelectorAll('.blob');\n  function pulse(){\n    blobs.forEach((b,i)=>{\n      b.style.transition = 'transform 520ms var(--ease), opacity 520ms var(--ease)';\n      b.style.transform = `scale(${1 + (i === idx%3 ? 0.04 : 0.02)}) rotate(${(i*8) + (idx*6)}deg)`;\n      b.style.opacity = `${0.08 + (i === idx%3 ? 0.06 : 0.03)}`;\n    });\n  }\n  // enhance pulse when applying state\n  const origApply = applyState;\n  applyState = function(state){\n    origApply(state);\n    pulse();\n  };\n\n  // Accessibility: ensure initial states described\n  valueHolder.setAttribute('aria-label', 'Variable x value');\n  typeBadge.setAttribute('aria-live', 'polite');\n\n  // small auto-stop after several loops? No — demo loops indefinitely but user can pause.\n\n  // Extra: smooth entrance animation\n  document.documentElement.style.setProperty('--intro', '0');\n  window.addEventListener('load', () => {\n    document.querySelectorAll('.card, .inspector, .logo, .big-claim').forEach((el,i)=>{\n      el.style.opacity = '0';\n      el.style.transform = 'translateY(12px) scale(0.995)';\n      setTimeout(()=> {\n        el.style.transition = 'opacity 720ms var(--ease), transform 720ms var(--ease)';\n        el.style.opacity = '1';\n        el.style.transform = 'translateY(0) scale(1)';\n      }, 120 + i*80);\n    });\n  });\n\n</script>\n</body>\n</html>"
