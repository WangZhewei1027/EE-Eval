    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Agile Methodology Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        h1, h2, p { margin: 10px 0; }\n        .section { margin-bottom: 20px; }\n        button { margin: 5px; }\n    </style>\n</head>\n<body>\n\n<h1>Agile Methodology Interactive Demo</h1>\n\n<div class=\"section\">\n    <h2>Define User Stories</h2>\n    <input type=\"text\" id=\"userStory\" placeholder=\"Enter a user story\" />\n    <button onclick=\"addUserStory()\">Add User Story</button>\n    <h3>User Stories:</h3>\n    <ul id=\"userStoryList\"></ul>\n</div>\n\n<div class=\"section\">\n    <h2>Sprint Planning</h2>\n    <label for=\"sprintLength\">Sprint Length (days): </label>\n    <input type=\"number\" id=\"sprintLength\" value=\"2\" min=\"1\" />\n    <button onclick=\"setSprint()\">Set Sprint</button>\n    <p id=\"sprintInfo\"></p>\n</div>\n\n<div class=\"section\">\n    <h2>Task Breakdown</h2>\n    <input type=\"text\" id=\"taskDescription\" placeholder=\"Enter task description\" />\n    <button onclick=\"addTask()\">Add Task</button>\n    <h3>Tasks:</h3>\n    <ul id=\"taskList\"></ul>\n</div>\n\n<div class=\"section\">\n    <h2>Task Status</h2>\n    <select id=\"taskSelect\">\n        <option>Select a task</option>\n    </select>\n    <button onclick=\"markAsDone()\">Mark as Done</button>\n    <h3>Completed Tasks:</h3>\n    <ul id=\"completedTaskList\"></ul>\n</div>\n\n<div class=\"section\">\n    <h2>Feedback Loop</h2>\n    <input type=\"text\" id=\"feedbackInput\" placeholder=\"Enter feedback\" />\n    <button onclick=\"addFeedback()\">Submit Feedback</button>\n    <h3>Feedback:</h3>\n    <ul id=\"feedbackList\"></ul>\n</div>\n\n<script>\n    let userStories = [];\n    let tasks = [];\n    let completedTasks = [];\n    let sprintLength = 2;\n\n    function addUserStory() {\n        const userStoryInput = document.getElementById('userStory');\n        const story = userStoryInput.value;\n        if (story) {\n            userStories.push(story);\n            userStoryInput.value = '';\n            updateUserStoryList();\n        }\n    }\n    \n    function updateUserStoryList() {\n        const userStoryList = document.getElementById('userStoryList');\n        userStoryList.innerHTML = userStories.map(story => `<li>${story}</li>`).join('');\n    }\n\n    function setSprint() {\n        sprintLength = document.getElementById('sprintLength').value;\n        document.getElementById('sprintInfo').innerText = `Sprint set for ${sprintLength} days.`;\n    }\n\n    function addTask() {\n        const taskInput = document.getElementById('taskDescription');\n        const task = taskInput.value;\n        if (task) {\n            tasks.push(task);\n            taskInput.value = '';\n            updateTaskList();\n            updateTaskSelect();\n        }\n    }\n\n    function updateTaskList() {\n        const taskList = document.getElementById('taskList');\n        taskList.innerHTML = tasks.map(task => `<li>${task}</li>`).join('');\n    }\n\n    function updateTaskSelect() {\n        const taskSelect = document.getElementById('taskSelect');\n        taskSelect.innerHTML = '<option>Select a task</option>' + tasks.map((task, index) => `<option value=\"${index}\">${task}</option>`).join('');\n    }\n\n    function markAsDone() {\n        const taskSelect = document.getElementById('taskSelect');\n        const selectedIndex = taskSelect.value;\n        if (selectedIndex !== \"Select a task\") {\n            completedTasks.push(tasks[selectedIndex]);\n            tasks.splice(selectedIndex, 1);\n            updateTaskList();\n            updateTaskSelect();\n            updateCompletedTaskList();\n        }\n    }\n\n    function updateCompletedTaskList() {\n        const completedTaskList = document.getElementById('completedTaskList');\n        completedTaskList.innerHTML = completedTasks.map(task => `<li>${task}</li>`).join('');\n    }\n\n    function addFeedback() {\n        const feedbackInput = document.getElementById('feedbackInput');\n        const feedback = feedbackInput.value;\n        if (feedback) {\n            const feedbackList = document.getElementById('feedbackList');\n            const newItem = document.createElement('li');\n            newItem.innerText = feedback;\n            feedbackList.appendChild(newItem);\n            feedbackInput.value = '';\n        }\n    }\n</script>\n\n</body>\n</html>"
