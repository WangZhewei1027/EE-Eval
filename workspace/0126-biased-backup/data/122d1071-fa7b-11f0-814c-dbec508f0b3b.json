    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Indexing</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: white;\n        }\n        input, select, textarea {\n            width: 100%;\n            padding: 0.5em;\n            margin: 0.5em 0;\n            border: 1px solid black;\n            border-radius: 0.5em;\n        }\n        button {\n            padding: 0.5em 1em;\n            margin: 0.5em 0;\n            border: none;\n            border-radius: 0.5em;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #ccc;\n        }\n        #example {\n            width: 80%;\n            margin: 40px auto;\n            padding: 0.5em;\n            border: 1px solid black;\n            border-radius: 0.5em;\n            background-color: white;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Indexing</h1>\n<h2>Multiple Interactive Controls</h2>\n<button id=\"button1\">Button 1</button>\n<button id=\"button2\">Button 2</button>\n<button id=\"button3\">Button 3</button>\n\n<h2>Complex State Transitions and User-Driven Workflows</h2>\n<select id=\"select1\">\n    <option value=\"option1\">Option 1</option>\n    <option value=\"option2\">Option 2</option>\n    <option value=\"option3\">Option 3</option>\n</select>\n\n<h2>Deep Exploration Capabilities</h2>\n<input id=\"input1\" type=\"text\" placeholder=\"Enter text here\">\n<button id=\"button4\">Submit</button>\n\n<h2>Rich Functionality</h2>\n<p>This is a simple text editor with the following features:</p>\n<ul>\n    <li>Text input</li>\n    <li>Submit button</li>\n</ul>\n\n<script>\n    // Define the button click handlers\n    document.getElementById('button1').addEventListener('click', function() {\n        alert('Button 1 clicked!');\n    });\n\n    document.getElementById('button2').addEventListener('click', function() {\n        alert('Button 2 clicked!');\n    });\n\n    document.getElementById('button3').addEventListener('click', function() {\n        alert('Button 3 clicked!');\n    });\n\n    // Define the select change handler\n    document.getElementById('select1').addEventListener('change', function() {\n        alert('Select changed to: ' + this.value);\n    });\n\n    // Define the input field change handler\n    document.getElementById('input1').addEventListener('input', function() {\n        alert('Input field changed to: ' + this.value);\n    });\n\n    // Define the submit button click handler\n    document.getElementById('button4').addEventListener('click', function() {\n        alert('Submit button clicked!');\n    });\n</script>\n\n<div id=\"example\">\n    <p>This is an example text editor.</p>\n    <button id=\"submit\">Submit</button>\n</div>\n\n</body>\n</html>"
