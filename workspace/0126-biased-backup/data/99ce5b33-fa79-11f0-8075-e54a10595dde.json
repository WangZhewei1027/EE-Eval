    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree Visualization</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #btreeDisplay { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>B-Tree Interactive Demo</h1>\n\n    <label for=\"order\">B-Tree Order (Number of Children): </label>\n    <input type=\"number\" id=\"order\" value=\"3\" min=\"2\" max=\"10\">\n    <button id=\"createTree\">Create B-Tree</button>\n    \n    <h2>Tree Operations</h2>\n    <label for=\"insertValue\">Insert Value: </label>\n    <input type=\"number\" id=\"insertValue\">\n    <button id=\"insertButton\">Insert</button>\n\n    <br><br>\n\n    <label for=\"deleteValue\">Delete Value: </label>\n    <input type=\"number\" id=\"deleteValue\">\n    <button id=\"deleteButton\">Delete</button>\n    \n    <h2>B-Tree Structure</h2>\n    <div id=\"btreeDisplay\"></div>\n\n    <script>\n        class BTreeNode {\n            constructor(t, leaf = true) {\n                this.t = t; // Minimum degree\n                this.leaf = leaf; // True if leaf node\n                this.keys = []; // Array of keys\n                this.children = []; // Child array\n            }\n\n            insertNonFull(key) {\n                let i = this.keys.length - 1;\n\n                if (this.leaf) {\n                    while (i >= 0 && key < this.keys[i]) {\n                        i--;\n                    }\n                    this.keys.splice(i + 1, 0, key);\n                } else {\n                    while (i >= 0 && key < this.keys[i]) {\n                        i--;\n                    }\n                    if (this.children[i + 1].keys.length === 2 * this.t - 1) {\n                        this.splitChild(i + 1);\n                        if (key > this.keys[i + 1]) {\n                            i++;\n                        }\n                    }\n                    this.children[i + 1].insertNonFull(key);\n                }\n            }\n\n            splitChild(i) {\n                const t = this.t;\n                const y = this.children[i];\n                const z = new BTreeNode(y.t, y.leaf);\n                \n                this.keys.splice(i, 0, y.keys[t - 1]);\n                this.children.splice(i + 1, 0, z);\n                \n                z.keys = y.keys.splice(t, t - 1);\n                if (!y.leaf) {\n                    z.children = y.children.splice(t, t);\n                }\n            }\n        }\n\n        class BTree {\n            constructor(t) {\n                this.root = new BTreeNode(t);\n                this.t = t;\n            }\n\n            insert(key) {\n                const root = this.root;\n                if (root.keys.length === 2 * this.t - 1) {\n                    const s = new BTreeNode(this.t, false);\n                    s.children.push(root);\n                    s.splitChild(0);\n                    s.insertNonFull(key);\n                    this.root = s;\n                } else {\n                    root.insertNonFull(key);\n                }\n            }\n\n            delete(key) {\n                // Deletion logic can be implemented if necessary\n            }\n\n            display(node = this.root) {\n                let result = \"Keys: \" + node.keys.join(\", \") + \"<br>\";\n                if (!node.leaf) {\n                    for (let i = 0; i < node.children.length; i++) {\n                        result += this.display(node.children[i]);\n                    }\n                }\n                return result;\n            }\n        }\n\n        let bTree;\n\n        document.getElementById('createTree').onclick = function() {\n            const order = parseInt(document.getElementById('order').value);\n            bTree = new BTree(order);\n            document.getElementById('btreeDisplay').innerHTML = \"B-Tree created with order \" + order;\n        };\n\n        document.getElementById('insertButton').onclick = function() {\n            const value = parseInt(document.getElementById('insertValue').value);\n            if (bTree) {\n                bTree.insert(value);\n                document.getElementById('btreeDisplay').innerHTML = bTree.display();\n            } else {\n                alert(\"Please create a B-Tree first.\");\n            }\n        };\n\n        document.getElementById('deleteButton').onclick = function() {\n            const value = parseInt(document.getElementById('deleteValue').value);\n            if (bTree) {\n                bTree.delete(value);\n                // Update display after deletion (not implemented)\n                // document.getElementById('btreeDisplay').innerHTML = bTree.display();\n            } else {\n                alert(\"Please create a B-Tree first.\");\n            }\n        };\n    </script>\n</body>\n</html>"
