    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Context Switching - Visual Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n  /* Reset */\n  * {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0; height: 100%;\n    background: linear-gradient(135deg, #2c3e50 0%, #4ca1af 100%);\n    font-family: 'Poppins', sans-serif;\n    color: #f0f4f8;\n    overflow-x: hidden;\n    user-select: none;\n  }\n  h1 {\n    font-weight: 600;\n    font-size: 3.4rem;\n    letter-spacing: 0.06em;\n    margin: 0 0 0.3em 0;\n  }\n  h2 {\n    font-weight: 300;\n    font-size: 1.2rem;\n    color: rgba(240,244,248,0.7);\n    margin: 0 0 2.4em 0;\n    letter-spacing: 0.06em;\n  }\n  .wrapper {\n    max-width: 960px;\n    margin: 3.5rem auto 6rem;\n    padding: 0 2rem;\n    text-align: center;\n  }\n  .button-container {\n    margin-top: 3rem;\n  }\n  button {\n    background: #6dd5ed;\n    background: linear-gradient(45deg, #6dd5ed 0%, #2193b0 100%);\n    border: none;\n    border-radius: 32px;\n    color: #f0f4f8;\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.06em;\n    padding: 0.95rem 3.2rem;\n    cursor: pointer;\n    box-shadow: 0 8px 16px rgb(33 147 176 / 0.5);\n    transition: background 0.4s ease, box-shadow 0.4s ease, transform 0.2s ease;\n  }\n  button:hover {\n    background: #43cea2;\n    background: linear-gradient(45deg, #43cea2 0%, #185a9d 100%);\n    box-shadow: 0 14px 24px rgb(24 90 157 / 0.6);\n    transform: translateY(-3px);\n  }\n  button:active {\n    transform: translateY(0);\n    box-shadow: 0 6px 12px rgb(24 90 157 / 0.45);\n  }\n  /* Context Switcher Container */\n  #contextSwitcher {\n    position: relative;\n    height: 420px;\n    margin: 0 auto;\n    max-width: 900px;\n    border-radius: 28px;\n    background: radial-gradient(circle at center, #1f3a5f 0%, #122a44 85%);\n    box-shadow:\n      inset 0 0 40px #3fa9f5aa,\n      0 15px 40px #0e243fcc;\n    overflow: visible;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  /* Circle background representing brain/task bubble */\n  .brain-area {\n    position: absolute;\n    border-radius: 50%;\n    filter: drop-shadow(0 0 4px #5dc1ffaa);\n    animation: pulseGlow 4s ease-in-out infinite alternate;\n  }\n  .brain-primary {\n    width: 320px;\n    height: 320px;\n    background: radial-gradient(circle at 30% 30%, #5599ffcc 0%, #1b2e5fcc 85%);\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    box-shadow:\n      0 0 30px 14px #5599ff88 inset,\n      0 8px 28px #5599ffbb;\n    border: 2.4px solid #7db9ffcc;\n  }\n  .brain-secondary {\n    width: 220px;\n    height: 220px;\n    background: radial-gradient(circle at 70% 70%, #42d392cc 0%, #266e5199 80%);\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    filter: drop-shadow(0 0 6px #42d392dd);\n    border: 1.8px solid #4ade8088;\n  }\n  @keyframes pulseGlow {\n    0% {\n      box-shadow:\n        inset 0 0 30px #5599ff99,\n        0 0 40px #5599ffbb;\n    }\n    100% {\n      box-shadow:\n        inset 0 0 40px #7fb9ffcc,\n        0 0 55px #7fb9ffcc;\n    }\n  }\n  /* Context labels and nodes */\n  .context-node {\n    position: absolute;\n    width: 88px;\n    height: 88px;\n    background: linear-gradient(145deg, #1f3e6f 0%, #3f6ecf 80%);\n    border-radius: 18px;\n    box-shadow: 0 0 18px #58a1ffee, 0 14px 24px #3d6bccaa;\n    color: #d9e6ff;\n    font-weight: 600;\n    font-size: 1.1rem;\n    text-align: center;\n    line-height: 1.2;\n    padding: 1.7rem 0.8rem 0 0.8rem;\n    user-select: none;\n    letter-spacing: 0.04em;\n    transition:\n      transform 0.9s cubic-bezier(0.4, 0.0, 0.2, 1),\n      box-shadow 0.7s ease,\n      background 0.8s ease;\n  }\n  .context-node p {\n    margin: 0;\n    color: #bbd7ffcc;\n    font-weight: 300;\n    font-size: 0.72rem;\n    opacity: 0.75;\n    letter-spacing: 0.04em;\n  }\n  /* Positions for the 5 contexts */\n  .context1 { top: 46%; left: 18%; }\n  .context2 { top: 18%; left: 70%; }\n  .context3 { top: 72%; left: 72%; }\n  .context4 { top: 80%; left: 32%; }\n  .context5 { top: 32%; left: 48%; }\n\n  /* Highlight active context node */\n  .active {\n    background: linear-gradient(135deg, #ff9a59 0%, #ff6040 100%);\n    box-shadow:\n      0 0 26px #ff8540cc,\n      0 12px 28px #ff4f260f,\n      0 0 18px #ff613426 inset;\n    color: #ffe8d4;\n  }\n  .active p {\n    color: #ffd9bbdd;\n  }\n\n  /* Connecting Arcs (Context Switching Paths) */\n  svg.connections {\n    position: absolute;\n    top: 50%; left: 50%;\n    width: 680px; height: 400px;\n    transform: translate(-50%, -50%);\n    pointer-events: none;\n    overflow: visible;\n  }\n  svg.connections path {\n    fill: none;\n    stroke: #619fdfbb;\n    stroke-width: 2.8;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 12px #619fdf66);\n    transition: stroke 0.7s ease;\n  }\n\n  svg.connections path.active-path {\n    stroke: #ff7c42cc;\n    stroke-width: 3.6;\n    filter: drop-shadow(0 0 18px #ff7c4266);\n    animation: pathGlow 1.8s ease-in-out infinite alternate;\n  }\n  @keyframes pathGlow {\n    0% {\n      stroke-width: 3.6;\n      filter: drop-shadow(0 0 18px #ff7c4266);\n      stroke-opacity: 0.65;\n    }\n    100% {\n      stroke-width: 4.4;\n      filter: drop-shadow(0 0 26px #ff7c4277);\n      stroke-opacity: 1;\n    }\n  }\n\n  /* Tooltip styling for node labels on hover (optional minimal) */\n  .context-node:hover {\n    box-shadow:\n      0 0 28px #81b3ffdd,\n      0 16px 32px #3a71ccbb;\n    transition: box-shadow 0.3s ease;\n  }\n\n  /* Subtitle with subtle shadow */\n  .tagline {\n    font-weight: 300;\n    font-size: 1.05rem;\n    color: #aacedfbb;\n    margin-bottom: 7rem;\n    letter-spacing: 0.1em;\n    text-shadow: 0 0 8px #2b5673bb;\n  }\n</style>\n</head>\n<body>\n  <div class=\"wrapper\" role=\"main\" aria-label=\"Context Switching visualization\">\n    <h1>Context Switching</h1>\n    <h2 class=\"tagline\">Seamlessly shifting your mental focus between diverse tasks</h2>\n    <div id=\"contextSwitcher\" aria-live=\"polite\" aria-atomic=\"true\" aria-label=\"Context switching visualization\">\n      <div class=\"brain-area brain-secondary\"></div>\n      <div class=\"brain-area brain-primary\"></div>\n\n      <!-- Context Nodes -->\n      <div class=\"context-node context1 active\" data-index=\"0\" aria-label=\"Context 1: Email Management\" tabindex=\"0\">\n        Email<br/><p>Management</p>\n      </div>\n      <div class=\"context-node context2\" data-index=\"1\" aria-label=\"Context 2: Code Review\" tabindex=\"0\">\n        Code<br/><p>Review</p>\n      </div>\n      <div class=\"context-node context3\" data-index=\"2\" aria-label=\"Context 3: Meeting Prep\" tabindex=\"0\">\n        Meeting<br/><p>Prep</p>\n      </div>\n      <div class=\"context-node context4\" data-index=\"3\" aria-label=\"Context 4: Design Work\" tabindex=\"0\">\n        Design<br/><p>Work</p>\n      </div>\n      <div class=\"context-node context5\" data-index=\"4\" aria-label=\"Context 5: Documentation\" tabindex=\"0\">\n        Documentation<br/><p>Tasks</p>\n      </div>\n\n      <!-- SVG Connections -->\n      <svg class=\"connections\" aria-hidden=\"true\" focusable=\"false\" viewBox=\"0 0 680 400\" >\n        <!-- Arcs connecting nodes in sequence -->\n        <path class=\"connection-path\" d=\"M120 190 Q170 60 430 80\" />\n        <path class=\"connection-path\" d=\"M430 80 Q470 150 515 287\" />\n        <path class=\"connection-path\" d=\"M515 287 Q510 350 280 335\" />\n        <path class=\"connection-path\" d=\"M280 335 Q150 330 120 200\" />\n        <path class=\"connection-path\" d=\"M120 200 Q210 250 335 160\" />\n      </svg>\n    </div>\n    <div class=\"button-container\" role=\"region\" aria-label=\"Control buttons to switch context\">\n      <button id=\"prevBtn\" aria-controls=\"contextSwitcher\" aria-label=\"Switch to previous context\">← Previous</button>\n      <button id=\"nextBtn\" aria-controls=\"contextSwitcher\" aria-label=\"Switch to next context\">Next →</button>\n    </div>\n  </div>\n\n<script>\n  (() => {\n    const contexts = [\n      { label: \"Email Management\" },\n      { label: \"Code Review\" },\n      { label: \"Meeting Prep\" },\n      { label: \"Design Work\" },\n      { label: \"Documentation Tasks\" },\n    ];\n    const nodes = document.querySelectorAll('.context-node');\n    const paths = document.querySelectorAll('.connections path.connection-path');\n    let activeIndex = 0;\n\n    // Helper: Update UI for active context\n    function updateActiveContext(newIndex) {\n      if (newIndex === activeIndex) return;\n      // Remove active classes from old node\n      nodes[activeIndex].classList.remove('active');\n      paths[activeIndex].classList.remove('active-path');\n      // Clear aria-live for old node\n      nodes[activeIndex].setAttribute('aria-pressed', 'false');\n\n      activeIndex = newIndex;\n\n      // Add active classes on new node\n      nodes[activeIndex].classList.add('active');\n      paths[activeIndex].classList.add('active-path');\n      nodes[activeIndex].setAttribute('aria-pressed', 'true');\n\n      // For accessibility: announce new focus\n      const liveRegion = document.getElementById('contextSwitcher');\n      liveRegion.setAttribute('aria-label', `Context switching visualization: Current context is ${contexts[activeIndex].label}`);\n\n      // Animate subtle context \"pulse\" on active node\n      pulseNode(nodes[activeIndex]);\n    }\n\n    // Subtle pulse animation on node for emphasis\n    function pulseNode(node) {\n      node.animate([\n        { transform: 'scale(1)', boxShadow: '0 0 18px #ff8540cc, 0 12px 28px #ff4f260f, 0 0 18px #ff613426 inset' },\n        { transform: 'scale(1.08)', boxShadow: '0 0 27px #ff9e6022, 0 22px 38px #ff7c420d, 0 0 22px #fb6e2012 inset' },\n        { transform: 'scale(1)', boxShadow: '0 0 18px #ff8540cc, 0 12px 28px #ff4f260f, 0 0 18px #ff613426 inset' }\n      ], {\n        duration: 700,\n        easing: 'ease-in-out',\n        iterations: 1\n      });\n    }\n\n    // Handle button clicks\n    document.getElementById('prevBtn').addEventListener('click', () => {\n      let newIndex = (activeIndex - 1 + contexts.length) % contexts.length;\n      updateActiveContext(newIndex);\n    });\n    document.getElementById('nextBtn').addEventListener('click', () => {\n      let newIndex = (activeIndex + 1) % contexts.length;\n      updateActiveContext(newIndex);\n    });\n\n    // Initialize active path style for first active context\n    paths[activeIndex].classList.add('active-path');\n    nodes[activeIndex].setAttribute('aria-pressed', 'true');\n\n  })();\n</script>\n</body>\n</html>"
