    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Abstract Syntax Tree</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: white;\n        }\n        input {\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.2);\n        }\n        button {\n            padding: 10px 20px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.2);\n        }\n        button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Abstract Syntax Tree</h1>\n\n<div id=\"tree\"></div>\n\n<div id=\"controls\">\n    <label for=\"type\">Type:</label>\n    <input type=\"radio\" id=\"function\" name=\"type\" value=\"function\" checked>\n    <label for=\"function\">Function</label>\n    <label for=\"variable\">Variable</label>\n    <input type=\"radio\" id=\"variable\" name=\"type\" value=\"variable\">\n    <label for=\"variable\">Variable</label>\n    <button id=\"add-button\">Add</button>\n    <button id=\"remove-button\">Remove</button>\n    <button id=\"edit-button\">Edit</button>\n</div>\n\n<div id=\"code\" style=\"display: none;\">\n    <pre id=\"code-print\"></pre>\n</div>\n\n<script>\n    const tree = document.getElementById('tree');\n    const controls = document.getElementById('controls');\n    const code = document.getElementById('code');\n    const codePrint = document.getElementById('code-print');\n\n    let currentType = 'function';\n    let currentCode = '';\n\n    function addNode(node, type) {\n        const nodeElement = document.createElement('div');\n        nodeElement.className = 'node';\n        nodeElement.textContent = `${node.type} ${node.value}`;\n\n        if (type === 'function') {\n            nodeElement.classList.add('function');\n        } else if (type === 'variable') {\n            nodeElement.classList.add('variable');\n        }\n\n        tree.appendChild(nodeElement);\n\n        if (node.type === 'function') {\n            addNode(node.children[0], 'variable');\n        } else if (node.type === 'variable') {\n            addNode(node.children[0], 'function');\n        }\n    }\n\n    function removeNode(node) {\n        const parent = node.parentNode;\n        parent.removeChild(node);\n\n        if (node.type === 'function') {\n            removeNode(node.children[0]);\n        } else if (node.type === 'variable') {\n            removeNode(node.children[0]);\n        }\n    }\n\n    function editNode(node, value) {\n        const parent = node.parentNode;\n        const newNode = document.createElement('div');\n        newNode.className = 'node';\n        newNode.textContent = `${node.type} ${value}`;\n\n        if (node.type === 'function') {\n            newNode.classList.add('function');\n        } else if (node.type === 'variable') {\n            newNode.classList.add('variable');\n        }\n\n        parent.replaceChild(newNode, node);\n\n        if (node.type === 'function') {\n            removeNode(node.children[0]);\n        } else if (node.type === 'variable') {\n            removeNode(node.children[0]);\n        }\n    }\n\n    function updateCode() {\n        if (currentType === 'function') {\n            const codeElement = document.getElementById('code-print');\n            codeElement.textContent = currentCode;\n        } else if (currentType === 'variable') {\n            const codeElement = document.getElementById('code-print');\n            codeElement.textContent = '';\n        }\n    }\n\n    function updateCodeValue(value) {\n        currentCode += value + '\\n';\n        updateCode();\n    }\n\n    function addEventListeners() {\n        const addButton = document.getElementById('add-button');\n        addButton.addEventListener('click', addNode);\n\n        const removeButton = document.getElementById('remove-button');\n        removeButton.addEventListener('click', removeNode);\n\n        const editButton = document.getElementById('edit-button');\n        editButton.addEventListener('click', editNode);\n\n        const codePrint = document.getElementById('code-print');\n        codePrint.addEventListener('input', updateCode);\n\n        addButton.addEventListener('click', () => {\n            const type = prompt('Enter type (function/variable):');\n            currentType = type;\n            currentCode = '';\n            updateCode();\n        });\n\n        removeButton.addEventListener('click', () => {\n            const type = prompt('Enter type (function/variable):');\n            currentType = type;\n            currentCode = '';\n            updateCode();\n        });\n\n        editButton.addEventListener('click', () => {\n            const value = prompt('Enter value:');\n            editNode(currentType, value);\n        });\n\n        codePrint.addEventListener('input', updateCode);\n    }\n\n    addEventListeners();\n\n    // Add initial code\n    currentType = 'function';\n    currentCode = 'function add 2 3';\n    updateCode();\n\n    // Update code on user input\n    function updateCodeEvent(event) {\n        const value = event.target.value;\n        updateCodeValue(value);\n    }\n\n    // Update code on user click\n    const addButton = document.getElementById('add-button');\n    addButton.addEventListener('click', updateCodeEvent);\n\n    const removeButton = document.getElementById('remove-button');\n    removeButton.addEventListener('click', updateCodeEvent);\n\n    const editButton = document.getElementById('edit-button');\n    editButton.addEventListener('click', updateCodeEvent);\n</script>\n\n</body>\n</html>"
