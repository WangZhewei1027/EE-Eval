  "status": "success",
  "question": "Agile Methodology",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Agile Methodology Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 1000px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        .panel {\n            border: 1px solid #ccc;\n            padding: 15px;\n            margin-bottom: 20px;\n        }\n        button, select, input {\n            margin: 5px;\n            padding: 5px;\n        }\n        .hidden {\n            display: none;\n        }\n        .active {\n            background-color: #f0f0f0;\n        }\n        .user-story {\n            border: 1px solid #ddd;\n            padding: 10px;\n            margin: 5px 0;\n        }\n        .sprint {\n            border: 1px solid #000;\n            padding: 10px;\n            margin: 10px 0;\n        }\n        #board {\n            display: grid;\n            grid-template-columns: repeat(4, 1fr);\n            gap: 10px;\n        }\n        .board-column {\n            border: 1px solid #999;\n            padding: 10px;\n            min-height: 200px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Agile Methodology Interactive Demo</h1>\n    \n    <div class=\"panel\">\n        <h2>Agile Process Simulator</h2>\n        <div>\n            <button id=\"startProject\">Start New Project</button>\n            <button id=\"startSprint\">Start Sprint</button>\n            <button id=\"showRetro\">Hold Retrospective</button>\n            <button id=\"showMetrics\">Show Metrics</button>\n        </div>\n        \n        <div id=\"projectSetup\" class=\"hidden\">\n            <h3>Project Setup</h3>\n            <div>\n                <label>Project Name: <input type=\"text\" id=\"projectName\"></label>\n                <label>Team Size: <input type=\"number\" id=\"teamSize\" min=\"1\" max=\"20\" value=\"5\"></label>\n                <label>Sprint Length (weeks): <input type=\"number\" id=\"sprintLength\" min=\"1\" max=\"4\" value=\"2\"></label>\n            </div>\n            <div>\n                <button id=\"createBacklog\">Create Product Backlog</button>\n            </div>\n        </div>\n        \n        <div id=\"backlogCreation\" class=\"hidden\">\n            <h3>Product Backlog</h3>\n            <div>\n                <label>Add User Story: <input type=\"text\" id=\"newStory\"></label>\n                <label>Story Points: <input type=\"number\" id=\"storyPoints\" min=\"1\" max=\"20\" value=\"3\"></label>\n                <button id=\"addStory\">Add Story</button>\n            </div>\n            <div id=\"backlogItems\"></div>\n            <div>\n                <button id=\"prioritizeBacklog\">Prioritize Backlog</button>\n                <button id=\"proceedToSprint\">Proceed to Sprint Planning</button>\n            </div>\n        </div>\n        \n        <div id=\"sprintPlanning\" class=\"hidden\">\n            <h3>Sprint Planning</h3>\n            <div>\n                <label>Select Stories for Sprint (Capacity: <span id=\"teamCapacity\">0</span> points):</label>\n                <div id=\"sprintSelection\"></div>\n            </div>\n            <div>\n                <button id=\"startSelectedSprint\">Start Selected Sprint</button>\n            </div>\n        </div>\n        \n        <div id=\"activeSprint\" class=\"hidden\">\n            <h3>Active Sprint: <span id=\"currentSprintNum\">1</span></h3>\n            <div>\n                <label>Day: <span id=\"currentDay\">1</span>/<span id=\"totalDays\">14</span></label>\n                <button id=\"advanceDay\">Advance Day</button>\n                <button id=\"completeSprint\">Complete Sprint</button>\n            </div>\n            \n            <div id=\"board\">\n                <div class=\"board-column\">\n                    <h4>To Do</h4>\n                    <div id=\"todoColumn\"></div>\n                </div>\n                <div class=\"board-column\">\n                    <h4>In Progress</h4>\n                    <div id=\"inProgressColumn\"></div>\n                </div>\n                <div class=\"board-column\">\n                    <h4>In Review</h4>\n                    <div id=\"inReviewColumn\"></div>\n                </div>\n                <div class=\"board-column\">\n                    <h4>Done</h4>\n                    <div id=\"doneColumn\"></div>\n                </div>\n            </div>\n            \n            <div>\n                <h4>Daily Standup</h4>\n                <div id=\"standupNotes\"></div>\n                <label>Add Note: <input type=\"text\" id=\"newStandupNote\"></label>\n                <button id=\"addStandupNote\">Add Note</button>\n            </div>\n        </div>\n        \n        <div id=\"sprintReview\" class=\"hidden\">\n            <h3>Sprint Review</h3>\n            <div id=\"reviewResults\"></div>\n            <button id=\"proceedToRetro\">Proceed to Retrospective</button>\n        </div>\n        \n        <div id=\"retrospective\" class=\"hidden\">\n            <h3>Retrospective</h3>\n            <div>\n                <h4>What went well:</h4>\n                <div id=\"wentWell\"></div>\n                <label>Add item: <input type=\"text\" id=\"newWentWell\"></label>\n                <button id=\"addWentWell\">Add</button>\n            </div>\n            <div>\n                <h4>What could be improved:</h4>\n                <div id=\"improve\"></div>\n                <label>Add item: <input type=\"text\" id=\"newImprove\"></label>\n                <button id=\"addImprove\">Add</button>\n            </div>\n            <div>\n                <h4>Action items:</h4>\n                <div id=\"actionItems\"></div>\n                <label>Add item: <input type=\"text\" id=\"newActionItem\"></label>\n                <button id=\"addActionItem\">Add</button>\n            </div>\n            <button id=\"completeRetro\">Complete Retrospective</button>\n        </div>\n        \n        <div id=\"metrics\" class=\"hidden\">\n            <h3>Project Metrics</h3>\n            <div>\n                <label>Show: \n                    <select id=\"metricType\">\n                        <option value=\"velocity\">Velocity</option>\n                        <option value=\"burndown\">Burndown</option>\n                        <option value=\"cycleTime\">Cycle Time</option>\n                    </select>\n                </label>\n            </div>\n            <div id=\"metricDisplay\"></div>\n        </div>\n    </div>\n    \n    <div class=\"panel\">\n        <h2>Agile Concepts Explorer</h2>\n        <div>\n            <button class=\"concept-btn\" data-concept=\"scrum\">Scrum</button>\n            <button class=\"concept-btn\" data-concept=\"kanban\">Kanban</button>\n            <button class=\"concept-btn\" data-concept=\"xp\">XP</button>\n            <button class=\"concept-btn\" data-concept=\"backlog\">Backlog</button>\n            <button class=\"concept-btn\" data-concept=\"sprint\">Sprint</button>\n            <button class=\"concept-btn\" data-concept=\"standup\">Daily Standup</button>\n            <button class=\"concept-btn\" data-concept=\"retro\">Retrospective</button>\n        </div>\n        <div id=\"conceptInfo\" class=\"panel hidden\">\n            <h3 id=\"conceptTitle\">Concept</h3>\n            <div id=\"conceptDescription\"></div>\n            <div id=\"conceptInteractive\"></div>\n        </div>\n    </div>\n    \n    <script>\n        // State management\n        const state = {\n            project: null,\n            backlog: [],\n            activeSprint: null,\n            completedSprints: [],\n            currentDay: 1,\n            metrics: {\n                velocity: [],\n                burndown: [],\n                cycleTime: []\n            }\n        };\n        \n        // DOM elements\n        const elements = {\n            projectSetup: document.getElementById('projectSetup'),\n            backlogCreation: document.getElementById('backlogCreation'),\n            sprintPlanning: document.getElementById('sprintPlanning'),\n            activeSprint: document.getElementById('activeSprint'),\n            sprintReview: document.getElementById('sprintReview'),\n            retrospective: document.getElementById('retrospective'),\n            metrics: document.getElementById('metrics')\n        };\n        \n        // Initialize\n        document.getElementById('startProject').addEventListener('click', startProject);\n        document.getElementById('createBacklog').addEventListener('click', createBacklog);\n        document.getElementById('addStory').addEventListener('click', addStory);\n        document.getElementById('prioritizeBacklog').addEventListener('click', prioritizeBacklog);\n        document.getElementById('proceedToSprint').addEventListener('click', proceedToSprint);\n        document.getElementById('startSelectedSprint').addEventListener('click', startSelectedSprint);\n        document.getElementById('advanceDay').addEventListener('click', advanceDay);\n        document.getElementById('completeSprint').addEventListener('click', completeSprint);\n        document.getElementById('proceedToRetro').addEventListener('click', proceedToRetro);\n        document.getElementById('completeRetro').addEventListener('click', completeRetro);\n        document.getElementById('startSprint').addEventListener('click', () => {\n            if (state.project && state.backlog.length > 0) {\n                showPanel('sprintPlanning');\n                renderSprintPlanning();\n            }\n        });\n        document.getElementById('showRetro').addEventListener('click', () => {\n            if (state.completedSprints.length > 0) {\n                showPanel('retrospective');\n            }\n        });\n        document.getElementById('showMetrics').addEventListener('click', () => {\n            if (state.project) {\n                showPanel('metrics');\n                renderMetrics();\n            }\n        });\n        \n        // Concept buttons\n        document.querySelectorAll('.concept-btn').forEach(btn => {\n            btn.addEventListener('click', () => showConcept(btn.dataset.concept));\n        });\n        \n        // Functions\n        function startProject() {\n            const projectName = document.getElementById('projectName').value || 'New Project';\n            const teamSize = parseInt(document.getElementById('teamSize').value) || 5;\n            const sprintLength = parseInt(document.getElementById('sprintLength').value) || 2;\n            \n            state.project = {\n                name: projectName,\n                teamSize: teamSize,\n                sprintLength: sprintLength,\n                currentSprint: 1\n            };\n            \n            showPanel('backlogCreation');\n        }\n        \n        function createBacklog() {\n            showPanel('backlogCreation');\n        }\n        \n        function addStory() {\n            const description = document.getElementById('newStory').value;\n            const points = parseInt(document.getElementById('storyPoints').value) || 3;\n            \n            if (description) {\n                state.backlog.push({\n                    id: Date.now(),\n                    description: description,\n                    points: points,\n                    priority: state.backlog.length + 1\n                });\n                \n                document.getElementById('newStory').value = '';\n                renderBacklog();\n            }\n        }\n        \n        function renderBacklog() {\n            const container = document.getElementById('backlogItems');\n            container.innerHTML = '';\n            \n            state.backlog.forEach(item => {\n                const div = document.createElement('div');\n                div.className = 'user-story';\n                div.innerHTML = `\n                    <div>${item.priority}. ${item.description} (${item.points} points)</div>\n                `;\n                container.appendChild(div);\n            });\n        }\n        \n        function prioritizeBacklog() {\n            // Simple shuffle for demo purposes\n            state.backlog = state.backlog.sort(() => Math.random() - 0.5);\n            state.backlog.forEach((item, index) => item.priority = index + 1);\n            renderBacklog();\n        }\n        \n        function proceedToSprint() {\n            showPanel('sprintPlanning');\n            renderSprintPlanning();\n        }\n        \n        function renderSprintPlanning() {\n            const capacity = state.project.teamSize * state.project.sprintLength * 3; // 3 points per person per week\n            document.getElementById('teamCapacity').textContent = capacity;\n            \n            const container = document.getElementById('sprintSelection');\n            container.innerHTML = '';\n            \n            state.backlog.forEach(item => {\n                const div = document.createElement('div');\n                div.className = 'user-story';\n                div.innerHTML = `\n                    <input type=\"checkbox\" id=\"story-${item.id}\" data-points=\"${item.points}\">\n                    <label for=\"story-${item.id}\">${item.priority}. ${item.description} (${item.points} points)</label>\n                `;\n                container.appendChild(div);\n            });\n        }\n        \n        function startSelectedSprint() {\n            const checkboxes = document.querySelectorAll('#sprintSelection input[type=\"checkbox\"]:checked');\n            const selectedStories = [];\n            let totalPoints = 0;\n            \n            checkboxes.forEach(cb => {\n                const id = parseInt(cb.id.split('-')[1]);\n                const story = state.backlog.find(s => item.id === id);\n                if (story) {\n                    selectedStories.push({\n                        ...story,\n                        status: 'todo'\n                    });\n                    totalPoints += parseInt(cb.dataset.points);\n                }\n            });\n            \n            state.activeSprint = {\n                number: state.project.currentSprint,\n                stories: selectedStories,\n                totalPoints: totalPoints,\n                remainingPoints: totalPoints,\n                days: state.project.sprintLength * 7,\n                day: 1,\n                completed: false\n            };\n            \n            state.project.currentSprint++;\n            showPanel('activeSprint');\n            renderActiveSprint();\n        }\n        \n        function renderActiveSprint() {\n            document.getElementById('currentSprintNum').textContent = state.activeSprint.number;\n            document.getElementById('currentDay').textContent = state.activeSprint.day;\n            document.getElementById('totalDays').textContent = state.activeSprint.days;\n            \n            // Clear columns\n            document.getElementById('todoColumn').innerHTML = '';\n            document.getElementById('inProgressColumn').innerHTML = '';\n            document.getElementById('inReviewColumn').innerHTML = '';\n            document.getElementById('doneColumn').innerHTML = '';\n            \n            // Populate columns\n            state.activeSprint.stories.forEach(story => {\n                const div = document.createElement('div');\n                div.className = 'user-story';\n                div.textContent = `${story.description} (${story.points} points)`;\n                div.draggable = true;\n                div.dataset.id = story.id;\n                \n                div.addEventListener('dragstart', dragStart);\n                \n                switch(story.status) {\n                    case 'todo':\n                        document.getElementById('todoColumn').appendChild(div);\n                        break;\n                    case 'progress':\n                        document.getElementById('inProgressColumn').appendChild(div);\n                        break;\n                    case 'review':\n                        document.getElementById('inReviewColumn').appendChild(div);\n                        break;\n                    case 'done':\n                        document.getElementById('doneColumn').appendChild(div);\n                        break;\n                }\n            });\n            \n            // Setup drop targets\n            setupDropTarget('todoColumn', 'todo');\n            setupDropTarget('inProgressColumn', 'progress');\n            setupDropTarget('inReviewColumn', 'review');\n            setupDropTarget('doneColumn', 'done');\n        }\n        \n        function dragStart(e) {\n            e.dataTransfer.setData('text/plain', e.target.dataset.id);\n        }\n        \n        function setupDropTarget(elementId, status) {\n            const element = document.getElementById(elementId);\n            element.addEventListener('dragover', e => e.preventDefault());\n            element.addEventListener('drop', e => {\n                e.preventDefault();\n                const storyId = e.dataTransfer.getData('text/plain');\n                const story = state.activeSprint.stories.find(s => s.id.toString() === storyId);\n                if (story) {\n                    story.status = status;\n                    if (status === 'done') {\n                        state.activeSprint.remainingPoints -= story.points;\n                    }\n                    renderActiveSprint();\n                }\n            });\n        }\n        \n        function advanceDay() {\n            if (state.activeSprint.day < state.activeSprint.days) {\n                state.activeSprint.day++;\n                document.getElementById('currentDay').textContent = state.activeSprint.day;\n                \n                // Random progress simulation\n                state.activeSprint.stories.forEach(story => {\n                    if (story.status !== 'done' && Math.random() > 0.7) {\n                        const statuses = ['todo', 'progress', 'review', 'done'];\n                        const currentIndex = statuses.indexOf(story.status);\n                        if (currentIndex < statuses.length - 1) {\n                            story.status = statuses[currentIndex + 1];\n                            if (story.status === 'done') {\n                                state.activeSprint.remainingPoints -= story.points;\n                            }\n                        }\n                    }\n                });\n                \n                renderActiveSprint();\n            }\n        }\n        \n        function completeSprint() {\n            state.activeSprint.completed = true;\n            state.completedSprints.push(state.activeSprint);\n            state.activeSprint = null;\n            showPanel('sprintReview');\n            renderSprintReview();\n        }\n        \n        function renderSprintReview() {\n            const container = document.getElementById('reviewResults');\n            const sprint = state.completedSprints[state.completedSprints.length - 1];\n            \n            let completed = 0;\n            let notCompleted = 0;\n            \n            sprint.stories.forEach(story => {\n                if (story.status === 'done') completed += story.points;\n                else notCompleted += story.points;\n            });\n            \n            const completionRate = Math.round((completed / sprint.totalPoints) * 100);\n            \n            container.innerHTML = `\n                <p>Sprint ${sprint.number} completed!</p>\n                <p>Planned: ${sprint.totalPoints} points</p>\n                <p>Completed: ${completed} points (${completionRate}%)</p>\n                <p>Not completed: ${notCompleted} points</p>\n            `;\n            \n            // Update metrics\n            state.metrics.velocity.push(completed);\n            state.metrics.burndown.push({\n                sprint: sprint.number,\n                planned: sprint.totalPoints,\n                actual: completed\n            });\n        }\n        \n        function proceedToRetro() {\n            showPanel('retrospective');\n        }\n        \n        function completeRetro() {\n            showPanel('backlogCreation');\n        }\n        \n        function renderMetrics() {\n            const type = document.getElementById('metricType').value;\n            const container = document.getElementById('metricDisplay');\n            \n            switch(type) {\n                case 'velocity':\n                    container.innerHTML = `\n                        <p>Velocity (points per sprint):</p>\n                        <ul>\n                            ${state.metrics.velocity.map((v, i) => `<li>Sprint ${i+1}: ${v} points</li>`).join('')}\n                        </ul>\n                    `;\n                    break;\n                case 'burndown':\n                    container.innerHTML = `\n                        <p>Burndown (planned vs actual):</p>\n                        <ul>\n                            ${state.metrics.burndown.map(b => `\n                                <li>Sprint ${b.sprint}: \n                                    Planned ${b.planned}, Actual ${b.actual}\n                                </li>\n                            `).join('')}\n                        </ul>\n                    `;\n                    break;\n                case 'cycleTime':\n                    container.innerHTML = `<p>Cycle time data will be displayed here</p>`;\n                    break;\n            }\n        }\n        \n        function showPanel(panelName) {\n            // Hide all panels\n            Object.values(elements).forEach(panel => {\n                panel.classList.add('hidden');\n            });\n            \n            // Show selected panel\n            if (elements[panelName]) {\n                elements[panelName].classList.remove('hidden');\n            }\n        }\n        \n        // Concept explorer\n        const concepts = {\n            scrum: {\n                title: \"Scrum\",\n                description: \"Scrum is an agile framework for developing, delivering, and sustaining complex products. It emphasizes iterative development, cross-functional teams, and regular inspection and adaptation.\",\n                interactive: `\n                    <div class=\"sprint\">\n                        <h4>Scrum Process</h4>\n                        <ol>\n                            <li>Product Backlog Creation</li>\n                            <li>Sprint Planning</li>\n                            <li>Daily Scrum</li>\n                            <li>Sprint Review</li>\n                            <li>Sprint Retrospective</li>\n                        </ol>\n                        <button id=\"simulateScrum\">Simulate Scrum Cycle</button>\n                        <div id=\"scrumSimulation\"></div>\n                    </div>\n                `\n            },\n            kanban: {\n                title: \"Kanban\",\n                description: \"Kanban is a visual system for managing work as it moves through a process. It visualizes both the process and the actual work passing through that process.\",\n                interactive: `\n                    <div>\n                        <h4>Kanban Board</h4>\n                        <div style=\"display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;\">\n                            <div style=\"border: 1px solid #999; padding: 10px;\">\n                                <h5>Backlog</h5>\n                                <div class=\"kanban-item\" draggable=\"true\">Task 1</div>\n                                <div class=\"kanban-item\" draggable=\"true\">Task 2</div>\n                            </div>\n                            <div style=\"border: 1px solid #999; padding: 10px;\">\n                                <h5>To Do</h5>\n                            </div>\n                            <div style=\"border: 1px solid #999; padding: 10px;\">\n                                <h5>In Progress</h5>\n                            </div>\n                            <div style=\"border: 1px solid #999; padding: 10px;\">\n                                <h5>Done</h5>\n                            </div>\n                        </div>\n                        <p>Try dragging tasks between columns</p>\n                    </div>\n                `\n            },\n            xp: {\n                title: \"Extreme Programming (XP)\",\n                description: \"Extreme Programming is an agile software development methodology that improves software quality and responsiveness to changing customer requirements.\",\n                interactive: `\n                    <div>\n                        <h4>XP Practices</h4>\n                        <ul>\n                            <li><input type=\"checkbox\"> Pair Programming</li>\n                            <li><input type=\"checkbox\"> Test-Driven Development</li>\n                            <li><input type=\"checkbox\"> Continuous Integration</li>\n                            <li><input type=\"checkbox\"> Refactoring</li>\n                            <li><input type=\"checkbox\"> Small Releases</li>\n                        </ul>\n                        <button id=\"xpSimulate\">Simulate XP Project</button>\n                    </div>\n                `\n            },\n            backlog: {\n                title: \"Product Backlog\",\n                description: \"The product backlog is an ordered list of everything that is known to be needed in the product. It is the single source of requirements for any changes to be made to the product.\",\n                interactive: `\n                    <div>\n                        <h4>Backlog Management</h4>\n                        <div>\n                            <label>Add Item: <input type=\"text\" id=\"backlogItem\"></label>\n                            <button id=\"addBacklogItem\">Add</button>\n                        </div>\n                        <div id=\"backlogList\">\n                            <div>1. User login functionality (5 points)</div>\n                            <div>2. Product search (3 points)</div>\n                            <div>3. Shopping cart (8 points)</div>\n                        </div>\n                        <div>\n                            <button id=\"prioritizeBtn\">Prioritize</button>\n                            <button id=\"estimateBtn\">Estimate</button>\n                        </div>\n                    </div>\n                `\n            },\n            sprint: {\n                title: \"Sprint\",\n                description: \"A sprint is a time-boxed iteration of a continuous development cycle. During a sprint, a usable and potentially releasable product increment is created.\",\n                interactive: `\n                    <div class=\"sprint\">\n                        <h4>Sprint Simulation</h4>\n                        <div>\n                            <label>Sprint Length: \n                                <select id=\"sprintLengthSelect\">\n                                    <option value=\"1\">1 week</option>\n                                    <option value=\"2\" selected>2 weeks</option>\n                                    <option value=\"3\">3 weeks</option>\n                                    <option value=\"4\">4 weeks</option>\n                                </select>\n                            </label>\n                        </div>\n                        <div>\n                            <button id=\"startSprintSim\">Start Sprint</button>\n                            <button id=\"advanceDaySim\">Advance Day</button>\n                        </div>\n                        <div id=\"sprintSimStatus\">\n                            <p>Day: <span id=\"simDay\">0</span>/<span id=\"simTotalDays\">14</span></p>\n                            <p>Completed: <span id=\"simCompleted\">0</span> points</p>\n                        </div>\n                    </div>\n                `\n            },\n            standup: {\n                title: \"Daily Standup\",\n                description: \"The daily standup is a short (usually 15 minutes) meeting where the team synchronizes activities and creates a plan for the next 24 hours.\",\n                interactive: `\n                    <div>\n                        <h4>Standup Meeting</h4>\n                        <div>\n                            <p>Team Member 1: <input type=\"text\" placeholder=\"What did you do yesterday?\"></p>\n                            <p><input type=\"text\" placeholder=\"What will you do today?\"></p>\n                            <p><input type=\"text\" placeholder=\"Any impediments?\"></p>\n                        </div>\n                        <div>\n                            <p>Team Member 2: <input type=\"text\" placeholder=\"What did you do yesterday?\"></p>\n                            <p><input type=\"text\" placeholder=\"What will you do today?\"></p>\n                            <p><input type=\"text\" placeholder=\"Any impediments?\"></p>\n                        </div>\n                        <button id=\"completeStandup\">Complete Standup</button>\n                    </div>\n                `\n            },\n            retro: {\n                title: \"Retrospective\",\n                description: \"The sprint retrospective is an opportunity for the team to inspect itself and create a plan for improvements to be enacted during the next sprint.\",\n                interactive: `\n                    <div>\n                        <h4>Retrospective Board</h4>\n                        <div style=\"display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;\">\n                            <div style=\"border: 1px solid #999; padding: 10px;\">\n                                <h5>What went well</h5>\n                                <div class=\"retro-item\">Good collaboration</div>\n                                <div class=\"retro-item\">Met sprint goal</div>\n                            </div>\n                            <div style=\"border: 1px solid #999; padding: 10px;\">\n                                <h5>What to improve</h5>\n                                <div class=\"retro-item\">Testing coverage</div>\n                                <div class=\"retro-item\">Code reviews</div>\n                            </div>\n                            <div style=\"border: 1px solid #999; padding: 10px;\">\n                                <h5>Action items</h5>\n                                <div class=\"retro-item\">Implement CI pipeline</div>\n                                <div class=\"retro-item\">Schedule test training</div>\n                            </div>\n                        </div>\n                        <div>\n                            <label>Add item: <input type=\"text\" id=\"newRetroItem\"></label>\n                            <select id=\"retroCategory\">\n                                <option value=\"well\">Went well</option>\n                                <option value=\"improve\">To improve</option>\n                                <option value=\"action\">Action item</option>\n                            </select>\n                            <button id=\"addRetroItem\">Add</button>\n                        </div>\n                    </div>\n                `\n            }\n        };\n        \n        function showConcept(concept) {\n            const info = concepts[concept];\n            if (!info) return;\n            \n            document.getElementById('conceptTitle').textContent = info.title;\n            document.getElementById('conceptDescription').textContent = info.description;\n            document.getElementById('conceptInteractive').innerHTML = info.interactive;\n            \n            document.getElementById('conceptInfo').classList.remove('hidden');\n            \n            // Setup interactive elements for the concept\n            setupConceptInteractivity(concept);\n        }\n        \n        function setupConceptInteractivity(concept) {\n            // Setup interactivity specific to each concept\n            switch(concept) {\n                case 'scrum':\n                    document.getElementById('simulateScrum').addEventListener('click', simulateScrum);\n                    break;\n                case 'kanban':\n                    setupKanbanDragDrop();\n                    break;\n                case 'xp':\n                    document.getElementById('xpSimulate').addEventListener('click', simulateXP);\n                    break;\n                case 'backlog':\n                    document.getElementById('addBacklogItem').addEventListener('click', addBacklogItem);\n                    document.getElementById('prioritizeBtn').addEventListener('click', prioritizeBacklogSim);\n                    document.getElementById('estimateBtn').addEventListener('click', estimateBacklog);\n                    break;\n                case 'sprint':\n                    document.getElementById('startSprintSim').addEventListener('click', startSprintSim);\n                    document.getElementById('advanceDaySim').addEventListener('click', advanceDaySim);\n                    break;\n                case 'standup':\n                    document.getElementById('completeStandup').addEventListener('click', completeStandup);\n                    break;\n                case 'retro':\n                    document.getElementById('addRetroItem').addEventListener('click', addRetroItem);\n                    break;\n            }\n        }\n        \n        // Concept interactive functions\n        function simulateScrum() {\n            const steps = [\n                \"Creating product backlog...\",\n                \"Prioritizing backlog items...\",\n                \"Planning sprint...\",\n                \"Daily standup (day 1)...\",\n                \"Developing features...\",\n                \"Daily standup (day 2)...\",\n                \"Conducting sprint review...\",\n                \"Holding retrospective...\"\n            ];\n            \n            const container = document.getElementById('scrumSimulation');\n            container.innerHTML = '<p>Starting Scrum cycle...</p>';\n            \n            let i = 0;\n            const interval = setInterval(() => {\n                if (i < steps.length) {\n                    container.innerHTML += `<p>${steps[i]}</p>`;\n                    i++;\n                } else {\n                    clearInterval(interval);\n                    container.innerHTML += '<p>Scrum cycle completed!</p>';\n                }\n            }, 1000);\n        }\n        \n        function setupKanbanDragDrop() {\n            const items = document.querySelectorAll('.kanban-item');\n            const columns = document.querySelectorAll('[class^=\"kanban\"]');\n            \n            items.forEach(item => {\n                item.addEventListener('dragstart', e => {\n                    e.dataTransfer.setData('text/plain', e.target.textContent);\n                });\n            });\n            \n            columns.forEach(col => {\n                col.addEventListener('dragover', e => e.preventDefault());\n                col.addEventListener('drop', e => {\n                    e.preventDefault();\n                    const data = e.dataTransfer.getData('text/plain');\n                    const newItem = document.createElement('div');\n                    newItem.className = 'kanban-item';\n                    newItem.textContent = data;\n                    newItem.draggable = true;\n                    newItem.addEventListener('dragstart', e => {\n                        e.dataTransfer.setData('text/plain', e.target.textContent);\n                        e.target.remove();\n                    });\n                    col.appendChild(newItem);\n                });\n            });\n        }\n        \n        function simulateXP() {\n            alert(\"Simulating XP project with selected practices...\");\n        }\n        \n        function addBacklogItem() {\n            const input = document.getElementById('backlogItem');\n            if (input.value) {\n                const list = document.getElementById('backlogList');\n                const item = document.createElement('div');\n                item.textContent = `${list.children.length + 1}. ${input.value}`;\n                list.appendChild(item);\n                input.value = '';\n            }\n        }\n        \n        function prioritizeBacklogSim() {\n            const list = document.getElementById('backlogList');\n            const items = Array.from(list.children);\n            items.sort(() => Math.random() - 0.5);\n            list.innerHTML = '';\n            items.forEach((item, index) => {\n                item.textContent = item.textContent.replace(/^\\d+/, index + 1);\n                list.appendChild(item);\n            });\n        }\n        \n        function estimateBacklog() {\n            const items = document.querySelectorAll('#backlogList div');\n            items.forEach(item => {\n                const points = Math.floor(Math.random() * 8) + 1;\n                item.textContent += ` (${points} points)`;\n            });\n        }\n        \n        function startSprintSim() {\n            const days = parseInt(document.getElementById('sprintLengthSelect').value) * 7;\n            document.getElementById('simTotalDays').textContent = days;\n            document.getElementById('simDay').textContent = 1';\n            document.getElementById('simCompleted').textContent = '0';\n        }\n        \n        function advanceDaySim() {\n            const currentDay = parseInt(document.getElementById('simDay').textContent);\n            const totalDays = parseInt(document.getElementById('simTotalDays').textContent);\n            \n            if (currentDay < totalDays) {\n                document.getElementById('simDay').textContent = currentDay + 1;\n                \n                // Random progress\n                if (Math.random() > 0.3) {\n                    const current = parseInt(document.getElementById('simCompleted').textContent);\n                    document.getElementById('simCompleted').textContent = current + Math.floor(Math.random() * 5) + 1;\n                }\n            }\n        }\n        \n        function completeStandup() {\n            alert(\"Standup completed! Team is aligned for the day.\");\n        }\n        \n        function addRetroItem() {\n            const text = document.getElementById('newRetroItem').value;\n            const category = document.getElementById('retroCategory').value;\n            \n            if (text) {\n                let targetClass = '';\n                switch(category) {\n                    case 'well': targetClass = 'wentWell'; break;\n                    case 'improve': targetClass = 'improve'; break;\n                    case 'action': targetClass = 'actionItems'; break;\n                }\n                \n                const div = document.createElement('div');\n                div.className = 'retro-item';\n                div.textContent = text;\n                \n                document.querySelector(`.${targetClass}`).appendChild(div);\n                document.getElementById('newRetroItem').value = '';\n            }\n        }\n    </script>\n</body>\n</html>"
