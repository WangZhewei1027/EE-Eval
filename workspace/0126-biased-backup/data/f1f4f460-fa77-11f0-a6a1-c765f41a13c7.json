    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Binary Tree — Visual Concept</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #081024;\n    --accent: #7dd3fc;\n    --accent-2: #8b5cf6;\n    --glass: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.6);\n    --glass-2: rgba(255,255,255,0.03);\n    --card-border: rgba(255,255,255,0.06);\n    --shadow: 0 8px 30px rgba(3,7,18,0.7);\n    --radius: 18px;\n    --node-size: 48;\n  }\n\n  /* Page layout */\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(59,130,246,0.08), transparent),\n                radial-gradient(1000px 500px at 90% 90%, rgba(139,92,246,0.06), transparent),\n                linear-gradient(180deg, var(--bg-1), var(--bg-2));\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated nebula background */\n  .bg-veil{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    background:\n      radial-gradient(600px 200px at 20% 15%, rgba(125,211,252,0.06), transparent 10%),\n      radial-gradient(400px 160px at 85% 85%, rgba(139,92,246,0.06), transparent 10%);\n    mix-blend-mode: screen;\n    animation: drift 18s linear infinite;\n    opacity:1;\n  }\n  @keyframes drift{\n    0%{ transform: translate3d(0,0,0) rotate(0deg); }\n    50%{ transform: translate3d(-20px,10px,0) rotate(2deg); }\n    100%{ transform: translate3d(0,-10px,0) rotate(0deg); }\n  }\n\n  /* Center card */\n  .stage{\n    position:relative;\n    width:min(1200px,94%);\n    height:min(760px,86vh);\n    margin:4vh auto;\n    border-radius: var(--radius);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid var(--card-border);\n    box-shadow: var(--shadow);\n    overflow:hidden;\n    display:flex;\n    gap:24px;\n  }\n\n  /* Left panel: info */\n  .panel{\n    width:36%;\n    padding:36px;\n    display:flex;\n    flex-direction:column;\n    justify-content:space-between;\n    backdrop-filter: blur(8px) saturate(120%);\n  }\n\n  .brand{\n    display:flex;\n    gap:14px;\n    align-items:center;\n  }\n  .logo{\n    width:72px;height:72px;\n    border-radius:14px;\n    background: linear-gradient(135deg, rgba(139,92,246,0.18), rgba(125,211,252,0.12));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: inset 0 -6px 20px rgba(3,7,18,0.35), 0 6px 26px rgba(2,6,23,0.6);\n    position:relative;\n    overflow:hidden;\n  }\n  .logo svg{ width:44px;height:44px; filter: drop-shadow(0 6px 18px rgba(125,211,252,0.06)); }\n\n  h1{\n    font-size:22px;\n    margin:0;\n    letter-spacing:-0.02em;\n    color: #f8fbff;\n  }\n  .subtitle{\n    color:var(--muted);\n    font-size:13px;\n    margin-top:6px;\n    max-width:280px;\n    line-height:1.4;\n  }\n\n  .desc{\n    margin-top:22px;\n    color:rgba(255,255,255,0.75);\n    font-size:14px;\n    line-height:1.6;\n  }\n\n  /* Controls */\n  .controls{\n    display:flex;\n    gap:12px;\n    margin-top:18px;\n  }\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 14px;\n    border-radius:12px;\n    font-weight:600;\n    cursor:pointer;\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--accent);\n    border:1px solid rgba(125,211,252,0.12);\n    box-shadow: 0 6px 20px rgba(3,7,18,0.4);\n    transition: transform .18s cubic-bezier(.2,.9,.3,1), box-shadow .18s;\n  }\n  .btn:hover{ transform: translateY(-3px); box-shadow: 0 12px 34px rgba(3,7,18,0.5); }\n  .btn.primary{\n    background: linear-gradient(90deg, rgba(125,211,252,0.08), rgba(139,92,246,0.06));\n    color: #eaf8ff;\n    border:1px solid rgba(255,255,255,0.06);\n  }\n\n  .legend{\n    margin-top:20px;\n    font-size:12px;\n    color:rgba(255,255,255,0.66);\n    display:flex;\n    gap:10px;\n    flex-direction:column;\n  }\n\n  /* Right: visualization canvas */\n  .canvas{\n    width:64%;\n    position:relative;\n    padding:28px;\n    display:flex;\n    align-items:stretch;\n    justify-content:center;\n  }\n\n  .viz-wrap{\n    flex:1;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.006), rgba(255,255,255,0.002));\n    border-radius:12px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    overflow:hidden;\n    padding:28px;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n\n  /* Decorative corner lights */\n  .corner-light{\n    position:absolute;\n    width:220px;height:220px;\n    filter: blur(60px);\n    opacity:0.08;\n    pointer-events:none;\n  }\n  .corner-light.left{ left:-40px; top:-40px; background: radial-gradient(closest-side, rgba(125,211,252,0.9), transparent); transform: rotate(30deg); }\n  .corner-light.right{ right:-40px; bottom:-40px; background: radial-gradient(closest-side, rgba(139,92,246,0.9), transparent); transform: rotate(-20deg); }\n\n  /* Caption */\n  .caption{\n    position:absolute;\n    left:36px;\n    bottom:14px;\n    font-size:12px;\n    color:rgba(255,255,255,0.6);\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n\n  /* SVG styles */\n  svg{\n    width:100%;\n    height:100%;\n  }\n\n  .edge{\n    stroke: url(#edgeGradient);\n    stroke-width:2.8;\n    fill:none;\n    stroke-linecap:round;\n    opacity:0.9;\n    filter: drop-shadow(0 8px 26px rgba(2,6,23,0.6));\n  }\n\n  .node{\n    transform-origin:center;\n    transition: transform .32s cubic-bezier(.2,.9,.3,1), opacity .22s;\n  }\n  .node circle{\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:1;\n    filter: drop-shadow(0 8px 26px rgba(2,6,23,0.6));\n  }\n  .node .label{\n    font-weight:700;\n    text-anchor:middle;\n    dominant-baseline:central;\n    fill:#001019;\n    font-size:14px;\n  }\n  .node .sub{\n    font-size:10px;\n    fill: rgba(255,255,255,0.66);\n  }\n\n  /* Small animated hint */\n  .hint{\n    font-size:12px;\n    color:rgba(255,255,255,0.6);\n    margin-top:12px;\n  }\n\n  /* Responsive tweaks */\n  @media (max-width:980px){\n    .stage{ flex-direction:column; height:auto; margin:6vh auto; width:94%; }\n    .panel{ width:100%; order:2; padding:20px; }\n    .canvas{ width:100%; order:1; padding:18px; }\n    .viz-wrap{ padding:18px; min-height:400px; }\n  }\n\n  /* Node entrance animation (JS triggered by adding class .enter) */\n  .enter{ animation: popIn .64s cubic-bezier(.2,.9,.3,1) both; }\n  @keyframes popIn{\n    0%{ transform: scale(.02) translateY(8px); opacity:0; filter: blur(6px); }\n    60%{ transform: scale(1.08) translateY(-6px); opacity:1; filter: blur(0); }\n    100%{ transform: scale(1) translateY(0); opacity:1; }\n  }\n\n  /* Edge drawing animation uses stroke-dashoffset changed via JS */\n  .edge-hidden{ opacity:0.0; }\n</style>\n</head>\n<body>\n  <div class=\"bg-veil\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\" role=\"region\" aria-label=\"Binary Tree visualization\">\n    <div class=\"panel\">\n      <div>\n        <div class=\"brand\">\n          <div class=\"logo\" aria-hidden=\"true\">\n            <!-- stylized binary tree glyph -->\n            <svg viewBox=\"0 0 64 64\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n              <defs>\n                <linearGradient id=\"gA\" x1=\"0\" x2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#7dd3fc\"/>\n                  <stop offset=\"1\" stop-color=\"#8b5cf6\"/>\n                </linearGradient>\n              </defs>\n              <g fill=\"none\" stroke=\"url(#gA)\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                <path d=\"M32 50v-8\"/>\n                <path d=\"M32 42c0-6 0-12 8-12\"/>\n                <path d=\"M32 42c0-6 0-12-8-12\"/>\n                <circle cx=\"32\" cy=\"18\" r=\"2.8\" fill=\"#7dd3fc\"/>\n                <circle cx=\"40\" cy=\"30\" r=\"2.8\" fill=\"#8b5cf6\"/>\n                <circle cx=\"24\" cy=\"30\" r=\"2.8\" fill=\"#7dd3fc\"/>\n              </g>\n            </svg>\n          </div>\n          <div>\n            <h1>Binary Tree</h1>\n            <div class=\"subtitle\">A refined visualization of hierarchical structure — nodes, edges, and balanced flow.</div>\n          </div>\n        </div>\n\n        <p class=\"desc\">\n          Observe a binary tree grow from its root: each node connects to left and right children, forming the branching structure fundamental to many algorithms.\n          This aesthetic demo emphasizes visual clarity, motion, and elegant composition over manipulation.\n        </p>\n\n        <div class=\"controls\" role=\"toolbar\" aria-label=\"controls\">\n          <button id=\"btn-toggle\" class=\"btn primary\" title=\"Play or pause growth animation\">\n            <!-- play/pause icon placeholder -->\n            <svg id=\"icon-play\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n              <path d=\"M7 5v14l12-7L7 5z\" fill=\"currentColor\"></path>\n            </svg>\n            Play\n          </button>\n          <button id=\"btn-rand\" class=\"btn\" title=\"Regenerate the tree pattern\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M20 8v-2l-3 3 3 3v-2a7 7 0 00-12.9 2H6a9 9 0 0116-5z\" fill=\"currentColor\"/></svg>\n            Regenerate\n          </button>\n        </div>\n\n        <div class=\"legend\" aria-hidden=\"true\">\n          <div><strong>Structure:</strong> Root → Left/Right children. Levels denote depth from the root.</div>\n          <div><strong>Animation:</strong> Nodes and edges reveal sequentially — pause to inspect, regenerate to refresh.</div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:24px; display:flex; flex-direction:column;\">\n        <div class=\"hint\">Limited interactivity — enjoy the visual narrative.</div>\n      </div>\n    </div>\n\n    <div class=\"canvas\">\n      <div class=\"viz-wrap\" aria-hidden=\"false\">\n        <div class=\"corner-light left\"></div>\n        <div class=\"corner-light right\"></div>\n\n        <!-- SVG visualization -->\n        <svg id=\"svg\" viewBox=\"0 0 1000 720\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Binary tree visualization\">\n          <defs>\n            <linearGradient id=\"edgeGradient\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7dd3fc\" stop-opacity=\"0.85\"/>\n              <stop offset=\"1\" stop-color=\"#8b5cf6\" stop-opacity=\"0.85\"/>\n            </linearGradient>\n            <radialGradient id=\"nodeFill\" cx=\"50%\" cy=\"30%\">\n              <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.95\"/>\n              <stop offset=\"45%\" stop-color=\"#e6f9ff\" stop-opacity=\"0.9\"/>\n              <stop offset=\"100%\" stop-color=\"#cfeffd\" stop-opacity=\"0.8\"/>\n            </radialGradient>\n\n            <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- edges group -->\n          <g id=\"edges\"></g>\n\n          <!-- nodes group -->\n          <g id=\"nodes\"></g>\n\n          <!-- subtle grid lines / depth markers -->\n          <g id=\"depthLines\" opacity=\"0.06\"></g>\n        </svg>\n\n        <div class=\"caption\">Depth: <span id=\"depthValue\">4</span> — Nodes reveal with graceful motion</div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(() => {\n  // Configuration\n  const svg = document.getElementById('svg');\n  const edgesGroup = document.getElementById('edges');\n  const nodesGroup = document.getElementById('nodes');\n  const depthLines = document.getElementById('depthLines');\n  const btnToggle = document.getElementById('btn-toggle');\n  const btnRand = document.getElementById('btn-rand');\n  const depthValueEl = document.getElementById('depthValue');\n\n  let maxDepth = 4; // levels 0..4\n  depthValueEl.textContent = maxDepth;\n  // Animation control\n  let playing = true;\n  btnToggle.addEventListener('click', () => {\n    playing = !playing;\n    btnToggle.classList.toggle('primary', playing);\n    btnToggle.innerHTML = playing ? playInner() : pauseInner();\n    if (playing) startReveal();\n    else cancelReveal(); // suspend future reveals\n  });\n\n  btnRand.addEventListener('click', () => {\n    regenerate();\n  });\n\n  // Icons text\n  function playInner(){\n    return '<svg id=\"icon-play\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M7 5v14l12-7L7 5z\" fill=\"currentColor\"></path></svg> Play';\n  }\n  function pauseInner(){\n    return '<svg id=\"icon-pause\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M6 6h4v12H6z\" fill=\"currentColor\"/><path d=\"M14 6h4v12h-4z\" fill=\"currentColor\"/></svg> Pause';\n  }\n\n  // Tree data representation: using indices like heap (1-based) up to (2^(maxDepth+1)-1)\n  let tree = [];\n  const totalNodes = () => (Math.pow(2, maxDepth + 1) - 1);\n\n  function buildRandomTree() {\n    const N = totalNodes();\n    // Each index from 1..N\n    // Generate presence with some randomness but ensure root exists\n    const presence = new Array(N + 1).fill(false);\n    presence[1] = true;\n    for (let i = 2; i <= N; i++) {\n      // Parent presence required\n      const parent = Math.floor(i / 2);\n      if (!presence[parent]) continue;\n      // probability decreases with depth\n      const depth = Math.floor(Math.log2(i));\n      const keepProb = 0.92 - depth * 0.14 + (Math.random() - 0.5) * 0.08;\n      presence[i] = Math.random() < keepProb;\n    }\n    // assign binary values (0/1) for demonstration\n    const nodes = [];\n    for (let i = 1; i <= N; i++) {\n      if (presence[i]) {\n        nodes.push({ idx: i, val: Math.random() < 0.5 ? 0 : 1, depth: Math.floor(Math.log2(i)) });\n      }\n    }\n    return { presence, nodes };\n  }\n\n  // Coordinate calculation based on full binary layout: for depth d, node index i (0..2^d -1), x = (2*i+1)/(2^(d+1)) * width\n  function computePositions(presence) {\n    const W = 1000, H = 720;\n    const positions = {};\n    for (let d = 0; d <= maxDepth; d++) {\n      const count = Math.pow(2, d);\n      for (let i = 0; i < count; i++) {\n        const idx = Math.pow(2, d) + i;\n        const x = ( (2*i + 1) / Math.pow(2, d+1) ) * W;\n        const y = 80 + d * ((H - 160) / maxDepth);\n        positions[idx] = { x, y };\n      }\n    }\n    return positions;\n  }\n\n  // Render depth guide lines\n  function renderDepthLines() {\n    depthLines.innerHTML = '';\n    const H = 720;\n    for (let d = 0; d <= maxDepth; d++) {\n      const y = 80 + d * ((H - 160) / maxDepth);\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1', 40);\n      line.setAttribute('x2', 960);\n      line.setAttribute('y1', y);\n      line.setAttribute('y2', y);\n      line.setAttribute('stroke', '#7dd3fc');\n      line.setAttribute('stroke-width', '0.6');\n      line.setAttribute('stroke-linecap', 'round');\n      line.setAttribute('opacity', 0.06);\n      depthLines.appendChild(line);\n    }\n  }\n\n  // Draw edges and nodes based on presence\n  let currentRevealSeq = []; // sequence of element animations (edges then nodes)\n  function renderTree(data) {\n    edgesGroup.innerHTML = '';\n    nodesGroup.innerHTML = '';\n    renderDepthLines();\n\n    const positions = computePositions(data.presence);\n    const N = totalNodes();\n\n    // Create edges for each present node that has children\n    for (let i = 1; i <= N; i++) {\n      if (!data.presence[i]) continue;\n      const left = 2 * i;\n      const right = 2 * i + 1;\n      [left, right].forEach(child => {\n        if (child <= N && data.presence[child]) {\n          // create a smooth cubic path from parent to child\n          const p = positions[i], c = positions[child];\n          const dx = c.x - p.x;\n          const controlY = (p.y + c.y) / 2;\n          const cx1 = p.x + dx * 0.12;\n          const cx2 = c.x - dx * 0.12;\n          const pathData = `M ${p.x} ${p.y} C ${cx1} ${controlY} ${cx2} ${controlY} ${c.x} ${c.y}`;\n          const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n          path.setAttribute('d', pathData);\n          path.classList.add('edge','edge-hidden');\n          path.setAttribute('data-from', i);\n          path.setAttribute('data-to', child);\n          edgesGroup.appendChild(path);\n        }\n      });\n    }\n\n    // Create nodes\n    data.nodes.forEach(n => {\n      const pos = positions[n.idx];\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform', `translate(${pos.x},${pos.y})`);\n      g.classList.add('node');\n      g.setAttribute('data-idx', n.idx);\n      g.setAttribute('opacity', '0');\n\n      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      circle.setAttribute('r', String(Math.max(18, Math.min(28, 24 - n.depth * 1.4))));\n      circle.setAttribute('fill', 'url(#nodeFill)');\n      circle.setAttribute('stroke-opacity', '0.06');\n      circle.setAttribute('cx', '0');\n      circle.setAttribute('cy', '0');\n\n      const outer = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      outer.setAttribute('r', String(Math.max(26, Math.min(34, 30 - n.depth * 1.8))));\n      outer.setAttribute('fill', 'none');\n      outer.setAttribute('stroke', 'rgba(125,211,252,0.06)');\n      outer.setAttribute('stroke-width', '1');\n\n      const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n      label.setAttribute('class','label');\n      label.setAttribute('x','0');\n      label.setAttribute('y','0');\n      label.textContent = String(n.val);\n\n      const sub = document.createElementNS('http://www.w3.org/2000/svg','text');\n      sub.setAttribute('class','sub');\n      sub.setAttribute('x','0');\n      sub.setAttribute('y','18');\n      sub.textContent = `#${n.idx}`;\n\n      g.appendChild(outer);\n      g.appendChild(circle);\n      g.appendChild(label);\n      g.appendChild(sub);\n\n      nodesGroup.appendChild(g);\n    });\n\n    // Build reveal sequence: edges from parent->child first (sorted by parent depth), then nodes (by depth)\n    currentRevealSeq = [];\n    // edges order: by parent depth ascending\n    const edgePaths = Array.from(edgesGroup.querySelectorAll('path'));\n    edgePaths.sort((a,b)=>{\n      const pa = Math.floor(Math.log2(a.dataset.from));\n      const pb = Math.floor(Math.log2(b.dataset.from));\n      return pa - pb || a.dataset.from - b.dataset.from;\n    });\n    edgePaths.forEach(p => currentRevealSeq.push({type:'edge', el:p}));\n\n    // nodes order: by depth ascending (root first) but reveal nodes slightly after edges to show connecting lines\n    const nodeElems = Array.from(nodesGroup.querySelectorAll('g'));\n    nodeElems.sort((a,b)=>{\n      const da = Math.floor(Math.log2(a.dataset.idx));\n      const db = Math.floor(Math.log2(b.dataset.idx));\n      return da - db || a.dataset.idx - b.dataset.idx;\n    });\n    nodeElems.forEach(n => currentRevealSeq.push({type:'node', el:n}));\n\n    // start the reveal animation\n    startReveal();\n  }\n\n  // Reveal animation controller\n  let revealCancel = false;\n  function startReveal(){\n    revealCancel = false;\n    // reset current elements to hidden initial state\n    currentRevealSeq.forEach(item => {\n      if (item.type === 'edge') {\n        item.el.classList.add('edge-hidden');\n        // set up stroke dash length\n        const len = item.el.getTotalLength();\n        item.el.style.strokeDasharray = len;\n        item.el.style.strokeDashoffset = len;\n        item.el.style.opacity = 0.9;\n      } else {\n        item.el.style.opacity = 0;\n        item.el.classList.remove('enter');\n        item.el.style.transform = 'scale(0.02) translateY(8px)';\n      }\n    });\n\n    // sequential reveal\n    let i = 0;\n    const baseDelay = 80; // ms\n    const step = () => {\n      if (revealCancel || i >= currentRevealSeq.length || !playing) return;\n      const item = currentRevealSeq[i++];\n      if (item.type === 'edge') {\n        animateEdgeIn(item.el);\n      } else {\n        animateNodeIn(item.el);\n      }\n      // spacing: edges are quicker, nodes slightly slower\n      const delay = (item.type === 'edge') ? baseDelay : baseDelay * 1.4;\n      setTimeout(step, delay);\n    };\n    // slight initial latency\n    setTimeout(step, 150);\n  }\n  function cancelReveal(){\n    revealCancel = true;\n  }\n\n  function animateEdgeIn(path) {\n    path.classList.remove('edge-hidden');\n    const len = path.getTotalLength();\n    path.style.transition = 'stroke-dashoffset 520ms cubic-bezier(.16,.85,.36,1), opacity 320ms';\n    // start drawing\n    requestAnimationFrame(() => {\n      path.style.strokeDashoffset = 0;\n      path.style.opacity = 0.95;\n    });\n    // subtle neon glow expansion\n    setTimeout(() => {\n      path.style.transition = 'opacity 600ms';\n      path.style.opacity = 0.84;\n    }, 700);\n  }\n\n  function animateNodeIn(g) {\n    g.style.opacity = 1;\n    g.classList.add('enter');\n    // small wobble of the surrounding edges for emphasis\n    const idx = g.dataset.idx;\n    const connectedEdges = Array.from(edgesGroup.querySelectorAll(`path[data-from=\"${idx}\"], path[data-to=\"${idx}\"]`));\n    connectedEdges.forEach(p => {\n      p.style.transformOrigin = 'center';\n      p.animate([{ transform: 'translateY(-2px)' }, { transform: 'translateY(0px)' }], { duration: 420, easing: 'cubic-bezier(.2,.9,.3,1)' });\n    });\n  }\n\n  // Regenerate and re-render\n  function regenerate() {\n    playing = true;\n    btnToggle.classList.add('primary');\n    btnToggle.innerHTML = playInner();\n\n    const data = buildRandomTree();\n    renderTree(data);\n  }\n\n  // Initialize\n  regenerate();\n\n  // Slightly animate background colors on resize or interaction\n  window.addEventListener('resize', () => {\n    // re-render positions (keeps layout crisp on resize)\n    // Using current presence stored in DOM: reconstruct presence array\n    const presence = [];\n    const nodesEls = Array.from(nodesGroup.querySelectorAll('g'));\n    nodesEls.forEach(n => presence.push(parseInt(n.dataset.idx)));\n    // We will just regenerate to fit new size nicely (keeps demo dynamic)\n    // but keep playing state\n    const wasPlaying = playing;\n    regenerate();\n    playing = wasPlaying;\n    btnToggle.classList.toggle('primary', playing);\n    btnToggle.innerHTML = playing ? playInner() : pauseInner();\n  });\n\n  // Small polish: hovering over nodes highlights path to root\n  nodesGroup.addEventListener('mouseover', (ev) => {\n    const g = ev.target.closest('g.node');\n    if (!g) return;\n    const idx = parseInt(g.dataset.idx,10);\n    // highlight chain to root\n    let cur = idx;\n    const chain = [];\n    while (cur >= 1) {\n      chain.push(cur);\n      cur = Math.floor(cur/2);\n    }\n    // dim everything\n    nodesGroup.querySelectorAll('g.node').forEach(n => n.style.opacity = 0.18);\n    edgesGroup.querySelectorAll('path').forEach(p => p.style.opacity = 0.08);\n    // highlight chain nodes and connecting edges\n    chain.forEach((id, i) => {\n      const node = nodesGroup.querySelector(`g.node[data-idx=\"${id}\"]`);\n      if (node) {\n        node.style.opacity = 1;\n        node.animate([{ transform: 'scale(1.04)' }, { transform: 'scale(1)' }], { duration: 420, easing: 'cubic-bezier(.2,.9,.3,1)' });\n      }\n      if (i < chain.length - 1) {\n        const child = chain[i];\n        const parent = chain[i+1];\n        // edge could be from parent->child or child->parent: we search both\n        const edge = edgesGroup.querySelector(`path[data-from=\"${parent}\"][data-to=\"${child}\"]`);\n        if (edge) {\n          edge.style.opacity = 0.98;\n        }\n      }\n    });\n  });\n\n  nodesGroup.addEventListener('mouseout', (ev) => {\n    // restore opacity\n    nodesGroup.querySelectorAll('g.node').forEach(n => n.style.opacity = 1);\n    edgesGroup.querySelectorAll('path').forEach(p => p.style.opacity = 0.9);\n  });\n\n  // Initial play/pause state\n  btnToggle.innerHTML = playInner();\n\n  // Accessibility: keyboard activation for regenerate via Enter/Space\n  btnRand.addEventListener('keydown', (e) => {\n    if (e.key === 'Enter' || e.key === ' ') {\n      e.preventDefault();\n      btnRand.click();\n    }\n  });\n})();\n</script>\n</body>\n</html>"
