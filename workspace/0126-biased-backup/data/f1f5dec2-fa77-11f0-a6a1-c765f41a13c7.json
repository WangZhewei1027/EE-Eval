  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Linear Search — Visual Demonstration</title>\n\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600&display=swap\" rel=\"stylesheet\">\n\n<style>\n  :root{\n    --bg1: #0f1724; /* deep navy */\n    --bg2: #0b1020; /* darker */\n    --accent1: #7c5cff; /* purple */\n    --accent2: #00e6a0; /* mint */\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.7);\n    --card: rgba(255,255,255,0.03);\n    --success: #00e6a0;\n    --danger: #ff6b7a;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;\n    background:\n      radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.12), transparent 6%),\n      radial-gradient(1000px 500px at 90% 90%, rgba(0,230,160,0.06), transparent 8%),\n      linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:40px;\n    overflow:hidden;\n  }\n\n  /* Subtle animated slanted strokes */\n  .bg-ornaments{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n    opacity:0.18;\n    mix-blend-mode:screen;\n  }\n  .bg-ornaments svg{width:100%;height:100%}\n\n  .container{\n    position:relative;\n    width:min(1100px,96%);\n    z-index:1;\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap:28px;\n    align-items:stretch;\n  }\n\n  header{\n    grid-column:1 / -1;\n    display:flex;\n    align-items:center;\n    gap:18px;\n    margin-bottom:6px;\n  }\n  .logo{\n    width:74px;\n    height:74px;\n    border-radius:12px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    background:linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    box-shadow: 0 6px 30px rgba(12,14,27,0.6), inset 0 -6px 18px rgba(0,0,0,0.4);\n    border:1px solid rgba(255,255,255,0.04);\n    transform:translateZ(0);\n    flex-shrink:0;\n    position:relative;\n    overflow:hidden;\n  }\n  .logo::after{\n    content:\"\";\n    position:absolute;\n    inset:0;\n    background:linear-gradient(120deg, rgba(124,92,255,0.06), rgba(0,230,160,0.05));\n    mix-blend-mode:overlay;\n  }\n  .logo svg{width:44px;height:44px;filter:drop-shadow(0 6px 18px rgba(0,0,0,0.6))}\n\n  h1{\n    font-family:\"Playfair Display\", serif;\n    font-size:28px;\n    margin:0;\n    letter-spacing:-0.02em;\n    color:white;\n  }\n  p.lead{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* Main panel */\n  .panel{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:16px;\n    padding:26px;\n    box-shadow: 0 10px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.04);\n    backdrop-filter: blur(8px) saturate(120%);\n    overflow:visible;\n  }\n\n  .visual{\n    display:flex;\n    gap:22px;\n    align-items:center;\n    justify-content:space-between;\n  }\n\n  /* Array area */\n  .array-wrap{\n    flex:1;\n    display:flex;\n    flex-direction:column;\n    gap:14px;\n    min-width:0;\n  }\n  .meta-row{\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .chip{\n    font-size:13px;\n    padding:8px 12px;\n    border-radius:999px;\n    background:linear-gradient(90deg, rgba(124,92,255,0.12), rgba(0,230,160,0.06));\n    color:white;\n    border:1px solid rgba(255,255,255,0.04);\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n  }\n  .target{\n    background: linear-gradient(90deg, rgba(0,230,160,0.06), rgba(124,92,255,0.04));\n    color:var(--success);\n    font-weight:600;\n    padding:10px 14px;\n    border-radius:12px;\n    box-shadow: 0 4px 18px rgba(0,230,160,0.06);\n    letter-spacing:0.02em;\n  }\n  .subtle{\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* The nodes */\n  .array{\n    margin-top:6px;\n    display:flex;\n    gap:14px;\n    padding:22px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border-radius:14px;\n    border:1px solid rgba(255,255,255,0.02);\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    overflow:visible;\n  }\n  .node{\n    width:78px;\n    height:78px;\n    border-radius:12px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:rgba(255,255,255,0.9);\n    font-weight:700;\n    font-size:22px;\n    position:relative;\n    transition: transform 450ms cubic-bezier(.2,.9,.25,1), box-shadow 350ms;\n    transform-origin:center;\n    box-shadow: 0 8px 22px rgba(2,6,23,0.55), inset 0 -6px 18px rgba(0,0,0,0.45);\n    border:1px solid rgba(255,255,255,0.02);\n    cursor:default;\n  }\n  .node .index{\n    position:absolute;\n    top:8px;\n    right:8px;\n    font-size:11px;\n    color:rgba(255,255,255,0.28);\n    font-weight:600;\n  }\n\n  .node.inspecting{\n    transform:translateY(-10px) scale(1.06);\n    box-shadow: 0 18px 40px rgba(7,12,25,0.6), 0 6px 24px rgba(124,92,255,0.08);\n    border: 1px solid rgba(124,92,255,0.28);\n    background:linear-gradient(180deg, rgba(124,92,255,0.06), rgba(255,255,255,0.01));\n  }\n  .node.found{\n    transform: translateY(-6px) scale(1.08);\n    background: linear-gradient(135deg, rgba(0,230,160,0.14), rgba(124,92,255,0.06));\n    border: 1px solid rgba(0,230,160,0.22);\n    box-shadow: 0 22px 54px rgba(0,230,160,0.06), 0 10px 30px rgba(0,0,0,0.45), 0 0 32px rgba(0,230,160,0.12);\n    color:#eafff5;\n  }\n  .node.rejected{\n    opacity:0.32;\n    transform:scale(0.96);\n    filter:grayscale(20%);\n  }\n\n  /* Magnifier */\n  .magnifier{\n    position:absolute;\n    top:-36px;\n    left:0;\n    width:96px;\n    height:96px;\n    transform:translateX(0);\n    transition: transform 700ms cubic-bezier(.2,.9,.25,1);\n    pointer-events:none;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n  .magnifier .glass{\n    width:78px;\n    height:78px;\n    border-radius:20px;\n    background: radial-gradient(120% 140% at 30% 20%, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    border: 1px solid rgba(255,255,255,0.06);\n    box-shadow: 0 8px 30px rgba(2,6,23,0.6);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    overflow:visible;\n    transform:rotate(-14deg);\n  }\n  .magnifier svg{width:46px;height:46px;opacity:0.95;filter:drop-shadow(0 6px 18px rgba(0,0,0,0.6))}\n  .magnifier .beam{\n    position:absolute;\n    bottom:-12px;\n    left:50%;\n    width:140px;\n    height:40px;\n    transform:translateX(-50%) rotate(-14deg);\n    background:linear-gradient(90deg, rgba(124,92,255,0.05), rgba(0,230,160,0.05));\n    border-radius:8px;\n    filter:blur(8px);\n    opacity:0.9;\n  }\n\n  /* Right column (pseudocode & status) */\n  .side{\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    align-items:stretch;\n  }\n  .code-card{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:14px;\n    border:1px solid rgba(255,255,255,0.02);\n    font-family:ui-monospace,SFMono-Regular,Menlo,monospace;\n    font-size:13px;\n    color:rgba(255,255,255,0.9);\n    line-height:1.6;\n    min-height:140px;\n    position:relative;\n    overflow:hidden;\n  }\n  .code-line{\n    display:block;\n    padding:6px 8px;\n    border-radius:8px;\n    transition: background 250ms, transform 200ms;\n    color:rgba(255,255,255,0.76);\n  }\n  .code-line.highlight{\n    background:linear-gradient(90deg, rgba(124,92,255,0.14), rgba(0,230,160,0.06));\n    color:white;\n    transform:translateX(6px);\n    box-shadow: 0 8px 30px rgba(7,12,25,0.6);\n  }\n  .code-line .num{\n    color:rgba(255,255,255,0.34);\n    display:inline-block;\n    width:22px;\n    text-align:right;\n    margin-right:10px;\n    font-weight:700;\n  }\n  .code-card .title{\n    font-weight:700;\n    margin-bottom:8px;\n    font-size:13px;\n    color:white;\n  }\n\n  .status{\n    padding:12px 14px;\n    border-radius:12px;\n    background:rgba(255,255,255,0.01);\n    border:1px solid rgba(255,255,255,0.02);\n    display:flex;\n    align-items:center;\n    gap:12px;\n    justify-content:space-between;\n  }\n  .status .message{\n    font-size:14px;\n    color:var(--muted);\n  }\n  .status .result{\n    font-weight:700;\n    color:transparent;\n    -webkit-background-clip:text;\n    background-image:linear-gradient(90deg,var(--accent1),var(--accent2));\n    letter-spacing:0.02em;\n  }\n\n  /* Controls */\n  .controls{\n    margin-top:12px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  button.btn{\n    border:0;\n    padding:12px 18px;\n    border-radius:12px;\n    font-weight:700;\n    cursor:pointer;\n    color:white;\n    background:linear-gradient(90deg,var(--accent1),#6f83ff);\n    box-shadow: 0 10px 30px rgba(111,131,255,0.14), 0 2px 6px rgba(0,0,0,0.4);\n    transition: transform 160ms, box-shadow 160ms, opacity 160ms;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n  }\n  button.btn:active{transform:translateY(1px)}\n  button.btn:disabled{opacity:0.48;cursor:default;transform:none;box-shadow:none}\n\n  button.ghost{\n    background:transparent;\n    border:1px solid rgba(255,255,255,0.06);\n    color:var(--muted);\n    padding:10px 14px;\n    font-weight:700;\n  }\n\n  .footer-note{\n    margin-top:18px;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* tiny found pulse */\n  .sparkle{\n    position:absolute;\n    pointer-events:none;\n    width:10px;height:10px;\n    border-radius:50%;\n    background:rgba(0,230,160,0.9);\n    box-shadow:0 0 32px rgba(0,230,160,0.24);\n    opacity:0;\n    transform:scale(0.6);\n    transition:all 420ms cubic-bezier(.2,.9,.25,1);\n  }\n\n  /* responsive */\n  @media (max-width:980px){\n    .container{grid-template-columns:1fr; padding:0}\n    .side{order:2}\n    .panel{padding:18px}\n    .logo{width:60px;height:60px}\n    .array{padding:16px}\n    .node{width:68px;height:68px;font-size:20px}\n    .magnifier{width:86px;height:86px;top:-32px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"bg-ornaments\" aria-hidden=\"true\">\n    <!-- Decorative diagonal strokes -->\n    <svg viewBox=\"0 0 1600 900\" preserveAspectRatio=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n      <defs>\n        <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n          <stop offset=\"0\" stop-color=\"#7c5cff\" stop-opacity=\"0.18\" />\n          <stop offset=\"1\" stop-color=\"#00e6a0\" stop-opacity=\"0.08\" />\n        </linearGradient>\n        <filter id=\"blur\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n          <feGaussianBlur stdDeviation=\"40\" />\n        </filter>\n      </defs>\n      <g filter=\"url(#blur)\">\n        <path d=\"M-200 100 C200 50, 600 200, 1000 120 C1400 40, 1800 220, 2200 120\" stroke=\"url(#g1)\" stroke-width=\"3\" fill=\"none\" opacity=\"0.55\" />\n        <path d=\"M-200 320 C200 260, 600 420, 1000 300 C1400 180, 1800 340, 2200 240\" stroke=\"url(#g1)\" stroke-width=\"2\" fill=\"none\" opacity=\"0.38\" />\n        <path d=\"M-200 540 C200 480, 600 640, 1000 520 C1400 400, 1800 560, 2200 460\" stroke=\"url(#g1)\" stroke-width=\"1.4\" fill=\"none\" opacity=\"0.26\" />\n      </g>\n    </svg>\n  </div>\n\n  <div class=\"container\" role=\"main\">\n    <header>\n      <div class=\"logo\" aria-hidden=\"true\">\n        <!-- Elegant icon -->\n        <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <rect x=\"6\" y=\"10\" width=\"40\" height=\"44\" rx=\"8\" fill=\"#0b1020\" stroke=\"white\" stroke-opacity=\"0.06\"/>\n          <path d=\"M14 20h24v6H14z\" fill=\"#7c5cff\" opacity=\"0.9\"/>\n          <circle cx=\"44\" cy=\"44\" r=\"8\" fill=\"#00e6a0\" opacity=\"0.95\"/>\n          <path d=\"M42 42 L46 46 M46 42 L42 46\" stroke=\"#0b1020\" stroke-width=\"2\" stroke-linecap=\"round\" />\n        </svg>\n      </div>\n      <div>\n        <h1>Linear Search</h1>\n        <p class=\"lead\">A sequential scan through an array — visually exploring each comparison with elegant motion.</p>\n      </div>\n    </header>\n\n    <div class=\"panel\" aria-hidden=\"false\">\n      <div class=\"visual\">\n        <div class=\"array-wrap\">\n          <div class=\"meta-row\">\n            <div class=\"chip\">Array • unsorted</div>\n            <div class=\"chip target\" title=\"Target value\">Target: <span id=\"target-value\" style=\"margin-left:8px\">73</span></div>\n            <div style=\"flex:1\"></div>\n            <div class=\"subtle\">Comparisons: <span id=\"comp-count\">0</span></div>\n          </div>\n\n          <div class=\"array\" id=\"array\" aria-label=\"Array elements\">\n            <!-- magnifier is absolutely positioned -->\n            <div class=\"magnifier\" id=\"magnifier\" style=\"transform:translateX(-18px);\">\n              <div class=\"glass\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 24 24\"><path fill=\"white\" opacity=\"0.92\" d=\"M10 4a6 6 0 0 1 4.472 10.013l3.257 3.257-1.414 1.414-3.257-3.257A6 6 0 1 1 10 4zm0 2a4 4 0 1 0 0 8 4 4 0 0 0 0-8z\"/></svg>\n              </div>\n              <div class=\"beam\"></div>\n            </div>\n\n            <!-- nodes populated by JS -->\n          </div>\n\n          <div class=\"controls\">\n            <button class=\"btn\" id=\"startBtn\" title=\"Animate the linear search\">Start Search</button>\n            <button class=\"ghost\" id=\"resetBtn\" title=\"Reset the visualization\">Reset</button>\n          </div>\n\n          <div class=\"footer-note\">Observe the scan — each item is compared in turn. Linear search examines elements sequentially until the target is found or the list ends.</div>\n        </div>\n\n        <div class=\"side\">\n          <div class=\"code-card\" aria-hidden=\"true\">\n            <div class=\"title\">Pseudo-code</div>\n            <div id=\"code\">\n              <span class=\"code-line\" data-line=\"1\"><span class=\"num\">1</span>function linearSearch(arr, target)</span>\n              <span class=\"code-line\" data-line=\"2\"><span class=\"num\">2</span>  for i = 0 to arr.length - 1</span>\n              <span class=\"code-line\" data-line=\"3\"><span class=\"num\">3</span>    if arr[i] == target</span>\n              <span class=\"code-line\" data-line=\"4\"><span class=\"num\">4</span>      return i  // found</span>\n              <span class=\"code-line\" data-line=\"5\"><span class=\"num\">5</span>  return -1     // not found</span>\n            </div>\n          </div>\n\n          <div class=\"status\" role=\"status\" aria-live=\"polite\">\n            <div>\n              <div class=\"message\" id=\"statusMessage\">Press Start to begin the scan</div>\n              <div style=\"font-size:12px;color:rgba(255,255,255,0.28);margin-top:4px\">Time complexity: O(n) • Best: O(1) • Worst: O(n)</div>\n            </div>\n            <div>\n              <div class=\"result\" id=\"resultText\">—</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- invisible sparkle placeholder -->\n    <div class=\"sparkle\" id=\"sparkle\"></div>\n\n  </div>\n\n<script>\n(function(){\n  // Configuration\n  const arr = [12, 73, 34, 90, 73, 5, 67, 29, 84, 41, 73]; // sample array (multiple 73 to show first match)\n  const target = 73;\n  const inspectDelay = 900; // ms per comparison\n\n  // Elements\n  const arrayEl = document.getElementById('array');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const statusMessage = document.getElementById('statusMessage');\n  const resultText = document.getElementById('resultText');\n  const compCount = document.getElementById('comp-count');\n  const magnifier = document.getElementById('magnifier');\n  const codeLines = Array.from(document.querySelectorAll('.code-line'));\n  const sparkle = document.getElementById('sparkle');\n\n  let nodeEls = [];\n  let timers = [];\n  let running = false;\n  let comparisons = 0;\n\n  // Initialize nodes\n  function buildNodes(){\n    arrayEl.querySelectorAll('.node').forEach(n=>n.remove());\n    nodeEls = arr.map((v,i)=>{\n      const n = document.createElement('div');\n      n.className = 'node';\n      n.innerHTML = '<div class=\"index\">'+i+'</div><div class=\"value\">'+v+'</div>';\n      n.dataset.index = i;\n      n.dataset.value = v;\n      arrayEl.appendChild(n);\n      return n;\n    });\n    // position magnifier initially over left\n    requestAnimationFrame(()=>{\n      placeMagnifierAtNode(0, true);\n    });\n  }\n\n  // Place magnifier (animated)\n  function placeMagnifierAtNode(i, instant=false){\n    const targetNode = nodeEls[Math.max(0,Math.min(i,nodeEls.length-1))];\n    const containerRect = arrayEl.getBoundingClientRect();\n    const nodeRect = targetNode.getBoundingClientRect();\n    const offset = nodeRect.left - containerRect.left + (nodeRect.width - magnifier.offsetWidth)/2;\n    if(instant){\n      magnifier.style.transition = 'none';\n      magnifier.style.transform = `translateX(${offset}px)`;\n      // force reflow then restore transition\n      void magnifier.offsetWidth;\n      magnifier.style.transition = 'transform 700ms cubic-bezier(.2,.9,.25,1)';\n    } else {\n      magnifier.style.transform = `translateX(${offset}px)`;\n    }\n  }\n\n  function highlightCode(line){\n    codeLines.forEach(cl=>{\n      if(Number(cl.dataset.line) === line) cl.classList.add('highlight');\n      else cl.classList.remove('highlight');\n    });\n  }\n\n  function setStatus(msg, result){\n    statusMessage.textContent = msg;\n    resultText.textContent = result || '—';\n  }\n\n  function resetAll(){\n    running = false;\n    timers.forEach(t=>clearTimeout(t));\n    timers = [];\n    nodeEls.forEach(n=>{\n      n.classList.remove('inspecting','found','rejected');\n      n.style.opacity = '';\n    });\n    comparisons = 0;\n    compCount.textContent = '0';\n    setStatus('Press Start to begin the scan', '—');\n    highlightCode(0);\n    // place magnifier to start\n    placeMagnifierAtNode(0, true);\n    startBtn.disabled = false;\n  }\n\n  // small celebratory effect\n  function showFoundAt(node){\n    node.classList.add('found');\n    // sparkle\n    const rect = node.getBoundingClientRect();\n    const containerRect = document.body.getBoundingClientRect();\n    sparkle.style.left = (rect.left + rect.width/2 - containerRect.left - 5) + 'px';\n    sparkle.style.top = (rect.top + rect.height/2 - containerRect.top - 5) + 'px';\n    sparkle.style.opacity = '1';\n    sparkle.style.transform = 'scale(1.4)';\n    setTimeout(()=> {\n      sparkle.style.opacity = '0';\n      sparkle.style.transform = 'scale(0.6)';\n    }, 700);\n  }\n\n  function animateScan(){\n    if(running) return;\n    running = true;\n    startBtn.disabled = true;\n    setStatus('Scanning...', '—');\n    highlightCode(2); // start for loop\n    let found = false;\n\n    for(let i=0;i<nodeEls.length;i++){\n      // schedule each step\n      const t = setTimeout(((idx)=>{\n        return ()=>{\n          if(!running) return;\n          comparisons++;\n          compCount.textContent = comparisons;\n          // move magnifier and highlight node\n          placeMagnifierAtNode(idx);\n          nodeEls.forEach(n=>n.classList.remove('inspecting'));\n          const current = nodeEls[idx];\n          current.classList.add('inspecting');\n          // animate code: \"if arr[i] == target\"\n          highlightCode(3);\n          setStatus('Comparing element at index ' + idx + '…', '—');\n\n          // inner check after short pause\n          const innerDelay = 420;\n          const t2 = setTimeout(()=>{\n            if(!running) return;\n            // compare\n            const val = Number(current.dataset.value);\n            if(val === target && !found){\n              found = true;\n              highlightCode(4);\n              setStatus('Target found at index ' + idx, 'Index '+idx);\n              showFoundAt(current);\n              // mark earlier non-found as rejected\n              nodeEls.forEach((n,ni)=>{ if(ni<idx && !n.classList.contains('found')) n.classList.add('rejected'); });\n              // mark later nodes faint\n              nodeEls.forEach((n,ni)=>{ if(ni>idx) n.classList.add('rejected'); });\n              running = false;\n              startBtn.disabled = false;\n              // stop remaining timers\n              timers.forEach(tt=>clearTimeout(tt));\n            } else {\n              // not equal\n              current.classList.remove('inspecting');\n              current.classList.add('rejected');\n              highlightCode(2); // back to for loop\n              setStatus('Not here — moving to next', '—');\n              // if last and not found\n              if(idx === nodeEls.length - 1 && !found){\n                highlightCode(5);\n                setStatus('Target not found in the array', 'Not found');\n                resultText.textContent = 'Not found';\n                running = false;\n                startBtn.disabled = false;\n              }\n            }\n          }, innerDelay);\n          timers.push(t2);\n        };\n      })(i), i * inspectDelay);\n      timers.push(t);\n    }\n  }\n\n  // events\n  startBtn.addEventListener('click', ()=>{\n    if(running) return;\n    animateScan();\n  });\n  resetBtn.addEventListener('click', ()=>{\n    resetAll();\n  });\n\n  // init\n  buildNodes();\n  resetAll();\n\n  // Reposition magnifier on resize\n  let rtid;\n  window.addEventListener('resize', ()=>{\n    clearTimeout(rtid);\n    rtid = setTimeout(()=> {\n      // reposition magnifier to current inspected node or 0\n      const inspecting = nodeEls.findIndex(n=>n.classList.contains('inspecting'));\n      const idx = inspecting >= 0 ? inspecting : 0;\n      placeMagnifierAtNode(idx, true);\n    }, 120);\n  });\n\n  // small entrance animation\n  requestAnimationFrame(()=>{\n    nodeEls.forEach((n,i)=>{\n      n.style.transition = 'transform 700ms cubic-bezier(.2,.9,.25,1), opacity 500ms';\n      n.style.transform = 'translateY(12px) scale(0.98)';\n      n.style.opacity = '0';\n      setTimeout(()=>{ n.style.transform = ''; n.style.opacity = ''; }, 120 + i*40);\n    });\n  });\n\n  // initial code highlight\n  highlightCode(0);\n\n  // Keyboard: only allow space to start/stop (limited interactivity)\n  window.addEventListener('keydown', (e)=>{\n    if(e.code === 'Space'){\n      e.preventDefault();\n      if(!running) startBtn.click();\n      else resetBtn.click();\n    }\n  });\n})();\n</script>\n</body>\n</html>"
