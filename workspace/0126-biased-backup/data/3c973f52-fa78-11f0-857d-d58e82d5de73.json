    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Jump Search Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #1f2335, #3a406e);\n    font-family: 'Poppins', sans-serif;\n    color: #e0e0e0;\n    overflow: hidden;\n    user-select: none;\n  }\n  #container {\n    max-width: 960px;\n    margin: 2rem auto 4rem;\n    padding: 0 2rem 3rem;\n    background: linear-gradient(145deg, #2d314d, #3f4671);\n    border-radius: 20px;\n    box-shadow:\n      0 10px 30px rgba(25,25,75,0.7),\n      inset 0 0 40px #4a529c50;\n    position: relative;\n    min-height: 540px;\n  }\n  h1 {\n    text-align: center;\n    font-weight: 600;\n    font-size: 3rem;\n    letter-spacing: 0.08em;\n    color: #9bc8ff;\n    text-shadow: 0 0 6px #72a7ffcc, 0 0 10px #2a3e9ccc;\n    margin-bottom: 0.6rem;\n  }\n  h2 {\n    text-align: center;\n    font-weight: 300;\n    font-style: italic;\n    font-size: 1.1rem;\n    color: #b0c3ff99;\n    margin-bottom: 2.4rem;\n    letter-spacing: 0.06em;\n  }\n\n  /* Array container */\n  #array {\n    display: flex;\n    justify-content: center;\n    gap: 14px;\n    margin-bottom: 60px;\n  }\n  .block {\n    position: relative;\n    width: 48px;\n    height: 64px;\n    background: linear-gradient(135deg, #4e557f, #6a73bd);\n    border-radius: 12px;\n    box-shadow:\n      inset 0 2px 10px #8a9cfff2,\n      0 6px 12px rgba(18,24,68,0.9);\n    color: #e0e0fff;\n    font-weight: 600;\n    font-size: 1.6rem;\n    letter-spacing: 0.08em;\n    line-height: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: default;\n    transition:\n      background 0.5s ease,\n      box-shadow 0.5s ease,\n      transform 0.5s cubic-bezier(0.645,0.045,0.355,1);\n  }\n  .block:hover {\n    box-shadow:\n      0 0 12px #8098ffcc,\n      inset 0 0 30px #a2b2ffff;\n  }\n\n  /* States for blocks */\n  .block.jumped {\n    background: #3d73d6;\n    box-shadow:\n      0 0 20px #76a3ffcc,\n      inset 0 0 40px #264c91;\n    color: #d0dfff;\n    transform: scale(1.02);\n  }\n  .block.checked {\n    background: #e27979;\n    box-shadow:\n      0 0 20px #ff4c4ccc,\n      inset 0 0 40px #b74040;\n    color: #fff5f5;\n    transform: scale(1.1) translateY(-6px);\n  }\n  .block.found {\n    background: #6adc91;\n    box-shadow:\n      0 0 30px #55ce80cc,\n      inset 0 0 45px #1d5e30;\n    color: #f0fff5;\n    font-weight: 700;\n    transform: scale(1.15) translateY(-8px);\n  }\n\n  /* Labels under blocks for jumps */\n  .label {\n    position: absolute;\n    top: 72px;\n    width: 48px;\n    font-size: 0.7rem;\n    color: #a3b2eccc;\n    text-align: center;\n    letter-spacing: 0.05em;\n    user-select: none;\n    pointer-events: none;\n    font-weight: 500;\n  }\n\n  /* Controls */\n  #controls {\n    position: absolute;\n    bottom: 24px;\n    right: 24px;\n    display: flex;\n    gap: 14px;\n  }\n  button {\n    background: #5c6bc0;\n    border: none;\n    padding: 14px 24px;\n    border-radius: 24px;\n    color: #e8ebff;\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.08em;\n    cursor: pointer;\n    box-shadow:\n      0 2px 12px #5c6bc099,\n      inset 0 -3px 10px #2b3873;\n    text-transform: uppercase;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.4s ease,\n      color 0.4s ease;\n  }\n  button:hover {\n    background: #4255a7;\n    box-shadow:\n      0 4px 20px #4c62b533,\n      inset 0 -4px 14px #1d2958;\n    color: #b8c2f2;\n  }\n  button:disabled {\n    background: #3b425f88;\n    box-shadow: none;\n    color: #8f97b1aa;\n    cursor: default;\n  }\n\n  /* Explanation Panel */\n  #explanation {\n    max-width: 880px;\n    margin: 0 auto;\n    font-style: italic;\n    font-weight: 300;\n    font-size: 1rem;\n    line-height: 1.55;\n    color: #bcc4ffcc;\n    text-align: center;\n    min-height: 64px;\n    user-select: none;\n    filter: drop-shadow(0 0 4px #20294a99);\n  }\n\n  /* Jump Arrow & Search Indicators with SVG */\n  svg#arrows {\n    position: absolute;\n    top: 98px;\n    left: 50%;\n    width: 860px;\n    height: 100px;\n    transform: translateX(-50%);\n    pointer-events: none;\n    overflow: visible;\n  }\n  .arrow-path {\n    fill: none;\n    stroke: #77a6ffcc;\n    stroke-width: 5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    opacity: 0.7;\n    filter: drop-shadow(0 0 4px #71a1ffb3);\n    transition: stroke 0.6s ease;\n  }\n  .arrow-head {\n    fill: #77a6ffcc;\n    filter: drop-shadow(0 0 3px #72a7ffcc);\n    opacity: 0.7;\n    transition: fill 0.6s ease;\n  }\n  .arrow-highlight {\n    stroke: #f5bb52ff !important;\n    opacity: 1 !important;\n  }\n  .arrow-head-highlight {\n    fill: #f5bb52ff !important;\n    opacity: 1 !important;\n  }\n\n  /* Smooth appear */\n  .fade-in {\n    opacity: 1 !important;\n    transition: opacity 1s ease;\n  }\n\n</style>\n</head>\n<body>\n  <div id=\"container\" role=\"main\" aria-label=\"Jump Search Algorithm visualization\">\n    <h1>Jump Search</h1>\n    <h2>Understanding Search with Elegant Visuals</h2>\n\n    <div id=\"array\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n    <svg id=\"arrows\" aria-hidden=\"true\" ></svg>\n\n    <div id=\"explanation\" aria-live=\"polite\"></div>\n\n    <div id=\"controls\" aria-label=\"Simulation controls\">\n      <button id=\"startBtn\" type=\"button\" aria-pressed=\"false\" aria-label=\"Start Jump Search simulation\">Start</button>\n      <button id=\"resetBtn\" type=\"button\" aria-label=\"Reset visualization\" disabled>Reset</button>\n    </div>\n  </div>\n\n<script>\n(() => {\n  const arrSize = 20;\n  const sortedArray = [];\n  for(let i=1; i<=arrSize; i++) {\n    sortedArray.push(i * 5);\n  }\n  const target = 73;  // Chosen target, not in the array (or could be). Let's put target=73 (between 65 and 75)\n\n  const arrayContainer = document.getElementById('array');\n  const explanation = document.getElementById('explanation');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const arrowsSVG = document.getElementById('arrows');\n\n  // Calculate optimal jump size for jump search: usually sqrt(n)\n  const jumpSize = Math.floor(Math.sqrt(arrSize));\n\n  // Create the blocks with labels for indexes\n  function createBlocks() {\n    arrayContainer.innerHTML = '';\n    for(let i=0; i<arrSize; i++) {\n      const b = document.createElement('div');\n      b.classList.add('block');\n      b.id = `block-${i}`;\n      b.textContent = sortedArray[i];\n      // Label with index below\n      const label = document.createElement('div');\n      label.classList.add('label');\n      label.textContent = i;\n      b.appendChild(label);\n      arrayContainer.appendChild(b);\n    }\n  }\n\n  // Draw arrows under the blocks for jump steps using SVG paths/arrows\n  // We'll draw arrows jumping from block 0 to block jumpSize, to 2*jumpSize, ... and final partial jump to arrSize-1\n  function drawJumpArrows() {\n    arrowsSVG.innerHTML = '';\n    const blocks = Array.from(document.querySelectorAll('.block'));\n    if(blocks.length === 0) return;\n\n    const startY = 8;\n    const arrowHeadSize = 12;\n    const strokeWidth = 5;\n\n    const coords = blocks.map(b => {\n      const rect = b.getBoundingClientRect();\n      const containerRect = arrayContainer.getBoundingClientRect();\n      // Relative to svg container\n      return {\n        x: rect.left - containerRect.left + rect.width/2,\n        y: startY\n      };\n    });\n\n    // Helper to create arrow path from startIdx to endIdx\n    function createArrowPath(startIdx, endIdx, id) {\n      const startX = coords[startIdx].x;\n      const endX = coords[endIdx].x;\n      const midX = (startX + endX)/2;\n      const ampY = 40; // vertical amplitude\n\n      // Path animates a smooth curving arc under the blocks\n      // Start horizontal line down, arc, then horizontal line back up to arrowhead.\n      // For simplicity an arch using cubic bezier\n\n      // Points:\n      // M startX, startY\n      // C startX, startY+ampY, endX, startY+ampY, endX, startY\n\n      return `\n        <path id=\"${id}\" class=\"arrow-path\" d=\"\n          M ${startX} ${startY}\n          C ${startX} ${startY + ampY}, ${endX} ${startY + ampY}, ${endX} ${startY}\n        \" />\n        <polygon class=\"arrow-head\" points=\"\n          ${endX - arrowHeadSize/2} ${startY - arrowHeadSize/3},\n          ${endX} ${startY},\n          ${endX - arrowHeadSize/2} ${startY + arrowHeadSize/3}\n        \" />\n      `;\n    }\n\n    // Draw arrows for jumps\n    for(let i=0; i<Math.ceil(arrSize/jumpSize)-1; i++) {\n      const startIdx = i*jumpSize;\n      const endIdx = Math.min((i+1)*jumpSize, arrSize-1);\n      arrowsSVG.insertAdjacentHTML('beforeend', createArrowPath(startIdx,endIdx,`arrow-${i}`));\n    }\n  }\n\n  // Reset states\n  function reset() {\n    // Clear highlights and roles\n    for(let i=0; i<arrSize; i++) {\n      const b = document.getElementById(`block-${i}`);\n      b.classList.remove('jumped','checked','found');\n    }\n    arrowsSVG.querySelectorAll('.arrow-path,.arrow-head').forEach(el=>{\n      el.classList.remove('arrow-highlight','arrow-head-highlight');\n    });\n    explanation.textContent = 'Click Start to see how Jump Search finds the target value with elegant leaps and steps.';\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n    startBtn.setAttribute('aria-pressed','false');\n  }\n\n  // Animate jump search steps \n  // Limited interactivity per request: just this simple sequence play\n\n  function jumpSearch() {\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n    startBtn.setAttribute('aria-pressed','true');\n\n    let currentJump = 0;\n    let lastJumpIdx = -1;\n    let interval = null;\n    let foundIdx = -1;\n\n    const blocks = [];\n    for(let i=0; i<arrSize; i++) {\n      blocks.push(document.getElementById(`block-${i}`));\n    }\n\n    // Highlight jump block and arrow, explain jump stage\n    function highlightJump(i) {\n      if(lastJumpIdx>=0) {\n        blocks[lastJumpIdx].classList.remove('jumped');\n        const prevArrowPath = arrowsSVG.querySelector(`#arrow-${lastJumpIdx} .arrow-path`);\n        const prevArrowHead = arrowsSVG.querySelector(`#arrow-${lastJumpIdx} .arrow-head`);\n        if(prevArrowPath) prevArrowPath.classList.remove('arrow-highlight');\n        if(prevArrowHead) prevArrowHead.classList.remove('arrow-head-highlight');\n      }\n      const jumpIdx = i * jumpSize;\n      if(jumpIdx>=arrSize) return false;\n      blocks[jumpIdx].classList.add('jumped');\n      const arrowPath = arrowsSVG.querySelector(`#arrow-${i} .arrow-path`);\n      const arrowHead = arrowsSVG.querySelector(`#arrow-${i} .arrow-head`);\n      if(arrowPath) arrowPath.classList.add('arrow-highlight');\n      if(arrowHead) arrowHead.classList.add('arrow-head-highlight');\n      explanation.textContent = `Jumping to index ${jumpIdx} (value: ${blocks[jumpIdx].textContent}) to check if target (${target}) might be here or beyond.`;\n      lastJumpIdx = jumpIdx;\n      return jumpIdx;\n    }\n\n    // When jump search determines the block to linear search inside\n    // We highlight the range and then search linearly\n\n    // Find block where target is <= block value or end\n    function findBlockForLinearSearch() {\n      let block = 0;\n      while(block + jumpSize < arrSize && sortedArray[block + jumpSize -1] < target) {\n        block += jumpSize;\n      }\n      return block;\n    }\n\n    // Linear search inside block ranges\n    function linearSearchInBlock(fromIdx, toIdx, step=0) {\n      if(step > (toIdx-fromIdx)) {\n        explanation.textContent = `Target (${target}) is not in the array. Completed linear search without a match.`;\n        startBtn.disabled = true;\n        resetBtn.disabled = false;\n        return;\n      }\n      // Highlight checked block\n      if(step>0) {\n        blocks[fromIdx+step-1].classList.remove('checked');\n      }\n      const idx = fromIdx + step;\n      blocks[idx].classList.add('checked');\n      explanation.textContent = `Checking index ${idx} (value: ${blocks[idx].textContent}) linearly for target ${target}.`;\n\n      // If found\n      if(sortedArray[idx] === target) {\n        blocks[idx].classList.remove('checked');\n        blocks[idx].classList.add('found');\n        explanation.textContent = `Target found at index ${idx} with value ${target}! Search complete.`;\n        startBtn.disabled = true;\n        resetBtn.disabled = false;\n        return;\n      }\n      // If value exceed target, no found\n      if(sortedArray[idx] > target) {\n        explanation.textContent = `Value at index ${idx} exceeds target (${target}). Target not found; search ends.`;\n        startBtn.disabled = true;\n        resetBtn.disabled = false;\n        return;\n      }\n\n      // Continue next check after delay\n      setTimeout(() => {\n        linearSearchInBlock(fromIdx,toIdx,step+1);\n      }, 1100);\n    }\n\n    // Animate jump steps sequentially with delay\n    // Prepare jump indices to check\n    const jumpIndices = [];\n    for(let i=0; i <= Math.ceil(arrSize/jumpSize)-1; i++) {\n      let jumpIdx = Math.min(i*jumpSize, arrSize-1);\n      if(jumpIdx>=arrSize) break;\n      jumpIndices.push(jumpIdx);\n    }\n\n    let i=0;\n    function jumpStep() {\n      if(i>=jumpIndices.length) {\n        // Linear search phase start\n        explanation.textContent = 'Determine linear search block and proceed.';\n        const startBlock = findBlockForLinearSearch();\n        const endBlock = Math.min(startBlock + jumpSize - 1, arrSize-1);\n        explanation.textContent = `Linear search between indices ${startBlock} to ${endBlock}.`;\n        // Highlight jump block last highlight off\n        blocks[lastJumpIdx].classList.remove('jumped');\n        arrowsSVG.querySelectorAll('.arrow-path,.arrow-head').forEach(el=>{\n          el.classList.remove('arrow-highlight','arrow-head-highlight');\n        });\n        linearSearchInBlock(startBlock, endBlock);\n        return;\n      }\n      const jumpIdx = jumpIndices[i];\n      blocks.forEach(b=>b.classList.remove('jumped'));\n      blocks[jumpIdx].classList.add('jumped');\n      // Highlight arrow for this jump\n      arrowsSVG.querySelectorAll('.arrow-path,.arrow-head').forEach(el=>{\n        el.classList.remove('arrow-highlight','arrow-head-highlight');\n      });\n      if(i>0) {\n        const prevArrowPath = arrowsSVG.querySelector(`#arrow-${i-1} .arrow-path`);\n        const prevArrowHead = arrowsSVG.querySelector(`#arrow-${i-1} .arrow-head`);\n        if(prevArrowPath) prevArrowPath.classList.remove('arrow-highlight');\n        if(prevArrowHead) prevArrowHead.classList.remove('arrow-head-highlight');\n      }\n      if(i < jumpIndices.length - 1) {\n        const arrowPath = arrowsSVG.querySelector(`#arrow-${i} .arrow-path`);\n        const arrowHead = arrowsSVG.querySelector(`#arrow-${i} .arrow-head`);\n        if(arrowPath) arrowPath.classList.add('arrow-highlight');\n        if(arrowHead) arrowHead.classList.add('arrow-head-highlight');\n      }\n      explanation.textContent = `Jumping to index ${jumpIdx} (value: ${sortedArray[jumpIdx]}) to check against target (${target}).`;\n      // Check if target <= current block value - then jump here is boundary\n      if(sortedArray[jumpIdx] >= target) {\n        explanation.textContent = `Target (${target}) is within this block or before index ${jumpIdx}. Proceeding to linear search.`;\n        setTimeout(() => {\n          const startBlock = Math.max(0, jumpIdx - jumpSize + 1);\n          const endBlock = jumpIdx;\n          // Remove jump highlights\n          blocks.forEach(b=>b.classList.remove('jumped'));\n          arrowsSVG.querySelectorAll('.arrow-path,.arrow-head').forEach(el=>{\n            el.classList.remove('arrow-highlight','arrow-head-highlight');\n          });\n          explanation.textContent = `Linear search from index ${startBlock} to ${endBlock}.`;\n          linearSearchInBlock(startBlock, endBlock);\n        }, 1300);\n        return;\n      }\n      // Else continue jumps\n      i++;\n      setTimeout(jumpStep,1300);\n    }\n\n    jumpStep();\n  }\n\n  // Initialization\n  createBlocks();\n  explanation.textContent = 'Click Start to see how Jump Search finds the target value with elegant leaps and steps.';\n  drawJumpArrows();\n\n  startBtn.addEventListener('click', () => {\n    jumpSearch();\n  });\n  resetBtn.addEventListener('click', () => {\n    reset();\n  });\n  window.addEventListener('resize', () => {\n    drawJumpArrows();\n  });\n\n  // Initial reset call to set state properly\n  reset();\n\n})();\n</script>\n\n</body>\n</html>"
