    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Branch and Bound Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600&family=Playfair+Display:ital,wght@1,700&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #1f1c2c, #928dab);\n    font-family: 'Montserrat', sans-serif;\n    color: #e5e5e5;\n    overflow-x: hidden;\n    user-select: none;\n  }\n\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.8rem;\n    margin: 1rem 0 0.4rem 0;\n    letter-spacing: 0.1em;\n    color: #f8f7ff;\n    text-shadow:\n      0 0 10px rgba(250, 240, 255, 0.8),\n      0 0 30px #a28cf7cc,\n      0 0 60px #6f5afdcc;\n  }\n\n  h2 {\n    font-weight: 600;\n    letter-spacing: 0.12em;\n    color: #d3d3ffdd;\n    font-size: 1.3rem;\n    font-family: 'Montserrat', sans-serif;\n    margin-bottom: 2rem;\n    text-transform: uppercase;\n  }\n\n  .container {\n    max-width: 1100px;\n    padding: 0 40px 80px 40px;\n    margin: 0 auto;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  /* The Tree Container */\n  #tree-container {\n    position: relative;\n    width: 100%;\n    max-width: 900px;\n    aspect-ratio: 16 / 9;\n    background: radial-gradient(circle at center, #3b3863 0%, #1f1c2c 90%);\n    border-radius: 1.4rem;\n    box-shadow:\n      inset 0 0 120px #8e8ad825,\n      0 20px 50px rgba(90,75,255,0.45);\n    overflow: visible;\n    user-select: none;\n  }\n\n  /* Nodes */\n\n  .node {\n    position: absolute;\n    width: 96px;\n    height: 96px;\n    background: linear-gradient(135deg, #6f5afd, #3b3863);\n    border: 3.5px solid #b8a7ffdd;\n    border-radius: 50%;\n    box-shadow:\n      0 0 8px #b8a7ffaa,\n      0 6px 12px #3f3bcfcc,\n      inset 0 2px 5px #a89eff55;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    cursor: default;\n    opacity: 0;\n    transform: scale(0.7);\n    transition:\n      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),\n      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);\n  }\n\n  .node.show {\n    opacity: 1;\n    transform: scale(1);\n  }\n\n  .node.branch {\n    background: linear-gradient(135deg, #5040e5, #2a2363);\n    border-color: #6c4df5cc;\n    box-shadow:\n      0 0 12px #925affdd,\n      0 8px 15px #6c4df5bb,\n      inset 0 2px 8px #b8a7ff88;\n  }\n\n  .node.bound {\n    background: linear-gradient(135deg, #fb6376, #7a1e36);\n    border-color: #ff5962cc;\n    box-shadow:\n      0 0 15px #ff5962ff,\n      0 10px 20px #de3247cc,\n      inset 0 3px 8px #ff8497aa;\n  }\n\n  .node .label {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: #fff;\n    text-shadow: 0 0 4px #0008;\n    user-select: none;\n  }\n  .node .value {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 1.9rem;\n    color: #ffd5ff;\n    letter-spacing: 0.02em;\n    margin-top: 0.1rem;\n    text-shadow:\n      0 0 8px #ba97ffdd,\n      0 0 16px #c48affee;\n    user-select: none;\n  }\n\n  /* Connecting Lines */\n\n  svg {\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    pointer-events: none;\n    overflow: visible;\n  }\n\n  line.connector {\n    stroke: #6f5affc9;\n    stroke-width: 3.4;\n    stroke-linecap: round;\n    filter:\n      drop-shadow(0 0 5px #8c7affaa);\n    transition: stroke 1s ease;\n  }\n\n  line.connector.bound {\n    stroke: #f95e72cc;\n    filter:\n      drop-shadow(0 0 10px #fb6376dd);\n  }\n\n  line.connector.faded {\n    stroke: #665fa294;\n    stroke-width: 2;\n    filter: none;\n  }\n\n  /* Controls */\n\n  #controls {\n    margin: 38px 0 0 0;\n    display: flex;\n    gap: 28px;\n  }\n\n  button {\n    background: linear-gradient(145deg, #452edb, #1f169e);\n    border: none;\n    padding: 14px 34px;\n    border-radius: 28px;\n    color: #e9e9ff;\n    font-weight: 700;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 1.12rem;\n    cursor: pointer;\n    user-select: none;\n    box-shadow:\n      0 0 10px #5b46ffcc,\n      inset 0 0 8px #8c7affcc;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.15s ease;\n  }\n  button:active {\n    transform: scale(0.95);\n    background: linear-gradient(145deg, #381fc4, #160f7d);\n    box-shadow:\n      0 0 5px #452edbcc inset;\n  }\n  button:focus-visible {\n    outline-offset: 3px;\n    outline: 3px solid #8c7affaa;\n  }\n\n  /* Footer */\n\n  footer {\n    margin-top: 64px;\n    font-family: 'Montserrat', sans-serif;\n    font-size: 0.9rem;\n    color: #9d9aae;\n    user-select: none;\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"container\" role=\"main\" aria-label=\"Branch and Bound Visualization\">\n    <h1>Branch &amp; Bound</h1>\n    <h2>Visualizing the pruning of solution space</h2>\n\n    <div id=\"tree-container\" aria-describedby=\"desc-tree\" tabindex=\"0\">\n      <svg id=\"connectors\" aria-hidden=\"true\"></svg>\n      <!-- Nodes will be dynamically generated -->\n    </div>\n\n    <div id=\"controls\" aria-label=\"Controls\">\n      <button id=\"btn-start\" aria-live=\"polite\" aria-pressed=\"false\">▶ Start Visualization</button>\n      <button id=\"btn-reset\" aria-live=\"polite\" aria-pressed=\"false\" disabled>⟲ Reset</button>\n    </div>\n  </div>\n\n  <footer>\n    Created with 🌌 by AI &mdash; Branch and Bound Algorithm Visualization\n  </footer>\n\n<script>\n  // Description for screenreaders\n  const treeContainer = document.getElementById('tree-container');\n  const desc = document.createElement('p');\n  desc.id = 'desc-tree';\n  desc.className = 'sr-only';\n  desc.textContent = 'This visualization shows a binary search tree representing a Branch and Bound algorithm exploring and pruning candidate solutions. Nodes highlight best solutions, pruning decisions, and bounding. A smooth animation reveals nodes and edges step-by-step.';\n  treeContainer.appendChild(desc);\n\n  // Setup nodes data for a small fixed example binary tree for Branch & Bound\n  // Each node: id, parentId, label, value, type (branch/bound/neutral)\n  // This simplistic tree will have 7 nodes: root + 2 levels\n  // Values represent solution estimates or bounds\n  // Branch nodes are active search points\n  // Bound nodes are pruned branches\n  // Neutral nodes are unexplored or neutral\n  const nodesData = [\n    { id: 'N1', parent: null, label: 'Root', value: 112, type: 'branch', pos: [50, 8] },\n    { id: 'N2', parent: 'N1', label: 'Left', value: 90, type: 'branch', pos: [25, 30] },\n    { id: 'N3', parent: 'N1', label: 'Right', value: 60, type: 'bound', pos: [75, 30] },\n    { id: 'N4', parent: 'N2', label: 'Left-Left', value: 45, type: 'branch', pos: [12, 52] },\n    { id: 'N5', parent: 'N2', label: 'Left-Right', value: 55, type: 'bound', pos: [38, 52] },\n    { id: 'N6', parent: 'N3', label: 'Right-Left', value: 31, type: 'bound', pos: [62, 52] },\n    { id: 'N7', parent: 'N3', label: 'Right-Right', value: 25, type: 'branch', pos: [88, 52] }\n  ];\n\n  // We'll animate the exploration in sequence, highlighting active nodes (branch) and pruning bounds\n  // We show the tree building line by line with easing fade and scale\n  // Lines will highlight with different colors for pruned edges\n\n  // Globals\n  const tree = document.getElementById('tree-container');\n  const svg = document.getElementById('connectors');\n  const btnStart = document.getElementById('btn-start');\n  const btnReset = document.getElementById('btn-reset');\n\n  // Convert % pos to pixels in container\n  function posToPixels(xPercent, yPercent) {\n    const w = tree.clientWidth;\n    const h = tree.clientHeight;\n    return { x: (xPercent / 100) * w, y: (yPercent / 100) * h };\n  }\n\n  // Create an SVG line connector\n  function createConnector(x1, y1, x2, y2, pruned = false) {\n    const line = document.createElementNS(\"http://www.w3.org/2000/svg\", 'line');\n    line.classList.add('connector');\n    if (pruned) line.classList.add('bound');\n    line.setAttribute('x1', x1);\n    line.setAttribute('y1', y1);\n    line.setAttribute('x2', x1);\n    line.setAttribute('y2', y1);\n    return line;\n  }\n\n  // Create a Node HTML element\n  function createNode(id, label, value, type, posPercent) {\n    const node = document.createElement('div');\n    node.className = `node ${type}`;\n    node.setAttribute('data-id', id);\n    node.setAttribute('role', 'img');\n    node.setAttribute('aria-label', `${label} node with estimated value ${value}. ${type === 'bound' ? 'Pruned branch.' : 'Active branch.'}`);\n\n    // Position\n    const { x, y } = posToPixels(posPercent[0], posPercent[1]);\n    // Offset half width and height for centering\n    node.style.left = `${x - 48}px`;\n    node.style.top = `${y - 48}px`;\n\n    // Inner content\n    const labelElem = document.createElement('div');\n    labelElem.className = 'label';\n    labelElem.textContent = label;\n    node.appendChild(labelElem);\n\n    const valueElem = document.createElement('div');\n    valueElem.className = 'value';\n    valueElem.textContent = value;\n    node.appendChild(valueElem);\n\n    return node;\n  }\n\n  // State variables\n  let nodesMap = new Map();\n  let connectorsMap = new Map();\n  let animationPhase = 0; // Steps through phases 0-9\n  let animationTimeout = null;\n\n  // Clear tree SVG and nodes\n  function clearTree() {\n    svg.innerHTML = '';\n    nodesMap.clear();\n    connectorsMap.clear();\n    tree.querySelectorAll('.node').forEach(n => n.remove());\n    animationPhase = 0;\n  }\n\n  // Build tree base (nodes hidden, no edges)\n  // We add all nodes but keep opacity to 0 (handled in CSS)\n  function buildTreeBase() {\n    nodesData.forEach(nd => {\n      const nodeEl = createNode(nd.id, nd.label, nd.value, nd.type, nd.pos);\n      tree.appendChild(nodeEl);\n      nodesMap.set(nd.id, nodeEl);\n    });\n  }\n\n  // Animate next step with smooth scaling/fading and connector growth\n  function animateStep(step) {\n    switch(step) {\n      case 1:\n        // show root node\n        showNode('N1');\n        break;\n      case 2:\n        // draw edge Root->Left and show Left node\n        drawConnector('N1', 'N2', false);\n        showNode('N2');\n        break;\n      case 3:\n        // draw edge Root->Right (pruned) and show Right node as bound pruned\n        drawConnector('N1', 'N3', true);\n        showNode('N3');\n        break;\n      case 4:\n        // draw Left->Left edge and show Left-Left node\n        drawConnector('N2', 'N4', false);\n        showNode('N4');\n        break;\n      case 5:\n        // draw Left->Right edge (pruned) and show Left-Right node\n        drawConnector('N2', 'N5', true);\n        showNode('N5');\n        break;\n      case 6:\n        // draw Right->Left edge (pruned) and show Right-Left node\n        drawConnector('N3', 'N6', true);\n        showNode('N6');\n        break;\n      case 7:\n        // draw Right->Right edge and show Right-Right node\n        drawConnector('N3', 'N7', false);\n        showNode('N7');\n        break;\n      case 8:\n        // highlight best candidate nodes scaling up briefly (root, Left-Left, Right-Right)\n        highlightBestNodes(['N1', 'N4', 'N7']);\n        break;\n      case 9:\n        // dim all bound nodes and edges for final clarity\n        dimBoundNodesAndEdges();\n        break;\n      default:\n        // end.\n        btnStart.disabled = false;\n        btnReset.disabled = false;\n        btnStart.setAttribute('aria-pressed', 'false');\n        btnReset.setAttribute('aria-pressed', 'false');\n        break;\n    }\n  }\n\n  // Show node with fade and scale\n  function showNode(id) {\n    const node = nodesMap.get(id);\n    if (!node) return;\n    node.classList.add('show');\n  }\n\n  // Draw connector line from p to c. If pruned = true, line is tinted differently\n  // Animate line growth.\n  function drawConnector(pId, cId, pruned = false) {\n    const pNode = nodesMap.get(pId);\n    const cNode = nodesMap.get(cId);\n    if (!pNode || !cNode) return;\n\n    // get center coords of source and target nodes\n    // computed from style left/top + 48 (half width)\n    const pRect = pNode.getBoundingClientRect();\n    const cRect = cNode.getBoundingClientRect();\n    const treeRect = tree.getBoundingClientRect();\n\n    // relative position inside tree container\n    const x1 = pRect.left + pRect.width / 2 - treeRect.left;\n    const y1 = pRect.top + pRect.height / 2 - treeRect.top;\n    const x2 = cRect.left + cRect.width / 2 - treeRect.left;\n    const y2 = cRect.top + cRect.height / 2 - treeRect.top;\n\n    const line = createConnector(x1, y1, x2, y2, pruned);\n    svg.appendChild(line);\n    connectorsMap.set(`${pId}-${cId}`, line);\n\n    // Animate line growth from p to c\n    // We'll animate the line's x2/y2 attr from x1/y1 to x2/y2 over 700ms\n    const duration = 700;\n    const startTime = performance.now();\n\n    function animateLine(time) {\n      const elapsed = time - startTime;\n      const progress = Math.min(elapsed / duration, 1);\n      const curX = x1 + (x2 - x1) * progress;\n      const curY = y1 + (y2 - y1) * progress;\n      line.setAttribute('x2', curX);\n      line.setAttribute('y2', curY);\n      if (progress < 1) {\n        requestAnimationFrame(animateLine);\n      }\n    }\n    requestAnimationFrame(animateLine);\n  }\n\n  // Highlight best candidate nodes for final focus\n  // Scale up and glow with subtle animation for 1.5s\n  function highlightBestNodes(nodeIds) {\n    nodeIds.forEach(id => {\n      const node = nodesMap.get(id);\n      if (!node) return;\n      node.style.transition = 'transform 0.6s ease, box-shadow 0.6s ease';\n      node.style.transform = 'scale(1.2)';\n      node.style.boxShadow =\n        '0 0 18px #ffc6ffcc, 0 0 40px #ff8afccc, inset 0 0 16px #ff8afcaa';\n\n      // Restore back after delay\n      setTimeout(() => {\n        node.style.transform = 'scale(1)';\n        node.style.boxShadow =\n          node.classList.contains('branch')\n            ? '0 0 12px #925affdd, 0 8px 15px #6c4df5bb, inset 0 2px 8px #b8a7ff88'\n            : node.classList.contains('bound')\n            ? '0 0 15px #ff5962ff, 0 10px 20px #de3247cc, inset 0 3px 8px #ff8497aa'\n            : '0 0 8px #b8a7ffaa, 0 6px 12px #3f3bcfcc, inset 0 2px 5px #a89eff55';\n      }, 1600);\n    });\n  }\n\n  // Dim all bound nodes and edges by applying CSS faded styles\n  function dimBoundNodesAndEdges() {\n    // Nodes\n    nodesMap.forEach(node => {\n      if (node.classList.contains('bound')) {\n        node.style.opacity = '0.45';\n      }\n    });\n    // Edges\n    connectorsMap.forEach((line, key) => {\n      if (line.classList.contains('bound')) {\n        line.classList.add('faded');\n      }\n    });\n  }\n\n  // Run animation sequence automatically with timing\n  function runAnimation() {\n    btnStart.disabled = true;\n    btnReset.disabled = false;\n    btnStart.setAttribute('aria-pressed', 'true');\n    btnReset.setAttribute('aria-pressed', 'false');\n\n    animationPhase = 1;\n\n    function step() {\n      animateStep(animationPhase);\n      animationPhase++;\n      if (animationPhase <= 9) {\n        // Timing:\n        // steps 1-7: nodes/edges ~900ms each,\n        // step 8 highlight 1800ms,\n        // step 9 dim 900ms,\n        // then finish\n        let delay;\n        if (animationPhase <= 7) delay = 900;\n        else if (animationPhase === 8) delay = 1800;\n        else if (animationPhase === 9) delay = 900;\n        else delay = 0;\n\n        if (delay > 0) {\n          animationTimeout = setTimeout(step, delay);\n        }\n      }\n    }\n    step();\n  }\n\n  // Reset visualization\n  function resetVisualization() {\n    btnStart.disabled = false;\n    btnReset.disabled = true;\n    btnStart.setAttribute('aria-pressed', 'false');\n    btnReset.setAttribute('aria-pressed', 'false');\n    clearTimeout(animationTimeout);\n    clearTree();\n    buildTreeBase();\n\n    // Reset styles\n    nodesMap.forEach(node => {\n      node.style.opacity = '';\n      node.style.transform = '';\n      node.style.boxShadow = '';\n      node.classList.remove('show');\n    });\n  }\n\n  // On window resize, reposition nodes and lines\n  function reposition() {\n    // Update node positions\n    nodesData.forEach(nd => {\n      const node = nodesMap.get(nd.id);\n      if (!node) return;\n      const { x, y } = posToPixels(nd.pos[0], nd.pos[1]);\n      node.style.left = `${x - 48}px`;\n      node.style.top = `${y - 48}px`;\n    });\n\n    // Update connectors position if any lines drawn\n    connectorsMap.forEach((line, key) => {\n      const [pId, cId] = key.split('-');\n      const pNode = nodesMap.get(pId);\n      const cNode = nodesMap.get(cId);\n      if (!pNode || !cNode) return;\n\n      const pRect = pNode.getBoundingClientRect();\n      const cRect = cNode.getBoundingClientRect();\n      const treeRect = tree.getBoundingClientRect();\n\n      const x1 = pRect.left + pRect.width / 2 - treeRect.left;\n      const y1 = pRect.top + pRect.height / 2 - treeRect.top;\n      const x2 = cRect.left + cRect.width / 2 - treeRect.left;\n      const y2 = cRect.top + cRect.height / 2 - treeRect.top;\n\n      line.setAttribute('x1', x1);\n      line.setAttribute('y1', y1);\n\n      // If line fully drawn, snap x2/y2 to new pos\n      // Or if animating, do not override the animation progress, but this is fine for resize\n      if (Number(line.getAttribute('x2')) !== x1 || Number(line.getAttribute('y2')) !== y1) {\n        line.setAttribute('x2', x2);\n        line.setAttribute('y2', y2);\n      }\n    });\n  }\n\n  // Initial setup\n  clearTree();\n  buildTreeBase();\n\n  // Event listeners\n  btnStart.addEventListener('click', () => {\n    if (btnStart.disabled) return;\n    runAnimation();\n  });\n\n  btnReset.addEventListener('click', () => {\n    resetVisualization();\n  });\n\n  window.addEventListener('resize', () => {\n    reposition();\n  });\n\n  // Accessibility support: add some keyboard focus styles\n  treeContainer.addEventListener('focus', () => {\n    treeContainer.style.outline = '2px solid #8c7affcc';\n    treeContainer.style.outlineOffset = '8px';\n  });\n  treeContainer.addEventListener('blur', () => {\n    treeContainer.style.outline = 'none';\n  });\n\n</script>\n</body>\n</html>"
  },
