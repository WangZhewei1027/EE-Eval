    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Agile Methodology</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 0;\n        }\n        .container {\n            max-width: 600px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #f9f9f9;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        h1 {\n            text-align: center;\n        }\n        p {\n            font-size: 16px;\n            margin-bottom: 20px;\n        }\n        button, input {\n            padding: 10px;\n            margin-bottom: 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover, input:hover {\n            background-color: #ccc;\n        }\n        .button-container {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Agile Methodology</h1>\n        <p>Agile is an iterative and incremental development process. It emphasizes collaboration, flexibility, and continuous improvement.</p>\n        <div class=\"button-container\">\n            <button id=\"start-button\">Start</button>\n            <button id=\"cancel-button\">Cancel</button>\n            <button id=\"finish-button\" disabled>Finish</button>\n        </div>\n        <div id=\"user-input-container\">\n            <label for=\"name\">Name:</label>\n            <input type=\"text\" id=\"name\" name=\"name\">\n            <label for=\"email\">Email:</label>\n            <input type=\"email\" id=\"email\" name=\"email\">\n            <label for=\"message\">Message:</label>\n            <textarea id=\"message\" name=\"message\"></textarea>\n        </div>\n        <div id=\"complex-workflow-container\">\n            <h2>Complex Workflow</h2>\n            <button id=\"add-button\">Add</button>\n            <button id=\"remove-button\">Remove</button>\n            <button id=\"update-button\">Update</button>\n            <button id=\"finish-workflow-button\">Finish Workflow</button>\n            <div id=\"workflow-container\"></div>\n        </div>\n        <div id=\"exploration-container\">\n            <h2>Exploration</h2>\n            <button id=\"next-button\">Next</button>\n            <button id=\"previous-button\">Previous</button>\n            <button id=\"back-button\">Back</button>\n        </div>\n        <div id=\"feedback-container\"></div>\n    </div>\n\n    <script>\n        let currentState = \"start\";\n        let currentWorkflow = \"\";\n        let currentInput = \"\";\n        let currentComplexWorkflow = \"\";\n        let currentExploration = \"\";\n\n        function start() {\n            document.getElementById(\"start-button\").disabled = true;\n            document.getElementById(\"cancel-button\").disabled = false;\n            document.getElementById(\"finish-button\").disabled = false;\n            document.getElementById(\"user-input-container\").disabled = false;\n            document.getElementById(\"complex-workflow-container\").disabled = false;\n            document.getElementById(\"exploration-container\").disabled = false;\n            document.getElementById(\"feedback-container\").innerHTML = \"\";\n        }\n\n        function cancel() {\n            document.getElementById(\"start-button\").disabled = false;\n            document.getElementById(\"cancel-button\").disabled = true;\n            document.getElementById(\"finish-button\").disabled = false;\n            document.getElementById(\"user-input-container\").disabled = true;\n            document.getElementById(\"complex-workflow-container\").disabled = true;\n            document.getElementById(\"exploration-container\").disabled = true;\n            document.getElementById(\"feedback-container\").innerHTML = \"\";\n        }\n\n        function finish() {\n            document.getElementById(\"start-button\").disabled = true;\n            document.getElementById(\"cancel-button\").disabled = false;\n            document.getElementById(\"finish-button\").disabled = false;\n            document.getElementById(\"user-input-container\").disabled = false;\n            document.getElementById(\"complex-workflow-container\").disabled = false;\n            document.getElementById(\"exploration-container\").disabled = false;\n            document.getElementById(\"feedback-container\").innerHTML = \"Workflow finished.\";\n        }\n\n        function add() {\n            if (currentInput.length > 0) {\n                currentInput = \"\";\n            } else {\n                currentInput += \"<button type='button' onclick='addInput()'>Add</button>\";\n            }\n        }\n\n        function remove() {\n            if (currentInput.length > 0) {\n                currentInput = currentInput.substring(0, currentInput.length - 10);\n            } else {\n                currentInput = \"\";\n            }\n        }\n\n        function update() {\n            if (currentInput.length > 0) {\n                currentInput += \"<button type='button' onclick='updateInput()'>Update</button>\";\n            } else {\n                currentInput = \"\";\n            }\n        }\n\n        function finishWorkflow() {\n            if (currentComplexWorkflow.length > 0) {\n                currentComplexWorkflow = \"\";\n            } else {\n                currentComplexWorkflow += \"<button type='button' onclick='finishComplexWorkflow()'>Finish Workflow</button>\";\n            }\n        }\n\n        function finishComplexWorkflow() {\n            if (currentComplexWorkflow.length > 0) {\n                currentComplexWorkflow = \"\";\n            } else {\n                finishWorkflow();\n            }\n        }\n\n        function finishWorkflow() {\n            if (currentInput.length > 0) {\n                currentInput = \"\";\n            } else {\n                finishWorkflow();\n            }\n        }\n\n        function updateInput() {\n            if (currentInput.length > 0) {\n                document.getElementById(\"feedback-container\").innerHTML = \"Input: \" + currentInput;\n            } else {\n                document.getElementById(\"feedback-container\").innerHTML = \"\";\n            }\n        }\n\n        function updateInput() {\n            if (currentInput.length > 0) {\n                document.getElementById(\"feedback-container\").innerHTML = \"Input: \" + currentInput;\n            } else {\n                document.getElementById(\"feedback-container\").innerHTML = \"\";\n            }\n        }\n\n        function addInput() {\n            document.getElementById(\"feedback-container\").innerHTML = \"Input: \" + currentInput;\n            currentInput = \"\";\n            add();\n        }\n\n        function updateInput() {\n            document.getElementById(\"feedback-container\").innerHTML = \"Input: \" + currentInput;\n        }\n\n        function finishComplexWorkflow() {\n            document.getElementById(\"feedback-container\").innerHTML = \"Complex workflow finished.\";\n            finish();\n        }\n\n        function startWorkflow() {\n            document.getElementById(\"feedback-container\").innerHTML = \"Workflow started.\";\n            start();\n        }\n\n        function cancelWorkflow() {\n            document.getElementById(\"feedback-container\").innerHTML = \"Workflow cancelled.\";\n            cancel();\n        }\n\n        function next() {\n            if (currentWorkflow.length > 0) {\n                currentWorkflow = currentWorkflow.substring(0, currentWorkflow.length - 10);\n            } else {\n                currentWorkflow = \"\";\n            }\n            update();\n        }\n\n        function previous() {\n            if (currentWorkflow.length > 0) {\n                currentWorkflow = currentWorkflow.substring(0, currentWorkflow.length - 10);\n            } else {\n                currentWorkflow = \"\";\n            }\n            update();\n        }\n\n        function back() {\n            if (currentWorkflow.length > 0) {\n                currentWorkflow = currentWorkflow.substring(0, currentWorkflow.length - 10);\n            } else {\n                currentWorkflow = \"\";\n            }\n            update();\n        }\n\n        function add() {\n            if (currentState === \"start\") {\n                document.getElementById(\"complex-workflow-container\").innerHTML = \"\";\n                currentState = \"complex-workflow\";\n            } else if (currentState === \"complex-workflow\") {\n                document.getElementById(\"exploration-container\").innerHTML = \"\";\n                currentState = \"exploration\";\n            } else if (currentState === \"exploration\") {\n                document.getElementById(\"feedback-container\").innerHTML = \"\";\n                currentState = \"feedback\";\n            } else if (currentState === \"feedback\") {\n                document.getElementById(\"complex-workflow-container\").innerHTML = \"\";\n                currentState = \"complex-workflow\";\n            }\n        }\n\n        function remove() {\n            if (currentState === \"start\") {\n                document.getElementById(\"complex-workflow-container\").innerHTML = \"\";\n                currentState = \"complex-workflow\";\n            } else if (currentState === \"complex-workflow\") {\n                document.getElementById(\"exploration-container\").innerHTML = \"\";\n                currentState = \"exploration\";\n            } else if (currentState === \"exploration\") {\n                document.getElementById(\"feedback-container\").innerHTML = \"\";\n                currentState = \"feedback\";\n            } else if (currentState === \"feedback\") {\n                document.getElementById(\"complex-workflow-container\").innerHTML = \"\";\n                currentState = \"complex-workflow\";\n            }\n        }\n\n        function update() {\n            if (currentState === \"start\") {\n                document.getElementById(\"complex-workflow-container\").innerHTML = \"\";\n                currentState = \"complex-workflow\";\n            } else if (currentState === \"complex-workflow\") {\n                document.getElementById(\"exploration-container\").innerHTML = \"\";\n                currentState = \"exploration\";\n            } else if (currentState === \"exploration\") {\n                document.getElementById(\"feedback-container\").innerHTML = \"\";\n                currentState = \"feedback\";\n            } else if (currentState === \"feedback\") {\n                document.getElementById(\"complex-workflow-container\").innerHTML = \"\";\n                currentState = \"complex-workflow\";\n            }\n        }\n\n        function finishWorkflow() {\n            document.getElementById(\"complex-workflow-container\").innerHTML = \"\";\n            currentState = \"start\";\n        }\n\n        document.getElementById(\"start-button\").addEventListener(\"click\", start);\n        document.getElementById(\"cancel-button\").addEventListener(\"click\", cancel);\n        document.getElementById(\"finish-button\").addEventListener(\"click\", finish);\n        document.getElementById(\"add-button\").addEventListener(\"click\", add);\n        document.getElementById(\"remove-button\").addEventListener(\"click\", remove);\n        document.getElementById(\"update-button\").addEventListener(\"click\", update);\n        document.getElementById(\"next-button\").addEventListener(\"click\", next);\n        document.getElementById(\"previous-button\").addEventListener(\"click\", previous);\n        document.getElementById(\"back-button\").addEventListener(\"click\", back);\n        document.getElementById(\"finish-workflow-button\").addEventListener(\"click\", finishWorkflow);\n    </script>\n</body>\n</html>"
