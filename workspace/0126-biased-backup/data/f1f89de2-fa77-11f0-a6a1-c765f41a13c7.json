    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Unit Testing — Visual Demonstration</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #071029;\n      --bg-2: #0b2238;\n      --glass: rgba(255,255,255,0.04);\n      --accent: #7be495;\n      --accent-2: #58a6ff;\n      --muted: rgba(255,255,255,0.55);\n      --card: rgba(255,255,255,0.03);\n      --success: #7be495;\n      --danger: #ff6b6b;\n      --glass-border: rgba(255,255,255,0.06);\n    }\n    .theme-light{\n      --bg-1: #f5fbff;\n      --bg-2: #e9f2ff;\n      --glass: rgba(6,10,28,0.04);\n      --accent: #2b6df6;\n      --accent-2: #7b61ff;\n      --muted: rgba(6,10,28,0.55);\n      --card: rgba(255,255,255,0.8);\n      --success: #1f8a58;\n      --danger: #c93b3b;\n      --glass-border: rgba(6,10,28,0.06);\n    }\n\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 800px at 10% 10%, rgba(91,129,255,0.09), transparent 6%),\n                  radial-gradient(1000px 700px at 90% 90%, rgba(123,228,149,0.06), transparent 6%),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      color: white;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Background decorative blobs */\n    .bg-blob{\n      position:fixed;\n      width:720px;\n      height:720px;\n      filter: blur(80px) saturate(120%);\n      opacity:0.22;\n      z-index:0;\n      mix-blend-mode:screen;\n      transform:translate3d(0,0,0);\n      border-radius:50%;\n      animation: floaty 12s ease-in-out infinite;\n    }\n    .blob-a{ background: linear-gradient(135deg, rgba(91,129,255,0.85), rgba(88,166,255,0.65)); left:-15%; top:-10%; }\n    .blob-b{ background: linear-gradient(135deg, rgba(123,228,149,0.85), rgba(125,97,255,0.65)); right:-15%; bottom:-10%; animation-delay:4s; }\n    @keyframes floaty{\n      0%{ transform:translateY(0px) scale(1) rotate(0deg)}\n      50%{ transform:translateY(-30px) scale(1.05) rotate(6deg)}\n      100%{ transform:translateY(0px) scale(1) rotate(0deg)}\n    }\n\n    /* Layout */\n    .wrap{\n      position:relative;\n      z-index:10;\n      display:grid;\n      grid-template-columns: 1fr 420px;\n      gap:32px;\n      align-items:center;\n      height:100vh;\n      padding:48px;\n      box-sizing:border-box;\n    }\n\n    /* Main Card */\n    .panel{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.02));\n      border-radius:20px;\n      padding:36px;\n      box-shadow: 0 10px 40px rgba(3,8,18,0.6), inset 0 1px 0 var(--glass-border);\n      border:1px solid var(--glass-border);\n      backdrop-filter: blur(8px) saturate(120%);\n      display:flex;\n      gap:28px;\n      min-height:520px;\n    }\n\n    /* Left Artwork */\n    .art{\n      flex:1;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n    }\n    .title{\n      display:flex;\n      align-items:center;\n      gap:18px;\n    }\n    .logo{\n      width:72px;\n      height:72px;\n      border-radius:16px;\n      background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      box-shadow: 0 6px 24px rgba(15,20,40,0.45);\n      border:1px solid rgba(255,255,255,0.04);\n    }\n    .logo svg{ filter: drop-shadow(0 6px 18px rgba(91,129,255,0.12)); }\n\n    .h{\n      font-size:20px;\n      font-weight:700;\n      letter-spacing:-0.02em;\n      color:var(--muted);\n    }\n    .sub{\n      color:var(--muted);\n      font-size:14px;\n      margin-top:4px;\n    }\n\n    /* Illustration card */\n    .canvas{\n      margin-top:8px;\n      border-radius:14px;\n      overflow:hidden;\n      position:relative;\n      padding:22px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      gap:18px;\n      align-items:center;\n      min-height:300px;\n    }\n\n    .gear-wrap{\n      width:220px;\n      height:220px;\n      border-radius:20px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      background: radial-gradient(circle at 20% 10%, rgba(255,255,255,0.02), transparent 20%), linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border:1px solid rgba(255,255,255,0.03);\n      position:relative;\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n\n    .gear{\n      width:160px;\n      height:160px;\n      transform-origin:center;\n      animation: spin 9s linear infinite;\n      filter: drop-shadow(0 18px 40px rgba(3,8,18,0.65));\n    }\n    @keyframes spin{ 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }\n\n    /* Animated code lines */\n    .code{\n      flex:1;\n      display:flex;\n      flex-direction:column;\n      gap:10px;\n      padding-right:10px;\n    }\n    .code .line{\n      height:12px;\n      border-radius:8px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n      width:100%;\n      position:relative;\n      overflow:hidden;\n    }\n    .code .tag{\n      height:12px;\n      width:36%;\n      border-radius:8px;\n      background: linear-gradient(90deg, var(--accent), var(--accent-2));\n      box-shadow:0 6px 14px rgba(91,129,255,0.07), inset 0 -2px 0 rgba(255,255,255,0.02);\n      transform:translateX(-6px);\n      opacity:0.95;\n    }\n\n    .pulse{\n      position:absolute;\n      inset:0;\n      background: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.00));\n      transform:translateX(-100%);\n      animation: sweep 2.6s ease-in-out infinite;\n      mix-blend-mode:overlay;\n    }\n    @keyframes sweep{\n      0%{ transform:translateX(-100%); opacity:0}\n      10%{ opacity:0.7}\n      50%{ transform:translateX(0%) ; opacity:0.4}\n      100%{ transform:translateX(100%); opacity:0}\n    }\n\n    /* Right Summary panel */\n    .summary{\n      width:420px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n    }\n    .summary-top{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n    }\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid var(--glass-border);\n      color:var(--muted);\n      padding:10px 14px;\n      border-radius:10px;\n      font-weight:600;\n      cursor:pointer;\n      box-shadow: 0 6px 16px rgba(3,8,18,0.45);\n      transition: transform .18s ease, box-shadow .18s ease, background .18s ease;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n    }\n    .btn:active{ transform:translateY(1px);}\n    .btn.primary{\n      background: linear-gradient(90deg, var(--accent), var(--accent-2));\n      color: #05122b;\n      border:0;\n      box-shadow: 0 10px 30px rgba(20,40,80,0.28), 0 2px 8px rgba(0,0,0,0.2);\n    }\n    .btn.ghost{\n      background:transparent;\n      color:var(--muted);\n      border:1px dashed rgba(255,255,255,0.04);\n    }\n\n    .donut{\n      width:180px;\n      height:180px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n    }\n    .donut svg{ transform: rotate(-90deg); }\n    .donut .center{\n      position:absolute;\n      text-align:center;\n    }\n    .donut .center .big{\n      font-size:28px;\n      font-weight:800;\n      letter-spacing:-0.02em;\n      color:var(--muted);\n    }\n    .donut .center .sm{\n      font-size:12px;\n      color:var(--muted);\n      margin-top:6px;\n    }\n\n    /* Tests list */\n    .tests{\n      background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n      padding:14px;\n      border-radius:12px;\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      flex-direction:column;\n      gap:8px;\n      margin-top:6px;\n      max-height:240px;\n      overflow:auto;\n    }\n    .test{\n      display:flex;\n      align-items:center;\n      gap:12px;\n      padding:10px;\n      border-radius:10px;\n      transition: transform .18s cubic-bezier(.2,.9,.3,1), box-shadow .18s;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .test.small{ padding:8px; border-radius:8px; font-size:13px;}\n    .badge{\n      min-width:48px;\n      height:48px;\n      border-radius:10px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:700;\n      color:#021427;\n      background:linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.03));\n      box-shadow: 0 6px 18px rgba(3,8,18,0.4);\n    }\n    .badge.ok{ background: linear-gradient(180deg, rgba(123,228,149,1), rgba(123,228,149,0.85)); color:#04160d;}\n    .badge.fail{ background: linear-gradient(180deg, rgba(255,107,107,1), rgba(255,78,78,0.92)); color:#2b0f0f;}\n    .meta{\n      flex:1;\n      display:flex;\n      flex-direction:column;\n      gap:4px;\n    }\n    .meta .name{ font-weight:700; color:var(--muted); }\n    .meta .desc{ font-size:13px; color:rgba(255,255,255,0.45); }\n\n    /* Console */\n    .console{\n      margin-top:8px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(2,6,14,0.45), rgba(2,6,14,0.25));\n      padding:12px;\n      border:1px solid rgba(255,255,255,0.03);\n      min-height:84px;\n      display:flex;\n      flex-direction:column;\n      gap:6px;\n      overflow:hidden;\n    }\n    .log{\n      font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;\n      font-size:12px;\n      color:rgba(255,255,255,0.9);\n      display:flex;\n      gap:8px;\n      align-items:flex-start;\n    }\n    .log .time{ color:rgba(255,255,255,0.35); min-width:52px; font-size:11px;}\n    .log .msg{ color:rgba(255,255,255,0.85); }\n\n    /* Footer small hint */\n    .hint{\n      margin-top:auto;\n      color:rgba(255,255,255,0.28);\n      font-size:12px;\n    }\n\n    /* small animations */\n    .test.appearing{ transform:translateY(6px); opacity:0; animation: dropIn .6s forwards cubic-bezier(.2,.9,.3,1); }\n    @keyframes dropIn{ to{ transform:none; opacity:1;} }\n    .badge.pulse{\n      animation: pop .54s cubic-bezier(.2,.9,.3,1);\n    }\n    @keyframes pop{\n      0%{ transform:scale(.6) rotate(-10deg); opacity:0 }\n      60%{ transform:scale(1.08) rotate(4deg); opacity:1}\n      100%{ transform:scale(1) rotate(0deg) }\n    }\n\n    /* scrollbar */\n    .tests::-webkit-scrollbar, .console::-webkit-scrollbar{ height:8px; width:8px; }\n    .tests::-webkit-scrollbar-thumb, .console::-webkit-scrollbar-thumb{\n      background: rgba(255,255,255,0.04); border-radius:10px; border:1px solid rgba(255,255,255,0.02);\n    }\n\n    /* small responsive */\n    @media (max-width:980px){\n      .wrap{ grid-template-columns: 1fr; padding:24px; gap:18px; height:auto; align-items:stretch;}\n      .summary{ width:100%;}\n      .panel{ flex-direction:column; padding:22px; min-height:720px;}\n      .canvas{ min-height:360px; flex-direction:row; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"bg-blob blob-a\" aria-hidden=\"true\"></div>\n  <div class=\"bg-blob blob-b\" aria-hidden=\"true\"></div>\n\n  <div class=\"wrap\" role=\"main\" aria-labelledby=\"pageTitle\">\n    <div class=\"panel\" role=\"region\" aria-label=\"Unit Testing visualization\">\n      <div class=\"art\">\n        <div class=\"title\">\n          <div class=\"logo\" aria-hidden=\"true\">\n            <!-- Inline stylized unit-test icon -->\n            <svg width=\"46\" height=\"46\" viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <defs>\n                <linearGradient id=\"g1\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#7be495\"/>\n                  <stop offset=\"1\" stop-color=\"#58a6ff\"/>\n                </linearGradient>\n              </defs>\n              <rect x=\"6\" y=\"10\" width=\"52\" height=\"44\" rx=\"6\" fill=\"url(#g1)\"></rect>\n              <rect x=\"12\" y=\"16\" width=\"40\" height=\"6\" rx=\"3\" fill=\"#021427\" opacity=\"0.12\"></rect>\n              <rect x=\"12\" y=\"26\" width=\"28\" height=\"6\" rx=\"3\" fill=\"#021427\" opacity=\"0.09\"></rect>\n              <circle cx=\"46\" cy=\"38\" r=\"6\" fill=\"#021427\" opacity=\"0.12\"></circle>\n            </svg>\n          </div>\n          <div>\n            <div id=\"pageTitle\" class=\"h\">Unit Testing</div>\n            <div class=\"sub\">Isolated · Repeatable · Fast — visualize the lifecycle of tests</div>\n          </div>\n        </div>\n\n        <div class=\"canvas\" aria-hidden=\"false\">\n          <div class=\"gear-wrap\" aria-hidden=\"true\">\n            <!-- Complex gear SVG with subtle shading -->\n            <svg class=\"gear\" viewBox=\"0 0 200 200\" xmlns=\"http://www.w3.org/2000/svg\">\n              <defs>\n                <radialGradient id=\"g2\" cx=\"30%\" cy=\"20%\">\n                  <stop offset=\"0\" stop-color=\"rgba(255,255,255,0.9)\"/>\n                  <stop offset=\"1\" stop-color=\"rgba(255,255,255,0.02)\"/>\n                </radialGradient>\n                <linearGradient id=\"g3\" x1=\"0\" x2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#7be495\"/>\n                  <stop offset=\"1\" stop-color=\"#58a6ff\"/>\n                </linearGradient>\n              </defs>\n              <g transform=\"translate(100,100)\">\n                <path d=\"M0-56 L15-56 L22-70 L38-66 L46-78 L62-71 L66-90 L86-90 L84-110 L100-110 L100-126 L76-126 L70-140 L50-134 L46-150 L26-150 L16-136 L0-140 L-16-136 L-26-150 L-46-150 L-50-134 L-70-140 L-76-126 L-100-126 L-100-110 L-84-110 L-86-90 L-66-90 L-62-71 L-46-78 L-38-66 L-22-70 L-15-56 L0-56 Z\" fill=\"url(#g3)\" opacity=\"0.95\" transform=\"scale(0.6)\"></path>\n                <circle r=\"48\" fill=\"url(#g2)\"></circle>\n                <circle r=\"26\" fill=\"rgba(2,8,16,0.3)\"></circle>\n                <circle r=\"12\" fill=\"rgba(255,255,255,0.92)\" opacity=\"0.07\"></circle>\n              </g>\n            </svg>\n            <!-- Micro glowing test lights -->\n            <svg style=\"position:absolute; left:12px; bottom:10px;\" width=\"36\" height=\"36\" viewBox=\"0 0 24 24\">\n              <circle cx=\"12\" cy=\"12\" r=\"6\" fill=\"rgba(123,228,149,0.28)\"><animate attributeName=\"r\" values=\"4;6;4\" dur=\"2s\" repeatCount=\"indefinite\" /></circle>\n            </svg>\n            <svg style=\"position:absolute; right:12px; top:18px;\" width=\"36\" height=\"36\" viewBox=\"0 0 24 24\">\n              <circle cx=\"12\" cy=\"12\" r=\"5\" fill=\"rgba(255,107,107,0.12)\"><animate attributeName=\"r\" values=\"3;5;3\" dur=\"2.6s\" repeatCount=\"indefinite\" /></circle>\n            </svg>\n          </div>\n\n          <div class=\"code\" aria-hidden=\"true\">\n            <div class=\"line\" style=\"width:86%\"><div class=\"tag\" style=\"width:36%\"></div><span class=\"pulse\"></span></div>\n            <div class=\"line\" style=\"width:92%\"><div class=\"tag\" style=\"width:48%\"></div><span class=\"pulse\"></span></div>\n            <div class=\"line\" style=\"width:72%\"><div class=\"tag\" style=\"width:28%\"></div><span class=\"pulse\"></span></div>\n            <div class=\"line\" style=\"width:98%\"><div class=\"tag\" style=\"width:62%\"></div><span class=\"pulse\"></span></div>\n            <div class=\"line\" style=\"width:60%\"><div class=\"tag\" style=\"width:40%\"></div><span class=\"pulse\"></span></div>\n            <div class=\"line\" style=\"width:80%\"><div class=\"tag\" style=\"width:20%\"></div><span class=\"pulse\"></span></div>\n          </div>\n        </div>\n\n        <div class=\"hint\">Aesthetic snapshot of a unit test run — press \"Run Tests\" to animate a simulated suite.</div>\n      </div>\n\n      <aside class=\"summary\" role=\"complementary\" aria-label=\"Test summary\">\n        <div class=\"summary-top\">\n          <div>\n            <div style=\"font-weight:800; font-size:13px; color:var(--muted)\">Current Suite</div>\n            <div style=\"color:rgba(255,255,255,0.28); font-size:12px; margin-top:6px\">simulated · isolated · deterministic</div>\n          </div>\n\n          <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n            <button class=\"btn primary\" id=\"runBtn\" title=\"Run the test suite (simulated)\">\n              <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" style=\"filter:brightness(1.05);\"><path fill=\"currentColor\" d=\"M3 22v-20l18 10-18 10z\"/></svg>\n              Run Tests\n            </button>\n            <button class=\"btn ghost\" id=\"themeBtn\" title=\"Toggle color theme\">\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\"><path fill=\"currentColor\" d=\"M5.64 17.657A9 9 0 1 1 18.343 6.36 7 7 0 0 0 5.64 17.657z\"/></svg>\n            </button>\n          </div>\n        </div>\n\n        <div style=\"display:flex; gap:12px; align-items:center;\">\n          <div class=\"donut\" aria-hidden=\"true\">\n            <svg width=\"180\" height=\"180\" viewBox=\"0 0 100 100\">\n              <defs>\n                <linearGradient id=\"arc\" x1=\"0\" x2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#7be495\"/>\n                  <stop offset=\"1\" stop-color=\"#58a6ff\"/>\n                </linearGradient>\n              </defs>\n              <circle cx=\"50\" cy=\"50\" r=\"40\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"10\" fill=\"none\"></circle>\n              <circle id=\"progressArc\" cx=\"50\" cy=\"50\" r=\"40\" stroke=\"url(#arc)\" stroke-width=\"10\" stroke-linecap=\"round\" fill=\"none\" stroke-dasharray=\"251.2\" stroke-dashoffset=\"251.2\"></circle>\n            </svg>\n            <div class=\"center\">\n              <div id=\"passPercent\" class=\"big\">—%</div>\n              <div class=\"sm\">passing</div>\n            </div>\n          </div>\n\n          <div style=\"flex:1; display:flex; flex-direction:column; gap:6px;\">\n            <div style=\"display:flex; gap:8px; align-items:center;\">\n              <div style=\"width:10px; height:10px; border-radius:3px; background:var(--success)\"></div>\n              <div style=\"color:var(--muted); font-weight:700\">Passed</div>\n              <div style=\"margin-left:auto; color:rgba(255,255,255,0.26)\" id=\"passedCount\">0</div>\n            </div>\n            <div style=\"display:flex; gap:8px; align-items:center;\">\n              <div style=\"width:10px; height:10px; border-radius:3px; background:var(--danger)\"></div>\n              <div style=\"color:var(--muted); font-weight:700\">Failed</div>\n              <div style=\"margin-left:auto; color:rgba(255,255,255,0.26)\" id=\"failedCount\">0</div>\n            </div>\n            <div style=\"display:flex; gap:8px; align-items:center; opacity:0.9; font-size:13px; color:rgba(255,255,255,0.3); margin-top:6px\">\n              <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" style=\"opacity:0.9; margin-right:6px;\"><path fill=\"currentColor\" d=\"M12 2a10 10 0 1 0 10 10A10.012 10.012 0 0 0 12 2zm1 15h-2v-2h2zm0-4h-2V7h2z\"/></svg>\n              Test runs are deterministic visualizations — durations are simulated for dramatic effect.\n            </div>\n          </div>\n        </div>\n\n        <div class=\"tests\" id=\"testsList\" role=\"list\" aria-label=\"Test results\">\n          <!-- Test items go here -->\n        </div>\n\n        <div class=\"console\" aria-live=\"polite\" aria-atomic=\"false\">\n          <div id=\"logArea\">\n            <div class=\"log\"><div class=\"time\">00:00</div><div class=\"msg\">Idle. Awaiting run.</div></div>\n          </div>\n        </div>\n\n      </aside>\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      // Simulated test names\n      const tests = [\n        \"should instantiate service with defaults\",\n        \"should validate input schema\",\n        \"should compute hash deterministically\",\n        \"should handle empty list gracefully\",\n        \"should retry on transient network error\",\n        \"should sanitize user input\",\n        \"should emit correct metrics\",\n        \"should close resources after error\",\n        \"should return cached result\",\n        \"should respect timeout configuration\",\n        \"should transform response body\",\n        \"should log useful context\",\n      ];\n\n      // UI elements\n      const runBtn = document.getElementById('runBtn');\n      const themeBtn = document.getElementById('themeBtn');\n      const testsList = document.getElementById('testsList');\n      const logArea = document.getElementById('logArea');\n      const arc = document.getElementById('progressArc');\n      const passPercent = document.getElementById('passPercent');\n      const passedCount = document.getElementById('passedCount');\n      const failedCount = document.getElementById('failedCount');\n      const body = document.body;\n\n      let running = false;\n      let currentTheme = 'dark';\n\n      // Helper: format time for log\n      function nowTime(){\n        const d = new Date();\n        return d.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit'});\n      }\n\n      // Append log line\n      function log(msg, prefixTime = true){\n        const el = document.createElement('div');\n        el.className = 'log';\n        el.innerHTML = '<div class=\"time\">'+(prefixTime?nowTime():'')+'</div><div class=\"msg\">'+msg+'</div>';\n        logArea.prepend(el);\n      }\n\n      // Reset UI\n      function resetUI(){\n        testsList.innerHTML = '';\n        passPercent.textContent = '—%';\n        arc.style.strokeDashoffset = 251.2; // full circumference no progress\n        passedCount.textContent = '0';\n        failedCount.textContent = '0';\n        logArea.innerHTML = '<div class=\"log\"><div class=\"time\">00:00</div><div class=\"msg\">Idle. Awaiting run.</div></div>';\n      }\n      resetUI();\n\n      // Simulate run\n      runBtn.addEventListener('click', async function(){\n        if (running) return;\n        running = true;\n        runBtn.textContent = 'Running...';\n        runBtn.disabled = true;\n        log('Starting test suite simulation');\n\n        // clear previous\n        testsList.innerHTML = '';\n        passPercent.textContent = '0%';\n        passedCount.textContent = '0';\n        failedCount.textContent = '0';\n        arc.style.transition = 'none';\n        arc.style.strokeDashoffset = 251.2;\n\n        // Render skeleton tests (hidden)\n        tests.forEach((t, i) => {\n          const item = document.createElement('div');\n          item.className = 'test appearing';\n          item.style.opacity = '0';\n          const badge = document.createElement('div');\n          badge.className = 'badge';\n          badge.textContent = i+1;\n          const meta = document.createElement('div');\n          meta.className = 'meta';\n          meta.innerHTML = '<div class=\"name\">'+t+'</div><div class=\"desc\">running…</div>';\n          item.appendChild(badge);\n          item.appendChild(meta);\n          testsList.appendChild(item);\n        });\n\n        // stagger reveal\n        const nodes = Array.from(testsList.children);\n        for(let i=0;i<nodes.length;i++){\n          nodes[i].style.animationDelay = (i*80)+'ms';\n        }\n\n        // Animate donut progress while tests run\n        arc.style.transition = 'stroke-dashoffset 1.2s ease-out';\n        let passed = 0, failed = 0;\n\n        // Random seed deterministic-ish: use time mod\n        const seed = (Date.now() % 97) / 97;\n        function rand(){\n          // simple LCG\n          let x = Math.sin((seed + Math.random()) * 10000) * 10000;\n          return x - Math.floor(x);\n        }\n\n        for (let i=0;i<tests.length;i++){\n          // simulate running time\n          const duration = 260 + Math.floor(Math.random()*360);\n          await new Promise(r => setTimeout(r, duration));\n\n          // determine pass/fail (80% pass)\n          const passChance = 0.82;\n          const passedTest = Math.random() < passChance;\n\n          // update UI for this test\n          const node = nodes[i];\n          const badge = node.querySelector('.badge');\n          const meta = node.querySelector('.meta .desc');\n          const nameEl = node.querySelector('.meta .name');\n\n          // assign badge style\n          badge.classList.add(passedTest ? 'ok' : 'fail','pulse');\n          badge.textContent = passedTest ? 'OK' : 'ERR';\n          meta.textContent = passedTest ? 'assertions: 3 • duration: '+(50+Math.floor(Math.random()*120))+'ms' : 'AssertionError: expected true to equal false';\n          nameEl.style.opacity = '1';\n\n          if (passedTest){ passed++; passedCountUpdate(passed); }\n          else { failed++; failedCount.textContent = failed; }\n\n          // animate progress arc according to tests completed\n          const percent = Math.round(((passed) / (i+1)) * 100);\n          const overallPercent = Math.round((passed / tests.length) * 100);\n          animateArc(overallPercent);\n          passPercent.textContent = overallPercent + '%';\n\n          // log\n          if (passedTest) log('✓ '+tests[i]+' (passed)', false);\n          else log('𐄂 '+tests[i]+' (failed) — AssertionError', false);\n\n          // small highlight\n          node.style.transform = 'translateY(0)';\n          node.style.opacity = '1';\n        }\n\n        // final summary\n        log('Test suite finished — '+passed+' passed, '+failed+' failed');\n        runBtn.textContent = 'Run Tests';\n        runBtn.disabled = false;\n        running = false;\n      });\n\n      function passedCountUpdate(n){\n        passedCount.textContent = n;\n      }\n\n      // animate donut arc to percent (0-100)\n      function animateArc(pct){\n        const circumference = 2 * Math.PI * 40; // r=40\n        const offset = circumference * (1 - (pct/100));\n        arc.style.transition = 'stroke-dashoffset 700ms cubic-bezier(.2,.9,.3,1)';\n        arc.style.strokeDashoffset = offset;\n      }\n\n      // Theme toggle\n      themeBtn.addEventListener('click', function(){\n        if (currentTheme === 'dark'){\n          body.classList.add('theme-light');\n          currentTheme = 'light';\n        } else {\n          body.classList.remove('theme-light');\n          currentTheme = 'dark';\n        }\n      });\n\n      // Accessibility: keyboard Enter triggers action\n      runBtn.addEventListener('keyup', (e)=>{ if(e.key==='Enter') runBtn.click(); });\n      themeBtn.addEventListener('keyup', (e)=>{ if(e.key==='Enter') themeBtn.click(); });\n\n      // Small initial demo auto-run once after load for visual engagement\n      setTimeout(()=>{ if(!running){ runBtn.click(); } }, 800);\n\n    })();\n  </script>\n</body>\n</html>"
