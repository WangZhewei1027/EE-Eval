  "question": "Space Complexity",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Space Complexity Explorer</title>\n  <style>\n    /* Extremely minimal styling: default colors, plain layout */\n    body { font-family: Arial, sans-serif; margin: 12px; color: black; background: white; }\n    h1 { font-size: 18px; margin: 0 0 8px 0; }\n    section { margin: 10px 0; padding: 6px 0; border-top: 1px solid #000; }\n    label, select, input, button, textarea { font-size: 13px; }\n    input[type=\"number\"], input[type=\"text\"], select { width: 120px; }\n    textarea { width: 100%; height: 120px; font-family: monospace; font-size: 12px; }\n    pre { font-family: monospace; font-size: 12px; white-space: pre-wrap; }\n    .row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }\n    .col { display: flex; flex-direction: column; gap: 4px; }\n    .small { font-size: 12px; }\n    .controls { margin: 6px 0; }\n    .memory-list { max-height: 200px; overflow: auto; border: 1px solid #000; padding: 6px; }\n    button { padding: 4px 8px; }\n    input[type=range] { width: 220px; }\n    .tiny { font-size: 11px; }\n  </style>\n</head>\n<body>\n  <h1>Space Complexity Explorer</h1>\n  <div class=\"small\">An interactive sandbox to explore space complexity: simulate allocations, recursion, auxiliary structures, and custom scenarios. Interface is intentionally plain.</div>\n\n  <section>\n    <div class=\"row controls\">\n      <div class=\"col\">\n        <label for=\"algo\">Choose algorithm / scenario:</label>\n        <select id=\"algo\">\n          <option value=\"iterative_sum\">Iterative Sum (O(1) extra)</option>\n          <option value=\"copy_array\">Copy Array (O(n) extra)</option>\n          <option value=\"merge_sort\">Merge Sort (O(n) extra)</option>\n          <option value=\"quicksort_inplace\">Quicksort (in-place) (O(log n) stack avg)</option>\n          <option value=\"quicksort_worst\">Quicksort Worst-case (O(n) stack)</option>\n          <option value=\"naive_fib\">Naive Fibonacci (exponential recursion tree)</option>\n          <option value=\"binary_tree_rec\">Binary Tree Recursion (O(n) stack? depending)</option>\n          <option value=\"graph_dfs\">Graph DFS (stack + adjacency)</option>\n          <option value=\"dynamic_prog\">Dynamic Programming (DP table O(n) or O(n^2))</option>\n          <option value=\"custom_script\">Custom Script (from editor)</option>\n        </select>\n      </div>\n\n      <div class=\"col\">\n        <label>Language preset / sizes:</label>\n        <select id=\"langPreset\">\n          <option value=\"python\">Python (object-heavy)</option>\n          <option value=\"java\">Java (objects + pointers)</option>\n          <option value=\"c\">C (primitive-focused)</option>\n        </select>\n      </div>\n\n      <div class=\"col\">\n        <label>Element size (bytes):</label>\n        <input id=\"elemSize\" type=\"number\" min=\"1\" value=\"8\">\n      </div>\n\n      <div class=\"col\">\n        <label>Pointer/reference size (bytes):</label>\n        <input id=\"ptrSize\" type=\"number\" min=\"1\" value=\"8\">\n      </div>\n\n      <div class=\"col\">\n        <label>Object overhead (bytes):</label>\n        <input id=\"objOverhead\" type=\"number\" min=\"0\" value=\"16\">\n      </div>\n\n    </div>\n\n    <div class=\"row controls\">\n      <div class=\"col\">\n        <label>Input size n:</label>\n        <input id=\"nVal\" type=\"number\" min=\"0\" value=\"16\">\n      </div>\n\n      <div class=\"col\">\n        <label>n slider:</label>\n        <input id=\"nSlider\" type=\"range\" min=\"1\" max=\"200\" value=\"16\">\n      </div>\n\n      <div class=\"col\">\n        <label><input id=\"countInput\" type=\"checkbox\" checked> Count input memory</label>\n        <label><input id=\"countStack\" type=\"checkbox\" checked> Count stack frames</label>\n        <label><input id=\"countAux\" type=\"checkbox\" checked> Count auxiliary/allocation</label>\n      </div>\n\n      <div class=\"col\">\n        <label><input id=\"includePtrs\" type=\"checkbox\" checked> Include pointer memory</label>\n        <label><input id=\"simulateGC\" type=\"checkbox\"> Simulate simple GC</label>\n      </div>\n\n    </div>\n\n    <div class=\"row controls\">\n      <button id=\"generateBtn\">Generate Events</button>\n      <button id=\"runBtn\">Run</button>\n      <button id=\"stepBtn\">Step</button>\n      <button id=\"backBtn\">Step Back</button>\n      <button id=\"playBtn\">Play</button>\n      <button id=\"pauseBtn\">Pause</button>\n      <button id=\"resetBtn\">Reset</button>\n      <button id=\"randomizeBtn\">Randomize Params</button>\n    </div>\n\n    <div class=\"row controls\">\n      <label>Playback speed (ms per step):</label>\n      <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\">\n      <label class=\"tiny\">GC frequency (steps):</label>\n      <input id=\"gcFreq\" type=\"number\" min=\"1\" value=\"8\">\n    </div>\n  </section>\n\n  <section>\n    <div class=\"row\">\n      <div style=\"flex:1;\">\n        <h2 style=\"font-size:14px;margin:4px 0;\">Simulation Controls & Manual Allocations</h2>\n        <div class=\"row\">\n          <div class=\"col\">\n            <label>Manual allocate size (elements count):</label>\n            <input id=\"manualCount\" type=\"number\" min=\"1\" value=\"4\">\n          </div>\n          <div class=\"col\">\n            <label>Region:</label>\n            <select id=\"manualRegion\">\n              <option value=\"heap\">heap</option>\n              <option value=\"stack\">stack</option>\n              <option value=\"aux\">aux</option>\n            </select>\n          </div>\n          <div class=\"col\">\n            <label>Description:</label>\n            <input id=\"manualDesc\" type=\"text\" value=\"manual\">\n          </div>\n          <div class=\"col\">\n            <button id=\"manualAllocBtn\">Allocate</button>\n            <button id=\"manualFreeBtn\">Free Last</button>\n          </div>\n        </div>\n\n        <div class=\"row\" style=\"margin-top:6px;\">\n          <div class=\"col\" style=\"flex:1;\">\n            <label>Custom script (command per line):</label>\n            <textarea id=\"scriptArea\">\n# Commands:\n# ALLOC id kind count       - allocate \"count\" elements under kind: heap/stack/aux\n# FREE id                  - free by id\n# CALL f id size           - push stack frame id (size elements)\n# RETURN id                - pop frame id\n# REF src dest             - create a reference from src -> dest (for GC)\n# UNREF src dest           - remove reference\n# WAIT k                   - advance k steps\n# EXAMPLE:\nALLOC A heap 16\nCALL f1 frame 1\nWAIT 1\nALLOC B aux 8\nREF A B\nRETURN f1\nWAIT 1\nFREE B\n# End\n            </textarea>\n            <div class=\"row\">\n              <button id=\"loadScriptBtn\">Load Script</button>\n              <button id=\"runScriptBtn\">Run Script</button>\n              <button id=\"stepScriptBtn\">Step Script</button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"width:360px;\">\n        <h2 style=\"font-size:14px;margin:4px 0;\">State / Memory</h2>\n        <div class=\"small\">Totals, breakdowns, and allocation table (textual bars indicate relative sizes).</div>\n        <div style=\"margin-top:6px;\">\n          <div>Total memory: <span id=\"totalMem\">0</span> bytes</div>\n          <div>Heap: <span id=\"heapMem\">0</span> bytes | Stack: <span id=\"stackMem\">0</span> bytes | Aux: <span id=\"auxMem\">0</span> bytes</div>\n          <div>Peak memory observed: <span id=\"peakMem\">0</span> bytes</div>\n        </div>\n        <div class=\"memory-list\" id=\"allocList\" style=\"margin-top:8px;\"></div>\n      </div>\n    </div>\n  </section>\n\n  <section>\n    <h2 style=\"font-size:14px;margin:4px 0;\">Event Timeline</h2>\n    <div class=\"row\">\n      <label>Step: <span id=\"stepCounter\">0</span> / <span id=\"maxStep\">0</span></label>\n      <input id=\"timelineSlider\" type=\"range\" min=\"0\" max=\"0\" value=\"0\" style=\"flex:1;\">\n      <button id=\"inspectBtn\">Inspect Step</button>\n    </div>\n    <pre id=\"eventsLog\"></pre>\n  </section>\n\n  <section>\n    <h2 style=\"font-size:14px;margin:4px 0;\">Space Complexity Estimator</h2>\n    <div class=\"row\">\n      <div class=\"col\">\n        <label>Formula selection:</label>\n        <select id=\"formulaSelect\">\n          <option value=\"O(1)\">O(1)</option>\n          <option value=\"O(log n)\">O(log n)</option>\n          <option value=\"O(n)\">O(n)</option>\n          <option value=\"O(n log n)\">O(n log n)</option>\n          <option value=\"O(n^2)\">O(n^2)</option>\n          <option value=\"Custom\">Custom expression (use n)</option>\n        </select>\n      </div>\n      <div class=\"col\">\n        <label>Custom expression:</label>\n        <input id=\"customExpr\" type=\"text\" value=\"n*8 + 16\">\n      </div>\n      <div class=\"col\">\n        <button id=\"estimateBtn\">Estimate Table</button>\n      </div>\n    </div>\n    <pre id=\"estTable\"></pre>\n  </section>\n\n  <section>\n    <h2 style=\"font-size:14px;margin:4px 0;\">Explanation & Notes</h2>\n    <pre id=\"explain\">Select an algorithm and parameters, then Generate Events. Use Step / Play to see allocations and frees over time. Use the custom script for advanced patterns (allocate/free/ref). The memory listing shows live allocations and a simple textual size bar. The estimator computes numeric sizes for chosen complexity.</pre>\n  </section>\n\n<script>\n(function(){\n  // Basic simulation engine\n  const state = {\n    params: {},\n    events: [], // each event: {desc, allocs:[{id,size,region,desc}], frees:[id], refs:[], unrefs:[], step}\n    live: {}, // id -> allocation {id, bytes, region, desc, refs:set}\n    timeline: [], // snapshot per step\n    step: 0,\n    peak: 0,\n    running: false,\n    interval: null,\n    scriptMode: false\n  };\n\n  // DOM refs\n  const elems = {\n    algo: document.getElementById('algo'),\n    lang: document.getElementById('langPreset'),\n    elemSize: document.getElementById('elemSize'),\n    ptrSize: document.getElementById('ptrSize'),\n    objOverhead: document.getElementById('objOverhead'),\n    nVal: document.getElementById('nVal'),\n    nSlider: document.getElementById('nSlider'),\n    countInput: document.getElementById('countInput'),\n    countStack: document.getElementById('countStack'),\n    countAux: document.getElementById('countAux'),\n    includePtrs: document.getElementById('includePtrs'),\n    simulateGC: document.getElementById('simulateGC'),\n    gcFreq: document.getElementById('gcFreq'),\n    generateBtn: document.getElementById('generateBtn'),\n    runBtn: document.getElementById('runBtn'),\n    stepBtn: document.getElementById('stepBtn'),\n    backBtn: document.getElementById('backBtn'),\n    playBtn: document.getElementById('playBtn'),\n    pauseBtn: document.getElementById('pauseBtn'),\n    resetBtn: document.getElementById('resetBtn'),\n    randomizeBtn: document.getElementById('randomizeBtn'),\n    speed: document.getElementById('speed'),\n    manualAllocBtn: document.getElementById('manualAllocBtn'),\n    manualFreeBtn: document.getElementById('manualFreeBtn'),\n    manualCount: document.getElementById('manualCount'),\n    manualRegion: document.getElementById('manualRegion'),\n    manualDesc: document.getElementById('manualDesc'),\n    scriptArea: document.getElementById('scriptArea'),\n    loadScriptBtn: document.getElementById('loadScriptBtn'),\n    runScriptBtn: document.getElementById('runScriptBtn'),\n    stepScriptBtn: document.getElementById('stepScriptBtn'),\n    allocList: document.getElementById('allocList'),\n    totalMem: document.getElementById('totalMem'),\n    heapMem: document.getElementById('heapMem'),\n    stackMem: document.getElementById('stackMem'),\n    auxMem: document.getElementById('auxMem'),\n    peakMem: document.getElementById('peakMem'),\n    eventsLog: document.getElementById('eventsLog'),\n    stepCounter: document.getElementById('stepCounter'),\n    maxStep: document.getElementById('maxStep'),\n    timelineSlider: document.getElementById('timelineSlider'),\n    inspectBtn: document.getElementById('inspectBtn'),\n    formulaSelect: document.getElementById('formulaSelect'),\n    customExpr: document.getElementById('customExpr'),\n    estimateBtn: document.getElementById('estimateBtn'),\n    estTable: document.getElementById('estTable'),\n    explain: document.getElementById('explain')\n  };\n\n  // Utilities\n  function clamp(v, a, b){ return Math.max(a, Math.min(b, v)); }\n  function bytesForElements(count) {\n    const el = parseInt(elems.elemSize.value,10) || 8;\n    return count * el;\n  }\n  function ptrBytes(count) {\n    return (parseInt(elems.ptrSize.value,10)||8) * count;\n  }\n  function objOverheadBytes(count) {\n    return (parseInt(elems.objOverhead.value,10)||0) * count;\n  }\n\n  function resetState(){\n    state.events = [];\n    state.live = {};\n    state.timeline = [];\n    state.step = 0;\n    state.peak = 0;\n    state.running = false;\n    clearInterval(state.interval);\n    state.interval = null;\n    state.scriptMode = false;\n    updateUI();\n  }\n\n  function pushEvent(ev){\n    ev.step = state.events.length;\n    state.events.push(ev);\n    elems.maxStep.textContent = state.events.length;\n    elems.timelineSlider.max = Math.max(0, state.events.length);\n    updateEventsLog();\n  }\n\n  function updateEventsLog(){\n    const lines = state.events.map((e,i)=> `${i}: ${e.desc} | allocs:${(e.allocs||[]).map(a=>a.id+'('+a.count+')').join(', ')} frees:${(e.frees||[]).join(', ')} refs:${(e.refs||[]).map(r=>r[0]+'->'+r[1]).join(',')}`);\n    elems.eventsLog.textContent = lines.join('\\n');\n    elems.maxStep.textContent = state.events.length;\n    elems.timelineSlider.max = Math.max(0, state.events.length);\n  }\n\n  function applyEvent(ev, forward=true){\n    // forward: apply allocations and refs; backward: reverse\n    if(forward){\n      if(ev.allocs) ev.allocs.forEach(a=>{\n        const id = a.id || ('A'+Math.random().toString(36).slice(2,8));\n        const count = a.count || 1;\n        const bytes = bytesForElements(count) + (elems.includePtrs.checked ? ptrBytes(a.ptrs||0) : 0) + objOverheadBytes(a.objects||0);\n        const region = a.region || 'heap';\n        state.live[id] = { id, bytes, region, desc: a.desc||('alloc '+id), count, refs: new Set(), createdStep: ev.step };\n      });\n      if(ev.calls) ev.calls.forEach(c=>{\n        const id = c.id || ('F'+Math.random().toString(36).slice(2,8));\n        const size = (c.size || 1);\n        const bytes = bytesForElements(size);\n        state.live[id] = { id, bytes, region: 'stack', desc: c.desc || 'frame '+id, count:size, refs: new Set(), createdStep: ev.step };\n      });\n      if(ev.frees) ev.frees.forEach(fid=>{\n        delete state.live[fid];\n      });\n      if(ev.refs) ev.refs.forEach(r=>{\n        const [src,dst] = r;\n        if(state.live[src]) state.live[src].refs.add(dst);\n      });\n      if(ev.unrefs) ev.unrefs.forEach(r=>{\n        const [src,dst] = r;\n        if(state.live[src]) state.live[src].refs.delete(dst);\n      });\n    } else {\n      // reverse: recreate from snapshot? Simpler: rebuild from scratch up to desired step outside.\n      rebuildUpToStep(ev.step - 1);\n    }\n    computeTotals();\n  }\n\n  function computeTotals(){\n    let total=0, heap=0, stack=0, aux=0;\n    Object.values(state.live).forEach(a=>{\n      total += a.bytes;\n      if(a.region === 'heap') heap += a.bytes;\n      else if(a.region === 'stack') stack += a.bytes;\n      else aux += a.bytes;\n    });\n    if(total > state.peak) state.peak = total;\n    elems.totalMem.textContent = total;\n    elems.heapMem.textContent = heap;\n    elems.stackMem.textContent = stack;\n    elems.auxMem.textContent = aux;\n    elems.peakMem.textContent = state.peak;\n    renderAllocList();\n  }\n\n  function renderAllocList(){\n    const lines = Object.values(state.live).map(a=>{\n      const bar = repeatChar('|', Math.min(60, Math.max(1, Math.floor(a.bytes/Math.max(1, Math.round((parseInt(elems.elemSize.value,10)||8)))))));\n      return `${a.id} [${a.region}] ${a.bytes} bytes ${a.desc} ${bar}`;\n    });\n    elems.allocList.textContent = lines.join('\\n') || '(no live allocations)';\n  }\n\n  function repeatChar(ch, n){ return new Array(n+1).join(ch); }\n\n  function rebuildUpToStep(step){\n    state.live = {};\n    for(let i=0;i<=step && i<state.events.length;i++){\n      const ev = state.events[i];\n      // apply without recursion (direct)\n      if(ev.allocs) ev.allocs.forEach(a=>{\n        const id = a.id || ('A'+Math.random().toString(36).slice(2,8));\n        const count = a.count || 1;\n        const bytes = bytesForElements(count) + (elems.includePtrs.checked ? ptrBytes(a.ptrs||0) : 0) + objOverheadBytes(a.objects||0);\n        const region = a.region || 'heap';\n        state.live[id] = { id, bytes, region, desc: a.desc||('alloc '+id), count, refs: new Set(), createdStep: ev.step };\n      });\n      if(ev.calls) ev.calls.forEach(c=>{\n        const id = c.id || ('F'+Math.random().toString(36).slice(2,8));\n        const size = (c.size || 1);\n        const bytes = bytesForElements(size);\n        state.live[id] = { id, bytes, region: 'stack', desc: c.desc || 'frame '+id, count:size, refs: new Set(), createdStep: ev.step };\n      });\n      if(ev.frees) ev.frees.forEach(fid=>{\n        delete state.live[fid];\n      });\n      if(ev.refs) ev.refs.forEach(r=>{\n        const [src,dst] = r;\n        if(state.live[src]) state.live[src].refs.add(dst);\n      });\n      if(ev.unrefs) ev.unrefs.forEach(r=>{\n        const [src,dst] = r;\n        if(state.live[src]) state.live[src].refs.delete(dst);\n      });\n    }\n    computeTotals();\n  }\n\n  // Algorithm event generators\n  function generateEventsForAlgorithm(algo){\n    state.events = [];\n    state.peak = 0;\n    const n = parseInt(elems.nVal.value,10) || 0;\n    const events = [];\n\n    function push(desc, opts){\n      const ev = Object.assign({desc}, opts || {});\n      pushEvent(ev);\n    }\n\n    // Common helper: allocate input array\n    if(algo === 'iterative_sum'){\n      if(elems.countInput.checked){\n        push(`allocate input array n=${n}`, {allocs:[{id:'INP', count:n, region:'heap', desc:'input array'}]});\n      }\n      push('init accumulator', {allocs:[{id:'acc', count:1, region:'stack', desc:'accumulator'}]});\n      // algorithm steps: iterate but constant extra\n      for(let i=0;i<Math.min(8, n);i++){\n        push(`iterate i=${i}`, {});\n      }\n      push('end, free stack', {frees:['acc']});\n    }\n\n    else if(algo === 'copy_array'){\n      if(elems.countInput.checked){\n        push(`allocate input array n=${n}`, {allocs:[{id:'INP', count:n, region:'heap', desc:'input array'}]});\n      }\n      push('allocate copy array', {allocs:[{id:'COPY', count:n, region:'heap', desc:'copy'}]});\n      push('use copy, then free copy', {frees:['COPY']});\n    }\n\n    else if(algo === 'merge_sort'){\n      if(elems.countInput.checked){\n        push(`allocate input array n=${n}`, {allocs:[{id:'INP', count:n, region:'heap', desc:'input array'}]});\n      }\n      // simulate recursive merges: allocate temp at each merge level, but overall O(n) extra\n      const levels = Math.max(1, Math.ceil(Math.log2(Math.max(1,n))));\n      for(let lvl=0; lvl<levels; lvl++){\n        push(`merge level ${lvl}`, {allocs:[{id:'TMP_L'+lvl, count: Math.ceil(n/Math.pow(2,lvl)), region:'aux', desc:'temp buffer'}]});\n        push(`free temp level ${lvl}`, {frees:['TMP_L'+lvl]});\n      }\n    }\n\n    else if(algo === 'quicksort_inplace'){\n      if(elems.countInput.checked){\n        push('allocate input array', {allocs:[{id:'INP', count:n, region:'heap', desc:'array'}]});\n      }\n      // push stack frames representing recursion, O(log n) average depth\n      const depth = Math.max(1, Math.floor(Math.log2(Math.max(1,n))));\n      for(let d=0; d<depth; d++){\n        push(`call depth ${d}`, {calls:[{id:'F'+d, size:1, desc:'stack frame'}]});\n      }\n      for(let d=depth-1; d>=0; d--){\n        push(`return depth ${d}`, {frees:[ 'F'+d ]});\n      }\n    }\n\n    else if(algo === 'quicksort_worst'){\n      if(elems.countInput.checked) push('allocate input array', {allocs:[{id:'INP', count:n, region:'heap', desc:'array'}]});\n      // worst-case stack depth ~ n\n      for(let d=0; d<Math.min(n,200); d++){\n        push(`call depth ${d}`, {calls:[{id:'F'+d, size:1, desc:'stack frame'}]});\n      }\n      for(let d=Math.min(n,200)-1; d>=0; d--){\n        push(`return depth ${d}`, {frees:[ 'F'+d ]});\n      }\n    }\n\n    else if(algo === 'naive_fib'){\n      if(elems.countInput.checked) push('no big input array for naive fib (counts n)', {});\n      // simulate exponential recursion by creating many short-lived frames\n      let counter = 0;\n      function fibSim(k){\n        const id = 'F'+(counter++);\n        push(`call fib(${k}) frame ${id}`, {calls:[{id:id, size:1, desc:'fib frame'}]});\n        if(k<=1){\n          push(`return fib(${k}) frame ${id}`, {frees:[id]});\n          return;\n        }\n        // left\n        fibSim(k-1);\n        // right\n        fibSim(k-2);\n        push(`return fib(${k}) frame ${id}`, {frees:[id]});\n      }\n      const depth = Math.min(10, n); // cap to avoid explosion\n      fibSim(depth);\n    }\n\n    else if(algo === 'binary_tree_rec'){\n      if(elems.countInput.checked){\n        // simulate tree with n nodes stored in heap\n        push(`allocate tree nodes n=${n}`, {allocs:[{id:'TREE', count:n, region:'heap', desc:'tree nodes', ptrs: n*2}]});\n      }\n      // recursion depth ~ log n if balanced\n      const depth = Math.max(1, Math.floor(Math.log2(Math.max(1,n))));\n      for(let d=0; d<depth; d++){\n        push(`call depth ${d}`, {calls:[{id:'F'+d, size:1, desc:'rec frame'}]});\n      }\n      for(let d=depth-1; d>=0; d--){\n        push(`return depth ${d}`, {frees:['F'+d]});\n      }\n    }\n\n    else if(algo === 'graph_dfs'){\n      if(elems.countInput.checked){\n        // adjacency list cost approx n + edges*ptrsize\n        const edges = Math.floor(n * 1.5);\n        push('allocate adjacency list', {allocs:[{id:'ADJ', count:n, region:'heap', desc:'adj-list nodes', ptrs: edges}]});\n      }\n      // DFS stack up to n\n      const depth = Math.min(n, 100);\n      for(let d=0; d<depth; d++){\n        push(`push node ${d}`, {calls:[{id:'S'+d, size:1, desc:'dfs stack frame'}]});\n      }\n      for(let d=depth-1; d>=0; d--){\n        push(`pop node ${d}`, {frees:['S'+d]});\n      }\n    }\n\n    else if(algo === 'dynamic_prog'){\n      // choose table size based on n: 1D or 2D depending on a toggle? We'll simulate both options\n      push('allocate dp table 1D', {allocs:[{id:'DP1', count:n, region:'heap', desc:'1D table'}]});\n      push('allocate dp table 2D', {allocs:[{id:'DP2', count: Math.min(1000,n*n), region:'heap', desc:'2D table (capped)'}]});\n      push('free 2D partial', {frees:['DP2']});\n    }\n\n    else if(algo === 'custom_script'){\n      // will be loaded from scriptArea when user presses Load Script\n      state.scriptMode = true;\n      // placeholder event\n      push('custom script loaded (use Load Script to populate timeline)', {});\n    }\n\n    // finished: update UI\n    computeTotals();\n    updateEventsLog();\n  }\n\n  // Playback controls\n  function stepForward(){\n    if(state.step >= state.events.length) return;\n    const ev = state.events[state.step];\n    applyEvent(ev, true);\n    state.step++;\n    elems.stepCounter.textContent = state.step;\n    elems.timelineSlider.value = state.step;\n  }\n\n  function stepBack(){\n    if(state.step <= 0) return;\n    state.step--;\n    rebuildUpToStep(state.step - 1);\n    elems.stepCounter.textContent = state.step;\n    elems.timelineSlider.value = state.step;\n  }\n\n  function play(){\n    if(state.running) return;\n    const ms = parseInt(elems.speed.value,10) || 400;\n    state.running = true;\n    state.interval = setInterval(()=>{\n      if(state.step >= state.events.length){\n        pause();\n        return;\n      }\n      stepForward();\n      // GC simulation\n      if(elems.simulateGC.checked){\n        const freq = parseInt(elems.gcFreq.value,10) || 8;\n        if(state.step % freq === 0){\n          runGC();\n        }\n      }\n    }, ms);\n  }\n\n  function pause(){\n    state.running = false;\n    clearInterval(state.interval);\n    state.interval = null;\n  }\n\n  function reset(){\n    pause();\n    resetState();\n    elems.eventsLog.textContent = '';\n    elems.allocList.textContent = '(no live allocations)';\n    elems.stepCounter.textContent = '0';\n    elems.timelineSlider.value = 0;\n  }\n\n  function runAll(){\n    // run to end in batch (non-play)\n    while(state.step < state.events.length){\n      stepForward();\n      if(elems.simulateGC.checked){\n        const freq = parseInt(elems.gcFreq.value,10) || 8;\n        if(state.step % freq === 0){\n          runGC();\n        }\n      }\n    }\n  }\n\n  // Manual allocation/free\n  let manualStack = [];\n  function manualAlloc(){\n    const count = parseInt(elems.manualCount.value,10) || 1;\n    const region = elems.manualRegion.value || 'heap';\n    const desc = elems.manualDesc.value || 'manual';\n    const id = 'M'+Math.random().toString(36).slice(2,8);\n    const ev = {desc:'manual alloc '+id, allocs:[{id:id, count:count, region:region, desc:desc}]};\n    pushEvent(ev);\n    // auto-apply\n    applyEvent(ev, true);\n    manualStack.push(id);\n    state.step = state.events.length;\n    elems.stepCounter.textContent = state.step;\n  }\n  function manualFreeLast(){\n    if(manualStack.length===0) return;\n    const id = manualStack.pop();\n    const ev = {desc:'manual free '+id, frees:[id]};\n    pushEvent(ev);\n    applyEvent(ev,true);\n    state.step = state.events.length;\n    elems.stepCounter.textContent = state.step;\n  }\n\n  // Garbage collector (very simple): mark from roots (items referenced by special root set: INP, or stack frames)\n  function runGC(){\n    // roots: all stack frames and special marked roots (INP)\n    const roots = new Set();\n    Object.values(state.live).forEach(a=>{\n      if(a.region === 'stack') roots.add(a.id);\n    });\n    if(state.live['INP']) roots.add('INP'); // treat input as root\n    // BFS mark\n    const marked = new Set();\n    const stack = [...roots];\n    while(stack.length){\n      const id = stack.pop();\n      if(marked.has(id)) continue;\n      marked.add(id);\n      const a = state.live[id];\n      if(a){\n        a.refs.forEach(r=>{\n          if(!marked.has(r)) stack.push(r);\n        });\n      }\n    }\n    // free unmarked heap/aux objects that are not roots\n    const toFree = Object.values(state.live).filter(a=>!marked.has(a.id) && (a.region === 'heap' || a.region === 'aux'));\n    if(toFree.length){\n      const frees = toFree.map(x=>x.id);\n      const ev = {desc:'GC freed '+frees.join(','), frees:frees};\n      pushEvent(ev);\n      applyEvent(ev,true);\n    }\n  }\n\n  // Script interpreter\n  function parseScript(text){\n    const lines = text.split('\\n').map(l=>l.trim()).filter(l=>l && !l.startsWith('#'));\n    const events = [];\n    let currentStep = {desc:'script start', allocs:[], frees:[], refs:[], unrefs:[], calls:[]};\n    function flush(){\n      if(currentStep && (currentStep.allocs.length || currentStep.frees.length || currentStep.refs.length || currentStep.calls.length || currentStep.unrefs.length || currentStep.desc)){\n        // clone\n        events.push(JSON.parse(JSON.stringify(currentStep)));\n        currentStep = {desc:'script step', allocs:[], frees:[], refs:[], unrefs:[], calls:[]};\n      }\n    }\n    for(let raw of lines){\n      const parts = raw.split(/\\s+/);\n      const cmd = parts[0].toUpperCase();\n      if(cmd === 'ALLOC'){\n        const id = parts[1] || ('S'+Math.random().toString(36).slice(2,6));\n        const region = parts[2] || 'heap';\n        const count = parseInt(parts[3],10) || 1;\n        currentStep.allocs.push({id:id, region:region, count:count, desc:'script\"});\n      } else if(cmd === 'FREE'){\n        const id = parts[1];\n        if(id) currentStep.frees.push(id);\n      } else if(cmd === 'CALL'){\n        const id = parts[1] || ('C'+Math.random().toString(36).slice(2,6));\n        const size = parseInt(parts[3],10) || 1;\n        currentStep.calls.push({id:id, size:size, desc:'frame'});\n      } else if(cmd === 'RETURN'){\n        const id = parts[1];\n        if(id) currentStep.frees.push(id);\n      } else if(cmd === 'REF'){\n        const s = parts[1], d = parts[2];\n        if(s && d) currentStep.refs.push([s,d]);\n      } else if(cmd === 'UNREF'){\n        const s = parts[1], d = parts[2];\n        if(s && d) currentStep.unrefs.push([s,d]);\n      } else if(cmd === 'WAIT'){\n        const k = parseInt(parts[1],10) || 1;\n        // flush current, then add k empty steps\n        flush();\n        for(let i=0;i<k;i++) events.push({desc:'wait', allocs:[], frees:[], refs:[], unrefs:[], calls:[]});\n        currentStep = {desc:'script step', allocs:[], frees:[], refs:[], unrefs:[], calls:[]};\n      } else {\n        // unknown, treat as note\n        currentStep.desc = raw;\n      }\n    }\n    flush();\n    return events;\n  }\n\n  // Load script into events\n  function loadScript(){\n    const txt = elems.scriptArea.value;\n    const evs = parseScript(txt);\n    state.events = evs;\n    state.step = 0;\n    state.live = {};\n    state.peak = 0;\n    updateEventsLog();\n    elems.stepCounter.textContent = state.step;\n    elems.timelineSlider.value = state.step;\n  }\n\n  function runScript(){\n    loadScript();\n    play();\n  }\n\n  function stepScript(){\n    if(state.events.length === 0) loadScript();\n    stepForward();\n  }\n\n  // Estimator\n  function estimate(){\n    const formula = elems.formulaSelect.value;\n    const out = [];\n    out.push('n\\testimated bytes');\n    for(let n=1; n<=Math.min(200, Math.max(10, parseInt(elems.nVal.value,10)||10)); n+= Math.max(1, Math.floor((Math.max(10, parseInt(elems.nVal.value,10)||10))/20))){\n      let val = 0;\n      if(formula === 'Custom'){\n        try {\n          const fn = new Function('n', 'return '+elems.customExpr.value+';');\n          val = Number(fn(n));\n        } catch(e){\n          val = NaN;\n        }\n      } else {\n        if(formula === 'O(1)') val = 64;\n        if(formula === 'O(log n)') val = Math.ceil(Math.log2(n+1))*8 + 16;\n        if(formula === 'O(n)') val = n * (parseInt(elems.elemSize.value,10)||8);\n        if(formula === 'O(n log n)') val = n * Math.ceil(Math.log2(n+1)) * (parseInt(elems.elemSize.value,10)||8);\n        if(formula === 'O(n^2)') val = n*n*(parseInt(elems.elemSize.value,10)||1);\n      }\n      out.push(`${n}\\t${Math.round(val)}`);\n    }\n    elems.estTable.textContent = out.join('\\n');\n  }\n\n  // UI wiring\n  elems.nSlider.addEventListener('input', ()=>{ elems.nVal.value = elems.nSlider.value; });\n  elems.nVal.addEventListener('input', ()=>{ elems.nSlider.value = elems.nVal.value; });\n\n  elems.generateBtn.addEventListener('click', ()=>{ resetState(); generateEventsForAlgorithm(elems.algo.value); });\n  elems.stepBtn.addEventListener('click', ()=>{ stepForward(); });\n  elems.backBtn.addEventListener('click', ()=>{ stepBack(); });\n  elems.playBtn.addEventListener('click', ()=>{ play(); });\n  elems.pauseBtn.addEventListener('click', ()=>{ pause(); });\n  elems.resetBtn.addEventListener('click', ()=>{ reset(); });\n  elems.runBtn.addEventListener('click', ()=>{ runAll(); });\n  elems.randomizeBtn.addEventListener('click', ()=>{\n    elems.nVal.value = Math.floor(Math.random()*120)+1;\n    elems.nSlider.value = elems.nVal.value;\n    elems.elemSize.value = [4,8,16][Math.floor(Math.random()*3)];\n    elems.ptrSize.value = [4,8][Math.floor(Math.random()*2)];\n    elems.objOverhead.value = [8,12,16][Math.floor(Math.random()*3)];\n  });\n\n  elems.manualAllocBtn.addEventListener('click', manualAlloc);\n  elems.manualFreeBtn.addEventListener('click', manualFreeLast);\n\n  elems.loadScriptBtn.addEventListener('click', loadScript);\n  elems.runScriptBtn.addEventListener('click', runScript);\n  elems.stepScriptBtn.addEventListener('click', stepScript);\n\n  elems.inspectBtn.addEventListener('click', ()=>{\n    const s = parseInt(elems.timelineSlider.value,10) || 0;\n    rebuildUpToStep(s-1);\n    state.step = s;\n    elems.stepCounter.textContent = state.step;\n    elems.timelineSlider.value = state.step;\n  });\n\n  elems.timelineSlider.addEventListener('input', ()=>{\n    const s = parseInt(elems.timelineSlider.value,10) || 0;\n    rebuildUpToStep(s-1);\n    state.step = s;\n    elems.stepCounter.textContent = state.step;\n  });\n\n  elems.estimateBtn.addEventListener('click', estimate);\n\n  // initial reset\n  resetState();\n\n  // populate initial algorithm events\n  generateEventsForAlgorithm(elems.algo.value);\n\n  elems.algo.addEventListener('change', ()=>{ resetState(); generateEventsForAlgorithm(elems.algo.value); });\n\n  // expose some debug functions to window for power users (console)\n  window.SpaceSim = {\n    state, applyEvent, rebuildUpToStep, runGC, pushEvent, parseScript\n  };\n\n  // Final update UI\n  updateEventsLog();\n  computeTotals();\n\n})();\n</script>\n</body>\n</html>"
