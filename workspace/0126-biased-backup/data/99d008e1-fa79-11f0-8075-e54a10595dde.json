    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Virtual Memory Simulation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .control {\n            margin: 10px 0;\n        }\n    </style>\n</head>\n<body>\n    <h1>Virtual Memory Simulation</h1>\n    <div class=\"control\">\n        <label for=\"totalPages\">Total Pages (in virtual memory): </label>\n        <input type=\"number\" id=\"totalPages\" value=\"5\" min=\"1\" />\n    </div>\n    <div class=\"control\">\n        <label for=\"pageSize\">Page Size (in KB): </label>\n        <input type=\"number\" id=\"pageSize\" value=\"4\" min=\"1\" />\n    </div>\n    <div class=\"control\">\n        <label for=\"processSize\">Process Size (in KB): </label>\n        <input type=\"number\" id=\"processSize\" value=\"12\" min=\"1\" />\n    </div>\n    <button id=\"calculate\">Calculate Virtual Memory Usage</button>\n    <button id=\"reset\">Reset</button>\n\n    <h2>Virtual Memory Usage</h2>\n    <div id=\"memoryOutput\"></div>\n\n    <div class=\"control\">\n        <button id=\"addPage\">Add Page to Process</button>\n        <button id=\"removePage\">Remove Page from Process</button>\n    </div>\n    <h3>Current Page Table</h3>\n    <div id=\"pageTable\"></div>\n\n    <script>\n        let totalPages = 5;\n        let pageSize = 4; // in KB\n        let processSize = 12; // in KB\n        let pagesInProcess = 0;\n\n        function updateMemoryOutput() {\n            const totalMemory = totalPages * pageSize;\n            const inUseMemory = pagesInProcess * pageSize;\n            document.getElementById(\"memoryOutput\").innerText = `Total Memory: ${totalMemory} KB, In Use: ${inUseMemory} KB`;\n        }\n\n        function updatePageTable() {\n            const pageTable = [];\n            for (let i = 0; i < pagesInProcess; i++) {\n                pageTable.push(`Page ${i + 1}`);\n            }\n            document.getElementById(\"pageTable\").innerText = pageTable.join(', ') || 'No pages allocated';\n        }\n\n        document.getElementById(\"calculate\").addEventListener(\"click\", function() {\n            totalPages = parseInt(document.getElementById(\"totalPages\").value);\n            pageSize = parseInt(document.getElementById(\"pageSize\").value);\n            processSize = parseInt(document.getElementById(\"processSize\").value);\n            pagesInProcess = Math.ceil(processSize / pageSize);\n            if (pagesInProcess > totalPages) {\n                alert(\"Error: Process uses more pages than total available in memory!\");\n                pagesInProcess = totalPages; // Limit to total pages\n            }\n            updateMemoryOutput();\n            updatePageTable();\n        });\n\n        document.getElementById(\"reset\").addEventListener(\"click\", function() {\n            document.getElementById(\"totalPages\").value = 5;\n            document.getElementById(\"pageSize\").value = 4;\n            document.getElementById(\"processSize\").value = 12;\n            pagesInProcess = 0;\n            updateMemoryOutput();\n            updatePageTable();\n        });\n\n        document.getElementById(\"addPage\").addEventListener(\"click\", function() {\n            if (pagesInProcess < totalPages) {\n                pagesInProcess++;\n                updateMemoryOutput();\n                updatePageTable();\n            } else {\n                alert(\"Cannot add more pages - limit reached!\");\n            }\n        });\n\n        document.getElementById(\"removePage\").addEventListener(\"click\", function() {\n            if (pagesInProcess > 0) {\n                pagesInProcess--;\n                updateMemoryOutput();\n                updatePageTable();\n            } else {\n                alert(\"No more pages to remove!\");\n            }\n        });\n\n        // Initialize default memory output on load\n        updateMemoryOutput();\n        updatePageTable();\n    </script>\n</body>\n</html>"
