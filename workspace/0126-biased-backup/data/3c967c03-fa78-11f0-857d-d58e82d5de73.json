    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Trie Data Structure – Visual Journey</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  :root {\n    --bg-dark: #110a1f;\n    --shade-dark: #1a142e;\n    --shade-medium: #392f58;\n    --shade-light: #7a6cc6;\n    --accent-primary: #ff6b6b;\n    --accent-secondary: #6c5ce7;\n    --text-light: #eeeafc;\n    --text-muted: #bbb8d0;\n    --node-glow: #ae7cfa;\n    --highlight-node: #ff8fa3;\n    --shadow-glow: rgba(174, 124, 250, 0.6);\n    --transition-fast: 0.35s cubic-bezier(0.4, 0, 0.2, 1);\n    --transition-smooth: 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  /* Reset & Base */\n  *,\n  *::before,\n  *::after {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, var(--bg-dark), var(--shade-dark));\n    font-family: 'Poppins', sans-serif;\n    color: var(--text-light);\n    overflow-x: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2rem 1rem 4rem;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.6rem;\n    letter-spacing: 0.1em;\n    color: var(--accent-primary);\n    margin: 0 0 0.5rem 0;\n    text-transform: uppercase;\n    text-shadow:\n      0 0 6px var(--accent-primary),\n      0 0 12px var(--accent-primary),\n      0 0 24px var(--accent-primary);\n  }\n  h2 {\n    font-weight: 300;\n    font-size: 1.4rem;\n    letter-spacing: 0.06em;\n    color: var(--shade-light);\n    margin: 0 0 2.5rem 0;\n    font-style: italic;\n    user-select: none;\n  }\n\n  main {\n    flex: 1 0 auto;\n    max-width: 960px;\n    width: 100%;\n    background: radial-gradient(circle at top center, var(--shade-dark) 0%, var(--bg-dark) 95%);\n    border-radius: 30px;\n    box-shadow:\n      0 4px 30px var(--shadow-glow),\n      inset 0 0 12px var(--node-glow);\n    padding: 3rem 3.5rem 4rem;\n    overflow-x: auto;\n  }\n\n  /* Canvas Container */\n  #trie-container {\n    position: relative;\n    width: 100%;\n    height: 480px;\n    background:\n      radial-gradient(circle at 50% 50%, transparent 30%, var(--shade-dark) 90%);\n    border-radius: 20px;\n    box-shadow:\n      0 0 30px var(--node-glow),\n      inset 0 0 25px var(--shade-light);\n    overflow: visible;\n  }\n\n  svg {\n    width: 100%;\n    height: 100%;\n    overflow: visible;\n  }\n\n  /* Node Style */\n  .node-group {\n    cursor: default;\n    transition: transform var(--transition-fast);\n  }\n  .node-circle {\n    fill: var(--shade-light);\n    stroke: var(--accent-secondary);\n    stroke-width: 2.4;\n    filter: drop-shadow(0 0 3px var(--accent-secondary));\n    transform-origin: center center;\n    transition: fill 0.4s ease, stroke-width 0.3s ease;\n  }\n\n  .node-text {\n    font-weight: 600;\n    font-size: 1.2rem;\n    fill: var(--text-light);\n    user-select: none;\n    pointer-events: none;\n    font-feature-settings: 'liga' off;\n  }\n\n  /* Highlight root nodes distinctly */\n  .node-root .node-circle {\n    fill: var(--accent-primary);\n    stroke: var(--accent-primary);\n    filter: drop-shadow(0 0 6px var(--accent-primary));\n  }\n\n  /* Highlight leaf nodes distinctly */\n  .node-leaf .node-circle {\n    fill: var(--accent-secondary);\n    stroke: var(--shade-light);\n    filter: drop-shadow(0 0 5px var(--shade-light));\n  }\n\n  /* Connections */\n  .link {\n    stroke: var(--shade-light);\n    stroke-width: 2;\n    filter: drop-shadow(0 0 3px var(--shade-light));\n    fill: none;\n    opacity: 0.85;\n    transition: stroke var(--transition-fast);\n  }\n\n  /* Buttons Bar */\n  #controls {\n    margin: 3rem 0 0 0;\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n  }\n  button {\n    font-family: 'Poppins', sans-serif;\n    font-weight: 600;\n    font-size: 1.1rem;\n    padding: 0.72rem 1.8rem;\n    border-radius: 35px;\n    border: none;\n    cursor: pointer;\n    color: var(--text-light);\n    background: var(--accent-primary);\n    box-shadow:\n      0 6px 15px var(--accent-primary);\n    transition:\n      background var(--transition-fast),\n      box-shadow var(--transition-fast),\n      transform var(--transition-fast);\n    user-select: none;\n  }\n  button:hover, button:focus {\n    background: var(--accent-secondary);\n    box-shadow:\n      0 8px 20px var(--accent-secondary);\n    outline: none;\n    transform: scale(1.06);\n  }\n  button:active {\n    transform: scale(0.97);\n  }\n\n\n  /* Tooltip */\n  #tooltip {\n    position: fixed;\n    pointer-events: none;\n    background: rgba(50, 40, 70, 0.85);\n    color: var(--text-light);\n    padding: 0.32rem 0.65rem;\n    font-size: 0.85rem;\n    border-radius: 10px;\n    font-weight: 500;\n    letter-spacing: 0.03em;\n    opacity: 0;\n    transition: opacity 0.4s ease;\n    user-select: none;\n    z-index: 1000;\n    white-space: nowrap;\n  }\n</style>\n</head>\n<body>\n  <h1>TRIE</h1>\n  <h2>Prefix Tree Visualization – Elegant & Illuminated</h2>\n  <main>\n    <div id=\"trie-container\" aria-label=\"Trie Data Structure Visualization\" role=\"img\"></div>\n  </main>\n  <div id=\"controls\" aria-label=\"Controls for Trie Visualization\">\n    <button id=\"toggleAnimation\" aria-pressed=\"false\" aria-controls=\"trie-container\">Toggle Animation</button>\n    <button id=\"highlightLeaves\" aria-pressed=\"false\" aria-controls=\"trie-container\">Highlight Leaves</button>\n  </div>\n  <div id=\"tooltip\" role=\"tooltip\" aria-hidden=\"true\"></div>\n\n<script>\n// Data for Trie demo - a simple handwritten insertion of \"TRIE\", \"TRY\", \"TRICK\", \"CAT\", \"CAR\", \"CARE\"\nconst trieData = {\n  c: {\n    a: {\n      r: {\n        e: { _end: true },\n        _end: true,\n      },\n      _end: true,\n    }\n  },\n  t: {\n    r: {\n      i: {\n        e: { _end: true },\n        c: {\n          k: { _end: true }\n        }\n      },\n      y: { _end: true }\n    }\n  }\n};\n\n// Visualization constants\nconst nodeRadius = 26;\nconst verticalSpacing = 90;\nconst horizontalSpacing = 130;\n\nconst container = document.getElementById('trie-container');\nconst tooltip = document.getElementById('tooltip');\nconst toggleAnimationBtn = document.getElementById('toggleAnimation');\nconst highlightLeavesBtn = document.getElementById('highlightLeaves');\n\nlet animationActive = true;\nlet leavesHighlighted = false;\n\n// Create SVG Element\nconst SVG_NS = \"http://www.w3.org/2000/svg\";\nconst svg = document.createElementNS(SVG_NS, 'svg');\nsvg.setAttribute('aria-hidden', 'true');\ncontainer.appendChild(svg);\n\n// Utility: Clean text label (uppercase)\nfunction cleanLabel(str){\n  return str.toUpperCase();\n}\n\n// Store dynamically created nodes and links for animation\nconst allNodes = [];\nconst allLinks = [];\n\n// Positioning & drawing logic:\n\n/**\n * Recursively parses trie object, lays out nodes horizontally,\n * returns x and y positions for each node,\n * draws circle/text for each character, and connects edges.\n * @param {Object} node - current trie node object\n * @param {number} depth - depth in trie (root = 0)\n * @param {number} xStart - horizontal position start for this group\n * @param {number} yStart - vertical position (depends on depth)\n * @returns {Object} {size, centerX} where size is total width used by subtree\n */\nfunction layoutTrie(node, depth=0, xStart=0, yStart=0) {\n  const keys = Object.keys(node).filter(k => k !== '_end').sort();\n\n  // If no children, leaf node: render node only\n  if (keys.length === 0) {\n    // Draw leaf node at xStart,yStart\n    drawNode(xStart, yStart, '_', depth === 0, true);\n    return { size: horizontalSpacing, centerX: xStart };\n  }\n\n  // Recursively layout children horizontally, then draw parent above center\n  let subtreeWidth = 0;\n  let childCenters = [];\n\n  for (const k of keys) {\n    const result = layoutTrie(node[k], depth + 1, xStart + subtreeWidth, yStart + verticalSpacing);\n    childCenters.push({char: k, x: result.centerX, y: yStart + verticalSpacing, nodeObj: node[k]});\n    subtreeWidth += result.size;\n  }\n\n  // Center parent node above children\n  const centerX = xStart + subtreeWidth / 2;\n\n  // Draw parent node with char label (for root no char, use \"\")\n  // For root at depth=0 we don't have a char because data object has multiple keys directly (like \"c\",\"t\")\n  // But our function is called for each child of root individually so char is passed up top?\n  // We must make an adapter function to call layoutTrie for each root child:\n\n  // Since we don't have parent's char here, return the center position for this subtree. Parent node drawn in the caller.\n\n  return { size: subtreeWidth, centerX: centerX, childCenters: childCenters };\n}\n\n/**\n * Draw edges (Bezier curves) between parent and children nodes.\n * @param {Array} childCenters - array of objects {char,x,y,nodeObj} of children\n * @param {number} parentX - X coordinate of parent node\n * @param {number} parentY - Y coordinate of parent node\n */\nfunction drawLinks(childCenters, parentX, parentY) {\n  for (const ch of childCenters) {\n    const link = document.createElementNS(SVG_NS, 'path');\n    // Cubic bezier curve from parent down to child with smooth curve\n    const startX = parentX;\n    const startY = parentY + nodeRadius * 0.9;\n    const endX = ch.x;\n    const endY = ch.y - nodeRadius * 0.9;\n\n    // Control points for smooth monotone curve\n    const controlY1 = startY + (endY - startY) / 2;\n    const controlY2 = controlY1;\n\n    const d = `\n      M${startX},${startY}\n      C${startX},${controlY1} ${endX},${controlY2} ${endX},${endY}\n    `;\n\n    link.setAttribute('d', d);\n    link.setAttribute('class', 'link');\n    svg.appendChild(link);\n    allLinks.push(link);\n  }\n}\n\n/**\n * Draw single node circle + label.\n * @param {number} x - X coordinate center\n * @param {number} y - Y coordinate center\n * @param {string} char - character to display\n * @param {boolean} isRoot - if this node is root of trie or branch root\n * @param {boolean} isLeaf - if this node is leaf\n */\nfunction drawNode(x, y, char, isRoot = false, isLeaf = false) {\n  const group = document.createElementNS(SVG_NS, 'g');\n  group.setAttribute('transform', `translate(${x},${y})`);\n  group.setAttribute('class', 'node-group');\n  group.setAttribute('role', 'listitem');\n  group.setAttribute('tabindex', '-1');\n\n  // Circle\n  const circle = document.createElementNS(SVG_NS, 'circle');\n  circle.setAttribute('r', nodeRadius);\n  circle.setAttribute('class', 'node-circle');\n  if (isRoot) circle.classList.add('node-root');\n  if (isLeaf) circle.classList.add('node-leaf');\n  group.appendChild(circle);\n\n  // Text\n  const text = document.createElementNS(SVG_NS, 'text');\n  text.setAttribute('class', 'node-text');\n  text.setAttribute('text-anchor', 'middle');\n  text.setAttribute('dy', '0.38em'); // optical centering vertically\n  text.textContent = char.toUpperCase();\n  group.appendChild(text);\n\n  svg.appendChild(group);\n  allNodes.push({group, circle, text, isLeaf, isRoot, char, x, y});\n\n  // Tooltip hover\n  group.addEventListener('mouseenter', (e) => {\n    showTooltip(`${char.toUpperCase()} node`, e.clientX, e.clientY);\n    if (animationActive) {\n      group.style.transform = 'scale(1.2)';\n      circle.style.fill = 'var(--highlight-node)';\n      circle.style.strokeWidth = '3.3';\n    }\n  });\n  group.addEventListener('mouseleave', () => {\n    hideTooltip();\n    if (animationActive) {\n      group.style.transform = 'scale(1)';\n      circle.style.fill = isRoot ? getComputedStyle(circle).getPropertyValue('--accent-primary') : isLeaf ? getComputedStyle(circle).getPropertyValue('--accent-secondary') : '';\n      circle.style.strokeWidth = '2.4';\n    }\n  });\n}\n\n/**\n * Show tooltip near cursor\n * @param {string} text - text to show\n * @param {number} x - cursor x\n * @param {number} y - cursor y\n */\nfunction showTooltip(text, x, y) {\n  tooltip.textContent = text;\n  tooltip.style.opacity = '1';\n  tooltip.style.left = (x + 14) + 'px';\n  tooltip.style.top = (y + 14) + 'px';\n  tooltip.setAttribute('aria-hidden', 'false');\n}\n/**\n * Hide tooltip\n */\nfunction hideTooltip() {\n  tooltip.style.opacity = '0';\n  tooltip.setAttribute('aria-hidden', 'true');\n}\n\n// Build full layout recursively – returns layout info for each root child\nfunction buildFullLayout(data, startX=0, y=60){\n  const keys = Object.keys(data).filter(k => k !== '_end').sort();\n\n  let totalWidth = 0;\n  // We'll compute each top-level branch's width, starting spread horizontally with gaps.\n  const branches = [];\n\n  // First pass to get children's layout sizes and positions\n  for (const k of keys) {\n    // recursive layout of subtree\n    const res = layoutTrie(data[k], 1, totalWidth, y + verticalSpacing);\n    // res contains {size, centerX, childCenters}\n    const branch = {\n      char: k,\n      childrenLayout: res.childCenters,\n      centerX: totalWidth + res.size / 2,\n      width: res.size,\n      nodeData: data[k]\n    };\n    branches.push(branch);\n    totalWidth += res.size;\n  }\n\n  // Now draw root nodes for each top-level key at y\n  for (const br of branches) {\n    // Draw root node\n    drawNode(br.centerX, y, br.char, true, false);\n    // Draw links & children nodes\n    drawLinks(br.childrenLayout, br.centerX, y);\n    // Draw children nodes recursively\n    drawNodesRecursive(br.nodeData, br.centerX, y + verticalSpacing);\n  }\n}\n\n/**\n * Recursively draw nodes below a parent node (except root nodes already drawn)\n * @param {Object} node - current trie node\n * @param {number} parentX - x coordinate of parent\n * @param {number} parentY - y coordinate of parent\n */\nfunction drawNodesRecursive(node, parentX, parentY) {\n  const keys = Object.keys(node).filter(k => k !== '_end').sort();\n\n  if (keys.length === 0) return;\n\n  for (const k of keys) {\n    // For each child, we need to know its pre-calculated centerX from layoutTrie\n    // But we didn't store it. We'll compute layout again but just for positioning.\n\n    // Using layoutTrie again to find position of child:\n    const layoutRes = layoutTrie(node, 0, 0, 0);\n    // Find child's centerX:\n    const childCenters = layoutRes.childCenters;\n    if (!childCenters) continue;\n\n    const child = childCenters.find(c => c.char === k);\n    if (!child) continue;\n\n    const isLeaf = (Object.keys(node[k]).filter(x => x !== '_end').length === 0);\n    drawNode(child.x, child.y, k, false, isLeaf);\n\n    // Draw links between parent and child\n    drawLinks([{char:k, x:child.x, y:child.y, nodeObj:node[k]}], parentX, parentY);\n\n    // Recursive for child's children\n    drawNodesRecursive(node[k], child.x, child.y);\n    // Avoid double drawing links for the same parent-child as drawLinks called twice? Refactored above calls drawLinks only for current children not recursively.\n  }\n}\n\n/**\n * Animate glowing nodes in sequence in a subtle loop\n */\nlet animationInterval = null;\nfunction startAnimation() {\n  let idx = 0;\n  animationInterval = setInterval(() => {\n    allNodes.forEach((n,i) => {\n      const intensity = (i === idx) ? 1 : 0.2;\n      n.circle.style.filter = `drop-shadow(0 0 ${6 * intensity}px var(--accent-secondary)) drop-shadow(0 0 ${14 * intensity}px var(--accent-primary))`;\n      n.circle.style.transition = 'filter 0.6s ease';\n      n.text.style.opacity = 0.8 + 0.2 * intensity;\n      n.group.style.transform = `scale(${1 + 0.07 * intensity})`;\n      n.group.style.transition = 'transform 0.6s ease';\n    });\n    idx = (idx + 1) % allNodes.length;\n  }, 1300);\n}\n\nfunction stopAnimation() {\n  clearInterval(animationInterval);\n  allNodes.forEach(n => {\n    n.circle.style.filter = '';\n    n.text.style.opacity = 1;\n    n.group.style.transform = 'scale(1)';\n  });\n}\n\n// Highlight leaf nodes style toggle\nfunction toggleLeavesHighlight() {\n  leavesHighlighted = !leavesHighlighted;\n  allNodes.forEach(n => {\n    if (n.isLeaf) {\n      if (leavesHighlighted) {\n        n.circle.style.fill = 'var(--accent-primary)';\n        n.circle.style.stroke = 'var(--accent-primary)';\n        n.circle.style.filter = 'drop-shadow(0 0 10px var(--accent-primary))';\n      } else {\n        n.circle.style.fill = 'var(--accent-secondary)';\n        n.circle.style.stroke = 'var(--shade-light)';\n        n.circle.style.filter = 'drop-shadow(0 0 5px var(--shade-light))';\n      }\n    }\n  });\n}\n\n// Clear SVG content and redraw entire trie\nfunction resetTrie() {\n  svg.innerHTML = '';\n  allLinks.length = 0;\n  allNodes.length = 0;\n  buildFullLayout(trieData);\n  if (animationActive) startAnimation();\n}\n// Init\nresetTrie();\n\n// Button toggles:\n\ntoggleAnimationBtn.addEventListener('click', () => {\n  animationActive = !animationActive;\n  toggleAnimationBtn.setAttribute('aria-pressed', animationActive.toString());\n  toggleAnimationBtn.textContent = animationActive ? 'Pause Animation' : 'Play Animation';\n  if (animationActive) {\n    startAnimation();\n  } else {\n    stopAnimation();\n  }\n});\n\nhighlightLeavesBtn.addEventListener('click', () => {\n  leavesHighlighted = !leavesHighlighted;\n  highlightLeavesBtn.setAttribute('aria-pressed', leavesHighlighted.toString());\n  highlightLeavesBtn.textContent = leavesHighlighted ? 'Unhighlight Leaves' : 'Highlight Leaves';\n  toggleLeavesHighlight();\n});\n\n// Accessibility & Keyboard hints\ntoggleAnimationBtn.title = \"Toggle node glow animation on/off\";\nhighlightLeavesBtn.title = \"Toggle highlight on leaf nodes\";\n\n// On window resize, no dynamic reposition required as SVG is fixed size & absolutely positioned\n\n// Tooltip position update on mouse move\ndocument.addEventListener('mousemove', (e) => {\n  if (tooltip.style.opacity === '1') {\n    const offsetX = 14;\n    const offsetY = 14;\n    let left = e.clientX + offsetX;\n    let top = e.clientY + offsetY;\n\n    // Keep inside viewport horizontally\n    if (left + tooltip.offsetWidth > window.innerWidth) {\n      left = e.clientX - tooltip.offsetWidth - offsetX;\n    }\n    // Keep inside viewport vertically\n    if (top + tooltip.offsetHeight > window.innerHeight) {\n      top = e.clientY - tooltip.offsetHeight - offsetY;\n    }\n    tooltip.style.left = left + 'px';\n    tooltip.style.top = top + 'px';\n  }\n});\n\n</script>\n</body>\n</html>"
