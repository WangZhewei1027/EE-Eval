    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Amortized Analysis Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #f4f4f9;\n            color: #333;\n            margin: 0;\n            padding: 0;\n            overflow: hidden;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            transition: background-color 0.3s ease;\n        }\n\n        h1 {\n            font-size: 3rem;\n            color: #4a90e2;\n            margin-bottom: 20px;\n            text-align: center;\n        }\n\n        .container {\n            position: relative;\n            width: 80%;\n            max-width: 700px;\n            border-radius: 15px;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n            background: linear-gradient(135deg, #eaeaea 0%, #f4f4f9 100%);\n            animation: fadeIn 2s ease;\n        }\n\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n            }\n            to {\n                opacity: 1;\n            }\n        }\n\n        .chart {\n            width: 100%;\n            height: 300px;\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            margin: 20px 0;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .bar {\n            width: 30px;\n            height: 0;\n            background-color: #4a90e2;\n            margin: 0 5px;\n            transition: height 0.5s ease, transform 0.5s ease;\n        }\n\n        .footer {\n            text-align: center;\n            padding: 20px 0;\n            font-size: 1rem;\n            color: #666;\n        }\n\n        .button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4a90e2;\n            color: white;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n        }\n\n        .button:hover {\n            background-color: #357ab7;\n        }\n\n        .hidden {\n            display: none;\n        }\n\n        .animated-text {\n            opacity: 0;\n            transition: opacity 1s ease;\n        }\n\n        .visible {\n            opacity: 1;\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <h1>Amortized Analysis</h1>\n        <div class=\"chart\" id=\"chart\">\n            <div class=\"bar\" style=\"height: 50%;\"></div>\n            <div class=\"bar\" style=\"height: 70%;\"></div>\n            <div class=\"bar\" style=\"height: 40%;\"></div>\n            <div class=\"bar\" style=\"height: 90%;\"></div>\n            <div class=\"bar\" style=\"height: 60%;\"></div>\n        </div>\n        <button class=\"button\" id=\"showTextButton\">Show Explanation</button>\n        <div class=\"footer\">\n            <p class=\"animated-text hidden\" id=\"explanation\">Amortized Analysis helps us study the\n                efficiency of an algorithm across multiple operations. By averaging out the time complexity\n                over a sequence of operations, it offers a more holistic view of performance.</p>\n        </div>\n    </div>\n\n    <script>\n        document.getElementById(\"showTextButton\").onclick = function() {\n            const explanation = document.getElementById(\"explanation\");\n            explanation.classList.toggle(\"visible\");\n            explanation.classList.toggle(\"hidden\");\n\n            // Animate bars\n            const bars = document.querySelectorAll(\".bar\");\n            bars.forEach((bar, index) => {\n                setTimeout(() => {\n                    bar.style.height = (Math.random() * 100) + '%';\n                    bar.style.transform = 'translateY(0)';\n                }, index * 100);\n            });\n        };\n    </script>\n</body>\n\n</html>"
