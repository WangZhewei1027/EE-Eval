  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Bucket Sort Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea {\n    width: 100%;\n    height: 5em;\n  }\n  button, input, select {\n    font: inherit;\n    margin: 0.2em 0.5em 0.2em 0;\n  }\n  fieldset {\n    margin-top: 1em;\n    padding: 0.5em;\n  }\n  legend {\n    font-weight: bold;\n  }\n  pre {\n    border: 1px solid black;\n    padding: 0.5em;\n    max-height: 12em;\n    overflow-y: auto;\n    white-space: pre-wrap;\n    word-wrap: break-word;\n  }\n  label {\n    user-select: none;\n  }\n  #bucketContainer {\n    margin-top: 1em;\n    border-top: 1px solid black;\n    padding-top: 1em;\n    max-height: 14em;\n    overflow-y: auto;\n  }\n  .bucket {\n    white-space: nowrap;\n    margin-bottom: 0.3em;\n    font-size: 0.9em;\n  }\n  .highlight {\n    font-weight: bold;\n    text-decoration: underline;\n  }\n  .controls-row {\n    margin-bottom: 0.5em;\n  }\n</style>\n</head>\n<body>\n<h1>Bucket Sort Interactive Demo</h1>\n\n<section id=\"inputSection\">\n  <label for=\"inputArray\">Enter array of numbers (comma or space separated):</label><br/>\n  <textarea id=\"inputArray\" aria-label=\"Array input\" placeholder=\"Example: 4, 2, 1, 5, 3\"></textarea><br/>\n\n  <label for=\"numBucketsInput\">Number of buckets (integer ≥1):</label>\n  <input type=\"number\" id=\"numBucketsInput\" min=\"1\" step=\"1\" value=\"5\" aria-label=\"Number of buckets\" />\n  \n  <button id=\"btnInitialize\">Initialize Sort</button>\n  <button id=\"btnReset\" disabled>Reset</button>\n</section>\n\n<form id=\"controlsForm\" style=\"margin-top:1em; display:none;\" aria-label=\"Bucket Sort controls\">\n  <fieldset>\n    <legend>Sort Controls</legend>\n    <div class=\"controls-row\">\n      <button id=\"btnStep\" type=\"button\" disabled>Step</button>\n      <button id=\"btnAuto\" type=\"button\" disabled>Start Auto Sort</button>\n      <button id=\"btnPause\" type=\"button\" disabled>Pause Auto</button>\n      <button id=\"btnFastForward\" type=\"button\" disabled>Fast Forward</button>\n      <button id=\"btnBackStep\" type=\"button\" disabled>Back Step</button>\n      <button id=\"btnResetStep\" type=\"button\" disabled>Reset Steps</button>\n    </div>\n\n    <label for=\"autoDelayRange\">Auto Step Delay (ms): </label>\n    <input type=\"range\" id=\"autoDelayRange\" min=\"50\" max=\"2000\" step=\"50\" value=\"500\" />\n    <span id=\"autoDelayValue\">500</span> ms\n  </fieldset>\n\n  <fieldset>\n    <legend>Bucket & Sorting Options</legend>\n    <label for=\"bucketSortType\">Sort algorithm inside buckets:</label>\n    <select id=\"bucketSortType\" aria-label=\"Choose bucket sorting algorithm\">\n      <option value=\"insertion\">Insertion Sort (default)</option>\n      <option value=\"jsbuiltin\">JavaScript Built-in Sort</option>\n      <option value=\"selection\">Selection Sort</option>\n      <option value=\"bubble\">Bubble Sort</option>\n    </select>\n    <button id=\"btnRebucket\" type=\"button\" disabled>Rebucket Current Array</button>\n  </fieldset>\n</form>\n\n<section id=\"stateSection\" style=\"margin-top:1em;\">\n  <fieldset aria-live=\"polite\" aria-atomic=\"true\">\n    <legend>Bucket Sort State & Logs</legend>\n    <div id=\"statusLine\" aria-live=\"polite\"></div>\n    <pre id=\"logArea\" aria-label=\"Sort logs\"></pre>\n  </fieldset>\n</section>\n\n<section id=\"bucketContainer\" aria-label=\"Buckets container\" tabindex=\"0\" style=\"margin-top:1em;\"></section>\n\n<section id=\"finalOutputSection\" style=\"margin-top:1em;display:none;\">\n  <fieldset>\n    <legend>Final Sorted Array</legend>\n    <pre id=\"finalSortedArray\"></pre>\n    <button id=\"btnShowSortedArray\" type=\"button\">Show/Hide Sorted Array</button>\n  </fieldset>\n</section>\n\n<script>\n(function(){\n  // Internal state and logic\n\n  // Utility parsing function\n  function parseInputArray(str) {\n    // Split by comma or spaces\n    const items = str.trim().split(/[\\s,]+/);\n    const arr = [];\n    for(let i=0; i<items.length; i++) {\n      if(items[i].length === 0) continue;\n      let n = Number(items[i]);\n      if(!Number.isFinite(n)) return null;\n      arr.push(n);\n    }\n    return arr;\n  }\n\n  // Sort algorithms for buckets:\n  // Insertion sort\n  function insertionSort(arr, recordStep) {\n    let logSteps = [];\n    for(let i=1; i<arr.length; i++) {\n      let key = arr[i];\n      let j = i-1;\n      while(j>=0 && arr[j]>key) {\n        arr[j+1] = arr[j];\n        j--;\n        if(recordStep) logSteps.push(arr.slice());\n      }\n      arr[j+1] = key;\n      if(recordStep) logSteps.push(arr.slice());\n    }\n    return logSteps;\n  }\n  // Selection sort\n  function selectionSort(arr, recordStep) {\n    let logSteps = [];\n    for(let i=0; i<arr.length-1; i++) {\n      let minIdx = i;\n      for(let j=i+1; j<arr.length; j++) {\n        if(arr[j]<arr[minIdx]) minIdx = j;\n      }\n      if(minIdx !== i) {\n        [arr[i], arr[minIdx]] = [arr[minIdx], arr[i]];\n        if(recordStep) logSteps.push(arr.slice());\n      }\n    }\n    return logSteps;\n  }\n  // Bubble sort\n  function bubbleSort(arr, recordStep) {\n    let logSteps = [];\n    let n = arr.length;\n    let swapped;\n    do {\n      swapped = false;\n      for(let i=1; i<n; i++) {\n        if(arr[i-1]>arr[i]) {\n          [arr[i-1], arr[i]] = [arr[i], arr[i-1]];\n          swapped = true;\n          if(recordStep) logSteps.push(arr.slice());\n        }\n      }\n      n--;\n    } while(swapped);\n    return logSteps;\n  }\n\n  // Safe to use JS builtin Array.prototype.sort with numeric comparator\n  function builtinSort(arr, recordStep) {\n    // Because sort() is opaque, just do one step: full sorted.\n    arr.sort((a,b)=>a-b);\n    return [arr.slice()];\n  }\n\n  // Step-by-step bucket sort states:\n  // States will guide UI interactivity and allow steps back/forward\n  // State stages:\n  //   0 = initial input not yet initialized\n  //   1 = buckets created & empty\n  //   2 = distribution of elements across buckets step-by-step\n  //   3 = bucket sorting step-by-step for each bucket\n  //   4 = buckets concatenated forming final array\n  //   5 = done\n\n  // Major properties:\n  // - original input array (originalArray)\n  // - current array (curArray)\n  // - buckets: array of arrays\n  // - number of buckets\n  // - min value and max value for bucketing \n  // - bucket ranges (for log display)\n  // - current state\n  // - step indexes for distribution, bucket sorting, concatenation\n  // - sorting logs per bucket for more detailed steps\n\n  // Global state object:\n  let state = {\n    originalArray: [],\n    curArray: [],\n    buckets: [],\n    numBuckets: 5,\n    minVal: 0,\n    maxVal: 0,\n    bucketRanges: [],\n    stage: 0,\n    // distribution step index: index of the next element to place into bucket\n    distIndex: 0,\n    // bucket sort info: sortingSteps for each bucket and current step index per bucket sorting\n    bucketSortType: 'insertion',\n    bucketSortingSteps: [], // array of arrays of states per bucket\n    bucketSortingStepIndices: [], // current index per bucket in its sortingSteps\n    curSortingBucket: 0, // which bucket is currently being sorted\n    concatenated: [],\n    concatIndex: 0, // index for concatenation process\n    // Logs:\n    logs: [],\n    // Last sorted array after final step\n    sortedArray: null,\n    // Auto stepping state\n    autoTimer: null,\n    autoDelay: 500,\n    autoActive: false,\n    autoForward: true,\n    history: [], // history of snapshots for backstep (deep copy states)\n    historyPointer: -1,\n  };\n\n  // HTML Elements references\n  const inputArrayEl = document.getElementById('inputArray');\n  const numBucketsEl = document.getElementById('numBucketsInput');\n  const btnInitialize = document.getElementById('btnInitialize');\n  const btnReset = document.getElementById('btnReset');\n  const btnStep = document.getElementById('btnStep');\n  const btnAuto = document.getElementById('btnAuto');\n  const btnPause = document.getElementById('btnPause');\n  const btnFastForward = document.getElementById('btnFastForward');\n  const btnBackStep = document.getElementById('btnBackStep');\n  const btnResetStep = document.getElementById('btnResetStep');\n  const autoDelayRange = document.getElementById('autoDelayRange');\n  const autoDelayValue = document.getElementById('autoDelayValue');\n  const bucketSortTypeSel = document.getElementById('bucketSortType');\n  const btnRebucket = document.getElementById('btnRebucket');\n  const statusLine = document.getElementById('statusLine');\n  const logArea = document.getElementById('logArea');\n  const bucketContainer = document.getElementById('bucketContainer');\n  const finalOutputSection = document.getElementById('finalOutputSection');\n  const finalSortedArrayPre = document.getElementById('finalSortedArray');\n  const btnShowSortedArray = document.getElementById('btnShowSortedArray');\n  const controlsForm = document.getElementById('controlsForm');\n\n  // Helpers for deep copying arrays and state\n  function deepCopyState(st) {\n    // Only copy fields that matter for history\n    return {\n      originalArray: st.originalArray.slice(),\n      curArray: st.curArray.slice(),\n      buckets: st.buckets.map(b=>b.slice()),\n      numBuckets: st.numBuckets,\n      minVal: st.minVal,\n      maxVal: st.maxVal,\n      bucketRanges: st.bucketRanges.slice(),\n      stage: st.stage,\n      distIndex: st.distIndex,\n      bucketSortType: st.bucketSortType,\n      bucketSortingSteps: st.bucketSortingSteps.map(arrs=>arrs.map(a=>a.slice())),\n      bucketSortingStepIndices: st.bucketSortingStepIndices.slice(),\n      curSortingBucket: st.curSortingBucket,\n      concatenated: st.concatenated.slice(),\n      concatIndex: st.concatIndex,\n      logs: st.logs.slice(),\n      sortedArray: st.sortedArray ? st.sortedArray.slice() : null,\n    };\n  }\n  function restoreState(snapshot) {\n    state.originalArray = snapshot.originalArray.slice();\n    state.curArray = snapshot.curArray.slice();\n    state.buckets = snapshot.buckets.map(b=>b.slice());\n    state.numBuckets = snapshot.numBuckets;\n    state.minVal = snapshot.minVal;\n    state.maxVal = snapshot.maxVal;\n    state.bucketRanges = snapshot.bucketRanges.slice();\n    state.stage = snapshot.stage;\n    state.distIndex = snapshot.distIndex;\n    state.bucketSortType = snapshot.bucketSortType;\n    state.bucketSortingSteps = snapshot.bucketSortingSteps.map(arrs=>arrs.map(a=>a.slice()));\n    state.bucketSortingStepIndices = snapshot.bucketSortingStepIndices.slice();\n    state.curSortingBucket = snapshot.curSortingBucket;\n    state.concatenated = snapshot.concatenated.slice();\n    state.concatIndex = snapshot.concatIndex;\n    state.logs = snapshot.logs.slice();\n    state.sortedArray = snapshot.sortedArray ? snapshot.sortedArray.slice() : null;\n  }\n\n  // State machine step handlers\n  // Stage 1: Create buckets\n  // Stage 2: Distribute elements from curArray to buckets, one step = one element placed\n  // Stage 3: Sort buckets stepwise; each bucket sorts fully before moving to next\n  // Stage 4: Concatenate buckets one by one to concatenated array\n  // Stage 5: Finished; sortedArray available\n\n  // Calculate bucket ranges for display and bucketing\n  function calculateBucketRanges(minV,maxV,numB) {\n    let ranges = [];\n    if(numB === 1) {\n      ranges.push({min:minV, max:maxV});\n      return ranges;\n    }\n    let interval = (maxV - minV)/numB;\n    for(let i=0; i<numB; i++) {\n      let start = minV + i*interval;\n      let end = (i===numB-1) ? maxV : start+interval;\n      ranges.push({min: start, max: end});\n    }\n    return ranges;\n  }\n\n  // Given a number, find bucket index\n  function findBucketIndex(num, ranges) {\n    for(let i=0; i<ranges.length; i++) {\n      // inclusive min, exclusive max for all except last bucket inclusive max\n      if(i<ranges.length-1) {\n        if(num >= ranges[i].min && num < ranges[i].max) return i;\n      } else {\n        if(num >= ranges[i].min && num <= ranges[i].max) return i;\n      }\n    }\n    return 0; // fallback bucket index\n  }\n\n  // Log helper\n  function log(msg) {\n    state.logs.push(msg);\n    if(state.logs.length > 1000) {\n      state.logs.shift();\n    }\n  }\n\n  // Update UI print states\n  function updateUI() {\n    // Status line\n    let statusMsg = '';\n    if(state.stage === 0) {\n      statusMsg = 'Initialize with input array and number of buckets.';\n    } else if(state.stage === 1) {\n      statusMsg = `Buckets Created: ${state.numBuckets} buckets from ${state.minVal} to ${state.maxVal}`;\n    } else if(state.stage === 2) {\n      statusMsg = `Distributing element ${state.distIndex+1} of ${state.originalArray.length} into buckets.`;\n    } else if(state.stage === 3) {\n      statusMsg = `Sorting bucket ${state.curSortingBucket+1} of ${state.numBuckets} - Step ${state.bucketSortingStepIndices[state.curSortingBucket]+1} of ${state.bucketSortingSteps[state.curSortingBucket].length}`;\n    } else if(state.stage === 4) {\n      statusMsg = `Concatenating buckets - bucket ${state.concatIndex+1} of ${state.numBuckets}`;\n    } else if(state.stage === 5) {\n      statusMsg = `Sort completed. Final sorted array ready.`;\n    }\n    statusLine.textContent = statusMsg;\n\n    // Log area\n    logArea.textContent = state.logs.join('\\n');\n\n    // Bucket container\n    bucketContainer.innerHTML = '';\n    // Show bucket ranges and contents\n    for(let i=0; i<state.numBuckets; i++) {\n      let b = state.buckets[i];\n      let range = state.bucketRanges[i];\n      let bucketText = b.length > 0 ? b.join(', ') : '(empty)';\n      let bucketLabel = `Bucket ${i+1} [${range.min.toFixed(2)} - ${range.max.toFixed(2)}]: ${bucketText}`;\n      // Highlight step focus elements:\n      let highlightIndices = [];\n      if(state.stage === 2 && state.distIndex < state.originalArray.length) {\n        // Highlight element about to distribute if belongs here?\n        let curEl = state.originalArray[state.distIndex];\n        let idx = b.indexOf(curEl);\n        if(idx >= 0 && i === findBucketIndex(curEl,state.bucketRanges)) highlightIndices.push(idx);\n      }\n      if(state.stage === 3 && i === state.curSortingBucket) {\n        // Highlight elements changed in sorting step\n        const stepI = state.bucketSortingStepIndices[i];\n        if(stepI >= 0 && stepI < state.bucketSortingSteps[i].length) {\n          let arrStep = state.bucketSortingSteps[i][stepI];\n          bucketLabel += ` (Sorting step ${stepI+1}/${state.bucketSortingSteps[i].length})`;\n        }\n      }\n\n      let div = document.createElement('div');\n      div.className = 'bucket';\n      div.textContent = bucketLabel;\n      bucketContainer.appendChild(div);\n    }\n\n    // Buttons enable states based on stage and auto running\n    const autoOn = state.autoActive;\n    btnStep.disabled = autoOn || (state.stage === 0) || (state.stage === 5);\n    btnAuto.disabled = autoOn || (state.stage === 0) || (state.stage === 5);\n    btnPause.disabled = !autoOn;\n    btnFastForward.disabled = autoOn || (state.stage === 0) || (state.stage === 5);\n    btnBackStep.disabled = (state.historyPointer <= 0);\n    btnResetStep.disabled = (state.stage === 0);\n    btnRebucket.disabled = (state.stage === 0 || state.stage === 5);\n  }\n\n  // Initialize bucket sort state from inputs (called on Initialize)\n  function initializeBucketSort() {\n    let arr = parseInputArray(inputArrayEl.value);\n    if(!arr || arr.length===0) {\n      alert('Invalid input array. Please enter valid numbers separated by comma or spaces.');\n      return false;\n    }\n    let nb = Number(numBucketsEl.value);\n    if(!Number.isInteger(nb) || nb<1) {\n      alert('Number of buckets must be an integer ≥ 1.');\n      return false;\n    }\n\n    // Init state properties:\n    state.originalArray = arr.slice();\n    state.curArray = arr.slice();\n    state.numBuckets = nb;\n    state.minVal = Math.min(...arr);\n    state.maxVal = Math.max(...arr);\n    if(state.minVal === state.maxVal) {\n      // If all values equal, create 1 bucket only.\n      state.numBuckets = 1;\n      numBucketsEl.value = 1;\n      alert('All numbers equal, number of buckets set to 1.');\n    }\n    state.bucketRanges = calculateBucketRanges(state.minVal, state.maxVal, state.numBuckets);\n    state.buckets = new Array(state.numBuckets).fill(null).map(_=>[]);\n    state.stage = 1;\n    state.distIndex = 0;\n    state.bucketSortingStepIndices = new Array(state.numBuckets).fill(-1);\n    state.bucketSortingSteps = new Array(state.numBuckets);\n    state.curSortingBucket = 0;\n    state.concatenated = [];\n    state.concatIndex = 0;\n    state.logs = [];\n    state.sortedArray = null;\n    state.bucketSortType = bucketSortTypeSel.value;\n\n    // Preset bucketSortingSteps and bucketSortingStepIndices to empty\n    for(let i=0; i < state.numBuckets; i++) {\n      state.bucketSortingSteps[i] = [];\n      state.bucketSortingStepIndices[i] = -1;\n    }\n\n    // Clear history and save first snapshot after initialization\n    state.history = [];\n    state.historyPointer = -1;\n    saveHistory();\n\n    log(`Initialized with array of length ${arr.length}, ${state.numBuckets} bucket(s).`);\n    log(`Value range: min=${state.minVal}, max=${state.maxVal}`);\n    updateUI();\n\n    // Show controls form\n    controlsForm.style.display = 'block';\n    btnReset.disabled = false;\n\n    return true;\n  }\n\n  // Save snapshot to history for backstep\n  function saveHistory() {\n    // Drop all states forward of current pointer\n    if(state.historyPointer < state.history.length-1) {\n      state.history = state.history.slice(0,state.historyPointer+1);\n    }\n    const snap = deepCopyState(state);\n    state.history.push(snap);\n    state.historyPointer++;\n  }\n\n  // Step distribution: place one element in bucket\n  function distributionStepForward() {\n    if(state.stage !== 1 && state.stage !== 2) {\n      log('Cannot distribute elements now.');\n      return false;\n    }\n    if(state.distIndex >= state.originalArray.length) {\n      // Distribution done; prepare sorting steps\n      prepareBucketsSortingSteps();\n      state.stage = 3;\n      log('Distribution complete. Proceeding to bucket sorting.');\n      saveHistory();\n      return true;\n    }\n    let val = state.originalArray[state.distIndex];\n    let bidx = findBucketIndex(val, state.bucketRanges);\n    state.buckets[bidx].push(val);\n    state.distIndex++;\n    state.stage = 2;\n    log(`Placed element ${val} into bucket ${bidx+1}`);\n    saveHistory();\n    return true;\n  }\n\n  // Step distribution backward (only if stage=2)\n  function distributionStepBackward() {\n    if(state.stage !== 2) return false;\n    if(state.distIndex <= 0) return false;\n    state.distIndex--;\n    let val = state.originalArray[state.distIndex];\n    let bidx = findBucketIndex(val, state.bucketRanges);\n    let b = state.buckets[bidx];\n    // Remove last occurrence of val from bucket (should be last element)\n    for(let i=b.length-1; i>=0; i--) {\n      if(b[i] === val) {\n        b.splice(i,1);\n        break;\n      }\n    }\n    log(`Removed element ${val} from bucket ${bidx+1}`);\n    saveHistory();\n    return true;\n  }\n\n  // Prepare bucketSortingSteps for each bucket based on chosen algorithm\n  // Each will store array states per sorting step for that bucket\n  function prepareBucketsSortingSteps() {\n    const sortAlgo = state.bucketSortType;\n    for(let i=0; i<state.numBuckets; i++) {\n      let b = state.buckets[i].slice();\n      let steps = [];\n      if(b.length <= 1) {\n        // No steps needed; 0 steps\n        steps = [b.slice()];\n      } else {\n        if(sortAlgo === 'insertion') {\n          steps = insertionSort(b.slice(), true);\n        } else if(sortAlgo === 'selection') {\n          steps = selectionSort(b.slice(), true);\n        } else if(sortAlgo === 'bubble') {\n          steps = bubbleSort(b.slice(), true);\n        } else if(sortAlgo === 'jsbuiltin') {\n          steps = builtinSort(b.slice(), true);\n        } else {\n          // Default fallback\n          steps = insertionSort(b.slice(), true);\n        }\n      }\n      state.bucketSortingSteps[i] = steps;\n      state.bucketSortingStepIndices[i] = -1;\n    }\n    state.curSortingBucket = 0;\n    log(`Prepared sorting steps per bucket with algorithm: ${sortAlgo}`);\n  }\n\n  // Step sorting in current bucket forward\n  // Returns true if step advanced, false if bucket done\n  function bucketSortStepForward() {\n    if(state.stage !== 3) return false;\n    let cb = state.curSortingBucket;\n    if(cb < 0 || cb >= state.numBuckets) return false;\n    let stepIdx = state.bucketSortingStepIndices[cb];\n    let steps = state.bucketSortingSteps[cb];\n    if(stepIdx + 1 < steps.length) {\n      state.bucketSortingStepIndices[cb]++;\n      // Update bucket to current step array\n      state.buckets[cb] = steps[state.bucketSortingStepIndices[cb]].slice();\n      log(`Sorting bucket ${cb+1}, step ${state.bucketSortingStepIndices[cb]+1} of ${steps.length}`);\n      saveHistory();\n      return true;\n    } else {\n      // Current bucket done, move to next bucket\n      log(`Bucket ${cb+1} sorted.`);\n      state.curSortingBucket++;\n      if(state.curSortingBucket >= state.numBuckets) {\n        // All buckets sorted, move to concatenation\n        state.stage = 4;\n        state.concatIndex = 0;\n        state.concatenated = [];\n        log('All buckets sorted. Starting concatenation.');\n        saveHistory();\n      }\n      return false;\n    }\n  }\n\n  // Step sorting backward in current or previous buckets\n  function bucketSortStepBackward() {\n    if(state.stage !== 3) return false;\n    let cb = state.curSortingBucket;\n    // If currently past last bucket (all done), move back into last bucket sorting state.\n    if(cb >= state.numBuckets) {\n      state.curSortingBucket = state.numBuckets-1;\n      cb = state.curSortingBucket;\n      let steps = state.bucketSortingSteps[cb];\n      state.bucketSortingStepIndices[cb] = steps.length-1;\n      state.buckets[cb] = steps[steps.length-1].slice();\n      log(`Back stepped into last bucket ${cb+1}, last sorting step.`);\n      saveHistory();\n      return true;\n    }\n\n    let stepIdx = state.bucketSortingStepIndices[cb];\n    if(stepIdx > 0) {\n      state.bucketSortingStepIndices[cb]--;\n      state.buckets[cb] = state.bucketSortingSteps[cb][state.bucketSortingStepIndices[cb]].slice();\n      log(`Back stepped sorting bucket ${cb+1} to step ${state.bucketSortingStepIndices[cb]+1}`);\n      saveHistory();\n      return true;\n    } else if(stepIdx === 0) {\n      // Move to previous bucket if any\n      if(cb === 0) {\n        // No previous bucket; can't step back more in sorting\n        return false;\n      }\n      let prevBucket = cb - 1;\n      let steps = state.bucketSortingSteps[prevBucket];\n      state.curSortingBucket = prevBucket;\n      state.bucketSortingStepIndices[prevBucket] = steps.length - 1;\n      state.buckets[prevBucket] = steps[steps.length - 1].slice();\n      log(`Back stepped to previous bucket ${prevBucket+1}, last sorting step.`);\n      saveHistory();\n      return true;\n    }\n    return false;\n  }\n\n  // Step concatenation forward: add one bucket's contents\n  function concatenationStepForward() {\n    if(state.stage !== 4) return false;\n    if(state.concatIndex >= state.numBuckets) {\n      // Finish concatenation\n      state.stage = 5;\n      state.sortedArray = state.concatenated.slice();\n      log('Concatenation done. Sorting complete.');\n      saveHistory();\n      return true;\n    }\n    // Append this bucket elements to concatenated array (one whole bucket per step)\n    state.concatenated = state.concatenated.concat(state.buckets[state.concatIndex]);\n    log(`Concatenated bucket ${state.concatIndex+1} with ${state.buckets[state.concatIndex].length} elements.`);\n    state.concatIndex++;\n    saveHistory();\n    return true;\n  }\n\n  // Step concatenation backward: remove last concatenated bucket\n  function concatenationStepBackward() {\n    if(state.stage !== 4) return false;\n    if(state.concatIndex === 0) return false;\n    state.concatIndex--;\n    // Remove last bucket elements from concatenated array\n    let b = state.buckets[state.concatIndex];\n    if(b.length > 0) {\n      state.concatenated.splice(state.concatenated.length - b.length, b.length);\n    }\n    log(`Removed concatenated bucket ${state.concatIndex+1}`);\n    saveHistory();\n    return true;\n  }\n\n  // Execute one forward step depending on stage\n  function stepForward() {\n    if(state.stage === 0) {\n      log('Please initialize first.');\n      return false;\n    } else if(state.stage === 1 || state.stage === 2) {\n      return distributionStepForward();\n    } else if(state.stage === 3) {\n      // Try sort step; if current bucket done, automatically try next bucket next step\n      return bucketSortStepForward();\n    } else if(state.stage === 4) {\n      let res = concatenationStepForward();\n      if(state.stage === 5) {\n        // Auto stop if done\n        stopAuto();\n      }\n      return res;\n    } else if(state.stage === 5) {\n      log('Sorting already complete.');\n      return false;\n    }\n  }\n\n  // Execute one backward step depending on stage\n  function stepBackward() {\n    if(state.historyPointer <= 0) return false; // no prev history\n    if(state.autoActive) return false;\n\n    // Restore previous state snapshot\n    if(state.historyPointer >= 1) {\n      state.historyPointer--;\n      let prev = state.history[state.historyPointer];\n      restoreState(pr