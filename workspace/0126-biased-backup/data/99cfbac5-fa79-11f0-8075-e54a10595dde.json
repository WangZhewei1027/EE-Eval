    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>CPU Scheduling Simulator</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .output {\n            margin-top: 20px;\n            border: 1px solid black;\n            padding: 10px;\n            min-height: 50px;\n        }\n    </style>\n</head>\n<body>\n    <h1>CPU Scheduling Simulator</h1>\n    \n    <h2>Add a Process</h2>\n    Process ID: <input type=\"text\" id=\"processID\"><br>\n    Burst Time: <input type=\"number\" id=\"burstTime\"><br>\n    Arrival Time: <input type=\"number\" id=\"arrivalTime\"><br>\n    <button onclick=\"addProcess()\">Add Process</button>\n    \n    <h2>Scheduling Algorithms</h2>\n    <button onclick=\"scheduleFCFS()\">First Come First Serve (FCFS)</button>\n    <button onclick=\"scheduleSJF()\">Shortest Job First (SJF)</button>\n    <button onclick=\"scheduleRR()\">Round Robin (RR)</button><br>\n    Time Quantum (for RR): <input type=\"number\" id=\"timeQuantum\" value=\"2\"><br>\n\n    <h2>Process List</h2>\n    <div id=\"processList\" class=\"output\"></div>\n\n    <h2>Scheduling Output</h2>\n    <div id=\"schedulingOutput\" class=\"output\"></div>\n\n    <script>\n        let processList = [];\n\n        function addProcess() {\n            const id = document.getElementById('processID').value;\n            const burst = parseInt(document.getElementById('burstTime').value);\n            const arrival = parseInt(document.getElementById('arrivalTime').value);\n\n            if (id && !isNaN(burst) && !isNaN(arrival)) {\n                processList.push({ id, burst, arrival });\n                updateProcessList();\n            }\n        }\n\n        function updateProcessList() {\n            const processDiv = document.getElementById('processList');\n            processDiv.innerHTML = JSON.stringify(processList, null, 2);\n        }\n\n        function scheduleFCFS() {\n            let time = 0;\n            let output = [];\n            processList.sort((a, b) => a.arrival - b.arrival);\n\n            for (let process of processList) {\n                if (time < process.arrival) time = process.arrival;\n                output.push(`Process ${process.id} starts at ${time} and finishes at ${time + process.burst}`);\n                time += process.burst;\n            }\n            document.getElementById('schedulingOutput').innerText = output.join('\\n');\n        }\n\n        function scheduleSJF() {\n            let time = 0;\n            let output = [];\n            let processes = [...processList];\n\n            while (processes.length > 0) {\n                processes.sort((a, b) => a.burst - b.burst);\n                const process = processes.find(p => p.arrival <= time);\n\n                if (process) {\n                    output.push(`Process ${process.id} starts at ${time} and finishes at ${time + process.burst}`);\n                    time += process.burst;\n                    processes = processes.filter(p => p.id !== process.id);\n                } else {\n                    time++;\n                }\n            }\n\n            document.getElementById('schedulingOutput').innerText = output.join('\\n');\n        }\n\n        function scheduleRR() {\n            const timeQuantum = parseInt(document.getElementById('timeQuantum').value);\n            let time = 0;\n            let output = [];\n            let queue = [...processList];\n\n            while (queue.length > 0) {\n                let process = queue.shift();\n                if (process.arrival <= time) {\n                    const slice = Math.min(process.burst, timeQuantum);\n                    output.push(`Process ${process.id} starts at ${time} and runs for ${slice}`);\n                    time += slice;\n\n                    process.burst -= slice;\n\n                    if (process.burst > 0) {\n                        queue.push(process);\n                    } else {\n                        output.push(`Process ${process.id} finishes at ${time}`);\n                    }\n                } else {\n                    queue.push(process);\n                }\n            }\n\n            document.getElementById('schedulingOutput').innerText = output.join('\\n');\n        }\n    </script>\n</body>\n</html>"
