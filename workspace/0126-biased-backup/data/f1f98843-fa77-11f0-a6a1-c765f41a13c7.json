    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Overfitting — Visual Exploration</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #081226;\n    --card: rgba(255,255,255,0.04);\n    --glass: rgba(255,255,255,0.05);\n    --accent: #7c5cff;\n    --accent-2: #48d1ff;\n    --muted: rgba(255,255,255,0.75);\n    --glass-border: rgba(255,255,255,0.06);\n    --success: #27e09b;\n    --danger: #ff7a7a;\n  }\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: \"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color:var(--muted);\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.09), transparent),\n                radial-gradient(900px 450px at 90% 90%, rgba(72,209,255,0.04), transparent),\n                linear-gradient(180deg,var(--bg1), var(--bg2));\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Page layout */\n  .wrap{\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:32px;\n    padding:48px;\n    height:100vh;\n    box-sizing:border-box;\n  }\n\n  /* Header Card */\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border-radius:18px;\n    padding:26px;\n    box-shadow: 0 10px 40px rgba(2,6,23,0.6);\n    border: 1px solid var(--glass-border);\n    backdrop-filter: blur(8px) saturate(120%);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n  }\n\n  header h1{\n    margin:0;\n    font-weight:800;\n    letter-spacing:-0.4px;\n    color:rgba(255,255,255,0.95);\n    font-size:22px;\n    display:flex;\n    align-items:center;\n    gap:14px;\n  }\n  header p{\n    margin:0;\n    color:rgba(255,255,255,0.60);\n    font-size:13px;\n  }\n\n  .topbar{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n  }\n\n  /* Visualization area */\n  .viz{\n    height: calc(100vh - 160px);\n    min-height:420px;\n    position:relative;\n    border-radius:14px;\n    overflow:hidden;\n    border:1px solid rgba(255,255,255,0.03);\n    background:\n      linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    display:flex;\n    align-items:stretch;\n  }\n\n  .left{\n    flex:1;\n    padding:28px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    position:relative;\n  }\n\n  .right{\n    width:420px;\n    padding:22px;\n    border-left:1px dashed rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    box-sizing:border-box;\n  }\n\n  .card-title{\n    color:rgba(255,255,255,0.9);\n    font-weight:700;\n    font-size:15px;\n    display:flex;\n    align-items:center;\n    gap:10px;\n  }\n  .card-sub{\n    color:rgba(255,255,255,0.6);\n    font-size:12px;\n  }\n\n  /* Canvas/ SVG area styling */\n  .plot {\n    background: linear-gradient(180deg, rgba(124,92,255,0.03), rgba(72,209,255,0.01));\n    border-radius:12px;\n    padding:18px;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    flex:1;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    overflow:hidden;\n  }\n\n  svg{\n    width:100%;\n    height:100%;\n    display:block;\n  }\n\n  /* Controls */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    color:var(--muted);\n    padding:10px 14px;\n    border-radius:10px;\n    border:1px solid rgba(255,255,255,0.04);\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    cursor:pointer;\n    font-weight:600;\n    font-size:13px;\n    transition:transform .18s ease, box-shadow .18s ease, background .18s ease;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n  }\n  .btn:active{ transform: translateY(1px) }\n  .btn:hover{ transform: translateY(-3px); }\n\n  .btn.primary{\n    background: linear-gradient(90deg, var(--accent), var(--accent-2));\n    color:white;\n    border: none;\n    box-shadow: 0 10px 30px rgba(124,92,255,0.22), 0 2px 6px rgba(0,0,0,0.5);\n  }\n  .btn.ghost{\n    background:transparent;\n    border:1px solid rgba(255,255,255,0.06);\n  }\n\n  /* Legend */\n  .legend{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:rgba(255,255,255,0.75);\n    font-size:13px;\n  }\n  .legend span{\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n  }\n  .dot{\n    width:12px;height:12px;border-radius:50%;\n    box-shadow: 0 2px 8px rgba(2,6,23,0.6);\n  }\n  .train-dot{ background: linear-gradient(180deg,#8aa2ff,#4b67ff); }\n  .val-dot{ background: linear-gradient(180deg,#ffb6d5,#ff7aa8); }\n  .curve-dot{ width:16px;height:3px;border-radius:6px;background:linear-gradient(90deg,var(--accent),var(--accent-2)); display:inline-block; }\n\n  /* Loss chart */\n  .loss-chart{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:14px;\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    min-height:200px;\n  }\n\n  .axis-label{\n    color:rgba(255,255,255,0.55);\n    font-size:12px;\n  }\n\n  .footer{\n    color:rgba(255,255,255,0.55);\n    font-size:12px;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:12px;\n  }\n\n  /* Floating subtle headline */\n  .big{\n    position:absolute;\n    right:36px;\n    top:36px;\n    font-weight:800;\n    color:rgba(255,255,255,0.06);\n    font-size:80px;\n    pointer-events:none;\n    user-select:none;\n    letter-spacing:12px;\n  }\n\n  /* Tiny description card */\n  .desc{\n    color:rgba(255,255,255,0.72);\n    font-size:13px;\n    line-height:1.5;\n    max-width:640px;\n  }\n\n  /* small helper */\n  .pill{\n    padding:6px 10px;\n    border-radius:999px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    font-size:12px;\n    color:rgba(255,255,255,0.65);\n  }\n\n  /* subtle animated background blobs */\n  .blob{\n    position:absolute;\n    border-radius:50%;\n    filter: blur(36px);\n    mix-blend-mode:screen;\n    opacity:0.18;\n  }\n  .blob.a{ width:380px;height:380px; right:-120px; top:-60px; background:linear-gradient(90deg,#7c5cff,#48d1ff); transform:rotate(12deg); }\n  .blob.b{ width:260px;height:260px; left:-80px; bottom:-40px; background:linear-gradient(90deg,#48d1ff,#7c5cff); opacity:0.12; }\n\n  /* responsive */\n  @media (max-width:980px){\n    .wrap{ grid-template-columns: 1fr; padding:20px; gap:18px; height:auto; }\n    .right{ width:auto; border-left:none; }\n    .big{ display:none; }\n    .viz{ height:auto; min-height:540px; }\n  }\n\n  /* subtle entrance */\n  .panel{ transform-origin:top center; animation:pop .8s cubic-bezier(.16,.82,.24,1); }\n  @keyframes pop{ from{ transform:translateY(18px) scale(.998); opacity:0 } to{ transform:none; opacity:1 } }\n\n  /* glow pulse */\n  .pulse{\n    animation: pulse 3.6s ease-in-out infinite;\n  }\n  @keyframes pulse{\n    0%{ opacity:1; transform:scale(1) }\n    50%{ opacity:0.85; transform:scale(1.02) }\n    100%{ opacity:1; transform:scale(1) }\n  }\n\n  /* subtle move */\n  .floating{\n    animation: floaty 6s ease-in-out infinite;\n  }\n  @keyframes floaty{\n    0%{ transform: translateY(0px) }\n    50%{ transform: translateY(-8px) }\n    100%{ transform: translateY(0px) }\n  }\n\n  /* small tooltip-like */\n  .metric{\n    display:flex;\n    gap:10px;\n    align-items:center;\n    font-weight:700;\n    color:white;\n  }\n\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"panel\">\n    <div class=\"topbar\">\n      <div>\n        <h1>\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden>\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n                <stop offset=\"1\" stop-color=\"#48d1ff\"/>\n              </linearGradient>\n            </defs>\n            <rect width=\"24\" height=\"24\" rx=\"6\" fill=\"url(#g1)\"></rect>\n            <path d=\"M6 15c1-3 3-5 6-6s5 0 7 3\" stroke=\"white\" stroke-opacity=\"0.9\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <circle cx=\"6\" cy=\"15\" r=\"1.6\" fill=\"white\"/>\n          </svg>\n          Overfitting\n        </h1>\n        <p>How models learn — and when they learn too much.</p>\n      </div>\n      <div class=\"controls\">\n        <div class=\"legend\">\n          <span><i class=\"dot train-dot\"></i> Training</span>\n          <span><i class=\"dot val-dot\"></i> Validation</span>\n          <span><i class=\"curve-dot\"></i> Model</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"viz\">\n      <div class=\"blob a floating\"></div>\n      <div class=\"blob b pulse\"></div>\n\n      <div class=\"left\">\n        <div style=\"display:flex;align-items:center;justify-content:space-between;gap:18px\">\n          <div>\n            <div class=\"card-title\">Model Fit — Complexity Slide</div>\n            <div class=\"card-sub\">Observe how increasing complexity reduces training error but can harm validation.</div>\n          </div>\n          <div style=\"display:flex;gap:8px;align-items:center\">\n            <div class=\"pill\" id=\"complexityValue\">Complexity: 0%</div>\n          </div>\n        </div>\n\n        <div class=\"plot\" id=\"plotArea\">\n          <svg id=\"plotSVG\" viewBox=\"0 0 800 480\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <filter id=\"soft\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur stdDeviation=\"6\" result=\"b\"/>\n                <feBlend in=\"SourceGraphic\" in2=\"b\" mode=\"screen\"/>\n              </filter>\n              <linearGradient id=\"traj\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#8aa2ff\"/>\n                <stop offset=\"1\" stop-color=\"#4b67ff\"/>\n              </linearGradient>\n            </defs>\n\n            <!-- Axes / grid -->\n            <g id=\"grid\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"1\">\n              <!-- verticals -->\n              <g id=\"vlines\"></g>\n              <!-- horizontals -->\n              <g id=\"hlines\"></g>\n            </g>\n\n            <!-- Underlying true function area -->\n            <path id=\"trueFunc\" fill=\"transparent\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"2\" stroke-linecap=\"round\"></path>\n\n            <!-- Model curve -->\n            <path id=\"modelCurve\" fill=\"none\" stroke=\"url(#traj)\" stroke-width=\"3.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" filter=\"url(#soft)\" opacity=\"0.95\"></path>\n\n            <!-- Model thin outline -->\n            <path id=\"modelCurveThin\" fill=\"none\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n\n            <!-- Training points -->\n            <g id=\"trainPoints\"></g>\n\n            <!-- Validation points -->\n            <g id=\"valPoints\"></g>\n\n            <!-- Highlight failing marker -->\n            <g id=\"spotlight\" opacity=\"0.0\">\n              <circle cx=\"0\" cy=\"0\" r=\"28\" fill=\"rgba(124,92,255,0.06)\"/>\n              <circle cx=\"0\" cy=\"0\" r=\"48\" fill=\"rgba(72,209,255,0.02)\"/>\n            </g>\n\n            <!-- floating label -->\n            <g id=\"labelFloating\">\n              <rect x=\"600\" y=\"28\" rx=\"8\" ry=\"8\" width=\"160\" height=\"52\" fill=\"rgba(255,255,255,0.03)\" stroke=\"rgba(255,255,255,0.03)\"></rect>\n              <text x=\"610\" y=\"52\" fill=\"#fff\" font-size=\"12\" font-weight=\"700\">Validation ↗︎</text>\n              <text id=\"valLossText\" x=\"610\" y=\"70\" fill=\"rgba(255,255,255,0.65)\" font-size=\"11\">Loss: 0.00</text>\n            </g>\n\n          </svg>\n        </div>\n      </div>\n\n      <div class=\"right\">\n        <div>\n          <div class=\"card-title\">Loss vs Complexity</div>\n          <div class=\"card-sub\">Training loss steadily decreases; validation loss often forms a U-shape.</div>\n        </div>\n\n        <div class=\"loss-chart\" id=\"lossChart\">\n          <svg id=\"lossSVG\" viewBox=\"0 0 380 170\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:100%;height:100%;\">\n            <defs>\n              <linearGradient id=\"gradTrain\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#8aa2ff\"/>\n                <stop offset=\"1\" stop-color=\"#4b67ff\"/>\n              </linearGradient>\n              <linearGradient id=\"gradVal\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#ffb6d5\"/>\n                <stop offset=\"1\" stop-color=\"#ff7aa8\"/>\n              </linearGradient>\n            </defs>\n\n            <rect width=\"100%\" height=\"100%\" rx=\"8\" fill=\"transparent\"></rect>\n\n            <!-- axes -->\n            <g id=\"lossGrid\" stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"></g>\n\n            <!-- training path -->\n            <path id=\"trainLossPath\" fill=\"none\" stroke=\"url(#gradTrain)\" stroke-width=\"3\" stroke-linecap=\"round\"></path>\n            <!-- validation path -->\n            <path id=\"valLossPath\" fill=\"none\" stroke=\"url(#gradVal)\" stroke-width=\"3\" stroke-linecap=\"round\"></path>\n\n            <!-- markers -->\n            <circle id=\"trainMarker\" r=\"6\" fill=\"url(#gradTrain)\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"></circle>\n            <circle id=\"valMarker\" r=\"6\" fill=\"url(#gradVal)\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"></circle>\n\n            <!-- axis labels -->\n            <text x=\"8\" y=\"16\" fill=\"rgba(255,255,255,0.6)\" font-size=\"12\">Loss</text>\n            <text x=\"312\" y=\"160\" fill=\"rgba(255,255,255,0.5)\" font-size=\"11\">Complexity →</text>\n          </svg>\n        </div>\n\n        <div class=\"footer\">\n          <div style=\"display:flex;flex-direction:column;\">\n            <div class=\"metric\"><span style=\"opacity:.85\">Training</span> <span style=\"margin-left:8px;color:var(--accent); font-weight:800\" id=\"trainLossVal\">0.00</span></div>\n            <div class=\"card-sub\" style=\"margin-top:2px\">Current training error</div>\n          </div>\n          <div style=\"display:flex;flex-direction:column;\">\n            <div class=\"metric\"><span style=\"opacity:.85\">Validation</span> <span style=\"margin-left:8px;color:var(--danger); font-weight:800\" id=\"valLossVal\">0.00</span></div>\n            <div class=\"card-sub\" style=\"margin-top:2px\">Current validation error</div>\n          </div>\n          <div style=\"display:flex;gap:8px;align-items:center\">\n            <button class=\"btn ghost\" id=\"toggleNoise\" title=\"Toggle dataset noisiness\">Toggle Noise</button>\n            <button class=\"btn primary\" id=\"playPause\" title=\"Play/Pause animation\">Pause</button>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <div style=\"display:flex;align-items:center;justify-content:space-between;gap:18px;margin-top:6px\">\n      <div class=\"desc\">\n        In machine learning, overfitting occurs when a model learns the noise of the training data rather than the underlying pattern — yielding low training error but worse generalization on new data. Watch the animation: as complexity increases, training loss drops continuously while validation loss eventually rises.\n      </div>\n      <div style=\"text-align:right\">\n        <div class=\"pill\">Beautifully Styled • Educational</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Config & state\n  const SVG_WIDTH = 800, SVG_HEIGHT = 480;\n  const PAD = {left:48, right:48, top:36, bottom:48};\n  const PLOT_W = SVG_WIDTH - PAD.left - PAD.right;\n  const PLOT_H = SVG_HEIGHT - PAD.top - PAD.bottom;\n\n  const trainN = 18, valN = 12;\n  let noiseOn = true;\n  let playing = true;\n  let t = 0; // normalized complexity [0,1]\n  let tDir = 1;\n\n  const plotSVG = document.getElementById('plotSVG');\n  const trainPointsG = document.getElementById('trainPoints');\n  const valPointsG = document.getElementById('valPoints');\n  const modelCurve = document.getElementById('modelCurve');\n  const modelCurveThin = document.getElementById('modelCurveThin');\n  const trueFunc = document.getElementById('trueFunc');\n  const vlines = document.getElementById('vlines');\n  const hlines = document.getElementById('hlines');\n  const complexityValue = document.getElementById('complexityValue');\n  const valLossText = document.getElementById('valLossText');\n\n  const lossSVG = document.getElementById('lossSVG');\n  const trainLossPath = document.getElementById('trainLossPath');\n  const valLossPath = document.getElementById('valLossPath');\n  const trainMarker = document.getElementById('trainMarker');\n  const valMarker = document.getElementById('valMarker');\n  const trainLossVal = document.getElementById('trainLossVal');\n  const valLossVal = document.getElementById('valLossVal');\n\n  const playPauseBtn = document.getElementById('playPause');\n  const toggleNoiseBtn = document.getElementById('toggleNoise');\n\n  // Generate dataset\n  let trainData = [];\n  let valData = [];\n  let kernelAlphas = []; // for overfitting bumps based on training residuals\n\n  function baseFunc(x){\n    // underlying smooth function on domain [0,1]\n    return 0.5 + 0.6*Math.sin(2*Math.PI*(x*1.0 + 0.05)) + 0.18*Math.cos(4*Math.PI*x);\n  }\n\n  function rand(seed){\n    // simple RNG\n    let x = Math.sin(seed)*43758.5453123;\n    return x - Math.floor(x);\n  }\n\n  function generateData(noisy=true){\n    // training x evenly spread with jitter\n    trainData = [];\n    valData = [];\n    for(let i=0;i<trainN;i++){\n      const x = (i+0.5)/trainN + (Math.random()-0.5)*0.02;\n      const noise = (Math.random()*2-1) * (noisy? 0.18 : 0.06);\n      const y = baseFunc(x) + noise;\n      trainData.push({x, y});\n    }\n    for(let i=0;i<valN;i++){\n      const x = (i+0.5)/valN + (Math.random()-0.5)*0.018;\n      const noise = (Math.random()*2-1) * (noisy? 0.18 : 0.06);\n      const y = baseFunc(x) + noise;\n      valData.push({x, y});\n    }\n\n    // compute kernel alphas to simulate overfitting bumps that fit training residuals\n    kernelAlphas = trainData.map(d => {\n      // residual relative to base\n      return d.y - baseFunc(d.x);\n    });\n  }\n\n  // Coordinate transforms\n  function sx(x){ return PAD.left + x * PLOT_W; }\n  function sy(y){ return PAD.top + (1-y) * PLOT_H; }\n\n  // Draw grid\n  function drawGrid(){\n    vlines.innerHTML = '';\n    hlines.innerHTML = '';\n    const vCount = 8;\n    for(let i=0;i<=vCount;i++){\n      const x = sx(i/vCount);\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1',x); line.setAttribute('x2',x);\n      line.setAttribute('y1', PAD.top); line.setAttribute('y2', PAD.top + PLOT_H);\n      line.setAttribute('stroke-opacity', i%vCount===0?0.06:0.02);\n      vlines.appendChild(line);\n    }\n    const hCount = 6;\n    for(let i=0;i<=hCount;i++){\n      const y = sy(i/hCount);\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1', PAD.left); line.setAttribute('x2', PAD.left + PLOT_W);\n      line.setAttribute('y1', y); line.setAttribute('y2', y);\n      line.setAttribute('stroke-opacity', i%hCount===0?0.06:0.02);\n      hlines.appendChild(line);\n    }\n  }\n\n  // Draw underlying true function\n  function drawTrue(){\n    const N = 220;\n    let d = '';\n    for(let i=0;i<=N;i++){\n      const x = i/N;\n      const xp = sx(x);\n      const yp = sy(baseFunc(x));\n      d += (i===0? 'M':'L') + xp + ' ' + yp + ' ';\n    }\n    trueFunc.setAttribute('d', d);\n  }\n\n  // Kernel bump\n  function kernel(x, xi, width=0.05){\n    return Math.exp(-0.5 * Math.pow((x-xi)/width,2));\n  }\n\n  // Model prediction for array of xs at complexity c\n  function predict(xs, c){\n    const preds = [];\n    for(const x of xs){\n      // smooth low-complex component\n      let y = baseFunc(x);\n      // add a gentle high-frequency global wiggle based on c\n      y += c * 0.08 * Math.sin(8*Math.PI*x + 0.6);\n      // add bump sum derived from training residuals scaled by c\n      for(let j=0;j<trainData.length;j++){\n        y += c * (kernel(x, trainData[j].x, 0.045) * kernelAlphas[j] * 0.9);\n      }\n      preds.push(y);\n    }\n    return preds;\n  }\n\n  // Build model curve path\n  function buildModelPath(c){\n    const N = 320;\n    let d = '';\n    const xs = [];\n    const ys = [];\n    for(let i=0;i<=N;i++){\n      const x = i/N;\n      xs.push(x);\n    }\n    const ps = predict(xs, c);\n    for(let i=0;i<ps.length;i++){\n      const xp = sx(xs[i]);\n      const yp = sy(ps[i]);\n      d += (i===0? 'M':'L') + xp + ' ' + yp + ' ';\n    }\n    modelCurve.setAttribute('d', d);\n    modelCurveThin.setAttribute('d', d);\n  }\n\n  // Plot points\n  function drawPoints(){\n    trainPointsG.innerHTML = '';\n    valPointsG.innerHTML = '';\n\n    for(let i=0;i<trainData.length;i++){\n      const d = trainData[i];\n      const cx = sx(d.x);\n      const cy = sy(d.y);\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform', `translate(${cx},${cy})`);\n      // glow\n      const glow = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      glow.setAttribute('r', 10);\n      glow.setAttribute('fill', 'rgba(124,92,255,0.10)');\n      g.appendChild(glow);\n      const c = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      c.setAttribute('r', 5.6);\n      c.setAttribute('fill', '#8aa2ff');\n      c.setAttribute('stroke', 'rgba(255,255,255,0.06)');\n      c.setAttribute('stroke-width','1');\n      g.appendChild(c);\n      trainPointsG.appendChild(g);\n    }\n\n    for(let i=0;i<valData.length;i++){\n      const d = valData[i];\n      const cx = sx(d.x);\n      const cy = sy(d.y);\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform', `translate(${cx},${cy})`);\n      // halo\n      const glow = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      glow.setAttribute('r', 9);\n      glow.setAttribute('fill', 'rgba(255,122,122,0.06)');\n      g.appendChild(glow);\n      const c = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      c.setAttribute('r', 4.8);\n      c.setAttribute('fill', '#ff9cc2');\n      c.setAttribute('stroke', 'rgba(255,255,255,0.06)');\n      c.setAttribute('stroke-width','1');\n      g.appendChild(c);\n      valPointsG.appendChild(g);\n    }\n  }\n\n  // Compute loss curves for many complexities\n  let complexitySamples = [];\n  let trainLossSamples = [];\n  let valLossSamples = [];\n\n  function computeLossSamples(){\n    const M = 120;\n    complexitySamples = [];\n    trainLossSamples = [];\n    valLossSamples = [];\n    for(let k=0;k<=M;k++){\n      const c = k/M;\n      complexitySamples.push(c);\n      const trainXs = trainData.map(d=>d.x);\n      const valXs = valData.map(d=>d.x);\n      const predTrain = predict(trainXs, c);\n      const predVal = predict(valXs, c);\n      let tra = 0, va = 0;\n      for(let i=0;i<predTrain.length;i++){\n        const e = predTrain[i] - trainData[i].y;\n        tra += e*e;\n      }\n      for(let i=0;i<predVal.length;i++){\n        const e = predVal[i] - valData[i].y;\n        va += e*e;\n      }\n      trainLossSamples.push(Math.sqrt(tra/predTrain.length));\n      valLossSamples.push(Math.sqrt(va/predVal.length));\n    }\n    // Normalize for plotting scale\n  }\n\n  // Draw loss chart\n  function drawLossChart(){\n    const W = 380, H = 170;\n    const PADL = 28, PADR = 16, PADT = 22, PADB = 22;\n    const innerW = W - PADL - PADR;\n    const innerH = H - PADT - PADB;\n\n    // grid lines\n    const grid = document.getElementById('lossGrid');\n    grid.innerHTML = '';\n    for(let i=0;i<=4;i++){\n      const y = PADT + (i/4)*innerH;\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1', PADL); line.setAttribute('x2', PADL + innerW);\n      line.setAttribute('y1', y); line.setAttribute('y2', y);\n      line.setAttribute('stroke-opacity', i===4?0.08:0.03);\n      grid.appendChild(line);\n    }\n\n    const M = complexitySamples.length;\n    if(M===0) return;\n\n    // Determine value range\n    const all = trainLossSamples.concat(valLossSamples);\n    const minV = Math.min(...all) * 0.9;\n    const maxV = Math.max(...all) * 1.08;\n\n    function lx(i){\n      return PADL + (i/(M-1))*innerW;\n    }\n    function ly(v){\n      const t = (v - minV) / (maxV - minV);\n      return PADT + (1 - t) * innerH;\n    }\n\n    // Build paths\n    let pt = '';\n    let pv = '';\n    for(let i=0;i<M;i++){\n      const x = lx(i);\n      pt += (i===0? 'M':'L') + x + ' ' + ly(trainLossSamples[i]) + ' ';\n      pv += (i===0? 'M':'L') + x + ' ' + ly(valLossSamples[i]) + ' ';\n    }\n    trainLossPath.setAttribute('d', pt);\n    valLossPath.setAttribute('d', pv);\n\n    // position markers at current t\n    const idx = Math.round(t * (M-1));\n    const tx = lx(idx); const ty = ly(trainLossSamples[idx]);\n    const vx = lx(idx); const vy = ly(valLossSamples[idx]);\n    trainMarker.setAttribute('cx', tx); trainMarker.setAttribute('cy', ty);\n    valMarker.setAttribute('cx', vx); valMarker.setAttribute('cy', vy);\n\n    // update numeric displays\n    trainLossVal.textContent = trainLossSamples[idx].toFixed(3);\n    valLossVal.textContent = valLossSamples[idx].toFixed(3);\n    valLossText.textContent = 'Loss: ' + valLossSamples[idx].toFixed(3);\n  }\n\n  // Update everything for current t\n  function updateForT(c){\n    complexityValue.textContent = `Complexity: ${Math.round(c*100)}%`;\n    buildModelPath(c);\n\n    // compute losses\n    const trainXs = trainData.map(d=>d.x);\n    const valXs = valData.map(d=>d.x);\n    const predTrain = predict(trainXs, c);\n    const predVal = predict(valXs, c);\n    let tra = 0, va = 0;\n    for(let i=0;i<predTrain.length;i++){\n      const e = predTrain[i] - trainData[i].y;\n      tra += e*e;\n    }\n    for(let i=0;i<predVal.length;i++){\n      const e = predVal[i] - valData[i].y;\n      va += e*e;\n    }\n    const trainLoss = Math.sqrt(tra/predTrain.length);\n    const valLoss = Math.sqrt(va/predVal.length);\n    document.getElementById('trainLossVal').textContent = trainLoss.toFixed(3);\n    document.getElementById('valLossVal').textContent = valLoss.toFixed(3);\n\n    // spotlight some failure when valLoss gets worse: move spotlight near a validation point with big error\n    let worstIdx = 0; let worstErr = -1;\n    for(let i=0;i<valData.length;i++){\n      const e = Math.abs(predVal[i] - valData[i].y);\n      if(e > worstErr){ worstErr = e; worstIdx = i; }\n    }\n    const spot = document.getElementById('spotlight');\n    const spotlightOpacity = Math.min(1, Math.max(0, (valLoss - trainLoss) * 6 ));\n    if(spotlightOpacity > 0.04){\n      const px = sx(valData[worstIdx].x);\n      const py = sy(predict([valData[worstIdx].x], c)[0]);\n      spot.setAttribute('transform', `translate(${px},${py})`);\n      spot.setAttribute('opacity', spotlightOpacity);\n    } else {\n      spot.setAttribute('opacity', 0.0);\n    }\n\n    // small gentle transform on model path for life\n    modelCurve.setAttribute('transform', `translate(0, ${Math.sin(c*10+Date.now()/2200)*2})`);\n  }\n\n  // Animation loop\n  let last = performance.now();\n  function loop(now){\n    const dt = now - last;\n    last = now;\n    if(playing){\n      // slowly move t from 0 to 1 and back\n      const speed = 0.00075; // lower -> slower\n      t += tDir * speed * dt;\n      if(t >= 1){ t = 1; tDir = -1; }\n      if(t <= 0){ t = 0; tDir = 1; }\n      updateForT(t);\n      // update small floating markers\n      drawLossChart();\n    }\n    requestAnimationFrame(loop);\n  }\n\n  // init\n  function init(){\n    generateData(true);\n    drawGrid();\n    drawTrue();\n    drawPoints();\n    computeLossSamples();\n    drawLossChart();\n    updateForT(t);\n    requestAnimationFrame(loop);\n  }\n\n  // controls\n  playPauseBtn.addEventListener('click', () => {\n    playing = !playing;\n    playPauseBtn.textContent = playing ? 'Pause' : 'Play';\n    if(playing){\n      last = performance.now();\n    }\n  });\n  toggleNoiseBtn.addEventListener('click', () => {\n    noiseOn = !noiseOn;\n    generateData(noiseOn);\n    drawPoints();\n    computeLossSamples();\n    // small pulse animation to indicate dataset refreshed\n    const btn = toggleNoiseBtn;\n    btn.style.transform = 'translateY(-3px)';\n    setTimeout(()=>{ btn.style.transform = ''; }, 180);\n  });\n\n  // handle window resize - keep responsive SVG viewBox handles scaling\n  window.addEventListener('resize', () => {\n    // no-op, SVG viewBox keeps proportions\n  });\n\n  // kick off\n  init();\n\n  // Small intro animation: sweep complexity from 0->0.6 then pause/play\n  (function intro(){\n    let i=0;\n    const steps = 80;\n    const id = setInterval(()=>{\n      i++;\n      t = Math.min(0.6, i/steps * 0.6);\n      updateForT(t);\n      drawLossChart();\n      if(i>=steps){ clearInterval(id); }\n    }, 10);\n  })();\n\n})();\n</script>\n</body>\n</html>"
