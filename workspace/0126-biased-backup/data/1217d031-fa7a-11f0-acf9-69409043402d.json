  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Hash Functions Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea, input, select, button {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  textarea {\n    width: 100%;\n    height: 5em;\n  }\n  .hash-output {\n    width: 100%;\n    height: 3em;\n    font-family: monospace, monospace;\n    font-size: 1em;\n    overflow-wrap: break-word;\n  }\n  label {\n    user-select:none;\n  }\n  fieldset {\n    margin: 1em 0;\n  }\n</style>\n</head>\n<body>\n\n<h1>Hash Functions Explorer</h1>\n\n<p>\n  Enter an input to see various hash computations, explore collision attempts,\n  tweak parameters, and understand hash function properties.\n</p>\n\n<fieldset>\n  <legend>Input Text</legend>\n  <textarea id=\"inputText\" aria-label=\"Input Text for hashing\" placeholder=\"Type text here...\"></textarea>\n  <br/>\n  <label><input type=\"checkbox\" id=\"inputHex\" /> Interpret input as HEX string</label>\n</fieldset>\n\n<fieldset>\n  <legend>Hash Algorithm</legend>\n  <select id=\"hashAlgorithm\" aria-label=\"Select hash algorithm\">\n    <option value=\"simpleSum\">Simple Sum (mod 2^32)</option>\n    <option value=\"xorBytes\">XOR Bytes (mod 2^32)</option>\n    <option value=\"rot13Sum\">ROT13 Sum (mod 2^32)</option>\n    <option value=\"jsHash\">JS Hash (DJB2 variation)</option>\n    <option value=\"fnv1a32\">FNV-1a 32-bit</option>\n    <option value=\"custom\">Custom JavaScript Hash (User Code)</option>\n  </select>\n  <div id=\"customHashDiv\" style=\"margin-top:0.5em; display:none;\">\n    <label for=\"customHashCode\">Define your custom hash function in JS:</label><br/>\n    <textarea id=\"customHashCode\" rows=\"8\" style=\"width:100%; font-family: monospace;\" placeholder=\"function hash(bytes) { /* bytes is Uint8Array */ return 0; }\"></textarea>\n    <small>Must define function <code>hash(bytes: Uint8Array): number</code> that returns 32-bit unsigned integer.</small>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Hash Output</legend>\n  <button id=\"computeHash\">Compute Hash</button><br/><br/>\n  <label for=\"hashOutputDec\">Decimal Output:</label><br/>\n  <textarea id=\"hashOutputDec\" class=\"hash-output\" readonly></textarea>\n  <label for=\"hashOutputHex\">Hex Output:</label><br/>\n  <textarea id=\"hashOutputHex\" class=\"hash-output\" readonly></textarea>\n</fieldset>\n\n<fieldset>\n  <legend>Collision Exploration</legend>\n  <p>\n    Try to find collisions! Given a target value, try to generate inputs that hash to it.\n  </p>\n  <label for=\"targetCollisionDec\">Target Decimal Hash:</label><br/>\n  <input id=\"targetCollisionDec\" type=\"number\" min=\"0\" max=\"4294967295\" step=\"1\" placeholder=\"Unsigned 32-bit integer\" autocomplete=\"off\"/><br/>\n  <label for=\"collisionMaxLen\">Max Length to guess (bytes):</label><br/>\n  <input id=\"collisionMaxLen\" type=\"number\" min=\"1\" max=\"8\" step=\"1\" value=\"3\"/><br/>\n  <button id=\"runCollisionSearch\">Search for Collision</button>\n  <button id=\"stopCollisionSearch\" disabled>Stop Search</button><br/>\n  <label><input id=\"collisionShowAll\" type=\"checkbox\"/> Show all collisions found (else show first 5)</label><br/>\n  <label><input id=\"collisionAsciiOnly\" type=\"checkbox\" checked/> Limit to ASCII chars 32-126</label><br/>\n  <label><input id=\"collisionUseHex\" type=\"checkbox\"/> Interpret target as Hex</label>\n  <pre id=\"collisionStatus\" style=\"height:8em; overflow:auto; border: 1px solid black; white-space: pre-wrap;\"></pre>\n  <label>Collision Inputs Found:</label><br/>\n  <textarea id=\"collisionResults\" readonly rows=\"6\" style=\"width:100%; font-family: monospace;\"></textarea>\n</fieldset>\n\n<fieldset>\n  <legend>Hash Function Exploration</legend>\n  <label for=\"byteOffset\">Byte Offset to extract (0-based):</label>\n  <input type=\"number\" id=\"byteOffset\" value=\"0\" min=\"0\" max=\"3\" step=\"1\" /> (Extract 1 byte of 32-bit output)<br/>\n  <button id=\"extractByteBtn\">Extract Byte from Hash</button><br/>\n  <label for=\"extractedByte\">Extracted Byte (decimal 0-255):</label><br/>\n  <input id=\"extractedByte\" readonly type=\"number\" value=\"\" min=\"0\" max=\"255\"/><br/>\n</fieldset>\n\n<fieldset>\n  <legend>Hash Function Testing Workflow</legend>\n  <p>Step your input to see how hash value changes by single-byte edits.</p>\n  <label for=\"stepBy\">Step by (number of bytes to edit per step):</label>\n  <input type=\"number\" id=\"stepBy\" value=\"1\" min=\"1\" max=\"4\" step=\"1\"/><br/>\n  <label for=\"stepRange\">Number of steps to generate:</label>\n  <input type=\"number\" id=\"stepRange\" value=\"16\" min=\"1\" max=\"256\"/><br/>\n  <button id=\"generateSteps\">Generate Step Hashes</button><br/>\n  <pre id=\"stepsOutput\" style=\"height:12em; overflow:auto; border:1px solid black; white-space: pre-wrap;\"></pre>\n</fieldset>\n\n<script>\n(function(){\n  'use strict';\n\n  // Utilities for bytes conversions\n\n  function stringToUtf8Bytes(str) {\n    const encoder = new TextEncoder();\n    return encoder.encode(str);\n  }\n\n  function hexToBytes(hexStr) {\n    const clean = hexStr.replace(/\\s+/g,'').toLowerCase();\n    if(clean.length % 2 !== 0) {\n      throw new Error('HEX input length must be even');\n    }\n    const result = new Uint8Array(clean.length / 2);\n    for(let i=0; i<result.length; i++) {\n      const byteStr = clean.substr(i*2,2);\n      const val = parseInt(byteStr,16);\n      if(isNaN(val)) {\n        throw new Error('Invalid HEX input at byte ' + i);\n      }\n      result[i] = val;\n    }\n    return result;\n  }\n\n  function uint32ToHex(u) {\n    return ('00000000' + u.toString(16)).slice(-8);\n  }\n\n  // Simple implementations of various hashes:\n\n  // 1) Simple Sum mod 2^32\n  function hashSimpleSum(bytes) {\n    let sum = 0 >>> 0;\n    for(const b of bytes) {\n      sum = (sum + b) >>> 0;\n    }\n    return sum >>> 0;\n  }\n\n  // 2) XOR Bytes mod 2^32 (XOR all bytes in 4-byte shifts, padded zero)\n  function hashXorBytes(bytes) {\n    // XOR each group of 4 bytes as uint32\n    let xor = 0 >>> 0;\n    for(let i=0; i<bytes.length; i+=4) {\n      let val = 0;\n      for(let j=0;j<4;j++){\n        val |= ((bytes[i+j]||0) << (8*j));\n      }\n      xor ^= val;\n    }\n    return xor >>> 0;\n  }\n\n  // 3) ROT13 Sum: rotate accumulator left 13 bits + add byte\n  function rotl(value, shift) {\n    return ((value << shift) | (value >>> (32-shift))) >>> 0;\n  }\n  function hashRot13Sum(bytes) {\n    let hash = 0 >>> 0;\n    for(const b of bytes) {\n      hash = rotl(hash,13);\n      hash = (hash + b) >>> 0;\n    }\n    return hash >>> 0;\n  }\n\n  // 4) JS Hash (DJB2 variation)\n  function hashJsHash(bytes) {\n    let hash = 5381 >>> 0;\n    for(const b of bytes){\n      hash = (((hash << 5) + hash) + b) >>> 0; // hash * 33 + b\n    }\n    return hash >>> 0;\n  }\n\n  // 5) FNV-1a 32-bit\n  function hashFNV1a32(bytes) {\n    let hash = 2166136261 >>> 0;\n    for(const b of bytes) {\n      hash ^= b;\n      hash = Math.imul(hash, 16777619) >>> 0;\n    }\n    return hash >>> 0;\n  }\n\n  // Input parsing & Validation\n\n  const inputTextEl = document.getElementById('inputText');\n  const inputHexEl = document.getElementById('inputHex');\n  const hashAlgorithmEl = document.getElementById('hashAlgorithm');\n  const customHashDiv = document.getElementById('customHashDiv');\n  const customHashCodeEl = document.getElementById('customHashCode');\n  const computeHashBtn = document.getElementById('computeHash');\n  const hashOutputDecEl = document.getElementById('hashOutputDec');\n  const hashOutputHexEl = document.getElementById('hashOutputHex');\n\n  const collisionTargetDecEl = document.getElementById('targetCollisionDec');\n  const collisionMaxLenEl = document.getElementById('collisionMaxLen');\n  const collisionStatusEl = document.getElementById('collisionStatus');\n  const collisionResultsEl = document.getElementById('collisionResults');\n  const runCollisionSearchBtn = document.getElementById('runCollisionSearch');\n  const stopCollisionSearchBtn = document.getElementById('stopCollisionSearch');\n  const collisionShowAllEl = document.getElementById('collisionShowAll');\n  const collisionAsciiOnlyEl = document.getElementById('collisionAsciiOnly');\n  const collisionUseHexEl = document.getElementById('collisionUseHex');\n\n  const byteOffsetEl = document.getElementById('byteOffset');\n  const extractByteBtn = document.getElementById('extractByteBtn');\n  const extractedByteEl = document.getElementById('extractedByte');\n\n  const stepByEl = document.getElementById('stepBy');\n  const stepRangeEl = document.getElementById('stepRange');\n  const generateStepsBtn = document.getElementById('generateSteps');\n  const stepsOutputEl = document.getElementById('stepsOutput');\n\n  let currentHashValue = null;\n  let currentHashFunc = null;\n\n  // For collision search:\n  let collisionSearchRunning = false;\n  let collisionSearchAbortController = null;\n\n  // Display or hide custom hash textarea\n  hashAlgorithmEl.addEventListener('change',()=>{\n    if(hashAlgorithmEl.value === 'custom'){\n      customHashDiv.style.display = 'block';\n    } else {\n      customHashDiv.style.display = 'none';\n    }\n  });\n\n  /**\n   * Parse input text to Uint8Array bytes.\n   * If HEX mode is on, parse hex string.\n   * Else parse UTF-8 bytes.\n   * Throws error if invalid.\n   */\n  function parseInputToBytes(text, isHex) {\n    if(isHex){\n      return hexToBytes(text);\n    } else {\n      return stringToUtf8Bytes(text);\n    }\n  }\n\n  /**\n   * Get the hashing function by selection.\n   * If custom, try to compile user code.\n   * Returns function(bytes: Uint8Array): number\n   * or throws error.\n   */\n  function getHashFunction() {\n    const sel = hashAlgorithmEl.value;\n    switch(sel){\n      case 'simpleSum': return hashSimpleSum;\n      case 'xorBytes': return hashXorBytes;\n      case 'rot13Sum': return hashRot13Sum;\n      case 'jsHash': return hashJsHash;\n      case 'fnv1a32': return hashFNV1a32;\n      case 'custom':\n        const userCode = customHashCodeEl.value.trim();\n        if(!userCode){\n          throw new Error('Custom hash function code is empty');\n        }\n        // Build a function from user code\n        // We wrap in a Function to sandbox the code\n        // The code must define a function called \"hash\".\n        let func = null;\n        try {\n          const fullFuncCode = `(function(){\n            let hash;\n            ${userCode}\n            if(typeof hash !== 'function') throw new Error('Function \"hash\" not defined.');\n            return hash;\n          })()`;\n          func = eval(fullFuncCode);\n          if(typeof func !== 'function') throw new Error('Code did not return a function.');\n          // Test the function with an empty Uint8Array:\n          const testVal = func(new Uint8Array());\n          if(typeof testVal !== 'number' || !(Number.isInteger(testVal) || Number.isSafeInteger(testVal))) {\n            throw new Error('Hash function should return a number.');\n          }\n          return func;\n        } catch(e){\n          throw new Error('Error compiling custom hash function: '+e.message);\n        }\n      default:\n        throw new Error('Unknown hash function selected');\n    }\n  }\n\n  function updateHashOutputs() {\n    const inputText = inputTextEl.value;\n    try {\n      const bytes = parseInputToBytes(inputText, inputHexEl.checked);\n      currentHashFunc = getHashFunction();\n      const hashVal = currentHashFunc(bytes) >>> 0;\n      currentHashValue = hashVal;\n      hashOutputDecEl.value = String(hashVal);\n      hashOutputHexEl.value = uint32ToHex(hashVal);\n    } catch(e) {\n      currentHashValue = null;\n      hashOutputDecEl.value = e.message;\n      hashOutputHexEl.value = '';\n    }\n  }\n\n  computeHashBtn.addEventListener('click', ()=>{\n    updateHashOutputs();\n  });\n\n  // Support pressing enter in textarea to compute hash (no shift+enter)\n  inputTextEl.addEventListener('keydown', (evt)=>{\n    if(evt.key === 'Enter' && !evt.shiftKey){\n      evt.preventDefault();\n      updateHashOutputs();\n    }\n  });\n\n  inputHexEl.addEventListener('change', ()=>{\n    // Just recompute on mode change\n    updateHashOutputs();\n  });\n\n  hashAlgorithmEl.addEventListener('change', ()=>{\n    updateHashOutputs();\n  });\n\n  customHashCodeEl.addEventListener('input', ()=>{\n    if(hashAlgorithmEl.value === 'custom'){\n      // On user code change, clear outputs until compute button clicked\n      hashOutputDecEl.value = '';\n      hashOutputHexEl.value = '';\n      currentHashValue = null;\n    }\n  });\n\n  // Collision Search Implementation (exhaustive search up to max length)\n  // Generates all possible inputs of length 1..maxLen, tries to find those\n  // that hash to target value. Limited charset for performance.\n  // Warning: brute force can be slow even for small lengths.\n\n  // Characters to consider for input guessing:\n  function getCollisionCharset(asciiOnly) {\n    if(asciiOnly) {\n      // Printable ASCII 32..126\n      let arr = [];\n      for(let c=32; c<=126; c++) arr.push(c);\n      return arr;\n    } else {\n      // Full byte range 0..255\n      let arr = [];\n      for(let c=0; c<=255; c++) arr.push(c);\n      return arr;\n    }\n  }\n\n  function numberToBytesBigEndian(num, length) {\n    const arr = new Uint8Array(length);\n    for(let i=length-1;i>=0;i--) {\n      arr[i] = num & 0xFF;\n      num >>>=8;\n    }\n    return arr;\n  }\n\n  // Encode bytes to ASCII string or hex notation\n  function bytesToString(bytes, asciiOnly) {\n    if(asciiOnly){\n      try {\n        return String.fromCharCode(...bytes);\n      } catch (ex) {\n        // fallback if too long\n        return Array.from(bytes).map(b=>String.fromCharCode(b)).join('');\n      }\n    } else {\n      return Array.from(bytes).map(b=>('0'+b.toString(16)).slice(-2)).join(' ');\n    }\n  }\n\n  // Collision search worker function\n  // Use async/await with a generator-like to keep UI responsive and allow stop\n  async function* collisionSearchGenerator(target, maxLen, hashFunc, asciiOnly, onStatusUpdate) {\n    const charset = getCollisionCharset(asciiOnly);\n    // For each length from 1..maxLen\n    for(let length=1; length<=maxLen; length++){\n      if(collisionSearchRunning === false) return;\n\n      if(onStatusUpdate) onStatusUpdate(`Searching length ${length}...`);\n\n      // Total combos = charset.length ^ length may be huge...\n      // We cannot loop that naively, so we do an indexed loop from 0 to charset^length-1\n\n      // We'll do base conversion of a number from 0..limit-1 to length-positions with indexes in charset\n      const limit = Math.pow(charset.length, length);\n\n      // For performance: UTF-8 bytes array to fill:\n      const inputBytes = new Uint8Array(length);\n\n      // We break search into chunks for UI refresh\n      const chunkSize = 50000;\n      let count = 0;\n\n      for(let index=0; index<limit; index++) {\n        if(collisionSearchRunning === false) return;\n\n        // Convert index to base charset.length digits\n        let v = index;\n        for(let pos=length-1; pos>=0; pos--) {\n          inputBytes[pos] = charset[v % charset.length];\n          v = Math.floor(v / charset.length);\n        }\n\n        const val = hashFunc(inputBytes) >>> 0;\n        if(val === target){\n          // Yield this collision\n          yield inputBytes.slice(); // copy\n        }\n\n        count++;\n        if(count >= chunkSize){\n          count = 0;\n          await new Promise(r=>setTimeout(r,0));\n        }\n      }\n    }\n    if(onStatusUpdate) onStatusUpdate('Search finished.');\n  }\n\n  runCollisionSearchBtn.addEventListener('click', async ()=>{\n    if(collisionSearchRunning) return;\n    collisionResultsEl.value = '';\n    collisionStatusEl.textContent = 'Starting search...';\n\n    let targetRaw = collisionTargetDecEl.value.trim();\n    if(targetRaw.length === 0){\n      collisionStatusEl.textContent = 'Please enter the target hash value';\n      return;\n    }\n    let targetVal;\n    try {\n      if(collisionUseHexEl.checked){\n        // Accept hex input: convert to uint32\n        if(!/^[0-9a-fA-F]+$/.test(targetRaw)){\n          throw new Error('Invalid hex target input');\n        }\n        targetVal = Number.parseInt(targetRaw,16);\n        if(isNaN(targetVal) || targetVal < 0 || targetVal > 0xFFFFFFFF){\n          throw new Error('Target hex value out of uint32 range');\n        }\n      } else {\n        targetVal = Number(targetRaw);\n        if(!Number.isInteger(targetVal) || targetVal < 0 || targetVal > 0xFFFFFFFF){\n          throw new Error('Target decimal value out of uint32 range');\n        }\n      }\n    } catch(e){\n      collisionStatusEl.textContent = 'Invalid target input: ' + e.message;\n      return;\n    }\n\n    let maxLen = Number(collisionMaxLenEl.value);\n    if(!Number.isInteger(maxLen) || maxLen <1 || maxLen > 8){\n      collisionStatusEl.textContent = 'Max length must be an integer 1 to 8';\n      return;\n    }\n\n    try {\n      currentHashFunc = getHashFunction();\n    } catch(e){\n      collisionStatusEl.textContent = \"Error with selected hash function: \" + e.message;\n      return;\n    }\n\n    collisionSearchRunning = true;\n    runCollisionSearchBtn.disabled = true;\n    stopCollisionSearchBtn.disabled = false;\n    collisionResultsEl.value = '';\n    const showAll = collisionShowAllEl.checked;\n    const asciiOnly = collisionAsciiOnlyEl.checked;\n\n    // We'll accumulate collisions found:\n    const foundCollisions = [];\n\n    try {\n      for await (const collisionBytes of collisionSearchGenerator(targetVal, maxLen, currentHashFunc, asciiOnly,\n          (status)=>{\n            collisionStatusEl.textContent = status + ' | Found: '+foundCollisions.length;\n          })){\n        if(!collisionSearchRunning) break;\n        // Format collision found:\n        let strRep = bytesToString(collisionBytes, asciiOnly);\n        if(!asciiOnly){\n          // Also show ascii fallback with nonprint replaced\n          let asciiFallback = Array.from(collisionBytes).map(b=>{\n            return (b>=32 && b<=126) ? String.fromCharCode(b) : '.';\n          }).join('');\n          strRep += '  | ascii: \"'+asciiFallback+'\"';\n        }\n\n        if(showAll){\n          foundCollisions.push(strRep);\n        } else {\n          if(foundCollisions.length < 5){\n            foundCollisions.push(strRep);\n          }\n        }\n\n        collisionResultsEl.value = foundCollisions.join('\\n');\n      }\n      if(collisionSearchRunning){\n        collisionStatusEl.textContent = 'Search finished. Found ' + foundCollisions.length + ' collisions.';\n      } else {\n        collisionStatusEl.textContent = 'Search stopped by user. Found ' + foundCollisions.length + ' collisions.';\n      }\n    } catch(e){\n      collisionStatusEl.textContent = 'Error during search: ' + e.message;\n    }\n    collisionSearchRunning = false;\n    runCollisionSearchBtn.disabled = false;\n    stopCollisionSearchBtn.disabled = true;\n  });\n\n  stopCollisionSearchBtn.addEventListener('click', ()=>{\n    collisionSearchRunning = false;\n    collisionStatusEl.textContent = 'Stopping search, please wait...';\n    stopCollisionSearchBtn.disabled = true;\n  });\n\n  // Byte extraction from hash output\n\n  extractByteBtn.addEventListener('click', ()=>{\n    if(currentHashValue === null){\n      extractedByteEl.value = '';\n      return;\n    }\n    const offset = Number(byteOffsetEl.value);\n    if(!Number.isInteger(offset) || offset < 0 || offset > 3){\n      extractedByteEl.value = '0';\n      return;\n    }\n    // Extract single byte from 0..3 (LSB=0)\n    const byteVal = (currentHashValue >>> (offset*8)) & 0xFF;\n    extractedByteEl.value = byteVal;\n  });\n\n  // Hash Function Testing Workflow:\n  // This generates a series of inputs by incrementing bytes and shows corresponding hash outputs.\n  // User controls number of steps and bytes stepped.\n\n  generateStepsBtn.addEventListener('click', ()=>{\n    stepsOutputEl.textContent = '';\n    let origText = inputTextEl.value;\n    let bytes;\n    try {\n      bytes = parseInputToBytes(origText, inputHexEl.checked);\n    } catch(e) {\n      stepsOutputEl.textContent = 'Error parsing input: ' + e.message;\n      return;\n    }\n    if(bytes.length === 0){\n      stepsOutputEl.textContent = 'Input byte length must be > 0';\n      return;\n    }\n\n    try {\n      currentHashFunc = getHashFunction();\n    } catch(e){\n      stepsOutputEl.textContent = 'Error with selected hash function: ' + e.message;\n      return;\n    }\n\n    let stepBy = Number(stepByEl.value);\n    let stepRange = Number(stepRangeEl.value);\n    if(!Number.isInteger(stepBy) || stepBy < 1 || stepBy > 4){\n      stepsOutputEl.textContent = 'Step by must be int 1-4';\n      return;\n    }\n    if(!Number.isInteger(stepRange) || stepRange < 1 || stepRange > 256){\n      stepsOutputEl.textContent = 'Step range must be int 1-256';\n      return;\n    }\n\n    // We'll generate a sequence of inputs in which first \"stepBy\" bytes are incremented from 0..stepRange-1\n    // If input shorter than stepBy, we pad with zeros for the steps?\n\n    // Clamp input to length at least stepBy\n    let inputLen = bytes.length;\n    if(inputLen < stepBy){\n      const padded = new Uint8Array(stepBy);\n      padded.set(bytes,0);\n      bytes = padded;\n      inputLen = stepBy;\n    } else {\n      // copy so we don't modify original\n      bytes = bytes.slice(0,inputLen);\n    }\n\n    let outputLines = [];\n    outputLines.push('Index | Input (hex bytes)                 | Hash Dec        | Hash Hex');\n    outputLines.push('-------------------------------------------------------------------------------');\n\n    for(let i=0; i<stepRange; i++){\n      // copy input bytes\n      const currInput = bytes.slice(0,inputLen);\n      // increment first stepBy bytes from i\n      for(let b=0; b<stepBy; b++){\n        let val = ((i + (b * Math.floor(stepRange / stepBy))) % 256);\n        currInput[b] = val;\n      }\n      // compute hash\n      let hval = currentHashFunc(currInput) >>> 0;\n      // format input hex\n      let inputHexStr = Array.from(currInput).map(x=>'0'+x.toString(16).toUpperCase()).map(x=>x.slice(-2)).join(' ');\n      outputLines.push(\n        ('' + i).padStart(5,' ') + ' | ' +\n        inputHexStr.padEnd(30,' ') + ' | ' +\n        String(hval).padEnd(15,' ') + ' | ' +\n        uint32ToHex(hval).toUpperCase()\n        );\n    }\n    stepsOutputEl.textContent = outputLines.join('\\n');\n  });\n\n  // Initialize default hash output\n  updateHashOutputs();\n\n})();\n</script>\n\n</body>\n</html>"
  },
