    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Priority Queue — Visual Demonstration</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071028;\n    --card: rgba(255,255,255,0.04);\n    --glass: rgba(255,255,255,0.03);\n    --accent: linear-gradient(135deg,#7b61ff 0%, #4ad6ff 100%);\n    --muted: rgba(255,255,255,0.65);\n    --glass-border: rgba(255,255,255,0.06);\n    --success: #6ef0a6;\n    --danger: #ff6b6b;\n  }\n\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, system-ui, -apple-system;\n    background: radial-gradient(1200px 500px at 10% 10%, rgba(122,81,255,0.12), transparent),\n                radial-gradient(1000px 400px at 90% 90%, rgba(74,214,255,0.06), transparent),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color: white;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated shapes */\n  .orb{\n    position:absolute;\n    filter:blur(60px) saturate(120%);\n    opacity:0.9;\n    pointer-events:none;\n    mix-blend-mode:screen;\n  }\n  .orb.o1{ width:420px;height:420px; left:-120px; top:-80px; background: radial-gradient(circle,#6f56ff,#4b9bff 60%, transparent 70%); transform:rotate(12deg); animation: floaty 12s ease-in-out infinite; }\n  .orb.o2{ width:340px;height:340px; right:-80px; bottom:-60px; background: radial-gradient(circle,#3fe6ff,#6ef0a6 40%, transparent 65%); animation: floaty 14s ease-in-out infinite reverse; }\n  @keyframes floaty {\n    0%{ transform:translateY(0) rotate(0deg); }\n    50%{ transform:translateY(18px) rotate(6deg); }\n    100%{ transform:translateY(0) rotate(0deg); }\n  }\n\n  /* Container */\n  .wrap{\n    position:relative;\n    max-width:1200px;\n    margin:48px auto;\n    padding:36px;\n    display:grid;\n    grid-template-columns: 420px 1fr;\n    gap:32px;\n    align-items:stretch;\n  }\n\n  /* Info card */\n  .card{\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border-radius:18px;\n    padding:28px;\n    box-shadow: 0 8px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid var(--glass-border);\n    backdrop-filter: blur(6px) saturate(120%);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    min-height:420px;\n  }\n\n  h1{\n    margin:0;\n    font-weight:700;\n    letter-spacing:-0.02em;\n    font-size:30px;\n    background: linear-gradient(90deg,#fff 0%, #dbe9ff 40%, #aef4ff 100%);\n    -webkit-background-clip:text;\n    background-clip:text;\n    color:transparent;\n    text-shadow: 0 6px 30px rgba(79,62,255,0.12);\n  }\n  .subtitle{\n    color:var(--muted);\n    font-size:13px;\n    margin-top:4px;\n  }\n\n  .explain{\n    color:rgba(255,255,255,0.85);\n    font-size:13px;\n    line-height:1.4;\n  }\n\n  .controls{\n    margin-top:auto;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  .btn{\n    appearance:none;\n    border:0;\n    padding:10px 14px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:white;\n    cursor:pointer;\n    box-shadow: 0 6px 16px rgba(12,16,30,0.4);\n    font-weight:600;\n    letter-spacing:0.02em;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    transition: transform .18s cubic-bezier(.2,.9,.3,1), box-shadow .18s;\n    border:1px solid rgba(255,255,255,0.04);\n    user-select:none;\n  }\n  .btn:active{ transform: translateY(2px) scale(0.996); }\n  .btn.play{\n    background: linear-gradient(90deg,#8456ff,#38d7ff);\n    box-shadow: 0 8px 30px rgba(76,61,255,0.18);\n  }\n  .btn.reset{\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n  }\n  .small{\n    font-size:12px;\n    color:var(--muted);\n  }\n\n  /* Visualization area */\n  .vis{\n    position:relative;\n    min-height:420px;\n    border-radius:18px;\n    padding:26px;\n    overflow:hidden;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    box-shadow: 0 10px 50px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n\n  .vis-head{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-bottom:6px;\n  }\n  .vis-title{\n    font-weight:700;\n    letter-spacing:-0.01em;\n    color:linear-gradient(90deg,#fff,#fff);\n    font-size:15px;\n  }\n  .vis-sub{\n    color:var(--muted);\n    font-size:12px;\n  }\n\n  .canvas{\n    position:relative;\n    height:300px;\n    margin-top:12px;\n    perspective:1000px;\n  }\n\n  /* Heap nodes */\n  .node{\n    position:absolute;\n    width:86px;\n    height:86px;\n    border-radius:50%;\n    transform-origin:center center;\n    transition: transform 600ms cubic-bezier(.18,.88,.32,1), box-shadow 300ms ease, opacity 400ms ease;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    will-change:transform, opacity;\n    cursor:default;\n    user-select:none;\n  }\n\n  .node .inner{\n    width:92%;\n    height:92%;\n    border-radius:50%;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-direction:column;\n    color:white;\n    text-shadow: 0 6px 18px rgba(2,8,23,0.4);\n    box-shadow: 0 8px 30px rgba(11,14,40,0.4), inset 0 1px 0 rgba(255,255,255,0.06);\n    border: 1px solid rgba(255,255,255,0.06);\n    transition: transform 400ms ease;\n  }\n\n  .node .label{\n    font-size:11px;\n    opacity:0.86;\n    color:rgba(255,255,255,0.95);\n  }\n  .node .prio{\n    font-size:20px;\n    font-weight:700;\n    margin-top:6px;\n    letter-spacing:-0.02em;\n  }\n\n  /* Highlight for root and swapped nodes */\n  .node.root .inner{\n    box-shadow: 0 12px 40px rgba(74,214,255,0.12), inset 0 1px 0 rgba(255,255,255,0.06);\n    transform: scale(1.03);\n  }\n  .node.swapping{\n    z-index:20;\n    transform:scale(1.05);\n    filter:drop-shadow(0 16px 40px rgba(74,214,255,0.08));\n  }\n\n  /* Underlying array view */\n  .array-view{\n    position:absolute;\n    left:24px;\n    right:24px;\n    bottom:18px;\n    height:72px;\n    display:flex;\n    align-items:center;\n    gap:10px;\n    overflow:hidden;\n  }\n  .cell{\n    min-width:56px;\n    height:56px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-direction:column;\n    color:var(--muted);\n    font-weight:700;\n    transition: transform .3s, box-shadow .3s, opacity .3s;\n  }\n  .cell .cprio{ font-size:13px; color:white; }\n  .cell .cid{ font-size:11px; opacity:0.85; margin-top:4px; color:rgba(255,255,255,0.7); }\n  .cell.empty{\n    opacity:0.18;\n    border-style:dashed;\n  }\n  .cell.root{\n    transform:scale(1.06);\n    box-shadow: 0 10px 30px rgba(74,214,255,0.06);\n  }\n\n  /* tiny legend */\n  .legend{\n    margin-top:6px;\n    display:flex;\n    gap:10px;\n    align-items:center;\n    color:var(--muted);\n    font-size:12px;\n  }\n  .key{\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n    color:var(--muted);\n  }\n  .swatch{\n    width:12px;height:12px;border-radius:4px;\n    background:linear-gradient(90deg,#8456ff,#38d7ff);\n    box-shadow: 0 6px 18px rgba(133,86,255,0.12);\n  }\n\n  /* subtle footer */\n  .foot{\n    margin-top:8px;\n    color:rgba(255,255,255,0.65);\n    font-size:12px;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n  }\n\n  /* Responsive */\n  @media (max-width:980px){\n    .wrap{ grid-template-columns:1fr; padding:20px; gap:18px; }\n    .canvas{ height:260px; }\n    .card{ min-height:360px; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"orb o1\" aria-hidden=\"true\"></div>\n  <div class=\"orb o2\" aria-hidden=\"true\"></div>\n\n  <div class=\"wrap\" role=\"main\">\n    <div class=\"card\" aria-labelledby=\"title\">\n      <div>\n        <h1 id=\"title\">Priority Queue</h1>\n        <div class=\"subtitle\">A visual and aesthetic demonstration of enqueuing and dequeuing by priority</div>\n      </div>\n\n      <p class=\"explain\">\n        A priority queue organizes items so that the element with the highest priority can be extracted first.\n        This demo shows a max-heap implementation: new items are enqueued and bubble up based on priority; when dequeued the top item is removed and the heap rearranges itself.\n        Watch the animated nodes flow into the heap and observe swaps as the structure maintains its invariants.\n      </p>\n\n      <div class=\"legend\" aria-hidden=\"true\">\n        <div class=\"key\"><span class=\"swatch\"></span> Max-Heap (higher number = higher priority)</div>\n        <div class=\"key\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\"><path fill=\"#6ef0a6\" d=\"M12 2L15 9H9L12 2zM12 22l-3-7h6l-3 7z\"/></svg> Highest priority</div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"true\">\n        <button id=\"play\" class=\"btn play\" title=\"Play / Pause animations\" aria-pressed=\"false\">\n          <svg id=\"iconPlay\" viewBox=\"0 0 24 24\" width=\"16\" height=\"16\" fill=\"none\" style=\"transform:translateY(1px)\">\n            <path d=\"M8 5v14l11-7L8 5z\" fill=\"white\"/>\n          </svg>\n          <span id=\"playLabel\">Play</span>\n        </button>\n\n        <button id=\"reset\" class=\"btn reset\" title=\"Reset demonstration\">\n          <svg viewBox=\"0 0 24 24\" width=\"14\" height=\"14\" fill=\"none\">\n            <path d=\"M12 6v2A6 6 0 1 1 6 12\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n            <path d=\"M8 4l-1.5 1.5L8 7\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n          Reset\n        </button>\n\n        <div style=\"flex:1\"></div>\n\n        <div class=\"small\">Operational speed: gentle — optimized for observation</div>\n      </div>\n\n      <div class=\"foot\" aria-hidden=\"true\">\n        <div>Implementation: Binary max-heap • Animated</div>\n        <div>Auto-demo • Limited controls</div>\n      </div>\n    </div>\n\n    <div class=\"vis\" aria-label=\"Visualization area\">\n      <div class=\"vis-head\">\n        <div style=\"flex:1\">\n          <div class=\"vis-title\">Heap View</div>\n          <div class=\"vis-sub\">Tree layout (top is highest priority)</div>\n        </div>\n        <div style=\"text-align:right\">\n          <div style=\"font-weight:700;font-size:14px\">Stateful Array</div>\n          <div class=\"vis-sub\">Underlying heap array (index order)</div>\n        </div>\n      </div>\n\n      <div class=\"canvas\" id=\"canvas\" aria-hidden=\"true\">\n        <!-- nodes will be appended here -->\n        <div class=\"array-view\" id=\"array\"></div>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  Priority Queue Visual Demo\n  - Binary max-heap implementation\n  - Smooth CSS transform animations between positions\n  - Minimal interactions: Play/Pause and Reset\n*/\n\n(() => {\n  const canvas = document.getElementById('canvas');\n  const arrayView = document.getElementById('array');\n  const playBtn = document.getElementById('play');\n  const playLabel = document.getElementById('playLabel');\n  const resetBtn = document.getElementById('reset');\n\n  let heap = []; // array of nodes {id, label, prio, el}\n  let nodesById = new Map();\n  let running = false;\n  let autoLoop = null;\n  let opInProgress = false;\n  let counter = 1;\n\n  // configuration\n  const MAX_NODES = 11;\n  const INSERT_DELAY = 650; // ms between steps in bubble operations\n  const ACTION_DELAY = 1100; // pause between automatic high-level actions\n\n  // compute node positions for tree layout relative to canvas\n  function computePositions() {\n    const rect = canvas.getBoundingClientRect();\n    const width = Math.max(520, rect.width - 48);\n    const topPadding = 12;\n    const levels = Math.ceil(Math.log2(Math.max(1, heap.length + 1)));\n    const positions = [];\n    const maxLevels = Math.max(1, Math.min(levels, 5)); // cap visual levels\n    for (let i = 0; i < heap.length; i++) {\n      const depth = Math.floor(Math.log2(i + 1));\n      const indexInLevel = i - (1 << depth) + 1;\n      const slots = 1 << depth;\n      const gap = width / (slots + 1);\n      const x = Math.round(24 + gap * (indexInLevel + 1) - 43); // center aligning (-width/2)\n      const y = Math.round(topPadding + depth * 84); // vertical spacing\n      positions.push({x, y});\n    }\n    return positions;\n  }\n\n  // create a node DOM element\n  function createNodeElement(node) {\n    const n = document.createElement('div');\n    n.className = 'node';\n    n.dataset.id = node.id;\n\n    const inner = document.createElement('div');\n    inner.className = 'inner';\n    inner.style.background = `linear-gradient(135deg, ${node.color[0]}, ${node.color[1]})`;\n    inner.style.border = '1px solid rgba(255,255,255,0.06)';\n\n    const label = document.createElement('div');\n    label.className = 'label';\n    label.textContent = node.label;\n\n    const prio = document.createElement('div');\n    prio.className = 'prio';\n    prio.textContent = node.prio;\n\n    inner.appendChild(label);\n    inner.appendChild(prio);\n    n.appendChild(inner);\n\n    // accessible title\n    n.setAttribute('aria-hidden','true');\n    canvas.appendChild(n);\n    node.el = n;\n    nodesById.set(node.id, node);\n    return n;\n  }\n\n  // create array cell element\n  function createCell(node) {\n    const c = document.createElement('div');\n    c.className = node ? 'cell' : 'cell empty';\n    if (node) {\n      c.innerHTML = `<div class=\"cprio\">${node.prio}</div><div class=\"cid\">${node.label}</div>`;\n    } else {\n      c.innerHTML = `<div style=\"opacity:.7\">—</div>`;\n    }\n    return c;\n  }\n\n  // apply positions to nodes with CSS transforms\n  function layoutAll(immediate=false) {\n    const positions = computePositions();\n    heap.forEach((node, i) => {\n      const pos = positions[i] || {x:24, y:24};\n      const el = node.el;\n      if (!el) return;\n      // mark root\n      el.classList.toggle('root', i === 0);\n      // set z-index by depth to ensure nice overlapping\n      el.style.zIndex = 100 - Math.floor(Math.log2(i + 1));\n      if (immediate) {\n        el.style.transition = 'none';\n        el.style.transform = `translate(${pos.x}px, ${pos.y}px)`;\n        void el.offsetWidth;\n        el.style.transition = '';\n      } else {\n        el.style.transform = `translate(${pos.x}px, ${pos.y}px)`;\n      }\n    });\n\n    // rebuild array view\n    arrayView.innerHTML = '';\n    heap.forEach((node, i) => {\n      const c = createCell(node);\n      if (i === 0) c.classList.add('root');\n      arrayView.appendChild(c);\n    });\n    // fill rest with empty placeholders for visual clarity\n    for (let k = heap.length; k < 12; k++) {\n      arrayView.appendChild(createCell(null));\n    }\n  }\n\n  // small utility: sleep\n  function sleep(ms){ return new Promise(r => setTimeout(r, ms)); }\n\n  // colors for nodes\n  const palette = [\n    ['#8456ff','#3b6bff'],\n    ['#3be3ff','#59ffc6'],\n    ['#ffb86b','#ff7ab6'],\n    ['#ffd36a','#ff6b6b'],\n    ['#6ef0a6','#32b0ff'],\n    ['#9b8cff','#4ad6ff'],\n  ];\n\n  // generate a new random node\n  function genNode() {\n    const prio = Math.floor(Math.random() * 99) + 1;\n    const id = `N${counter++}`;\n    const label = `Item ${id}`;\n    const color = palette[Math.floor(Math.random()*palette.length)];\n    return {id, label, prio, color, el:null};\n  }\n\n  // bubble up operation with animations\n  async function bubbleUp(idx) {\n    while (idx > 0) {\n      const parent = Math.floor((idx - 1) / 2);\n      if (heap[parent].prio >= heap[idx].prio) break;\n      await animateSwap(parent, idx);\n      idx = parent;\n    }\n  }\n\n  async function bubbleDown(idx) {\n    const n = heap.length;\n    while (true) {\n      const left = idx*2 + 1;\n      const right = idx*2 + 2;\n      let largest = idx;\n      if (left < n && heap[left].prio > heap[largest].prio) largest = left;\n      if (right < n && heap[right].prio > heap[largest].prio) largest = right;\n      if (largest === idx) break;\n      await animateSwap(idx, largest);\n      idx = largest;\n    }\n  }\n\n  // animate swapping two nodes at indices i and j\n  async function animateSwap(i, j) {\n    opInProgress = true;\n    const a = heap[i], b = heap[j];\n    const elA = a.el, elB = b.el;\n    if (!elA || !elB) return;\n    // highlight\n    elA.classList.add('swapping');\n    elB.classList.add('swapping');\n\n    // swap in data\n    [heap[i], heap[j]] = [heap[j], heap[i]];\n    // update layout (CSS transforms will animate)\n    layoutAll();\n\n    // wait for transform to settle\n    await sleep(INSERT_DELAY);\n    elA.classList.remove('swapping');\n    elB.classList.remove('swapping');\n    opInProgress = false;\n  }\n\n  // Enqueue: create element off-screen, then animate to position and bubble up\n  async function enqueue(node) {\n    if (opInProgress) return;\n    opInProgress = true;\n    // append node element, starting from above canvas\n    createNodeElement(node);\n    const el = node.el;\n    el.style.opacity = '0';\n    el.style.transform = `translate(${Math.round(canvas.clientWidth/2 - 43)}px, -120px) scale(.98)`;\n    void el.offsetWidth;\n    await sleep(40);\n    el.style.opacity = '1';\n    // push to heap array (end)\n    heap.push(node);\n    layoutAll();\n    // wait so initial move is visible\n    await sleep(INSERT_DELAY);\n    // bubble up with animations\n    await bubbleUp(heap.length - 1);\n    opInProgress = false;\n  }\n\n  // Dequeue: remove root and animate replacement & bubble down\n  async function dequeue() {\n    if (opInProgress) return;\n    if (heap.length === 0) return;\n    opInProgress = true;\n    // highlight root to remove\n    const root = heap[0];\n    root.el.classList.add('swapping');\n\n    // if only one, just remove\n    if (heap.length === 1) {\n      await sleep(INSERT_DELAY);\n      fadeOutAndRemove(root);\n      heap.splice(0,1);\n      layoutAll();\n      opInProgress = false;\n      return;\n    }\n\n    // swap root with last, animate, then remove last\n    const lastIndex = heap.length - 1;\n    await animateSwap(0, lastIndex);\n    // now pop last (which was root), animate fade-away\n    const removed = heap.pop();\n    // fade out removed element\n    fadeOutAndRemove(removed);\n    await sleep(INSERT_DELAY/1.2);\n    // bubble down replacement at root\n    await bubbleDown(0);\n    opInProgress = false;\n  }\n\n  function fadeOutAndRemove(node) {\n    if (!node || !node.el) return;\n    const el = node.el;\n    el.style.transition = 'transform 400ms ease, opacity 400ms ease';\n    el.style.opacity = '0';\n    el.style.transform = `translate(${parseFloat(getComputedStyle(el).transform.split(',')[4]||0)}px, ${canvas.clientHeight + 120}px) scale(.92)`;\n    setTimeout(()=> {\n      if (el && el.parentNode) el.parentNode.removeChild(el);\n      nodesById.delete(node.id);\n    }, 520);\n  }\n\n  // Automatic demo loop\n  async function demoLoop() {\n    while (running) {\n      if (opInProgress) {\n        await sleep(120);\n        continue;\n      }\n      // choose action: fill up then dequeue\n      if (heap.length < MAX_NODES && Math.random() < 0.85) {\n        await enqueue(genNode());\n      } else {\n        await dequeue();\n      }\n      // brief pause to observe\n      await sleep(ACTION_DELAY);\n    }\n  }\n\n  // Play/Pause toggle\n  function setRunning(state) {\n    running = state;\n    playBtn.setAttribute('aria-pressed', String(state));\n    if (state) {\n      playBtn.classList.add('play');\n      playLabel.textContent = 'Pause';\n      // change icon to pause\n      playBtn.querySelector('#iconPlay').innerHTML = '<path fill=\"white\" d=\"M6 5h4v14H6zM14 5h4v14h-4z\"/>';\n      demoLoop();\n    } else {\n      playBtn.classList.remove('play');\n      playLabel.textContent = 'Play';\n      playBtn.querySelector('#iconPlay').innerHTML = '<path d=\"M8 5v14l11-7L8 5z\" fill=\"white\"/>';\n    }\n  }\n\n  // Reset state\n  function reset() {\n    running = false;\n    setRunning(false);\n    // clear elements\n    heap.forEach(n => {\n      if (n.el && n.el.parentNode) n.el.parentNode.removeChild(n.el);\n    });\n    heap = [];\n    nodesById.clear();\n    counter = 1;\n    layoutAll(true);\n  }\n\n  // initial layout\n  layoutAll(true);\n\n  // event listeners\n  playBtn.addEventListener('click', () => {\n    setRunning(!running);\n  });\n\n  resetBtn.addEventListener('click', () => {\n    reset();\n    // brief playback to demonstrate after reset\n    setTimeout(()=> setRunning(true), 220);\n  });\n\n  // initialize with a few items for starting view\n  (async function seed() {\n    const seeds = [\n      {prio:87}, {prio:36}, {prio:71}, {prio:14}\n    ];\n    for (let s of seeds) {\n      await enqueue(Object.assign(genNode(), {prio: s.prio}));\n      await sleep(260);\n    }\n    // start auto demo after a subtle delay\n    setTimeout(()=> setRunning(true), 800);\n  })();\n\n  // responsive: relayout on resize\n  let resizeTimeout;\n  window.addEventListener('resize', ()=> {\n    clearTimeout(resizeTimeout);\n    resizeTimeout = setTimeout(()=> layoutAll(true), 120);\n  });\n})();\n</script>\n</body>\n</html>"
  },
