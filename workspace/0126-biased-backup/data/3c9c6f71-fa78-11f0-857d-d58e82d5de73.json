    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Symmetric Cryptography - Visual Explanation</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;600&family=JetBrains+Mono:wght@400;700&display=swap');\n\n  /* Root and base styles */\n  :root {\n    --color-primary: #0d3b66;\n    --color-secondary: #faa307;\n    --color-accent: #f48c06;\n    --color-bg: #fdf6f0;\n    --color-text: #1b262c;\n    --color-shadow: rgba(13, 59, 102, 0.15);\n    --animation-duration: 4s;\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: var(--color-bg);\n    color: var(--color-text);\n    font-family: 'Montserrat', sans-serif;\n    overflow-x: hidden;\n  }\n\n  main {\n    max-width: 960px;\n    margin: 5vh auto 8vh;\n    padding: 0 2rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.5rem;\n    margin-bottom: 0.1em;\n    color: var(--color-primary);\n    text-align: center;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    text-shadow: 0 2px 5px #b7ad99aa;\n  }\n\n  h2 {\n    font-weight: 600;\n    font-size: 1.4rem;\n    color: var(--color-secondary);\n    letter-spacing: 0.12em;\n    margin: 0.5em 0 2em;\n    text-align: center;\n  }\n\n  p.description {\n    max-width: 680px;\n    margin: 0 auto 4em;\n    font-weight: 300;\n    font-size: 1.1rem;\n    line-height: 1.7;\n    color: #3e4c59;\n    text-align: center;\n  }\n\n  /* Symmetric Cryptography Visual Container */\n  .visual-container {\n    position: relative;\n    width: 100%;\n    max-width: 860px;\n    aspect-ratio: 16 / 9;\n    margin: 0 auto 3em;\n    background: linear-gradient(135deg, #ffffffdd 0%, #fef9f2dd 100%);\n    border-radius: 24px;\n    box-shadow:\n      0 20px 40px var(--color-shadow),\n      inset 0 0 40px #f0ead9aa,\n      inset 0 -3px 12px #faa30722;\n    overflow: visible;\n  }\n\n  /* Background subtle shapes */\n  .visual-container::before {\n    content: \"\";\n    position: absolute;\n    width: 520px;\n    height: 520px;\n    background: radial-gradient(circle at center, rgba(250,163,7,0.18), transparent 80%);\n    top: 30%;\n    left: 50%;\n    transform: translate(-50%, -50%) rotate(-10deg);\n    filter: blur(88px);\n    z-index: 0;\n  }\n\n  .visual-container::after {\n    content: \"\";\n    position: absolute;\n    width: 380px;\n    height: 380px;\n    background: radial-gradient(circle at center, rgba(13,59,102,0.11), transparent 80%);\n    bottom: 16%;\n    right: 16%;\n    filter: blur(72px);\n    border-radius: 50%;\n    z-index: 0;\n  }\n\n  /* Core symmetric encryption graphic */\n  svg.symmetric-graphic {\n    position: relative;\n    width: 100%;\n    height: 100%;\n    z-index: 1;\n    overflow: visible;\n  }\n\n  /* Common styles */\n  .lock-icon {\n    fill: var(--color-primary);\n    filter: drop-shadow(0 2px 3px #00000015);\n  }\n\n  .key-icon {\n    fill: var(--color-secondary);\n    filter: drop-shadow(0 2px 2px #faa307aa);\n  }\n\n  .arrow {\n    fill: none;\n    stroke: var(--color-accent);\n    stroke-width: 3.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    filter: drop-shadow(0 0 3px var(--color-accent));\n  }\n\n  /* Animation groups */\n  .encryption-group, .decryption-group {\n    transform-origin: center;\n  }\n\n  /* Animate symmetric key pulse */\n  @keyframes pulseKey {\n    0%, 100% {\n      filter: drop-shadow(0 0 4px #faa307cc);\n      transform: scale(1);\n      opacity: 1;\n    }\n    50% {\n      filter: drop-shadow(0 0 10px #faa307ff);\n      transform: scale(1.1);\n      opacity: 0.8;\n    }\n  }\n\n  .symmetric-key {\n    animation: pulseKey 4s ease-in-out infinite;\n    transform-box: fill-box;\n    transform-origin: center;\n  }\n\n  /* Animate arrows flowing */\n  @keyframes arrowFlow {\n    0% {\n      stroke-dashoffset: 100;\n      opacity: 0.6;\n    }\n    50% {\n      stroke-dashoffset: 0;\n      opacity: 1;\n    }\n    100% {\n      stroke-dashoffset: -100;\n      opacity: 0.6;\n    }\n  }\n\n  .arrow-path {\n    stroke-dasharray: 100;\n    animation: arrowFlow 4s linear infinite;\n  }\n\n  /* Encrypted data style */\n  .data-block {\n    fill: var(--color-primary);\n    stroke: var(--color-primary);\n    stroke-width: 2.6;\n    rx: 14;\n    ry: 14;\n    filter:\n      drop-shadow(0 2px 4px #0d3b6625),\n      drop-shadow(0 0 12px #faa30722 inset);\n  }\n\n  .data-text {\n    font-family: 'JetBrains Mono', monospace;\n    font-weight: 700;\n    font-size: 1.3rem;\n    fill: var(--color-bg);\n    letter-spacing: 0.04em;\n    user-select: none;\n    pointer-events: none;\n  }\n\n  /* Simple button container and style */\n  .btn-container {\n    text-align: center;\n    margin-top: 2rem;\n  }\n\n  button.toggle-animate {\n    background: var(--color-primary);\n    border: none;\n    padding: 0.95em 1.9em;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: var(--color-bg);\n    border-radius: 44px;\n    cursor: pointer;\n    box-shadow:\n      0 6px 16px var(--color-shadow),\n      inset 0 -3px 6px #0d3b6611;\n    transition:\n      background-color 0.32s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.32s cubic-bezier(0.4, 0, 0.2, 1),\n      transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);\n    user-select: none;\n  }\n\n  button.toggle-animate:hover {\n    background-color: var(--color-accent);\n    box-shadow:\n      0 10px 24px #faa307cc,\n      inset 0 -4px 8px #faa307dd;\n    transform: translateY(-2px);\n  }\n\n  button.toggle-animate:active {\n    transform: scale(0.97);\n  }\n\n  /* Footer styling */\n  footer {\n    text-align: center;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 300;\n    color: #7a7a7abb;\n    font-size: 0.9rem;\n    margin-bottom: 3vh;\n    user-select: none;\n  }\n\n  /* Tooltip style */\n  .tooltip {\n    position: absolute;\n    background: #faa307;\n    color: #202022dd;\n    font-family: 'JetBrains Mono', monospace;\n    font-weight: 700;\n    font-size: 0.8rem;\n    padding: 0.22em 0.6em;\n    border-radius: 8px;\n    pointer-events: none;\n    opacity: 0;\n    transform: translate(-50%, -130%);\n    transition: opacity 0.3s;\n    mix-blend-mode: multiply;\n    user-select: none;\n  }\n\n  /* Responsive */\n  @media (max-width: 580px) {\n    h1 {\n      font-size: 2.6rem;\n    }\n    h2 {\n      font-size: 1.15rem;\n    }\n    p.description {\n      font-size: 1rem;\n      max-width: 90vw;\n    }\n  }\n\n</style>\n</head>\n<body>\n  <main>\n    <h1>SYMMETRIC CRYPTOGRAPHY</h1>\n    <h2>Secret Key Encryption | Identical Keys for Encrypt & Decrypt</h2>\n    <p class=\"description\">\n      Symmetric cryptography uses a single shared secret key for both encrypting and decrypting data.<br />\n      The same key transforms plaintext into ciphertext and back, ensuring secure communication.<br />\n      This visualization illustrates the fundamental process with elegant design and subtle animations.\n    </p>\n\n    <section aria-label=\"Visual representation of symmetric cryptography\" class=\"visual-container\" role=\"img\" aria-describedby=\"desc1\">\n      <svg class=\"symmetric-graphic\" viewBox=\"0 0 860 484\" aria-hidden=\"true\" focusable=\"false\" >\n        <!-- Left: Plaintext and lock -->\n        <g class=\"encryption-group\" transform=\"translate(130, 242)\">\n          <!-- Lock icon (plaintext security) -->\n          <path class=\"lock-icon\" d=\"M-52 -58a24 24 0 0 1 48 0v30a18 18 0 0 1 18 18v28a18 18 0 0 1-36 0v-28a6 6 0 1 0-12 0v28a30 30 0 0 0 60 0v-28a30 30 0 0 0-30-30v-30z\"></path>\n\n          <!-- Plaintext block -->\n          <rect class=\"data-block\" x=\"-90\" y=\"30\" width=\"120\" height=\"90\" rx=\"14\" ry=\"14\" />\n          <text class=\"data-text\" x=\"-30\" y=\"88\" dominant-baseline=\"middle\" text-anchor=\"middle\">\n            Plaintext\n          </text>\n        </g>\n\n        <!-- Right: Ciphertext (encrypted) and lock -->\n        <g class=\"decryption-group\" transform=\"translate(730, 242)\">\n          <!-- Lock icon (ciphertext) -->\n          <path class=\"lock-icon\" d=\"M-52 -58a24 24 0 0 1 48 0v30a18 18 0 0 1 18 18v28a18 18 0 0 1-36 0v-28a6 6 0 1 0-12 0v28a30 30 0 0 0 60 0v-28a30 30 0 0 0-30-30v-30z\"></path>\n\n          <!-- Ciphertext block -->\n          <rect class=\"data-block\" x=\"-90\" y=\"30\" width=\"120\" height=\"90\" rx=\"14\" ry=\"14\" />\n          <text class=\"data-text\" x=\"-30\" y=\"88\" dominant-baseline=\"middle\" text-anchor=\"middle\" letter-spacing=\"0.03em\">\n            Ciphertext\n          </text>\n        </g>\n\n        <!-- Central symmetric key -->\n        <g class=\"symmetric-key\" transform=\"translate(430, 237) scale(1.1)\">\n          <!-- Key shaft -->\n          <rect x=\"-110\" y=\"-8\" width=\"140\" height=\"16\" rx=\"8\" ry=\"8\" fill=\"none\" stroke=\"url(#keyGradient)\" stroke-width=\"7\" filter=\"drop-shadow(0 1px 3px #faa307bb)\"/>\n          <!-- Key teeth -->\n          <rect x=\"34\" y=\"-8\" width=\"20\" height=\"6\" rx=\"2\" ry=\"2\" fill=\"url(#keyGradient)\"/>\n          <rect x=\"54\" y=\"2\" width=\"12\" height=\"4\" rx=\"2\" ry=\"2\" fill=\"url(#keyGradient)\"/>\n          <!-- Key head circle -->\n          <circle cx=\"-110\" r=\"26\" fill=\"url(#keyGradient)\" filter=\"drop-shadow(0 2px 6px #faa307cc)\"/>\n          <circle cx=\"-110\" r=\"12\" fill=\"var(--color-bg)\" />\n        </g>\n\n        <!-- Key Gradient -->\n        <defs>\n          <linearGradient id=\"keyGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n            <stop offset=\"0%\" stop-color=\"#faa307\" />\n            <stop offset=\"100%\" stop-color=\"#f48c06\" />\n          </linearGradient>\n          <marker id=\"arrowhead\" markerWidth=\"12\" markerHeight=\"9\" refX=\"6\" refY=\"4.5\" orient=\"auto\" fill=\"var(--color-accent)\">\n            <polygon points=\"0 0, 12 4.5, 0 9\"></polygon>\n          </marker>\n        </defs>\n\n        <!-- Encryption arrow: left to center -->\n        <path class=\"arrow arrow-path\" d=\"M70 170 Q210 220 350 220\" marker-end=\"url(#arrowhead)\" />\n\n        <!-- Decryption arrow: center to right -->\n        <path class=\"arrow arrow-path\" d=\"M512 220 Q652 220 780 170\" marker-end=\"url(#arrowhead)\" />\n\n      </svg>\n\n      <!-- Tooltip explanation (hidden by default) -->\n      <div class=\"tooltip\" id=\"tooltip\" style=\"top:0; left:0;\">Symmetric Key</div>\n    </section>\n\n    <div class=\"btn-container\">\n      <button class=\"toggle-animate\" id=\"btnToggle\">Pause Animations</button>\n    </div>\n  </main>\n\n  <footer>© 2024 Visual Cryptography by AI</footer>\n\n<script>\n  (() => {\n    const btn = document.getElementById('btnToggle');\n    let isAnimating = true;\n    const svg = document.querySelector('.symmetric-graphic');\n\n    btn.addEventListener('click', () => {\n      if (isAnimating) {\n        svg.style.animationPlayState = 'paused';\n        svg.querySelectorAll('.symmetric-key').forEach(el => el.style.animationPlayState = 'paused');\n        svg.querySelectorAll('.arrow-path').forEach(el => el.style.animationPlayState = 'paused');\n        btn.textContent = 'Play Animations';\n        isAnimating = false;\n      } else {\n        svg.style.animationPlayState = 'running';\n        svg.querySelectorAll('.symmetric-key').forEach(el => el.style.animationPlayState = 'running');\n        svg.querySelectorAll('.arrow-path').forEach(el => el.style.animationPlayState = 'running');\n        btn.textContent = 'Pause Animations';\n        isAnimating = true;\n      }\n    });\n\n  })();\n</script>\n\n</body>\n</html>"
