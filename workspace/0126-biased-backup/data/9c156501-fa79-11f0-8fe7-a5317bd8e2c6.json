  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Monitor Playground</title>\n  <style>\n    /* Extremely minimal styling: plain black text on white background. */\n    html,body { margin:8px; padding:8px; font-family: monospace; color: #000; background: #fff; }\n    .row { display:flex; gap:12px; align-items:flex-start; }\n    .col { flex:1 1 0; min-width:240px; }\n    fieldset { margin-bottom:8px; padding:8px; }\n    label { display:block; margin-top:6px; }\n    input[type=\"text\"], input[type=\"number\"], select, textarea { width:100%; box-sizing:border-box; }\n    textarea { height:100px; }\n    pre { white-space:pre-wrap; word-wrap:break-word; max-height:240px; overflow:auto; background:transparent; padding:4px; }\n    button { margin:3px 0; }\n    .small { font-size:12px; }\n  </style>\n</head>\n<body>\n  <h1>Monitor Playground</h1>\n\n  <div class=\"row\">\n    <div class=\"col\">\n      <fieldset>\n        <legend>Monitor Collection</legend>\n\n        <label>Name: <input id=\"newName\" type=\"text\" value=\"monitor-1\"></label>\n        <label>Type:\n          <select id=\"newType\">\n            <option value=\"random\">random (0-100)</option>\n            <option value=\"sin\">sine wave</option>\n            <option value=\"counter\">counter</option>\n            <option value=\"static\">static</option>\n          </select>\n        </label>\n\n        <label>Initial Threshold: <input id=\"newThreshold\" type=\"number\" value=\"75\"></label>\n        <label>Sampling Interval (ms): <input id=\"newInterval\" type=\"number\" value=\"1000\"></label>\n        <label>Tags (comma): <input id=\"newTags\" type=\"text\"></label>\n\n        <div>\n          <button id=\"createMonitor\">Create Monitor</button>\n          <button id=\"cloneMonitor\">Clone Selected</button>\n          <button id=\"deleteMonitor\">Delete Selected</button>\n        </div>\n\n        <label>Monitors:\n          <select id=\"monitorSelect\" size=\"6\" style=\"height:120px;\"></select>\n        </label>\n\n        <div>\n          <button id=\"startAll\">Start All</button>\n          <button id=\"stopAll\">Stop All</button>\n          <button id=\"pauseAll\">Pause All</button>\n        </div>\n\n        <div class=\"small\">\n          Use the list to pick a monitor. Create many monitors and experiment with workflows, thresholds, and escalations.\n        </div>\n      </fieldset>\n\n      <fieldset>\n        <legend>Advanced Tools</legend>\n        <label>Import JSON: <textarea id=\"importJson\"></textarea></label>\n        <div>\n          <button id=\"importBtn\">Import</button>\n          <button id=\"exportBtn\">Export Selected</button>\n          <button id=\"exportAllBtn\">Export All</button>\n          <button id=\"saveLocal\">Save to Local</button>\n          <button id=\"loadLocal\">Load from Local</button>\n        </div>\n\n        <label>Undo/Redo: <span id=\"historyState\">0 steps</span></label>\n        <div>\n          <button id=\"undoBtn\">Undo</button>\n          <button id=\"redoBtn\">Redo</button>\n        </div>\n\n        <label>Batch Actions (IDs comma): <input id=\"batchIds\" type=\"text\"></label>\n        <div>\n          <button id=\"batchDisable\">Disable</button>\n          <button id=\"batchEnable\">Enable</button>\n          <button id=\"batchStart\">Start</button>\n          <button id=\"batchStop\">Stop</button>\n        </div>\n      </fieldset>\n    </div>\n\n    <div class=\"col\">\n      <fieldset>\n        <legend>Selected Monitor Configuration</legend>\n\n        <div id=\"noSelection\">No monitor selected.</div>\n\n        <div id=\"configPanel\" style=\"display:none;\">\n          <label>Name: <input id=\"m_name\" type=\"text\"></label>\n          <label>Type:\n            <select id=\"m_type\">\n              <option value=\"random\">random</option>\n              <option value=\"sin\">sin</option>\n              <option value=\"counter\">counter</option>\n              <option value=\"static\">static</option>\n            </select>\n          </label>\n          <label>Enabled: <input id=\"m_enabled\" type=\"checkbox\"></label>\n          <label>Sampling Interval (ms): <input id=\"m_interval\" type=\"number\"></label>\n          <label>Threshold: <input id=\"m_threshold\" type=\"number\"></label>\n          <label>Comparator:\n            <select id=\"m_comparator\">\n              <option value=\">\">&gt;</option>\n              <option value=\"<\">&lt;</option>\n              <option value=\">=\">&ge;</option>\n              <option value=\"<=\">&le;</option>\n              <option value=\"==\">==</option>\n            </select>\n          </label>\n          <label>Aggregation:\n            <select id=\"m_agg\">\n              <option value=\"last\">last</option>\n              <option value=\"avg\">avg</option>\n              <option value=\"max\">max</option>\n              <option value=\"min\">min</option>\n            </select>\n          </label>\n          <label>Tags: <input id=\"m_tags\" type=\"text\"></label>\n          <label>Dependencies (comma IDs): <input id=\"m_deps\" type=\"text\"></label>\n\n          <details>\n            <summary>Escalation Steps (click to open)</summary>\n            <div id=\"escalationList\"></div>\n            <button id=\"addEscStep\">Add Escalation Step</button>\n          </details>\n\n          <div>\n            <button id=\"saveConfigBtn\">Save Configuration</button>\n            <button id=\"applyDefaults\">Apply Defaults</button>\n            <button id=\"resetConfigBtn\">Reset to Last Saved</button>\n          </div>\n        </div>\n      </fieldset>\n\n      <fieldset>\n        <legend>State & Controls</legend>\n        <div id=\"statePanel\" style=\"display:none;\">\n          <div>State: <b id=\"m_state\"></b></div>\n          <div>Current Value: <b id=\"m_value\"></b></div>\n          <div>Last Alert: <b id=\"m_lastAlert\"></b></div>\n\n          <div>\n            <button id=\"startBtn\">Start Simulation</button>\n            <button id=\"stopBtn\">Stop Simulation</button>\n            <button id=\"stepBtn\">Step Once</button>\n            <button id=\"pauseBtn\">Pause</button>\n            <button id=\"resumeBtn\">Resume</button>\n          </div>\n\n          <div>\n            <button id=\"triggerAlertBtn\">Trigger Alert Now</button>\n            <button id=\"ackBtn\">Acknowledge</button>\n            <button id=\"escalateBtn\">Escalate Now</button>\n            <button id=\"resolveBtn\">Resolve</button>\n            <button id=\"disableBtn\">Disable</button>\n            <button id=\"enableBtn\">Enable</button>\n          </div>\n\n          <label>Force State:\n            <select id=\"forceStateSelect\">\n              <option value=\"\">--select--</option>\n              <option value=\"INITIAL\">INITIAL</option>\n              <option value=\"RUNNING\">RUNNING</option>\n              <option value=\"PAUSED\">PAUSED</option>\n              <option value=\"ALERTING\">ALERTING</option>\n              <option value=\"ACKNOWLEDGED\">ACKNOWLEDGED</option>\n              <option value=\"ESCALATED\">ESCALATED</option>\n              <option value=\"RESOLVED\">RESOLVED</option>\n              <option value=\"DISABLED\">DISABLED</option>\n            </select>\n            <button id=\"forceStateBtn\">Apply</button>\n          </label>\n\n          <label>Simulation Speed Multiplier: <input id=\"simSpeed\" type=\"range\" min=\"0.25\" max=\"4\" step=\"0.25\" value=\"1\"></label>\n        </div>\n      </fieldset>\n    </div>\n\n    <div class=\"col\">\n      <fieldset>\n        <legend>Live View & Logs</legend>\n\n        <label>Filters:\n          <label><input type=\"checkbox\" id=\"f_info\" checked>Info</label>\n          <label><input type=\"checkbox\" id=\"f_warn\" checked>Warn</label>\n          <label><input type=\"checkbox\" id=\"f_alert\" checked>Alert</label>\n          <label><input type=\"checkbox\" id=\"f_action\" checked>Action</label>\n        </label>\n\n        <label>Search: <input id=\"logSearch\" type=\"text\"></label>\n        <div>\n          <button id=\"clearLogs\">Clear Logs</button>\n          <button id=\"downloadLogs\">Download Logs</button>\n        </div>\n\n        <label>Event Log:\n          <pre id=\"logArea\"></pre>\n        </label>\n\n        <label>ASCII Sparkline (last 60 samples):\n          <pre id=\"sparkline\" style=\"height:120px;\"></pre>\n        </label>\n\n        <label>Alert History:\n          <select id=\"alertHistory\" size=\"6\" style=\"height:120px;\"></select>\n        </label>\n\n        <div>\n          <label>Replay Index: <input id=\"replayIndex\" type=\"number\" min=\"0\" value=\"0\"></label>\n          <button id=\"replayStep\">Replay Step</button>\n          <button id=\"replayAll\">Replay All</button>\n        </div>\n      </fieldset>\n\n      <fieldset>\n        <legend>Scripted Tests</legend>\n        <label>Condition Tester (value variable available): <input id=\"conditionExpr\" type=\"text\" value=\"value &gt; 80\"></label>\n        <div>\n          <button id=\"testCondition\">Test with Current Value</button>\n          <button id=\"bulkTest\">Bulk Test Range</button>\n        </div>\n\n        <label>Action Simulation (console output): <textarea id=\"actionScript\">// example: run: console.log('alert for', id, value)</textarea></label>\n        <div>\n          <button id=\"runActionScript\">Run Script for Selected</button>\n        </div>\n      </fieldset>\n    </div>\n  </div>\n\n  <script>\n    // Minimal UI, heavy interactivity. Everything kept in this file.\n\n    // Data structures\n    let monitors = {}; // id -> monitor\n    let monitorOrder = [];\n    let selectedId = null;\n    let history = [];\n    let historyIndex = -1;\n\n    // Utility\n    function uid(prefix='m') { return prefix + '-' + Math.random().toString(36).slice(2,9); }\n    function now() { return new Date().toISOString(); }\n    function pushHistory(snapshotLabel) {\n      const snapshot = JSON.stringify({ monitors, monitorOrder });\n      // chop forward if we undid\n      if (historyIndex < history.length - 1) history = history.slice(0, historyIndex + 1);\n      history.push({ snapshot, label: snapshotLabel, time: now() });\n      historyIndex++;\n      updateHistoryUI();\n    }\n    function updateHistoryUI() {\n      document.getElementById('historyState').innerText = history.length + ' snapshots; index ' + historyIndex;\n    }\n    function restoreHistory(index) {\n      if (index < 0 || index >= history.length) return;\n      const state = JSON.parse(history[index].snapshot);\n      monitors = state.monitors;\n      monitorOrder = state.monitorOrder;\n      selectedId = monitorOrder[0] || null;\n      historyIndex = index;\n      rebuildMonitorList();\n      selectMonitor(selectedId);\n      log('info', 'History restored: ' + history[index].label);\n      updateHistoryUI();\n    }\n\n    // Logging\n    const logs = [];\n    function log(level, message, meta = {}) {\n      const entry = { time: now(), level, message, meta };\n      logs.unshift(entry);\n      trimLogs();\n      renderLogs();\n      // Save to monitor-specific log if applicable\n      if (meta.id && monitors[meta.id]) {\n        monitors[meta.id].events = monitors[meta.id].events || [];\n        monitors[meta.id].events.unshift(entry);\n        if (monitors[meta.id].events.length > 500) monitors[meta.id].events.pop();\n      }\n    }\n    function trimLogs() {\n      if (logs.length > 1000) logs.splice(1000);\n    }\n    function renderLogs() {\n      const area = document.getElementById('logArea');\n      const search = document.getElementById('logSearch').value.toLowerCase();\n      const f_info = document.getElementById('f_info').checked;\n      const f_warn = document.getElementById('f_warn').checked;\n      const f_alert = document.getElementById('f_alert').checked;\n      const f_action = document.getElementById('f_action').checked;\n      const filtered = logs.filter(e => {\n        if (search && !(e.message.toLowerCase().includes(search) || JSON.stringify(e.meta).toLowerCase().includes(search))) return false;\n        if (e.level === 'info' && !f_info) return false;\n        if (e.level === 'warn' && !f_warn) return false;\n        if (e.level === 'alert' && !f_alert) return false;\n        if (e.level === 'action' && !f_action) return false;\n        return true;\n      });\n      area.innerText = filtered.map(e => '['+e.time+'] '+e.level.toUpperCase()+': '+e.message + (Object.keys(e.meta).length? ' '+JSON.stringify(e.meta):'')).join('\\n\\n');\n    }\n\n    // Monitor structure default\n    function defaultMonitor(name, type, threshold, interval, tags) {\n      return {\n        id: uid('mon'),\n        name: name || 'monitor',\n        type: type || 'random',\n        enabled: true,\n        interval: interval || 1000,\n        threshold: Number(threshold) || 75,\n        comparator: '>',\n        agg: 'last',\n        tags: tags || [],\n        deps: [],\n        state: 'INITIAL',\n        running: false,\n        paused: false,\n        history: [],\n        samples: [],\n        currentValue: null,\n        events: [],\n        escalation: [], // array of { delayMs, actionType, recipient, condition }\n        escalationTimerIds: [],\n        alertHistory: [],\n        lastAlert: null,\n        simMeta: { t: 0, counter: 0 },\n        intervalHandle: null\n      };\n    }\n\n    // UI wiring\n    function rebuildMonitorList() {\n      const sel = document.getElementById('monitorSelect');\n      sel.innerHTML = '';\n      monitorOrder.forEach(id => {\n        const m = monitors[id];\n        const opt = document.createElement('option');\n        opt.value = id;\n        opt.innerText = id + ' | ' + (m.name || '(no-name)') + ' | ' + m.state + ' | ' + (m.enabled? 'enabled':'disabled');\n        sel.appendChild(opt);\n      });\n    }\n\n    function createMonitorFromForm() {\n      const name = document.getElementById('newName').value || 'monitor';\n      const type = document.getElementById('newType').value;\n      const threshold = Number(document.getElementById('newThreshold').value || 75);\n      const interval = Number(document.getElementById('newInterval').value || 1000);\n      const tags = (document.getElementById('newTags').value || '').split(',').map(s=>s.trim()).filter(Boolean);\n      const m = defaultMonitor(name, type, threshold, interval, tags);\n      monitors[m.id] = m;\n      monitorOrder.unshift(m.id);\n      pushHistory('create ' + m.id);\n      rebuildMonitorList();\n      selectMonitor(m.id);\n      log('info', 'Created monitor ' + m.id, { id: m.id });\n    }\n\n    function selectMonitor(id) {\n      if (!id || !monitors[id]) {\n        selectedId = null;\n        document.getElementById('configPanel').style.display = 'none';\n        document.getElementById('statePanel').style.display = 'none';\n        document.getElementById('noSelection').style.display = 'block';\n        return;\n      }\n      selectedId = id;\n      document.getElementById('noSelection').style.display = 'none';\n      document.getElementById('configPanel').style.display = 'block';\n      document.getElementById('statePanel').style.display = 'block';\n      renderSelectedConfig();\n    }\n\n    function renderSelectedConfig() {\n      const m = monitors[selectedId];\n      if (!m) return;\n      document.getElementById('m_name').value = m.name;\n      document.getElementById('m_type').value = m.type;\n      document.getElementById('m_enabled').checked = m.enabled;\n      document.getElementById('m_interval').value = m.interval;\n      document.getElementById('m_threshold').value = m.threshold;\n      document.getElementById('m_comparator').value = m.comparator || '>';\n      document.getElementById('m_agg').value = m.agg || 'last';\n      document.getElementById('m_tags').value = (m.tags||[]).join(', ');\n      document.getElementById('m_deps').value = (m.deps||[]).join(', ');\n      document.getElementById('m_state').innerText = m.state;\n      document.getElementById('m_value').innerText = Number(m.currentValue).toFixed(2) || '-';\n      document.getElementById('m_lastAlert').innerText = m.lastAlert ? (m.lastAlert.time + ' : ' + m.lastAlert.message) : '-';\n      renderEscalationList();\n      renderSparkline();\n      renderAlertHistory();\n    }\n\n    function renderEscalationList() {\n      const m = monitors[selectedId];\n      const container = document.getElementById('escalationList');\n      container.innerHTML = '';\n      if (!m) return;\n      m.escalation.forEach((step, idx) => {\n        const div = document.createElement('div');\n        div.style.margin = '6px 0';\n        div.innerHTML = 'Step ' + (idx+1) + ': Delay(ms): <input data-idx=\"'+idx+'\" class=\"escDelay\" value=\"'+step.delayMs+'\"> Action: <select data-idx=\"'+idx+'\" class=\"escAction\"><option>log</option><option>email</option><option>sms</option><option>webhook</option><option>script</option></select> Recipient: <input data-idx=\"'+idx+'\" class=\"escRec\" value=\"'+(step.recipient||'')+'\"> Condition: <input data-idx=\"'+idx+'\" class=\"escCond\" value=\"'+(step.condition||'')+'\"> <button data-idx=\"'+idx+'\" class=\"removeEsc\">Remove</button>';\n        container.appendChild(div);\n        // set selects\n        div.querySelector('.escAction').value = step.actionType || 'log';\n      });\n\n      // attach listeners\n      container.querySelectorAll('.escDelay').forEach(el=>{\n        el.addEventListener('change', e=>{\n          const idx = Number(e.target.dataset.idx);\n          const val = Number(e.target.value) || 0;\n          monitors[selectedId].escalation[idx].delayMs = val;\n        });\n      });\n      container.querySelectorAll('.escAction').forEach(el=>{\n        el.addEventListener('change', e=>{\n          const idx = Number(e.target.dataset.idx);\n          monitors[selectedId].escalation[idx].actionType = e.target.value;\n        });\n      });\n      container.querySelectorAll('.escRec').forEach(el=>{\n        el.addEventListener('change', e=>{\n          const idx = Number(e.target.dataset.idx);\n          monitors[selectedId].escalation[idx].recipient = e.target.value;\n        });\n      });\n      container.querySelectorAll('.escCond').forEach(el=>{\n        el.addEventListener('change', e=>{\n          const idx = Number(e.target.dataset.idx);\n          monitors[selectedId].escalation[idx].condition = e.target.value;\n        });\n      });\n      container.querySelectorAll('.removeEsc').forEach(el=>{\n        el.addEventListener('click', e=>{\n          const idx = Number(e.target.dataset.idx);\n          monitors[selectedId].escalation.splice(idx,1);\n          pushHistory('removeEsc ' + selectedId);\n          renderSelectedConfig();\n        });\n      });\n    }\n\n    // Simulation engine\n    function startSimulation(id) {\n      const m = monitors[id];\n      if (!m || m.running || !m.enabled) return;\n      m.running = true;\n      m.paused = false;\n      m.state = 'RUNNING';\n      m.intervalHandle = setInterval(()=>{\n        performSampling(id);\n      }, Math.max(10, m.interval) / Number(document.getElementById('simSpeed').value || 1));\n      pushHistory('start ' + id);\n      log('info', 'Started simulation for ' + id, { id });\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    function stopSimulation(id) {\n      const m = monitors[id];\n      if (!m || !m.running) return;\n      m.running = false;\n      m.paused = false;\n      m.state = 'INITIAL';\n      if (m.intervalHandle) clearInterval(m.intervalHandle);\n      m.intervalHandle = null;\n      // cancel escalation timers\n      m.escalationTimerIds.forEach(t => clearTimeout(t));\n      m.escalationTimerIds = [];\n      pushHistory('stop ' + id);\n      log('info', 'Stopped simulation for ' + id, { id });\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    function pauseSimulation(id) {\n      const m = monitors[id];\n      if (!m || !m.running || m.paused) return;\n      m.paused = true;\n      m.state = 'PAUSED';\n      log('info', 'Paused ' + id, { id });\n      if (m.intervalHandle) clearInterval(m.intervalHandle);\n      m.intervalHandle = null;\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    function resumeSimulation(id) {\n      const m = monitors[id];\n      if (!m || !m.running || !m.paused) return;\n      m.paused = false;\n      m.state = 'RUNNING';\n      m.intervalHandle = setInterval(()=>{\n        performSampling(id);\n      }, Math.max(10, m.interval) / Number(document.getElementById('simSpeed').value || 1));\n      log('info', 'Resumed ' + id, { id });\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    function stepSimulation(id) {\n      const m = monitors[id];\n      if (!m) return;\n      performSampling(id);\n    }\n\n    function performSampling(id) {\n      const m = monitors[id];\n      if (!m || !m.enabled) return;\n      m.simMeta.t += (m.interval/1000);\n      let value;\n      switch (m.type) {\n        case 'random':\n          value = Math.random()*100;\n          break;\n        case 'sin':\n          value = 50 + Math.sin(m.simMeta.t || 0) * 50;\n          break;\n        case 'counter':\n          m.simMeta.counter = (m.simMeta.counter || 0) + 1;\n          value = m.simMeta.counter;\n          break;\n        case 'static':\n          value = Number(m.threshold) * 0.9;\n          break;\n        default:\n          value = Math.random()*100;\n      }\n      // store sample\n      m.samples.unshift(value);\n      if (m.samples.length > 200) m.samples.pop();\n      m.currentValue = value;\n      // compute aggregation\n      let evalValue = value;\n      if (m.agg === 'avg') {\n        const arr = m.samples.slice(0, m.interval ? Math.ceil(60000/m.interval) : 10);\n        evalValue = arr.reduce((a,b)=>a+b,0)/arr.length;\n      } else if (m.agg === 'max') {\n        evalValue = Math.max(...m.samples);\n      } else if (m.agg === 'min') {\n        evalValue = Math.min(...m.samples);\n      }\n\n      log('info', 'Sampled ' + id + ' = ' + evalValue.toFixed(2), { id, value: evalValue });\n\n      // check dependencies\n      if (m.deps && m.deps.some(depId => monitors[depId] && monitors[depId].state === 'ALERTING')) {\n        log('warn', 'Suppressed alert for ' + id + ' due to dependency in ALERTING', { id });\n        // still display sample; no alert\n      } else {\n        // evaluate threshold/comparator\n        if (evaluateComparator(evalValue, m.comparator || '>', m.threshold)) {\n          createAlert(id, evalValue);\n        }\n      }\n\n      // record history\n      m.history.unshift({ time: now(), value: evalValue });\n      if (m.history.length > 1000) m.history.pop();\n      if (selectedId === id) {\n        renderSelectedConfig();\n      }\n    }\n\n    function evaluateComparator(value, comparator, threshold) {\n      threshold = Number(threshold);\n      if (isNaN(threshold)) return false;\n      switch (comparator) {\n        case '>': return value > threshold;\n        case '<': return value < threshold;\n        case '>=': return value >= threshold;\n        case '<=': return value <= threshold;\n        case '==': return value == threshold;\n        default: return value > threshold;\n      }\n    }\n\n    // Alerts and escalation\n    function createAlert(id, value) {\n      const m = monitors[id];\n      if (!m) return;\n      // if already alerting or acknowledged, note occurrence\n      if (m.state === 'ALERTING' || m.state === 'ACKNOWLEDGED' || m.state === 'ESCALATED') {\n        log('warn', 'Alert occurred but monitor already in alerting state: ' + id, { id, value });\n        m.alertHistory.unshift({ time: now(), value, auto: true });\n        m.lastAlert = { time: now(), message: 'Repeated alert value ' + value.toFixed(2) };\n        return;\n      }\n      // create alert\n      m.state = 'ALERTING';\n      const alert = { time: now(), value, id, message: 'Threshold crossed: ' + value.toFixed(2) + ' ' + (m.comparator||'>') + ' ' + m.threshold };\n      m.alertHistory.unshift(alert);\n      m.lastAlert = alert;\n      log('alert', 'ALERT: ' + id + ' -> ' + alert.message, { id, value });\n      // schedule escalation steps if any\n      scheduleEscalationSteps(m);\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    function scheduleEscalationSteps(monitor) {\n      // clear previous timers\n      monitor.escalationTimerIds.forEach(t => clearTimeout(t));\n      monitor.escalationTimerIds = [];\n\n      const esc = monitor.escalation || [];\n      if (!esc.length) return;\n      let cumulative = 0;\n      esc.forEach((step, idx) => {\n        cumulative += Number(step.delayMs || 0);\n        const timer = setTimeout(() => {\n          // if monitor acknowledged or resolved/disabled, stop\n          const cur = monitors[monitor.id];\n          if (!cur) return;\n          if (cur.state === 'ACKNOWLEDGED' || cur.state === 'RESOLVED' || cur.state === 'DISABLED') {\n            log('info', 'Escalation stopped for ' + monitor.id + ' due to state ' + cur.state, { id: monitor.id });\n            return;\n          }\n          // check step condition if present\n          const cond = step.condition;\n          let conditionOk = true;\n          if (cond && cond.trim()) {\n            try {\n              const value = cur.currentValue;\n              conditionOk = safeEvalCondition(cond, value);\n            } catch (e) {\n              conditionOk = false;\n            }\n          }\n          if (!conditionOk) {\n            log('info', 'Escalation step condition false; skipping', { id: monitor.id, step: idx+1, condition: cond });\n            return;\n          }\n          runEscalationAction(monitor.id, idx, step);\n        }, cumulative);\n        monitor.escalationTimerIds.push(timer);\n      });\n    }\n\n    function runEscalationAction(id, stepIdx, step) {\n      const m = monitors[id];\n      if (!m) return;\n      log('action', 'Running escalation step ' + (stepIdx+1) + ' for ' + id + ' action=' + step.actionType, { id, step: stepIdx+1, action: step });\n      // Simulated actions:\n      switch ((step.actionType || 'log')) {\n        case 'log':\n          log('info', 'Escalation log for ' + id + ' recipient=' + (step.recipient||'n/a'), { id, step: stepIdx+1 });\n          break;\n        case 'email':\n          log('action', 'Simulated EMAIL to ' + (step.recipient||'(none)') + ' for ' + id, { id, step: stepIdx+1, recipient: step.recipient });\n          break;\n        case 'sms':\n          log('action', 'Simulated SMS to ' + (step.recipient||'(none)') + ' for ' + id, { id, step: stepIdx+1, recipient: step.recipient });\n          break;\n        case 'webhook':\n          log('action', 'Simulated WEBHOOK ping to ' + (step.recipient||'(url)') + ' for ' + id, { id, step: stepIdx+1, url: step.recipient });\n          break;\n        case 'script':\n          try {\n            const value = m.currentValue;\n            const idLocal = id;\n            // run script in safe sandbox - limited functionality\n            const fnBody = '(function(value,id){' + (step.recipient || '') + '})';\n            const fn = eval(fnBody);\n            fn(value, idLocal);\n            log('action', 'Ran script for ' + id, { id, step: stepIdx+1 });\n          } catch (e) {\n            log('warn', 'Script failed: ' + e.message, { id, step: stepIdx+1 });\n          }\n          break;\n      }\n      // escalate state marker\n      m.state = 'ESCALATED';\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    function safeEvalCondition(expr, value) {\n      // allow simple arithmetic and comparisons with variable 'value'\n      // Block suspicious characters\n      if (/[^-+*/()<>=!&|%.\\d\\svaluetruefalsenull]/i.test(expr)) {\n        throw new Error('Unsafe expression');\n      }\n      // evaluate\n      // eslint-disable-next-line no-new-func\n      return Function('\"use strict\";return (' + expr + ')').call(null, value);\n    }\n\n    function ackAlert(id) {\n      const m = monitors[id];\n      if (!m) return;\n      if (m.state !== 'ALERTING' && m.state !== 'ESCALATED') {\n        log('info', 'Acknowledge called but monitor not in alerting state', { id, state: m.state });\n      }\n      m.state = 'ACKNOWLEDGED';\n      // cancel timers\n      m.escalationTimerIds.forEach(t => clearTimeout(t));\n      m.escalationTimerIds = [];\n      log('info', 'Acknowledged alert for ' + id, { id });\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    function escalateNow(id) {\n      const m = monitors[id];\n      if (!m) return;\n      // run first pending step immediately\n      const esc = m.escalation || [];\n      if (!esc.length) {\n        log('info', 'No escalation steps for ' + id, { id });\n        return;\n      }\n      runEscalationAction(id, 0, esc[0]);\n      log('info', 'Manual escalate invoked for ' + id, { id });\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    function resolveAlert(id) {\n      const m = monitors[id];\n      if (!m) return;\n      m.state = 'RESOLVED';\n      // cancel timers\n      m.escalationTimerIds.forEach(t => clearTimeout(t));\n      m.escalationTimerIds = [];\n      log('info', 'Resolved alert for ' + id, { id });\n      if (selectedId === id) renderSelectedConfig();\n    }\n\n    // UI actions wiring\n    document.getElementById('createMonitor').addEventListener('click', createMonitorFromForm);\n    document.getElementById('monitorSelect').addEventListener('change', (e)=>selectMonitor(e.target.value));\n    document.getElementById('cloneMonitor').addEventListener('click', ()=>{\n      const sel = document.getElementById('monitorSelect').value;\n      if (!sel) return;\n      const orig = monitors[sel];\n      const clone = JSON.parse(JSON.stringify(orig));\n      clone.id = uid('mon');\n      clone.name = clone.name + '-clone';\n      clone.running = false; clone.paused = false;\n      clone.intervalHandle = null;\n      monitors[clone.id] = clone;\n      monitorOrder.unshift(clone.id);\n      pushHistory('clone ' + sel + ' -> ' + clone.id);\n      rebuildMonitorList();\n      selectMonitor(clone.id);\n      log('info', 'Cloned monitor ' + sel + ' to ' + clone.id, { id: clone.id });\n    });\n\n    document.getElementById('deleteMonitor').addEventListener('click', ()=>{\n      const sel = document.getElementById('monitorSelect').value;\n      if (!sel) return;\n      if (monitors[sel] && monitors[sel].intervalHandle) clearInterval(monitors[sel].intervalHandle);\n      delete monitors[sel];\n      monitorOrder = monitorOrder.filter(id => id !== sel);\n      pushHistory('delete ' + sel);\n      rebuildMonitorList();\n      selectMonitor(monitorOrder[0] || null);\n      log('info', 'Deleted monitor ' + sel);\n    });\n\n    // config save/reset\n    document.getElementById('saveConfigBtn').addEventListener('click', ()=>{\n      if (!selectedId) return;\n      const m = monitors[selectedId];\n      m.name = document.getElementById('m_name').value;\n      m.type = document.getElementById('m_type').value;\n      m.enabled = document.getElementById('m_enabled').checked;\n      m.interval = Number(document.getElementById('m_interval').value) || m.interval;\n      m.threshold = Number(document.getElementById('m_threshold').value) || m.threshold;\n      m.comparator = document.getElementById('m_comparator').value;\n      m.agg = document.getElementById('m_agg').value;\n      m.tags = (document.getElementById('m_tags').value || '').split(',').map(s=>s.trim()).filter(Boolean);\n      m.deps = (document.getElementById('m_deps').value || '').split(',').map(s=>s.trim()).filter(Boolean);\n      pushHistory('save ' + selectedId);\n      rebuildMonitorList();\n      renderSelectedConfig();\n      log('info', 'Saved configuration for ' + selectedId, { id: selectedId });\n    });\n\n    document.getElementById('resetConfigBtn').addEventListener('click', ()=>{\n      if (!selectedId) return;\n      renderSelectedConfig();\n      log('info', 'Reset config UI to last saved for ' + selectedId, { id: selectedId });\n    });\n\n    document.getElementById('applyDefaults').addEventListener('click', ()=>{\n      if (!selectedId) return;\n      const m = monitors[selectedId];\n      m.comparator = '>';\n      m.agg = 'last';\n      m.escalation = [{ delayMs:5000, actionType:'email', recipient:'oncall@example.com', condition: '' }];\n      pushHistory('defaults ' + selectedId);\n      renderSelectedConfig();\n      log('info', 'Applied defaults for ' + selectedId, { id: selectedId });\n    });\n\n    // Escalation management\n    document.getElementById('addEscStep').addEventListener('click', ()=>{\n      if (!selectedId) return;\n      monitors[selectedId].escalation.push({ delayMs: 5000, actionType: 'email', recipient: '', condition: '' });\n      pushHistory('addEsc ' + selectedId);\n      renderSelectedConfig();\n    });\n\n    // State & control buttons\n    document.getElementById('startBtn').addEventListener('click', ()=>{ if (selectedId) startSimulation(selectedId); });\n    document.getElementById('stopBtn').addEventListener('click', ()=>{ if (selectedId) stopSimulation(selectedId); });\n    document.getElementById('pauseBtn').addEventListener('click', ()=>{ if (selectedId) pauseSimulation(selectedId); });\n    document.getElementById('resumeBtn').addEventListener('click', ()=>{ if (selectedId) resumeSimulation(selectedId); });\n    document.getElementById('stepBtn').addEventListener('click', ()=>{ if (selectedId) stepSimulation(selectedId); });\n\n    document.getElementById('triggerAlertBtn').addEventListener('click', ()=>{ if (selectedId) createAlert(selectedId, monitors[selectedId].currentValue || 999); });\n    document.getElementById('ackBtn').addEventListener('click', ()=>{ if (selectedId) ackAlert(selectedId); });\n    document.getElementById('escalateBtn').addEventListener('click', ()=>{ if (selectedId) escalateNow(selectedId); });\n    document.getElementById('resolveBtn').addEventListener('click', ()=>{ if (selectedId) resolveAlert(selectedId); });\n    document.getElementById('disableBtn').addEventListener('click', ()=>{ if (selectedId) { monitors[selectedId].enabled = false; monitors[selectedId].state='DISABLED'; stopSimulation(selectedId); pushHistory('disable ' + selectedId); renderSelectedConfig(); } });\n    document.getElementById('enableBtn').addEventListener('click', ()=>{ if (selectedId) { monitors[selectedId].enabled = true; monitors[selectedId].state='INITIAL'; pushHistory('enable ' + selectedId); renderSelectedConfig(); } });\n\n    document.getElementById('forceStateBtn').addEventListener('click', ()=>{\n      if (!selectedId) return;\n      const s = document.getElementById('forceStateSelect').value;\n      if (!s) return;\n      monitors[selectedId].state = s;\n      pushHistory('forceState ' + selectedId + ' -> ' + s);\n      log('info', 'Forced state for ' + selectedId + ' to ' + s, { id: selectedId });\n      renderSelectedConfig();\n    });\n\n    // Global controls\n    document.getElementById('startAll').addEventListener('click', ()=>{ monitorOrder.forEach(id => { if (monitors[id].enabled) startSimulation(id); }); });\n    document.getElementById('stopAll').addEventListener('click', ()=>{ monitorOrder.forEach(id => stopSimulation(id)); });\n    document.getElementById('pauseAll').addEventListener('click', ()=>{ monitorOrder.forEach(id => pauseSimulation(id)); });\n\n    // Export/import\n    document.getElementById('exportBtn').addEventListener('click', ()=>{\n      if (!selectedId) return;\n      const json = JSON.stringify(monitors[selectedId], null, 2);\n      document.getElementById('importJson').value = json;\n      log('info', 'Exported selected monitor JSON to import area', { id: selectedId });\n    });\n    document.getElementById('exportAllBtn').addEventListener('click', ()=>{\n      const json = JSON.stringify({ monitors, monitorOrder }, null, 2);\n      document.getElementById('importJson').value = json;\n      log('info', 'Exported all monitors JSON to import area');\n    });\n    document.getElementById('importBtn').addEventListener('click', ()=>{\n      try {\n        const json = document.getElementById('importJson').value;\n        const obj = JSON.parse(json);\n        if (obj.monitors) {\n          // full import\n          monitors = obj.monitors;\n          monitorOrder = obj.monitorOrder || Object.keys(monitors);\n        } else {\n          // single monitor import\n          const id = obj.id || uid('mon');\n          obj.id = id;\n          monitors[id] = obj;\n          monitorOrder.unshift(id);\n        }\n        pushHistory('import');\n        rebuildMonitorList();\n        selectMonitor(monitorOrder[0] || null);\n        log('info', 'Imported JSON', {});\n      } catch (e) {\n        log('warn', 'Import failed: ' + e.message);\n      }\n    });\n\n    // Local Storage\n    document.getElementById('saveLocal').addEventListener('click', ()=>{\n      localStorage.setItem('monitors', JSON.stringify({ monitors, monitorOrder }));\n      log('info', 'Saved monitors to localStorage');\n    });\n    document.getElementById('loadLocal').addEventListener('click', ()=>{\n      const data = localStorage.getItem('monitors');\n      if (!data) { log('warn', 'No saved monitors in localStorage'); return; }\n      const obj = JSON.parse(data);\n      monitors = obj.monitors || {};\n      monitorOrder = obj.monitorOrder || Object.keys(monitors);\n      pushHistory('loadLocal');\n      rebuildMonitorList();\n      selectMonitor(monitorOrder[0] || null);\n      log('info', 'Loaded monitors from localStorage');\n    });\n\n    // Undo/Redo\n    document.getElementById('undoBtn').addEventListener('click', ()=>{\n      if (historyIndex > 0) {\n        restoreHistory(historyIndex - 1);\n      } else {\n        log('info', 'Nothing to undo');\n      }\n    });\n    document.getElementById('redoBtn').addEventListener('click', ()=>{\n      if (historyIndex < history.length - 1) {\n        restoreHistory(historyIndex + 1);\n      } else {\n        log('info', 'Nothing to redo');\n      }\n    });\n\n    // Batch actions\n    function parseBatchIds() {\n      const s = document.getElementById('batchIds').value || '';\n      return s.split(',').map(x=>x.trim()).filter(Boolean);\n    }\n    document.getElementById('batchDisable').addEventListener('click', ()=>{\n      const ids = parseBatchIds();\n      ids.forEach(id => { if (monitors[id]) { monitors[id].enabled = false; stopSimulation(id); } });\n      pushHistory('batchDisable');\n      log('info', 'Batch disabled: ' + ids.join(','));\n      rebuildMonitorList();\n    });\n    document.getElementById('batchEnable').addEventListener('click', ()=>{\n      const ids = parseBatchIds();\n      ids.forEach(id => { if (monitors[id]) { monitors[id].enabled = true; } });\n      pushHistory('batchEnable');\n      log('info', 'Batch enabled: ' + ids.join(','));\n      rebuildMonitorList();\n    });\n    document.getElementById('batchStart').addEventListener('click', ()=>{\n      const ids = parseBatchIds();\n      ids.forEach(id => { if (monitors[id]) startSimulation(id); });\n      pushHistory('batchStart');\n      log('info', 'Batch start: ' + ids.join(','));\n    });\n    document.getElementById('batchStop').addEventListener('click', ()=>{\n      const ids = parseBatchIds();\n      ids.forEach(id => { if (monitors[id]) stopSimulation(id); });\n      pushHistory('batchStop');\n      log('info', 'Batch stop: ' + ids.join(','));\n    });\n\n    // Live view controls\n    document.getElementById('clearLogs').addEventListener('click', ()=>{ logs.length = 0; renderLogs(); });\n    document.getElementById('downloadLogs').addEventListener('click', ()=>{\n      const blob = new Blob([document.getElementById('logArea').innerText], { type: 'text/plain' });\n      const url = URL.createObjectURL(blob);\n      const a = document.createElement('a');\n      a.href = url; a.download = 'monitor-logs.txt'; a.click(); URL.revokeObjectURL(url);\n    });\n\n    document.getElementById('logSearch').addEventListener('input', renderLogs);\n    ['f_info','f_warn','f_alert','f_action'].forEach(id => document.getElementById(id).addEventListener('change', renderLogs));\n\n    // Alert history view\n    function renderAlertHistory() {\n      const select = document.getElementById('alertHistory');\n      select.innerHTML = '';\n      const m = monitors[selectedId];\n      if (!m) return;\n      m.alertHistory.slice(0,30).forEach(a => {\n        const opt = document.createElement('option');\n        opt.innerText = (a.time || '') + ' | ' + (a.message || JSON.stringify(a));\n        select.appendChild(opt);\n      });\n    }\n\n    // Sparkline ASCII\n    function renderSparkline() {\n      const pre = document.getElementById('sparkline');\n      if (!selectedId) { pre.innerText = ''; return; }\n      const m = monitors[selectedId];\n      const samples = m.samples.slice(0,60).slice().reverse();\n      if (!samples.length) { pre.innerText = '(no samples)'; return; }\n      // normalize to 0-20 height\n      const max = Math.max(...samples);\n      const min = Math.min(...samples);\n      const range = Math.max(1, max - min);\n      const rows = samples.map(v => {\n        const h = Math.round((v - min) / range * 20);\n        return '|' + '█'.repeat(h) + ' '.repeat(20 - h) + '| ' + v.toFixed(1);\n      });\n      pre.innerText = rows.join('\\n');\n    }\n\n    // Replay\n    document.getElementById('replayStep').addEventListener('click', ()=>{\n      const idx = Number(document.getElementById('replayIndex').value) || 0;\n      replayStep(idx);\n    });\n    document.getElementById('replayAll').addEventListener('click', ()=>{\n      const idx = Number(document.getElementById('replayIndex').value) || 0;\n      const m = monitors[selectedId];\n      if (!m) return;\n      const steps = m.history.slice().reverse();\n      let i = idx;\n      const interval = setInterval(()=>{\n        if (i >= steps.length) { clearInterval(interval); return; }\n        const s = steps[i++];\n        log('info', '[REPLAY] ' + selectedId + ' @' + s.time + ' = ' + s.value, { id: selectedId });\n      }, 200);\n    });\n\n    function replayStep(i) {\n      const m = monitors[selectedId];\n      if (!m) return;\n      const steps = m.history.slice().reverse();\n      if (i < 0 || i >= steps.length) { log('warn', 'Replay index out of range'); return; }\n      const s = steps[i];\n      log('info', '[REPLAY STEP] ' + selectedId + ' @' + s.time + ' = ' + s.value, { id: selectedId });\n    }\n\n    // Condition tester\n    document.getElementById('testCondition').addEventListener('click', ()=>{\n      const expr = document.getElementById('conditionExpr').value;\n      const m = monitors[selectedId];\n      const value = m ? m.currentValue : undefined;\n      try {\n        const ok = safeEvalCondition(expr, value);\n        log('info', 'Condition test result: ' + !!ok + ' (value=' + value + ')', { expr, value });\n      } catch (e) {\n        log('warn', 'Condition eval error: ' + e.message);\n      }\n    });\n\n    document.getElementById('bulkTest').addEventListener('click', ()=>{\n      const expr = document.getElementById('conditionExpr').value;\n      const results = [];\n      for (let v = 0; v <= 100; v += 5) {\n        try {\n          const ok = safeEvalCondition(expr, v);\n          if (ok) results.push(v);\n        } catch (e) {}\n      }\n      log('info', 'Bulk test values satisfying condition: ' + results.join(', '), { expr });\n    });\n\n    // Run action script\n    document.getElementById('runActionScript').addEventListener('click', ()=>{\n      const script = document.getElementById('actionScript').value || '';\n      if (!selectedId) return;\n      const m = monitors[selectedId];\n      try {\n        const fn = new Function('value','id','log','meta', script);\n        fn(m.currentValue, selectedId, log, { monitor: m });\n        log('action', 'Ran action script for ' + selectedId, { id: selectedId });\n      } catch (e) {\n        log('warn', 'Action script error: ' + e.message, { id: selectedId });\n      }\n    });\n\n    // Run once: populate initial monitor for convenience\n    (function bootstrap(){\n      const m = defaultMonitor('example-monitor', 'random', 75, 1200, ['example']);\n      monitors[m.id] = m;\n      monitorOrder.unshift(m.id);\n      pushHistory('bootstrap create ' + m.id);\n      rebuildMonitorList();\n      selectMonitor(m.id);\n      log('info', 'Bootstrap monitor created: ' + m.id, { id: m.id });\n    })();\n\n    // Periodic UI updates\n    setInterval(() => {\n      if (selectedId) renderSelectedConfig();\n      renderLogs();\n    }, 800);\n\n    // Safety: before unload, stop all intervals\n    window.addEventListener('beforeunload', ()=> {\n      monitorOrder.forEach(id => { if (monitors[id] && monitors[id].intervalHandle) clearInterval(monitors[id].intervalHandle); });\n    });\n\n    // Simple helper for downloading logs (not used here)\n    function downloadText(filename, text) {\n      const blob = new Blob([text], { type: 'text/plain' });\n      const url = URL.createObjectURL(blob);\n      const a = document.createElement('a'); a.href = url; a.download = filename; a.click(); URL.revokeObjectURL(url);\n    }\n  </script>\n</body>\n</html>"
