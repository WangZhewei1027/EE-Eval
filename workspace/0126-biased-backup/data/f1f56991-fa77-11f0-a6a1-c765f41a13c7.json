    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Graph (Directed) — Aesthetic Visualization</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071028;\n    --card: rgba(255,255,255,0.04);\n    --accent-a: #7b61ff;\n    --accent-b: #00d4ff;\n    --accent-c: #00ffa3;\n    --muted: rgba(255,255,255,0.65);\n    --glass: rgba(255,255,255,0.03);\n    --glass-2: rgba(255,255,255,0.02);\n  }\n\n  /* Page level */\n  html,body{height:100%;margin:0;font-family:Inter, ui-sans-serif, system-ui, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;}\n  body{\n    background:\n      radial-gradient(1200px 600px at 10% 20%, rgba(123,97,255,0.08), transparent 6%),\n      radial-gradient(900px 400px at 90% 80%, rgba(0,212,255,0.03), transparent 8%),\n      linear-gradient(180deg,var(--bg-1),var(--bg-2) 60%);\n    color:var(--muted);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated aurora lines (pure CSS) */\n  .aurora{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    opacity:0.12;\n    mix-blend-mode:screen;\n  }\n  .aurora:before, .aurora:after{\n    content:\"\";\n    position:absolute;\n    height:45vh;\n    width:150%;\n    left:-25%;\n    top:5%;\n    filter:blur(60px);\n    background:linear-gradient(90deg, rgba(123,97,255,0.18), rgba(0,212,255,0.12), rgba(0,255,163,0.08));\n    transform:rotate(-6deg);\n    animation: drift 14s linear infinite;\n    opacity:0.9;\n  }\n  .aurora:after{\n    top:auto; bottom:0;\n    transform:rotate(6deg);\n    animation-duration:18s;\n    opacity:0.7;\n  }\n  @keyframes drift{ from{transform:translateX(-5%) rotate(-6deg)} to{transform:translateX(5%) rotate(-4deg)} }\n\n  /* Main card */\n  .card{\n    width:min(1100px,92vw);\n    height:min(720px,86vh);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:20px;\n    padding:28px;\n    box-shadow:\n      0 10px 30px rgba(2,6,23,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.03);\n    backdrop-filter: blur(8px) saturate(120%);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Header */\n  .header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:12px;\n  }\n  .title{\n    display:flex;\n    gap:18px;\n    align-items:center;\n  }\n  .badge{\n    width:64px;height:64px;border-radius:14px;\n    background:linear-gradient(135deg,var(--accent-a), #3ec6ff 70%);\n    display:grid;place-items:center;\n    box-shadow: 0 6px 20px rgba(123,97,255,0.18), inset 0 -6px 14px rgba(255,255,255,0.06);\n    transform:rotate(-8deg);\n  }\n  .badge svg{filter:drop-shadow(0 6px 18px rgba(0,0,0,0.45));}\n  .heading{\n    display:flex;flex-direction:column;\n    line-height:1;\n  }\n  .heading h1{\n    margin:0;color:linear-gradient(90deg,#fff,#ddd);\n    font-weight:700;font-size:20px;\n    letter-spacing:0.2px;color:#f8fbff;\n    text-shadow:0 2px 20px rgba(123,97,255,0.06);\n  }\n  .heading p{margin:0;margin-top:4px;font-size:13px;color:rgba(255,255,255,0.6)}\n\n  /* Controls */\n  .controls{\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn{\n    --pad:12px 16px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));\n    border:1px solid rgba(255,255,255,0.04);\n    color:var(--muted);\n    padding:var(--pad);\n    border-radius:10px;\n    font-weight:600;\n    font-size:13px;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    cursor:pointer;\n    backdrop-filter: blur(4px);\n    transition:transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n    box-shadow: 0 6px 18px rgba(3,6,23,0.5);\n  }\n  .btn:active{ transform:translateY(1px) scale(0.996); }\n  .btn.secondary{\n    background:transparent;border:1px solid rgba(255,255,255,0.04);\n  }\n  .btn .dot{\n    width:10px;height:10px;border-radius:50%;\n    background:linear-gradient(180deg,var(--accent-b),var(--accent-a));\n    box-shadow:0 4px 12px rgba(0,212,255,0.1), inset 0 -3px 6px rgba(255,255,255,0.05);\n  }\n\n  /* Graph area */\n  .viewer{\n    flex:1;\n    display:flex;\n    gap:18px;\n    align-items:stretch;\n    position:relative;\n  }\n  .canvas{\n    flex:1;\n    border-radius:14px;\n    background:\n      radial-gradient(60% 40% at 9% 12%, rgba(123,97,255,0.03), transparent 6%),\n      linear-gradient(180deg, rgba(255,255,255,0.01), transparent 10%);\n    overflow:hidden;\n    position:relative;\n    padding:20px;\n    border:1px solid rgba(255,255,255,0.02);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* SVG styling */\n  svg{width:100%;height:100%;display:block;overflow:visible;}\n  .edge{\n    fill:none;\n    stroke-width:3.25;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.45));\n    stroke-dasharray:10 12;\n    animation: flow var(--duration,2.2s) linear infinite;\n    transition:opacity .25s ease;\n  }\n\n  @keyframes flow{ to{ stroke-dashoffset: -360; } }\n\n  /* Node visuals */\n  .node-group{ cursor:default; transition:transform .45s cubic-bezier(.2,.9,.2,1); }\n  .node-circle{\n    transition: r .25s ease, fill .25s ease;\n    stroke-width:1.2;\n    stroke:rgba(255,255,255,0.06);\n    filter: drop-shadow(0 10px 30px rgba(0,0,0,0.6));\n  }\n  .node-core{\n    transform-origin:center;\n    animation: pulse 2.6s ease-in-out infinite;\n  }\n  @keyframes pulse{\n    0%{ transform:scale(1); opacity:1; }\n    50%{ transform:scale(1.06); opacity:0.9; }\n    100%{ transform:scale(1); opacity:1; }\n  }\n  .node-label{\n    font-weight:700;\n    font-size:12px;\n    fill:rgba(255,255,255,0.95);\n    pointer-events:none;\n    text-anchor:middle;\n    letter-spacing:0.2px;\n  }\n  .node-sub{\n    font-size:10px;\n    fill:rgba(255,255,255,0.62);\n    pointer-events:none;\n    text-anchor:middle;\n    dy:14;\n  }\n\n  /* Small info column */\n  .info{\n    width:260px;\n    padding:18px;\n    border-radius:12px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n    align-items:flex-start;\n  }\n  .info h3{margin:0;font-size:13px;color:#f8fbff}\n  .legend{\n    display:flex;gap:10px;flex-wrap:wrap;\n  }\n  .legend .item{display:flex;gap:10px;align-items:center;font-size:13px;color:rgba(255,255,255,0.72)}\n  .swatch{width:34px;height:34px;border-radius:8px;display:inline-block;box-shadow:0 6px 20px rgba(0,0,0,0.45)}\n  .muted{font-size:12px;color:rgba(255,255,255,0.5)}\n\n  /* paused state - stop all animations */\n  .paused .edge{ animation-play-state:paused; }\n  .paused .node-core{ animation-play-state:paused; }\n  .paused .aurora{ opacity:0.02; }\n\n  /* Responsive tweaks */\n  @media (max-width:900px){\n    .card{height:88vh;padding:18px;}\n    .info{display:none;}\n  }\n\n  /* micro interactions */\n  .hint{\n    position:absolute;left:28px;bottom:20px;font-size:12px;color:rgba(255,255,255,0.35);\n    display:flex;gap:8px;align-items:center;\n  }\n  .hint .kbd{ background: rgba(255,255,255,0.03); padding:6px 8px;border-radius:6px;border:1px solid rgba(255,255,255,0.02); font-weight:700; font-size:11px; }\n</style>\n</head>\n<body>\n<div class=\"aurora\"></div>\n\n<div class=\"card\" id=\"card\">\n  <div class=\"header\">\n    <div class=\"title\">\n      <div class=\"badge\" aria-hidden=\"true\">\n        <!-- Stylized directed graph glyph -->\n        <svg width=\"34\" height=\"34\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#fff\" stop-opacity=\"0.98\"/>\n              <stop offset=\"1\" stop-color=\"#fff\" stop-opacity=\"0.7\"/>\n            </linearGradient>\n          </defs>\n          <g transform=\"translate(2,2)\" stroke=\"url(#g1)\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <circle cx=\"3\" cy=\"3\" r=\"2.2\" fill=\"#ffffff22\" />\n            <circle cx=\"13\" cy=\"3\" r=\"2.2\" fill=\"#ffffff22\" />\n            <circle cx=\"9\" cy=\"12\" r=\"2.6\" fill=\"#ffffff22\" />\n            <path d=\"M5 3 L11 12 L13 4\" />\n            <path d=\"M11 12 L15 3\" />\n          </g>\n        </svg>\n      </div>\n      <div class=\"heading\">\n        <h1>Graph (Directed)</h1>\n        <p>Elegant visualization of directed graphs — flow, direction, and structure.</p>\n      </div>\n    </div>\n\n    <div class=\"controls\">\n      <button class=\"btn\" id=\"toggleBtn\" title=\"Pause or resume the subtle animations\">\n        <span class=\"dot\" id=\"playDot\" style=\"background:linear-gradient(180deg,var(--accent-b),var(--accent-a));\"></span>\n        <span id=\"toggleLabel\">Pause</span>\n      </button>\n      <button class=\"btn secondary\" id=\"shuffleBtn\" title=\"Subtly reshuffle node positions\">Shuffle</button>\n    </div>\n  </div>\n\n  <div class=\"viewer\">\n    <div class=\"canvas\" aria-hidden=\"false\">\n      <svg id=\"svgRoot\" viewBox=\"0 0 1000 640\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Directed graph visualization\">\n        <defs>\n          <!-- Edge gradient -->\n          <linearGradient id=\"edgeGrad1\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7b61ff\"/>\n            <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n          </linearGradient>\n          <linearGradient id=\"edgeGrad2\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#ff8a65\"/>\n            <stop offset=\"1\" stop-color=\"#ffd166\"/>\n          </linearGradient>\n          <linearGradient id=\"edgeGrad3\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#4be9a1\"/>\n            <stop offset=\"1\" stop-color=\"#00ffa3\"/>\n          </linearGradient>\n\n          <!-- Marker (arrow) -->\n          <marker id=\"arrow\" markerWidth=\"10\" markerHeight=\"10\" refX=\"12\" refY=\"6\" orient=\"auto\" markerUnits=\"strokeWidth\">\n            <path d=\"M2,1 L10,6 L2,11 L4,6 z\" fill=\"#ffffff\" opacity=\"0.95\"></path>\n          </marker>\n\n          <!-- Soft glow filter for nodes -->\n          <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"8\" result=\"coloredBlur\"/>\n            <feMerge>\n              <feMergeNode in=\"coloredBlur\"/>\n              <feMergeNode in=\"SourceGraphic\"/>\n            </feMerge>\n          </filter>\n\n          <!-- Edge glow -->\n          <filter id=\"edgeGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"6\" result=\"b\"/>\n            <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n        </defs>\n\n        <!-- Edges group -->\n        <g id=\"edges\"></g>\n\n        <!-- Nodes group -->\n        <g id=\"nodes\"></g>\n      </svg>\n    </div>\n\n    <aside class=\"info\" aria-hidden=\"true\">\n      <h3>Visual details</h3>\n      <div class=\"legend\">\n        <div class=\"item\"><div class=\"swatch\" style=\"background:linear-gradient(135deg,#7b61ff,#00d4ff)\"></div> <div><strong>Directional Flow</strong><div class=\"muted\">Arrows indicate edge direction</div></div></div>\n        <div class=\"item\"><div class=\"swatch\" style=\"background:linear-gradient(135deg,#4be9a1,#00ffa3)\"></div> <div><strong>Weighted Paths</strong><div class=\"muted\">Stroke & speed reflect weight</div></div></div>\n      </div>\n      <p class=\"muted\">This demonstration focuses on aesthetics and clarity. Controls are intentionally minimal: pause/resume subtle motion and reshuffle node layout. Observe how edges curve, arrows indicate direction, and gradients emphasize flow.</p>\n      <div style=\"height:10px\"></div>\n      <div class=\"muted\">Nodes: 8 • Edges: 12</div>\n    </aside>\n  </div>\n\n  <div class=\"hint\"><div class=\"kbd\">Tip</div> Hover to highlight a node (visual only)</div>\n</div>\n\n<script>\n/* Directed Graph Visual — Aesthetic-focused, minimal interactions\n   - Toggle animations (Play/Pause)\n   - Shuffle node positions (subtle repositioning with smooth tween)\n*/\n\n// Graph definition (small, curated)\nconst nodesData = [\n  { id:\"A\", label:\"A\", sub:\"Start\" },\n  { id:\"B\", label:\"B\", sub:\"Process\" },\n  { id:\"C\", label:\"C\", sub:\"Decision\" },\n  { id:\"D\", label:\"D\", sub:\"I/O\" },\n  { id:\"E\", label:\"E\", sub:\"Worker\" },\n  { id:\"F\", label:\"F\", sub:\"Merge\" },\n  { id:\"G\", label:\"G\", sub:\"Analyze\" },\n  { id:\"H\", label:\"H\", sub:\"Final\" }\n];\n\nconst edgesData = [\n  { source:\"A\", target:\"B\", weight:1.0, grad: \"edgeGrad1\" },\n  { source:\"B\", target:\"C\", weight:0.9, grad: \"edgeGrad1\" },\n  { source:\"C\", target:\"D\", weight:0.8, grad: \"edgeGrad2\" },\n  { source:\"C\", target:\"E\", weight:0.6, grad: \"edgeGrad3\" },\n  { source:\"B\", target:\"F\", weight:0.5, grad: \"edgeGrad2\" },\n  { source:\"E\", target:\"F\", weight:0.7, grad: \"edgeGrad3\" },\n  { source:\"F\", target:\"G\", weight:1.0, grad: \"edgeGrad1\" },\n  { source:\"G\", target:\"H\", weight:0.95, grad: \"edgeGrad3\" },\n  { source:\"D\", target:\"H\", weight:0.7, grad: \"edgeGrad2\" },\n  { source:\"A\", target:\"D\", weight:0.4, grad: \"edgeGrad2\" },\n  { source:\"E\", target:\"B\", weight:0.35, grad: \"edgeGrad1\" },\n  { source:\"G\", target:\"C\", weight:0.25, grad: \"edgeGrad2\" }\n];\n\n// Initial layout: circle-ish with slight randomized radii for aesthetic\nconst width = 1000, height = 640;\nconst center = { x: width/2, y: height/2 };\nconst R = Math.min(width, height) * 0.34;\n\nconst svg = document.getElementById('svgRoot');\nconst edgesLayer = document.getElementById('edges');\nconst nodesLayer = document.getElementById('nodes');\n\nlet nodes = {};\nlet edges = [];\n\n// Create nodes with positions\nfunction initializeNodes() {\n  const n = nodesData.length;\n  nodesData.forEach((nd,i) => {\n    const angle = (i / n) * Math.PI * 2;\n    // vary radius for organic layout\n    const radius = R * (0.88 + (Math.sin(i*1.3)*0.06));\n    const x = center.x + Math.cos(angle) * radius;\n    const y = center.y + Math.sin(angle) * radius * 0.9;\n    nodes[nd.id] = { ...nd, x, y, ix:x, iy:y };\n  });\n}\n\n// Utility to compute curved cubic bezier path between two nodes\nfunction curvePath(sx,sy,tx,ty, curvature=0.25, alt=1) {\n  const dx = tx - sx;\n  const dy = ty - sy;\n  const mx = (sx + tx) / 2;\n  const my = (sy + ty) / 2;\n  // Normal vector\n  let nx = -dy;\n  let ny = dx;\n  // Normalize\n  const mag = Math.sqrt(nx*nx + ny*ny) || 1;\n  nx /= mag; ny /= mag;\n  // Scale curvature a bit based on distance\n  const dist = Math.sqrt(dx*dx + dy*dy);\n  const c = Math.max(36, Math.min(220, dist * curvature)) * (alt || 1);\n  const cx1 = mx + nx * c;\n  const cy1 = my + ny * c;\n  const cx2 = mx - nx * c * 0.6;\n  const cy2 = my - ny * c * 0.6;\n  return `M ${sx},${sy} C ${cx1},${cy1} ${cx2},${cy2} ${tx},${ty}`;\n}\n\n// Build SVG elements\nfunction buildGraph() {\n  // Clear\n  edgesLayer.innerHTML = '';\n  nodesLayer.innerHTML = '';\n  edges = [];\n\n  // create edges (paths)\n  edgesData.forEach((ed,i) => {\n    const s = nodes[ed.source], t = nodes[ed.target];\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('class','edge-wrap');\n    // Path\n    const p = document.createElementNS('http://www.w3.org/2000/svg','path');\n    p.setAttribute('class','edge');\n    p.setAttribute('data-i', i);\n    // color and gradient\n    p.setAttribute('stroke', `url(#${ed.grad})`);\n    p.setAttribute('marker-end','url(#arrow)');\n    p.setAttribute('filter','url(#edgeGlow)');\n    // set variable speed controlled by weight\n    const dur = 1.4 + (1.6 * (1 - Math.min(1, ed.weight || 0.5)));\n    p.style.setProperty('--duration', dur + 's');\n    // stroke-opacity variation\n    p.style.opacity = 0.95 - Math.min(0.45, (1 - (ed.weight || 0.5)));\n    // initial d\n    const alt = (i % 2 === 0) ? 1 : -1;\n    p.setAttribute('d', curvePath(s.x, s.y, t.x, t.y, 0.22, alt));\n    g.appendChild(p);\n\n    // optional subtle inner glow path overlay, thinner, blended\n    const p2 = document.createElementNS('http://www.w3.org/2000/svg','path');\n    p2.setAttribute('d', p.getAttribute('d'));\n    p2.setAttribute('fill','none');\n    p2.setAttribute('stroke', 'rgba(255,255,255,0.06)');\n    p2.setAttribute('stroke-width', 1);\n    p2.setAttribute('opacity', 0.9);\n    p2.setAttribute('style', 'filter: blur(0.2px); mix-blend-mode:screen;');\n    g.appendChild(p2);\n\n    edgesLayer.appendChild(g);\n    edges.push({ data: ed, path: p, overlay: p2, alt });\n  });\n\n  // create nodes\n  Object.values(nodes).forEach(nd => {\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('class','node-group');\n    g.setAttribute('transform', `translate(${nd.x},${nd.y})`);\n    g.setAttribute('data-id', nd.id);\n\n    // outer ring\n    const ring = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    ring.setAttribute('cx', 0);\n    ring.setAttribute('cy', 0);\n    ring.setAttribute('r', 34);\n    ring.setAttribute('fill', 'url(#nodeRing' + nd.id + ')');\n    ring.setAttribute('class', 'node-ring');\n    ring.setAttribute('opacity', 0.045);\n    g.appendChild(ring);\n\n    // decorative gradient for each node via inline defs\n    const gdef = document.createElementNS('http://www.w3.org/2000/svg','defs');\n    const lg = document.createElementNS('http://www.w3.org/2000/svg','linearGradient');\n    lg.setAttribute('id','g' + nd.id);\n    lg.setAttribute('x1','0'); lg.setAttribute('x2','1');\n    const s1 = document.createElementNS('http://www.w3.org/2000/svg','stop'); s1.setAttribute('offset','0'); s1.setAttribute('stop-color','#ffffff'); s1.setAttribute('stop-opacity','0.02');\n    const s2 = document.createElementNS('http://www.w3.org/2000/svg','stop'); s2.setAttribute('offset','1'); s2.setAttribute('stop-color','#ffffff'); s2.setAttribute('stop-opacity','0.0');\n    lg.appendChild(s1); lg.appendChild(s2);\n    gdef.appendChild(lg);\n    g.appendChild(gdef);\n\n    // core circle\n    const core = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    core.setAttribute('cx', 0);\n    core.setAttribute('cy', 0);\n    core.setAttribute('r', 22);\n    core.setAttribute('class', 'node-core node-circle');\n    // gradient fill per node for variety\n    const fillGrad = [\n      'radial-gradient(#7b61ff, #2b1a5f)', // not directly used (CSS), fallback below\n    ];\n    // We'll set fill using a small SVG radial gradient defined inline per node\n    const rg = document.createElementNS('http://www.w3.org/2000/svg','radialGradient');\n    const rgid = 'rg' + nd.id;\n    rg.setAttribute('id', rgid);\n    rg.setAttribute('cx','50%'); rg.setAttribute('cy','40%'); rg.setAttribute('r','70%');\n    const stopA = document.createElementNS('http://www.w3.org/2000/svg','stop');\n    stopA.setAttribute('offset','0%'); stopA.setAttribute('stop-color', pickColor(nd.id, 0));\n    stopA.setAttribute('stop-opacity','0.96');\n    const stopB = document.createElementNS('http://www.w3.org/2000/svg','stop');\n    stopB.setAttribute('offset','100%'); stopB.setAttribute('stop-color', pickColor(nd.id, 1));\n    stopB.setAttribute('stop-opacity','0.9');\n    rg.appendChild(stopA); rg.appendChild(stopB);\n    // append gradient to global defs\n    svg.querySelector('defs').appendChild(rg);\n    core.setAttribute('fill', `url(#${rgid})`);\n    core.setAttribute('stroke','rgba(255,255,255,0.06)');\n    core.style.transition = 'r .24s ease';\n    g.appendChild(core);\n\n    // inner glossy shine\n    const shine = document.createElementNS('http://www.w3.org/2000/svg','ellipse');\n    shine.setAttribute('cx', -6);\n    shine.setAttribute('cy', -8);\n    shine.setAttribute('rx', 10);\n    shine.setAttribute('ry', 6);\n    shine.setAttribute('fill','rgba(255,255,255,0.12)');\n    shine.setAttribute('transform','rotate(-18)');\n    shine.setAttribute('opacity','0.9');\n    g.appendChild(shine);\n\n    // label\n    const t = document.createElementNS('http://www.w3.org/2000/svg','text');\n    t.setAttribute('class','node-label');\n    t.setAttribute('y', 6);\n    t.textContent = nd.label;\n    g.appendChild(t);\n\n    const tsub = document.createElementNS('http://www.w3.org/2000/svg','text');\n    tsub.setAttribute('class','node-sub');\n    tsub.setAttribute('y', 20);\n    tsub.textContent = nd.sub;\n    g.appendChild(tsub);\n\n    // halo blur for focal nodes\n    core.setAttribute('filter','url(#glow)');\n\n    nodesLayer.appendChild(g);\n\n    // store reference\n    nd.el = g;\n    nd.core = core;\n  });\n}\n\n// pick nice gradient colors for nodes based on id\nfunction pickColor(id, pos){\n  const palette = [\n    ['#7b61ff','#3b28a8'],\n    ['#00d4ff','#006b9a'],\n    ['#4be9a1','#00a86b'],\n    ['#ff8a65','#b64b2a'],\n    ['#ffd166','#d8a12f'],\n    ['#b4a0ff','#6b54d8'],\n    ['#7fe0ff','#3ab0d8'],\n    ['#aaffc0','#36b37a']\n  ];\n  const idx = (id.charCodeAt(0) - 65) % palette.length;\n  return palette[idx][pos?1:0];\n}\n\n// update edges based on node positions\nfunction updateEdgePaths() {\n  edges.forEach((e, i) => {\n    const s = nodes[e.data.source];\n    const t = nodes[e.data.target];\n    const d = curvePath(s.x, s.y, t.x, t.y, 0.22, e.alt);\n    e.path.setAttribute('d', d);\n    e.overlay.setAttribute('d', d);\n    // optionally adjust marker scale based on weight (small)\n    // We keep arrow marker static for simplicity\n  });\n}\n\n// initialize and render\ninitializeNodes();\nbuildGraph();\nupdateEdgePaths();\n\n// Interaction handlers (minimal)\nconst card = document.getElementById('card');\nconst toggleBtn = document.getElementById('toggleBtn');\nconst toggleLabel = document.getElementById('toggleLabel');\nlet paused = false;\n\ntoggleBtn.addEventListener('click', () => {\n  paused = !paused;\n  if (paused) {\n    card.classList.add('paused');\n    toggleLabel.textContent = 'Resume';\n    document.getElementById('playDot').style.background = 'linear-gradient(180deg,#555,#333)';\n  } else {\n    card.classList.remove('paused');\n    toggleLabel.textContent = 'Pause';\n    document.getElementById('playDot').style.background = 'linear-gradient(180deg,var(--accent-b),var(--accent-a))';\n  }\n});\n\n// shuffle button — animate to a new layout\nconst shuffleBtn = document.getElementById('shuffleBtn');\nshuffleBtn.addEventListener('click', () => {\n  // compute new target positions using slightly randomized circle + offsets\n  const n = Object.keys(nodes).length;\n  const ids = Object.keys(nodes);\n  const newPositions = {};\n  ids.forEach((id,i) => {\n    const angle = (i / n) * Math.PI * 2 + (Math.random() - 0.5) * 0.6;\n    const radius = R * (0.7 + Math.random() * 0.35);\n    const x = center.x + Math.cos(angle) * radius;\n    const y = center.y + Math.sin(angle) * radius * (0.85 + Math.random()*0.3);\n    newPositions[id] = { x, y };\n  });\n  // animate nodes\n  animatePositions(newPositions, 800);\n});\n\n// animate positions: tween nodes and update edges\nfunction animatePositions(targets, duration = 800) {\n  const start = performance.now();\n  const startPositions = {};\n  Object.keys(targets).forEach(id => {\n    startPositions[id] = { x: nodes[id].x, y: nodes[id].y };\n  });\n  function step(now) {\n    const t = Math.min(1, (now - start) / duration);\n    const ease = easeOutCubic(t);\n    Object.keys(targets).forEach(id => {\n      const s = startPositions[id];\n      const tg = targets[id];\n      nodes[id].x = s.x + (tg.x - s.x) * ease;\n      nodes[id].y = s.y + (tg.y - s.y) * ease;\n      // apply transform\n      nodes[id].el.setAttribute('transform', `translate(${nodes[id].x},${nodes[id].y})`);\n      // also subtly scale focal nodes\n      const scale = 0.98 + 0.04 * Math.sin((nodes[id].x + nodes[id].y + now*0.002)/120);\n      nodes[id].el.style.transformOrigin = 'center';\n    });\n    updateEdgePaths();\n    if (t < 1) requestAnimationFrame(step);\n    else { /* finalize */ }\n  }\n  requestAnimationFrame(step);\n}\n\n// easing\nfunction easeOutCubic(t){ return 1 - Math.pow(1 - t, 3); }\n\n// hover highlight (purely visual, no heavy interactions)\nnodesLayer.addEventListener('mouseover', (evt) => {\n  const g = evt.target.closest && evt.target.closest('.node-group');\n  if (!g) return;\n  // find id\n  const id = g.getAttribute('data-id');\n  // subtle emphasis\n  const nd = nodes[id];\n  if (nd && nd.core){\n    nd.core.setAttribute('r', 26);\n    nd.core.style.filter = 'url(#glow)';\n  }\n  // bring edges connected to/from into focus\n  edges.forEach(e => {\n    if (e.data.source === id || e.data.target === id) {\n      e.path.style.opacity = 1;\n      e.path.style.strokeWidth = 4.2;\n    } else {\n      e.path.style.opacity = 0.18;\n      e.path.style.strokeWidth = 2.1;\n    }\n  });\n});\n\nnodesLayer.addEventListener('mouseout', (evt) => {\n  const g = evt.target.closest && evt.target.closest('.node-group');\n  if (!g) return;\n  const id = g.getAttribute('data-id');\n  const nd = nodes[id];\n  if (nd && nd.core){\n    nd.core.setAttribute('r', 22);\n  }\n  edges.forEach(e => {\n    e.path.style.opacity = 0.95 - Math.min(0.45, (1 - (e.data.weight || 0.5)));\n    e.path.style.strokeWidth = 3.25;\n  });\n});\n\n// subtle ongoing breathing offset for nodes and edge dash offsets\nlet t0 = performance.now();\n(function animateLoop(now){\n  const dt = (now - t0) / 1000;\n  t0 = now;\n  // slight ambient movement when not paused\n  if (!paused){\n    Object.values(nodes).forEach((nd, idx) => {\n      const wobble = 0.6;\n      const nx = Math.cos((now*0.0006) + idx) * wobble;\n      const ny = Math.sin((now*0.0007) + idx*1.3) * wobble;\n      // apply small transform to element (SVG transform separate from that used by shuffle)\n      const tx = nd.x + nx * 6;\n      const ty = nd.y + ny * 6;\n      nd.el.setAttribute('transform', `translate(${tx},${ty})`);\n    });\n    // update edge dashoffset manually for a touch more organic motion\n    edges.forEach((e,i) => {\n      const phase = (now*0.004*(1 + (i%3)*0.15));\n      e.path.style.strokeDashoffset = (phase % 360);\n    });\n    updateEdgePaths();\n  }\n  requestAnimationFrame(animateLoop);\n})(performance.now());\n\n/* Accessibility: keyboard toggle (space) for convenience */\ndocument.addEventListener('keydown', (e) => {\n  if (e.code === 'Space') {\n    e.preventDefault();\n    toggleBtn.click();\n  }\n});\n</script>\n</body>\n</html>"
