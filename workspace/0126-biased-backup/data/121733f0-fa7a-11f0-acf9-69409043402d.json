  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Linear Regression Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 10px;\n  }\n  textarea, input[type=\"number\"], input[type=\"text\"] {\n    font-family: monospace, monospace;\n    font-size: 12px;\n    margin: 3px 0;\n  }\n  button {\n    font-family: monospace, monospace;\n    font-size: 11px;\n    margin: 3px 2px 3px 0;\n  }\n  #plotarea {\n    border: 1px solid black;\n    margin-top: 10px;\n  }\n  label {\n    font-size: 12px;\n  }\n  fieldset {\n    margin-top: 12px;\n    padding: 5px;\n  }\n  legend {\n    font-weight: bold;\n    font-size: 13px;\n  }\n  #log {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    height: 150px;\n    overflow-y: auto;\n    font-size: 11px;\n    margin-top: 10px;\n    padding: 3px;\n  }\n</style>\n</head>\n<body>\n<h1>Linear Regression Explorer</h1>\n\n<!-- Section 1: Data Input and Generation -->\n<fieldset>\n<legend>1. Data Input and Generation</legend>\n<label for=\"datapoints\">Input Data Points (x,y) one per line, comma or space separated:</label><br />\n<textarea id=\"datapoints\" rows=\"8\" cols=\"40\" placeholder=\"Example:\n1,2\n2,3.5\n3,4\"></textarea><br />\n<button id=\"loadDataBtn\">Load Data</button>\n<button id=\"clearDataBtn\">Clear Data</button><br />\n\n<label for=\"autoGenCount\">Auto-generate data points (count): </label>\n<input type=\"number\" id=\"autoGenCount\" value=\"10\" min=\"2\" max=\"100\" step=\"1\" style=\"width:50px\" />\n<label for=\"autoGenSlope\">Slope (m): </label>\n<input type=\"number\" id=\"autoGenSlope\" value=\"2\" step=\"0.1\" style=\"width:50px\" />\n<label for=\"autoGenIntercept\">Intercept (b): </label>\n<input type=\"number\" id=\"autoGenIntercept\" value=\"1\" step=\"0.1\" style=\"width:50px\" />\n<label for=\"autoGenNoise\">Noise SD (optional): </label>\n<input type=\"number\" id=\"autoGenNoise\" value=\"1\" step=\"0.1\" style=\"width:50px\" />\n<button id=\"genDataBtn\">Generate Data</button>\n</fieldset>\n\n<!-- Section 2: Data Visualization & Exploration -->\n<fieldset>\n<legend>2. Data Visualization & Exploration</legend>\n<button id=\"showDataTableBtn\">Show/Hide Data Table</button>\n<button id=\"sortXBtn\">Sort by X</button>\n<button id=\"sortYBtn\">Sort by Y</button>\n<button id=\"clearSortBtn\">Original Order</button>\n\n<div id=\"dataTableContainer\" style=\"display:none; max-height: 150px; overflow-y:auto; margin-top:6px;\">\n<table id=\"dataTable\" border=\"1\" cellspacing=\"0\" cellpadding=\"2\" style=\"border-collapse: collapse; font-size:12px;\">\n<thead><tr><th>Index</th><th>X</th><th>Y</th></tr></thead>\n<tbody></tbody>\n</table>\n</div>\n</fieldset>\n\n<!-- Section 3: Linear Regression Computation -->\n<fieldset>\n<legend>3. Linear Regression Calculation & Fitting</legend>\n\n<label><input type=\"radio\" name=\"method\" value=\"analytic\" checked /> Analytical (Normal Equation)</label>\n<label><input type=\"radio\" name=\"method\" value=\"gradient\" /> Gradient Descent</label><br />\n\n<div id=\"gradientOptions\" style=\"display:none; margin-top:6px;\">\n  <label for=\"gdAlpha\">Learning Rate (α): </label>\n  <input type=\"number\" id=\"gdAlpha\" value=\"0.01\" step=\"0.001\" min=\"0.0001\" max=\"1\" style=\"width:60px\" />\n  <label for=\"gdIter\">Iterations: </label>\n  <input type=\"number\" id=\"gdIter\" value=\"1000\" min=\"1\" max=\"100000\" step=\"1\" style=\"width:60px\" />\n  <label for=\"gdInitM\">Init Slope (m): </label>\n  <input type=\"number\" id=\"gdInitM\" value=\"0\" step=\"0.1\" style=\"width:60px\" />\n  <label for=\"gdInitB\">Init Intercept (b): </label>\n  <input type=\"number\" id=\"gdInitB\" value=\"0\" step=\"0.1\" style=\"width:60px\" /><br />\n  <button id=\"runGDStepBtn\">Run Single Gradient Step</button>\n  <button id=\"runGDFullBtn\">Run Full Gradient Descent</button>\n  <button id=\"stopGDBtn\" disabled>Stop Gradient Descent</button>\n  <button id=\"resetGDBtn\">Reset Gradient Parameters</button>\n</div>\n\n<button id=\"computeRegressionBtn\">Compute Regression</button>\n<button id=\"clearRegressionBtn\">Clear Regression</button>\n\n<div id=\"regressionResult\" style=\"margin-top: 8px; font-size: 12px;\"></div>\n\n</fieldset>\n\n<!-- Section 4: Plot and Interactions -->\n<fieldset>\n<legend>4. Plot and Interactive Fit</legend>\n\n<div>\n  <canvas id=\"plotarea\" width=\"600\" height=\"400\">Canvas not supported</canvas>\n</div>\n\n<label for=\"manualM\">Manual slope (m): </label>\n<input type=\"number\" id=\"manualM\" step=\"0.01\" style=\"width:80px\" />\n<label for=\"manualB\">Manual intercept (b): </label>\n<input type=\"number\" id=\"manualB\" step=\"0.01\" style=\"width:80px\" />\n<button id=\"applyManualFitBtn\">Apply Manual Fit</button>\n<button id=\"resetManualFitBtn\">Reset Manual Fit</button>\n\n<p><small>Drag any data point within plot to move it. Drag fitted line endpoints to adjust slope/intercept.</small></p>\n</fieldset>\n\n<!-- Section 5: Detailed Metrics and Diagnostics -->\n<fieldset>\n<legend>5. Metrics and Diagnostics</legend>\n<button id=\"calcMetricsBtn\" disabled>Calculate Metrics</button>\n<div id=\"metricsOutput\" style=\"white-space: pre-wrap; font-size: 12px; margin-top:4px;\"></div>\n</fieldset>\n\n<!-- Section 6: Export/Import -->\n<fieldset>\n<legend>6. Export / Import</legend>\n<button id=\"exportDataBtn\">Export Data (JSON)</button>\n<button id=\"importDataBtn\">Import Data (JSON)</button>\n<input type=\"file\" id=\"importFileInput\" accept=\".json\" style=\"display:none\" />\n<button id=\"exportRegressionBtn\" disabled>Export Regression Result</button>\n\n<div>\n  <label for=\"importJSONArea\">Paste JSON data here for import:</label><br />\n  <textarea id=\"importJSONArea\" rows=\"4\" cols=\"60\" placeholder='{\"data\":[[x1,y1],[x2,y2],...],\"regression\":{\"m\":val,\"b\":val}}'></textarea><br />\n  <button id=\"importFromTextareaBtn\">Import from Textarea</button>\n</div>\n</fieldset>\n\n<!-- Section Log: Debug and info messages -->\n<fieldset>\n<legend>Log / Info</legend>\n<div id=\"log\"></div>\n</fieldset>\n\n<script>\n(() => {\n  let dataPoints = []; // Array of {x:number,y:number}\n  let originalDataOrder = [];\n  let regressionParams = null; // {m:number,b:number}\n  let manualFit = null; // {m:number,b:number}\n  \n  let gdRunning = false;\n  let gdIntervalId = null;\n  let gdCurrentM = 0;\n  let gdCurrentB = 0;\n  let gdAlpha = 0.01;\n  let gdIterationsTotal = 1000;\n  let gdIterationsDone = 0;\n\n  // Canvas and scaling parameters\n  const canvas = document.getElementById(\"plotarea\");\n  const ctx = canvas.getContext(\"2d\");\n  const margin = 40;\n  const width = canvas.width;\n  const height = canvas.height;\n\n  // Transformation parameters to map data space to canvas space\n  let dataXMin = 0, dataXMax = 10, dataYMin = 0, dataYMax = 10;\n  let scaleX = 1, scaleY = 1;\n\n  // Dragging state\n  let draggedPointIndex = null;\n  let draggingLinePoint = null; // \"start\" or \"end\" line dragging for manual line adjust\n  let dragOffset = {x:0,y:0};\n\n  // Log helper\n  function logMsg(s){\n    const log = document.getElementById(\"log\");\n    log.textContent = s + \"\\n---\\n\" + log.textContent;\n  }\n\n  // Utility: parse data from textarea\n  function parseData(rawText){\n    const lines = rawText.trim().split(/\\r?\\n/);\n    let pts = [];\n    for(let i=0;i<lines.length;i++){\n      const line = lines[i].trim();\n      if(!line) continue;\n      let parts = line.split(/[, \\t]+/);\n      if(parts.length<2) continue;\n      let x=parseFloat(parts[0]);\n      let y=parseFloat(parts[1]);\n      if(isNaN(x) || isNaN(y)){\n        logMsg(\"Ignoring invalid line \"+(i+1)+\": \"+line);\n        continue;\n      }\n      pts.push({x:x,y:y});\n    }\n    return pts;\n  }\n\n  // Utility: update original order backup\n  function backupDataOrder(){\n    originalDataOrder = dataPoints.slice();\n  }\n\n  // Update scaling params for plotting based on current data (plus some margin)\n  function updateScaling(){\n    if(dataPoints.length===0){\n      dataXMin=0; dataXMax=10; dataYMin=0; dataYMax=10; return;\n    }\n    let xs=dataPoints.map(p=>p.x);\n    let ys=dataPoints.map(p=>p.y);\n    dataXMin = Math.min(...xs);\n    dataXMax = Math.max(...xs);\n    dataYMin = Math.min(...ys);\n    dataYMax = Math.max(...ys);\n    if(dataXMax===dataXMin){\n      dataXMax+=1;\n      dataXMin-=1;\n    }\n    if(dataYMax===dataYMin){\n      dataYMax+=1;\n      dataYMin-=1;\n    }\n    // Add margin of 10% on each side\n    let dx = (dataXMax - dataXMin)*0.1;\n    let dy = (dataYMax - dataYMin)*0.1;\n    dataXMin -= dx; dataXMax += dx;\n    dataYMin -= dy; dataYMax += dy;\n\n    scaleX = (width - 2*margin) / (dataXMax - dataXMin);\n    scaleY = (height - 2*margin) / (dataYMax - dataYMin);\n  }\n\n  // Map data x to canvas x coordinate\n  function xToCanvas(x){\n    return margin + (x - dataXMin)*scaleX;\n  }\n  // Map data y to canvas y coordinate (inverted y axis)\n  function yToCanvas(y){\n    return height - margin - (y - dataYMin)*scaleY;\n  }\n  // Map canvas x to data x\n  function canvasToX(cx){\n    return dataXMin + (cx - margin)/scaleX;\n  }\n  // Map canvas y to data y\n  function canvasToY(cy){\n    return dataYMin + (height - margin - cy)/scaleY;\n  }\n\n  // Draw everything: points, fitted line (if any)\n  function redraw(){\n    ctx.clearRect(0,0,width,height);\n    updateScaling();\n\n    // Draw axis\n    ctx.strokeStyle = \"black\";\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    // x-axis\n    let yAxisPixel = yToCanvas(0);\n    if(yAxisPixel < margin || yAxisPixel > height - margin) yAxisPixel = height - margin;\n    ctx.moveTo(margin,yAxisPixel);\n    ctx.lineTo(width - margin, yAxisPixel);\n    // y-axis\n    let xAxisPixel = xToCanvas(0);\n    if(xAxisPixel < margin || xAxisPixel > width - margin) xAxisPixel = margin;\n    ctx.moveTo(xAxisPixel, margin);\n    ctx.lineTo(xAxisPixel, height - margin);\n    ctx.stroke();\n\n    // Draw data points\n    ctx.fillStyle = \"black\";\n    dataPoints.forEach((p,i) => {\n      const cx = xToCanvas(p.x);\n      const cy = yToCanvas(p.y);\n      ctx.beginPath();\n      ctx.arc(cx,cy,5,0,2*Math.PI);\n      ctx.fill();\n      // Draw index for clarity\n      ctx.fillText(i, cx+6, cy-6);\n    });\n\n    // Draw regression line if exists\n    let line = null;\n    if(manualFit){\n      line = manualFit;\n    } else if(regressionParams){\n      line = regressionParams;\n    }\n    if(line){\n      let {m,b} = line;\n      // Compute line endpoints within dataXMin/MAX\n      let x1 = dataXMin;\n      let y1 = m*x1 + b;\n      let x2 = dataXMax;\n      let y2 = m*x2 + b;\n      // Clip y1 and y2 to dataYMin/MAX (optional)\n      // Map to canvas coords\n      let cx1 = xToCanvas(x1);\n      let cy1 = yToCanvas(y1);\n      let cx2 = xToCanvas(x2);\n      let cy2 = yToCanvas(y2);\n      ctx.strokeStyle = \"black\";\n      ctx.lineWidth = 1;\n      ctx.beginPath();\n      ctx.moveTo(cx1,cy1);\n      ctx.lineTo(cx2,cy2);\n      ctx.stroke();\n      // Draw draggable endpoints squares\n      ctx.fillRect(cx1-4, cy1-4, 8, 8);\n      ctx.fillRect(cx2-4, cy2-4, 8, 8);\n    }\n\n    // Draw text - axis scales\n    ctx.fillStyle = \"black\";\n    ctx.font = \"10px monospace\";\n    // X axis ticks\n    let xStep = niceStep(dataXMax - dataXMin);\n    for(let xv = Math.ceil(dataXMin/xStep)*xStep; xv <= dataXMax; xv += xStep){\n      let cx = xToCanvas(xv);\n      ctx.beginPath();\n      ctx.moveTo(cx, height - margin);\n      ctx.lineTo(cx, height - margin + 5);\n      ctx.stroke();\n      ctx.fillText(xv.toFixed(2), cx-10, height - margin + 15);\n    }\n    // Y axis ticks\n    let yStep = niceStep(dataYMax - dataYMin);\n    for(let yv = Math.ceil(dataYMin/yStep)*yStep; yv <= dataYMax; yv += yStep){\n      let cy = yToCanvas(yv);\n      ctx.beginPath();\n      ctx.moveTo(margin-5, cy);\n      ctx.lineTo(margin, cy);\n      ctx.stroke();\n      ctx.fillText(yv.toFixed(2), margin-35, cy+3);\n    }\n  }\n\n  // Nice step utility for axis ticks\n  function niceStep(range){\n    // Choose a nice step size for axis ticks given range\n    let roughStep = range/10;\n    let magnitude = Math.pow(10, Math.floor(Math.log10(roughStep)));\n    let residual = roughStep / magnitude;\n    if(residual >= 5) return 5 * magnitude;\n    else if(residual >= 2) return 2 * magnitude;\n    else return magnitude;\n  }\n\n\n  // Show/hide data table\n  function toggleDataTable(){\n    const container = document.getElementById(\"dataTableContainer\");\n    container.style.display = (container.style.display===\"none\" ? \"block\" : \"none\");\n    if(container.style.display===\"block\"){\n      fillDataTable();\n    }\n  }\n\n  // Fill data table with current data points\n  function fillDataTable(){\n    const tbody = document.querySelector(\"#dataTable tbody\");\n    tbody.innerHTML = \"\";\n    dataPoints.forEach((p,i) => {\n      let row = document.createElement(\"tr\");\n      let idxCell = document.createElement(\"td\");\n      idxCell.textContent = i;\n      let xCell = document.createElement(\"td\");\n      xCell.textContent = p.x.toFixed(4);\n      let yCell = document.createElement(\"td\");\n      yCell.textContent = p.y.toFixed(4);\n      row.appendChild(idxCell);\n      row.appendChild(xCell);\n      row.appendChild(yCell);\n      tbody.appendChild(row);\n    });\n  }\n\n  // Sort data by X ascending\n  function sortByX(){\n    dataPoints.sort((a,b) => a.x - b.x);\n    fillDataTable();\n    redraw();\n  }\n\n  // Sort data by Y ascending\n  function sortByY(){\n    dataPoints.sort((a,b) => a.y - b.y);\n    fillDataTable();\n    redraw();\n  }\n\n  // Restore original data order\n  function resetDataOrder(){\n    if(originalDataOrder.length === dataPoints.length){\n      dataPoints = originalDataOrder.slice();\n    }\n    fillDataTable();\n    redraw();\n  }\n\n  // Clear data points\n  function clearData(){\n    dataPoints = [];\n    originalDataOrder = [];\n    regressionParams = null;\n    manualFit = null;\n    fillDataTable();\n    redraw();\n    document.getElementById(\"regressionResult\").textContent = \"\";\n    document.getElementById(\"metricsOutput\").textContent = \"\";\n    updateComputeMetricsState(false);\n  }\n\n  // Generate data points based on y=mx+b + noise\n  function generateDataPoints(count,m,b,noiseSD){\n    let pts = [];\n    for(let i=0;i<count;i++){\n      let x = i + 1;\n      let noise = noiseSD > 0 ? (randNormal()*noiseSD) : 0;\n      let y = m*x + b + noise;\n      pts.push({x:x,y:y});\n    }\n    return pts;\n  }\n\n  // Random normal distribution using Box-Muller\n  function randNormal(){\n    let u=0,v=0;\n    while(u===0) u = Math.random();\n    while(v===0) v = Math.random();\n    return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);\n  }\n\n  // Compute regression by normal equation\n  function computeAnalyticRegression(){\n    if(dataPoints.length < 2) {\n      alert(\"Need at least 2 points for regression\");\n      return null;\n    }\n    const n = dataPoints.length;\n    let sumX = 0, sumY = 0, sumXX = 0, sumXY = 0;\n    dataPoints.forEach(p => {\n      sumX += p.x;\n      sumY += p.y;\n      sumXX += p.x*p.x;\n      sumXY += p.x*p.y;\n    });\n    let denominator = n*sumXX - sumX*sumX;\n    if(denominator === 0){\n      alert(\"Cannot compute regression (denominator zero)\");\n      return null;\n    }\n    let m = (n*sumXY - sumX*sumY) / denominator;\n    let b = (sumY - m*sumX) / n;\n    logMsg(\"Computed analytical regression: m=\"+m.toFixed(6)+\", b=\"+b.toFixed(6));\n    return {m:m,b:b};\n  }\n\n  // Compute loss (MSE)\n  function computeLoss(m,b){\n    let sumSq = 0;\n    dataPoints.forEach(p => {\n      let yPred = m*p.x + b;\n      let err = p.y - yPred;\n      sumSq += err*err;\n    });\n    return sumSq / dataPoints.length;\n  }\n\n  // Gradient descent single step update\n  function gdStep(m,b,alpha){\n    let n = dataPoints.length;\n    let dm = 0;\n    let db = 0;\n    dataPoints.forEach(p => {\n      let yPred = m*p.x + b;\n      let err = yPred - p.y;\n      dm += err*p.x;\n      db += err;\n    });\n    dm = (2/n)*dm;\n    db = (2/n)*db;\n    let mNext = m - alpha*dm;\n    let bNext = b - alpha*db;\n    return {m:mNext,b:bNext,dm:dm,db:db};\n  }\n\n  // Fill the regression result display\n  function displayRegressionResult(params, method){\n    const div = document.getElementById(\"regressionResult\");\n    if(!params){\n      div.textContent=\"No regression parameters computed.\";\n      return;\n    }\n    let loss = computeLoss(params.m, params.b);\n    div.textContent =\n      (method === \"analytic\" ? \"Analytical Regression Result:\\n\" : \"Gradient Descent Result (after \"+gdIterationsDone+\" iterations):\\n\") +\n      \"Slope (m): \" + params.m.toFixed(6) + \"\\n\" +\n      \"Intercept (b): \" + params.b.toFixed(6) + \"\\n\" +\n      \"Mean Squared Error (MSE): \" + loss.toFixed(6);\n  }\n\n  // Update state for Gradient Descent controls\n  function toggleGDControls(isGD){\n    document.getElementById(\"gradientOptions\").style.display = isGD ? \"block\" : \"none\";\n  }\n\n  // Enable or disable compute regression button\n  function updateComputeRegressionState(enabled){\n    document.getElementById(\"computeRegressionBtn\").disabled = !enabled;\n  }\n\n  function updateComputeMetricsState(enabled){\n    document.getElementById(\"calcMetricsBtn\").disabled = !enabled;\n  }\n\n  // Reset gradient descent parameters to inputs or initial values\n  function resetGDParameters(){\n    gdRunning = false;\n    if(gdIntervalId){\n      clearInterval(gdIntervalId);\n      gdIntervalId = null;\n    }\n    document.getElementById(\"stopGDBtn\").disabled = true;\n    gdAlpha = parseFloat(document.getElementById(\"gdAlpha\").value);\n    gdIterationsTotal = parseInt(document.getElementById(\"gdIter\").value);\n    gdCurrentM = parseFloat(document.getElementById(\"gdInitM\").value);\n    gdCurrentB = parseFloat(document.getElementById(\"gdInitB\").value);\n    gdIterationsDone = 0;\n    logMsg(\"Gradient Descent parameters reset.\");\n  }\n\n  // Run single GD step\n  function runGDStep(){\n    if(dataPoints.length < 2){\n      alert(\"Need at least 2 points for regression.\");\n      return;\n    }\n    if(!gdAlpha || gdAlpha <= 0){\n      alert(\"Learning rate α must be positive.\");\n      return;\n    }\n    const result = gdStep(gdCurrentM, gdCurrentB, gdAlpha);\n    gdCurrentM = result.m;\n    gdCurrentB = result.b;\n    gdIterationsDone++;\n    regressionParams = {m: gdCurrentM, b: gdCurrentB};\n    displayRegressionResult(regressionParams, \"gradient\");\n    updateComputeMetricsState(true);\n    manualFit = null;\n    redraw();\n  }\n\n  // Run full GD loop asynchronously\n  function runGDFull(){\n    if(gdRunning)\n      return;\n    if(dataPoints.length < 2){\n      alert(\"Need at least 2 points for regression.\");\n      return;\n    }\n    gdAlpha = parseFloat(document.getElementById(\"gdAlpha\").value);\n    gdIterationsTotal = parseInt(document.getElementById(\"gdIter\").value);\n    if(gdAlpha <= 0){\n      alert(\"Learning rate α must be positive.\");\n      return;\n    }\n    if(gdIterationsTotal < 1){\n      alert(\"Iterations must be >= 1\");\n      return;\n    }\n    gdRunning = true;\n    gdIterationsDone = 0;\n    document.getElementById(\"stopGDBtn\").disabled = false;\n    document.getElementById(\"runGDFullBtn\").disabled = true;\n    document.getElementById(\"runGDStepBtn\").disabled = true;\n    gdIntervalId = setInterval(() => {\n      const result = gdStep(gdCurrentM, gdCurrentB, gdAlpha);\n      gdCurrentM = result.m;\n      gdCurrentB = result.b;\n      gdIterationsDone++;\n      regressionParams = {m: gdCurrentM, b: gdCurrentB};\n      displayRegressionResult(regressionParams, \"gradient\");\n      manualFit = null;\n      redraw();\n      if(gdIterationsDone >= gdIterationsTotal){\n        gdStop();\n      }\n    }, 10);\n  }\n\n  function gdStop(){\n    gdRunning = false;\n    if(gdIntervalId){\n      clearInterval(gdIntervalId);\n      gdIntervalId = null;\n    }\n    document.getElementById(\"stopGDBtn\").disabled = true;\n    document.getElementById(\"runGDFullBtn\").disabled = false;\n    document.getElementById(\"runGDStepBtn\").disabled = false;\n    logMsg(\"Gradient Descent stopped at iteration \"+gdIterationsDone);\n  }\n\n  // Compute metrics: R2, RMSE, MAE\n  function computeMetrics(m,b){\n    if(dataPoints.length < 2) return null;\n    let yMean = dataPoints.reduce((s,p) => s+p.y,0)/dataPoints.length;\n    let ssTot=0, ssRes=0, absErrSum=0;\n    dataPoints.forEach(p => {\n      let yPred = m*p.x + b;\n      ssTot += (p.y - yMean)*(p.y - yMean);\n      ssRes += (p.y - yPred)*(p.y - yPred);\n      absErrSum += Math.abs(p.y - yPred);\n    });\n    let r2 = 1 - ssRes/ssTot;\n    let rmse = Math.sqrt(ssRes/dataPoints.length);\n    let mae = absErrSum/dataPoints.length;\n    return {\n      R2: r2,\n      RMSE: rmse,\n      MAE: mae\n    };\n  }\n\n  // Handle manual fit application: update regression params and redraw\n  function applyManualFit(){\n    const mval = parseFloat(document.getElementById(\"manualM\").value);\n    const bval = parseFloat(document.getElementById(\"manualB\").value);\n    if(isNaN(mval) || isNaN(bval)){\n      alert(\"Invalid manual slope or intercept.\");\n      return;\n    }\n    manualFit = {m:mval,b:bval};\n    regressionParams = null;\n    updateComputeMetricsState(true);\n    redraw();\n  }\n\n  // Reset manual fit to no manual fit\n  function resetManualFit(){\n    manualFit = null;\n    document.getElementById(\"manualM\").value = \"\";\n    document.getElementById(\"manualB\").value = \"\";\n    redraw();\n  }\n\n  // Update manual M,B inputs from regression / manual fit\n  function updateManualInputs(){\n    let line = manualFit || regressionParams;\n    if(line){\n      document.getElementById(\"manualM\").value = line.m.toFixed(4);\n      document.getElementById(\"manualB\").value = line.b.toFixed(4);\n    } else {\n      document.getElementById(\"manualM\").value = \"\";\n      document.getElementById(\"manualB\").value = \"\";\n    }\n  }\n\n  // Export current data & regression as JSON\n  function exportDataJSON(){\n    let exportObj = {data: dataPoints.slice()};\n    if(regressionParams) exportObj.regression = regressionParams;\n    if(manualFit) exportObj.manualFit = manualFit;\n    let json = JSON.stringify(exportObj, null, 2);\n    downloadTextFile(json, \"linear_regression_data.json\");\n  }\n\n  // Export regression params JSON only\n  function exportRegressionJSON(){\n    if(!regressionParams && !manualFit){\n      alert(\"No regression params to export.\");\n      return;\n    }\n    let exportObj = {};\n    if(manualFit) exportObj = {manualFit: manualFit};\n    else exportObj = {regression: regressionParams};\n    let json = JSON.stringify(exportObj,null,2);\n    downloadTextFile(json, \"linear_regression_params.json\");\n  }\n\n  // Download text file helper\n  function downloadTextFile(text, filename){\n    let blob = new Blob([text], {type:\"text/json\"});\n    let url = URL.createObjectURL(blob);\n    let a = document.createElement(\"a\");\n    a.href = url;\n    a.download = filename;\n    document.body.appendChild(a);\n    a.click();\n    setTimeout(() => {\n      document.body.removeChild(a);\n      URL.revokeObjectURL(url);\n    }, 100);\n  }\n\n  // Import JSON from textarea or file\n  function importJSONText(text){\n    let obj;\n    try{\n      obj = JSON.parse(text);\n    }catch(e){\n      alert(\"Invalid JSON: \"+e.message);\n      return;\n    }\n    if(!obj.data || !Array.isArray(obj.data)){\n      alert(\"JSON does not contain valid 'data' array.\");\n      return;\n    }\n    // Validate points\n    let pts = [];\n    for(let i=0;i<obj.data.length;i++){\n      let item = obj.data[i];\n      if(!Array.isArray(item) || item.length<2){\n        alert(\"Invalid point format at index \"+i);\n        return;\n      }\n      let x = parseFloat(item[0]);\n      let y = parseFloat(item[1]);\n      if(isNaN(x) || isNaN(y)){\n        alert(\"Invalid number in point at index \"+i);\n        return;\n      }\n      pts.push({x:x,y:y});\n    }\n    dataPoints = pts;\n    backupDataOrder();\n    regressionParams=null;\n    manualFit=null;\n    if(obj.regression && typeof obj.regression.m === \"number\" && typeof obj.regression.b === \"number\"){\n      regressionParams = {m: obj.regression.m, b: obj.regression.b};\n    }\n    if(obj.manualFit && typeof obj.manualFit.m === \"number\" && typeof obj.manualFit.b === \"number\"){\n      manualFit = {m: obj.manualFit.m, b: obj.manualFit.b};\n    }\n    fillDataTable();\n    redraw();\n    updateComputeMetricsState(true);\n    updateManualInputs();\n    logMsg(\"Imported data and regression from JSON.\");\n  }\n\n  // Handle file import\n  function handleFileImport(evt){\n    let file = evt.target.files[0];\n    if(!file) return;\n    let reader = new FileReader();\n    reader.onload = function(e){\n      importJSONText(e.target.result);\n    };\n    reader.readAsText(file);\n  }\n\n  // Prepare metrics display\n  function displayMetrics(){\n    let line = manualFit || regressionParams;\n    if(!line){\n      alert(\"No regression parameters to compute metrics for.\");\n      return;\n    }\n    let metrics = computeMetrics(line.m, line.b);\n    if(!metrics){\n      alert(\"Insufficient data points for metrics.\");\n      return;\n    }\n    let txt = \n      \"R² (Coefficient of Determination): \" + metrics.R2.toFixed(6) + \"\\n\" +\n      \"RMSE (Root Mean Squared Error): \" + metrics.RMSE.toFixed(6) + \"\\n\" +\n      \"MAE (Mean Absolute Error): \" + metrics.MAE.toFixed(6);\n    document.getElementById(\"metricsOutput\").textContent = txt;\n  }\n\n  // Event bindings\n\n  document.getElementById(\"loadDataBtn\").addEventListener(\"click\", () => {\n    const rawText = document.getElementById(\"datapoints\").value;\n    let pts = parseData(rawText);\n    if(pts.length < 2){\n      alert(\"Need at least 2 valid data points.\");\n      return;\n    }\n    dataPoints = pts;\n    backupDataOrder();\n    regressionParams = null;\n    manualFit = null;\n    fillDataTable();\n    redraw();\n    updateComputeMetricsState(false);\n    document.getElementById(\"regressionResult\").textContent = \"\";\n    updateManualInputs();\n    logMsg(\"Loaded \" + pts.length + \" data points from input.\");\n  });\n\n  document.getElementById(\"clearDataBtn\").addEventListener(\"click\", () => {\n    clearData();\n    document.getElementById(\"datapoints\").value = \"\";\n    updateComputeMetricsState(false);\n    updateManualInputs();\n    document.getElementById(\"regressionResult\").textContent = \"\";\n    document.getElementById(\"metricsOutput\").textContent = \"\";\n  });\n\n  document.getElementById(\"genDataBtn\").addEventListener(\"click\", () => {\n    let count = parseInt(document.getElementById(\"autoGenCount\").value);\n    let m = parseFloat(document.getElementById(\"autoGenSlope\").value);\n    let b = parseFloat(document.getElementById(\"autoGenIntercept\").value);\n    let noise = parseFloat(document.getElementById(\"autoGenNoise\").value);\n    if(isNaN(count) || count < 2 || count > 100){\n      alert(\"Count must be an integer between 2 and 100.\");\n      return;\n    }\n    if(isNaN(m) || isNaN(b) || isNaN(noise)){\n      alert(\"Slope, intercept, and noise must be numbers.\");\n      return;\n    }\n    dataPoints = generateDataPoints(count,m,b,noise);\n    backupDataOrder();\n    regressionParams = null;\n    manualFit = null;\n    fillDataTable();\n    redraw();\n    updateComputeMetricsState(false);\n    document.getElementById(\"regressionResult\").textContent = \"\";\n    updateManualInputs();\n    logMsg(\"Generated \"+count+\" data points with slope=\"+m+\", intercept=\"+b+\", noise SD=\"+noise);\n  });\n\n  document.getElementById(\"showDataTableBtn\").addEventListener(\"click\", () => {\n    toggleDataTable();\n  });\n\n  document.getElementById(\"sortXBtn\").addEventListener(\"click\", () => {\n    sortByX();\n  });\n\n  document.getElementById(\"sortYBtn\").addEventListener(\"click\", () => {\n    sortByY();\n  });\n\n  document.getElementById(\"clearSortBtn\").addEventListener(\"click\", () => {\n    resetDataOrder();\n  });\n\n  // Regression method toggles\n  const methodInputs = document.querySelectorAll(\"input[name=method]\");\n  methodInputs.forEach(input => {\n    input.addEventListener(\"change\", e => {\n      toggleGDControls(e.target.value === \"gradient\");\n      resetGDParameters();\n    });\n  });\n\n  // Compute regression button\n  document.getElementById(\"computeRegressionBtn\").addEventListener(\"click\", () => {\n    if(dataPoints.length < 2){\n      alert(\"Need at least 2 data points.\");\n      return;\n    }\n    let method = document.querySelector(\"input[name=method]:checked\").value;\n    if(method === \"analytic\"){\n      regressionParams = computeAnalyticRegression();\n      manualFit = null;\n      if(regressionParams){\n        displayRegressionResult(regressionParams, \"analytic\");\n        updateComputeMetricsState(true);\n        redraw();\n        updateManualInputs();\n      }\n    } else if(method === \"gradient\"){\n      resetGDParameters();\n      gdAlpha = parseFloat(document.getElementById(\"gdAlpha\").value);\n      gdIterationsTotal = parseInt(document.getElementById(\"gdIter\").value);\n      gdCurrentM = parseFloat(document.getElementById(\"gdInitM\").value);\n      gdCurrentB = parseFloat(document.getElementById(\"gdInitB\").value);\n      gdIterationsDone = 0;\n      regressionParams = {m: gdCurrentM, b: gdCurrentB};\n      manualFit = null;\n      // Just run one step automatically\n      runGDStep();\n    }\n  });\n\n  // Clear regression\n  document.getElementById(\"clearRegressionBtn\").addEventListener(\"click\", () => {\n    regressionParams = null;\n    manualFit = null;\n    document.getElementById(\"regressionResult\").textContent = \"\";\n    updateComputeMetricsState(false);\n    updateManualInputs();\n    redraw();\n  });\n\n  // Gradient Descent step controls\n  document.getElementById(\"runGDStepBtn\").addEventListener(\"click\", () => {\n    runGDStep();\n  });\n\n  document.getElementById(\"runGDFullBtn\").addEventListener(\"click\", () => {\n    runGDFull();\n  });\n\n  document.getElementById(\"stopGDBtn\").addEventListener(\"click\", () => {\n    gdStop();\n  });\n\n  document.getElementById(\"resetGDBtn\").addEventListener(\"click\", () => {\n    resetGDParameters();\n    redraw();\n    displayRegressionResult({m:gdCurrentM,b:gdCurrentB}, \"gradient\");\n  });\n\n  // Manual fit controls\n  document.getElementById(\"applyManualFitBtn\").addEventListener(\"click\", () => {\n    applyManualFit();\n  });\n  document.getElementById(\"resetManualFitBtn\").addEventListener(\"click\", () => {\n    resetManualFit();\n  });\n\n  // Metrics button\n  document.getElementById(\"calcMetricsBtn\").addEventListener(\"click\", () => {\n    displayMetrics();\n  });\n\n  // Export/import controls\n  document.getElementById(\"exportDataBtn\").addEventListener(\"click\", () => {\n    if(dataPoints.length === 0){\n      alert(\"No data points to export.\");\n      return;\n    }\n    exportDataJSON();\n  });\n\n  document.getElementById(\"exportRegressionBtn\").addEventListener(\"click\", () => {\n    exportRegressionJSON();\n  });\n\n  document.getElementById(\"importDataBtn\").addEventListener(\"click\", () => {\n    document.getElementById(\"importFileInput\").click();\n  });\n\n  document.getElementById(\"importFileInput\").addEventListener(\"change\", (e) => {\n    handleFileImport(e);\n  });\n\n  document.getElementById(\"importFromTextareaBtn\").addEventListener(\"click\", () => {\n    let jsonText = document.getElementById(\"importJSONArea\").value;\n    if(!jsonText.trim()){\n      alert(\"Paste JSON data first.\");\n      return;\n    }\n    importJSONText(jsonText);\n  });\n\n  // Canvas interactive dragging logic\n\n  // To detect if click is on point or line endpoint\n  function posHitTest(px, py, cx, cy, radius=7){\n    return Math.sqrt((px-cx)**2+(py-cy)**2) <= radius;\n  }\n\n  // On mousedown, we check if user clicked a point or line endpoint to drag\n  canvas.addEventListener(\"mousedown\", e => {\n    const rect = canvas.getBoundingClientRect();\n    const mx = e.clientX - rect.left;\n    const my = e.clientY - rect.top;\n    draggedPointIndex = null;\n    draggingLinePoint = null;\n\n    // Check data points first\n    for(let i=0; i<dataPoints.length; i++){\n      let p = dataPoints[i];\n      let cx = xToCanvas(p.x);\n      let cy = yToCanvas(p.y);\n      if(posHitTest(mx,my,cx,cy,7)){\n        draggedPointIndex = i;\n        dragOffset.x = cx - mx;\n        dragOffset.y = cy - my;\n        logMsg(\"Dragging data point \"+i);\n        return;\n      }\n    }\n\n    // Check line endpoints (manualFit or regressionParams)\n    let line = manualFit || regressionParams;\n    if(line){\n      let {m,b} = line;\n      let x1 = dataXMin; let y1 = m*x1 + b;\n      let x2 = dataXMax; let y2 = m*x2 + b;\n      let cx1 = xToCanvas(x1);\n      let cy1 = yToCanvas(y1);\n      let cx2 = xToCanvas(x2);\n      let cy2 = yToCanvas(y2);\n      if(posHitTest(mx,my,cx1,cy1,8)){\n        draggingLinePoint = \"start\";\n        dragOffset.x = cx1 - mx;\n        dragOffset.y = cy1 - my;\n        logMsg(\"Dragging line start point\");\n        return;\n      }\n      if(posHitTest(mx,my,cx2,cy2,8)){\n        draggingLinePoint = \"end\";\n        dragOffset.x = cx2 - mx;\n        dragOffset.y = cy2 - my;\n        logMsg(\"Dragging line end point\");\n        return;\n      }\n    }\n  });\n\n  // On mousemove, update the dragged point or line endpoint position\n  canvas.addEventListener(\"mousemove\", e => {\n    if(draggedPointIndex === null && draggingLinePoint === null) return;\n    const rect = canvas.getBoundingClientRect();\n    const mx = e.clientX - rect.left;\n    const my = e.clientY - rect.top;\n\n    if(draggedPointIndex !== null){\n      // Move data point accordingly\n      let newX = canvasToX(mx + dragOffset.x);\n      let newY = canvasToY(my + dragOffset.y);\n      dataPoints[draggedPointIndex].x = newX;\n      dataPoints[draggedPointIndex].y = newY;\n\n      // Update display text area with new data if visible\n      updateDataTextareaWithPoints();\n      fillDataTable();\n      regressionParams = null;\n      manualFit = null;\n      document.getElementById(\"regressionResult\").textContent = \"Point moved => cleared regression.\";\n      updateComputeMetricsState(false);\n      updateManualInputs();\n      redraw();\n    }\n\n    if(draggingLinePoint !== null){\n      // Adjust manualFit line endpoints based on dragging\n      if(!manualFit && regressionParams){\n        // Start manualFit from regressionParams line\n        manualFit = Object.assign({}, regressionParams);\n      }\n      if(!manualFit){\n        return;\n      }\n      // Get other endpoint coords\n      let otherPx, otherPy;\n      if(draggingLinePoint === \"start\"){\n        // Update start endpoint\n        let cxStart = mx + dragOffset.x;\n        let cyStart = my + dragOffset.y;\n        // Other endpoint\n        let x2 = dataXMax; let y2 = manualFit.m*x2 + manualFit.b;\n        let cx2 = xToCanvas(x2);\n        let cy2 = yToCanvas(y2);\n        otherPx = canvasToX(cx2);\n        otherPy = canvasToY(cy2);\n        // Update manualFit slope and intercept from new start and fixed end\n        let newX1 = canvasToX(cxStart);\n        let newY1 = canvasToY(cyStart);\n        // Calculate slope and intercept for line through (newX1,newY1) & (otherPx,otherPy)\n        let newM, newB;\n        if(otherPx === newX1){\n          // vertical line edge case, avoid slope infinity:\n          newM = manualFit.m;\n          newB = manualFit.b;\n        } else {\n          newM = (otherPy - newY1)/(otherPx - newX1);\n          newB = newY1 - newM*newX1;\n        }\n        manualFit.m = newM;\n        manualFit.b = newB;\n        document.getElementById(\"manualM\").value = newM.toFixed(4);\n        document.getElementById(\"manualB\").value = newB.toFixed(4);\n        redraw();\n      } else if(draggingLinePoint === \"end\"){\n        // Update end endpoint\n        let cxEnd = mx + dragOffset.x;\n        let cyEnd = my + dragOffset.y;\n        let x1 = dataXMin; let y1 = manualFit.m*x1 + manualFit.b;\n        let cx1 = xToCanvas(x1);\n        let cy1 = yToCanvas(y1);\n        otherPx = canvasToX(cx1);\n        otherPy = canvasToY(cy1);\n        let newX2 = canvasToX(cxEnd);\n        let newY2 = canvasToY(cyEnd);\n        let newM, newB;\n        if(otherPx === newX2){\n          newM = manualFit.m;\n          newB = manualFit.b;\n        } else {\n          newM = (newY2 - otherPy)/(newX2 - otherPx);\n          newB = otherPy - newM*otherPx;\n        }\n        manualFit.m = newM;\n        manualFit.b = newB;\n        document.getElementById(\"manualM\").value = newM.toFixed(4);\n        document.getElementById(\"manualB\").value = newB.toFixed(4);\n        redraw();\n      }\n      regressionParams = null;\n      updateComputeMetricsState(true);\n    }\n  });\n\n  // On mouseup cancel dragging\n  canvas.addEventListener(\"mouseup\", e => {\n    if(draggedPointIndex !== null){\n      logMsg(\"Dropped data point \"+draggedPointIndex);\n      draggedPointIndex = null;\n    }\n    if(draggingLinePoint !== null){\n      logMsg(\"Dropped line endpoint (\"+draggingLinePoint+\")\");\n      draggingLinePoint = null;\n    }\n  });\n  // Also on mouseleave cancel\n  canvas.addEventListener(\"mouseleave\", e => {\n    if(draggedPointIndex !== null || draggingLinePoint !== null){\n      logMsg(\"Drag cancelled\");\n    }\n    draggedPointIndex = null;\n    draggingLinePoint = null;\n  });\n\n  // Sync manual fit inputs when changed externally\n  document.getElementById(\"manualM\").addEventListener(\"change\", () => {\n    if(manualFit){\n      let m = parseFloat(document.getElementById(\"manualM\").value);\n      if(!isNaN(m)){\n        manualFit.m = m;\n        redraw();\n      }\n    }\n  });\n  document.getElementById(\"manualB\").addEventListener(\"change\", () => {\n    if(manualFit){\n      let b = parseFloat(document.getElementById(\"manualB\").value);\n      if(!isNaN(b)){\n        manualFit.b = b;\n        redraw();\n      }\n    }\n  });\n\n  // Update data textarea when point is dragged\n  function updateDataTextareaWithPoints(){\n    let lines = dataPoints.map(p => p.x.toFixed(4)+\", \"+p.y.toFixed(4));\n    document.getElementById(\"datapoints\").value = lines.join(\"\\n\");\n  }\n\n  // At init: disable some buttons which require data\n  updateComputeMetricsState(false);\n  toggleGDControls(false);\n  redraw();\n\n  logMsg(\"Application loaded. Enter or generate data to begin.\");\n\n})();\n</script>\n</body>\n</html>"
