    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Abstract Syntax Tree — Visual Concept</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071226;\n    --accent-1: #7C5CFF;\n    --accent-2: #00E5A8;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.65);\n    --panel: rgba(255,255,255,0.03);\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    --node-glow: 0 6px 30px rgba(124,92,255,0.18), 0 2px 8px rgba(0,229,168,0.06);\n    --glass-border: linear-gradient(135deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color: #eaf2ff;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.09), transparent 10%),\n                radial-gradient(900px 500px at 90% 90%, rgba(0,229,168,0.06), transparent 12%),\n                linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 100%);\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Layout */\n  .stage{\n    position:relative;\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:56px;\n    gap:40px;\n  }\n\n  .panel{\n    width:min(1100px, 94vw);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:22px;\n    box-shadow: var(--shadow);\n    padding:28px;\n    backdrop-filter: blur(8px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.04);\n    position:relative;\n    overflow:hidden;\n  }\n\n  header.title{\n    display:flex;\n    align-items:center;\n    gap:18px;\n    margin-bottom:18px;\n  }\n  .badge{\n    width:86px;\n    height:86px;\n    border-radius:16px;\n    background: linear-gradient(135deg, rgba(124,92,255,0.18), rgba(0,229,168,0.06));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex:0 0 86px;\n    box-shadow: var(--node-glow);\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n  .badge svg{width:48px;height:48px;filter:drop-shadow(0 6px 20px rgba(0,0,0,0.25));}\n\n  .heading{\n    display:flex;\n    flex-direction:column;\n    gap:4px;\n  }\n  h1{\n    margin:0;\n    font-family: \"Playfair Display\", serif;\n    font-weight:700;\n    letter-spacing:-0.02em;\n    font-size:22px;\n    color:#ffffff;\n  }\n  p.lead{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n    max-width:740px;\n  }\n\n  /* Controls */\n  .controls{\n    position:absolute;\n    right:22px;\n    top:22px;\n    display:flex;\n    gap:10px;\n    z-index:5;\n  }\n  .btn{\n    appearance:none;\n    border:0;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:var(--muted);\n    padding:10px 14px;\n    border-radius:12px;\n    font-weight:600;\n    font-size:13px;\n    cursor:pointer;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    box-shadow: 0 4px 18px rgba(2,6,23,0.5);\n    transition:transform .22s cubic-bezier(.2,.9,.2,1), box-shadow .22s;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .btn:hover{transform:translateY(-3px)}\n  .btn:active{transform:translateY(-1px)}\n  .btn.primary{\n    background:linear-gradient(90deg,var(--accent-1), #31b8ff);\n    color:white;\n    box-shadow: 0 8px 30px rgba(49,184,255,0.08), 0 2px 8px rgba(0,0,0,0.35);\n  }\n\n  /* Canvas */\n  .canvas-wrap{\n    width:100%;\n    height:680px;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.015));\n    margin-top:6px;\n    position:relative;\n    overflow:visible;\n    padding:24px;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    display:block;\n  }\n\n  svg{\n    width:100%;\n    height:100%;\n    overflow:visible;\n  }\n\n  /* Node visuals */\n  .node{\n    transform-origin:center;\n    cursor:default;\n    transition:transform .35s cubic-bezier(.2,.9,.2,1), opacity .35s, filter .35s;\n    filter: drop-shadow(0 8px 26px rgba(3,9,20,0.5));\n  }\n  .node .card{\n    fill: url(#nodeGrad);\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:1;\n    rx:12;\n    ry:12;\n    filter: drop-shadow(0 6px 22px rgba(0,0,0,0.5));\n  }\n  .node .label{\n    fill:#eaf2ff;\n    font-weight:600;\n    font-size:12px;\n    font-family:Inter, system-ui, -apple-system;\n  }\n  .node .sub{\n    fill: rgba(255,255,255,0.68);\n    font-weight:500;\n    font-size:10px;\n    opacity:0.9;\n  }\n  .node .chip{\n    fill:rgba(255,255,255,0.03);\n    stroke: rgba(255,255,255,0.04);\n    rx:8;\n    ry:8;\n  }\n  .node .type{\n    font-size:10px;\n    fill: rgba(255,255,255,0.75);\n    font-weight:700;\n    font-family:Inter;\n  }\n\n  /* Link styles */\n  .link{\n    fill:none;\n    stroke: linear-gradient(90deg,#7C5CFF,#00E5A8); /* fallback */\n    stroke-width:2.2;\n    stroke-linecap:round;\n    opacity:0.96;\n    transition:stroke-dashoffset .9s ease, opacity .5s ease;\n  }\n\n  /* Animated drawing */\n  .link.path-animate{\n    stroke-dasharray: 200;\n    stroke-dashoffset: 200;\n    animation:dash .9s ease forwards;\n    animation-delay: var(--delay,0s);\n  }\n  @keyframes dash{\n    to{stroke-dashoffset:0}\n  }\n\n  /* Node entrance */\n  .node.enter{\n    opacity:0;\n    transform: translateY(-30px) scale(0.96);\n    animation:pop .62s cubic-bezier(.2,.9,.2,1) forwards;\n    animation-delay: var(--delay, 0s);\n  }\n  @keyframes pop{\n    to { opacity:1; transform:translateY(0) scale(1) }\n  }\n\n  /* Floating */\n  .floating{\n    animation:floaty 6s ease-in-out infinite;\n    transform-origin:center;\n  }\n  @keyframes floaty{\n    0%{ transform: translateY(0) }\n    50%{ transform: translateY(-6px) }\n    100%{ transform: translateY(0) }\n  }\n\n  /* paused state */\n  .paused .floating{ animation-play-state:paused }\n  .paused .node{ transition:none }\n  .paused .link.path-animate{ animation-play-state:paused }\n\n  /* small screen */\n  @media (max-width:880px){\n    .panel{ padding:18px }\n    .badge{ width:66px;height:66px;flex:0 0 66px }\n    .canvas-wrap{ height:540px }\n  }\n\n  /* footer descriptive area */\n  .meta{\n    display:flex;\n    align-items:center;\n    gap:12px;\n    margin-top:18px;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .dot{\n    width:10px;height:10px;border-radius:50%;background:linear-gradient(90deg,var(--accent-1), #31b8ff);box-shadow:0 6px 18px rgba(124,92,255,0.12);\n  }\n\n  /* subtle grid overlay */\n  .grid{\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    background-image:\n      radial-gradient(circle at 20% 30%, rgba(255,255,255,0.02) 0px, transparent 1px),\n      radial-gradient(circle at 70% 80%, rgba(0,0,0,0.02) 0px, transparent 1px);\n    opacity:0.6;\n    mix-blend-mode: overlay;\n  }\n\n  /* tiny hint */\n  .hint{\n    position:absolute;\n    left:22px;\n    bottom:18px;\n    color:rgba(255,255,255,0.12);\n    font-size:12px;\n    font-weight:600;\n    letter-spacing:0.1em;\n  }\n\n</style>\n</head>\n<body>\n<div class=\"stage\">\n  <div class=\"panel\" id=\"rootPanel\" aria-hidden=\"false\">\n    <div class=\"controls\" role=\"group\" aria-label=\"controls\">\n      <button class=\"btn\" id=\"regenBtn\" title=\"Generate a fresh AST\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"filter:drop-shadow(0 2px 6px rgba(0,0,0,0.25))\"><path d=\"M21 12a9 9 0 10-3 6.63\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path><path d=\"M21 3v6h-6\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n        Regenerate\n      </button>\n      <button class=\"btn primary\" id=\"toggleAnim\" title=\"Pause or resume motion\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 5v14\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/><path d=\"M18 5v14\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg>\n        Pause\n      </button>\n    </div>\n\n    <header class=\"title\" aria-hidden=\"true\">\n      <div class=\"badge\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 48 48\" fill=\"none\">\n          <defs>\n            <linearGradient id=\"b\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7C5CFF\"/>\n              <stop offset=\"1\" stop-color=\"#00E5A8\"/>\n            </linearGradient>\n          </defs>\n          <rect width=\"48\" height=\"48\" rx=\"12\" fill=\"url(#b)\" opacity=\"0.12\"></rect>\n          <g transform=\"translate(6 6)\" stroke=\"url(#b)\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <path d=\"M6 12 L12 6 L18 12\" />\n            <path d=\"M12 6v18\" />\n            <path d=\"M2 20h20\" opacity=\"0.6\"/>\n          </g>\n        </svg>\n      </div>\n      <div class=\"heading\">\n        <h1>Abstract Syntax Tree</h1>\n        <p class=\"lead\">A sculpted visualization of code structure — nodes as composable tokens, edges as grammatical relationships. Observe the gentle choreography of a parsed program.</p>\n      </div>\n    </header>\n\n    <div class=\"canvas-wrap\" id=\"canvasWrap\" role=\"img\" aria-label=\"Abstract Syntax Tree visualization\">\n      <svg id=\"svg\" viewBox=\"0 0 1200 700\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"nodeGrad\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#0b1b2a\" stop-opacity=\"0.9\"/>\n            <stop offset=\"1\" stop-color=\"#071226\" stop-opacity=\"0.95\"/>\n          </linearGradient>\n          <linearGradient id=\"linkGrad\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7C5CFF\"/>\n            <stop offset=\"1\" stop-color=\"#00E5A8\"/>\n          </linearGradient>\n          <filter id=\"blur\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n            <feGaussianBlur stdDeviation=\"8\" result=\"b\"/>\n            <feBlend in=\"SourceGraphic\" in2=\"b\"/>\n          </filter>\n        </defs>\n\n        <!-- decorative soft glows -->\n        <g id=\"glows\">\n          <circle cx=\"200\" cy=\"120\" r=\"140\" fill=\"url(#nodeGrad)\" opacity=\"0.04\" filter=\"url(#blur)\"></circle>\n          <circle cx=\"980\" cy=\"520\" r=\"180\" fill=\"#00E5A8\" opacity=\"0.02\" filter=\"url(#blur)\"></circle>\n        </g>\n\n        <!-- container groups -->\n        <g id=\"links\"></g>\n        <g id=\"nodes\"></g>\n      </svg>\n      <div class=\"grid\" aria-hidden=\"true\"></div>\n      <div class=\"hint\">Beautiful, limited interactivity — observe the tree.</div>\n    </div>\n\n    <div class=\"meta\" aria-hidden=\"true\">\n      <div class=\"dot\" aria-hidden=\"true\"></div>\n      <div>\n        <div style=\"font-weight:700\">Elegant parsing</div>\n        <div style=\"font-size:12px;color:var(--muted)\">Nodes are tokens, edges are relationships — the AST is a structural map of source code.</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Minimal interactivity: regenerate and toggle animation\n  const regenBtn = document.getElementById('regenBtn');\n  const toggleBtn = document.getElementById('toggleAnim');\n  const panel = document.getElementById('rootPanel');\n  const svg = document.getElementById('svg');\n  const nodesGroup = document.getElementById('nodes');\n  const linksGroup = document.getElementById('links');\n  let paused = false;\n\n  // Sample AST node type palette\n  const TYPES = [\n    \"Program\",\"FunctionDeclaration\",\"VariableDeclaration\",\"Identifier\",\"Parameter\",\n    \"BlockStatement\",\"ReturnStatement\",\"ExpressionStatement\",\"CallExpression\",\n    \"BinaryExpression\",\"Literal\",\"IfStatement\",\"Else\",\"ForLoop\",\"AssignmentExpression\",\n    \"WhileStatement\",\"MemberExpression\",\"ObjectExpression\",\"Property\"\n  ];\n\n  // Generate a random tree with constraints for aesthetic\n  function generateTree(depthLimit=4, breadth=3){\n    let idCounter=0;\n    function rnd(min,max){ return Math.floor(Math.random()*(max-min+1))+min }\n    function makeNode(depth=0){\n      const type = TYPES[Math.max(0, Math.floor(Math.random()*TYPES.length - depth*0.4))] || \"Node\";\n      const node = {\n        id: ++idCounter,\n        type,\n        name: pickName(type),\n        children: []\n      };\n      if(depth < depthLimit){\n        // decide number of children based on type heuristics\n        let maxChildren = depth===0? rnd(2,4) : (Math.random()<0.7? rnd(0, Math.max(0, breadth-depth)) : rnd(0,2));\n        maxChildren = Math.min(maxChildren, 5);\n        for(let i=0;i<maxChildren;i++){\n          if(Math.random() < 0.75 - depth*0.12) node.children.push(makeNode(depth+1));\n        }\n      }\n      return node;\n    }\n    return makeNode(0);\n  }\n\n  function pickName(type){\n    // simple mapping for nicer labels\n    const examples = {\n      \"Identifier\":[\"add\",\"x\",\"result\",\"sum\",\"items\",\"index\"],\n      \"Literal\":[\"42\",\"true\",\"'hello'\",\"3.14\",\"null\"],\n      \"FunctionDeclaration\":[\"compute\",\"render\",\"update\",\"handleClick\",\"sum\"],\n      \"VariableDeclaration\":[\"const\",\"let\",\"var\"],\n      \"BinaryExpression\":[\"+\", \"-\", \"*\", \"/\",\"==\",\"===\"],\n      \"CallExpression\":[\"call\",\"invoke\",\"map\",\"filter\"],\n      \"ReturnStatement\":[\"return\"],\n      \"IfStatement\":[\"if\"],\"ForLoop\":[\"for\"],\"WhileStatement\":[\"while\"],\n      \"MemberExpression\":[\"obj.prop\"],\"ObjectExpression\":[\"{...}\"],\"Property\":[\"key:value\"]\n    };\n    if(examples[type]) return examples[type][Math.floor(Math.random()*examples[type].length)];\n    // fallback\n    const short = [\"α\",\"β\",\"γ\",\"δ\",\"λ\",\"φ\",\"ω\"];\n    return short[Math.floor(Math.random()*short.length)];\n  }\n\n  // layout: compute subtree widths and x positions\n  function layoutTree(root, svgW=1200, svgH=700){\n    const nodeWidth = 160;\n    const nodeHeight = 56;\n    const levelGap = 110;\n    // compute width units\n    function computeSize(n){\n      if(!n.children || n.children.length===0){ n._size = 1; return 1; }\n      let s=0;\n      for(let c of n.children) s+=computeSize(c);\n      n._size = s || 1;\n      return n._size;\n    }\n    computeSize(root);\n\n    // horizontal spacing\n    const leftPadding = 80;\n    const rightPadding = 80;\n    const availW = svgW - leftPadding - rightPadding;\n    let xCursor = leftPadding;\n\n    function assign(n, depth){\n      const wUnits = n._size;\n      const span = (availW) * (wUnits / root._size);\n      const xCenter = xCursor + span/2;\n      n.x = xCenter;\n      n.y = 60 + depth*levelGap;\n      // allocate children\n      let childCursor = xCursor;\n      for(let c of n.children){\n        const childSpan = (availW) * (c._size / root._size);\n        // set child's allocation and recursive\n        xCursor = childCursor;\n        assign(c, depth+1);\n        childCursor += childSpan;\n      }\n      xCursor = childCursor;\n    }\n    assign(root, 0);\n    return {nodeWidth, nodeHeight};\n  }\n\n  // Draw the tree - nodes and links\n  function render(tree){\n    // clear\n    while(nodesGroup.firstChild) nodesGroup.removeChild(nodesGroup.firstChild);\n    while(linksGroup.firstChild) linksGroup.removeChild(linksGroup.firstChild);\n\n    const viewW = 1200, viewH = 700;\n    const dims = layoutTree(tree, viewW, viewH);\n    const nodeW = dims.nodeWidth;\n    const nodeH = dims.nodeHeight;\n\n    // create nodes map for connectors\n    const map = new Map();\n\n    // flatten nodes for staggered animation\n    const flat = [];\n    (function collect(n){ flat.push(n); for(let c of n.children) collect(c) })(tree);\n\n    // draw links first so they appear behind\n    flat.forEach((n,i)=>{\n      if(n.parent){\n        const p = n.parent;\n        const sx = p.x;\n        const sy = p.y + nodeH/2;\n        const tx = n.x;\n        const ty = n.y - nodeH/2;\n        const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n        path.setAttribute('d', bezierPath(sx,sy,tx,ty));\n        path.setAttribute('stroke', 'url(#linkGrad)');\n        path.setAttribute('class','link path-animate');\n        path.style.setProperty('--delay', (i*0.03)+'s');\n        path.setAttribute('stroke-width', 2.2);\n        path.setAttribute('fill','none');\n        path.setAttribute('opacity', 0.95);\n        linksGroup.appendChild(path);\n      }\n    });\n\n    // draw nodes\n    flat.forEach((n,i)=>{\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('class','node enter floating');\n      g.style.setProperty('--delay', (i*0.04)+'s');\n      g.setAttribute('transform', `translate(${n.x - nodeW/2}, ${n.y - nodeH/2})`);\n      // group content: rounded rect, label, sublabel\n      const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      rect.setAttribute('class','card');\n      rect.setAttribute('x',0);\n      rect.setAttribute('y',0);\n      rect.setAttribute('width', nodeW);\n      rect.setAttribute('height', nodeH);\n      rect.setAttribute('rx',12);\n      rect.setAttribute('ry',12);\n\n      // left color ribbon\n      const clipId = 'clip-'+n.id;\n      const clip = document.createElementNS('http://www.w3.org/2000/svg','clipPath');\n      clip.setAttribute('id', clipId);\n      const clipRect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      clipRect.setAttribute('x',0);\n      clipRect.setAttribute('y',0);\n      clipRect.setAttribute('width', 18);\n      clipRect.setAttribute('height', nodeH);\n      clipRect.setAttribute('rx',10);\n      clip.appendChild(clipRect);\n      svg.querySelector('defs').appendChild(clip);\n\n      const ribbon = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      ribbon.setAttribute('x',0);\n      ribbon.setAttribute('y',0);\n      ribbon.setAttribute('width',18);\n      ribbon.setAttribute('height', nodeH);\n      ribbon.setAttribute('rx',10);\n      ribbon.setAttribute('fill','url(#linkGrad)');\n      ribbon.setAttribute('opacity',0.98);\n      ribbon.setAttribute('clip-path','url(#'+clipId+')');\n\n      // label texts\n      const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n      label.setAttribute('x',26);\n      label.setAttribute('y',22);\n      label.setAttribute('class','label');\n      label.textContent = n.type;\n\n      const sub = document.createElementNS('http://www.w3.org/2000/svg','text');\n      sub.setAttribute('x',26);\n      sub.setAttribute('y',40);\n      sub.setAttribute('class','sub');\n      sub.textContent = n.name || '';\n\n      // tiny chip with children count\n      if(n.children && n.children.length){\n        const chip = document.createElementNS('http://www.w3.org/2000/svg','rect');\n        chip.setAttribute('x', nodeW - 62);\n        chip.setAttribute('y', nodeH/2 - 12);\n        chip.setAttribute('width', 48);\n        chip.setAttribute('height', 24);\n        chip.setAttribute('class','chip');\n        chip.setAttribute('rx',8);\n        chip.setAttribute('ry',8);\n\n        const ctxt = document.createElementNS('http://www.w3.org/2000/svg','text');\n        ctxt.setAttribute('x', nodeW - 38);\n        ctxt.setAttribute('y', nodeH/2 + 6);\n        ctxt.setAttribute('class','type');\n        ctxt.textContent = String(n.children.length)+' ⭢';\n        g.appendChild(chip);\n        g.appendChild(ctxt);\n      }\n\n      g.appendChild(rect);\n      g.appendChild(ribbon);\n      g.appendChild(label);\n      g.appendChild(sub);\n\n      nodesGroup.appendChild(g);\n      map.set(n.id, g);\n    });\n\n    // set parent references (done in generator but ensure)\n    // dismiss stale clipPaths occasionally\n    // animate slight shift to create subtle motion via CSS variables (already using floating)\n  }\n\n  function bezierPath(sx,sy,tx,ty){\n    const dx = Math.abs(tx - sx);\n    const cpx = sx + (tx - sx)/2;\n    const cpy1 = sy + 48;\n    const cpy2 = ty - 48;\n    return `M ${sx} ${sy} C ${sx} ${cpy1} ${tx} ${cpy2} ${tx} ${ty}`;\n  }\n\n  // Attach parent links to nodes for layout convenience\n  function attachParents(node){\n    if(node.children){\n      node.children.forEach(c=>{\n        c.parent = node;\n        attachParents(c);\n      });\n    }\n  }\n\n  // main bootstrap\n  let currentTree = null;\n\n  function refresh(){\n    currentTree = generateTree(4,3);\n    attachParents(currentTree);\n    render(currentTree);\n  }\n\n  regenBtn.addEventListener('click', ()=> {\n    regenBtn.animate([{transform:'translateY(0)'},{transform:'translateY(-6px)'}],{duration:240, easing:'cubic-bezier(.2,.9,.2,1)'});\n    refresh();\n  });\n\n  toggleBtn.addEventListener('click', ()=>{\n    paused = !paused;\n    document.documentElement.classList.toggle('paused', paused);\n    panel.classList.toggle('paused', paused);\n    toggleBtn.textContent = paused ? 'Resume' : 'Pause';\n    // change icon to play/pause minimal\n    toggleBtn.innerHTML = paused ? '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\\\"M5 3v18l15-9L5 3z\\\" fill=\\\"white\\\"/></svg> Resume' : '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\\\"M6 5v14\\\" stroke=\\\"white\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\"/><path d=\\\"M18 5v14\\\" stroke=\\\"white\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\"/></svg> Pause';\n  });\n\n  // initial render\n  refresh();\n\n  // accessibility: make svg nodes non-focusable\n  svg.querySelectorAll('g.node').forEach(n => n.setAttribute('aria-hidden','true'));\n\n  // subtle continuous micro-oscillation for nodes using CSS animation delay offsets\n  // nothing else interactive\n\n  // Keep page responsive: on resize recompute layout for aesthetic positioning\n  let resizeTimeout;\n  window.addEventListener('resize', () => {\n    clearTimeout(resizeTimeout);\n    resizeTimeout = setTimeout(()=>{ render(currentTree); }, 180);\n  });\n\n  // Nice: set initial toggle button icon explicitly\n  toggleBtn.innerHTML = '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 5v14\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/><path d=\"M18 5v14\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg> Pause';\n})();\n</script>\n</body>\n</html>"
  },
