  "question": "Topological Sort",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Topological Sort Interactive Demo</title>\n<style>\n  /* Extremely minimal visual design: default black text on white background,\n     small layout helpers only. No colors, no animations. */\n  html,body { margin: 8px; padding: 0; font-family: monospace; font-size: 13px; }\n  .row { display: block; margin: 6px 0; }\n  label { display: inline-block; width: 140px; }\n  select,input,button,textarea { font-family: monospace; font-size: 13px; }\n  textarea { width: 100%; height: 120px; }\n  fieldset { margin: 8px 0; padding: 6px; }\n  .panel { border: 1px solid #000000; padding: 6px; }\n  .tiny { font-size: 12px; }\n  .compact { margin: 2px 0; padding: 2px; }\n  pre { white-space: pre-wrap; word-wrap: break-word; }\n</style>\n</head>\n<body>\n\n<h2>Topological Sort — Interactive Demonstration</h2>\n\n<div class=\"panel\">\n  <fieldset>\n    <legend>Graph Construction</legend>\n    <div class=\"row compact\">\n      <label>New node id:</label>\n      <input id=\"nodeIdInput\" placeholder=\"e.g. A or 1\" />\n      <button id=\"addNodeBtn\">Add Node</button>\n      <button id=\"autoAddNodesBtn\">Add 5 Nodes (auto)</button>\n    </div>\n\n    <div class=\"row compact\">\n      <label>From node:</label>\n      <select id=\"fromSelect\"></select>\n      <label style=\"width:80px\">To node:</label>\n      <select id=\"toSelect\"></select>\n      <button id=\"addEdgeBtn\">Add Edge</button>\n      <button id=\"removeEdgeBtn\">Remove Edge</button>\n    </div>\n\n    <div class=\"row compact\">\n      <label>Remove node:</label>\n      <select id=\"removeNodeSelect\"></select>\n      <button id=\"removeNodeBtn\">Remove Node</button>\n      <button id=\"clearGraphBtn\">Clear Graph</button>\n    </div>\n\n    <div class=\"row compact\">\n      <label>Random graph:</label>\n      <input id=\"randN\" type=\"number\" value=\"6\" min=\"1\" style=\"width:60px\" />\n      <label style=\"width:70px\">p (0-1):</label>\n      <input id=\"randP\" type=\"number\" step=\"0.05\" value=\"0.25\" min=\"0\" max=\"1\" style=\"width:60px\" />\n      <label style=\"width:80px\">Force DAG:</label>\n      <input id=\"randDAG\" type=\"checkbox\" checked />\n      <button id=\"genRandBtn\">Generate</button>\n    </div>\n\n    <div class=\"row compact\">\n      <label>Save/Load graph:</label>\n      <button id=\"exportBtn\">Export JSON</button>\n      <button id=\"importBtn\">Import JSON</button>\n    </div>\n\n    <div class=\"row compact\">\n      <label>Undo/Redo edits:</label>\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Graph Views & Controls</legend>\n    <div class=\"row compact\">\n      <label>Nodes:</label><span id=\"nodesView\"></span>\n    </div>\n    <div class=\"row compact\">\n      <label>Adjacency list:</label>\n      <pre id=\"adjView\" style=\"display:block\"></pre>\n    </div>\n    <div class=\"row compact\">\n      <label>Indegrees:</label>\n      <pre id=\"indegView\" style=\"display:block\"></pre>\n    </div>\n    <div class=\"row compact\">\n      <label>Edges:</label>\n      <pre id=\"edgesView\" style=\"display:block\"></pre>\n    </div>\n    <div class=\"row compact\">\n      <label>Cycle present:</label><span id=\"cycleView\"></span>\n      <button id=\"detectCycleBtn\">Detect Cycle</button>\n    </div>\n  </fieldset>\n</div>\n\n<div class=\"panel\">\n  <fieldset>\n    <legend>Kahn's Algorithm (iterative)</legend>\n\n    <div class=\"row compact\">\n      <button id=\"kahnInitBtn\">Initialize Kahn</button>\n      <button id=\"kahnNextBtn\">Next Step</button>\n      <button id=\"kahnPrevBtn\">Prev Step</button>\n      <button id=\"kahnAutoBtn\">Auto Play</button>\n      <button id=\"kahnPauseBtn\">Pause</button>\n      <button id=\"kahnResetBtn\">Reset</button>\n      <label style=\"width:70px\">Speed ms:</label>\n      <input id=\"kahnSpeed\" type=\"range\" min=\"100\" max=\"2000\" value=\"600\" />\n    </div>\n\n    <div class=\"row compact\">\n      <label>Queue view:</label><span id=\"kahnQueue\"></span>\n    </div>\n    <div class=\"row compact\">\n      <label>Output order:</label><span id=\"kahnOutput\"></span>\n    </div>\n    <div class=\"row compact\">\n      <label>Step log:</label>\n      <pre id=\"kahnLog\"></pre>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>DFS-based Toposort (reverse postorder)</legend>\n\n    <div class=\"row compact\">\n      <button id=\"dfsInitBtn\">Initialize DFS</button>\n      <button id=\"dfsNextBtn\">Next Step</button>\n      <button id=\"dfsPrevBtn\">Prev Step</button>\n      <button id=\"dfsAutoBtn\">Auto Play</button>\n      <button id=\"dfsPauseBtn\">Pause</button>\n      <button id=\"dfsResetBtn\">Reset</button>\n      <label style=\"width:70px\">Speed ms:</label>\n      <input id=\"dfsSpeed\" type=\"range\" min=\"100\" max=\"2000\" value=\"600\" />\n    </div>\n\n    <div class=\"row compact\">\n      <label>Visit state:</label><span id=\"dfsState\"></span>\n    </div>\n    <div class=\"row compact\">\n      <label>Stack / output:</label><span id=\"dfsOutput\"></span>\n    </div>\n    <div class=\"row compact\">\n      <label>Step log:</label>\n      <pre id=\"dfsLog\"></pre>\n    </div>\n  </fieldset>\n</div>\n\n<div class=\"panel\">\n  <fieldset>\n    <legend>All Topological Orders (enumeration)</legend>\n\n    <div class=\"row compact\">\n      <label>Max nodes allowed:</label>\n      <input id=\"enumLimit\" type=\"number\" value=\"8\" min=\"1\" style=\"width:60px\" />\n      <button id=\"enumAllBtn\">Enumerate All</button>\n      <button id=\"enumStopBtn\">Stop</button>\n    </div>\n\n    <div class=\"row compact\">\n      <label>Orders count:</label><span id=\"ordersCount\">0</span>\n    </div>\n    <div class=\"row compact\">\n      <label>Current order:</label><span id=\"currentOrder\">-</span>\n      <button id=\"orderPrevBtn\">Prev</button>\n      <button id=\"orderNextBtn\">Next</button>\n      <button id=\"orderCopyBtn\">Copy Order to Sequence Input</button>\n    </div>\n\n    <div class=\"row compact\">\n      <label>Constrainted generation:</label>\n      <input id=\"enumStartNode\" placeholder=\"optional start node\" style=\"width:160px\" />\n      <small class=\"tiny\"> (will force first element if present)</small>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Validate & Manipulate Orders</legend>\n    <div class=\"row compact\">\n      <label>Sequence to check:</label>\n      <input id=\"seqInput\" placeholder=\"comma separated nodes\" style=\"width:420px\" />\n      <button id=\"checkSeqBtn\">Check Validity</button>\n      <span id=\"seqCheckResult\"></span>\n    </div>\n\n    <div class=\"row compact\">\n      <label>Assign topological rank:</label>\n      <input id=\"rankSeqInput\" placeholder=\"comma separated nodes\" style=\"width:360px\" />\n      <button id=\"assignRankBtn\">Assign Ranks</button>\n    </div>\n\n    <div class=\"row compact\">\n      <label>Incremental edge add:</label>\n      <input id=\"incrFrom\" placeholder=\"from\" style=\"width:70px\" />\n      <input id=\"incrTo\" placeholder=\"to\" style=\"width:70px\" />\n      <button id=\"incrAddEdgeBtn\">Add Edge (try incremental update)</button>\n      <span id=\"incrResult\"></span>\n    </div>\n  </fieldset>\n</div>\n\n<div class=\"panel\">\n  <fieldset>\n    <legend>Graph JSON / Logs</legend>\n    <div class=\"row compact\">\n      <label>Exported JSON:</label>\n      <button id=\"copyJsonBtn\">Copy to Clipboard</button>\n    </div>\n    <textarea id=\"jsonArea\" placeholder=\"Graph JSON will appear here\"></textarea>\n    <div class=\"row compact\">\n      <label>Action log:</label>\n      <pre id=\"actionLog\"></pre>\n      <button id=\"clearLogBtn\">Clear Log</button>\n    </div>\n  </fieldset>\n</div>\n\n<script>\n/*\n  Minimal UI/UX but rich interactivity for exploring topological sort.\n  No external dependencies. All text-only, basic elements.\n*/\n\n/* Graph data structure: nodes set, adjacency map (node -> array of neighbors) */\n(function(){\n\n  // Utility helpers\n  function logAction(msg){\n    const el = document.getElementById('actionLog');\n    el.textContent = (el.textContent?el.textContent + '\\\\n': '') + '['+ new Date().toLocaleTimeString() + '] ' + msg;\n    el.scrollTop = el.scrollHeight;\n  }\n\n  function cloneGraph(graph){\n    return {\n      nodes: Array.from(graph.nodes),\n      adj: graph.nodes.reduce((m,n)=>{ m[n]= (graph.adj[n]||[]).slice(); return m; }, {})\n    };\n  }\n\n  // Graph state with undo/redo\n  let graph = { nodes: [], adj: {} };\n  let history = [];\n  let future = [];\n\n  function pushHistory(){\n    history.push(cloneGraph(graph));\n    if(history.length > 200) history.shift();\n    future = [];\n    updateUndoRedoButtons();\n  }\n  function updateUndoRedoButtons(){\n    document.getElementById('undoBtn').disabled = history.length===0;\n    document.getElementById('redoBtn').disabled = future.length===0;\n  }\n  function setGraph(newGraph, recordHistory=true){\n    if(recordHistory) pushHistory();\n    graph.nodes = Array.from(newGraph.nodes);\n    graph.adj = {};\n    graph.nodes.forEach(n=> graph.adj[n] = (newGraph.adj && newGraph.adj[n]) ? newGraph.adj[n].slice() : []);\n    refreshUI();\n  }\n\n  function ensureNodeExists(id){\n    if(!graph.nodes.includes(id)){\n      graph.nodes.push(id);\n      graph.adj[id] = [];\n      logAction('Added node ' + id);\n    }\n  }\n\n  // Basic graph operations\n  function addNode(id){\n    id = id.trim();\n    if(!id) { alert('Empty node id not allowed'); return; }\n    if(graph.nodes.includes(id)){\n      alert('Node already exists: ' + id);\n      return;\n    }\n    pushHistory();\n    graph.nodes.push(id);\n    graph.adj[id] = [];\n    refreshUI();\n    logAction('Node added: ' + id);\n  }\n\n  function removeNode(id){\n    if(!graph.nodes.includes(id)) { alert('No such node: ' + id); return; }\n    pushHistory();\n    graph.nodes = graph.nodes.filter(n=> n !== id);\n    delete graph.adj[id];\n    // remove incoming edges\n    graph.nodes.forEach(n => {\n      graph.adj[n] = graph.adj[n].filter(v => v !== id);\n    });\n    refreshUI();\n    logAction('Node removed: ' + id);\n  }\n\n  function addEdge(from, to){\n    if(from===to){ if(!confirm('Self-edge will create a cycle. Add anyway?')) return; }\n    if(!graph.nodes.includes(from) || !graph.nodes.includes(to)){\n      alert('Both nodes must exist.');\n      return;\n    }\n    if(graph.adj[from].includes(to)){\n      alert('Edge already exists.');\n      return;\n    }\n    pushHistory();\n    graph.adj[from].push(to);\n    refreshUI();\n    logAction('Edge added: ' + from + ' -> ' + to);\n  }\n\n  function removeEdge(from, to){\n    if(!graph.nodes.includes(from) || !graph.nodes.includes(to)) return;\n    if(!graph.adj[from].includes(to)) { alert('No such edge.'); return; }\n    pushHistory();\n    graph.adj[from] = graph.adj[from].filter(v=> v!==to);\n    refreshUI();\n    logAction('Edge removed: ' + from + ' -> ' + to);\n  }\n\n  function clearGraph(){\n    pushHistory();\n    graph = { nodes: [], adj: {} };\n    refreshUI();\n    logAction('Graph cleared');\n  }\n\n  // Indegree map\n  function computeIndegreeMap(g){\n    const indeg = {};\n    g.nodes.forEach(n => indeg[n] = 0);\n    g.nodes.forEach(n => {\n      (g.adj[n]||[]).forEach(v => {\n        if(indeg[v]===undefined) indeg[v] = 0;\n        indeg[v]++;\n      });\n    });\n    return indeg;\n  }\n\n  // Cycle detection (DFS) returns boolean and optionally a cycle path\n  function detectCycle(g){\n    const vis = {}; // 0 un, 1 visiting, 2 done\n    const stack = [];\n    let found = null;\n    function dfs(u){\n      if(found) return;\n      vis[u]=1; stack.push(u);\n      for(const v of (g.adj[u]||[])){\n        if(vis[v]===1){\n          // found cycle: extract\n          const idx = stack.lastIndexOf(v);\n          found = stack.slice(idx).concat(v);\n          return;\n        } else if(!vis[v]){\n          dfs(v);\n          if(found) return;\n        }\n      }\n      stack.pop();\n      vis[u]=2;\n    }\n    for(const n of g.nodes){\n      if(!vis[n]) dfs(n);\n      if(found) break;\n    }\n    return {cycle: !!found, path: found};\n  }\n\n  // UI helpers to populate selects and displays\n  function populateNodeSelects(){\n    const from = document.getElementById('fromSelect');\n    const to = document.getElementById('toSelect');\n    const rem = document.getElementById('removeNodeSelect');\n    const incrFrom = document.getElementById('incrFrom');\n    const incrTo = document.getElementById('incrTo');\n    const enumStart = document.getElementById('enumStartNode');\n\n    [from,to,rem].forEach(sel=>{\n      sel.innerHTML = '';\n      graph.nodes.forEach(n=>{\n        const opt = document.createElement('option');\n        opt.value = n;\n        opt.textContent = n;\n        sel.appendChild(opt);\n      });\n    });\n    // also update simple text nodesView\n    document.getElementById('nodesView').textContent = graph.nodes.join(', ');\n  }\n\n  function refreshUI(){\n    populateNodeSelects();\n    // adjacency view\n    const adjEl = document.getElementById('adjView');\n    adjEl.textContent = graph.nodes.map(n => n + ' -> [' + (graph.adj[n]||[]).join(', ') + ']' ).join('\\\\n');\n    const indeg = computeIndegreeMap(graph);\n    const indegEl = document.getElementById('indegView');\n    indegEl.textContent = graph.nodes.map(n => n + ': ' + (indeg[n]||0)).join(', ');\n    const edgesEl = document.getElementById('edgesView');\n    const edges = [];\n    graph.nodes.forEach(n=> (graph.adj[n]||[]).forEach(v=> edges.push(n+'->'+v)));\n    edgesEl.textContent = edges.join(', ');\n    // cycle view\n    const cyc = detectCycle(graph);\n    document.getElementById('cycleView').textContent = cyc.cycle ? 'Yes (use Detect Cycle to see path)' : 'No';\n    // update json\n    document.getElementById('jsonArea').value = JSON.stringify(graph, null, 2);\n    updateUndoRedoButtons();\n  }\n\n  // Save/Load\n  function exportGraph(){\n    document.getElementById('jsonArea').value = JSON.stringify(graph, null, 2);\n    logAction('Graph exported to JSON area');\n  }\n  function importGraph(){\n    const val = document.getElementById('jsonArea').value;\n    if(!val) { alert('JSON area empty'); return; }\n    try{\n      const parsed = JSON.parse(val);\n      if(!Array.isArray(parsed.nodes) || typeof parsed.adj !== 'object'){ alert('Invalid format. Expected { nodes: [...], adj: {...} }'); return; }\n      setGraph(parsed);\n      logAction('Graph imported from JSON area');\n    }catch(e){ alert('Invalid JSON: ' + e.message); }\n  }\n\n  // Random generator\n  function genRandom(n, p, forceDAG){\n    if(n <= 0) return;\n    const nodes = [];\n    for(let i=0;i<n;i++) nodes.push('N'+(i+1));\n    const adj = {};\n    nodes.forEach(x=> adj[x]=[]);\n    for(let i=0;i<n;i++){\n      for(let j=0;j<n;j++){\n        if(i===j) continue;\n        if(Math.random() < p){\n          if(forceDAG){\n            if(i<j) adj[nodes[i]].push(nodes[j]);\n            else continue;\n          } else {\n            adj[nodes[i]].push(nodes[j]);\n          }\n        }\n      }\n    }\n    setGraph({nodes: nodes, adj: adj});\n    logAction('Random graph generated: n=' + n + ' p=' + p + ' forceDAG=' + forceDAG);\n  }\n\n  // Clipboard helper\n  function copyToClipboard(text){\n    if(navigator.clipboard && navigator.clipboard.writeText){\n      navigator.clipboard.writeText(text).then(()=>{ logAction('Copied to clipboard'); }).catch(()=>{ alert('Copy failed.'); });\n    } else {\n      const tmp = document.createElement('textarea'); document.body.appendChild(tmp);\n      tmp.value = text; tmp.select();\n      document.execCommand('copy'); document.body.removeChild(tmp);\n      logAction('Copied (fallback) to clipboard');\n    }\n  }\n\n  // Initialize UI event handlers\n  document.getElementById('addNodeBtn').addEventListener('click', ()=>{\n    const val = document.getElementById('nodeIdInput').value.trim();\n    if(!val){ alert('Enter a node id'); return; }\n    addNode(val);\n    document.getElementById('nodeIdInput').value = '';\n  });\n\n  document.getElementById('autoAddNodesBtn').addEventListener('click', ()=>{\n    pushHistory();\n    const base = graph.nodes.length + 1;\n    for(let i=0;i<5;i++){\n      const id = 'N' + (base + i);\n      graph.nodes.push(id);\n      graph.adj[id] = [];\n    }\n    refreshUI();\n    logAction('Auto-added 5 nodes');\n  });\n\n  document.getElementById('addEdgeBtn').addEventListener('click', ()=> {\n    const from = document.getElementById('fromSelect').value;\n    const to = document.getElementById('toSelect').value;\n    addEdge(from,to);\n  });\n\n  document.getElementById('removeEdgeBtn').addEventListener('click', ()=> {\n    const from = document.getElementById('fromSelect').value;\n    const to = document.getElementById('toSelect').value;\n    removeEdge(from,to);\n  });\n\n  document.getElementById('removeNodeBtn').addEventListener('click', ()=>{\n    const id = document.getElementById('removeNodeSelect').value;\n    if(!id) return;\n    if(confirm('Remove node ' + id + ' and its edges?')){\n      removeNode(id);\n    }\n  });\n\n  document.getElementById('clearGraphBtn').addEventListener('click', ()=>{\n    if(confirm('Clear the entire graph?')) clearGraph();\n  });\n\n  document.getElementById('genRandBtn').addEventListener('click', ()=>{\n    const n = parseInt(document.getElementById('randN').value,10) || 6;\n    const p = parseFloat(document.getElementById('randP').value) || 0.25;\n    const dag = document.getElementById('randDAG').checked;\n    genRandom(n,p,dag);\n  });\n\n  document.getElementById('exportBtn').addEventListener('click', exportGraph);\n  document.getElementById('importBtn').addEventListener('click', importGraph);\n  document.getElementById('copyJsonBtn').addEventListener('click', ()=> copyToClipboard(document.getElementById('jsonArea').value));\n\n  document.getElementById('undoBtn').addEventListener('click', ()=>{\n    if(history.length===0) return;\n    future.push(cloneGraph(graph));\n    const prev = history.pop();\n    graph = { nodes: prev.nodes.slice(), adj: {} };\n    prev.nodes.forEach(n=> graph.adj[n] = (prev.adj[n] || []).slice());\n    refreshUI();\n    updateUndoRedoButtons();\n    logAction('Undo performed');\n  });\n\n  document.getElementById('redoBtn').addEventListener('click', ()=>{\n    if(future.length===0) return;\n    history.push(cloneGraph(graph));\n    const nxt = future.pop();\n    graph = { nodes: nxt.nodes.slice(), adj: {} };\n    nxt.nodes.forEach(n=> graph.adj[n] = (nxt.adj[n] || []).slice());\n    refreshUI();\n    updateUndoRedoButtons();\n    logAction('Redo performed');\n  });\n\n  document.getElementById('detectCycleBtn').addEventListener('click', ()=>{\n    const res = detectCycle(graph);\n    if(!res.cycle) alert('No cycle detected');\n    else alert('Cycle detected: ' + res.path.join(' -> '));\n    logAction('Cycle detection executed, cycle=' + res.cycle);\n  });\n\n  document.getElementById('clearLogBtn').addEventListener('click', ()=> {\n    document.getElementById('actionLog').textContent = '';\n  });\n\n  // Kahn's algorithm stepper\n  let kahnState = null;\n  let kahnTimer = null;\n  function initKahn(){\n    // prepare indegree map and initial queue\n    const indeg = computeIndegreeMap(graph);\n    const q = Object.keys(indeg).filter(n=> indeg[n]===0).sort();\n    kahnState = {\n      indeg: indeg,\n      queue: q.slice(),\n      output: [],\n      steps: [],\n      index: -1 // before first step\n    };\n    kahnState.steps.push(snapshotKahn(kahnState));\n    updateKahnViews();\n    logAction('Kahn initialized');\n  }\n  function snapshotKahn(s){\n    return { queue: s.queue.slice(), output: s.output.slice(), indeg: Object.assign({}, s.indeg) };\n  }\n  function updateKahnViews(){\n    if(!kahnState){ document.getElementById('kahnQueue').textContent = ''; document.getElementById('kahnOutput').textContent = ''; document.getElementById('kahnLog').textContent = ''; return; }\n    document.getElementById('kahnQueue').textContent = '['+ kahnState.queue.join(', ') +']';\n    document.getElementById('kahnOutput').textContent = '['+ kahnState.output.join(', ') +']';\n    const logText = kahnState.steps.map((st,i)=> i + ': queue=' + '['+st.queue.join(',')+'] output=' + '['+st.output.join(',')+']').join('\\\\n');\n    document.getElementById('kahnLog').textContent = logText;\n  }\n  function kahnNext(){\n    if(!kahnState){ alert('Initialize Kahn first'); return; }\n    // if queue empty but not all output then cycle\n    if(kahnState.queue.length === 0){\n      if(kahnState.output.length === graph.nodes.length){\n        alert('Kahn complete. Output length = nodes count.');\n      } else {\n        alert('Queue empty and graph still has nodes: cycle detected or disconnected components with cycles.');\n      }\n      return;\n    }\n    // pop smallest element (lexicographic) to keep determinism\n    const u = kahnState.queue.shift();\n    kahnState.output.push(u);\n    // reduce indegree\n    (graph.adj[u]||[]).forEach(v=>{\n      kahnState.indeg[v]--;\n      if(kahnState.indeg[v] === 0){\n        kahnState.queue.push(v);\n      }\n    });\n    kahnState.queue.sort();\n    kahnState.steps.push(snapshotKahn(kahnState));\n    kahnState.index = kahnState.steps.length-1;\n    updateKahnViews();\n    logAction('Kahn step: popped ' + u);\n  }\n  function kahnPrev(){\n    if(!kahnState) return;\n    if(kahnState.steps.length <= 1){\n      alert('At initial state');\n      return;\n    }\n    // move back one step by popping last snapshot (but maintain snapshots)\n    kahnState.steps.pop();\n    const prev = kahnState.steps[kahnState.steps.length-1];\n    kahnState.queue = prev.queue.slice();\n    kahnState.output = prev.output.slice();\n    kahnState.indeg = Object.assign({}, prev.indeg);\n    kahnState.index = kahnState.steps.length-1;\n    updateKahnViews();\n    logAction('Kahn moved back one step');\n  }\n  function kahnReset(){\n    kahnState = null;\n    clearInterval(kahnTimer);\n    kahnTimer = null;\n    updateKahnViews();\n    logAction('Kahn reset');\n  }\n  document.getElementById('kahnInitBtn').addEventListener('click', initKahn);\n  document.getElementById('kahnNextBtn').addEventListener('click', kahnNext);\n  document.getElementById('kahnPrevBtn').addEventListener('click', kahnPrev);\n  document.getElementById('kahnResetBtn').addEventListener('click', kahnReset);\n  document.getElementById('kahnAutoBtn').addEventListener('click', ()=>{\n    if(kahnTimer) return;\n    if(!kahnState) initKahn();\n    kahnTimer = setInterval(()=>{\n      kahnNext();\n      if(kahnState && kahnState.output.length === graph.nodes.length) { clearInterval(kahnTimer); kahnTimer = null; logAction('Kahn auto-play finished'); }\n    }, parseInt(document.getElementById('kahnSpeed').value,10));\n    logAction('Kahn auto-play started');\n  });\n  document.getElementById('kahnPauseBtn').addEventListener('click', ()=>{ clearInterval(kahnTimer); kahnTimer=null; logAction('Kahn auto-play paused'); });\n\n  // DFS-based toposort stepper\n  let dfsState = null;\n  let dfsTimer = null;\n  function initDFS(){\n    // prepare structures for iterative step simulation\n    const nodes = graph.nodes.slice().sort();\n    dfsState = {\n      nodes: nodes,\n      vis: {}, // 0 un, 1 visiting, 2 done\n      stack: [], // call stack for simulated recursion [ {node, iterIndex} ]\n      output: [],\n      steps: [],\n      index: -1\n    };\n    // ready to start from first unvisited node\n    dfsState.steps.push(snapshotDFS(dfsState));\n    updateDFSViews();\n    logAction('DFS initialized');\n  }\n  function snapshotDFS(s){\n    return { vis: Object.assign({}, s.vis), stack: s.stack.map(x=> ({node:x.node, i:x.i})), output: s.output.slice() };\n  }\n  function updateDFSViews(){\n    if(!dfsState){ document.getElementById('dfsState').textContent=''; document.getElementById('dfsOutput').textContent=''; document.getElementById('dfsLog').textContent=''; return; }\n    document.getElementById('dfsState').textContent = 'vis: { ' + Object.keys(dfsState.vis).map(k=> k+':'+dfsState.vis[k]).join(', ') + ' }';\n    document.getElementById('dfsOutput').textContent = '['+ dfsState.output.join(',') +']';\n    const logText = dfsState.steps.map((st,i)=> i + ': output=' + '['+st.output.join(',')+'] stack=' + (dfsState.stack.map(s=>s.node).join('>')) ).join('\\\\n');\n    document.getElementById('dfsLog').textContent = logText;\n  }\n  function dfsNext(){\n    if(!dfsState) { alert('Initialize DFS first'); return; }\n    // if stack empty, find next unvisited node\n    function findNextUnvisited(){\n      for(const n of dfsState.nodes) if(!dfsState.vis[n]) return n;\n      return null;\n    }\n    if(dfsState.stack.length === 0){\n      const next = findNextUnvisited();\n      if(!next){\n        alert('DFS complete');\n        return;\n      }\n      // push new frame\n      dfsState.stack.push({node: next, i: 0});\n      dfsState.vis[next] = 1;\n      dfsState.steps.push(snapshotDFS(dfsState));\n      updateDFSViews();\n      logAction('DFS visit start: ' + next);\n      return;\n    }\n    // process top of stack\n    const top = dfsState.stack[dfsState.stack.length - 1];\n    const neighbors = graph.adj[top.node] || [];\n    if(top.i < neighbors.length){\n      const v = neighbors[top.i];\n      top.i++;\n      if(!dfsState.vis[v]){\n        // push v\n        dfsState.stack.push({node: v, i: 0});\n        dfsState.vis[v] = 1;\n        dfsState.steps.push(snapshotDFS(dfsState));\n        updateDFSViews();\n        logAction('DFS visiting: ' + v);\n        return;\n      } else {\n        // already visited or visiting -> skip; if visiting then cycle\n        if(dfsState.vis[v] === 1){\n          logAction('DFS found back-edge (cycle) ' + top.node + ' -> ' + v);\n        }\n        // continue in same frame\n        dfsState.steps.push(snapshotDFS(dfsState));\n        updateDFSViews();\n        return;\n      }\n    } else {\n      // finish node\n      dfsState.stack.pop();\n      dfsState.vis[top.node] = 2;\n      dfsState.output.push(top.node);\n      dfsState.steps.push(snapshotDFS(dfsState));\n      updateDFSViews();\n      logAction('DFS finished node: ' + top.node);\n      return;\n    }\n  }\n  function dfsPrev(){\n    if(!dfsState) return;\n    if(dfsState.steps.length <= 1){\n      alert('At initial DFS state');\n      return;\n    }\n    // pop last snapshot\n    dfsState.steps.pop();\n    const prev = dfsState.steps[dfsState.steps.length-1];\n    dfsState.vis = Object.assign({}, prev.vis);\n    dfsState.output = prev.output.slice();\n    // we cannot fully recover stack from prev snapshot easily (but we saved stack at snapshot)\n    dfsState.stack = prev.stack.map(x=>({node:x.node, i:x.i}));\n    dfsState.index = dfsState.steps.length-1;\n    updateDFSViews();\n    logAction('DFS moved back one step');\n  }\n  function dfsReset(){\n    dfsState = null;\n    clearInterval(dfsTimer);\n    dfsTimer = null;\n    updateDFSViews();\n    logAction('DFS reset');\n  }\n  document.getElementById('dfsInitBtn').addEventListener('click', initDFS);\n  document.getElementById('dfsNextBtn').addEventListener('click', dfsNext);\n  document.getElementById('dfsPrevBtn').addEventListener('click', dfsPrev);\n  document.getElementById('dfsResetBtn').addEventListener('click', dfsReset);\n  document.getElementById('dfsAutoBtn').addEventListener('click', ()=>{\n    if(dfsTimer) return;\n    if(!dfsState) initDFS();\n    dfsTimer = setInterval(()=>{\n      dfsNext();\n      // stop when finished: when output length == nodes length\n      if(dfsState && dfsState.output.length === graph.nodes.length){\n        clearInterval(dfsTimer); dfsTimer = null; logAction('DFS auto-play finished');\n      }\n    }, parseInt(document.getElementById('dfsSpeed').value,10));\n    logAction('DFS auto-play started');\n  });\n  document.getElementById('dfsPauseBtn').addEventListener('click', ()=>{ clearInterval(dfsTimer); dfsTimer=null; logAction('DFS auto-play paused'); });\n\n  // Enumerate all topological orders (backtracking), with limit control\n  let allOrders = [];\n  let enumRunning = false;\n  let currentOrderIndex = 0;\n  function enumerateAll(){\n    const limit = parseInt(document.getElementById('enumLimit').value,10) || 8;\n    if(graph.nodes.length > limit){\n      if(!confirm('Graph has ' + graph.nodes.length + ' nodes. Enumeration may be expensive. Continue?')) return;\n    }\n    const forcedStart = document.getElementById('enumStartNode').value.trim() || null;\n    allOrders = [];\n    enumRunning = true;\n    document.getElementById('ordersCount').textContent = '...';\n    logAction('Enumeration started');\n    // backtracking algorithm using indeg\n    const indeg = computeIndegreeMap(graph);\n    const used = {};\n    const order = [];\n    const nodesList = graph.nodes.slice().sort();\n    let maxEnumerate = 50000; // safety cap\n    function backtrack(){\n      if(!enumRunning) return;\n      if(order.length === nodesList.length){\n        allOrders.push(order.slice());\n        if(allOrders.length >= maxEnumerate){\n          enumRunning = false;\n          return;\n        }\n        return;\n      }\n      // candidates: nodes with indeg==0 and not used\n      let cand = nodesList.filter(n => indeg[n] === 0 && !used[n]);\n      cand.sort();\n      // if forced start present and position 0 choose only that\n      if(order.length === 0 && forcedStart){\n        if(!cand.includes(forcedStart)) return;\n        cand = [forcedStart];\n      }\n      for(const n of cand){\n        // choose\n        used[n] = true;\n        order.push(n);\n        // reduce indeg of neighbors\n        (graph.adj[n]||[]).forEach(v => indeg[v]--);\n        backtrack();\n        // restore\n        (graph.adj[n]||[]).forEach(v => indeg[v]++);\n        order.pop();\n        used[n] = false;\n        if(!enumRunning) return;\n      }\n    }\n    // Run backtracking synchronously but it may be heavy; provide feedback\n    setTimeout(()=> {\n      backtrack();\n      enumRunning = false;\n      document.getElementById('ordersCount').textContent = allOrders.length;\n      currentOrderIndex = 0;\n      document.getElementById('currentOrder').textContent = allOrders.length>0 ? allOrders[0].join(',') : '-';\n      logAction('Enumeration completed, count=' + allOrders.length);\n    }, 10);\n  }\n  document.getElementById('enumAllBtn').addEventListener('click', enumerateAll);\n  document.getElementById('enumStopBtn').addEventListener('click', ()=>{\n    enumRunning = false;\n    logAction('Enumeration stopped by user');\n  });\n  document.getElementById('orderNextBtn').addEventListener('click', ()=>{\n    if(allOrders.length===0) return;\n    currentOrderIndex = (currentOrderIndex + 1) % allOrders.length;\n    document.getElementById('currentOrder').textContent = allOrders[currentOrderIndex].join(',');\n  });\n  document.getElementById('orderPrevBtn').addEventListener('click', ()=>{\n    if(allOrders.length===0) return;\n    currentOrderIndex = (currentOrderIndex - 1 + allOrders.length) % allOrders.length;\n    document.getElementById('currentOrder').textContent = allOrders[currentOrderIndex].join(',');\n  });\n  document.getElementById('orderCopyBtn').addEventListener('click', ()=>{\n    if(allOrders.length===0) return;\n    document.getElementById('seqInput').value = allOrders[currentOrderIndex].join(',');\n    logAction('Copied order #' + currentOrderIndex + ' to sequence input');\n  });\n\n  // Sequence validation / rank assignment / incremental edge add\n  function checkSequence(seq){\n    const seqArr = seq.split(',').map(s=> s.trim()).filter(s=> s);\n    if(seqArr.length !== graph.nodes.length){\n      return {valid: false, reason: 'Sequence length differs from number of nodes ('+graph.nodes.length+')'};\n    }\n    // map positions\n    const pos = {};\n    for(let i=0;i<seqArr.length;i++) pos[seqArr[i]] = i;\n    // ensure nodes match\n    const missing = graph.nodes.filter(n=> !(n in pos));\n    if(missing.length>0) return {valid:false, reason: 'Missing nodes: ' + missing.join(',')};\n    // check edges: for each u->v pos[u] < pos[v]\n    for(const u of graph.nodes){\n      for(const v of (graph.adj[u]||[])){\n        if(pos[u] >= pos[v]) return {valid:false, reason: 'Edge ' + u + '->' + v + ' violates order'};\n      }\n    }\n    return {valid:true};\n  }\n\n  document.getElementById('checkSeqBtn').addEventListener('click', ()=>{\n    const seq = document.getElementById('seqInput').value;\n    if(!seq){ alert('Enter a comma separated sequence'); return; }\n    const res = checkSequence(seq);\n    document.getElementById('seqCheckResult').textContent = res.valid ? 'Valid topological order' : ('Invalid: ' + res.reason);\n    logAction('Sequence checked, valid=' + res.valid);\n  });\n\n  document.getElementById('assignRankBtn').addEventListener('click', ()=>{\n    const seq = document.getElementById('rankSeqInput').value;\n    if(!seq){ alert('Enter a comma separated sequence'); return; }\n    const seqArr = seq.split(',').map(s=> s.trim()).filter(s=> s);\n    const map = {};\n    for(let i=0;i<seqArr.length;i++) map[seqArr[i]] = i;\n    // assign any missing nodes to end\n    const miss = graph.nodes.filter(n=> !(n in map));\n    let msg = 'Assigned ranks:\\\\n';\n    graph.nodes.forEach(n=>{\n      const r = map.hasOwnProperty(n)? map[n] : (seqArr.length + miss.indexOf(n));\n      msg += n + ' -> ' + r + '\\\\n';\n    });\n    alert(msg);\n    logAction('Ranks assigned from sequence');\n  });\n\n  document.getElementById('incrAddEdgeBtn').addEventListener('click', ()=>{\n    const f = document.getElementById('incrFrom').value.trim();\n    const t = document.getElementById('incrTo').value.trim();\n    if(!f || !t){ alert('Enter from and to nodes'); return; }\n    if(!graph.nodes.includes(f) || !graph.nodes.includes(t)){ alert('Both nodes must exist'); return; }\n    // Try optimistic incremental update: if we have a current Kahn output that is a topological order, see if adding edge still respects it\n    const currOrder = kahnState && kahnState.output.length === graph.nodes.length ? kahnState.output.slice() : null;\n    // add edge tentatively and test\n    pushHistory();\n    graph.adj[f].push(t);\n    const cycleRes = detectCycle(graph);\n    if(cycleRes.cycle){\n      // undo\n      history.pop(); // remove record of pushHistory because we will revert\n      future = [];\n      // revert by popping last state (we had pushed before adding)\n      if(history.length>0){\n        const prev = history.pop();\n        graph = { nodes: prev.nodes.slice(), adj: {} };\n        prev.nodes.forEach(n=> graph.adj[n] = (prev.adj[n] || []).slice());\n      } else {\n        // fallback: remove the edge we just added\n        graph.adj[f] = graph.adj[f].filter(x=> x !== t);\n      }\n      refreshUI();\n      document.getElementById('incrResult').textContent = 'Edge creates cycle: ' + cycleRes.path.join('->');\n      logAction('Incremental edge add failed (cycle)');\n      return;\n    }\n    // successful insert\n    refreshUI();\n    // Try to update existing order if present\n    if(currOrder){\n      // test if currOrder respects new edge\n      const pos = {};\n      for(let i=0;i<currOrder.length;i++) pos[currOrder[i]] = i;\n      if(pos[f] < pos[t]){\n        document.getElementById('incrResult').textContent = 'Edge added; existing order remains valid';\n      } else {\n        document.getElementById('incrResult').textContent = 'Edge added; existing order invalidated. A recompute is needed.';\n      }\n    } else {\n      document.getElementById('incrResult').textContent = 'Edge added';\n    }\n    logAction('Incremental edge added: ' + f + '->' + t);\n  });\n\n  // Save graph on load (empty)\n  refreshUI();\n  logAction('Interactive Topological Sort demo loaded');\n\n  // Export/import keyboard helpers\n  document.addEventListener('keydown', (e)=>{\n    if(e.ctrlKey && e.key === 's'){ e.preventDefault(); exportGraph(); }\n  });\n\n})();\n</script>\n\n</body>\n</html>"
