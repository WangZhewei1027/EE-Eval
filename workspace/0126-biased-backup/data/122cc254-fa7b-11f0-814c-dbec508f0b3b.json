    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deadlock</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n            margin: 0;\n            padding: 0;\n        }\n        .container {\n            width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        .button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #ccc;\n        }\n        .input-field {\n            padding: 10px;\n            font-size: 16px;\n            margin-bottom: 20px;\n        }\n        .input-field input {\n            padding: 10px;\n            font-size: 16px;\n        }\n        .button-group {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 20px;\n        }\n        .button-group button {\n            width: 40%;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Deadlock Simulator</h1>\n        <button id=\"reset-button\">Reset</button>\n        <button id=\"increase-value-button\">Increase Value</button>\n        <button id=\"decrease-value-button\">Decrease Value</button>\n        <button id=\"add-value-button\">Add Value</button>\n        <button id=\"subtract-value-button\">Subtract Value</button>\n        <button id=\"save-button\">Save</button>\n        <button id=\"load-button\">Load</button>\n        <div class=\"button-group\">\n            <button id=\"max-value-button\">Max Value</button>\n            <button id=\"min-value-button\">Min Value</button>\n            <button id=\"random-value-button\">Random Value</button>\n        </div>\n        <div class=\"input-field\">\n            <label for=\"value-input\">Value:</label>\n            <input type=\"number\" id=\"value-input\" value=\"0\">\n        </div>\n        <div class=\"input-field\">\n            <label for=\"max-value-input\">Max Value:</label>\n            <input type=\"number\" id=\"max-value-input\" value=\"100\">\n        </div>\n        <div class=\"input-field\">\n            <label for=\"min-value-input\">Min Value:</label>\n            <input type=\"number\" id=\"min-value-input\" value=\"0\">\n        </div>\n        <div class=\"input-field\">\n            <label for=\"random-value-input\">Random Value:</label>\n            <input type=\"number\" id=\"random-value-input\" value=\"0\">\n        </div>\n    </div>\n\n    <script>\n        let currentValue = 0;\n        let maxValue = 100;\n        let minValue = 0;\n        let randomValue = 0;\n\n        document.getElementById(\"reset-button\").addEventListener(\"click\", () => {\n            currentValue = 0;\n            maxValue = 100;\n            minValue = 0;\n            randomValue = 0;\n            document.getElementById(\"value-input\").value = \"0\";\n            document.getElementById(\"max-value-input\").value = \"100\";\n            document.getElementById(\"min-value-input\").value = \"0\";\n            document.getElementById(\"random-value-input\").value = \"0\";\n        });\n\n        document.getElementById(\"increase-value-button\").addEventListener(\"click\", () => {\n            currentValue++;\n            document.getElementById(\"value-input\").value = currentValue.toString();\n        });\n\n        document.getElementById(\"decrease-value-button\").addEventListener(\"click\", () => {\n            currentValue--;\n            document.getElementById(\"value-input\").value = currentValue.toString();\n        });\n\n        document.getElementById(\"add-value-button\").addEventListener(\"click\", () => {\n            currentValue += 10;\n            document.getElementById(\"value-input\").value = currentValue.toString();\n        });\n\n        document.getElementById(\"subtract-value-button\").addEventListener(\"click\", () => {\n            currentValue -= 10;\n            document.getElementById(\"value-input\").value = currentValue.toString();\n        });\n\n        document.getElementById(\"save-button\").addEventListener(\"click\", () => {\n            localStorage.setItem(\"currentValue\", currentValue.toString());\n            localStorage.setItem(\"maxValue\", maxValue.toString());\n            localStorage.setItem(\"minValue\", minValue.toString());\n            localStorage.setItem(\"randomValue\", randomValue.toString());\n        });\n\n        document.getElementById(\"load-button\").addEventListener(\"click\", () => {\n            currentValue = parseInt(localStorage.getItem(\"currentValue\"));\n            maxValue = parseInt(localStorage.getItem(\"maxValue\"));\n            minValue = parseInt(localStorage.getItem(\"minValue\"));\n            randomValue = parseInt(localStorage.getItem(\"randomValue\"));\n            document.getElementById(\"value-input\").value = currentValue.toString();\n            document.getElementById(\"max-value-input\").value = maxValue.toString();\n            document.getElementById(\"min-value-input\").value = minValue.toString();\n            document.getElementById(\"random-value-input\").value = randomValue.toString();\n        });\n\n        document.getElementById(\"max-value-button\").addEventListener(\"click\", () => {\n            maxValue = parseInt(document.getElementById(\"max-value-input\").value);\n            document.getElementById(\"max-value-input\").value = maxValue.toString();\n        });\n\n        document.getElementById(\"min-value-button\").addEventListener(\"click\", () => {\n            minValue = parseInt(document.getElementById(\"min-value-input\").value);\n            document.getElementById(\"min-value-input\").value = minValue.toString();\n        });\n\n        document.getElementById(\"random-value-button\").addEventListener(\"click\", () => {\n            randomValue = Math.floor(Math.random() * 101);\n            document.getElementById(\"random-value-input\").value = randomValue.toString();\n        });\n\n        document.getElementById(\"max-value-button\").addEventListener(\"click\", () => {\n            maxValue = 100;\n            document.getElementById(\"max-value-input\").value = maxValue.toString();\n        });\n\n        document.getElementById(\"min-value-button\").addEventListener(\"click\", () => {\n            minValue = 0;\n            document.getElementById(\"min-value-input\").value = minValue.toString();\n        });\n\n        document.getElementById(\"random-value-button\").addEventListener(\"click\", () => {\n            randomValue = 0;\n            document.getElementById(\"random-value-input\").value = randomValue.toString();\n        });\n    </script>\n</body>\n</html>"
