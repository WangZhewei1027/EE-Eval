  "question": "Software Development Life Cycle",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>SDLC Interactive Lab</title>\n<style>\n/* Minimal plain layout: black text on white, basic elements only */\nbody { font-family: sans-serif; margin: 8px; color: #000; background: #fff; }\n.header { margin-bottom: 8px; }\n.controls { display: flex; gap: 12px; margin-bottom: 8px; }\n.column-wrap { display: flex; gap: 12px; align-items: flex-start; }\n.col { padding: 6px; border: 1px solid #000; min-width: 260px; max-width: 420px; }\n.col h3 { margin: 4px 0; }\n.field { margin: 4px 0; }\n.small { font-size: 12px; }\n.task { padding: 6px; margin: 4px 0; border: 1px dotted #000; cursor: move; background: white; }\n.task .meta { font-size: 11px; margin-top: 4px; }\ntextarea { width: 100%; box-sizing: border-box; }\n.log { height: 160px; overflow: auto; font-size: 12px; white-space: pre-wrap; background: #fff; }\n.btn { margin: 2px; }\n.list { min-height: 40px; }\n.hidden { display: none; }\n.inline { display: inline-block; }\n.controls-block { margin-bottom: 8px; }\n</style>\n</head>\n<body>\n<div class=\"header\">\n  <h1>Software Development Life Cycle - Interactive Lab</h1>\n  <div class=\"small\">A sandbox to create, move, simulate, and explore SDLC workflows. Minimal UI; heavy interaction.</div>\n</div>\n\n<div class=\"controls\">\n  <div class=\"col\" id=\"project-col\">\n    <h3>Project Setup</h3>\n    <div class=\"field\">\n      <label>Project name: <input id=\"proj-name\" value=\"Demo App\"></label>\n    </div>\n    <div class=\"field\">\n      <label>Process model:\n        <select id=\"process-model\">\n          <option value=\"waterfall\">Waterfall</option>\n          <option value=\"agile\" selected>Agile (Kanban/Scrum)</option>\n          <option value=\"spiral\">Spiral</option>\n          <option value=\"devops\">DevOps / Continuous</option>\n        </select>\n      </label>\n    </div>\n    <div class=\"field\">\n      <label>Developers: <input id=\"dev-count\" type=\"number\" value=\"3\" min=\"1\" style=\"width:60px\"></label>\n      <label>Testers: <input id=\"test-count\" type=\"number\" value=\"2\" min=\"0\" style=\"width:60px\"></label>\n    </div>\n    <div class=\"field small\">\n      <label>Dev speed: <input id=\"dev-speed\" type=\"range\" min=\"1\" max=\"10\" value=\"6\"> <span id=\"dev-speed-val\">6</span></label>\n    </div>\n    <div class=\"field small\">\n      <label>Test thoroughness: <input id=\"test-thorough\" type=\"range\" min=\"0\" max=\"100\" value=\"60\"> <span id=\"test-thorough-val\">60</span>%</label>\n    </div>\n    <div class=\"field small\">\n      <label>Defect injection: <input id=\"defect-rate\" type=\"range\" min=\"0\" max=\"100\" value=\"15\"> <span id=\"defect-rate-val\">15</span>%</label>\n    </div>\n    <div class=\"field small\">\n      <label>Automation level: <input id=\"automation\" type=\"range\" min=\"0\" max=\"100\" value=\"30\"> <span id=\"automation-val\">30</span>%</label>\n    </div>\n\n    <div class=\"controls-block\">\n      <button id=\"init-proj\" class=\"btn\">Initialize / Reset Project</button>\n      <button id=\"create-demo\" class=\"btn\">Create Demo Tasks</button>\n    </div>\n\n    <div class=\"field\">\n      <label>Auto-run step interval (ms): <input id=\"auto-interval\" type=\"number\" value=\"1200\" style=\"width:80px\"></label>\n    </div>\n\n    <div class=\"controls-block\">\n      <button id=\"run-toggle\" class=\"btn\">Start Auto-Run</button>\n      <button id=\"step\" class=\"btn\">Step Once</button>\n      <button id=\"pause\" class=\"btn\">Pause</button>\n      <button id=\"advance-day\" class=\"btn\">Advance 1 Day</button>\n      <input id=\"advance-days\" type=\"number\" value=\"3\" style=\"width:60px\">\n      <button id=\"advance-n\" class=\"btn\">Advance N Days</button>\n      <button id=\"fast-run\" class=\"btn\">Fast Run 50 Steps</button>\n    </div>\n  </div>\n\n  <div class=\"col\" id=\"task-ops\">\n    <h3>Task Operations</h3>\n\n    <div class=\"field\">\n      <input id=\"new-title\" placeholder=\"Task title\" style=\"width:60%\">\n      <select id=\"new-type\">\n        <option value=\"feature\">Feature</option>\n        <option value=\"bug\">Bug</option>\n        <option value=\"spike\">Spike</option>\n        <option value=\"chore\">Chore</option>\n      </select>\n      <input id=\"new-est\" type=\"number\" min=\"1\" value=\"3\" style=\"width:60px\">\n      <button id=\"create-task\" class=\"btn\">Create Task</button>\n    </div>\n\n    <div class=\"field\">\n      <label>Default start stage:\n        <select id=\"start-stage\"></select>\n      </label>\n    </div>\n\n    <div class=\"field\">\n      <button id=\"inject-change\" class=\"btn\">Inject Change Request (forces rework)</button>\n      <button id=\"trigger-hotfix\" class=\"btn\">Trigger Hotfix (create urgent bug)</button>\n      <button id=\"create-spike\" class=\"btn\">Create Spike</button>\n    </div>\n\n    <div class=\"field\">\n      <button id=\"split-task\" class=\"btn\">Split Selected Task</button>\n      <button id=\"merge-tasks\" class=\"btn\">Merge Selected Tasks</button>\n      <button id=\"duplicate-task\" class=\"btn\">Duplicate Selected</button>\n    </div>\n\n    <div class=\"field\">\n      <label><input type=\"checkbox\" id=\"allow-dnd\" checked> Allow drag & drop</label>\n      <label><input type=\"checkbox\" id=\"auto-approve\"> Auto-approve gates</label>\n    </div>\n\n    <div class=\"field\">\n      <div class=\"small\">Selected task id: <span id=\"selected-id\">none</span></div>\n      <div><button id=\"open-detail\" class=\"btn\">Open Details</button>\n        <button id=\"delete-task\" class=\"btn\">Delete</button>\n        <button id=\"mark-blocked\" class=\"btn\">Toggle Blocked</button>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"col\" id=\"process-col\">\n    <h3>Process Controls</h3>\n    <div class=\"field small\">Current Model Rules & Controls</div>\n    <div class=\"field\">\n      <label>Gate threshold (test% required to pass to Deploy): <input id=\"gate-threshold\" type=\"number\" min=\"0\" max=\"100\" value=\"50\" style=\"width:60px\"></label>\n    </div>\n    <div class=\"field\">\n      <button id=\"enforce-waterfall\" class=\"btn\">Enforce Waterfall Constraints</button>\n      <button id=\"open-gate\" class=\"btn\">Force Open Gate</button>\n      <button id=\"rollback-deploy\" class=\"btn\">Rollback Last Deploy</button>\n    </div>\n    <div class=\"field\">\n      <label>Risk appetite: <input id=\"risk-appetite\" type=\"range\" min=\"0\" max=\"100\" value=\"40\"></label>\n    </div>\n    <div class=\"field\">\n      <label>Simulate outage: <input id=\"simulate-outage\" type=\"checkbox\"></label>\n      <button id=\"resolve-outage\" class=\"btn\">Resolve Outage</button>\n    </div>\n  </div>\n</div>\n\n<div class=\"column-wrap\">\n  <div class=\"col\" id=\"board-col\">\n    <h3>Board</h3>\n    <div class=\"small\">Drag tasks between stages (if allowed). Click task for detail. Right-click to quick actions.</div>\n    <div id=\"board\" style=\"display:flex; gap:8px; margin-top:8px; overflow:auto;\"></div>\n  </div>\n\n  <div class=\"col\" id=\"details-col\">\n    <h3>Task Detail / Editor</h3>\n    <div id=\"detail-panel\">\n      <div class=\"small\">Select a task to view/edit details.</div>\n      <div id=\"detail-form\" class=\"hidden\">\n        <div class=\"field\"><b id=\"detail-title\"></b> (<span id=\"detail-id\"></span>)</div>\n        <div class=\"field\">\n          <label>Title: <input id=\"detail-name\" style=\"width:100%\"></label>\n        </div>\n        <div class=\"field\">\n          <label>Type:\n            <select id=\"detail-type\">\n              <option value=\"feature\">Feature</option>\n              <option value=\"bug\">Bug</option>\n              <option value=\"spike\">Spike</option>\n              <option value=\"chore\">Chore</option>\n            </select>\n          </label>\n        </div>\n        <div class=\"field\">\n          <label>Estimate (days): <input id=\"detail-est\" type=\"number\" style=\"width:80px\"></label>\n          <label>Spent: <input id=\"detail-spent\" type=\"number\" style=\"width:80px\"></label>\n        </div>\n        <div class=\"field\">\n          <label>Assigned to: <input id=\"detail-assigned\" style=\"width:60%\"></label>\n          <label>Priority:\n            <select id=\"detail-priority\">\n              <option>Low</option><option selected>Normal</option><option>High</option><option>Urgent</option>\n            </select>\n          </label>\n        </div>\n        <div class=\"field\">\n          <label>Status (stage):\n            <select id=\"detail-stage\"></select>\n          </label>\n        </div>\n        <div class=\"field\">\n          <label>Blocked: <input id=\"detail-blocked\" type=\"checkbox\"></label>\n          <label>Deployed: <input id=\"detail-deployed\" type=\"checkbox\"></label>\n        </div>\n        <div class=\"field\">\n          <label>Notes:</label>\n          <textarea id=\"detail-notes\" rows=\"4\"></textarea>\n        </div>\n        <div class=\"field\">\n          <button id=\"save-detail\" class=\"btn\">Save</button>\n          <button id=\"close-detail\" class=\"btn\">Close</button>\n          <button id=\"add-comment\" class=\"btn\">Add Comment</button>\n          <button id=\"create-dep\" class=\"btn\">Add Dependency (selected)</button>\n        </div>\n        <div class=\"field small\">\n          <b>Dependencies:</b> <span id=\"detail-deps\">none</span>\n        </div>\n        <div class=\"field small\">\n          <b>Comments:</b>\n          <div id=\"detail-comments\" style=\"border:1px solid #000; padding:4px; max-height:100px; overflow:auto;\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"col\" id=\"analytics-col\">\n    <h3>Analytics & Log</h3>\n    <div class=\"field small\">\n      <div>Day: <span id=\"sim-day\">0</span></div>\n      <div>Completed: <span id=\"metric-completed\">0</span></div>\n      <div>In Progress: <span id=\"metric-inprog\">0</span></div>\n      <div>Open Defects: <span id=\"metric-defects\">0</span></div>\n      <div>Velocity (avg): <span id=\"metric-vel\">0</span></div>\n      <div>Avg Cycle Time: <span id=\"metric-cycle\">0</span> days</div>\n    </div>\n\n    <div class=\"field\">\n      <b>History Log</b>\n      <div id=\"log\" class=\"log\"></div>\n    </div>\n\n    <div class=\"field\">\n      <b>Scenario / Scripts</b>\n      <div><textarea id=\"script\" rows=\"6\" placeholder=\"Type simple commands: create feature X; run 5; inject change; hotfix\"></textarea></div>\n      <div>\n        <button id=\"run-script\" class=\"btn\">Run Script</button>\n        <button id=\"clear-log\" class=\"btn\">Clear Log</button>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n/*\n  SDLC Interactive Lab\n  - Plain UI (black on white)\n  - Many interactive controls: create tasks, drag/drop, simulate steps, process models\n  - Complex state transitions and exploration capabilities\n*/\n\n(function(){\n  // Utilities\n  const uid = (() => { let n=1; return (p='') => (p? p+'-':'') + (n++); })();\n  function now(){ return Date.now(); }\n  function clamp(v,a,b){ return Math.max(a,Math.min(b,v)); }\n\n  // State\n  let state = {\n    projectName: 'Demo App',\n    model: 'agile',\n    devCount: 3,\n    testCount: 2,\n    devSpeed: 6,\n    testThorough: 60,\n    defectRate: 15,\n    automation: 30,\n    gateThreshold: 50,\n    selectedTask: null,\n    allowDnd: true,\n    autoApprove: false,\n    day: 0,\n    tasks: [],\n    history: [],\n    running: false,\n    autoTimer: null,\n    outage: false,\n    lastDeploySnapshot: null\n  };\n\n  // Process model rules\n  const models = {\n    waterfall: {\n      name: 'Waterfall',\n      stages: ['Planning','Requirements','Design','Implementation','Testing','Deployment','Maintenance'],\n      canMove: (fromIdx,toIdx,task,s) => {\n        // Waterfall strongly sequential: only forward to next stage allowed unless gate override\n        if(s.autoApprove) return true;\n        if(task.blocked) return false;\n        if(toIdx === fromIdx+1) return true;\n        // allow moving to Maintenance from Deploy or backward only by change requests\n        if(toIdx > fromIdx+1) return false;\n        // don't allow backward moves unless change/injected\n        return false;\n      },\n      description: 'Strict sequential flow. Each phase completes before next starts. Backward moves limited.'\n    },\n    agile: {\n      name: 'Agile',\n      stages: ['Backlog','Ready','In Progress','Review','Testing','Done','Deploy'],\n      canMove: (fromIdx,toIdx,task,s) => {\n        if(task.blocked) return false;\n        // Agile: allow flexible moves but prevent skipping Review/Testing before Done unless automation high\n        if(toIdx > fromIdx + 2 && s.automation < 80) return false;\n        return true;\n      },\n      description: 'Flexible iterative flow. Encourages frequent deliveries.'\n    },\n    spiral: {\n      name: 'Spiral',\n      stages: ['Concept','Prototype','Evaluate','Refine','Implementation','Test','Release'],\n      canMove: (fromIdx,toIdx,task,s) => {\n        // Allow cycles back and forth; require evaluation after prototype\n        if(task.blocked) return false;\n        if(fromIdx === 1 && toIdx === 2) return true;\n        return true;\n      },\n      description: 'Iterative with risk analysis loops.'\n    },\n    devops: {\n      name: 'DevOps',\n      stages: ['Ideate','Develop','CI','QA','Staging','Production','Operate'],\n      canMove: (fromIdx,toIdx,task,s) => {\n        if(task.blocked) return false;\n        // DevOps allows quick deployment if automation high and tests pass\n        if(toIdx >= 5) {\n          // going to Production requires tests >= gateThreshold or automation compensates\n          let effective = s.testThorough + s.automation*0.5;\n          return effective >= s.gateThreshold;\n        }\n        return true;\n      },\n      description: 'Continuous integration/delivery with automated gates.'\n    }\n  };\n\n  // DOM refs\n  const $ = id => document.getElementById(id);\n  const boardEl = $('board');\n  const startStageSelect = $('start-stage');\n  const detailStageSelect = $('detail-stage');\n\n  // Initialize\n  function init(){\n    // Wire controls\n    $('proj-name').value = state.projectName;\n    $('process-model').value = state.model;\n    $('dev-count').value = state.devCount;\n    $('test-count').value = state.testCount;\n    $('dev-speed').value = state.devSpeed;\n    $('dev-speed-val').textContent = state.devSpeed;\n    $('test-thorough').value = state.testThorough;\n    $('test-thorough-val').textContent = state.testThorough;\n    $('defect-rate').value = state.defectRate;\n    $('defect-rate-val').textContent = state.defectRate;\n    $('automation').value = state.automation;\n    $('automation-val').textContent = state.automation;\n    $('gate-threshold').value = state.gateThreshold;\n    $('risk-appetite').value = 40;\n\n    // Event bindings\n    $('dev-speed').addEventListener('input', e => { state.devSpeed = +e.target.value; $('dev-speed-val').textContent = e.target.value; });\n    $('test-thorough').addEventListener('input', e => { state.testThorough = +e.target.value; $('test-thorough-val').textContent = e.target.value; });\n    $('defect-rate').addEventListener('input', e => { state.defectRate = +e.target.value; $('defect-rate-val').textContent = e.target.value; });\n    $('automation').addEventListener('input', e => { state.automation = +e.target.value; $('automation-val').textContent = e.target.value; });\n    $('process-model').addEventListener('change', e => { state.model = e.target.value; rebuildBoard(); log('Process model changed to ' + e.target.value); });\n    $('init-proj').addEventListener('click', initProject);\n    $('create-demo').addEventListener('click', createDemo);\n    $('create-task').addEventListener('click', createTaskFromForm);\n    $('start-stage').addEventListener('change', () => {});\n    $('run-toggle').addEventListener('click', toggleRun);\n    $('pause').addEventListener('click', pauseRun);\n    $('step').addEventListener('click', stepOnce);\n    $('advance-day').addEventListener('click', () => advanceDays(1));\n    $('advance-n').addEventListener('click', () => advanceDays(Number($('advance-days').value) || 0));\n    $('fast-run').addEventListener('click', () => fastRun(50));\n    $('auto-interval').addEventListener('change', () => { if(state.running){ pauseRun(); startAuto(); }});\n    $('allow-dnd').addEventListener('change', e => state.allowDnd = e.target.checked);\n    $('auto-approve').addEventListener('change', e => state.autoApprove = e.target.checked);\n    $('inject-change').addEventListener('click', injectChangeRequest);\n    $('trigger-hotfix').addEventListener('click', triggerHotfix);\n    $('create-spike').addEventListener('click', () => createTask({title:'Spike: investigate', type:'spike', est:2}));\n    $('split-task').addEventListener('click', splitSelectedTask);\n    $('merge-tasks').addEventListener('click', mergeSelectedTasks);\n    $('duplicate-task').addEventListener('click', duplicateSelected);\n    $('open-detail').addEventListener('click', openDetail);\n    $('delete-task').addEventListener('click', deleteSelected);\n    $('mark-blocked').addEventListener('click', toggleBlockedSelected);\n    $('enforce-waterfall').addEventListener('click', () => { $('process-model').value='waterfall'; $('process-model').dispatchEvent(new Event('change')); });\n    $('open-gate').addEventListener('click', forceOpenGate);\n    $('rollback-deploy').addEventListener('click', rollbackDeploy);\n    $('simulate-outage').addEventListener('change', e => { state.outage = e.target.checked; log('Outage simulated: ' + state.outage); });\n    $('resolve-outage').addEventListener('click', () => { state.outage=false; $('simulate-outage').checked=false; log('Outage resolved'); });\n    $('save-detail').addEventListener('click', saveDetail);\n    $('close-detail').addEventListener('click', closeDetail);\n    $('add-comment').addEventListener('click', addCommentDetail);\n    $('create-dep').addEventListener('click', addDependencyFromSelected);\n    $('run-script').addEventListener('click', runScript);\n    $('clear-log').addEventListener('click', () => { state.history=[]; $('log').textContent=''; });\n    $('start-stage').addEventListener('change', () => {});\n    $('gate-threshold').addEventListener('change', e => state.gateThreshold = +e.target.value);\n\n    // Board dnd events delegated later\n\n    initProject();\n  }\n\n  // Basic logging\n  function log(msg){\n    const time = 'Day'+state.day;\n    const entry = `[${time}] ${msg}`;\n    state.history.push(entry);\n    const el = $('log');\n    el.textContent = entry + '\\n' + el.textContent;\n  }\n\n  // Project init/reset\n  function initProject(){\n    state.projectName = $('proj-name').value || 'Project';\n    state.devCount = +$('dev-count').value || 1;\n    state.testCount = +$('test-count').value || 0;\n    state.model = $('process-model').value;\n    state.day = 0;\n    state.tasks = [];\n    state.selectedTask = null;\n    state.running = false;\n    if(state.autoTimer) clearInterval(state.autoTimer);\n    state.autoTimer = null;\n    $('run-toggle').textContent = 'Start Auto-Run';\n    $('sim-day').textContent = state.day;\n    log('Project initialized: ' + state.projectName + ' [' + state.model + ']');\n    rebuildBoard();\n    renderMetrics();\n  }\n\n  // Rebuild board columns based on model\n  function rebuildBoard(){\n    boardEl.innerHTML = '';\n    const model = models[state.model];\n    const stages = model.stages;\n    // fill start-stage and detail-stage selects\n    startStageSelect.innerHTML = '';\n    detailStageSelect.innerHTML = '';\n    stages.forEach((s,i) => {\n      const col = document.createElement('div');\n      col.style.minWidth = '160px';\n      col.style.flex = '1';\n      col.dataset.stage = s;\n      const h = document.createElement('div');\n      h.innerHTML = '<b>' + s + '</b>';\n      const list = document.createElement('div');\n      list.className = 'list';\n      list.id = 'col-'+i;\n      list.dataset.index = i;\n      list.style.minHeight = '60px';\n      list.addEventListener('dragover', onDragOver);\n      list.addEventListener('drop', onDrop);\n      list.addEventListener('contextmenu', onContextBoard);\n      col.appendChild(h);\n      col.appendChild(list);\n      boardEl.appendChild(col);\n\n      const opt = document.createElement('option');\n      opt.value = s; opt.textContent = s;\n      startStageSelect.appendChild(opt);\n      const opt2 = opt.cloneNode(true);\n      detailStageSelect.appendChild(opt2);\n    });\n    renderTasks();\n  }\n\n  // Task model\n  function createTask(opts){\n    const id = uid('T');\n    const t = {\n      id,\n      title: opts.title || ('Task ' + id),\n      type: opts.type || 'feature',\n      est: opts.est || 3,\n      spent: opts.spent || 0,\n      priority: opts.priority || 'Normal',\n      assigned: opts.assigned || null,\n      stage: opts.stage || models[state.model].stages[0],\n      blocked: !!opts.blocked,\n      deployed: !!opts.deployed,\n      notes: opts.notes || '',\n      comments: [],\n      deps: [],\n      createdDay: state.day,\n      completedDay: null,\n      history: []\n    };\n    t.history.push(`Created at day ${state.day}`);\n    state.tasks.push(t);\n    log('Created task ' + t.id + ': ' + t.title + ' [' + t.type + '] in stage ' + t.stage);\n    renderTasks();\n    return t;\n  }\n\n  function createTaskFromForm(){\n    const title = $('new-title').value || ('Task ' + (state.tasks.length+1));\n    const est = Number($('new-est').value) || 3;\n    const type = $('new-type').value;\n    const stage = startStageSelect.value || models[state.model].stages[0];\n    createTask({title, est, type, stage});\n    $('new-title').value='';\n  }\n\n  function createDemo(){\n    initProject();\n    // Create varied tasks across stages\n    const mm = models[state.model];\n    createTask({title:'Define product vision', type:'feature', est:2, stage:mm.stages[0]});\n    createTask({title:'User stories for v1', type:'feature', est:5, stage:mm.stages[1]||mm.stages[0]});\n    createTask({title:'Design API', type:'feature', est:4, stage:mm.stages.includes('Design')? 'Design' : mm.stages[2] || mm.stages[0]});\n    createTask({title:'Implement auth', type:'feature', est:6, stage:mm.stages.includes('Implementation')? 'Implementation': mm.stages[2]});\n    createTask({title:'Automated tests', type:'chore', est:3, stage:mm.stages.includes('Testing')? 'Testing': mm.stages[3]});\n    createTask({title:'Fix login bug', type:'bug', est:2, stage:mm.stages[2] || mm.stages[3]});\n    renderTasks();\n  }\n\n  // Rendering tasks on board\n  function renderTasks(){\n    // Clear lists\n    const cols = boardEl.querySelectorAll('.list');\n    cols.forEach(c => c.innerHTML = '');\n    // Place tasks into columns\n    state.tasks.forEach(t => {\n      const listIdx = models[state.model].stages.indexOf(t.stage);\n      const listEl = document.querySelector('#col-' + (listIdx>=0?listIdx:0));\n      if(!listEl) return;\n      const item = document.createElement('div');\n      item.className = 'task';\n      item.draggable = state.allowDnd;\n      item.dataset.id = t.id;\n      item.innerHTML = `<div><b>${t.title}</b> (${t.type})</div><div class=\"meta\">#${t.id} ${t.priority} est:${t.est} spent:${t.spent}${t.blocked?' [BLOCKED]':''}${t.deployed?' [DEPLOYED]':''}</div>`;\n      item.addEventListener('click', onSelectTask);\n      item.addEventListener('dblclick', openDetail);\n      item.addEventListener('contextmenu', onContextTask);\n      item.addEventListener('dragstart', onDragStart);\n      listEl.appendChild(item);\n    });\n    $('selected-id').textContent = state.selectedTask ? state.selectedTask : 'none';\n    renderMetrics();\n  }\n\n  // Drag & drop\n  let dragTaskId = null;\n  function onDragStart(e){\n    if(!state.allowDnd) { e.preventDefault(); return; }\n    dragTaskId = e.target.dataset.id;\n    e.dataTransfer.setData('text/plain', dragTaskId);\n  }\n  function onDragOver(e){ e.preventDefault(); }\n  function onDrop(e){\n    e.preventDefault();\n    const id = e.dataTransfer.getData('text/plain') || dragTaskId;\n    const list = e.currentTarget;\n    const toIdx = +list.dataset.index;\n    const t = state.tasks.find(x => x.id === id);\n    if(!t) return;\n    const model = models[state.model];\n    const fromIdx = model.stages.indexOf(t.stage);\n    const toStage = model.stages[toIdx];\n    const allowed = model.canMove(fromIdx,toIdx,t,state);\n    if(!allowed){\n      log(`Move not allowed by process rules: ${t.id} ${t.stage} -> ${toStage}`);\n      if(!state.autoApprove) return;\n    }\n    // Check dependencies\n    const unmet = t.deps.some(did => {\n      const dep = state.tasks.find(x=>x.id===did);\n      return dep && !dep.completedDay;\n    });\n    if(unmet) {\n      log(`Cannot move ${t.id}; dependencies not completed.`);\n      return;\n    }\n    t.stage = toStage;\n    t.history.push(`Moved to ${toStage} at day ${state.day}`);\n    log(`Moved ${t.id} to ${toStage}`);\n    // If moved to Implementation/Develop start work\n    renderTasks();\n  }\n\n  // Context actions\n  function onContextTask(e){\n    e.preventDefault();\n    const id = e.currentTarget.dataset.id;\n    const t = state.tasks.find(x=>x.id===id);\n    if(!t) return;\n    // toggle selected\n    selectTask(id);\n    // Show quick menu via prompt (minimal UI)\n    const action = prompt(`Task ${id} quick actions: (assign/edit/deploy/complete/spawnbug/split)\\nType command:`);\n    if(!action) return;\n    handleQuickAction(action.trim().toLowerCase(), t);\n  }\n  function onContextBoard(e){\n    // right-click board column show quick create\n    if(e.button===2){\n      e.preventDefault();\n      const idx = +e.currentTarget.dataset.index;\n      const stage = models[state.model].stages[idx];\n      const title = prompt(`Create task in ${stage}. Title:`);\n      if(title) createTask({title, stage});\n    }\n  }\n\n  function handleQuickAction(cmd, t){\n    if(cmd.startsWith('assign')){\n      const who = prompt('Assign to:','Dev');\n      if(who){ t.assigned = who; log(`Assigned ${t.id} to ${who}`); renderTasks(); }\n    } else if(cmd === 'edit'){\n      openDetail();\n    } else if(cmd === 'deploy'){\n      t.deployed = true; log(`Deployed ${t.id}`); renderTasks();\n    } else if(cmd === 'complete'){\n      completeTask(t);\n    } else if(cmd === 'spawnbug'){\n      const b = createTask({title:'Bug from '+t.id, type:'bug', est:2, stage:models[state.model].stages[Math.max(0,1)]});\n      b.notes = 'Auto-created from ' + t.id;\n      log(`Spawned ${b.id} due to ${t.id}`);\n      renderTasks();\n    } else if(cmd === 'split'){\n      splitTask(t);\n    } else {\n      log('Unknown quick action: ' + cmd);\n    }\n  }\n\n  // Selection and detail\n  function onSelectTask(e){\n    const id = e.currentTarget.dataset.id;\n    selectTask(id);\n  }\n  function selectTask(id){\n    state.selectedTask = id;\n    $('selected-id').textContent = id;\n    // highlight?\n    openDetail();\n  }\n  function openDetail(){\n    if(!state.selectedTask) { alert('No task selected'); return; }\n    const t = state.tasks.find(x=>x.id===state.selectedTask);\n    if(!t) { alert('Selected task missing'); return; }\n    $('detail-form').classList.remove('hidden');\n    $('detail-title').textContent = t.title;\n    $('detail-id').textContent = t.id;\n    $('detail-name').value = t.title;\n    $('detail-type').value = t.type;\n    $('detail-est').value = t.est;\n    $('detail-spent').value = t.spent;\n    $('detail-assigned').value = t.assigned || '';\n    $('detail-priority').value = t.priority || 'Normal';\n    $('detail-stage').value = t.stage;\n    $('detail-blocked').checked = !!t.blocked;\n    $('detail-deployed').checked = !!t.deployed;\n    $('detail-notes').value = t.notes;\n    $('detail-deps').textContent = t.deps.join(', ') || 'none';\n    const cm = $('detail-comments'); cm.innerHTML='';\n    t.comments.forEach(c => {\n      const d = document.createElement('div'); d.textContent = c; cm.appendChild(d);\n    });\n  }\n  function closeDetail(){\n    $('detail-form').classList.add('hidden');\n  }\n  function saveDetail(){\n    const id = state.selectedTask;\n    const t = state.tasks.find(x=>x.id===id);\n    if(!t) return;\n    t.title = $('detail-name').value;\n    t.type = $('detail-type').value;\n    t.est = Number($('detail-est').value) || t.est;\n    t.spent = Number($('detail-spent').value) || t.spent;\n    t.assigned = $('detail-assigned').value || null;\n    t.priority = $('detail-priority').value;\n    t.stage = $('detail-stage').value;\n    t.blocked = $('detail-blocked').checked;\n    t.deployed = $('detail-deployed').checked;\n    t.notes = $('detail-notes').value;\n    t.history.push(`Edited at day ${state.day}`);\n    log(`Saved details for ${t.id}`);\n    renderTasks();\n    closeDetail();\n  }\n\n  function addCommentDetail(){\n    const id = state.selectedTask;\n    const t = state.tasks.find(x=>x.id===id);\n    if(!t) return;\n    const txt = prompt('Comment:');\n    if(txt){ t.comments.push(`[Day${state.day}] ${txt}`); log(`Comment added to ${t.id}`); openDetail(); }\n  }\n\n  function addDependencyFromSelected(){\n    const sel = state.selectedTask;\n    if(!sel) { alert('Select a task first'); return; }\n    const other = prompt('Dependency task id to add:');\n    if(!other) return;\n    const t = state.tasks.find(x=>x.id===sel);\n    if(!t) return;\n    if(!state.tasks.find(x=>x.id===other)){ alert('No such task id'); return; }\n    if(!t.deps.includes(other)){ t.deps.push(other); log(`${other} added as dependency to ${t.id}`); openDetail(); }\n  }\n\n  // Delete / block\n  function deleteSelected(){\n    const id = state.selectedTask;\n    if(!id) return alert('No selected');\n    const idx = state.tasks.findIndex(x=>x.id===id);\n    if(idx>=0){ state.tasks.splice(idx,1); log('Deleted task ' + id); state.selectedTask=null; renderTasks(); closeDetail(); }\n  }\n  function toggleBlockedSelected(){\n    const id = state.selectedTask;\n    if(!id) return;\n    const t = state.tasks.find(x=>x.id===id);\n    if(t){ t.blocked = !t.blocked; log(`${t.id} blocked=${t.blocked}`); renderTasks(); openDetail(); }\n  }\n\n  // Split / merge / duplicate\n  function splitSelectedTask(){\n    const id = state.selectedTask;\n    if(!id) return alert('Select a task to split');\n    const t = state.tasks.find(x=>x.id===id);\n    if(!t) return;\n    splitTask(t);\n  }\n  function splitTask(t){\n    const part = Math.max(1, Math.round(t.est/2));\n    t.est = t.est - part;\n    const child = createTask({title: t.title+' (split)', type: t.type, est: part, stage: t.stage});\n    child.notes = 'Split from ' + t.id;\n    t.history.push(`Split into ${child.id} at day ${state.day}`);\n    child.history.push(`Created by split of ${t.id}`);\n    log(`Split ${t.id} -> ${child.id}`);\n    renderTasks();\n  }\n  function mergeSelectedTasks(){\n    const sel = state.selectedTask;\n    if(!sel) return alert('Select base task then enter other ids to merge');\n    const base = state.tasks.find(x=>x.id===sel);\n    const other = prompt('IDs to merge into ' + base.id + ' (comma separated):');\n    if(!other) return;\n    const ids = other.split(',').map(s=>s.trim()).filter(Boolean);\n    ids.forEach(id => {\n      if(id===base.id) return;\n      const t = state.tasks.find(x=>x.id===id);\n      if(t){\n        base.est += t.est;\n        base.spent += t.spent;\n        base.notes += '\\nMerged ' + t.id;\n        const idx = state.tasks.indexOf(t);\n        state.tasks.splice(idx,1);\n        log(`Merged ${id} into ${base.id}`);\n      }\n    });\n    renderTasks();\n  }\n  function duplicateSelected(){\n    const id = state.selectedTask;\n    if(!id) return alert('Select a task');\n    const t = state.tasks.find(x=>x.id===id);\n    const copy = createTask(Object.assign({}, {title: t.title + ' (copy)', type: t.type, est: t.est, stage: t.stage}));\n    copy.notes = 'Duplicate of ' + t.id;\n    log(`Duplicated ${t.id} -> ${copy.id}`);\n    renderTasks();\n  }\n\n  // Sim steps\n  function stepOnce(){\n    simulateWork(1);\n  }\n\n  function advanceDays(days){\n    days = Number(days) || 1;\n    for(let i=0;i<days;i++){\n      state.day++;\n      simulateWork(1);\n    }\n  }\n\n  function fastRun(n){\n    for(let i=0;i<n;i++){\n      state.day++;\n      simulateWork(1);\n    }\n  }\n\n  function toggleRun(){\n    if(state.running) { pauseRun(); } else { startAuto(); }\n  }\n  function startAuto(){\n    state.running = true;\n    $('run-toggle').textContent = 'Stop Auto-Run';\n    const interval = Math.max(50, Number($('auto-interval').value) || 1000);\n    state.autoTimer = setInterval(() => { state.day++; simulateWork(1); }, interval);\n    log('Auto-run started');\n  }\n  function pauseRun(){\n    state.running = false;\n    if(state.autoTimer) clearInterval(state.autoTimer);\n    state.autoTimer = null;\n    $('run-toggle').textContent = 'Start Auto-Run';\n    log('Auto-run paused');\n  }\n\n  // Main simulation engine for a single day step\n  function simulateWork(days){\n    // Apply resource rates and progress tasks\n    const devThroughput = state.devCount * (state.devSpeed/5); // normalized\n    const testEffect = state.testThorough;\n    const auto = state.automation;\n    const defectChance = state.defectRate;\n    const model = models[state.model];\n\n    // Prioritize In Progress or Implementation/Develop columns\n    // Work allocation: developers to feature/spike/chore in development stage\n    for(let d=0; d<days; d++){\n      // pick tasks to work on\n      let devCapacity = devThroughput;\n      const devCandidates = state.tasks.filter(t => {\n        const idx = model.stages.indexOf(t.stage);\n        return idx >= 0 && ['Implementation','Develop','In Progress','Ready','Prototype','Implementation','Develop'].includes(t.stage) || (t.type==='feature' && idx===model.stages.indexOf('Develop'));\n      });\n      // simpler processing: allocate time to tasks in certain stages\n      const devStages = ['Implementation','Develop','In Progress','Prototype','Implementation','Refine'];\n      const workList = state.tasks.filter(t => devStages.includes(t.stage) && !t.blocked);\n      // If none, also work on Ready/Backlog for grooming/prototypes\n      if(workList.length===0){\n        workList.push(...state.tasks.filter(t => ['Ready','Backlog','Concept'].includes(t.stage) && !t.blocked));\n      }\n      // sort by priority\n      workList.sort((a,b)=> priorityVal(b.priority)-priorityVal(a.priority));\n      while(devCapacity > 0 && workList.length>0){\n        const t = workList.shift();\n        const progress = Math.min(devCapacity, Math.max(0.25, state.devSpeed/4));\n        t.spent += progress;\n        devCapacity -= progress;\n        logIf(`Worked on ${t.id}: +${progress.toFixed(2)}d (spent ${t.spent.toFixed(2)}/${t.est})`);\n        // chance to introduce defect during implementation\n        if(Math.random()*100 < defectChance){\n          const bug = createTask({title:'Defect in '+t.id, type:'bug', est:2, stage: model.stages[ model.stages.indexOf('Testing') >= 0 ? model.stages.indexOf('Testing') : 0 ]});\n          bug.notes = `Auto-generated from work on ${t.id} at day ${state.day}`;\n          log(`Defect ${bug.id} created due to work on ${t.id}`);\n        }\n        // If spent >= estimate, try to move forward\n        if(t.spent >= t.est){\n          // attempt to move to next stage\n          const curIdx = model.stages.indexOf(t.stage);\n          const targetIdx = Math.min(model.stages.length-1, curIdx+1);\n          if(model.canMove(curIdx,targetIdx,t,state)){\n            t.stage = model.stages[targetIdx];\n            t.history.push(`Auto-advanced to ${t.stage} at day ${state.day}`);\n            log(`${t.id} auto-advanced to ${t.stage}`);\n            if(t.stage === 'Done' || t.stage === 'Release' || t.stage === 'Deploy' || t.stage === 'Staging' || t.stage === 'Production'){\n              t.completedDay = state.day;\n            }\n          } else {\n            log(`Cannot auto-advance ${t.id} due to process rules`);\n          }\n        }\n      }\n\n      // Testing: testers pick up items in Testing/QA/Review\n      let testCapacity = state.testCount * Math.max(0.5, state.testThorough/50);\n      const testStages = ['Testing','QA','Review','Test','Staging'];\n      const testList = state.tasks.filter(t => testStages.includes(t.stage) && !t.blocked);\n      testList.sort((a,b)=> priorityVal(b.priority)-priorityVal(a.priority));\n      for(const t of testList){\n        if(testCapacity <= 0) break;\n        const effort = Math.min(testCapacity, 1);\n        testCapacity -= effort;\n        // determine pass/fail based on thoroughness and automation\n        const passChance = clamp(state.testThorough + state.automation*0.4 - (t.type==='bug'?10:0), 0, 95);\n        if(Math.random()*100 < passChance){\n          // pass => move forward\n          const curIdx = model.stages.indexOf(t.stage);\n          const targetIdx = Math.min(model.stages.length-1, curIdx+1);\n          if(model.canMove(curIdx,targetIdx,t,state)){\n            t.stage = model.stages[targetIdx];\n            t.history.push(`Test passed -> ${t.stage} at day ${state.day}`);\n            log(`Test passed ${t.id} -> ${t.stage}`);\n            if(t.stage === 'Done' || t.stage === 'Production' || t.stage === 'Deploy'){\n              t.completedDay = state.day;\n            }\n          }\n        } else {\n          // fail: create bug or move back\n          const failAction = Math.random() < 0.6 ? 'moveback' : 'bug';\n          if(failAction === 'moveback'){\n            const curIdx = model.stages.indexOf(t.stage);\n            const backIdx = Math.max(0, curIdx-1);\n            const prevStage = model.stages[backIdx];\n            t.stage = prevStage;\n            log(`Test failed: ${t.id} moved back to ${prevStage}`);\n          } else {\n            const bug = createTask({title:'Bug found in ' + t.id, type:'bug', est:2, stage: model.stages[ model.stages.indexOf('Backlog') >= 0 ? model.stages.indexOf('Backlog') : 0 ]});\n            bug.notes = `Found during testing of ${t.id}`;\n            log(`Bug ${bug.id} created while testing ${t.id}`);\n          }\n        }\n      }\n\n      // Deploy: move items if deployment OK and not outage\n      const deployCandidates = state.tasks.filter(t => ['Deploy','Staging','Done','Release','Staging','Staging'].includes(t.stage) && !t.deployed);\n      for(const t of deployCandidates){\n        if(state.outage) { log(`Cannot deploy ${t.id} due to outage`); continue; }\n        // require gate threshold unless autoApprove or automation high\n        const pass = state.autoApprove || (state.testThorough + state.automation*0.5 >= state.gateThreshold);\n        if(pass){\n          t.deployed = true;\n          t.history.push(`Deployed at day ${state.day}`);\n          log(`Deployed ${t.id} to Production`);\n          // snapshot for possible rollback\n          state.lastDeploySnapshot = JSON.stringify(state.tasks);\n        }\n      }\n    }\n\n    // book-keeping\n    renderTasks();\n    renderMetrics();\n  }\n\n  function priorityVal(p){\n    if(!p) return 0;\n    if(p==='Urgent') return 4;\n    if(p==='High') return 3;\n    if(p==='Normal') return 2;\n    return 1;\n  }\n\n  // Complete task manually\n  function completeTask(t){\n    t.completedDay = state.day;\n    t.stage = models[state.model].stages[models[state.model].stages.length-1];\n    t.deployed = true;\n    log(`Manually completed ${t.id}`);\n    renderTasks();\n  }\n\n  // Gate / rollback / hotfix / change\n  function injectChangeRequest(){\n    // pick one or multiple tasks in Done/Deploy and send them back to Requirements/Backlog\n    const candidates = state.tasks.filter(t => ['Done','Deploy','Production','Release','Staging'].includes(t.stage));\n    if(candidates.length === 0) { alert('No candidates to send back'); return; }\n    const count = Math.min( Math.max(1, Math.round(candidates.length/2)), candidates.length );\n    for(let i=0;i<count;i++){\n      const t = candidates[i];\n      const target = models[state.model].stages[1] || models[state.model].stages[0];\n      t.stage = target;\n      t.spent = 0;\n      t.deployed = false;\n      t.history.push(`Change request forced rework to ${target} at day ${state.day}`);\n      log(`Change request: ${t.id} moved back to ${target}`);\n    }\n    renderTasks();\n  }\n\n  function triggerHotfix(){\n    // create urgent bug targeting production\n    const bug = createTask({title:'Hotfix: production issue', type:'bug', est:1, stage: models[state.model].stages[0]});\n    bug.priority = 'Urgent';\n    bug.notes = 'Hotfix needs expedited path';\n    // try to fast-track: move to deploy if rules allow or override\n    const curIdx = models[state.model].stages.indexOf(bug.stage);\n    const destIdx = models[state.model].stages.length-1;\n    if(models[state.model].canMove(curIdx,destIdx,bug,state) || state.autoApprove){\n      bug.stage = models[state.model].stages[destIdx];\n      bug.deployed = true;\n      bug.history.push('Hotfix fast-tracked to deploy');\n      log(`Hotfix ${bug.id} fast-tracked to deploy`);\n    } else {\n      log('Hotfix created but could not be fast-tracked by model rules');\n    }\n    renderTasks();\n  }\n\n  function forceOpenGate(){\n    // Allow all tasks to advance without checks for one day\n    state.autoApprove = true;\n    log('Gates forced open (auto-approve ON). Turn off manually.');\n  }\n\n  function rollbackDeploy(){\n    if(!state.lastDeploySnapshot){ log('No deploy snapshot available'); return; }\n    if(!confirm('Rollback to last deploy snapshot? This will restore tasks state.')) return;\n    const tasks = JSON.parse(state.lastDeploySnapshot);\n    state.tasks = tasks;\n    log('Rollback executed to last deploy snapshot');\n    renderTasks();\n  }\n\n  // Utility logs (suppress small chatter)\n  let chatter = 0;\n  function logIf(msg){\n    // minor logs aggregated occasionally\n    chatter++;\n    if(chatter % 6 === 0) log(msg);\n  }\n\n  // Script runner - minimal DSL\n  function runScript(){\n    const script = $('script').value || '';\n    const lines = script.split('\\n').map(s=>s.trim()).filter(Boolean);\n    for(const ln of lines){\n      executeScriptLine(ln);\n    }\n    renderTasks();\n  }\n  function executeScriptLine(line){\n    const cmd = line.toLowerCase();\n    if(cmd.startsWith('create ')){\n      const rest = line.slice(7).trim();\n      const parts = rest.split('|').map(s=>s.trim());\n      createTask({title: parts[0], type: parts[1] || 'feature', est: Number(parts[2]) || 3});\n      return;\n    }\n    if(cmd.startsWith('run ')){\n      const n = Number(line.split(' ')[1]) || 1;\n      fastRun(n);\n      return;\n    }\n    if(cmd === 'inject change' || cmd === 'inject change request'){\n      injectChangeRequest();\n      return;\n    }\n    if(cmd === 'hotfix'){\n      triggerHotfix();\n      return;\n    }\n    if(cmd === 'advance 1' || cmd === 'advance'){\n      advanceDays(1);\n      return;\n    }\n    log('Script command unknown: ' + line);\n  }\n\n  // Metrics\n  function renderMetrics(){\n    $('sim-day').textContent = state.day;\n    const completed = state.tasks.filter(t => t.completedDay).length;\n    const inprog = state.tasks.filter(t => !t.completedDay && !['Backlog','Ready','Planning','Concept'].includes(t.stage)).length;\n    const defects = state.tasks.filter(t => t.type==='bug' && !t.completedDay).length;\n    const vel = computeVelocity();\n    const cycle = computeAvgCycle();\n    $('metric-completed').textContent = completed;\n    $('metric-inprog').textContent = inprog;\n    $('metric-defects').textContent = defects;\n    $('metric-vel').textContent = vel.toFixed(2);\n    $('metric-cycle').textContent = cycle.toFixed(2);\n  }\n\n  function computeVelocity(){\n    // average completed tasks per day over last 14 days\n    const completed = state.tasks.filter(t => t.completedDay !== null);\n    if(completed.length === 0) return 0;\n    const days = Math.max(1, state.day - Math.min(...completed.map(c => c.completedDay)));\n    return completed.length / days;\n  }\n  function computeAvgCycle(){\n    const done = state.tasks.filter(t => t.completedDay && t.createdDay != null);\n    if(done.length===0) return 0;\n    const sum = done.reduce((acc,t) => acc + (t.completedDay - t.createdDay), 0);\n    return sum / done.length;\n  }\n\n  // Misc helpers\n  function logState(){\n    log('State dump: tasks='+state.tasks.length + ' day=' + state.day);\n  }\n\n  // Init on load\n  init();\n\n  // Expose some functions for console/debugging (not necessary)\n  window.SDLC = { state, createTask, createDemo, simulateWork, log, models };\n\n})();\n</script>\n</body>\n</html>"
  },
  "messages": [
