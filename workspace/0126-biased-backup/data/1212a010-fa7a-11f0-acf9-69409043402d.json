  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Stack Demonstration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  button, input[type=number], input[type=text], select {\n    font: inherit;\n    margin: 0.2em 0.5em 0.2em 0;\n  }\n  label {\n    margin-right: 0.5em;\n  }\n  #stackDisplay {\n    margin-top: 1em;\n    white-space: pre;\n    border: 1px solid black;\n    padding: 0.5em;\n    min-height: 150px;\n    max-width: 300px;\n    overflow-y: auto;\n  }\n  #log {\n    margin-top: 1em;\n    max-height: 200px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 0.5em;\n    font-size: 0.85em;\n  }\n  hr {\n    margin: 1em 0;\n  }\n  fieldset {\n    margin-bottom: 1em;\n  }\n</style>\n</head>\n<body>\n\n<h1>Stack Interactive Demo</h1>\n\n<p>This tool demonstrates a Stack data structure with rich interactivity and multiple ways to manipulate and explore stack behavior. The stack holds string items.</p>\n\n<fieldset>\n  <legend>Push Items</legend>\n  <label for=\"pushInput\">Value to Push:</label>\n  <input type=\"text\" id=\"pushInput\" aria-label=\"Value to push onto the stack\" />\n  <button id=\"pushBtn\">Push</button>\n  \n  <label for=\"pushCount\" title=\"Number of repetitions when pushing\">Count:</label>\n  <input type=\"number\" id=\"pushCount\" value=\"1\" min=\"1\" max=\"100\" />\n  \n  <button id=\"pushRandomBtn\" title=\"Push random alphanumeric strings\">Push Random</button>\n  <label for=\"pushRandomCount\" title=\"How many random elements to push\">Count:</label>\n  <input type=\"number\" id=\"pushRandomCount\" value=\"1\" min=\"1\" max=\"100\" />\n  \n  <br/>\n  <label for=\"bulkPushInput\">Bulk Push (comma or newline separated):</label><br />\n  <textarea id=\"bulkPushInput\" rows=\"3\" cols=\"30\" aria-label=\"Bulk push multiple items, separated by commas or new lines\"></textarea><br />\n  <button id=\"bulkPushBtn\">Bulk Push</button>\n</fieldset>\n\n<fieldset>\n  <legend>Pop Items</legend>\n  <label for=\"popCount\">Count:</label>\n  <input type=\"number\" id=\"popCount\" value=\"1\" min=\"1\" max=\"100\" />\n  <button id=\"popBtn\">Pop</button>\n  <button id=\"popAllBtn\" title=\"Pop all items\">Pop All</button>\n</fieldset>\n\n<fieldset>\n  <legend>Stack Manipulation</legend>\n  <button id=\"clearBtn\">Clear Stack</button>\n  \n  <label for=\"peekDepth\" title=\"Peek at nth item from top (1=top)\">Peek Depth:</label>\n  <input type=\"number\" id=\"peekDepth\" value=\"1\" min=\"1\" />\n  <button id=\"peekBtn\">Peek</button> \n  <span id=\"peekResult\" aria-live=\"polite\"></span>\n  \n  <br />\n  \n  <label for=\"searchInput\" title=\"Search for an item in the stack\">Search:</label>\n  <input type=\"text\" id=\"searchInput\" />\n  <button id=\"searchBtn\">Search</button>\n  <span id=\"searchResult\" aria-live=\"polite\"></span>\n</fieldset>\n\n<fieldset>\n  <legend>Stack Settings / Exploration</legend>\n  \n  <label for=\"maxStackSize\">Max Stack Size (0 = unlimited):</label>\n  <input type=\"number\" id=\"maxStackSize\" value=\"0\" min=\"0\" max=\"10000\" />\n  <button id=\"applyMaxSizeBtn\">Apply Max Size</button>\n  <br />\n  <label><input type=\"checkbox\" id=\"strictMode\" /> Strict mode (disallow pushes when full)</label>\n  <br />\n  <label for=\"autoPopCount\">Auto-pop count on overflow (if not strict):</label>\n  <input type=\"number\" id=\"autoPopCount\" value=\"1\" min=\"0\" max=\"100\" />\n  <br />\n  <button id=\"autoPopTestBtn\" title=\"Push items continuously at intervals to test overflow and auto-pop\">Start Auto Push Test</button>\n  <button id=\"stopAutoPushBtn\" disabled>Stop Auto Push Test</button>\n  <br />\n  <label for=\"autoPushInterval\">Auto Push Interval (ms):</label>\n  <input type=\"number\" id=\"autoPushInterval\" value=\"500\" min=\"50\" max=\"10000\" step=\"50\" />\n</fieldset>\n\n<fieldset>\n  <legend>Advanced Exploration / State Control</legend>\n  <button id=\"undoBtn\" disabled>Undo Last Operation</button>\n  <button id=\"redoBtn\" disabled>Redo Last Undo</button>\n  <br />\n  <button id=\"saveStateBtn\">Save Stack State</button>\n  <button id=\"loadStateBtn\">Load Saved State</button>\n  <br />\n  <label for=\"stateExportArea\" title=\"View or copy saved stack state JSON\">Saved Stack State JSON:</label><br />\n  <textarea id=\"stateExportArea\" rows=\"5\" cols=\"50\" aria-label=\"Saved stack state JSON\"></textarea>\n</fieldset>\n\n<h2>Stack Content (Top at Bottom)</h2>\n<div id=\"stackDisplay\" aria-live=\"polite\" aria-label=\"Current stack contents\"></div>\n\n<h2>Pop Log / History</h2>\n<div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<script>\n(function(){\n  // Stack implementation and all interaction logic:\n  // The stack holds strings.\n  \n  let stack = [];\n  let maxStackSize = 0; // 0 = unlimited\n  let strictMode = false; // if true, disallow pushes when full\n  let autoPopCount = 1; // how many to pop when overflow and !strictMode\n  let undoStack = [];\n  let redoStack = [];\n  let autoPushIntervalId = null;\n  \n  // DOM references\n  const stackDisplay = document.getElementById('stackDisplay');\n  const logArea = document.getElementById('log');\n  const pushInput = document.getElementById('pushInput');\n  const pushBtn = document.getElementById('pushBtn');\n  const pushCountInput = document.getElementById('pushCount');\n  const pushRandomBtn = document.getElementById('pushRandomBtn');\n  const pushRandomCountInput = document.getElementById('pushRandomCount');\n  const bulkPushInput = document.getElementById('bulkPushInput');\n  const bulkPushBtn = document.getElementById('bulkPushBtn');\n  \n  const popCountInput = document.getElementById('popCount');\n  const popBtn = document.getElementById('popBtn');\n  const popAllBtn = document.getElementById('popAllBtn');\n  \n  const clearBtn = document.getElementById('clearBtn');\n  \n  const peekDepthInput = document.getElementById('peekDepth');\n  const peekBtn = document.getElementById('peekBtn');\n  const peekResult = document.getElementById('peekResult');\n  \n  const searchInput = document.getElementById('searchInput');\n  const searchBtn = document.getElementById('searchBtn');\n  const searchResult = document.getElementById('searchResult');\n  \n  const maxStackSizeInput = document.getElementById('maxStackSize');\n  const applyMaxSizeBtn = document.getElementById('applyMaxSizeBtn');\n  const strictModeCheckbox = document.getElementById('strictMode');\n  const autoPopCountInput = document.getElementById('autoPopCount');\n  \n  const autoPopTestBtn = document.getElementById('autoPopTestBtn');\n  const stopAutoPushBtn = document.getElementById('stopAutoPushBtn');\n  const autoPushIntervalInput = document.getElementById('autoPushInterval');\n  \n  const undoBtn = document.getElementById('undoBtn');\n  const redoBtn = document.getElementById('redoBtn');\n  \n  const saveStateBtn = document.getElementById('saveStateBtn');\n  const loadStateBtn = document.getElementById('loadStateBtn');\n  const stateExportArea = document.getElementById('stateExportArea');\n  \n  // --- Utilities ---\n  function log(message){\n    const time = new Date().toLocaleTimeString();\n    logArea.textContent = `[${time}] ${message}\\n` + logArea.textContent;\n  }\n  \n  function updateStackDisplay(){\n    if(stack.length === 0){\n      stackDisplay.textContent = \"(empty)\";\n      return;\n    }\n    \n    // display top at bottom line-wise\n    // e.g. bottom\n    // item0\n    // item1\n    // ...\n    // top\n    // but requirement: \"Top at Bottom\"\n    // So reversed display with bottom on top line, top on bottom line\n    \n    let lines = stack.map( (item,i) => \n      i === stack.length-1 ? `> ${item}` : `  ${item}`\n    );\n    // top marked with >, bottom no special mark\n    \n    stackDisplay.textContent = lines.join('\\n');\n  }\n  \n  // Save state for undo system\n  function saveUndoState(){\n    const stateCopy = JSON.stringify({ stack: stack.slice(), maxStackSize, strictMode, autoPopCount });\n    undoStack.push(stateCopy);\n    redoStack = [];\n    undoBtn.disabled = false;\n    redoBtn.disabled = true;\n  }\n  \n  function restoreState(stateJson){\n    try {\n      const obj = JSON.parse(stateJson);\n      if(obj && Array.isArray(obj.stack)){\n        stack = obj.stack;\n        maxStackSize = typeof obj.maxStackSize === \"number\" ? obj.maxStackSize : 0;\n        strictMode = typeof obj.strictMode === \"boolean\" ? obj.strictMode : false;\n        autoPopCount = typeof obj.autoPopCount === \"number\" ? obj.autoPopCount : 1;\n        maxStackSizeInput.value = maxStackSize;\n        strictModeCheckbox.checked = strictMode;\n        autoPopCountInput.value = autoPopCount;\n        updateStackDisplay();\n        log(\"Stack state loaded.\");\n      } else {\n        throw new Error(\"Invalid state structure\");\n      }\n    } catch(e) {\n      alert(\"Failed to load state: \"+e.message);\n    }\n  }\n  \n  // --- Stack Operations ---\n  // Push one item (string)\n  // Return true if pushed, false if rejected due to strict mode stack full\n  function pushOne(item){\n    if(typeof item !== \"string\" || item === \"\"){\n      log(\"Skipped pushing empty string\");\n      return false;\n    }\n    if(maxStackSize > 0 && stack.length >= maxStackSize){\n      if(strictMode){\n        log(\"Push rejected: stack at max size and strict mode enabled\");\n        return false;\n      }\n      // auto pop some items before pushing\n      if(autoPopCount > 0){\n        const toPop = Math.min(autoPopCount, stack.length);\n        const popped = popN(toPop);\n        log(`Auto-popped ${popped.length} item(s) due to overflow before push.`);\n      }\n      // else no pop: push anyway (can exceed max)\n    }\n    stack.push(item);\n    log(`Pushed: \"${item}\"`);\n    return true;\n  }\n  \n  function pushN(item, n){\n    if(n < 1) return;\n    saveUndoState();\n    let pushedCount = 0;\n    for(let i=0; i<n; i++){\n      if(pushOne(item)){\n        pushedCount++;\n      } else {\n        if(strictMode) break; // stop pushing if rejected\n      }\n    }\n    updateStackDisplay();\n    log(`Push operation complete: ${pushedCount} item(s) pushed.`);\n  }\n  \n  // Push random alpha num string, length between 3-7\n  function genRandomString(){\n    const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789\";\n    const len = 3 + Math.floor(Math.random()*5);\n    let s = \"\";\n    for(let i=0;i<len;i++) s += chars.charAt(Math.floor(Math.random()*chars.length));\n    return s;\n  }\n  function pushRandomN(n){\n    if(n < 1) return;\n    saveUndoState();\n    let pushedCount = 0;\n    for(let i=0; i<n; i++){\n      if(pushOne(genRandomString())){\n        pushedCount++;\n      } else {\n        if(strictMode) break;\n      }\n    }\n    updateStackDisplay();\n    log(`Random push operation complete: ${pushedCount} item(s) pushed.`);\n  }\n  \n  // Bulk push array of strings\n  function bulkPush(arr){\n    if(!Array.isArray(arr) || arr.length === 0) return;\n    saveUndoState();\n    let pushedCount = 0;\n    for(let item of arr){\n      item = item.trim();\n      if(item === \"\") continue;\n      if(pushOne(item)){\n        pushedCount++;\n      } else {\n        if(strictMode) break;\n      }\n    }\n    updateStackDisplay();\n    log(`Bulk push complete: ${pushedCount} item(s) pushed.`);\n  }\n  \n  // Pop N items, return array of popped items\n  function popN(n){\n    n = Math.min(n, stack.length);\n    let popped = [];\n    for(let i=0; i<n; i++){\n      popped.push(stack.pop());\n    }\n    if(popped.length > 0){\n      log(`Popped ${popped.length} item(s): ${popped.map(i=>'\"'+i+'\"').join(\", \")}`);\n    } else {\n      log(\"Pop attempted but stack empty.\");\n    }\n    updateStackDisplay();\n    return popped;\n  }\n  \n  // Peek nth item from top (1=top)\n  function peek(n){\n    if(stack.length === 0) return null;\n    if(n < 1) return null;\n    if(n > stack.length) return null;\n    return stack[stack.length - n];\n  }\n  \n  // Search all occurrences (case-sensitive) return array of indices from top 1-based\n  function search(term){\n    if(term === \"\") return [];\n    let indices = [];\n    for(let i=stack.length-1; i>=0; i--){\n      if(stack[i].indexOf(term) !== -1){\n        indices.push(stack.length - i);\n      }\n    }\n    return indices;\n  }\n  \n  // --- Event Handlers ---\n  \n  pushBtn.addEventListener('click', ()=> {\n    const val = pushInput.value.trim();\n    const count = Number(pushCountInput.value);\n    if(val === \"\"){\n      alert(\"Enter a value to push\");\n      return;\n    }\n    if(!Number.isInteger(count) || count < 1){\n      alert(\"Push count must be an integer >= 1\");\n      return;\n    }\n    pushN(val, count);\n  });\n  \n  pushRandomBtn.addEventListener('click', ()=>{\n    const count = Number(pushRandomCountInput.value);\n    if(!Number.isInteger(count) || count < 1){\n      alert(\"Random push count must be an integer >= 1\");\n      return;\n    }\n    pushRandomN(count);\n  });\n  \n  bulkPushBtn.addEventListener('click', ()=>{\n    const text = bulkPushInput.value;\n    if(text.trim() === \"\"){\n      alert(\"Enter bulk items separated by commas or new lines\");\n      return;\n    }\n    let items = [];\n    // split by new lines and commas\n    text.split(/\\r?\\n/).forEach(line=>{\n      line.split(',').forEach(x=>{\n        const trimmed = x.trim();\n        if(trimmed !== \"\") items.push(trimmed);\n      });\n    });\n    if(items.length === 0){\n      alert(\"No valid items to push\");\n      return;\n    }\n    bulkPush(items);\n  });\n  \n  popBtn.addEventListener('click', ()=>{\n    const count = Number(popCountInput.value);\n    if(!Number.isInteger(count) || count < 1){\n      alert(\"Pop count must be an integer >= 1\");\n      return;\n    }\n    if(stack.length === 0){\n      log(\"Pop attempted but stack empty.\");\n      return;\n    }\n    saveUndoState();\n    popN(count);\n  });\n  \n  popAllBtn.addEventListener('click', ()=>{\n    if(stack.length === 0){\n      log(\"Pop All attempted but stack empty.\");\n      return;\n    }\n    saveUndoState();\n    popN(stack.length);\n  });\n  \n  clearBtn.addEventListener('click', ()=>{\n    if(stack.length === 0) {\n      log(\"Clear attempted but stack already empty.\");\n      return;\n    }\n    saveUndoState();\n    stack = [];\n    updateStackDisplay();\n    log(\"Cleared entire stack.\");\n  });\n  \n  peekBtn.addEventListener('click', ()=>{\n    const n = Number(peekDepthInput.value);\n    if(!Number.isInteger(n) || n < 1){\n      alert(\"Peek depth must be an integer >= 1\");\n      return;\n    }\n    if(stack.length === 0){\n      peekResult.textContent = \" Stack empty.\";\n      return;\n    }\n    const p = peek(n);\n    if(p === null){\n      peekResult.textContent = ` No item at depth ${n}.`;\n    } else {\n      peekResult.textContent = ` Item at depth ${n} from top: \"${p}\"`;\n    }\n  });\n  \n  searchBtn.addEventListener('click', ()=>{\n    const term = searchInput.value;\n    if(term === \"\"){\n      searchResult.textContent = \" Enter a search term.\";\n      return;\n    }\n    const results = search(term);\n    if(results.length === 0){\n      searchResult.textContent = ` No matching items containing \"${term}\".`;\n    } else {\n      searchResult.textContent = ` Found ${results.length} match(es) at depth(s) from top: ${results.join(', ')}`;\n    }\n  });\n  \n  applyMaxSizeBtn.addEventListener('click', ()=>{\n    const val = Number(maxStackSizeInput.value);\n    if(!Number.isInteger(val) || val < 0){\n      alert(\"Max stack size must be integer >= 0\");\n      return;\n    }\n    maxStackSize = val;\n    strictMode = strictModeCheckbox.checked;\n    autoPopCount = Number(autoPopCountInput.value);\n    if(!Number.isInteger(autoPopCount) || autoPopCount < 0) autoPopCount = 1;\n    log(`Max stack size set to ${maxStackSize} (0=unlimited), strict mode ${strictMode ? 'ON' : 'OFF'}, auto-pop count ${autoPopCount}.`);\n    \n    // enforce limits immediately by popping if reduces to smaller max size\n    if(maxStackSize > 0 && stack.length > maxStackSize){\n      saveUndoState();\n      const toPop = stack.length - maxStackSize;\n      const popped = popN(toPop);\n      log(`Auto-popped ${popped.length} item(s) to enforce new max stack size.`);\n    }\n    updateStackDisplay();\n  });\n  \n  strictModeCheckbox.addEventListener('change', ()=>{\n    strictMode = strictModeCheckbox.checked;\n    log(`Strict mode set to ${strictMode ? 'ON' : 'OFF'}.`);\n  });\n  \n  autoPopCountInput.addEventListener('change', ()=>{\n    let val = Number(autoPopCountInput.value);\n    if(!Number.isInteger(val) || val < 0){\n      val = 1;\n      autoPopCountInput.value = val;\n    }\n    autoPopCount = val;\n    log(`Auto-pop count set to ${autoPopCount}.`);\n  });\n  \n  // --- Undo/Redo ---\n  undoBtn.addEventListener('click', ()=>{\n    if(undoStack.length === 0) return;\n    const currentState = JSON.stringify({ stack: stack.slice(), maxStackSize, strictMode, autoPopCount });\n    redoStack.push(currentState);\n    const prevState = undoStack.pop();\n    restoreState(prevState);\n    undoBtn.disabled = undoStack.length === 0;\n    redoBtn.disabled = false;\n  });\n  \n  redoBtn.addEventListener('click', ()=>{\n    if(redoStack.length === 0) return;\n    const currentState = JSON.stringify({ stack: stack.slice(), maxStackSize, strictMode, autoPopCount });\n    undoStack.push(currentState);\n    const nextState = redoStack.pop();\n    restoreState(nextState);\n    redoBtn.disabled = redoStack.length === 0;\n    undoBtn.disabled = false;\n  });\n  \n  // Save / Load stack state manually\n  saveStateBtn.addEventListener('click', ()=>{\n    const state = JSON.stringify({ stack, maxStackSize, strictMode, autoPopCount });\n    stateExportArea.value = state;\n    log(\"Stack state saved to export area.\");\n  });\n  \n  loadStateBtn.addEventListener('click', ()=>{\n    const txt = stateExportArea.value;\n    if(!txt){\n      alert(\"No saved state JSON in text area.\");\n      return;\n    }\n    saveUndoState();\n    restoreState(txt);\n  });\n  \n  // --- Auto Push Test ---\n  autoPopTestBtn.addEventListener('click', ()=>{\n    if(autoPushIntervalId !== null){\n      alert(\"Auto push test already running.\");\n      return;\n    }\n    let interval = Number(autoPushIntervalInput.value);\n    if(!Number.isInteger(interval) || interval < 50) interval = 500;\n    log(`Auto push test started with interval ${interval} ms.`);\n    autoPushIntervalId = setInterval(() => {\n      const val = genRandomString();\n      pushOne(val);\n      updateStackDisplay();\n    }, interval);\n    autoPopTestBtn.disabled = true;\n    stopAutoPushBtn.disabled = false;\n    saveUndoState();\n  });\n  stopAutoPushBtn.addEventListener('click', ()=>{\n    if(autoPushIntervalId !== null){\n      clearInterval(autoPushIntervalId);\n      autoPushIntervalId = null;\n      log(\"Auto push test stopped.\");\n      autoPopTestBtn.disabled = false;\n      stopAutoPushBtn.disabled = true;\n    }\n  });\n  \n  // --- Initialization ---\n  updateStackDisplay();\n  log(\"Interactive stack demo loaded. Start by pushing items.\");\n}());\n</script>\n\n</body>\n</html>"
  },
