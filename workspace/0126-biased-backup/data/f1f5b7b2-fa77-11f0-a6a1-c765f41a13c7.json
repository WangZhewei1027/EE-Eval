    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Counting Sort — Visual Elegance</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #081023;\n    --glass: rgba(255,255,255,0.06);\n    --accent: #66d9ff;\n    --accent-2: #b794ff;\n    --muted: rgba(255,255,255,0.65);\n    --card: rgba(255,255,255,0.04);\n    --success: #6ee7b7;\n    --glass-2: rgba(255,255,255,0.03);\n  }\n  * { box-sizing: border-box; }\n  html,body { height:100%; margin:0; font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; background:\n    radial-gradient(1200px 600px at 10% 10%, rgba(103,128,255,0.08), transparent 8%),\n    linear-gradient(180deg, var(--bg-1), var(--bg-2));\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;\n  }\n\n  /* Page layout */\n  .wrap {\n    max-width:1100px;\n    margin:36px auto;\n    padding:36px;\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 8px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    position:relative;\n    overflow:hidden;\n  }\n\n  /* Top decorative */\n  .header {\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:20px;\n    margin-bottom:18px;\n  }\n  .title {\n    display:flex;\n    flex-direction:column;\n  }\n  .title h1 {\n    margin:0;\n    font-family: \"Playfair Display\", serif;\n    font-weight:700;\n    letter-spacing: -0.02em;\n    font-size:28px;\n    color: #f8fbff;\n    text-shadow: 0 6px 30px rgba(103,128,255,0.08);\n  }\n  .title p {\n    margin:6px 0 0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .controls {\n    display:flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn {\n    border:0;\n    padding:10px 16px;\n    border-radius:12px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    color:var(--accent);\n    font-weight:600;\n    letter-spacing:0.02em;\n    cursor:pointer;\n    transition: all 240ms cubic-bezier(.2,.9,.2,1);\n    box-shadow: 0 6px 18px rgba(3,8,20,0.5);\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn:active { transform: translateY(1px) scale(0.998); }\n  .btn.primary {\n    background: linear-gradient(90deg, var(--accent), var(--accent-2));\n    color: #052029;\n    box-shadow: 0 10px 30px rgba(102,217,255,0.12), 0 2px 8px rgba(0,0,0,0.4);\n  }\n  .btn.ghost {\n    background:transparent;\n    color:var(--muted);\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n\n  /* Main visualization panel */\n  .panel {\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap:26px;\n    align-items:start;\n  }\n\n  /* Left: visualization canvas */\n  .canvas {\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.015));\n    border-radius:14px;\n    padding:20px;\n    min-height:420px;\n    position:relative;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    overflow:hidden;\n  }\n\n  /* Decorative blobs */\n  .blob {\n    position:absolute;\n    width:360px;\n    height:220px;\n    border-radius:40%;\n    filter: blur(40px);\n    opacity:0.12;\n    transform: rotate(10deg);\n  }\n  .blob.a { background: linear-gradient(120deg, rgba(102,217,255,0.18), rgba(183,148,255,0.12)); top:-60px; left:-80px; }\n  .blob.b { background: linear-gradient(120deg, rgba(110,231,183,0.08), rgba(102,217,255,0.06)); bottom:-40px; right:-60px; width:420px; height:260px; opacity:0.07; }\n\n  /* Rows: input / counts / output */\n  .row {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:center;\n    padding:8px 6px;\n    margin:8px 0;\n    position:relative;\n  }\n  .row.label {\n    justify-content:space-between;\n    padding:0 12px 6px;\n    font-size:13px;\n    color:var(--muted);\n  }\n\n  /* Tiles */\n  .tile {\n    width:62px;\n    height:62px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-weight:700;\n    font-size:20px;\n    color:#eafcff;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n    position:relative;\n    transition: all 300ms cubic-bezier(.2,.9,.2,1);\n  }\n\n  .tile.small { width:56px; height:56px; font-size:18px; border-radius:10px; }\n  .tile.grey { color:var(--muted); background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005)); border:1px solid rgba(255,255,255,0.02); }\n  .tile.value {\n    background: linear-gradient(90deg, rgba(102,217,255,0.12), rgba(183,148,255,0.06));\n    color: #022b32;\n    font-weight:800;\n    text-shadow: 0 1px 0 rgba(255,255,255,0.04);\n    border: 1px solid rgba(255,255,255,0.06);\n  }\n\n  /* count tiles bar */\n  .counts {\n    display:flex;\n    gap:10px;\n    justify-content:center;\n    padding:14px 8px;\n    flex-wrap:nowrap;\n    overflow:hidden;\n    scroll-behavior:smooth;\n  }\n  .count-card {\n    width:84px;\n    min-width:84px;\n    padding:10px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:8px;\n  }\n  .count-card .label {\n    font-size:12px;\n    color:var(--muted);\n  }\n  .count-bubble {\n    width:46px;\n    height:46px;\n    border-radius:10px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n    color:var(--muted);\n    font-weight:700;\n    transition: all 260ms cubic-bezier(.2,.9,.2,1);\n  }\n  .count-bubble.active {\n    transform: translateY(-6px) scale(1.05);\n    box-shadow: 0 14px 40px rgba(102,217,255,0.08), inset 0 1px 0 rgba(255,255,255,0.04);\n    background: linear-gradient(90deg, rgba(102,217,255,0.16), rgba(183,148,255,0.12));\n    color:#022b32;\n  }\n\n  /* cumulative bars */\n  .cum-row {\n    display:flex;\n    gap:10px;\n    justify-content:center;\n    margin-top:8px;\n  }\n  .cum-bar {\n    width:84px;\n    height:8px;\n    border-radius:8px;\n    background: rgba(255,255,255,0.02);\n    overflow:hidden;\n    position:relative;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .cum-fill {\n    position:absolute;\n    left:0; top:0; bottom:0;\n    width:0%;\n    background: linear-gradient(90deg, rgba(102,217,255,0.32), rgba(183,148,255,0.28));\n    transition: width 420ms cubic-bezier(.2,.9,.2,1);\n  }\n\n  /* output row */\n  .output {\n    display:flex;\n    gap:12px;\n    justify-content:center;\n    padding:12px;\n  }\n  .slot {\n    width:62px;\n    height:62px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border: 1px dashed rgba(255,255,255,0.02);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:var(--muted);\n    font-weight:700;\n    font-size:18px;\n  }\n\n  /* explanation / legend */\n  .side {\n    padding:18px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.012), rgba(255,255,255,0.008));\n    border: 1px solid rgba(255,255,255,0.02);\n    min-height:420px;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n  }\n  .side h3 {\n    margin:0;\n    font-size:16px;\n    font-weight:700;\n    color:#f7fcff;\n    font-family: \"Playfair Display\", serif;\n  }\n  .side p { margin:0; color:var(--muted); font-size:13px; line-height:1.5; }\n  .legend {\n    display:flex;\n    gap:10px;\n    align-items:center;\n    margin-top:8px;\n  }\n  .swatch {\n    width:12px; height:12px; border-radius:3px;\n    background:linear-gradient(90deg, var(--accent), var(--accent-2));\n    box-shadow: 0 6px 18px rgba(102,217,255,0.07);\n  }\n  .note { font-size:12px; color:var(--muted); margin-top:6px; }\n\n  /* animations & helpers */\n  .pulse {\n    animation: pop 420ms cubic-bezier(.2,.9,.2,1);\n  }\n  @keyframes pop {\n    0% { transform: scale(0.92); opacity:0.6 }\n    60% { transform: scale(1.08); opacity:1 }\n    100% { transform: scale(1); opacity:1 }\n  }\n\n  .floating {\n    position:fixed;\n    pointer-events:none;\n    z-index:9999;\n    transition: transform 520ms cubic-bezier(.2,.9,.2,1), opacity 360ms;\n  }\n\n  .muted-sm { color:var(--muted); font-size:12px; }\n\n  /* footer */\n  .footer {\n    margin-top:18px;\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* responsive */\n  @media (max-width:980px){\n    .panel { grid-template-columns: 1fr; }\n    .side { order:2; }\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\" role=\"main\" aria-label=\"Counting Sort Visualization\">\n  <div class=\"header\">\n    <div class=\"title\">\n      <h1>Counting Sort — An Elegant Walkthrough</h1>\n      <p>Observe the stable distribution of elements using counting arrays and cumulative positions.</p>\n    </div>\n    <div class=\"controls\" aria-hidden=\"false\">\n      <button id=\"playBtn\" class=\"btn primary\" title=\"Play the animation\">Play Animation</button>\n      <button id=\"resetBtn\" class=\"btn ghost\" title=\"Reset view\">Reset</button>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"canvas\" id=\"canvas\">\n      <div class=\"blob a\" aria-hidden=\"true\"></div>\n      <div class=\"blob b\" aria-hidden=\"true\"></div>\n\n      <div class=\"row label\">\n        <div style=\"display:flex; gap:8px; align-items:center;\">\n          <div style=\"width:10px;height:10px;border-radius:2px;background:linear-gradient(90deg,var(--accent),var(--accent-2));box-shadow:0 6px 20px rgba(102,217,255,0.07)\"></div>\n          <div style=\"font-weight:700\">Input Array</div>\n        </div>\n        <div class=\"muted-sm\">Stable Counting Sort • Range-based</div>\n      </div>\n\n      <div id=\"inputRow\" class=\"row\" aria-live=\"polite\"></div>\n\n      <div class=\"row label\" style=\"margin-top:6px;\">\n        <div style=\"font-weight:700\">Count Buckets</div>\n        <div class=\"muted-sm\">Increment bucket counts for values</div>\n      </div>\n\n      <div id=\"countRow\" class=\"counts\" aria-hidden=\"false\"></div>\n      <div id=\"cumRow\" class=\"cum-row\" aria-hidden=\"false\" style=\"margin-top:6px;\"></div>\n\n      <div class=\"row label\" style=\"margin-top:8px;\">\n        <div style=\"font-weight:700\">Output (Sorted)</div>\n        <div class=\"muted-sm\">Items placed using cumulative positions</div>\n      </div>\n\n      <div id=\"outputRow\" class=\"output\" aria-live=\"polite\"></div>\n    </div>\n\n    <aside class=\"side\" aria-label=\"Explanation\">\n      <h3>What you’re seeing</h3>\n      <p>Counting Sort tallies how many times each value appears (count buckets), transforms those counts into cumulative positions, and then places each input element into the right index in the output array. This visualization highlights those stages: tallying, prefix-summing, and placing items — all while preserving stability.</p>\n\n      <div class=\"legend\">\n        <div style=\"flex:1\">\n          <div style=\"display:flex;gap:8px;align-items:center;margin-bottom:6px\"><div class=\"swatch\"></div><div style=\"font-weight:700\">Moving elements</div></div>\n          <div class=\"note\">Elements animate from Input → Count → Output with graceful motion and subtle emphasis.</div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <h3 style=\"margin-bottom:8px\">Algorithm Summary</h3>\n        <p><strong>1.</strong> Count occurrences for each value.<br><strong>2.</strong> Convert counts to cumulative positions.<br><strong>3.</strong> Iterate input (reverse for stability), place each element using cumulative index, decrement count.</p>\n      </div>\n\n      <div style=\"margin-top:auto\">\n        <p class=\"muted-sm\">Designed for clarity and aesthetics. Interaction deliberately minimal — press Play to observe the algorithm.</p>\n      </div>\n    </aside>\n  </div>\n\n  <div class=\"footer\">\n    <div>Range shown: <span id=\"rangeLabel\" style=\"font-weight:700\">0 — 9</span></div>\n    <div style=\"opacity:0.9\">© Visual Algorithms</div>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Configuration and initial data\n  const inputArray = [4,2,2,8,3,3,1]; // example input\n  const MIN = 0;\n  const MAX = 9; // we display buckets 0..9 for clarity\n  const VALUES = [];\n  for(let v=MIN; v<=MAX; v++) VALUES.push(v);\n\n  const canvas = document.getElementById('canvas');\n  const inputRow = document.getElementById('inputRow');\n  const countRow = document.getElementById('countRow');\n  const cumRow = document.getElementById('cumRow');\n  const outputRow = document.getElementById('outputRow');\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const rangeLabel = document.getElementById('rangeLabel');\n\n  rangeLabel.textContent = `${MIN} — ${MAX}`;\n\n  let running = false;\n  let floatingPool = [];\n\n  // Utilities\n  function createTile(text, cls='tile') {\n    const d = document.createElement('div');\n    d.className = cls;\n    d.textContent = text;\n    return d;\n  }\n\n  function sleep(ms){ return new Promise(r=>setTimeout(r,ms)); }\n\n  // Build UI\n  function buildUI(){\n    inputRow.innerHTML = '';\n    countRow.innerHTML = '';\n    cumRow.innerHTML = '';\n    outputRow.innerHTML = '';\n\n    // Input tiles (arranged with slight curve)\n    inputArray.forEach((v, i) => {\n      const t = createTile(v, 'tile');\n      t.dataset.index = i;\n      t.dataset.value = v;\n      inputRow.appendChild(t);\n    });\n\n    // Count buckets: show 0..9\n    VALUES.forEach((v) => {\n      const card = document.createElement('div');\n      card.className = 'count-card';\n      const lbl = document.createElement('div');\n      lbl.className = 'label';\n      lbl.textContent = `v = ${v}`;\n      const bubble = document.createElement('div');\n      bubble.className = 'count-bubble';\n      bubble.textContent = '0';\n      bubble.dataset.value = v;\n      card.appendChild(lbl);\n      card.appendChild(bubble);\n      countRow.appendChild(card);\n    });\n\n    // Cumulative bars\n    VALUES.forEach((v) => {\n      const barWrap = document.createElement('div');\n      barWrap.className = 'cum-bar';\n      const fill = document.createElement('div');\n      fill.className = 'cum-fill';\n      fill.dataset.value = v;\n      barWrap.appendChild(fill);\n      cumRow.appendChild(barWrap);\n    });\n\n    // Output slots\n    for(let i=0;i<inputArray.length;i++){\n      const slot = document.createElement('div');\n      slot.className = 'slot';\n      slot.dataset.index = i;\n      slot.textContent = '';\n      outputRow.appendChild(slot);\n    }\n  }\n\n  // Floating element for smooth motion\n  function createFloatingTile(text){\n    const f = createTile(text, 'tile floating');\n    f.style.position = 'fixed';\n    f.style.left = '0px';\n    f.style.top = '0px';\n    f.style.margin = '0';\n    f.style.pointerEvents = 'none';\n    canvas.appendChild(f);\n    return f;\n  }\n\n  function getCenterRect(el){\n    const r = el.getBoundingClientRect();\n    return { x: r.left + r.width/2, y: r.top + r.height/2, w:r.width, h:r.height };\n  }\n\n  async function animateMove(elem, targetEl, options={duration:520, scale:1.02}){\n    // Create floating clone\n    const srcRect = getCenterRect(elem);\n    const tgtRect = getCenterRect(targetEl);\n\n    const f = createFloatingTile(elem.textContent);\n    const startX = srcRect.x - 31; // tile half-size assumption\n    const startY = srcRect.y - 31;\n    f.style.transform = `translate(${startX}px, ${startY}px) scale(1)`;\n    f.style.opacity = '1';\n\n    await sleep(20);\n\n    // Move to target with bezier-like transition\n    const dx = tgtRect.x - srcRect.x;\n    const dy = tgtRect.y - srcRect.y;\n    const midX = startX + dx*0.45;\n    const midY = startY + dy*0.15 - 30;\n\n    f.animate([\n      { transform: `translate(${startX}px, ${startY}px) scale(1)` },\n      { transform: `translate(${midX}px, ${midY}px) scale(${options.scale})` },\n      { transform: `translate(${startX+dx}px, ${startY+dy}px) scale(1)` }\n    ], {\n      duration: options.duration,\n      easing: 'cubic-bezier(.2,.9,.2,1)',\n      fill:'forwards'\n    });\n\n    await sleep(options.duration - 40);\n    // settle\n    f.style.opacity = '0';\n    await sleep(80);\n    f.remove();\n  }\n\n  // Core animation sequence\n  async function playSequence(){\n    if(running) return;\n    running = true;\n    playBtn.disabled = true;\n    resetBtn.disabled = true;\n\n    const bubbles = Array.from(countRow.querySelectorAll('.count-bubble'));\n    const counts = new Array(VALUES.length).fill(0);\n    const cum = new Array(VALUES.length).fill(0);\n\n    // Stage: Counting\n    for(let i=0;i<inputArray.length;i++){\n      const tile = inputRow.children[i];\n      tile.classList.add('pulse');\n      tile.style.zIndex = 10;\n      await sleep(240);\n\n      const val = Number(tile.dataset.value);\n      const idx = val - MIN;\n      const bub = bubbles[idx];\n      // Animate a floating small arc to the count bubble\n      await animateMove(tile, bub, {duration:520, scale:1.06});\n      // increment visual count\n      counts[idx]++;\n      bub.textContent = String(counts[idx]);\n      bub.classList.add('active', 'pulse');\n      await sleep(180);\n      bub.classList.remove('pulse');\n      tile.style.zIndex = '';\n      tile.classList.remove('pulse');\n      await sleep(160);\n    }\n\n    await sleep(300);\n\n    // Stage: Cumulative\n    const fills = Array.from(cumRow.querySelectorAll('.cum-fill'));\n    let runningSum = 0;\n    for(let i=0;i<counts.length;i++){\n      runningSum += counts[i];\n      cum[i] = runningSum;\n      const pct = Math.min(100, (cum[i] / inputArray.length) * 100);\n      fills[i].style.width = pct + '%';\n      // tiny emphasis on corresponding bubble\n      const bub = bubbles[i];\n      bub.classList.add('pulse');\n      await sleep(200);\n      bub.classList.remove('pulse');\n      await sleep(120);\n    }\n\n    await sleep(400);\n\n    // Stage: Build output (iterate input in reverse for stability)\n    const slots = Array.from(outputRow.children);\n    for(let i=inputArray.length-1;i>=0;i--){\n      const tile = inputRow.children[i];\n      tile.classList.add('pulse');\n      const val = Number(tile.dataset.value);\n      const idx = val - MIN;\n      const pos = cum[idx] - 1; // target slot index\n      if(pos < 0) continue; // safety\n      // animate to output slot[pos]\n      await animateMove(tile, slots[pos], {duration:520, scale:1.04});\n      // visually place value in slot\n      slots[pos].textContent = tile.textContent;\n      slots[pos].classList.add('value');\n      // decrement cum & counts\n      cum[idx] -= 1;\n      counts[idx] -= 1;\n      // update visuals\n      const bub = bubbles[idx];\n      bub.textContent = String(Math.max(0, counts[idx]));\n      bub.classList.add('active');\n      bub.classList.add('pulse');\n      // reduce cumulative fill proportionally\n      const fillEl = fills[idx];\n      const pct = Math.min(100, (cum[idx] / inputArray.length) * 100);\n      fillEl.style.width = pct + '%';\n      await sleep(240);\n      bub.classList.remove('pulse');\n      await sleep(120);\n      tile.classList.remove('pulse');\n      await sleep(120);\n    }\n\n    // Final flourish\n    for(const s of slots){\n      s.animate([{transform:'scale(0.98)'},{transform:'scale(1)'}], {duration:420, easing:'cubic-bezier(.2,.9,.2,1)'});\n      await sleep(40);\n    }\n\n    await sleep(500);\n    running = false;\n    playBtn.disabled = false;\n    resetBtn.disabled = false;\n  }\n\n  // Reset to initial state\n  function resetAll(){\n    if(running) return;\n    buildUI();\n  }\n\n  // Initial render\n  buildUI();\n\n  // Event handlers\n  playBtn.addEventListener('click', () => {\n    playSequence();\n  });\n  resetBtn.addEventListener('click', () => {\n    resetAll();\n  });\n\n  // Small accessibility: space or enter on play button\n  playBtn.addEventListener('keydown', (e) => {\n    if(e.key === 'Enter' || e.key===' ') { e.preventDefault(); playSequence(); }\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
