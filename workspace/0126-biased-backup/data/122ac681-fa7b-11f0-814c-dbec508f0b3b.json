    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Queue</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        input, select, textarea {\n            width: 100%;\n            padding: 0.5rem;\n            margin-bottom: 1rem;\n            border: 1px solid #ccc;\n            border-radius: 0.25rem;\n            box-shadow: 0 0 0 0.125rem rgba(0, 0, 0, 0.1);\n        }\n        button, input[type=\"submit\"] {\n            padding: 0.5rem 1rem;\n            border: none;\n            border-radius: 0.25rem;\n            cursor: pointer;\n            background-color: #4CAF50;\n            color: #fff;\n            font-size: 16px;\n            font-weight: bold;\n        }\n        button:hover, input[type=\"submit\"]:hover {\n            background-color: #3e8e41;\n        }\n        .queue {\n            position: relative;\n            width: 80%;\n            height: 300px;\n            margin: 40px auto;\n            overflow-y: auto;\n            padding: 20px;\n        }\n        .queue input, .queue select, .queue textarea {\n            width: 100%;\n        }\n        .queue button {\n            width: 20%;\n            margin: 10px 0;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"queue\">\n        <input type=\"text\" id=\"input\" placeholder=\"Enter text\">\n        <select id=\"select\">\n            <option value=\"1\">Option 1</option>\n            <option value=\"2\">Option 2</option>\n            <option value=\"3\">Option 3</option>\n        </select>\n        <textarea id=\"textarea\" placeholder=\"Enter text\"></textarea>\n        <button id=\"submit\">Submit</button>\n        <button id=\"clear\">Clear</button>\n        <button id=\"move-left\">Move Left</button>\n        <button id=\"move-right\">Move Right</button>\n        <button id=\"move-up\">Move Up</button>\n        <button id=\"move-down\">Move Down</button>\n    </div>\n\n    <script>\n        let queue = [];\n        let current = 0;\n        let isClear = false;\n        let isMoveLeft = false;\n        let isMoveRight = false;\n        let isMoveUp = false;\n        let isMoveDown = false;\n\n        document.getElementById('input').addEventListener('input', (e) => {\n            queue.push(e.target.value);\n            document.getElementById('textarea').value = queue.join('\\n');\n        });\n\n        document.getElementById('select').addEventListener('change', () => {\n            queue = [];\n            current = 0;\n            isClear = false;\n            isMoveLeft = false;\n            isMoveRight = false;\n            isMoveUp = false;\n            isMoveDown = false;\n            document.getElementById('textarea').value = '';\n        });\n\n        document.getElementById('textarea').addEventListener('input', (e) => {\n            queue = [];\n            current = 0;\n            isClear = false;\n            isMoveLeft = false;\n            isMoveRight = false;\n            isMoveUp = false;\n            isMoveDown = false;\n            document.getElementById('input').value = '';\n        });\n\n        document.getElementById('submit').addEventListener('click', () => {\n            if (queue.length > 0) {\n                let result = queue.shift();\n                document.getElementById('textarea').value += result + '\\n';\n                document.getElementById('input').value = '';\n            } else {\n                alert('No text to submit');\n            }\n        });\n\n        document.getElementById('clear').addEventListener('click', () => {\n            queue = [];\n            isClear = true;\n            document.getElementById('textarea').value = '';\n        });\n\n        document.getElementById('move-left').addEventListener('click', () => {\n            if (queue.length > 0) {\n                current -= 1;\n                document.getElementById('input').value = queue[current];\n                document.getElementById('textarea').value = queue.join('\\n');\n            }\n        });\n\n        document.getElementById('move-right').addEventListener('click', () => {\n            if (queue.length > 0) {\n                current += 1;\n                document.getElementById('input').value = queue[current];\n                document.getElementById('textarea').value = queue.join('\\n');\n            }\n        });\n\n        document.getElementById('move-up').addEventListener('click', () => {\n            if (queue.length > 0) {\n                current -= queue.length;\n                document.getElementById('input').value = queue[current];\n                document.getElementById('textarea').value = queue.join('\\n');\n            }\n        });\n\n        document.getElementById('move-down').addEventListener('click', () => {\n            if (queue.length > 0) {\n                current += queue.length;\n                document.getElementById('input').value = queue[current];\n                document.getElementById('textarea').value = queue.join('\\n');\n            }\n        });\n    </script>\n</body>\n</html>"
