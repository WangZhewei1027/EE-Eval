  "question": "Branch and Bound",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Branch and Bound Interactive Demo</title>\n<style>\n  /* Extremely minimal styling */\n  body {\n    font-family: monospace, monospace;\n    margin: 10px;\n    background: white;\n    color: black;\n  }\n  textarea {\n    width: 100%;\n    height: 80px;\n    font-family: monospace;\n    resize: vertical;\n  }\n  input[type=number] {\n    width: 60px;\n  }\n  input[type=text] {\n    width: 150px;\n  }\n  select {\n    width: 100px;\n  }\n  .section {\n    margin-bottom: 15px;\n  }\n  label {\n    user-select:none;\n  }\n  button {\n    margin-right: 5px;\n  }\n  hr {\n    margin-top: 15px;\n    margin-bottom: 15px;\n  }\n</style>\n</head>\n<body>\n<h1>Branch and Bound Interactive Demo</h1>\n\n<div class=\"section\">\n  <strong>Problem Setup:</strong><br />\n  Define variables and objective function (maximize):<br />\n  <label>Number of variables (1-6): <input type=\"number\" id=\"varCount\" min=\"1\" max=\"6\" value=\"3\" /></label>\n  <button id=\"setupProblemBtn\">Setup Problem</button><br />\n  <div id=\"varCoeffInputs\" style=\"margin-top:5px;\"></div>\n  Objective function format example: Maximize z = 3x1 + 5x2 + 2x3<br />\n  <small>All variables assumed integer and ≥ 0, no explicit constraints beyond branching variable bounds.</small>\n</div>\n\n<hr />\n\n<div class=\"section\" id=\"branchBoundControls\" style=\"display:none;\">\n  <strong>Branch and Bound Controls:</strong><br />\n  <button id=\"initBtn\">Initialize Algorithm</button>\n  <button id=\"stepBtn\" disabled>Next Step</button>\n  <button id=\"autoRunBtn\" disabled>Auto Run</button>\n  <button id=\"pauseBtn\" disabled>Pause Auto Run</button>\n  <button id=\"resetBtn\">Reset</button> \n  <button id=\"addNodeBtn\" disabled>Add Custom Node</button> (Add a node manually to the live node list)\n  <br /><br />\n  <label>Speed (steps/sec):\n    <input type=\"range\" id=\"speedRange\" min=\"0.1\" max=\"5\" value=\"1\" step=\"0.1\" />\n  </label>\n</div>\n\n<hr />\n\n<div class=\"section\" id=\"manualAddNodeSection\" style=\"display:none;\">\n  <strong>Manual Node Addition</strong><br />\n  <label>Node ID: <input type=\"text\" id=\"manualNodeId\" placeholder=\"unique id\" /></label><br />\n  <label>Variable bounds (JSON, e.g. {\"x1\":[0,10],\"x2\":[1,5]}): <br />\n    <textarea id=\"manualNodeBounds\" placeholder='e.g. {\"x1\":[0,10],\"x2\":[0,5]}'> </textarea>\n  </label><br />\n  <label>Objective bound (upper bound estimate): <input type=\"number\" id=\"manualNodeBound\" /></label><br />\n  <label>Parent Node ID (optional): <input type=\"text\" id=\"manualParentId\" placeholder=\"parent id or empty\" /></label><br />\n  <button id=\"addManualNodeConfirmBtn\">Add Node</button>\n  <button id=\"cancelManualNodeBtn\">Cancel</button>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Current State:</strong><br />\n  <div id=\"stateSummary\" style=\"white-space:pre-wrap; font-family: monospace;\"></div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Live Node List:</strong> (Nodes waiting to branch)<br />\n  <div id=\"liveNodeList\" style=\"max-height:180px; overflow-y:auto; font-family: monospace; white-space:pre-wrap; border: 1px solid #000; padding:5px;\"></div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Explored Nodes / Solutions:</strong><br />\n  <div id=\"exploredNodesList\" style=\"max-height:180px; overflow-y:auto; font-family: monospace; white-space:pre-wrap; border: 1px solid #000; padding:5px;\"></div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Logs / Messages:</strong><br />\n  <textarea id=\"logOutput\" readonly></textarea><br />\n  <button id=\"clearLogBtn\">Clear Log</button>\n</div>\n\n<script>\n(function(){\n  // === Variables and State ===\n  let varCount = 3;\n  let variables = []; // ['x1', 'x2', ...]\n  let objectiveCoeffs = []; // length varCount\n  /*\n    Nodes structure:\n    {\n      id: string,\n      bounds: { x1: [min,max], x2: [min,max], ... } integer ranges,\n      parent: string|null,\n      ub: number, // upper bound estimate,\n      lbSol: null | {solution: {x1: int,...}, value:number} // if feasible solution found,\n      status: 'live' | 'fathomed' | 'branched' | 'pruned'\n    }\n  */\n  let nodes = {}; // Dictionary by id\n  let liveNodes = []; // IDs of live nodes (waiting to branch)\n  let exploredNodes = new Set(); // IDs of nodes already processed\n  let bestSolution = null; // {solution:{...}, value:number}\n  let running = false;\n  let autoRunTimer = null;\n  let autoRunInterval = 1000;\n  let stepCount = 0;\n\n  // UI refs\n  const varCoeffInputsDiv = document.getElementById('varCoeffInputs');\n  const setupProblemBtn = document.getElementById('setupProblemBtn');\n  const varCountInput = document.getElementById('varCount');\n  const branchBoundControls = document.getElementById('branchBoundControls');\n  const initBtn = document.getElementById('initBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const autoRunBtn = document.getElementById('autoRunBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const addNodeBtn = document.getElementById('addNodeBtn');\n  const manualAddNodeSection = document.getElementById('manualAddNodeSection');\n  const manualNodeIdInput = document.getElementById('manualNodeId');\n  const manualNodeBoundsInput = document.getElementById('manualNodeBounds');\n  const manualNodeBoundInput = document.getElementById('manualNodeBound');\n  const manualParentIdInput = document.getElementById('manualParentId');\n  const addManualNodeConfirmBtn = document.getElementById('addManualNodeConfirmBtn');\n  const cancelManualNodeBtn = document.getElementById('cancelManualNodeBtn');\n  const stateSummaryDiv = document.getElementById('stateSummary');\n  const liveNodeListDiv = document.getElementById('liveNodeList');\n  const exploredNodesListDiv = document.getElementById('exploredNodesList');\n  const logOutput = document.getElementById('logOutput');\n  const clearLogBtn = document.getElementById('clearLogBtn');\n  const speedRange = document.getElementById('speedRange');\n\n  // --- Utility functions ---\n\n  // Log message with timestamp\n  function log(msg){\n    const now = new Date().toLocaleTimeString();\n    logOutput.value += `[${now}] ${msg}\\n`;\n    logOutput.scrollTop = logOutput.scrollHeight;\n  }\n\n  // Clear log\n  clearLogBtn.onclick = () => logOutput.value = '';\n\n  // Generate variable names x1,x2,... up to varCount\n  function genVarNames(count){\n    let res = [];\n    for(let i=1;i<=count;i++) res.push('x'+i);\n    return res;\n  }\n\n  // Render coefficient input fields for objective function\n  function renderCoeffInputs(){\n    varCoeffInputsDiv.innerHTML = '';\n    variables = genVarNames(varCount);\n    objectiveCoeffs = [];\n    variables.forEach(v=>{\n      const label = document.createElement('label');\n      label.textContent = `${v} coeff: `;\n      const input = document.createElement('input');\n      input.type = 'number';\n      input.value = '1';\n      input.min = '-1000';\n      input.max = '1000';\n      input.step = '1';\n      input.style.width = '40px';\n      input.dataset.varname = v;\n      label.appendChild(input);\n      varCoeffInputsDiv.appendChild(label);\n      varCoeffInputsDiv.appendChild(document.createTextNode(' '));\n    });\n  }\n\n  // Read current coefficients from inputs\n  function readCoeffs(){\n    objectiveCoeffs = [];\n    const inputs = varCoeffInputsDiv.querySelectorAll('input[type=number]');\n    for(let i=0;i<varCount;i++){\n      const val = parseInt(inputs[i].value,10);\n      if(isNaN(val)) return null;\n      objectiveCoeffs.push(val);\n    }\n    return objectiveCoeffs;\n  }\n\n  // Evaluate objective function for solution {x1:int,...}\n  function evalObjective(sol){\n    let val = 0;\n    for(let i=0;i<varCount;i++){\n      const v = variables[i];\n      val += (sol[v]||0)*objectiveCoeffs[i];\n    }\n    return val;\n  }\n\n  // Check if a solution respects node bounds\n  function respectsBounds(sol, bounds){\n    for(const v of variables){\n      const val = sol[v]||0;\n      const b = bounds[v];\n      if(!b) return false; // if bound missing for a var, no respect\n      if(val < b[0] || val > b[1]) return false;\n    }\n    return true;\n  }\n\n  // Solve LP relaxation to get upper bound for a node\n  // Since variables integer ≥0 and bounded, just assign each var max bound to maximize\n  // and objective coeff positive or negative? We maximize objective.\n  // So for each variable, if coeff positive, take variable upper bound,\n  // if coeff negative, take variable lower bound, because it reduces objective.\n  // This is a rough relaxation for demo.\n  function computeUpperBound(node){\n    let val = 0;\n    for(let i=0;i<varCount;i++){\n      const v = variables[i];\n      const c = objectiveCoeffs[i];\n      if(c >= 0){\n        val += c*(node.bounds[v][1]);\n      } else {\n        val += c*(node.bounds[v][0]);\n      }\n    }\n    return val;\n  }\n\n  // Find a feasible integer solution at the node (naive, tries to round down upper bounds, check respects)\n  function findFeasibleSolution(node){\n    // Try integer solution with all vars at lower bound\n    // then try upper bound, then mid-point floor, then try some randomized attempts\n    const b = node.bounds;\n    let candidate = {};\n    variables.forEach(v=>{\n      candidate[v] = b[v][0];\n    });\n    if(respectsBounds(candidate,b)) return candidate;\n\n    // Try upper bounds\n    candidate = {};\n    variables.forEach(v=>{\n      candidate[v] = b[v][1];\n    });\n    if(respectsBounds(candidate,b)) return candidate;\n\n    // Mid points floor\n    candidate = {};\n    variables.forEach(v=>{\n      candidate[v] = Math.floor((b[v][0] + b[v][1])/2);\n    });\n    if(respectsBounds(candidate,b)) return candidate;\n\n    // Random attempts (up to 20)\n    for(let attempt=0;attempt<20;attempt++){\n      candidate = {};\n      variables.forEach(v=>{\n        const minb = b[v][0];\n        const maxb = b[v][1];\n        candidate[v] = minb + Math.floor(Math.random()*(maxb - minb +1));\n      });\n      if(respectsBounds(candidate,b)) return candidate;\n    }\n    return null;\n  }\n\n  // Select variable to branch on\n  // Heuristic: Find variable with largest range and fractional midpoint for branching variable (to simulate fractional LP solution)\n  function selectBranchVariable(node){\n    // Simulated LP solution: midpoint of bounds float (not integer necessarily)\n    // We pretend fractional solution here to demonstrate branching\n    // We'll pick variable with largest fractional gap midpoint - floor(midpoint)\n    let bestVar = null;\n    let bestFrac = -1;\n    variables.forEach(v=>{\n      const [minb,maxb] = node.bounds[v];\n      if(minb === maxb) return; // fixed var, skip\n      const mid = (minb + maxb)/2;\n      const frac = mid - Math.floor(mid);\n      if(frac > bestFrac) {\n        bestFrac = frac;\n        bestVar = v;\n      }\n    });\n    // If none fractional, pick variable with largest range\n    if(!bestVar){\n      let maxRange = -1;\n      variables.forEach(v=>{\n        const [minb,maxb] = node.bounds[v];\n        if(minb !== maxb && (maxb - minb) > maxRange){\n          maxRange = maxb - minb;\n          bestVar = v;\n        }\n      });\n    }\n    return bestVar;\n  }\n\n  // Branch node on variable v at mid floor(midpoint) value:\n  // Create two child nodes:\n  // left child: var ≤ midFloor\n  // right child: var ≥ midFloor+1\n  function branchNode(node, v){\n    const [minb,maxb] = node.bounds[v];\n    if(minb === maxb) return []; // no actual branch possible\n    const mid = (minb + maxb)/2;\n    const midFloor = Math.floor(mid);\n    if(midFloor < minb || midFloor >= maxb) return [];\n\n    // Left child bounds copy with var max bound updated\n    let leftBounds = {};\n    for(const varName of variables){\n      leftBounds[varName] = [...node.bounds[varName]];\n    }\n    leftBounds[v][1] = midFloor;\n\n    // Right child bounds copy with var min bound updated\n    let rightBounds = {};\n    for(const varName of variables){\n      rightBounds[varName] = [...node.bounds[varName]];\n    }\n    rightBounds[v][0] = midFloor + 1;\n\n    // Generate unique ids for children\n    const leftId = node.id + 'L';\n    const rightId = node.id + 'R';\n\n    let leftNode = {\n      id: leftId,\n      bounds: leftBounds,\n      parent: node.id,\n      ub: computeUpperBound({bounds:leftBounds}),\n      lbSol: null,\n      status: 'live'\n    };\n    let rightNode = {\n      id: rightId,\n      bounds: rightBounds,\n      parent: node.id,\n      ub: computeUpperBound({bounds:rightBounds}),\n      lbSol: null,\n      status: 'live'\n    };\n    return [leftNode, rightNode];\n  }\n\n  // Update UI functions\n\n  function updateStateSummary(){\n    let s = '';\n    s += `Variables (${varCount}): ${variables.join(', ')}\\n`;\n    s += `Objective coefficients: ${objectiveCoeffs.join(', ')}\\n`;\n    s += `Step count: ${stepCount}\\n`;\n    s += `Best solution found:\\n`;\n    if(bestSolution){\n      s += `  Value = ${bestSolution.value}\\n  Solution: `;\n      const sol = bestSolution.solution;\n      s += variables.map(v=>`${v}=${sol[v]||0}`).join(', ') + '\\n';\n    } else {\n      s += '  None\\n';\n    }\n    s += `Live nodes count: ${liveNodes.length}\\n`;\n    s += `Explored nodes count: ${exploredNodes.size}\\n`;\n    stateSummaryDiv.textContent = s;\n  }\n\n  function formatNodeBrief(node){\n    let solStr = 'none';\n    if(node.lbSol) {\n      solStr = `val=${node.lbSol.value}, sol: ` + variables.map(v=>`${v}=${node.lbSol.solution[v]||0}`).join(',');\n    }\n    return `${node.id}: UB=${node.ub}, status=${node.status}, parent=${node.parent || 'none'}, feasibleSol [${solStr}]`;\n  }\n\n  function refreshLiveNodeList(){\n    let lines = [];\n    liveNodes.forEach(id=>{\n      if(nodes[id]){\n        lines.push(formatNodeBrief(nodes[id]));\n      }\n    });\n    liveNodeListDiv.textContent = lines.join('\\n');\n  }\n\n  function refreshExploredNodesList(){\n    let lines = [];\n    Array.from(exploredNodes).forEach(id=>{\n      const n = nodes[id];\n      if(n){\n        lines.push(formatNodeBrief(n));\n      }\n    });\n    exploredNodesListDiv.textContent = lines.join('\\n');\n  }\n\n  // === Controls wiring and logic ===\n\n  // Setup problem - generate coefficients inputs\n  setupProblemBtn.onclick = () => {\n    let c = parseInt(varCountInput.value,10);\n    if(isNaN(c) || c <1 || c >6){\n      alert('Variable count must be between 1 and 6');\n      return;\n    }\n    varCount = c;\n    renderCoeffInputs();\n    branchBoundControls.style.display = 'none';\n    manualAddNodeSection.style.display = 'none';\n    // Reset any prior state\n    resetAll();\n  };\n\n  function resetAll(){\n    variables = genVarNames(varCount);\n    objectiveCoeffs = readCoeffs() || objectiveCoeffs.fill(1);\n    nodes = {};\n    liveNodes = [];\n    exploredNodes.clear();\n    bestSolution = null;\n    running = false;\n    if(autoRunTimer){\n      clearInterval(autoRunTimer);\n      autoRunTimer = null;\n    }\n    stepCount = 0;\n    stepBtn.disabled = true;\n    autoRunBtn.disabled = true;\n    pauseBtn.disabled = true;\n    addNodeBtn.disabled = true;\n    stateSummaryDiv.textContent = '';\n    liveNodeListDiv.textContent = '';\n    exploredNodesListDiv.textContent = '';\n    log('State reset.');\n  }\n\n  resetBtn.onclick = () => {\n    resetAll();\n    branchBoundControls.style.display = 'none';\n    manualAddNodeSection.style.display = 'none';\n  };\n\n  // Initialize algorithm creates root node\n  initBtn.onclick = () => {\n    const coeffs = readCoeffs();\n    if(!coeffs){\n      alert('Invalid objective coefficients!');\n      return;\n    }\n    objectiveCoeffs = coeffs;\n    nodes = {};\n    liveNodes = [];\n    exploredNodes.clear();\n    bestSolution = null;\n    running = false;\n    if(autoRunTimer){\n      clearInterval(autoRunTimer);\n      autoRunTimer = null;\n    }\n    stepCount = 0;\n    // Root node bounds: all variables [0,100] by default\n    let rootBounds = {};\n    variables.forEach(v=>{\n      rootBounds[v]=[0,100];\n    });\n    const rootUb = computeUpperBound({bounds:rootBounds});\n    let rootNode = {\n      id: \"root\",\n      bounds: rootBounds,\n      parent: null,\n      ub: rootUb,\n      lbSol: null,\n      status: 'live'\n    };\n    nodes[rootNode.id] = rootNode;\n    liveNodes = [rootNode.id];\n    exploredNodes.clear();\n    bestSolution = null;\n    stepCount = 0;\n\n    stepBtn.disabled = false;\n    autoRunBtn.disabled = false;\n    pauseBtn.disabled = true;\n    addNodeBtn.disabled = false;\n\n    branchBoundControls.style.display = 'block';\n    manualAddNodeSection.style.display = 'none';\n\n    updateStateSummary();\n    refreshLiveNodeList();\n    refreshExploredNodesList();\n    log('Initialized with root node.');\n  };\n\n  // Core algorithm logic step\n\n  // Choose next node to branch: best first search (max UB node)\n  function pickNextNode(){\n    if(liveNodes.length === 0) return null;\n    let bestNode = null;\n    let bestUb = -Infinity;\n    liveNodes.forEach(id=>{\n      let n = nodes[id];\n      if(n.ub > bestUb) {\n        bestUb = n.ub;\n        bestNode = n;\n      }\n    });\n    return bestNode;\n  }\n\n  // Prune nodes with UB ≤ current best solution value\n  function pruneNodes(){\n    if(bestSolution == null) return;\n    let bestVal = bestSolution.value;\n    let newLiveNodes = [];\n    liveNodes.forEach(id=>{\n      let n = nodes[id];\n      if(n.ub <= bestVal) {\n        n.status = 'pruned';\n        log(`Pruned node ${id} with UB=${n.ub} ≤ best solution value =${bestVal}`);\n        exploredNodes.add(id);\n      } else {\n        newLiveNodes.push(id);\n      }\n    });\n    liveNodes = newLiveNodes;\n  }\n\n  // Perform one branch and bound step:\n  // 1) Pick next node with highest UB among live nodes\n  // 2) If no live nodes, done\n  // 3) Try find feasible solution in node, update best if improves\n  // 4) If UB ≤ best, fathom/prune node\n  // 5) Otherwise branch node on a variable, add children as live nodes, mark parent branched.\n  // 6) Update states and UI\n  function doStep(){\n    if(running) return; // prevent re-entrant\n\n    if(liveNodes.length === 0){\n      log('No live nodes left, algorithm finished.');\n      stepBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      pauseBtn.disabled = true;\n      addNodeBtn.disabled = true;\n      running = false;\n      return;\n    }\n    stepCount++;\n\n    pruneNodes();\n    if(liveNodes.length === 0){\n      log('All nodes pruned or fathomed after pruning. Finished.');\n      stepBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      pauseBtn.disabled = true;\n      addNodeBtn.disabled = true;\n      running = false;\n      updateStateSummary();\n      refreshLiveNodeList();\n      refreshExploredNodesList();\n      return;\n    }\n\n    let node = pickNextNode();\n    if(!node){\n      log('No suitable node to branch. Finished.');\n      stepBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      pauseBtn.disabled = true;\n      addNodeBtn.disabled = true;\n      running = false;\n      return;\n    }\n    \n    log(`Branching on node ${node.id} with UB=${node.ub}`);\n\n    // Try find feasible solution at node if none\n    if(!node.lbSol){\n      let feasibleSol = findFeasibleSolution(node);\n      if(feasibleSol){\n        let val = evalObjective(feasibleSol);\n        node.lbSol = {solution: feasibleSol, value: val};\n        log(`Found feasible solution at node ${node.id} with value=${val}`);\n        if(!bestSolution || val > bestSolution.value) {\n          bestSolution = {solution: feasibleSol, value: val};\n          log(`Best solution updated with value=${val} at node ${node.id}`);\n        }\n      }\n    }\n    // Fathom/prune if cannot improve best\n    if(bestSolution && node.ub <= bestSolution.value) {\n      node.status = 'pruned';\n      log(`Fathomed node ${node.id} with UB=${node.ub} ≤ best solution =${bestSolution.value}`);\n      // Remove node from live nodes and add to explored\n      liveNodes = liveNodes.filter(id => id !== node.id);\n      exploredNodes.add(node.id);\n      updateStateSummary();\n      refreshLiveNodeList();\n      refreshExploredNodesList();\n      return;\n    }\n\n    // If node bounds are all fixed (min=max for all vars), node is a leaf (integer solution fixed)\n    let fixedAll = variables.every(v=>{\n      let [minb,maxb] = node.bounds[v];\n      return minb === maxb;\n    });\n    if(fixedAll){\n      node.status = 'fathomed';\n      log(`Node ${node.id} is a leaf with fixed vars, fathomed.`);\n      // If no feasible sol yet, assign solution of bounds fixed\n      if(!node.lbSol){\n        let sol = {};\n        variables.forEach(v=>{\n          sol[v] = node.bounds[v][0];\n        });\n        let val = evalObjective(sol);\n        node.lbSol = {solution: sol, value: val};\n        if(!bestSolution || val > bestSolution.value) {\n          bestSolution = {solution: sol, value: val};\n          log(`Best solution updated with leaf node value=${val}`);\n        }\n      }\n      // Remove node from live, add to explored\n      liveNodes = liveNodes.filter(id=>id !== node.id);\n      exploredNodes.add(node.id);\n\n      updateStateSummary();\n      refreshLiveNodeList();\n      refreshExploredNodesList();\n      return;\n    }\n\n    // Otherwise branch\n    let branchVar = selectBranchVariable(node);\n    if(!branchVar) {\n      log(`No variable to branch on node ${node.id}, fathomed.`);\n      node.status = 'fathomed';\n      liveNodes = liveNodes.filter(id=>id !== node.id);\n      exploredNodes.add(node.id);\n      updateStateSummary();\n      refreshLiveNodeList();\n      refreshExploredNodesList();\n      return;\n    }\n\n    // Branch and create children\n    let children = branchNode(node,branchVar);\n    if(children.length === 0){\n      log(`No children generated when branching on variable ${branchVar} at node ${node.id}, fathomed.`);\n      node.status = 'fathomed';\n      liveNodes = liveNodes.filter(id=>id !== node.id);\n      exploredNodes.add(node.id);\n      updateStateSummary();\n      refreshLiveNodeList();\n      refreshExploredNodesList();\n      return;\n    }\n\n    log(`Branching node ${node.id} on variable ${branchVar} into ${children.map(c=>c.id).join(', ')}`);\n\n    // Add children and mark parent branched\n    children.forEach(c=>{\n      // If child's UB ≤ best known, prune immediately\n      if(bestSolution && c.ub <= bestSolution.value){\n        c.status = 'pruned';\n        log(`Pruned child node ${c.id} immediately (UB ≤ best solution)`);\n        exploredNodes.add(c.id);\n      } else {\n        nodes[c.id] = c;\n        liveNodes.push(c.id);\n      }\n    });\n\n    node.status = 'branched';\n    liveNodes = liveNodes.filter(id=>id !== node.id);\n    exploredNodes.add(node.id);\n\n    updateStateSummary();\n    refreshLiveNodeList();\n    refreshExploredNodesList();\n  }\n\n  // Step button\n  stepBtn.onclick = () => {\n    doStep();\n  };\n\n  // Auto run controls\n  autoRunBtn.onclick = () => {\n    if(running) return;\n    running = true;\n    stepBtn.disabled = true;\n    autoRunBtn.disabled = true;\n    pauseBtn.disabled = false;\n    addNodeBtn.disabled = true;\n    log('Starting auto run.');\n    autoRunInterval = 1000 / parseFloat(speedRange.value);\n    autoRunTimer = setInterval(()=>{\n      doStep();\n      if(liveNodes.length === 0){\n        clearInterval(autoRunTimer);\n        running = false;\n        stepBtn.disabled = true;\n        autoRunBtn.disabled = true;\n        pauseBtn.disabled = true;\n        addNodeBtn.disabled = true;\n        log('Auto run finished.');\n      }\n    }, autoRunInterval);\n  };\n\n  pauseBtn.onclick = () => {\n    if(autoRunTimer){\n      clearInterval(autoRunTimer);\n      autoRunTimer = null;\n      running = false;\n      stepBtn.disabled = false;\n      autoRunBtn.disabled = false;\n      pauseBtn.disabled = true;\n      addNodeBtn.disabled = false;\n      log('Auto run paused.');\n    }\n  };\n\n  speedRange.oninput = () => {\n    if(running){\n      clearInterval(autoRunTimer);\n      autoRunInterval = 1000 / parseFloat(speedRange.value);\n      autoRunTimer = setInterval(()=>{\n        doStep();\n        if(liveNodes.length === 0){\n          clearInterval(autoRunTimer);\n          running = false;\n          stepBtn.disabled = true;\n          autoRunBtn.disabled = true;\n          pauseBtn.disabled = true;\n          addNodeBtn.disabled = true;\n          log('Auto run finished.');\n        }\n      }, autoRunInterval);\n    }\n  };\n\n  // Add node button to open manual node addition UI\n  addNodeBtn.onclick = () => {\n    manualAddNodeSection.style.display = 'block';\n    manualNodeIdInput.value = '';\n    manualNodeBoundsInput.value = JSON.stringify(\n      variables.reduce((acc,v)=>{\n        acc[v] = [0,100];\n        return acc;\n      }, {})\n    , null, 2);\n    manualNodeBoundInput.value = '';\n    manualParentIdInput.value = '';\n  };\n\n  cancelManualNodeBtn.onclick = () => {\n    manualAddNodeSection.style.display = 'none';\n  };\n\n  addManualNodeConfirmBtn.onclick = () => {\n    let id = manualNodeIdInput.value.trim();\n    if(!id){\n      alert('Node ID required');\n      return;\n    }\n    if(nodes[id]){\n      alert('Node ID must be unique');\n      return;\n    }\n    let boundsStr = manualNodeBoundsInput.value.trim();\n    if(!boundsStr){\n      alert('Bounds required');\n      return;\n    }\n    let boundsObj;\n    try {\n      boundsObj = JSON.parse(boundsStr);\n    } catch(e){\n      alert('Invalid JSON for bounds');\n      return;\n    }\n    // Validate bounds keys and values\n    for(let v of variables){\n      if(!boundsObj[v]){\n        alert(`Bounds missing variable ${v}`);\n        return;\n      }\n      let b = boundsObj[v];\n      if(!Array.isArray(b) || b.length !== 2) {\n        alert(`Bounds for variable ${v} must be an array of two integers`);\n        return;\n      }\n      if(!Number.isInteger(b[0]) || !Number.isInteger(b[1])){\n        alert(`Bounds for variable ${v} must be integers`);\n        return;\n      }\n      if(b[0] > b[1]){\n        alert(`Lower bound > upper bound for variable ${v}`);\n        return;\n      }\n    }\n    let ub = parseFloat(manualNodeBoundInput.value);\n    if(isNaN(ub)){\n      alert('Objective bound (UB) required and must be a number');\n      return;\n    }\n    let parentId = manualParentIdInput.value.trim();\n    if(parentId && !nodes[parentId]){\n      alert('Parent node ID does not exist');\n      return;\n    }\n\n    let newNode = {\n      id: id,\n      bounds: boundsObj,\n      parent: parentId || null,\n      ub: ub,\n      lbSol: null,\n      status: 'live'\n    };\n    nodes[id] = newNode;\n    liveNodes.push(id);\n    manualAddNodeSection.style.display = 'none';\n    addNodeBtn.disabled = false;\n    log(`Manual node ${id} added.`);\n    updateStateSummary();\n    refreshLiveNodeList();\n    refreshExploredNodesList();\n  };\n\n  // Initial setup on load:\n  renderCoeffInputs();\n\n})();\n</script>\n</body>\n</html>"
