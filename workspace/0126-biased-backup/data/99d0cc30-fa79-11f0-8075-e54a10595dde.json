    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Integration Testing Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n        .control-group {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Integration Testing Live Demo</h1>\n\n<div class=\"control-group\">\n    <label for=\"inputField\">Type a value:</label>\n    <input type=\"text\" id=\"inputField\" placeholder=\"Enter a number\">\n    <button onclick=\"submitValue()\">Submit</button>\n    <p id=\"submitResult\"></p>\n</div>\n\n<div class=\"control-group\">\n    <label for=\"slider\">Adjust the slider:</label>\n    <input type=\"range\" id=\"slider\" min=\"0\" max=\"100\" value=\"50\" oninput=\"updateSliderValue()\">\n    <p>Current Value: <span id=\"sliderValue\">50</span></p>\n</div>\n\n<div class=\"control-group\">\n    <button onclick=\"resetAll()\">Reset All</button>\n</div>\n\n<div class=\"control-group\">\n    <h3>Integration Test Results:</h3>\n    <ul id=\"testResults\">\n        <li>No tests run yet.</li>\n    </ul>\n</div>\n\n<script>\n    let testResults = [];\n\n    function submitValue() {\n        const inputVal = document.getElementById('inputField').value;\n        const resultArea = document.getElementById('submitResult');\n        const sliderValue = document.getElementById('slider').value;\n        \n        if (isNaN(inputVal) || inputVal === \"\") {\n            resultArea.innerText = \"Please enter a valid number.\";\n            return;\n        }\n\n        const resultText = `Submitted Value: ${inputVal}, Slider Value: ${sliderValue}`;\n        resultArea.innerText = resultText;\n\n        // Log the result for integration testing\n        logTestResult(resultText);\n    }\n\n    function updateSliderValue() {\n        const sliderValue = document.getElementById('slider').value;\n        document.getElementById('sliderValue').innerText = sliderValue;\n    }\n\n    function resetAll() {\n        document.getElementById('inputField').value = '';\n        document.getElementById('submitResult').innerText = '';\n        document.getElementById('slider').value = 50;\n        document.getElementById('sliderValue').innerText = '50';\n        testResults = [];\n        document.getElementById('testResults').innerHTML = '<li>No tests run yet.</li>';\n    }\n\n    function logTestResult(result) {\n        testResults.push(result);\n        updateTestResultsDisplay();\n    }\n\n    function updateTestResultsDisplay() {\n        const resultsList = document.getElementById('testResults');\n        resultsList.innerHTML = ''; // Clear existing results\n        testResults.forEach((testResult, index) => {\n            const listItem = document.createElement('li');\n            listItem.innerText = `Test ${index + 1}: ${testResult}`;\n            resultsList.appendChild(listItem);\n        });\n    }\n</script>\n\n</body>\n</html>"
