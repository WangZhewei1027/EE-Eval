  "question": "Agile Methodology",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Agile Methodology Interactive Explorer</title>\n<style>\n  body {\n    margin: 1em;\n    font-family: monospace, monospace;\n    white-space: pre-wrap;\n  }\n  button,input,select,textarea {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  textarea {\n    width: 100%;\n    height: 80px;\n  }\n  label {\n    display: inline-block;\n    margin-top: 0.5em;\n    margin-bottom: 0.2em;\n  }\n  hr {\n    margin: 1em 0;\n  }\n</style>\n</head>\n<body>\n<h1>Agile Methodology Interactive Explorer</h1>\n\n<div>\n  <p>\n    This interactive tool lets you simulate, plan, and explore Agile workflows: roles, ceremonies, artifacts, and iterative sprints.\n    Use the controls below to create backlog items, define teams, run sprints, hold ceremonies, and track progress.\n    Experiment with dependencies, changes, and team decisions to see how Agile principles apply.\n  </p>\n</div>\n\n<hr/>\n\n<section aria-label=\"Project setup\">\n  <h2>1. Project and Team Setup</h2>\n  <label for=\"projectName\">Project name:</label><br/>\n  <input type=\"text\" id=\"projectName\" placeholder=\"Enter project name\" /><br/>\n\n  <label for=\"teamSize\">Team size (1–10):</label><br/>\n  <input type=\"number\" id=\"teamSize\" min=\"1\" max=\"10\" value=\"3\"/><br/>\n\n  <label for=\"rolesSelect\">Assign roles to team members:</label><br/>\n  <div id=\"rolesInputsContainer\" aria-live=\"polite\"></div>\n\n  <button id=\"setupProjectBtn\">Initialize Project</button>\n\n  <p id=\"projectSetupResult\" aria-live=\"polite\"></p>\n</section>\n\n<hr/>\n\n<section aria-label=\"Product Backlog Management\" hidden>\n  <h2>2. Product Backlog Management</h2>\n\n  <label for=\"backlogTitle\">Backlog item title:</label><br/>\n  <input type=\"text\" id=\"backlogTitle\" placeholder=\"User story or task title\" /><br/>\n\n  <label for=\"backlogDescription\">Description:</label><br/>\n  <textarea id=\"backlogDescription\" placeholder=\"Describe the requirement or task\"></textarea><br/>\n\n  <label for=\"backlogPriority\">Priority (1=highest):</label><br/>\n  <input type=\"number\" id=\"backlogPriority\" min=\"1\" max=\"10\" value=\"3\" /><br/>\n\n  <label for=\"backlogEstimation\">Story points estimation (1–13):</label><br/>\n  <input type=\"number\" id=\"backlogEstimation\" min=\"1\" max=\"13\" value=\"3\" /><br/>\n\n  <label for=\"backlogDependency\">Depends on backlog item ID (optional):</label><br/>\n  <input type=\"number\" id=\"backlogDependency\" min=\"1\" /><br/>\n\n  <button id=\"addBacklogItemBtn\">Add Backlog Item</button>\n  <button id=\"showBacklogBtn\" type=\"button\">Show Backlog</button>\n\n  <p id=\"backlogMessage\" aria-live=\"polite\"></p>\n\n  <details id=\"backlogListDetails\">\n    <summary>Product Backlog Items</summary>\n    <pre id=\"backlogList\" tabindex=\"0\"></pre>\n  </details>\n\n</section>\n\n<hr/>\n\n<section aria-label=\"Sprint Planning and Execution\" hidden>\n  <h2>3. Sprint Planning and Execution</h2>\n\n  <label for=\"sprintLength\">Sprint length (in days, 1–30):</label><br/>\n  <input type=\"number\" id=\"sprintLength\" min=\"1\" max=\"30\" value=\"7\" /><br/>\n\n  <button id=\"startSprintBtn\" type=\"button\">Start Sprint</button>\n  <button id=\"endSprintBtn\" type=\"button\" disabled>End Sprint</button>\n\n  <p id=\"sprintStatus\" aria-live=\"polite\"></p>\n\n  <details id=\"sprintBacklogDetails\" hidden>\n    <summary>Sprint Backlog</summary>\n    <pre id=\"sprintBacklogList\" tabindex=\"0\"></pre>\n  </details>\n\n  <h3>Task Board (Kanban style)</h3>\n  <div>\n    <label for=\"selectSprintItem\">Select Sprint Backlog Item:</label><br/>\n    <select id=\"selectSprintItem\" aria-label=\"Sprint Backlog Item\"></select><br/>\n\n    <label for=\"taskStateSelect\">Change Task State:</label><br/>\n    <select id=\"taskStateSelect\" aria-label=\"Task State\">\n      <option value=\"To Do\">To Do</option>\n      <option value=\"In Progress\">In Progress</option>\n      <option value=\"Review\">Review</option>\n      <option value=\"Done\">Done</option>\n    </select><br/>\n\n    <button id=\"updateTaskStateBtn\" type=\"button\">Update Task State</button>\n  </div>\n\n  <details id=\"taskBoardDetails\" hidden>\n    <summary>Current Task States</summary>\n    <pre id=\"taskBoardOutput\" tabindex=\"0\"></pre>\n  </details>\n</section>\n\n<hr/>\n\n<section aria-label=\"Agile Ceremonies\" hidden>\n  <h2>4. Agile Ceremonies</h2>\n\n  <button id=\"dailyStandupBtn\" type=\"button\">Hold Daily Stand-up</button>\n  <button id=\"sprintReviewBtn\" type=\"button\" disabled>Hold Sprint Review</button>\n  <button id=\"sprintRetrospectiveBtn\" type=\"button\" disabled>Hold Sprint Retrospective</button>\n\n  <details id=\"ceremonyDetails\" hidden>\n    <summary>Latest Ceremony Output</summary>\n    <pre id=\"ceremonyOutput\" tabindex=\"0\"></pre>\n  </details>\n</section>\n\n<hr/>\n\n<section aria-label=\"Explore Agile Concepts\" hidden>\n  <h2>5. Agile Exploration and Experimentation</h2>\n\n  <p>Modify backlog, reprioritize, add impediments, simulate team decisions. The state is dynamic and you can:</p>\n\n  <button id=\"addImpedimentBtn\" type=\"button\">Add Impediment</button>\n  <button id=\"resolveImpedimentBtn\" type=\"button\">Resolve Impediment</button>\n\n  <label for=\"impedimentText\">Impediment Description:</label><br/>\n  <input type=\"text\" id=\"impedimentText\" placeholder=\"Describe impediment\" /><br/>\n\n  <details id=\"impedimentsDetails\">\n    <summary>Current Impediments</summary>\n    <pre id=\"impedimentsList\" tabindex=\"0\"></pre>\n  </details>\n</section>\n\n<hr/>\n\n<section aria-label=\"Project Summary\" hidden>\n  <h2>6. Project Summary and Insights</h2>\n\n  <button id=\"generateReportBtn\" type=\"button\">Generate Report</button>\n\n  <details id=\"reportDetails\">\n    <summary>Project Report</summary>\n    <pre id=\"projectReport\" tabindex=\"0\"></pre>\n  </details>\n</section>\n\n<script>\n(function(){\n  // Core data structures:\n  let project = {\n    name: null,\n    teamSize: 0,\n    roles: [],\n    backlog: [],\n    sprint: null,\n    impediments: [],\n  };\n\n  // Roles allowed and role assignment state:\n  const allowedRoles = [\"Product Owner\", \"Scrum Master\", \"Developer\"];\n\n  // Sprint States\n  const sprintStates = {\n    planned: \"Planned\",\n    active: \"Active\",\n    completed: \"Completed\"\n  };\n\n  // Task States\n  const taskStates = [\"To Do\", \"In Progress\", \"Review\", \"Done\"];\n\n  // Cached elements\n  const projectNameInput = document.getElementById(\"projectName\");\n  const teamSizeInput = document.getElementById(\"teamSize\");\n  const rolesInputsContainer = document.getElementById(\"rolesInputsContainer\");\n  const setupProjectBtn = document.getElementById(\"setupProjectBtn\");\n  const projectSetupResult = document.getElementById(\"projectSetupResult\");\n\n  const productBacklogSection = document.querySelector(\"section[aria-label='Product Backlog Management']\");\n  const backlogTitleInput = document.getElementById(\"backlogTitle\");\n  const backlogDescriptionInput = document.getElementById(\"backlogDescription\");\n  const backlogPriorityInput = document.getElementById(\"backlogPriority\");\n  const backlogEstimationInput = document.getElementById(\"backlogEstimation\");\n  const backlogDependencyInput = document.getElementById(\"backlogDependency\");\n  const addBacklogItemBtn = document.getElementById(\"addBacklogItemBtn\");\n  const showBacklogBtn = document.getElementById(\"showBacklogBtn\");\n  const backlogMessage = document.getElementById(\"backlogMessage\");\n  const backlogListDetails = document.getElementById(\"backlogListDetails\");\n  const backlogListPre = document.getElementById(\"backlogList\");\n\n  const sprintSection = document.querySelector(\"section[aria-label='Sprint Planning and Execution']\");\n  const sprintLengthInput = document.getElementById(\"sprintLength\");\n  const startSprintBtn = document.getElementById(\"startSprintBtn\");\n  const endSprintBtn = document.getElementById(\"endSprintBtn\");\n  const sprintStatus = document.getElementById(\"sprintStatus\");\n  const sprintBacklogDetails = document.getElementById(\"sprintBacklogDetails\");\n  const sprintBacklogList = document.getElementById(\"sprintBacklogList\");\n\n  const selectSprintItem = document.getElementById(\"selectSprintItem\");\n  const taskStateSelect = document.getElementById(\"taskStateSelect\");\n  const updateTaskStateBtn = document.getElementById(\"updateTaskStateBtn\");\n  const taskBoardDetails = document.getElementById(\"taskBoardDetails\");\n  const taskBoardOutput = document.getElementById(\"taskBoardOutput\");\n\n  const ceremoniesSection = document.querySelector(\"section[aria-label='Agile Ceremonies']\");\n  const dailyStandupBtn = document.getElementById(\"dailyStandupBtn\");\n  const sprintReviewBtn = document.getElementById(\"sprintReviewBtn\");\n  const sprintRetrospectiveBtn = document.getElementById(\"sprintRetrospectiveBtn\");\n  const ceremonyDetails = document.getElementById(\"ceremonyDetails\");\n  const ceremonyOutput = document.getElementById(\"ceremonyOutput\");\n\n  const explorationSection = document.querySelector(\"section[aria-label='Explore Agile Concepts']\");\n  const addImpedimentBtn = document.getElementById(\"addImpedimentBtn\");\n  const resolveImpedimentBtn = document.getElementById(\"resolveImpedimentBtn\");\n  const impedimentTextInput = document.getElementById(\"impedimentText\");\n  const impedimentsDetails = document.getElementById(\"impedimentsDetails\");\n  const impedimentsListPre = document.getElementById(\"impedimentsList\");\n\n  const projectSummarySection = document.querySelector(\"section[aria-label='Project Summary']\");\n  const generateReportBtn = document.getElementById(\"generateReportBtn\");\n  const reportDetails = document.getElementById(\"reportDetails\");\n  const projectReportPre = document.getElementById(\"projectReport\");\n\n  // Helpers for roles input creation and reading:\n  function createRoleInputs() {\n    rolesInputsContainer.innerHTML = \"\";\n    if (project.teamSize < 1 || project.teamSize > 10) return;\n    for(let i=1; i<=project.teamSize; i++) {\n      const label = document.createElement(\"label\");\n      label.textContent = `Team member #${i} role:`;\n      label.htmlFor = `roleInput${i}`;\n      const select = document.createElement(\"select\");\n      select.id = `roleInput${i}`;\n      select.setAttribute(\"aria-label\", `Role for team member ${i}`);\n      // Create options\n      allowedRoles.forEach(role=>{\n        const option = document.createElement(\"option\");\n        option.value = role;\n        option.textContent = role;\n        select.appendChild(option);\n      });\n      rolesInputsContainer.appendChild(label);\n      rolesInputsContainer.appendChild(document.createElement(\"br\"));\n      rolesInputsContainer.appendChild(select);\n      rolesInputsContainer.appendChild(document.createElement(\"br\"));\n    }\n  }\n\n  function getAssignedRoles() {\n    const roles = [];\n    for(let i=1; i<=project.teamSize; i++) {\n      const sel = document.getElementById(`roleInput${i}`);\n      if (sel) roles.push(sel.value);\n    }\n    return roles;\n  }\n\n  // Backlog item structure:\n  // id, title, description, priority, estimation, dependencies (array of IDs), state (\"backlog\", \"sprint\"), sprintId (null or sprint.id)\n  // Task state within sprint is tracked separately.\n\n  // Utility:\n  function getBacklogItemById(id) {\n    return project.backlog.find(it=>it.id === id) || null;\n  }\n\n  // --- Event listeners ---\n\n  // When teamSize changes, recreate role selectors\n  teamSizeInput.addEventListener(\"change\", () => {\n    let val = parseInt(teamSizeInput.value,10);\n    if (isNaN(val) || val < 1) val = 1;\n    else if (val > 10) val = 10;\n    teamSizeInput.value = val;\n    createRoleInputs();\n  });\n\n  projectNameInput.addEventListener(\"keydown\", (e)=>{\n    if (e.key === \"Enter\") e.preventDefault();\n  });\n\n  addBacklogItemBtn.addEventListener(\"click\", () => {\n    backlogMessage.textContent = \"\";\n    const title = backlogTitleInput.value.trim();\n    const description = backlogDescriptionInput.value.trim();\n    const priority = parseInt(backlogPriorityInput.value,10);\n    const estimation = parseInt(backlogEstimationInput.value,10);\n    const depIdRaw = backlogDependencyInput.value.trim();\n    let depId = null;\n    if (depIdRaw !== \"\") {\n      const d = parseInt(depIdRaw,10);\n      if (!isNaN(d)) depId = d;\n    }\n    if (!title) {\n      backlogMessage.textContent = \"Error: Backlog item title is required.\";\n      return;\n    }\n    if (isNaN(priority) || priority < 1 || priority > 10) {\n      backlogMessage.textContent = \"Error: Priority must be a number between 1 and 10.\";\n      return;\n    }\n    if (isNaN(estimation) || estimation < 1 || estimation > 13) {\n      backlogMessage.textContent = \"Error: Estimation must be between 1 and 13 story points.\";\n      return;\n    }\n    if (depId !== null) {\n      const depItem = getBacklogItemById(depId);\n      if (!depItem) {\n        backlogMessage.textContent = \"Error: Dependency ID does not exist in backlog.\";\n        return;\n      }\n    }\n    const newId = project.backlog.length > 0 ? project.backlog[project.backlog.length - 1].id + 1 : 1;\n    // Check circular dependency:\n    if (depId !== null) {\n      if (checkCircularDependency(newId, depId)) {\n        backlogMessage.textContent = \"Error: Circular dependency detected.\";\n        return;\n      }\n    }\n    project.backlog.push({\n      id: newId,\n      title,\n      description,\n      priority,\n      estimation,\n      dependencies: depId !== null ? [depId] : [],\n      state: \"backlog\",\n      sprintId: null,\n      taskState: null\n    });\n    backlogMessage.textContent = `Backlog item #${newId} added.`;\n    backlogTitleInput.value = \"\";\n    backlogDescriptionInput.value = \"\";\n    backlogPriorityInput.value = \"3\";\n    backlogEstimationInput.value = \"3\";\n    backlogDependencyInput.value = \"\";\n  });\n\n  // Show/hide backlog list with content sorted by priority asc then id\n  showBacklogBtn.addEventListener(\"click\", () => {\n    backlogListDetails.open = !backlogListDetails.open;\n    if (backlogListDetails.open) {\n      displayBacklog();\n    }\n  });\n\n  // Setup project button:\n  setupProjectBtn.addEventListener(\"click\", () => {\n    const name = projectNameInput.value.trim();\n    if (!name) {\n      projectSetupResult.textContent = \"Project name is required.\";\n      return;\n    }\n    const size = parseInt(teamSizeInput.value,10);\n    if (isNaN(size) || size < 1 || size > 10) {\n      projectSetupResult.textContent = \"Team size must be between 1 and 10.\";\n      return;\n    }\n    const assignedRoles = getAssignedRoles();\n    // Validate roles:\n    if (assignedRoles.length !== size) {\n      projectSetupResult.textContent = \"Assign all team member roles.\";\n      return;\n    }\n    // At least one PO and one SM:\n    const poCount = assignedRoles.filter(r=>r===\"Product Owner\").length;\n    const smCount = assignedRoles.filter(r=>r===\"Scrum Master\").length;\n    if (poCount < 1) {\n      projectSetupResult.textContent = \"At least one Product Owner is required.\";\n      return;\n    }\n    if (smCount < 1) {\n      projectSetupResult.textContent = \"At least one Scrum Master is required.\";\n      return;\n    }\n    project.name = name;\n    project.teamSize = size;\n    project.roles = assignedRoles;\n    project.backlog = [];\n    project.sprint = null;\n    project.impediments = [];\n    projectSetupResult.textContent = `Project \"${name}\" initialized with team of ${size} members.`;\n    // Show next section\n    productBacklogSection.hidden = false;\n    sprintSection.hidden = false;\n    ceremoniesSection.hidden = false;\n    explorationSection.hidden = false;\n    projectSummarySection.hidden = false;\n    backlogMessage.textContent = \"\";\n    updateSprintUI();\n  });\n\n  // Sprint start button\n  startSprintBtn.addEventListener(\"click\", () => {\n    if (project.sprint && project.sprint.state === sprintStates.active) {\n      sprintStatus.textContent = \"Sprint already active.\";\n      return;\n    }\n    if (project.backlog.length === 0) {\n      sprintStatus.textContent = \"Cannot start sprint: backlog is empty.\";\n      return;\n    }\n    // Select backlog items for sprint - prioritize highest priority and those without unresolved dependencies\n    const sprintLengthDays = parseInt(sprintLengthInput.value,10);\n    if (isNaN(sprintLengthDays) || sprintLengthDays < 1 || sprintLengthDays > 30) {\n      sprintStatus.textContent = \"Sprint length must be from 1 to 30 days.\";\n      return;\n    }\n    // Select items: sort by priority ascending, then id ascending\n    let selectable = project.backlog.filter(it=>it.state===\"backlog\");\n    // Filter out those that have unmet dependencies not in sprint or done\n    selectable = selectable.filter(it=>{\n      return it.dependencies.every(depId=>{\n        const dep = getBacklogItemById(depId);\n        if (!dep) return true; // should not happen\n        if (dep.state === \"sprint\" && dep.sprintId === (project.sprint ? project.sprint.id : null)) return true;\n        if (dep.state === \"done\") return true;\n        return false;\n      });\n    });\n    if (selectable.length === 0) {\n      sprintStatus.textContent = \"No backlog items without unmet dependencies to assign to sprint.\";\n      return;\n    }\n    // Capacity: assume each developer can handle 10 story points per sprint length week (scaled)\n    const devCount = project.roles.filter(r=>r===\"Developer\").length;\n    if (devCount === 0) {\n      sprintStatus.textContent = \"No Developers on team to assign sprint work.\";\n      return;\n    }\n    const capacityPoints = devCount * sprintLengthDays * (10 / 7);\n    let accumulated = 0;\n    let sprintItems = [];\n    for (const it of selectable) {\n      if ((accumulated + it.estimation) <= capacityPoints) {\n        sprintItems.push(it);\n        accumulated += it.estimation;\n      }\n    }\n    if (sprintItems.length === 0) {\n      sprintStatus.textContent = \"Backlog items too large to assign given capacity.\";\n      return;\n    }\n    // Create sprint object\n    const newSprintId = (project.sprint ? project.sprint.id + 1 : 1);\n    project.sprint = {\n      id: newSprintId,\n      length: sprintLengthDays,\n      state: sprintStates.active,\n      backlog: sprintItems.map(it=>it.id),\n      startDate: new Date(),\n      endDate: new Date(Date.now() + sprintLengthDays*24*60*60*1000),\n      taskStates: {}, // key: backlogItemId, value: taskState string\n      dailyStandupCount: 0,\n      reviewDone: false,\n      retrospectiveDone: false,\n    };\n    sprintItems.forEach(it=>{\n      it.state = \"sprint\";\n      it.sprintId = newSprintId;\n      it.taskState = \"To Do\";\n      project.sprint.taskStates[it.id] = \"To Do\";\n    });\n    sprintStatus.textContent = `Sprint #${newSprintId} started with ${sprintItems.length} backlog item(s), capacity ~${Math.round(capacityPoints)} story points.`;\n    updateSprintUI();\n    // Enable sprint end button\n    endSprintBtn.disabled = false;\n    sprintReviewBtn.disabled = true;\n    sprintRetrospectiveBtn.disabled = true;\n  });\n\n  // End sprint button\n  endSprintBtn.addEventListener(\"click\", () => {\n    if (!project.sprint || project.sprint.state !== sprintStates.active) {\n      sprintStatus.textContent = \"No active sprint to end.\";\n      return;\n    }\n    // Check if all sprint tasks are Done or blocked by impediments\n    const sprint = project.sprint;\n    const unfinished = sprint.backlog.filter(id=>{\n      const state = sprint.taskStates[id];\n      return state !== \"Done\";\n    });\n    if (unfinished.length > 0) {\n      sprintStatus.textContent = `Cannot end sprint: ${unfinished.length} task(s) not done yet.`;\n      return;\n    }\n    sprint.state = sprintStates.completed;\n    sprint.endDate = new Date();\n    // Mark backlog items as done\n    sprint.backlog.forEach(id=>{\n      const item = getBacklogItemById(id);\n      if (item) {\n        item.state = \"done\";\n        item.taskState = \"Done\";\n        item.sprintId = null;\n      }\n    });\n    sprintStatus.textContent = `Sprint #${sprint.id} completed.`;\n    endSprintBtn.disabled = true;\n    sprintReviewBtn.disabled = false;\n    sprintRetrospectiveBtn.disabled = false;\n    updateSprintUI();\n  });\n\n  // Update task state in sprint:\n  updateTaskStateBtn.addEventListener(\"click\", () => {\n    if (!project.sprint || project.sprint.state !== sprintStates.active) {\n      sprintStatus.textContent = \"No active sprint for updating task state.\";\n      return;\n    }\n    const selectedId = parseInt(selectSprintItem.value,10);\n    if (isNaN(selectedId)) {\n      sprintStatus.textContent = \"Select a sprint backlog item first.\";\n      return;\n    }\n    const newState = taskStateSelect.value;\n    project.sprint.taskStates[selectedId] = newState;\n    const item = getBacklogItemById(selectedId);\n    if (item) {\n      item.taskState = newState;\n    }\n    sprintStatus.textContent = `Task #${selectedId} state updated to \"${newState}\".`;\n    updateTaskBoardDisplay();\n  });\n\n  // Show daily stand-up dialog simulation\n  dailyStandupBtn.addEventListener(\"click\", () => {\n    if (!project.sprint || project.sprint.state !== sprintStates.active) {\n      ceremonyOutput.textContent = \"No active sprint for Daily Stand-up.\";\n      ceremonyDetails.hidden = false;\n      return;\n    }\n    const sprint = project.sprint;\n    sprint.dailyStandupCount++;\n    // For each team member, simulate status answers (for richness)\n    let output = `Daily Stand-up #${sprint.dailyStandupCount} for Sprint #${sprint.id}\\n\\n`;\n    for (let i=0; i<project.teamSize; i++) {\n      const role = project.roles[i];\n      const memberIndex = i+1;\n      if (role !== \"Developer\") {\n        output += `Team member #${memberIndex} (${role}): No development tasks.\\n`;\n        continue;\n      }\n      // List tasks assigned (for simulation: just pick one random sprint task)\n      const sprintTasks = sprint.backlog.map(id=>getBacklogItemById(id)).filter(it=>it!==null);\n      if (sprintTasks.length === 0) {\n        output += `Team member #${memberIndex} (${role}): No tasks assigned.\\n`;\n        continue;\n      }\n      // Randomly pick 1-2 tasks for \"working on\"\n      const numTasks = Math.min(2, sprintTasks.length);\n      const assignedTasks = [];\n      for(let j=0;j<numTasks;j++) {\n        const t = sprintTasks[(memberIndex + j) % sprintTasks.length];\n        assignedTasks.push(t);\n      }\n      assignedTasks.forEach((task,i)=>{\n        const state = sprint.taskStates[task.id] || \"To Do\";\n        output += `Team member #${memberIndex} (${role}): Task #${task.id} \"${task.title}\" is currently: ${state}.\\n`;\n        output += `  Yesterday: Worked on it.\\n`;\n        output += `  Today: Will continue.\\n`;\n        output += `  Blockers: ${project.impediments.length > 0 ? 'Yes' : 'No'}.\\n`;\n      });\n      output+=\"\\n\";\n    }\n    ceremonyOutput.textContent = output;\n    ceremonyDetails.hidden = false;\n  });\n\n  // Sprint review\n  sprintReviewBtn.addEventListener(\"click\", () => {\n    if (!project.sprint || project.sprint.state !== sprintStates.completed) {\n      ceremonyOutput.textContent = \"Sprint Review can only be held after sprint completion.\";\n      ceremonyDetails.hidden = false;\n      return;\n    }\n    const sprint = project.sprint;\n    if (sprint.reviewDone) {\n      ceremonyOutput.textContent = `Sprint #${sprint.id} review was already held.`;\n      ceremonyDetails.hidden = false;\n      return;\n    }\n    // Summary of delivered work\n    let output = `Sprint Review for Sprint #${sprint.id}\\n\\nDelivered product backlog items:\\n`;\n    sprint.backlog.forEach(id=>{\n      const item = getBacklogItemById(id);\n      if (item) {\n        output += `- #${item.id} \"${item.title}\" (Estimated ${item.estimation}pts)\\n`;\n      }\n    });\n    output += \"\\nFeedback: Collect feedback from Product Owner and stakeholders.\\n\";\n    sprint.reviewDone = true;\n    ceremonyOutput.textContent = output;\n    ceremonyDetails.hidden = false;\n  });\n\n  // Sprint retrospective\n  sprintRetrospectiveBtn.addEventListener(\"click\", () => {\n    if (!project.sprint || project.sprint.state !== sprintStates.completed) {\n      ceremonyOutput.textContent = \"Sprint Retrospective can only be held after sprint completion.\";\n      ceremonyDetails.hidden = false;\n      return;\n    }\n    const sprint = project.sprint;\n    if (sprint.retrospectiveDone) {\n      ceremonyOutput.textContent = `Sprint #${sprint.id} retrospective was already held.`;\n      ceremonyDetails.hidden = false;\n      return;\n    }\n    // Simple retrospective template for user interaction\n    let output = `Sprint Retrospective for Sprint #${sprint.id}\\n\\nPlease record:\\n`;\n    output += \"What went well:\\n- \\n\";\n    output += \"What could be improved:\\n- \\n\";\n    output += \"Action items:\\n- \\n\";\n    sprint.retrospectiveDone = true;\n    ceremonyOutput.textContent = output;\n    ceremonyDetails.hidden = false;\n  });\n\n  // Add impediment\n  addImpedimentBtn.addEventListener(\"click\", () => {\n    const desc = impedimentTextInput.value.trim();\n    if (!desc) return;\n    const newId = project.impediments.length > 0 ? project.impediments[project.impediments.length-1].id +1 : 1;\n    project.impediments.push({id:newId, description: desc, resolved: false});\n    impedimentTextInput.value = \"\";\n    updateImpedimentsList();\n  });\n\n  // Resolve impediment (resolve oldest unresolved by ID)\n  resolveImpedimentBtn.addEventListener(\"click\", () => {\n    const unresolved = project.impediments.filter(i=>!i.resolved);\n    if (unresolved.length === 0) return;\n    unresolved[0].resolved = true;\n    updateImpedimentsList();\n  });\n\n  // Generate summary report\n  generateReportBtn.addEventListener(\"click\", () => {\n    let r = `Project Report: \"${project.name}\"\\n\\nTeam (${project.teamSize}):\\n`;\n    project.roles.forEach((rname,i) => {\n      r += ` - Member #${i+1}: ${rname}\\n`;\n    });\n    r += \"\\nBacklog:\\n\";\n    if (project.backlog.length === 0) {\n      r += \" (No backlog items yet)\\n\";\n    } else {\n      project.backlog.forEach(it=>{\n        r += ` #${it.id} [${it.state}] \"${it.title}\" (Priority: ${it.priority}, Estimation: ${it.estimation})\\n`;\n      });\n    }\n    r += \"\\nCurrent Sprint:\\n\";\n    if (!project.sprint) {\n      r += \" No active or completed sprints.\\n\";\n    } else {\n      const sprint = project.sprint;\n      r += ` Sprint #${sprint.id} [${sprint.state}]\\n Length: ${sprint.length} days\\n Tasks:\\n`;\n      if (sprint.backlog.length === 0) {\n        r += \"  (No tasks assigned)\\n\";\n      } else {\n        sprint.backlog.forEach(id=>{\n          const item = getBacklogItemById(id);\n          if (item) {\n            r += `  #${id} \"${item.title}\" - State: ${sprint.taskStates[id] || \"To Do\"}\\n`;\n          }\n        });\n      }\n    }\n    r += \"\\nImpediments:\\n\";\n    if (project.impediments.length === 0) {\n      r += \" None.\\n\";\n    } else {\n      project.impediments.forEach(i=>{\n        r += ` #${i.id} - ${i.description} [${i.resolved ? \"Resolved\" : \"Active\"}]\\n`;\n      });\n    }\n    projectReportPre.textContent = r;\n    reportDetails.open = true;\n  });\n\n  // Helpers:\n  function displayBacklog() {\n    if (project.backlog.length === 0) {\n      backlogListPre.textContent = \"(No backlog items)\";\n      return;\n    }\n    // Sort by priority ascending, id ascending\n    const sorted = project.backlog.slice().sort((a,b)=>{\n      if (a.priority !== b.priority) return a.priority - b.priority;\n      return a.id - b.id;\n    });\n    let text = \"\";\n    sorted.forEach(item=>{\n      text += `#${item.id} [${item.state}] Title: ${item.title}\\n  Priority: ${item.priority}, Estimation: ${item.estimation} pts\\n  Desc: ${item.description}\\n`;\n      if (item.dependencies.length > 0) {\n        text += \"  Depends on: \" + item.dependencies.join(\", \") + \"\\n\";\n      }\n      text += \"\\n\";\n    });\n    backlogListPre.textContent = text;\n  }\n\n  function updateSprintUI(){\n    if (!project.sprint) {\n      sprintBacklogDetails.hidden = true;\n      selectSprintItem.innerHTML = \"\";\n      taskBoardDetails.hidden = true;\n      taskBoardOutput.textContent = \"\";\n      endSprintBtn.disabled = true;\n      sprintStatus.textContent = \"No active sprint.\";\n      sprintReviewBtn.disabled = true;\n      sprintRetrospectiveBtn.disabled = true;\n      return;\n    }\n    const sprint = project.sprint;\n    if (sprint.backlog.length === 0) {\n      sprintBacklogList.textContent = \"(No sprint backlog items)\";\n      sprintBacklogDetails.hidden = false;\n      selectSprintItem.innerHTML = \"\";\n      taskBoardDetails.hidden = true;\n      taskBoardOutput.textContent = \"\";\n      sprintStatus.textContent = `Sprint #${sprint.id} [${sprint.state}] has no tasks assigned.`;\n      return;\n    }\n    let text = \"\";\n    sprint.backlog.forEach(id=>{\n      const item = getBacklogItemById(id);\n      if (item) {\n        text += `#${item.id} \"${item.title}\" (Estimated ${item.estimation} pts) - State: ${sprint.taskStates[id] || \"To Do\"}\\n`;\n      }\n    });\n    sprintBacklogList.textContent = text;\n    sprintBacklogDetails.hidden = false;\n    sprintStatus.textContent = `Sprint #${sprint.id} [${sprint.state}], length ${sprint.length} days.`;\n    // Update selectSprintItem options:\n    selectSprintItem.innerHTML = \"\";\n    sprint.backlog.forEach(id=>{\n      const item = getBacklogItemById(id);\n      if (item) {\n        const opt = document.createElement(\"option\");\n        opt.value = id;\n        opt.textContent = `#${id}: ${item.title}`;\n        selectSprintItem.appendChild(opt);\n      }\n    });\n    taskBoardDetails.hidden = false;\n    updateTaskBoardDisplay();\n  }\n\n  function updateTaskBoardDisplay() {\n    if (!project.sprint) {\n      taskBoardOutput.textContent = \"\";\n      return;\n    }\n    const sprint = project.sprint;\n    let text = \"\";\n    taskStates.forEach(s=>{\n      text += `${s}:\\n`;\n      sprint.backlog.forEach(id=>{\n        if ((sprint.taskStates[id] || \"To Do\") === s) {\n          const item = getBacklogItemById(id);\n          if (item) text += ` - #${id} \"${item.title}\"\\n`;\n        }\n      });\n      text += \"\\n\";\n    });\n    taskBoardOutput.textContent = text;\n  }\n\n  function updateImpedimentsList() {\n    if (project.impediments.length === 0) {\n      impedimentsListPre.textContent = \"(No impediments)\";\n      impedimentsDetails.open = false;\n      return;\n    }\n    let text = \"\";\n    project.impediments.forEach(i=>{\n      text += `#${i.id} - ${i.description} [${i.resolved ? \"Resolved\" : \"Active\"}]\\n`;\n    });\n    impedimentsListPre.textContent = text;\n    impedimentsDetails.open = true;\n  }\n\n  // Circular dependency check using DFS:\n  function checkCircularDependency(newId, depId) {\n    // Build map for quick lookup\n    const graph = {};\n    project.backlog.forEach(it=>{\n      graph[it.id] = it.dependencies.slice();\n    });\n    graph[newId] = [depId];\n    // DFS to detect cycle starting from newId\n    const visited = new Set();\n    function dfs(id, path) {\n      if (path.includes(id)) return true;\n      if (!graph[id]) return false;\n      for (const neighbor of graph[id]) {\n        if (dfs(neighbor, path.concat(id))) return true;\n      }\n      return false;\n    }\n    return dfs(newId, []);\n  }\n\n  // Initial setup\n  createRoleInputs();\n\n})();\n</script>\n\n</body>\n</html>"
