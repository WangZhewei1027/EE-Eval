    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Digital Signatures — A Visual Exploration</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;600&family=JetBrains+Mono&display=swap');\n  /* Reset and base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, #0d1b2a, #1b263b);\n    font-family: 'Space Grotesk', sans-serif;\n    color: #e0e6f0;\n    overflow-x: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2rem 1rem 4rem;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.2rem;\n    color: #64d2ff;\n    letter-spacing: 0.12em;\n    margin: 0 0 0.5rem 0;\n    user-select:none;\n    text-shadow:\n      0 0 12px #64d2ff,\n      0 0 24px #64d2ff;\n    transition: color 0.6s ease;\n  }\n  h1 span {\n    color: #ffffff;\n  }\n  h2 {\n    font-weight: 300;\n    font-size: 1.2rem;\n    color: #94b9ffdd;\n    letter-spacing: 0.1em;\n    margin: 0 0 3rem 0;\n    user-select:none;\n  }\n\n  .container {\n    max-width: 960px;\n    width: 100%;\n    position: relative;\n  }\n\n  /* CARD / VISUAL SECTION */\n  .visual-card {\n    background: rgba(6,22,43,0.85);\n    border-radius: 24px;\n    box-shadow:\n      0 0 20px #0af,\n      0 10px 30px #0af50a44 inset,\n      0 0 60px #64d2ff55 inset;\n    padding: 3rem 3.5rem 3rem 3.5rem;\n    user-select:none;\n    overflow: visible;\n    position: relative;\n  }\n  .visual-card::before {\n    content: '';\n    position: absolute;\n    top: -25%;\n    left: -25%;\n    width: 150%;\n    height: 150%;\n    pointer-events:none;\n    background:\n      radial-gradient(ellipse at center, #64d2ff33 0%, transparent 60%);\n    filter: blur(90px);\n    z-index: 0;\n  }\n  .visual-inner {\n    position: relative;\n    z-index: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 2.5rem;\n  }\n  /* GRAPHIC VISUALIZATION: Letter/Document and Signature + Chain */\n\n  .graphic {\n    display: flex;\n    justify-content: center;\n    gap: 3.5rem;\n    flex-wrap: wrap;\n  }\n\n  .element-card {\n    background: #152e50;\n    border-radius: 20px;\n    box-shadow: 0 2px 15px #0af7ff33;\n    width: 280px;\n    min-height: 320px;\n    padding: 2rem 2.5rem;\n    position: relative;\n    color: #c0d8ffcc;\n    text-align: center;\n    user-select:none;\n    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  .element-card:hover {\n    transform: translateY(-10px);\n    box-shadow:\n      0 15px 30px #64d2ffaa,\n      inset 0 0 60px #64d2ffbb;\n    color: #d0e8ff;\n  }\n\n  .element-card h3 {\n    font-weight: 600;\n    font-size: 1.6rem;\n    margin-bottom: 1rem;\n    color: #74cbff;\n    text-shadow: 0 0 8px #74cbff88;\n  }\n\n  /* Document graphic */\n  .document {\n    position: relative;\n    width: 120px;\n    height: 160px;\n    margin: 0 auto 1.6rem;\n    filter: drop-shadow(0 0 4px #64d2ff44);\n  }\n  .document svg {\n    width: 120px;\n    height: 160px;\n  }\n  .doc-page {\n    fill: linear-gradient(180deg, #0f2345 0%, #1a3e77 100%);\n    filter: drop-shadow(0 0 8px #0af);\n  }\n  /* Stylized lines inside doc */\n  .doc-line {\n    stroke: #76c7ff88;\n    stroke-linecap: round;\n    stroke-width: 4;\n    opacity: 0.6;\n    transform-origin: left center;\n  }\n\n  /* Signature graphic */\n  .signature-graphic {\n    position: relative;\n    width: 140px;\n    height: 80px;\n    margin: 0 auto 1.6rem;\n  }\n  .signature-svg {\n    filter: drop-shadow(0 2px 6px #0af6ff99);\n  }\n  .signature-path {\n    fill: none;\n    stroke: #72e0ffcc;\n    stroke-width: 4;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    filter:\n      drop-shadow(0 0 6px #72e0ffbb);\n    animation: sign-draw 3s ease forwards;\n    stroke-dasharray: 600;\n    stroke-dashoffset: 600;\n  }\n\n  @keyframes sign-draw {\n    to {\n      stroke-dashoffset: 0;\n    }\n  }\n\n  /* Hash graphic */\n  .hash-box {\n    width: 110px;\n    height: 110px;\n    margin: 0 auto 1.6rem;\n    position: relative;\n    filter: drop-shadow(0 0 8px #72d2ffbb);\n  }\n  .hash-svg circle {\n    fill: none;\n    stroke: #5ed2ffaa;\n    stroke-width: 5;\n  }\n  .hash-svg line {\n    stroke: #72e0ffcc;\n    stroke-width: 4;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n  .hash-svg path {\n    stroke: #72e0ffcc;\n    stroke-width: 3;\n    fill: none;\n    filter: drop-shadow(0 0 6px #72e0ffbb);\n  }\n\n  /* Chain connecting lines */\n  .chain-line {\n    position: absolute;\n    width: 160px;\n    height: 6px;\n    top: 50%;\n    left: 100%;\n    margin-left: 8px;\n    background: linear-gradient(90deg, #64d2ffaa, #0a99e1cc);\n    border-radius: 4px;\n    box-shadow:\n      0 0 10px #64d2ff88,\n      inset 0 0 12px #0af;\n    filter: blur(0.6px);\n    transition: background 0.4s ease;\n  }\n  /* vertical chain lines for small screen */\n  @media (max-width: 720px) {\n    .graphic {\n      gap: 5rem;\n      flex-direction: column;\n    }\n    .chain-line {\n      width: 6px;\n      height: 80px;\n      top: 100%;\n      left: 50%;\n      margin-left: 0;\n      margin-top: 12px;\n      background: linear-gradient(180deg, #64d2ffaa, #0a99e1cc);\n      border-radius: 4px;\n      filter: blur(0.6px);\n    }\n  }\n\n\n  /* Explanation text */\n  .explanation {\n    margin-top: 3rem;\n    font-weight: 300;\n    font-size: 1rem;\n    line-height: 1.65;\n    max-width: 720px;\n    color: #b0c8ffcc;\n    border-left: 3px solid #64d2ff88;\n    padding-left: 1.6rem;\n    user-select:none;\n  }\n  .explanation strong {\n    color: #a2d8ff;\n  }\n\n  /* Button style */\n  .btn-container {\n    margin-top: 3rem;\n    text-align: center;\n  }\n  button#revealSign {\n    background: #0af;\n    border: none;\n    padding: 12px 32px;\n    font-family: 'JetBrains Mono', monospace;\n    font-size: 1.1rem;\n    font-weight: 600;\n    border-radius: 36px;\n    color: #cce8ff;\n    cursor: pointer;\n    box-shadow:\n      0 0 8px #0cf8ffaa,\n      inset 0 0 12px #27eaffcc;\n    transition:\n      box-shadow 0.3s ease,\n      background 0.3s ease,\n      color 0.3s ease;\n    user-select:none;\n    filter: drop-shadow(0 0 6px #0affffbb);\n  }\n  button#revealSign:hover {\n    background: #40cfff;\n    box-shadow:\n      0 0 18px #3af6ffcc,\n      inset 0 0 18px #12dbffcc;\n    color: #e0f4ff;\n  }\n  button#revealSign:focus-visible {\n    outline: 2px solid #3af6ffcc;\n    outline-offset: 3px;\n  }\n\n\n  /* Footer fade */\n  footer {\n    margin-top: auto;\n    color: #40507088;\n    font-size: 0.9rem;\n    font-weight: 300;\n    user-select:none;\n    user-drag:none;\n    filter: drop-shadow(0 0 3px #0008);\n  }\n\n</style>\n</head>\n<body>\n  <h1><span>Digital</span><br />Signatures</h1>\n  <h2>An Elegant Visual Insight</h2>\n\n  <div class=\"container\">\n    <section class=\"visual-card\" aria-label=\"Visual demonstration of digital signature workflow\">\n      <div class=\"visual-inner\">\n        <div class=\"graphic\" aria-hidden=\"true\">\n          <!-- Document -->\n          <article class=\"element-card\" aria-label=\"Original document or message\">\n            <div class=\"document\" aria-hidden=\"true\">\n              <svg viewBox=\"0 0 120 160\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-labelledby=\"docTitle docDesc\" >\n                <title id=\"docTitle\">Document</title>\n                <desc id=\"docDesc\">A digital representation of a document with lines of text</desc>\n                <defs>\n                  <linearGradient id=\"docGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop stop-color=\"#123a6a\" offset=\"0%\" />\n                    <stop stop-color=\"#1b4e8e\" offset=\"100%\" />\n                  </linearGradient>\n                </defs>\n                <rect width=\"110\" height=\"150\" x=\"5\" y=\"5\" rx=\"12\" ry=\"12\" fill=\"url(#docGradient)\" filter=\"url(#shadow)\" />\n                <g stroke=\"#76c7ff99\" stroke-width=\"5\" stroke-linecap=\"round\">\n                  <line x1=\"20\" y1=\"30\" x2=\"90\" y2=\"30\" opacity=\"0.55\" />\n                  <line x1=\"20\" y1=\"55\" x2=\"80\" y2=\"55\" opacity=\"0.45\" />\n                  <line x1=\"20\" y1=\"80\" x2=\"100\" y2=\"80\" opacity=\"0.4\" />\n                  <line x1=\"20\" y1=\"105\" x2=\"75\" y2=\"105\" opacity=\"0.3\" />\n                  <line x1=\"20\" y1=\"130\" x2=\"90\" y2=\"130\" opacity=\"0.2\" />\n                </g>\n              </svg>\n            </div>\n            <h3>Original Message</h3>\n            <p style=\"font-size:0.9rem; color:#8fbfffcc; user-select:none;\">The document or message you want to send or prove authenticity of.</p>\n          </article>\n\n          <!-- Signature -->\n          <article class=\"element-card\" aria-label=\"Digital signature generated from hash and private key\">\n            <div class=\"signature-graphic\" aria-hidden=\"true\" id=\"signatureGraphic\">\n              <svg class=\"signature-svg\" viewBox=\"0 0 140 80\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-labelledby=\"signatureTitle signatureDesc\">\n                <title id=\"signatureTitle\">Digital Signature</title>\n                <desc id=\"signatureDesc\">A stylized signature stroke animating to illustrate a digital signature.</desc>\n                <path class=\"signature-path\" d=\"\n                  M10,60\n                  C35,10 75,110 120,40\n                  S135,10 130,40\n                  \" />\n              </svg>\n            </div>\n            <h3>Digital Signature</h3>\n            <p style=\"font-size:0.9rem; color:#8fbfffcc; user-select:none;\" id=\"sigText\">A cryptographic signature uniquely derived from message hash and sender's private key.</p>\n          </article>\n\n          <!-- Hash -->\n          <article class=\"element-card\" aria-label=\"Mathematical hash representation\">\n            <div class=\"hash-box\" aria-hidden=\"true\">\n              <svg class=\"hash-svg\" viewBox=\"0 0 110 110\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-labelledby=\"hashTitle hashDesc\">\n                <title id=\"hashTitle\">Hash Function</title>\n                <desc id=\"hashDesc\">A cryptographic hash transforming message into a fixed size digest.</desc>\n                <circle cx=\"55\" cy=\"55\" r=\"50\" stroke=\"#5ed2ff88\" />\n                <line x1=\"15\" y1=\"55\" x2=\"95\" y2=\"55\" />\n                <line x1=\"55\" y1=\"15\" x2=\"55\" y2=\"95\" />\n                <path d=\"M30 45 L50 65 L80 35\" />\n              </svg>\n            </div>\n            <h3>Message Hash</h3>\n            <p style=\"font-size:0.9rem; color:#8fbfffcc; user-select:none;\">A unique, fixed-length digest produced by hashing the original message.</p>\n          </article>\n        </div>\n\n        <!-- Chain lines connecting -->\n        <div aria-hidden=\"true\">\n          <div class=\"chain-line\" style=\"top: 40%; left: calc(33% + 160px); transform-origin: left center;\"></div>\n          <div class=\"chain-line\" style=\"top: 40%; left: calc(66% + 320px);\"></div>\n        </div>\n\n        <article class=\"explanation\" tabindex=\"0\" aria-label=\"Brief explanation about how digital signatures work\">\n          <p>\n          A <strong>Digital Signature</strong> ensures message authenticity and integrity by combining a <strong>cryptographic hash</strong> of the <em>original message</em> with the sender's <strong>private key</strong>. This signature can be verified by recipients using the sender's public key, confirming the data was unaltered and truly from the sender. Notice how the original message is hashed into a unique digest (represented by the circular hash icon), and then signed cryptographically (illustrated by the elegant signature stroke), binding the identity and the message securely.\n          </p>\n        </article>\n\n        <div class=\"btn-container\">\n          <button id=\"revealSign\" aria-pressed=\"false\" aria-label=\"Show or hide the signature animation\">Show Signature Animation</button>\n        </div>\n      </div>\n    </section>\n  </div>\n\n  <footer>\n    &copy; 2024 Visual Cryptography Presentations\n  </footer>\n\n<script>\n  const button = document.getElementById('revealSign');\n  const signaturePath = document.querySelector('.signature-path');\n  const sigText = document.getElementById('sigText');\n  let animated = false;\n\n  // Initially signature path animation is stopped (stroke-dashoffset set)\n  function resetSignatureAnimation() {\n    signaturePath.style.transition = 'none';\n    signaturePath.style.strokeDashoffset = '600';\n    // Trigger reflow for restarting animation\n    void signaturePath.offsetWidth;\n  }\n  resetSignatureAnimation();\n\n  button.addEventListener('click', () => {\n    if (!animated) {\n      signaturePath.style.transition = 'stroke-dashoffset 3s ease forwards';\n      signaturePath.style.strokeDashoffset = '0';\n      button.textContent = 'Hide Signature Animation';\n      button.setAttribute('aria-pressed', 'true');\n      sigText.style.color = '#a8f0ff';\n    } else {\n      signaturePath.style.transition = 'stroke-dashoffset 0.5s ease forwards';\n      signaturePath.style.strokeDashoffset = '600';\n      button.textContent = 'Show Signature Animation';\n      button.setAttribute('aria-pressed', 'false');\n      sigText.style.color = '#8fbfffcc';\n    }\n    animated = !animated;\n  });\n</script>\n\n</body>\n</html>"
