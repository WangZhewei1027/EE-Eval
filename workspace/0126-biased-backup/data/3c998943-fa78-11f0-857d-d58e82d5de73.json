    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Indexing — Visual Metaphor & Explanation</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600&family=Playfair+Display:ital,wght@1,700&display=swap');\n\n  /* Root colors */\n  :root {\n    --primary-color: #0a74da;\n    --secondary-color: #f3f6fb;\n    --accent-color: #ff6f61;\n    --dark-color: #22303c;\n    --text-color: #2e4053;\n    --shadow-color: rgba(10, 116, 218, 0.3);\n    --bg-gradient: linear-gradient(135deg, #0a74da 0%, #1356b9 100%);\n    --soft-gradient: linear-gradient(135deg, #e3f0ff 0%, #f9fbff 100%);\n  }\n\n  /* Reset & base */\n  * {\n    box-sizing: border-box;\n  }\n\n  html, body {\n    margin: 0; padding: 0;\n    min-height: 100vh;\n    background: var(--soft-gradient);\n    font-family: 'Montserrat', sans-serif;\n    color: var(--text-color);\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    overflow-x: hidden;\n  }\n\n  body {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 2rem;\n  }\n\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-size: 3.4rem;\n    font-weight: 700;\n    color: var(--primary-color);\n    margin: 0 0 0.25em 0;\n    letter-spacing: -0.03em;\n    text-align: center;\n    text-shadow:\n      0 0 8px rgba(10,116,218,0.3),\n      0 2px 12px rgba(10,116,218,0.15);\n  }\n\n  h2.subtitle {\n    font-weight: 600;\n    font-size: 1.25rem;\n    color: var(--accent-color);\n    margin: 0 0 2.5rem 0;\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n    font-family: 'Montserrat', sans-serif;\n  }\n  \n  .container {\n    max-width: 960px;\n    background: white;\n    border-radius: 1.25rem;\n    box-shadow:\n      0 20px 40px rgba(10,116,218,0.08),\n      0 10px 20px rgba(10,116,218,0.05);\n    padding: 3rem 3.5rem 4rem 3.5rem;\n    position: relative;\n  }\n\n  /* Animated index cards container */\n  .indexing-visual {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 2rem;\n    perspective: 1600px;\n    margin-bottom: 3.5rem;\n  }\n\n  /* The \"data\" cards */\n  .card {\n    background: white;\n    border-radius: 1rem;\n    box-shadow:\n      0 10px 30px rgba(33, 59, 99, 0.12),\n      inset 0 0 0 1.5px #e1eaf6;\n    padding: 1.85rem 1.7rem 2.25rem 1.7rem;\n    font-weight: 600;\n    color: var(--dark-color);\n    font-size: 1.1rem;\n    user-select: none;\n    position: relative;\n    transform-style: preserve-3d;\n    transition:\n      box-shadow 0.6s ease,\n      transform 1.2s cubic-bezier(0.25, 0.8, 0.25, 1);\n  }\n\n  .card h3 {\n    margin: 0 0 0.75rem 0;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1.35rem;\n    color: var(--primary-color);\n  }\n\n  .card p {\n    font-weight: 400;\n    line-height: 1.45;\n    color: var(--text-color);\n    margin: 0;\n  }\n\n  /* Index container */\n  .index-container {\n    position: relative;\n    background: var(--primary-color);\n    border-radius: 2rem;\n    padding: 2.75rem 2rem;\n    box-shadow:\n      0 30px 70px rgba(10, 116, 218, 0.33);\n    overflow: visible;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n  }\n\n  /* Index Title */\n  .index-title {\n    color: white;\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 2.25rem;\n    letter-spacing: 0.03em;\n    margin-bottom: 2rem;\n    text-shadow:\n      0 3px 6px rgba(0,0,0,0.15);\n    user-select: none;\n  }\n\n  /* Index Bar (like a vertical bar) */\n  .index-bar {\n    width: 12px;\n    height: 240px;\n    background: linear-gradient(180deg, #ff6f61 0%, #ff3b20 100%);\n    border-radius: 10px;\n    box-shadow:\n      0 10px 24px rgba(255, 111, 97, 0.55);\n    position: relative;\n    margin: 0 auto 2.5rem auto;\n    overflow: visible;\n  }\n\n  /* Index markers (dots) */\n  .index-marker {\n    position: absolute;\n    width: 18px;\n    height: 18px;\n    border-radius: 50%;\n    background: #fff;\n    box-shadow:\n      0 0 8px rgba(255, 111, 97, 0.65);\n    left: 50%;\n    transform: translateX(-50%);\n    transition: background-color 0.4s ease, box-shadow 0.4s ease;\n  }\n\n  /* Markers spaced evenly on bar */\n  .index-marker:nth-child(1) { top: 12%; }\n  .index-marker:nth-child(2) { top: 32%; }\n  .index-marker:nth-child(3) { top: 52%; }\n  .index-marker:nth-child(4) { top: 72%; }\n  .index-marker:nth-child(5) { top: 92%; }\n\n  /* Highlighted marker */\n  .highlighted {\n    background: var(--accent-color);\n    box-shadow:\n      0 0 18px var(--accent-color),\n      0 0 36px var(--accent-color);\n  }\n\n  /* Arrow Shape pointing to selected card */\n  .index-arrow {\n    position: absolute;\n    left: 105%;\n    width: 32px;\n    height: 32px;\n    top: 50%;\n    transform: translateY(-50%);\n    pointer-events: none;\n  }\n  .index-arrow svg {\n    fill: var(--accent-color);\n    filter: drop-shadow(0 0 3px rgba(255,111,97,0.5));\n    animation: pulseArrow 3s infinite ease-in-out;\n  }\n\n  @keyframes pulseArrow {\n    0%, 100% {\n      filter: drop-shadow(0 0 3px rgba(255,111,97,0.5)) drop-shadow(0 0 5px rgba(255,111,97,0.4));\n      transform: translateY(-50%) scale(1);\n      opacity: 1;\n    }\n    50% {\n      filter: drop-shadow(0 0 9px rgba(255,111,97,0.75)) drop-shadow(0 0 12px rgba(255,111,97,0.55));\n      transform: translateY(-50%) scale(1.15);\n      opacity: 0.8;\n    }\n  }\n\n  /* Data List beside index bar */\n  .data-list {\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n  }\n  .data-item {\n    font-weight: 600;\n    font-size: 1.1rem;\n    color: white;\n    padding: 0.68rem 1rem;\n    border-radius: 0.75rem;\n    margin-bottom: 0.85rem;\n    background: linear-gradient(145deg, #ff6f61, #ff3b20);\n    box-shadow:\n      0 3px 8px rgba(255, 111, 97, 0.35);\n    transition:\n      background-color 0.5s ease,\n      box-shadow 0.5s ease;\n    user-select: none;\n    cursor: default;\n  }\n  .data-item.highlighted {\n    background: white;\n    color: var(--primary-color);\n    font-weight: 700;\n    box-shadow:\n      0 6px 14px rgba(10,116,218,0.6);\n  }\n\n  /* Explanation paragraph */\n  .explanation {\n    font-size: 1.15rem;\n    max-width: 820px;\n    margin: 0 auto 3.5rem auto;\n    line-height: 1.58;\n    color: var(--text-color);\n    font-family: 'Montserrat', sans-serif;\n    text-align: center;\n    user-select: text;\n  }\n\n  /* Button section */\n  .btn-container {\n    text-align: center;\n  }\n\n  button {\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1rem;\n    background: var(--primary-color);\n    color: white;\n    border: none;\n    border-radius: 0.75rem;\n    padding: 0.75rem 2.2rem;\n    cursor: pointer;\n    box-shadow:\n      0 6px 12px rgba(10, 116, 218, 0.38);\n    transition:\n      background-color 0.3s ease,\n      box-shadow 0.3s ease,\n      transform 0.15s ease;\n    user-select: none;\n  }\n  button:hover,\n  button:focus {\n    background: #0859a2;\n    box-shadow:\n      0 8px 20px rgba(8, 89, 162, 0.6);\n    outline: none;\n    transform: translateY(-2px);\n  }\n  button:active {\n    transform: translateY(0);\n    box-shadow:\n      0 4px 10px rgba(8, 89, 162, 0.5);\n  }\n\n  /* Footer */\n  footer {\n    font-size: 0.925rem;\n    color: #9aa7b6;\n    margin-top: 3.5rem;\n    font-style: italic;\n    text-align: center;\n    user-select: none;\n  }\n\n  /* Media query */\n  @media (max-width: 720px) {\n    h1 {\n      font-size: 2.5rem;\n    }\n    .indexing-visual {\n      grid-template-columns: 1fr;\n      gap: 1.5rem;\n    }\n    .container {\n      padding: 2rem 2rem 3rem 2rem;\n    }\n    .index-container {\n      margin-top: 2rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <h1>Indexing</h1>\n  <h2 class=\"subtitle\">Organizing Data for Instant Retrieval</h2>\n\n  <div class=\"container\" aria-label=\"Visual demonstration of Indexing\">\n    <div class=\"indexing-visual\" aria-hidden=\"true\">\n      <!-- Cards represent data entries in a dataset -->\n      <article class=\"card\" id=\"card-1\" style=\"transform: translateZ(0px);\">\n        <h3>Book: \"Algorithms\"</h3>\n        <p>Author: Cormen, Leiserson, Rivest, Stein</p>\n      </article>\n      <article class=\"card\" id=\"card-2\" style=\"transform: translateZ(0px);\">\n        <h3>Book: \"Clean Code\"</h3>\n        <p>Author: Robert C. Martin</p>\n      </article>\n      <article class=\"card\" id=\"card-3\" style=\"transform: translateZ(0px);\">\n        <h3>Book: \"Design Patterns\"</h3>\n        <p>Author: Gamma, Helm, Johnson, Vlissides</p>\n      </article>\n    </div>\n\n    <div class=\"index-container\" aria-label=\"Index structure visualization\">\n\n      <div class=\"index-title\">Index</div>\n\n      <div class=\"index-bar\" role=\"list\" aria-label=\"Index keys\">\n        <div class=\"index-marker highlighted\" role=\"listitem\" aria-selected=\"true\" style=\"top: 12%;\"></div>\n        <div class=\"index-marker\" role=\"listitem\" aria-selected=\"false\" style=\"top: 32%;\"></div>\n        <div class=\"index-marker\" role=\"listitem\" aria-selected=\"false\" style=\"top: 52%;\"></div>\n        <div class=\"index-marker\" role=\"listitem\" aria-selected=\"false\" style=\"top: 72%;\"></div>\n        <div class=\"index-marker\" role=\"listitem\" aria-selected=\"false\" style=\"top: 92%;\"></div>\n        <div class=\"index-arrow\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" focusable=\"false\" aria-hidden=\"true\" width=\"24\" height=\"24\" >\n            <path d=\"M8 5v14l11-7z\"/>\n          </svg>\n        </div>\n      </div>\n\n      <nav class=\"data-list\" aria-label=\"Indexed data list\">\n        <div class=\"data-item highlighted\" id=\"data-1\" tabindex=\"0\" aria-current=\"true\">Algorithms</div>\n        <div class=\"data-item\" id=\"data-2\" tabindex=\"-1\">Clean Code</div>\n        <div class=\"data-item\" id=\"data-3\" tabindex=\"-1\">Design Patterns</div>\n      </nav>\n    </div>\n\n    <p class=\"explanation\" id=\"explanation-text\">\n      Indexing is the technique of organizing data to allow for rapid retrieval, much like a book's index lets you quickly find a topic without scanning every page. \n      Here, the <strong>Index</strong> acts as a focused guide, pointing directly to the desired data entries (books) with minimal delay.\n    </p>\n\n    <div class=\"btn-container\">\n      <button type=\"button\" id=\"cycle-btn\" aria-label=\"Cycle highlighted index item\">Next Highlight</button>\n    </div>\n  </div>\n\n<script>\n  (function(){\n    const indexMarkers = document.querySelectorAll('.index-marker');\n    const dataItems = document.querySelectorAll('.data-item');\n    const cards = document.querySelectorAll('.card');\n    const explanationText = document.getElementById('explanation-text');\n    const cycleBtn = document.getElementById('cycle-btn');\n    const indexArrow = document.querySelector('.index-arrow');\n\n    // Mapping of index positions to cards & data items\n    // Only 3 data, 5 markers: We'll use first 3 markers + data + cards to highlight cycling\n    const maxIndex = dataItems.length;\n\n    let current = 0;\n\n    // Smooth highlight animation\n    function updateHighlight(i) {\n      // Remove all highlights\n      indexMarkers.forEach((mark, idx) => {\n        if (idx < maxIndex) {\n          mark.classList.toggle('highlighted', idx === i);\n          mark.setAttribute('aria-selected', idx === i ? 'true' : 'false');\n        }\n      });\n      dataItems.forEach((item, idx) => {\n        if(idx === i){\n          item.classList.add('highlighted');\n          item.setAttribute('aria-current', 'true');\n          item.setAttribute('tabindex', '0');\n          item.focus();\n        } else {\n          item.classList.remove('highlighted');\n          item.removeAttribute('aria-current');\n          item.setAttribute('tabindex', '-1');\n        }\n      });\n\n      cards.forEach((card, idx) => {\n        if(idx === i){\n          card.style.transform = 'translateZ(24px) scale(1.06)';\n          card.style.boxShadow = '0 20px 50px rgba(10,116,218,0.3)';\n          card.style.zIndex = '5';\n        } else {\n          card.style.transform = 'translateZ(0px) scale(1)';\n          card.style.boxShadow = '0 10px 30px rgba(33, 59, 99, 0.12), inset 0 0 0 1.5px #e1eaf6';\n          card.style.zIndex = '1';\n        }\n      });\n\n      // Move arrow up/down aligned with marker\n      const marker = indexMarkers[i];\n      if(marker){\n        const barRect = marker.parentElement.getBoundingClientRect();\n        const markRect = marker.getBoundingClientRect();\n        const topPos = markRect.top - barRect.top + (markRect.height/2);\n        indexArrow.style.top = `${topPos}px`;\n      }\n\n      // Update explanation with subtle new sentence for variety\n      const explanations = [\n        'Indexing improves retrieval speed by creating a direct path to the data, avoiding the need to scan everything.',\n        'Think of an index like a smart directory, instantly guiding you to what you seek.',\n        'Indexes greatly reduce lookup time, enhancing system performance especially for large datasets.'\n      ];\n      explanationText.textContent = explanations[i % explanations.length];\n    }\n\n    cycleBtn.addEventListener('click', () => {\n      current++;\n      if(current >= maxIndex) current = 0;\n      updateHighlight(current);\n    });\n\n    // Initialize highlight\n    updateHighlight(0);\n\n  })();\n</script>\n</body>\n</html>"
