    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Paging — Visual Concept</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071126;\n    --glass: rgba(255,255,255,0.06);\n    --accent-1: #7ee7d9;\n    --accent-2: #6b8bff;\n    --accent-3: #f6a6ff;\n    --muted: rgba(255,255,255,0.45);\n    --card-w: 780px;\n    --card-h: 520px;\n    --radius: 20px;\n    --shadow-1: 0 10px 30px rgba(2,6,23,0.6);\n    --ease: cubic-bezier(.2,.9,.25,1);\n    font-synthesis: none;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  /* Background */\n  html,body{\n    height:100%;\n    margin:0;\n    font-family: Inter, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(110,95,255,0.08), transparent 8%),\n                radial-gradient(800px 500px at 90% 90%, rgba(126,231,217,0.06), transparent 12%),\n                linear-gradient(180deg,var(--bg-1) 0%, var(--bg-2) 100%);\n    color: #fff;\n    overflow:hidden;\n  }\n\n  /* Subtle animated starfield */\n  .sky {\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    mix-blend-mode:screen;\n    z-index:0;\n  }\n  .star {\n    position:absolute;\n    width:2px; height:2px;\n    background: linear-gradient(180deg,#fff6,#fff0);\n    border-radius:50%;\n    opacity:0.15;\n    filter:blur(.5px);\n    animation: twinkle 6s linear infinite;\n  }\n  @keyframes twinkle {\n    0% { opacity:0.06; transform: scale(.9) }\n    50% { opacity:0.24; transform: scale(1.4) }\n    100% { opacity:0.06; transform: scale(.9) }\n  }\n\n  /* Main layout */\n  .stage {\n    position:relative;\n    z-index:2;\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    box-sizing:border-box;\n    gap:28px;\n  }\n\n  .card {\n    width:var(--card-w);\n    height:var(--card-h);\n    border-radius:var(--radius);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n    box-shadow: var(--shadow-1);\n    position:relative;\n    overflow:visible;\n    padding:28px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transform-style:preserve-3d;\n    backdrop-filter: blur(8px) saturate(1.05);\n    -webkit-backdrop-filter: blur(8px) saturate(1.05);\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  /* Decorative corner accent */\n  .card::before{\n    content:\"\";\n    position:absolute;\n    inset:auto 18px 18px auto;\n    width:120px;height:120px;\n    background:linear-gradient(135deg, rgba(107,139,255,0.14), rgba(246,166,255,0.08));\n    filter: blur(48px);\n    transform: rotate(18deg);\n    border-radius:28px;\n    pointer-events:none;\n  }\n\n  /* Pages container */\n  .viewport {\n    position:relative;\n    width:100%;\n    height:100%;\n    perspective:1500px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .pages {\n    position:relative;\n    width:calc(100% - 56px);\n    height:calc(100% - 56px);\n    display:block;\n    transform-style:preserve-3d;\n  }\n\n  .page {\n    position:absolute;\n    inset:0;\n    border-radius:14px;\n    padding:36px;\n    box-sizing:border-box;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    transform-origin:center left;\n    transition: transform 900ms var(--ease), opacity 700ms var(--ease), filter 700ms var(--ease);\n    display:flex;\n    gap:32px;\n    align-items:center;\n    justify-content:flex-start;\n    backface-visibility:hidden;\n    overflow:hidden;\n  }\n\n  /* Page art and content */\n  .art {\n    width:44%;\n    height:100%;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .visual {\n    width:90%;\n    height:86%;\n    border-radius:12px;\n    background: linear-gradient(135deg, rgba(126,231,217,0.08), rgba(107,139,255,0.06));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 12px 30px rgba(4,8,20,0.55), inset 0 1px 0 rgba(255,255,255,0.02);\n    position:relative;\n    overflow:visible;\n    transform-style:preserve-3d;\n  }\n\n  .content {\n    width:56%;\n    padding-right:8px;\n    display:flex;\n    flex-direction:column;\n    gap:14px;\n    justify-content:center;\n  }\n\n  .index {\n    font-size:112px;\n    line-height:1;\n    font-weight:800;\n    letter-spacing:-6px;\n    margin:0;\n    background: linear-gradient(90deg,var(--accent-1), var(--accent-2), var(--accent-3));\n    -webkit-background-clip: text;\n    background-clip:text;\n    color:transparent;\n    opacity:0.95;\n    transform:translateZ(40px);\n    text-shadow: 0 10px 30px rgba(11,15,30,0.6);\n  }\n\n  .title {\n    font-size:22px;\n    font-weight:600;\n    margin:0;\n    color:#f7fbff;\n    letter-spacing:0.2px;\n  }\n\n  .desc {\n    color:var(--muted);\n    font-size:14px;\n    line-height:1.6;\n    margin:0;\n    max-width:430px;\n  }\n\n  .meta {\n    margin-top:8px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  .chip {\n    padding:8px 12px;\n    border-radius:999px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.026), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);\n    display:inline-flex;\n    gap:8px;\n    align-items:center;\n  }\n\n  /* Visual ornament shapes */\n  .shape {\n    position:absolute;\n    filter: drop-shadow(0 12px 26px rgba(8,12,25,0.6));\n  }\n\n  .shape.s1{\n    width:220px;height:220px;\n    left:-30px; top:10%;\n    transform: rotate(-12deg) translateZ(60px);\n    opacity:0.95;\n    background: radial-gradient(circle at 30% 30%, rgba(126,231,217,0.45), rgba(107,139,255,0.1) 40%, transparent 65%);\n    border-radius:34px;\n    mix-blend-mode:screen;\n  }\n\n  .shape.s2{\n    width:160px;height:160px;\n    right:-40px; bottom:8%;\n    transform: rotate(18deg) translateZ(20px);\n    opacity:0.95;\n    background: conic-gradient(from 120deg, rgba(246,166,255,0.45), rgba(107,139,255,0.08));\n    border-radius:38px;\n    mix-blend-mode:screen;\n  }\n\n  /* Page states */\n  .page { opacity:0; pointer-events:none; transform: translateX(60%) scale(.92) rotateY(-10deg); filter: blur(6px) grayscale(.08); }\n  .page.is-active { opacity:1; pointer-events:auto; transform: translateX(0%) scale(1) rotateY(0deg); filter: blur(0) grayscale(0); z-index:5; transition-duration:950ms; }\n  .page.is-prev { opacity:0.42; transform: translateX(-30%) scale(.96) rotateY(8deg); filter: blur(2px) grayscale(.12); z-index:4; }\n  .page.is-next { opacity:0.42; transform: translateX(30%) scale(.96) rotateY(-8deg); filter: blur(2px) grayscale(.12); z-index:3; }\n\n  /* Depth layers within page */\n  .visual .orb {\n    width:110%;\n    height:110%;\n    border-radius:14px;\n    position:absolute;\n    left:-5%;\n    top:-6%;\n    background: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.06), transparent 12%),\n                linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    transform: translateZ(40px) scale(1.02);\n  }\n\n  .visual svg { width:86%; height:86%; }\n\n  /* Controls */\n  .controls {\n    position:absolute;\n    bottom:24px;\n    left:24px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n\n  .btn {\n    appearance:none;\n    border:0;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n    color:#fff;\n    padding:12px 14px;\n    border-radius:12px;\n    box-shadow: 0 6px 20px rgba(5,9,20,0.6);\n    cursor:pointer;\n    transition: transform 220ms var(--ease), box-shadow 220ms var(--ease), background 220ms var(--ease);\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    font-weight:600;\n    font-size:14px;\n    border:1px solid rgba(255,255,255,0.035);\n  }\n  .btn:active { transform: translateY(2px) scale(.995); }\n  .btn:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(5,9,20,0.72); }\n\n  .pager {\n    position:absolute;\n    right:24px;\n    bottom:26px;\n    display:flex;\n    align-items:center;\n    gap:14px;\n    background: rgba(255,255,255,0.02);\n    padding:10px 14px;\n    border-radius:14px;\n    border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 8px 30px rgba(3,6,16,0.45);\n  }\n  .page-ind {\n    font-weight:700;\n    font-size:15px;\n    letter-spacing:0.4px;\n    color:#eafcfd;\n  }\n  .progress {\n    width:84px; height:12px;\n    border-radius:999px;\n    overflow:hidden;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n  }\n  .progress > i {\n    display:block;\n    height:100%;\n    width:0%;\n    background: linear-gradient(90deg, var(--accent-1), var(--accent-2), var(--accent-3));\n    transition: width 650ms var(--ease);\n    box-shadow: 0 6px 22px rgba(105,96,255,0.18);\n  }\n\n  /* Footer tagline */\n  .tag {\n    position:absolute;\n    top:28px;\n    left:28px;\n    font-size:13px;\n    color:var(--muted);\n    background: rgba(255,255,255,0.02);\n    padding:8px 12px;\n    border-radius:999px;\n    border:1px solid rgba(255,255,255,0.02);\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n  }\n\n  /* responsive */\n  @media (max-width:920px){\n    :root{ --card-w:680px; --card-h:480px; }\n    .index { font-size:88px; letter-spacing:-3px; }\n    .art{ width:46% }\n  }\n  @media (max-width:720px){\n    :root{ --card-w:92vw; --card-h:68vh; }\n    .page { flex-direction:column; padding:18px; gap:18px; }\n    .art{ width:100%; height:48%; }\n    .content{ width:100%; }\n    .controls{ left:50%; transform:translateX(-50%); bottom:12px; }\n    .pager{ right:50%; transform:translateX(50%); bottom:12px; }\n    .index{ font-size:68px; }\n  }\n\n  /* micro interactions */\n  .btn svg{ opacity:0.96; transform:translateZ(10px); }\n  .chip .dot { width:8px;height:8px;border-radius:50%; background:linear-gradient(90deg,var(--accent-1),var(--accent-2)); box-shadow:0 6px 18px rgba(110,95,255,0.18); }\n\n</style>\n</head>\n<body>\n<div class=\"sky\" aria-hidden=\"true\">\n  <!-- procedural stars -->\n  <div class=\"star\" style=\"left:6%;top:18%;animation-duration:7s;opacity:.12\"></div>\n  <div class=\"star\" style=\"left:18%;top:62%;animation-duration:9s;opacity:.08\"></div>\n  <div class=\"star\" style=\"left:34%;top:25%;animation-duration:5.3s;opacity:.12\"></div>\n  <div class=\"star\" style=\"left:52%;top:75%;animation-duration:8.4s;opacity:.09\"></div>\n  <div class=\"star\" style=\"left:71%;top:22%;animation-duration:6.8s;opacity:.11\"></div>\n  <div class=\"star\" style=\"left:86%;top:54%;animation-duration:7.6s;opacity:.07\"></div>\n</div>\n\n<div class=\"stage\" role=\"main\" aria-label=\"Paging demo\">\n  <div class=\"card\" role=\"region\" aria-label=\"Paging canvas\">\n    <div class=\"tag\">Paging — Conceptual Visual</div>\n\n    <div class=\"viewport\">\n      <div class=\"pages\" id=\"pages\">\n        <!-- Page 1 -->\n        <section class=\"page is-active\" data-index=\"1\" aria-hidden=\"false\" aria-label=\"Page 1\">\n          <div class=\"art\">\n            <div class=\"visual\">\n              <div class=\"orb\"></div>\n              <div class=\"shape s1\" aria-hidden=\"true\"></div>\n              <svg viewBox=\"0 0 600 520\" xmlns=\"http://www.w3.org/2000/svg\" style=\"z-index:2;position:relative\">\n                <defs>\n                  <linearGradient id=\"g1\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#7EE7D9\"/>\n                    <stop offset=\"1\" stop-color=\"#6B8BFF\"/>\n                  </linearGradient>\n                </defs>\n                <g transform=\"translate(40,40)\">\n                  <path d=\"M120 360 C 220 260 380 260 480 360 L480 120 C370 60 260 60 120 120 Z\" fill=\"url(#g1)\" opacity=\"0.95\" transform=\"rotate(-6 300 260) translateZ(20px)\"/>\n                  <circle cx=\"420\" cy=\"130\" r=\"38\" fill=\"#F6A6FF\" opacity=\"0.12\" />\n                  <g transform=\"translate(90,70)\" opacity=\"0.9\">\n                    <rect x=\"40\" y=\"40\" rx=\"18\" ry=\"18\" width=\"220\" height=\"140\" fill=\"rgba(255,255,255,0.03)\" stroke=\"rgba(255,255,255,0.02)\"/>\n                    <path d=\"M60 120 C110 90 180 90 230 120\" stroke=\"#ffffff22\" stroke-width=\"2\" fill=\"none\"/>\n                  </g>\n                </g>\n              </svg>\n            </div>\n          </div>\n\n          <div class=\"content\">\n            <h1 class=\"index\">01</h1>\n            <h2 class=\"title\">Foundations of Paging</h2>\n            <p class=\"desc\">Paging divides a larger collection into discrete, navigable pages. This presentation focuses on the motion and hierarchy that define each page's entry and exit, emphasizing clarity and visual rhythm.</p>\n            <div class=\"meta\">\n              <div class=\"chip\"><span class=\"dot\"></span><span>Overview</span></div>\n              <div style=\"color:var(--muted)\">Minimal controls • Clean transitions</div>\n            </div>\n          </div>\n        </section>\n\n        <!-- Page 2 -->\n        <section class=\"page is-next\" data-index=\"2\" aria-hidden=\"true\" aria-label=\"Page 2\">\n          <div class=\"art\">\n            <div class=\"visual\">\n              <div class=\"orb\"></div>\n              <div class=\"shape s2\" aria-hidden=\"true\"></div>\n              <svg viewBox=\"0 0 600 520\" xmlns=\"http://www.w3.org/2000/svg\">\n                <defs>\n                  <linearGradient id=\"g2\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#6B8BFF\"/>\n                    <stop offset=\"1\" stop-color=\"#F6A6FF\"/>\n                  </linearGradient>\n                </defs>\n                <g transform=\"translate(0,10)\">\n                  <path d=\"M40 300 C160 140 440 140 560 300 L560 60 C430 10 170 10 40 60 Z\" fill=\"url(#g2)\" opacity=\"0.95\"/>\n                  <g transform=\"translate(90,180)\" opacity=\"0.95\">\n                    <rect x=\"10\" y=\"10\" rx=\"12\" ry=\"12\" width=\"220\" height=\"120\" fill=\"rgba(255,255,255,0.02)\"/>\n                    <circle cx=\"180\" cy=\"30\" r=\"16\" fill=\"#7EE7D9\" opacity=\"0.9\"></circle>\n                  </g>\n                </g>\n              </svg>\n            </div>\n          </div>\n\n          <div class=\"content\">\n            <h1 class=\"index\">02</h1>\n            <h2 class=\"title\">Spatial Transitions</h2>\n            <p class=\"desc\">Smooth spatial motion helps users maintain context. Translate, scale and subtle rotation combine to suggest depth while preserving readability and focus on content.</p>\n            <div class=\"meta\">\n              <div class=\"chip\"><span class=\"dot\"></span><span>Motion</span></div>\n              <div style=\"color:var(--muted)\">Depth • Continuity</div>\n            </div>\n          </div>\n        </section>\n\n        <!-- Page 3 -->\n        <section class=\"page is-next\" data-index=\"3\" aria-hidden=\"true\" aria-label=\"Page 3\">\n          <div class=\"art\">\n            <div class=\"visual\">\n              <div class=\"orb\"></div>\n              <svg viewBox=\"0 0 600 520\" xmlns=\"http://www.w3.org/2000/svg\">\n                <defs>\n                  <linearGradient id=\"g3\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#F6A6FF\"/>\n                    <stop offset=\"1\" stop-color=\"#7EE7D9\"/>\n                  </linearGradient>\n                </defs>\n                <g transform=\"translate(30,20)\">\n                  <path d=\"M80 420 C170 240 420 240 520 420 L520 120 C400 48 200 48 80 120 Z\" fill=\"url(#g3)\" opacity=\"0.95\"/>\n                  <g transform=\"translate(70,80)\">\n                    <rect x=\"50\" y=\"180\" rx=\"12\" ry=\"12\" width=\"260\" height=\"120\" fill=\"rgba(255,255,255,0.02)\"/>\n                    <path d=\"M120 200 L220 200\" stroke=\"#ffffff22\" stroke-width=\"3\"/>\n                  </g>\n                </g>\n              </svg>\n            </div>\n          </div>\n\n          <div class=\"content\">\n            <h1 class=\"index\">03</h1>\n            <h2 class=\"title\">Progress & Orientation</h2>\n            <p class=\"desc\">Indicators and subtle feedback keep users oriented. A compact progress visualization can communicate position within the entire sequence without overwhelming the layout.</p>\n            <div class=\"meta\">\n              <div class=\"chip\"><span class=\"dot\"></span><span>Guidance</span></div>\n              <div style=\"color:var(--muted)\">Position • Feedback</div>\n            </div>\n          </div>\n        </section>\n\n        <!-- Page 4 -->\n        <section class=\"page is-next\" data-index=\"4\" aria-hidden=\"true\" aria-label=\"Page 4\">\n          <div class=\"art\">\n            <div class=\"visual\">\n              <div class=\"orb\"></div>\n              <svg viewBox=\"0 0 600 520\" xmlns=\"http://www.w3.org/2000/svg\">\n                <defs>\n                  <linearGradient id=\"g4\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#7EE7D9\"/>\n                    <stop offset=\"1\" stop-color=\"#6B8BFF\"/>\n                  </linearGradient>\n                </defs>\n                <g transform=\"translate(20,30)\">\n                  <rect x=\"40\" y=\"60\" rx=\"28\" ry=\"28\" width=\"480\" height=\"340\" fill=\"rgba(255,255,255,0.02)\"/>\n                  <g transform=\"translate(60,80)\">\n                    <circle cx=\"120\" cy=\"40\" r=\"30\" fill=\"#F6A6FF\" opacity=\"0.12\"/>\n                    <rect x=\"8\" y=\"100\" rx=\"8\" ry=\"8\" width=\"360\" height=\"120\" fill=\"rgba(255,255,255,0.02)\"/>\n                  </g>\n                </g>\n              </svg>\n            </div>\n          </div>\n\n          <div class=\"content\">\n            <h1 class=\"index\">04</h1>\n            <h2 class=\"title\">Polish & Details</h2>\n            <p class=\"desc\">Subtle shadows, consistent spacing, and a restrained palette create a refined paging experience. Transitions should feel effortless—fast to perceive, slow enough to follow.</p>\n            <div class=\"meta\">\n              <div class=\"chip\"><span class=\"dot\"></span><span>Refinement</span></div>\n              <div style=\"color:var(--muted)\">Texture • Little things</div>\n            </div>\n          </div>\n        </section>\n\n      </div>\n    </div>\n\n    <div class=\"controls\" role=\"toolbar\" aria-label=\"Paging controls\">\n      <button class=\"btn\" id=\"prevBtn\" aria-label=\"Previous page\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n          <path d=\"M15 18L9 12L15 6\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n        Prev\n      </button>\n      <button class=\"btn\" id=\"nextBtn\" aria-label=\"Next page\">\n        Next\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n          <path d=\"M9 6L15 12L9 18\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </button>\n    </div>\n\n    <div class=\"pager\" aria-hidden=\"true\">\n      <div class=\"page-ind\" id=\"pageInd\">1 / 4</div>\n      <div class=\"progress\"><i id=\"progressBar\"></i></div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n(function(){\n  const pages = Array.from(document.querySelectorAll('.page'));\n  const total = pages.length;\n  let idx = 0;\n\n  const prevBtn = document.getElementById('prevBtn');\n  const nextBtn = document.getElementById('nextBtn');\n  const pageInd = document.getElementById('pageInd');\n  const progressBar = document.getElementById('progressBar');\n\n  // initial setup\n  function layout(){\n    pages.forEach((p,i)=>{\n      p.classList.remove('is-active','is-prev','is-next');\n      if(i === idx) {\n        p.classList.add('is-active');\n        p.setAttribute('aria-hidden','false');\n      } else if (i < idx) {\n        p.classList.add('is-prev');\n        p.setAttribute('aria-hidden','true');\n      } else {\n        p.classList.add('is-next');\n        p.setAttribute('aria-hidden','true');\n      }\n    });\n    pageInd.textContent = (idx+1) + \" / \" + total;\n    progressBar.style.width = ( (idx) / (total-1) * 100 ) + '%';\n    // subtle micro-bounce for active page content\n    const active = pages[idx];\n    if(active){\n      active.animate([\n        { transform: getComputedStyle(active).transform + ' translateZ(0)'},\n        { transform: getComputedStyle(active).transform + ' translateY(-6px)'},\n        { transform: getComputedStyle(active).transform + ' translateY(0)'}\n      ], { duration: 550, easing: 'cubic-bezier(.2,.9,.25,1)' });\n    }\n  }\n\n  function next(){\n    idx = (idx + 1) % total;\n    layout();\n  }\n  function prev(){\n    idx = (idx - 1 + total) % total;\n    layout();\n  }\n\n  prevBtn.addEventListener('click', ()=>{ prev(); });\n  nextBtn.addEventListener('click', ()=>{ next(); });\n\n  // keyboard arrows limited: not required by spec; keep minimal - comment out to strictly limit interactions\n  // document.addEventListener('keydown',(e)=>{ if(e.key==='ArrowRight') next(); if(e.key==='ArrowLeft') prev(); });\n\n  // small auto-cycle micro-demo on idle (very subtle): rotates every 6s, but only when no interactions for a while\n  let idleTimer, auto;\n  function scheduleAuto(){\n    clearTimeout(idleTimer);\n    idleTimer = setTimeout(()=>{ autoCycleStart(); }, 4500);\n  }\n  function autoCycleStart(){\n    if(auto) return;\n    auto = setInterval(()=>{ next(); }, 5200);\n    // stop after some cycles so user mostly observes\n    setTimeout(()=>{ autoCycleStop(); }, 5200 * 3 + 200);\n  }\n  function autoCycleStop(){\n    if(!auto) return;\n    clearInterval(auto);\n    auto = null;\n  }\n\n  // reset idle on interactions\n  ['mousemove','mousedown','touchstart','keydown'].forEach(evt=>{\n    window.addEventListener(evt, ()=>{ scheduleAuto(); autoCycleStop(); });\n  });\n\n  // start\n  layout();\n  scheduleAuto();\n\n  // Decorative: gently sway the art on hover-less subtle animation for non-interactive observation\n  pages.forEach((p,i)=>{\n    const visual = p.querySelector('.visual');\n    if(!visual) return;\n    visual.animate([\n      { transform: 'rotateZ(-1deg) translateY(0px)' },\n      { transform: 'rotateZ(1deg) translateY(-6px)' },\n      { transform: 'rotateZ(-1deg) translateY(0px)' }\n    ], { duration: 5200 + (i*200), iterations: Infinity, easing: 'ease-in-out' });\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
