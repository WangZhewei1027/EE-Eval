    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deque Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(to right, #1c1f26, #1e2128);\n            color: #ffffff;\n            margin: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        .container {\n            text-align: center;\n            padding: 20px;\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);\n            background-color: #25282d;\n            width: 90%;\n            max-width: 600px;\n        }\n        h1 {\n            font-size: 2.5em;\n            margin: 0;\n            padding: 0 0 20px 0;\n            background: linear-gradient(90deg, #4a90e2, #50e3c2);\n            -webkit-background-clip: text;\n            color: transparent;\n            animation: glow 1.5s infinite alternate;\n        }\n        @keyframes glow {\n            0% { text-shadow: 0 0 20px rgba(74, 144, 226, 0.7); }\n            100% { text-shadow: 0 0 40px rgba(74, 144, 226, 1); }\n        }\n        .deque {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            padding: 20px;\n            margin: 20px 0;\n            border: 2px solid #4a90e2;\n            border-radius: 10px;\n            background: #2a2e35;\n            transition: transform 0.5s ease-in-out;\n        }\n        .node {\n            background: #4a90e2;\n            border-radius: 10px;\n            padding: 15px 20px;\n            margin: 0 5px;\n            transition: transform 0.3s ease;\n            cursor: pointer;\n        }\n        .node:hover {\n            transform: scale(1.1);\n            background: #50e3c2;\n        }\n        .button {\n            background: #4a90e2;\n            border: none;\n            border-radius: 5px;\n            color: white;\n            padding: 10px 20px;\n            font-size: 1em;\n            cursor: pointer;\n            margin-top: 20px;\n            transition: background 0.3s ease, transform 0.3s ease;\n        }\n        .button:hover {\n            background: #50e3c2;\n            transform: translateY(-2px);\n        }\n        .button:active {\n            transform: translateY(0);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Deque Visualization</h1>\n        <div class=\"deque\" id=\"deque\">\n            <div class=\"node\">1</div>\n            <div class=\"node\">2</div>\n            <div class=\"node\">3</div>\n            <div class=\"node\">4</div>\n            <div class=\"node\">5</div>\n        </div>\n        <button class=\"button\" id=\"addButton\">Add Node</button>\n    </div>\n    \n    <script>\n        const deque = document.getElementById('deque');\n        const addButton = document.getElementById('addButton');\n        let count = 6;\n\n        addButton.addEventListener('click', () => {\n            const newNode = document.createElement('div');\n            newNode.classList.add('node');\n            newNode.textContent = count++;\n            deque.appendChild(newNode);\n            deque.style.transform = 'scale(1.05)';\n            setTimeout(() => {\n                deque.style.transform = 'scale(1)';\n            }, 300);\n        });\n    </script>\n</body>\n</html>"
