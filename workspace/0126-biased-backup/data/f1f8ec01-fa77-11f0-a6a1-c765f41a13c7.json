    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Garbage Collection — Visual Demonstration</title>\n<style>\n  :root{\n    --bg1:#0f1724;\n    --bg2:#071025;\n    --card:#0c1220cc;\n    --glass: rgba(255,255,255,0.04);\n    --accent:#6EE7B7;\n    --accent-2:#60A5FA;\n    --muted:#9AA8B2;\n    --glass-2: rgba(255,255,255,0.03);\n    --neon: rgba(108, 99, 255, 0.18);\n    --success: #38bdf8;\n  }\n\n  /* Page reset */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(96,165,250,0.06), transparent 8%),\n                radial-gradient(1000px 500px at 90% 90%, rgba(110,231,183,0.03), transparent 8%),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    color:#E6EEF3;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated background shapes */\n  .scene-bg{\n    position:absolute;inset:0;pointer-events:none;mix-blend-mode:overlay;opacity:0.7;\n  }\n  .orb{\n    position:absolute;border-radius:50%;filter:blur(60px);opacity:0.35;\n    animation: drift 18s ease-in-out infinite;\n  }\n  .orb.a{width:520px;height:520px;background:linear-gradient(135deg,var(--accent),transparent);left:-120px;top:-50px;animation-delay:-2s}\n  .orb.b{width:420px;height:420px;background:linear-gradient(135deg,var(--accent-2),transparent);right:-100px;bottom:-60px;animation-delay:0s}\n  .orb.c{width:300px;height:300px;background:linear-gradient(135deg,rgba(255,255,255,0.06),transparent);left:20%;top:40%;animation-delay:6s}\n  @keyframes drift{0%{transform:translateY(0) translateX(0)}50%{transform:translateY(18px) translateX(16px)}100%{transform:translateY(0) translateX(0)}}\n\n  /* Layout */\n  .wrap{\n    position:relative;\n    max-width:1200px;\n    margin:48px auto;\n    padding:36px;\n    display:grid;\n    grid-template-columns:420px 1fr;\n    gap:28px;\n    z-index:1;\n  }\n\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n    border-radius:16px;\n    padding:26px;\n    box-shadow: 0 8px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(110%);\n    border:1px solid rgba(255,255,255,0.04);\n  }\n\n  /* Left Info Card */\n  .heading{\n    display:flex;align-items:center;gap:14px;margin-bottom:18px;\n  }\n  .logo{\n    width:56px;height:56px;border-radius:12px;\n    background:linear-gradient(135deg,var(--accent),var(--accent-2));\n    display:flex;align-items:center;justify-content:center;\n    box-shadow:0 6px 20px rgba(60,100,200,0.22);\n    color:#081022;font-weight:700;font-size:20px;\n  }\n  h1{font-size:20px;margin:0}\n  .sub{color:var(--muted);font-size:13px;margin-top:6px;line-height:1.45}\n\n  .desc{\n    margin-top:14px;color:var(--muted);font-size:13px;line-height:1.55;\n  }\n\n  .legend{\n    display:flex;gap:10px;align-items:center;margin-top:18px;\n  }\n  .legend .item{display:flex;gap:10px;align-items:center;font-size:13px;color:var(--muted)}\n  .swatch{width:14px;height:14px;border-radius:4px;box-shadow:0 2px 10px rgba(2,6,23,0.5)}\n  .swatch.reachable{background:linear-gradient(135deg,var(--accent),#44c8a8)}\n  .swatch.unreachable{background:linear-gradient(135deg,#6b7280,#374151)}\n  .swatch.collected{background:linear-gradient(135deg,#1f2937,#0b1220)}\n  .controls{margin-top:20px;display:flex;gap:12px;align-items:center}\n\n  .btn{\n    padding:12px 18px;border-radius:12px;border:0;color:#071022;font-weight:700;\n    background:linear-gradient(90deg,var(--accent),var(--accent-2));\n    box-shadow:0 6px 20px rgba(96,165,250,0.14), inset 0 -2px 6px rgba(255,255,255,0.06);\n    cursor:pointer;transition:transform .18s ease;\n    font-size:13px;\n  }\n  .btn:active{transform:translateY(2px)}\n  .btn.ghost{\n    background:transparent;color:var(--muted);border:1px solid rgba(255,255,255,0.04);\n    box-shadow:none;padding:10px 14px;font-weight:600;\n  }\n  .meta{margin-top:18px;font-size:13px;color:var(--muted);display:flex;justify-content:space-between;align-items:center}\n\n  /* Right Visual Panel */\n  .visual{\n    position:relative;overflow:hidden;min-height:560px;\n    display:flex;align-items:center;justify-content:center;\n  }\n\n  .heap-frame{\n    width:100%;height:520px;border-radius:16px;padding:28px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 12px 60px rgba(2,6,23,0.6);\n    position:relative;overflow:visible;\n  }\n\n  .heap-title{\n    position:absolute;left:34px;top:20px;color:var(--muted);font-size:12px;letter-spacing:0.06em;\n    display:flex;align-items:center;gap:10px;\n  }\n  .root-node{\n    position:absolute;left:34px;top:44px;display:flex;gap:12px;align-items:center;\n    color:var(--muted);font-size:13px;\n  }\n  .root-pill{\n    width:84px;height:42px;border-radius:12px;background:linear-gradient(180deg,rgba(255,255,255,0.02),transparent);\n    display:flex;align-items:center;justify-content:center;color:var(--muted);font-weight:700;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  .heap-grid{\n    position:absolute;left:34px;right:34px;top:120px;bottom:34px;border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    display:grid;grid-template-columns:repeat(6,1fr);grid-auto-rows:1fr;padding:18px;gap:14px;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  .cell{\n    background:linear-gradient(180deg, rgba(255,255,255,0.015), transparent);\n    border-radius:10px;position:relative;overflow:visible;border:1px solid rgba(255,255,255,0.02);\n    display:flex;align-items:center;justify-content:center;padding:12px;min-height:78px;\n    transition:transform .4s cubic-bezier(.2,.9,.3,1),box-shadow .4s,opacity .35s;\n  }\n  .cell::after{\n    content:\"\";position:absolute;inset:0;border-radius:10px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.02);\n    pointer-events:none;\n  }\n\n  .node{\n    width:86px;height:56px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;\n    color:#071022;font-weight:700;font-size:13px;box-shadow: 0 12px 30px rgba(8,18,34,0.45);\n    transition:transform .45s cubic-bezier(.2,.9,.3,1),opacity .32s,filter .32s,box-shadow .32s;\n    transform-origin:center;\n    position:relative;\n    cursor:default;\n  }\n  .node .type{font-size:11px;color:rgba(7,16,34,0.6);font-weight:800;letter-spacing:0.04em}\n  .node .id{font-size:12px;margin-top:6px;color:#061227;opacity:0.9}\n\n  .node.reachable{\n    background:linear-gradient(90deg,var(--accent),var(--accent-2));\n    box-shadow: 0 18px 40px rgba(96,165,250,0.18), 0 6px 20px rgba(9,10,20,0.35);\n    transform:translateY(-6px) scale(1.02);\n  }\n  .node.unreachable{\n    background:linear-gradient(90deg,#4b5563,#2f3742);\n    color:#d7e6ee;filter:grayscale(.15) brightness(.9);\n    box-shadow: 0 8px 20px rgba(2,6,23,0.5);\n  }\n  .node.collected{\n    transform:scale(.85) translateY(10px);opacity:0;filter:blur(2px);\n    pointer-events:none;\n    box-shadow:none;\n  }\n\n  /* mini badge */\n  .badge{\n    position:absolute;right:18px;top:18px;background:linear-gradient(90deg,var(--accent-2),var(--accent));padding:8px 12px;border-radius:10px;font-weight:800;color:#071022;font-size:13px;\n    box-shadow: 0 8px 20px rgba(96,165,250,0.12);\n  }\n\n  /* Collector */\n  .collector{\n    position:absolute;width:120px;height:120px;border-radius:50%;\n    left:34px;top:34px;transform:translateY(-40px);\n    pointer-events:none;mix-blend-mode:screen;filter:blur(6px);\n    opacity:0;\n    transition:opacity .25s;\n  }\n  .collector .core{\n    width:100%;height:100%;border-radius:50%;\n    background: conic-gradient(from 120deg, rgba(96,165,250,0.2), rgba(110,231,183,0.18), rgba(96,165,250,0.22));\n    box-shadow: 0 18px 80px rgba(60,120,220,0.18);\n    border:1px solid rgba(255,255,255,0.03);\n  }\n\n  /* svg arrows */\n  svg.refs{position:absolute;inset:0;overflow:visible;pointer-events:none}\n  .ref-path{fill:none;stroke:rgba(255,255,255,0.12);stroke-width:2.2;stroke-linecap:round}\n  .ref-path.reachable{stroke:rgba(110,231,183,0.85)}\n  .ref-path.ghost{stroke-dasharray:6 8;stroke-opacity:.08}\n  .ref-arrow marker path{fill:rgba(255,255,255,0.12)}\n  .ref-path.pulse{animation:pulse 1.6s linear infinite}\n  @keyframes pulse{0%{stroke-dashoffset:0}100%{stroke-dashoffset:24}}\n\n  /* reclaimed highlight */\n  .cell.reclaimed::before{\n    content:\"\";position:absolute;inset:-2px;border-radius:12px;\n    background:linear-gradient(90deg, rgba(96,165,250,0.12), rgba(110,231,183,0.08));\n    opacity:0;transform:scale(0.98);transition:opacity .4s,transform .4s;\n  }\n  .cell.reclaimed::before{opacity:1;transform:scale(1)}\n\n  /* small status toast */\n  .toast{\n    position:absolute;left:50%;bottom:26px;transform:translateX(-50%);padding:10px 16px;border-radius:12px;background:rgba(7,16,34,0.7);color:var(--muted);font-size:13px;border:1px solid rgba(255,255,255,0.03);\n    box-shadow:0 8px 30px rgba(2,6,23,0.6);opacity:0;pointer-events:none;transition:opacity .25s,transform .25s;\n  }\n  .toast.show{opacity:1;transform:translateX(-50%) translateY(-6px)}\n\n  /* responsive */\n  @media (max-width:1080px){\n    .wrap{grid-template-columns:1fr; padding:20px}\n    .visual{order:-1;margin-bottom:18px}\n    .heap-grid{top:150px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"scene-bg\" aria-hidden=\"true\">\n    <div class=\"orb a\"></div>\n    <div class=\"orb b\"></div>\n    <div class=\"orb c\"></div>\n  </div>\n\n  <div class=\"wrap\">\n    <div class=\"panel\">\n      <div class=\"heading\">\n        <div class=\"logo\">GC</div>\n        <div>\n          <h1>Garbage Collection — Visualized</h1>\n          <div class=\"sub\">A refined, aesthetic demonstration of how a garbage collector marks and reclaims unreachable objects in memory.</div>\n        </div>\n      </div>\n\n      <div class=\"desc\">\n        This visualization shows a simplified heap and object graph. The \"root\" represents active references (e.g., stack, globals). Objects reachable from the root are preserved (green). Unreachable objects are eligible for collection (muted). Press \"Run GC\" to trigger a sweep that marks and reclaims unreachable memory with a graceful animation.\n      </div>\n\n      <div class=\"legend\">\n        <div class=\"item\"><span class=\"swatch reachable\"></span> Reachable</div>\n        <div class=\"item\"><span class=\"swatch unreachable\"></span> Unreachable</div>\n        <div class=\"item\"><span class=\"swatch collected\"></span> Collected</div>\n      </div>\n\n      <div class=\"controls\">\n        <button id=\"runBtn\" class=\"btn\">Run GC</button>\n        <button id=\"resetBtn\" class=\"btn ghost\">Reset</button>\n      </div>\n\n      <div class=\"meta\">\n        <div>Algorithm: Mark & Sweep (conceptual)</div>\n        <div id=\"stats\" style=\"color:var(--muted);font-weight:700\">Heap objects: 12</div>\n      </div>\n    </div>\n\n    <div class=\"panel visual\">\n      <div class=\"heap-frame\" id=\"frame\">\n        <div class=\"heap-title\">Managed Heap</div>\n\n        <div class=\"root-node\" id=\"rootArea\" aria-hidden=\"true\">\n          <div class=\"root-pill\" title=\"Root set\">Root</div>\n          <div style=\"width:12px\"></div>\n        </div>\n\n        <div class=\"heap-grid\" id=\"grid\"></div>\n\n        <svg class=\"refs\" id=\"svg\"></svg>\n\n        <div class=\"collector\" id=\"collector\" aria-hidden=\"true\">\n          <div class=\"core\"></div>\n        </div>\n\n        <div class=\"badge\" id=\"badge\">Mark & Sweep</div>\n\n        <canvas id=\"particles\" style=\"position:absolute;inset:0;pointer-events:none;\"></canvas>\n\n        <div class=\"toast\" id=\"toast\">0 objects reclaimed</div>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  Aesthetic Garbage Collection Visual Demo\n  - Minimal interactivity: Run GC and Reset\n  - Smooth animations and transitions\n*/\n\n// Model definition: objects with ids, references, and positions in grid (row,col)\nconst modelTemplate = {\n  rows: 3,\n  cols: 6,\n  objects: [\n    { id: 'A', row:0, col:0, refs:['B','C'] },\n    { id: 'B', row:0, col:2, refs:['D'] },\n    { id: 'C', row:0, col:1, refs:[] },\n    { id: 'D', row:1, col:2, refs:[] },\n\n    { id: 'E', row:0, col:4, refs:['F'] },\n    { id: 'F', row:1, col:4, refs:[] },\n\n    { id: 'G', row:1, col:0, refs:['H'] },\n    { id: 'H', row:2, col:0, refs:[] },\n\n    // Some unreachable cluster\n    { id: 'X', row:1, col:5, refs:['Y'] },\n    { id: 'Y', row:2, col:5, refs:['Z'] },\n    { id: 'Z', row:2, col:4, refs:[] },\n\n    // Isolated unreachable\n    { id: 'Q', row:2, col:2, refs:[] }\n  ],\n  roots: ['A','E','G'] // root set\n};\n\n// DOM references\nconst gridEl = document.getElementById('grid');\nconst svg = document.getElementById('svg');\nconst frame = document.getElementById('frame');\nconst runBtn = document.getElementById('runBtn');\nconst resetBtn = document.getElementById('resetBtn');\nconst collectorEl = document.getElementById('collector');\nconst particlesCanvas = document.getElementById('particles');\nconst toast = document.getElementById('toast');\nconst stats = document.getElementById('stats');\nlet ctx;\n\n// State\nlet model;\nlet nodes = {}; // id => dom element\nlet cellEls = []; // every cell\nlet paths = {}; // pair key => svg path element\nlet busy = false;\nlet canvasW, canvasH;\nlet particleList = [];\n\nfunction init(){\n  model = JSON.parse(JSON.stringify(modelTemplate)); // deep copy\n  setupCanvas();\n  renderGrid();\n  renderObjects();\n  renderRefs();\n  stats.textContent = `Heap objects: ${model.objects.length}`;\n  toast.classList.remove('show');\n}\n\nfunction setupCanvas(){\n  const rect = frame.getBoundingClientRect();\n  canvasW = rect.width; canvasH = rect.height;\n  particlesCanvas.width = canvasW * devicePixelRatio;\n  particlesCanvas.height = canvasH * devicePixelRatio;\n  particlesCanvas.style.width = canvasW+'px';\n  particlesCanvas.style.height = canvasH+'px';\n  ctx = particlesCanvas.getContext('2d');\n  ctx.scale(devicePixelRatio, devicePixelRatio);\n  requestAnimationFrame(runParticles);\n}\n\nfunction clearGrid(){\n  gridEl.innerHTML = '';\n  svg.innerHTML = '';\n  nodes = {}; cellEls = []; paths = {};\n}\n\nfunction renderGrid(){\n  clearGrid();\n  gridEl.style.gridTemplateColumns = `repeat(${model.cols}, 1fr)`;\n  const total = model.rows * model.cols;\n  for(let r=0;r<model.rows;r++){\n    for(let c=0;c<model.cols;c++){\n      const cell = document.createElement('div');\n      cell.className = 'cell';\n      cell.dataset.row = r; cell.dataset.col = c;\n      gridEl.appendChild(cell);\n      cellEls.push(cell);\n    }\n  }\n}\n\nfunction findCell(row,col){\n  const index = row * model.cols + col;\n  return cellEls[index];\n}\n\nfunction makeNodeEl(obj){\n  const el = document.createElement('div');\n  el.className = 'node unreachable';\n  el.dataset.id = obj.id;\n  el.innerHTML = `<div class=\"type\">Object</div><div class=\"id\">${obj.id}</div>`;\n  el.style.transitionDelay = (Math.random()*180)+'ms';\n  return el;\n}\n\nfunction renderObjects(){\n  // place objects into cells\n  model.objects.forEach(o=>{\n    const cell = findCell(o.row, o.col);\n    if(!cell) return;\n    const n = makeNodeEl(o);\n    cell.appendChild(n);\n    nodes[o.id] = { el:n, cell };\n  });\n\n  // mark roots visually near top with small pointers\n  const rootArea = document.getElementById('rootArea');\n  rootArea.querySelectorAll('.root-entry')?.forEach(x=>x.remove());\n  model.roots.forEach((rid,i)=>{\n    const r = document.createElement('div');\n    r.className = 'root-entry';\n    r.style.marginLeft = (i*6)+'px';\n    r.style.opacity = 0.95;\n    r.innerHTML = `<div style=\"width:78px;height:28px;border-radius:8px;background:linear-gradient(90deg,var(--accent-2),var(--accent));display:flex;align-items:center;justify-content:center;font-weight:800;color:#071022;font-size:12px;margin-left:6px\">${rid}</div>`;\n    rootArea.appendChild(r);\n  });\n\n  // animate slight entrance\n  setTimeout(()=> {\n    Object.values(nodes).forEach(n=>{\n      n.el.style.transform = 'translateY(0)';\n    });\n  },60);\n}\n\nfunction renderRefs(){\n  // draw reference paths from each object to its referenced objects\n  // also draw from roots to object(s)\n  svg.innerHTML = '';\n  // marker defs\n  const defs = document.createElementNS('http://www.w3.org/2000/svg','defs');\n  defs.innerHTML = `\n    <marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"8\" refX=\"7\" refY=\"4\" orient=\"auto\" markerUnits=\"strokeWidth\">\n      <path d=\"M0,0 L8,4 L0,8 z\" fill=\"rgba(255,255,255,0.16)\"></path>\n    </marker>\n  `;\n  svg.appendChild(defs);\n\n  // helper: position centers\n  const posOf = (el) => {\n    const rect = frame.getBoundingClientRect();\n    const nodeRect = el.getBoundingClientRect();\n    return {\n      x: nodeRect.left - rect.left + nodeRect.width/2,\n      y: nodeRect.top - rect.top + nodeRect.height/2\n    };\n  };\n\n  // draw object-to-object refs\n  model.objects.forEach(o=>{\n    const src = nodes[o.id];\n    if(!src) return;\n    o.refs.forEach(tid=>{\n      const tgt = nodes[tid];\n      if(!tgt) return;\n      const p = document.createElementNS('http://www.w3.org/2000/svg','path');\n      p.classList.add('ref-path','ghost');\n      p.setAttribute('stroke-width',2.2);\n      p.setAttribute('data-src',o.id);\n      p.setAttribute('data-tgt',tid);\n      svg.appendChild(p);\n      paths[`${o.id}-${tid}`] = p;\n      updatePath(p, posOf(src.el), posOf(tgt.el));\n    });\n  });\n\n  // draw root refs\n  model.roots.forEach(rid=>{\n    const target = nodes[rid];\n    if(!target) return;\n    const p = document.createElementNS('http://www.w3.org/2000/svg','path');\n    p.classList.add('ref-path','ghost');\n    p.setAttribute('stroke-width',2.6);\n    p.setAttribute('data-src','root');\n    p.setAttribute('data-tgt',rid);\n    svg.appendChild(p);\n    paths[`root-${rid}`] = p;\n    // position root pill center\n    const rootRect = document.getElementById('rootArea').getBoundingClientRect();\n    const rect = frame.getBoundingClientRect();\n    const srcPos = { x: rootRect.left - rect.left + 48, y: rootRect.top - rect.top + 42 };\n    updatePath(p, srcPos, posOf(target.el));\n  });\n}\n\nfunction updatePath(p, src, tgt){\n  // curve control points to be nice\n  const dx = tgt.x - src.x;\n  const dy = tgt.y - src.y;\n  const cx1 = src.x + dx*0.18;\n  const cy1 = src.y - Math.max(36, Math.abs(dx)*0.25);\n  const cx2 = src.x + dx*0.82;\n  const cy2 = tgt.y + Math.max(36, Math.abs(dx)*0.25);\n  const d = `M ${src.x} ${src.y} C ${cx1} ${cy1} ${cx2} ${cy2} ${tgt.x} ${tgt.y}`;\n  p.setAttribute('d', d);\n  p.setAttribute('marker-end', 'url(#arrowhead)');\n}\n\nfunction computeReachable(){\n  // mark reachable via DFS\n  const adj = {};\n  model.objects.forEach(o=> adj[o.id] = (o.refs||[]).slice());\n  const visited = new Set();\n  const stack = model.roots.slice();\n  while(stack.length){\n    const cur = stack.pop();\n    if(visited.has(cur)) continue;\n    visited.add(cur);\n    const children = adj[cur] || [];\n    children.forEach(ch=> {\n      if(!visited.has(ch)) stack.push(ch);\n    });\n  }\n  return visited;\n}\n\n// Animation: collector sweep\nasync function runGC(){\n  if(busy) return;\n  busy = true;\n  runBtn.disabled = true; resetBtn.disabled = true;\n  runBtn.style.opacity = 0.9;\n  // compute reachable set\n  const reachable = computeReachable();\n\n  // visually mark nodes reachable/unreachable\n  Object.entries(nodes).forEach(([id,info])=>{\n    const el = info.el;\n    el.classList.remove('reachable','unreachable','collected');\n    if(reachable.has(id)){\n      el.classList.add('reachable');\n      // highlight corresponding paths\n      setPathState(id, 'reachable');\n    } else {\n      el.classList.add('unreachable');\n      setPathState(id, 'ghost');\n    }\n  });\n\n  // animate collector across grid\n  const rect = frame.getBoundingClientRect();\n  const leftX = rect.left + 34;\n  const rightX = rect.right - 34 - 120; // collector width\n  collectorEl.style.opacity = 1;\n  collectorEl.style.top = (rect.top + 34) - rect.top + 'px';\n  // animate horizontal move via requestAnimationFrame\n  const duration = 3000;\n  const start = performance.now();\n  const toCollect = [];\n  const objPositions = Object.fromEntries(Object.entries(nodes).map(([id,info])=>{\n    const nrect = info.el.getBoundingClientRect();\n    return [id, {x: nrect.left - rect.left + nrect.width/2, y: nrect.top - rect.top + nrect.height/2}];\n  }));\n\n  // compute order of visitation by x coordinate\n  const ordered = Object.entries(objPositions).sort((a,b)=>a[1].x - b[1].x).map(([id,_])=>id);\n\n  // sweeping: when collector center passes the object's x - trigger\n  let collectedCount = 0;\n  let triggered = new Set();\n\n  return new Promise(resolve=>{\n    function step(t){\n      const p = Math.min(1, (t - start)/duration);\n      // smooth easing\n      const ease = (--p)*p*p+1;\n      const cx = leftX + (rightX-leftX) * ease;\n      collectorEl.style.left = cx + 'px';\n      // check triggers\n      ordered.forEach(id=>{\n        if(triggered.has(id)) return;\n        const pos = objPositions[id];\n        const collectorCenter = cx + 60; // collector width/2\n        if(collectorCenter > pos.x - 10){\n          // collector reached object x\n          triggered.add(id);\n          if(!reachable.has(id)){\n            // collect it with particle burst and fade\n            collectObject(id);\n            collectedCount++;\n          } else {\n            // small glow on reachable\n            pulsePreserve(id);\n          }\n        }\n      });\n      if(t - start < duration){\n        requestAnimationFrame(step);\n      } else {\n        // finish\n        setTimeout(()=>{\n          collectorEl.style.opacity = 0;\n          busy = false;\n          runBtn.disabled = false;\n          resetBtn.disabled = false;\n          showToast(`${collectedCount} object${collectedCount===1?'':'s'} reclaimed`);\n          resolve();\n        },420);\n      }\n    }\n    requestAnimationFrame(step);\n  });\n}\n\nfunction setPathState(sourceId, state){\n  // adjust all paths where source or target equals sourceId\n  Object.values(paths).forEach(p=>{\n    const tgt = p.getAttribute('data-tgt');\n    const src = p.getAttribute('data-src');\n    if(src === sourceId || tgt === sourceId){\n      p.classList.remove('reachable','ghost','pulse');\n      if(state === 'reachable'){\n        p.classList.add('reachable','pulse');\n        p.style.stroke = 'rgba(110,231,183,0.9)';\n        p.setAttribute('stroke-width', 2.8);\n      } else {\n        p.classList.add('ghost');\n        p.style.stroke = 'rgba(255,255,255,0.08)';\n        p.setAttribute('stroke-width', 2.0);\n      }\n    }\n  });\n}\n\nfunction pulsePreserve(id){\n  const info = nodes[id];\n  if(!info) return;\n  const el = info.el;\n  el.animate([\n    { transform: 'translateY(-6px) scale(1.02)', boxShadow: '0 22px 48px rgba(96,165,250,0.22)'},\n    { transform: 'translateY(-2px) scale(1.01)', boxShadow: '0 14px 30px rgba(96,165,250,0.14)'}\n  ], {duration:420, easing:'ease-out'});\n}\n\nfunction collectObject(id){\n  const info = nodes[id];\n  if(!info) return;\n  const el = info.el;\n  // fade out\n  el.classList.add('collected');\n  el.classList.remove('unreachable','reachable');\n  // remove references visually\n  Object.entries(paths).forEach(([k,p])=>{\n    if(p.getAttribute('data-src') === id || p.getAttribute('data-tgt') === id){\n      p.style.opacity = 0;\n      setTimeout(()=>{ try{ p.remove() }catch(e){} },520);\n    }\n  });\n  // particle burst\n  const rect = frame.getBoundingClientRect();\n  const nodeRect = el.getBoundingClientRect();\n  const cx = nodeRect.left - rect.left + nodeRect.width/2;\n  const cy = nodeRect.top - rect.top + nodeRect.height/2;\n  spawnParticles(cx,cy, 16, '#7EE7C2');\n  // mark cell reclaimed\n  const cell = info.cell;\n  cell.classList.add('reclaimed');\n  // remove DOM node after short delay\n  setTimeout(()=> {\n    try{ el.remove(); }catch(e){}\n    // remove from nodes and model\n    delete nodes[id];\n    const idx = model.objects.findIndex(o=>o.id===id);\n    if(idx>=0) model.objects.splice(idx,1);\n    stats.textContent = `Heap objects: ${model.objects.length}`;\n  }, 520);\n}\n\nfunction spawnParticles(x,y,count,color){\n  for(let i=0;i<count;i++){\n    particleList.push({\n      x, y,\n      vx: (Math.random()-0.5) * 2.8,\n      vy: (Math.random()-0.8) * -3.2,\n      life: 600 + Math.random()*500,\n      born: performance.now(),\n      size: 6 + Math.random()*8,\n      color\n    });\n  }\n}\n\nfunction runParticles(){\n  const now = performance.now();\n  ctx.clearRect(0,0,canvasW,canvasH);\n  const alive = [];\n  for(const p of particleList){\n    const t = now - p.born;\n    if(t > p.life) continue;\n    const dt = 16/1000;\n    p.vy += 0.06;\n    p.x += p.vx * (dt*60);\n    p.y += p.vy * (dt*60);\n    const lifeRatio = 1 - (t / p.life);\n    ctx.globalAlpha = Math.max(0, lifeRatio);\n    const g = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size);\n    g.addColorStop(0, p.color);\n    g.addColorStop(1, 'rgba(255,255,255,0)');\n    ctx.fillStyle = g;\n    ctx.beginPath();\n    ctx.arc(p.x, p.y, p.size * lifeRatio, 0, Math.PI*2);\n    ctx.fill();\n    alive.push(p);\n  }\n  particleList = alive;\n  ctx.globalAlpha = 1;\n  requestAnimationFrame(runParticles);\n}\n\nfunction showToast(text){\n  toast.textContent = text;\n  toast.classList.add('show');\n  setTimeout(()=> toast.classList.remove('show'), 2200);\n}\n\nfunction reset(){\n  if(busy) return;\n  // rebuild model\n  model = JSON.parse(JSON.stringify(modelTemplate));\n  renderGrid();\n  renderObjects();\n  renderRefs();\n  stats.textContent = `Heap objects: ${model.objects.length}`;\n  toast.classList.remove('show');\n}\n\n// Handle resize to adjust paths and canvas\nwindow.addEventListener('resize', ()=> {\n  setupCanvas();\n  // re-render paths positions\n  Object.values(paths).forEach(p=>{\n    const srcId = p.getAttribute('data-src');\n    const tgtId = p.getAttribute('data-tgt');\n    const rect = frame.getBoundingClientRect();\n    let srcPos, tgtPos;\n    if(srcId === 'root'){\n      const rootRect = document.getElementById('rootArea').getBoundingClientRect();\n      srcPos = { x: rootRect.left - rect.left + 48, y: rootRect.top - rect.top + 42 };\n    } else {\n      const srcNode = nodes[srcId];\n      if(!srcNode) return;\n      const nrect = srcNode.el.getBoundingClientRect();\n      srcPos = { x: nrect.left - rect.left + nrect.width/2, y: nrect.top - rect.top + nrect.height/2 };\n    }\n    const tgtNode = nodes[tgtId];\n    if(!tgtNode) return;\n    const nrectT = tgtNode.el.getBoundingClientRect();\n    tgtPos = { x: nrectT.left - rect.left + nrectT.width/2, y: nrectT.top - rect.top + nrectT.height/2 };\n    updatePath(p, srcPos, tgtPos);\n  });\n});\n\n// attach events\nrunBtn.addEventListener('click', ()=> {\n  runGC();\n});\nresetBtn.addEventListener('click', ()=> {\n  reset();\n});\n\n// initial render\ninit();\n\n// small initial animation for badge\ndocument.getElementById('badge').animate([\n  { transform: 'translateY(8px) scale(0.98)', opacity:0},\n  { transform: 'translateY(0px) scale(1)', opacity:1}\n], {duration:700, easing:'cubic-bezier(.2,.9,.3,1)'});\n\n</script>\n</body>\n</html>"
