    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Congestion Control — Visual Simulation</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg:#0b1020;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.6);\n    --accent1: #7b61ff;\n    --accent2: #00e0b8;\n    --danger: #ff4d6d;\n    --neon: 0 8px 40px rgba(123,97,255,0.14);\n    --soft-shadow: 0 6px 24px rgba(2,6,23,0.6);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    background:\n      radial-gradient(1200px 600px at 10% 10%, rgba(123,97,255,0.07), transparent 8%),\n      radial-gradient(1000px 500px at 90% 80%, rgba(0,224,184,0.04), transparent 6%),\n      linear-gradient(180deg, #060612 0%, #0b1020 100%);\n    font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color: #dfe9f8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    padding:48px;\n  }\n\n  .container{\n    max-width:1200px;\n    margin:0 auto;\n    display:grid;\n    grid-template-columns: 1fr 420px;\n    gap:28px;\n    align-items:start;\n  }\n\n  .panel{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    border-radius:18px;\n    padding:26px;\n    box-shadow:var(--soft-shadow);\n    backdrop-filter: blur(6px) saturate(120%);\n  }\n\n  header{\n    grid-column: 1 / -1;\n    display:flex;\n    align-items:center;\n    gap:20px;\n    margin-bottom:10px;\n  }\n\n  .brand{\n    display:flex;\n    gap:16px;\n    align-items:center;\n  }\n\n  .logo{\n    width:64px;\n    height:64px;\n    display:grid;\n    place-items:center;\n    border-radius:14px;\n    background:linear-gradient(135deg,var(--accent1), var(--accent2));\n    box-shadow: var(--neon);\n    color:white;\n    font-weight:800;\n    font-size:22px;\n    letter-spacing:-0.02em;\n  }\n\n  h1{\n    margin:0;\n    font-size:20px;\n    font-weight:800;\n    color: #fff;\n    line-height:1;\n  }\n  p.lead{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n  }\n\n  /* Main visual area */\n  .visual{\n    height:640px;\n    position:relative;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:22px;\n  }\n\n  /* decorative background blobs */\n  .blob{\n    position:absolute;\n    filter: blur(40px) saturate(120%);\n    opacity:0.14;\n    transform:translate3d(0,0,0);\n  }\n  .blob.a{ width:520px;height:520px;background:linear-gradient(135deg,var(--accent1),#4eadff); top:-80px; left:-120px; border-radius:46%;}\n  .blob.b{ width:400px;height:400px;background:linear-gradient(135deg,var(--accent2),#00a3ff); bottom:-80px; right:-160px;border-radius:42%;}\n  .blob.c{ width:260px;height:260px;background:linear-gradient(135deg,#ff66b2, #7b61ff); top:120px; right:20px;border-radius:50%;opacity:0.06; filter: blur(80px); }\n\n  /* network canvas layout */\n  .network-stage{\n    position:relative;\n    width:100%;\n    height:100%;\n    display:grid;\n    grid-template-columns: 1fr 220px 1fr;\n    align-items:center;\n    gap:30px;\n    padding:32px;\n  }\n\n  .lane{\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:18px;\n    height:100%;\n    position:relative;\n  }\n\n  .node{\n    width:160px;\n    min-height:120px;\n    border-radius:14px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.04);\n    padding:14px;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:10px;\n    box-shadow:0 6px 20px rgba(2,6,23,0.5);\n    transition:transform .28s ease;\n  }\n  .node h3{\n    margin:0;\n    font-size:15px;\n    font-weight:700;\n    color:#fff;\n  }\n  .node .sub{ font-size:12px;color:var(--muted) }\n\n  .router{\n    width:190px;\n    min-height:160px;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:12px;\n    padding:14px;\n    border-radius:18px;\n    background:linear-gradient(180deg, rgba(0,0,0,0.22), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.06);\n    box-shadow: var(--neon);\n  }\n\n  .queue{\n    width:140px;\n    height:70px;\n    border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    display:flex;\n    align-items:center;\n    justify-content:flex-start;\n    gap:6px;\n    padding:6px;\n    overflow:hidden;\n    position:relative;\n  }\n  .queue .slot{\n    width:18px;height:18px;border-radius:6px;background:rgba(255,255,255,0.03); margin-right:6px;\n    transition:background .18s;\n    box-shadow: 0 1px 6px rgba(0,0,0,0.3) inset;\n  }\n\n  /* links and path visuals */\n  .path{\n    position:absolute;\n    pointer-events:none;\n    left:0;right:0;top:0;bottom:0;\n  }\n\n  .packets-container{\n    position:absolute;\n    left:0;right:0;top:0;bottom:0;\n  }\n\n  .packet{\n    position:absolute;\n    width:12px;height:12px;border-radius:4px;\n    background:linear-gradient(135deg,var(--accent1),var(--accent2));\n    box-shadow:0 6px 22px rgba(123,97,255,0.18);\n    transform:translate(-6px,-6px);\n    will-change: transform, opacity;\n  }\n  .packet.dropped{\n    background:linear-gradient(135deg,var(--danger),#ff9aa8);\n    box-shadow:0 10px 30px rgba(255,77,109,0.14);\n    transform:translate(-6px,-6px) scale(1.12);\n    opacity:0.95;\n  }\n\n  /* controls & metrics */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-top:8px;\n  }\n  .btn{\n    padding:10px 14px;\n    border-radius:10px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.06);\n    color:#fff;\n    cursor:pointer;\n    font-weight:600;\n    letter-spacing:0.01em;\n    box-shadow: 0 8px 30px rgba(5,8,20,0.5);\n    transition: transform .18s ease, opacity .18s;\n  }\n  .btn:hover{ transform:translateY(-3px) }\n  .btn.strong{\n    background:linear-gradient(90deg,var(--accent1),var(--accent2));\n    border:none;\n    box-shadow: 0 12px 36px rgba(123,97,255,0.22);\n  }\n\n  .metrics{\n    margin-top:14px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:space-between;\n  }\n  .metric{\n    background:var(--glass);\n    padding:10px 12px;\n    border-radius:10px;\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n    min-width:110px;\n  }\n  .metric .k{ font-weight:800; font-size:18px; color:#fff }\n  .metric .label{ font-size:12px; color:var(--muted) }\n\n  /* small chart */\n  canvas.cwnd-chart{\n    width:100%;\n    height:120px;\n    border-radius:10px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n    border: 1px solid rgba(255,255,255,0.03);\n    display:block;\n  }\n\n  /* info panel */\n  .info{\n    font-size:13px;\n    color:var(--muted);\n    line-height:1.5;\n  }\n\n  footer{\n    grid-column: 1 / -1;\n    margin-top:18px;\n    color:var(--muted);\n    font-size:12px;\n    display:flex;\n    justify-content:center;\n  }\n\n  /* subtle animated glows */\n  .glow {\n    position:absolute;\n    inset:0;\n    pointer-events:none;\n    background:\n      radial-gradient(600px 200px at 10% 20%, rgba(123,97,255,0.03), transparent 10%),\n      radial-gradient(400px 140px at 90% 80%, rgba(0,224,184,0.025), transparent 8%);\n    mix-blend-mode:screen;\n  }\n\n  /* small responsiveness */\n  @media (max-width:1080px){\n    .container{grid-template-columns:1fr; padding:20px}\n    .visual{height:640px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <header>\n      <div class=\"brand\">\n        <div class=\"logo\">CC</div>\n        <div>\n          <h1>Congestion Control — Elegant Simulation</h1>\n          <p class=\"lead\">A refined visual explanation of how congestion control manages packet flows, queues and recovery.</p>\n        </div>\n      </div>\n      <div style=\"margin-left:auto; display:flex; gap:10px; align-items:center;\">\n        <div style=\"text-align:right;\">\n          <div style=\"font-weight:700; font-size:12px; color:var(--muted)\">Simulation</div>\n          <div style=\"font-weight:800; font-size:14px\">Additive Increase / Multiplicative Decrease</div>\n        </div>\n      </div>\n    </header>\n\n    <section class=\"panel visual\">\n      <div class=\"blob a\"></div>\n      <div class=\"blob b\"></div>\n      <div class=\"blob c\"></div>\n      <div class=\"network-stage\" aria-hidden=\"false\">\n        <!-- Sender -->\n        <div class=\"lane\">\n          <div class=\"node\" id=\"senderNode\" title=\"Sender\">\n            <h3>Sender</h3>\n            <div class=\"sub\">Congestion window <span id=\"cwndText\">10</span></div>\n            <div style=\"width:100%; height:8px; background:rgba(255,255,255,0.03); border-radius:6px; overflow:hidden;\">\n              <div id=\"cwndBar\" style=\"height:8px; width:40%; background:linear-gradient(90deg,var(--accent1),var(--accent2)); border-radius:6px; transition:width .25s;\"></div>\n            </div>\n            <div class=\"controls\" style=\"margin-top:8px;\">\n              <button class=\"btn strong\" id=\"playBtn\" aria-pressed=\"false\">Start</button>\n              <button class=\"btn\" id=\"resetBtn\">Reset</button>\n            </div>\n            <div class=\"metrics\" style=\"margin-top:10px;\">\n              <div class=\"metric\">\n                <div class=\"k\" id=\"rate\">--</div>\n                <div class=\"label\">Send rate (pps)</div>\n              </div>\n              <div class=\"metric\">\n                <div class=\"k\" id=\"rtt\">-- ms</div>\n                <div class=\"label\">RTT (sim)</div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <!-- Router -->\n        <div style=\"display:flex; align-items:center; justify-content:center;\">\n          <div class=\"router\" id=\"routerNode\">\n            <h3>Router</h3>\n            <div class=\"sub\">Buffer occupancy</div>\n            <div class=\"queue\" id=\"queueBox\" aria-hidden=\"true\">\n              <!-- slots will be added -->\n            </div>\n            <div style=\"display:flex; gap:8px; margin-top:6px;\">\n              <div style=\"font-size:13px; color:var(--muted)\">Buffer:</div>\n              <div id=\"bufStat\" style=\"font-weight:800\">0 / 20</div>\n            </div>\n            <div style=\"width:160px; margin-top:6px;\">\n              <canvas id=\"utilCanvas\" width=\"160\" height=\"40\" style=\"width:160px;height:40px;border-radius:8px;background:transparent;\"></canvas>\n            </div>\n          </div>\n        </div>\n\n        <!-- Receiver -->\n        <div class=\"lane\">\n          <div class=\"node\" id=\"receiverNode\">\n            <h3>Receiver</h3>\n            <div class=\"sub\">Ack feedback & delivery</div>\n            <div style=\"margin-top:10px; display:flex; gap:8px;\">\n              <div style=\"min-width:70px;\">\n                <div style=\"font-size:12px;color:var(--muted)\">Delivered</div>\n                <div style=\"font-weight:800; font-size:18px;\" id=\"delivered\">0</div>\n              </div>\n              <div style=\"min-width:70px;\">\n                <div style=\"font-size:12px;color:var(--muted)\">Dropped</div>\n                <div style=\"font-weight:800; font-size:18px; color:var(--danger);\" id=\"dropped\">0</div>\n              </div>\n            </div>\n            <div style=\"height:12px\"></div>\n            <div style=\"margin-top:8px; font-size:12px; color:var(--muted)\">Acks are returned to the sender and influence cwnd.</div>\n          </div>\n        </div>\n\n        <!-- overlay holders -->\n        <div class=\"path\"></div>\n        <div class=\"packets-container\" id=\"packets\"></div>\n      </div>\n\n      <div class=\"glow\"></div>\n    </section>\n\n    <aside class=\"panel\" aria-labelledby=\"infoTitle\">\n      <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n        <div>\n          <h3 id=\"infoTitle\" style=\"margin:0; font-size:16px\">Telemetry & Storyboard</h3>\n          <div style=\"font-size:12px;color:var(--muted)\">Watch the window adjust when congestion occurs.</div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:14px;\">\n        <canvas class=\"cwnd-chart\" id=\"chart\" width=\"400\" height=\"140\"></canvas>\n      </div>\n\n      <div style=\"margin-top:14px;\" class=\"info\">\n        <p style=\"margin:0 0 8px 0;\">\n          This aesthetic simulation illustrates Additive Increase / Multiplicative Decrease (AIMD):\n          the sender slowly raises its congestion window until packet loss is detected (packets dropped at the router),\n          at which point it reduces the window substantially and then increases again.\n        </p>\n        <ul style=\"margin:10px 0 0 18px; padding:0; color:var(--muted)\">\n          <li>Minimal controls: Start / Pause and Reset.</li>\n          <li>Observe queue buildup, packet drops, window (cwnd) changes and throughput.</li>\n        </ul>\n      </div>\n\n      <div style=\"margin-top:16px; display:flex; gap:10px; align-items:center;\">\n        <div style=\"font-size:12px; color:var(--muted)\">Legend:</div>\n        <div style=\"display:flex; gap:8px; align-items:center;\">\n          <div style=\"width:12px;height:12px;border-radius:3px;background:linear-gradient(135deg,var(--accent1),var(--accent2)); box-shadow:0 6px 18px rgba(123,97,255,0.12)\"></div>\n          <div style=\"font-size:13px;\">Packet (in-flight)</div>\n          <div style=\"width:12px;height:12px;border-radius:3px;background:var(--danger); margin-left:12px\"></div>\n          <div style=\"font-size:13px;\">Dropped packet</div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:18px; display:flex; gap:8px;\">\n        <div style=\"font-size:12px; color:var(--muted)\"><strong>Notes:</strong></div>\n        <div style=\"font-size:12px; color:var(--muted)\">This is a stylized demonstration — not a full network emulator.</div>\n      </div>\n    </aside>\n\n    <footer>\n      Crafted with visual elegance to explain the dynamics of congestion control • Minimal controls for focused observation\n    </footer>\n  </div>\n\n<script>\n/* Elegant Congestion Control Simulation\n   Minimal controls: Start/Pause (toggle) and Reset\n   Visuals: moving packets, queue slots, cwnd chart, buffer util indicator\n*/\n\n(() => {\n  // Parameters\n  const bufferSize = 20;\n  let cwnd = 10;       // congestion window (packets)\n  let ssthresh = 1000; // not used deeply, but kept for narrative\n  let rtt = 240;       // ms simulated RTT\n  let baseSendInterval = 80; // base interval ms between packet sends (if cwnd small)\n  let running = false;\n  let lastTime = null;\n  let accum = 0;\n\n  // state\n  const packetsEl = document.getElementById('packets');\n  const queueBox = document.getElementById('queueBox');\n  const bufStat = document.getElementById('bufStat');\n  const deliveredEl = document.getElementById('delivered');\n  const droppedEl = document.getElementById('dropped');\n  const cwndText = document.getElementById('cwndText');\n  const cwndBar = document.getElementById('cwndBar');\n  const rateEl = document.getElementById('rate');\n  const rttEl = document.getElementById('rtt');\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const chart = document.getElementById('chart');\n  const utilCanvas = document.getElementById('utilCanvas');\n\n  const ctx = chart.getContext('2d');\n  const utilCtx = utilCanvas.getContext('2d');\n\n  let delivered = 0, dropped = 0;\n\n  // visual layout points (sender -> router -> receiver)\n  const stage = document.querySelector('.network-stage');\n  const senderNode = document.getElementById('senderNode');\n  const routerNode = document.getElementById('routerNode');\n  const receiverNode = document.getElementById('receiverNode');\n  const rect = stage.getBoundingClientRect();\n\n  function worldPos(el){\n    const r = el.getBoundingClientRect();\n    return { x: r.left + r.width/2 - rect.left, y: r.top + r.height/2 - rect.top };\n  }\n\n  // queue slots visual\n  function renderQueueSlots(){\n    queueBox.innerHTML = '';\n    for(let i=0;i<bufferSize;i++){\n      const s = document.createElement('div');\n      s.className='slot';\n      s.style.opacity = '0.18';\n      queueBox.appendChild(s);\n    }\n  }\n  renderQueueSlots();\n\n  function updateQueueVisual(occ){\n    const slots = queueBox.children;\n    for(let i=0;i<slots.length;i++){\n      if(i < occ){\n        slots[i].style.background = 'linear-gradient(135deg, #00e0b8, #4ff1c2)';\n        slots[i].style.opacity = '1';\n      } else {\n        slots[i].style.background = 'rgba(255,255,255,0.03)';\n        slots[i].style.opacity = '0.28';\n      }\n    }\n    bufStat.textContent = `${occ} / ${bufferSize}`;\n    // util canvas (simple bar)\n    utilCtx.clearRect(0,0,utilCanvas.width,utilCanvas.height);\n    utilCtx.fillStyle = 'rgba(255,255,255,0.06)';\n    utilCtx.fillRect(0,0,utilCanvas.width,utilCanvas.height);\n    const w = Math.max(2, Math.round(utilCanvas.width * (occ / bufferSize)));\n    utilCtx.fillStyle = 'linear-gradient(90deg,#00e0b8,#7b61ff)';\n    // gradient\n    const g = utilCtx.createLinearGradient(0,0,utilCanvas.width,0);\n    g.addColorStop(0,'#00e0b8'); g.addColorStop(1,'#7b61ff');\n    utilCtx.fillStyle = g;\n    utilCtx.fillRect(0,2,w,utilCanvas.height-4);\n  }\n\n  // packet model\n  let packetId = 0;\n  const inflight = []; // each has {id, state, t, x,y, toX,toY, birth, delivered}\n\n  // spawn logic based on cwnd: send up to cwnd per simulated RTT\n  let nextSendTick = 0;\n\n  function sendPacket(){\n    const sPos = worldPos(senderNode);\n    const rPos = worldPos(routerNode);\n    const rxPos = worldPos(receiverNode);\n    const p = document.createElement('div');\n    p.className = 'packet';\n    p.dataset.id = packetId;\n    p.style.left = sPos.x + 'px';\n    p.style.top = sPos.y + 'px';\n    packetsEl.appendChild(p);\n\n    const packet = {\n      id: packetId++,\n      el: p,\n      state: 'toRouter',\n      birth: performance.now(),\n      pos: {x:sPos.x, y:sPos.y},\n      to: {x:rPos.x, y:rPos.y},\n      speed: 0.6 + Math.random()*0.6 // px per ms\n    };\n    inflight.push(packet);\n  }\n\n  // simulate router queue (simple FIFO)\n  const routerQueue = [];\n\n  function stepSim(dt){\n    // spawn logic: want to send approximately cwnd packets per RTT\n    // compute sendInterval = rtt / cwnd\n    const sendInterval = Math.max(10, rtt / Math.max(1,cwnd));\n    accum += dt;\n    while(accum > sendInterval){\n      accum -= sendInterval;\n      // only send if total inflight < cwnd * 2 (prevent explosion)\n      const inFlightCount = inflight.length + routerQueue.length;\n      if(inFlightCount < Math.max(1, cwnd*1.8)){\n        sendPacket();\n      }\n    }\n\n    // move packets\n    for(let i=inflight.length-1;i>=0;i--){\n      const p = inflight[i];\n      const el = p.el;\n      const dx = p.to.x - p.pos.x;\n      const dy = p.to.y - p.pos.y;\n      const dist = Math.sqrt(dx*dx + dy*dy);\n      if(dist < 1){\n        // reached target\n        if(p.state === 'toRouter'){\n          // try enqueue at router\n          if(routerQueue.length < bufferSize){\n            // enqueue and mark waiting to go to receiver\n            p.state = 'queued';\n            routerQueue.push(p);\n            // snap to queue visual position (we'll place it near router)\n            p.to = { x: p.to.x + 16 + routerQueue.length*8 - bufferSize*4, y: p.to.y + 12 + (Math.random()*6-3) };\n            updateQueueVisual(routerQueue.length);\n          } else {\n            // drop\n            p.state = 'dropped';\n            p.el.classList.add('dropped');\n            p.to = { x: p.pos.x + (Math.random()*60-30), y: p.pos.y + 80 };\n            dropped++;\n            droppedEl.textContent = dropped;\n            // congestion event occurs when drop detected -> multiplicative decrease\n            // only trigger when a fresh drop occurs — we do it here\n            onPacketDrop();\n          }\n        } else if(p.state === 'queued'){\n          // waiting; once we reach some time, route to receiver\n          // we'll let dequeue logic move from queue to receiver\n          // if somehow it reaches target, go to receiver\n          p.state = 'toReceiver';\n          p.to = worldPos(receiverNode);\n        } else if(p.state === 'toReceiver'){\n          // delivered\n          p.state = 'delivered';\n          delivered++;\n          deliveredEl.textContent = delivered;\n          // schedule ack back to sender (we model ack as cwnd increase additive)\n          onAckReceived();\n          // fade out visual\n          p.el.style.transition = 'transform .8s ease, opacity .9s ease';\n          p.el.style.opacity = '0';\n          setTimeout(()=>{ try{ p.el.remove(); }catch(e){} }, 900);\n          inflight.splice(i,1);\n          continue;\n        } else if(p.state === 'dropped'){\n          // animate drop fade\n          p.el.style.transition = 'transform .6s ease, opacity .6s ease';\n          p.el.style.opacity = '0';\n          setTimeout(()=>{ try{ p.el.remove(); }catch(e){} }, 700);\n          inflight.splice(i,1);\n          continue;\n        }\n      } else {\n        // move toward target\n        const step = p.speed * dt;\n        p.pos.x += dx/dist * step;\n        p.pos.y += dy/dist * step;\n        el.style.transform = `translate(${p.pos.x - 6}px, ${p.pos.y - 6}px)`;\n      }\n    }\n\n    // Router dequeue logic: move packets from routerQueue to receiver at a paced rate\n    if(routerQueue.length > 0){\n      // pace: router forwards with slight delay based on utilization\n      const forwardRate = 0.9 + Math.max(0, (bufferSize - routerQueue.length) / bufferSize) * 1.8; // packets per action\n      // for simplicity, occasionally pop one\n      if(Math.random() < Math.min(0.6, forwardRate * 0.07)){\n        const p = routerQueue.shift();\n        // find the packet in inflight and set to receiver path\n        p.state = 'toReceiver';\n        p.to = worldPos(receiverNode);\n        updateQueueVisual(routerQueue.length);\n      }\n    }\n\n    // update metrics\n    cwndText.textContent = Math.max(1, Math.round(cwnd));\n    const cwdf = Math.max(5, Math.min(100, cwnd));\n    cwndBar.style.width = Math.min(100, Math.round((cwdf/100)*100)) + '%';\n    rateEl.textContent = Math.max(1, Math.round(1000 / Math.max(1, rtt / Math.max(1, cwnd)))) + ' pps';\n    rttEl.textContent = rtt + ' ms';\n  }\n\n  function onPacketDrop(){\n    // multiplicative decrease\n    cwnd = Math.max(1, cwnd * 0.5);\n    // small rtt bump to visualize congestion\n    rtt = Math.min(600, rtt + 30);\n    pushChart();\n    // visual nudge\n    routerNode.animate([\n      { transform: 'translateY(0px)'},\n      { transform: 'translateY(-6px)'},\n      { transform: 'translateY(0px)'}\n    ], { duration: 420, easing: 'cubic-bezier(.2,.9,.3,1)'});\n  }\n\n  function onAckReceived(){\n    // additive increase: cwnd += 1/cwnd approx (but for visuals: small linear increase)\n    cwnd += 0.2;\n    // slight recovery of RTT\n    rtt = Math.max(90, rtt - 2);\n    pushChart();\n  }\n\n  // chart data\n  const chartData = [];\n  function pushChart(){\n    chartData.push(Math.max(1, Math.round(cwnd*10)/10));\n    if(chartData.length > 200) chartData.shift();\n  }\n\n  function drawChart(){\n    const w = chart.width, h = chart.height;\n    ctx.clearRect(0,0,w,h);\n    // background gradient\n    const g = ctx.createLinearGradient(0,0,0,h);\n    g.addColorStop(0,'rgba(123,97,255,0.06)');\n    g.addColorStop(1,'rgba(0,224,184,0.02)');\n    ctx.fillStyle = g;\n    ctx.fillRect(0,0,w,h);\n\n    // axes subtle\n    ctx.strokeStyle = 'rgba(255,255,255,0.03)';\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    ctx.moveTo(0,h-1); ctx.lineTo(w,h-1); ctx.stroke();\n\n    // draw line\n    if(chartData.length>1){\n      const maxVal = Math.max(10, Math.max(...chartData));\n      ctx.beginPath();\n      for(let i=0;i<chartData.length;i++){\n        const x = (i/(chartData.length-1)) * w;\n        const y = h - (chartData[i]/maxVal) * (h-10) - 6;\n        if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n      }\n      // gradient stroke\n      const g2 = ctx.createLinearGradient(0,0,w,0);\n      g2.addColorStop(0,'#7b61ff'); g2.addColorStop(1,'#00e0b8');\n      ctx.strokeStyle = g2;\n      ctx.lineWidth = 2.6;\n      ctx.stroke();\n\n      // area\n      ctx.lineTo(w,h); ctx.lineTo(0,h); ctx.closePath();\n      const g3 = ctx.createLinearGradient(0,0,0,h);\n      g3.addColorStop(0,'rgba(123,97,255,0.08)'); g3.addColorStop(1,'rgba(0,224,184,0.02)');\n      ctx.fillStyle = g3;\n      ctx.globalAlpha = 0.42;\n      ctx.fill();\n      ctx.globalAlpha = 1;\n    }\n\n    // draw current cwnd big\n    ctx.fillStyle = '#fff';\n    ctx.font = '700 16px Inter, system-ui';\n    ctx.fillText('cwnd ' + Math.round(cwnd*10)/10, 8, 20);\n  }\n\n  // animation loop\n  function loop(t){\n    if(!lastTime) lastTime = t;\n    const dt = Math.min(40, t - lastTime);\n    lastTime = t;\n    if(running){\n      stepSim(dt);\n      // sometimes push queued packets' positions to visually stay near router\n      // update inflight packet positions transform ensures visuals\n    }\n    drawChart();\n    requestAnimationFrame(loop);\n  }\n\n  // initial chart fill\n  for(let i=0;i<30;i++) pushChart();\n\n  // controls\n  playBtn.addEventListener('click', ()=>{\n    running = !running;\n    if(running){\n      playBtn.textContent = 'Pause';\n      playBtn.setAttribute('aria-pressed','true');\n      playBtn.classList.add('strong'); // keep gradient\n    } else {\n      playBtn.textContent = 'Start';\n      playBtn.setAttribute('aria-pressed','false');\n    }\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    // reset simulation to gentle state\n    cwnd = 10;\n    ssthresh = 1000;\n    rtt = 240;\n    delivered = 0; dropped = 0;\n    deliveredEl.textContent = delivered;\n    droppedEl.textContent = dropped;\n    // clear packets\n    inflight.slice().forEach(p => { try{ p.el.remove(); }catch(e){} });\n    inflight.length = 0;\n    routerQueue.length = 0;\n    updateQueueVisual(0);\n    packetId = 0;\n    chartData.length = 0;\n    for(let i=0;i<30;i++) pushChart();\n  });\n\n  // minor responsiveness: recalc stage rect on resize\n  window.addEventListener('resize', ()=>{\n    // update rect\n    rect.left = stage.getBoundingClientRect().left;\n    rect.top = stage.getBoundingClientRect().top;\n  });\n\n  // subtle periodic events to create aesthetic motion even when paused\n  setInterval(()=>{\n    // micro glows on nodes\n    senderNode.animate([\n      { boxShadow: '0 8px 28px rgba(123,97,255,0.06)' },\n      { boxShadow: '0 16px 56px rgba(123,97,255,0.12)' },\n      { boxShadow: '0 8px 28px rgba(123,97,255,0.06)' }\n    ], { duration: 2200 + Math.random()*1600, easing: 'ease-in-out' });\n  }, 2600);\n\n  // start loop\n  requestAnimationFrame(loop);\n\n  // friendly hint: start paused initially\n  running = false;\n\n})();\n</script>\n</body>\n</html>"
