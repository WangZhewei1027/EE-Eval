    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Jump Search Demonstration</title>\n    <style>\n        body { font-family: monospace; }\n        input, button, select { margin: 5px; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n<h1>Jump Search Demonstration</h1>\n\n<label for=\"length\">Array Length:</label>\n<input type=\"number\" id=\"length\" value=\"10\" min=\"1\" max=\"100\">\n<br>\n\n<label for=\"target\">Target Value:</label>\n<input type=\"number\" id=\"target\" value=\"0\">\n<br>\n\n<button id=\"generate\">Generate Array</button>\n<button id=\"search\">Jump Search</button>\n\n<div>\n    <strong>Generated Array:</strong> <span id=\"arrayOutput\"></span>\n</div>\n\n<div id=\"output\"></div>\n\n<script>\n    let array = [];\n    let jump = 0;\n\n    document.getElementById(\"generate\").addEventListener(\"click\", function() {\n        const length = parseInt(document.getElementById(\"length\").value, 10);\n        array = Array.from({ length }, (_, i) => i); // Generates a sorted array [0, 1, ..., N-1]\n        jump = Math.floor(Math.sqrt(length));\n        document.getElementById(\"arrayOutput\").innerText = JSON.stringify(array);\n        document.getElementById(\"output\").innerText = \"\";\n    });\n\n    document.getElementById(\"search\").addEventListener(\"click\", function() {\n        const target = parseInt(document.getElementById(\"target\").value, 10);\n        const result = jumpSearch(array, target);\n        document.getElementById(\"output\").innerText = result !== -1 ? `Element found at index: ${result}` : `Element not found.`;\n    });\n\n    function jumpSearch(arr, target) {\n        let n = arr.length;\n        let prev = 0;\n\n        while (arr[Math.min(jump, n) - 1] < target) {\n            prev = jump;\n            jump += Math.floor(Math.sqrt(n));\n            if (prev >= n) return -1;\n        }\n\n        while (arr[prev] < target) {\n            prev++;\n            if (prev === Math.min(jump, n)) return -1;\n        }\n\n        if (arr[prev] === target) return prev;\n        return -1;\n    }\n</script>\n\n</body>\n</html>"
