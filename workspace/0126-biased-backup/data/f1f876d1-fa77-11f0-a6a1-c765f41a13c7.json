    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>REST API — Visual Concept</title>\n\n  <!-- Google Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Space+Grotesk:wght@400;600&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #071028;\n      --glass: rgba(255,255,255,0.06);\n      --accent: linear-gradient(135deg,#7b6cff 0%, #3fe0c6 100%);\n      --muted: rgba(255,255,255,0.55);\n      --glass-2: rgba(255,255,255,0.03);\n      --card-glow: rgba(63,224,198,0.12);\n      --duration: 2800ms;\n      --soft: cubic-bezier(.2,.9,.3,1);\n    }\n\n    /* Reset */\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(125,108,255,0.12), transparent 6%),\n                  radial-gradient(1000px 500px at 90% 90%, rgba(63,224,198,0.06), transparent 8%),\n                  linear-gradient(180deg,var(--bg1) 0%, var(--bg2) 100%);\n      color: #e9f0ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding:48px;\n      overflow-y:auto;\n    }\n\n    /* Top header */\n    .header{\n      max-width:1100px;\n      margin:0 auto 28px;\n      display:flex;\n      align-items:center;\n      gap:20px;\n    }\n    .logo {\n      width:86px;\n      height:86px;\n      border-radius:18px;\n      background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n      box-shadow: 0 6px 30px rgba(7,10,20,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(6px) saturate(120%);\n      overflow:hidden;\n    }\n\n    .logo svg { width:64px;height:64px; transform:translateY(-2px); filter: drop-shadow(0 6px 22px rgba(67,54,255,0.12)); }\n\n    .title-block{\n      flex:1;\n    }\n    .title{\n      font-family: \"Space Grotesk\", Inter, sans-serif;\n      font-weight:600;\n      font-size:22px;\n      letter-spacing:0.2px;\n      margin:0 0 6px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .subtitle{\n      color:var(--muted);\n      font-size:13px;\n      margin:0;\n      max-width:820px;\n    }\n\n    /* Control */\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n    .btn {\n      appearance:none;\n      border:0;\n      padding:10px 16px;\n      border-radius:12px;\n      font-weight:600;\n      cursor:pointer;\n      color: #071028;\n      background: linear-gradient(90deg,#8b7bff,#3fe0c6);\n      box-shadow: 0 6px 20px rgba(63,224,198,0.12), inset 0 -3px 8px rgba(0,0,0,0.12);\n      transition: transform 220ms var(--soft), box-shadow 220ms var(--soft), filter 220ms var(--soft);\n      display:inline-flex;\n      align-items:center;\n      gap:10px;\n      font-size:14px;\n    }\n    .btn:active{ transform:translateY(1px) scale(.997); }\n    .btn .dot {\n      width:10px;height:10px;border-radius:50%;\n      background:rgba(255,255,255,0.95); box-shadow:0 2px 6px rgba(0,0,0,0.25);\n      transform:scale(0.95);\n    }\n    .btn.secondary {\n      background:transparent;\n      color:var(--muted);\n      border:1px solid rgba(255,255,255,0.04);\n      box-shadow:none;\n    }\n\n    /* Main scene */\n    .container{\n      max-width:1100px;\n      margin:0 auto;\n      display:grid;\n      grid-template-columns:1fr;\n      gap:28px;\n    }\n\n    .stage {\n      border-radius:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:28px;\n      position:relative;\n      overflow:hidden;\n      box-shadow: 0 12px 50px rgba(3,6,17,0.6);\n      backdrop-filter: blur(8px) saturate(130%);\n    }\n\n    /* Decorative orbs */\n    .orb{\n      position:absolute;\n      width:260px;height:260px;\n      border-radius:50%;\n      filter: blur(36px);\n      opacity:0.12;\n      transform:translate3d(0,0,0);\n    }\n    .orb.orb-1{ top:-80px; left:-40px; background: linear-gradient(135deg,#7b6cff,#3fe0c6); }\n    .orb.orb-2{ bottom:-100px; right:-40px; background: linear-gradient(135deg,#63b2ff,#7b6cff); opacity:0.08; }\n\n    /* Scene layout */\n    .scene {\n      display:flex;\n      gap:18px;\n      align-items:center;\n      justify-content:space-between;\n      height:380px;\n      position:relative;\n    }\n\n    .node {\n      width:260px;\n      min-width:260px;\n      height:260px;\n      border-radius:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);\n      padding:18px;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n      box-shadow: 0 8px 30px rgba(2,6,20,0.6);\n      position:relative;\n      transition: transform 600ms var(--soft);\n    }\n\n    .node .label {\n      font-weight:700;\n      font-size:14px;\n      letter-spacing:0.4px;\n      display:flex;\n      align-items:center;\n      gap:10px;\n    }\n    .node small {\n      color:var(--muted);\n      font-size:12px;\n    }\n    .client-illustration, .server-illustration {\n      flex:1;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n    }\n\n    .client-card {\n      width:120px;height:120px;border-radius:14px;\n      background:linear-gradient(180deg,#0f1b2b 0%, #071028 100%);\n      border:1px solid rgba(255,255,255,0.04);\n      display:flex;align-items:center;justify-content:center;\n      box-shadow:0 8px 30px rgba(2,6,20,0.7);\n      transform:translateY(0);\n      transition: transform 700ms var(--soft);\n    }\n\n    .server-stack {\n      width:140px;height:140px;border-radius:14px;\n      display:flex;flex-direction:column;gap:8px;align-items:center;justify-content:center;\n    }\n    .db {\n      width:110px;height:64px;border-radius:8px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);\n      display:flex;align-items:center;justify-content:center;flex-direction:column;\n      font-size:13px;\n      color:var(--muted);\n      box-shadow: inset 0 -6px 20px rgba(3,8,18,0.6);\n    }\n\n    /* Network lane */\n    .lane{\n      flex:1;\n      height:100%;\n      position:relative;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n    .path {\n      width:100%;\n      height:6px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      border-radius:6px;\n      position:relative;\n      overflow:visible;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:0 60px;\n    }\n\n    .path::before {\n      content:\"\";\n      position:absolute;\n      left:0;right:0;top:50%;\n      transform:translateY(-50%);\n      height:2px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.02));\n      border-radius:2px;\n    }\n\n    /* Animated request beads (very limited interactivity: button toggles) */\n    .bead {\n      position:absolute;\n      width:22px;height:22px;border-radius:50%;\n      display:inline-flex;align-items:center;justify-content:center;\n      color:#071028;font-weight:700;font-size:11px;\n      box-shadow:0 6px 20px rgba(11,21,40,0.7);\n      transform:translateY(-50%);\n      left:8%;\n    }\n    .bead.request { background: linear-gradient(90deg,#ffd66b,#ff9a86); top:calc(50% - 48px); }\n    .bead.response { background: linear-gradient(90deg,#7b6cff,#3fe0c6); top:calc(50% + 48px); left:84%; }\n\n    /* when running, animate beads across the lane */\n    .scene.running .bead.request{\n      animation: moveRequest var(--duration) linear infinite;\n      animation-delay: -1600ms;\n    }\n    .scene.running .bead.response{\n      animation: moveResponse var(--duration) linear infinite;\n      animation-delay: 0ms;\n    }\n\n    @keyframes moveRequest{\n      0%{ left:8%; opacity:0; transform:translateY(-50%) scale(.9) }\n      8%{ opacity:1; transform:translateY(-50%) scale(1) }\n      48%{ left:50%; transform:translateY(-50%) scale(0.98) }\n      92%{ left:84%; opacity:0.0; transform:translateY(-50%) scale(.85) }\n      100%{ left:100%; opacity:0 }\n    }\n    @keyframes moveResponse{\n      0%{ left:84%; opacity:0; transform:translateY(-50%) scale(.95) }\n      8%{ opacity:1; transform:translateY(-50%) scale(1) }\n      48%{ left:50%; transform:translateY(-50%) scale(0.98) }\n      92%{ left:8%; opacity:0; transform:translateY(-50%) scale(.85) }\n      100%{ left:0%; opacity:0 }\n    }\n\n    /* Flow arrows (SVG stroke animation) */\n    .flow-arrows{\n      position:absolute; inset:0; pointer-events:none;\n    }\n    .flow-arrows svg { width:100%; height:100%; overflow:visible; }\n    .flow-path { stroke:rgba(255,255,255,0.06); stroke-width:2; stroke-linecap:round; fill:none; }\n    .flow-active { stroke: url(#gradFlow); stroke-width:3.5; stroke-linecap:round; stroke-linejoin:round; stroke-dasharray: 8 6; opacity:0; }\n    .scene.running .flow-active { animation: pulseFlow 1600ms linear infinite; opacity:1; }\n\n    @keyframes pulseFlow{\n      0% { stroke-dashoffset:0; opacity:1; }\n      50% { stroke-dashoffset:30; opacity:0.9; }\n      100% { stroke-dashoffset:60; opacity:1; }\n    }\n\n    /* Cards below describing principles */\n    .principles {\n      display:grid;\n      grid-template-columns:repeat(3, 1fr);\n      gap:18px;\n      margin-top:8px;\n    }\n    .card {\n      border-radius:14px;\n      padding:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      gap:12px;\n      align-items:flex-start;\n      box-shadow: 0 8px 30px rgba(2,6,20,0.6);\n      transition: transform 600ms var(--soft), box-shadow 600ms var(--soft);\n    }\n    .card:hover { transform:translateY(-6px); box-shadow: 0 20px 60px rgba(2,6,20,0.7); }\n    .icon {\n      width:56px;height:56px;border-radius:12px;\n      display:flex;align-items:center;justify-content:center;\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      color:var(--muted);\n      font-weight:700;\n      font-size:14px;\n      flex-shrink:0;\n    }\n    .card h4 { margin:0; font-size:15px; font-weight:700; }\n    .card p { margin:6px 0 0; color:var(--muted); font-size:13px; line-height:1.45; }\n\n    /* Footer */\n    .footer {\n      max-width:1100px;\n      margin:18px auto 0;\n      color:rgba(255,255,255,0.12);\n      font-size:13px;\n      text-align:center;\n    }\n\n    /* Responsive */\n    @media (max-width:980px){\n      .scene{ flex-direction:column; height:auto; padding:28px 0; gap:22px; align-items:center; }\n      .node{ width:92%; min-width:unset; height:200px; }\n      .lane{ width:92%; }\n      .principles{ grid-template-columns:1fr; }\n      .header{ flex-direction:column; align-items:flex-start; gap:14px; }\n      .controls{ align-self:stretch; width:100%; justify-content:space-between; }\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"header\" role=\"banner\">\n    <div class=\"logo\" aria-hidden=\"true\">\n      <!-- Stylized REST symbol -->\n      <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n        <defs>\n          <linearGradient id=\"lg1\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7b6cff\"/>\n            <stop offset=\"1\" stop-color=\"#3fe0c6\"/>\n          </linearGradient>\n        </defs>\n        <rect x=\"4\" y=\"4\" width=\"56\" height=\"56\" rx=\"12\" fill=\"url(#lg1)\" opacity=\"0.14\"/>\n        <g transform=\"translate(8,8)\">\n          <rect x=\"2\" y=\"6\" width=\"18\" height=\"12\" rx=\"3\" fill=\"#ffffff\" opacity=\"0.06\"></rect>\n          <rect x=\"24\" y=\"6\" width=\"18\" height=\"12\" rx=\"3\" fill=\"#ffffff\" opacity=\"0.06\"></rect>\n          <path d=\"M22 12h6\" stroke=\"#fff\" stroke-opacity=\"0.8\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          <circle cx=\"11\" cy=\"12\" r=\"3.2\" fill=\"#fff\" opacity=\"0.9\"/>\n          <circle cx=\"33\" cy=\"12\" r=\"3.2\" fill=\"#fff\" opacity=\"0.9\"/>\n        </g>\n      </svg>\n    </div>\n    <div class=\"title-block\">\n      <h1 class=\"title\">REST API</h1>\n      <p class=\"subtitle\">Representational State Transfer — a lightweight architectural style for communication between clients and servers using stateless HTTP and resource-oriented interactions.</p>\n    </div>\n\n    <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n      <button class=\"btn\" id=\"toggleBtn\" aria-pressed=\"false\" title=\"Animate request / response flow\">\n        <span class=\"dot\" aria-hidden=\"true\"></span>\n        <span id=\"btnLabel\">Animate Flow</span>\n      </button>\n    </div>\n  </div>\n\n  <main class=\"container\" role=\"main\">\n    <section class=\"stage\" aria-labelledby=\"scene-heading\">\n      <span class=\"orb orb-1\" aria-hidden=\"true\"></span>\n      <span class=\"orb orb-2\" aria-hidden=\"true\"></span>\n\n      <div class=\"scene\" id=\"scene\" aria-hidden=\"false\">\n        <!-- Client Node -->\n        <div class=\"node client\" title=\"Client (Browser, App)\">\n          <div class=\"label\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 7h18M3 12h18M3 17h12\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n            Client\n          </div>\n          <small>Consumer: web, mobile, IoT</small>\n\n          <div class=\"client-illustration\" aria-hidden=\"true\">\n            <div class=\"client-card\" style=\"background: linear-gradient(180deg,#06101a 0%, #06111b 100%);\">\n              <svg width=\"72\" height=\"72\" viewBox=\"0 0 24 24\" fill=\"none\">\n                <path d=\"M4 7h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7z\" fill=\"rgba(255,255,255,0.04)\"></path>\n                <rect x=\"7\" y=\"9\" width=\"10\" height=\"2\" rx=\"1\" fill=\"#7b6cff\"></rect>\n                <rect x=\"7\" y=\"13\" width=\"6\" height=\"2\" rx=\"1\" fill=\"#3fe0c6\"></rect>\n              </svg>\n            </div>\n          </div>\n        </div>\n\n        <!-- Lane (network) -->\n        <div class=\"lane\" aria-hidden=\"true\">\n          <div class=\"path\" role=\"img\" aria-label=\"Network path\">\n            <div class=\"bead request\">GET</div>\n            <div class=\"bead response\">200</div>\n\n            <!-- Decorative labels -->\n            <div style=\"position:absolute; left:16%; top:6%; color:rgba(255,255,255,0.06); font-size:12px;\">HTTP</div>\n            <div style=\"position:absolute; right:16%; top:6%; color:rgba(255,255,255,0.06); font-size:12px;\">Transport</div>\n          </div>\n\n          <div class=\"flow-arrows\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 1000 380\" preserveAspectRatio=\"none\">\n              <defs>\n                <linearGradient id=\"gradFlow\" x1=\"0\" x2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#ffd66b\"/>\n                  <stop offset=\"0.5\" stop-color=\"#ff9a86\"/>\n                  <stop offset=\"1\" stop-color=\"#7b6cff\"/>\n                </linearGradient>\n              </defs>\n\n              <!-- Path from client to server -->\n              <path class=\"flow-path\" d=\"M200 190 C 360 190, 640 190, 800 190\" />\n              <path class=\"flow-active\" d=\"M200 190 C 360 190, 640 190, 800 190\" stroke-linecap=\"round\" />\n\n              <!-- small arrows -->\n              <g opacity=\"0.9\" transform=\"translate(0,0)\">\n                <polygon points=\"450,180 460,190 450,200\" fill=\"#ffd66b\" opacity=\"0.0\"></polygon>\n              </g>\n            </svg>\n          </div>\n        </div>\n\n        <!-- Server Node -->\n        <div class=\"node server\" title=\"Server (API)\">\n          <div class=\"label\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M3 5h18v14H3z\" stroke=\"rgba(255,255,255,0.9)\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n            Server\n          </div>\n          <small>API, services, database</small>\n\n          <div class=\"server-illustration\" aria-hidden=\"true\">\n            <div class=\"server-stack\" style=\"align-items:center;\">\n              <div class=\"db\">\n                <div style=\"font-size:12px; color:var(--muted);\">Database</div>\n                <div style=\"font-size:11px; margin-top:6px; color:rgba(255,255,255,0.9); font-weight:700;\">Users</div>\n              </div>\n\n              <svg width=\"62\" height=\"58\" viewBox=\"0 0 64 64\" fill=\"none\" style=\"margin-top:4px;\">\n                <rect x=\"2\" y=\"10\" width=\"60\" height=\"12\" rx=\"3\" fill=\"rgba(255,255,255,0.03)\"/>\n                <rect x=\"2\" y=\"28\" width=\"60\" height=\"12\" rx=\"3\" fill=\"rgba(255,255,255,0.03)\"/>\n                <rect x=\"2\" y=\"46\" width=\"60\" height=\"12\" rx=\"3\" fill=\"rgba(255,255,255,0.03)\"/>\n              </svg>\n            </div>\n          </div>\n        </div>\n\n      </div>\n\n      <!-- Explanation overlay -->\n      <div style=\"position:absolute; right:30px; bottom:22px; color:var(--muted); font-size:13px; max-width:420px;\">\n        <div style=\"display:flex; gap:10px; align-items:center; margin-bottom:8px;\">\n          <div style=\"width:10px;height:10px;border-radius:50%;background:#ffd66b; box-shadow:0 6px 18px rgba(255,214,107,0.08)\"></div>\n          <div style=\"font-weight:700;\">Request</div>\n        </div>\n        <div style=\"display:flex; gap:10px; align-items:center;\">\n          <div style=\"width:10px;height:10px;border-radius:50%;background:#7b6cff; box-shadow:0 6px 18px rgba(123,108,255,0.08)\"></div>\n          <div style=\"font-weight:700;\">Response</div>\n        </div>\n      </div>\n    </section>\n\n    <section>\n      <div class=\"principles\" aria-hidden=\"false\">\n        <div class=\"card\" role=\"article\" aria-label=\"Resources\">\n          <div class=\"icon\" style=\"background:linear-gradient(180deg,#7b6cff22,#3fe0c622); border:1px solid rgba(255,255,255,0.02)\">\n            R\n          </div>\n          <div>\n            <h4>Resources</h4>\n            <p>Everything is a resource identified by URIs — users, images, orders. Clients interact with representations of these resources via standard endpoints.</p>\n          </div>\n        </div>\n\n        <div class=\"card\" role=\"article\" aria-label=\"Statelessness\">\n          <div class=\"icon\" style=\"background:linear-gradient(180deg,#3fe0c622,#7b6cff22);\">\n            S\n          </div>\n          <div>\n            <h4>Stateless</h4>\n            <p>Each request from client to server contains all information needed. The server does not rely on prior interactions, enabling scalability and simplicity.</p>\n          </div>\n        </div>\n\n        <div class=\"card\" role=\"article\" aria-label=\"HTTP Verbs\">\n          <div class=\"icon\" style=\"background:linear-gradient(180deg,#ffd66b22,#ff9a8622); color:#071028;\">\n            V\n          </div>\n          <div>\n            <h4>HTTP Verbs</h4>\n            <p>Use uniform interface: GET to retrieve, POST to create, PUT/PATCH to update, DELETE to remove. Semantics give APIs clarity and predictability.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section style=\"margin-top:18px;\">\n      <div class=\"stage\" style=\"padding:18px;\">\n        <div style=\"display:flex; gap:18px; align-items:center;\">\n          <div style=\"width:64px; height:64px; border-radius:12px; display:flex; align-items:center; justify-content:center; background:linear-gradient(90deg,#7b6cff55,#3fe0c655); box-shadow: 0 10px 40px rgba(63,224,198,0.06);\">\n            <svg width=\"36\" height=\"36\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M7 11l5-5 5 5M7 13l5 5 5-5\" stroke=\"#051426\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          </div>\n          <div style=\"flex:1;\">\n            <div style=\"font-weight:700; font-size:15px; margin-bottom:6px;\">Payloads & Representations</div>\n            <div style=\"color:var(--muted); font-size:13px;\">APIs transfer representations — JSON is common for its simplicity. Responses include status codes and standardized headers to convey state and meta information.</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <div class=\"footer\" role=\"contentinfo\">\n      <div>Conceptual visualization of REST principles • Minimal, aesthetic demo • Click \"Animate Flow\" to see request/response in motion</div>\n    </div>\n  </main>\n\n  <script>\n    (function(){\n      const scene = document.getElementById('scene');\n      const btn = document.getElementById('toggleBtn');\n      const label = document.getElementById('btnLabel');\n      let running = false;\n\n      // Toggle animation state with a single button (extremely limited interactivity)\n      btn.addEventListener('click', () => {\n        running = !running;\n        scene.classList.toggle('running', running);\n        btn.setAttribute('aria-pressed', running ? 'true' : 'false');\n        label.textContent = running ? 'Pause Flow' : 'Animate Flow';\n      });\n\n      // Subtle entrance animations on load\n      window.addEventListener('load', () => {\n        document.body.style.transition = 'opacity 800ms ease';\n        document.body.style.opacity = 1;\n        // Gentle floating for nodes\n        const nodes = document.querySelectorAll('.node');\n        nodes.forEach((n,i) => {\n          n.animate([\n            { transform: 'translateY(6px)' },\n            { transform: 'translateY(0px)' }\n          ], {\n            duration: 800 + i * 120,\n            easing: 'cubic-bezier(.2,.9,.3,1)',\n            fill: 'forwards'\n          });\n        });\n      });\n    })();\n  </script>\n</body>\n</html>"
  },
