    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Heap Sort Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  input[type=\"number\"] {\n    width: 4em;\n  }\n  button {\n    margin: 0.2em 0.5em 0.2em 0;\n  }\n  #arrayVisualization {\n    white-space: pre;\n    font-size: 14px;\n    margin-top: 1em;\n    margin-bottom: 1em;\n  }\n  label {\n    font-weight: bold;\n  }\n  fieldset {\n    margin-bottom: 1em;\n  }\n  #log {\n    white-space: pre-wrap;\n    border: 1px solid #000;\n    padding: 0.5em;\n    height: 10em;\n    overflow-y: auto;\n    font-size: 13px;\n    background: #fff;\n  }\n  #stateDescription {\n    margin-bottom: 1em;\n    font-size: 14px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Heap Sort Interactive Demonstrator</h1>\n\n<fieldset>\n  <legend>Input Array</legend>\n  <label for=\"arrayInput\">Enter integers (space/comma separated): </label><br />\n  <input type=\"text\" id=\"arrayInput\" size=\"60\" aria-label=\"Array Input\" />\n  <button id=\"loadArrayBtn\">Load Array</button>\n  <button id=\"randomArrayBtn\">Random Array</button>\n  <label for=\"randomSize\">Size:</label>\n  <input type=\"number\" id=\"randomSize\" min=\"1\" max=\"30\" value=\"10\" />\n  <br />\n  <small>Max size 30 to keep visualization manageable.</small>\n</fieldset>\n\n<fieldset>\n  <legend>Heap Sort Controls</legend>\n  <button id=\"buildHeapBtn\" disabled>Build Max Heap</button>\n  <button id=\"heapifyStepBtn\" disabled>Heapify Step</button>\n  <button id=\"heapSortStepBtn\" disabled>Heap Sort Step</button>\n  <button id=\"autoHeapifyBtn\" disabled>Auto Heapify</button>\n  <button id=\"autoHeapSortBtn\" disabled>Auto Heap Sort</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n  <br />\n  <label for=\"autoDelayRange\">Auto delay (ms):</label>\n  <input type=\"range\" id=\"autoDelayRange\" min=\"50\" max=\"2000\" value=\"500\" step=\"50\" />\n  <span id=\"autoDelayDisplay\">500</span> ms\n</fieldset>\n\n<fieldset>\n  <legend>State & Explanation</legend>\n  <div id=\"stateDescription\" aria-live=\"polite\"></div>\n  <div id=\"arrayVisualization\" aria-label=\"Array Visualization\"></div>\n  <label for=\"log\">Detailed Action Log:</label>\n  <div id=\"log\" tabindex=\"0\" aria-live=\"polite\"></div>\n</fieldset>\n\n<fieldset>\n  <legend>Explore Specific Heapify or Sort</legend>\n  <label for=\"heapifyIndexInput\">Heapify Index (0-based): </label>\n  <input type=\"number\" id=\"heapifyIndexInput\" min=\"0\" value=\"0\" />\n  <button id=\"heapifyAtIndexBtn\" disabled>Heapify Index Now</button>\n  <br />\n  <label for=\"sortExtractCountInput\">Extracted Elements Count: </label>\n  <input type=\"number\" id=\"sortExtractCountInput\" min=\"0\" value=\"0\" />\n  <button id=\"sortExtractToCountBtn\" disabled>Extract to Count</button>\n</fieldset>\n\n<script>\n  (() => {\n    // State and core data structures\n    let array = [];\n    let n = 0; // length of array\n    let heapSize = 0; // size of heap during sort\n    let phase = \"loaded\"; \n    // \"loaded\" = array loaded not heapified\n    // \"builtHeap\" = max heap built\n    // \"heapSort\" = sorting started\n    // \"sorted\" = sorting finished\n    // \"autoHeapifyRunning\" = auto heapify running\n    // \"autoHeapSortRunning\" = auto heap sort running\n\n    let heapifyI = 0; // index for buildHeap maxHeapify calls\n    let sortingIndex = 0; // index of current extraction for sorting\n\n    let autoTimer = null;\n    let autoDelay = 500;\n\n    // Cached DOM\n    const arrayInputEl = document.getElementById(\"arrayInput\");\n    const loadArrayBtn = document.getElementById(\"loadArrayBtn\");\n    const randomArrayBtn = document.getElementById(\"randomArrayBtn\");\n    const randomSizeEl = document.getElementById(\"randomSize\");\n\n    const buildHeapBtn = document.getElementById(\"buildHeapBtn\");\n    const heapifyStepBtn = document.getElementById(\"heapifyStepBtn\");\n    const heapSortStepBtn = document.getElementById(\"heapSortStepBtn\");\n    const autoHeapifyBtn = document.getElementById(\"autoHeapifyBtn\");\n    const autoHeapSortBtn = document.getElementById(\"autoHeapSortBtn\");\n    const resetBtn = document.getElementById(\"resetBtn\");\n    const autoDelayRange = document.getElementById(\"autoDelayRange\");\n    const autoDelayDisplay = document.getElementById(\"autoDelayDisplay\");\n\n    const stateDescEl = document.getElementById(\"stateDescription\");\n    const arrayVisEl = document.getElementById(\"arrayVisualization\");\n    const logEl = document.getElementById(\"log\");\n\n    const heapifyIndexInput = document.getElementById(\"heapifyIndexInput\");\n    const heapifyAtIndexBtn = document.getElementById(\"heapifyAtIndexBtn\");\n    const sortExtractCountInput = document.getElementById(\"sortExtractCountInput\");\n    const sortExtractToCountBtn = document.getElementById(\"sortExtractToCountBtn\");\n\n    // Utilities\n    function log(msg) {\n      logEl.textContent += msg + \"\\n\";\n      logEl.scrollTop = logEl.scrollHeight;\n    }\n    function clearLog() {\n      logEl.textContent = \"\";\n    }\n\n    // Heap Utilities\n    // Parent, left, right\n    function parent(i) {return Math.floor((i-1)/2);}\n    function left(i) {return 2*i+1;}\n    function right(i) {return 2*i+2;}\n\n    // Swap two elements of array (heapSize respected)\n    function swap(i, j) {\n      let temp = array[i];\n      array[i] = array[j];\n      array[j] = temp;\n      log(`Swapped indices ${i} and ${j}: ${arrayToString()}`);\n    }\n\n    // Display the array alongside indexes\n    function arrayToString(highlightIndices=[]) {\n      // highlightIndices is array of indexes to emphasize with brackets []\n      // We'll mark these indices by surrounding values with []\n      return array.map((v,i) =>\n          highlightIndices.includes(i) ? \"[\"+v+\"]\" : \" \"+v+\" \"\n      ).join(\"\");\n    }\n    // Display the array as tree structure (textual)\n    function arrayToTreeString() {\n      let lines = [];\n      if (array.length === 0) return \"(empty array)\";\n      let level = 0;\n      let count = 0;\n      let nextCount = 1;\n      let line = \"\";\n      for (let i=0;i<array.length;i++) {\n        line += array[i].toString() + \" \";\n        count++;\n        if (count === nextCount) {\n          lines.push(line.trim());\n          level++;\n          count=0;\n          nextCount = 2 ** level;\n          line = \"\";\n        }\n      }\n      if (line.length) lines.push(line.trim());\n      return lines.join(\"\\n\");\n    }\n\n    // maxHeapify at index i, heapSize respected\n    // returns true if any swaps happened, else false\n    // We log detailed steps for user understanding\n    function maxHeapify(i) {\n      let l = left(i);\n      let r = right(i);\n      let largest = i;\n      let didSwap = false;\n      log(`Heapifying at index ${i} with value ${array[i]}`);\n      if (l < heapSize) {\n        log(`  Left child index ${l} value ${array[l]}`);\n        if (array[l] > array[largest]) {\n          largest = l;\n          log(`    Left child is larger than current largest (index ${i} val ${array[i]})`);\n        }\n      }\n      if (r < heapSize) {\n        log(`  Right child index ${r} value ${array[r]}`);\n        if (array[r] > array[largest]) {\n          largest = r;\n          log(`    Right child is larger than current largest (index ${largest} val ${array[largest]})`);\n        }\n      }\n      if (largest !== i) {\n        swap(i, largest);\n        didSwap = true;\n        // Recursive heapify at the largest index\n        let recursiveSwapped = maxHeapify(largest);\n        return true;\n      } else {\n        log(`  No swaps needed at index ${i}`);\n      }\n      return didSwap;\n    }\n\n    // Build max heap by calling maxHeapify starting from last internal node up to root\n    // We'll do this incrementally here for step-by-step interactivity\n    // Return true if next step is available, false if done\n    function buildHeapStep() {\n      if (heapifyI < Math.floor(heapSize/2)) {\n        log(`Building max heap step at index ${heapifyI}`);\n        maxHeapify(heapifyI);\n        heapifyI++;\n        return true;\n      }\n      return false;\n    }\n\n    // Heap sort step: swap root with last element then maxHeapify root heapSize-1 times\n    // Returns true if the step was done (sorting continues), or false if finished\n    function heapSortStep() {\n      if (sortingIndex < n-1) {\n        // Swap root and last element in heap\n        log(`Heap sort step: swapping root with element at index ${heapSize-1}`);\n        swap(0, heapSize-1);\n        heapSize--;\n        log(`Heap size reduced to ${heapSize}`);\n        maxHeapify(0);\n        sortingIndex++;\n        return true;\n      }\n      return false;\n    }\n\n    // Render the entire interface array and state\n    function renderState() {\n      // Explanation text with phase description\n      let desc = \"\";\n      if (phase === \"loaded\") {\n        desc = \"Array loaded but heap not built yet. You can build the max heap.\";\n      } else if (phase === \"buildingHeap\") {\n        desc = `Building max heap step-by-step. Current index to heapify: ${heapifyI}`;\n      } else if (phase === \"builtHeap\") {\n        desc = \"Max heap built. You can perform heap sort steps now.\";\n      } else if (phase === \"heapSorting\") {\n        desc = `Heap sort in progress. Extracted elements: ${sortingIndex}. Heap size: ${heapSize}`;\n      } else if (phase === \"sorted\") {\n        desc = \"Sorting finished. The array is sorted (ascending order).\";\n      } else if (phase === \"autoHeapifyRunning\") {\n        desc = `Auto building max heap... Current heapify index: ${heapifyI}`;\n      } else if (phase === \"autoHeapSortRunning\") {\n        desc = `Auto heap sort running... Extracted elements: ${sortingIndex}`;\n      }\n      stateDescEl.textContent = desc;\n\n      // Visual representation of the array\n      // We'll show as line with brackets around heap part\n      // heap portion will include indices 0 to heapSize-1\n      let heapPortionString = array.map((v,i) => {\n        if (i < heapSize) return `[${v}]`;\n        else return ` ${v} `;\n      }).join(\" \");\n      let indexesString = array.map((_,i) => (\" \"+i+\" \").padStart(3)).join(\" \");\n      arrayVisEl.textContent = \"Indexes: \" + indexesString + \"\\nValues:  \" + heapPortionString + \"\\n\\nHeap is demarcated by [] brackets.\";\n\n      // Enable/disable controls based on phase and state\n      buildHeapBtn.disabled = !(phase === \"loaded\");\n      heapifyStepBtn.disabled = !(phase === \"buildingHeap\");\n      heapSortStepBtn.disabled = !(phase === \"builtHeap\" || phase === \"heapSorting\");\n      autoHeapifyBtn.disabled = (phase !== \"loaded\");\n      autoHeapSortBtn.disabled = !(phase === \"builtHeap\" || phase === \"heapSorting\");\n      resetBtn.disabled = (phase === \"loaded\");\n      heapifyAtIndexBtn.disabled = (phase !== \"builtHeap\" && phase !== \"buildingHeap\" && phase !== \"loaded\");\n      sortExtractToCountBtn.disabled = !(phase === \"builtHeap\" || phase === \"heapSorting\");\n\n      // Specific inputs enabled only if array present and phase right\n      heapifyIndexInput.disabled = !(phase === \"builtHeap\" || phase === \"buildingHeap\" || phase === \"loaded\");\n      sortExtractCountInput.disabled = !(phase === \"builtHeap\" || phase === \"heapSorting\");\n\n      autoDelayRange.disabled = (phase === \"autoHeapifyRunning\" || phase === \"autoHeapSortRunning\");\n    }\n\n    // Validate and parse array input string\n    // returns array of integers or null on error\n    function parseArrayInput(str) {\n      let tokens = str.trim().split(/[\\s,]+/);\n      if (tokens.length === 0) return [];\n      let res = [];\n      for (let t of tokens) {\n        if (t === \"\") continue;\n        let num = Number(t);\n        if (Number.isNaN(num) || !Number.isInteger(num)) return null;\n        res.push(num);\n      }\n      if (res.length > 30) return null; // max limit\n      return res;\n    }\n\n    // Reset demo fully to loaded state\n    function resetAll() {\n      if (autoTimer) {\n        clearInterval(autoTimer);\n        autoTimer = null;\n      }\n      phase = \"loaded\";\n      heapifyI = 0;\n      sortingIndex = 0;\n      heapSize = array.length;\n      clearLog();\n      renderState();\n    }\n\n\n    // Button Handlers\n\n    loadArrayBtn.addEventListener(\"click\", () => {\n      let arrStr = arrayInputEl.value.trim();\n      if (!arrStr) {\n        alert(\"Input array is empty.\");\n        return;\n      }\n      let parsedArray = parseArrayInput(arrStr);\n      if (!parsedArray) {\n        alert(\"Input incorrect. Please enter up to 30 integers separated by spaces or commas.\");\n        return;\n      }\n      array = parsedArray.slice();\n      n = array.length;\n      heapSize = n;\n      phase = \"loaded\";\n      heapifyI = 0;\n      sortingIndex = 0;\n      clearLog();\n      log(`Array loaded: ${arrayToString()}`);\n      renderState();\n    });\n\n    randomArrayBtn.addEventListener(\"click\", () => {\n      let size = Number(randomSizeEl.value);\n      if (!Number.isInteger(size) || size < 1 || size > 30) {\n        alert(\"Size must be an integer between 1 and 30.\");\n        return;\n      }\n      array = [];\n      for (let i=0;i<size;i++) {\n        // random integers from 0 to 99\n        array.push(Math.floor(Math.random()*100));\n      }\n      n = size;\n      heapSize = n;\n      phase = \"loaded\";\n      heapifyI = 0;\n      sortingIndex = 0;\n      arrayInputEl.value = array.join(\" \");\n      clearLog();\n      log(`Random array generated: ${arrayToString()}`);\n      renderState();\n    });\n\n    buildHeapBtn.addEventListener(\"click\", () => {\n      if (phase !== \"loaded\") return;\n      phase = \"buildingHeap\";\n      heapifyI = Math.floor(heapSize/2) -1;\n      if (heapifyI < 0) { \n        // Already heap for array length 1 or 0\n        phase = \"builtHeap\";\n        log(\"Array too small, max heap trivially built.\");\n        renderState();\n        return;\n      }\n      log(\"Starting build max heap process...\");\n      renderState();\n    });\n\n    heapifyStepBtn.addEventListener(\"click\", () => {\n      if (phase !== \"buildingHeap\") return;\n      if (heapifyI < 0) {\n        phase = \"builtHeap\";\n        log(\"Build max heap completed.\");\n        renderState();\n        return;\n      }\n      log(`Heapify step at index ${heapifyI}`);\n      maxHeapify(heapifyI);\n      heapifyI--;\n      if (heapifyI < 0) {\n        phase = \"builtHeap\";\n        log(\"Build max heap completed.\");\n      }\n      renderState();\n    });\n\n    heapSortStepBtn.addEventListener(\"click\", () => {\n      if (!(phase === \"builtHeap\" || phase === \"heapSorting\")) return;\n      if (phase === \"builtHeap\") {\n        phase = \"heapSorting\";\n        heapSize = n;\n        sortingIndex = 0;\n        log(\"Starting heap sort process...\");\n      }\n      if (heapSize <= 1) {\n        phase = \"sorted\";\n        log(\"Heap sort finished.\");\n        renderState();\n        return;\n      }\n      let cont = heapSortStep();\n      if (!cont) {\n        phase = \"sorted\";\n        log(\"Heap sort finished.\");\n      }\n      renderState();\n    });\n\n    autoHeapifyBtn.addEventListener(\"click\", () => {\n      if (phase !== \"loaded\") return;\n      phase = \"autoHeapifyRunning\";\n      heapifyI = Math.floor(heapSize/2) - 1;\n      clearLog();\n      log(\"Auto building max heap started...\");\n      renderState();\n      autoTimer = setInterval(() => {\n        if (heapifyI < 0) {\n          clearInterval(autoTimer);\n          autoTimer = null;\n          phase = \"builtHeap\";\n          log(\"Auto build max heap completed.\");\n          renderState();\n          return;\n        }\n        log(`Auto heapify index ${heapifyI}`);\n        maxHeapify(heapifyI);\n        heapifyI--;\n        renderState();\n      }, autoDelay);\n    });\n\n    autoHeapSortBtn.addEventListener(\"click\", () => {\n      if (!(phase === \"builtHeap\" || phase === \"heapSorting\")) return;\n      if (phase === \"builtHeap\") {\n        heapSize = n;\n        sortingIndex = 0;\n        phase = \"autoHeapSortRunning\";\n        clearLog();\n        log(\"Auto heap sort started...\");\n      } else if (phase === \"heapSorting\") {\n        phase = \"autoHeapSortRunning\";\n        clearLog();\n        log(\"Auto heap sort resumed...\");\n      }\n      renderState();\n      if (autoTimer) return; // ignore if already running\n      autoTimer = setInterval(() => {\n        if (heapSize <= 1) {\n          clearInterval(autoTimer);\n          autoTimer = null;\n          phase = \"sorted\";\n          log(\"Auto heap sort ended.\");\n          renderState();\n          return;\n        }\n        heapSortStep();\n        renderState();\n      }, autoDelay);\n    });\n\n    resetBtn.addEventListener(\"click\", () => {\n      array = [];\n      n = 0;\n      heapSize = 0;\n      phase = \"loaded\";\n      heapifyI = 0;\n      sortingIndex = 0;\n      clearLog();\n      arrayInputEl.value = \"\";\n      if (autoTimer) {\n        clearInterval(autoTimer);\n        autoTimer = null;\n      }\n      renderState();\n    });\n\n    autoDelayRange.addEventListener(\"input\", (e) => {\n      autoDelay = Number(autoDelayRange.value);\n      autoDelayDisplay.textContent = autoDelay.toString();\n      if (autoTimer) {\n        clearInterval(autoTimer);\n        if (phase === \"autoHeapifyRunning\") {\n          autoTimer = setInterval(() => {\n            if (heapifyI < 0) {\n              clearInterval(autoTimer);\n              autoTimer = null;\n              phase = \"builtHeap\";\n              log(\"Auto build max heap completed.\");\n              renderState();\n              return;\n            }\n            log(`Auto heapify index ${heapifyI}`);\n            maxHeapify(heapifyI);\n            heapifyI--;\n            renderState();\n          }, autoDelay);\n        } else if (phase === \"autoHeapSortRunning\") {\n          autoTimer = setInterval(() => {\n            if (heapSize <= 1) {\n              clearInterval(autoTimer);\n              autoTimer = null;\n              phase = \"sorted\";\n              log(\"Auto heap sort ended.\");\n              renderState();\n              return;\n            }\n            heapSortStep();\n            renderState();\n          }, autoDelay);\n        }\n      }\n    });\n\n    // Specific Heapify at index user control\n    heapifyAtIndexBtn.addEventListener(\"click\", () => {\n      if (phase !== \"builtHeap\" && phase !== \"buildingHeap\" && phase !== \"loaded\") {\n        alert(\"Heapify at index only allowed when array loaded or heap built.\");\n        return;\n      }\n      let idx = Number(heapifyIndexInput.value);\n      if (!Number.isInteger(idx) || idx < 0 || idx >= heapSize) {\n        alert(`Index must be integer between 0 and ${heapSize-1}`);\n        return;\n      }\n      log(`User triggered maxHeapify at index ${idx}`);\n      maxHeapify(idx);\n      renderState();\n    });\n\n    // Extract elements to a specific count (heap sort step shortcut)\n    sortExtractToCountBtn.addEventListener(\"click\", () => {\n      if (!(phase === \"builtHeap\" || phase === \"heapSorting\")) {\n        alert(\"Heap sort extraction only allowed after heap is built.\");\n        return;\n      }\n      let count = Number(sortExtractCountInput.value);\n      if (!Number.isInteger(count) || count < 0 || count > n) {\n        alert(`Count must be integer between 0 and ${n}`);\n        return;\n      }\n      if (phase === \"builtHeap\") {\n        phase = \"heapSorting\";\n        heapSize = n;\n        sortingIndex = 0;\n        clearLog();\n        log(\"Heap sort started via extraction count shortcut.\");\n      }\n      while (sortingIndex < count && heapSize > 1) {\n        heapSortStep();\n      }\n      if (heapSize <= 1) {\n        phase = \"sorted\";\n        log(\"Heap sort finished.\");\n      }\n      renderState();\n    });\n\n    // Initial render\n    renderState();\n  })();\n</script>\n\n</body>\n</html>"
