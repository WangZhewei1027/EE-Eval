    "content": "<html>\n<head>\n    <title>Static Typing Explorer</title>\n    <script>\n        let currentExample = 0;\n        let typeSystem = 'TypeScript';\n        let strictMode = true;\n        let userCode = '';\n        let typeErrors = [];\n        let inferredTypes = {};\n        let typeAnnotations = {};\n\n        const examples = [\n            {\n                title: \"Basic Type Annotations\",\n                description: \"Explicitly declare variable types\",\n                code: `let age: number = 30;\nlet name: string = \"Alice\";\nlet isActive: boolean = true;`,\n                controls: [\n                    {type: \"checkbox\", id: \"strict1\", label: \"Strict Mode\", checked: true},\n                    {type: \"dropdown\", id: \"lang1\", label: \"Language\", options: [\"TypeScript\", \"Flow\"], value: \"TypeScript\"}\n                ]\n            },\n            {\n                title: \"Function Signatures\",\n                description: \"Type annotations for function parameters and return values\",\n                code: `function add(a: number, b: number): number {\n    return a + b;\n}\n\nconst result = add(5, \"10\");`,\n                controls: [\n                    {type: \"slider\", id: \"paramCount\", label: \"Parameters\", min: 1, max: 5, value: 2},\n                    {type: \"button\", id: \"toggleReturn\", label: \"Toggle Return Type\"}\n                ]\n            },\n            {\n                title: \"Type Inference\",\n                description: \"How types are automatically determined\",\n                code: `let inferredNumber = 42;\nlet inferredString = \"hello\";\nlet inferredArray = [1, 2, 3];`,\n                controls: [\n                    {type: \"button\", id: \"showTypes\", label: \"Show Inferred Types\"},\n                    {type: \"button\", id: \"addAnnotation\", label: \"Add Annotation\"}\n                ]\n            },\n            {\n                title: \"Union Types\",\n                description: \"Variables that can be multiple types\",\n                code: `let id: string | number;\nid = \"ABC123\";\nid = 456;`,\n                controls: [\n                    {type: \"checkbox\", id: \"strict4\", label: \"Strict Null Checks\", checked: false},\n                    {type: \"dropdown\", id: \"unionCount\", label: \"Union Members\", options: [\"2\", \"3\", \"4\"], value: \"2\"}\n                ]\n            }\n        ];\n\n        function init() {\n            loadExample(currentExample);\n            document.getElementById('prev').addEventListener('click', prevExample);\n            document.getElementById('next').addEventListener('click', nextExample);\n            document.getElementById('run').addEventListener('click', checkTypes);\n            document.getElementById('code').addEventListener('input', updateCode);\n        }\n\n        function loadExample(index) {\n            const example = examples[index];\n            document.getElementById('title').textContent = example.title;\n            document.getElementById('description').textContent = example.description;\n            document.getElementById('code').value = example.code;\n            userCode = example.code;\n            \n            const controlsDiv = document.getElementById('controls');\n            controlsDiv.innerHTML = '';\n            \n            example.controls.forEach(control => {\n                const div = document.createElement('div');\n                const label = document.createElement('label');\n                label.textContent = control.label + ': ';\n                \n                if (control.type === 'checkbox') {\n                    const input = document.createElement('input');\n                    input.type = 'checkbox';\n                    input.id = control.id;\n                    input.checked = control.checked || false;\n                    input.addEventListener('change', updateSettings);\n                    label.appendChild(input);\n                } \n                else if (control.type === 'dropdown') {\n                    const select = document.createElement('select');\n                    select.id = control.id;\n                    control.options.forEach(option => {\n                        const opt = document.createElement('option');\n                        opt.value = option;\n                        opt.textContent = option;\n                        if (option === control.value) opt.selected = true;\n                        select.appendChild(opt);\n                    });\n                    select.addEventListener('change', updateSettings);\n                    label.appendChild(select);\n                }\n                else if (control.type === 'slider') {\n                    const input = document.createElement('input');\n                    input.type = 'range';\n                    input.id = control.id;\n                    input.min = control.min;\n                    input.max = control.max;\n                    input.value = control.value;\n                    input.addEventListener('input', updateSettings);\n                    label.appendChild(input);\n                    const valueSpan = document.createElement('span');\n                    valueSpan.id = control.id + 'Value';\n                    valueSpan.textContent = control.value;\n                    div.appendChild(valueSpan);\n                }\n                else if (control.type === 'button') {\n                    const button = document.createElement('button');\n                    button.id = control.id;\n                    button.textContent = control.label;\n                    button.addEventListener('click', () => handleButton(control.id));\n                    div.appendChild(button);\n                }\n                \n                div.appendChild(label);\n                controlsDiv.appendChild(div);\n            });\n            \n            updateOutput();\n        }\n\n        function updateSettings() {\n            strictMode = document.getElementById('strict1') ? document.getElementById('strict1').checked : true;\n            typeSystem = document.getElementById('lang1') ? document.getElementById('lang1').value : 'TypeScript';\n            \n            if (document.getElementById('paramCount')) {\n                const paramCount = document.getElementById('paramCount').value;\n                document.getElementById('paramCountValue').textContent = paramCount;\n                updateFunctionParams(parseInt(paramCount));\n            }\n            \n            updateOutput();\n        }\n\n        function updateFunctionParams(count) {\n            let params = '';\n            let args = '';\n            for (let i = 0; i < count; i++) {\n                params += `param${i}: number, `;\n                args += `${i * 10}, `;\n            }\n            params = params.slice(0, -2);\n            args = args.slice(0, -2);\n            \n            userCode = `function example(${params}): number {\n    return ${args.split(',').map((_, i) => `param${i}`).join(' + ')};\n}\n\nconst result = example(${args});`;\n            document.getElementById('code').value = userCode;\n        }\n\n        function handleButton(id) {\n            if (id === 'showTypes') {\n                showInferredTypes();\n            } else if (id === 'addAnnotation') {\n                addTypeAnnotation();\n            } else if (id === 'toggleReturnType') {\n                toggleReturnType();\n            }\n        }\n\n        function showInferredTypes() {\n            inferredTypes = {\n                'inferredNumber': 'number',\n                'inferredString': 'string',\n                'inferredArray': 'number[]'\n            };\n            updateOutput();\n        }\n\n        function addTypeAnnotation() {\n            typeAnnotations = {\n                'inferredNumber': ': number',\n                'inferredString': ': string',\n                'inferredArray': ': number[]'\n            };\n            updateOutput();\n        }\n\n        function toggleReturnType() {\n            const code = document.getElementById('code').value;\n            if (code.includes(': number')) {\n                userCode = code.replace(': number', ': string');\n                userCode = userCode.replace('a + b', 'a.toString() + b.toString()');\n            } else {\n                userCode = code.replace(': string', ': number');\n                userCode = userCode.replace('a.toString() + b.toString()', 'a + b');\n            }\n            document.getElementById('code').value = userCode;\n            updateOutput();\n        }\n\n        function updateCode() {\n            userCode = document.getElementById('code').value;\n            updateOutput();\n        }\n\n        function checkTypes() {\n            // Simulate type checking\n            typeErrors = [];\n            \n            if (userCode.includes('add(5, \"10\")')) {\n                typeErrors.push(\"Argument of type 'string' is not assignable to parameter of type 'number'\");\n            }\n            \n            if (userCode.includes('let id: string | number') && strictMode) {\n                typeErrors.push(\"Type 'number' is not assignable to type 'string'\");\n            }\n            \n            updateOutput();\n        }\n\n        function updateOutput() {\n            let output = '';\n            \n            if (Object.keys(inferredTypes).length > 0) {\n                output += \"Inferred Types:\\n\";\n                for (const [varName, type] of Object.entries(inferredTypes)) {\n                    output += `${varName}: ${type}\\n`;\n                }\n                output += \"\\n\";\n            }\n            \n            if (Object.keys(typeAnnotations).length > 0) {\n                output += \"Suggested Annotations:\\n\";\n                for (const [varName, annotation] of Object.entries(typeAnnotations)) {\n                    output += `let ${varName}${annotation} = ...\\n`;\n                }\n                output += \"\\n\";\n            }\n            \n            if (typeErrors.length > 0) {\n                output += \"Type Errors:\\n\";\n                typeErrors.forEach(err => output += `❌ ${err}\\n`);\n            } else if (typeErrors.length === 0 && document.getElementById('run')?.clicked) {\n                output += \"✅ No type errors found!\";\n            }\n            \n            document.getElementById('output').textContent = output;\n        }\n\n        function nextExample() {\n            if (currentExample < examples.length - 1) {\n                currentExample++;\n                loadExample(currentExample);\n            }\n        }\n\n        function prevExample() {\n            if (currentExample > 0) {\n                currentExample--;\n                loadExample(currentExample);\n            }\n        }\n    </script>\n</head>\n<body onload=\"init()\">\n    <h1>Static Typing Explorer</h1>\n    \n    <div>\n        <button id=\"prev\">Previous</button>\n        <button id=\"next\">Next</button>\n        <span id=\"title\"></span>\n    </div>\n    \n    <p id=\"description\"></p>\n    \n    <div id=\"controls\"></div>\n    \n    <div>\n        <textarea id=\"code\" rows=\"10\" cols=\"80\"></textarea>\n    </div>\n    \n    <div>\n        <button id=\"run\">Check Types</button>\n    </div>\n    \n    <pre id=\"output\"></pre>\n    \n    <div>\n        <h3>Current Settings</h3>\n        <p>Type System: <span id=\"currentTypeSystem\">TypeScript</span></p>\n        <p>Strict Mode: <span id=\"currentStrictMode\">true</span></p>\n    </div>\n</body>\n</html>"
