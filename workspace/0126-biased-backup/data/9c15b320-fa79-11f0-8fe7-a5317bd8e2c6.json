  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>ACID Properties Interactive Simulator</title>\n  <style>\n    /* Extremely minimal styling: keep default browser look, only tiny layout tweaks */\n    body { margin: 8px; font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color: black; background: white; }\n    .container { display: flex; gap: 12px; align-items: flex-start; }\n    .column { min-width: 320px; max-width: 720px; }\n    textarea, input, select { font-family: inherit; font-size: 13px; }\n    button { font-size: 13px; }\n    .small { font-size: 12px; }\n    pre { white-space: pre-wrap; }\n    .ops-list { max-height: 180px; overflow: auto; border: 1px solid #ccc; padding: 6px; }\n    .table { border-collapse: collapse;}\n    .table td, .table th { padding: 4px 6px; border: 1px solid #ddd; }\n  </style>\n</head>\n<body>\n  <h2>ACID Properties Interactive Simulator</h2>\n  <div>\n    This simulator lets you build, run, step through and manipulate transactions to explore Atomicity, Consistency, Isolation and Durability. Create transactions, compose operations, configure isolation/durability/WAL, run multiple transactions concurrently, force crashes, recover, and inspect logs, lock tables and persisted state. Interface is intentionally plain.\n  </div>\n\n  <div style=\"margin-top:10px;\">\n    <button id=\"reset-db\">Reset DB to Default</button>\n    <button id=\"load-persisted\">Load Persisted DB</button>\n    <button id=\"export-state\">Export Current State (JSON)</button>\n    <button id=\"clear-storage\">Clear Local Storage (WAL & DB)</button>\n    <label class=\"small\"> Scheduler:\n      <select id=\"scheduler-mode\">\n        <option value=\"manual\">Manual (step)</option>\n        <option value=\"roundrobin\">Round-Robin</option>\n        <option value=\"random\">Random</option>\n        <option value=\"priority\">Priority (by ID)</option>\n      </select>\n    </label>\n    <label class=\"small\"> Auto speed (ms): <input id=\"auto-speed\" type=\"number\" value=\"500\" style=\"width:70px;\"></label>\n  </div>\n\n  <div class=\"container\" style=\"margin-top:10px;\">\n    <div class=\"column\" id=\"left-col\">\n      <h3>Create / Manage Transactions</h3>\n\n      <div>\n        <label>Transaction name: <input id=\"tx-name\" value=\"T1\"></label>\n        <label>Isolation:\n          <select id=\"tx-isolation\">\n            <option value=\"READ_UNCOMMITTED\">READ_UNCOMMITTED</option>\n            <option value=\"READ_COMMITTED\">READ_COMMITTED</option>\n            <option value=\"REPEATABLE_READ\">REPEATABLE_READ</option>\n            <option value=\"SERIALIZABLE\">SERIALIZABLE</option>\n          </select>\n        </label>\n        <label>Durability:\n          <select id=\"tx-durability\">\n            <option value=\"durable\">Durable (persist commits)</option>\n            <option value=\"non-durable\">Non-durable (memory only)</option>\n          </select>\n        </label>\n        <label>WAL:\n          <select id=\"tx-wal\">\n            <option value=\"wal\">Write-Ahead Log ON</option>\n            <option value=\"nowal\">Write-Ahead Log OFF</option>\n          </select>\n        </label>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <button id=\"create-tx\">Create Transaction</button>\n        <button id=\"spawn-random\">Spawn Random Transaction</button>\n        <button id=\"clear-txs\">Clear All Transactions</button>\n      </div>\n\n      <h4 style=\"margin-top:10px;\">Transactions</h4>\n      <div id=\"tx-list\" class=\"ops-list\" aria-live=\"polite\"></div>\n\n      <h4 style=\"margin-top:10px;\">Selected Transaction Controls</h4>\n      <div>\n        <label>Selected TX ID: <input id=\"selected-tx-id\" style=\"width:50px\"></label>\n        <button id=\"begin-tx\">Begin</button>\n        <button id=\"step-tx\">Step Next Op</button>\n        <button id=\"run-tx\">Run To End</button>\n        <button id=\"commit-tx\">Commit</button>\n        <button id=\"abort-tx\">Abort</button>\n        <button id=\"force-wait\">Force Wait (simulate lock)</button>\n      </div>\n\n      <h4 style=\"margin-top:10px;\">Build Operation</h4>\n      <div>\n        <label>Type:\n          <select id=\"op-type\">\n            <option value=\"READ\">READ</option>\n            <option value=\"WRITE\">WRITE</option>\n            <option value=\"TRANSFER\">TRANSFER</option>\n            <option value=\"ASSERT\">ASSERT (consistency check)</option>\n          </select>\n        </label>\n        <label>Key:\n          <select id=\"op-key\"><option value=\"A\">A</option><option value=\"B\">B</option><option value=\"C\">C</option><option value=\"D\">D</option></select>\n        </label>\n        <label>To Key (transfer): <select id=\"op-key-to\"><option value=\"A\">A</option><option value=\"B\">B</option><option value=\"C\">C</option><option value=\"D\">D</option></select></label>\n        <label>Amount: <input id=\"op-amount\" value=\"10\" style=\"width:70px\"></label>\n      </div>\n      <div style=\"margin-top:6px;\">\n        <button id=\"op-add\">Add Operation to Selected TX</button>\n        <button id=\"op-insert\">Insert at Cursor</button>\n        <button id=\"op-remove\">Remove Selected Op</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <label>Selected Op Index: <input id=\"selected-op-index\" style=\"width:40px\"></label>\n      </div>\n\n      <div style=\"margin-top:10px;\">\n        <button id=\"simulate-concurrent\">Simulate Scheduler Run (many txs)</button>\n        <button id=\"auto-run\">Auto Run (use scheduler)</button>\n        <button id=\"stop-auto\">Stop Auto</button>\n        <button id=\"deadlock-detect\">Detect Deadlocks</button>\n        <button id=\"resolve-deadlocks\">Resolve (abort victim)</button>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <h4>Advanced Controls</h4>\n        <label>Allow dirty reads for READ_UNCOMMITTED: <input id=\"allow-dirty\" type=\"checkbox\" checked></label>\n        <label>Enforce constraints on commit: <input id=\"enforce-constraints\" type=\"checkbox\" checked></label>\n        <label>Strict S/X locks for SERIALIZABLE: <input id=\"strict-2pl\" type=\"checkbox\" checked></label>\n        <div style=\"margin-top:6px;\">\n          <button id=\"force-crash\">Force Crash (simulate power loss)</button>\n          <button id=\"recover\">Recover</button>\n          <button id=\"inspect-wal\">Show WAL</button>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"column\" id=\"middle-col\">\n      <h3>Global Database</h3>\n      <div>\n        <strong>Accounts:</strong>\n        <table class=\"table\" id=\"accounts-table\" style=\"margin-top:6px;\">\n          <thead><tr><th>Key</th><th>Balance</th></tr></thead>\n          <tbody></tbody>\n        </table>\n      </div>\n\n      <div style=\"margin-top:10px;\">\n        <label>Initialize accounts with total sum: <input id=\"init-total\" value=\"1000\" style=\"width:80px;\"></label>\n        <label>Num accounts: <input id=\"init-count\" value=\"4\" style=\"width:50px;\"></label>\n        <button id=\"init-db\">Init DB</button>\n      </div>\n\n      <div style=\"margin-top:10px;\">\n        <strong>Persistence (localStorage):</strong>\n        <div>Persisted DB present: <span id=\"persisted-indicator\">unknown</span></div>\n        <div>WAL entries present: <span id=\"wal-indicator\">0</span></div>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <h4>Lock Table</h4>\n        <pre id=\"lock-table\" style=\"max-height:160px; overflow:auto; border:1px solid #ccc; padding:6px;\"></pre>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <h4>Write-Ahead Log (WAL)</h4>\n        <pre id=\"wal-log\" style=\"max-height:160px; overflow:auto; border:1px solid #ccc; padding:6px;\"></pre>\n      </div>\n\n    </div>\n\n    <div class=\"column\" id=\"right-col\">\n      <h3>Transaction / Execution Log</h3>\n      <div>\n        <label>Event log search: <input id=\"log-search\" style=\"width:160px;\"></label>\n        <button id=\"clear-log\">Clear Log Display</button>\n      </div>\n      <pre id=\"event-log\" style=\"max-height:760px; overflow:auto; border:1px solid #ccc; padding:6px;\"></pre>\n\n      <h4 style=\"margin-top:10px;\">Inspector</h4>\n      <div>\n        <button id=\"show-all-state\">Show Full In-Memory State</button>\n        <button id=\"show-all-pers\">Show Persisted (localStorage)</button>\n      </div>\n      <pre id=\"inspector\" style=\"max-height:220px; overflow:auto; border:1px solid #ccc; padding:6px;\"></pre>\n\n    </div>\n  </div>\n\n<script>\n/*\n  ACID Interactive Simulator\n  - In-memory DB of accounts: keys A,B,C,...\n  - Transactions: build op lists, start, step, commit, abort\n  - Isolation levels: READ_UNCOMMITTED, READ_COMMITTED, REPEATABLE_READ, SERIALIZABLE\n  - Locks: S/X lock manager\n  - WAL & durability: writes to localStorage to simulate persistence\n  - Crash & recover simulation\n  - Constraints: no negative balances, total constant\n  - Multiple transactions & scheduler\n*/\n\n(function(){\n  // ======== Utilities ========\n  function logEvent(msg, level) {\n    var el = document.getElementById('event-log');\n    var t = new Date().toISOString().substr(11,12) + \" \";\n    el.textContent = t + (level ? (\"[\" + level + \"] \") : \"\") + msg + \"\\n\" + el.textContent;\n  }\n  function setText(id, txt) { document.getElementById(id).textContent = txt; }\n  function clone(obj){ return JSON.parse(JSON.stringify(obj)); }\n  function uid(prefix){ return prefix + Math.random().toString(36).slice(2,9); }\n\n  // ======== Persistent keys ========\n  const STORAGE_DB = 'acid_sim_db';\n  const STORAGE_WAL = 'acid_sim_wal';\n\n  // ======== Global Simulator State ========\n  let inMemoryDB = {}; // key -> number\n  let persistedDB = null;\n  let walLog = []; // array of {txid, ops, committedAt}\n  let transactions = {}; // txid -> tx object\n  let txOrder = []; // maintain order\n  let locks = {}; // resource -> {mode, owners: Set(txid), queue: [{txid,mode,op}]}\n  let crashed = false;\n  let autoRunner = null;\n\n  // ======== Default DB initialization ========\n  function initDefaultDB(count, total) {\n    count = Math.max(1, Math.floor(count));\n    total = Number(total) || 1000;\n    inMemoryDB = {};\n    var base = Math.floor(total / count);\n    var remainder = total - base * count;\n    for (var i = 0; i < count; i++) {\n      var key = String.fromCharCode(65 + i); // A,B,C...\n      inMemoryDB[key] = base + (i === 0 ? remainder : 0);\n    }\n    saveIndicators();\n    logEvent(\"Initialized in-memory DB with \" + count + \" accounts, total \" + total);\n    renderAccounts();\n  }\n\n  function savePersistedDB() {\n    try {\n      localStorage.setItem(STORAGE_DB, JSON.stringify(inMemoryDB));\n    } catch (e) {\n      logEvent(\"Failed to persist DB: \" + e, \"ERROR\");\n    }\n    updateIndicators();\n  }\n\n  function loadPersistedDB() {\n    var s = localStorage.getItem(STORAGE_DB);\n    if (!s) { logEvent(\"No persisted DB found\"); return null; }\n    try {\n      persistedDB = JSON.parse(s);\n      inMemoryDB = clone(persistedDB);\n      logEvent(\"Loaded persisted DB into memory\");\n      renderAccounts();\n      updateIndicators();\n      return persistedDB;\n    } catch (e) {\n      logEvent(\"Failed to load persisted DB: \" + e, \"ERROR\");\n      return null;\n    }\n  }\n\n  function clearStorage() {\n    localStorage.removeItem(STORAGE_DB);\n    localStorage.removeItem(STORAGE_WAL);\n    walLog = [];\n    persistedDB = null;\n    updateIndicators();\n    logEvent(\"Cleared persisted storage (DB and WAL).\");\n  }\n\n  function loadWALFromStorage() {\n    var s = localStorage.getItem(STORAGE_WAL);\n    if (!s) { walLog = []; return; }\n    try {\n      walLog = JSON.parse(s) || [];\n    } catch(e) {\n      walLog = [];\n    }\n    updateIndicators();\n  }\n\n  function appendToWAL(entry, persist) {\n    walLog.push(entry);\n    if (persist) {\n      try {\n        localStorage.setItem(STORAGE_WAL, JSON.stringify(walLog));\n      } catch (e) {\n        logEvent(\"Failed to persist WAL: \" + e, \"ERROR\");\n      }\n    }\n    updateIndicators();\n    renderWAL();\n  }\n\n  function flushWAL() {\n    try {\n      localStorage.setItem(STORAGE_WAL, JSON.stringify(walLog));\n      logEvent(\"WAL flushed to localStorage.\");\n    } catch(e) {\n      logEvent(\"Failed to flush WAL: \" + e, \"ERROR\");\n    }\n    updateIndicators();\n  }\n\n  function clearWAL() {\n    walLog = [];\n    localStorage.removeItem(STORAGE_WAL);\n    updateIndicators();\n    renderWAL();\n    logEvent(\"WAL cleared.\");\n  }\n\n  function updateIndicators() {\n    var p = localStorage.getItem(STORAGE_DB) ? \"yes\" : \"no\";\n    document.getElementById('persisted-indicator').textContent = p;\n    loadWALFromStorage();\n    document.getElementById('wal-indicator').textContent = walLog.length;\n    renderWAL();\n  }\n\n  function saveIndicators() {\n    // do not auto persist DB unless commit/durability says so\n    document.getElementById('persisted-indicator').textContent = localStorage.getItem(STORAGE_DB) ? \"yes\" : \"no\";\n    document.getElementById('wal-indicator').textContent = walLog.length;\n  }\n\n  // ======== Rendering functions ========\n  function renderAccounts() {\n    var tbody = document.querySelector('#accounts-table tbody');\n    tbody.innerHTML = '';\n    var keys = Object.keys(inMemoryDB).sort();\n    for (var k of keys) {\n      var tr = document.createElement('tr');\n      var td1 = document.createElement('td'); td1.textContent = k;\n      var td2 = document.createElement('td'); td2.textContent = inMemoryDB[k];\n      tr.appendChild(td1); tr.appendChild(td2);\n      tbody.appendChild(tr);\n    }\n  }\n\n  function renderTxList() {\n    var el = document.getElementById('tx-list');\n    el.innerHTML = '';\n    for (var id of txOrder) {\n      var tx = transactions[id];\n      var div = document.createElement('div');\n      var header = document.createElement('div');\n      header.textContent = id + \" | \" + tx.name + \" | \" + tx.state + \" | iso:\" + tx.isolation + \" | dur:\" + tx.durability + \" | WAL:\" + (tx.wal ? \"ON\":\"OFF\");\n      var ops = document.createElement('div');\n      ops.style.marginLeft = '6px';\n      ops.textContent = tx.ops.map((o,i)=> (i+1)+\") \"+opToString(o)).join(\"\\n\");\n      var details = document.createElement('div');\n      details.textContent = \"pc=\" + tx.pc + \" | reads=\" + JSON.stringify(Array.from(tx.readSet || [])) + \" | writes=\" + JSON.stringify(Object.keys(tx.writes || {}));\n      details.style.marginLeft = '6px';\n      div.appendChild(header);\n      div.appendChild(ops);\n      div.appendChild(details);\n      div.style.borderTop = '1px solid #eee';\n      div.style.paddingTop = '4px';\n      el.appendChild(div);\n    }\n  }\n\n  function renderLockTable() {\n    var el = document.getElementById('lock-table');\n    var out = [];\n    for (var r in locks) {\n      var entry = locks[r];\n      out.push(\"Resource \" + r + \" | mode:\" + (entry.mode||'none') + \" | owners: \" + (entry.owners ? Array.from(entry.owners).join(\",\") : \"[]\"));\n      if (entry.queue && entry.queue.length) {\n        out.push(\"  Queue: \" + entry.queue.map(q=>q.txid+\"(\"+q.mode+\")\").join(\", \"));\n      }\n    }\n    el.textContent = out.join(\"\\n\");\n  }\n\n  function renderWAL() {\n    var el = document.getElementById('wal-log');\n    el.textContent = JSON.stringify(walLog, null, 2);\n  }\n\n  function renderInspector(obj) {\n    document.getElementById('inspector').textContent = JSON.stringify(obj, null, 2);\n  }\n\n  // ======== Transaction model ========\n  function createTransaction(name, isolation, durability, wal) {\n    var id = uid(\"TX_\");\n    transactions[id] = {\n      id: id,\n      name: name || id,\n      state: 'new', // new, active, waiting, committed, aborted\n      isolation: isolation || 'READ_COMMITTED',\n      durability: durability || 'durable',\n      wal: wal || false,\n      ops: [], // operation sequence\n      pc: 0, // next op index\n      writes: {}, // local write workspace key->value\n      readSet: new Set(),\n      locksHeld: new Set(),\n      snapshot: null, // for repeatable read\n      createdAt: Date.now()\n    };\n    txOrder.push(id);\n    renderTxList();\n    logEvent(\"Created transaction \" + id + \" (\" + name + \")\");\n    return id;\n  }\n\n  function deleteAllTransactions() {\n    transactions = {};\n    txOrder = [];\n    locks = {};\n    logEvent(\"Cleared all transactions and locks\");\n    renderTxList();\n    renderLockTable();\n  }\n\n  function opToString(o) {\n    if (!o) return '';\n    switch(o.type) {\n      case 'READ': return \"READ \" + o.key;\n      case 'WRITE': return \"WRITE \" + o.key + \" = \" + o.value;\n      case 'TRANSFER': return \"TRANSFER \" + o.from + \" -> \" + o.to + \" amt:\" + o.amount;\n      case 'ASSERT': return \"ASSERT \" + (o.expr || 'constraint');\n      default: return JSON.stringify(o);\n    }\n  }\n\n  // ======== Lock manager ========\n  function ensureLockResource(r) {\n    if (!locks[r]) locks[r] = {mode: null, owners: new Set(), queue: []};\n  }\n\n  function compatible(existingMode, requestMode, owners, requester) {\n    // shared (S) compatible with other S.\n    if (!existingMode) return true;\n    if (existingMode === 'S' && requestMode === 'S') {\n      // multiple S owners allowed\n      return true;\n    }\n    // otherwise exclusive conflicts except if the only owner is the requester and upgrading?\n    if (owners.size === 1 && owners.has(requester)) {\n      // same owner requesting upgrade possible (treat as compatible)\n      return true;\n    }\n    return false;\n  }\n\n  function acquireLock(txid, resource, mode, op) {\n    ensureLockResource(resource);\n    var entry = locks[resource];\n    if (compatible(entry.mode, mode, entry.owners, txid)) {\n      // grant\n      entry.mode = entry.mode || mode;\n      entry.owners.add(txid);\n      transactions[txid].locksHeld.add(resource);\n      logEvent(txid + \" acquired \" + mode + \" lock on \" + resource);\n      renderLockTable();\n      return true;\n    } else {\n      // enqueue\n      entry.queue.push({txid: txid, mode: mode, op: op});\n      transactions[txid].state = 'waiting';\n      logEvent(txid + \" waiting for \" + mode + \" lock on \" + resource);\n      renderLockTable();\n      return false;\n    }\n  }\n\n  function releaseLocks(txid) {\n    var tx = transactions[txid];\n    if (!tx) return;\n    for (var r of Array.from(tx.locksHeld)) {\n      var entry = locks[r];\n      if (!entry) continue;\n      entry.owners.delete(txid);\n      if (entry.owners.size === 0) {\n        entry.mode = null;\n      }\n      tx.locksHeld.delete(r);\n      // try to grant queued requests in order\n      while (entry.queue.length) {\n        var q = entry.queue[0];\n        if (compatible(entry.mode, q.mode, entry.owners, q.txid)) {\n          entry.queue.shift();\n          entry.mode = entry.mode || q.mode;\n          entry.owners.add(q.txid);\n          transactions[q.txid].locksHeld.add(r);\n          if (transactions[q.txid].state === 'waiting') transactions[q.txid].state = 'active';\n          logEvent(q.txid + \" granted queued \" + q.mode + \" lock on \" + r);\n        } else break;\n      }\n    }\n    renderLockTable();\n  }\n\n  // ======== Operation execution ========\n  function readValueVisibleTo(tx, key) {\n    // Respect isolation\n    if (tx.writes.hasOwnProperty(key)) return tx.writes[key];\n    if (tx.isolation === 'READ_UNCOMMITTED') {\n      // may read uncommitted writes from other txs if allowed\n      var allowDirty = document.getElementById('allow-dirty').checked;\n      if (allowDirty && document.getElementById('tx-isolation').value === 'READ_UNCOMMITTED') {\n        // but per transaction-level selection we should check others; implement: find latest uncommitted write\n      }\n      // We'll implement RU as: reads current inMemoryDB plus any uncommitted writes from any active txn (non-serializable)\n      for (var id of txOrder) {\n        var other = transactions[id];\n        if (other && other !== tx && other.state === 'active') {\n          if (other.writes.hasOwnProperty(key)) return other.writes[key];\n        }\n      }\n      return inMemoryDB[key];\n    }\n    if (tx.isolation === 'READ_COMMITTED') {\n      // read committed: inMemoryDB contains committed state\n      return inMemoryDB[key];\n    }\n    if (tx.isolation === 'REPEATABLE_READ') {\n      // use snapshot created on begin\n      if (tx.snapshot && tx.snapshot.hasOwnProperty(key)) return tx.snapshot[key];\n      return inMemoryDB[key];\n    }\n    if (tx.isolation === 'SERIALIZABLE') {\n      // assume strict 2PL: we will attempt to acquire S lock before read then read from inMemoryDB + own workspace\n      return inMemoryDB[key];\n    }\n    return inMemoryDB[key];\n  }\n\n  function executeOperation(txid) {\n    if (crashed) return {ok:false, msg:\"System crashed, cannot execute\"};\n    var tx = transactions[txid];\n    if (!tx) return {ok:false, msg:\"No such tx\"};\n    if (tx.state === 'aborted' || tx.state === 'committed') return {ok:false, msg:\"TX not active\"};\n    if (tx.pc >= tx.ops.length) {\n      tx.state = 'active';\n      return {ok:true, msg:\"No more ops\"};\n    }\n    var op = tx.ops[tx.pc];\n    logEvent(txid + \" executing op #\" + (tx.pc+1) + \" : \" + opToString(op));\n    // For Serializable or strict lock modes, attempt to acquire locks as needed\n    var strict2pl = document.getElementById('strict-2pl').checked;\n    var needX = false, needS = false;\n    if (op.type === 'READ') needS = true;\n    if (op.type === 'WRITE' || op.type === 'TRANSFER') needX = true;\n    if (tx.isolation === 'SERIALIZABLE' && strict2pl) {\n      if (needS) {\n        var ok = acquireLock(txid, op.key, 'S', op);\n        if (!ok) return {ok:false, msg:\"blocked on lock\"};\n      }\n      if (needX) {\n        // for transfer, acquire X on both resources\n        if (op.type === 'TRANSFER') {\n          var ok1 = acquireLock(txid, op.from, 'X', op);\n          var ok2 = acquireLock(txid, op.to, 'X', op);\n          if (!ok1 || !ok2) return {ok:false, msg:\"blocked on lock\"};\n        } else {\n          var ok = acquireLock(txid, op.key, 'X', op);\n          if (!ok) return {ok:false, msg:\"blocked on lock\"};\n        }\n      }\n    } else {\n      // for other isolation levels we may still acquire X locks for writes to prevent lost updates\n      if (needX) {\n        if (op.type === 'TRANSFER') {\n          var ok1 = acquireLock(txid, op.from, 'X', op);\n          var ok2 = acquireLock(txid, op.to, 'X', op);\n          if (!ok1 || !ok2) return {ok:false, msg:\"blocked on lock\"};\n        } else {\n          var ok = acquireLock(txid, op.key, 'X', op);\n          if (!ok) return {ok:false, msg:\"blocked on lock\"};\n        }\n      }\n    }\n\n    // Execute op logic (operate on tx.writes, not global DB)\n    try {\n      if (op.type === 'READ') {\n        var val = readValueVisibleTo(tx, op.key);\n        tx.readSet.add(op.key);\n        logEvent(txid + \" READ \" + op.key + \" => \" + (val === undefined ? 'NULL' : val));\n      } else if (op.type === 'WRITE') {\n        // write into local workspace\n        tx.writes[op.key] = Number(op.value);\n        tx.readSet.add(op.key);\n        logEvent(txid + \" WRITE local \" + op.key + \" = \" + op.value);\n      } else if (op.type === 'TRANSFER') {\n        var fromVal = tx.writes.hasOwnProperty(op.from) ? tx.writes[op.from] : readValueVisibleTo(tx, op.from);\n        var toVal = tx.writes.hasOwnProperty(op.to) ? tx.writes[op.to] : readValueVisibleTo(tx, op.to);\n        fromVal = Number(fromVal || 0);\n        toVal = Number(toVal || 0);\n        var amt = Number(op.amount);\n        tx.writes[op.from] = fromVal - amt;\n        tx.writes[op.to] = toVal + amt;\n        tx.readSet.add(op.from); tx.readSet.add(op.to);\n        logEvent(txid + \" TRANSFER local: \" + op.from + \": \" + fromVal + \" -> \" + tx.writes[op.from] + \" ; \" + op.to + \": \" + toVal + \" -> \" + tx.writes[op.to]);\n      } else if (op.type === 'ASSERT') {\n        // evaluate simple asserts: support expr \"SUM==1000\" or \"NO_NEGATIVE\"\n        if (op.expr === 'NO_NEGATIVE') {\n          // check that applying local writes to DB results in no negative\n          var simulated = clone(inMemoryDB);\n          for (var k in tx.writes) simulated[k] = tx.writes[k];\n          for (var k in simulated) if (simulated[k] < 0) throw new Error(\"Negative balance detected for \" + k);\n          logEvent(txid + \" ASSERT NO_NEGATIVE passed\");\n        } else if (op.expr && op.expr.startsWith('SUM==')) {\n          var target = Number(op.expr.split('==')[1]);\n          var simulated = clone(inMemoryDB);\n          for (var k in tx.writes) simulated[k] = tx.writes[k];\n          var sum = 0; for (var k in simulated) sum += Number(simulated[k] || 0);\n          if (sum !== target) throw new Error(\"SUM check failed: \" + sum + \" != \" + target);\n          logEvent(txid + \" ASSERT SUM== passed\");\n        } else {\n          logEvent(txid + \" ASSERT no-op\");\n        }\n      } else {\n        logEvent(txid + \" Unknown op: \" + JSON.stringify(op), \"WARN\");\n      }\n    } catch(e) {\n      tx.state = 'aborted';\n      releaseLocks(txid);\n      logEvent(txid + \" aborted during op: \" + e.message, \"ERROR\");\n      return {ok:false, msg:\"operation error: \" + e.message};\n    }\n\n    tx.pc++;\n    return {ok:true, msg:\"op executed\"};\n  }\n\n  // ======== Commit / Abort ========\n  function validateConstraints(simulated) {\n    // Enforce \"no negative\" and total sum constant if enforce-constraints checked\n    if (!document.getElementById('enforce-constraints').checked) return {ok:true};\n    for (var k in simulated) {\n      if (simulated[k] < 0) return {ok:false, msg:\"Constraint violated: negative balance \" + k};\n    }\n    // total sum must equal initial persisted or initial total; if persisted DB exists, use that initial total\n    var initialTotal = 0;\n    // compute initial from persisted DB if available, else from current inMemoryDB plus applied txs? We'll use current in-memory baseline before applying simulated changes\n    // For simplicity, track that transfers should preserve sum; if simulated sum differs from current DB sum, and there's no creation, flag violation.\n    var currentSum = 0;\n    for (var k in inMemoryDB) currentSum += Number(inMemoryDB[k] || 0);\n    var newSum = 0;\n    for (var k in simulated) newSum += Number(simulated[k] || 0);\n    if (Math.abs(newSum - currentSum) > 0.0001) {\n      return {ok:false, msg:\"Constraint violated: total sum changed from \" + currentSum + \" to \" + newSum};\n    }\n    return {ok:true};\n  }\n\n  function commitTransaction(txid) {\n    if (crashed) { logEvent(\"Cannot commit while crashed\", \"ERROR\"); return; }\n    var tx = transactions[txid];\n    if (!tx || tx.state === 'committed' || tx.state === 'aborted') return;\n    // For atomicity: assemble simulated DB\n    var simulated = clone(inMemoryDB);\n    for (var k in tx.writes) simulated[k] = tx.writes[k];\n    // Validate constraints\n    var v = validateConstraints(simulated);\n    if (!v.ok) {\n      tx.state = 'aborted';\n      releaseLocks(txid);\n      logEvent(txid + \" commit failed: \" + v.msg, \"ERROR\");\n      return;\n    }\n    // WAL handling\n    if (tx.wal && tx.durability === 'durable') {\n      // write WAL record synchronously (simulate)\n      var walEntry = {txid: txid, ops: clone(tx.writes), committedAt: Date.now()};\n      appendToWAL(walEntry, true);\n      logEvent(txid + \" wrote WAL entry (durable) before applying\");\n    } else if (tx.wal && tx.durability === 'non-durable') {\n      // write WAL but not persisted across crash\n      var walEntry = {txid: txid, ops: clone(tx.writes), committedAt: Date.now()};\n      appendToWAL(walEntry, false);\n      logEvent(txid + \" wrote WAL entry (memory only) before applying\");\n    }\n\n    // Apply changes atomically to inMemoryDB\n    for (var k in tx.writes) {\n      inMemoryDB[k] = tx.writes[k];\n    }\n\n    // If durable, persist DB\n    if (tx.durability === 'durable') {\n      savePersistedDB();\n      // Optionally flush WAL\n      if (tx.wal) flushWAL();\n    }\n\n    tx.state = 'committed';\n    releaseLocks(txid);\n    logEvent(txid + \" committed successfully. Applied writes: \" + JSON.stringify(tx.writes));\n    renderAccounts();\n    updateIndicators();\n  }\n\n  function abortTransaction(txid, reason) {\n    var tx = transactions[txid];\n    if (!tx) return;\n    tx.state = 'aborted';\n    tx.writes = {};\n    releaseLocks(txid);\n    logEvent(txid + \" aborted. \" + (reason || \"\"));\n    renderTxList();\n  }\n\n  // ======== Scheduler / Execution orchestration ========\n  function schedulerStep() {\n    if (crashed) return;\n    var mode = document.getElementById('scheduler-mode').value;\n    // pick one active transaction to step\n    var activeTxs = txOrder.filter(id => transactions[id] && transactions[id].state !== 'committed' && transactions[id].state !== 'aborted');\n    if (!activeTxs.length) {\n      logEvent(\"No active transactions to schedule\");\n      return;\n    }\n    var pickId = null;\n    if (mode === 'manual') {\n      logEvent(\"Manual scheduler: use Step buttons\");\n      return;\n    } else if (mode === 'roundrobin') {\n      // rotate order\n      pickId = activeTxs[0];\n      // rotate order: find first non-waiting or waiting?\n      for (var id of activeTxs) {\n        if (transactions[id].state === 'active') { pickId = id; break; }\n      }\n    } else if (mode === 'random') {\n      pickId = activeTxs[Math.floor(Math.random()*activeTxs.length)];\n    } else if (mode === 'priority') {\n      pickId = activeTxs.sort()[0];\n    } else {\n      pickId = activeTxs[0];\n    }\n\n    var tx = transactions[pickId];\n    if (!tx) return;\n    if (tx.state === 'waiting') {\n      logEvent(pickId + \" is waiting; scheduler skipping\");\n      return;\n    }\n    if (tx.pc >= tx.ops.length) {\n      // no ops; try to auto-commit\n      if (tx.state !== 'committed' && tx.state !== 'aborted') {\n        logEvent(pickId + \" has no remaining ops; auto-committing\");\n        commitTransaction(pickId);\n      }\n      return;\n    }\n    var res = executeOperation(pickId);\n    if (!res.ok && res.msg && res.msg.indexOf('blocked') >= 0) {\n      // blocked on locks\n    } else if (!res.ok) {\n      // operation failure caused abort inside executeOperation\n      logEvent(\"Execution error for \" + pickId + \": \" + res.msg, \"ERROR\");\n    } else {\n      // op executed successfully\n      if (transactions[pickId].pc >= transactions[pickId].ops.length) {\n        // finished ops - auto commit\n        logEvent(pickId + \" finished ops; auto-committing\");\n        commitTransaction(pickId);\n      }\n    }\n    renderTxList();\n    renderLockTable();\n  }\n\n  // ======== Crash & Recovery ========\n  function forceCrash() {\n    crashed = true;\n    // simulate power loss: in-memory transactions and locks lost, but persistent WAL and persisted DB remain in localStorage\n    logEvent(\"FORCED CRASH: in-memory state frozen. Transactions cannot run until recovery.\");\n    // do NOT clear WAL or persisted DB\n  }\n\n  function recoverSystem() {\n    if (!crashed) { logEvent(\"System not crashed; recovery is a no-op\"); return; }\n    // reload persisted DB into memory (the durable baseline)\n    var persisted = localStorage.getItem(STORAGE_DB);\n    if (persisted) {\n      try {\n        inMemoryDB = JSON.parse(persisted);\n        logEvent(\"Recovered DB from persisted storage.\");\n      } catch(e) {\n        logEvent(\"Failed to parse persisted DB: \" + e, \"ERROR\");\n      }\n    } else {\n      logEvent(\"No persisted DB to restore; starting with existing in-memory if any\");\n    }\n    // Reapply WAL entries to bring DB to committed state\n    var wal = localStorage.getItem(STORAGE_WAL);\n    if (wal) {\n      try {\n        var entries = JSON.parse(wal) || [];\n        for (var e of entries) {\n          // apply op map\n          for (var k in e.ops) inMemoryDB[k] = e.ops[k];\n          logEvent(\"Reapplied WAL for \" + e.txid + \" at recovery\");\n        }\n      } catch(e) {\n        logEvent(\"Failed to apply WAL: \" + e, \"ERROR\");\n      }\n    } else {\n      logEvent(\"No WAL present on recovery.\");\n    }\n    // Reset transient state\n    transactions = {};\n    txOrder = [];\n    locks = {};\n    crashed = false;\n    logEvent(\"Recovery complete. In-memory transactions cleared; start new transactions.\");\n    renderAccounts();\n    renderLockTable();\n    renderWAL();\n    renderTxList();\n    updateIndicators();\n  }\n\n  // ======== Deadlock detection ========\n  function detectDeadlocks() {\n    // Build wait-for graph: if tx is waiting for resource r whose owners are set O, then edges tx -> owner\n    var graph = {};\n    for (var id of txOrder) graph[id] = new Set();\n    for (var r in locks) {\n      var entry = locks[r];\n      if (entry.queue && entry.queue.length) {\n        for (var q of entry.queue) {\n          var waiting = q.txid;\n          for (var owner of entry.owners) {\n            graph[waiting].add(owner);\n          }\n        }\n      }\n    }\n    // detect cycles via DFS\n    var visited = {}, stack = {};\n    var cycles = [];\n    function dfs(n, path) {\n      visited[n] = true; stack[n] = true; path.push(n);\n      for (let m of graph[n]) {\n        if (!visited[m]) dfs(m, path);\n        else if (stack[m]) {\n          // found cycle; extract\n          var idx = path.indexOf(m);\n          if (idx >= 0) cycles.push(path.slice(idx).concat([m]));\n        }\n      }\n      stack[n] = false; path.pop();\n    }\n    for (var n in graph) if (!visited[n]) dfs(n, []);\n    if (cycles.length) {\n      logEvent(\"Deadlock(s) detected: \" + JSON.stringify(cycles), \"WARN\");\n      return cycles;\n    } else {\n      logEvent(\"No deadlocks detected\");\n      return [];\n    }\n  }\n\n  function resolveDeadlocks() {\n    var cycles = detectDeadlocks();\n    if (!cycles.length) return;\n    // choose victim: abort the youngest tx (largest createdAt) in the first cycle\n    var cycle = cycles[0];\n    var victim = null; var maxCreated = -1;\n    for (var id of cycle) {\n      var t = transactions[id];\n      if (t && t.createdAt > maxCreated) { victim = id; maxCreated = t.createdAt; }\n    }\n    if (victim) {\n      abortTransaction(victim, \"Aborted to resolve deadlock\");\n      logEvent(\"Aborted \" + victim + \" as deadlock victim\");\n    }\n  }\n\n  // ======== UI wiring ========\n  function wireUI() {\n    document.getElementById('reset-db').addEventListener('click', function(){\n      initDefaultDB(4,1000);\n      clearWAL();\n    });\n    document.getElementById('load-persisted').addEventListener('click', function(){ loadPersistedDB(); });\n    document.getElementById('init-db').addEventListener('click', function(){\n      var total = Number(document.getElementById('init-total').value);\n      var count = Number(document.getElementById('init-count').value);\n      initDefaultDB(count, total);\n    });\n    document.getElementById('export-state').addEventListener('click', function(){\n      var s = {inMemoryDB: inMemoryDB, wal: walLog, transactions: transactions};\n      var blob = \"data:application/json;charset=utf-8,\" + encodeURIComponent(JSON.stringify(s, null, 2));\n      window.open(blob, \"_blank\");\n    });\n    document.getElementById('clear-storage').addEventListener('click', function(){ clearStorage(); });\n\n    document.getElementById('create-tx').addEventListener('click', function(){\n      var name = document.getElementById('tx-name').value;\n      var iso = document.getElementById('tx-isolation').value;\n      var dur = document.getElementById('tx-durability').value;\n      var wal = document.getElementById('tx-wal').value === 'wal';\n      var id = createTransaction(name, iso, dur, wal);\n      renderTxList();\n    });\n    document.getElementById('spawn-random').addEventListener('click', function(){\n      // spawn a transaction with random operations\n      var names = ['Alice','Bob','Cart','Delta','Echo'];\n      var name = names[Math.floor(Math.random()*names.length)];\n      var iso = ['READ_UNCOMMITTED','READ_COMMITTED','REPEATABLE_READ','SERIALIZABLE'][Math.floor(Math.random()*4)];\n      var dur = Math.random() < 0.6 ? 'durable' : 'non-durable';\n      var wal = Math.random() < 0.7;\n      var id = createTransaction(name, iso, dur, wal);\n      // add random ops\n      var keys = Object.keys(inMemoryDB);\n      for (var i=0;i<3;i++) {\n        var t = Math.random();\n        if (t < 0.4) {\n          transactions[id].ops.push({type:'READ', key: keys[Math.floor(Math.random()*keys.length)]});\n        } else if (t < 0.7) {\n          transactions[id].ops.push({type:'TRANSFER', from: keys[Math.floor(Math.random()*keys.length)], to: keys[Math.floor(Math.random()*keys.length)], amount: Math.floor(Math.random()*50)});\n        } else {\n          var key = keys[Math.floor(Math.random()*keys.length)];\n          transactions[id].ops.push({type:'WRITE', key: key, value: Math.floor(Math.random()*200)});\n        }\n      }\n      renderTxList();\n    });\n\n    document.getElementById('clear-txs').addEventListener('click', function(){ deleteAllTransactions(); });\n\n    document.getElementById('selected-tx-id').addEventListener('change', function(){\n      // no-op\n    });\n\n    document.getElementById('begin-tx').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      if (!transactions[id]) { logEvent(\"No such tx: \" + id); return;}\n      var tx = transactions[id];\n      if (tx.state === 'new') {\n        tx.state = 'active';\n        tx.pc = 0;\n        tx.writes = {};\n        tx.readSet = new Set();\n        tx.locksHeld = new Set();\n        if (tx.isolation === 'REPEATABLE_READ') {\n          tx.snapshot = clone(inMemoryDB);\n          logEvent(id + \" snapshot created for REPEATABLE_READ\");\n        }\n        logEvent(\"Transaction \" + id + \" begun\");\n        renderTxList();\n      } else logEvent(\"Transaction \" + id + \" already started or finished\");\n    });\n\n    document.getElementById('step-tx').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      if (!transactions[id]) { logEvent(\"No such tx: \" + id); return;}\n      var res = executeOperation(id);\n      if (!res.ok) logEvent(\"Step result: \" + res.msg, \"INFO\");\n      if (transactions[id].pc >= transactions[id].ops.length && transactions[id].state === 'active') {\n        logEvent(id + \" finished operations (manual); not auto-committing unless user requests\");\n      }\n      renderTxList();\n      renderLockTable();\n      renderAccounts();\n    });\n\n    document.getElementById('run-tx').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      if (!transactions[id]) { logEvent(\"No such tx: \" + id); return;}\n      // step until complete or blocked\n      var count = 0;\n      while (transactions[id] && transactions[id].pc < transactions[id].ops.length && transactions[id].state === 'active' && count < 500) {\n        var res = executeOperation(id);\n        if (!res.ok) { break; }\n        count++;\n      }\n      if (transactions[id] && transactions[id].pc >= transactions[id].ops.length) logEvent(id + \" reached end of ops; auto-commit invoked\");\n      if (transactions[id] && transactions[id].state === 'active') {\n        commitTransaction(id);\n      }\n      renderTxList();\n      renderAccounts();\n    });\n\n    document.getElementById('commit-tx').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      commitTransaction(id);\n      renderTxList();\n      renderAccounts();\n    });\n\n    document.getElementById('abort-tx').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      abortTransaction(id, \"Manual abort\");\n      renderTxList();\n    });\n\n    document.getElementById('op-add').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      if (!transactions[id]) { logEvent(\"Select a transaction to add ops\"); return; }\n      var type = document.getElementById('op-type').value;\n      var key = document.getElementById('op-key').value;\n      var keyTo = document.getElementById('op-key-to').value;\n      var amount = Number(document.getElementById('op-amount').value);\n      var op = null;\n      if (type === 'READ') op = {type:'READ', key: key};\n      if (type === 'WRITE') op = {type:'WRITE', key: key, value: amount};\n      if (type === 'TRANSFER') op = {type:'TRANSFER', from: key, to: keyTo, amount: amount};\n      if (type === 'ASSERT') {\n        // allow simple selects for assert\n        op = {type:'ASSERT', expr: (document.getElementById('op-amount').value === \"0\" ? 'NO_NEGATIVE' : ('SUM==' + Number(document.getElementById('op-amount').value)))};\n      }\n      transactions[id].ops.push(op);\n      logEvent(\"Added op to \" + id + \": \" + opToString(op));\n      renderTxList();\n    });\n\n    document.getElementById('op-insert').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      if (!transactions[id]) { logEvent(\"Select a transaction to insert ops\"); return; }\n      var idx = Number(document.getElementById('selected-op-index').value) - 1;\n      if (isNaN(idx) || idx < 0) idx = transactions[id].ops.length;\n      var type = document.getElementById('op-type').value;\n      var key = document.getElementById('op-key').value;\n      var keyTo = document.getElementById('op-key-to').value;\n      var amount = Number(document.getElementById('op-amount').value);\n      var op = null;\n      if (type === 'READ') op = {type:'READ', key: key};\n      if (type === 'WRITE') op = {type:'WRITE', key: key, value: amount};\n      if (type === 'TRANSFER') op = {type:'TRANSFER', from: key, to: keyTo, amount: amount};\n      if (type === 'ASSERT') op = {type:'ASSERT', expr: (amount===0?'NO_NEGATIVE':'SUM=='+amount)};\n      transactions[id].ops.splice(idx, 0, op);\n      logEvent(\"Inserted op into \" + id + \" at \" + (idx+1) + \": \" + opToString(op));\n      renderTxList();\n    });\n\n    document.getElementById('op-remove').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      if (!transactions[id]) { logEvent(\"Select a transaction to remove ops\"); return; }\n      var idx = Number(document.getElementById('selected-op-index').value) - 1;\n      if (isNaN(idx) || idx < 0 || idx >= transactions[id].ops.length) { logEvent(\"Invalid op index\"); return; }\n      var removed = transactions[id].ops.splice(idx,1);\n      logEvent(\"Removed op from \" + id + \": \" + opToString(removed[0]));\n      renderTxList();\n    });\n\n    document.getElementById('force-wait').addEventListener('click', function(){\n      var id = document.getElementById('selected-tx-id').value;\n      if (!transactions[id]) return;\n      transactions[id].state = 'waiting';\n      logEvent(id + \" manually forced to waiting\");\n      renderTxList();\n    });\n\n    document.getElementById('simulate-concurrent').addEventListener('click', function(){\n      // spawn several txs and run scheduler for some steps\n      for (var i=0;i<4;i++) {\n        var id = createTransaction(\"sim\"+i, ['READ_COMMITTED','SERIALIZABLE','REPEATABLE_READ','READ_UNCOMMITTED'][i%4], Math.random()<0.5?'durable':'non-durable', Math.random()<0.6);\n        // build a transfer chain to create conflicts\n        var keys = Object.keys(inMemoryDB);\n        transactions[id].ops.push({type:'TRANSFER', from: keys[i%keys.length], to: keys[(i+1)%keys.length], amount: 30});\n        transactions[id].ops.push({type:'READ', key: keys[(i+2)%keys.length]});\n        transactions[id].ops.push({type:'ASSERT', expr: 'NO_NEGATIVE'});\n        transactions[id].state = 'active';\n      }\n      // run scheduler for a number of steps\n      var steps = 30;\n      for (var s=0;s<steps;s++) schedulerStep();\n      renderTxList();\n      renderAccounts();\n    });\n\n    document.getElementById('auto-run').addEventListener('click', function(){\n      if (autoRunner) { logEvent(\"Auto-run already active\"); return; }\n      var speed = Number(document.getElementById('auto-speed').value) || 500;\n      autoRunner = setInterval(function(){\n        var mode = document.getElementById('scheduler-mode').value;\n        if (mode === 'manual') return;\n        schedulerStep();\n      }, speed);\n      logEvent(\"Auto-run started at speed \" + speed + \"ms\");\n    });\n    document.getElementById('stop-auto').addEventListener('click', function(){\n      if (autoRunner) { clearInterval(autoRunner); autoRunner = null; logEvent(\"Auto-run stopped\"); }\n    });\n\n    document.getElementById('deadlock-detect').addEventListener('click', function(){ detectDeadlocks(); });\n    document.getElementById('resolve-deadlocks').addEventListener('click', function(){ resolveDeadlocks(); });\n\n    document.getElementById('force-crash').addEventListener('click', function(){ forceCrash(); });\n    document.getElementById('recover').addEventListener('click', function(){ recoverSystem(); });\n    document.getElementById('inspect-wal').addEventListener('click', function(){ renderWAL(); });\n\n    document.getElementById('show-all-state').addEventListener('click', 