  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Dijkstra's Algorithm Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        #graph-container { margin: 20px 0; }\n        #graph { border: 1px solid #000; }\n        .control-group { margin: 10px 0; padding: 10px; border: 1px solid #ccc; }\n        button, input, select { margin: 5px; }\n        table { border-collapse: collapse; margin: 10px 0; }\n        th, td { border: 1px solid #000; padding: 5px; text-align: center; }\n        .node { cursor: pointer; }\n        .edge { stroke: #000; }\n        .visited { stroke: #000; stroke-width: 3px; }\n        .path { stroke: #000; stroke-width: 4px; }\n        .distance { font-size: 10px; }\n    </style>\n</head>\n<body>\n    <h1>Dijkstra's Algorithm Interactive Demo</h1>\n    \n    <div class=\"control-group\">\n        <h2>Graph Construction</h2>\n        <div>\n            <button id=\"add-node\">Add Node</button>\n            <button id=\"add-edge\">Add Edge (select two nodes)</button>\n            <button id=\"clear-graph\">Clear Graph</button>\n            <button id=\"random-graph\">Generate Random Graph</button>\n        </div>\n        <div>\n            <label>Edge Weight: <input type=\"number\" id=\"edge-weight\" min=\"1\" value=\"1\"></label>\n            <label>Random Nodes: <input type=\"number\" id=\"random-nodes\" min=\"2\" max=\"15\" value=\"5\"></label>\n            <label>Random Edges: <input type=\"number\" id=\"random-edges\" min=\"1\" max=\"50\" value=\"8\"></label>\n        </div>\n    </div>\n    \n    <div class=\"control-group\">\n        <h2>Algorithm Controls</h2>\n        <div>\n            <label>Start Node: <select id=\"start-node\"></select></label>\n            <label>Target Node: <select id=\"target-node\"></select></label>\n            <button id=\"run-algorithm\">Run Dijkstra's</button>\n            <button id=\"step-algorithm\">Step Through</button>\n            <button id=\"reset-algorithm\">Reset Visualization</button>\n        </div>\n        <div>\n            <label>Animation Speed: <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\"></label>\n        </div>\n    </div>\n    \n    <div id=\"graph-container\">\n        <svg id=\"graph\" width=\"600\" height=\"400\"></svg>\n    </div>\n    \n    <div class=\"control-group\">\n        <h2>Algorithm State</h2>\n        <div id=\"algorithm-state\">Ready to begin</div>\n        <div id=\"current-step\"></div>\n    </div>\n    \n    <div class=\"control-group\">\n        <h2>Distance Table</h2>\n        <table id=\"distance-table\">\n            <thead>\n                <tr>\n                    <th>Node</th>\n                    <th>Distance</th>\n                    <th>Previous</th>\n                    <th>Visited</th>\n                </tr>\n            </thead>\n            <tbody></tbody>\n        </table>\n    </div>\n    \n    <div class=\"control-group\">\n        <h2>Path Information</h2>\n        <div id=\"path-result\"></div>\n        <div id=\"distance-result\"></div>\n    </div>\n    \n    <div class=\"control-group\">\n        <h2>Graph Information</h2>\n        <div id=\"node-count\">Nodes: 0</div>\n        <div id=\"edge-count\">Edges: 0</div>\n        <div id=\"adjacency-list\"></div>\n    </div>\n\n    <script>\n        // Graph data structure\n        const graph = {\n            nodes: [],\n            edges: [],\n            adjacencyList: {},\n            nextNodeId: 0,\n            \n            addNode: function(x, y) {\n                const node = { id: this.nextNodeId++, x, y };\n                this.nodes.push(node);\n                this.adjacencyList[node.id] = [];\n                this.updateUI();\n                return node;\n            },\n            \n            addEdge: function(source, target, weight) {\n                const edge = { source, target, weight };\n                this.edges.push(edge);\n                this.adjacencyList[source].push({ node: target, weight });\n                this.adjacencyList[target].push({ node: source, weight });\n                this.updateUI();\n                return edge;\n            },\n            \n            clear: function() {\n                this.nodes = [];\n                this.edges = [];\n                this.adjacencyList = {};\n                this.nextNodeId = 0;\n                this.updateUI();\n            },\n            \n            generateRandom: function(nodeCount, edgeCount) {\n                this.clear();\n                \n                // Add nodes\n                for (let i = 0; i < nodeCount; i++) {\n                    const x = 50 + Math.random() * 500;\n                    const y = 50 + Math.random() * 300;\n                    this.addNode(x, y);\n                }\n                \n                // Add edges\n                for (let i = 0; i < edgeCount; i++) {\n                    const source = Math.floor(Math.random() * nodeCount);\n                    let target = Math.floor(Math.random() * nodeCount);\n                    while (target === source) {\n                        target = Math.floor(Math.random() * nodeCount);\n                    }\n                    \n                    // Check if edge already exists\n                    const exists = this.edges.some(e => \n                        (e.source === source && e.target === target) || \n                        (e.source === target && e.target === source)\n                    );\n                    \n                    if (!exists) {\n                        const weight = 1 + Math.floor(Math.random() * 10);\n                        this.addEdge(source, target, weight);\n                    }\n                }\n            },\n            \n            updateUI: function() {\n                // Update node and edge counts\n                document.getElementById('node-count').textContent = `Nodes: ${this.nodes.length}`;\n                document.getElementById('edge-count').textContent = `Edges: ${this.edges.length}`;\n                \n                // Update node dropdowns\n                const startNodeSelect = document.getElementById('start-node');\n                const targetNodeSelect = document.getElementById('target-node');\n                \n                startNodeSelect.innerHTML = '';\n                targetNodeSelect.innerHTML = '';\n                \n                this.nodes.forEach(node => {\n                    const option = document.createElement('option');\n                    option.value = node.id;\n                    option.textContent = `Node ${node.id}`;\n                    startNodeSelect.appendChild(option.cloneNode(true));\n                    targetNodeSelect.appendChild(option);\n                });\n                \n                // Update adjacency list display\n                const adjListDiv = document.getElementById('adjacency-list');\n                adjListDiv.innerHTML = '<strong>Adjacency List:</strong><br>';\n                \n                for (const nodeId in this.adjacencyList) {\n                    adjListDiv.innerHTML += `Node ${nodeId}: `;\n                    this.adjacencyList[nodeId].forEach(neighbor => {\n                        adjListDiv.innerHTML += `→ ${neighbor.node} (${neighbor.weight}) `;\n                    });\n                    adjListDiv.innerHTML += '<br>';\n                }\n                \n                // Redraw graph\n                this.drawGraph();\n            },\n            \n            drawGraph: function() {\n                const svg = document.getElementById('graph');\n                svg.innerHTML = '';\n                \n                // Draw edges\n                this.edges.forEach(edge => {\n                    const sourceNode = this.nodes.find(n => n.id === edge.source);\n                    const targetNode = this.nodes.find(n => n.id === edge.target);\n                    \n                    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n                    line.setAttribute('x1', sourceNode.x);\n                    line.setAttribute('y1', sourceNode.y);\n                    line.setAttribute('x2', targetNode.x);\n                    line.setAttribute('y2', targetNode.y);\n                    line.setAttribute('class', 'edge');\n                    line.setAttribute('data-source', edge.source);\n                    line.setAttribute('data-target', edge.target);\n                    svg.appendChild(line);\n                    \n                    // Add weight label\n                    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n                    const midX = (sourceNode.x + targetNode.x) / 2;\n                    const midY = (sourceNode.y + targetNode.y) / 2;\n                    text.setAttribute('x', midX);\n                    text.setAttribute('y', midY);\n                    text.setAttribute('class', 'distance');\n                    text.textContent = edge.weight;\n                    svg.appendChild(text);\n                });\n                \n                // Draw nodes\n                this.nodes.forEach(node => {\n                    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n                    circle.setAttribute('cx', node.x);\n                    circle.setAttribute('cy', node.y);\n                    circle.setAttribute('r', 15);\n                    circle.setAttribute('class', 'node');\n                    circle.setAttribute('data-id', node.id);\n                    svg.appendChild(circle);\n                    \n                    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n                    text.setAttribute('x', node.x);\n                    text.setAttribute('y', node.y + 5);\n                    text.setAttribute('text-anchor', 'middle');\n                    text.textContent = node.id;\n                    svg.appendChild(text);\n                });\n            }\n        };\n        \n        // Dijkstra's algorithm implementation\n        const dijkstra = {\n            running: false,\n            stepInterval: null,\n            visitedEdges: [],\n            pathEdges: [],\n            currentStep: 0,\n            distances: {},\n            previous: {},\n            unvisited: new Set(),\n            \n            initialize: function(startNode) {\n                this.distances = {};\n                this.previous = {};\n                this.visited = new Set();\n                this.visitedEdges = [];\n                this.pathEdges = [];\n                this.currentStep = 0;\n                \n                graph.nodes.forEach(node => {\n                    this.distances[node.id] = Infinity;\n                    this.previous[node.id] = null;\n                    this.unvisited.add(node.id);\n                });\n                \n                this.distances[startNode] = 0;\n                this.updateDistanceTable();\n            },\n            \n            run: function(startNode, targetNode, stepByStep = false) {\n                if (this.running) return;\n                this.running = true;\n                \n                this.initialize(startNode);\n                document.getElementById('algorithm-state').textContent = 'Running Dijkstra\\'s algorithm...';\n                \n                if (stepByStep) {\n                    document.getElementById('step-algorithm').disabled = false;\n                    document.getElementById('current-step').textContent = 'Step 0: Initialized distances';\n                } else {\n                    const speed = parseInt(document.getElementById('speed').value);\n                    this.stepInterval = setInterval(() => {\n                        if (!this.step(startNode, targetNode)) {\n                            clearInterval(this.stepInterval);\n                            this.running = false;\n                        }\n                    }, speed);\n                }\n            },\n            \n            step: function(startNode, targetNode) {\n                if (this.unvisited.size === 0) {\n                    this.reconstructPath(targetNode);\n                    document.getElementById('algorithm-state').textContent = 'Algorithm completed';\n                    return false;\n                }\n                \n                // Get node with smallest distance\n                let currentNode = null;\n                let smallestDistance = Infinity;\n                \n                this.unvisited.forEach(nodeId => {\n                    if (this.distances[nodeId] < smallestDistance) {\n                        smallestDistance = this.distances[nodeId];\n                        currentNode = nodeId;\n                    }\n                });\n                \n                if (currentNode === null || this.distances[currentNode] === Infinity) {\n                    document.getElementById('algorithm-state').textContent = 'No path exists to some nodes';\n                    return false;\n                }\n                \n                // Mark as visited\n                this.unvisited.delete(currentNode);\n                this.currentStep++;\n                \n                // Update UI\n                const stepText = `Step ${this.currentStep}: Visiting node ${currentNode} (distance: ${this.distances[currentNode]})`;\n                document.getElementById('current-step').textContent = stepText;\n                \n                // Check neighbors\n                graph.adjacencyList[currentNode].forEach(neighbor => {\n                    if (this.unvisited.has(neighbor.node)) {\n                        const distance = this.distances[currentNode] + neighbor.weight;\n                        \n                        if (distance < this.distances[neighbor.node]) {\n                            this.distances[neighbor.node] = distance;\n                            this.previous[neighbor.node] = currentNode;\n                            \n                            // Mark edge as visited\n                            const edge = graph.edges.find(e => \n                                (e.source === currentNode && e.target === neighbor.node) || \n                                (e.source === neighbor.node && e.target === currentNode)\n                            );\n                            \n                            if (edge && !this.visitedEdges.includes(edge)) {\n                                this.visitedEdges.push(edge);\n                            }\n                        }\n                    }\n                });\n                \n                this.updateDistanceTable();\n                this.highlightVisitedEdges();\n                \n                return true;\n            },\n            \n            reconstructPath: function(targetNode) {\n                const path = [];\n                let currentNode = targetNode;\n                \n                while (currentNode !== null && this.previous[currentNode] !== null) {\n                    path.unshift(currentNode);\n                    const prevNode = this.previous[currentNode];\n                    \n                    // Find the edge between current and previous node\n                    const edge = graph.edges.find(e => \n                        (e.source === prevNode && e.target === currentNode) || \n                        (e.source === currentNode && e.target === prevNode)\n                    );\n                    \n                    if (edge) {\n                        this.pathEdges.push(edge);\n                    }\n                    \n                    currentNode = prevNode;\n                }\n                \n                if (currentNode !== null) {\n                    path.unshift(currentNode);\n                }\n                \n                // Update UI with path information\n                if (this.distances[targetNode] !== Infinity) {\n                    document.getElementById('path-result').textContent = `Path: ${path.join(' → ')}`;\n                    document.getElementById('distance-result').textContent = `Total distance: ${this.distances[targetNode]}`;\n                } else {\n                    document.getElementById('path-result').textContent = 'No path exists to target node';\n                    document.getElementById('distance-result').textContent = '';\n                }\n                \n                this.highlightPathEdges();\n            },\n            \n            updateDistanceTable: function() {\n                const tableBody = document.querySelector('#distance-table tbody');\n                tableBody.innerHTML = '';\n                \n                graph.nodes.forEach(node => {\n                    const row = document.createElement('tr');\n                    \n                    const nodeCell = document.createElement('td');\n                    nodeCell.textContent = node.id;\n                    row.appendChild(nodeCell);\n                    \n                    const distanceCell = document.createElement('td');\n                    distanceCell.textContent = this.distances[node.id] === Infinity ? '∞' : this.distances[node.id];\n                    row.appendChild(distanceCell);\n                    \n                    const previousCell = document.createElement('td');\n                    previousCell.textContent = this.previous[node.id] === null ? 'None' : this.previous[node.id];\n                    row.appendChild(previousCell);\n                    \n                    const visitedCell = document.createElement('td');\n                    visitedCell.textContent = this.unvisited.has(node.id) ? 'No' : 'Yes';\n                    row.appendChild(visitedCell);\n                    \n                    tableBody.appendChild(row);\n                });\n            },\n            \n            highlightVisitedEdges: function() {\n                // Reset all edges to default\n                document.querySelectorAll('.edge').forEach(edge => {\n                    edge.classList.remove('visited');\n                });\n                \n                // Highlight visited edges\n                this.visitedEdges.forEach(edge => {\n                    const edgeElement = document.querySelector(`.edge[data-source=\"${edge.source}\"][data-target=\"${edge.target}\"]`) || \n                                       document.querySelector(`.edge[data-source=\"${edge.source}\"][data-target=\"${edge.target}\"]`);\n                    if (edgeElement) {\n                        edgeElement.classList.add('visited');\n                    }\n                });\n            },\n            \n            highlightPathEdges: function() {\n                // Highlight path edges\n                this.pathEdges.forEach(edge => {\n                    const edgeElement = document.querySelector(`.edge[data-source=\"${edge.source}\"][data-target=\"${edge.target}\"]`) || \n                                       document.querySelector(`.edge[data-source=\"${edge.source}\"][data-target=\"${edge.target}\"]`);\n                    if (edgeElement) {\n                        edgeElement.classList.add('path');\n                    }\n                });\n            },\n            \n            reset: function() {\n                clearInterval(this.stepInterval);\n                this.running = false;\n                \n                document.getElementById('algorithm-state').textContent = 'Ready to begin';\n                document.getElementById('current-step').textContent = '';\n                document.getElementById('path-result').textContent = '';\n                document.getElementById('distance-result').textContent = '';\n                document.getElementById('step-algorithm').disabled = false;\n                \n                // Reset edge highlighting\n                document.querySelectorAll('.edge').forEach(edge => {\n                    edge.classList.remove('visited', 'path');\n                });\n                \n                // Clear distance table\n                const tableBody = document.querySelector('#distance-table tbody');\n                tableBody.innerHTML = '';\n            }\n        };\n        \n        // UI event handlers\n        document.addEventListener('DOMContentLoaded', function() {\n            // Graph construction\n            document.getElementById('add-node').addEventListener('click', function() {\n                const svg = document.getElementById('graph');\n                const rect = svg.getBoundingClientRect();\n                const x = Math.random() * (rect.width - 30) + 15;\n                const y = Math.random() * (rect.height - 30) + 15;\n                graph.addNode(x, y);\n            });\n            \n            let edgeStartNode = null;\n            document.getElementById('add-edge').addEventListener('click', function() {\n                if (edgeStartNode === null) {\n                    edgeStartNode = 'selecting';\n                    this.textContent = 'Select first node';\n                } else if (edgeStartNode === 'selecting') {\n                    this.textContent = 'Add Edge (select two nodes)';\n                    edgeStartNode = null;\n                }\n            });\n            \n            document.getElementById('graph').addEventListener('click', function(e) {\n                if (edgeStartNode === 'selecting') {\n                    const circle = e.target.closest('.node');\n                    if (circle) {\n                        const nodeId = parseInt(circle.getAttribute('data-id'));\n                        edgeStartNode = nodeId;\n                        document.getElementById('add-edge').textContent = 'Select second node';\n                    }\n                } else if (typeof edgeStartNode === 'number') {\n                    const circle = e.target.closest('.node');\n                    if (circle) {\n                        const nodeId = parseInt(circle.getAttribute('data-id'));\n                        if (nodeId !== edgeStartNode) {\n                            const weight = parseInt(document.getElementById('edge-weight').value) || 1;\n                            graph.addEdge(edgeStartNode, nodeId, weight);\n                        }\n                        edgeStartNode = null;\n                        document.getElementById('add-edge').textContent = 'Add Edge (select two nodes)';\n                    }\n                }\n            });\n            \n            document.getElementById('clear-graph').addEventListener('click', function() {\n                graph.clear();\n                dijkstra.reset();\n            });\n            \n            document.getElementById('random-graph').addEventListener('click', function() {\n                const nodeCount = parseInt(document.getElementById('random-nodes').value) || 5;\n                const edgeCount = parseInt(document.getElementById('random-edges').value) || 8;\n                graph.generateRandom(nodeCount, edgeCount);\n                dijkstra.reset();\n            });\n            \n            // Algorithm controls\n            document.getElementById('run-algorithm').addEventListener('click', function() {\n                const startNode = parseInt(document.getElementById('start-node').value);\n                const targetNode = parseInt(document.getElementById('target-node').value);\n                \n                if (isNaN(startNode) || isNaN(targetNode)) {\n                    alert('Please select both start and target nodes');\n                    return;\n                }\n                \n                dijkstra.run(startNode, targetNode);\n            });\n            \n            document.getElementById('step-algorithm').addEventListener('click', function() {\n                const startNode = parseInt(document.getElementById('start-node').value);\n                const targetNode = parseInt(document.getElementById('target-node').value);\n                \n                if (isNaN(startNode) || isNaN(targetNode)) {\n                    alert('Please select both start and target nodes');\n                    return;\n                }\n                \n                if (!dijkstra.running) {\n                    dijkstra.run(startNode, targetNode, true);\n                } else {\n                    if (!dijkstra.step(startNode, targetNode)) {\n                        this.disabled = true;\n                    }\n                }\n            });\n            \n            document.getElementById('reset-algorithm').addEventListener('click', function() {\n                dijkstra.reset();\n            });\n            \n            // Initialize with a simple graph\n            graph.addNode(100, 100);\n            graph.addNode(200, 200);\n            graph.addNode(300, 100);\n            graph.addNode(400, 200);\n            graph.addEdge(0, 1, 4);\n            graph.addEdge(1, 2, 3);\n            graph.addEdge(2, 3, 5);\n            graph.addEdge(0, 2, 1);\n        });\n    </script>\n</body>\n</html>"
