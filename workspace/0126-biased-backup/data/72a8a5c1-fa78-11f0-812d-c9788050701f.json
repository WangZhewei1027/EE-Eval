    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Visual Deque Demonstration</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n            --warning: #fdcb6e;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n        \n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n        }\n        \n        .header {\n            text-align: center;\n            margin-bottom: 2rem;\n            animation: fadeIn 1s ease;\n        }\n        \n        .header h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            color: var(--primary);\n            margin-bottom: 0.5rem;\n            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);\n        }\n        \n        .header p {\n            font-size: 1.2rem;\n            color: var(--dark);\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .container {\n            width: 100%;\n            max-width: 900px;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.1);\n            padding: 2rem;\n            position: relative;\n            overflow: hidden;\n            animation: slideUp 0.8s ease;\n        }\n        \n        .deque-display {\n            position: relative;\n            height: 200px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin: 3rem 0;\n            perspective: 1000px;\n        }\n        \n        .deque-line {\n            position: absolute;\n            width: 90%;\n            height: 4px;\n            background: linear-gradient(90deg, var(--secondary), var(--primary));\n            border-radius: 2px;\n            top: 50%;\n            transform: translateY(-50%);\n            box-shadow: 0 2px 10px rgba(108, 92, 231, 0.3);\n        }\n        \n        .deque-node {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            background: white;\n            border-radius: 12px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.8rem;\n            font-weight: bold;\n            color: var(--primary);\n            box-shadow: 0 8px 20px rgba(0,0,0,0.1);\n            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            transform-style: preserve-3d;\n            z-index: 2;\n        }\n        \n        .deque-node::before {\n            content: '';\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(135deg, var(--secondary), var(--primary));\n            border-radius: 12px;\n            transform: translateZ(-4px);\n            box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3);\n        }\n        \n        .deque-node.front {\n            background: linear-gradient(135deg, var(--accent), #e84393);\n            color: white;\n            z-index: 3;\n            transform: scale(1.1) translateY(-10px);\n            box-shadow: 0 12px 25px rgba(253, 121, 168, 0.4);\n        }\n        \n        .deque-node.front::before {\n            background: linear-gradient(135deg, #e84393, #fd79a8);\n        }\n        \n        .deque-node.rear {\n            background: linear-gradient(135deg, var(--success), #00cec9);\n            color: white;\n            z-index: 3;\n            transform: scale(1.1) translateY(-10px);\n            box-shadow: 0 12px 25px rgba(0, 184, 148, 0.4);\n        }\n        \n        .deque-node.rear::before {\n            background: linear-gradient(135deg, #00cec9, #55efc4);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        .btn {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 10px rgba(0,0,0,0.1);\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n        \n        .btn:disabled {\n            opacity: 0.6;\n            cursor: not-allowed;\n        }\n        \n        .btn-primary {\n            background: linear-gradient(135deg, var(--primary), #7049f5);\n            color: white;\n        }\n        \n        .btn-primary:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 15px rgba(108, 92, 231, 0.3);\n        }\n        \n        .btn-secondary {\n            background: white;\n            color: var(--primary);\n            border: 2px solid var(--secondary);\n        }\n        \n        .btn-secondary:hover {\n            background: var(--secondary);\n            color: white;\n            transform: translateY(-2px);\n        }\n        \n        .animation-panel {\n            display: flex;\n            flex-direction: column;\n            gap: 1.5rem;\n            margin-top: 2rem;\n        }\n        \n        .operation {\n            padding: 1.5rem;\n            background: white;\n            border-radius: 12px;\n            box-shadow: 0 4px 15px rgba(0,0,0,0.05);\n            animation: fadeIn 0.6s ease;\n            transition: all 0.3s ease;\n        }\n        \n        .operation:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(0,0,0,0.1);\n        }\n        \n        .operation h3 {\n            color: var(--primary);\n            margin-bottom: 0.5rem;\n            font-size: 1.3rem;\n        }\n        \n        .operation p {\n            color: #636e72;\n            line-height: 1.6;\n        }\n        \n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 1.5rem;\n        }\n        \n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n            color: var(--dark);\n        }\n        \n        .legend-color {\n            width: 16px;\n            height: 16px;\n            border-radius: 4px;\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        \n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(30px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n        \n        .tutorial {\n            margin-top: 3rem;\n            max-width: 800px;\n            animation: fadeIn 1s ease;\n        }\n        \n        .tutorial h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            text-align: center;\n        }\n        \n        .features {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n            gap: 1.5rem;\n            margin-top: 2rem;\n        }\n        \n        .feature {\n            background: white;\n            padding: 1.5rem;\n            border-radius: 12px;\n            box-shadow: 0 4px 15px rgba(0,0,0,0.05);\n            transition: all 0.3s ease;\n        }\n        \n        .feature:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 8px 25px rgba(0,0,0,0.1);\n        }\n        \n        .feature-icon {\n            width: 50px;\n            height: 50px;\n            background: linear-gradient(135deg, var(--secondary), var(--primary));\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin-bottom: 1rem;\n            color: white;\n            font-size: 1.5rem;\n        }\n        \n        .feature h3 {\n            color: var(--dark);\n            margin-bottom: 0.5rem;\n        }\n        \n        .feature p {\n            color: #636e72;\n            font-size: 0.95rem;\n            line-height: 1.6;\n        }\n        \n        footer {\n            margin-top: 3rem;\n            text-align: center;\n            color: #636e72;\n            font-size: 0.9rem;\n            padding: 1rem;\n            animation: fadeIn 1s ease;\n        }\n        \n        /* Responsive adjustments */\n        @media (max-width: 768px) {\n            .header h1 {\n                font-size: 2.2rem;\n            }\n            \n            .header p {\n                font-size: 1rem;\n            }\n            \n            .controls {\n                flex-direction: column;\n                align-items: center;\n            }\n            \n            .btn {\n                width: 100%;\n                justify-content: center;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Deque Visualizer</h1>\n        <p>Explore the double-ended queue data structure with this elegant visualization. Watch elements flow gracefully from both ends of the deque.</p>\n    </div>\n    \n    <div class=\"container\">\n        <div class=\"deque-display\">\n            <div class=\"deque-line\"></div>\n            <!-- Nodes will be added here by JavaScript -->\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"addFrontBtn\" class=\"btn btn-primary\">Add to Front</button>\n            <button id=\"removeFrontBtn\" class=\"btn btn-secondary\">Remove from Front</button>\n            <button id=\"addRearBtn\" class=\"btn btn-primary\">Add to Rear</button>\n            <button id=\"removeRearBtn\" class=\"btn btn-secondary\">Remove from Rear</button>\n        </div>\n        \n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(135deg, var(--accent), #e84393);\"></div>\n                <span>Front of Deque</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(135deg, var(--secondary), var(--primary));\"></div>\n                <span>Regular Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: linear-gradient(135deg, var(--success), #00cec9);\"></div>\n                <span>Rear of Deque</span>\n            </div>\n        </div>\n        \n        <div class=\"animation-panel\">\n            <div class=\"operation\">\n                <h3>Add Front Operation</h3>\n                <p>Inserting an element at the front of the deque. This operation takes O(1) time complexity.</p>\n            </div>\n            <div class=\"operation\">\n                <h3>Remove Front Operation</h3>\n                <p>Removing an element from the front of the deque. This operation takes O(1) time complexity.</p>\n            </div>\n            <div class=\"operation\">\n                <h3>Add Rear Operation</h3>\n                <p>Inserting an element at the rear of the deque. This operation takes O(1) time complexity.</p>\n            </div>\n            <div class=\"operation\">\n                <h3>Remove Rear Operation</h3>\n                <p>Removing an element from the rear of the deque. This operation takes O(1) time complexity.</p>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"tutorial\">\n        <h2>Understanding the Deque</h2>\n        \n        <div class=\"features\">\n            <div class=\"feature\">\n                <div class=\"feature-icon\">👥</div>\n                <h3>Double-Ended</h3>\n                <p>A deque allows insertion and removal of elements from both the front and rear, making it more versatile than a simple queue.</p>\n            </div>\n            \n            <div class=\"feature\">\n                <div class=\"feature-icon\">⚡</div>\n                <h3>Constant Time Operations</h3>\n                <p>All basic operations (add/remove front/rear) can be performed in O(1) time with proper implementation.</p>\n            </div>\n            \n            <div class=\"feature\">\n                <div class=\"feature-icon\">🔀</div>\n                <h3>Flexible Usage</h3>\n                <p>Can be used as both a stack (LIFO) and queue (FIFO), or a combination of both.</p>\n            </div>\n        </div>\n    </div>\n    \n    <footer>\n        <p>Deque Visualization | A beautiful demonstration of double-ended queue operations</p>\n    </footer>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const dequeDisplay = document.querySelector('.deque-display');\n            const addFrontBtn = document.getElementById('addFrontBtn');\n            const removeFrontBtn = document.getElementById('removeFrontBtn');\n            const addRearBtn = document.getElementById('addRearBtn');\n            const removeRearBtn = document.getElementById('removeRearBtn');\n            \n            let deque = [];\n            let currentValue = 1;\n            \n            function renderDeque() {\n                // Clear existing nodes\n                const existingNodes = document.querySelectorAll('.deque-node');\n                existingNodes.forEach(node => node.remove());\n                \n                // Calculate positions\n                const displayWidth = dequeDisplay.offsetWidth;\n                const startX = (displayWidth * 0.1) + 20; // 10% margin + half node width\n                const endX = (displayWidth * 0.9) - 100; // 90% margin - node width\n                const step = (endX - startX) / Math.max(1, deque.length - 1);\n                \n                // Add new nodes\n                deque.forEach((value, index) => {\n                    const node = document.createElement('div');\n                    node.className = 'deque-node';\n                    \n                    if (index === 0) node.classList.add('front');\n                    if (index === deque.length - 1 && deque.length > 1) node.classList.add('rear');\n                    \n                    node.textContent = value;\n                    node.style.left = `${startX + index * step}px`;\n                    node.style.opacity = '0';\n                    node.style.transform = node.style.transform || 'translateY(30px) scale(0.8)';\n                    \n                    dequeDisplay.appendChild(node);\n                    \n                    // Animate entry\n                    setTimeout(() => {\n                        node.style.opacity = '1';\n                        node.style.transform = node.classList.contains('front') || node.classList.contains('rear') \n                            ? 'translateY(-10px) scale(1.1)' \n                            : 'translateY(0) scale(1)';\n                    }, 50 * index);\n                });\n                \n                // Update button states\n                removeFrontBtn.disabled = removeRearBtn.disabled = deque.length === 0;\n            }\n            \n            // Add to front\n            addFrontBtn.addEventListener('click', function() {\n                deque.unshift(currentValue++);\n                renderDeque();\n                \n                // Highlight the new front node\n                const frontNode = document.querySelector('.deque-node.front');\n                if (frontNode) {\n                    frontNode.style.animation = 'pulse 0.6s ease';\n                    setTimeout(() => {\n                        frontNode.style.animation = '';\n                    }, 600);\n                }\n            });\n            \n            // Remove from front\n            removeFrontBtn.addEventListener('click', function() {\n                if (deque.length === 0) return;\n                \n                const frontNode = document.querySelector('.deque-node.front');\n                if (frontNode) {\n                    frontNode.style.transform = 'translateY(50px) scale(0.8)';\n                    frontNode.style.opacity = '0';\n                    \n                    setTimeout(() => {\n                        deque.shift();\n                        renderDeque();\n                    }, 400);\n                }\n            });\n            \n            // Add to rear\n            addRearBtn.addEventListener('click', function() {\n                deque.push(currentValue++);\n                renderDeque();\n                \n                // Highlight the new rear node\n                const rearNode = document.querySelector('.deque-node.rear');\n                if (rearNode) {\n                    rearNode.style.animation = 'pulse 0.6s ease';\n                    setTimeout(() => {\n                        rearNode.style.animation = '';\n                    }, 600);\n                }\n            });\n            \n            // Remove from rear\n            removeRearBtn.addEventListener('click', function() {\n                if (deque.length === 0) return;\n                \n                const rearNode = document.querySelector('.deque-node.rear');\n                if (rearNode) {\n                    rearNode.style.transform = 'translateY(50px) scale(0.8)';\n                    rearNode.style.opacity = '0';\n                    \n                    setTimeout(() => {\n                        deque.pop();\n                        renderDeque();\n                    }, 400);\n                }\n            });\n            \n            // Initial render\n            renderDeque();\n        });\n    </script>\n</body>\n</html>"
