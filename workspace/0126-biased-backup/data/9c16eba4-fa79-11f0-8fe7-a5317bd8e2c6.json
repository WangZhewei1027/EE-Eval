  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Backpropagation Interactive Lab</title>\n<style>\n/* Extremely minimal styling as requested */\nbody { font-family: monospace; margin: 10px; background: white; color: black; }\ninput, select, button, textarea { font-family: monospace; font-size: 12px; }\n.container { display: flex; gap: 12px; }\n.column { flex: 1; min-width: 300px; }\n.panel { border: 1px solid #000; padding: 8px; margin-bottom: 8px; }\n.small { font-size: 11px; }\npre { white-space: pre-wrap; word-wrap: break-word; max-height: 300px; overflow: auto; }\ntable { border-collapse: collapse; }\ntd, th { border: 1px solid #000; padding: 2px 6px; }\n</style>\n</head>\n<body>\n<h1>Backpropagation Interactive Lab</h1>\n<div class=\"container\">\n  <div class=\"column\">\n    <div class=\"panel\">\n      <strong>Network Topology</strong><br>\n      <div>\n        Layers (comma-separated neuron counts, include input and output):<br>\n        <input id=\"layersInput\" type=\"text\" value=\"2,2,1\" style=\"width:100%\"><br>\n        <button id=\"applyLayersBtn\">Apply Topology</button>\n        <button id=\"addLayerBtn\">Add Hidden Layer</button>\n        <button id=\"removeLayerBtn\">Remove Last Hidden Layer</button>\n      </div>\n      <div style=\"margin-top:8px;\">\n        Per-layer activation (comma-separated, same length as layers):<br>\n        <input id=\"activationsInput\" type=\"text\" value=\"linear,sigmoid,linear\" style=\"width:100%\"><br>\n        <small class=\"small\">choices: linear, sigmoid, tanh, relu, softmax</small>\n      </div>\n      <div style=\"margin-top:8px;\">\n        Weight init: \n        <select id=\"initSelect\">\n          <option value=\"random\">Random [-1,1]</option>\n          <option value=\"xavier\">Xavier</option>\n          <option value=\"zeros\">Zeros</option>\n        </select>\n        <button id=\"initWeightsBtn\">Initialize Weights</button>\n      </div>\n      <div style=\"margin-top:8px;\">\n        Controls:<br>\n        <label>Learning rate <input id=\"lrInput\" type=\"number\" step=\"0.0001\" value=\"0.5\" style=\"width:80px\"></label><br>\n        <label>Momentum <input id=\"momentumInput\" type=\"number\" step=\"0.01\" value=\"0.0\" style=\"width:80px\"></label><br>\n        <label>L2 lambda <input id=\"l2Input\" type=\"number\" step=\"0.0001\" value=\"0.0\" style=\"width:80px\"></label><br>\n        <label>Gradient clip (abs) <input id=\"clipInput\" type=\"number\" step=\"0.1\" value=\"1000\" style=\"width:80px\"></label>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Dataset</strong><br>\n      Presets:\n      <select id=\"datasetPreset\">\n        <option value=\"xor\">XOR (2->1)</option>\n        <option value=\"and\">AND</option>\n        <option value=\"or\">OR</option>\n        <option value=\"linear\">Linear y = sum(x)</option>\n        <option value=\"circle\">Circle classification</option>\n      </select>\n      <button id=\"loadPresetBtn\">Load Preset</button>\n      <button id=\"clearDataBtn\">Clear</button>\n      <div style=\"margin-top:8px;\">\n        Add sample (comma-separated inputs and output):<br>\n        <input id=\"addSampleInput\" type=\"text\" value=\"0,0 -> 0\" style=\"width:100%\"><br>\n        <button id=\"addSampleBtn\">Add Sample</button>\n      </div>\n      <div style=\"margin-top:8px;\">\n        Bulk edit / paste CSV (each line: x1,x2,...,y1,y2,...):<br>\n        <textarea id=\"dataArea\" rows=\"6\" style=\"width:100%\"></textarea><br>\n        <button id=\"applyDataBtn\">Apply Data</button>\n      </div>\n      <div style=\"margin-top:8px;\">\n        <strong>Samples</strong>\n        <pre id=\"samplesPre\">[]</pre>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Training Controls</strong><br>\n      <label>Loss:\n        <select id=\"lossSelect\">\n          <option value=\"mse\">MSE</option>\n          <option value=\"crossentropy\">Cross-Entropy (with softmax)</option>\n        </select>\n      </label><br>\n      <label>Batch size <input id=\"batchSizeInput\" type=\"number\" step=\"1\" value=\"1\" style=\"width:80px\"></label><br>\n      <label>Shuffle <input id=\"shuffleCheckbox\" type=\"checkbox\" checked></label><br>\n      <label>Epochs <input id=\"epochsInput\" type=\"number\" step=\"1\" value=\"1000\" style=\"width:80px\"></label><br>\n      <button id=\"trainBtn\">Train (Run)</button>\n      <button id=\"trainStepBtn\">Train Step (1 batch)</button>\n      <button id=\"stopBtn\">Stop</button>\n      <div style=\"margin-top:8px;\">\n        <button id=\"stepForwardBtn\">Step Forward (single sample forward)</button>\n        <button id=\"stepBackwardBtn\">Step Backprop (on last sample)</button>\n        <button id=\"resetStateBtn\">Reset State (zero grads, zero cache)</button>\n      </div>\n      <div style=\"margin-top:8px;\">\n        <small class=\"small\">Epoch: <span id=\"epochLabel\">0</span> Iter: <span id=\"iterLabel\">0</span> Loss: <span id=\"lossLabel\">N/A</span></small>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Utilities</strong><br>\n      <button id=\"saveJsonBtn\">Save Network JSON</button>\n      <button id=\"loadJsonBtn\">Load JSON</button>\n      <input id=\"jsonFileInput\" type=\"file\" accept=\".json\">\n      <button id=\"randomSeedBtn\">Set Random Seed</button>\n      <div style=\"margin-top:8px;\">\n        <button id=\"gradCheckBtn\">Gradient Check (numeric vs analytic)</button>\n        <input id=\"gradEps\" type=\"number\" step=\"1e-6\" value=\"1e-5\" style=\"width:90px\">\n        <input id=\"gradTol\" type=\"number\" step=\"1e-6\" value=\"1e-4\" style=\"width:90px\">\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"column\">\n    <div class=\"panel\">\n      <strong>Network Viewer / Edit</strong>\n      <div id=\"networkView\"></div>\n      <div style=\"margin-top:8px;\">\n        <button id=\"toggleFreezeBtn\">Toggle Freeze Selected Layer</button>\n        <button id=\"zeroWeightsBtn\">Zero Selected Layer Weights</button>\n        <div>Selected layer index: <input id=\"selectedLayerIndex\" type=\"number\" value=\"1\" style=\"width:60px\"></div>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Forward / Backprop Trace</strong>\n      <div>\n        Choose sample index: <input id=\"traceSampleIndex\" type=\"number\" value=\"0\" style=\"width:60px\">\n        <button id=\"showForwardBtn\">Show Forward</button>\n        <button id=\"showBackwardBtn\">Show Backprop</button>\n      </div>\n      <pre id=\"tracePre\">No trace yet.</pre>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Training History & Logs</strong>\n      <div>\n        <button id=\"clearLogBtn\">Clear Log</button>\n      </div>\n      <pre id=\"logPre\">Ready.</pre>\n    </div>\n\n    <div class=\"panel\">\n      <strong>Loss History</strong>\n      <pre id=\"lossHistoryPre\">[]</pre>\n      <div>\n        Show last N <input id=\"historyN\" type=\"number\" value=\"50\" style=\"width:60px\">\n        <button id=\"showHistoryBtn\">Show</button>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n// Backpropagation Interactive Lab\n// Plain UI, many controls, complex flows.\n\n// Utility functions\nfunction rand(seed=null) {\n  // seeded random if seed provided\n  if (seed === null) return Math.random();\n  seed = (seed * 9301 + 49297) % 233280;\n  return seed / 233280;\n}\nfunction deepCopy(x) { return JSON.parse(JSON.stringify(x)); }\nfunction arr(n, v=0) { return Array.from({length:n}, ()=> typeof v === 'function' ? v() : v); }\nfunction zeros(n) { return arr(n,0); }\nfunction sum(arr) { return arr.reduce((a,b)=>a+b,0); }\nfunction add(a,b){ return a.map((v,i)=>v+b[i]); }\nfunction clamp(x,mi,ma){ return Math.max(mi, Math.min(ma, x)); }\n\n// Activation functions and derivatives\nconst Activations = {\n  linear: {\n    f: x => x,\n    df: x => 1\n  },\n  sigmoid: {\n    f: x => 1 / (1 + Math.exp(-x)),\n    df: x => {\n      const s = 1 / (1 + Math.exp(-x));\n      return s*(1-s);\n    }\n  },\n  tanh: {\n    f: x => Math.tanh(x),\n    df: x => 1 - Math.tanh(x)**2\n  },\n  relu: {\n    f: x => x>0?x:0,\n    df: x => x>0?1:0\n  },\n  softmax: {\n    f: function(vec){\n      // numerically stable\n      const m = Math.max(...vec);\n      const ex = vec.map(v=>Math.exp(v-m));\n      const s = sum(ex);\n      return ex.map(v=>v/s);\n    },\n    df: null // handled differently (softmax combined with cross-entropy)\n  }\n};\n\n// Loss functions\nconst Losses = {\n  mse: {\n    f: (yPred, yTrue) => {\n      // yPred, yTrue arrays\n      let s = 0;\n      for (let i=0;i<yPred.length;i++){\n        const d = yPred[i]-yTrue[i];\n        s += 0.5*d*d;\n      }\n      return s;\n    },\n    df: (yPred, yTrue) => yPred.map((v,i)=> v - yTrue[i]) // derivative w.r.t pre-activation for linear outputs\n  },\n  crossentropy: {\n    f: (yPred, yTrue) => {\n      // yPred are probabilities (softmax), yTrue is one-hot or distribution\n      let s = 0;\n      for (let i=0;i<yPred.length;i++){\n        const p = clamp(yPred[i], 1e-15, 1-1e-15);\n        s -= yTrue[i] * Math.log(p);\n      }\n      return s;\n    },\n    df: null // handled with softmax combined\n  }\n};\n\n// Network model\nclass Network {\n  constructor(layerSizes=[2,2,1], activations=null){\n    this.layerSizes = layerSizes.slice();\n    this.L = layerSizes.length;\n    this.activations = activations || layerSizes.map((_,i)=> i===0 ? 'linear' : 'sigmoid');\n    this.weights = []; // weights[l][i][j] for layer l (1..L-1) neuron i, from prev j\n    this.biases = [];\n    this.initWeights('random');\n    this.resetState();\n    this.frozen = Array(this.L).fill(false);\n    this.velocities = this.layerSizes.map((n, idx)=>{\n      if (idx===0) return null;\n      return {w: arr(this.layerSizes[idx], ()=> arr(this.layerSizes[idx-1], ()=>0)), b: arr(this.layerSizes[idx], ()=>0)};\n    });\n  }\n  resetState(){\n    this.Z = []; // pre-activations per layer\n    this.A = []; // activations per layer\n    this.grads = null; // grads for weights and biases\n    this.lastInputs = null;\n  }\n  initWeights(mode='random'){\n    this.weights = [null];\n    this.biases = [null];\n    for (let l=1;l<this.L;l++){\n      const n = this.layerSizes[l];\n      const m = this.layerSizes[l-1];\n      let w = arr(n, ()=> arr(m, ()=>0));\n      let b = arr(n, ()=>0);\n      if (mode === 'random'){\n        for (let i=0;i<n;i++){\n          for (let j=0;j<m;j++){\n            w[i][j] = Math.random()*2 - 1;\n          }\n          b[i] = Math.random()*2 - 1;\n        }\n      } else if (mode === 'xavier'){\n        const range = Math.sqrt(6 / (n + m));\n        for (let i=0;i<n;i++){\n          for (let j=0;j<m;j++){\n            w[i][j] = (Math.random()*2 - 1) * range;\n          }\n          b[i] = 0;\n        }\n      } else if (mode === 'zeros'){\n        // already zeros\n      }\n      this.weights.push(w);\n      this.biases.push(b);\n    }\n    // reset velocities\n    this.velocities = this.layerSizes.map((s, idx)=>{\n      if (idx===0) return null;\n      return {w: arr(this.layerSizes[idx], ()=> arr(this.layerSizes[idx-1], ()=>0)), b: arr(this.layerSizes[idx], ()=>0)};\n    });\n    this.resetState();\n  }\n  forward(x){\n    // x: array length layerSizes[0]\n    this.A = [x.slice()];\n    this.Z = [null];\n    for (let l=1;l<this.L;l++){\n      const n = this.layerSizes[l];\n      const m = this.layerSizes[l-1];\n      const z = arr(n, ()=>0);\n      const aPrev = this.A[l-1];\n      for (let i=0;i<n;i++){\n        let s = this.biases[l][i];\n        for (let j=0;j<m;j++){\n          s += this.weights[l][i][j] * aPrev[j];\n        }\n        z[i] = s;\n      }\n      this.Z.push(z);\n      const actName = this.activations[l];\n      if (actName === 'softmax'){\n        this.A.push(Activations.softmax.f(z));\n      } else {\n        this.A.push(z.map(v=>Activations[actName].f(v)));\n      }\n    }\n    this.lastInputs = x.slice();\n    return this.A[this.A.length-1];\n  }\n  backprop(yTrue, lossName='mse', options={}){\n    // Compute gradients given last forward run (must call forward before)\n    if (!this.A || this.A.length===0) throw new Error(\"Call forward first\");\n    const L = this.L;\n    const gradsW = [null];\n    const gradsB = [null];\n    let delta = null;\n    // Output layer\n    const outIdx = L-1;\n    const actOut = this.activations[outIdx];\n    const yPred = this.A[outIdx].slice();\n    if (lossName === 'crossentropy' && actOut === 'softmax'){\n      // special case: delta = yPred - yTrue\n      delta = yPred.map((p,i)=> p - yTrue[i]);\n    } else {\n      // general: delta = dLoss/dA * dA/dZ\n      const dLossdA = Losses[lossName].df(yPred, yTrue);\n      const z = this.Z[outIdx];\n      delta = arr(z.length, (i)=> dLossdA[i] * (Activations[actOut].df(z[i])));\n    }\n    // gradients for output layer\n    gradsW[outIdx] = arr(this.layerSizes[outIdx], ()=> arr(this.layerSizes[outIdx-1], ()=>0));\n    gradsB[outIdx] = arr(this.layerSizes[outIdx], ()=>0);\n    const aPrev = this.A[outIdx-1];\n    for (let i=0;i<this.layerSizes[outIdx];i++){\n      for (let j=0;j<aPrev.length;j++){\n        gradsW[outIdx][i][j] = delta[i] * aPrev[j];\n      }\n      gradsB[outIdx][i] = delta[i];\n    }\n    // backpropagate\n    for (let l=L-2; l>=1; l--){\n      const n = this.layerSizes[l];\n      const m = this.layerSizes[l+1];\n      const nextW = this.weights[l+1];\n      const nextDelta = delta;\n      const z = this.Z[l];\n      const act = this.activations[l];\n      const myDelta = arr(n, ()=>0);\n      for (let i=0;i<n;i++){\n        let s = 0;\n        for (let k=0;k<m;k++){\n          s += nextW[k][i] * nextDelta[k];\n        }\n        myDelta[i] = s * Activations[act].df(z[i]);\n      }\n      delta = myDelta;\n      // compute grads for this layer\n      gradsW[l] = arr(this.layerSizes[l], ()=> arr(this.layerSizes[l-1], ()=>0));\n      gradsB[l] = arr(this.layerSizes[l], ()=>0);\n      const aPrev2 = this.A[l-1];\n      for (let i=0;i<this.layerSizes[l];i++){\n        for (let j=0;j<aPrev2.length;j++){\n          gradsW[l][i][j] = delta[i] * aPrev2[j];\n        }\n        gradsB[l][i] = delta[i];\n      }\n    }\n    this.grads = {W: gradsW, B: gradsB};\n    return this.grads;\n  }\n  applyGradients(grads, lr=0.1, momentum=0.0, l2=0.0, clipAbs=1e9){\n    for (let l=1;l<this.L;l++){\n      if (this.frozen[l]) continue;\n      for (let i=0;i<this.layerSizes[l];i++){\n        for (let j=0;j<this.layerSizes[l-1];j++){\n          let g = grads.W[l][i][j];\n          if (l2) g += l2 * this.weights[l][i][j];\n          if (Math.abs(g) > clipAbs) g = Math.sign(g) * clipAbs;\n          // momentum update\n          this.velocities[l].w[i][j] = momentum*this.velocities[l].w[i][j] - lr * g;\n          this.weights[l][i][j] += this.velocities[l].w[i][j];\n        }\n        let gb = grads.B[l][i];\n        if (Math.abs(gb) > clipAbs) gb = Math.sign(gb) * clipAbs;\n        this.velocities[l].b[i] = momentum*this.velocities[l].b[i] - lr * gb;\n        this.biases[l][i] += this.velocities[l].b[i];\n      }\n    }\n  }\n\n  toJSON(){\n    return {\n      layerSizes: this.layerSizes,\n      activations: this.activations,\n      weights: this.weights,\n      biases: this.biases,\n      frozen: this.frozen\n    };\n  }\n  loadJSON(obj){\n    this.layerSizes = obj.layerSizes.slice();\n    this.L = this.layerSizes.length;\n    this.activations = obj.activations.slice();\n    this.weights = obj.weights.slice();\n    this.biases = obj.biases.slice();\n    this.frozen = obj.frozen || Array(this.L).fill(false);\n    this.velocities = this.layerSizes.map((s, idx)=>{\n      if (idx===0) return null;\n      return {w: arr(this.layerSizes[idx], ()=> arr(this.layerSizes[idx-1], ()=>0)), b: arr(this.layerSizes[idx], ()=>0)};\n    });\n    this.resetState();\n  }\n}\n\n// Global app state\nconst App = {\n  net: new Network([2,2,1], ['linear','sigmoid','linear']),\n  samples: [], // {x:[], y:[]}\n  epoch: 0,\n  iter: 0,\n  running: false,\n  log: [],\n  lossHistory: [],\n  rngSeed: null\n};\n\n// DOM elements\nconst layersInput = document.getElementById('layersInput');\nconst activationsInput = document.getElementById('activationsInput');\nconst applyLayersBtn = document.getElementById('applyLayersBtn');\nconst addLayerBtn = document.getElementById('addLayerBtn');\nconst removeLayerBtn = document.getElementById('removeLayerBtn');\nconst initSelect = document.getElementById('initSelect');\nconst initWeightsBtn = document.getElementById('initWeightsBtn');\n\nconst lrInput = document.getElementById('lrInput');\nconst momentumInput = document.getElementById('momentumInput');\nconst l2Input = document.getElementById('l2Input');\nconst clipInput = document.getElementById('clipInput');\n\nconst datasetPreset = document.getElementById('datasetPreset');\nconst loadPresetBtn = document.getElementById('loadPresetBtn');\nconst clearDataBtn = document.getElementById('clearDataBtn');\nconst addSampleInput = document.getElementById('addSampleInput');\nconst addSampleBtn = document.getElementById('addSampleBtn');\nconst dataArea = document.getElementById('dataArea');\nconst applyDataBtn = document.getElementById('applyDataBtn');\nconst samplesPre = document.getElementById('samplesPre');\n\nconst trainBtn = document.getElementById('trainBtn');\nconst trainStepBtn = document.getElementById('trainStepBtn');\nconst stopBtn = document.getElementById('stopBtn');\nconst stepForwardBtn = document.getElementById('stepForwardBtn');\nconst stepBackwardBtn = document.getElementById('stepBackwardBtn');\nconst resetStateBtn = document.getElementById('resetStateBtn');\n\nconst lossSelect = document.getElementById('lossSelect');\nconst batchSizeInput = document.getElementById('batchSizeInput');\nconst shuffleCheckbox = document.getElementById('shuffleCheckbox');\nconst epochsInput = document.getElementById('epochsInput');\nconst epochLabel = document.getElementById('epochLabel');\nconst iterLabel = document.getElementById('iterLabel');\nconst lossLabel = document.getElementById('lossLabel');\n\nconst saveJsonBtn = document.getElementById('saveJsonBtn');\nconst loadJsonBtn = document.getElementById('loadJsonBtn');\nconst jsonFileInput = document.getElementById('jsonFileInput');\nconst randomSeedBtn = document.getElementById('randomSeedBtn');\n\nconst gradCheckBtn = document.getElementById('gradCheckBtn');\nconst gradEps = document.getElementById('gradEps');\nconst gradTol = document.getElementById('gradTol');\n\nconst networkView = document.getElementById('networkView');\nconst toggleFreezeBtn = document.getElementById('toggleFreezeBtn');\nconst zeroWeightsBtn = document.getElementById('zeroWeightsBtn');\nconst selectedLayerIndex = document.getElementById('selectedLayerIndex');\n\nconst traceSampleIndex = document.getElementById('traceSampleIndex');\nconst showForwardBtn = document.getElementById('showForwardBtn');\nconst showBackwardBtn = document.getElementById('showBackwardBtn');\nconst tracePre = document.getElementById('tracePre');\n\nconst logPre = document.getElementById('logPre');\nconst clearLogBtn = document.getElementById('clearLogBtn');\n\nconst lossHistoryPre = document.getElementById('lossHistoryPre');\nconst historyN = document.getElementById('historyN');\nconst showHistoryBtn = document.getElementById('showHistoryBtn');\n\nconst gradCheckEpsInput = gradEps;\nconst gradCheckTolInput = gradTol;\n\n// Helper functions\nfunction log(msg){\n  const time = new Date().toLocaleTimeString();\n  App.log.push(`[${time}] ${msg}`);\n  logPre.textContent = App.log.slice(-200).join('\\n');\n}\n\nfunction updateNetworkView(){\n  // Render network weights and biases as editable table\n  const net = App.net;\n  const out = [];\n  out.push('Topology: ' + net.layerSizes.join(', '));\n  out.push('Activations: ' + net.activations.join(', '));\n  out.push('');\n  for (let l=1;l<net.L;l++){\n    out.push('Layer ' + l + ' (neurons: ' + net.layerSizes[l] + ') activation: ' + net.activations[l] + (net.frozen[l] ? ' [FROZEN]' : ''));\n    const rows = [];\n    rows.push('| neuron | bias | weights from prev |');\n    for (let i=0;i<net.layerSizes[l];i++){\n      rows.push('| ' + i + ' | ' + net.biases[l][i].toFixed(4) + ' | ' + net.weights[l][i].map(v=>v.toFixed(4)).join(', ') + ' |');\n    }\n    out.push(rows.join('\\n'));\n    out.push('');\n  }\n  networkView.textContent = out.join('\\n');\n}\n\nfunction updateSamplesView(){\n  samplesPre.textContent = JSON.stringify(App.samples, null, 2);\n}\n\nfunction parseLayers(text){\n  const parts = text.split(',').map(s=>s.trim()).filter(s=>s.length>0).map(Number);\n  if (parts.some(isNaN)) throw new Error('Invalid layers input');\n  if (parts.length < 2) throw new Error('Need at least input and output layers');\n  return parts;\n}\n\nfunction parseActivations(text){\n  const parts = text.split(',').map(s=>s.trim()).filter(s=>s.length>0);\n  return parts;\n}\n\n// Dataset management\nfunction loadPreset(name){\n  App.samples = [];\n  if (name === 'xor'){\n    App.samples.push({x:[0,0], y:[0]});\n    App.samples.push({x:[0,1], y:[1]});\n    App.samples.push({x:[1,0], y:[1]});\n    App.samples.push({x:[1,1], y:[0]});\n  } else if (name === 'and'){\n    App.samples.push({x:[0,0], y:[0]});\n    App.samples.push({x:[0,1], y:[0]});\n    App.samples.push({x:[1,0], y:[0]});\n    App.samples.push({x:[1,1], y:[1]});\n  } else if (name === 'or'){\n    App.samples.push({x:[0,0], y:[0]});\n    App.samples.push({x:[0,1], y:[1]});\n    App.samples.push({x:[1,0], y:[1]});\n    App.samples.push({x:[1,1], y:[1]});\n  } else if (name === 'linear'){\n    // simple linear 2D dataset\n    for (let i=0;i<10;i++){\n      const x1 = i/9;\n      const x2 = (9-i)/9;\n      App.samples.push({x:[x1,x2], y:[x1 + x2]});\n    }\n  } else if (name === 'circle'){\n    // classification inside circle radius 0.5\n    for (let i=0;i<200;i++){\n      const ang = Math.random()*Math.PI*2;\n      const r = Math.random();\n      const x = Math.cos(ang)*r;\n      const y = Math.sin(ang)*r;\n      const label = (x*x+y*y < 0.25) ? 1 : 0;\n      App.samples.push({x:[x,y], y:[label]});\n    }\n  }\n  updateSamplesView();\n  log('Loaded preset: ' + name + ' samples: ' + App.samples.length);\n}\n\n// Apply topology\napplyLayersBtn.addEventListener('click', ()=>{\n  try {\n    const layers = parseLayers(layersInput.value);\n    const acts = parseActivations(activationsInput.value);\n    if (acts.length !== layers.length) {\n      alert('Activations length must equal number of layers');\n      return;\n    }\n    App.net = new Network(layers, acts);\n    updateNetworkView();\n    log('Applied topology: ' + layers.join(', '));\n  } catch (e){\n    alert('Error: ' + e.message);\n  }\n});\n\naddLayerBtn.addEventListener('click', ()=>{\n  // add hidden layer of average size\n  const net = App.net;\n  const hiddenIndex = net.L - 1;\n  const avg = Math.max(1, Math.round((net.layerSizes[hiddenIndex] + net.layerSizes[0]) / 2));\n  net.layerSizes.splice(net.L-1, 0, avg);\n  // add activation default\n  net.activations.splice(net.L-1, 0, 'sigmoid');\n  net.L = net.layerSizes.length;\n  net.initWeights('random');\n  updateNetworkView();\n  layersInput.value = net.layerSizes.join(',');\n  activationsInput.value = net.activations.join(',');\n  log('Added hidden layer with ' + avg + ' neurons');\n});\n\nremoveLayerBtn.addEventListener('click', ()=>{\n  const net = App.net;\n  if (net.L <= 2) {\n    alert('No hidden layers to remove');\n    return;\n  }\n  net.layerSizes.splice(net.L-2,1); // remove the last hidden layer\n  net.activations.splice(net.L-2,1);\n  net.L = net.layerSizes.length;\n  layersInput.value = net.layerSizes.join(',');\n  activationsInput.value = net.activations.join(',');\n  net.initWeights('random');\n  updateNetworkView();\n  log('Removed last hidden layer');\n});\n\ninitWeightsBtn.addEventListener('click', ()=>{\n  const mode = initSelect.value;\n  App.net.initWeights(mode);\n  updateNetworkView();\n  log('Initialized weights: ' + mode);\n});\n\n// Dataset UI\nloadPresetBtn.addEventListener('click', ()=>{\n  loadPreset(datasetPreset.value);\n});\nclearDataBtn.addEventListener('click', ()=>{\n  App.samples = [];\n  updateSamplesView();\n  log('Cleared samples');\n});\naddSampleBtn.addEventListener('click', ()=>{\n  // parse input like \"0,1 -> 1\" or \"0,1,0\"\n  const txt = addSampleInput.value;\n  try {\n    if (txt.includes('->')){\n      const parts = txt.split('->');\n      const xin = parts[0].trim();\n      const yout = parts[1].trim();\n      const xs = xin.split(',').map(s=>Number(s.trim()));\n      const ys = yout.split(',').map(s=>Number(s.trim()));\n      App.samples.push({x: xs, y: ys});\n    } else {\n      const parts = txt.split(',').map(s=>s.trim()).map(Number);\n      if (parts.length < 2) throw new Error('Need at least one input and one output');\n      const half = Math.floor(parts.length/2);\n      // ambiguous: choose 1 output if otherwise\n      const xs = parts.slice(0, parts.length-1);\n      const ys = [parts[parts.length-1]];\n      App.samples.push({x: xs, y: ys});\n    }\n    updateSamplesView();\n    log('Added sample');\n  } catch(e){\n    alert('Error parsing sample: ' + e.message);\n  }\n});\n\napplyDataBtn.addEventListener('click', ()=>{\n  // each line: x1,x2,...,y1,y2,...\n  const lines = dataArea.value.split('\\n').map(s=>s.trim()).filter(s=>s.length);\n  const newSamples = [];\n  for (const ln of lines){\n    const parts = ln.split(',').map(s=>Number(s.trim()));\n    if (parts.some(isNaN)) { alert('Bad number in line: ' + ln); return; }\n    // assume one output if ambiguous\n    if (parts.length < 2) { alert('line too short: ' + ln); return; }\n    const xs = parts.slice(0, parts.length - 1);\n    const ys = [parts[parts.length - 1]];\n    newSamples.push({x: xs, y: ys});\n  }\n  App.samples = newSamples;\n  updateSamplesView();\n  log('Applied dataset, samples: ' + App.samples.length);\n});\n\n// Training controls\nlet trainingAbort = {stop:false};\ntrainBtn.addEventListener('click', async ()=>{\n  if (App.samples.length === 0) { alert('No samples'); return; }\n  trainingAbort.stop = false;\n  App.running = true;\n  const epochs = Number(epochsInput.value);\n  const batchSize = Number(batchSizeInput.value) || 1;\n  const shuffle = shuffleCheckbox.checked;\n  const lr = Number(lrInput.value);\n  const momentum = Number(momentumInput.value);\n  const l2 = Number(l2Input.value);\n  const clip = Number(clipInput.value);\n  const lossName = lossSelect.value;\n  App.lossHistory = [];\n  App.epoch = 0;\n  App.iter = 0;\n  updateLabels();\n  log('Starting training for ' + epochs + ' epochs');\n  for (let e=0;e<epochs && !trainingAbort.stop;e++){\n    App.epoch = e+1;\n    let order = Array.from({length:App.samples.length}, (_,i)=>i);\n    if (shuffle) {\n      for (let i=order.length-1;i>0;i--){\n        const j = Math.floor(Math.random()*(i+1));\n        [order[i], order[j]] = [order[j], order[i]];\n      }\n    }\n    for (let bi=0; bi<order.length; bi+=batchSize){\n      const batchIdx = order.slice(bi, bi+batchSize);\n      // accumulate grads\n      let accumulated = null;\n      let totalLoss = 0;\n      for (const idx of batchIdx){\n        const s = App.samples[idx];\n        const yPred = App.net.forward(s.x);\n        totalLoss += (lossName === 'crossentropy' && App.net.activations[App.net.L-1] === 'softmax') ?\n          Losses.crossentropy.f(yPred, s.y) :\n          Losses[lossName].f(yPred, s.y);\n        const grads = App.net.backprop(s.y, lossName);\n        if (!accumulated){\n          accumulated = {W: grads.W.map(g=> g ? deepCopy(g) : null), B: grads.B.map(g=> g ? deepCopy(g) : null)};\n        } else {\n          // sum\n          for (let l=1;l<App.net.L;l++){\n            for (let i=0;i<App.net.layerSizes[l];i++){\n              for (let j=0;j<App.net.layerSizes[l-1];j++){\n                accumulated.W[l][i][j] += grads.W[l][i][j];\n              }\n              accumulated.B[l][i] += grads.B[l][i];\n            }\n          }\n        }\n      }\n      // average\n      const bs = batchIdx.length;\n      for (let l=1;l<App.net.L;l++){\n        for (let i=0;i<App.net.layerSizes[l];i++){\n          for (let j=0;j<App.net.layerSizes[l-1];j++){\n            accumulated.W[l][i][j] /= bs;\n          }\n          accumulated.B[l][i] /= bs;\n        }\n      }\n      App.net.applyGradients(accumulated, lr, momentum, l2, clip);\n      App.iter++;\n      const avgLoss = totalLoss / bs;\n      App.lossHistory.push(avgLoss);\n      updateLabels(avgLoss);\n      if (trainingAbort.stop) break;\n    }\n    // epoch end\n    if (e % Math.max(1, Math.floor(epochs/10)) === 0) log('Epoch ' + (e+1) + ' loss ' + App.lossHistory.slice(-1)[0]);\n  }\n  App.running = false;\n  trainingAbort.stop = false;\n  log('Training finished at epoch ' + App.epoch);\n  updateNetworkView();\n});\n\ntrainStepBtn.addEventListener('click', ()=>{\n  if (App.samples.length === 0) { alert('No samples'); return; }\n  const batchSize = Number(batchSizeInput.value) || 1;\n  const lr = Number(lrInput.value);\n  const momentum = Number(momentumInput.value);\n  const l2 = Number(l2Input.value);\n  const clip = Number(clipInput.value);\n  const lossName = lossSelect.value;\n  const order = Array.from({length:App.samples.length}, (_,i)=>i);\n  const batchIdx = order.slice(0,batchSize);\n  let accumulated = null;\n  let totalLoss = 0;\n  for (const idx of batchIdx){\n    const s = App.samples[idx];\n    const yPred = App.net.forward(s.x);\n    totalLoss += (lossName === 'crossentropy' && App.net.activations[App.net.L-1] === 'softmax') ?\n      Losses.crossentropy.f(yPred, s.y) :\n      Losses[lossName].f(yPred, s.y);\n    const grads = App.net.backprop(s.y, lossName);\n    if (!accumulated){\n      accumulated = {W: grads.W.map(g=> g ? deepCopy(g) : null), B: grads.B.map(g=> g ? deepCopy(g) : null)};\n    } else {\n      for (let l=1;l<App.net.L;l++){\n        for (let i=0;i<App.net.layerSizes[l];i++){\n          for (let j=0;j<App.net.layerSizes[l-1];j++){\n            accumulated.W[l][i][j] += grads.W[l][i][j];\n          }\n          accumulated.B[l][i] += grads.B[l][i];\n        }\n      }\n    }\n  }\n  const bs = batchIdx.length;\n  for (let l=1;l<App.net.L;l++){\n    for (let i=0;i<App.net.layerSizes[l];i++){\n      for (let j=0;j<App.net.layerSizes[l-1];j++){\n        accumulated.W[l][i][j] /= bs;\n      }\n      accumulated.B[l][i] /= bs;\n    }\n  }\n  App.net.applyGradients(accumulated, lr, momentum, l2, clip);\n  App.iter++;\n  const avgLoss = totalLoss / bs;\n  App.lossHistory.push(avgLoss);\n  updateLabels(avgLoss);\n  log('Performed one training step, loss: ' + avgLoss.toFixed(6));\n  updateNetworkView();\n});\n\nstopBtn.addEventListener('click', ()=>{\n  trainingAbort.stop = true;\n  App.running = false;\n  log('Stop requested');\n});\n\nstepForwardBtn.addEventListener('click', ()=>{\n  const idx = Number(traceSampleIndex.value) || 0;\n  if (!App.samples[idx]) { alert('No such sample'); return; }\n  const y = App.net.forward(App.samples[idx].x);\n  tracePre.textContent = 'Forward for sample ' + idx + '\\n' + JSON.stringify({x:App.samples[idx].x, z: App.net.Z, a: App.net.A}, null, 2);\n  updateNetworkView();\n  log('Stepped forward sample ' + idx);\n});\n\nstepBackwardBtn.addEventListener('click', ()=>{\n  const idx = Number(traceSampleIndex.value) || 0;\n  if (!App.samples[idx]) { alert('No such sample'); return; }\n  App.net.forward(App.samples[idx].x);\n  const grads = App.net.backprop(App.samples[idx].y, lossSelect.value);\n  tracePre.textContent = 'Backward for sample ' + idx + '\\n' + JSON.stringify(grads, null, 2);\n  log('Computed backprop for sample ' + idx);\n});\n\nresetStateBtn.addEventListener('click', ()=>{\n  App.net.resetState();\n  log('Reset network state');\n});\n\n// Utilities\nsaveJsonBtn.addEventListener('click', ()=>{\n  const data = JSON.stringify(App.net.toJSON());\n  const blob = new Blob([data], {type:'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'network.json';\n  a.click();\n  URL.revokeObjectURL(url);\n  log('Saved network JSON');\n});\n\nloadJsonBtn.addEventListener('click', ()=>{\n  jsonFileInput.click();\n});\njsonFileInput.addEventListener('change', (ev)=>{\n  const f = ev.target.files[0];\n  if (!f) return;\n  const reader = new FileReader();\n  reader.onload = function(e){\n    const obj = JSON.parse(e.target.result);\n    App.net.loadJSON(obj);\n    updateNetworkView();\n    layersInput.value = App.net.layerSizes.join(',');\n    activationsInput.value = App.net.activations.join(',');\n    log('Loaded network JSON');\n  };\n  reader.readAsText(f);\n});\n\nrandomSeedBtn.addEventListener('click', ()=>{\n  App.rngSeed = Math.floor(Math.random()*1000000);\n  log('Set random seed (not used globally) to ' + App.rngSeed);\n});\n\n// Network viewer actions\ntoggleFreezeBtn.addEventListener('click', ()=>{\n  const idx = Number(selectedLayerIndex.value);\n  if (isNaN(idx) || idx <= 0 || idx >= App.net.L){ alert('Invalid layer index'); return; }\n  App.net.frozen[idx] = !App.net.frozen[idx];\n  updateNetworkView();\n  log('Toggled freeze for layer ' + idx + ' => ' + App.net.frozen[idx]);\n});\nzeroWeightsBtn.addEventListener('click', ()=>{\n  const idx = Number(selectedLayerIndex.value);\n  if (isNaN(idx) || idx <= 0 || idx >= App.net.L){ alert('Invalid layer index'); return; }\n  for (let i=0;i<App.net.layerSizes[idx];i++){\n    App.net.biases[idx][i] = 0;\n    for (let j=0;j<App.net.layerSizes[idx-1];j++){\n      App.net.weights[idx][i][j] = 0;\n    }\n  }\n  updateNetworkView();\n  log('Zeroed weights for layer ' + idx);\n});\n\n// Trace buttons\nshowForwardBtn.addEventListener('click', ()=>{\n  const idx = Number(traceSampleIndex.value);\n  if (!App.samples[idx]) { alert('No such sample'); return; }\n  const y = App.net.forward(App.samples[idx].x);\n  const out = [];\n  out.push('Sample ' + idx);\n  out.push('Input: ' + JSON.stringify(App.samples[idx].x));\n  for (let l=1;l<App.net.L;l++){\n    out.push('Layer ' + l + ' pre-activations: ' + JSON.stringify(App.net.Z[l].map(v=>v.toFixed(6))));\n    out.push('Layer ' + l + ' activations: ' + JSON.stringify(App.net.A[l].map(v=>v.toFixed(6))));\n  }\n  out.push('Output: ' + JSON.stringify(y.map(v=>v.toFixed(6))));\n  tracePre.textContent = out.join('\\n');\n});\n\nshowBackwardBtn.addEventListener('click', ()=>{\n  const idx = Number(traceSampleIndex.value);\n  if (!App.samples[idx]) { alert('No such sample'); return; }\n  App.net.forward(App.samples[idx].x);\n  const grads = App.net.backprop(App.samples[idx].y, lossSelect.value);\n  const out = [];\n  out.push('Backprop for sample ' + idx);\n  for (let l=1;l<App.net.L;l++){\n    out.push('Layer ' + l + ' grad biases: ' + JSON.stringify(grads.B[l].map(v=>v.toFixed(8))));\n    out.push('Layer ' + l + ' grad weights: ');\n    for (let i=0;i<grads.W[l].length;i++){\n      out.push('  neuron ' + i + ': ' + JSON.stringify(grads.W[l][i].map(v=>v.toFixed(8))));\n    }\n  }\n  tracePre.textContent = out.join('\\n');\n});\n\n// Logging\nclearLogBtn.addEventListener('click', ()=>{\n  App.log = [];\n  logPre.textContent = '';\n});\n\n// Loss history\nshowHistoryBtn.addEventListener('click', ()=>{\n  const N = Number(historyN.value) || 50;\n  const h = App.lossHistory.slice(-N);\n  lossHistoryPre.textContent = JSON.stringify(h, null, 2);\n});\n\n// Gradient check\ngradCheckBtn.addEventListener('click', ()=>{\n  if (App.samples.length === 0) { alert('No samples'); return; }\n  const s = App.samples[0];\n  // pick one weight randomly to check\n  const eps = Number(gradEps.value) || 1e-5;\n  const tol = Number(gradTol.value) || 1e-4;\n  App.net.forward(s.x);\n  const grads = App.net.backprop(s.y, lossSelect.value);\n  // find a non-frozen layer and a non-zero weight to test\n  let chosen = null;\n  for (let l=1;l<App.net.L && !chosen;l++){\n    for (let i=0;i<App.net.layerSizes[l] && !chosen;i++){\n      for (let j=0;j<App.net.layerSizes[l-1] && !chosen;j++){\n        chosen = {l,i,j};\n      }\n    }\n  }\n  if (!chosen) { alert('No weights to check'); return; }\n  const {l,i,j} = chosen;\n  const orig = App.net.weights[l][i][j];\n  // approximate derivative by finite differences\n  App.net.weights[l][i][j] = orig + eps;\n  const y1 = App.net.forward(s.x);\n  const loss1 = (lossSelect.value === 'crossentropy' && App.net.activations[App.net.L-1] === 'softmax') ?\n    Losses.crossentropy.f(y1, s.y) : Losses[lossSelect.value].f(y1, s.y);\n  App.net.weights[l][i][j] = orig - eps;\n  const y2 = App.net.forward(s.x);\n  const loss2 = (lossSelect.value === 'crossentropy' && App.net.activations[App.net.L-1] === 'softmax') ?\n    Losses.crossentropy.f(y2, s.y) : Losses[lossSelect.value].f(y2, s.y);\n  const numeric = (loss1 - loss2) / (2*eps);\n  // restore\n  App.net.weights[l][i][j] = orig;\n  App.net.forward(s.x);\n  const analyticGrads = App.net.backprop(s.y, lossSelect.value);\n  const analytic = analyticGrads.W[l][i][j];\n  const diff = Math.abs(numeric - analytic);\n  const ok = diff < tol;\n  log('GradCheck weight w['+l+']['+i+']['+j+'] numeric=' + numeric.toExponential(6) + ' analytic=' + analytic.toExponential(6) + ' diff=' + diff.toExponential(6) + ' ok=' + ok);\n  alert('GradCheck result: numeric=' + numeric + ' analytic=' + analytic + ' diff=' + diff + ' ok=' + ok);\n});\n\n// Update labels\nfunction updateLabels(loss=null){\n  epochLabel.textContent = App.epoch;\n  iterLabel.textContent = App.iter;\n  lossLabel.textContent = (loss === null ? (App.lossHistory.length ? App.lossHistory.slice(-1)[0].toFixed(6) : 'N/A') : loss.toFixed(6));\n  updateNetworkView();\n  updateSamplesView();\n  lossHistoryPre.textContent = JSON.stringify(App.lossHistory.slice(-200), null, 2);\n}\n\n// Initial rendering\nupdateNetworkView();\nupdateSamplesView();\nlog('Ready. Use controls to build network, load data, and run backpropagation experiments.');\n\n</script>\n</body>\n</html>"
  },
