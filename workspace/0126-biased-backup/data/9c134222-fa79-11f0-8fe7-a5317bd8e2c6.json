  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Multiset Explorer - Interactive Playground</title>\n<style>\n/* Extremely minimal styling: plain black text on white background, basic layout only */\nhtml,body { height: 100%; margin: 8px; font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color: #000; background: #fff; }\nsection { margin-bottom: 16px; padding: 6px 0; }\nlabel { display: inline-block; margin-right: 8px; }\nbutton, input, select, textarea { margin: 4px 6px 4px 0; font: inherit; }\ntextarea { width:100%; height:80px; }\n.controls-row { margin-bottom:8px; }\n.split { display: flex; gap: 12px; align-items: flex-start; }\n.column { flex: 1 1 0; min-width: 240px; }\n.small { width: 90px; }\n.listbox { width:100%; height:160px; }\ntable { border-collapse: collapse; }\ntd, th { padding: 2px 6px; vertical-align: top; }\n.code { font-family: monospace; white-space: pre-wrap; }\n.op-list { max-height:160px; overflow:auto; border: 1px solid #ddd; padding: 6px; }\n.badge { display:inline-block; padding:2px 6px; margin-left:6px; border:1px solid #ddd; }\n</style>\n</head>\n<body>\n\n<h2>Multiset Explorer</h2>\n\n<section>\n  <div class=\"controls-row\">\n    <label for=\"ms-select\">Active multiset:</label>\n    <select id=\"ms-select\"></select>\n    <button id=\"new-ms\">New</button>\n    <button id=\"clone-ms\">Clone</button>\n    <button id=\"rename-ms\">Rename</button>\n    <button id=\"delete-ms\">Delete</button>\n    <span class=\"badge\" id=\"ms-stats\">distinct:0 total:0</span>\n  </div>\n\n  <div class=\"controls-row\">\n    <label for=\"element-input\">Element:</label>\n    <input id=\"element-input\" placeholder=\"text or number\" />\n    <label for=\"multiplicity-input\">Multiplicity:</label>\n    <input id=\"multiplicity-input\" class=\"small\" type=\"number\" value=\"1\" min=\"0\" />\n    <button id=\"add-element\">Add / Set</button>\n    <button id=\"inc-element\">+1</button>\n    <button id=\"dec-element\">-1</button>\n    <button id=\"remove-element\">Remove</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label for=\"bulk-input\">Bulk add (comma/newline separated, optional multiplicities like a:3):</label>\n  </div>\n  <div class=\"controls-row\">\n    <textarea id=\"bulk-input\" placeholder=\"apple:2, banana, orange:4\"></textarea>\n    <button id=\"apply-bulk\">Apply to active</button>\n    <button id=\"clear-bulk\">Clear</button>\n  </div>\n\n  <div class=\"controls-row\">\n    <label>Quick element generator:</label>\n    <select id=\"gen-type\">\n      <option value=\"words\">words</option>\n      <option value=\"ints\">integers</option>\n      <option value=\"letters\">letters</option>\n      <option value=\"pattern\">pattern</option>\n    </select>\n    <label for=\"gen-count\">distinct</label>\n    <input id=\"gen-count\" type=\"number\" value=\"5\" class=\"small\" min=\"1\" />\n    <label for=\"gen-multi-max\">max multiplicity</label>\n    <input id=\"gen-multi-max\" type=\"number\" value=\"5\" class=\"small\" min=\"1\" />\n    <button id=\"gen-add\">Generate and add</button>\n    <button id=\"gen-replace\">Generate and replace</button>\n    <input id=\"gen-pattern\" placeholder=\"pattern e.g. item_{i}\" class=\"small\" />\n  </div>\n</section>\n\n<section>\n  <div class=\"split\">\n    <div class=\"column\">\n      <h4>Multiset View</h4>\n      <div class=\"controls-row\">\n        <label>View mode:</label>\n        <select id=\"view-mode\">\n          <option value=\"compact\">Compact (element:count)</option>\n          <option value=\"expanded\">Expanded (repeated items)</option>\n          <option value=\"sorted\">Sorted by multiplicity desc</option>\n        </select>\n        <label for=\"expand-limit\">expand limit</label>\n        <input id=\"expand-limit\" type=\"number\" value=\"50\" class=\"small\" min=\"1\" />\n      </div>\n      <div id=\"ms-view\" class=\"code\"></div>\n      <div class=\"controls-row\">\n        <button id=\"copy-as-list\">Copy expanded list to clipboard</button>\n        <button id=\"export-json\">Export JSON</button>\n        <button id=\"import-json\">Import JSON</button>\n      </div>\n      <div class=\"controls-row\">\n        <label for=\"filter-input\">Filter elements (substring or regex /.../):</label>\n        <input id=\"filter-input\" class=\"small\" />\n        <button id=\"apply-filter\">Apply</button>\n        <button id=\"clear-filter\">Clear</button>\n      </div>\n    </div>\n\n    <div class=\"column\">\n      <h4>Operations (between A and B or single)</h4>\n      <div class=\"controls-row\">\n        <label for=\"lhs-select\">LHS:</label>\n        <select id=\"lhs-select\"></select>\n        <label for=\"rhs-select\">RHS:</label>\n        <select id=\"rhs-select\"></select>\n      </div>\n\n      <div class=\"controls-row\">\n        <button id=\"op-union\">Union (max)</button>\n        <button id=\"op-sum\">Sum (add)</button>\n        <button id=\"op-intersection\">Intersection (min)</button>\n        <button id=\"op-diff\">Difference (lhs - rhs)</button>\n        <button id=\"op-symdiff\">Symmetric diff (abs)</button>\n      </div>\n\n      <div class=\"controls-row\">\n        <label for=\"op-scale\">Scale multiplicities by</label>\n        <input id=\"op-scale\" type=\"number\" value=\"1\" class=\"small\" />\n        <button id=\"op-scale-btn\">Apply to active</button>\n        <label for=\"op-cap\">Cap at</label>\n        <input id=\"op-cap\" type=\"number\" value=\"10\" class=\"small\" />\n        <button id=\"op-cap-btn\">Cap active</button>\n      </div>\n\n      <div class=\"controls-row\">\n        <label for=\"op-filter-min\">Keep multiplicity >=</label>\n        <input id=\"op-filter-min\" type=\"number\" value=\"1\" class=\"small\" />\n        <label for=\"op-filter-max\">and <=</label>\n        <input id=\"op-filter-max\" type=\"number\" value=\"9999\" class=\"small\" />\n        <button id=\"op-filter-btn\">Filter active</button>\n      </div>\n\n      <div class=\"controls-row\">\n        <label for=\"sample-k\">Random sample k</label>\n        <input id=\"sample-k\" type=\"number\" value=\"3\" class=\"small\" min=\"1\" />\n        <label><input id=\"sample-replace\" type=\"checkbox\" /> with replacement</label>\n        <button id=\"sample-btn\">Sample from active</button>\n      </div>\n\n      <div class=\"controls-row\">\n        <label for=\"apply-to\">Apply result to:</label>\n        <select id=\"apply-to\"></select>\n        <button id=\"apply-result-new\">Create New</button>\n        <button id=\"apply-result-overwrite\">Overwrite target</button>\n      </div>\n\n      <div class=\"controls-row\">\n        <label for=\"op-log-desc\">Operation description (for log):</label>\n        <input id=\"op-log-desc\" placeholder=\"optional note\" />\n        <button id=\"run-op-and-log\">Run & Log</button>\n      </div>\n\n      <div>\n        <strong>Operation preview:</strong>\n        <div id=\"op-preview\" class=\"code\"></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section>\n  <div class=\"split\">\n    <div class=\"column\">\n      <h4>History & Undo/Redo</h4>\n      <div class=\"controls-row\">\n        <button id=\"undo\">Undo</button>\n        <button id=\"redo\">Redo</button>\n        <label for=\"history-slider\">History index:</label>\n        <input id=\"history-slider\" type=\"range\" min=\"0\" max=\"0\" value=\"0\" style=\"width:200px;\" />\n      </div>\n      <div class=\"controls-row\">\n        <strong>History:</strong>\n        <div id=\"history-list\" class=\"op-list\"></div>\n      </div>\n    </div>\n\n    <div class=\"column\">\n      <h4>Workflow Builder (chain operations)</h4>\n      <div class=\"controls-row\">\n        <label for=\"wf-name\">Name:</label>\n        <input id=\"wf-name\" placeholder=\"workflow name\" />\n        <button id=\"wf-new\">New</button>\n        <button id=\"wf-load\">Load JSON</button>\n        <button id=\"wf-save\">Export JSON</button>\n      </div>\n\n      <div class=\"controls-row\">\n        <label>Choose op:</label>\n        <select id=\"wf-op-type\">\n          <option value=\"union\">union</option>\n          <option value=\"sum\">sum</option>\n          <option value=\"intersection\">intersection</option>\n          <option value=\"difference\">difference</option>\n          <option value=\"symdiff\">symdiff</option>\n          <option value=\"scale\">scale</option>\n          <option value=\"cap\">cap</option>\n          <option value=\"filter\">filter</option>\n          <option value=\"map\">map(element mapping)</option>\n        </select>\n        <label for=\"wf-lhs\">LHS</label>\n        <select id=\"wf-lhs\"></select>\n        <label for=\"wf-rhs\">RHS</label>\n        <select id=\"wf-rhs\"></select>\n      </div>\n\n      <div class=\"controls-row\">\n        <label for=\"wf-param\">Param (JSON):</label>\n        <input id=\"wf-param\" placeholder='{\"scale\":2} or {\"cap\":5}' style=\"width:60%;\" />\n        <button id=\"wf-add-op\">Add op to workflow</button>\n      </div>\n\n      <div class=\"controls-row\">\n        <div><strong>Workflow steps:</strong></div>\n        <div id=\"wf-steps\" class=\"op-list\"></div>\n      </div>\n\n      <div class=\"controls-row\">\n        <label for=\"wf-preview-target\">Preview target:</label>\n        <select id=\"wf-preview-target\"></select>\n        <button id=\"wf-preview\">Preview</button>\n        <button id=\"wf-run\">Run and create new</button>\n      </div>\n\n      <div>\n        <strong>Workflow preview result:</strong>\n        <div id=\"wf-preview-result\" class=\"code\"></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section>\n  <h4>Diagnostics / Advanced Queries</h4>\n  <div class=\"controls-row\">\n    <button id=\"distinct-btn\">Distinct elements (support)</button>\n    <button id=\"cardinality-btn\">Cardinality (total counts)</button>\n    <button id=\"topk-btn\">Top-k frequent</button>\n    <input id=\"topk-k\" type=\"number\" value=\"5\" class=\"small\" min=\"1\" />\n    <button id=\"entropy-btn\">Shannon entropy (multiplicity dist)</button>\n    <button id=\"gfs-btn\">Generating function (polynomial string)</button>\n  </div>\n  <div class=\"controls-row\">\n    <strong>Result:</strong>\n    <div id=\"diagnostic-result\" class=\"code\"></div>\n  </div>\n</section>\n\n<section>\n  <h4>Operation Log</h4>\n  <div class=\"controls-row\">\n    <div id=\"op-log\" class=\"op-list\"></div>\n    <button id=\"clear-log\">Clear log</button>\n    <button id=\"export-log\">Export log JSON</button>\n  </div>\n</section>\n\n<script>\n/*\nMultiset Explorer\n- Minimal visual design, many interactive controls\n- Multisets are maps from string element -> integer multiplicity >=0\n- Multiple multisets managed by name\n- Undo/redo, history, workflow builder, operation chaining, many operations\n*/\n\n(function(){\n\n/* Utilities */\nfunction cloneDeep(obj) { return JSON.parse(JSON.stringify(obj)); }\nfunction isRegexLike(s) { return /^\\\\/.+\\\\/[a-z]*$/i.test(s); }\nfunction parseRegexLike(s) {\n  if (!isRegexLike(s)) return null;\n  var parts = s.split('/');\n  var flags = parts.pop();\n  parts.shift();\n  return new RegExp(parts.join('/'), flags);\n}\nfunction elemKey(e) { return String(e); }\nfunction parseBulkText(text) {\n  const entries = {};\n  text.split(/[,\\\\n]+/).map(t => t.trim()).filter(Boolean).forEach(token => {\n    // token maybe \"a:3\" or \"b=4\" or just \"x\"\n    let m = token.match(/^(.+?)\\\\s*[:=]\\\\s*([0-9]+)\\\\s*$/);\n    if (m) {\n      entries[elemKey(m[1].trim())] = (entries[elemKey(m[1].trim())] || 0) + parseInt(m[2]);\n    } else {\n      entries[elemKey(token)] = (entries[elemKey(token)] || 0) + 1;\n    }\n  });\n  return entries;\n}\n\n/* Data store */\nlet state = {\n  multisets: {}, // name -> {elem:count}\n  namesOrder: [],\n  active: null,\n  history: [], // snapshots of multisets state, with description\n  historyIndex: -1,\n  log: [],\n  undoStack: [],\n  redoStack: []\n};\n\nfunction snapshot(description) {\n  // deep copy current multisets\n  const data = cloneDeep({multisets: state.multisets, namesOrder: state.namesOrder, active: state.active});\n  // discard redo on new snapshot\n  state.history = state.history.slice(0, state.historyIndex+1);\n  state.history.push({data, description, time: (new Date()).toISOString()});\n  state.historyIndex = state.history.length - 1;\n  updateHistoryUI();\n}\n\n/* Initialize with two sample multisets */\nfunction newMultiset(name, base) {\n  let nm = name || makeUniqueName(\"M\");\n  state.multisets[nm] = base ? cloneDeep(base) : {};\n  state.namesOrder.push(nm);\n  if (!state.active) state.active = nm;\n  snapshot(\"Created multiset \" + nm);\n  refreshAll();\n  return nm;\n}\nfunction makeUniqueName(prefix) {\n  prefix = prefix || \"M\";\n  let i = 1;\n  while (state.namesOrder.includes(prefix + i)) i++;\n  return prefix + i;\n}\n\n/* Core multiset ops */\nfunction setMultiplicity(msName, elem, count) {\n  count = Math.max(0, Math.floor(count));\n  const ms = state.multisets[msName];\n  if (count === 0) {\n    delete ms[elemKey(elem)];\n  } else {\n    ms[elemKey(elem)] = count;\n  }\n  snapshot(\"Set \" + elem + \" -> \" + count + \" in \" + msName);\n  refreshAll();\n}\nfunction incMultiplicity(msName, elem, delta) {\n  delta = Math.floor(delta)||0;\n  const ms = state.multisets[msName] || {};\n  const key = elemKey(elem);\n  const prev = ms[key] || 0;\n  const next = Math.max(0, prev + delta);\n  if (next === 0) delete ms[key]; else ms[key] = next;\n  snapshot((delta>=0?\"+\":\"\") + delta + \" \" + elem + \" in \" + msName);\n  refreshAll();\n}\nfunction addBulk(msName, entries, replace=false) {\n  const ms = state.multisets[msName];\n  if (replace) {\n    state.multisets[msName] = cloneDeep(entries);\n    snapshot(\"Replaced \" + msName + \" with bulk\");\n  } else {\n    Object.keys(entries).forEach(k => {\n      ms[k] = (ms[k]||0) + entries[k];\n      if (ms[k] <= 0) delete ms[k];\n    });\n    snapshot(\"Added bulk to \" + msName);\n  }\n  refreshAll();\n}\n\nfunction getMultisetClone(name) { return cloneDeep(state.multisets[name] || {}); }\nfunction setMultiset(name, data, desc) {\n  state.multisets[name] = cloneDeep(data);\n  snapshot(desc || (\"Set multiset \" + name));\n  refreshAll();\n}\n\n/* Combining ops */\nfunction union(msA, msB) {\n  const a = getMultisetClone(msA), b = getMultisetClone(msB);\n  const res = {};\n  Object.keys(a).forEach(k => res[k] = Math.max(res[k]||0, a[k]));\n  Object.keys(b).forEach(k => res[k] = Math.max(res[k]||0, b[k]));\n  return res;\n}\nfunction sum(msA, msB) {\n  const a = getMultisetClone(msA), b = getMultisetClone(msB);\n  const res = {};\n  Object.keys(a).forEach(k => res[k] = (res[k]||0) + a[k]);\n  Object.keys(b).forEach(k => res[k] = (res[k]||0) + b[k]);\n  return res;\n}\nfunction intersection(msA, msB) {\n  const a = getMultisetClone(msA), b = getMultisetClone(msB);\n  const res = {};\n  Object.keys(a).forEach(k => {\n    if (b[k]) res[k] = Math.min(a[k], b[k]);\n  });\n  return res;\n}\nfunction difference(msA, msB) {\n  const a = getMultisetClone(msA), b = getMultisetClone(msB);\n  const res = {};\n  Object.keys(a).forEach(k => {\n    const v = a[k] - (b[k]||0);\n    if (v>0) res[k] = v;\n  });\n  return res;\n}\nfunction symdiff(msA, msB) {\n  const a = getMultisetClone(msA), b = getMultisetClone(msB);\n  const res = {};\n  const keys = new Set([...Object.keys(a), ...Object.keys(b)]);\n  keys.forEach(k => {\n    const v = Math.abs((a[k]||0) - (b[k]||0));\n    if (v>0) res[k] = v;\n  });\n  return res;\n}\n\n/* Transform ops */\nfunction scaleMultiset(ms, factor) {\n  factor = Number(factor) || 0;\n  const res = {};\n  Object.keys(ms).forEach(k => {\n    const v = Math.floor(ms[k] * factor);\n    if (v>0) res[k] = v;\n  });\n  return res;\n}\nfunction capMultiset(ms, cap) {\n  cap = Math.max(0, Math.floor(cap));\n  const res = {};\n  Object.keys(ms).forEach(k => {\n    const v = Math.min(ms[k], cap);\n    if (v>0) res[k] = v;\n  });\n  return res;\n}\nfunction filterByMultiplicity(ms, minv, maxv) {\n  minv = Math.floor(minv||0);\n  maxv = Math.floor(maxv||Infinity);\n  const res = {};\n  Object.keys(ms).forEach(k => {\n    const v = ms[k];\n    if (v >= minv && v <= maxv) res[k] = v;\n  });\n  return res;\n}\nfunction mapElements(ms, mapFunc) {\n  const res = {};\n  Object.keys(ms).forEach(k => {\n    const newk = mapFunc(k);\n    if (newk == null) return;\n    res[newk] = (res[newk]||0) + ms[k];\n  });\n  return res;\n}\n\n/* Sampling */\nfunction sampleFrom(ms, k, withReplacement) {\n  // expand but limit size safety\n  const expanded = [];\n  Object.keys(ms).forEach(k1 => {\n    for (let i=0;i<ms[k1];i++) {\n      expanded.push(k1);\n    }\n  });\n  if (expanded.length === 0) return [];\n  const out = [];\n  if (withReplacement) {\n    for (let i=0;i<k;i++) {\n      out.push(expanded[Math.floor(Math.random() * expanded.length)]);\n    }\n  } else {\n    // without replacement from multiset: pick up to distinct occurrences\n    const copy = expanded.slice();\n    k = Math.min(k, copy.length);\n    for (let i=0;i<k;i++) {\n      const idx = Math.floor(Math.random() * copy.length);\n      out.push(copy.splice(idx,1)[0]);\n    }\n  }\n  return out;\n}\n\n/* Metrics / diagnostics */\nfunction cardinality(ms) {\n  return Object.values(ms).reduce((s,x)=>s+x,0);\n}\nfunction supportSize(ms) {\n  return Object.keys(ms).length;\n}\nfunction distinctElements(ms) {\n  return Object.keys(ms).slice().sort();\n}\nfunction topK(ms, k) {\n  return Object.entries(ms).sort((a,b)=>b[1]-a[1]).slice(0,k);\n}\nfunction shannonEntropy(ms) {\n  const total = cardinality(ms);\n  if (total === 0) return 0;\n  let h = 0;\n  Object.values(ms).forEach(v=>{\n    const p = v / total;\n    h -= p * Math.log2(p);\n  });\n  return h;\n}\nfunction generatingFunction(ms, varName='x', maxTerms=200) {\n  // product over elements (1 + x + x^2 + ... + x^m) = product ((1-x^(m+1))/(1-x))\n  // We'll build polynomial coefficients up to some bound (cap total).\n  const total = cardinality(ms);\n  const cap = Math.min(total, maxTerms);\n  let coeffs = [1]; // coeffs[i] = coefficient for x^i\n  Object.keys(ms).forEach(k=>{\n    const m = ms[k];\n    const newCoeffs = new Array(Math.min(cap, coeffs.length + m) + 1).fill(0);\n    for (let i=0;i<coeffs.length;i++){\n      for (let j=0;j<=m && i+j<=cap;j++){\n        newCoeffs[i+j] += coeffs[i];\n      }\n    }\n    coeffs = newCoeffs;\n  });\n  return coeffs.slice(0, cap+1).map((c,i)=>c + (i>0?('*'+varName+'^'+i):'')).join(' + ');\n}\n\n/* UI wiring */\nconst el = id => document.getElementById(id);\n\n/* Initialize UI elements */\nfunction refreshMsSelects() {\n  const selects = ['ms-select', 'lhs-select', 'rhs-select', 'apply-to', 'wf-lhs', 'wf-rhs', 'wf-preview-target', 'wf-select', 'wf-preview-target'];\n  selects.forEach(id=>{\n    const s = el(id);\n    if (!s) return;\n    // remember selection\n    const prev = s.value;\n    s.innerHTML = '';\n    state.namesOrder.forEach(nm=>{\n      const o = document.createElement('option');\n      o.value = nm; o.textContent = nm;\n      s.appendChild(o);\n    });\n    if (state.active && s.id === 'ms-select') s.value = state.active;\n    // try restore previous selection\n    if (s.querySelector('option[value=\"'+prev+'\"]')) s.value = prev;\n  });\n}\n\nfunction updateMsStats() {\n  const msName = state.active;\n  if (!msName) { el('ms-stats').textContent = 'distinct:0 total:0'; return; }\n  const ms = state.multisets[msName];\n  el('ms-stats').textContent = 'distinct:' + supportSize(ms) + ' total:' + cardinality(ms);\n}\n\nfunction formatCompact(ms) {\n  return Object.keys(ms).sort().map(k=>k + ':' + ms[k]).join(', ');\n}\nfunction formatSorted(ms){\n  return Object.entries(ms).sort((a,b)=>b[1]-a[1]||a[0].localeCompare(b[0])).map(e=>e[0]+':'+e[1]).join('\\\\n');\n}\nfunction formatExpanded(ms, limit) {\n  const arr = [];\n  Object.keys(ms).forEach(k=>{\n    for (let i=0;i<ms[k] && arr.length < limit;i++) arr.push(k);\n  });\n  if (Object.values(ms).reduce((s,x)=>s+x,0) > limit) arr.push('... (truncated)');\n  return arr.join(', ');\n}\n\nfunction renderView() {\n  const msName = state.active;\n  const mode = el('view-mode').value;\n  const limit = parseInt(el('expand-limit').value) || 50;\n  let text = '';\n  if (!msName) { el('ms-view').textContent = '(no multiset)'; return;}\n  const ms = state.multisets[msName];\n  const filter = el('filter-input').value.trim();\n  let filteredMs = ms;\n  if (filter) {\n    const regex = parseRegexLike(filter);\n    filteredMs = {};\n    Object.keys(ms).forEach(k=>{\n      if (regex) {\n        if (regex.test(k)) filteredMs[k] = ms[k];\n      } else {\n        if (k.indexOf(filter) !== -1) filteredMs[k] = ms[k];\n      }\n    });\n  }\n  if (mode === 'compact') text = formatCompact(filteredMs) || '(empty)';\n  else if (mode === 'expanded') text = formatExpanded(filteredMs, limit) || '(empty)';\n  else if (mode === 'sorted') text = formatSorted(filteredMs) || '(empty)';\n  el('ms-view').textContent = text;\n  updateMsStats();\n}\n\n/* History UI */\nfunction updateHistoryUI() {\n  const hl = el('history-list');\n  hl.innerHTML = '';\n  state.history.forEach((h, idx) => {\n    const d = document.createElement('div');\n    d.textContent = idx + ': ' + (h.description || '(no desc)') + ' @' + h.time;\n    if (idx === state.historyIndex) d.style.fontWeight = 'bold';\n    d.addEventListener('click', ()=> {\n      // restore snapshot without adding new snapshot to history\n      const dp = cloneDeep(h.data);\n      state.multisets = cloneDeep(dp.multisets);\n      state.namesOrder = cloneDeep(dp.namesOrder);\n      state.active = dp.active;\n      // do not snapshot; add to undo stack\n      refreshAll();\n    });\n    hl.appendChild(d);\n  });\n  const hs = el('history-slider');\n  hs.max = Math.max(0, state.history.length-1);\n  hs.value = state.historyIndex >= 0 ? state.historyIndex : 0;\n}\n\n/* Operation preview generation */\nfunction previewOperation(type, lhs, rhs, params) {\n  params = params || {};\n  if (!lhs) return '(need LHS)';\n  const left = state.multisets[lhs] || {};\n  let res;\n  try {\n    switch(type) {\n      case 'union': res = union(lhs, rhs||lhs); break;\n      case 'sum': res = sum(lhs, rhs||lhs); break;\n      case 'intersection': res = intersection(lhs, rhs||lhs); break;\n      case 'difference': res = difference(lhs, rhs||lhs); break;\n      case 'symdiff': res = symdiff(lhs, rhs||lhs); break;\n      case 'scale': res = scaleMultiset(left, params.scale||1); break;\n      case 'cap': res = capMultiset(left, params.cap||Infinity); break;\n      case 'filter': res = filterByMultiplicity(left, params.min||0, params.max||Infinity); break;\n      case 'map':\n        if (params.mapping) {\n          const f = new Function('el', 'return ' + params.mapping);\n          res = mapElements(left, f);\n        } else res = left;\n        break;\n      default: res = left;\n    }\n  } catch(e) {\n    return 'Error generating preview: ' + e.message;\n  }\n  return JSON.stringify(res, null, 2);\n}\n\n/* Operation log management */\nfunction logOp(entry) {\n  state.log.push({time:(new Date()).toISOString(), entry});\n  renderLog();\n}\nfunction renderLog() {\n  const out = el('op-log');\n  out.innerHTML = '';\n  state.log.forEach((l, i)=>{\n    const d = document.createElement('div');\n    d.textContent = i + ': ' + l.time + ' - ' + l.entry;\n    out.appendChild(d);\n  });\n}\n\n/* Workflow builder */\nlet workflow = {name:'', steps:[]};\n\nfunction renderWorkflow() {\n  const container = el('wf-steps');\n  container.innerHTML = '';\n  workflow.steps.forEach((s, i)=>{\n    const d = document.createElement('div');\n    d.textContent = i + ': ' + s.type + ' LHS=' + s.lhs + ' RHS=' + (s.rhs||'') + ' param=' + JSON.stringify(s.param || {});\n    const up = document.createElement('button'); up.textContent = '↑'; up.addEventListener('click', ()=>{ if (i>0){ const t=workflow.steps[i-1]; workflow.steps[i-1]=workflow.steps[i]; workflow.steps[i]=t; renderWorkflow(); }});\n    const down = document.createElement('button'); down.textContent = '↓'; down.addEventListener('click', ()=>{ if (i<workflow.steps.length-1){ const t=workflow.steps[i+1]; workflow.steps[i+1]=workflow.steps[i]; workflow.steps[i]=t; renderWorkflow(); }});\n    const r = document.createElement('button'); r.textContent = 'Remove'; r.addEventListener('click', ()=>{ workflow.steps.splice(i,1); renderWorkflow();});\n    d.appendChild(up); d.appendChild(down); d.appendChild(r);\n    container.appendChild(d);\n  });\n  el('wf-name').value = workflow.name || '';\n}\n\n/* Run a workflow: starting from a target multiset name (cloned), apply each step\n   Steps refer to available multisets by name or to special token \"__current__\" representing the current result.\n*/\nfunction runWorkflow(targetName) {\n  let current = cloneDeep(state.multisets[targetName] || {});\n  workflow.steps.forEach(step=>{\n    try {\n      switch(step.type) {\n        case 'union': current = unionObject(current, state.multisets[step.rhs] || {}); break;\n        case 'sum': current = sumObject(current, state.multisets[step.rhs] || {}); break;\n        case 'intersection': current = intersectionObject(current, state.multisets[step.rhs] || {}); break;\n        case 'difference': current = differenceObject(current, state.multisets[step.rhs] || {}); break;\n        case 'symdiff': current = symdiffObject(current, state.multisets[step.rhs] || {}); break;\n        case 'scale': current = scaleMultiset(current, step.param.scale); break;\n        case 'cap': current = capMultiset(current, step.param.cap); break;\n        case 'filter': current = filterByMultiplicity(current, step.param.min, step.param.max); break;\n        case 'map':\n          if (step.param && step.param.mapping) {\n            const f = new Function('el', 'return ' + step.param.mapping);\n            current = mapElements(current, f);\n          }\n          break;\n      }\n    } catch(e) {\n      // stop on error\n      throw new Error('Error in workflow step ' + step.type + ': ' + e.message);\n    }\n  });\n  return current;\n}\n\n/* Helper object-based combine functions to apply on in-memory data (not by name) */\nfunction unionObject(aObj, bObj) {\n  const res = {};\n  Object.keys(aObj).forEach(k => res[k] = Math.max(res[k]||0, aObj[k]));\n  Object.keys(bObj).forEach(k => res[k] = Math.max(res[k]||0, bObj[k]));\n  return res;\n}\nfunction sumObject(aObj, bObj) {\n  const res = {};\n  Object.keys(aObj).forEach(k => res[k] = (res[k]||0) + aObj[k]);\n  Object.keys(bObj).forEach(k => res[k] = (res[k]||0) + bObj[k]);\n  return res;\n}\nfunction intersectionObject(aObj, bObj) {\n  const res = {};\n  Object.keys(aObj).forEach(k => {\n    if (bObj[k]) res[k] = Math.min(aObj[k], bObj[k]);\n  });\n  return res;\n}\nfunction differenceObject(aObj, bObj) {\n  const res = {};\n  Object.keys(aObj).forEach(k => {\n    const v = aObj[k] - (bObj[k]||0);\n    if (v>0) res[k] = v;\n  });\n  return res;\n}\nfunction symdiffObject(aObj, bObj) {\n  const res = {};\n  const keys = new Set([...Object.keys(aObj), ...Object.keys(bObj)]);\n  keys.forEach(k => {\n    const v = Math.abs((aObj[k]||0) - (bObj[k]||0));\n    if (v>0) res[k] = v;\n  });\n  return res;\n}\n\n/* Event handlers wiring */\nfunction wire() {\n  // basic ms management\n  el('new-ms').addEventListener('click', ()=> {\n    const name = prompt('New multiset name (leave empty for default):');\n    newMultiset(name || undefined);\n  });\n  el('clone-ms').addEventListener('click', ()=> {\n    const active = state.active;\n    if (!active) return alert('No active');\n    const newName = makeUniqueName(active + '_copy');\n    state.multisets[newName] = cloneDeep(state.multisets[active]);\n    state.namesOrder.push(newName);\n    snapshot('Cloned ' + active + ' to ' + newName);\n    refreshAll();\n  });\n  el('rename-ms').addEventListener('click', ()=>{\n    const active = state.active;\n    if (!active) return alert('No active');\n    const nn = prompt('Rename ' + active + ' to:', active);\n    if (!nn) return;\n    if (state.multisets[nn]) return alert('Name exists');\n    state.multisets[nn] = state.multisets[active];\n    state.namesOrder = state.namesOrder.map(n=> n===active? nn: n);\n    delete state.multisets[active];\n    if (state.active === active) state.active = nn;\n    snapshot('Renamed ' + active + ' -> ' + nn);\n    refreshAll();\n  });\n  el('delete-ms').addEventListener('click', ()=>{\n    const active = state.active;\n    if (!active) return alert('No active');\n    if (!confirm('Delete ' + active + '?')) return;\n    delete state.multisets[active];\n    state.namesOrder = state.namesOrder.filter(n=> n!==active);\n    state.active = state.namesOrder[0] || null;\n    snapshot('Deleted ' + active);\n    refreshAll();\n  });\n  el('ms-select').addEventListener('change', (e)=> {\n    state.active = e.target.value;\n    refreshAll();\n  });\n\n  // element ops\n  el('add-element').addEventListener('click', ()=>{\n    const name = state.active; if (!name) return alert('No active');\n    const elem = el('element-input').value.trim(); if (!elem) return alert('No element');\n    const count = Math.floor(Number(el('multiplicity-input').value) || 0);\n    if (count <= 0) return alert('multiplicity must be >0');\n    addBulk(name, {[elem]: count}, false);\n  });\n  el('inc-element').addEventListener('click', ()=>{\n    const name = state.active; if (!name) return;\n    const elem = el('element-input').value.trim(); if (!elem) return alert('No element');\n    incMultiplicity(name, elem, 1);\n  });\n  el('dec-element').addEventListener('click', ()=>{\n    const name = state.active; if (!name) return;\n    const elem = el('element-input').value.trim(); if (!elem) return alert('No element');\n    incMultiplicity(name, elem, -1);\n  });\n  el('remove-element').addEventListener('click', ()=>{\n    const name = state.active; if (!name) return;\n    const elem = el('element-input').value.trim(); if (!elem) return alert('No element');\n    setMultiplicity(name, elem, 0);\n  });\n\n  // bulk\n  el('apply-bulk').addEventListener('click', ()=> {\n    const txt = el('bulk-input').value;\n    if (!txt.trim()) return alert('No bulk text');\n    const entries = parseBulkText(txt);\n    addBulk(state.active, entries, false);\n  });\n  el('clear-bulk').addEventListener('click', ()=> el('bulk-input').value = '');\n\n  // generator\n  el('gen-add').addEventListener('click', ()=> {\n    const kind = el('gen-type').value;\n    const cnt = Math.max(1, parseInt(el('gen-count').value) || 1);\n    const mmax = Math.max(1, parseInt(el('gen-multi-max').value) || 1);\n    const pattern = el('gen-pattern').value || 'item_{i}';\n    const entries = {};\n    for (let i=1;i<=cnt;i++) {\n      let val;\n      if (kind === 'words') val = ['alpha','beta','gamma','delta','epsilon'][i % 5] + (Math.floor(i/5) || '');\n      else if (kind === 'letters') val = String.fromCharCode(96 + ((i-1)%26)+1);\n      else if (kind === 'ints') val = String(i);\n      else val = pattern.replace('{i}', i).replace('{n}', i);\n      entries[elemKey(val)] = 1 + Math.floor(Math.random() * mmax);\n    }\n    addBulk(state.active, entries, false);\n  });\n  el('gen-replace').addEventListener('click', ()=> {\n    const kind = el('gen-type').value;\n    const cnt = Math.max(1, parseInt(el('gen-count').value) || 1);\n    const mmax = Math.max(1, parseInt(el('gen-multi-max').value) || 1);\n    const pattern = el('gen-pattern').value || 'item_{i}';\n    const entries = {};\n    for (let i=1;i<=cnt;i++) {\n      let val;\n      if (kind === 'words') val = ['alpha','beta','gamma','delta','epsilon'][i % 5] + (Math.floor(i/5) || '');\n      else if (kind === 'letters') val = String.fromCharCode(96 + ((i-1)%26)+1);\n      else if (kind === 'ints') val = String(i);\n      else val = pattern.replace('{i}', i).replace('{n}', i);\n      entries[elemKey(val)] = 1 + Math.floor(Math.random() * mmax);\n    }\n    addBulk(state.active, entries, true);\n  });\n\n  // view controls\n  el('view-mode').addEventListener('change', renderView);\n  el('expand-limit').addEventListener('change', renderView);\n  el('apply-filter').addEventListener('click', renderView);\n  el('clear-filter').addEventListener('click', ()=>{\n    el('filter-input').value = '';\n    renderView();\n  });\n\n  // export/import\n  el('export-json').addEventListener('click', ()=>{\n    const ms = state.multisets[state.active];\n    if (!ms) return alert('No active');\n    const text = JSON.stringify(ms, null, 2);\n    prompt('Copy JSON', text);\n  });\n  el('import-json').addEventListener('click', ()=>{\n    const txt = prompt('Paste JSON for multiset:');\n    if (!txt) return;\n    try {\n      const obj = JSON.parse(txt);\n      if (typeof obj !== 'object') throw new Error('not object');\n      state.multisets[state.active] = obj;\n      snapshot('Imported JSON into ' + state.active);\n      refreshAll();\n    } catch(e) {\n      alert('Invalid JSON: ' + e.message);\n    }\n  });\n  el('copy-as-list').addEventListener('click', ()=>{\n    const list = [];\n    const ms = state.multisets[state.active] || {};\n    Object.keys(ms).forEach(k=>{\n      for (let i=0;i<ms[k];i++) list.push(k);\n    });\n    const txt = list.join(', ');\n    // Try clipboard\n    navigator.clipboard && navigator.clipboard.writeText(txt).then(()=>alert('Copied to clipboard'), ()=>prompt('Copy text', txt));\n  });\n\n  // operations\n  function runBinaryOp(opType) {\n    const lhs = el('lhs-select').value;\n    const rhs = el('rhs-select').value;\n    const target = el('apply-to').value;\n    if (!lhs) return alert('Choose LHS');\n    let res;\n    switch(opType) {\n      case 'union': res = union(lhs, rhs); break;\n      case 'sum': res = sum(lhs, rhs); break;\n      case 'intersection': res = intersection(lhs, rhs); break;\n      case 'difference': res = difference(lhs, rhs); break;\n      case 'symdiff': res = symdiff(lhs, rhs); break;\n    }\n    el('op-preview').textContent = JSON.stringify(res, null, 2);\n    // default: create new when apply buttons pressed\n    return res;\n  }\n  el('op-union').addEventListener('click', ()=>{ const res = runBinaryOp('union'); logOp('preview union'); });\n  el('op-sum').addEventListener('click', ()=>{ const res = runBinaryOp('sum'); logOp('preview sum'); });\n  el('op-intersection').addEventListener('click', ()=>{ const res = runBinaryOp('intersection'); logOp('preview intersection'); });\n  el('op-diff').addEventListener('click', ()=>{ const res = runBinaryOp('difference'); logOp('preview difference'); });\n  el('op-symdiff').addEventListener('click', ()=>{ const res = runBinaryOp('symdiff'); logOp('preview symdiff'); });\n\n  el('op-scale-btn').addEventListener('click', ()=>{\n    const factor = Number(el('op-scale').value);\n    const active = state.active;\n    if (!active) return alert('No active');\n    setMultiset(active, scaleMultiset(state.multisets[active], factor), 'Scaled ' + active + ' by ' + factor);\n    logOp('Scaled ' + active + ' by ' + factor);\n  });\n  el('op-cap-btn').addEventListener('click', ()=>{\n    const cap = Number(el('op-cap').value);\n    const active = state.active;\n    if (!active) return alert('No active');\n    setMultiset(active, capMultiset(state.multisets[active], cap), 'Capped ' + active + ' at ' + cap);\n    logOp('Capped ' + active + ' at ' + cap);\n  });\n\n  el('op-filter-btn').addEventListener('click', ()=>{\n    const minv = Number(el('op-filter-min').value);\n    const maxv = Number(el('op-filter-max').value);\n    const active = state.active;\n    if (!active) return alert('No active');\n    setMultiset(active, filterByMultiplicity(state.multisets[active], minv, maxv), 'Filtered ' + active + ' multiplicity in ['+minv+','+maxv+']');\n    logOp('Filtered ' + active + ' multiplicity in ['+minv+','+maxv+']');\n  });\n\n  el('sample-btn').addEventListener('click', ()=>{\n    const k = Math.max(1, Number(el('sample-k').value));\n    const wr = el('sample-replace').checked;\n    const res = sampleFrom(state.multisets[state.active] || {}, k, wr);\n    el('op-preview').textContent = 'Sample: ' + JSON.stringify(res);\n    logOp('Sampled ' + k + ' from ' + state.active + ' (replace=' + wr + ')');\n  });\n\n  el('run-op-and-log').addEventListener('click', ()=>{\n    const desc = el('op-log-desc').value || 'Manual op';\n    const prevPreview = el('op-preview').textContent;\n    // if preview is JSON, prompt whether to create new\n    let parsed;\n    try { parsed = JSON.parse(prevPreview); } catch(e){ parsed = null; }\n    if (!parsed) return alert('No valid preview to apply (generate preview first).');\n    const applyTo = el('apply-to').value;\n    const overwrite = confirm('Press OK to overwrite target ' + applyTo + '. Cancel to create new multiset.');\n    if (overwrite) {\n      setMultiset(applyTo, parsed, desc);\n      logOp(desc + ' applied overwrite -> ' + applyTo);\n    } else {\n      const newName = makeUniqueName('M');\n      state.multisets[newName] = parsed;\n      state.namesOrder.push(newName);\n      snapshot(desc + ' created ' + newName);\n      refreshAll();\n      logOp(desc + ' created new -> ' + newName);\n    }\n  });\n\n  el('apply-result-new').addEventListener('click', ()=>{\n    const prevPreview = el('op-preview').textContent;\n    let parsed;\n    try { parsed = JSON.parse(prevPreview); } catch(e){ parsed = null; }\n    if (!parsed) return alert('No preview');\n    const newName = makeUniqueName('M');\n    state.multisets[newName] = parsed;\n    state.namesOrder.push(newName);\n    snapshot('Created ' + newName + ' from preview');\n    refreshAll();\n    logOp('Created ' + newName + ' from preview');\n  });\n  el('apply-result-overwrite').addEventListener('click', ()=>{\n    const prevPreview = el('op-preview').textContent;\n    let parsed;\n    try { parsed = JSON.parse(prevPreview); } catch(e){ parsed = null; }\n    if (!parsed) return alert('No preview');\n    const tgt = el('apply-to').value;\n    if (!tgt) return alert('Choose target to overwrite');\n    state.multisets[tgt] = parsed;\n    snapshot('Overwrote ' + tgt + ' from preview');\n    refreshAll();\n    logOp('Overwrote ' + tgt + ' from preview');\n  });\n\n  // history undo/redo\n  el('undo').addEventListener('click', ()=>{\n    if (state.historyIndex <= 0) return alert('No more undo');\n    state.historyIndex--;\n    const dp = cloneDeep(state.history[state.historyIndex].data);\n    state.multisets = cloneDeep(dp.multisets);\n    state.namesOrder = cloneDeep(dp.namesOrder);\n    state.active = dp.active;\n    refreshAll();\n    updateHistoryUI();\n    logOp('Undo to ' + state.historyIndex);\n  });\n  el('redo').addEventListener('click', ()=>{\n    if (state.historyIndex >= state.history.length -1) return alert('No more redo');\n    state.historyIndex++;\n    const dp = cloneDeep(state.history[state.historyIndex].data);\n    state.multisets = cloneDeep(dp.multisets);\n    state.namesOrder = cloneDeep(dp.namesOrder);\n    state.active = dp.active;\n    refreshAll();\n    updateHistoryUI();\n    logOp('Redo to ' + state.historyIndex);\n  });\n  el('history-slider').addEventListener('input', (e)=>{\n    const idx = Number(e.target.value);\n    if (!state.history[idx]) return;\n    state.historyIndex = idx;\n    const dp = cloneDeep(state.history[idx].data);\n    state.multisets = cloneDeep(dp.multisets);\n    state.namesOrder = cloneDeep(dp.namesOrder);\n    state.active = dp.active;\n    refreshAll();\n    updateHistoryUI();\n    logOp('Jumped history to ' + idx);\n  });\n\n  // workflow builder\n  el('wf-new').addEventListener('click', ()=>{ workflow = {name:'NewWorkflow', steps:[]}; renderWorkflow();});\n  el('wf-add-op').addEventListener('click', ()=>{\n    const t = el('wf-op-type').value;\n    const lhs = el('wf-lhs').value;\n    const rhs = el('wf-rhs').value;\n    let param = {};\n    try { param = el('wf-param').value ? JSON.parse(el('wf-param').value) : {}; } catch(e){ return alert('Invalid JSON param');}\n    workflow.steps.push({type:t, lhs, rhs, param});\n    renderWorkflow();\n  });\n  el('wf-preview').addEventListener('click', ()=>{\n    const target = el('wf-preview-target').value;\n    try {\n      const res = runWorkflow(target);\n      el('wf-preview-result').textContent = JSON.stringify(res, null, 2);\n      logOp('Previewed workflow on ' + target);\n    } catch(e) {\n      alert('Workflow error: ' + e.message);\n    }\n  });\n  el('wf-run').addEventListener('click', ()=>{\n    const target = el('wf-preview-target').value;\n    try {\n      const res = runWorkflow(target);\n      const newName = makeUniqueName('WF');\n      state.multisets[newName] = res;\n      state.namesOrder.push(newName);\n      snapshot('Workflow run created ' + newName);\n      refreshAll();\n      logOp('Workflow run created ' + newName);\n    } catch(e) {\n      alert('Workflow error: ' + e.message);\n    }\n  });\n  el('wf-save').addEventListener('click', ()=>{\n    el('wf-name').value = el('wf-name').value || 'wf';\n    const json = JSON.stringify(workflow, null, 2);\n    prompt('Workflow JSON', json);\n  });\n  el('wf-load').addEventListener('click', ()=>{\n    const txt = prompt('Paste workflow JSON:');\n    if (!txt) return;\n    try {\n      workflow = JSON.parse(txt);\n      renderWorkflow();\n    } catch(e) {\n      alert('Invalid workflow JSON');\n    }\n  });\n\n  // diagnostics\n  el('distinct-btn').addEventListener('click', ()=> {\n    const ms = state.multisets[state.active] || {};\n    el('diagnostic-result').textContent = JSON.stringify(distinctElements(ms), null, 2);\n  });\n  el('cardinality-btn').addEventListener('click', ()=> {\n    const ms = state.multisets[state.active] || {};\n    el('diagnostic-result').textContent = 'cardinality: ' + cardinality(ms) + ' supportSize: ' + supportSize(ms);\n  });\n  el('topk-btn').addEventListener('click', ()=> {\n    const ms = state.multisets[state.active] || {};\n    const k = Math.max(1, Number(el('topk-k').value));\n    el('diagnostic-result').textContent = JSON.stringify(topK(ms, k), null, 2);\n  });\n  el('entropy-btn').addEventListener('click', ()=> {\n    const ms = state.multisets[state.active] || {};\n    el('diagnostic-result').textContent = 'Shannon entropy: ' + shannonEntropy(ms).toFixed(4);\n  });\n  el('gfs-btn').addEventListener('click', ()=> {\n    const ms = state.multisets[state.active] || {};\n    el('diagnostic-result').textContent = generatingFunction(ms, 'x', 100);\n  });\n\n  // log controls\n  el('clear-log').addEventListener('click', ()=>{ state.log = []; renderLog();});\n  el('export-log').addEventListener('click', ()=>{ prompt('Copy operation log JSON', JSON.stringify(state.log, null, 2));});\n}\n\n/* Render all UI parts */\nfunction refreshAll() {\n  refreshMsSelects();\n  renderView();\n  updateHistoryUI();\n  renderLog();\n  renderWorkflow();\n  renderApplyToOptions();\n}\n\n/* helper to update apply-to dropdowns */\nfunction renderApplyToOptions() {\n  const selects = ['apply-to', 'wf-preview-target', 'wf-lhs', 'wf-rhs', 'lhs-select', 'rhs-select', 'ms-select'];\n  selects.forEach(id=>{\n    const s = el(id);\n    if (!s) return;\n    const prev = s.value;\n    s.innerHTML = '';\n    state.namesOrder.forEach(nm=> {\n      const o = document.createElement('option'); o.value = nm; o.textContent = nm;\n      s.appendChild(o);\n    });\n    if (state.namesOrder.length === 0) {\n      const o = document.createElement('option'); o.value = ''; o.textContent = '(none)';\n      s.appendChild(o);\n    }\n    if (prev && s.querySelector('option[value=\"'+prev+'\"]')) s.value = prev;\n    if (id === 'ms-select' && state.active) s.value = state.active;\n  });\n}\n\n/* Initialize sample data */\nfunction bootstrap() {\n  // Create two sample multisets for experimentation\n  state.multisets['M1'] = {'apple':3,'banana':2,'orange':1};\n  state.multisets['M2'] = {'banana':4,'cherry':2,'apple':1};\n  state.namesOrder.push('M1','M2');\n  state.active = 'M1';\n  snapshot('Initial sample multisets');\n  refreshAll();\n}\n\n/* Wire up preview generator when selections change */\nfunction attachPreviews() {\n  const previewUpdater = () => {\n    const type = (document.querySelector('input[name=\"hidden\"]') || {}).value;\n  };\n}\n\n/* Initialization */\nwire();\nbootstrap();\n\n})(); // end closure\n</script>\n\n</body>\n</html>"
