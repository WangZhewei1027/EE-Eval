    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Cosmic Harmony</title>\n    <style>\n        :root {\n            --primary: #2a2358;\n            --secondary: #9a7bb0;\n            --accent: #e8c7c8;\n            --text: #f0e6ef;\n            --space-dark: #0c0b1d;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            background: var(--space-dark);\n            color: var(--text);\n            font-family: 'Montserrat', sans-serif;\n            overflow: hidden;\n            height: 100vh;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            perspective: 1000px;\n        }\n\n        @font-face {\n            font-family: 'Montserrat';\n            src: url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&display=swap');\n        }\n\n        .header {\n            position: absolute;\n            top: 5%;\n            text-align: center;\n            z-index: 10;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            margin-bottom: 1rem;\n            letter-spacing: 0.5rem;\n            text-transform: uppercase;\n            background: linear-gradient(90deg, var(--accent), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 2s ease forwards 0.5s;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            font-weight: 300;\n            letter-spacing: 0.3rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 2s ease forwards 1s;\n        }\n\n        .cosmic-scene {\n            position: relative;\n            width: 100%;\n            height: 100vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .galaxy {\n            position: relative;\n            width: 600px;\n            height: 600px;\n            border-radius: 50%;\n            background: radial-gradient(circle at center, transparent 40%, var(--primary) 100%);\n            box-shadow: 0 0 200px var(--secondary);\n            transform-style: preserve-3d;\n            animation: rotate 120s linear infinite;\n        }\n\n        .star {\n            position: absolute;\n            background: white;\n            border-radius: 50%;\n            filter: blur(1px);\n            animation: twinkle 4s ease-in-out infinite alternate;\n        }\n\n        .planet {\n            position: absolute;\n            border-radius: 50%;\n            transform-style: preserve-3d;\n        }\n\n        .planet-1 {\n            width: 120px;\n            height: 120px;\n            background: linear-gradient(135deg, var(--accent), var(--secondary));\n            box-shadow: 0 0 50px var(--accent);\n            top: 20%;\n            left: 20%;\n            animation: orbit-1 40s linear infinite;\n        }\n\n        .planet-2 {\n            width: 80px;\n            height: 80px;\n            background: linear-gradient(135deg, #7bb0b0, #4d8b8b);\n            box-shadow: 0 0 30px #7bb0b0;\n            top: 60%;\n            left: 70%;\n            animation: orbit-2 30s linear infinite;\n        }\n\n        .planet-3 {\n            width: 160px;\n            height: 160px;\n            background: linear-gradient(135deg, #b07b9a, #8b4d6e);\n            box-shadow: 0 0 60px #b07b9a;\n            top: 70%;\n            left: 30%;\n            animation: orbit-3 50s linear infinite;\n        }\n\n        .control-panel {\n            position: absolute;\n            bottom: 10%;\n            display: flex;\n            gap: 2rem;\n            z-index: 10;\n        }\n\n        .btn {\n            padding: 1rem 2rem;\n            background: transparent;\n            color: var(--text);\n            border: 1px solid var(--secondary);\n            border-radius: 50px;\n            font-size: 1rem;\n            letter-spacing: 0.1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            opacity: 0;\n            animation: fadeIn 2s ease forwards 1.5s;\n        }\n\n        .btn:hover {\n            background: var(--secondary);\n            box-shadow: 0 0 20px var(--secondary);\n            transform: translateY(-3px);\n        }\n\n        .nebula {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            background: radial-gradient(circle at 30% 30%, rgba(154, 123, 176, 0.2) 0%, transparent 50%),\n                        radial-gradient(circle at 70% 70%, rgba(232, 199, 200, 0.2) 0%, transparent 50%);\n            opacity: 0.5;\n            z-index: -1;\n        }\n\n        @keyframes rotate {\n            0% { transform: rotateZ(0deg); }\n            100% { transform: rotateZ(360deg); }\n        }\n\n        @keyframes orbit-1 {\n            0% { transform: rotateZ(0deg) translateX(250px) rotateZ(0deg); }\n            100% { transform: rotateZ(360deg) translateX(250px) rotateZ(360deg); }\n        }\n\n        @keyframes orbit-2 {\n            0% { transform: rotateZ(0deg) translateX(180px) rotateZ(0deg); }\n            100% { transform: rotateZ(360deg) translateX(180px) rotateZ(360deg); }\n        }\n\n        @keyframes orbit-3 {\n            0% { transform: rotateZ(0deg) translateX(300px) rotateZ(0deg); }\n            100% { transform: rotateZ(360deg) translateX(300px) rotateZ(360deg); }\n        }\n\n        @keyframes twinkle {\n            0% { opacity: 0.3; }\n            100% { opacity: 1; }\n        }\n\n        @keyframes fadeIn {\n            0% { opacity: 0; transform: translateY(20px); }\n            100% { opacity: 1; transform: translateY(0); }\n        }\n\n        .pulse {\n            animation: pulse 4s infinite;\n        }\n\n        @keyframes pulse {\n            0% { box-shadow: 0 0 0 0 rgba(154, 123, 176, 0.7); }\n            70% { box-shadow: 0 0 0 20px rgba(154, 123, 176, 0); }\n            100% { box-shadow: 0 0 0 0 rgba(154, 123, 176, 0); }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Cosmic Harmony</h1>\n        <p class=\"subtitle\">A Celestial Dance of Light and Motion</p>\n    </div>\n\n    <div class=\"cosmic-scene\">\n        <div class=\"nebula\"></div>\n        <div class=\"galaxy pulse\">\n            <!-- Stars will be generated by JS -->\n        </div>\n        <div class=\"planet planet-1\"></div>\n        <div class=\"planet planet-2\"></div>\n        <div class=\"planet planet-3\"></div>\n    </div>\n\n    <div class=\"control-panel\">\n        <button class=\"btn\" id=\"pauseBtn\">Pause Motion</button>\n        <button class=\"btn\" id=\"themeBtn\">Change Theme</button>\n    </div>\n\n    <script>\n        // Create stars\n        const galaxy = document.querySelector('.galaxy');\n        for (let i = 0; i < 200; i++) {\n            const star = document.createElement('div');\n            star.classList.add('star');\n            \n            // Random size between 1-3px\n            const size = Math.random() * 2 + 1;\n            star.style.width = `${size}px`;\n            star.style.height = `${size}px`;\n            \n            // Random position within galaxy\n            star.style.left = `${Math.random() * 100}%`;\n            star.style.top = `${Math.random() * 100}%`;\n            \n            // Random animation delay\n            star.style.animationDelay = `${Math.random() * 4}s`;\n            \n            galaxy.appendChild(star);\n        }\n\n        // Minimal interactivity\n        const pauseBtn = document.getElementById('pauseBtn');\n        const themeBtn = document.getElementById('themeBtn');\n        let isPaused = false;\n        let currentTheme = 'default';\n\n        const themes = {\n            default: {\n                primary: '#2a2358',\n                secondary: '#9a7bb0',\n                accent: '#e8c7c8'\n            },\n            nebula: {\n                primary: '#1a1b3a',\n                secondary: '#7b9ab0',\n                accent: '#c7e8e0'\n            },\n            cosmic: {\n                primary: '#3a1b5a',\n                secondary: '#b07b7b',\n                accent: '#e8c7d8'\n            }\n        };\n\n        pauseBtn.addEventListener('click', () => {\n            isPaused = !isPaused;\n            const planets = document.querySelectorAll('.planet');\n            const galaxy = document.querySelector('.galaxy');\n            \n            if (isPaused) {\n                planets.forEach(p => p.style.animationPlayState = 'paused');\n                galaxy.style.animationPlayState = 'paused';\n                pauseBtn.textContent = 'Resume Motion';\n            } else {\n                planets.forEach(p => p.style.animationPlayState = 'running');\n                galaxy.style.animationPlayState = 'running';\n                pauseBtn.textContent = 'Pause Motion';\n            }\n        });\n\n        themeBtn.addEventListener('click', () => {\n            const themeKeys = Object.keys(themes);\n            currentTheme = themeKeys[(themeKeys.indexOf(currentTheme) + 1) % themeKeys.length];\n            \n            document.documentElement.style.setProperty('--primary', themes[currentTheme].primary);\n            document.documentElement.style.setProperty('--secondary', themes[currentTheme].secondary);\n            document.documentElement.style.setProperty('--accent', themes[currentTheme].accent);\n        });\n    </script>\n</body>\n</html>"
