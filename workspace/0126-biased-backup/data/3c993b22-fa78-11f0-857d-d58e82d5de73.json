    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Semaphore Concept - Visual Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap');\n\n  /* Root and base styling */\n  :root {\n    --color-bg: #0a142f;\n    --color-primary: #ff4e50;\n    --color-secondary: #011627;\n    --color-accent: #ff9a76;\n    --color-neutral-light: #e6eaf0;\n    --color-neutral-dark: #1d2d50;\n    --color-green: #3ddc97;\n    --color-red: #ff6b6b;\n    --color-yellow: #ffd166;\n    --shadow-glow: rgba(255, 78, 80, 0.4);\n    --shadow-glow-green: rgba(61, 220, 151, 0.5);\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, var(--color-secondary), var(--color-bg));\n    font-family: 'Poppins', sans-serif;\n    color: var(--color-neutral-light);\n    display: flex;\n    flex-direction: column;\n    min-height: 100vh;\n    overflow-x: hidden;\n  }\n\n  header {\n    padding: 2rem 3rem 1rem 3rem;\n    text-align: center;\n  }\n\n  header h1 {\n    font-weight: 700;\n    font-size: 3.4rem;\n    letter-spacing: 0.06em;\n    color: var(--color-primary);\n    margin: 0 0 0.3rem 0;\n    text-shadow: 0 0 8px var(--color-primary);\n    user-select: none;\n    font-variant: small-caps;\n  }\n\n  header p {\n    font-weight: 500;\n    font-size: 1.25rem;\n    color: var(--color-accent);\n    opacity: 0.85;\n    margin-top: 0;\n    user-select: none;\n  }\n\n  main {\n    flex: 1 0 auto;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 1rem 2rem 4rem 2rem;\n  }\n\n  .semaphore-container {\n    background: var(--color-neutral-dark);\n    border-radius: 1.5rem;\n    box-shadow:\n      0 0 40px 12px rgba(255, 78, 80, 0.12),\n      inset 0 4px 15px 0 rgba(255, 78, 80, 0.15);\n    width: 300px;\n    height: 560px;\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 2rem 2.5rem 2rem;\n  }\n\n  /* Semaphore pole */\n  .pole {\n    position: absolute;\n    bottom: 0;\n    left: 50%;\n    width: 20px;\n    height: 380px;\n    background: linear-gradient(180deg, #222b3a 0%, #151f2f 100%);\n    border-radius: 10px;\n    box-shadow:\n      inset 0 5px 10px -2px rgba(255, 255, 255, 0.1),\n      0 12px 20px -12px #ff4e50cc;\n    transform: translateX(-50%);\n    z-index: 1;\n  }\n  /* The base foot */\n  .base-foot {\n    position: absolute;\n    bottom: 0;\n    left: 50%;\n    width: 120px;\n    height: 36px;\n    background: linear-gradient(90deg, #151f2f 0%, #222b3a 100%);\n    border-radius: 18px/12px;\n    box-shadow:\n      inset 0 6px 14px -3px #ff4e50cc,\n      0 3px 8px 0 rgba(0,0,0,0.6);\n    transform: translateX(-50%);\n    filter: drop-shadow(0 3px 3px rgba(0,0,0,0.2));\n  }\n\n  /* Semaphore light housing */\n  .lights-housing {\n    position: relative;\n    width: 140px;\n    height: 360px;\n    background: linear-gradient(135deg, #1e2836, #2d394f);\n    border-radius: 32px;\n    box-shadow:\n      0 10px 30px -5px var(--shadow-glow),\n      inset 0 0 12px 4px #0b101a,\n      inset 0 -5px 20px #ff4e50cc;\n    border: 3.5px solid #ff4e50cc;\n    z-index: 2;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-around;\n    padding: 30px 0;\n    user-select: none;\n  }\n\n  /* Single light container */\n  .light {\n    position: relative;\n    margin: 0 auto;\n    width: 72px;\n    height: 72px;\n    border-radius: 50%;\n    background-color: #111a2e;\n    box-shadow:\n      inset 0 -6px 12px #000a19,\n      0 7px 19px -3px #000000aa;\n    transition:\n      background-color 0.8s ease,\n      box-shadow 1.25s ease;\n    cursor: default;\n  }\n\n  /* Lights colors and glow on active */\n  .light.red {\n    background: #331616;\n  }\n  .light.red.active {\n    background: #ff6b6b;\n    box-shadow:\n      0 0 28px 9px #ff6b6b99,\n      inset 0 -3px 10px 2px #ff6b6bcc;\n  }\n  .light.yellow {\n    background: #3f3a16;\n  }\n  .light.yellow.active {\n    background: #ffd166;\n    box-shadow:\n      0 0 28px 9px #ffd166cc,\n      inset 0 -3px 10px 2px #ffd166ff;\n  }\n  .light.green {\n    background: #16331a;\n  }\n  .light.green.active {\n    background: #3ddc97;\n    box-shadow:\n      0 0 28px 9px #3ddc9799,\n      inset 0 -3px 10px 2px #3ddc97cc;\n  }\n\n  /* Light halo effect */\n  .light.active::before {\n    content: \"\";\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 120%;\n    height: 120%;\n    border-radius: 50%;\n    transform: translate(-50%, -50%) scale(1);\n    opacity: 0.45;\n    filter: blur(18px);\n    z-index: -1;\n  }\n  .light.red.active::before {\n    background-color: #ff6b6b;\n  }\n  .light.yellow.active::before {\n    background-color: #ffd166;\n  }\n  .light.green.active::before {\n    background-color: #3ddc97;\n  }\n\n  /* Semaphore title below */\n  .semaphore-title {\n    margin-top: 1rem;\n    font-weight: 700;\n    font-size: 2rem;\n    color: var(--color-primary);\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    text-shadow: 0 0 12px var(--color-primary);\n    user-select: none;\n  }\n\n  /* Info panel */\n  .info-panel {\n    margin-top: 3.2rem;\n    font-weight: 400;\n    font-size: 1rem;\n    color: var(--color-neutral-light);\n    line-height: 1.6;\n    max-width: 310px;\n    text-align: center;\n    font-style: italic;\n    user-select: none;\n    opacity: 0.8;\n  }\n\n  /* Controls */\n  .controls {\n    margin-top: 3rem;\n    display: flex;\n    justify-content: center;\n    gap: 1.4rem;\n  }\n\n  button {\n    background-color: var(--color-primary);\n    border: none;\n    padding: 0.85rem 2.25rem;\n    border-radius: 32px;\n    font-size: 1rem;\n    font-weight: 600;\n    color: var(--color-neutral-light);\n    letter-spacing: 0.07em;\n    cursor: pointer;\n    box-shadow: 0 0 10px var(--shadow-glow);\n    transition:\n      background-color 0.35s ease,\n      box-shadow 0.4s ease,\n      transform 0.25s ease;\n    user-select: none;\n  }\n  button:focus {\n    outline: none;\n    box-shadow:\n      0 0 18px 3px var(--color-primary);\n  }\n  button:hover:not(:disabled) {\n    background-color: var(--color-accent);\n    box-shadow:\n      0 0 28px 6px var(--color-accent);\n    transform: translateY(-2px);\n  }\n  button:active:not(:disabled) {\n    transform: translateY(0);\n  }\n  button:disabled {\n    cursor: default;\n    opacity: 0.35;\n    box-shadow: none;\n  }\n\n  /* Footer */\n  footer {\n    text-align: center;\n    color: var(--color-neutral-light);\n    font-size: 0.9rem;\n    font-weight: 400;\n    padding-bottom: 1.5rem;\n    opacity: 0.5;\n    user-select: none;\n  }\n\n  /* Responsive */\n  @media (max-width: 400px) {\n    main {\n      padding-left: 1rem;\n      padding-right: 1rem;\n    }\n    .semaphore-container {\n      width: 260px;\n      height: 500px;\n      padding: 2rem 1.5rem 2rem 1.5rem;\n    }\n    .lights-housing {\n      width: 120px;\n      height: 320px;\n      border-radius: 26px;\n      padding: 20px 0;\n    }\n    .light {\n      width: 60px;\n      height: 60px;\n    }\n    .semaphore-title {\n      font-size: 1.6rem;\n    }\n    .info-panel {\n      max-width: 260px;\n      font-size: 0.95rem;\n    }\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Semaphore</h1>\n  <p>Visualizing the Classic Signaling Concept</p>\n</header>\n<main>\n  <section class=\"semaphore-container\" aria-label=\"Semaphore signal illustration\">\n    <div class=\"pole\" aria-hidden=\"true\"></div>\n    <div class=\"base-foot\" aria-hidden=\"true\"></div>\n    <div class=\"lights-housing\" role=\"presentation\">\n      <div class=\"light red\" id=\"light-red\" aria-label=\"Red Signal\" tabindex=\"-1\"></div>\n      <div class=\"light yellow\" id=\"light-yellow\" aria-label=\"Yellow Signal\" tabindex=\"-1\"></div>\n      <div class=\"light green\" id=\"light-green\" aria-label=\"Green Signal\" tabindex=\"-1\"></div>\n    </div>\n    <div class=\"semaphore-title\" aria-live=\"polite\" aria-atomic=\"true\">Red</div>\n    <div class=\"info-panel\">\n      Timeless semaphore uses clear color codes to signal stop, caution, and go. Observe the smooth transitions of lights illuminating in turn.\n    </div>\n    <div class=\"controls\" aria-label=\"Semaphore Controls\">\n      <button id=\"btn-cycle\" aria-describedby=\"cycle-desc\">Cycle Signal</button>\n      <button id=\"btn-auto\" aria-pressed=\"false\" aria-describedby=\"auto-desc\">Start Auto</button>\n    </div>\n  </section>\n</main>\n<footer>\n  &copy; 2024 &mdash; Semaphore Visualization\n</footer>\n\n<script>\n  (() => {\n    const lights = [\n      { id: 'light-red', label: 'Red', colorClass: 'red' },\n      { id: 'light-yellow', label: 'Yellow', colorClass: 'yellow' },\n      { id: 'light-green', label: 'Green', colorClass: 'green' },\n    ];\n    let currentIndex = 0;\n\n    const lightElements = lights.map(({id}) => document.getElementById(id));\n    const semaphoreTitle = document.querySelector('.semaphore-title');\n    const btnCycle = document.getElementById('btn-cycle');\n    const btnAuto = document.getElementById('btn-auto');\n\n    function setActiveLight(index) {\n      lightElements.forEach((el, i) => {\n        if(i === index) {\n          el.classList.add('active');\n        } else {\n          el.classList.remove('active');\n        }\n      });\n      semaphoreTitle.textContent = lights[index].label;\n    }\n\n    function nextSignal() {\n      currentIndex = (currentIndex + 1) % lights.length;\n      setActiveLight(currentIndex);\n    }\n\n    // Initialize red light active\n    setActiveLight(currentIndex);\n\n    // Button action — cycle signal once\n    btnCycle.addEventListener('click', () => {\n      if(autoCycle) return; // disable manual if auto running\n      nextSignal();\n    });\n\n    // Auto cycling mechanism\n    let autoCycle = false;\n    let autoInterval = null;\n\n    btnAuto.addEventListener('click', () => {\n      autoCycle = !autoCycle;\n\n      if(autoCycle) {\n        btnAuto.textContent = 'Stop Auto';\n        btnAuto.setAttribute('aria-pressed', 'true');\n        btnCycle.disabled = true;\n        autoInterval = setInterval(() => {\n          nextSignal();\n        }, 2800);\n      } else {\n        btnAuto.textContent = 'Start Auto';\n        btnAuto.setAttribute('aria-pressed', 'false');\n        btnCycle.disabled = false;\n        clearInterval(autoInterval);\n      }\n    });\n  })();\n</script>\n</body>\n</html>"
