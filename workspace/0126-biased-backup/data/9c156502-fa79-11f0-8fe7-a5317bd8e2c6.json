    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Virtual Memory Interactive Simulator</title>\n<style>\n/* Extremely minimal styling to keep layout readable but plain */\nbody { background: white; color: black; font-family: monospace; margin: 10px; }\nsection { margin-bottom: 12px; }\nlabel { display: inline-block; width: 160px; }\ninput, select, button, textarea { font-family: monospace; }\ntextarea { width: 100%; height: 120px; }\ntable { border-collapse: collapse; }\ntd, th { padding: 2px 6px; border: 1px solid #000; text-align: left; }\n.small { width: 60px; }\n.mono { font-family: monospace; }\n</style>\n</head>\n<body>\n<h1>Virtual Memory Interactive Simulator</h1>\n\n<section id=\"setup\">\n  <h2>1) System Configuration</h2>\n  <div>\n    <label>Page size (KB):</label><input id=\"pageSizeKB\" type=\"number\" value=\"4\" min=\"1\" class=\"small\"> \n    <label>Pages per process:</label><input id=\"pagesPerProcess\" type=\"number\" value=\"64\" min=\"1\" class=\"small\">\n    <label>Physical frames:</label><input id=\"numFrames\" type=\"number\" value=\"16\" min=\"1\" class=\"small\">\n  </div>\n  <div>\n    <label>TLB entries:</label><input id=\"tlbEntries\" type=\"number\" value=\"4\" min=\"0\" class=\"small\">\n    <label>Replacement alg:</label>\n    <select id=\"replacementAlg\">\n      <option value=\"LRU\">LRU</option>\n      <option value=\"FIFO\">FIFO</option>\n      <option value=\"Clock\">Clock</option>\n      <option value=\"Random\">Random</option>\n    </select>\n  </div>\n  <div>\n    <label>Swap latency (ms):</label><input id=\"swapLatency\" type=\"number\" value=\"50\" min=\"0\" class=\"small\">\n    <label>Prefetch on load:</label><input id=\"prefetch\" type=\"checkbox\">\n    <label>Demand paging only:</label><input id=\"demandOnly\" type=\"checkbox\" checked>\n  </div>\n  <div>\n    <button id=\"applyConfig\">Apply configuration</button>\n    <button id=\"resetSystem\">Reset system</button>\n    <button id=\"randomizeState\">Randomize initial memory</button>\n  </div>\n</section>\n\n<section id=\"processControls\">\n  <h2>2) Processes & Memory Allocation</h2>\n  <div>\n    <label>New process name:</label><input id=\"newProcName\" type=\"text\" value=\"P1\">\n    <label>Initial pages:</label><input id=\"newProcPages\" type=\"number\" class=\"small\" value=\"16\" min=\"1\">\n    <button id=\"createProc\">Create process</button>\n    <button id=\"killProc\">Kill selected process</button>\n  </div>\n  <div>\n    <label>Selected process:</label>\n    <select id=\"procSelect\"></select>\n    <label>Pin pages at creation:</label><input id=\"pinOnCreate\" type=\"checkbox\">\n  </div>\n  <div>\n    <label>Clone (copy-on-write):</label><button id=\"cloneProc\">Clone selected</button>\n    <label>Force allocate page:</label><input id=\"forcePageNum\" type=\"number\" class=\"small\" value=\"0\" min=\"0\">\n    <button id=\"forceAlloc\">Force allocate</button>\n    <button id=\"forceFree\">Force free page</button>\n  </div>\n  <div>\n    <label>Manual page ops (PID:VPN):</label>\n    <input id=\"manualPID\" type=\"text\" placeholder=\"P1\" class=\"small\">\n    <input id=\"manualVPN\" type=\"number\" class=\"small\" value=\"0\" min=\"0\">\n    <button id=\"pinPage\">Pin</button>\n    <button id=\"unpinPage\">Unpin</button>\n    <button id=\"markDirty\">Mark dirty</button>\n    <button id=\"clearDirty\">Clear dirty</button>\n  </div>\n</section>\n\n<section id=\"workloads\">\n  <h2>3) Memory Accesses & Workloads</h2>\n  <div>\n    <label>Address input (hex/dec):</label>\n    <input id=\"addrPID\" type=\"text\" placeholder=\"P1\" class=\"small\">\n    <input id=\"addrInput\" type=\"text\" placeholder=\"0x1A\" class=\"small\">\n    <select id=\"accessType\"><option>R</option><option>W</option></select>\n    <button id=\"accessBtn\">Access</button>\n    <button id=\"explainLast\">Explain last action</button>\n  </div>\n  <div>\n    <label>Prebuilt pattern:</label>\n    <select id=\"patternSelect\">\n      <option value=\"sequential\">Sequential scan</option>\n      <option value=\"random\">Random accesses</option>\n      <option value=\"locality\">Looping working set (locality)</option>\n      <option value=\"stress\">Stress test (many faults)</option>\n    </select>\n    <label>Operations:</label><input id=\"patternOps\" type=\"number\" value=\"100\" min=\"1\" class=\"small\">\n    <button id=\"runPattern\">Run pattern</button>\n    <button id=\"stopRun\">Stop run</button>\n    <label>Speed (ms/op):</label><input id=\"runSpeed\" type=\"number\" value=\"200\" min=\"0\" class=\"small\">\n  </div>\n  <div>\n    <label>Custom script (one access per line):</label>\n    <textarea id=\"scriptArea\" placeholder=\"Format: PID R 0x10   or  P1 W 42\"></textarea>\n    <button id=\"runScript\">Run script</button>\n  </div>\n</section>\n\n<section id=\"tlbControls\">\n  <h2>4) TLB & Caching Controls</h2>\n  <div>\n    <label>Enable TLB:</label><input id=\"enableTLB\" type=\"checkbox\" checked>\n    <label>TLB entries:</label><input id=\"tlbSizeCtl\" type=\"number\" value=\"4\" min=\"0\" class=\"small\">\n    <label>TLB replacement:</label>\n    <select id=\"tlbAlg\"><option>LRU</option><option>FIFO</option><option>Random</option></select>\n  </div>\n  <div>\n    <button id=\"flushTLB\">Flush TLB</button>\n    <button id=\"showTLB\">Show TLB state</button>\n  </div>\n</section>\n\n<section id=\"controls\">\n  <h2>5) Simulation Controls & Stats</h2>\n  <div>\n    <label>Step mode:</label><button id=\"stepBtn\">Step</button>\n    <label>Play:</label><button id=\"playBtn\">Play</button>\n    <label>Pause:</label><button id=\"pauseBtn\">Pause</button>\n    <label>Run until faults:</label><input id=\"runUntilFaults\" type=\"number\" value=\"0\" class=\"small\" min=\"0\">\n    <button id=\"runUntil\">Run</button>\n  </div>\n  <div>\n    <label>Statistics:</label>\n    <button id=\"resetStats\">Reset stats</button>\n    <button id=\"dumpState\">Dump system state</button>\n  </div>\n</section>\n\n<section id=\"visuals\">\n  <h2>6) Visual State</h2>\n  <div>\n    <h3>Processes</h3>\n    <div id=\"procTableContainer\"></div>\n  </div>\n  <div>\n    <h3>Physical Frames</h3>\n    <div id=\"frameTableContainer\"></div>\n  </div>\n  <div>\n    <h3>Page Table (selected process)</h3>\n    <div id=\"pageTableContainer\"></div>\n  </div>\n  <div>\n    <h3>Logs</h3>\n    <textarea id=\"logArea\" readonly></textarea>\n    <div>\n      <button id=\"clearLog\">Clear log</button>\n      <button id=\"exportLog\">Export log (console)</button>\n    </div>\n  </div>\n  <div>\n    <h3>Counters</h3>\n    <div id=\"counters\"></div>\n  </div>\n</section>\n\n<script>\n/*\nVirtual Memory Interactive Simulator\nPlain UI, rich interactivity. Single-file implementation.\n*/\n\n// Utilities\nfunction $(id){return document.getElementById(id);}\nfunction now(){return Date.now();}\nfunction log(s){ const a=$('logArea'); a.value = nowReadable() + ' ' + s + '\\\\n' + a.value; }\nfunction nowReadable(){ const d=new Date(); return d.toLocaleTimeString(); }\nfunction hex(v){ return '0x' + (v>>>0).toString(16).toUpperCase(); }\n\n// System state\nlet config = {\n  pageSizeKB: 4,\n  pagesPerProc: 64,\n  numFrames: 16,\n  tlbEntries: 4,\n  replacementAlg: 'LRU',\n  swapLatency: 50,\n  prefetch: false,\n  demandOnly: true\n};\n\nlet processes = {}; // pid -> process\nlet processList = []; // order\nlet frames = []; // array of frame objects\nlet tlb = []; // array of entries\nlet swapStore = {}; // swapSlotId -> {pid,vpn,dirty,data}\nlet nextSwapSlot = 1;\nlet globalCounters = {};\nlet sim = { playing:false, interval:null, speed:200, runUntilFaults:0, stopRequested:false };\n\ninitialize();\n\nfunction initialize(){\n  setupFromUI();\n  resetSystem();\n  attachUI();\n  renderAll();\n  log('Simulator initialized.');\n}\n\nfunction setupFromUI(){\n  config.pageSizeKB = parseInt($('pageSizeKB').value) || 4;\n  config.pagesPerProc = parseInt($('pagesPerProcess').value) || 64;\n  config.numFrames = parseInt($('numFrames').value) || 16;\n  config.tlbEntries = parseInt($('tlbEntries').value) || 4;\n  config.replacementAlg = $('replacementAlg').value;\n  config.swapLatency = parseInt($('swapLatency').value) || 50;\n  config.prefetch = $('prefetch').checked;\n  config.demandOnly = $('demandOnly').checked;\n}\n\nfunction resetSystem(){\n  // reset data structures\n  processes = {};\n  processList = [];\n  frames = [];\n  for(let i=0;i<config.numFrames;i++){\n    frames.push({\n      id:i, occupied:false, pid:null, vpn:null, dirty:false, referenced:false, pinned:false,\n      loadTime:0, lastAccess:0, fifoOrder:i\n    });\n  }\n  tlb = [];\n  for(let i=0;i<config.tlbEntries;i++){\n    tlb.push({valid:false, pid:null, vpn:null, frame:null, lastAccess:0, loadedAt:i});\n  }\n  swapStore = {};\n  nextSwapSlot = 1;\n  resetCounters();\n  sim.playing = false;\n  sim.stopRequested = false;\n  if(sim.interval) clearInterval(sim.interval);\n  renderAll();\n}\n\nfunction resetCounters(){\n  globalCounters = {\n    accesses:0, reads:0, writes:0, pageFaults:0, tlbHits:0, tlbMisses:0, swapsOut:0, swapsIn:0, evictions:0\n  };\n}\n\n// UI attachment\nfunction attachUI(){\n  $('applyConfig').onclick = () => { setupFromUI(); resetSystem(); log('Applied configuration.'); };\n  $('resetSystem').onclick = () => { setupFromUI(); resetSystem(); log('System reset.'); };\n  $('randomizeState').onclick = randomizeMemory;\n\n  $('createProc').onclick = createProcessFromUI;\n  $('killProc').onclick = killSelectedProcess;\n  $('procSelect').onchange = renderAll;\n  $('cloneProc').onclick = cloneSelectedProcess;\n  $('forceAlloc').onclick = forceAllocate;\n  $('forceFree').onclick = forceFree;\n  $('pinPage').onclick = () => manualPageOp('pin');\n  $('unpinPage').onclick = () => manualPageOp('unpin');\n  $('markDirty').onclick = () => manualPageOp('dirtyOn');\n  $('clearDirty').onclick = () => manualPageOp('dirtyOff');\n\n  $('accessBtn').onclick = handleAccessInput;\n  $('explainLast').onclick = explainLast;\n  $('runPattern').onclick = runPattern;\n  $('stopRun').onclick = stopRun;\n  $('runScript').onclick = runScript;\n  $('stepBtn').onclick = stepOnce;\n  $('playBtn').onclick = startPlay;\n  $('pauseBtn').onclick = pausePlay;\n  $('runUntil').onclick = runUntilFaults;\n  $('resetStats').onclick = () => { resetCounters(); renderAll(); log('Stats reset.'); };\n  $('dumpState').onclick = () => { console.log({config,processes,frames,tlb,swapStore,globalCounters}); log('State dumped to console.'); };\n\n  $('flushTLB').onclick = flushTLB;\n  $('showTLB').onclick = () => { console.log(tlb); alert('TLB dumped to console'); };\n\n  $('clearLog').onclick = () => { $('logArea').value=''; };\n  $('exportLog').onclick = () => { console.log($('logArea').value); alert('Log exported to console'); };\n\n  $('applyConfig').onclick = () => { setupFromUI(); resetSystem(); renderAll(); log('Configuration applied.'); };\n  // dynamic UI values\n  $('tlbSizeCtl').onchange = () => { $('tlbEntries').value = $('tlbSizeCtl').value; $('tlbEntries').dispatchEvent(new Event('change')); };\n  $('tlbEntries').onchange = () => { config.tlbEntries = parseInt($('tlbEntries').value)||0; rebuildTLB(); renderAll(); };\n\n  $('runSpeed').onchange = () => { sim.speed = parseInt($('runSpeed').value)||200; if(sim.playing){ pausePlay(); startPlay(); } };\n  $('tlbSizeCtl').value = config.tlbEntries;\n\n  // ensure procSelect initial\n  renderProcSelect();\n}\n\n// Processes\nfunction pidFromName(name){ return name.trim(); }\n\nfunction createProcessFromUI(){\n  let name = $('newProcName').value.trim();\n  if(!name){ alert('Provide a process name.'); return; }\n  if(processes[name]) { alert('Process already exists.'); return; }\n  let pages = parseInt($('newProcPages').value)||16;\n  createProcess(name, pages, $('pinOnCreate').checked);\n}\n\nfunction createProcess(name, numPages, pinPages=false){\n  let proc = {\n    pid: pidFromName(name),\n    name: name,\n    numPages: numPages,\n    pageTable: [],\n    stats: { accesses:0, faults:0, reads:0, writes:0 }\n  };\n  for(let v=0; v<numPages; v++){\n    proc.pageTable[v] = {\n      valid:false, frame:null, dirty:false, referenced:false, swapped:false, swapSlot:null, permissions:'RW'\n    };\n  }\n  processes[proc.pid] = proc;\n  processList.push(proc.pid);\n  // Optionally allocate pinned pages in frames\n  if(pinPages){\n    for(let v=0; v<Math.min(numPages, config.numFrames); v++){\n      let f = findFreeFrame();\n      if(!f) break;\n      mapFrameTo(proc.pid, v, f);\n      f.pinned = true;\n    }\n  }\n  log('Created process ' + proc.pid + ' with ' + numPages + ' pages.');\n  renderProcSelect();\n  renderAll();\n}\n\nfunction killSelectedProcess(){\n  let pid = $('procSelect').value;\n  if(!pid) { alert('No process selected'); return; }\n  killProcess(pid);\n}\n\nfunction killProcess(pid){\n  let proc = processes[pid];\n  if(!proc) return;\n  // free frames and swap slots\n  for(let v=0; v<proc.numPages; v++){\n    let pte = proc.pageTable[v];\n    if(pte.valid){\n      let f = frames[pte.frame];\n      if(f){\n        f.occupied = false; f.pid=null; f.vpn=null; f.dirty=false; f.referenced=false; f.pinned=false;\n      }\n      pte.valid=false; pte.frame=null;\n    }\n    if(pte.swapped && pte.swapSlot){\n      delete swapStore[pte.swapSlot];\n      pte.swapped=false; pte.swapSlot=null;\n    }\n  }\n  delete processes[pid];\n  processList = processList.filter(x=>x!==pid);\n  flushTLBEntriesForPid(pid);\n  log('Killed process ' + pid);\n  renderProcSelect();\n  renderAll();\n}\n\nfunction cloneSelectedProcess(){\n  let pid = $('procSelect').value;\n  if(!pid) { alert('No process selected'); return; }\n  let old = processes[pid];\n  if(!old) return;\n  // create a clone with COW semantics: new PIDs appended with _c\n  let newPid = pid + '_c' + Math.floor(Math.random()*1000);\n  let cloneProc = {\n    pid: newPid,\n    name: newPid,\n    numPages: old.numPages,\n    pageTable: [],\n    stats: { accesses:0, faults:0, reads:0, writes:0 }\n  };\n  for(let v=0; v<old.numPages; v++){\n    let opte = old.pageTable[v];\n    cloneProc.pageTable[v] = {\n      valid: opte.valid,\n      frame: opte.frame,\n      dirty: false, // child's write will mark COW\n      referenced: opte.referenced,\n      swapped: opte.swapped, swapSlot: opte.swapSlot, permissions: 'R' // start read-only\n    };\n    // parent also becomes read-only if page in memory\n    if(opte.valid){\n      processes[pid].pageTable[v].permissions = 'R';\n    }\n  }\n  processes[newPid] = cloneProc;\n  processList.push(newPid);\n  log('Cloned ' + pid + ' -> ' + newPid + ' (COW enabled)');\n  renderProcSelect();\n  renderAll();\n}\n\n// Frames & mapping\nfunction findFreeFrame(){\n  for(let f of frames) if(!f.occupied) return f;\n  return null;\n}\n\nfunction mapFrameTo(pid, vpn, frame){\n  const proc = processes[pid];\n  if(!proc) return;\n  frame.occupied = true; frame.pid = pid; frame.vpn = vpn; frame.dirty = false; frame.referenced = true;\n  frame.loadTime = now();\n  proc.pageTable[vpn].valid = true; proc.pageTable[vpn].frame = frame.id; proc.pageTable[vpn].referenced = true;\n  proc.pageTable[vpn].swapped = false; proc.pageTable[vpn].swapSlot = null;\n  return frame;\n}\n\nfunction evictFrame(frame){\n  // remove mapping from owner process, write to swap if dirty, respect pinned\n  if(frame.pinned) return false;\n  let pid = frame.pid;\n  let vpn = frame.vpn;\n  if(pid===null || vpn===null) {\n    frame.occupied = false; frame.pid = null; frame.vpn = null; frame.dirty=false; frame.referenced=false;\n    return true;\n  }\n  let proc = processes[pid];\n  if(!proc) { frame.occupied=false; frame.pid=null; frame.vpn=null; frame.dirty=false; frame.referenced=false; return true; }\n  let pte = proc.pageTable[vpn];\n  // write-back if dirty\n  if(frame.dirty || pte.dirty){\n    // allocate swap slot\n    let slot = nextSwapSlot++;\n    swapStore[slot] = {pid:pid, vpn:vpn, dirty:true, data:'(page data)'}; // data is symbolic\n    pte.swapped = true; pte.swapSlot = slot; globalCounters.swapsOut++;\n    log('Evicted page ' + pid + ':' + vpn + ' -> swap slot ' + slot + ' (dirty)');\n    // simulate latency not blocking here; accounted via counters\n  } else {\n    // not dirty\n    pte.swapped = true; pte.swapSlot = nextSwapSlot++; swapStore[pte.swapSlot] = {pid:pid, vpn:vpn, dirty:false, data:'(page data)'};\n    log('Evicted page ' + pid + ':' + vpn + ' -> swap slot ' + pte.swapSlot + ' (clean)');\n  }\n  pte.valid = false; pte.frame = null; pte.dirty = false; pte.referenced = false;\n  frame.occupied = false; frame.pid = null; frame.vpn = null; frame.dirty = false; frame.referenced = false; frame.pinned=false;\n  globalCounters.evictions++;\n  return true;\n}\n\n// Replacement algorithm\nfunction chooseFrameToEvict(){\n  // Try free frame first\n  let freef = findFreeFrame();\n  if(freef) return freef;\n  let alg = config.replacementAlg;\n  if(alg === 'Random') {\n    let candidates = frames.filter(f=> !f.pinned);\n    return candidates[Math.floor(Math.random()*candidates.length)];\n  }\n  if(alg === 'FIFO') {\n    // choose oldest loadTime\n    let cand = null; let min = Infinity;\n    for(let f of frames) if(!f.pinned && f.loadTime < min){min=f.loadTime; cand=f;}\n    return cand;\n  }\n  if(alg === 'LRU') {\n    let cand = null; let min = Infinity;\n    for(let f of frames) if(!f.pinned && f.lastAccess < min){min=f.lastAccess; cand=f;}\n    return cand;\n  }\n  if(alg === 'Clock') {\n    // implement simple clock hand\n    if(typeof chooseFrameToEvict.clockHand === 'undefined') chooseFrameToEvict.clockHand = 0;\n    let loops = 0;\n    while(loops < frames.length*2){\n      let f = frames[chooseFrameToEvict.clockHand];\n      chooseFrameToEvict.clockHand = (chooseFrameToEvict.clockHand+1) % frames.length;\n      if(f.pinned) { loops++; continue; }\n      if(!f.referenced) return f;\n      f.referenced = false;\n      loops++;\n    }\n    // fallback\n    return frames[0];\n  }\n  // default fallback\n  return frames[0];\n}\n\n// TLB operations\nfunction rebuildTLB(){\n  let newSize = parseInt($('tlbEntries').value) || 0;\n  tlb = [];\n  for(let i=0;i<newSize;i++) tlb.push({valid:false, pid:null, vpn:null, frame:null, lastAccess:0, loadedAt:i});\n  renderAll();\n}\n\nfunction lookupTLB(pid, vpn){\n  if(!($('enableTLB').checked)) return null;\n  for(let i=0;i<tlb.length;i++){\n    let e = tlb[i];\n    if(e.valid && e.pid === pid && e.vpn === vpn){\n      e.lastAccess = now();\n      globalCounters.tlbHits++;\n      return e.frame;\n    }\n  }\n  globalCounters.tlbMisses++;\n  return null;\n}\n\nfunction insertTLB(pid, vpn, frame){\n  if(!($('enableTLB').checked)) return;\n  let alg = $('tlbAlg').value;\n  // find empty slot\n  for(let e of tlb) if(!e.valid){ e.valid=true; e.pid=pid; e.vpn=vpn; e.frame=frame; e.lastAccess=now(); return; }\n  // replacement\n  let idx = 0;\n  if(alg === 'Random') idx = Math.floor(Math.random()*tlb.length);\n  else if(alg === 'FIFO') {\n    // oldest loadedAt\n    let min=Infinity; for(let i=0;i<tlb.length;i++){ if(tlb[i].loadedAt < min){min=tlb[i].loadedAt; idx=i;} }\n  } else { // LRU\n    let min=Infinity; for(let i=0;i<tlb.length;i++){ if(tlb[i].lastAccess < min){min=tlb[i].lastAccess; idx=i;} }\n  }\n  tlb[idx] = {valid:true, pid:pid, vpn:vpn, frame:frame, lastAccess:now(), loadedAt:now()};\n}\n\n// Page fault handler / memory access\nlet lastActionExplanation = '';\n\nfunction accessMemory(pid, seqAccess){\n  // seqAccess: {type:'R'|'W', addr: number (byte offset) or vpn number if small}\n  const proc = processes[pid];\n  if(!proc){ log('Access to non-existent process ' + pid); return; }\n  globalCounters.accesses++;\n  if(seqAccess.type === 'R') globalCounters.reads++; else globalCounters.writes++;\n  proc.stats.accesses++;\n  // Interpret address as page number or raw hex.\n  let vpn = resolveAddressToVPN(seqAccess.addr, proc);\n  if(vpn < 0 || vpn >= proc.numPages){ log('Access fault: address out of process range: ' + seqAccess.addr); return; }\n  // TLB lookup\n  let tlbFrame = lookupTLB(pid, vpn);\n  let usedTLB = tlbFrame !== null;\n  let explanation = [];\n  explanation.push('Access ' + seqAccess.type + ' to ' + pid + ':' + vpn + ' (addr=' + seqAccess.addr + ')');\n  if(usedTLB){ explanation.push('TLB hit -> frame ' + tlbFrame); recordAccessOnFrame(tlbFrame); lastActionExplanation = explanation.join('\\\\n'); renderAll(); return; }\n  explanation.push('TLB miss or disabled.');\n  // check page table\n  let pte = proc.pageTable[vpn];\n  if(pte.valid){\n    // page in memory\n    let frame = frames[pte.frame];\n    explanation.push('Page present in frame ' + frame.id);\n    // permissions and COW handling\n    if(seqAccess.type === 'W' && pte.permissions && pte.permissions.indexOf('W')===-1){\n      // Copy-on-write: allocate new frame, copy content\n      explanation.push('Write attempt on read-only page -> Copy-on-write triggered.');\n      handleCOW(pid, vpn, frame, explanation);\n    } else {\n      // normal access\n      pte.referenced = true; frame.referenced = true; frame.lastAccess = now();\n      if(seqAccess.type === 'W'){ pte.dirty = true; frame.dirty = true; proc.stats.writes++; }\n    }\n    insertTLB(pid, vpn, pte.frame);\n    lastActionExplanation = explanation.join('\\\\n');\n    renderAll();\n    return;\n  }\n  // page fault\n  globalCounters.pageFaults++; proc.stats.faults++;\n  explanation.push('Page fault: page not present. Handling fault...');\n  // Find frame to use\n  let targetFrame = findFreeFrame();\n  if(!targetFrame){\n    targetFrame = chooseFrameToEvict();\n    explanation.push('No free frame -> evict candidate frame ' + targetFrame.id + ' (pid=' + targetFrame.pid + ',vpn=' + targetFrame.vpn + ')');\n    let ok = evictFrame(targetFrame);\n    if(!ok){\n      explanation.push('Eviction failed due to pin. Searching next candidate.');\n      // try linear fallback\n      for(let f of frames){ if(!f.pinned){ targetFrame=f; evictFrame(f); break; } }\n    }\n  }\n  // load page into frame (simulate swap in if needed)\n  if(pte.swapped && pte.swapSlot){\n    explanation.push('Loading from swap slot ' + pte.swapSlot + ' (swap latency ' + config.swapLatency + 'ms).');\n    globalCounters.swapsIn++;\n    // symbolic read\n    delete swapStore[pte.swapSlot]; pte.swapped=false; pte.swapSlot=null;\n  } else {\n    explanation.push('Allocating new zero-filled page from backing store.');\n  }\n  // map\n  mapFrameTo(pid, vpn, targetFrame);\n  if(seqAccess.type === 'W') { proc.pageTable[vpn].dirty = true; targetFrame.dirty = true; proc.stats.writes++; }\n  targetFrame.lastAccess = now(); targetFrame.loadTime = now();\n  insertTLB(pid, vpn, targetFrame.id);\n  lastActionExplanation = explanation.join('\\\\n');\n  renderAll();\n}\n\nfunction resolveAddressToVPN(addr, proc){\n  // Accept formats: hex string \"0x1A\", decimal, or integer representing page number for simplicity when small\n  if(typeof addr === 'number') return addr;\n  if(typeof addr === 'string'){\n    let s = addr.trim();\n    if(s.startsWith('0x') || s.startsWith('0X')){\n      let val = parseInt(s,16);\n      return Math.floor(val / (config.pageSizeKB*1024));\n    } else if(/^[0-9]+$/.test(s)){\n      let v = parseInt(s,10);\n      // if value looks like a small page number (less than pages per proc), treat as vpn\n      if(v < proc.numPages) return v;\n      return Math.floor(v / (config.pageSizeKB*1024));\n    } else {\n      return 0;\n    }\n  }\n  return 0;\n}\n\nfunction recordAccessOnFrame(frameId){\n  let f = frames[frameId];\n  if(!f) return;\n  f.lastAccess = now();\n  f.referenced = true;\n}\n\n// Copy on write\nfunction handleCOW(pid, vpn, frame, explanation){\n  // allocate new frame and copy mapping for writer\n  let freef = findFreeFrame();\n  if(!freef){\n    freef = chooseFrameToEvict();\n    explanation.push('No free frame for COW, evicting frame ' + freef.id);\n    evictFrame(freef);\n  }\n  // copy contents (symbolic)\n  mapFrameTo(pid, vpn, freef);\n  freef.dirty = true;\n  processes[pid].pageTable[vpn].permissions = 'RW'; // now writer gets RW\n  explanation.push('Allocated new frame ' + freef.id + ' for write.');\n  // original frame remains mapped by other process if any; parent's page becomes read-only\n  // update TLB etc.\n}\n\n// Manual operations\nfunction manualPageOp(op){\n  let pid = $('manualPID').value.trim();\n  let vpn = parseInt($('manualVPN').value)||0;\n  if(!processes[pid]){ alert('Process not found'); return; }\n  let p = processes[pid];\n  if(vpn<0||vpn>=p.numPages){ alert('VPN out of range'); return; }\n  let pte = p.pageTable[vpn];\n  if(op==='pin'){ if(pte.valid){ frames[pte.frame].pinned=true; log('Pinned ' + pid + ':' + vpn); } else log('Cannot pin: page not resident.'); }\n  if(op==='unpin'){ if(pte.valid){ frames[pte.frame].pinned=false; log('Unpinned ' + pid + ':' + vpn); } }\n  if(op==='dirtyOn'){ if(pte.valid){ pte.dirty=true; frames[pte.frame].dirty=true; log('Marked dirty ' + pid + ':' + vpn); } }\n  if(op==='dirtyOff'){ if(pte.valid){ pte.dirty=false; frames[pte.frame].dirty=false; log('Cleared dirty ' + pid + ':' + vpn); } }\n  renderAll();\n}\n\nfunction forceAllocate(){\n  let pid = $('procSelect').value;\n  let v = parseInt($('forcePageNum').value)||0;\n  if(!processes[pid]){ alert('Select process'); return; }\n  if(v<0||v>=processes[pid].numPages){ alert('Page out of range'); return; }\n  let f = findFreeFrame();\n  if(!f){ f=chooseFrameToEvict(); evictFrame(f); }\n  mapFrameTo(pid, v, f);\n  log('Forced allocation of ' + pid + ':' + v + ' into frame ' + f.id);\n  renderAll();\n}\n\nfunction forceFree(){\n  let pid = $('procSelect').value;\n  let v = parseInt($('forcePageNum').value)||0;\n  if(!processes[pid]){ alert('Select process'); return; }\n  let pte = processes[pid].pageTable[v];\n  if(!pte.valid){ alert('Page not resident'); return; }\n  let f = frames[pte.frame];\n  if(f) { evictFrame(f); log('Force freed ' + pid + ':' + v + ' from frame ' + f.id); renderAll(); }\n}\n\n// Workload runner\nlet runner = { active:false, scriptQueue:[], onStep:null };\n\nfunction runPattern(){\n  let pattern = $('patternSelect').value;\n  let ops = parseInt($('patternOps').value)||100;\n  let speed = parseInt($('runSpeed').value)||200;\n  sim.speed = speed;\n  runner.scriptQueue = [];\n  if(processList.length===0){ alert('Create at least one process first.'); return; }\n  if(pattern === 'sequential'){\n    for(let pid of processList){\n      for(let v=0; v<Math.min(processes[pid].numPages, ops); v++){\n        runner.scriptQueue.push({pid:pid, type:'R', addr:v});\n      }\n    }\n  } else if(pattern === 'random'){\n    for(let i=0;i<ops;i++){\n      let pid = processList[Math.floor(Math.random()*processList.length)];\n      let vpn = Math.floor(Math.random()*processes[pid].numPages);\n      let t = Math.random()<0.5?'R':'W';\n      runner.scriptQueue.push({pid:pid, type:t, addr:vpn});\n    }\n  } else if(pattern === 'locality'){\n    // pick one process and small working set\n    let pid = processList[0];\n    let ws = Math.min(8, processes[pid].numPages);\n    for(let i=0;i<ops;i++){\n      let base = Math.floor(Math.random()*(processes[pid].numPages - ws));\n      let vpn = base + Math.floor(Math.random()*ws);\n      let t = Math.random()<0.25?'W':'R';\n      runner.scriptQueue.push({pid:pid, type:t, addr:vpn});\n    }\n  } else if(pattern === 'stress'){\n    for(let i=0;i<ops;i++){\n      let pid = processList[Math.floor(Math.random()*processList.length)];\n      let vpn = Math.floor(Math.random()*processes[pid].numPages);\n      let t = Math.random()<0.5?'W':'R';\n      runner.scriptQueue.push({pid:pid, type:t, addr:vpn});\n    }\n  }\n  runner.active = true;\n  sim.stopRequested = false;\n  runNextInQueue();\n}\n\nfunction runNextInQueue(){\n  if(sim.stopRequested || !runner.active) { runner.active=false; log('Pattern run stopped.'); return; }\n  if(runner.scriptQueue.length===0){ runner.active=false; log('Pattern run completed.'); return; }\n  let op = runner.scriptQueue.shift();\n  accessMemory(op.pid, op);\n  renderAll();\n  if(sim.runUntilFaults>0 && globalCounters.pageFaults >= sim.runUntilFaults){ log('Stopped: reached page fault target'); runner.active=false; return; }\n  setTimeout(runNextInQueue, sim.speed);\n}\n\nfunction stopRun(){\n  sim.stopRequested = true;\n  runner.active = false;\n}\n\n// Script runner\nfunction runScript(){\n  let text = $('scriptArea').value.trim();\n  if(!text) { alert('Enter script lines'); return; }\n  let lines = text.split('\\\\n').map(s=>s.trim()).filter(s=>s);\n  runner.scriptQueue = [];\n  for(let line of lines){\n    let parts = line.split(/\\\\s+/);\n    if(parts.length < 3) continue;\n    let pid = parts[0];\n    let type = parts[1].toUpperCase();\n    let addr = parts[2];\n    runner.scriptQueue.push({pid:pid, type:type, addr:addr});\n  }\n  runner.active = true; sim.stopRequested=false; runNextInQueue();\n}\n\n// Single step\nfunction stepOnce(){\n  // simple: if script queue has items, execute next; otherwise do nothing.\n  if(runner.active && runner.scriptQueue.length>0){\n    let op = runner.scriptQueue.shift();\n    accessMemory(op.pid, op);\n    renderAll();\n  } else {\n    // No script queued: prompt user for manual step?\n    log('Step executed (no queued operations). You can create operations or run a pattern/script.');\n  }\n}\n\n// Play/Pause\nfunction startPlay(){\n  if(sim.playing) return;\n  sim.playing = true;\n  sim.interval = setInterval(()=> {\n    // default behavior: if script queue active, perform next; else try a random access\n    if(runner.active && runner.scriptQueue.length>0) runNextInQueue();\n    else {\n      // random gentle activity: pick random process and random page\n      if(processList.length===0) return;\n      let pid = processList[Math.floor(Math.random()*processList.length)];\n      let vpn = Math.floor(Math.random()*processes[pid].numPages);\n      let t = Math.random()<0.25?'W':'R';\n      accessMemory(pid,{type:t, addr:vpn});\n      renderAll();\n    }\n  }, sim.speed);\n  log('Play started.');\n}\n\nfunction pausePlay(){\n  if(sim.interval) clearInterval(sim.interval);\n  sim.playing=false;\n  sim.interval=null;\n  log('Play paused.');\n}\n\n// Run until faults count\nfunction runUntilFaults(){\n  let target = parseInt($('runUntilFaults').value)||0;\n  if(target <= 0){ alert('Enter a positive number of faults to run until.'); return; }\n  sim.runUntilFaults = globalCounters.pageFaults + target;\n  sim.stopRequested = false;\n  // start random activities until pageFaults >= sim.runUntilFaults\n  if(!sim.playing) startPlay();\n  let checkInterval = setInterval(()=> {\n    if(globalCounters.pageFaults >= sim.runUntilFaults){ pausePlay(); clearInterval(checkInterval); log('Reached target page faults.'); }\n    if(!sim.playing) { clearInterval(checkInterval); }\n  }, 100);\n}\n\n// TLB flush\nfunction flushTLB(){\n  for(let e of tlb){ e.valid=false; e.pid=null; e.vpn=null; e.frame=null; e.lastAccess=0; }\n  log('TLB flushed.');\n  renderAll();\n}\n\nfunction flushTLBEntriesForPid(pid){\n  for(let e of tlb) if(e.valid && e.pid===pid) e.valid=false;\n}\n\n// Randomize initial memory (useful for testing)\nfunction randomizeMemory(){\n  // create frames filled randomly by random existing processes or void\n  for(let f of frames){\n    if(Math.random() < 0.5 && processList.length>0){\n      let pid = processList[Math.floor(Math.random()*processList.length)];\n      let vpn = Math.floor(Math.random()*processes[pid].numPages);\n      mapFrameTo(pid, vpn, f);\n      f.dirty = Math.random() < 0.3;\n      f.pinned = Math.random() < 0.1;\n    } else {\n      f.occupied = false; f.pid=null; f.vpn=null; f.dirty=false; f.referenced=false; f.pinned=false;\n    }\n  }\n  log('Memory randomized.');\n  renderAll();\n}\n\n// Explain last action\nfunction explainLast(){\n  alert(lastActionExplanation || 'No recorded action yet.');\n}\n\n// Rendering\nfunction renderAll(){\n  renderProcSelect();\n  renderProcTable();\n  renderFrameTable();\n  renderPageTable();\n  renderCounters();\n}\n\nfunction renderProcSelect(){\n  let sel = $('procSelect');\n  sel.innerHTML = '';\n  for(let pid of processList){\n    let opt = document.createElement('option');\n    opt.value = pid; opt.textContent = pid;\n    sel.appendChild(opt);\n  }\n}\n\nfunction renderProcTable(){\n  let cont = $('procTableContainer');\n  let html = '<table><tr><th>PID</th><th>Pages</th><th>Resident</th><th>Faults</th><th>Accesses</th></tr>';\n  for(let pid of processList){\n    let p = processes[pid];\n    let resident = p.pageTable.filter(x=>x.valid).length;\n    html += '<tr><td>' + pid + '</td><td>' + p.numPages + '</td><td>' + resident + '</td><td>' + p.stats.faults + '</td><td>' + p.stats.accesses + '</td></tr>';\n  }\n  html += '</table>';\n  cont.innerHTML = html;\n}\n\nfunction renderFrameTable(){\n  let cont = $('frameTableContainer');\n  let html = '<table><tr><th>Frame</th><th>PID</th><th>VPN</th><th>Dirty</th><th>Ref</th><th>Pinned</th><th>Loaded</th><th>LastAccess</th></tr>';\n  for(let f of frames){\n    html += '<tr><td>' + f.id + '</td><td>' + (f.pid||'') + '</td><td>' + (f.vpn!==null?f.vpn:'') + '</td><td>' + (f.dirty?'Y':'') + '</td><td>' + (f.referenced?'Y':'') + '</td><td>' + (f.pinned?'Y':'') + '</td><td>' + (f.loadTime?new Date(f.loadTime).toLocaleTimeString():'') + '</td><td>' + (f.lastAccess?new Date(f.lastAccess).toLocaleTimeString():'') + '</td></tr>';\n  }\n  html += '</table>';\n  cont.innerHTML = html;\n}\n\nfunction renderPageTable(){\n  let sel = $('procSelect');\n  let pid = sel.value;\n  let cont = $('pageTableContainer');\n  if(!pid || !processes[pid]) { cont.innerHTML = '<div>Select a process to view its page table</div>'; return; }\n  let p = processes[pid];\n  let html = '<table><tr><th>VPN</th><th>Valid</th><th>Frame</th><th>Dirty</th><th>Ref</th><th>Swapped</th><th>SwapSlot</th><th>Perm</th></tr>';\n  for(let v=0; v<p.numPages; v++){\n    let e = p.pageTable[v];\n    html += '<tr><td>' + v + '</td><td>' + (e.valid?'Y':'') + '</td><td>' + (e.frame!==null?e.frame:'') + '</td><td>' + (e.dirty?'Y':'') + '</td><td>' + (e.referenced?'Y':'') + '</td><td>' + (e.swapped?'Y':'') + '</td><td>' + (e.swapSlot||'') + '</td><td>' + (e.permissions||'') + '</td></tr>';\n  }\n  html += '</table>';\n  cont.innerHTML = html;\n}\n\nfunction renderCounters(){\n  let c = $('counters');\n  c.innerHTML = '';\n  let s = '';\n  s += 'Accesses: ' + globalCounters.accesses + ' | Reads: ' + globalCounters.reads + ' | Writes: ' + globalCounters.writes + '<br>';\n  s += 'TLB Hits: ' + globalCounters.tlbHits + ' | TLB Misses: ' + globalCounters.tlbMisses + '<br>';\n  s += 'Page Faults: ' + globalCounters.pageFaults + ' | Swaps In: ' + globalCounters.swapsIn + ' | Swaps Out: ' + globalCounters.swapsOut + ' | Evictions: ' + globalCounters.evictions + '<br>';\n  s += 'Replacement: ' + config.replacementAlg + ' | Frames: ' + config.numFrames + ' | Page size: ' + config.pageSizeKB + 'KB';\n  c.innerHTML = s;\n}\n\n// Explain last step more detailed in the log\n// (We already store lastActionExplanation string)\n\n// Initial demo: create default processes so user can interact quickly\n(function initialDemo(){\n  // apply UI config\n  setupFromUI();\n  // Create two demo processes\n  createProcess('P1', Math.max(16, config.pagesPerProc), false);\n  createProcess('P2', Math.max(12, Math.floor(config.pagesPerProc/2)), false);\n  // Preload a few pages\n  for(let i=0;i<4;i++){\n    let f = findFreeFrame(); if(!f) break;\n    mapFrameTo('P1', i, f);\n  }\n  renderAll();\n  log('Demo processes P1 and P2 created.');\n})();\n\n</script>\n\n</body>\n</html>"
