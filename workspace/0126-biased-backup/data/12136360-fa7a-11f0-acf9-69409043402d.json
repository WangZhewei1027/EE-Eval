    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Max Heap Interactive Explorer</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre;\n  }\n  button, input, select {\n    font-family: monospace, monospace;\n    font-size: 14px;\n    margin: 2px 4px 2px 0;\n  }\n  #heap-display {\n    font-family: monospace, monospace;\n  }\n  #log {\n    max-height: 15em;\n    overflow-y: scroll;\n    border: 1px solid;\n    padding: 4px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Max Heap Interactive Explorer</h1>\n\n<p>\nThis tool lets you build and explore a max heap step-by-step with full interactive control and detailed feedback.\n</p>\n\n<section>\n  <h2>1. Build Heap: Insert Elements</h2>\n  <label for=\"insert-value\">Insert value:</label>\n  <input type=\"number\" id=\"insert-value\" style=\"width:5em\" />\n  <button id=\"btn-insert\">Insert</button>\n  <button id=\"btn-insert-random\">Insert Random (1-99)</button>\n  <button id=\"btn-clear\">Clear Heap</button>\n  <p>Heap size: <span id=\"heap-size\">0</span></p>\n</section>\n\n<section>\n  <h2>2. Operations</h2>\n  <button id=\"btn-extract-max\">Extract Max (Pop Root)</button>\n  <button id=\"btn-peek-max\">Peek Max (View Root)</button>\n  <button id=\"btn-heapify-scratch\">Build Heap from Array</button>\n</section>\n\n<section>\n  <h2>3. Heapify Modes and Controls</h2>\n  <label for=\"heapify-array-input\">Array (space-separated integers):</label><br />\n  <input type=\"text\" id=\"heapify-array-input\" style=\"width: 90%\" placeholder=\"e.g. 15 10 20 30 5\" />\n  <br />\n  <label for=\"heapify-strategy\">Heapify strategy:</label>\n  <select id=\"heapify-strategy\">\n    <option value=\"bottom-up\">Bottom-Up (Floyd's algorithm)</option>\n    <option value=\"insert\">Insert each element</option>\n  </select>\n  <br />\n  <button id=\"btn-heapify-step\">Do One Step of Heapify</button>\n  <button id=\"btn-heapify-reset\">Reset Heapify Process</button>\n  <p>\n    Heapify State: <span id=\"heapify-state\">Idle</span>\n  </p>\n</section>\n\n<section>\n  <h2>4. Stepwise Visualization & Manual Swaps</h2>\n  <p>Use the index-based manual swap tool to explore sifting and heap property.</p>\n  <label for=\"swap-index1\">Index 1:</label>\n  <input type=\"number\" id=\"swap-index1\" style=\"width:4em\" min=\"0\" />\n  <label for=\"swap-index2\">Index 2:</label>\n  <input type=\"number\" id=\"swap-index2\" style=\"width:4em\" min=\"0\" />\n  <button id=\"btn-swap\">Swap Indices</button>\n</section>\n\n<section>\n  <h2>5. Heap Display (Array representation)</h2>\n  <div id=\"heap-display\"></div>\n</section>\n\n<section>\n  <h2>6. Log / Explanation / Step Info</h2>\n  <div id=\"log\" aria-live=\"polite\"></div>\n</section>\n\n<script>\n(function(){\n  'use strict';\n\n  // Heap array container\n  let heap = [];\n\n  // Heapify stepwise process variables\n  let heapifyProcess = null;\n  // HeapifyProcess will be an object with strategy, array, index pointers, etc.\n\n  // Log helper\n  function log(msg){\n    const logDiv = document.getElementById('log');\n    logDiv.textContent += msg + '\\\\n';\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n  function clearLog(){\n    document.getElementById('log').textContent = '';\n  }\n\n  // Utility: swap in heap array\n  function swap(i,j){\n    if(i < 0 || j < 0 || i >= heap.length || j >= heap.length){\n      log('Swap indices out of range; no swap performed.');\n      return false;\n    }\n    const v1 = heap[i], v2 = heap[j];\n    heap[i] = v2;\n    heap[j] = v1;\n    log('Swapped indices '+i+' ('+v1+') and '+j+' ('+v2+').');\n    return true;\n  }\n\n  // Utility: Parent and children indices\n  function parent(i){ return Math.floor((i-1)/2); }\n  function leftChild(i){ return 2*i+1; }\n  function rightChild(i){ return 2*i+2; }\n\n  // Check if heap property holds fully\n  function isMaxHeap(arr){\n    for(let i=0;i<arr.length;i++){\n      const l = leftChild(i), r = rightChild(i);\n      if(l < arr.length && arr[l] > arr[i]) return false;\n      if(r < arr.length && arr[r] > arr[i]) return false;\n    }\n    return true;\n  }\n\n  // Render the heap array visually - as array and a tree printed in text\n  function renderHeap(){\n    const display = document.getElementById('heap-display');\n    if(heap.length === 0){\n      display.textContent = '(Heap is empty)';\n      updateHeapSize();\n      return;\n    }\n    // Show array\n    let out = 'Heap array (index: value):\\\\n';\n    for(let i=0;i<heap.length;i++){\n      out += '  ['+i+']: '+heap[i] + '\\\\n';\n    }\n    // Show tree layer by layer (level order)\n    out += '\\\\nHeap tree level order:\\\\n';\n    let level = 0;\n    let levelStart = 0;\n    while(levelStart < heap.length){\n      const levelCount = Math.pow(2, level);\n      const levelEnd = Math.min(heap.length, levelStart+levelCount);\n      let line = 'Level '+ level + ': ';\n      for(let i=levelStart;i<levelEnd;i++){\n        line += heap[i];\n        if(i < levelEnd-1) line += ' ';\n      }\n      out += line + '\\\\n';\n      levelStart = levelEnd;\n      level++;\n    }\n    display.textContent = out;\n    updateHeapSize();\n  }\n\n  function updateHeapSize(){\n    document.getElementById('heap-size').textContent = heap.length.toString();\n  }\n\n  // Heap insertion with sift-up\n  function heapInsert(value){\n    heap.push(value);\n    log('Inserted '+value+' at index '+(heap.length-1)+'. Starting sift-up.');\n    siftUp(heap.length-1);\n    renderHeap();\n  }\n\n  // sift-up operation\n  function siftUp(i){\n    while(i > 0){\n      const p = parent(i);\n      if(heap[i] > heap[p]){\n        log('siftUp: heap['+i+']('+heap[i]+') > heap['+p+']('+heap[p]+'), swapping.');\n        swap(i,p);\n        i=p;\n      } else {\n        log('siftUp: heap['+i+']('+heap[i]+') <= heap['+p+']('+heap[p]+'), stop.');\n        break;\n      }\n    }\n  }\n\n  // sift-down operation for heapify and extract max\n  function siftDown(i, endIndex=heap.length){\n    while(true){\n      let largest = i;\n      const l = leftChild(i);\n      const r = rightChild(i);\n      if(l < endIndex && heap[l] > heap[largest]) largest = l;\n      if(r < endIndex && heap[r] > heap[largest]) largest = r;\n      if(largest !== i){\n        log('siftDown: heap['+largest+']('+heap[largest]+') > heap['+i+']('+heap[i]+'), swapping.');\n        swap(i,largest);\n        i = largest;\n      } else {\n        log('siftDown: position '+i+' ('+heap[i]+') is correct, stop.');\n        break;\n      }\n    }\n  }\n\n  // Extract max (pop root)\n  function extractMax(){\n    if(heap.length === 0){\n      log('Heap is empty. Cannot extract max.');\n      return null;\n    }\n    const max = heap[0];\n    const end = heap.pop();\n    if(heap.length > 0){\n      heap[0] = end;\n      log('Extracted max '+max+'. Moved '+end+' to root. Starting sift-down.');\n      siftDown(0);\n    } else {\n      log('Extracted last element '+max+'. Heap is now empty.');\n    }\n    renderHeap();\n    return max;\n  }\n\n  // Peek max (root value)\n  function peekMax(){\n    if(heap.length === 0){\n      log('Heap is empty.');\n      return null;\n    }\n    log('Max (root) value is: '+heap[0]);\n    return heap[0];\n  }\n\n  // Build heap from array using bottom-up Floyd's method\n  // This is stepwise version with external state\n  function initBottomUpHeapify(array){\n    heapifyProcess = {\n      strategy: 'bottom-up',\n      array: array.slice(),\n      stepStage: 'init', // steps: init -> siftDown(currIndex) -> done\n      currentIndex: Math.floor(array.length/2)-1,\n      done: false\n    };\n    log('Initialized bottom-up Floyd heapify with array: [' + heapifyProcess.array.join(', ') + ']');\n    renderHeapifyProcess();\n  }\n\n  // Build heap from array inserting elements one by one stepwise\n  function initInsertHeapify(array){\n    heapifyProcess = {\n      strategy: 'insert',\n      array: array.slice(),\n      stepStage: 'init-0', // phases: init-0, init-1, ..., inserting each index,\n      currentIndex: 0,\n      done: false\n    };\n    log('Initialized insert-style heapify with array: [' + heapifyProcess.array.join(', ') + ']');\n    renderHeapifyProcess();\n  }\n\n  // Perform one step of heapify according to strategy\n  function stepHeapify(){\n    if(!heapifyProcess){\n      log('Heapify process not started.');\n      return;\n    }\n    if(heapifyProcess.done){\n      log('Heapify process is already complete.');\n      return;\n    }\n\n    if(heapifyProcess.strategy === 'bottom-up'){\n      bottomUpHeapifyStep();\n    } else if(heapifyProcess.strategy === 'insert'){\n      insertHeapifyStep();\n    } else {\n      log('Unknown heapify strategy.');\n    }\n    renderHeapifyProcess();\n  }\n\n  // Reset Heapify process\n  function resetHeapify(){\n    heapifyProcess = null;\n    log('Heapify process reset.');\n    document.getElementById('heapify-state').textContent = 'Idle';\n  }\n\n  // Bottom-up step implementation (Floyd)\n  function bottomUpHeapifyStep(){\n    if(heapifyProcess.stepStage === 'init'){\n      heap = heapifyProcess.array.slice();\n      if(heap.length === 0){\n        heapifyProcess.done = true;\n        log('Empty array: heapify done.');\n        return;\n      }\n      heapifyProcess.stepStage = 'siftDown';\n      log('Heap array copied. Start heapify from index '+heapifyProcess.currentIndex);\n    }\n    if(heapifyProcess.stepStage === 'siftDown'){\n      if(heapifyProcess.currentIndex < 0){\n        heapifyProcess.done = true;\n        log('Heapify complete. Final heap is: ['+heap.join(', ')+']');\n        return;\n      }\n      log('Heapify step: siftDown at index '+heapifyProcess.currentIndex+' (value: '+heap[heapifyProcess.currentIndex]+')');\n      siftDown(heapifyProcess.currentIndex);\n      heapifyProcess.currentIndex--;\n    }\n  }\n\n  // Insert heapify step implementation\n  function insertHeapifyStep(){\n    if(heapifyProcess.stepStage.startsWith('init')){\n      // Clear heap first on first step (init-0)\n      if(heapifyProcess.currentIndex === 0){\n        heap = [];\n        log('Starting insert heapify: empty heap.');\n      }\n      if(heapifyProcess.currentIndex >= heapifyProcess.array.length){\n        heapifyProcess.done = true;\n        log('Insert heapify complete. Final heap is: [' + heap.join(', ') + ']');\n        return;\n      }\n      // Insert next element with siftUp\n      const val = heapifyProcess.array[heapifyProcess.currentIndex];\n      heap.push(val);\n      log('Inserted '+val+' at index '+(heap.length-1)+'. Starting sift-up.');\n      siftUp(heap.length-1);\n      heapifyProcess.currentIndex++;\n    }\n  }\n\n  // Render heapify process state\n  function renderHeapifyProcess(){\n    const stateEl = document.getElementById('heapify-state');\n    if(!heapifyProcess){\n      stateEl.textContent = 'Idle';\n      renderHeap();\n      return;\n    }\n    let s = '';\n    if(heapifyProcess.done){\n      s = 'DONE';\n    } else {\n      s = 'Running -> Strategy: '+heapifyProcess.strategy + '; ';\n      if(heapifyProcess.strategy === 'bottom-up'){\n        s += 'Current siftDown index: '+heapifyProcess.currentIndex;\n      } else if(heapifyProcess.strategy === 'insert'){\n        s += 'Inserted elements: '+heapifyProcess.currentIndex + '/' + heapifyProcess.array.length;\n      }\n    }\n    stateEl.textContent = s;\n    renderHeap();\n  }\n\n  // Parse array from input string\n  function parseArrayInput(str){\n    let parts = str.trim().split(/\\s+/);\n    let nums = [];\n    for(let p of parts){\n      let v = parseInt(p,10);\n      if(isNaN(v)){\n        log('Invalid integer in array input: \"'+p+'\"');\n        return null;\n      }\n      nums.push(v);\n    }\n    return nums;\n  }\n\n  // --- Event handlers below ---\n\n  document.getElementById('btn-insert').onclick = function(){\n    clearLog();\n    let valStr = document.getElementById('insert-value').value;\n    let val = parseInt(valStr,10);\n    if(isNaN(val)){\n      log('Please enter a valid integer to insert.');\n      return;\n    }\n    heapifyProcess = null; // interrupt any heapify\n    heapInsert(val);\n  };\n\n  document.getElementById('btn-insert-random').onclick = function(){\n    clearLog();\n    heapifyProcess = null;\n    let val = Math.floor(Math.random()*99)+1;\n    log('Randomly generated value: '+val);\n    heapInsert(val);\n  };\n\n  document.getElementById('btn-clear').onclick = function(){\n    clearLog();\n    heapifyProcess = null;\n    heap = [];\n    renderHeap();\n    log('Heap cleared.');\n  };\n\n  document.getElementById('btn-extract-max').onclick = function(){\n    clearLog();\n    heapifyProcess = null;\n    let max = extractMax();\n    if(max !== null){\n      log('Extracted max value: '+max);\n    }\n  };\n\n  document.getElementById('btn-peek-max').onclick = function(){\n    clearLog();\n    peekMax();\n  };\n\n  document.getElementById('btn-heapify-scratch').onclick = function(){\n    clearLog();\n    let arrStr = document.getElementById('heapify-array-input').value;\n    if(!arrStr.trim()){\n      log('Enter an array of integers for heapify.');\n      return;\n    }\n    let arr = parseArrayInput(arrStr);\n    if(arr === null){\n      return;\n    }\n    let strategy = document.getElementById('heapify-strategy').value;\n    if(strategy === 'bottom-up'){\n      initBottomUpHeapify(arr);\n    } else if(strategy === 'insert'){\n      initInsertHeapify(arr);\n    } else {\n      log('Unknown heapify strategy selected.');\n      return;\n    }\n    renderHeapifyProcess();\n  };\n\n  document.getElementById('btn-heapify-step').onclick = function(){\n    clearLog();\n    if(!heapifyProcess){\n      log('No heapify process started. Use \"Build Heap from Array\" first.');\n      return;\n    }\n    stepHeapify();\n  };\n\n  document.getElementById('btn-heapify-reset').onclick = function(){\n    resetHeapify();\n    renderHeapifyProcess();\n  };\n\n  document.getElementById('btn-swap').onclick = function(){\n    clearLog();\n    heapifyProcess = null;\n    let i1 = parseInt(document.getElementById('swap-index1').value,10);\n    let i2 = parseInt(document.getElementById('swap-index2').value,10);\n    if(isNaN(i1) || isNaN(i2)){\n      log('Please enter valid integer indices to swap.');\n      return;\n    }\n    if(i1 === i2){\n      log('Indices are the same; no swap needed.');\n      return;\n    }\n    if(swap(i1,i2)){\n      log('After manual swap. Check and fix heap property as needed.');\n    }\n    renderHeap();\n  };\n\n  // Initial render\n  renderHeap();\n\n})();\n</script>\n\n</body>\n</html>"
