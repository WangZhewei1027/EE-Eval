    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Circular Linked List | Visual Elegance</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@400;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f9f9f9;\n            --shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            overflow-x: hidden;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3rem;\n            font-weight: 700;\n            color: var(--primary);\n            margin-bottom: 0.5rem;\n            letter-spacing: 1px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualization-container {\n            position: relative;\n            width: 90%;\n            max-width: 1000px;\n            height: 500px;\n            margin: 2rem auto;\n            background: rgba(255, 255, 255, 0.8);\n            border-radius: 20px;\n            box-shadow: var(--shadow);\n            overflow: hidden;\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n            animation: scaleIn 1s ease-out;\n        }\n        \n        .node {\n            position: absolute;\n            width: 100px;\n            height: 100px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-weight: 700;\n            font-size: 1.5rem;\n            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.3);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            z-index: 10;\n            cursor: default;\n        }\n        \n        .node::after {\n            content: '';\n            position: absolute;\n            width: 30px;\n            height: 30px;\n            background: white;\n            border-radius: 50%;\n            right: -15px;\n            top: 35px;\n            z-index: 5;\n        }\n        \n        .node.highlight {\n            transform: scale(1.1);\n            box-shadow: 0 15px 30px rgba(108, 92, 231, 0.5);\n            background: linear-gradient(135deg, var(--accent) 0%, #ff7675 100%);\n        }\n        \n        .connection {\n            position: absolute;\n            height: 4px;\n            background: var(--secondary);\n            transform-origin: left center;\n            z-index: 1;\n            transition: all 0.5s ease-out;\n        }\n        \n        .connection::before {\n            content: '';\n            position: absolute;\n            width: 12px;\n            height: 12px;\n            background: var(--secondary);\n            border-radius: 50%;\n            right: -6px;\n            top: -4px;\n            animation: pulse 2s infinite;\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 2rem;\n            animation: fadeIn 1.5s ease-out 0.5s both;\n        }\n        \n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            color: white;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            font-size: 1rem;\n            cursor: pointer;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n            transition: all 0.3s ease;\n            outline: none;\n        }\n        \n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.6);\n        }\n        \n        button:active {\n            transform: translateY(1px);\n        }\n        \n        .info-panel {\n            background: white;\n            border-radius: 15px;\n            padding: 2rem;\n            margin-top: 2rem;\n            max-width: 800px;\n            box-shadow: var(--shadow);\n            animation: fadeIn 1.5s ease-out 1s both;\n        }\n        \n        .info-panel h2 {\n            font-family: 'Playfair Display', serif;\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.8rem;\n        }\n        \n        .info-panel p {\n            line-height: 1.8;\n            margin-bottom: 1rem;\n            color: var(--dark);\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n        \n        @keyframes scaleIn {\n            from { transform: scale(0.9); opacity: 0; }\n            to { transform: scale(1); opacity: 1; }\n        }\n        \n        @keyframes pulse {\n            0% { transform: scale(1); opacity: 1; }\n            50% { transform: scale(1.2); opacity: 0.7; }\n            100% { transform: scale(1); opacity: 1; }\n        }\n        \n        @keyframes rotate {\n            from { transform: rotate(0deg); }\n            to { transform: rotate(360deg); }\n        }\n        \n        .decoration {\n            position: absolute;\n            width: 300px;\n            height: 300px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, rgba(253, 121, 168, 0.1) 0%, rgba(162, 155, 254, 0.1) 100%);\n            z-index: -1;\n        }\n        \n        .decoration-1 {\n            top: -100px;\n            left: -100px;\n            animation: rotate 20s linear infinite;\n        }\n        \n        .decoration-2 {\n            bottom: -150px;\n            right: -100px;\n            animation: rotate 25s linear infinite reverse;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Circular Linked List</h1>\n        <p class=\"subtitle\">A visually stunning representation of a data structure where the last node points back to the first, creating a circular connection.</p>\n    </header>\n    \n    <div class=\"visualization-container\">\n        <div class=\"decoration decoration-1\"></div>\n        <div class=\"decoration decoration-2\"></div>\n        \n        <!-- Nodes will be added here by JavaScript -->\n    </div>\n    \n    <div class=\"controls\">\n        <button id=\"traverse\">Traverse List</button>\n        <button id=\"reset\">Reset Animation</button>\n    </div>\n    \n    <div class=\"info-panel\">\n        <h2>About Circular Linked Lists</h2>\n        <p>A circular linked list is a variation of a linked list in which the last node points back to the first node instead of pointing to null. This creates a circular structure that can be traversed indefinitely.</p>\n        <p>Circular linked lists are useful in applications where you need to cycle through items repeatedly, such as in operating system scheduling algorithms, multiplayer games where players take turns, or round-robin databases.</p>\n        <p>The visual representation above shows a circular linked list with 5 nodes. Click \"Traverse List\" to see an animated traversal through the circular structure.</p>\n    </div>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const container = document.querySelector('.visualization-container');\n            const traverseBtn = document.getElementById('traverse');\n            const resetBtn = document.getElementById('reset');\n            \n            // Create nodes and connections\n            const nodeCount = 5;\n            const nodes = [];\n            const connections = [];\n            \n            // Calculate positions in a circle\n            const centerX = container.offsetWidth / 2;\n            const centerY = container.offsetHeight / 2;\n            const radius = Math.min(centerX, centerY) * 0.7;\n            \n            // Create nodes\n            for (let i = 0; i < nodeCount; i++) {\n                const angle = (i * (2 * Math.PI / nodeCount)) - Math.PI / 2;\n                const x = centerX + radius * Math.cos(angle);\n                const y = centerY + radius * Math.sin(angle);\n                \n                const node = document.createElement('div');\n                node.className = 'node';\n                node.textContent = i + 1;\n                node.style.left = `${x - 50}px`;\n                node.style.top = `${y - 50}px`;\n                container.appendChild(node);\n                nodes.push(node);\n                \n                // Create connections\n                if (i > 0) {\n                    const prevX = centerX + radius * Math.cos(angle - (2 * Math.PI / nodeCount));\n                    const prevY = centerY + radius * Math.sin(angle - (2 * Math.PI / nodeCount));\n                    \n                    const length = Math.sqrt(Math.pow(x - prevX, 2) + Math.pow(y - prevY, 2));\n                    const connAngle = Math.atan2(y - prevY, x - prevX);\n                    \n                    const connection = document.createElement('div');\n                    connection.className = 'connection';\n                    connection.style.width = `${length}px`;\n                    connection.style.left = `${prevX}px`;\n                    connection.style.top = `${prevY}px`;\n                    connection.style.transform = `rotate(${connAngle}rad)`;\n                    container.appendChild(connection);\n                    connections.push(connection);\n                }\n            }\n            \n            // Create final connection (circular)\n            const firstX = centerX + radius * Math.cos(-Math.PI / 2);\n            const firstY = centerY + radius * Math.sin(-Math.PI / 2);\n            const lastX = centerX + radius * Math.cos(-Math.PI / 2 + (nodeCount - 1) * (2 * Math.PI / nodeCount));\n            const lastY = centerY + radius * Math.sin(-Math.PI / 2 + (nodeCount - 1) * (2 * Math.PI / nodeCount));\n            \n            const length = Math.sqrt(Math.pow(firstX - lastX, 2) + Math.pow(firstY - lastY, 2));\n            const connAngle = Math.atan2(firstY - lastY, firstX - lastX);\n            \n            const finalConnection = document.createElement('div');\n            finalConnection.className = 'connection';\n            finalConnection.style.width = `${length}px`;\n            finalConnection.style.left = `${lastX}px`;\n            finalConnection.style.top = `${lastY}px`;\n            finalConnection.style.transform = `rotate(${connAngle}rad)`;\n            container.appendChild(finalConnection);\n            connections.push(finalConnection);\n            \n            // Traverse animation\n            let currentIndex = 0;\n            let animationInterval;\n            \n            function traverse() {\n                resetAnimation();\n                \n                // Highlight first node\n                nodes[currentIndex].classList.add('highlight');\n                \n                animationInterval = setInterval(() => {\n                    nodes[currentIndex].classList.remove('highlight');\n                    currentIndex = (currentIndex + 1) % nodeCount;\n                    nodes[currentIndex].classList.add('highlight');\n                }, 1000);\n            }\n            \n            function resetAnimation() {\n                clearInterval(animationInterval);\n                nodes.forEach(node => node.classList.remove('highlight'));\n                currentIndex = 0;\n            }\n            \n            traverseBtn.addEventListener('click', traverse);\n            resetBtn.addEventListener('click', resetAnimation);\n            \n            // Initial small animation\n            setTimeout(() => {\n                nodes[0].classList.add('highlight');\n                setTimeout(() => {\n                    nodes[0].classList.remove('highlight');\n                }, 1000);\n            }, 2000);\n        });\n    </script>\n</body>\n</html>"
