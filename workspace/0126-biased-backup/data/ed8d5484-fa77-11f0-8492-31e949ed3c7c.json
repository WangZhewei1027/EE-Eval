    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Quick Sort Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            background: linear-gradient(135deg, #f0f2f5, #d9e5f0);\n            font-family: 'Arial', sans-serif;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            color: #333;\n            overflow: hidden;\n        }\n        h1 {\n            position: absolute;\n            top: 20px;\n            font-size: 2.5rem;\n            text-align: center;\n            color: #2f4f4f;\n        }\n        #array-container {\n            display: flex;\n            align-items: flex-end;\n            justify-content: center;\n            height: 300px;\n            width: 80%;\n            margin: 0 auto;\n            position: relative;\n        }\n        .bar {\n            width: 20px;\n            margin: 0 2px;\n            background: #8acb88;\n            display: inline-block;\n            transition: height 0.3s ease, background 0.3s ease;\n        }\n        .pivot {\n            background: #ff6347;\n        }\n        .sorted {\n            background: #4169e1;\n        }\n        button {\n            margin-top: 20px;\n            padding: 10px 20px;\n            font-size: 1.2rem;\n            background-color: #3b5998;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n        }\n        button:hover {\n            background-color: #2e4571;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Quick Sort Visualization</h1>\n    <div id=\"array-container\"></div>\n    <button id=\"sort-button\">Sort Array</button>\n\n    <script>\n        const arrayContainer = document.getElementById('array-container');\n        const sortButton = document.getElementById('sort-button');\n\n        let array = [];\n        for(let i = 0; i < 15; i++) {\n            array.push(Math.floor(Math.random() * 200) + 20);\n        }\n\n        function createBars() {\n            arrayContainer.innerHTML = '';\n            array.forEach(value => {\n                const bar = document.createElement('div');\n                bar.className = 'bar';\n                bar.style.height = `${value}px`;\n                arrayContainer.appendChild(bar);\n            });\n        }\n\n        async function quickSort(array, left, right) {\n            if(left < right) {\n                let pivotIndex = await partition(array, left, right);\n                await quickSort(array, left, pivotIndex - 1);\n                await quickSort(array, pivotIndex + 1, right);\n            }\n        }\n\n        async function partition(array, left, right) {\n            let pivot = array[right];\n            let i = left - 1;\n            for(let j = left; j < right; j++) {\n                if(array[j] < pivot) {\n                    i++;\n                    [array[i], array[j]] = [array[j], array[i]];\n                    updateBars(i, j);\n                    await sleep(200);\n                }\n            }\n            [array[i + 1], array[right]] = [array[right], array[i + 1]];\n            updateBars(i + 1, right);\n            await sleep(200);\n            return i + 1;\n        }\n\n        function updateBars(index1, index2) {\n            const bars = document.querySelectorAll('.bar');\n            bars[index1].classList.add('pivot');\n            bars[index2].classList.add('pivot');\n            setTimeout(() => {\n                bars[index1].classList.remove('pivot');\n                bars[index2].classList.remove('pivot');\n            }, 300);\n            createBars();\n        }\n\n        function sleep(ms) {\n            return new Promise(resolve => setTimeout(resolve, ms));\n        }\n\n        sortButton.addEventListener('click', async () => {\n            await quickSort(array, 0, array.length - 1);\n            const bars = document.querySelectorAll('.bar');\n            bars.forEach(bar => bar.classList.add('sorted'));\n        });\n\n        createBars();\n    </script>\n\n</body>\n</html>"
