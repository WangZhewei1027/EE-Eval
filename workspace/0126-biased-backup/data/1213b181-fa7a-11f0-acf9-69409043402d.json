  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Selection Sort Interactive Explorer</title>\n<style>\n  body {\n    background: white;\n    color: black;\n    font-family: monospace, monospace;\n    margin: 1rem;\n  }\n  button, input[type=number], input[type=text], label, select {\n    font-family: monospace, monospace;\n    font-size: 1rem;\n    margin: 0.2rem 0.5rem 0.2rem 0;\n  }\n  #array-container {\n    margin: 1rem 0 1rem 0;\n  }\n  .array-element {\n    display: inline-block;\n    width: 3rem;\n    text-align: center;\n    border: 1px solid black;\n    padding: 0.2rem 0;\n    margin: 0 0.1rem;\n    user-select: none;\n  }\n  .current-index {\n    border-bottom: 3px solid black;\n  }\n  .min-index {\n    border-bottom: 3px double black;\n  }\n  .selected-sorted {\n    border-bottom: 3px dotted black;\n  }\n  #log {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    max-height: 180px;\n    overflow-y: auto;\n    padding: 0.5rem;\n    font-size: 0.9rem;\n  }\n  #controls {\n    margin-top: 1rem;\n  }\n  #slider-controls label, #manual-controls label {\n    font-weight: bold;\n    user-select: none;\n  }\n  fieldset {\n    margin-top: 1rem;\n    padding: 0.5rem;\n  }\n</style>\n</head>\n<body>\n<h1>Selection Sort Interactive Explorer</h1>\n\n<p>\n  This demo allows you to deeply explore the Selection Sort algorithm with full manual control, automatic and step-by-step execution, and customization of the data set.\n</p>\n\n<div id=\"array-container\" aria-label=\"Array to sort\" role=\"list\" tabindex=\"0\"></div>\n\n<div id=\"info\" aria-live=\"polite\" style=\"margin-bottom: 1rem;\">\n  Status: <span id=\"status-text\">Array not initialized.</span>\n</div>\n\n<div id=\"controls\">\n\n  <fieldset>\n    <legend>Array Setup and Input</legend>\n    <label for=\"array-input\">Enter array (comma separated integers):</label><br />\n    <input type=\"text\" id=\"array-input\" aria-describedby=\"array-input-desc\" size=\"40\" placeholder=\"e.g. 5,3,8,1,9\" />\n    <button id=\"load-array\">Load Array</button>\n    <span id=\"array-input-desc\" style=\"font-size:0.8rem;\">Only integer values supported. Max length 30.</span><br /><br />\n\n    <label for=\"random-size\">Generate Random Array Size:</label>\n    <input type=\"number\" id=\"random-size\" min=\"2\" max=\"30\" value=\"10\" aria-describedby=\"random-size-desc\" />\n    <button id=\"generate-random\">Generate Random Array</button>\n    <span id=\"random-size-desc\" style=\"font-size:0.8rem;\">Between 2 and 30 elements.</span><br /><br />\n\n    <label for=\"random-min\">Min Value:</label>\n    <input type=\"number\" id=\"random-min\" value=\"0\" aria-describedby=\"random-range-desc\" />\n    <label for=\"random-max\">Max Value:</label>\n    <input type=\"number\" id=\"random-max\" value=\"100\" aria-describedby=\"random-range-desc\" />\n    <span id=\"random-range-desc\" style=\"font-size:0.8rem;\">Min &le; Max.</span>\n  </fieldset>\n\n  <fieldset>\n    <legend>Step Controls</legend>\n    <button id=\"step-forward\" disabled>Step Forward</button>\n    <button id=\"step-backward\" disabled>Step Backward</button>\n    <button id=\"run-auto\" disabled>Run Auto</button>\n    <button id=\"pause-auto\" disabled>Pause Auto</button>\n    <button id=\"reset\" disabled>Reset</button>\n    <label for=\"auto-interval\">Speed (ms per step):</label>\n    <input type=\"number\" id=\"auto-interval\" value=\"800\" min=\"100\" max=\"5000\" step=\"100\" />\n  </fieldset>\n\n  <fieldset>\n    <legend>Visualization Options</legend>\n    <label for=\"highlight-current\">Highlight Current Index</label>\n    <input type=\"checkbox\" id=\"highlight-current\" checked />\n    <label for=\"highlight-min\">Highlight Min Index</label>\n    <input type=\"checkbox\" id=\"highlight-min\" checked />\n    <label for=\"highlight-sorted\">Highlight Sorted Section</label>\n    <input type=\"checkbox\" id=\"highlight-sorted\" checked />\n  </fieldset>\n\n</div>\n\n<fieldset style=\"margin-top:1rem;\">\n  <legend>Sort Log and Exploration</legend>\n  <button id=\"clear-log\">Clear Log</button>\n  <p style=\"font-size:0.9rem; margin:0.5rem 0;\">You can click on any element below to jump to the step in which that element was last modified (swapped or considered minimum).</p>\n  <div id=\"log\" tabindex=\"0\" aria-label=\"Sort operation log\"></div>\n</fieldset>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // State variables\n  let array = [];\n  let originalArray = [];\n  let stepHistory = [];\n  let currentStepIndex = -1; // -1 = before first step, 0..n = steps\n  let isAutoRunning = false;\n  let autoTimer = null;\n\n  // Selection sort internal state per step:\n  // Each step object:\n  // {\n  //  i: current index (outer loop)\n  //  j: current index (inner loop)\n  //  minIndex: index of current minimum\n  //  array: snapshot array at this step\n  //  action: string describing step action (\"init\", \"findMin\", \"swap\", \"done\")\n  //  description: human readable description\n  // }\n\n  // Cached DOM Elements\n  const arrayContainer = document.getElementById(\"array-container\");\n  const statusText = document.getElementById(\"status-text\");\n  const stepForwardBtn = document.getElementById(\"step-forward\");\n  const stepBackwardBtn = document.getElementById(\"step-backward\");\n  const runAutoBtn = document.getElementById(\"run-auto\");\n  const pauseAutoBtn = document.getElementById(\"pause-auto\");\n  const resetBtn = document.getElementById(\"reset\");\n  const autoIntervalInput = document.getElementById(\"auto-interval\");\n  const clearLogBtn = document.getElementById(\"clear-log\");\n\n  const highlightCurrentCheckbox = document.getElementById(\"highlight-current\");\n  const highlightMinCheckbox = document.getElementById(\"highlight-min\");\n  const highlightSortedCheckbox = document.getElementById(\"highlight-sorted\");\n\n  const loadArrayBtn = document.getElementById(\"load-array\");\n  const arrayInput = document.getElementById(\"array-input\");\n  const generateRandomBtn = document.getElementById(\"generate-random\");\n  const randomSizeInput = document.getElementById(\"random-size\");\n  const randomMinInput = document.getElementById(\"random-min\");\n  const randomMaxInput = document.getElementById(\"random-max\");\n\n  const logContainer = document.getElementById(\"log\");\n\n  // Utility functions\n  function cloneArray(arr){\n    return arr.slice();\n  }\n\n  function safeParseArray(text){\n    // Parse comma separated integers, ignore empty\n    try {\n      let parts = text.split(\",\").map(s=>s.trim()).filter(s=>s.length>0);\n      let vals = parts.map(s=>{\n        let v = Number(s);\n        if (!Number.isInteger(v)) throw new Error(\"Non-integer detected\");\n        return v;\n      });\n      if(vals.length === 0) throw new Error(\"Input is empty\");\n      if(vals.length > 30) throw new Error(\"Max length 30 exceeded\");\n      return vals;\n    } catch(e) {\n      return null;\n    }\n  }\n\n  function generateRandomArray(size,min,max){\n    let arr = [];\n    for(let i=0;i<size;i++){\n      let val = Math.floor(Math.random()*(max-min+1)) + min;\n      arr.push(val);\n    }\n    return arr;\n  }\n\n  // Log management\n  function pushLogStep(step){\n    stepHistory.push(step);\n  }\n\n  function setStatus(str){\n    statusText.textContent = str;\n  }\n\n  function clearAllStates(){\n    array = [];\n    originalArray = [];\n    stepHistory = [];\n    currentStepIndex = -1;\n    isAutoRunning = false;\n    clearInterval(autoTimer);\n    autoTimer = null;\n  }\n\n  // Build the entire stepHistory for the full selection sort of originalArray\n  function buildSelectionSortSteps(arr){\n    let stateSteps = [];\n\n    let a = cloneArray(arr);\n    let n = a.length;\n\n    // Initial step: before sorting\n    stateSteps.push({\n      i: -1,\n      j: -1,\n      minIndex: -1,\n      array: cloneArray(a),\n      action: \"init\",\n      description: \"Initial array state before sorting.\"\n    });\n\n    for(let i=0;i<n-1;i++){\n      let minIdx = i;\n      // Log the start of searching min for position i\n      stateSteps.push({\n        i:i,\n        j: i,\n        minIndex: minIdx,\n        array: cloneArray(a),\n        action: \"startOuterLoop\",\n        description: `Selecting index ${i} as initial minimum.`\n      });\n\n      for(let j=i+1;j<n;j++){\n        // Log checking element j against minIdx\n        stateSteps.push({\n          i:i,\n          j:j,\n          minIndex:minIdx,\n          array: cloneArray(a),\n          action: \"checkComparison\",\n          description: `Comparing element at index ${j} (${a[j]}) with current min at index ${minIdx} (${a[minIdx]}).`\n        });\n        if(a[j] < a[minIdx]){\n          minIdx = j;\n          // Log minIdx updated\n          stateSteps.push({\n            i:i,\n            j:j,\n            minIndex:minIdx,\n            array: cloneArray(a),\n            action: \"updateMin\",\n            description: `New minimum found at index ${minIdx} (${a[minIdx]}).`\n          });\n        }\n      }\n\n      if(minIdx !== i){\n        // Log swap about to happen\n        stateSteps.push({\n          i:i,\n          j:-1,\n          minIndex:minIdx,\n          array: cloneArray(a),\n          action: \"swapStart\",\n          description: `Swapping element at index ${i} (${a[i]}) with minimum at index ${minIdx} (${a[minIdx]}).`\n        });\n        // Swap\n        [a[i], a[minIdx]] = [a[minIdx], a[i]];\n\n        // Log array after swap\n        stateSteps.push({\n          i:i,\n          j:-1,\n          minIndex:minIdx,\n          array: cloneArray(a),\n          action: \"swapDone\",\n          description: `Swap completed: element at index ${i} is now ${a[i]}, minimum placed at index ${minIdx}.`\n        });\n      } else {\n        // Log no swap needed\n        stateSteps.push({\n          i:i,\n          j:-1,\n          minIndex:minIdx,\n          array: cloneArray(a),\n          action: \"noSwap\",\n          description: `No swap needed for index ${i}, current minimum is already in place.`\n        });\n      }\n    }\n\n    // Final step: sorted array\n    stateSteps.push({\n      i:-1,\n      j:-1,\n      minIndex:-1,\n      array: cloneArray(a),\n      action: \"done\",\n      description: \"Array sorted, selection sort complete.\"\n    });\n\n    return stateSteps;\n  }\n\n  // Render the array with highlights depending on step and user settings\n  function renderArray(step){\n    arrayContainer.innerHTML = \"\";\n    if(!step) return;\n\n    const arr = step.array;\n    const currentI = (typeof step.i === \"number\")?step.i:-1;\n    const currentJ = (typeof step.j === \"number\")?step.j:-1;\n    const minIdx = (typeof step.minIndex === \"number\")?step.minIndex:-1;\n\n    // Sorted section = indices < currentI (if currentI >= 0)\n    // For step \"done\", whole array sorted\n\n    const highlightCurrent = highlightCurrentCheckbox.checked;\n    const highlightMin = highlightMinCheckbox.checked;\n    const highlightSorted = highlightSortedCheckbox.checked;\n\n    const n = arr.length;\n\n    for(let k=0;k<n;k++){\n      const el = document.createElement(\"div\");\n      el.className = \"array-element\";\n      el.textContent = arr[k];\n      el.tabIndex = 0;\n      el.setAttribute(\"role\", \"listitem\");\n      el.setAttribute(\"aria-label\", `Element ${k} with value ${arr[k]}`);\n\n      // Mark current i\n      if(highlightCurrent && k === currentI && currentI >=0){\n        el.classList.add(\"current-index\");\n        el.setAttribute(\"aria-current\", \"step\");\n      }\n\n      // Mark minIndex\n      if(highlightMin && k === minIdx && minIdx >=0){\n        el.classList.add(\"min-index\");\n      }\n\n      // Mark sorted section\n      if(highlightSorted && currentI>=0 && k < currentI){\n        el.classList.add(\"selected-sorted\");\n      }\n\n      // For finished state - mark all sorted\n      if(step.action === \"done\"){\n        el.classList.add(\"selected-sorted\");\n      }\n\n      arrayContainer.appendChild(el);\n    }\n  }\n\n  // Render the log and enable clicking on entries to jump to that step\n  function renderLog(){\n    logContainer.innerHTML = \"\";\n    for(let i=0;i<stepHistory.length;i++){\n      let s = stepHistory[i];\n      let line = document.createElement(\"div\");\n      line.textContent = `Step ${i}: ${s.description}`;\n      line.tabIndex = 0;\n      line.setAttribute(\"role\", \"button\");\n      line.setAttribute(\"aria-pressed\", (i === currentStepIndex) ? \"true\" : \"false\");\n      if(i === currentStepIndex){\n        line.style.fontWeight = \"bold\";\n      }\n      // Attach click to jump to step i\n      line.addEventListener(\"click\", function(){\n        gotoStep(i);\n      });\n      // Keyboard accessibility explicit handling\n      line.addEventListener(\"keydown\", function(ev){\n        if(ev.key === \"Enter\" || ev.key === \" \"){\n          ev.preventDefault();\n          gotoStep(i);\n        }\n      });\n      logContainer.appendChild(line);\n    }\n    // Scroll log to show current step\n    if(currentStepIndex >= 0){\n      let children = logContainer.children;\n      if(children.length > currentStepIndex){\n        children[currentStepIndex].scrollIntoView({block:\"nearest\"});\n      }\n    }\n  }\n\n  // Update UI controls status\n  function updateControls(){\n    const canStepForward = currentStepIndex < stepHistory.length -1 && currentStepIndex >=0;\n    const canStepBackward = currentStepIndex > 0;\n\n    stepForwardBtn.disabled = !canStepForward;\n    stepBackwardBtn.disabled = !canStepBackward;\n    runAutoBtn.disabled = !canStepForward || isAutoRunning;\n    pauseAutoBtn.disabled = !isAutoRunning;\n    resetBtn.disabled = (currentStepIndex < 0);\n  }\n\n  // Go to a step index, update visuals and status\n  function gotoStep(index){\n    if(index < 0 || index >= stepHistory.length){\n      return;\n    }\n    currentStepIndex = index;\n    let step = stepHistory[currentStepIndex];\n    renderArray(step);\n    renderLog();\n    setStatus(`Step ${currentStepIndex}: ${step.description}`);\n    updateControls();\n  }\n\n  // Step forward handler\n  function stepForward(){\n    if(currentStepIndex < stepHistory.length -1){\n      gotoStep(currentStepIndex+1);\n    }\n  }\n\n  // Step backward handler\n  function stepBackward(){\n    if(currentStepIndex > 0){\n      gotoStep(currentStepIndex-1);\n    }\n  }\n\n  // Auto run start\n  function startAutoRun(){\n    if(isAutoRunning) return;\n    isAutoRunning = true;\n    updateControls();\n    let interval = parseInt(autoIntervalInput.value,10);\n    if(isNaN(interval) || interval < 100) interval = 800;\n    autoTimer = setInterval(()=>{\n      if(currentStepIndex >= stepHistory.length-1){\n        stopAutoRun();\n      } else {\n        stepForward();\n      }\n    }, interval);\n  }\n\n  // Auto run stop\n  function stopAutoRun(){\n    if(!isAutoRunning) return;\n    isAutoRunning = false;\n    clearInterval(autoTimer);\n    autoTimer = null;\n    updateControls();\n  }\n\n  // Reset entire state to original unsorted array first step\n  function resetSorting(){\n    if(originalArray.length === 0) return;\n    stepHistory = buildSelectionSortSteps(originalArray);\n    currentStepIndex = 0;\n    renderArray(stepHistory[0]);\n    renderLog();\n    setStatus(`Reset to initial state at step 0.`);\n    updateControls();\n  }\n\n  // Initialize sorting from a loaded array (valid int array)\n  function initializeWithArray(arr){\n    clearAllStates();\n    originalArray = cloneArray(arr);\n    stepHistory = buildSelectionSortSteps(originalArray);\n    currentStepIndex = 0;\n    renderArray(stepHistory[0]);\n    renderLog();\n    setStatus(`Array loaded with length ${arr.length}. Ready to start.`);\n    updateControls();\n  }\n\n  function logError(msg){\n    alert(\"Input error: \"+msg);\n  }\n\n  // Event Listeners\n  loadArrayBtn.addEventListener(\"click\", function(){\n    const arr = safeParseArray(arrayInput.value);\n    if(arr === null){\n      logError(\"Invalid input array. Make sure to enter a comma-separated list of integers with max 30 elements.\");\n      return;\n    }\n    initializeWithArray(arr);\n  });\n\n  generateRandomBtn.addEventListener(\"click\", function(){\n    const size = parseInt(randomSizeInput.value,10);\n    if(isNaN(size) || size < 2 || size > 30){\n      logError(\"Random array size must be between 2 and 30.\");\n      return;\n    }\n    let minVal = parseInt(randomMinInput.value,10);\n    let maxVal = parseInt(randomMaxInput.value,10);\n    if(isNaN(minVal)) minVal = 0;\n    if(isNaN(maxVal)) maxVal = 100;\n    if(minVal > maxVal){\n      logError(\"Min value cannot be greater than Max value.\");\n      return;\n    }\n    const arr = generateRandomArray(size,minVal,maxVal);\n    arrayInput.value = arr.join(\", \");\n    initializeWithArray(arr);\n  });\n\n  stepForwardBtn.addEventListener(\"click\", function(){\n    stepForward();\n    stopAutoRun();\n  });\n\n  stepBackwardBtn.addEventListener(\"click\", function(){\n    stepBackward();\n    stopAutoRun();\n  });\n\n  runAutoBtn.addEventListener(\"click\", function(){\n    startAutoRun();\n  });\n\n  pauseAutoBtn.addEventListener(\"click\", function(){\n    stopAutoRun();\n  });\n\n  resetBtn.addEventListener(\"click\", function(){\n    stopAutoRun();\n    resetSorting();\n  });\n\n  clearLogBtn.addEventListener(\"click\", function(){\n    logContainer.innerHTML = \"\";\n  });\n\n  // If user changes the interval during auto run, reset timer\n  autoIntervalInput.addEventListener(\"change\", function(){\n    if(isAutoRunning){\n      stopAutoRun();\n      startAutoRun();\n    }\n  });\n\n  // Highlight option changed - rerender current step\n  [highlightCurrentCheckbox, highlightMinCheckbox, highlightSortedCheckbox].forEach(chk=>{\n    chk.addEventListener(\"change\", function(){\n      if(currentStepIndex >= 0){\n        renderArray(stepHistory[currentStepIndex]);\n      }\n    });\n  });\n\n  // Keyboard shortcuts for convenience\n  window.addEventListener(\"keydown\", function(e){\n    if(e.target.tagName === \"INPUT\" || e.target.tagName === \"TEXTAREA\") return; // ignore inputs\n\n    switch(e.key){\n      case \"ArrowRight\":\n      case \"n\": // next\n        if(!stepForwardBtn.disabled){\n          stepForward();\n          stopAutoRun();\n        }\n        break;\n      case \"ArrowLeft\":\n      case \"p\": // previous\n        if(!stepBackwardBtn.disabled){\n          stepBackward();\n          stopAutoRun();\n        }\n        break;\n      case \"r\": // run auto\n        if(!runAutoBtn.disabled){\n          startAutoRun();\n        }\n        break;\n      case \"s\": // stop auto\n        if(!pauseAutoBtn.disabled){\n          stopAutoRun();\n        }\n        break;\n      case \"0\": // reset\n        if(!resetBtn.disabled){\n          stopAutoRun();\n          resetSorting();\n        }\n        break;\n    }\n  });\n\n  // On page load: no array loaded\n  setStatus(\"Please input or generate an array to start sorting.\");\n\n})();\n</script>\n</body>\n</html>"
  },
