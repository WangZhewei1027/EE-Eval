    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Ternary Search — Visual Elegance</title>\n\n  <!-- Google Fonts -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,700&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #071023;\n      --glass: rgba(255,255,255,0.06);\n      --muted: rgba(255,255,255,0.65);\n      --accent: #7C5CFC;\n      --accent-2: #3EE7C8;\n      --danger: #FF6B6B;\n      --success: #4ADE80;\n      --node-size: 64px;\n      --card-radius: 20px;\n      --transition: 450ms cubic-bezier(.2,.9,.2,1);\n    }\n\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,252,0.12), transparent 10%),\n                  radial-gradient(900px 400px at 90% 80%, rgba(62,231,200,0.06), transparent 10%),\n                  linear-gradient(180deg,var(--bg1),var(--bg2) 60%);\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color: #eaf2ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:48px;\n    }\n\n    /* Container */\n    .stage{\n      width:min(1200px,96vw);\n      display:grid;\n      grid-template-columns: 460px 1fr;\n      gap:28px;\n      align-items:start;\n    }\n\n    /* Left card - Title & Controls */\n    .panel{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:var(--card-radius);\n      padding:28px;\n      position:relative;\n      box-shadow: 0 8px 30px rgba(2,6,23,0.55), inset 0 1px 0 rgba(255,255,255,0.02);\n      backdrop-filter: blur(8px) saturate(120%);\n      overflow:hidden;\n      min-height:420px;\n    }\n\n    .brand{\n      display:flex;\n      gap:16px;\n      align-items:center;\n    }\n\n    .logo{\n      width:64px;height:64px;border-radius:14px;\n      background:linear-gradient(135deg,var(--accent),var(--accent-2));\n      display:flex;align-items:center;justify-content:center;\n      box-shadow: 0 6px 30px rgba(124,92,252,0.18), 0 1px 0 rgba(255,255,255,0.06) inset;\n      transform:translateZ(0);\n      flex-shrink:0;\n    }\n\n    .logo svg{filter: drop-shadow(0 6px 20px rgba(124,92,252,0.18));}\n\n    .title{\n      font-family: \"Playfair Display\", serif;\n      font-size:22px;\n      letter-spacing:-0.02em;\n      color: #fbfbff;\n      margin:0;\n    }\n    .subtitle{\n      margin:6px 0 0 0;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    .desc{\n      margin-top:22px;\n      color:rgba(235,245,255,0.86);\n      line-height:1.5;\n      font-size:14px;\n    }\n\n    /* Info badges */\n    .badges{\n      display:flex;\n      gap:12px;\n      margin-top:20px;\n    }\n    .badge{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:12px;\n      padding:8px 12px;\n      color:var(--muted);\n      font-weight:600;\n      font-size:13px;\n      display:flex;\n      gap:8px;\n      align-items:center;\n      box-shadow: 0 4px 22px rgba(3,8,23,0.35);\n    }\n    .badge .dot{\n      width:10px;height:10px;border-radius:50%;\n      background:linear-gradient(90deg,var(--accent),var(--accent-2));\n      box-shadow: 0 4px 12px rgba(62,231,200,0.12);\n    }\n\n    /* Control area bottom of left panel */\n    .controls{\n      margin-top:28px;\n      display:flex;\n      gap:12px;\n      align-items:center;\n      justify-content:flex-start;\n    }\n\n    .btn{\n      -webkit-tap-highlight-color: transparent;\n      border:0;\n      color:white;\n      padding:10px 16px;\n      border-radius:12px;\n      font-weight:700;\n      letter-spacing:0.02em;\n      cursor:pointer;\n      display:inline-flex;\n      gap:10px;\n      align-items:center;\n      transition:var(--transition);\n      box-shadow: 0 6px 24px rgba(7,10,30,0.45);\n      background:linear-gradient(90deg,var(--accent),#5f8bff);\n    }\n    .btn.secondary{\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.06);\n      color:var(--muted);\n      padding:10px 14px;\n      font-weight:600;\n      box-shadow:none;\n    }\n    .btn:active{transform:translateY(1px) scale(0.998)}\n\n    .small{\n      font-size:13px;color:var(--muted);margin-top:18px;\n    }\n\n    /* Right panel - visual playground */\n    .playground{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:var(--card-radius);\n      padding:28px;\n      min-height:420px;\n      box-shadow: 0 8px 30px rgba(2,6,23,0.55);\n      position:relative;\n      overflow:hidden;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n    }\n\n    .statusBar{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n    }\n\n    .status{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n\n    .pill{\n      padding:8px 10px;border-radius:999px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:var(--muted);\n      font-weight:600;\n      font-size:13px;\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n      min-width:84px;\n      justify-content:center;\n    }\n\n    .displayTarget{\n      padding:12px 18px;border-radius:14px;\n      background:linear-gradient(90deg, rgba(124,92,252,0.08), rgba(62,231,200,0.04));\n      color: #fff;\n      font-weight:800;\n      font-size:16px;\n      letter-spacing:0.02em;\n      display:flex;gap:12px;align-items:center;\n      box-shadow: 0 12px 30px rgba(124,92,252,0.06);\n    }\n\n    /* Array visualization*/\n    .arrayWrap{\n      padding:12px;\n      border-radius:14px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n      overflow:visible;\n      flex:1 1 auto;\n    }\n\n    .array{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:18px;\n      transition:var(--transition);\n      padding:10px 18px;\n      width:100%;\n      max-width:1000px;\n    }\n\n    .node{\n      width:var(--node-size);\n      height:var(--node-size);\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:14px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:800;\n      color:rgba(255,255,255,0.9);\n      font-size:15px;\n      position:relative;\n      transition: transform 520ms cubic-bezier(.2,.9,.2,1), opacity 480ms ease, filter 420ms ease;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      user-select:none;\n    }\n\n    .node .sub{\n      position:absolute;\n      bottom:-18px;\n      left:50%;\n      transform:translateX(-50%);\n      font-size:11px;color:var(--muted);opacity:0.9;\n    }\n\n    .node.neon{\n      background: linear-gradient(180deg,#1b0d3b, rgba(124,92,252,0.06));\n      box-shadow: 0 12px 40px rgba(124,92,252,0.16), 0 2px 6px rgba(0,0,0,0.45), 0 0 28px rgba(124,92,252,0.14) inset;\n      transform:translateY(-6px) scale(1.04);\n    }\n\n    .node.m1{\n      background: linear-gradient(90deg, rgba(124,92,252,0.95), rgba(97,87,255,0.85));\n      box-shadow: 0 18px 60px rgba(124,92,252,0.22), 0 0 40px rgba(124,92,252,0.18);\n    }\n    .node.m2{\n      background: linear-gradient(90deg, rgba(62,231,200,0.95), rgba(34,203,189,0.85));\n      box-shadow: 0 18px 60px rgba(62,231,200,0.18), 0 0 40px rgba(62,231,200,0.14);\n      color:rgba(10,10,12,0.98);\n    }\n\n    .node.match{\n      background: linear-gradient(90deg,var(--success), #9ef3b8);\n      color:#062218;\n      transform:scale(1.12) rotate(-2deg);\n      box-shadow: 0 30px 80px rgba(74,222,128,0.12), 0 0 60px rgba(74,222,128,0.12);\n    }\n\n    .node.dim{\n      opacity:0.18;\n      transform:scale(0.98) translateY(6px);\n      filter:grayscale(40%) blur(0.2px);\n    }\n\n    /* Overlays to mark removed segments */\n    .cut{\n      position:absolute;\n      top:18%;\n      bottom:18%;\n      background: linear-gradient(90deg, rgba(8,10,18,0.0), rgba(10,10,20,0.85));\n      border-radius:12px;\n      transition:var(--transition);\n      pointer-events:none;\n      box-shadow: inset 0 2px 16px rgba(0,0,0,0.6);\n      opacity:0.55;\n      mix-blend-mode:normal;\n    }\n\n    .explain{\n      padding:16px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      color:var(--muted);\n      font-size:14px;\n      min-height:84px;\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n      display:flex;\n      align-items:center;\n      gap:12px;\n    }\n\n    .explain .step{\n      font-weight:700;color:#fff;font-size:15px;\n    }\n\n    .footerNote{\n      text-align:right;color:rgba(255,255,255,0.06);font-size:11px;margin-top:6px;\n    }\n\n    /* Tiny animations */\n    @keyframes floaty {\n      0% { transform: translateY(0px) rotate(-1deg); }\n      50% { transform: translateY(-6px) rotate(1deg); }\n      100% { transform: translateY(0px) rotate(-1deg); }\n    }\n    .logo{ animation: floaty 6s ease-in-out infinite; }\n\n    /* Responsive */\n    @media (max-width: 980px){\n      .stage{ grid-template-columns: 1fr; }\n      .panel{ order:2 }\n      .playground{ order:1 }\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"stage\" aria-hidden=\"false\">\n    <div class=\"panel\" role=\"region\" aria-label=\"Introduction\">\n      <div class=\"brand\">\n        <div class=\"logo\" title=\"Ternary Search\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden>\n            <path d=\"M3 16L11 8l10 10\" stroke=\"#fff\" stroke-opacity=\"0.96\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <path d=\"M8 6h8\" stroke=\"#fff\" stroke-opacity=\"0.8\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </div>\n        <div>\n          <h1 class=\"title\">Ternary Search</h1>\n          <div class=\"subtitle\">A refined, animated demonstration of dividing to conquer</div>\n        </div>\n      </div>\n\n      <p class=\"desc\">\n        Ternary Search is a divide-and-conquer algorithm that splits a sorted range into three parts,\n        checks two middle points, and discards one third each iteration. This visualization shows the\n        elegant reduction of the search interval until the target is found (or not).\n      </p>\n\n      <div class=\"badges\" aria-hidden=\"true\">\n        <div class=\"badge\"><span class=\"dot\"></span> Sorted array</div>\n        <div class=\"badge\">Comparisons: 2 per step</div>\n        <div class=\"badge\">Complexity: O(log3 n)</div>\n      </div>\n\n      <div style=\"height:1px\"></div>\n\n      <div class=\"controls\" aria-hidden=\"true\">\n        <button id=\"toggleBtn\" class=\"btn\" title=\"Play / Pause\">\n          <svg id=\"playIcon\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden>\n            <path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"></path>\n          </svg>\n          <span id=\"toggleLabel\">Animate</span>\n        </button>\n\n        <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset visualization\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden>\n            <path d=\"M20 12A8 8 0 1 0 4 12\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <path d=\"M4 4v6h6\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n          Reset\n        </button>\n      </div>\n\n      <div class=\"small\" style=\"margin-top:18px\">\n        Tip: Watch the array gracefully dim as segments are pruned — subtle cues help understand each decision.\n      </div>\n\n      <div style=\"flex:1\"></div>\n\n      <div class=\"footerNote\">Designed with care — limited interactivity. Observe the process.</div>\n\n    </div>\n\n    <div class=\"playground\" role=\"main\" aria-label=\"Ternary Search Visualization\">\n      <div class=\"statusBar\">\n        <div class=\"status\">\n          <div class=\"pill\" id=\"boundsPill\">l: <strong id=\"lIdx\" style=\"margin-left:8px\">—</strong>  r: <strong id=\"rIdx\" style=\"margin-left:8px\">—</strong></div>\n          <div class=\"pill\" id=\"stepPill\">Step: <strong id=\"stepCount\" style=\"margin-left:8px\">0</strong></div>\n        </div>\n        <div class=\"displayTarget\" aria-live=\"polite\" title=\"Target value\">\n          Target:\n          <div id=\"targetValue\" style=\"font-family:Inter, sans-serif;font-weight:900;font-size:18px\">—</div>\n        </div>\n      </div>\n\n      <div class=\"arrayWrap\" id=\"arrayWrap\">\n        <!-- overlays for cut regions -->\n        <div id=\"leftCut\" class=\"cut\" style=\"left:0; width:0;\"></div>\n        <div id=\"rightCut\" class=\"cut\" style=\"right:0; width:0;\"></div>\n\n        <div class=\"array\" id=\"array\"></div>\n      </div>\n\n      <div class=\"explain\" id=\"explain\">\n        <div style=\"flex:1\">\n          <div class=\"step\" id=\"exStep\">Press \"Animate\" to begin</div>\n          <div style=\"margin-top:6px;color:var(--muted);font-size:13px\" id=\"explainText\">This demonstration walks through each ternary search comparison and prunes the interval with smooth transitions.</div>\n        </div>\n        <div style=\"width:12px\"></div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Minimal, self-contained visualization script\n    (function(){\n      const arrayEl = document.getElementById('array');\n      const lIdxEl = document.getElementById('lIdx');\n      const rIdxEl = document.getElementById('rIdx');\n      const stepCountEl = document.getElementById('stepCount');\n      const targetEl = document.getElementById('targetValue');\n      const exStepEl = document.getElementById('exStep');\n      const exTextEl = document.getElementById('explainText');\n      const leftCut = document.getElementById('leftCut');\n      const rightCut = document.getElementById('rightCut');\n      const toggleBtn = document.getElementById('toggleBtn');\n      const toggleLabel = document.getElementById('toggleLabel');\n      const playIcon = document.getElementById('playIcon');\n      const resetBtn = document.getElementById('resetBtn');\n\n      let arr = [];\n      let nodes = [];\n      const N = 19; // array size\n      let l = 0, r = N - 1;\n      let target = null;\n      let running = false;\n      let step = 0;\n      let timer = null;\n      let foundIndex = -1;\n\n      // aesthetic timing\n      const PAUSE = 1100;\n      const STEP_ANIM = 520;\n\n      function generateArray() {\n        arr = [];\n        // Generate increasing values with gentle randomness\n        let val = 3;\n        for (let i = 0; i < N; i++) {\n          val += 1 + Math.floor(Math.random()*4);\n          arr.push(val);\n        }\n        // Choose target sometimes absent, sometimes present\n        if (Math.random() < 0.7) {\n          // pick existing\n          target = arr[Math.floor(Math.random()*N)];\n        } else {\n          // pick a non-existing number\n          const offset = Math.random() < 0.5 ? -1 : 1;\n          const idx = Math.floor(Math.random()*N);\n          target = arr[idx] + offset * (1 + Math.floor(Math.random()*3));\n        }\n      }\n\n      function renderArray() {\n        arrayEl.innerHTML = '';\n        nodes = [];\n        arr.forEach((v, idx) => {\n          const n = document.createElement('div');\n          n.className = 'node';\n          n.dataset.idx = idx;\n          n.innerHTML = `<div style=\"position:relative\">${v}</div><div class=\"sub\">[${idx}]</div>`;\n          arrayEl.appendChild(n);\n          nodes.push(n);\n        });\n        // small entrance animation\n        nodes.forEach((n,i)=>{\n          n.style.opacity = '0';\n          n.style.transform = 'translateY(12px) scale(.98)';\n          setTimeout(()=> {\n            n.style.transition = 'transform 640ms cubic-bezier(.2,.9,.2,1), opacity 640ms cubic-bezier(.2,.9,.2,1)';\n            n.style.opacity = '1';\n            n.style.transform = 'translateY(0px) scale(1)';\n          }, 40 + i*18);\n        });\n      }\n\n      function updatePills(){\n        lIdxEl.textContent = l;\n        rIdxEl.textContent = r;\n        stepCountEl.textContent = step;\n        targetEl.textContent = target;\n      }\n\n      function setExplain(title, text){\n        exStepEl.textContent = title;\n        exTextEl.textContent = text;\n      }\n\n      function markAllNeutral(){\n        nodes.forEach(n => {\n          n.classList.remove('m1','m2','neon','match','dim');\n        });\n      }\n\n      function fadeSegment(side, idx){\n        // side: 'left' or 'right'; idx inclusive cutoff\n        if(side==='left'){\n          // nodes 0..idx dim\n          nodes.forEach((n,i)=> {\n            if(i<=idx) n.classList.add('dim'); else n.classList.remove('dim');\n          });\n        } else {\n          nodes.forEach((n,i)=> {\n            if(i>=idx) n.classList.add('dim'); else n.classList.remove('dim');\n          });\n        }\n        // adjust overlay widths\n        const totalW = arrayEl.getBoundingClientRect().width;\n        const nodeW = nodes[0].getBoundingClientRect().width;\n        const gap = 18;\n        // compute left cut width\n        const leftCount = Math.max(0, Math.min(N, side==='left' ? (idx+1) : 0));\n        const leftWidth = leftCount > 0 ? Math.min(totalW, leftCount * nodeW + Math.max(0, leftCount-1) * gap + 28) : 0;\n        leftCut.style.width = leftWidth + 'px';\n        leftCut.style.left = (arrayEl.getBoundingClientRect().left - arrayEl.parentElement.getBoundingClientRect().left - 12) + 'px';\n\n        const rightCount = Math.max(0, side==='right' ? (N - idx) : 0);\n        const rightWidth = rightCount > 0 ? Math.min(totalW, rightCount * nodeW + Math.max(0, rightCount-1) * gap + 28) : 0;\n        rightCut.style.width = rightWidth + 'px';\n        rightCut.style.right = (arrayEl.parentElement.getBoundingClientRect().right - arrayEl.getBoundingClientRect().right - 12) + 'px';\n      }\n\n      function clearCuts(){\n        leftCut.style.width = '0px';\n        rightCut.style.width = '0px';\n      }\n\n      function doStep(){\n        if(!running) return;\n        if(l>r){\n          setExplain('Not Found', `The interval is empty. Target ${target} is not in the array.`);\n          running = false; toggleBtn.classList.remove('active'); toggleLabel.textContent = 'Animate'; playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"></path>';\n          clearCuts();\n          return;\n        }\n        step++;\n        updatePills();\n\n        // Compute mid points\n        const third = Math.floor((r - l) / 3);\n        const m1 = l + third;\n        const m2 = r - third;\n\n        // Visual highlight\n        markAllNeutral();\n        nodes[m1].classList.add('m1','neon');\n        nodes[m2].classList.add('m2','neon');\n\n        setExplain(`Step ${step}: Compare`, `Checking positions m1 = ${m1} (value ${arr[m1]}) and m2 = ${m2} (value ${arr[m2]}) against target ${target}.`);\n        updatePills();\n\n        // schedule comparison resolution\n        setTimeout(()=> {\n          // check matches first\n          if(arr[m1] === target){\n            nodes[m1].classList.add('match');\n            setExplain('Found', `Target ${target} found at index ${m1}. Algorithm halts.`);\n            running = false;\n            toggleBtn.classList.remove('active'); toggleLabel.textContent = 'Animate'; playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"></path>';\n            // highlight rest dims\n            nodes.forEach((n,i)=>{ if(i!==m1) n.classList.add('dim'); });\n            clearCuts();\n            return;\n          }\n          if(arr[m2] === target){\n            nodes[m2].classList.add('match');\n            setExplain('Found', `Target ${target} found at index ${m2}. Algorithm halts.`);\n            running = false;\n            toggleBtn.classList.remove('active'); toggleLabel.textContent = 'Animate'; playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"></path>';\n            nodes.forEach((n,i)=>{ if(i!==m2) n.classList.add('dim'); });\n            clearCuts();\n            return;\n          }\n\n          // decide which third to discard\n          if(target < arr[m1]){\n            // discard right part from m1..end? Actually discard [m1..r]\n            setExplain('Prune Right', `Target < arr[m1]. Discard indices ${m1} through ${r}. New interval: [${l} .. ${m1-1}].`);\n            // fade right portion starting at m1\n            nodes.forEach((n,i)=>{ if(i>=m1) n.classList.add('dim'); else n.classList.remove('dim'); });\n            // visual overlay on right\n            fadeSegment('right', m1);\n            r = m1 - 1;\n          } else if(target > arr[m2]){\n            setExplain('Prune Left', `Target > arr[m2]. Discard indices ${l} through ${m2}. New interval: [${m2+1} .. ${r}].`);\n            nodes.forEach((n,i)=>{ if(i<=m2) n.classList.add('dim'); else n.classList.remove('dim'); });\n            fadeSegment('left', m2);\n            l = m2 + 1;\n          } else {\n            setExplain('Narrow Middle', `Target is between arr[m1] and arr[m2]. Discard the outer thirds. New interval: [${m1+1} .. ${m2-1}].`);\n            nodes.forEach((n,i)=>{ if(i<=m1 || i>=m2) n.classList.add('dim'); else n.classList.remove('dim'); });\n            // mark both sides cut\n            // left cut width up to m1, right cut width from m2\n            fadeSegment('left', m1);\n            setTimeout(()=> fadeSegment('right', m2), 20);\n            l = m1 + 1;\n            r = m2 - 1;\n          }\n\n          updatePills();\n\n          // after a pause, continue or stop\n          setTimeout(()=> {\n            if(r < l){\n              setExplain('Not Found', `Interval exhausted. Target ${target} is not present.`);\n              running = false;\n              toggleBtn.classList.remove('active'); toggleLabel.textContent = 'Animate'; playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"></path>';\n              return;\n            }\n            // continue to next step\n            if(running) {\n              // minor snap: clear special classes before next highlight\n              nodes.forEach(n => n.classList.remove('m1','m2','neon'));\n              // smooth reposition overlay\n              doStep();\n            }\n          }, PAUSE);\n        }, STEP_ANIM + 120);\n      }\n\n      function start(){\n        if(running) return;\n        running = true;\n        toggleBtn.classList.add('active');\n        toggleLabel.textContent = 'Pause';\n        playIcon.innerHTML = '<path d=\"M6 19h4V5H6v14zm8-14v14h4V5h-4z\" fill=\"white\"></path>'; // pause icon\n        // if already finished do nothing\n        if(l>r) {\n          setExplain('Done', 'Interval is empty. Reset to visualize a new example.');\n          running = false;\n          toggleBtn.classList.remove('active');\n          toggleLabel.textContent = 'Animate';\n          playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"></path>';\n          return;\n        }\n        // kickoff\n        setTimeout(()=> doStep(), 220);\n      }\n\n      function pause(){\n        running = false;\n        toggleBtn.classList.remove('active');\n        toggleLabel.textContent = 'Animate';\n        playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"></path>';\n      }\n\n      function reset(){\n        // stop\n        running = false;\n        toggleBtn.classList.remove('active');\n        toggleLabel.textContent = 'Animate';\n        playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"></path>';\n\n        step = 0;\n        l = 0;\n        r = N - 1;\n        foundIndex = -1;\n        clearCuts();\n        generateArray();\n        renderArray();\n        updatePills();\n        setExplain('Ready', 'Press \"Animate\" to see ternary search divide the interval step by step.');\n      }\n\n      // event listeners\n      toggleBtn.addEventListener('click', ()=> {\n        if(running) pause(); else start();\n      });\n      resetBtn.addEventListener('click', ()=> {\n        reset();\n      });\n\n      // initial boot\n      reset();\n\n      // Accessibility: keyboard shortcuts (very minimal)\n      window.addEventListener('keydown', (e)=>{\n        if(e.key === ' '){\n          e.preventDefault();\n          if(running) pause(); else start();\n        } else if(e.key.toLowerCase() === 'r'){\n          reset();\n        }\n      });\n\n      // Resize handler to keep overlays consistent\n      window.addEventListener('resize', ()=> {\n        // attempt to recalc overlay positions (simple approach)\n        leftCut.style.left = (arrayEl.getBoundingClientRect().left - arrayEl.parentElement.getBoundingClientRect().left - 12) + 'px';\n        rightCut.style.right = (arrayEl.parentElement.getBoundingClientRect().right - arrayEl.getBoundingClientRect().right - 12) + 'px';\n      });\n\n    })();\n  </script>\n</body>\n</html>"
