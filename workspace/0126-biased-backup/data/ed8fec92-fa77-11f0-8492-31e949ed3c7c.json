    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Garbage Collection Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            background-color: #f0f0f0;\n            color: #333;\n            overflow: hidden;\n        }\n        .container {\n            position: relative;\n            width: 100vw;\n            height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background: linear-gradient(135deg, #75b2ff, #ff7e7e);\n            overflow: hidden;\n        }\n        .garbage {\n            position: absolute;\n            border-radius: 50%;\n            background-color: #4a4a4a;\n            animation: fall 5s infinite linear;\n            will-change: transform;\n        }\n        @keyframes fall {\n            0% {\n                transform: translateY(-100px);\n            }\n            100% {\n                transform: translateY(100vh);\n            }\n        }\n        .title {\n            position: absolute;\n            top: 20px;\n            font-size: 4em;\n            color: #fff;\n            text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.7);\n            z-index: 2;\n            transition: opacity 0.5s;\n        }\n        .button-container {\n            position: absolute;\n            bottom: 30px;\n            text-align: center;\n            z-index: 2;\n        }\n        .button {\n            background-color: #fff;\n            border: none;\n            border-radius: 25px;\n            padding: 15px 30px;\n            font-size: 1.5em;\n            color: #333;\n            cursor: pointer;\n            transition: transform 0.2s;\n        }\n        .button:hover {\n            transform: scale(1.05);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"title\" id=\"title\">Garbage Collection</div>\n        <div class=\"button-container\">\n            <button class=\"button\" id=\"start\">Start Visual</button>\n            <button class=\"button\" id=\"stop\" style=\"display: none;\">Stop Visual</button>\n        </div>\n    </div>\n    <script>\n        const startButton = document.getElementById('start');\n        const stopButton = document.getElementById('stop');\n        const container = document.querySelector('.container');\n        let garbageInterval;\n\n        function createGarbage() {\n            const garbage = document.createElement('div');\n            garbage.className = 'garbage';\n            garbage.style.width = Math.random() * 50 + 20 + 'px';\n            garbage.style.height = garbage.style.width;\n            garbage.style.left = Math.random() * 100 + 'vw';\n            container.appendChild(garbage);\n        }\n\n        function startAnimation() {\n            startButton.style.display = 'none';\n            stopButton.style.display = 'block';\n            garbageInterval = setInterval(createGarbage, 800);\n        }\n\n        function stopAnimation() {\n            startButton.style.display = 'block';\n            stopButton.style.display = 'none';\n            clearInterval(garbageInterval);\n            document.querySelectorAll('.garbage').forEach(g => g.remove());\n        }\n\n        startButton.addEventListener('click', startAnimation);\n        stopButton.addEventListener('click', stopAnimation);\n    </script>\n</body>\n</html>"
