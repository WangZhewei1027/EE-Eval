    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Logistic Regression: A Visual Journey</title>\n    <style>\n        :root {\n            --primary: #6C63FF;\n            --secondary: #FF6584;\n            --accent: #28C76F;\n            --dark: #2F2E41;\n            --light: #F9F9FF;\n            --transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n        }\n        \n        body {\n            background-color: var(--light);\n            color: var(--dark);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            line-height: 1.6;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            animation: fadeIn 1.2s ease-out forwards;\n        }\n        \n        h1 {\n            font-size: 2.8rem;\n            font-weight: 700;\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            margin-bottom: 0.5rem;\n            letter-spacing: -0.5px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: #999;\n            font-weight: 300;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n        \n        .container {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 3rem;\n            width: 100%;\n            max-width: 1200px;\n            margin-bottom: 3rem;\n            opacity: 0;\n            animation: fadeIn 1.2s ease-out 0.3s forwards;\n        }\n        \n        .card {\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);\n            padding: 2rem;\n            transition: var(--transition);\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            overflow: hidden;\n        }\n        \n        .card:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.12);\n        }\n        \n        .card-title {\n            font-size: 1.4rem;\n            font-weight: 600;\n            margin-bottom: 1rem;\n            color: var(--primary);\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n        \n        .card-icon {\n            width: 1.5rem;\n            height: 1.5rem;\n            fill: var(--primary);\n        }\n        \n        .visualization {\n            width: 100%;\n            height: 300px;\n            position: relative;\n            margin-top: 2rem;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-grow: 1;\n        }\n        \n        .chart-container {\n            width: 100%;\n            height: 100%;\n            position: relative;\n        }\n        \n        #scatterPlot, #sigmoid {\n            width: 100%;\n            height: 100%;\n            transition: var(--transition);\n        }\n        \n        #scatterPlot:hover, #sigmoid:hover {\n            transform: scale(1.02);\n        }\n        \n        .point {\n            position: absolute;\n            width: 12px;\n            height: 12px;\n            border-radius: 50%;\n            transform: translate(-50%, -50%);\n            transition: var(--transition);\n        }\n        \n        .point.negative {\n            background-color: var(--secondary);\n            box-shadow: 0 0 0 5px rgba(255, 101, 132, 0.3);\n        }\n        \n        .point.positive {\n            background-color: var(--accent);\n            box-shadow: 0 0 0 5px rgba(40, 199, 111, 0.3);\n        }\n        \n        .decision-boundary {\n            position: absolute;\n            height: 2px;\n            background-color: var(--primary);\n            width: 100%;\n            top: 50%;\n            left: 0;\n            transform: translateY(-50%);\n            transition: var(--transition);\n            z-index: 1;\n        }\n        \n        .sigmoid-curve {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            width: 80%;\n            height: 70%;\n            transform: translate(-50%, -50%);\n        }\n        \n        #sigmoidPath {\n            stroke: var(--primary);\n            stroke-width: 3;\n            fill: none;\n            stroke-dasharray: 1000;\n            stroke-dashoffset: 1000;\n            animation: draw 2s ease-out forwards;\n            animation-delay: 0.6s;\n        }\n        \n        .axis-label {\n            position: absolute;\n            font-size: 0.9rem;\n            color: #999;\n            font-weight: 300;\n        }\n        \n        .x-label {\n            bottom: -1.5rem;\n            left: 50%;\n            transform: translateX(-50%);\n        }\n        \n        .y-label {\n            left: -1.5rem;\n            top: 50%;\n            transform: translateY(-50%) rotate(-90deg);\n        }\n        \n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 2rem;\n            justify-content: center;\n            opacity: 0;\n            animation: fadeIn 1.2s ease-out 0.6s forwards;\n        }\n        \n        button {\n            background: linear-gradient(135deg, var(--primary), #8B84FF);\n            border: none;\n            color: white;\n            padding: 0.8rem 1.8rem;\n            border-radius: 50px;\n            font-weight: 500;\n            cursor: pointer;\n            transition: var(--transition);\n            box-shadow: 0 5px 15px rgba(108, 99, 255, 0.3);\n            outline: none;\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(108, 99, 255, 0.4);\n        }\n        \n        button.secondary {\n            background: white;\n            color: var(--primary);\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n        }\n        \n        button.secondary:hover {\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);\n            background: #f5f5ff;\n        }\n        \n        .explanation {\n            max-width: 800px;\n            margin: 3rem auto;\n            padding: 2rem;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);\n            opacity: 0;\n            animation: fadeIn 1.2s ease-out 0.9s forwards;\n        }\n        \n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.8rem;\n        }\n        \n        .explanation p {\n            margin-bottom: 1.5rem;\n            font-weight: 400;\n            color: #555;\n        }\n        \n        .highlight {\n            padding: 0.2rem 0.4rem;\n            background-color: rgba(108, 99, 255, 0.1);\n            border-radius: 4px;\n            color: var(--primary);\n            font-weight: 500;\n        }\n        \n        .formula {\n            background: #f8f8ff;\n            padding: 1.5rem;\n            border-radius: 8px;\n            margin: 1.5rem 0;\n            font-family: 'Courier New', monospace;\n            text-align: center;\n            border-left: 4px solid var(--primary);\n        }\n        \n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n        \n        @keyframes draw {\n            to { stroke-dashoffset: 0; }\n        }\n        \n        @media (max-width: 900px) {\n            .container {\n                grid-template-columns: 1fr;\n            }\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Logistic Regression</h1>\n        <p class=\"subtitle\">A visual exploration of binary classification through probability estimation</p>\n    </header>\n    \n    <div class=\"container\">\n        <div class=\"card\">\n            <h2 class=\"card-title\">\n                <svg class=\"card-icon\" viewBox=\"0 0 24 24\">\n                    <path d=\"M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M9,12c0-1.66,1.34-3,3-3s3,1.34,3,3 s-1.34,3-3,3S9,13.66,9,12z\"/>\n                </svg>\n                Decision Boundary\n            </h2>\n            <p>Observe how logistic regression separates two classes (blue vs green) using a linear decision boundary.</p>\n            <div class=\"visualization\">\n                <div class=\"chart-container\" id=\"scatterPlot\">\n                    <!-- Points will be generated by JavaScript -->\n                </div>\n                <div class=\"axis-label x-label\">Feature 1</div>\n                <div class=\"axis-label y-label\">Feature 2</div>\n            </div>\n        </div>\n        \n        <div class=\"card\">\n            <h2 class=\"card-title\">\n                <svg class=\"card-icon\" viewBox=\"0 0 24 24\">\n                    <path d=\"M19,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z M19,19H5V5h14V19z\"/>\n                </svg>\n                Sigmoid Function\n            </h2>\n            <p>The sigmoid function maps any real-valued number to a probability value between 0 and 1.</p>\n            <div class=\"visualization\">\n                <div class=\"chart-container\" id=\"sigmoid\">\n                    <svg class=\"sigmoid-curve\" viewBox=\"0 0 200 100\">\n                        <path id=\"sigmoidPath\" d=\"M10,90 C50,90 50,10 100,10 C150,10 150,90 190,90\" />\n                    </svg>\n                </div>\n                <div class=\"axis-label x-label\">Linear Combination of Features</div>\n                <div class=\"axis-label y-label\">Probability (0 to 1)</div>\n            </div>\n        </div>\n    </div>\n    \n    <div class=\"controls\">\n        <button id=\"trainModel\">Train Model</button>\n        <button class=\"secondary\" id=\"resetView\">Reset View</button>\n    </div>\n    \n    <div class=\"explanation\">\n        <h2>Understanding Logistic Regression</h2>\n        <p>Logistic regression is a statistical model that uses a logistic function to model a binary dependent variable. Despite its name, it is actually a <span class=\"highlight\">classification algorithm</span> rather than regression.</p>\n        \n        <div class=\"formula\">\n            P(Y=1) = 1 / (1 + e<sup>-(β₀ + β₁X₁ + ... + βₙXₙ)</sup>)\n        </div>\n        \n        <p>The algorithm learns the <span class=\"highlight\">coefficients (β)</span> that maximize the likelihood of observing the sample data. The resulting probabilities are transformed into class predictions (typically using a threshold of 0.5).</p>\n        \n        <p>Key advantages include:</p>\n        <ul style=\"margin-left: 1.5rem; margin-bottom: 1.5rem; color: #555;\">\n            <li>Efficient to train and interpret</li>\n            <li>Provides probability estimates along with classifications</li>\n            <li>Works well with linearly separable data</li>\n            <li>Resistant to overfitting with proper regularization</li>\n        </ul>\n    </div>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Scatter Plot Visualization\n            const scatterPlot = document.getElementById('scatterPlot');\n            const width = scatterPlot.clientWidth;\n            const height = scatterPlot.clientHeight;\n            \n            // Generate sample data\n            const negativePoints = generatePoints(20, 0, width, 0, height/2 - 20);\n            const positivePoints = generatePoints(20, 0, width, height/2 + 20, height);\n            \n            // Create DOM elements for points\n            negativePoints.forEach(point => {\n                const el = createPoint(point.x, point.y, 'negative');\n                scatterPlot.appendChild(el);\n            });\n            \n            positivePoints.forEach(point => {\n                const el = createPoint(point.x, point.y, 'positive');\n                scatterPlot.appendChild(el);\n            });\n            \n            // Initially show decision boundary at middle\n            const boundary = document.createElement('div');\n            boundary.className = 'decision-boundary';\n            boundary.style.width = '0%';\n            scatterPlot.appendChild(boundary);\n            \n            // Sigmoid animation\n            setTimeout(() => {\n                const sigmoidPath = document.getElementById('sigmoidPath');\n                sigmoidPath.style.strokeDashoffset = '0';\n            }, 600);\n            \n            // Button interactions\n            document.getElementById('trainModel').addEventListener('click', function() {\n                // Animate the decision boundary growing\n                boundary.style.width = '100%';\n                boundary.style.backgroundColor = var(--primary);\n                \n                // Animate points adjusting to boundary\n                document.querySelectorAll('.point').forEach(point => {\n                    point.style.transform = `translate(-50%, -50%) scale(1.2)`;\n                    setTimeout(() => {\n                        point.style.transform = `translate(-50%, -50%) scale(1)`;\n                    }, 300);\n                });\n                \n                // Button animation\n                this.style.transform = 'translateY(0)';\n                this.style.boxShadow = '0 5px 15px rgba(108, 99, 255, 0.3)';\n                \n                // Add slight delay before allowing reset\n                setTimeout(() => {\n                    document.getElementById('resetView').style.pointerEvents = 'auto';\n                }, 1000);\n            });\n            \n            document.getElementById('resetView').addEventListener('click', function() {\n                boundary.style.width = '0%';\n                this.style.pointerEvents = 'none';\n            });\n            \n            // Helper functions\n            function generatePoints(count, minX, maxX, minY, maxY) {\n                const points = [];\n                for (let i = 0; i < count; i++) {\n                    points.push({\n                        x: Math.random() * (maxX - minX) + minX,\n                        y: Math.random() * (maxY - minY) + minY\n                    });\n                }\n                return points;\n            }\n            \n            function createPoint(x, y, className) {\n                const point = document.createElement('div');\n                point.className = `point ${className}`;\n                point.style.left = `${x}px`;\n                point.style.top = `${y}px`;\n                return point;\n            }\n        });\n    </script>\n</body>\n</html>"
