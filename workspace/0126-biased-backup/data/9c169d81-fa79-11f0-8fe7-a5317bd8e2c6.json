  "question": "Runtime Environment",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Runtime Environment Simulator</title>\n  <style>\n    /* Minimal layout styling only to make controls usable; visual design kept plain */\n    body { font-family: monospace; margin: 8px; }\n    .row { display: flex; gap: 8px; }\n    .col { flex: 1; min-width: 220px; }\n    .pane { border: 1px solid #000; padding: 6px; }\n    label { display: block; margin-top: 6px; }\n    input[type=\"text\"], input[type=\"number\"], textarea, select { width: 100%; box-sizing: border-box; }\n    textarea { height: 80px; }\n    .small { font-size: 12px; }\n    button { margin: 2px 0; display: inline-block; }\n    .log { height: 220px; overflow: auto; white-space: pre-wrap; background: #fff; }\n    .tiny { font-size: 12px; }\n    .controls { display:flex; flex-wrap:wrap; gap:4px; }\n  </style>\n</head>\n<body>\n  <h3>Runtime Environment Simulator</h3>\n  <div class=\"row\">\n    <div class=\"col pane\" id=\"instancesPane\">\n      <strong>Instances</strong>\n      <div>\n        <label>Name: <input type=\"text\" id=\"newName\" value=\"env-1\"></label>\n        <label>Type:\n          <select id=\"newType\">\n            <option>container</option>\n            <option>vm</option>\n            <option>function</option>\n          </select>\n        </label>\n        <div>\n          <button id=\"createBtn\">Create</button>\n          <button id=\"cloneBtn\">Clone Selected</button>\n          <button id=\"deleteBtn\">Delete Selected</button>\n        </div>\n      </div>\n      <label>Instances List:</label>\n      <select id=\"instancesList\" size=\"8\" style=\"width:100%\"></select>\n      <div class=\"tiny\">\n        Selected: <span id=\"selectedId\">none</span><br>\n        Quick actions: <button id=\"startQuick\">Start</button><button id=\"stopQuick\">Stop</button><button id=\"snapshotQuick\">Snap</button>\n      </div>\n    </div>\n\n    <div class=\"col pane\" id=\"configPane\">\n      <strong>Configuration & Resources</strong>\n      <label>CPU (cores): <input type=\"range\" id=\"cpuSlider\" min=\"0.1\" max=\"8\" step=\"0.1\" value=\"1\"> <span id=\"cpuVal\">1</span></label>\n      <label>Memory (MB): <input type=\"range\" id=\"memSlider\" min=\"128\" max=\"16384\" step=\"64\" value=\"512\"> <span id=\"memVal\">512</span></label>\n      <label>Port: <input type=\"number\" id=\"portInput\" value=\"8080\"></label>\n      <label>Environment Variables (key=value, one per line):</label>\n      <textarea id=\"envText\">PATH=/usr/bin\nDEBUG=false</textarea>\n      <label>Mounts (host:container, one per line):</label>\n      <textarea id=\"mountsText\"></textarea>\n      <label>Startup command:</label>\n      <input type=\"text\" id=\"cmdInput\" value=\"run.sh\">\n      <div style=\"margin-top:6px;\">\n        <button id=\"applyConfig\">Apply to Selected</button>\n        <button id=\"resetConfig\">Reset to Instance</button>\n      </div>\n      <div class=\"tiny\">You can edit config and Apply; use Clone to copy instance including runtime state.</div>\n    </div>\n\n    <div class=\"col pane\" id=\"controlPane\">\n      <strong>Controls & Workflow</strong>\n      <div class=\"controls\">\n        <button id=\"startBtn\">Start</button>\n        <button id=\"pauseBtn\">Pause</button>\n        <button id=\"resumeBtn\">Resume</button>\n        <button id=\"stopBtn\">Stop</button>\n        <button id=\"crashBtn\">Crash</button>\n        <button id=\"killBtn\">Kill</button>\n      </div>\n      <div style=\"margin-top:6px;\">\n        <button id=\"snapshotBtn\">Snapshot</button>\n        <button id=\"restoreBtn\">Restore</button>\n        <button id=\"rollbackBtn\">Rollback</button>\n      </div>\n\n      <label>Autoscale: <input type=\"checkbox\" id=\"autoscaleChk\"></label>\n      <label>Load (simulated): <input type=\"range\" id=\"loadSlider\" min=\"0\" max=\"100\" value=\"0\"> <span id=\"loadVal\">0%</span></label>\n      <label>Fault injection:\n        <select id=\"faultSelect\">\n          <option value=\"\">none</option>\n          <option value=\"disk\">Disk Full</option>\n          <option value=\"net\">Network Partition</option>\n          <option value=\"memLeak\">Memory Leak</option>\n          <option value=\"highCpu\">High CPU</option>\n        </select>\n      </label>\n      <div style=\"margin-top:6px;\">\n        <button id=\"injectFaultBtn\">Inject Fault</button>\n        <button id=\"resolveFaultBtn\">Resolve Fault</button>\n      </div>\n\n      <hr>\n      <strong>Tasks & Triggers</strong>\n      <label>Task command: <input type=\"text\" id=\"taskCmd\" value=\"backup\"></label>\n      <label>Delay (sec): <input type=\"number\" id=\"taskDelay\" value=\"0\" min=\"0\"></label>\n      <div>\n        <button id=\"queueTaskBtn\">Queue Task</button>\n        <button id=\"runTaskNowBtn\">Run Now</button>\n      </div>\n      <label>Trigger (example: cpu>70, mem>2048, load>50):</label>\n      <input type=\"text\" id=\"triggerExpr\" placeholder=\"cpu>70\">\n      <div>\n        <button id=\"addTriggerBtn\">Add Trigger</button>\n        <button id=\"removeTriggersBtn\">Remove All Triggers</button>\n      </div>\n\n      <hr>\n      <strong>CLI</strong>\n      <textarea id=\"cliInput\" placeholder=\"type commands: start, stop, status, env set KEY VAL, exec echo hi\"></textarea>\n      <div><button id=\"cliRunBtn\">Run CLI</button></div>\n      <div class=\"tiny\">Commands affect selected instance.</div>\n    </div>\n  </div>\n\n  <div class=\"row\" style=\"margin-top:8px;\">\n    <div class=\"col pane\">\n      <strong>State & Metrics</strong>\n      <div id=\"stateDisplay\">No instance selected.</div>\n      <label>State timeline (events):</label>\n      <div id=\"events\" class=\"log\"></div>\n      <label>Metrics (live):</label>\n      <div id=\"metrics\" class=\"log tiny\"></div>\n    </div>\n\n    <div class=\"col pane\">\n      <strong>Snapshots & History</strong>\n      <div>\n        <label>Snapshot name: <input type=\"text\" id=\"snapName\" value=\"snap-1\"></label>\n        <button id=\"createSnapBtn\">Create Snapshot</button>\n        <button id=\"listSnapsBtn\">List Snapshots</button>\n      </div>\n      <label>Snapshots:</label>\n      <select id=\"snapList\" size=\"6\" style=\"width:100%\"></select>\n      <div style=\"margin-top:6px;\">\n        <button id=\"restoreSelectedSnap\">Restore Selected</button>\n        <button id=\"deleteSnapBtn\">Delete Snapshot</button>\n      </div>\n      <hr>\n      <strong>Export / Import</strong>\n      <div>\n        <button id=\"exportBtn\">Export Selected (JSON)</button>\n        <button id=\"importBtn\">Import JSON</button>\n      </div>\n      <textarea id=\"exportArea\" placeholder=\"Exported JSON appears here\"></textarea>\n      <div><input type=\"file\" id=\"importFile\"></div>\n    </div>\n\n    <div class=\"col pane\">\n      <strong>Logs & Debug</strong>\n      <div>\n        <label>Filter text: <input type=\"text\" id=\"logFilter\"></label>\n        <button id=\"clearLogBtn\">Clear Logs</button>\n      </div>\n      <div id=\"logConsole\" class=\"log\"></div>\n      <div style=\"margin-top:6px;\">\n        <button id=\"replayEventsBtn\">Replay Events (selected instance)</button>\n        <button id=\"undoBtn\">Undo Last Config</button>\n        <button id=\"redoBtn\">Redo</button>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  Runtime Environment Simulator\n  - Multiple instances\n  - Config editable\n  - Start/Stop/Pause/Crash/Resume etc.\n  - Tasks, Triggers, Fault injection, Snapshots\n  - CLI and export/import\n  - Minimal visual styling; focus on interactivity and complexity\n*/\n\n(function(){\n  // Utility\n  function id() { return 'i'+Math.random().toString(36).slice(2,9); }\n  function now() { return new Date().toISOString().replace('T',' ').slice(0,19); }\n  function logGlobal(msg){ appendLog('GLOBAL', msg); }\n  function appendLog(src, msg){\n    const el = document.getElementById('logConsole');\n    el.textContent += '['+now()+'] ['+src+'] ' + msg + '\\n';\n    el.scrollTop = el.scrollHeight;\n  }\n  function appendEvent(instance, msg){\n    const el = document.getElementById('events');\n    el.textContent += '['+now()+'] ['+instance.name+'] ' + msg + '\\n';\n    el.scrollTop = el.scrollHeight;\n  }\n\n  // State stores\n  const store = {\n    instances: {}, // id -> instance\n    selectedId: null,\n    history: [], // for undo/redo of configs\n    future: []\n  };\n\n  // Instance model factory\n  function createInstance(opts){\n    const instance = {\n      id: id(),\n      name: opts.name || ('env-'+Math.floor(Math.random()*1000)),\n      type: opts.type || 'container',\n      config: {\n        cpu: parseFloat(opts.cpu || 1),\n        mem: parseInt(opts.mem || 512),\n        port: opts.port || 8080,\n        env: opts.env || { PATH: '/usr/bin', DEBUG: 'false' },\n        mounts: opts.mounts || [],\n        cmd: opts.cmd || 'run',\n      },\n      state: 'stopped', // stopped, initializing, running, paused, crashed, terminating, killed\n      metrics: {\n        cpuUsage: 0.0, // percent\n        memUsage: 0, // MB\n        load: 0 // 0-100\n      },\n      tasks: [], // queued tasks: {id, cmd, delay, status}\n      triggers: [], // trigger expressions\n      snapshots: {},\n      events: [],\n      fault: null,\n      createdAt: Date.now(),\n      lastStart: null,\n      scale: 1\n    };\n    return instance;\n  }\n\n  // UI binds\n  const instancesList = document.getElementById('instancesList');\n  const selectedIdSpan = document.getElementById('selectedId');\n  const stateDisplay = document.getElementById('stateDisplay');\n  const metricsDisplay = document.getElementById('metrics');\n  const eventsDisplay = document.getElementById('events');\n  const logConsole = document.getElementById('logConsole');\n\n  // Init with one instance\n  function init(){\n    const base = createInstance({name:'env-1', type:'container'});\n    store.instances[base.id] = base;\n    selectInstance(base.id);\n    refreshInstancesList();\n    renderSelected();\n    appendLog('SYSTEM','Simulator initialized');\n    globalTick(); // start engine\n  }\n\n  // Rendering functions\n  function refreshInstancesList(){\n    instancesList.innerHTML = '';\n    Object.values(store.instances).forEach(inst=>{\n      const opt = document.createElement('option');\n      opt.value = inst.id;\n      opt.text = inst.name + ' ('+inst.type+') ['+inst.state+']';\n      instancesList.appendChild(opt);\n    });\n    // keep selection\n    if(store.selectedId){\n      instancesList.value = store.selectedId;\n    }\n  }\n\n  function selectInstance(idVal){\n    if(!idVal) return;\n    if(!store.instances[idVal]) return;\n    store.selectedId = idVal;\n    instancesList.value = idVal;\n    selectedIdSpan.textContent = store.instances[idVal].name + ' / ' + idVal;\n    renderSelected();\n  }\n\n  instancesList.addEventListener('change', function(){\n    selectInstance(this.value);\n  });\n\n  function renderSelected(){\n    const inst = store.instances[store.selectedId];\n    if(!inst){\n      stateDisplay.textContent = 'No instance selected.';\n      metricsDisplay.textContent = '';\n      return;\n    }\n    // state display\n    stateDisplay.textContent = 'Name: '+inst.name + '\\nType: '+inst.type + '\\nState: '+inst.state + '\\nFault: '+(inst.fault||'none') + '\\nScale: '+inst.scale;\n    // metrics\n    metricsDisplay.textContent =\n      'cpuUsage: '+inst.metrics.cpuUsage.toFixed(1)+'%  memUsage: '+inst.metrics.memUsage.toFixed(0)+'MB  load: '+inst.metrics.load+'%\\n' +\n      'Configured CPU: '+inst.config.cpu+' cores  Mem: '+inst.config.mem+'MB  Port: '+inst.config.port + '\\n' +\n      'Tasks queued: '+inst.tasks.length + '  Triggers: '+inst.triggers.length;\n    // populate config fields\n    document.getElementById('cpuSlider').value = inst.config.cpu;\n    document.getElementById('cpuVal').textContent = inst.config.cpu;\n    document.getElementById('memSlider').value = inst.config.mem;\n    document.getElementById('memVal').textContent = inst.config.mem;\n    document.getElementById('portInput').value = inst.config.port;\n    document.getElementById('envText').value = Object.entries(inst.config.env).map(e=>e.join('=')).join('\\n');\n    document.getElementById('mountsText').value = inst.config.mounts.join('\\n');\n    document.getElementById('cmdInput').value = inst.config.cmd;\n    // snapshots\n    const snapList = document.getElementById('snapList');\n    snapList.innerHTML = '';\n    Object.keys(inst.snapshots).forEach(k=>{\n      const opt = document.createElement('option');\n      opt.value = k;\n      opt.text = k + ' @ ' + inst.snapshots[k].time;\n      snapList.appendChild(opt);\n    });\n    // events\n    eventsDisplay.textContent = inst.events.join('\\n');\n    refreshInstancesList();\n  }\n\n  function saveHistory(inst){\n    // Save a deep copy of config for undo\n    try{\n      const snapshot = JSON.parse(JSON.stringify({id: inst.id, config: inst.config}));\n      store.history.push(snapshot);\n      if(store.history.length>50) store.history.shift();\n      store.future = [];\n    } catch(e){}\n  }\n\n  // Control handlers\n  document.getElementById('createBtn').addEventListener('click', ()=>{\n    const name = document.getElementById('newName').value || 'env';\n    const type = document.getElementById('newType').value;\n    const inst = createInstance({name, type});\n    store.instances[inst.id] = inst;\n    appendLog('SYSTEM','Created instance '+inst.name+' ('+inst.id+')');\n    selectInstance(inst.id);\n    refreshInstancesList();\n    renderSelected();\n  });\n\n  document.getElementById('cloneBtn').addEventListener('click', ()=>{\n    const sel = store.selectedId;\n    if(!sel) return alert('Select instance');\n    const src = store.instances[sel];\n    const clone = createInstance({\n      name: src.name + '-clone',\n      type: src.type\n    });\n    // deep copy\n    clone.config = JSON.parse(JSON.stringify(src.config));\n    clone.state = src.state;\n    clone.metrics = JSON.parse(JSON.stringify(src.metrics));\n    clone.tasks = JSON.parse(JSON.stringify(src.tasks));\n    clone.triggers = JSON.parse(JSON.stringify(src.triggers));\n    clone.fault = src.fault;\n    clone.scale = src.scale;\n    store.instances[clone.id] = clone;\n    appendLog('SYSTEM','Cloned '+src.name+' to '+clone.name);\n    selectInstance(clone.id);\n    refreshInstancesList();\n    renderSelected();\n  });\n\n  document.getElementById('deleteBtn').addEventListener('click', ()=>{\n    const sel = store.selectedId;\n    if(!sel) return alert('Select instance');\n    if(!confirm('Delete '+store.instances[sel].name+' ?')) return;\n    appendLog('SYSTEM','Deleted '+store.instances[sel].name);\n    delete store.instances[sel];\n    store.selectedId = Object.keys(store.instances)[0] || null;\n    refreshInstancesList();\n    if(store.selectedId) selectInstance(store.selectedId);\n    else renderSelected();\n  });\n\n  // Quick actions\n  document.getElementById('startQuick').addEventListener('click', ()=>triggerAction('start'));\n  document.getElementById('stopQuick').addEventListener('click', ()=>triggerAction('stop'));\n  document.getElementById('snapshotQuick').addEventListener('click', ()=>createSnapshot());\n\n  // Core actions\n  function triggerAction(action){\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    saveHistory(inst);\n    if(action==='start'){\n      if(inst.state==='running' || inst.state==='initializing') { appendEvent(inst,'start requested but already running/initializing'); return; }\n      inst.state = 'initializing';\n      inst.events.push(now()+' initializing');\n      appendEvent(inst,'initializing');\n      setTimeout(()=> {\n        if(inst.state==='initializing'){\n          inst.state = 'running';\n          inst.lastStart = Date.now();\n          inst.events.push(now()+' running');\n          appendEvent(inst,'running');\n        }\n        renderSelected();\n      }, 800);\n    } else if(action==='pause'){\n      if(inst.state==='running') { inst.state='paused'; inst.events.push(now()+' paused'); appendEvent(inst,'paused'); }\n      else appendEvent(inst,'pause requested but not running');\n    } else if(action==='resume'){\n      if(inst.state==='paused') { inst.state='running'; inst.events.push(now()+' resumed'); appendEvent(inst,'resumed'); }\n      else appendEvent(inst,'resume requested but not paused');\n    } else if(action==='stop'){\n      if(inst.state==='running' || inst.state==='paused' || inst.state==='initializing'){\n        inst.state = 'terminating';\n        inst.events.push(now()+' terminating');\n        appendEvent(inst,'terminating');\n        setTimeout(()=> { inst.state='stopped'; inst.events.push(now()+' stopped'); appendEvent(inst,'stopped'); renderSelected(); }, 600);\n      } else { inst.state='stopped'; appendEvent(inst,'stop requested'); }\n    } else if(action==='crash'){\n      inst.state='crashed'; inst.events.push(now()+' crashed'); appendEvent(inst,'crashed'); inst.fault='injected crash';\n    } else if(action==='kill'){\n      inst.state='killed'; inst.events.push(now()+' killed'); appendEvent(inst,'killed'); inst.fault='killed';\n    }\n    renderSelected();\n  }\n\n  document.getElementById('startBtn').addEventListener('click', ()=>triggerAction('start'));\n  document.getElementById('pauseBtn').addEventListener('click', ()=>triggerAction('pause'));\n  document.getElementById('resumeBtn').addEventListener('click', ()=>triggerAction('resume'));\n  document.getElementById('stopBtn').addEventListener('click', ()=>triggerAction('stop'));\n  document.getElementById('crashBtn').addEventListener('click', ()=>triggerAction('crash'));\n  document.getElementById('killBtn').addEventListener('click', ()=>triggerAction('kill'));\n\n  // snapshot / restore\n  function createSnapshot(name){\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    const snapName = name || document.getElementById('snapName').value || ('snap-'+Date.now());\n    inst.snapshots[snapName] = {\n      time: now(),\n      state: inst.state,\n      config: JSON.parse(JSON.stringify(inst.config)),\n      metrics: JSON.parse(JSON.stringify(inst.metrics)),\n      tasks: JSON.parse(JSON.stringify(inst.tasks)),\n      fault: inst.fault,\n      events: inst.events.slice()\n    };\n    appendLog('SNAP', 'Created snapshot '+snapName+' for '+inst.name);\n    renderSelected();\n  }\n  document.getElementById('createSnapBtn').addEventListener('click', ()=>createSnapshot());\n\n  document.getElementById('listSnapsBtn').addEventListener('click', ()=> {\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    const keys = Object.keys(inst.snapshots);\n    alert('Snapshots:\\n' + keys.map(k=>k+' @ '+inst.snapshots[k].time).join('\\n'));\n  });\n\n  document.getElementById('restoreSelectedSnap').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    const sel = document.getElementById('snapList').value;\n    if(!inst || !sel) return alert('Select snapshot');\n    const snap = inst.snapshots[sel];\n    if(!snap) return alert('No such snapshot');\n    saveHistory(inst);\n    inst.config = JSON.parse(JSON.stringify(snap.config));\n    inst.metrics = JSON.parse(JSON.stringify(snap.metrics));\n    inst.tasks = JSON.parse(JSON.stringify(snap.tasks));\n    inst.state = snap.state;\n    inst.fault = snap.fault;\n    inst.events.push(now()+' restored snapshot '+sel);\n    appendLog('SNAP','Restored '+sel+' on '+inst.name);\n    renderSelected();\n  });\n\n  document.getElementById('deleteSnapBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    const sel = document.getElementById('snapList').value;\n    if(!inst || !sel) return alert('Select snapshot');\n    delete inst.snapshots[sel];\n    appendLog('SNAP','Deleted snapshot '+sel);\n    renderSelected();\n  });\n\n  // export/import\n  document.getElementById('exportBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    const json = JSON.stringify(inst, null, 2);\n    document.getElementById('exportArea').value = json;\n    appendLog('EXPORT','Exported '+inst.name);\n  });\n\n  document.getElementById('importBtn').addEventListener('click', ()=>{\n    const txt = document.getElementById('exportArea').value;\n    if(!txt) return alert('Paste JSON into export area');\n    try {\n      const obj = JSON.parse(txt);\n      const newId = id();\n      obj.id = newId;\n      obj.name = obj.name || ('import-'+newId);\n      store.instances[newId] = obj;\n      appendLog('IMPORT','Imported '+obj.name);\n      selectInstance(newId);\n      refreshInstancesList();\n      renderSelected();\n    } catch(e){ alert('Invalid JSON'); }\n  });\n\n  document.getElementById('importFile').addEventListener('change', function(e){\n    const f = e.target.files[0];\n    if(!f) return;\n    const r = new FileReader();\n    r.onload = function(){ try {\n      const obj = JSON.parse(r.result);\n      const newId = id(); obj.id=newId; obj.name = obj.name || ('import-'+newId);\n      store.instances[newId] = obj;\n      appendLog('IMPORT','Imported file '+f.name+' as '+obj.name);\n      selectInstance(newId); refreshInstancesList(); renderSelected();\n    } catch(e){ alert('Invalid JSON'); } };\n    r.readAsText(f);\n  });\n\n  // config apply/reset\n  document.getElementById('applyConfig').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    saveHistory(inst);\n    inst.config.cpu = parseFloat(document.getElementById('cpuSlider').value);\n    inst.config.mem = parseInt(document.getElementById('memSlider').value);\n    inst.config.port = parseInt(document.getElementById('portInput').value);\n    inst.config.env = {};\n    const ev = document.getElementById('envText').value.split(/\\n/).map(s=>s.trim()).filter(Boolean);\n    ev.forEach(line=>{\n      const m = line.split('=');\n      inst.config.env[m[0]] = m.slice(1).join('=') || '';\n    });\n    inst.config.mounts = document.getElementById('mountsText').value.split(/\\n/).map(s=>s.trim()).filter(Boolean);\n    inst.config.cmd = document.getElementById('cmdInput').value;\n    appendLog('CONFIG','Applied config to '+inst.name);\n    inst.events.push(now()+' config applied');\n    renderSelected();\n  });\n\n  document.getElementById('resetConfig').addEventListener('click', ()=>{\n    renderSelected();\n  });\n\n  // sliders sync\n  document.getElementById('cpuSlider').addEventListener('input', function(){ document.getElementById('cpuVal').textContent = this.value; });\n  document.getElementById('memSlider').addEventListener('input', function(){ document.getElementById('memVal').textContent = this.value; });\n\n  // tasks & triggers\n  document.getElementById('queueTaskBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    const cmd = document.getElementById('taskCmd').value || 'task';\n    const delay = Math.max(0, parseInt(document.getElementById('taskDelay').value) || 0);\n    const t = { id: id(), cmd, delay, status: 'queued', queuedAt: Date.now() };\n    inst.tasks.push(t);\n    appendLog('TASK','Queued '+cmd+' on '+inst.name+' (delay '+delay+'s)');\n    inst.events.push(now()+' queued task '+cmd);\n    renderSelected();\n  });\n\n  document.getElementById('runTaskNowBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    const cmd = document.getElementById('taskCmd').value || 'task';\n    runTask(inst, {id:id(), cmd, delay:0, status:'queued', queuedAt:Date.now()});\n  });\n\n  function runTask(inst, task){\n    task.status = 'running';\n    appendLog('TASK','Running '+task.cmd+' on '+inst.name);\n    inst.events.push(now()+' running task '+task.cmd);\n    renderSelected();\n    setTimeout(()=> {\n      task.status = 'done';\n      appendLog('TASK','Completed '+task.cmd+' on '+inst.name);\n      inst.events.push(now()+' completed task '+task.cmd);\n      // apply effect: sample: if backup, reduce load; if leak cause mem usage\n      if(task.cmd.toLowerCase().includes('backup')) inst.metrics.load = Math.max(0, inst.metrics.load - 15);\n      if(task.cmd.toLowerCase().includes('restart')) { inst.state='running'; inst.events.push(now()+' restart finished'); }\n      renderSelected();\n    }, 1000 + Math.random()*2000);\n  }\n\n  document.getElementById('addTriggerBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    const expr = document.getElementById('triggerExpr').value.trim();\n    if(!expr) return alert('Enter trigger expression');\n    inst.triggers.push(expr);\n    appendLog('TRIG','Added trigger \"'+expr+'\" to '+inst.name);\n    inst.events.push(now()+' added trigger '+expr);\n    renderSelected();\n  });\n\n  document.getElementById('removeTriggersBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    inst.triggers = [];\n    appendLog('TRIG','Removed all triggers from '+inst.name);\n    inst.events.push(now()+' removed triggers');\n    renderSelected();\n  });\n\n  // fault injection\n  document.getElementById('injectFaultBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    const fault = document.getElementById('faultSelect').value;\n    if(!fault) return alert('Select a fault to inject');\n    inst.fault = fault;\n    if(fault==='disk') inst.metrics.load += 10;\n    if(fault==='net') inst.metrics.load += 5;\n    if(fault==='memLeak') inst.metrics.memUsage += 300;\n    if(fault==='highCpu') inst.metrics.cpuUsage += 40;\n    inst.state = 'running';\n    appendLog('FAULT','Injected '+fault+' into '+inst.name);\n    inst.events.push(now()+' injected fault '+fault);\n    renderSelected();\n  });\n\n  document.getElementById('resolveFaultBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    inst.fault = null;\n    appendLog('FAULT','Resolved faults on '+inst.name);\n    inst.events.push(now()+' resolved faults');\n    renderSelected();\n  });\n\n  // CLI\n  document.getElementById('cliRunBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    const txt = document.getElementById('cliInput').value.trim();\n    if(!inst) return alert('Select instance');\n    if(!txt) return alert('Type CLI command(s)');\n    const lines = txt.split('\\n').map(s=>s.trim()).filter(Boolean);\n    lines.forEach(line => execCLI(inst, line));\n    document.getElementById('cliInput').value = '';\n    renderSelected();\n  });\n\n  function execCLI(inst, line){\n    appendLog('CLI','['+inst.name+'] $ '+line);\n    const parts = line.split(' ').filter(Boolean);\n    const cmd = parts[0];\n    if(cmd==='start') triggerAction('start');\n    else if(cmd==='stop') triggerAction('stop');\n    else if(cmd==='status') appendLog('CLI', JSON.stringify({state:inst.state,metrics:inst.metrics},null,0));\n    else if(cmd==='env' && parts[1]==='set'){\n      const k = parts[2], v = parts.slice(3).join(' ') || '';\n      inst.config.env[k] = v;\n      appendLog('CLI','Set env '+k+'='+v);\n    } else if(cmd==='exec'){\n      const program = parts.slice(1).join(' ');\n      inst.events.push(now()+' exec:'+program);\n      appendLog('CLI','Executed \"'+program+'\" on '+inst.name);\n    } else if(cmd==='snapshot'){\n      createSnapshot('cli-snap-'+Date.now());\n    } else if(cmd==='scale'){\n      const s = parseInt(parts[1]||1);\n      inst.scale = s;\n      appendLog('CLI','Scaled '+inst.name+' to '+s);\n    } else {\n      appendLog('CLI','Unknown CLI command: '+line);\n    }\n  }\n\n  // Undo/Redo simple for configs\n  document.getElementById('undoBtn').addEventListener('click', ()=>{\n    const last = store.history.pop();\n    if(!last) { appendLog('UNDO', 'Nothing to undo'); return; }\n    const inst = store.instances[last.id];\n    if(inst){\n      store.future.push(JSON.parse(JSON.stringify({id:inst.id, config:inst.config})));\n      inst.config = last.config;\n      appendLog('UNDO','Undid config on '+inst.name);\n      renderSelected();\n    }\n  });\n\n  document.getElementById('redoBtn').addEventListener('click', ()=>{\n    const f = store.future.pop();\n    if(!f) { appendLog('UNDO','Nothing to redo'); return; }\n    const inst = store.instances[f.id];\n    if(inst){\n      store.history.push(JSON.parse(JSON.stringify({id:inst.id, config:inst.config})));\n      inst.config = f.config;\n      appendLog('UNDO','Redid config on '+inst.name);\n      renderSelected();\n    }\n  });\n\n  // Logs and replay\n  document.getElementById('clearLogBtn').addEventListener('click', ()=>{\n    logConsole.textContent = '';\n  });\n\n  document.getElementById('replayEventsBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    alert('Replaying events:\\n' + inst.events.join('\\n'));\n  });\n\n  // Undo for config apply already saved above.\n\n  // Auto engine tick for metrics, triggers, tasks\n  let engineInterval = null;\n  function globalTick(){\n    if(engineInterval) clearInterval(engineInterval);\n    engineInterval = setInterval(()=> {\n      // Update each instance\n      Object.values(store.instances).forEach(inst=>{\n        // Passive decay of metrics\n        inst.metrics.cpuUsage = Math.max(0, inst.metrics.cpuUsage - 0.5);\n        inst.metrics.memUsage = Math.max(128, inst.metrics.memUsage - 1);\n        // Load slider from UI influences selected instance only:\n        const loadVal = parseInt(document.getElementById('loadSlider').value);\n        if(inst.id === store.selectedId){\n          inst.metrics.load = loadVal;\n        } else {\n          // other instances drift randomly\n          inst.metrics.load = Math.max(0, Math.min(100, inst.metrics.load + (Math.random()-0.5)*4));\n        }\n        // Fault effects\n        if(inst.fault === 'highCpu') inst.metrics.cpuUsage = Math.min(100, inst.metrics.cpuUsage + 5);\n        if(inst.fault === 'memLeak') inst.metrics.memUsage = Math.min(inst.config.mem*2, inst.metrics.memUsage + 20);\n        if(inst.fault === 'disk') inst.metrics.load = Math.min(100, inst.metrics.load + 3);\n        // Autoscale: increase scale if load high\n        const autos = document.getElementById('autoscaleChk').checked;\n        if(autos && inst.metrics.load > 70) {\n          inst.scale = Math.min(10, inst.scale + 1);\n          appendEvent(inst, 'autoscale up to '+inst.scale);\n        } else if(autos && inst.metrics.load < 30 && inst.scale>1) {\n          inst.scale = Math.max(1, inst.scale - 1);\n          appendEvent(inst, 'autoscale down to '+inst.scale);\n        }\n        // CPU and memory usage interplay with scale and config\n        inst.metrics.cpuUsage = Math.min(100, inst.metrics.cpuUsage + inst.metrics.load * 0.02 * inst.scale);\n        inst.metrics.memUsage = Math.min(inst.config.mem * Math.max(1,inst.scale), Math.max(inst.metrics.memUsage, inst.metrics.load*inst.config.mem/100));\n\n        // Execute due tasks\n        for(let i=0;i<inst.tasks.length;i++){\n          const t = inst.tasks[i];\n          if(t.status==='queued'){\n            const age = (Date.now() - t.queuedAt)/1000;\n            if(age >= t.delay){\n              runTask(inst, t);\n            }\n          }\n        }\n        // Remove done tasks older than 10s\n        inst.tasks = inst.tasks.filter(t => !(t.status==='done' && ((Date.now()-t.queuedAt)/1000 > 10)));\n\n        // Check triggers\n        inst.triggers.forEach(expr=>{\n          try {\n            const local = {\n              cpu: inst.metrics.cpuUsage,\n              mem: inst.metrics.memUsage,\n              load: inst.metrics.load,\n              state: inst.state\n            };\n            // create a safe evaluator for simple comparisons: cpu>70, mem>2048, load<20, state==running\n            const safe = expr.replace(/([a-zA-Z_][a-zA-Z0-9_]*)/g, function(m){\n              if(['cpu','mem','load','state'].indexOf(m)>=0) return 'local.'+m;\n              return m;\n            });\n            // disallow letters other than allowed words and operators\n            // eslint-disable-next-line no-eval\n            const result = eval(safe); // intentionally using eval for flexible triggers - controlled\n            if(result){\n              appendEvent(inst, 'trigger fired: '+expr);\n              // default action: queue a task named trigger:<expr>\n              const t = {id:id(), cmd:'trigger:'+expr, delay:0, status:'queued', queuedAt: Date.now()};\n              inst.tasks.push(t);\n              // remove trigger by default to avoid flooding\n              const idx = inst.triggers.indexOf(expr);\n              if(idx>=0) inst.triggers.splice(idx,1);\n            }\n          } catch(e){}\n        });\n\n        // If crashed and no fault set, maybe auto-restart if policy\n        if(inst.state==='crashed'){\n          // try auto-restart after some time\n          if(Math.random() < 0.05){\n            inst.state='initializing';\n            appendEvent(inst, 'auto-restart triggered');\n            setTimeout(()=>{ if(inst.state==='initializing'){ inst.state='running'; appendEvent(inst,'auto-restarted'); renderSelected(); }}, 500);\n          }\n        }\n      });\n\n      // Update displays for selected instance\n      renderSelected();\n    }, 1000);\n  }\n\n  // Snapshot via button reference\n  document.getElementById('snapshotBtn').addEventListener('click', ()=>createSnapshot());\n\n  document.getElementById('restoreBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    const keys = Object.keys(inst.snapshots);\n    if(keys.length===0) return alert('No snapshots available');\n    const choice = keys[0];\n    inst.config = JSON.parse(JSON.stringify(inst.snapshots[choice].config));\n    inst.state = inst.snapshots[choice].state;\n    appendLog('SNAP','Restored '+choice+' on '+inst.name);\n    renderSelected();\n  });\n\n  document.getElementById('rollbackBtn').addEventListener('click', ()=>{\n    const inst = store.instances[store.selectedId];\n    if(!inst) return alert('Select instance');\n    // simple rollback: restore last snapshot if exists\n    const keys = Object.keys(inst.snapshots);\n    if(keys.length===0) return alert('No snapshots');\n    const choice = keys[keys.length-1];\n    inst.config = JSON.parse(JSON.stringify(inst.snapshots[choice].config));\n    appendLog('SNAP','Rolled back to '+choice+' on '+inst.name);\n    renderSelected();\n  });\n\n  // Quick start/stop Buttons in Instances pane\n  document.getElementById('startQuick').addEventListener('click', ()=>triggerAction('start'));\n  document.getElementById('stopQuick').addEventListener('click', ()=>triggerAction('stop'));\n\n  // Quick snapshot\n  document.getElementById('snapshotQuick').addEventListener('click', ()=>createSnapshot('quick-'+Date.now()));\n\n  // Load slider display\n  document.getElementById('loadSlider').addEventListener('input', function(){ document.getElementById('loadVal').textContent = this.value+'%'; });\n\n  // Clear events\n  document.getElementById('clearLogBtn').addEventListener('click', ()=>{ document.getElementById('logConsole').value=''; });\n\n  // Initialize\n  init();\n\n  // Expose minimal debugging globally (not necessary but handy)\n  window._sim = { store, createInstance, triggerAction, appendLog };\n\n})();\n</script>\n</body>\n</html>"
