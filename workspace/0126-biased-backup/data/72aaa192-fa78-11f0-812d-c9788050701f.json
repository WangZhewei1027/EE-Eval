    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>A* Pathfinding Visualization</title>\n    <style>\n        :root {\n            --primary: #5e35b1;\n            --secondary: #3949ab;\n            --accent: #7c4dff;\n            --text: #f5f5f5;\n            --background: #121212;\n            --grid: #1e1e1e;\n            --open: #43a047;\n            --closed: #e53935;\n            --path: #ffd600;\n            --wall: #212121;\n            --start: #00e676;\n            --end: #ff4081;\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: var(--background);\n            color: var(--text);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        header {\n            width: 100%;\n            padding: 2rem 0;\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            text-align: center;\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);\n            margin-bottom: 2rem;\n        }\n\n        h1 {\n            font-size: 2.5rem;\n            margin: 0;\n            font-weight: 300;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.1rem;\n            opacity: 0.9;\n            margin-top: 0.5rem;\n        }\n\n        .container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            width: 90%;\n            max-width: 1000px;\n        }\n\n        .grid-container {\n            position: relative;\n            width: 600px;\n            height: 600px;\n            margin: 2rem 0;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);\n            border-radius: 8px;\n            overflow: hidden;\n        }\n\n        .grid {\n            display: grid;\n            grid-template-columns: repeat(20, 1fr);\n            grid-template-rows: repeat(20, 1fr);\n            width: 100%;\n            height: 100%;\n            background-color: var(--grid);\n            gap: 1px;\n        }\n\n        .cell {\n            background-color: var(--background);\n            transition: all 0.3s ease;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: relative;\n        }\n\n        .cell.wall {\n            background-color: var(--wall);\n            animation: wallAppear 0.3s ease-out;\n        }\n\n        .cell.start {\n            background-color: var(--start);\n            animation: pulse 1.5s infinite;\n        }\n\n        .cell.end {\n            background-color: var(--end);\n            animation: pulse 1.5s infinite;\n        }\n\n        .cell.open {\n            background-color: var(--open);\n            animation: cellExpand 0.4s ease-out;\n        }\n\n        .cell.closed {\n            background-color: var(--closed);\n            animation: cellShrink 0.3s ease-out;\n        }\n\n        .cell.path {\n            background-color: var(--path);\n            animation: pathPulse 0.8s ease-in-out;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-bottom: 2rem;\n        }\n\n        button {\n            padding: 0.8rem 1.5rem;\n            background: linear-gradient(135deg, var(--accent), var(--primary));\n            color: white;\n            border: none;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .legend {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: center;\n            gap: 1.5rem;\n            margin: 1rem 0;\n            width: 100%;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .info-panel {\n            background: rgba(30, 30, 30, 0.8);\n            backdrop-filter: blur(10px);\n            padding: 1.5rem;\n            border-radius: 12px;\n            margin: 2rem 0;\n            width: 100%;\n            max-width: 800px;\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);\n        }\n\n        h2 {\n            color: var(--accent);\n            font-weight: 400;\n            margin-top: 0;\n        }\n\n        p {\n            line-height: 1.6;\n            margin-bottom: 1rem;\n        }\n\n        footer {\n            margin-top: auto;\n            padding: 1.5rem;\n            text-align: center;\n            width: 100%;\n            background: linear-gradient(135deg, var(--secondary), var(--primary));\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        @keyframes cellExpand {\n            0% { transform: scale(0.8); opacity: 0; }\n            100% { transform: scale(1); opacity: 1; }\n        }\n\n        @keyframes cellShrink {\n            0% { transform: scale(1.1); }\n            100% { transform: scale(1); }\n        }\n\n        @keyframes wallAppear {\n            0% { transform: scale(0.9); opacity: 0; }\n            100% { transform: scale(1); opacity: 1; }\n        }\n\n        @keyframes pathPulse {\n            0% { transform: scale(1); background-color: var(--path); }\n            50% { transform: scale(1.1); background-color: #ffeb3b; }\n            100% { transform: scale(1); background-color: var(--path); }\n        }\n\n        .heuristic-value {\n            position: absolute;\n            font-size: 0.6rem;\n            color: rgba(255, 255, 255, 0.7);\n            pointer-events: none;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>A* Pathfinding Algorithm</h1>\n        <div class=\"subtitle\">An intelligent search method combining Dijkstra's and Greedy Best-First Search</div>\n    </header>\n\n    <div class=\"container\">\n        <div class=\"controls\">\n            <button id=\"visualize-btn\">Visualize A*</button>\n            <button id=\"reset-btn\">Reset Grid</button>\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--start);\"></div>\n                <span>Start Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--end);\"></div>\n                <span>End Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--open);\"></div>\n                <span>Open Set</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--closed);\"></div>\n                <span>Closed Set</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--path);\"></div>\n                <span>Final Path</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background-color: var(--wall);\"></div>\n                <span>Wall/Obstacle</span>\n            </div>\n        </div>\n\n        <div class=\"grid-container\">\n            <div class=\"grid\" id=\"grid\"></div>\n        </div>\n\n        <div class=\"info-panel\">\n            <h2>How A* Search Works</h2>\n            <p>A* is an informed search algorithm that finds the shortest path between two points while avoiding obstacles. It combines the advantages of Dijkstra's algorithm (which finds the shortest path) and Greedy Best-First Search (which is fast but not optimal).</p>\n            <p>The algorithm uses a heuristic function to estimate the cost from the current node to the goal. At each step, it prioritizes nodes that minimize the total estimated cost (f(n) = g(n) + h(n)), where g(n) is the actual cost from the start node to n, and h(n) is the heuristic estimate from n to the goal.</p>\n            <p>When the heuristic function is admissible (never overestimates the true cost), A* is guaranteed to find the optimal path.</p>\n        </div>\n    </div>\n\n    <footer>\n        © 2023 A* Pathfinding Visualization | Designed for aesthetic excellence\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            const grid = document.getElementById('grid');\n            const visualizeBtn = document.getElementById('visualize-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            \n            const ROWS = 20;\n            const COLS = 20;\n            let gridState = [];\n            let startNode = { row: 5, col: 5 };\n            let endNode = { row: 15, col: 15 };\n            let isVisualizing = false;\n\n            // Initialize grid\n            function initializeGrid() {\n                grid.innerHTML = '';\n                gridState = Array(ROWS).fill().map(() => Array(COLS).fill().map(() => ({\n                    isWall: false,\n                    isStart: false,\n                    isEnd: false,\n                    isOpen: false,\n                    isClosed: false,\n                    isPath: false,\n                    gScore: Infinity,\n                    fScore: Infinity,\n                    cameFrom: null\n                })));\n\n                // Set start and end nodes\n                gridState[startNode.row][startNode.col].isStart = true;\n                gridState[endNode.row][endNode.col].isEnd = true;\n\n                // Create grid cells\n                for (let row = 0; row < ROWS; row++) {\n                    for (let col = 0; col < COLS; col++) {\n                        const cell = document.createElement('div');\n                        cell.className = 'cell';\n                        cell.dataset.row = row;\n                        cell.dataset.col = col;\n\n                        if (gridState[row][col].isStart) cell.classList.add('start');\n                        if (gridState[row][col].isEnd) cell.classList.add('end');\n\n                        // Add heuristic value display\n                        const heuristicValue = document.createElement('div');\n                        heuristicValue.className = 'heuristic-value';\n                        heuristicValue.textContent = Math.floor(calculateHeuristic(row, col));\n                        cell.appendChild(heuristicValue);\n\n                        grid.appendChild(cell);\n                    }\n                }\n\n                // Add some walls for demonstration\n                addDemoWalls();\n            }\n\n            function addDemoWalls() {\n                // Horizontal wall\n                for (let col = 5; col < 15; col++) {\n                    setWall(10, col);\n                }\n\n                // Vertical wall\n                for (let row = 5; row < 15; row++) {\n                    setWall(row, 10);\n                }\n\n                // Some random walls\n                setWall(3, 3);\n                setWall(3, 4);\n                setWall(4, 3);\n                setWall(17, 17);\n                setWall(17, 16);\n                setWall(16, 17);\n            }\n\n            function setWall(row, col) {\n                if (row === startNode.row && col === startNode.col) return;\n                if (row === endNode.row && col === endNode.col) return;\n                \n                gridState[row][col].isWall = true;\n                const cell = document.querySelector(`.cell[data-row=\"${row}\"][data-col=\"${col}\"]`);\n                if (cell) cell.classList.add('wall');\n            }\n\n            function calculateHeuristic(row, col) {\n                // Euclidean distance heuristic\n                return Math.sqrt(\n                    Math.pow(row - endNode.row, 2) + \n                    Math.pow(col - endNode.col, 2)\n                ) * 10;\n            }\n\n            function resetGrid() {\n                if (isVisualizing) return;\n                initializeGrid();\n            }\n\n            async function visualizeAStar() {\n                if (isVisualizing) return;\n                isVisualizing = true;\n\n                // Reset visualization state\n                for (let row = 0; row < ROWS; row++) {\n                    for (let col = 0; col < COLS; col++) {\n                        gridState[row][col].isOpen = false;\n                        gridState[row][col].isClosed = false;\n                        gridState[row][col].isPath = false;\n                        gridState[row][col].gScore = Infinity;\n                        gridState[row][col].fScore = Infinity;\n                        gridState[row][col].cameFrom = null;\n                        \n                        const cell = document.querySelector(`.cell[data-row=\"${row}\"][data-col=\"${col}\"]`);\n                        if (cell) {\n                            cell.classList.remove('open', 'closed', 'path');\n                        }\n                    }\n                }\n\n                // Initialize open set with start node\n                const openSet = [startNode];\n                gridState[startNode.row][startNode.col].gScore = 0;\n                gridState[startNode.row][startNode.col].fScore = calculateHeuristic(startNode.row, startNode.col);\n\n                while (openSet.length > 0) {\n                    // Find node in openSet with lowest fScore\n                    let currentIndex = 0;\n                    for (let i = 1; i < openSet.length; i++) {\n                        const currentF = gridState[openSet[currentIndex].row][openSet[currentIndex].col].fScore;\n                        const nextF = gridState[openSet[i].row][openSet[i].col].fScore;\n                        if (nextF < currentF) currentIndex = i;\n                    }\n                    \n                    const currentNode = openSet[currentIndex];\n                    \n                    // Check if we've reached the end\n                    if (currentNode.row === endNode.row && currentNode.col === endNode.col) {\n                        await reconstructPath();\n                        isVisualizing = false;\n                        return;\n                    }\n\n                    // Move current node from open to closed\n                    openSet.splice(currentIndex, 1);\n                    gridState[currentNode.row][currentNode.col].isClosed = true;\n                    gridState[currentNode.row][currentNode.col].isOpen = false;\n                    \n                    const cell = document.querySelector(`.cell[data-row=\"${currentNode.row}\"][data-col=\"${currentNode.col}\"]`);\n                    if (cell) {\n                        cell.classList.remove('open');\n                        cell.classList.add('closed');\n                    }\n\n                    // Get neighbors\n                    const neighbors = [];\n                    const directions = [\n                        { row: -1, col: 0 },  // up\n                        { row: 1, col: 0 },   // down\n                        { row: 0, col: -1 },  // left\n                        { row: 0, col: 1 },   // right\n                        { row: -1, col: -1 }, // up-left\n                        { row: -1, col: 1 },  // up-right\n                        { row: 1, col: -1 },  // down-left\n                        { row: 1, col: 1 }    // down-right\n                    ];\n\n                    for (const dir of directions) {\n                        const neighborRow = currentNode.row + dir.row;\n                        const neighborCol = currentNode.col + dir.col;\n                        \n                        if (neighborRow >= 0 && neighborRow < ROWS && \n                            neighborCol >= 0 && neighborCol < COLS && \n                            !gridState[neighborRow][neighborCol].isWall) {\n                            \n                            neighbors.push({ row: neighborRow, col: neighborCol });\n                        }\n                    }\n\n                    for (const neighbor of neighbors) {\n                        if (gridState[neighbor.row][neighbor.col].isClosed) continue;\n\n                        // Diagonal movement costs more\n                        const isDiagonal = Math.abs(currentNode.row - neighbor.row) + Math.abs(currentNode.col - neighbor.col) === 2;\n                        const tentativeGScore = gridState[currentNode.row][currentNode.col].gScore + (isDiagonal ? 14 : 10);\n                        \n                        if (tentativeGScore < gridState[neighbor.row][neighbor.col].gScore) {\n                            gridState[neighbor.row][neighbor.col].cameFrom = currentNode;\n                            gridState[neighbor.row][neighbor.col].gScore = tentativeGScore;\n                            gridState[neighbor.row][neighbor.col].fScore = tentativeGScore + calculateHeuristic(neighbor.row, neighbor.col);\n                            \n                            if (!openSet.some(node => node.row === neighbor.row && node.col === neighbor.col)) {\n                                openSet.push(neighbor);\n                                gridState[neighbor.row][neighbor.col].isOpen = true;\n                                \n                                const neighborCell = document.querySelector(`.cell[data-row=\"${neighbor.row}\"][data-col=\"${neighbor.col}\"]`);\n                                if (neighborCell) {\n                                    neighborCell.classList.add('open');\n                                }\n                            }\n                        }\n                    }\n\n                    // Add slight delay for visualization\n                    await new Promise(resolve => setTimeout(resolve, 20));\n                }\n\n                // No path found\n                isVisualizing = false;\n            }\n\n            async function reconstructPath() {\n                let current = endNode;\n                const path = [];\n                \n                while (current && !(current.row === startNode.row && current.col === startNode.col)) {\n                    path.unshift(current);\n                    current = gridState[current.row][current.col].cameFrom;\n                }\n                \n                // Visualize path with delay\n                for (const node of path) {\n                    gridState[node.row][node.col].isPath = true;\n                    const cell = document.querySelector(`.cell[data-row=\"${node.row}\"][data-col=\"${node.col}\"]`);\n                    if (cell) {\n                        cell.classList.add('path');\n                        await new Promise(resolve => setTimeout(resolve, 50));\n                    }\n                }\n            }\n\n            // Event listeners\n            visualizeBtn.addEventListener('click', visualizeAStar);\n            resetBtn.addEventListener('click', resetGrid);\n\n            // Initialize\n            initializeGrid();\n        });\n    </script>\n</body>\n</html>"
