    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Heap (Min) Explanation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        #text {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n    </style>\n</head>\n<body>\n    <div id=\"text\"></div>\n    <button id=\"demonstration-button\">Demonstrate Min Heap</button>\n\n    <script>\n        const textElement = document.getElementById('text');\n        const demonstrationButton = document.getElementById('demonstration-button');\n\n        // Define a sample array\n        let array = [4, 2, 9, 6, 23, 12, 13, 10, 7, 5, 1];\n\n        // Define a function to build a min heap\n        function buildMinHeap(array) {\n            for (let i = Math.floor(array.length / 2) - 1; i >= 0; i--) {\n                heapify(array, i);\n            }\n        }\n\n        // Define a function to heapify an array\n        function heapify(array, i) {\n            let smallest = i;\n            let left = 2 * i + 1;\n            let right = 2 * i + 2;\n\n            if (left < array.length && array[left] < array[smallest]) {\n                smallest = left;\n            }\n\n            if (right < array.length && array[right] < array[smallest]) {\n                smallest = right;\n            }\n\n            if (smallest !== i) {\n                swap(array, i, smallest);\n                heapify(array, smallest);\n            }\n        }\n\n        // Define a function to swap two elements in an array\n        function swap(array, i, j) {\n            let temp = array[i];\n            array[i] = array[j];\n            array[j] = temp;\n        }\n\n        // Define a function to print the min heap\n        function printMinHeap(array) {\n            textElement.innerHTML = '';\n            for (let i = 0; i < array.length; i++) {\n                textElement.innerHTML += array[i] + ' ';\n            }\n        }\n\n        // Build the min heap\n        buildMinHeap(array);\n\n        // Print the min heap\n        printMinHeap(array);\n\n        // Add an event listener to the demonstration button\n        demonstrationButton.addEventListener('click', () => {\n            // Build a new min heap\n            let newArray = [1, 5, 3, 6, 7, 8, 2, 4];\n\n            // Print the new min heap\n            printMinHeap(newArray);\n        });\n    </script>\n</body>\n</html>"
