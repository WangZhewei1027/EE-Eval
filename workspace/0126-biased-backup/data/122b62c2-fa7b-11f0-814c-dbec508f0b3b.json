    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Graph (Undirected)</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n        }\n        #graph-container {\n            width: 800px;\n            height: 600px;\n            border: 1px solid black;\n            padding: 10px;\n            margin: 20px auto;\n        }\n        #graph {\n            border: 1px solid black;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"graph-container\"></div>\n    <script>\n        let graph = {\n            nodes: [],\n            edges: [],\n            selectedNode: null,\n            currentNode: null,\n            clickHandler: function(node) {\n                if (node === this.selectedNode) return;\n                this.selectedNode = node;\n                this.updateGraph();\n            },\n            updateGraph: function() {\n                const graphElement = document.getElementById('graph');\n                graphElement.innerHTML = '';\n                graph.nodes.forEach(node => {\n                    const nodeElement = document.createElement('div');\n                    nodeElement.classList.add('node');\n                    nodeElement.textContent = node.name;\n                    graphElement.appendChild(nodeElement);\n                });\n                graph.edges.forEach(edge => {\n                    const edgeElement = document.createElement('div');\n                    edgeElement.classList.add('edge');\n                    edgeElement.textContent = edge.description;\n                    graphElement.appendChild(edgeElement);\n                });\n            },\n            addNode: function(name) {\n                this.nodes.push({ name, color: 'black' });\n                this.updateGraph();\n            },\n            addEdge: function(description) {\n                this.edges.push({ description, color: 'black' });\n                this.updateGraph();\n            },\n            removeNode: function(node) {\n                this.nodes = this.nodes.filter(n => n !== node);\n                this.updateGraph();\n            },\n            removeEdge: function(edge) {\n                this.edges = this.edges.filter(e => e !== edge);\n                this.updateGraph();\n            },\n            selectNode: function(node) {\n                this.selectedNode = node;\n                this.updateGraph();\n            },\n            deselectNode: function() {\n                this.selectedNode = null;\n                this.updateGraph();\n            },\n            toggleNode: function(node) {\n                if (node.color === 'black') {\n                    node.color = 'white';\n                } else {\n                    node.color = 'black';\n                }\n                this.updateGraph();\n            },\n            toggleEdge: function(edge) {\n                if (edge.color === 'black') {\n                    edge.color = 'white';\n                } else {\n                    edge.color = 'black';\n                }\n                this.updateGraph();\n            }\n        };\n\n        const graphElement = document.getElementById('graph');\n        graphElement.style.position = 'relative';\n        graphElement.style.width = '800px';\n        graphElement.style.height = '600px';\n        graphElement.style.border = '1px solid black';\n        graphElement.style.padding = '10px';\n\n        const nodeInput = document.getElementById('node-input');\n        const edgeInput = document.getElementById('edge-input');\n        const nodeColorSelect = document.getElementById('node-color-select');\n        const edgeDescriptionInput = document.getElementById('edge-description-input');\n\n        nodeInput.oninput = function() {\n            graph.addNode(this.value);\n        };\n\n        edgeInput.oninput = function() {\n            graph.addEdge(this.value);\n        };\n\n        nodeColorSelect.onchange = function() {\n            graph.toggleNode(graph.nodes.find(node => node.name === this.value));\n        };\n\n        edgeDescriptionInput.oninput = function() {\n            graph.toggleEdge(this.value);\n        };\n\n        graphElement.addEventListener('click', function(event) {\n            if (event.target.classList.contains('node')) {\n                graph.selectNode(event.target);\n            } else if (event.target.classList.contains('edge')) {\n                graph.toggleEdge(event.target);\n            }\n        });\n\n        graph.nodes.forEach(function(node) {\n            const nodeElement = document.createElement('div');\n            nodeElement.classList.add('node');\n            nodeElement.textContent = node.name;\n            graphElement.appendChild(nodeElement);\n        });\n        graph.edges.forEach(function(edge) {\n            const edgeElement = document.createElement('div');\n            edgeElement.classList.add('edge');\n            edgeElement.textContent = edge.description;\n            graphElement.appendChild(edgeElement);\n        });\n    </script>\n</body>\n</html>"
