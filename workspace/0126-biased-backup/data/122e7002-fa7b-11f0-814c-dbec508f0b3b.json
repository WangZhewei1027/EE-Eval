    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Symmetric Cryptography</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        button, input, select {\n            padding: 10px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button {\n            background-color: #4CAF50;\n            color: #fff;\n        }\n        input, select {\n            width: 100%;\n            height: 20px;\n            margin-bottom: 10px;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n        select {\n            margin-bottom: 20px;\n        }\n        .progress-bar {\n            height: 20px;\n            background-color: #4CAF50;\n            margin-bottom: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Symmetric Cryptography</h1>\n    <p>Learn how to create symmetric encryption algorithms using Python.</p>\n    <button id=\"encrypt-btn\">Encrypt</button>\n    <button id=\"decrypt-btn\">Decrypt</button>\n    <button id=\"generate-btn\">Generate Key</button>\n    <button id=\"clear-btn\">Clear</button>\n    <div id=\"progress-bar\"></div>\n    <div id=\"output\"></div>\n\n    <script>\n        // Function to encrypt a message\n        function encrypt(message) {\n            const key = prompt(\"Enter your encryption key:\");\n            if (key === null) {\n                alert(\"Please enter a key.\");\n                return;\n            }\n\n            const encryptedMessage = message + key;\n            document.getElementById(\"output\").innerHTML = encryptedMessage;\n            document.getElementById(\"progress-bar\").style.width = 20 + \"%\";\n        }\n\n        // Function to decrypt a message\n        function decrypt(message) {\n            const key = prompt(\"Enter your decryption key:\");\n            if (key === null) {\n                alert(\"Please enter a key.\");\n                return;\n            }\n\n            const decryptedMessage = message + key;\n            document.getElementById(\"output\").innerHTML = decryptedMessage;\n            document.getElementById(\"progress-bar\").style.width = 40 + \"%\";\n        }\n\n        // Function to generate a key\n        function generateKey() {\n            const key = prompt(\"Enter your encryption key:\");\n            if (key === null) {\n                alert(\"Please enter a key.\");\n                return;\n            }\n\n            document.getElementById(\"progress-bar\").style.width = 20 + \"%\";\n            document.getElementById(\"output\").innerHTML = key;\n            document.getElementById(\"progress-bar\").style.width = 50 + \"%\";\n        }\n\n        // Function to clear the output\n        function clearOutput() {\n            document.getElementById(\"output\").innerHTML = \"\";\n            document.getElementById(\"progress-bar\").style.width = 0 + \"%\";\n        }\n\n        // Get the buttons and progress bar\n        const buttons = document.querySelectorAll(\"button\");\n        const progressBar = document.getElementById(\"progress-bar\");\n        const output = document.getElementById(\"output\");\n\n        // Add event listeners to the buttons\n        buttons.forEach(button => {\n            button.addEventListener(\"click\", () => {\n                if (button.id === \"encrypt-btn\") {\n                    encrypt();\n                } else if (button.id === \"decrypt-btn\") {\n                    decrypt();\n                } else if (button.id === \"generate-btn\") {\n                    generateKey();\n                } else if (button.id === \"clear-btn\") {\n                    clearOutput();\n                }\n            });\n        });\n\n        // Add event listener to the progress bar\n        progressBar.addEventListener(\"change\", () => {\n            if (progressBar.value >= 100) {\n                alert(\"Encryption and decryption completed successfully.\");\n            } else {\n                alert(\"Encryption and decryption in progress.\");\n            }\n        });\n    </script>\n</body>\n</html>"
