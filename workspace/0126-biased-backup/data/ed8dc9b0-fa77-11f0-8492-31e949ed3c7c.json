    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Depth-First Search Visualizer</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #f0f4f8, #a4c8e1);\n            color: #333;\n            margin: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        #container {\n            position: relative;\n            width: 80vw;\n            height: 80vh;\n            border: 2px solid #0d47a1;\n            border-radius: 10px;\n            box-shadow: 0 4px 20px rgba(0,0,0,0.2);\n            background-color: #fff;\n            overflow: hidden;\n        }\n        #title {\n            text-align: center;\n            font-size: 2.5rem;\n            margin: 20px 0;\n            color: #0d47a1;\n        }\n        .node {\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background: #ff5722;\n            color: #fff;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            position: absolute;\n            transition: background 0.5s ease;\n        }\n        .visited {\n            background: #4caf50 !important;\n            transition: background 0.5s ease;\n        }\n        button {\n            background-color: #0d47a1;\n            color: #fff;\n            border: none;\n            padding: 10px 20px;\n            border-radius: 5px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: background 0.3s ease;\n            position: relative;\n            margin: 20px auto;\n            display: block;\n        }\n        button:hover {\n            background-color: #1565c0;\n        }\n    </style>\n</head>\n<body>\n\n<div id=\"container\">\n    <div id=\"title\">Visualizing Depth-First Search (DFS)</div>\n    <div class=\"node\" style=\"top: 50px; left: 50px;\">A</div>\n    <div class=\"node\" style=\"top: 150px; left: 150px;\">B</div>\n    <div class=\"node\" style=\"top: 50px; left: 250px;\">C</div>\n    <div class=\"node\" style=\"top: 250px; left: 50px;\">D</div>\n    <div class=\"node\" style=\"top: 250px; left: 250px;\">E</div>\n    <div class=\"node\" style=\"top: 150px; left: 350px;\">F</div>\n    <button id=\"startButton\">Start DFS</button>\n</div>\n\n<script>\n    const nodes = document.querySelectorAll('.node');\n    const startButton = document.getElementById('startButton');\n    \n    const stack = [];\n    let index = 0;\n\n    startButton.addEventListener('click', () => {\n        if (index < nodes.length) {\n            stack.push(index);\n            dfs();\n        }\n    });\n\n    function dfs() {\n        if (stack.length === 0) return;\n\n        const currentIndex = stack.pop();\n        const currentNode = nodes[currentIndex];\n        \n        currentNode.classList.add('visited');\n\n        setTimeout(() => {\n            index++;\n            if (index < nodes.length) {\n                stack.push(index);\n                dfs();\n            }\n        }, 1000);\n    }\n</script>\n\n</body>\n</html>"
