    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Neural Network Demo</title>\n    <style>\n        body {\n            font-family: sans-serif;\n            margin: 20px;\n            font-size: 14px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interactive Neural Network Demo</h1>\n    <div>\n        <label for=\"num_layers\">Number of Layers:</label>\n        <input type=\"range\" id=\"num_layers\" min=\"1\" max=\"10\" value=\"3\" />\n        <span id=\"layer_count\">3</span>\n    </div>\n    <div>\n        <label for=\"neurons_per_layer\">Neurons per Layer:</label>\n        <input type=\"number\" id=\"neurons_per_layer\" min=\"1\" value=\"5\" />\n    </div>\n    <div>\n        <button id=\"create_network\">Create Network</button>\n    </div>\n    \n    <h2>Network Configuration:</h2>\n    <pre id=\"network_config\"></pre>\n\n    <h2>Training Data</h2>\n    <div>\n        <label for=\"input_data\">Input Data (comma-separated):</label>\n        <input type=\"text\" id=\"input_data\" placeholder=\"0.2, 0.8\" />\n    </div>\n    <div>\n        <button id=\"train_network\">Train Network</button>\n    </div>\n    \n    <h2>Output</h2>\n    <pre id=\"output_display\"></pre>\n\n    <h2>Test the Network</h2>\n    <div>\n        <label for=\"test_data\">Test Data (comma-separated):</label>\n        <input type=\"text\" id=\"test_data\" placeholder=\"0.1, 0.9\" />\n    </div>\n    <div>\n        <button id=\"run_network\">Run Network</button>\n    </div>\n\n    <script>\n        let numLayers = 3;\n        let neuronsPerLayer = 5;\n        let network = [];\n\n        document.getElementById('num_layers').addEventListener('input', function() {\n            numLayers = this.value;\n            document.getElementById('layer_count').textContent = numLayers;\n        });\n\n        document.getElementById('neurons_per_layer').addEventListener('input', function() {\n            neuronsPerLayer = this.value;\n        });\n\n        document.getElementById('create_network').addEventListener('click', function() {\n            network = [];\n            for (let i = 0; i < numLayers; i++) {\n                let layer = [];\n                for (let j = 0; j < neuronsPerLayer; j++) {\n                    layer.push(Math.random());\n                }\n                network.push(layer);\n            }\n            displayNetworkConfig();\n        });\n\n        function displayNetworkConfig() {\n            document.getElementById('network_config').textContent = JSON.stringify(network);\n        }\n\n        document.getElementById('train_network').addEventListener('click', function() {\n            let inputData = document.getElementById('input_data').value.split(',').map(Number);\n            if (inputData.length !== neuronsPerLayer) {\n                alert(\"Input data must match the number of neurons per layer!\");\n                return;\n            }\n            // Simulate training (skipping complex logic for demonstration)\n            for (let i = 0; i < network.length; i++) {\n                for (let j = 0; j < network[i].length; j++) {\n                    network[i][j] += inputData[i % inputData.length] * 0.1; // Random training logic\n                }\n            }\n            document.getElementById('output_display').textContent = \"Network trained!\";\n        });\n\n        document.getElementById('run_network').addEventListener('click', function() {\n            let testData = document.getElementById('test_data').value.split(',').map(Number);\n            if (testData.length !== neuronsPerLayer) {\n                alert(\"Test data must match the number of neurons per layer!\");\n                return;\n            }\n\n            let output = network.map(layer => {\n                return layer.map(weight => {\n                    return weight * testData[0]; // Simple output calculation\n                });\n            });\n\n            document.getElementById('output_display').textContent = JSON.stringify(output);\n        });\n    </script>\n</body>\n</html>"
