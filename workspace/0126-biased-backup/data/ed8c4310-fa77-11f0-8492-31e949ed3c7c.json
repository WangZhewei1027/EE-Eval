    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Array Showcase</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #6a11cb, #2575fc);\n            color: #ffffff;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        .container {\n            text-align: center;\n            animation: fadeIn 1s ease;\n            border-radius: 15px;\n            overflow: hidden;\n            box-shadow: 0 12px 36px rgba(0, 0, 0, 0.2);\n        }\n        h1 {\n            font-size: 2.5em;\n            margin-bottom: 0.5em;\n            text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.5);\n        }\n        p {\n            font-size: 1.2em;\n            margin: 0.5em 0 1.5em;\n            opacity: 0.85;\n        }\n        .dynamic-array {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            overflow: hidden;\n            border: 2px solid rgba(255, 255, 255, 0.7);\n            border-radius: 12px;\n            padding: 20px;\n            width: 80vw;\n            height: 200px;\n            position: relative;\n            background: rgba(255, 255, 255, 0.1);\n        }\n        .element {\n            width: 60px;\n            height: 60px;\n            margin: 0 10px;\n            background: #ff4081;\n            border-radius: 8px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 1.5em;\n            opacity: 0.9;\n            transition: transform 0.5s ease;\n        }\n        .element:hover {\n            transform: scale(1.1);\n        }\n        button {\n            background-color: #ffffff;\n            color: #6a11cb;\n            border: none;\n            border-radius: 8px;\n            font-size: 1em;\n            padding: 10px 20px;\n            margin-top: 1em;\n            cursor: pointer;\n            transition: background 0.3s ease, transform 0.3s ease;\n            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.2);\n        }\n        button:hover {\n            background-color: #ff4081;\n            transform: translateY(-2px);\n        }\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n                transform: translateY(-20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Dynamic Array Showcase</h1>\n        <p>Observe the dynamic behavior of elements as they shift and grow!</p>\n        <div class=\"dynamic-array\" id=\"dynamicArray\"></div>\n        <button id=\"addElementBtn\">Add Element</button>\n    </div>\n    <script>\n        const dynamicArray = document.getElementById('dynamicArray');\n        const addElementBtn = document.getElementById('addElementBtn');\n        let count = 0;\n\n        addElementBtn.addEventListener('click', () => {\n            if (count < 10) {\n                count++;\n                const newElement = document.createElement('div');\n                newElement.className = 'element';\n                newElement.textContent = count;\n                dynamicArray.appendChild(newElement);\n            }\n        });\n    </script>\n</body>\n</html>"
