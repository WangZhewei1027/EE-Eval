    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Array Visualizer</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        .header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        .header h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .header p {\n            font-size: 1.2rem;\n            color: var(--dark);\n            max-width: 600px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            width: 100%;\n            max-width: 900px;\n            margin: 0 auto;\n            position: relative;\n            perspective: 1000px;\n        }\n\n        .array-container {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 300px;\n            position: relative;\n            margin-bottom: 4rem;\n            transition: all 0.5s ease;\n        }\n\n        .array-cell {\n            width: 80px;\n            height: 80px;\n            background: white;\n            border-radius: 12px;\n            margin: 0 10px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 1.5rem;\n            font-weight: bold;\n            color: var(--dark);\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            position: relative;\n            transform-style: preserve-3d;\n            transform: translateY(0) rotateX(0);\n            animation: float 4s ease-in-out infinite;\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-15px); }\n        }\n\n        .array-cell::before {\n            content: '';\n            position: absolute;\n            top: -5px;\n            left: -5px;\n            right: -5px;\n            bottom: -5px;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            border-radius: 15px;\n            z-index: -1;\n            opacity: 0.7;\n            filter: blur(10px);\n            transition: all 0.3s ease;\n        }\n\n        .array-cell:hover::before {\n            opacity: 0.9;\n            filter: blur(15px);\n        }\n\n        .array-cell.empty {\n            background: rgba(255, 255, 255, 0.3);\n            color: transparent;\n            border: 2px dashed rgba(108, 92, 231, 0.3);\n        }\n\n        .array-index {\n            position: absolute;\n            bottom: -25px;\n            font-size: 0.9rem;\n            color: var(--dark);\n            opacity: 0.7;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 3rem;\n            gap: 1rem;\n        }\n\n        .btn {\n            padding: 12px 24px;\n            border: none;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            color: white;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);\n        }\n\n        .btn:active {\n            transform: translateY(1px);\n        }\n\n        .btn::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(to right, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0));\n            transform: translateX(-100%);\n            transition: transform 0.3s ease;\n        }\n\n        .btn:hover::after {\n            transform: translateX(0);\n        }\n\n        .resize-animation {\n            animation: resize 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;\n        }\n\n        @keyframes resize {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.2); }\n            100% { transform: scale(1); }\n        }\n\n        .explanation {\n            background: white;\n            border-radius: 20px;\n            padding: 2rem;\n            margin-top: 3rem;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);\n            max-width: 800px;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeInUp 1s ease-out 0.5s forwards;\n        }\n\n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.8rem;\n        }\n\n        .explanation p {\n            line-height: 1.8;\n            margin-bottom: 1.5rem;\n            color: #555;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(-20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes fadeInUp {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        .memory-blocks {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: center;\n            gap: 15px;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1s forwards;\n        }\n\n        .memory-block {\n            width: 60px;\n            height: 60px;\n            background: rgba(255, 255, 255, 0.8);\n            border-radius: 8px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-weight: bold;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            transition: all 0.3s ease;\n            position: relative;\n        }\n\n        .memory-block.allocated {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: white;\n        }\n\n        .memory-block.highlight {\n            animation: pulse 1.5s infinite;\n        }\n\n        @keyframes pulse {\n            0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(108, 92, 231, 0.4); }\n            50% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(108, 92, 231, 0); }\n        }\n\n        .footer {\n            margin-top: 4rem;\n            text-align: center;\n            color: #777;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Dynamic Array</h1>\n        <p>A visual representation of how dynamic arrays work, with automatic resizing when capacity is reached.</p>\n    </div>\n\n    <div class=\"visualization\">\n        <div class=\"array-container\" id=\"arrayContainer\">\n            <!-- Array cells will be added here by JavaScript -->\n        </div>\n\n        <div class=\"controls\">\n            <button class=\"btn\" id=\"addBtn\">Add Element</button>\n            <button class=\"btn\" id=\"resetBtn\">Reset Array</button>\n        </div>\n\n        <div class=\"memory-blocks\" id=\"memoryBlocks\">\n            <!-- Memory blocks will be added here -->\n        </div>\n    </div>\n\n    <div class=\"explanation\">\n        <h2>How Dynamic Arrays Work</h2>\n        <p>A dynamic array is a random access, variable-size list data structure that allows elements to be added or removed. When the array's capacity is reached, it automatically allocates a larger memory space and copies all elements to the new space.</p>\n        <p>This visualization shows how the array grows dynamically. Each time you add an element beyond the current capacity, the array doubles in size to accommodate more elements efficiently.</p>\n    </div>\n\n    <div class=\"footer\">\n        <p>© 2023 Dynamic Array Visualizer | Beautiful Computer Science Concepts</p>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const arrayContainer = document.getElementById('arrayContainer');\n            const memoryBlocks = document.getElementById('memoryBlocks');\n            const addBtn = document.getElementById('addBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            let array = [];\n            let capacity = 4;\n            let size = 0;\n            let isResizing = false;\n\n            // Initialize the array visualization\n            function initArray() {\n                arrayContainer.innerHTML = '';\n                for (let i = 0; i < capacity; i++) {\n                    const cell = document.createElement('div');\n                    cell.className = 'array-cell empty';\n                    cell.innerHTML = `<span class=\"array-index\">${i}</span>`;\n                    arrayContainer.appendChild(cell);\n                }\n            }\n\n            // Initialize memory blocks visualization\n            function initMemory() {\n                memoryBlocks.innerHTML = '';\n                for (let i = 0; i < 16; i++) {\n                    const block = document.createElement('div');\n                    block.className = 'memory-block';\n                    block.textContent = i < capacity ? '✔' : '✖';\n                    if (i < capacity) block.classList.add('allocated');\n                    memoryBlocks.appendChild(block);\n                }\n            }\n\n            // Add element to the array\n            function addElement() {\n                if (isResizing) return;\n                \n                if (size >= capacity) {\n                    resizeArray();\n                    return;\n                }\n\n                const value = Math.floor(Math.random() * 100) + 1;\n                array.push(value);\n                size++;\n                \n                updateArrayDisplay();\n                \n                // Highlight the added element\n                const cells = document.querySelectorAll('.array-cell');\n                cells[size - 1].classList.add('resize-animation');\n                cells[size - 1].textContent = value;\n                cells[size - 1].classList.remove('empty');\n                \n                setTimeout(() => {\n                    cells[size - 1].classList.remove('resize-animation');\n                }, 800);\n            }\n\n            // Resize the array (double the capacity)\n            function resizeArray() {\n                isResizing = true;\n                \n                // Show current array fading out\n                const cells = document.querySelectorAll('.array-cell');\n                cells.forEach(cell => {\n                    cell.style.opacity = '0.3';\n                    cell.style.transform = 'scale(0.9)';\n                });\n                \n                // Double the capacity\n                capacity *= 2;\n                \n                // Update memory visualization\n                setTimeout(() => {\n                    initMemory();\n                    highlightNewMemory();\n                }, 500);\n                \n                // Create new array visualization\n                setTimeout(() => {\n                    initArray();\n                    updateArrayDisplay();\n                    \n                    // Animate new cells\n                    const newCells = document.querySelectorAll('.array-cell');\n                    newCells.forEach((cell, i) => {\n                        cell.style.opacity = '0';\n                        cell.style.transform = 'translateY(50px)';\n                        \n                        setTimeout(() => {\n                            cell.style.opacity = '1';\n                            cell.style.transform = 'translateY(0)';\n                            if (i < size) {\n                                cell.textContent = array[i];\n                                cell.classList.remove('empty');\n                            }\n                        }, i * 100);\n                    });\n                    \n                    isResizing = false;\n                }, 1000);\n            }\n\n            // Highlight newly allocated memory blocks\n            function highlightNewMemory() {\n                const blocks = document.querySelectorAll('.memory-block');\n                for (let i = capacity / 2; i < capacity && i < blocks.length; i++) {\n                    blocks[i].classList.add('highlight');\n                    setTimeout(() => {\n                        blocks[i].classList.remove('highlight');\n                    }, 2000);\n                }\n            }\n\n            // Update array display with current values\n            function updateArrayDisplay() {\n                const cells = document.querySelectorAll('.array-cell');\n                cells.forEach((cell, i) => {\n                    if (i < size) {\n                        cell.textContent = array[i];\n                        cell.classList.remove('empty');\n                    } else {\n                        cell.textContent = '';\n                        cell.classList.add('empty');\n                    }\n                });\n            }\n\n            // Reset the array\n            function resetArray() {\n                array = [];\n                size = 0;\n                capacity = 4;\n                initArray();\n                initMemory();\n            }\n\n            // Event listeners\n            addBtn.addEventListener('click', addElement);\n            resetBtn.addEventListener('click', resetArray);\n\n            // Initialize\n            initArray();\n            initMemory();\n        });\n    </script>\n</body>\n</html>"
