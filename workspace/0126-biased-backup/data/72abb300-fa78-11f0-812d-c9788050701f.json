    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Visual Mutex Demonstration</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n            --danger: #d63031;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n        \n        .container {\n            width: 90%;\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            text-align: center;\n        }\n        \n        h1 {\n            font-size: 3rem;\n            margin-bottom: 1.5rem;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-shadow: 0 2px 10px rgba(108, 92, 231, 0.1);\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            margin-bottom: 3rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 700px;\n            margin-left: auto;\n            margin-right: auto;\n            line-height: 1.6;\n        }\n        \n        .mutex-visualization {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin: 3rem 0;\n            position: relative;\n            height: 500px;\n        }\n        \n        .mutex-container {\n            width: 100px;\n            height: 100px;\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            border-radius: 12px;\n            box-shadow: 0 10px 30px rgba(108, 92, 231, 0.3);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            position: relative;\n            z-index: 2;\n            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n        \n        .mutex-lock {\n            font-size: 2rem;\n            color: white;\n            transition: transform 0.3s ease;\n        }\n        \n        .threads-container {\n            display: flex;\n            justify-content: space-between;\n            width: 100%;\n            position: absolute;\n            top: 50%;\n            transform: translateY(-50%);\n            z-index: 1;\n        }\n        \n        .thread {\n            width: 120px;\n            height: 80px;\n            background: white;\n            border-radius: 8px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);\n            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            position: relative;\n            opacity: 0.9;\n        }\n        \n        .thread-1 {\n            transform: translateX(-150px);\n            background: linear-gradient(135deg, #74b9ff, #0984e3);\n        }\n        \n        .thread-2 {\n            transform: translateX(150px);\n            background: linear-gradient(135deg, #55efc4, #00b894);\n        }\n        \n        .thread-label {\n            position: absolute;\n            top: -30px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-weight: 600;\n            color: var(--dark);\n        }\n        \n        .thread-icon {\n            font-size: 1.5rem;\n            color: white;\n        }\n        \n        .access-line {\n            position: absolute;\n            height: 4px;\n            background: var(--accent);\n            width: 0;\n            top: 50%;\n            left: 50%;\n            transform-origin: left center;\n            z-index: 1;\n            transition: width 0.4s ease;\n        }\n        \n        .instructions {\n            max-width: 600px;\n            margin: 2rem auto;\n            padding: 1.5rem;\n            background: white;\n            border-radius: 12px;\n            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n        \n        button {\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);\n            transition: all 0.3s ease;\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .explanation {\n            margin-top: 3rem;\n            background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.7));\n            backdrop-filter: blur(10px);\n            padding: 2rem;\n            border-radius: 16px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            max-width: 800px;\n            margin-left: auto;\n            margin-right: auto;\n        }\n        \n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n        }\n        \n        .explanation p {\n            line-height: 1.8;\n            margin-bottom: 1.5rem;\n        }\n        \n        .status {\n            position: absolute;\n            top: -20px;\n            left: 50%;\n            transform: translateX(-50%);\n            background: white;\n            padding: 0.5rem 1rem;\n            border-radius: 50px;\n            font-weight: 600;\n            box-shadow: 0 3px 15px rgba(0, 0, 0, 0.1);\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n        \n        .active {\n            opacity: 1;\n        }\n        \n        .pulse {\n            animation: pulse 1.5s infinite;\n        }\n        \n        @keyframes pulse {\n            0% {\n                box-shadow: 0 0 0 0 rgba(108, 92, 231, 0.4);\n            }\n            70% {\n                box-shadow: 0 0 0 15px rgba(108, 92, 231, 0);\n            }\n            100% {\n                box-shadow: 0 0 0 0 rgba(108, 92, 231, 0);\n            }\n        }\n        \n        .floating {\n            animation: floating 3s ease-in-out infinite;\n        }\n        \n        @keyframes floating {\n            0% {\n                transform: translateY(0px);\n            }\n            50% {\n                transform: translateY(-15px);\n            }\n            100% {\n                transform: translateY(0px);\n            }\n        }\n        \n        .highlight {\n            color: var(--primary);\n            font-weight: 600;\n        }\n        \n        footer {\n            margin-top: 3rem;\n            padding: 1rem;\n            text-align: center;\n            color: var(--dark);\n            opacity: 0.7;\n            font-size: 0.9rem;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Mutex Visualization</h1>\n        <p class=\"subtitle\">A visual demonstration of mutual exclusion in concurrent programming, ensuring only one thread accesses a shared resource at a time.</p>\n        \n        <div class=\"mutex-visualization\">\n            <div class=\"status\" id=\"status\">Mutex: Unlocked</div>\n            <div class=\"mutex-container\" id=\"mutex\">\n                <div class=\"mutex-lock\" id=\"lock\">🔓</div>\n            </div>\n            \n            <div class=\"threads-container\">\n                <div class=\"thread thread-1 floating\" id=\"thread1\">\n                    <span class=\"thread-label\">Thread A</span>\n                    <div class=\"thread-icon\">🔄</div>\n                </div>\n                <div class=\"thread thread-2 floating\" id=\"thread2\">\n                    <span class=\"thread-label\">Thread B</span>\n                    <div class=\"thread-icon\">🔄</div>\n                </div>\n            </div>\n            \n            <div class=\"access-line\" id=\"line1\"></div>\n            <div class=\"access-line\" id=\"line2\"></div>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"startBtn\">Start Simulation</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n        \n        <div class=\"instructions\">\n            <p>Click \"Start Simulation\" to visualize how a mutex controls access to a shared resource. Threads will attempt to access the resource, but only one can hold the mutex at a time.</p>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>Understanding Mutex</h2>\n            <p>A <span class=\"highlight\">mutex (mutual exclusion)</span> is a synchronization primitive that prevents simultaneous access to a shared resource by multiple threads. It creates a critical section of code that can only be executed by one thread at a time.</p>\n            \n            <p>When a thread wants to access the shared resource, it must first <span class=\"highlight\">acquire the mutex</span>. If another thread already holds the mutex, the requesting thread will be blocked until the mutex becomes available.</p>\n            \n            <p>This visualization shows two threads competing for access to a shared resource (represented by the central box). The mutex (lock icon) ensures orderly access, preventing race conditions and maintaining data integrity.</p>\n        </div>\n    </div>\n    \n    <footer>\n        Visual Mutex Demonstration | Concept by Concurrent Programming | Designed for Aesthetic Education\n    </footer>\n    \n    <script>\n        const mutex = document.getElementById('mutex');\n        const lock = document.getElementById('lock');\n        const thread1 = document.getElementById('thread1');\n        const thread2 = document.getElementById('thread2');\n        const line1 = document.getElementById('line1');\n        const line2 = document.getElementById('line2');\n        const status = document.getElementById('status');\n        const startBtn = document.getElementById('startBtn');\n        const resetBtn = document.getElementById('resetBtn');\n        \n        let isSimulating = false;\n        let isLocked = false;\n        \n        // Animation timeline\n        const timeline = [\n            { action: 'thread1Request', delay: 1000 },\n            { action: 'thread1Access', delay: 2000 },\n            { action: 'thread1Release', delay: 4000 },\n            { action: 'thread2Request', delay: 5000 },\n            { action: 'thread2Access', delay: 6000 },\n            { action: 'thread2Release', delay: 8000 }\n        ];\n        \n        let currentStep = 0;\n        let timeoutId = null;\n        \n        function resetSimulation() {\n            isSimulating = false;\n            isLocked = false;\n            currentStep = 0;\n            \n            clearTimeout(timeoutId);\n            \n            // Reset visual elements\n            mutex.style.transform = 'scale(1)';\n            mutex.classList.remove('pulse');\n            lock.textContent = '🔓';\n            \n            thread1.style.transform = 'translateX(-150px)';\n            thread2.style.transform = 'translateX(150px)';\n            thread1.querySelector('.thread-icon').textContent = '🔄';\n            thread2.querySelector('.thread-icon').textContent = '🔄';\n            \n            line1.style.width = '0';\n            line2.style.width = '0';\n            \n            status.textContent = 'Mutex: Unlocked';\n            status.classList.remove('active');\n            \n            startBtn.disabled = false;\n        }\n        \n        function animateStep(step) {\n            if (!isSimulating) return;\n            \n            const { action, delay } = timeline[step];\n            \n            switch(action) {\n                case 'thread1Request':\n                    status.textContent = 'Mutex: Thread A Requesting...';\n                    status.classList.add('active');\n                    thread1.querySelector('.thread-icon').textContent = '🔒';\n                    thread1.style.transform = 'translateX(-70px)';\n                    line1.style.width = '80px';\n                    line1.style.transform = 'rotate(180deg)';\n                    break;\n                    \n                case 'thread1Access':\n                    isLocked = true;\n                    mutex.classList.add('pulse');\n                    mutex.style.transform = 'scale(1.1)';\n                    lock.textContent = '🔒';\n                    thread1.style.transform = 'translateX(-30px)';\n                    line1.style.width = '40px';\n                    status.textContent = 'Mutex: Locked by Thread A';\n                    break;\n                    \n                case 'thread1Release':\n                    isLocked = false;\n                    mutex.classList.remove('pulse');\n                    mutex.style.transform = 'scale(1)';\n                    lock.textContent = '🔓';\n                    thread1.style.transform = 'translateX(-150px)';\n                    line1.style.width = '0';\n                    thread1.querySelector('.thread-icon').textContent = '🔄';\n                    status.textContent = 'Mutex: Unlocked';\n                    break;\n                    \n                case 'thread2Request':\n                    status.textContent = 'Mutex: Thread B Requesting...';\n                    thread2.querySelector('.thread-icon').textContent = '🔒';\n                    thread2.style.transform = 'translateX(70px)';\n                    line2.style.width = '80px';\n                    break;\n                    \n                case 'thread2Access':\n                    isLocked = true;\n                    mutex.classList.add('pulse');\n                    mutex.style.transform = 'scale(1.1)';\n                    lock.textContent = '🔒';\n                    thread2.style.transform = 'translateX(30px)';\n                    line2.style.width = '40px';\n                    status.textContent = 'Mutex: Locked by Thread B';\n                    break;\n                    \n                case 'thread2Release':\n                    isLocked = false;\n                    mutex.classList.remove('pulse');\n                    mutex.style.transform = 'scale(1)';\n                    lock.textContent = '🔓';\n                    thread2.style.transform = 'translateX(150px)';\n                    line2.style.width = '0';\n                    thread2.querySelector('.thread-icon').textContent = '🔄';\n                    status.textContent = 'Mutex: Unlocked';\n                    status.classList.remove('active');\n                    isSimulating = false;\n                    startBtn.disabled = false;\n                    return;\n            }\n            \n            currentStep++;\n            if (currentStep < timeline.length) {\n                timeoutId = setTimeout(() => animateStep(currentStep), delay);\n            }\n        }\n        \n        startBtn.addEventListener('click', () => {\n            if (isSimulating) return;\n            \n            isSimulating = true;\n            startBtn.disabled = true;\n            animateStep(currentStep);\n        });\n        \n        resetBtn.addEventListener('click', resetSimulation);\n        \n        // Initial setup\n        resetSimulation();\n    </script>\n</body>\n</html>"
