    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Relational Database Visualization</title>\n    <style>\n        :root {\n            --primary: #3a86ff;\n            --secondary: #8338ec;\n            --accent: #ff006e;\n            --light: #f8f9fa;\n            --dark: #212529;\n            --success: #06d6a0;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #f0f2f5 100%);\n            min-height: 100vh;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n            z-index: 10;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 800;\n            margin-bottom: 1rem;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: -0.5px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: #6c757d;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .visualization {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 3rem;\n            position: relative;\n        }\n\n        .database {\n            width: 100%;\n            max-width: 900px;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.1);\n            transform-style: preserve-3d;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .database::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(45deg, rgba(58, 134, 255, 0.05) 0%, rgba(131, 56, 236, 0.05) 100%);\n            z-index: -1;\n        }\n\n        .db-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 1.5rem;\n            padding-bottom: 1rem;\n            border-bottom: 1px solid rgba(0, 0, 0, 0.1);\n        }\n\n        .db-title {\n            font-size: 1.5rem;\n            font-weight: 700;\n            color: var(--primary);\n        }\n\n        .table {\n            margin-bottom: 2rem;\n            overflow: hidden;\n            border-radius: 8px;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s ease;\n        }\n\n        .table:hover {\n            transform: translateY(-5px);\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);\n        }\n\n        .table-header {\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            color: white;\n            padding: 1rem;\n            font-weight: 600;\n            display: flex;\n            align-items: center;\n        }\n\n        .table-header span {\n            margin-right: 1rem;\n            font-size: 1.2rem;\n        }\n\n        .table-content {\n            background: white;\n        }\n\n        .row {\n            display: grid;\n            grid-template-columns: 1fr 1fr 1fr 1fr;\n            padding: 1rem;\n            border-bottom: 1px solid #eee;\n        }\n\n        .row.header {\n            font-weight: 600;\n            background: rgba(0, 0, 0, 0.02);\n        }\n\n        .row:last-child {\n            border-bottom: none;\n        }\n\n        .cell {\n            padding: 0.5rem;\n        }\n\n        .primary-key {\n            font-weight: 700;\n            color: var(--primary);\n        }\n\n        .foreign-key {\n            color: var(--secondary);\n            font-weight: 600;\n        }\n\n        .relations {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            z-index: 1;\n        }\n\n        .relation-line {\n            position: absolute;\n            background: linear-gradient(90deg, var(--accent), var(--secondary));\n            height: 4px;\n            transform-origin: left center;\n            z-index: 2;\n            border-radius: 2px;\n            opacity: 0;\n            transition: all 0.5s ease;\n        }\n\n        .relation-line.active {\n            opacity: 0.7;\n        }\n\n        .relation-dot {\n            position: absolute;\n            width: 12px;\n            height: 12px;\n            background: var(--accent);\n            border-radius: 50%;\n            z-index: 3;\n            transform: scale(0);\n            transition: all 0.3s ease;\n        }\n\n        .relation-dot.active {\n            transform: scale(1);\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        .btn {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            color: white;\n            box-shadow: 0 5px 15px rgba(58, 134, 255, 0.3);\n        }\n\n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 25px rgba(58, 134, 255, 0.4);\n        }\n\n        .btn:active {\n            transform: translateY(0);\n        }\n\n        .highlight {\n            position: relative;\n            z-index: 1;\n        }\n\n        .highlight::after {\n            content: '';\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 8px;\n            background: rgba(255, 0, 110, 0.2);\n            z-index: -1;\n            transform: scaleX(0);\n            transform-origin: left;\n            transition: transform 0.3s ease;\n        }\n\n        .highlight.active::after {\n            transform: scaleX(1);\n        }\n\n        @keyframes float {\n            0%, 100% {\n                transform: translateY(0);\n            }\n            50% {\n                transform: translateY(-10px);\n            }\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 5rem;\n            color: #6c757d;\n            font-size: 0.9rem;\n        }\n\n        .floating-shapes {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            top: 0;\n            left: 0;\n            pointer-events: none;\n            z-index: -1;\n            overflow: hidden;\n        }\n\n        .shape {\n            position: absolute;\n            border-radius: 50%;\n            opacity: 0.1;\n        }\n\n        .shape-1 {\n            width: 300px;\n            height: 300px;\n            background: var(--primary);\n            top: -100px;\n            right: -100px;\n            animation: float 8s ease-in-out infinite;\n        }\n\n        .shape-2 {\n            width: 200px;\n            height: 200px;\n            background: var(--secondary);\n            bottom: -50px;\n            left: -50px;\n            animation: float 10s ease-in-out infinite 2s;\n        }\n\n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .row {\n                grid-template-columns: 1fr 1fr;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"floating-shapes\">\n        <div class=\"shape shape-1\"></div>\n        <div class=\"shape shape-2\"></div>\n    </div>\n\n    <div class=\"container\">\n        <header>\n            <h1>Relational Database Visualization</h1>\n            <p class=\"subtitle\">Explore the elegant structure of relational databases through this visually engaging demonstration of tables, keys, and relationships.</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"database\">\n                <div class=\"relations\" id=\"relations\"></div>\n                \n                <div class=\"db-header\">\n                    <div class=\"db-title\">E-Commerce Database</div>\n                </div>\n\n                <div class=\"table\" id=\"customers\">\n                    <div class=\"table-header\">\n                        <span>📋</span> Customers Table\n                    </div>\n                    <div class=\"table-content\">\n                        <div class=\"row header\">\n                            <div class=\"cell\">customer_id</div>\n                            <div class=\"cell\">name</div>\n                            <div class=\"cell\">email</div>\n                            <div class=\"cell\">join_date</div>\n                        </div>\n                        <div class=\"row\">\n                            <div class=\"cell primary-key\">1001</div>\n                            <div class=\"cell\">Alice Johnson</div>\n                            <div class=\"cell\">alice@example.com</div>\n                            <div class=\"cell\">2023-01-15</div>\n                        </div>\n                        <div class=\"row\">\n                            <div class=\"cell primary-key\">1002</div>\n                            <div class=\"cell\">Bob Smith</div>\n                            <div class=\"cell\">bob@example.com</div>\n                            <div class=\"cell\">2023-02-20</div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"table\" id=\"products\">\n                    <div class=\"table-header\">\n                        <span>📦</span> Products Table\n                    </div>\n                    <div class=\"table-content\">\n                        <div class=\"row header\">\n                            <div class=\"cell\">product_id</div>\n                            <div class=\"cell\">name</div>\n                            <div class=\"cell\">price</div>\n                            <div class=\"cell\">category</div>\n                        </div>\n                        <div class=\"row\">\n                            <div class=\"cell primary-key\">2001</div>\n                            <div class=\"cell\">Wireless Headphones</div>\n                            <div class=\"cell\">$129.99</div>\n                            <div class=\"cell\">Electronics</div>\n                        </div>\n                        <div class=\"row\">\n                            <div class=\"cell primary-key\">2002</div>\n                            <div class=\"cell\">Smart Watch</div>\n                            <div class=\"cell\">$249.99</div>\n                            <div class=\"cell\">Electronics</div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"table\" id=\"orders\">\n                    <div class=\"table-header\">\n                        <span>🛒</span> Orders Table\n                    </div>\n                    <div class=\"table-content\">\n                        <div class=\"row header\">\n                            <div class=\"cell\">order_id</div>\n                            <div class=\"cell\">customer_id</div>\n                            <div class=\"cell\">product_id</div>\n                            <div class=\"cell\">order_date</div>\n                        </div>\n                        <div class=\"row\">\n                            <div class=\"cell primary-key\">3001</div>\n                            <div class=\"cell foreign-key\">1001</div>\n                            <div class=\"cell foreign-key\">2001</div>\n                            <div class=\"cell\">2023-03-05</div>\n                        </div>\n                        <div class=\"row\">\n                            <div class=\"cell primary-key\">3002</div>\n                            <div class=\"cell foreign-key\">1002</div>\n                            <div class=\"cell foreign-key\">2002</div>\n                            <div class=\"cell\">2023-03-10</div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"controls\">\n                <button class=\"btn\" id=\"showRelations\">Show Relationships</button>\n            </div>\n        </div>\n    </div>\n\n    <footer>\n        <p>Relational Database Visualization | Designed for aesthetic demonstration</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const showRelationsBtn = document.getElementById('showRelations');\n            const relationsContainer = document.getElementById('relations');\n            let relationsVisible = false;\n\n            // Define the relationships between tables\n            const relationships = [\n                {\n                    from: 'orders',\n                    fromField: 'customer_id',\n                    to: 'customers',\n                    toField: 'customer_id'\n                },\n                {\n                    from: 'orders',\n                    fromField: 'product_id',\n                    to: 'products',\n                    toField: 'product_id'\n                }\n            ];\n\n            // Create relationship lines and dots\n            function createRelationships() {\n                relationships.forEach(rel => {\n                    const fromTable = document.getElementById(rel.from);\n                    const toTable = document.getElementById(rel.to);\n                    \n                    // Find the from cell\n                    const fromRows = fromTable.querySelectorAll('.row:not(.header)');\n                    const fromHeader = fromTable.querySelector('.row.header');\n                    const fromHeaderCells = fromHeader.querySelectorAll('.cell');\n                    let fromFieldIndex = -1;\n                    \n                    fromHeaderCells.forEach((cell, index) => {\n                        if (cell.textContent === rel.fromField) {\n                            fromFieldIndex = index;\n                        }\n                    });\n                    \n                    // Find the to cell\n                    const toRows = toTable.querySelectorAll('.row:not(.header)');\n                    const toHeader = toTable.querySelector('.row.header');\n                    const toHeaderCells = toHeader.querySelectorAll('.cell');\n                    let toFieldIndex = -1;\n                    \n                    toHeaderCells.forEach((cell, index) => {\n                        if (cell.textContent === rel.toField) {\n                            toFieldIndex = index;\n                        }\n                    });\n                    \n                    if (fromFieldIndex !== -1 && toFieldIndex !== -1) {\n                        fromRows.forEach((fromRow, rowIndex) => {\n                            const fromCells = fromRow.querySelectorAll('.cell');\n                            const fromFieldCell = fromCells[fromFieldIndex];\n                            \n                            // Find corresponding toRow (assuming same order for demo)\n                            const toRow = toRows[rowIndex];\n                            const toCells = toRow.querySelectorAll('.cell');\n                            const toFieldCell = toCells[toFieldIndex];\n                            \n                            if (fromFieldCell && toFieldCell) {\n                                // Create line\n                                const line = document.createElement('div');\n                                line.className = 'relation-line';\n                                \n                                // Create start dot\n                                const startDot = document.createElement('div');\n                                startDot.className = 'relation-dot';\n                                \n                                // Create end dot\n                                const endDot = document.createElement('div');\n                                endDot.className = 'relation-dot';\n                                \n                                // Position elements\n                                updateRelationPosition(line, startDot, endDot, fromFieldCell, toFieldCell);\n                                \n                                // Add to container\n                                relationsContainer.appendChild(line);\n                                relationsContainer.appendChild(startDot);\n                                relationsContainer.appendChild(endDot);\n                                \n                                // Highlight related cells\n                                fromFieldCell.classList.add('highlight');\n                                toFieldCell.classList.add('highlight');\n                                \n                                // Update position on resize\n                                window.addEventListener('resize', () => {\n                                    updateRelationPosition(line, startDot, endDot, fromFieldCell, toFieldCell);\n                                });\n                            }\n                        });\n                    }\n                });\n            }\n            \n            function updateRelationPosition(line, startDot, endDot, fromCell, toCell) {\n                const fromRect = fromCell.getBoundingClientRect();\n                const toRect = toCell.getBoundingClientRect();\n                const dbRect = document.querySelector('.database').getBoundingClientRect();\n                \n                const startX = fromRect.right - dbRect.left;\n                const startY = fromRect.top + fromRect.height / 2 - dbRect.top;\n                const endX = toRect.left - dbRect.left;\n                const endY = toRect.top + toRect.height / 2 - dbRect.top;\n                \n                const length = Math.sqrt(Math.pow(endX - startX, 2) + Math.pow(endY - startY, 2));\n                const angle = Math.atan2(endY - startY, endX - startX) * 180 / Math.PI;\n                \n                line.style.width = `${length}px`;\n                line.style.left = `${startX}px`;\n                line.style.top = `${startY}px`;\n                line.style.transform = `rotate(${angle}deg)`;\n                \n                startDot.style.left = `${startX - 6}px`;\n                startDot.style.top = `${startY - 6}px`;\n                \n                endDot.style.left = `${endX - 6}px`;\n                endDot.style.top = `${endY - 6}px`;\n            }\n            \n            // Toggle relationships visibility\n            showRelationsBtn.addEventListener('click', function() {\n                relationsVisible = !relationsVisible;\n                \n                const lines = document.querySelectorAll('.relation-line');\n                const dots = document.querySelectorAll('.relation-dot');\n                const highlights = document.querySelectorAll('.highlight');\n                \n                lines.forEach(line => {\n                    line.classList.toggle('active', relationsVisible);\n                });\n                \n                dots.forEach(dot => {\n                    dot.classList.toggle('active', relationsVisible);\n                });\n                \n                highlights.forEach(highlight => {\n                    highlight.classList.toggle('active', relationsVisible);\n                });\n                \n                showRelationsBtn.textContent = relationsVisible ? 'Hide Relationships' : 'Show Relationships';\n                \n                // Animate the database container\n                const database = document.querySelector('.database');\n                database.style.transform = relationsVisible ? 'perspective(1000px) rotateX(5deg) rotateY(5deg)' : 'none';\n            });\n            \n            // Initialize relationships (create elements but keep hidden)\n            createRelationships();\n            \n            // Add subtle hover effect to tables\n            const tables = document.querySelectorAll('.table');\n            tables.forEach(table => {\n                table.addEventListener('mouseenter', () => {\n                    if (!relationsVisible) return;\n                    \n                    const tableId = table.id;\n                    const relatedLines = document.querySelectorAll('.relation-line');\n                    \n                    // Check if this table is involved in any relationships\n                    const isRelated = relationships.some(rel => rel.from === tableId || rel.to === tableId);\n                    \n                    if (isRelated) {\n                        table.style.transform = 'translateY(-10px) scale(1.02)';\n                        table.style.zIndex = '10';\n                    }\n                });\n                \n                table.addEventListener('mouseleave', () => {\n                    table.style.transform = '';\n                    table.style.zIndex = '';\n                });\n            });\n        });\n    </script>\n</body>\n</html>"
  },
