    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Breadth-First Search — Visual Elegance</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1:#0f1724;\n    --bg-2:#071129;\n    --glass: rgba(255,255,255,0.06);\n    --accent-1:#7ee7c6;\n    --accent-2:#6bb7ff;\n    --accent-3:#ffd166;\n    --muted: rgba(255,255,255,0.55);\n    --pulse: rgba(123, 201, 255, 0.12);\n    --node-bg: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    --glass-border: rgba(255,255,255,0.06);\n  }\n\n  * { box-sizing: border-box; }\n  html,body { height:100%; margin:0; font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; background: radial-gradient(1200px 600px at 10% 10%, rgba(120,85,255,0.06), transparent), radial-gradient(900px 500px at 90% 85%, rgba(106,211,255,0.03), transparent), linear-gradient(180deg, var(--bg-1), var(--bg-2)); color: #e6eef8; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }\n  .wrap {\n    min-height:100vh;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    gap:28px;\n    position:relative;\n  }\n\n  /* Background decorative orbs */\n  .orb {\n    position:absolute;\n    filter: blur(36px);\n    transform: translate3d(0,0,0);\n    mix-blend-mode: screen;\n    opacity:0.8;\n    pointer-events:none;\n  }\n  .orb.one { width:420px; height:420px; left:6%; top:6%; background: radial-gradient(circle at 30% 20%, rgba(123,201,255,0.18), transparent 30%), linear-gradient(135deg, rgba(123,201,255,0.06), rgba(123,201,255,0.02)); }\n  .orb.two { width:520px; height:520px; right:6%; bottom:2%; background: radial-gradient(circle at 70% 70%, rgba(255,200,102,0.12), transparent 35%), linear-gradient(135deg, rgba(255,200,102,0.03), transparent); }\n\n  /* Main card */\n  .card {\n    width:1150px;\n    max-width:calc(100% - 96px);\n    height:680px;\n    border-radius:20px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: 0 12px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border: 1px solid var(--glass-border);\n    display:flex;\n    overflow:hidden;\n    position:relative;\n    backdrop-filter: blur(8px) saturate(1.05);\n  }\n\n  /* Left visual stage */\n  .stage {\n    flex:1.25;\n    position:relative;\n    padding:40px;\n    display:flex;\n    align-items:stretch;\n    justify-content:center;\n    overflow:hidden;\n  }\n\n  /* Right info panel */\n  .panel {\n    width:400px;\n    min-width:320px;\n    padding:34px;\n    border-left:1px solid rgba(255,255,255,0.03);\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    align-items:stretch;\n    justify-content:flex-start;\n  }\n\n  .title {\n    font-weight:700;\n    font-size:22px;\n    letter-spacing: -0.2px;\n    color: #f0fbff;\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .subtitle {\n    color:var(--muted);\n    font-size:13px;\n    margin-top:2px;\n  }\n\n  /* Buttons */\n  .controls { margin-top:12px; display:flex; gap:12px; }\n  .btn {\n    appearance:none;\n    border:0;\n    padding:10px 14px;\n    border-radius:12px;\n    font-weight:700;\n    cursor:pointer;\n    color:#04243a;\n    background:linear-gradient(180deg,var(--accent-1), #43c7a8);\n    box-shadow: 0 6px 18px rgba(34,128,104,0.18), inset 0 1px 0 rgba(255,255,255,0.18);\n    transition:transform .18s ease, box-shadow .18s ease, opacity .18s ease;\n    display:inline-flex;\n    align-items:center;\n    gap:8px;\n  }\n  .btn.secondary {\n    background:transparent;\n    color:var(--muted);\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow:none;\n    font-weight:600;\n  }\n  .btn:active { transform:translateY(1px); }\n  .btn[disabled] { opacity:0.6; cursor:not-allowed; transform:none; }\n\n  /* Stage content */\n  .graph-wrap {\n    width:860px;\n    height:560px;\n    border-radius:18px;\n    background: linear-gradient(180deg, rgba(7,19,33,0.45), rgba(10,22,34,0.35));\n    box-shadow: 0 10px 40px rgba(2,4,12,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    position:relative;\n    padding:12px;\n    overflow:visible;\n  }\n\n  /* subtle grid */\n  .graph-wrap:before {\n    content:\"\";\n    position:absolute;\n    inset:0;\n    background-image: linear-gradient(rgba(255,255,255,0.014) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px);\n    background-size: 80px 80px, 80px 80px;\n    opacity:0.04;\n    pointer-events:none;\n  }\n\n  /* nodes */\n  .node {\n    position:absolute;\n    width:62px;\n    height:62px;\n    border-radius:999px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:#e9fbff;\n    font-weight:700;\n    letter-spacing:0.6px;\n    font-size:16px;\n    background: var(--node-bg);\n    border: 1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 6px 20px rgba(5,9,16,0.6), 0 0 18px rgba(120,200,255,0.02) inset;\n    transform: translate3d(-50%,-50%,0);\n    transition: transform .36s cubic-bezier(.2,.9,.2,1), box-shadow .28s ease, background .3s ease, opacity .24s ease;\n    z-index: 3;\n    backdrop-filter: blur(6px);\n    cursor:default;\n  }\n\n  .node .label {\n    display:block;\n    text-align:center;\n    pointer-events:none;\n  }\n\n  .node .badge {\n    position:absolute;\n    right: -8px;\n    bottom: -8px;\n    width:30px;\n    height:30px;\n    border-radius:10px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));\n    border: 1px solid rgba(255,255,255,0.06);\n    color:var(--muted);\n    font-size:12px;\n    font-weight:700;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transform: scale(.88);\n    transition: transform .25s ease, background .25s ease, color .25s ease;\n  }\n\n  /* node glows and states */\n  .node.frontier {\n    transform: translate3d(-50%,-50%,0) scale(1.06);\n    box-shadow: 0 18px 48px rgba(99,160,255,0.12), 0 0 40px rgba(123,201,255,0.12);\n    background: linear-gradient(135deg, rgba(107,183,255,0.12), rgba(255,255,255,0.02));\n  }\n  .node.visited {\n    background: linear-gradient(135deg, rgba(34,115,95,0.9), rgba(46,153,118,0.85));\n    box-shadow: 0 16px 48px rgba(32,115,95,0.18), 0 0 30px rgba(126,231,198,0.12);\n    color:#042a21;\n  }\n  .node.dim {\n    opacity:0.42;\n    transform: translate3d(-50%,-50%,0) scale(.96);\n  }\n\n  /* ripple pulse for frontier */\n  .node .ring {\n    position:absolute;\n    width:120%;\n    height:120%;\n    border-radius:999px;\n    left:50%;\n    top:50%;\n    transform:translate(-50%,-50%);\n    pointer-events:none;\n    z-index:-1;\n    opacity:0;\n  }\n  .node.frontier .ring {\n    animation: pulse 1200ms ease-out forwards;\n    opacity:1;\n  }\n  @keyframes pulse {\n    0% { transform: translate(-50%,-50%) scale(.9); opacity:1; filter:blur(0px); }\n    100% { transform: translate(-50%,-50%) scale(1.6); opacity:0; filter:blur(6px); }\n  }\n\n  /* SVG edges */\n  svg.edges { position:absolute; inset:12px; width:calc(100% - 24px); height:calc(100% - 24px); pointer-events:none; z-index:2; overflow:visible; }\n  svg.edges line {\n    stroke: linear-gradient(90deg, var(--accent-2), var(--accent-3));\n    stroke-width:2.8;\n    stroke-linecap:round;\n    stroke: rgba(255,255,255,0.06);\n    transition: stroke .26s ease, stroke-width .26s ease, opacity .26s ease;\n    opacity:0.9;\n  }\n\n  svg.edges line.discovered {\n    stroke: url(#edge-grad);\n    stroke-width:3.8;\n    filter: drop-shadow(0 6px 18px rgba(99,160,255,0.12));\n    opacity:1;\n  }\n  svg.edges line.traversed {\n    stroke: linear-gradient(90deg, #43c7a8, #7ee7c6);\n    stroke: rgba(66,199,168,0.96);\n    stroke-width:4.6;\n    filter: drop-shadow(0 12px 30px rgba(66,199,168,0.12));\n    opacity:1;\n  }\n\n  /* legend & pseudocode */\n  .legend { display:flex; gap:10px; align-items:center; margin-top:6px; }\n  .chip { display:inline-flex; gap:8px; align-items:center; padding:8px 10px; border-radius:10px; background: rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.02); font-size:13px; color:var(--muted); }\n  .chip .dot { width:12px; height:12px; border-radius:6px; background:var(--accent-1); box-shadow:0 6px 12px rgba(123,201,255,0.08); }\n\n  .pseudocode {\n    margin-top:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:12px;\n    color:var(--muted);\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Courier New\", monospace;\n    font-size:13px;\n    line-height:1.5;\n  }\n\n  .footer {\n    margin-top:auto;\n    font-size:12px;\n    color:rgba(255,255,255,0.35);\n  }\n\n  /* small queue viz */\n  .queue {\n    display:flex;\n    gap:8px;\n    margin-top:12px;\n    align-items:center;\n  }\n  .q-bubble {\n    width:44px;\n    height:44px;\n    border-radius:10px;\n    background: rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:var(--muted);\n    font-weight:700;\n    font-size:13px;\n  }\n\n  /* responsive */\n  @media (max-width:1100px) {\n    .card { flex-direction:column; height:auto; padding-bottom:20px; }\n    .stage { order:2; width:100%; }\n    .panel { order:1; width:100%; border-left:0; border-top:1px solid rgba(255,255,255,0.03); }\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"orb one\" aria-hidden=\"true\"></div>\n  <div class=\"orb two\" aria-hidden=\"true\"></div>\n\n  <div class=\"card\" role=\"region\" aria-label=\"Breadth First Search visualization\">\n    <div class=\"stage\">\n      <div class=\"graph-wrap\" id=\"graphWrap\" aria-hidden=\"false\">\n        <!-- edges drawn as SVG -->\n        <svg class=\"edges\" id=\"edgesSvg\" viewBox=\"0 0 860 560\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"edge-grad\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#6bb7ff\" stop-opacity=\"0.95\"/>\n              <stop offset=\"100%\" stop-color=\"#7ee7c6\" stop-opacity=\"0.95\"/>\n            </linearGradient>\n          </defs>\n        </svg>\n\n        <!-- Nodes are positioned absolutely; JS will place them -->\n        <div id=\"nodesLayer\" aria-hidden=\"true\"></div>\n\n        <!-- subtle center watermark -->\n        <svg width=\"860\" height=\"560\" style=\"position:absolute;left:0;top:0;pointer-events:none;opacity:0.06\">\n          <g transform=\"translate(50,420) rotate(-20)\">\n            <text x=\"0\" y=\"0\" fill=\"#7ee7c6\" font-size=\"86\" font-weight=\"800\" font-family=\"Inter, sans-serif\">BFS</text>\n          </g>\n        </svg>\n      </div>\n    </div>\n\n    <aside class=\"panel\" aria-hidden=\"false\">\n      <div>\n        <div class=\"title\">\n          Breadth‑First Search\n        </div>\n        <div class=\"subtitle\">Observe a wave-like exploration of a graph — level by level, shortest‑path first.</div>\n        <div class=\"controls\" style=\"margin-top:16px;\">\n          <button id=\"startBtn\" class=\"btn\" title=\"Start BFS animation\">Start BFS</button>\n          <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset visualization\">Reset</button>\n        </div>\n        <div class=\"legend\" style=\"margin-top:12px;\">\n          <div class=\"chip\"><span class=\"dot\" style=\"background:linear-gradient(180deg,var(--accent-2),var(--accent-1));\"></span> Discovered</div>\n          <div class=\"chip\"><span class=\"dot\" style=\"background:linear-gradient(180deg,#43c7a8,#2fb98f);\"></span> Visited</div>\n        </div>\n      </div>\n\n      <div class=\"pseudocode\" aria-hidden=\"true\">\n        // BFS (high-level)<br>\n        queue = [start]  &nbsp;&nbsp;&nbsp; visited[start]=true<br>\n        while queue not empty:<br>\n        &nbsp;&nbsp;&nbsp; node = queue.pop_front()<br>\n        &nbsp;&nbsp;&nbsp; for each neighbor of node:<br>\n        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; if not visited: mark visited, push neighbor<br>\n        <div style=\"height:6px;\"></div>\n        Small observation: BFS discovers nodes in waves — nodes at distance d are discovered before any node at distance d+1.\n      </div>\n\n      <div style=\"margin-top:14px;\">\n        <div style=\"font-size:13px;color:var(--muted);\">Queue (visual):</div>\n        <div class=\"queue\" id=\"queueView\" aria-hidden=\"true\">\n          <!-- realtime queue items -->\n        </div>\n      </div>\n\n      <div class=\"footer\">\n        Tip: Minimal controls here — start the animation and watch BFS unfold with graceful, aesthetic motion.\n      </div>\n    </aside>\n  </div>\n</div>\n\n<script>\n/*\n  BFS visualization — Aesthetic, limited interactivity.\n  Two buttons: Start and Reset.\n  Predefined graph with beautiful animations and subtle effects.\n*/\n\n(function(){\n  // Graph layout (positions relative to 860x560 canvas)\n  const layout = [\n    {id:0,label:'A', x:430, y:70},\n    {id:1,label:'B', x:240, y:140},\n    {id:2,label:'C', x:620, y:140},\n    {id:3,label:'D', x:110, y:260},\n    {id:4,label:'E', x:330, y:260},\n    {id:5,label:'F', x:540, y:260},\n    {id:6,label:'G', x:760, y:260},\n    {id:7,label:'H', x:210, y:420},\n    {id:8,label:'I', x:360, y:420},\n    {id:9,label:'J', x:520, y:420},\n    {id:10,label:'K', x:670, y:420},\n    {id:11,label:'L', x:430, y:520}\n  ];\n\n  // adjacency list for undirected graph\n  const adj = {\n    0: [1,2,4],\n    1: [0,3,4],\n    2: [0,5,6],\n    3: [1,7],\n    4: [0,1,5,8],\n    5: [2,4,6,9],\n    6: [2,5,10],\n    7: [3,8],\n    8: [7,4,11],\n    9: [5,10,11],\n    10:[6,9,11],\n    11:[8,9,10]\n  };\n\n  const startNode = 0; // A\n\n  const nodesLayer = document.getElementById('nodesLayer');\n  const edgesSvg = document.getElementById('edgesSvg');\n  const queueView = document.getElementById('queueView');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  let nodes = {};\n  let edgeElements = {};\n  let animating = false;\n  let events = [];\n  let orderNumber = 0;\n  let timeouts = [];\n\n  // Create nodes\n  function createNodes(){\n    nodesLayer.innerHTML = '';\n    nodes = {};\n    layout.forEach(n => {\n      const el = document.createElement('div');\n      el.className = 'node';\n      el.dataset.id = n.id;\n      el.style.left = n.x + 'px';\n      el.style.top = n.y + 'px';\n      el.setAttribute('aria-label','Node '+n.label);\n      el.innerHTML = `\n        <div class=\"ring\" style=\"background: radial-gradient(circle, rgba(107,183,255,0.12), transparent 35%);\"></div>\n        <span class=\"label\">${n.label}</span>\n        <div class=\"badge\"></div>\n      `;\n      nodesLayer.appendChild(el);\n      nodes[n.id] = el;\n    });\n  }\n\n  // Create edges SVG lines\n  function createEdges(){\n    edgesSvg.querySelectorAll('*:not(defs)').forEach(n=>n.remove());\n    edgeElements = {};\n    // create invisible base lines first for subtle look\n    Object.keys(adj).forEach(k=>{\n      const from = parseInt(k,10);\n      adj[from].forEach(to=>{\n        if (to <= from) return; // avoid dup for undirected\n        const f = layout.find(p=>p.id===from);\n        const t = layout.find(p=>p.id===to);\n        const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n        line.setAttribute('x1', f.x);\n        line.setAttribute('y1', f.y);\n        line.setAttribute('x2', t.x);\n        line.setAttribute('y2', t.y);\n        line.setAttribute('stroke-linecap','round');\n        line.setAttribute('stroke','rgba(255,255,255,0.04)');\n        line.setAttribute('stroke-width','2.2');\n        line.dataset.id = from+'-'+to;\n        edgesSvg.appendChild(line);\n        edgeElements[`${from}-${to}`] = line;\n        edgeElements[`${to}-${from}`] = line; // alias\n      });\n    });\n  }\n\n  // Utility: mark node state\n  function setNodeState(id, state){\n    const el = nodes[id];\n    if(!el) return;\n    el.classList.remove('frontier','visited','dim');\n    if(state === 'frontier') el.classList.add('frontier');\n    if(state === 'visited') el.classList.add('visited');\n    if(state === 'dim') el.classList.add('dim');\n  }\n\n  function setBadge(id, text, color){\n    const el = nodes[id];\n    if(!el) return;\n    const badge = el.querySelector('.badge');\n    if(!badge) return;\n    badge.textContent = text || '';\n    if(color){\n      badge.style.background = color;\n      badge.style.color = '#042a21';\n    } else {\n      badge.style.background = 'linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02))';\n      badge.style.color = 'var(--muted)';\n    }\n  }\n\n  function highlightEdge(from,to,cls){\n    const el = edgeElements[`${from}-${to}`];\n    if(!el) return;\n    el.classList.remove('discovered','traversed');\n    if(cls) el.classList.add(cls);\n  }\n\n  // BFS algorithm that records discovery events (when a neighbor is first enqueued)\n  function computeBfsEvents(start){\n    const visited = new Array(layout.length).fill(false);\n    const q = [];\n    const ev = [];\n    orderNumber = 0;\n    visited[start] = true;\n    ev.push({type:'discover',from:null,to:start,order:++orderNumber}); // starting node\n    q.push(start);\n    while(q.length){\n      const cur = q.shift();\n      // iterate neighbors in listed order\n      const neighbors = adj[cur] || [];\n      for(const nb of neighbors){\n        if(!visited[nb]){\n          visited[nb] = true;\n          ev.push({type:'edge',from:cur,to:nb,order:++orderNumber});\n          q.push(nb);\n        }\n      }\n    }\n    return ev;\n  }\n\n  // Animate events sequentially\n  function animateEvents(evList){\n    animating = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n    queueView.innerHTML = '';\n    // initial dimming\n    layout.forEach(n => {\n      setNodeState(n.id, 'dim');\n      setBadge(n.id,'','');\n    });\n\n    let t = 0;\n    const baseDelay = 700;\n    const short = 360;\n    const long = 900;\n\n    evList.forEach((e, idx) => {\n      const delay = t;\n      if(e.type === 'discover' && e.from === null){\n        // starting node immediate highlight\n        schedule(delay, ()=>{\n          setNodeState(e.to,'frontier');\n          setBadge(e.to,String(e.order), 'linear-gradient(180deg,var(--accent-2),var(--accent-1))');\n          updateQueueVisual([e.to]);\n        });\n        t += short;\n      } else if(e.type === 'edge'){\n        // highlight edge, then mark node frontier\n        schedule(delay, ()=>{\n          highlightEdge(e.from,e.to,'discovered');\n          // small anim on \"from\" to show active exploring\n          const fromEl = nodes[e.from];\n          if(fromEl){\n            fromEl.animate([\n              { transform: 'translate3d(-50%,-50%,0) scale(1)' },\n              { transform: 'translate3d(-50%,-50%,0) scale(1.04)' },\n              { transform: 'translate3d(-50%,-50%,0) scale(1)' }\n            ], { duration: 420, easing: 'ease-out' });\n          }\n          // reveal the neighbor\n          setNodeState(e.to,'frontier');\n          setBadge(e.to,String(e.order), 'linear-gradient(180deg,var(--accent-2),var(--accent-1))');\n          // update queue view by showing the next nodes enqueued briefly\n          const curQueue = gatherQueueUpToIndex(evList, idx);\n          updateQueueVisual(curQueue);\n        });\n        t += short;\n      }\n    });\n\n    // final sweep: mark all as visited with stagger\n    const finalDelay = t + 360;\n    layout.forEach((n,i)=>{\n      schedule(finalDelay + i*120, ()=>{\n        setNodeState(n.id,'visited');\n        // finalize edge styling for edges leading to visited nodes\n        // (we transition discovered edges to traversed)\n        // find edges connecting earlier-order nodes to this node (we highlight all incident edges)\n        Object.keys(edgeElements).forEach(k=>{\n          const parts = k.split('-').map(Number);\n          if(parts[0]===n.id || parts[1]===n.id){\n            highlightEdge(parts[0],parts[1],'traversed');\n          }\n        });\n      });\n    });\n\n    // end of animation: enable reset and keep start disabled\n    schedule(finalDelay + layout.length*120 + 600, ()=>{\n      animating = false;\n      startBtn.disabled = true;\n      resetBtn.disabled = false;\n      // keep queue empty at end\n      updateQueueVisual([]);\n    });\n  }\n\n  // schedule helper\n  function schedule(delay, fn){\n    const id = setTimeout(fn, delay);\n    timeouts.push(id);\n  }\n\n  // compute current queue representation based on events processed up to idx\n  function gatherQueueUpToIndex(evList, idx){\n    // reconstruct BFS queue state as it's being discovered (approx)\n    // We'll approximate by listing nodes discovered so far but not yet \"settled\" in visited order.\n    const discovered = [];\n    for(let i=0;i<=idx;i++){\n      const e = evList[i];\n      if(e.type === 'discover' || e.type === 'edge'){\n        if(!discovered.includes(e.to)) discovered.push(e.to);\n      }\n    }\n    // remove those that would have been processed (settled) earlier: BFS dequeues in discovery order.\n    // We'll show the queue as the discovered list (front is first item)\n    return discovered;\n  }\n\n  // update queue UI\n  function updateQueueVisual(qArray){\n    queueView.innerHTML = '';\n    qArray.slice(0,8).forEach(id=>{\n      const node = layout.find(n=>n.id===id);\n      const el = document.createElement('div');\n      el.className = 'q-bubble';\n      el.textContent = node ? node.label : id;\n      queueView.appendChild(el);\n    });\n    if(qArray.length > 8){\n      const more = document.createElement('div');\n      more.className = 'q-bubble';\n      more.textContent = '…';\n      queueView.appendChild(more);\n    }\n  }\n\n  // Reset\n  function reset(){\n    // clear timeouts\n    timeouts.forEach(t => clearTimeout(t));\n    timeouts = [];\n    animating = false;\n    startBtn.disabled = false;\n    resetBtn.disabled = false;\n    // clear styles\n    layout.forEach(n=>{\n      const el = nodes[n.id];\n      if(el){\n        el.className = 'node';\n        el.style.left = n.x + 'px';\n        el.style.top = n.y + 'px';\n        const badge = el.querySelector('.badge');\n        if(badge) badge.textContent='';\n      }\n    });\n    // reset edges\n    Object.values(edgeElements).forEach(l=>{\n      if(l){\n        l.classList.remove('discovered','traversed');\n        l.setAttribute('stroke','rgba(255,255,255,0.04)');\n        l.setAttribute('stroke-width','2.2');\n      }\n    });\n    queueView.innerHTML = '';\n  }\n\n  // start handler\n  function start(){\n    if(animating) return;\n    // prepare\n    reset(); // ensure clean\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n    // compute events\n    events = computeBfsEvents(startNode);\n    // animate\n    animateEvents(events);\n  }\n\n  // init\n  createNodes();\n  createEdges();\n  resetBtn.disabled = false;\n\n  // attach events\n  startBtn.addEventListener('click', ()=>{\n    start();\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    // stop and reset\n    timeouts.forEach(t => clearTimeout(t));\n    timeouts = [];\n    animating = false;\n    reset();\n  });\n\n  // Make it visually appealing on load: little entrance animation\n  window.addEventListener('load', ()=>{\n    const card = document.querySelector('.card');\n    card.animate([\n      { transform: 'translateY(18px) scale(.996)', opacity: 0 },\n      { transform: 'translateY(0px) scale(1)', opacity: 1 }\n    ], { duration: 700, easing:'cubic-bezier(.2,.9,.3,1)', fill:'forwards' });\n\n    // subtle stagger node pop-in\n    layout.forEach((n,i)=>{\n      const el = nodes[n.id];\n      if(el){\n        el.animate([\n          { transform: 'translate3d(-50%,-60%,0) scale(.92)', opacity:0 },\n          { transform: 'translate3d(-50%,-50%,0) scale(1.02)', opacity:1 },\n          { transform: 'translate3d(-50%,-50%,0) scale(1)', opacity:1 }\n        ], { duration: 720, delay: 120 + i*40, easing: 'cubic-bezier(.2,.9,.2,1)', fill:'forwards' });\n      }\n    });\n\n    // gentle pulse on start button to attract attention\n    startBtn.animate([\n      { transform: 'translateY(0) scale(1)', boxShadow: '0 6px 18px rgba(34,128,104,0.18)' },\n      { transform: 'translateY(-4px) scale(1.02)', boxShadow: '0 18px 44px rgba(34,128,104,0.18)' },\n      { transform: 'translateY(0) scale(1)', boxShadow: '0 6px 18px rgba(34,128,104,0.18)' }\n    ], { duration: 2400, delay:300, iterations:1, easing:'ease-out' });\n  });\n\n  // Accessibility: keyboard support limited (Enter to start)\n  document.addEventListener('keydown', (e)=>{\n    if(e.key === 'Enter' && !animating){\n      start();\n    }\n    if(e.key === 'Escape'){\n      resetBtn.click();\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
