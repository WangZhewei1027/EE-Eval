    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Insertion Sort Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #f3f4f6, #cbd5e1);\n            color: #334155;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n        }\n        #container {\n            width: 80%;\n            max-width: 800px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n            padding: 20px;\n            text-align: center;\n        }\n        h1 {\n            font-size: 2.5em;\n            margin-bottom: 20px;\n            color: #1e3a8a;\n        }\n        .bar {\n            display: inline-block;\n            width: 20px;\n            margin: 0 3px;\n            background-color: #60a5fa;\n            border-radius: 5px;\n            transition: height 0.3s ease, background-color 0.3s ease;\n        }\n        .active {\n            background-color: #f97316;\n        }\n        .sorted {\n            background-color: #4ade80;\n        }\n        button {\n            padding: 10px 15px;\n            border: none;\n            border-radius: 5px;\n            background-color: #2563eb;\n            color: white;\n            font-size: 1em;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n        }\n        button:hover {\n            background-color: #3b82f6;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\">\n        <h1>Insertion Sort Visualization</h1>\n        <div id=\"bars\"></div>\n        <br>\n        <button onclick=\"startSorting()\">Start Sort</button>\n    </div>\n\n    <script>\n        const bars = [];\n        const numberOfBars = 20;\n\n        // Generate random bars\n        for (let i = 0; i < numberOfBars; i++) {\n            const height = Math.floor(Math.random() * 200) + 20;\n            bars.push(height);\n        }\n\n        const renderBars = () => {\n            const barsContainer = document.getElementById('bars');\n            barsContainer.innerHTML = '';\n            bars.forEach((height) => {\n                const bar = document.createElement('div');\n                bar.style.height = height + 'px';\n                bar.className = 'bar';\n                barsContainer.appendChild(bar);\n            });\n        }\n        \n        const startSorting = async () => {\n            for (let i = 1; i < bars.length; i++) {\n                let key = bars[i];\n                let j = i - 1;\n\n                // Mark current item as active\n                document.getElementsByClassName('bar')[i].classList.add('active');\n                await new Promise(resolve => setTimeout(resolve, 300));\n                \n                while (j >= 0 && bars[j] > key) {\n                    bars[j + 1] = bars[j];\n                    j--;\n\n                    // Update bars during sort\n                    renderBars();\n                    await new Promise(resolve => setTimeout(resolve, 300));\n                }\n                bars[j + 1] = key;\n\n                // Unmark current item\n                document.getElementsByClassName('bar')[i].classList.remove('active');\n                document.getElementsByClassName('bar')[j + 1].classList.add('sorted');\n            }\n            renderBars();\n        };\n\n        renderBars();\n    </script>\n</body>\n</html>"
