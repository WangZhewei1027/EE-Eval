    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Backpropagation Simulation</title>\n    <style>\n        body { font-family: sans-serif; padding: 20px; }\n        #output { margin-top: 20px; }\n    </style>\n</head>\n<body>\n\n    <h1>Backpropagation Interactive Simulation</h1>\n\n    <h2>Network Configuration</h2>\n    <label for=\"numLayers\">Number of Layers (1-5): </label>\n    <input type=\"number\" id=\"numLayers\" min=\"1\" max=\"5\" value=\"3\"><br><br>\n\n    <label for=\"neuronsPerLayer\">Neurons per Layer (1-10): </label>\n    <input type=\"number\" id=\"neuronsPerLayer\" min=\"1\" max=\"10\" value=\"5\"><br><br>\n\n    <h2>Training Configuration</h2>\n    <label for=\"learningRate\">Learning Rate (0.01 - 1): </label>\n    <input type=\"number\" step=\"0.01\" id=\"learningRate\" min=\"0.01\" max=\"1\" value=\"0.1\"><br><br>\n\n    <label for=\"numEpochs\">Number of Epochs (1-100): </label>\n    <input type=\"number\" id=\"numEpochs\" min=\"1\" max=\"100\" value=\"10\"><br><br>\n\n    <button id=\"initialize\">Initialize Network</button>\n    <button id=\"train\">Train Network</button>\n\n    <div id=\"output\"></div>\n\n    <script>\n        let network = {};\n        \n        document.getElementById('initialize').addEventListener('click', function() {\n            const numLayers = parseInt(document.getElementById('numLayers').value);\n            const neuronsPerLayer = parseInt(document.getElementById('neuronsPerLayer').value);\n            network = createNetwork(numLayers, neuronsPerLayer);\n            document.getElementById('output').innerText = `Network initialized with ${numLayers} layers and ${neuronsPerLayer} neurons each.`;\n        });\n\n        document.getElementById('train').addEventListener('click', function() {\n            const learningRate = parseFloat(document.getElementById('learningRate').value);\n            const numEpochs = parseInt(document.getElementById('numEpochs').value);\n            const results = trainNetwork(network, learningRate, numEpochs);\n            document.getElementById('output').innerText = results;\n        });\n\n        function createNetwork(numLayers, neuronsPerLayer) {\n            let network = [];\n            for (let i = 0; i < numLayers; i++) {\n                let layer = [];\n                for (let j = 0; j < neuronsPerLayer; j++) {\n                    layer.push({ weight: Math.random(), bias: Math.random() });\n                }\n                network.push(layer);\n            }\n            return network;\n        }\n\n        function trainNetwork(network, learningRate, numEpochs) {\n            let errorSum = 0;\n            // Simulate training process and error calculation\n            for (let epoch = 0; epoch < numEpochs; epoch++) {\n                let error = Math.random();  // Dummy error calculation\n                errorSum += error;\n                // Update weights and biases\n                for (let layer of network) {\n                    for (let neuron of layer) {\n                        neuron.weight -= learningRate * error;\n                        neuron.bias -= learningRate * error;\n                    }\n                }\n            }\n            return `Training complete. Total Error: ${errorSum.toFixed(4)}`;\n        }\n    </script>\n\n</body>\n</html>"
