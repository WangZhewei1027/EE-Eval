    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>AVL Tree — Aesthetic Visualization</title>\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071126;\n    --card: rgba(255,255,255,0.04);\n    --glass: rgba(255,255,255,0.06);\n    --accent: linear-gradient(135deg,#7c7cff 0%, #7ad0ff 40%, #9ef7d3 100%);\n    --muted: rgba(255,255,255,0.6);\n    --glass-border: rgba(255,255,255,0.08);\n    --node-fill: linear-gradient(180deg,#111827,#0b1220);\n    --success: #7ef3b4;\n    --danger: #ff7c7c;\n    --shadow: 0 8px 30px rgba(2,6,23,0.7);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,124,255,0.07), transparent),\n                radial-gradient(800px 400px at 90% 80%, rgba(122,208,255,0.06), transparent),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    padding:48px;\n    overflow:hidden;\n  }\n\n  /* aesthetic floating orbs */\n  .orb{\n    position:absolute;\n    border-radius:50%;\n    filter: blur(36px);\n    opacity:0.6;\n    mix-blend-mode: screen;\n    pointer-events:none;\n  }\n  .orb.one{width:520px;height:520px;left:-120px;top:-60px;background:radial-gradient(circle,#7c7cff 0%, rgba(124,124,255,0.04) 40%, transparent 60%);}\n  .orb.two{width:420px;height:420px;right:-100px;bottom:-80px;background:radial-gradient(circle,#7ad0ff 0%, rgba(122,208,255,0.04) 40%, transparent 60%);}\n\n  .stage{\n    width: min(1200px, calc(100% - 96px));\n    height: calc(100vh - 96px);\n    margin: 0 auto;\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap:28px;\n    align-items:stretch;\n    position:relative;\n    z-index:2;\n  }\n\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid var(--glass-border);\n    border-radius:18px;\n    padding:22px;\n    box-shadow: var(--shadow);\n    backdrop-filter: blur(8px) saturate(120%);\n    overflow:hidden;\n  }\n\n  .left{\n    padding:32px;\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    min-height:500px;\n  }\n  .title{\n    display:flex;\n    align-items:center;\n    gap:16px;\n  }\n  .logo{\n    width:64px;height:64px;border-radius:14px;\n    background: linear-gradient(135deg,#101826 0%, rgba(255,255,255,0.02) 100%);\n    box-shadow: 0 6px 18px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    display:grid;place-items:center;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .logo svg{filter: drop-shadow(0 6px 22px rgba(122,208,255,0.08));}\n\n  h1{\n    margin:0;font-weight:700;font-size:20px;letter-spacing:-0.02em;\n    color: #ffffff;\n  }\n  p.lead{\n    margin:0;color:var(--muted);font-size:13px;line-height:1.5;\n  }\n\n  .view{\n    flex:1;\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:18px;\n  }\n\n  /* card with SVG tree */\n  .canvas{\n    width:100%;\n    height:100%;\n    border-radius:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.02);\n    padding:18px;\n    position:relative;\n    overflow:hidden;\n  }\n  .canvas header{\n    position:absolute;top:14px;left:18px;z-index:3;\n    display:flex;gap:12px;align-items:center;backdrop-filter: blur(6px);\n  }\n  .badge{\n    padding:8px 12px;border-radius:999px;background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.03);font-weight:600;font-size:13px;color:#dfefff;\n    display:flex;gap:8px;align-items:center;\n  }\n\n  svg{width:100%;height:100%;}\n  .edges{fill:none;stroke:rgba(255,255,255,0.08);stroke-width:2.4;filter: drop-shadow(0 6px 18px rgba(2,6,23,0.5));}\n  .edge-highlight{stroke:rgba(158,247,211,0.95);stroke-width:3.2;opacity:0.0;transition:opacity .6s ease;}\n  .node{\n    transition: transform 700ms cubic-bezier(.2,.9,.2,1), opacity 400ms ease;\n    transform-origin:center center;\n    cursor:default;\n  }\n  .node .circle{\n    fill: url(#nodeGrad);\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:1.4;\n    filter: drop-shadow(0 6px 22px rgba(2,6,23,0.55));\n  }\n  .node .text{\n    font-weight:700;font-size:14px;fill:#e9fbff;text-anchor:middle;dominant-baseline:central;\n    text-shadow: 0 2px 8px rgba(2,6,23,0.6);\n  }\n  .node .bf{\n    font-size:11px;fill:#9fbcd1;text-anchor:middle;dominant-baseline:central;\n  }\n  .node .halo{\n    fill: none; stroke: rgba(124,124,255,0.09); stroke-width:12; opacity:0; transition:opacity .45s ease;\n  }\n  .node.highlight .halo{opacity:1;}\n  .node.inserting{opacity:0; transform:scale(.6) translateY(40px); transition: none;}\n  .node.appear{opacity:1; transform:scale(1) translateY(0); transition: transform 700ms cubic-bezier(.2,.9,.2,1), opacity 600ms ease;}\n  .node.fade{opacity:.18; transform:scale(.95);}\n\n  /* right controls */\n  .right{\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    padding:22px;\n    min-height:500px;\n  }\n  .controls{\n    display:flex;gap:12px;align-items:center;\n  }\n  .btn{\n    appearance:none;border:0;padding:12px 16px;border-radius:12px;font-weight:700;font-size:13px;\n    color: #071126;background: linear-gradient(90deg,#1e2b48 0%, #132139 100%);\n    box-shadow: 0 6px 22px rgba(2,6,23,0.45);\n    border:1px solid rgba(255,255,255,0.04);\n    cursor:pointer;\n    transition: transform .14s ease, box-shadow .14s ease, opacity .14s ease;\n  }\n  .btn:active{transform:translateY(1px)}\n  .btn.primary{\n    background: linear-gradient(90deg,#7c7cff 0%, #7ad0ff 60%);\n    color:#031428;\n    box-shadow: 0 10px 40px rgba(124,124,255,0.12);\n  }\n  .btn.ghost{\n    background:transparent;border:1px dashed rgba(255,255,255,0.04);color:var(--muted);\n  }\n\n  .meta{\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.015));\n    border:1px solid rgba(255,255,255,0.02);\n    padding:16px;border-radius:12px;\n    color:var(--muted);font-size:13px;\n  }\n  .meta h3{margin:0;color:#f6fbff;font-size:13px;font-weight:700}\n  .meta p{margin:8px 0 0 0;font-size:13px}\n\n  .legend{\n    display:flex;gap:12px;flex-wrap:wrap;margin-top:6px;\n  }\n  .chip{\n    padding:8px 10px;border-radius:999px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.02);\n    font-size:12px;color:var(--muted);display:flex;gap:8px;align-items:center;\n  }\n  .step{\n    margin-top:14px;font-size:13px;color:var(--muted);\n  }\n\n  footer.attribution{\n    position:absolute;left:50%;transform:translateX(-50%);bottom:20px;color:rgba(255,255,255,0.06);\n    font-size:12px;letter-spacing:0.08em;\n  }\n\n  /* responsive */\n  @media (max-width:980px){\n    .stage{grid-template-columns: 1fr; padding-bottom:28px}\n    .right{order:2}\n    .left{order:1}\n    footer.attribution{display:none}\n  }\n</style>\n</head>\n<body>\n  <div class=\"orb one\"></div>\n  <div class=\"orb two\"></div>\n\n  <div class=\"stage\">\n    <div class=\"panel left\">\n      <div class=\"title\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7c7cff\" />\n                <stop offset=\"1\" stop-color=\"#7ad0ff\" />\n              </linearGradient>\n            </defs>\n            <path d=\"M12 3v18\" stroke=\"url(#g1)\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n            <path d=\"M6 9l6-6 6 6\" stroke=\"url(#g1)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <path d=\"M6 15l6 6 6-6\" stroke=\"url(#g1)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </div>\n        <div>\n          <h1>AVL Tree — Balanced by Design</h1>\n          <p class=\"lead\">A visually rich, animated depiction of AVL tree insertions and rotations. Watch how the tree auto-balances as nodes are added.</p>\n        </div>\n      </div>\n\n      <div class=\"view\">\n        <div class=\"canvas\" id=\"canvas\">\n          <header>\n            <div class=\"badge\">AVL • Self‑Balancing Binary Search Tree</div>\n          </header>\n          <svg id=\"svgroot\" viewBox=\"0 0 1200 800\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"nodeGrad\" x1=\"0\" x2=\"0\" y1=\"0\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#10202f\"/>\n                <stop offset=\"1\" stop-color=\"#071624\"/>\n              </linearGradient>\n              <filter id=\"soft\" x=\"-20%\" y=\"-20%\" width=\"140%\" height=\"140%\">\n                <feDropShadow dx=\"0\" dy=\"10\" stdDeviation=\"18\" flood-color=\"#061124\" flood-opacity=\"0.6\"/>\n              </filter>\n            </defs>\n            <g class=\"edges\" id=\"edges\"></g>\n            <g id=\"nodes\"></g>\n          </svg>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"panel right\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n        <div>\n          <h3 style=\"margin:0\">Playback</h3>\n          <p style=\"margin:6px 0 0 0;color:var(--muted);font-size:13px\">Minimal controls — observe automatic insertions and rotations.</p>\n        </div>\n      </div>\n\n      <div class=\"controls\" style=\"margin-top:16px\">\n        <button id=\"playBtn\" class=\"btn primary\">Play Animation</button>\n        <button id=\"resetBtn\" class=\"btn ghost\">Reset</button>\n      </div>\n\n      <div class=\"meta\" style=\"margin-top:14px\">\n        <h3>Sequence</h3>\n        <p id=\"seq\" style=\"margin-top:8px\">Predefined insertion order: <span style=\"color:#dff6ff;font-weight:700\">30, 20, 40, 10, 25, 35, 50, 5, 15, 27</span></p>\n        <div class=\"legend\" aria-hidden=\"true\" style=\"margin-top:10px\">\n          <div class=\"chip\">Node</div>\n          <div class=\"chip\">Balance Factor</div>\n          <div class=\"chip\">Rotations animated</div>\n        </div>\n        <div class=\"step\" id=\"stepInfo\">Step: 0 / 10</div>\n      </div>\n\n      <div class=\"meta\" style=\"margin-top:12px;flex:1;display:flex;flex-direction:column;justify-content:flex-end\">\n        <h3>Concept</h3>\n        <p style=\"margin-top:8px\">AVL trees maintain balance by ensuring the heights of subtrees differ by at most 1. When imbalance occurs, rotations (left, right, or double) restore balance — animated here for clarity.</p>\n      </div>\n    </div>\n  </div>\n\n  <footer class=\"attribution\">AVL Visualization • Smooth animations • Aesthetic design</footer>\n\n<script>\n(function(){\n  // Minimal, self-contained AVL implementation with snapshot events recorded for visualization.\n  // Only Play and Reset controls (2) — interactivity intentionally limited.\n\n  // Predefined sequence to demonstrate various rotations\n  const sequence = [30,20,40,10,25,35,50,5,15,27];\n\n  // Config\n  const svg = document.getElementById('svgroot');\n  const nodesLayer = document.getElementById('nodes');\n  const edgesLayer = document.getElementById('edges');\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const stepInfo = document.getElementById('stepInfo');\n  const seqEl = document.getElementById('seq');\n\n  seqEl.innerHTML = 'Predefined insertion order: <span style=\"color:#dff6ff;font-weight:700\">' + sequence.join(', ') + '</span>';\n\n  // Canvas size used for layout coordinates\n  const viewW = 1200, viewH = 800;\n  const nodeRadius = 28;\n  const levelGap = 115;\n  const minNodeGap = 40;\n\n  let nodeIdCounter = 1;\n\n  function Node(val){\n    this.id = 'n' + (nodeIdCounter++);\n    this.val = val;\n    this.left = null;\n    this.right = null;\n    this.height = 1;\n  }\n\n  function getHeight(n){ return n ? n.height : 0; }\n  function updateHeight(n){ n.height = 1 + Math.max(getHeight(n.left), getHeight(n.right)); }\n  function balanceFactor(n){ return n ? getHeight(n.left) - getHeight(n.right) : 0; }\n\n  // Rotation helpers with recording\n  const events = []; // snapshots after each structural change\n  function recordEvent(root, highlightIds=[], note='') {\n    // Take a shallow structural snapshot to allow layout for visualization\n    const snap = cloneTree(root);\n    events.push({ tree: snap, highlight: highlightIds.slice(), note: note });\n  }\n\n  function cloneTree(root){\n    if(!root) return null;\n    const map = new Map();\n    function clone(n){\n      if(!n) return null;\n      const c = { id: n.id, val: n.val, left: null, right: null, height: n.height };\n      map.set(n, c);\n      c.left = clone(n.left);\n      c.right = clone(n.right);\n      return c;\n    }\n    return clone(root);\n  }\n\n  // Rotation operations (standard AVL)\n  function rotateRight(y){\n    const x = y.left;\n    const T2 = x.right;\n    x.right = y;\n    y.left = T2;\n    updateHeight(y);\n    updateHeight(x);\n    return x;\n  }\n  function rotateLeft(x){\n    const y = x.right;\n    const T2 = y.left;\n    y.left = x;\n    x.right = T2;\n    updateHeight(x);\n    updateHeight(y);\n    return y;\n  }\n\n  // Insert with rebalancing and recording events\n  function avlInsert(root, key){\n    function insert(node, key){\n      if(!node){\n        const n = new Node(key);\n        recordEvent(globalRoot, [n.id], `Inserted ${key}`);\n        return n;\n      }\n      if(key === node.val){\n        // duplicates ignored\n        return node;\n      }\n      if(key < node.val) node.left = insert(node.left, key);\n      else node.right = insert(node.right, key);\n\n      updateHeight(node);\n      const bf = balanceFactor(node);\n\n      // Left heavy\n      if(bf > 1){\n        if(key < node.left.val){\n          // Right rotation\n          recordEvent(globalRoot, [node.id, node.left.id], 'Right rotation');\n          node = rotateRight(node);\n          recordEvent(globalRoot, [node.id], 'After rotation');\n        } else {\n          // Left-Right\n          recordEvent(globalRoot, [node.left.id], 'Left rotation (LR case)');\n          node.left = rotateLeft(node.left);\n          recordEvent(globalRoot, [node.id], 'Right rotation (LR case)');\n          node = rotateRight(node);\n          recordEvent(globalRoot, [node.id], 'After double rotation');\n        }\n      }\n      // Right heavy\n      else if(bf < -1){\n        if(key > node.right.val){\n          // Left rotation\n          recordEvent(globalRoot, [node.id, node.right.id], 'Left rotation');\n          node = rotateLeft(node);\n          recordEvent(globalRoot, [node.id], 'After rotation');\n        } else {\n          // Right-Left\n          recordEvent(globalRoot, [node.right.id], 'Right rotation (RL case)');\n          node.right = rotateRight(node.right);\n          recordEvent(globalRoot, [node.id], 'Left rotation (RL case)');\n          node = rotateLeft(node);\n          recordEvent(globalRoot, [node.id], 'After double rotation');\n        }\n      }\n      return node;\n    }\n    return insert(root, key);\n  }\n\n  // Layout computation: assign x,y positions\n  function layoutTree(root){\n    // Inorder traversal to distribute x positions\n    const positions = {};\n    let idx = 0;\n    const spacing = minNodeGap;\n\n    function dfsWidth(n){\n      if(!n) return 0;\n      return 1 + dfsWidth(n.left) + dfsWidth(n.right);\n    }\n\n    function assign(n, depth){\n      if(!n) return;\n      assign(n.left, depth+1);\n      const x = ++idx;\n      positions[n.id] = { x: x, depth: depth };\n      assign(n.right, depth+1);\n    }\n\n    assign(root, 0);\n    // convert x index to pixel coordinates\n    const total = Math.max(1, idx);\n    const padding = 80;\n    const usableW = viewW - padding*2;\n    const step = usableW / total;\n    // Return pos map with pixel coords\n    const posMap = {};\n    for(const id in positions){\n      const p = positions[id];\n      const px = padding + (p.x - 0.5) * step;\n      const py = 80 + p.depth * levelGap;\n      posMap[id] = { x: px, y: py, depth: p.depth };\n    }\n    return posMap;\n  }\n\n  // Rendering: update DOM nodes and edges based on a snapshot\n  // We'll reuse DOM elements and animate transforms\n  const domNodes = new Map();\n\n  function ensureNodeElement(id){\n    if(domNodes.has(id)) return domNodes.get(id);\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('class','node');\n    g.setAttribute('data-id',id);\n\n    const halo = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    halo.setAttribute('class','halo');\n    halo.setAttribute('r', nodeRadius + 8);\n    g.appendChild(halo);\n\n    const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    circle.setAttribute('class','circle');\n    circle.setAttribute('r', nodeRadius);\n    g.appendChild(circle);\n\n    const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n    text.setAttribute('class','text');\n    g.appendChild(text);\n\n    const bf = document.createElementNS('http://www.w3.org/2000/svg','text');\n    bf.setAttribute('class','bf');\n    bf.setAttribute('y', nodeRadius + 18);\n    g.appendChild(bf);\n\n    nodesLayer.appendChild(g);\n    domNodes.set(id, g);\n    return g;\n  }\n\n  function removeAllNodes(){\n    domNodes.forEach((el) => { el.remove(); });\n    domNodes.clear();\n    edgesLayer.innerHTML = '';\n  }\n\n  function renderSnapshot(snapshot, highlightIds=[]){\n    const posMap = layoutTree(snapshot);\n\n    // collect nodes by traversal to set labels\n    const all = [];\n    function collect(n){\n      if(!n) return;\n      all.push(n);\n      collect(n.left);\n      collect(n.right);\n    }\n    collect(snapshot);\n\n    // create nodes present\n    const presentIds = new Set();\n    all.forEach(n => {\n      presentIds.add(n.id);\n      const g = ensureNodeElement(n.id);\n      const x = posMap[n.id].x;\n      const y = posMap[n.id].y;\n      // set label and bf\n      const t = g.querySelector('.text');\n      t.textContent = n.val;\n      const bfText = g.querySelector('.bf');\n      const bf = (getHeight(n.left) - getHeight(n.right)).toFixed(0); // approximate for display\n      bfText.textContent = 'bf ' + bf;\n      // apply transforms for animation\n      g.style.transition = 'transform 700ms cubic-bezier(.2,.9,.2,1), opacity 450ms ease';\n      g.style.transform = `translate(${x}px, ${y}px)`;\n      // set initial if new appeared with small pop\n      if(!g.classList.contains('appear') && !g.classList.contains('inserting')){\n        g.classList.add('appear');\n      }\n      if(highlightIds.includes(n.id)){\n        g.classList.add('highlight');\n      } else {\n        g.classList.remove('highlight');\n      }\n      // accessibility data attribute\n      g.setAttribute('data-val', n.val);\n    });\n\n    // remove nodes not present\n    domNodes.forEach((el, id) => {\n      if(!presentIds.has(id)){\n        el.style.opacity = '0';\n        setTimeout(()=>{ if(el.parentNode) el.remove(); domNodes.delete(id); }, 700);\n      }\n    });\n\n    // edges\n    edgesLayer.innerHTML = '';\n    function drawEdges(n){\n      if(!n) return;\n      const p = posMap[n.id];\n      if(n.left){\n        const c = posMap[n.left.id];\n        const path = createCurvePath(p.x, p.y, c.x, c.y);\n        edgesLayer.appendChild(path);\n        drawEdges(n.left);\n      }\n      if(n.right){\n        const c = posMap[n.right.id];\n        const path = createCurvePath(p.x, p.y, c.x, c.y);\n        edgesLayer.appendChild(path);\n        drawEdges(n.right);\n      }\n    }\n    if(snapshot) drawEdges(snapshot);\n\n    // subtle fade for non-highlighted nodes\n    domNodes.forEach((el, id) => {\n      if(highlightIds.length === 0) el.classList.remove('fade');\n      else if(!highlightIds.includes(id)) el.classList.add('fade');\n      else el.classList.remove('fade');\n    });\n  }\n\n  function createCurvePath(x1,y1,x2,y2){\n    const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n    const dx = Math.abs(x2-x1);\n    const midY = (y1 + y2) / 2;\n    const c1x = x1;\n    const c1y = y1 + (midY - y1) * 0.8;\n    const c2x = x2;\n    const c2y = y2 - (y2 - midY) * 0.8;\n    const d = `M ${x1} ${y1} C ${c1x} ${c1y}, ${c2x} ${c2y}, ${x2} ${y2}`;\n    path.setAttribute('d', d);\n    path.setAttribute('class','edge');\n    path.setAttribute('stroke','rgba(255,255,255,0.06)');\n    path.setAttribute('fill','none');\n    path.setAttribute('stroke-width','2.4');\n    return path;\n  }\n\n  // Animation sequence runner\n  let isPlaying = false;\n  let playIndex = 0;\n  let animationTimer = null;\n  let globalRoot = null;\n\n  function reset(){\n    if(animationTimer) { clearTimeout(animationTimer); animationTimer = null; }\n    isPlaying = false;\n    playIndex = 0;\n    globalRoot = null;\n    events.length = 0;\n    removeAllNodes();\n    stepInfo.textContent = 'Step: 0 / ' + sequence.length;\n    playBtn.disabled = false;\n    playBtn.textContent = 'Play Animation';\n  }\n\n  function buildEventsAndSnapshots(){\n    events.length = 0;\n    globalRoot = null;\n    // record initial empty state\n    recordEvent(globalRoot, [], 'Start');\n    for(const val of sequence){\n      globalRoot = avlInsert(globalRoot, val);\n      // After full insertion of this value, record tree final state (if last snapshot not equal)\n      recordEvent(globalRoot, [], `After inserting ${val}`);\n    }\n  }\n\n  // Play events visually with pacing\n  function play(){\n    if(isPlaying) return;\n    isPlaying = true;\n    playBtn.disabled = true;\n    playBtn.textContent = 'Playing…';\n    buildEventsAndSnapshots();\n    let idx = 0;\n    const totalSteps = events.filter(e => e.note.startsWith('After inserting') ).length;\n    function step(){\n      if(idx >= events.length){\n        isPlaying = false;\n        playBtn.disabled = false;\n        playBtn.textContent = 'Play Animation';\n        return;\n      }\n      const ev = events[idx];\n      renderSnapshot(ev.tree, ev.highlight);\n      // update step info when it's an \"After inserting\"\n      if(ev.note.startsWith('After inserting')){\n        const stepCount = (ev.note.match(/After inserting (\\d+)/) ? idx : null);\n        const insertedVal = ev.note.split('After inserting ')[1];\n        const done = sequence.indexOf(Number(insertedVal)) + 1;\n        stepInfo.textContent = 'Step: ' + done + ' / ' + sequence.length;\n      }\n      // Determine delay: longer when rotation events (note contains 'rotation')\n      let delay = 700;\n      if(ev.note.toLowerCase().includes('rotation')) delay = 900;\n      if(ev.note.toLowerCase().includes('inserted')) delay = 400;\n      idx++;\n      animationTimer = setTimeout(step, delay);\n    }\n    step();\n  }\n\n  // Attach events\n  playBtn.addEventListener('click', () => {\n    reset(); // ensure clean\n    play();\n  });\n  resetBtn.addEventListener('click', () => {\n    reset();\n  });\n\n  // Initialize page with empty canvas and subtle greeting nodes\n  function initialDecor(){\n    // create a gentle hint node arrangement\n    const hintRoot = (function(){\n      const a = new Node(30); a.id = 'hint1';\n      a.left = new Node(20); a.left.id = 'hint2';\n      a.right = new Node(40); a.right.id = 'hint3';\n      return a;\n    })();\n    renderSnapshot(hintRoot, []);\n    stepInfo.textContent = 'Step: 0 / ' + sequence.length;\n  }\n\n  reset();\n  initialDecor();\n\n})();\n</script>\n</body>\n</html>"
