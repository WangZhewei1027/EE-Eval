    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Static Typing Interactive Demo</title>\n<style>\n/* Extremely minimal styling: keep defaults, only tiny layout nudges */\nbody { margin: 12px; font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color: #000; background: #fff; }\nsection { margin-bottom: 12px; }\ntextarea, input[type=\"text\"], select { width: 100%; box-sizing: border-box; }\n.row { display: flex; gap: 12px; }\n.col { flex: 1; min-width: 0; }\nsmall { display: block; margin-top: 6px; }\npre { white-space: pre-wrap; background: #fff; border: 1px solid #ccc; padding: 8px; max-height: 280px; overflow: auto; }\nbutton, input[type=\"range\"] { margin-top: 6px; }\nlabel { display: block; margin-top: 6px; }\n</style>\n</head>\n<body>\n\n<h1>Static Typing — Interactive Playground</h1>\n\n<section>\n  <strong>Overview</strong>\n  <div>Explore static typing concepts: define types, create variables, run checks, simulate inference, refactor types, and see detailed step-by-step diagnostics. Visuals kept intentionally plain.</div>\n</section>\n\n<section>\n  <div class=\"row\">\n    <div class=\"col\">\n      <strong>Type Definitions (DSL)</strong>\n      <textarea id=\"typeDefs\" rows=\"10\">\n# Examples:\ntype Person = { name: string, age: number }\ntype Admin = Person & { role: string }\ntype ID = string\nnominal UserId = ID\ntype Maybe<T> = T | null\ntype Pair<T,U> = { first: T, second: U }\ntype NumArray = number[]\n      </textarea>\n      <div>\n        <button id=\"btnParse\">Parse Types</button>\n        <button id=\"btnResetTypes\">Reset Types</button>\n      </div>\n      <small>Use \"type Name = <expr>\" or \"nominal Name = <expr>\". Expressions: primitives: number,string,boolean,any,unknown,null,undefined. Object: {a: number, b: string}. Union with |. Intersection with &. Arrays with T[]. Generics: Name&lt;T&gt;.</small>\n      <label>Parsed Types:</label>\n      <pre id=\"typesList\">(no types parsed yet)</pre>\n    </div>\n\n    <div class=\"col\">\n      <strong>Variables</strong>\n      <label>New variable name</label>\n      <input type=\"text\" id=\"varName\" placeholder=\"e.g. alice\">\n      <label>Declared type (optional)</label>\n      <select id=\"varDeclaredType\">\n        <option value=\"\">(none)</option>\n      </select>\n      <label>Value (literal, JSON, function or hint)</label>\n      <input type=\"text\" id=\"varValue\" placeholder='e.g. {\"name\":\"A\",\"age\":30}  or  42  or  [\"x\",\"y\"] or fn(x:number):number'>\n      <label>Value type hint (helps inference, optional)</label>\n      <input type=\"text\" id=\"varValueHint\" placeholder=\"e.g. Person or number[]\">\n      <div>\n        <button id=\"btnAddVar\">Add Variable</button>\n        <button id=\"btnClearVars\">Clear Variables</button>\n      </div>\n\n      <label>Existing Variables:</label>\n      <pre id=\"varsList\">(none)</pre>\n    </div>\n\n    <div class=\"col\">\n      <strong>Typing Mode & Controls</strong>\n      <label>Typing Mode\n        <select id=\"typingMode\">\n          <option value=\"static\">Static</option>\n          <option value=\"gradual\">Gradual</option>\n          <option value=\"dynamic\">Dynamic</option>\n        </select>\n      </label>\n\n      <label>Strictness (gradual mode favors lower strictness)</label>\n      <input type=\"range\" id=\"strictness\" min=\"0\" max=\"100\" value=\"100\">\n      <div id=\"strictnessValue\">100</div>\n\n      <label><input type=\"checkbox\" id=\"structural\" checked> Structural matching (uncheck for nominal)</label>\n      <label><input type=\"checkbox\" id=\"enableInference\" checked> Enable inference when requested</label>\n      <label><input type=\"checkbox\" id=\"runtimeChecks\"> Simulate runtime checks</label>\n\n      <div style=\"margin-top:8px;\">\n        <button id=\"btnInferAll\">Infer All</button>\n        <button id=\"btnCheckAll\">Check All Assignments</button>\n        <button id=\"btnAutoFix\">Auto-fix Suggestions</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <label>Workflows</label>\n        <div>\n          <button id=\"btnRefactorRename\">Refactor: Rename property</button>\n          <button id=\"btnUnionize\">Unionize Selected Types</button>\n          <button id=\"btnIntersect\">Intersectionize Selected Types</button>\n        </div>\n        <small>Pick types from the list below when prompted.</small>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n<section>\n  <div class=\"row\">\n    <div class=\"col\">\n      <strong>Type Graph / Details</strong>\n      <label>Choose type for details:</label>\n      <select id=\"typeDetailSelect\"></select>\n      <pre id=\"typeDetail\">(choose a type)</pre>\n    </div>\n\n    <div class=\"col\">\n      <strong>Variable Inspector</strong>\n      <label>Choose variable:</label>\n      <select id=\"varDetailSelect\"></select>\n      <pre id=\"varDetail\">(choose a variable)</pre>\n      <div>\n        <button id=\"btnInferVar\">Infer Variable</button>\n        <button id=\"btnAssignToVar\">Assign expression to variable</button>\n        <input type=\"text\" id=\"assignExpr\" placeholder='right-hand expression or var name'>\n        <small>Use JSON-like literals or another variable name to assign from.</small>\n      </div>\n    </div>\n\n    <div class=\"col\">\n      <strong>History & Replay</strong>\n      <div>\n        <button id=\"btnPrevHist\">Prev</button>\n        <button id=\"btnNextHist\">Next</button>\n        <button id=\"btnShowHistory\">Show History</button>\n        <button id=\"btnClearHistory\">Clear History</button>\n      </div>\n      <label>Recent Actions:</label>\n      <pre id=\"historyLog\">(no actions yet)</pre>\n    </div>\n  </div>\n</section>\n\n<section>\n  <strong>Diagnostics / Log</strong>\n  <pre id=\"log\">Ready. Parse types to begin.</pre>\n</section>\n\n<script>\n/*\n  Interactive static typing simulation.\n  Very functional, minimal UI. The type system is simplified but supports\n  primitives, objects, arrays, unions, intersections, generics (basic aliasing),\n  nominal aliases, and basic structural vs nominal compatibility checking.\n*/\n\n// Utilities\nfunction cloneDeep(obj) { return JSON.parse(JSON.stringify(obj)); }\nfunction safeJsonParse(str) {\n  try { return JSON.parse(str); } catch (e) { return null; }\n}\nfunction trimLines(s) { return s.replace(/^\\\\s+|\\\\s+$/g,''); }\nfunction logPush(text) { logs.push(text); renderLogs(); }\nfunction now() { return new Date().toISOString().slice(11,23); }\n\n// Global state\nlet types = {}; // name -> typeObj\nlet variables = []; // array of {name, declared: typeName|null, valueRaw, valueHint, inferredType}\nlet history = []; // snapshots\nlet historyIndex = -1;\nlet logs = [];\nlet lastActionId = 0;\n\nconst ui = {\n  typeDefs: document.getElementById('typeDefs'),\n  btnParse: document.getElementById('btnParse'),\n  btnResetTypes: document.getElementById('btnResetTypes'),\n  typesList: document.getElementById('typesList'),\n  varName: document.getElementById('varName'),\n  varDeclaredType: document.getElementById('varDeclaredType'),\n  varValue: document.getElementById('varValue'),\n  varValueHint: document.getElementById('varValueHint'),\n  btnAddVar: document.getElementById('btnAddVar'),\n  btnClearVars: document.getElementById('btnClearVars'),\n  varsList: document.getElementById('varsList'),\n  typingMode: document.getElementById('typingMode'),\n  strictness: document.getElementById('strictness'),\n  strictnessValue: document.getElementById('strictnessValue'),\n  structural: document.getElementById('structural'),\n  enableInference: document.getElementById('enableInference'),\n  runtimeChecks: document.getElementById('runtimeChecks'),\n  btnInferAll: document.getElementById('btnInferAll'),\n  btnCheckAll: document.getElementById('btnCheckAll'),\n  btnAutoFix: document.getElementById('btnAutoFix'),\n  btnRefactorRename: document.getElementById('btnRefactorRename'),\n  btnUnionize: document.getElementById('btnUnionize'),\n  btnIntersect: document.getElementById('btnIntersect'),\n  typesDetailSelect: document.getElementById('typeDetailSelect'),\n  typeDetail: document.getElementById('typeDetail'),\n  varDetailSelect: document.getElementById('varDetailSelect'),\n  varDetail: document.getElementById('varDetail'),\n  btnInferVar: document.getElementById('btnInferVar'),\n  btnAssignToVar: document.getElementById('btnAssignToVar'),\n  assignExpr: document.getElementById('assignExpr'),\n  btnPrevHist: document.getElementById('btnPrevHist'),\n  btnNextHist: document.getElementById('btnNextHist'),\n  btnShowHistory: document.getElementById('btnShowHistory'),\n  btnClearHistory: document.getElementById('btnClearHistory'),\n  historyLog: document.getElementById('historyLog'),\n  log: document.getElementById('log'),\n};\n\n// Type representation helpers\nfunction makePrimitive(name) { return { kind: 'primitive', name }; }\nfunction makeObject(props) { return { kind: 'object', props }; }\nfunction makeUnion(members) { return { kind: 'union', members }; }\nfunction makeIntersection(members) { return { kind: 'intersection', members }; }\nfunction makeArray(elem) { return { kind: 'array', elem }; }\nfunction makeAlias(name, target, params, nominal=false) { return { kind: 'alias', name, target, params: params||[], nominal: !!nominal }; }\nfunction makeGenericInstance(name, args) { return { kind:'genericInstance', name, args }; }\nfunction makeFunction(pars, ret) { return { kind: 'function', params: pars, returnType: ret }; }\n\n// Parser: small recursive descent for type expressions\nfunction parseTypeDefinitions(text) {\n  const lines = text.split('\\\\n').map(l=>l.trim()).filter(l=>l && !l.startsWith('#'));\n  const localTypes = {};\n  const errors = [];\n  for (let line of lines) {\n    // accept \"type Name = expr\" or \"nominal Name = expr\"\n    let m = line.match(/^(type|nominal)\\\\s+([A-Za-z0-9_]+)(<[^>]+>)?\\\\s*=\\\\s*(.+)$/);\n    if (!m) { errors.push('Unrecognized line: ' + line); continue; }\n    let [, kind, name, typeParams, expr] = m;\n    let params = null;\n    if (typeParams) {\n      // parse <T,U>\n      params = typeParams.slice(1,-1).split(',').map(p=>p.trim()).filter(Boolean);\n    }\n    try {\n      const parsed = parseTypeExpr(expr, name);\n      if (kind === 'nominal') {\n        localTypes[name] = makeAlias(name, parsed, params, true);\n      } else {\n        localTypes[name] = makeAlias(name, parsed, params, false);\n      }\n    } catch (e) {\n      errors.push('Parse error in \"'+line+'\": '+e.message);\n    }\n  }\n  return { types: localTypes, errors };\n}\n\n// Tokenizer for type expr\nfunction tokenizeTypeExpr(s) {\n  const tokens = [];\n  const re = /\\\\s*([A-Za-z0-9_]+|\\\\{|\\\\}|\\\\(|\\\\)|\\\\[|\\\\]|<|>|:|,|\\\\||&|\\\\.|=>|->|\\\\?|=|\\\\*|\\\\+|\\\\-|\\\\+|\\\\[\\\\]|\\\\[|\\\\]|\\\\[\\\\]|\\\\[|\\\\]|\\\\[\\\\]|\\\\]|\\\\[|\\\\]|\\\\[|\\\\]|\\\\[|\\\\]|\\\\[|\\\\]|\\\\[|\\\\]|\\\\[|\\\\]|\\\\[|\\\\]|\\\\[|\\\\]|\\\\[|\\\\]|\\\\S)\\\\s*/g;\n  let m;\n  while ((m = re.exec(s)) !== null) {\n    tokens.push(m[1]);\n  }\n  return tokens;\n}\n\n// Improved tokenizer simpler:\nfunction lex(s) {\n  const out = [];\n  let i=0;\n  while (i<s.length) {\n    let c = s[i];\n    if (/\\s/.test(c)) { i++; continue; }\n    if (/[,:\\\\{\\\\}\\\\(\\\\)\\\\[\\\\]\\\\|&<>]/.test(c)) { out.push(c); i++; continue; }\n    // identifier or string\n    if (/[A-Za-z0-9_]/.test(c)) {\n      let j=i; while (j<s.length && /[A-Za-z0-9_]/.test(s[j])) j++;\n      out.push(s.slice(i,j)); i=j; continue;\n    }\n    // others\n    out.push(c); i++;\n  }\n  return out;\n}\n\nfunction parseTypeExpr(expr, contextName) {\n  const tokens = lex(expr);\n  let pos = 0;\n  function peek() { return tokens[pos]; }\n  function consume(t) {\n    if (t && peek() !== t) throw new Error('Expected \"'+t+'\", got \"'+peek()+'\" in \"'+expr+'\"');\n    const v = tokens[pos++];\n    return v;\n  }\n  function parsePrimary() {\n    let tk = peek();\n    if (!tk) throw new Error('Unexpected end while parsing \"'+expr+'\"');\n    if (tk === '{') {\n      consume('{');\n      const props = {};\n      while (peek() && peek() !== '}') {\n        const key = consume(); if (!key.match(/^[A-Za-z0-9_]+$/)) throw new Error('Invalid prop name: '+key);\n        consume(':');\n        const val = parseUnion();\n        props[key] = val;\n        if (peek() === ',') consume(',');\n      }\n      consume('}');\n      return makeObject(props);\n    }\n    if (tk === '(') {\n      consume('(');\n      const inside = parseUnion();\n      consume(')');\n      return inside;\n    }\n    // identifier or primitive\n    if (tk.match(/^[A-Za-z0-9_]+$/)) {\n      let id = consume();\n      // generics: < ... >\n      if (peek() === '<') {\n        consume('<');\n        const args = [];\n        while (peek() && peek() !== '>') {\n          args.push(parseUnion());\n          if (peek() === ',') consume(',');\n        }\n        consume('>');\n        // if id looks like built-in maybe treat specially; else generic instance reference\n        return makeGenericInstance(id, args);\n      }\n      // arrays like T []\n      if (peek() === '[' && tokens[pos+1] === ']') {\n        consume('['); consume(']');\n        let base = id;\n        // create type for array of id\n        // Represent as array whose element may be alias if id refers to alias later\n        return makeArray({ kind: 'aliasRef', name: id });\n      }\n      // primitives\n      if (['number','string','boolean','any','unknown','null','undefined','void'].includes(id)) {\n        return makePrimitive(id);\n      }\n      // bare alias reference\n      return { kind: 'aliasRef', name: id };\n    }\n    throw new Error('Unexpected token \"'+tk+'\" in \"'+expr+'\"');\n  }\n\n  function parseIntersection() {\n    let left = parsePrimary();\n    while (peek() === '&') {\n      consume('&');\n      let right = parsePrimary();\n      left = makeIntersection([left, right]);\n    }\n    return left;\n  }\n\n  function parseUnion() {\n    let left = parseIntersection();\n    while (peek() === '|') {\n      consume('|');\n      let right = parseIntersection();\n      left = makeUnion([left, right]);\n    }\n    return left;\n  }\n\n  const parsed = parseUnion();\n  if (pos < tokens.length) {\n    // trailing array '[]' handling like number[] or aliasRef handled above; if leftover tokens, complain\n    // But allow repeated [] tokens\n    while (peek() === '[' && tokens[pos+1] === ']') {\n      consume('['); consume(']');\n      parsed = makeArray(parsed);\n    }\n    if (pos < tokens.length) throw new Error('Unexpected token \"'+peek()+'\" in \"'+expr+'\"');\n  }\n  return parsed;\n}\n\n// Resolve alias references into actual types (deferred until needed)\nfunction resolveType(t, depth=0) {\n  if (!t || depth>200) return { kind:'unknown' };\n  if (t.kind === 'aliasRef') {\n    const def = types[t.name];\n    if (!def) {\n      // unresolved alias -> unknown\n      return { kind: 'unknown', name: t.name };\n    }\n    // create instance of alias.target; shallow clone and mark alias name\n    // If alias has params and this reference included generics not resolved, we leave as alias instance\n    if (def.params && def.params.length>0) {\n      // We don't have concrete args here, so produce a paramized alias instance\n      return { kind: 'aliasInstance', name: def.name, target: def.target, params: def.params, nominal: def.nominal };\n    }\n    // resolve the target recursively\n    const resolvedTarget = resolveType(def.target, depth+1);\n    // keep alias wrapper with nominal flag\n    return { kind: 'aliasWrap', name: def.name, target: resolvedTarget, nominal: def.nominal };\n  } else if (t.kind === 'alias') {\n    // immediate alias object from parse; resolve its inner target\n    const resolved = resolveType(t.target, depth+1);\n    return { kind: 'aliasWrap', name: t.name, target: resolved, nominal: t.nominal || false };\n  } else if (t.kind === 'genericInstance') {\n    // Attempt to instantiate generic by inlining args if the generic alias is known.\n    const def = types[t.name];\n    if (!def) return { kind: 'unknown', name: t.name };\n    if (!def.params || def.params.length !== t.args.length) {\n      // mismatched generics; keep as instance\n      return { kind: 'genericInstance', name: t.name, args: t.args.map(a=>resolveType(a, depth+1)) };\n    }\n    // Simple substitution: replace param occurrences inside def.target with provided args\n    const subst = (node) => {\n      if (!node) return node;\n      if (node.kind === 'aliasRef') {\n        const idx = def.params.indexOf(node.name);\n        if (idx >= 0) return resolveType(t.args[idx], depth+1);\n        return resolveType(node, depth+1);\n      } else if (node.kind === 'object') {\n        const p = {};\n        for (let k in node.props) p[k] = subst(node.props[k]);\n        return makeObject(p);\n      } else if (node.kind === 'union') {\n        return makeUnion(node.members.map(subst));\n      } else if (node.kind === 'intersection') {\n        return makeIntersection(node.members.map(subst));\n      } else if (node.kind === 'array') {\n        return makeArray(subst(node.elem));\n      } else if (node.kind === 'genericInstance') {\n        return { kind: 'genericInstance', name: node.name, args: node.args.map(subst) };\n      } else if (node.kind === 'alias') {\n        // nested alias with own params: leave as is\n        return { kind:'aliasWrap', name: node.name, target: subst(node.target), nominal: node.nominal };\n      } else {\n        return node;\n      }\n    };\n    const body = subst(def.target);\n    return resolveType(body, depth+1);\n  } else if (t.kind === 'object') {\n    const p = {};\n    for (let k in t.props) p[k] = resolveType(t.props[k], depth+1);\n    return makeObject(p);\n  } else if (t.kind === 'union') {\n    return makeUnion(t.members.map(m=>resolveType(m, depth+1)));\n  } else if (t.kind === 'intersection') {\n    return makeIntersection(t.members.map(m=>resolveType(m, depth+1)));\n  } else if (t.kind === 'array') {\n    return makeArray(resolveType(t.elem, depth+1));\n  } else {\n    return t;\n  }\n}\n\n// Type rendering for display\nfunction renderType(t) {\n  if (!t) return 'unknown';\n  if (t.kind === 'primitive') return t.name;\n  if (t.kind === 'object') {\n    const keys = Object.keys(t.props).map(k=>k+': '+renderType(t.props[k]));\n    return '{ ' + keys.join(', ') + ' }';\n  }\n  if (t.kind === 'union') return t.members.map(renderType).join(' | ');\n  if (t.kind === 'intersection') return t.members.map(renderType).join(' & ');\n  if (t.kind === 'array') return renderType(t.elem) + '[]';\n  if (t.kind === 'alias') return t.name + ' (alias)';\n  if (t.kind === 'aliasWrap') return t.name + ' = ' + renderType(t.target) + (t.nominal ? ' (nominal)' : '');\n  if (t.kind === 'aliasRef') return t.name;\n  if (t.kind === 'aliasInstance') return t.name + ' (instance)';\n  if (t.kind === 'genericInstance') return t.name + '<' + t.args.map(renderType).join(',') + '>';\n  if (t.kind === 'unknown') return 'unknown' + (t.name ? '('+t.name+')':'' );\n  if (t.kind === 'function') return '(' + t.params.map((p,i)=>('p'+i+':'+renderType(p))).join(',') + ') => ' + renderType(t.returnType);\n  return JSON.stringify(t);\n}\n\n// Compatibility / assignability check\nfunction isAssignable(from, to, ctx={structural:true, trace:[], depth:0}) {\n  // ctx: {structural: bool, trace: []}\n  if (ctx.depth > 200) { ctx.trace.push('Recursion limit'); return false; }\n  ctx.depth++;\n  function note(msg) { ctx.trace.push(msg); }\n  // Resolve aliases for better comparison except when nominal\n  const resolveForCheck = (x) => {\n    if (!x) return x;\n    if (x.kind === 'aliasWrap') {\n      // If target is nominal and other is not same alias, then keep alias\n      return x;\n    }\n    return resolveType(x);\n  };\n  let A = from, B = to;\n  // If B is aliasWrap (named type), and B.nominal true and ctx.structural false => require same alias name\n  if (B && B.kind === 'aliasWrap' && B.nominal && !ctx.structural) {\n    // match only if A is aliasWrap of same name or aliasRef of same name\n    if ((A && A.kind === 'aliasWrap' && A.name === B.name) || (A && A.kind === 'aliasRef' && A.name === B.name)) {\n      note('Nominal match by name ' + B.name);\n      ctx.depth--; return true;\n    } else {\n      note('Nominal mismatch: target requires ' + B.name);\n      ctx.depth--; return false;\n    }\n  }\n\n  // For aliasWraps treat as underlying target for structural comparison\n  if (A && A.kind === 'aliasWrap') A = A.target;\n  if (B && B.kind === 'aliasWrap') B = B.target;\n\n  if (!A || !B) { note('One side unknown -> not assignable'); ctx.depth--; return false; }\n\n  if (B.kind === 'primitive') {\n    if (A.kind === 'primitive' && (A.name === B.name || B.name === 'any' || A.name === 'any' || B.name === 'unknown')) { note('primitive match ' + A.name + ' -> ' + B.name); ctx.depth--; return true; }\n    // Allow numeric coercion option? for demo treat number<->string as incompatible\n    note('primitive mismatch: ' + (A.name||A.kind) + ' -> ' + B.name);\n    ctx.depth--; return false;\n  }\n\n  if (B.kind === 'unknown' || B.kind === 'primitive' && B.name === 'any') { note('target is any/unknown: allow'); ctx.depth--; return true; }\n\n  if (B.kind === 'union') {\n    // from assignable to any member\n    for (let m of B.members) {\n      const localTrace = [];\n      const subctx = {structural: ctx.structural, trace: localTrace, depth: ctx.depth+1};\n      if (isAssignable(A, m, subctx)) { note('matches union member: ' + renderType(m)); ctx.depth--; return true; }\n    }\n    note('no union member matched');\n    ctx.depth--; return false;\n  }\n\n  if (B.kind === 'intersection') {\n    // from must satisfy all members\n    for (let m of B.members) {\n      const localTrace = [];\n      const subctx = {structural: ctx.structural, trace: localTrace, depth: ctx.depth+1};\n      if (!isAssignable(A, m, subctx)) { note('fails intersection member: ' + renderType(m)); ctx.depth--; return false; }\n    }\n    note('satisfies intersection');\n    ctx.depth--; return true;\n  }\n\n  if (B.kind === 'array') {\n    if (A.kind === 'array') {\n      const ok = isAssignable(A.elem, B.elem, ctx);\n      note('array element assignable: ' + ok);\n      ctx.depth--; return ok;\n    } else {\n      note('not array -> cannot assign');\n      ctx.depth--; return false;\n    }\n  }\n\n  if (B.kind === 'object') {\n    if (A.kind !== 'object') { note('source not object'); ctx.depth--; return false; }\n    // For each property in B, ensure A has compatible prop\n    for (let k in B.props) {\n      if (!(k in A.props)) { note('missing property ' + k); ctx.depth--; return false; }\n      const ok = isAssignable(A.props[k], B.props[k], ctx);\n      if (!ok) { note('property ' + k + ' incompatible'); ctx.depth--; return false; }\n    }\n    note('object structural match');\n    ctx.depth--; return true;\n  }\n\n  if (B.kind === 'function') {\n    if (A.kind !== 'function') { note('source not function'); ctx.depth--; return false; }\n    // contravariant parameters, covariant returns (simple check)\n    if (A.params.length !== B.params.length) { note('function arity mismatch'); ctx.depth--; return false; }\n    for (let i=0;i<B.params.length;i++) {\n      // target param must be assignable from source param? for contravariant: B.param <= A.param (A param should accept more)\n      const ok = isAssignable(B.params[i], A.params[i], ctx);\n      if (!ok) { note('param ' + i + ' incompatible'); ctx.depth--; return false; }\n    }\n    const retOk = isAssignable(A.returnType, B.returnType, ctx);\n    if (!retOk) { note('return type incompatible'); ctx.depth--; return false; }\n    note('function match');\n    ctx.depth--; return true;\n  }\n\n  // fallback\n  note('unhandled type comparison: ' + B.kind + ' vs ' + A.kind);\n  ctx.depth--; return false;\n}\n\n// Inference from value string\nfunction inferTypeFromValue(valueRaw, hint) {\n  const s = (valueRaw||'').trim();\n  if (!s) return null;\n  // If hint provided, try parse hint as type name or expr\n  if (hint) {\n    // if hint matches existing type name\n    if (types[hint]) return resolveType(types[hint]);\n    try { return parseTypeExpr(hint); } catch (e) { /* ignore */ }\n  }\n  // try JSON\n  try {\n    const parsed = JSON.parse(s);\n    return inferTypeFromJsValue(parsed);\n  } catch (e) {\n    // not JSON - try simple numeric/boolean/literal forms\n    if (/^\\\\d+(\\\\.\\\\d+)?$/.test(s)) return makePrimitive('number');\n    if (s === 'true' || s === 'false') return makePrimitive('boolean');\n    if ((s.startsWith('\"') && s.endsWith('\"')) || (s.startsWith(\"'\") && s.endsWith(\"'\"))) return makePrimitive('string');\n    // function hint: fn(x:number):number\n    const fm = s.match(/^fn\\\\s*\\\\(([^)]*)\\\\)\\\\s*:\\\\s*([A-Za-z0-9_\\\\[\\\\]\\\\<\\\\>\\\\s\\\\,\\\\{\\\\}:|&]+)$/);\n    if (fm) {\n      const params = fm[1].split(',').map(x=>x.trim()).filter(Boolean);\n      const ptypes = params.map(p=>{\n        const m = p.split(':');\n        if (m.length===2) return parseTypeExpr(m[1].trim());\n        return makePrimitive('any');\n      });\n      const ret = parseTypeExpr(fm[2].trim());\n      return makeFunction(ptypes, ret);\n    }\n    // try arrow like \"(x:number)=>number\"\n    const arrMatch = s.match(/\\\\((.*)\\\\)\\\\s*=>\\\\s*([^\\\\s]+)/);\n    if (arrMatch) {\n      const params = arrMatch[1].split(',').map(x=>x.trim()).filter(Boolean);\n      const ptypes = params.map(p=>{\n        const m = p.split(':');\n        if (m.length===2) return parseTypeExpr(m[1].trim());\n        return makePrimitive('any');\n      });\n      const retTypeName = arrMatch[2];\n      let retType = makePrimitive('any');\n      try { retType = parseTypeExpr(retTypeName); } catch(e){}\n      return makeFunction(ptypes, retType);\n    }\n    // fallback to string\n    return makePrimitive('string');\n  }\n\n  function inferTypeFromJsValue(v) {\n    if (v === null) return makePrimitive('null');\n    if (Array.isArray(v)) {\n      if (v.length === 0) return makeArray(makePrimitive('any'));\n      // infer element type union\n      let elemTypes = v.map(inferTypeFromJsValue);\n      // reduce to common type if equal, else union\n      if (elemTypes.every((et)=>renderType(et) === renderType(elemTypes[0]))) {\n        return makeArray(elemTypes[0]);\n      } else {\n        return makeArray(makeUnion(elemTypes));\n      }\n    }\n    if (typeof v === 'number') return makePrimitive('number');\n    if (typeof v === 'string') return makePrimitive('string');\n    if (typeof v === 'boolean') return makePrimitive('boolean');\n    if (typeof v === 'object') {\n      const props = {};\n      for (let k in v) props[k] = inferTypeFromJsValue(v[k]);\n      return makeObject(props);\n    }\n    return makePrimitive('unknown');\n  }\n}\n\n// Rendering functions\nfunction renderTypesList() {\n  const lines = [];\n  for (let name in types) {\n    const t = types[name];\n    lines.push(name + (t.params && t.params.length ? '<' + t.params.join(',') + '>' : '') + (t.nominal ? ' (nominal)' : '') + ' = ' + renderType(t.target));\n  }\n  ui.typesList.textContent = lines.length ? lines.join('\\\\n') : '(no types defined)';\n  // populate selects\n  const sel = ui.varDeclaredType;\n  sel.innerHTML = '<option value=\"\">(none)</option>';\n  const sel2 = ui.typeDetailSelect;\n  sel2.innerHTML = '<option value=\"\">(choose)</option>';\n  for (let n in types) {\n    const o = document.createElement('option'); o.value = n; o.textContent = n; sel.appendChild(o);\n    const p = document.createElement('option'); p.value = n; p.textContent = n; sel2.appendChild(p);\n  }\n}\n\n// Variable list rendering\nfunction renderVarsList() {\n  const lines = [];\n  for (let v of variables) {\n    const declared = v.declared || '(none)';\n    const inferredText = v.inferredType ? renderType(v.inferredType) : '(not inferred)';\n    lines.push(v.name + ' : declared=' + declared + ' ; inferred=' + inferredText + ' ; value=' + (v.valueRaw||''));\n  }\n  ui.varsList.textContent = lines.length ? lines.join('\\\\n') : '(none)';\n  const sel = ui.varDetailSelect;\n  sel.innerHTML = '<option value=\"\">(choose)</option>';\n  for (let v of variables) {\n    const o = document.createElement('option'); o.value = v.name; o.textContent = v.name; sel.appendChild(o);\n  }\n}\n\n// History\nfunction pushHistory(actionDescription) {\n  const snapshot = {\n    types: cloneDeep(types),\n    variables: cloneDeep(variables),\n    action: actionDescription,\n    time: now(),\n    id: ++lastActionId\n  };\n  // truncate future if navigated\n  if (historyIndex < history.length-1) history = history.slice(0, historyIndex+1);\n  history.push(snapshot);\n  historyIndex = history.length - 1;\n  renderHistory();\n}\n\nfunction renderHistory() {\n  ui.historyLog.textContent = history.map((h,i)=> (i===historyIndex?'* ':'  ') + '['+h.time+'] '+h.action).reverse().join('\\\\n');\n}\n\nfunction applyHistoryIndex(i) {\n  if (i < 0 || i >= history.length) return;\n  const snap = history[i];\n  types = cloneDeep(snap.types);\n  variables = cloneDeep(snap.variables);\n  historyIndex = i;\n  renderTypesList(); renderVarsList(); renderHistory(); logPush('Rewound to: '+snap.action);\n}\n\n// Checks and inference operations\nfunction inferAll() {\n  const enabled = ui.enableInference.checked;\n  if (!enabled) { logPush('Inference disabled in settings.'); return; }\n  for (let v of variables) {\n    const inferred = inferTypeFromValue(v.valueRaw, v.valueHint);\n    v.inferredType = inferred ? resolveType(inferred) : null;\n  }\n  pushHistory('Infer All types');\n  renderVarsList();\n  logPush('All variables inferred (where possible).');\n}\n\nfunction checkAllAssignments() {\n  const structural = ui.structural.checked;\n  const mode = ui.typingMode.value;\n  logs = []; // reset for detailed build\n  for (let v of variables) {\n    const declared = v.declared ? resolveType(types[v.declared]) : null;\n    let fromType = v.inferredType;\n    if (!fromType) {\n      fromType = inferTypeFromValue(v.valueRaw, v.valueHint);\n      if (fromType) fromType = resolveType(fromType);\n    }\n    if (!declared) {\n      // no declared type, in strict static mode warn\n      if (mode === 'static') {\n        logPush('Variable ' + v.name + ' has no declared type. In static mode this is a potential issue.');\n      } else {\n        logPush('Variable ' + v.name + ' unchecked (no declared type in ' + mode + ' mode).');\n      }\n      continue;\n    }\n    const ctx = {structural: structural, trace: []};\n    const ok = isAssignable(fromType, declared, ctx);\n    let msg = 'Check: ' + v.name + ' <- declared ' + v.declared + ' : ';\n    if (ok) msg += 'OK';\n    else msg += 'TYPE ERROR';\n    logPush(msg);\n    for (let t of ctx.trace) logPush('  - ' + t);\n  }\n  pushHistory('Check All Assignments');\n}\n\n// Auto-fix suggestions: simple heuristics\nfunction autoFix() {\n  // For each variable with declared type but not assignable, try to propose changes:\n  const structural = ui.structural.checked;\n  const suggestions = [];\n  for (let v of variables) {\n    if (!v.declared) continue;\n    const declared = resolveType(types[v.declared]);\n    const fromType = v.inferredType || resolveType(inferTypeFromValue(v.valueRaw, v.valueHint));\n    const ctx = {structural: structural, trace: []};\n    const ok = isAssignable(fromType, declared, ctx);\n    if (!ok) {\n      // Suggest casting to a union with declared type or widening declared to any/object\n      if (declared.kind === 'object' && fromType && fromType.kind === 'object') {\n        // propose adding missing properties to declared type\n        const missing = [];\n        for (let k in fromType.props) if (!(k in declared.props)) missing.push(k);\n        if (missing.length) {\n          suggestions.push('Suggest adding properties ' + missing.join(', ') + ' to declared type ' + v.declared + ' to match ' + v.name);\n        } else {\n          suggestions.push('Unable to auto-fix ' + v.name + ' -> ' + v.declared + ', mismatched shapes.');\n        }\n      } else {\n        suggestions.push('Suggest changing declared type of ' + v.name + ' to a union including ' + renderType(fromType));\n      }\n    }\n  }\n  if (!suggestions.length) suggestions.push('No fixes proposed.');\n  for (let s of suggestions) logPush(s);\n  pushHistory('Auto-fix suggestions generated');\n}\n\n// Refactor: rename property across types\nfunction refactorRenameProperty() {\n  const typeNames = Object.keys(types);\n  if (!typeNames.length) { logPush('No types to refactor'); return; }\n  const name = prompt('Type to refactor (name):\\\\nAvailable: ' + typeNames.join(', '));\n  if (!name || !types[name]) { logPush('Canceled or unknown type'); return; }\n  const from = prompt('Property to rename (in ' + name + '):');\n  if (!from) { logPush('Canceled'); return; }\n  const to = prompt('New property name:');\n  if (!to) { logPush('Canceled'); return; }\n  // apply rename to any type that references property with that name (structural)\n  for (let n in types) {\n    const t = types[n];\n    const resolved = t.target;\n    // simple recursive rename in object shapes only for def targets\n    function renameIn(node) {\n      if (!node) return;\n      if (node.kind === 'object') {\n        if (node.props && node.props[from]) {\n          node.props[to] = node.props[from];\n          delete node.props[from];\n          logPush('Renamed property in type ' + n);\n        }\n        for (let k in node.props) renameIn(node.props[k]);\n      } else if (node.kind === 'union' || node.kind === 'intersection') {\n        for (let m of node.members) renameIn(m);\n      } else if (node.kind === 'array') renameIn(node.elem);\n      else if (node.kind === 'alias') renameIn(node.target);\n    }\n    renameIn(t.target);\n  }\n  pushHistory('Refactor rename ' + from + ' -> ' + to + ' in type ' + name);\n  renderTypesList();\n  logPush('Refactor complete: ' + from + ' renamed to ' + to);\n}\n\n// Unionize selected types: merge names into a new union alias\nfunction unionizeTypes() {\n  const names = prompt('Comma-separated type names to unionize:');\n  if (!names) return;\n  const arr = names.split(',').map(s=>s.trim()).filter(Boolean);\n  const newName = prompt('New type name for union:');\n  if (!newName) return;\n  const members = arr.map(n => ({ kind: 'aliasRef', name: n }));\n  types[newName] = makeAlias(newName, makeUnion(members), null, false);\n  pushHistory('Unionize into ' + newName);\n  renderTypesList();\n  logPush('Created union type ' + newName + ' = ' + arr.join(' | '));\n}\n\nfunction intersectTypes() {\n  const names = prompt('Comma-separated type names to intersect:');\n  if (!names) return;\n  const arr = names.split(',').map(s=>s.trim()).filter(Boolean);\n  const newName = prompt('New type name for intersection:');\n  if (!newName) return;\n  const members = arr.map(n => ({ kind: 'aliasRef', name: n }));\n  types[newName] = makeAlias(newName, makeIntersection(members), null, false);\n  pushHistory('Intersect into ' + newName);\n  renderTypesList();\n  logPush('Created intersection type ' + newName + ' = ' + arr.join(' & '));\n}\n\n// Assign expression to a variable (simulate assignment + check)\nfunction assignExprToVar(varName, expr) {\n  const v = variables.find(x=>x.name===varName);\n  if (!v) { logPush('Unknown variable'); return; }\n  // If expr refers to another variable name, take its inferred type and valueRaw\n  const other = variables.find(x=>x.name===expr);\n  let rightType = null;\n  let rightValueRaw = expr;\n  if (other) {\n    rightType = other.inferredType || inferTypeFromValue(other.valueRaw, other.valueHint);\n    rightValueRaw = other.valueRaw;\n  } else {\n    // try to infer rightType from literal/JSON\n    rightType = inferTypeFromValue(expr, null);\n  }\n  // perform assignability check\n  const declared = v.declared ? resolveType(types[v.declared]) : null;\n  const structural = ui.structural.checked;\n  const ctx = { structural: structural, trace: [] };\n  if (!declared) {\n    // In static mode, assignment without declared type is a potential problem\n    if (ui.typingMode.value === 'static') {\n      logPush('Assignment to ' + varName + ' has no declared type; consider adding one. Value inferred as: ' + renderType(rightType));\n      v.valueRaw = rightValueRaw;\n      v.inferredType = resolveType(rightType);\n      pushHistory('Assign expression to ' + varName + ' (no declared type)');\n      renderVarsList();\n      return;\n    } else {\n      v.valueRaw = rightValueRaw;\n      v.inferredType = resolveType(rightType);\n      pushHistory('Assign expression to ' + varName);\n      renderVarsList();\n      logPush('Assigned (no declared type) ' + varName + ' = ' + expr);\n      return;\n    }\n  }\n  const ok = isAssignable(rightType, declared, ctx);\n  if (ok) {\n    v.valueRaw = rightValueRaw;\n    v.inferredType = resolveType(rightType);\n    logPush('Assignment OK: ' + varName + ' = ' + expr);\n    for (let t of ctx.trace) logPush('  - ' + t);\n    pushHistory('Assign expression to ' + varName + ' (ok)');\n  } else {\n    logPush('Type ERROR on assignment to ' + varName + ':');\n    for (let t of ctx.trace) logPush('  - ' + t);\n    if (ui.runtimeChecks.checked) {\n      // simulate runtime guard\n      const accept = confirm('Runtime checks enabled. Perform runtime guard (wrap check) to allow assignment at runtime?');\n      if (accept) {\n        v.valueRaw = rightValueRaw;\n        v.inferredType = resolveType(rightType);\n        pushHistory('Assign with runtime guard to ' + varName);\n        logPush('Assigned under runtime guard. Static mismatch remains.');\n      } else {\n        logPush('Assignment aborted.');\n      }\n    } else {\n      logPush('Assignment rejected (static mode).');\n    }\n  }\n  renderVarsList();\n}\n\n// UI event wiring\nui.btnParse.addEventListener('click', ()=> {\n  const txt = ui.typeDefs.value;\n  const res = parseTypeDefinitions(txt);\n  if (res.errors.length) {\n    for (let e of res.errors) logPush('Parse error: ' + e);\n  }\n  // merge parsed types into types map\n  for (let k in res.types) types[k] = res.types[k];\n  renderTypesList();\n  pushHistory('Parsed types');\n  logPush('Types parsed.');\n});\n\nui.btnResetTypes.addEventListener('click', ()=> {\n  const confirmed = confirm('Reset all parsed types? This will clear types and may break variables.');\n  if (!confirmed) return;\n  types = {};\n  renderTypesList();\n  pushHistory('Reset types');\n  logPush('Types cleared.');\n});\n\nui.btnAddVar.addEventListener('click', ()=> {\n  const name = (ui.varName.value||'').trim();\n  if (!name) { alert('Enter variable name'); return; }\n  if (variables.find(v=>v.name===name)) { alert('Variable already exists'); return; }\n  const declared = ui.varDeclaredType.value || null;\n  const valueRaw = ui.varValue.value || '';\n  const valueHint = ui.varValueHint.value || '';\n  const inferred = (ui.enableInference.checked) ? resolveType(inferTypeFromValue(valueRaw, valueHint)) : null;\n  variables.push({ name, declared, valueRaw, valueHint, inferredType: inferred });\n  ui.varName.value=''; ui.varValue.value=''; ui.varValueHint.value='';\n  renderVarsList();\n  pushHistory('Add variable ' + name);\n  logPush('Added variable ' + name + ' declared=' + (declared||'(none)') );\n});\n\nui.btnClearVars.addEventListener('click', ()=> {\n  if (!confirm('Clear all variables?')) return;\n  variables = [];\n  renderVarsList();\n  pushHistory('Clear variables');\n  logPush('Variables cleared.');\n});\n\nui.strictness.addEventListener('input', ()=> {\n  ui.strictnessValue.textContent = ui.strictness.value;\n});\n\nui.btnInferAll.addEventListener('click', ()=> {\n  inferAll();\n});\n\nui.btnCheckAll.addEventListener('click', ()=> {\n  checkAllAssignments();\n});\n\nui.btnAutoFix.addEventListener('click', ()=> {\n  autoFix();\n});\n\nui.btnRefactorRename.addEventListener('click', ()=> {\n  refactorRenameProperty();\n});\n\nui.btnUnionize.addEventListener('click', ()=> {\n  unionizeTypes();\n});\n\nui.btnIntersect.addEventListener('click', ()=> {\n  intersectTypes();\n});\n\nui.typesDetailSelect.addEventListener('change', ()=> {\n  const name = ui.typesDetailSelect.value;\n  if (!name) { ui.typeDetail.textContent='(choose a type)'; return; }\n  const t = types[name];\n  ui.typeDetail.textContent = name + (t.params && t.params.length ? '<' + t.params.join(',') + '>' : '') + (t.nominal ? ' (nominal)' : '') + ' = ' + renderType(resolveType(t.target));\n});\n\nui.varDetailSelect.addEventListener('change', ()=> {\n  const n = ui.varDetailSelect.value;\n  if (!n) { ui.varDetail.textContent='(choose a variable)'; return; }\n  const v = variables.find(x=>x.name===n);\n  const lines = [];\n  lines.push('name: ' + v.name);\n  lines.push('declared: ' + (v.declared||'(none)'));\n  lines.push('valueRaw: ' + v.valueRaw);\n  lines.push('valueHint: ' + v.valueHint);\n  lines.push('inferred: ' + (v.inferredType ? renderType(v.inferredType) : '(none)'));\n  ui.varDetail.textContent = lines.join('\\\\n');\n});\n\nui.btnInferVar.addEventListener('click', ()=> {\n  const n = ui.varDetailSelect.value;\n  if (!n) { alert('Pick a variable'); return; }\n  const v = variables.find(x=>x.name===n);\n  const t = inferTypeFromValue(v.valueRaw, v.valueHint);\n  v.inferredType = t ? resolveType(t) : null;\n  renderVarsList(); ui.varDetailSelect.dispatchEvent(new Event('change'));\n  pushHistory('Infer variable ' + n);\n  logPush('Inferred ' + n + ' as ' + (v.inferredType ? renderType(v.inferredType) : '(unknown)'));\n});\n\nui.btnAssignToVar.addEventListener('click', ()=> {\n  const n = ui.varDetailSelect.value;\n  if (!n) { alert('Pick a variable'); return; }\n  const expr = ui.assignExpr.value || '';\n  if (!expr) { alert('Enter expression or variable name to assign from'); return; }\n  assignExprToVar(n, expr);\n  ui.varDetailSelect.dispatchEvent(new Event('change'));\n});\n\nui.btnPrevHist.addEventListener('click', ()=> {\n  if (historyIndex > 0) applyHistoryIndex(historyIndex-1);\n});\n\nui.btnNextHist.addEventListener('click', ()=> {\n  if (historyIndex < history.length-1) applyHistoryIndex(historyIndex+1);\n});\n\nui.btnShowHistory.addEventListener('click', ()=> {\n  renderHistory();\n  alert('History shown in the right panel.');\n});\n\nui.btnClearHistory.addEventListener('click', ()=> {\n  if (!confirm('Clear history?')) return;\n  history = []; historyIndex = -1;\n  renderHistory(); logPush('History cleared.');\n});\n\n// Initial small demo setup\n(function initDemo() {\n  // pre-parse initial defs\n  ui.btnParse.click();\n  // add a couple demo variables\n  variables.push({ name: 'a', declared: 'Person', valueRaw: '{\"name\":\"Anna\",\"age\":28}', valueHint:'', inferredType: null });\n  variables.push({ name: 'b', declared: 'Admin', valueRaw: '{\"name\":\"Bob\",\"age\":40,\"role\":\"ops\"}', valueHint:'', inferredType: null });\n  variables.push({ name: 'id', declared: 'UserId', valueRaw: '\"abc123\"', valueHint:'', inferredType: null });\n  renderVarsList();\n  pushHistory('Initial demo state');\n  logPush('Demo initialized with sample variables. Use controls to explore.');\n})();\n\n// Render logs\nfunction renderLogs() {\n  ui.log.textContent = logs.join('\\\\n') || '(no messages)';\n}\n\n// initial render\nrenderTypesList();\nrenderVarsList();\nrenderHistory();\nrenderLogs();\n</script>\n\n</body>\n</html>"
