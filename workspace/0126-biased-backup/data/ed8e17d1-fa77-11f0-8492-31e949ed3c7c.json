    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Programming Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #74EBD5 0%, #ACB6E5 100%);\n            color: #333;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n\n        .container {\n            text-align: center;\n            border-radius: 15px;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);\n            background-color: white;\n            padding: 40px;\n            width: 80%;\n            max-width: 600px;\n            animation: fadeIn 1s;\n        }\n\n        @keyframes fadeIn {\n            from {\n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        h1 {\n            font-size: 2.5rem;\n            color: #5C4D7D;\n            margin-bottom: 20px;\n        }\n\n        p {\n            font-size: 1.2rem;\n            line-height: 1.6;\n            margin-bottom: 30px;\n        }\n\n        .button {\n            background-color: #5C4D7D;\n            color: white;\n            border: none;\n            padding: 15px 30px;\n            border-radius: 5px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: background 0.3s ease;\n        }\n\n        .button:hover {\n            background-color: #7C6C99;\n        }\n\n        .grid {\n            display: grid;\n            grid-template-columns: repeat(5, 1fr);\n            grid-gap: 15px;\n            margin-top: 20px;\n        }\n\n        .cell {\n            width: 50px;\n            height: 50px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            border-radius: 10px;\n            background-color: #8E9BFF;\n            color: white;\n            font-size: 1.2rem;\n            transition: transform 0.3s ease;\n        }\n\n        .cell:hover {\n            transform: scale(1.1);\n        }\n    </style>\n</head>\n\n<body>\n    <div class=\"container\">\n        <h1>Dynamic Programming Visualization</h1>\n        <p>Watch the magic of solving complex problems step-by-step using Dynamic Programming!</p>\n        <button class=\"button\" id=\"startButton\">Start Visualization</button>\n        <div class=\"grid\" id=\"grid\"></div>\n    </div>\n\n    <script>\n        const gridElement = document.getElementById('grid');\n        const startButton = document.getElementById('startButton');\n\n        const fibonacci = (n) => {\n            const fib = [0, 1];\n\n            for (let i = 2; i <= n; i++) {\n                fib[i] = fib[i - 1] + fib[i - 2];\n                animateCell(i, fib[i]);\n            }\n            return fib[n];\n        };\n\n        const animateCell = (index, value) => {\n            const cell = document.createElement('div');\n            cell.className = 'cell';\n            cell.innerText = value;\n            gridElement.appendChild(cell);\n\n            // Fade-in animation for each cell\n            cell.animate([\n                { opacity: 0 },\n                { opacity: 1 }\n            ], {\n                duration: 500,\n                fill: 'forwards'\n            });\n        };\n\n        startButton.onclick = () => {\n            gridElement.innerHTML = ''; // Clear previous grid\n            fibonacci(10); // Start visualizing the first 10 Fibonacci numbers\n        };\n    </script>\n</body>\n\n</html>"
