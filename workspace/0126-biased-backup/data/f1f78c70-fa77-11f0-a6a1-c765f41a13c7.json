    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Mutex — Visualized</title>\n<style>\n  :root{\n    --bg-1: #0f1724;\n    --bg-2: #071025;\n    --accent: #7ce7d9;\n    --accent-2: #7b61ff;\n    --muted: #a6b0c3;\n    --glass: rgba(255,255,255,0.06);\n    --glass-2: rgba(255,255,255,0.03);\n    --success: #60d394;\n    --danger: #ff6b6b;\n    --gold: #ffd166;\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    --radius: 18px;\n    font-synthesis: none;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    * { transition: none !important; animation: none !important; }\n  }\n\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(123,97,255,0.10), transparent 8%),\n                radial-gradient(800px 400px at 90% 80%, rgba(124,231,217,0.06), transparent 6%),\n                linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color: #e6eef8;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 40px;\n  }\n\n  .container {\n    width: 100%;\n    max-width: 1100px;\n    position: relative;\n    padding: 48px;\n    border-radius: calc(var(--radius) + 8px);\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    box-shadow: var(--shadow);\n    overflow: hidden;\n    backdrop-filter: blur(8px) saturate(120%);\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n\n  .header {\n    display:flex;\n    align-items:center;\n    gap:18px;\n    margin-bottom: 28px;\n  }\n\n  .logo {\n    width:78px;\n    height:78px;\n    border-radius: 18px;\n    background: linear-gradient(135deg, rgba(123,97,255,0.18), rgba(124,231,217,0.08));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 8px 30px rgba(124,97,255,0.08), inset 0 -6px 18px rgba(0,0,0,0.25);\n    position:relative;\n    overflow:visible;\n  }\n\n  .logo svg { filter: drop-shadow(0 8px 30px rgba(0,0,0,0.38)); }\n\n  h1 {\n    margin: 0;\n    font-size: 20px;\n    letter-spacing: -0.02em;\n    color: #f6fbff;\n    font-weight: 700;\n  }\n\n  p.lead {\n    margin: 0;\n    color: var(--muted);\n    font-size: 13px;\n    margin-top: 6px;\n  }\n\n  .main {\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap: 28px;\n    align-items: stretch;\n  }\n\n  .scene {\n    position: relative;\n    height: 520px;\n    border-radius: 14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    padding: 28px;\n    overflow: visible;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Decorative blurred shapes */\n  .scene::before, .scene::after {\n    content: \"\";\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(60px) saturate(120%);\n    opacity: 0.9;\n    pointer-events:none;\n  }\n  .scene::before {\n    width: 420px;\n    height: 420px;\n    left: -120px;\n    top: -80px;\n    background: radial-gradient(circle at 30% 30%, rgba(123,97,255,0.22), transparent 30%),\n                radial-gradient(circle at 70% 70%, rgba(124,231,217,0.06), transparent 40%);\n    mix-blend-mode: screen;\n  }\n  .scene::after {\n    width: 360px;\n    height: 360px;\n    right: -120px;\n    bottom: -120px;\n    background: radial-gradient(circle at 40% 30%, rgba(124,231,217,0.08), transparent 30%),\n                radial-gradient(circle at 70% 70%, rgba(255,209,102,0.05), transparent 20%);\n  }\n\n  /* Mutex visual */\n  .arena {\n    width: 720px;\n    height: 420px;\n    position: relative;\n    transform: translateY(-8px);\n  }\n\n  /* resource area */\n  .resource {\n    width: 220px;\n    height: 220px;\n    border-radius: 20px;\n    position: absolute;\n    right: 40px;\n    top: 100px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-direction:column;\n    box-shadow: 0 18px 60px rgba(1,7,18,0.6);\n    transition: transform 0.6s cubic-bezier(.2,.9,.2,1);\n  }\n\n  .resource .core {\n    width: 120px;\n    height: 120px;\n    border-radius: 14px;\n    background: linear-gradient(160deg, rgba(124,231,217,0.08), rgba(123,97,255,0.04));\n    border: 1px solid rgba(255,255,255,0.04);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-weight:700;\n    color: var(--muted);\n    font-size: 13px;\n    letter-spacing: 0.02em;\n    position:relative;\n    box-shadow: inset 0 -8px 40px rgba(0,0,0,0.35);\n  }\n  .resource .label {\n    margin-top: 12px;\n    color: var(--muted);\n    font-size: 12px;\n  }\n\n  /* mutex lock in the center-left */\n  .mutex {\n    position: absolute;\n    left: 80px;\n    top: 60px;\n    width: 220px;\n    height: 220px;\n    border-radius: 24px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border: 1px solid rgba(255,255,255,0.03);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 20px 60px rgba(1,6,20,0.55);\n  }\n\n  .lock-plate {\n    width: 140px;\n    height: 140px;\n    border-radius: 20px;\n    background: linear-gradient(160deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n  }\n\n  .shackle {\n    width: 68px;\n    height: 68px;\n    position:absolute;\n    top:-34px;\n    left:50%;\n    transform: translateX(-50%) rotate(0deg);\n    transform-origin: center bottom;\n    transition: transform 0.55s cubic-bezier(.2,.9,.2,1);\n  }\n\n  .shackle path {\n    stroke: linear-gradient(90deg,var(--accent),var(--accent-2));\n  }\n\n  .lock-body {\n    width: 82px;\n    height: 82px;\n    border-radius: 12px;\n    background: linear-gradient(180deg, rgba(123,97,255,0.14), rgba(124,231,217,0.05));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 12px 40px rgba(2,6,23,0.45), inset 0 -8px 18px rgba(0,0,0,0.35);\n  }\n\n  .keyhole {\n    width: 22px;\n    height: 32px;\n    background: radial-gradient(circle at 40% 30%, rgba(0,0,0,0.7), rgba(0,0,0,0.5) 30%);\n    border-radius: 6px;\n    position:relative;\n    display:block;\n    box-shadow: inset 0 -4px 8px rgba(0,0,0,0.5);\n  }\n  .keyhole::after {\n    content:'';\n    position:absolute;\n    left:50%;\n    top: 58%;\n    width: 10px;\n    height: 8px;\n    transform: translateX(-50%);\n    border-radius: 2px;\n    background: rgba(255,255,255,0.02);\n    box-shadow: 0 2px 6px rgba(0,0,0,0.6);\n  }\n\n  /* lock states */\n  .mutex.locked .shackle { transform: translateX(-50%) rotate(-8deg) translateY(2px); }\n  .mutex.locked .lock-body { box-shadow: 0 6px 18px rgba(2,6,23,0.45), inset 0 -6px 12px rgba(0,0,0,0.45); }\n  .mutex.unlocked .shackle { transform: translateX(-50%) rotate(18deg) translateY(-6px); }\n\n  /* Threads / Processes */\n  .lane {\n    position:absolute;\n    left: 40px;\n    top: 280px;\n    width: 580px;\n    height: 120px;\n    border-radius: 12px;\n    display:flex;\n    align-items:center;\n    gap:10px;\n    padding: 8px 12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    border: 1px solid rgba(255,255,255,0.02);\n    box-shadow: inset 0 -12px 40px rgba(0,0,0,0.2);\n    overflow:visible;\n  }\n\n  .lane .path {\n    position:absolute;\n    left: 20px;\n    top: -112px;\n    width: 1px;\n    height: 1px;\n    pointer-events:none;\n    opacity:0;\n  }\n\n  .process {\n    width: 56px;\n    height: 56px;\n    border-radius: 50%;\n    background: linear-gradient(135deg, rgba(124,231,217,0.18), rgba(123,97,255,0.08));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    font-weight:700;\n    color: #051023;\n    font-size: 12px;\n    box-shadow: 0 12px 30px rgba(2,6,23,0.5);\n    position:absolute;\n    left: 40px; top: 300px;\n    transform: translate3d(0,0,0);\n    transition: transform 0.9s cubic-bezier(.2,.85,.2,1), box-shadow 0.5s, opacity 0.4s;\n    will-change: transform;\n  }\n\n  .process .halo {\n    content:'';\n    position:absolute;\n    width: 120%;\n    height: 120%;\n    border-radius:50%;\n    top: -10%;\n    left:-10%;\n    pointer-events:none;\n    filter: blur(10px);\n    opacity:0;\n    transition: opacity 0.4s;\n  }\n\n  .process.waiting { opacity:0.95; transform: translateY(0) scale(1); z-index: 10; }\n  .process.queued { opacity:0.95; transform: translateY(-4px) scale(0.98); z-index: 20; }\n  .process.acquiring { transform: translateY(-10px) scale(1.02); z-index: 40; box-shadow: 0 26px 60px rgba(2,6,23,0.6); }\n  .process.critical { transform: translateY(-12px) scale(1.06); z-index: 60; box-shadow: 0 28px 88px rgba(2,6,23,0.7); }\n  .process.idle { opacity:0.28; transform: translateY(8px) scale(0.96); }\n\n  .process .num {\n    position:relative;\n    z-index:3;\n  }\n\n  /* colors for processes */\n  .proc-0 { background: linear-gradient(135deg,#7b61ff22,#7ce7d922); }\n  .proc-1 { background: linear-gradient(135deg,#ffd16622,#7ce7d922); }\n  .proc-2 { background: linear-gradient(135deg,#ff6b6b22,#7b61ff22); }\n  .proc-3 { background: linear-gradient(135deg,#60d39422,#ffd16622); }\n  .proc-4 { background: linear-gradient(135deg,#7ce7d922,#ff6b6b22); }\n\n  /* queue markers */\n  .queue-slot {\n    position:absolute;\n    width:64px;\n    height:64px;\n    border-radius:12px;\n    border: 1px dashed rgba(255,255,255,0.04);\n    top: 160px;\n    left: 260px;\n    transform: translate3d(0,0,0);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    opacity:0.6;\n    color: var(--muted);\n    font-size: 11px;\n  }\n  .queue-slot.q0 { left: 240px; }\n  .queue-slot.q1 { left: 310px; }\n  .queue-slot.q2 { left: 380px; }\n  .queue-slot.q3 { left: 450px; }\n\n  .resource.active { box-shadow: 0 30px 80px rgba(124,97,255,0.12); transform: translateY(-6px); }\n  .resource .core.in-use { background: linear-gradient(160deg,#7b61ff33,#7ce7d922); box-shadow: 0 20px 60px rgba(123,97,255,0.12); color: #fff; }\n\n  /* timeline indicator */\n  .timeline {\n    position:absolute;\n    left: 40px;\n    right: 40px;\n    bottom: 18px;\n    height: 6px;\n    border-radius: 6px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    overflow:hidden;\n  }\n  .progress {\n    height:100%;\n    width:0%;\n    background: linear-gradient(90deg, var(--accent), var(--accent-2));\n    box-shadow: 0 6px 30px rgba(123,97,255,0.09);\n    transition: width 600ms linear;\n  }\n\n  /* side panel */\n  .panel {\n    padding: 20px;\n    border-radius: 12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    height: 100%;\n    box-shadow: inset 0 -10px 40px rgba(0,0,0,0.15);\n  }\n\n  .panel h3 {\n    margin: 0 0 8px 0;\n    font-size: 15px;\n  }\n  .panel p {\n    margin:0 0 16px 0;\n    color:var(--muted);\n    font-size: 13px;\n  }\n\n  .legend {\n    display:flex;\n    gap:10px;\n    flex-direction:column;\n  }\n  .legend .item {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .swatch {\n    width:14px;\n    height:14px;\n    border-radius:4px;\n    box-shadow: 0 6px 14px rgba(2,6,23,0.45);\n  }\n\n  /* controls */\n  .controls {\n    display:flex;\n    gap:12px;\n    margin-top: 18px;\n  }\n  .btn {\n    appearance:none;\n    border: none;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color: #eaf6f2;\n    padding: 10px 14px;\n    border-radius: 12px;\n    cursor:pointer;\n    font-weight:600;\n    font-size: 13px;\n    letter-spacing: 0.01em;\n    display:inline-flex;\n    align-items:center;\n    gap:10px;\n    box-shadow: 0 10px 26px rgba(2,6,23,0.5);\n    transition: transform 180ms ease, box-shadow 180ms ease, opacity 120ms ease;\n  }\n  .btn:active { transform: translateY(2px) scale(0.995); }\n  .btn.pause { background: linear-gradient(90deg,var(--accent),var(--accent-2)); color: #04131a; }\n  .btn.lock { background: linear-gradient(90deg,#ff6b6b,#ffb397); color: #091114; }\n\n  .footer-note {\n    margin-top: 16px;\n    color: var(--muted);\n    font-size: 12px;\n  }\n\n  /* subtle animated sparkles */\n  .sparkle {\n    position:absolute;\n    width:10px;\n    height:10px;\n    background: radial-gradient(circle at 40% 40%, #fff, rgba(255,255,255,0.8) 20%, rgba(255,255,255,0.0) 48%);\n    border-radius:50%;\n    filter: blur(8px);\n    opacity: 0.12;\n    transform: scale(1.1);\n    animation: floaty 6s linear infinite;\n    pointer-events:none;\n  }\n  @keyframes floaty {\n    0% { transform: translateY(0) translateX(0) scale(1); opacity:0.12; }\n    50% { transform: translateY(-24px) translateX(18px) scale(1.25); opacity:0.22;}\n    100% { transform: translateY(0) translateX(0) scale(1); opacity:0.12; }\n  }\n\n  /* micro labels */\n  .micro {\n    position:absolute;\n    font-size:11px;\n    color:var(--muted);\n    top:16px;\n    right:28px;\n    letter-spacing:0.02em;\n  }\n\n  /* small responsivity */\n  @media (max-width: 980px) {\n    .main { grid-template-columns: 1fr; }\n    .panel { order:2; margin-top:18px; height:auto; }\n    .scene { height:480px; }\n    .arena { transform: none; }\n    .mutex { left: calc(50% - 260px); top: 42px; }\n    .resource { right: 28px; top: 210px; transform: none; }\n  }\n</style>\n</head>\n<body>\n<div class=\"container\" role=\"main\" aria-label=\"Mutex visualization\">\n  <div class=\"header\">\n    <div class=\"logo\" aria-hidden=\"true\">\n      <!-- Artistic lock glyph -->\n      <svg width=\"64\" height=\"64\" viewBox=\"0 0 48 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <defs>\n          <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#7ce7d9\"/>\n            <stop offset=\"1\" stop-color=\"#7b61ff\"/>\n          </linearGradient>\n        </defs>\n        <rect x=\"6\" y=\"16\" width=\"36\" height=\"26\" rx=\"6\" fill=\"url(#g1)\" opacity=\"0.12\"/>\n        <g transform=\"translate(12,8)\">\n          <path d=\"M12 0C7.582 0 4 3.582 4 8v4h16v-4c0-4.418-3.582-8-8-8z\" fill=\"#7b61ff\" opacity=\"0.12\"/>\n          <rect x=\"2\" y=\"10\" width=\"20\" height=\"16\" rx=\"4\" fill=\"url(#g1)\" opacity=\"0.06\"/>\n        </g>\n        <g transform=\"translate(12,14)\">\n          <rect x=\"6\" y=\"6\" width=\"8\" height=\"10\" rx=\"2\" fill=\"#ffffff\" opacity=\"0.9\"/>\n        </g>\n      </svg>\n    </div>\n    <div>\n      <h1>Mutex — Mutual Exclusion Visualized</h1>\n      <p class=\"lead\">A refined, animated depiction of how a mutex coordinates access to a shared resource. Observe queued \"threads\", acquisition, and release — presented as a polished, aesthetic study.</p>\n    </div>\n  </div>\n\n  <div class=\"main\">\n    <div class=\"scene\" aria-hidden=\"false\">\n      <div class=\"arena\" id=\"arena\">\n\n        <!-- mutex block -->\n        <div class=\"mutex unlocked\" id=\"mutexEl\" aria-hidden=\"true\">\n          <div class=\"lock-plate\">\n            <svg class=\"shackle\" viewBox=\"0 0 64 64\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M48 28c0-9.94-8.06-18-18-18S12 18.06 12 28\" fill=\"none\" stroke=\"#cfeff0\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n            <div class=\"lock-body\" aria-hidden=\"true\">\n              <span class=\"keyhole\" aria-hidden=\"true\"></span>\n            </div>\n          </div>\n        </div>\n\n        <!-- resource -->\n        <div class=\"resource\" id=\"resourceEl\">\n          <div class=\"core\" id=\"resourceCore\">RESOURCE</div>\n          <div class=\"label\">Critical Section</div>\n        </div>\n\n        <!-- lane / queue visuals -->\n        <div class=\"lane\" aria-hidden=\"true\">\n          <div class=\"path\"></div>\n          <div class=\"queue-slot q0\">1</div>\n          <div class=\"queue-slot q1\">2</div>\n          <div class=\"queue-slot q2\">3</div>\n          <div class=\"queue-slot q3\">4+</div>\n        </div>\n\n        <!-- processes (5) -->\n        <div class=\"process proc-0\" id=\"p0\"><div class=\"num\">A</div></div>\n        <div class=\"process proc-1\" id=\"p1\"><div class=\"num\">B</div></div>\n        <div class=\"process proc-2\" id=\"p2\"><div class=\"num\">C</div></div>\n        <div class=\"process proc-3\" id=\"p3\"><div class=\"num\">D</div></div>\n        <div class=\"process proc-4\" id=\"p4\"><div class=\"num\">E</div></div>\n\n        <!-- timeline -->\n        <div class=\"timeline\" aria-hidden=\"true\" style=\"left:40px; right:40px; bottom:18px;\">\n          <div class=\"progress\" id=\"progressBar\"></div>\n        </div>\n\n        <!-- subtle sparkles -->\n        <div class=\"sparkle\" style=\"left:24px; top:34px; animation-duration:7s;\"></div>\n        <div class=\"sparkle\" style=\"left:84%; top:14%; animation-duration:9s; opacity:0.08;\"></div>\n        <div class=\"sparkle\" style=\"left:12%; top:70%; animation-duration:6.5s; opacity:0.06;\"></div>\n      </div>\n      <div class=\"micro\">FIFO queue • Single lock</div>\n    </div>\n\n    <aside class=\"panel\" aria-label=\"Controls and explanation\">\n      <h3>How it works</h3>\n      <p>Processes (A–E) approach the mutex. When the mutex is free, the next waiting process acquires it and enters the critical section. Others queue up — the mutex ensures mutual exclusion: only one at a time.</p>\n\n      <div class=\"legend\" aria-hidden=\"true\">\n        <div class=\"item\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,var(--accent),var(--accent-2));\"></div> Acquiring / Active</div>\n        <div class=\"item\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,#ffd166,#7ce7d9);\"></div> Waiting / Queued</div>\n        <div class=\"item\"><div class=\"swatch\" style=\"background:linear-gradient(90deg,#7ce7d9,#ff6b6b);\"></div> Idle</div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\" style=\"margin-top:18px;\">\n        <button class=\"btn pause\" id=\"playPauseBtn\" title=\"Play / Pause animation\" aria-pressed=\"false\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(-1px);\">\n            <path d=\"M6 5v14\" stroke=\"#04131a\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n            <path d=\"M18 5v14\" stroke=\"#04131a\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n          </svg>\n          Pause\n        </button>\n\n        <button class=\"btn lock\" id=\"toggleLockBtn\" title=\"Toggle lock state\" aria-pressed=\"false\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(-1px);\">\n            <path d=\"M6 10v6a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-6\" stroke=\"#091114\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <rect x=\"8\" y=\"10\" width=\"8\" height=\"6\" rx=\"1.5\" fill=\"#091114\" opacity=\"0.12\"/>\n          </svg>\n          Lock\n        </button>\n      </div>\n\n      <div class=\"footer-note\">Tip: Observe — interact only when needed. The visualization emphasizes aesthetics and clarity over control.</div>\n    </aside>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Configuration\n  const PROCESS_COUNT = 5;\n  const POSITIONS = { // approximate coordinates relative to arena (absolute)\n    startXs: [40, 30, 20, 10, -0], // stacked left offsets\n    startY: 300,\n    queueXs: [240, 310, 380, 450],\n    acquireX: 520, // just before resource\n    criticalX: 560, // inside resource\n    y: 300,\n    idleX: 40\n  };\n\n  // State\n  let queue = []; // indices waiting (FIFO)\n  let inCritical = null; // index of process in critical\n  let locked = false; // explicit forced lock by user (toggleLock)\n  let autoPlay = true; // whether the demo is progressing\n  let tickTimer = null;\n  let processEls = [];\n  let progressBar = document.getElementById('progressBar');\n  let mutexEl = document.getElementById('mutexEl');\n  let resourceEl = document.getElementById('resourceEl');\n  let resourceCore = document.getElementById('resourceCore');\n\n  // Initialize process elements and positions\n  for (let i=0;i<PROCESS_COUNT;i++){\n    processEls[i] = document.getElementById('p'+i);\n    // initial positioning\n    let x = POSITIONS.idleX + i*8;\n    let y = POSITIONS.y + i*6;\n    setTransform(processEls[i], x, y);\n    processEls[i].dataset.state = 'idle';\n    processEls[i].style.opacity = '0.9';\n  }\n\n  // Utility to set transform positions\n  function setTransform(el, x, y){\n    el.style.transform = `translate3d(${x}px, ${y}px, 0)`;\n  }\n\n  // Queue newcomers initially (simulate approach)\n  let arrivalOrder = [0,1,2,3,4];\n  let arrivalIndex = 0;\n  function simulateArrival(){\n    if (arrivalIndex < arrivalOrder.length){\n      let pid = arrivalOrder[arrivalIndex++];\n      enqueue(pid);\n      // slight stagger\n      setTimeout(simulateArrival, 700);\n    }\n  }\n  simulateArrival();\n\n  // Enqueue process if not already queued or in critical\n  function enqueue(pid){\n    if (queue.includes(pid) || inCritical === pid) return;\n    queue.push(pid);\n    updateVisuals();\n  }\n\n  // Dequeue next\n  function dequeue(){\n    return queue.shift();\n  }\n\n  // Acquire sequence for next process\n  async function tryAcquire(){\n    if (!autoPlay) return;\n    if (locked) return; // external lock held\n    if (inCritical != null) return;\n    if (queue.length === 0) return;\n\n    const next = dequeue();\n    // Acquire: animate to acquiring position then to critical\n    inCritical = next;\n    updateVisuals();\n\n    await animateToAcquiring(next);\n    // show locked state for duration\n    mutexEl.classList.remove('unlocked');\n    mutexEl.classList.add('locked');\n    resourceEl.classList.add('active');\n    resourceCore.classList.add('in-use');\n\n    // progress bar animation simulating work\n    await progressLoop(2200);\n\n    // release\n    resourceEl.classList.remove('active');\n    resourceCore.classList.remove('in-use');\n\n    await animateToRelease(next);\n    inCritical = null;\n    updateVisuals();\n\n    // auto-enqueue again to simulate repeated requests\n    setTimeout(()=>{ enqueue(next); }, 1800 + Math.random()*2200);\n  }\n\n  // Animation helpers\n  function animateToAcquiring(pid){\n    return new Promise((resolve) => {\n      const el = processEls[pid];\n      el.classList.remove('idle');\n      el.classList.add('queued','acquiring');\n      // move to queue front visual (if present)\n      const idx = Math.max(0, 0); // it's next\n      const qx = POSITIONS.queueXs[0];\n      setTransform(el, qx, POSITIONS.y - 6);\n      // Slight delay then move to acquireX\n      setTimeout(()=>{\n        setTransform(el, POSITIONS.acquireX, POSITIONS.y - 18);\n      }, 520);\n      // then into critical\n      setTimeout(()=>{\n        el.classList.remove('queued');\n        el.classList.add('critical');\n        setTransform(el, POSITIONS.criticalX, POSITIONS.y - 32);\n      }, 1100);\n      // finish acquiring\n      setTimeout(()=>{\n        resolve();\n      }, 1500);\n    });\n  }\n\n  function animateToRelease(pid){\n    return new Promise((resolve) => {\n      const el = processEls[pid];\n      el.classList.remove('critical','acquiring');\n      // open lock (release)\n      mutexEl.classList.remove('locked');\n      mutexEl.classList.add('unlocked');\n\n      // move back to idle position\n      setTransform(el, POSITIONS.idleX + pid*8, POSITIONS.y + pid*6);\n      el.classList.add('idle');\n      setTimeout(()=>{ resolve(); }, 700);\n    });\n  }\n\n  // Update positions and classes for queued processes\n  function updateVisuals(){\n    // All queued processes (in order) should be placed into queue slots\n    for (let i=0;i<PROCESS_COUNT;i++){\n      const el = processEls[i];\n      if (inCritical === i){\n        el.classList.remove('queued','waiting','idle');\n        el.classList.add('critical');\n      } else {\n        // is in queue?\n        const pos = queue.indexOf(i);\n        if (pos >= 0){\n          el.classList.remove('idle','critical');\n          el.classList.add('queued');\n          const slot = Math.min(pos, POSITIONS.queueXs.length-1);\n          setTransform(el, POSITIONS.queueXs[slot], POSITIONS.y - (pos*4));\n        } else {\n          // not queued and not in critical -> idle (but keep visible)\n          el.classList.remove('queued','critical','acquiring');\n          el.classList.add('idle');\n          setTransform(el, POSITIONS.idleX + i*8, POSITIONS.y + i*6);\n        }\n      }\n    }\n\n    // If queue has entries, show them partially advanced if mutex unlocked\n    if (!locked && queue.length > 0 && inCritical == null && autoPlay){\n      // highlight next as waiting\n      const next = queue[0];\n      processEls[next].classList.add('waiting');\n    }\n  }\n\n  // Progress bar for simulated critical section work\n  function progressLoop(duration){\n    return new Promise((resolve) => {\n      progressBar.style.transition = 'none';\n      progressBar.style.width = '4%';\n      // small initial frame to force style\n      requestAnimationFrame(()=> {\n        progressBar.style.transition = `width ${duration}ms linear`;\n        progressBar.style.width = '100%';\n      });\n      setTimeout(()=>{\n        // reset\n        progressBar.style.transition = 'width 400ms ease';\n        progressBar.style.width = '0%';\n        setTimeout(()=> resolve(), 420);\n      }, duration + 40);\n    });\n  }\n\n  // Main tick for attempts to acquire\n  function tick(){\n    if (autoPlay && !locked){\n      tryAcquire();\n    }\n    // schedule next tick\n    tickTimer = setTimeout(()=> tick(), 700);\n  }\n\n  // Start ticking\n  tick();\n\n  // Attach controls\n  const playPauseBtn = document.getElementById('playPauseBtn');\n  const toggleLockBtn = document.getElementById('toggleLockBtn');\n\n  playPauseBtn.addEventListener('click', ()=>{\n    autoPlay = !autoPlay;\n    playPauseBtn.setAttribute('aria-pressed', String(!autoPlay));\n    if (!autoPlay){\n      playPauseBtn.classList.remove('pause');\n      playPauseBtn.style.opacity = '0.85';\n      playPauseBtn.innerHTML = `<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(-1px);\"><path d=\"M5 3l14 9-14 9V3z\" stroke=\"#04131a\" stroke-width=\"0\" fill=\"#04131a\"/></svg>Play`;\n      // pause progress and stop tick\n      clearTimeout(tickTimer);\n    } else {\n      playPauseBtn.setAttribute('aria-pressed', 'false');\n      playPauseBtn.classList.add('pause');\n      playPauseBtn.style.opacity = '1';\n      playPauseBtn.innerHTML = `<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(-1px);\"><path d=\"M6 5v14\" stroke=\"#04131a\" stroke-width=\"3\" stroke-linecap=\"round\"/><path d=\"M18 5v14\" stroke=\"#04131a\" stroke-width=\"3\" stroke-linecap=\"round\"/></svg>Pause`;\n      tick();\n    }\n  });\n\n  toggleLockBtn.addEventListener('click', ()=>{\n    locked = !locked;\n    toggleLockBtn.setAttribute('aria-pressed', String(locked));\n    if (locked){\n      // set forced lock: prevent acquisition until unlocked, but keep current critical until finished\n      mutexEl.classList.add('locked');\n      mutexEl.classList.remove('unlocked');\n      toggleLockBtn.innerHTML = `<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(-1px);\"><path d=\"M6 10v6a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-6\" stroke=\"#091114\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Locked`;\n    } else {\n      toggleLockBtn.innerHTML = `<svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(-1px);\"><path d=\"M6 10v6a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-6\" stroke=\"#091114\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>Lock`;\n      mutexEl.classList.remove('locked');\n      mutexEl.classList.add('unlocked');\n      // try acquire immediately when unlocking\n      if (autoPlay) tryAcquire();\n    }\n  });\n\n  // small breathing animation for resource core\n  let breathe = 0;\n  setInterval(()=>{\n    breathe = (breathe + 1) % 360;\n    resourceCore.style.transform = `rotate(${Math.sin(breathe/40)/8}deg)`;\n  }, 280);\n\n  // ensure visuals reflect state\n  setTimeout(updateVisuals, 500);\n\n  // Accessibility: allow space/enter to toggle play/pause when focused\n  playPauseBtn.addEventListener('keydown', (e)=> {\n    if (e.key === 'Enter' || e.key === ' ') {\n      e.preventDefault();\n      playPauseBtn.click();\n    }\n  });\n  toggleLockBtn.addEventListener('keydown', (e)=> {\n    if (e.key === 'Enter' || e.key === ' ') {\n      e.preventDefault();\n      toggleLockBtn.click();\n    }\n  });\n\n  // Minimal auto-incoming behavior to keep it alive\n  setInterval(()=>{\n    if (autoPlay && Math.random() < 0.26){\n      // randomly create a new \"external\" arrival by selecting a process not in queue and not in critical\n      const candidates = [];\n      for (let i=0;i<PROCESS_COUNT;i++){\n        if (!queue.includes(i) && inCritical !== i){\n          candidates.push(i);\n        }\n      }\n      if (candidates.length){\n        const pick = candidates[Math.floor(Math.random()*candidates.length)];\n        enqueue(pick);\n      }\n    }\n  }, 2400);\n\n  // Helpful: On load, set unlocked style\n  mutexEl.classList.add('unlocked');\n})();\n</script>\n</body>\n</html>"
