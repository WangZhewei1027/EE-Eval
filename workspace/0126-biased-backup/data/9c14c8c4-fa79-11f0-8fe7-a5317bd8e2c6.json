  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Sliding Window Maximum - Interactive Demo</title>\n  <style>\n    /* Minimal styling only to make text monospace for clarity */\n    body { font-family: monospace; margin: 12px; }\n    .row { margin: 6px 0; }\n    .group { margin: 10px 0; padding: 6px 0; }\n    button, input, select, textarea { font-family: monospace; }\n    pre { white-space: pre-wrap; }\n  </style>\n</head>\n<body>\n  <h2>Sliding Window Maximum — Interactive Demo</h2>\n\n  <div class=\"group\">\n    <div class=\"row\">\n      <label>Array (comma or space separated):</label>\n      <input id=\"arrayInput\" size=\"60\" value=\"9, 11, 8, 5, 7, 10, 6\">\n      <button id=\"loadArray\">Load Array</button>\n      <button id=\"clearArray\">Clear</button>\n    </div>\n\n    <div class=\"row\">\n      <label>Randomize:</label>\n      <input id=\"randomSize\" type=\"number\" min=\"1\" value=\"10\" style=\"width:60px\">\n      <input id=\"randomMin\" type=\"number\" value=\"0\" style=\"width:60px\">\n      <input id=\"randomMax\" type=\"number\" value=\"20\" style=\"width:60px\">\n      <button id=\"randomize\">Randomize</button>\n      <label> Seed (optional): </label><input id=\"randomSeed\" size=\"12\">\n    </div>\n\n    <div class=\"row\">\n      <label>Append value:</label>\n      <input id=\"appendValue\" size=\"8\">\n      <button id=\"appendBtn\">Append</button>\n      <label> Prepend value:</label>\n      <input id=\"prependValue\" size=\"8\">\n      <button id=\"prependBtn\">Prepend</button>\n      <label> Insert at index:</label>\n      <input id=\"insertIndex\" type=\"number\" style=\"width:60px\">\n      <input id=\"insertValue\" size=\"8\">\n      <button id=\"insertBtn\">Insert</button>\n    </div>\n\n    <div class=\"row\">\n      <label>Window size k:</label>\n      <input id=\"kInput\" type=\"number\" min=\"1\" value=\"3\" style=\"width:70px\">\n      <label> or quick slider: </label>\n      <input id=\"kSlider\" type=\"range\" min=\"1\" value=\"3\" style=\"width:200px\">\n      <span id=\"kDisplay\"></span>\n      <button id=\"addMultiK\">Add to Multi-windows</button>\n      <button id=\"clearMultiK\">Clear Multi-windows</button>\n      <span id=\"multiKList\"></span>\n    </div>\n\n    <div class=\"row\">\n      <label>Algorithm:</label>\n      <select id=\"algorithm\">\n        <option value=\"deque\">Deque (O(n))</option>\n        <option value=\"brute\">Brute-force (O(n·k))</option>\n      </select>\n\n      <label> Tie-breaking on equal values:</label>\n      <select id=\"tieBreak\">\n        <option value=\"right\">Prefer newest (pop when equal)</option>\n        <option value=\"left\">Prefer oldest (do not pop on equal)</option>\n      </select>\n\n      <label> Circular:</label>\n      <input id=\"circular\" type=\"checkbox\">\n      <label> Streaming mode:</label>\n      <input id=\"streaming\" type=\"checkbox\">\n    </div>\n  </div>\n\n  <div class=\"group\">\n    <div class=\"row\">\n      <button id=\"runFull\">Run Full</button>\n      <button id=\"resetRun\">Reset</button>\n      <button id=\"stepBack\">Step Back</button>\n      <button id=\"stepForward\">Step Forward</button>\n      <button id=\"playPause\">Play</button>\n      <label> Speed(ms): </label><input id=\"speed\" type=\"number\" value=\"600\" style=\"width:80px\">\n      <label> Show indices:</label><input id=\"showIndices\" type=\"checkbox\" checked>\n      <label> Show values:</label><input id=\"showValues\" type=\"checkbox\" checked>\n      <label> Detailed ops:</label><input id=\"showOps\" type=\"checkbox\" checked>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"stepExplain\">Explain Current Step</button>\n      <button id=\"exportJSON\">Export Snapshot</button>\n      <button id=\"importJSON\">Import Snapshot</button>\n      <input id=\"importText\" size=\"60\" placeholder=\"Paste JSON here then click Import\">\n      <button id=\"undoBtn\">Undo</button>\n      <button id=\"redoBtn\">Redo</button>\n    </div>\n  </div>\n\n  <div class=\"group\">\n    <strong>Streaming Controls (when streaming mode is on):</strong>\n    <div class=\"row\">\n      <button id=\"streamAdd\">Add Next Element</button>\n      <button id=\"streamRemove\">Remove Oldest</button>\n      <label> Auto-add interval(ms):</label><input id=\"streamInterval\" type=\"number\" value=\"800\" style=\"width:80px\">\n      <button id=\"streamAuto\">Auto Stream</button>\n      <button id=\"streamStop\">Stop Stream</button>\n    </div>\n    <div class=\"row\">\n      <label>Next value to push:</label><input id=\"nextStreamValue\" size=\"10\">\n      <label>Stream capacity (max elements stored):</label><input id=\"streamCapacity\" type=\"number\" value=\"100\" style=\"width:80px\">\n    </div>\n  </div>\n\n  <div class=\"group\">\n    <strong>Visualization:</strong>\n    <div class=\"row\"><pre id=\"arrayView\"></pre></div>\n    <div class=\"row\"><pre id=\"windowView\"></pre></div>\n    <div class=\"row\"><pre id=\"dequeView\"></pre></div>\n    <div class=\"row\"><pre id=\"resultView\"></pre></div>\n    <div class=\"row\"><pre id=\"countersView\"></pre></div>\n    <div class=\"row\"><pre id=\"logView\"></pre></div>\n    <div class=\"row\"><pre id=\"explainView\"></pre></div>\n  </div>\n\n  <script>\n    // ====== Core state and utilities ======\n    (function(){\n      // State\n      let state = {\n        arr: [],                // original array\n        n: 0,\n        k: 3,\n        ks: [],                // multi-window sizes\n        algorithm: 'deque',\n        tieBreak: 'right',\n        circular: false,\n        streaming: false,\n        streamIndex: 0,        // for streaming synthetic data\n        streamAutoTimer: null,\n        trace: [],             // generated steps\n        stepIndex: -1,         // current step index in trace\n        playing: false,\n        playTimer: null,\n        playSpeed: 600,\n        counters: { comparisons:0, dequeOps:0, steps:0 },\n        undoStack: [],\n        redoStack: [],\n        showIndices: true,\n        showValues: true,\n        showOps: true\n      };\n\n      // DOM helpers\n      const $ = id => document.getElementById(id);\n      const arrayInput = $('arrayInput');\n      const loadArrayBtn = $('loadArray');\n      const clearArrayBtn = $('clearArray');\n      const randomizeBtn = $('randomize');\n      const randomSize = $('randomSize');\n      const randomMin = $('randomMin');\n      const randomMax = $('randomMax');\n      const randomSeed = $('randomSeed');\n      const appendValue = $('appendValue');\n      const appendBtn = $('appendBtn');\n      const prependValue = $('prependValue');\n      const prependBtn = $('prependBtn');\n      const insertIndex = $('insertIndex');\n      const insertValue = $('insertValue');\n      const insertBtn = $('insertBtn');\n      const kInput = $('kInput');\n      const kSlider = $('kSlider');\n      const kDisplay = $('kDisplay');\n      const algorithmSel = $('algorithm');\n      const tieBreakSel = $('tieBreak');\n      const circularChk = $('circular');\n      const streamingChk = $('streaming');\n      const runFullBtn = $('runFull');\n      const resetRunBtn = $('resetRun');\n      const stepBackBtn = $('stepBack');\n      const stepForwardBtn = $('stepForward');\n      const playPauseBtn = $('playPause');\n      const speedInput = $('speed');\n      const showIndicesChk = $('showIndices');\n      const showValuesChk = $('showValues');\n      const showOpsChk = $('showOps');\n      const stepExplainBtn = $('stepExplain');\n      const exportBtn = $('exportJSON');\n      const importBtn = $('importJSON');\n      const importText = $('importText');\n      const undoBtn = $('undoBtn');\n      const redoBtn = $('redoBtn');\n      const streamAddBtn = $('streamAdd');\n      const streamRemoveBtn = $('streamRemove');\n      const streamInterval = $('streamInterval');\n      const streamAutoBtn = $('streamAuto');\n      const streamStopBtn = $('streamStop');\n      const nextStreamValue = $('nextStreamValue');\n      const streamCapacity = $('streamCapacity');\n      const arrayView = $('arrayView');\n      const windowView = $('windowView');\n      const dequeView = $('dequeView');\n      const resultView = $('resultView');\n      const countersView = $('countersView');\n      const logView = $('logView');\n      const explainView = $('explainView');\n      const addMultiKBtn = $('addMultiK');\n      const clearMultiKBtn = $('clearMultiK');\n      const multiKList = $('multiKList');\n\n      // Initialize k slider later\n      function pushUndoSnapshot() {\n        const snapshot = JSON.stringify({\n          arr: state.arr.slice(),\n          k: state.k,\n          ks: state.ks.slice(),\n          algorithm: state.algorithm,\n          tieBreak: state.tieBreak,\n          circular: state.circular,\n          streaming: state.streaming\n        });\n        state.undoStack.push(snapshot);\n        if (state.undoStack.length > 50) state.undoStack.shift();\n        state.redoStack = [];\n        updateUndoRedoButtons();\n      }\n      function applySnapshot(snapStr) {\n        try {\n          const s = JSON.parse(snapStr);\n          state.arr = s.arr.slice();\n          state.k = s.k;\n          state.ks = (s.ks||[]).slice();\n          state.algorithm = s.algorithm;\n          state.tieBreak = s.tieBreak;\n          state.circular = s.circular;\n          state.streaming = s.streaming;\n          syncControlsFromState();\n          rebuildTraceAndRender();\n        } catch(e){ alert('Invalid snapshot'); }\n      }\n      function updateUndoRedoButtons() {\n        undoBtn.disabled = state.undoStack.length===0;\n        redoBtn.disabled = state.redoStack.length===0;\n      }\n\n      // Parse array text\n      function parseArrayText(text) {\n        if (!text.trim()) return [];\n        const parts = text.trim().split(/[\\s,]+/);\n        const arr = [];\n        for (let p of parts) {\n          if (p==='') continue;\n          const num = Number(p);\n          if (isNaN(num)) {\n            // allow strings? For this demo only numbers are handled.\n            continue;\n          }\n          arr.push(num);\n        }\n        return arr;\n      }\n\n      function formatArrayDisplay(arr) {\n        if (!arr.length) return '(empty array)';\n        const parts = [];\n        for (let i=0;i<arr.length;i++){\n          const idx = '['+i+']';\n          const val = String(arr[i]);\n          parts.push(idx + ' ' + val);\n        }\n        return parts.join('  ');\n      }\n\n      // Build trace for deque algorithm or brute force\n      function buildTrace() {\n        state.trace = [];\n        state.counters = { comparisons:0, dequeOps:0, steps:0 };\n        const arr = state.arr.slice();\n        const n = arr.length;\n        if (n===0) return;\n        const k = Math.max(1, Math.min(state.k, n));\n        // If circular, extend by k-1 to simulate wrap\n        let procArr = arr.slice();\n        let indicesOffset = 0;\n        if (state.circular) {\n          const extra = procArr.slice(0, k-1);\n          procArr = procArr.concat(extra);\n        }\n        if (state.algorithm === 'deque') {\n          const deque = []; // will store indices (into procArr)\n          for (let i=0;i<procArr.length;i++) {\n            const step = { i:i, val: procArr[i], removedFromBack: [], removedFromFront: null, pushed: i, dequeBefore: deque.slice(), dequeAfter: null, windowStart:null, windowEnd:null, output:null, notes:[] };\n            // Remove from back while new value is better\n            while (deque.length>0) {\n              state.counters.comparisons++;\n              const backIdx = deque[deque.length-1];\n              const backVal = procArr[backIdx];\n              let shouldPop;\n              if (state.tieBreak === 'right') {\n                // prefer newest -> pop on >= so rightmost wins ties\n                shouldPop = (procArr[i] >= backVal);\n              } else {\n                // prefer oldest -> pop only if strictly greater\n                shouldPop = (procArr[i] > backVal);\n              }\n              if (shouldPop) {\n                const removed = deque.pop();\n                state.counters.dequeOps++;\n                step.removedFromBack.push({ idx:removed, val: backVal });\n                step.notes.push('Popped back idx '+removed+' val '+backVal);\n              } else break;\n            }\n            // Push back current index\n            deque.push(i);\n            state.counters.dequeOps++;\n            // Remove from front if out of window (only when we have reached full window size)\n            const startIdx = i - (k-1);\n            if (startIdx > 0) {\n              // front index must be >= startIdx\n              if (deque.length>0 && deque[0] < startIdx) {\n                const removed = deque.shift();\n                state.counters.dequeOps++;\n                step.removedFromFront = { idx: removed, val: procArr[removed] };\n                step.notes.push('Popped front idx '+removed+' val '+procArr[removed]);\n              }\n            }\n            step.dequeAfter = deque.slice();\n            step.windowStart = Math.max(0, startIdx);\n            step.windowEnd = i;\n            if (i >= k-1) {\n              const outIdx = deque[0];\n              step.output = { idx: outIdx, val: procArr[outIdx] };\n            }\n            state.trace.push(step);\n            state.counters.steps++;\n            // For circular mode, we should only create outputs for the first n windows if processed length > n\n            if (state.circular && i >= k-1 && i - (k-1) >= n) {\n              // do nothing; this extra window is beyond first n windows\n            }\n          }\n        } else {\n          // brute force: for each window starting position compute max by scanning\n          const maxStart = state.circular ? n : (n - k + 1);\n          for (let start = 0; start < maxStart; start++) {\n            const step = { start: start, k: k, checks: [], maxIdx: null, maxVal: null, comparisons:0 };\n            let bestIdx = start;\n            let bestVal = procArr[start];\n            for (let j=1;j<k;j++) {\n              const idx = start + j;\n              const val = procArr[idx];\n              step.checks.push({ idx: idx, val: val, compareWith: bestVal });\n              state.counters.comparisons++; step.comparisons++;\n              if (val > bestVal || (val===bestVal && state.tieBreak==='right')) {\n                bestVal = val; bestIdx = idx;\n              }\n            }\n            step.maxIdx = bestIdx; step.maxVal = bestVal;\n            state.trace.push(step);\n            state.counters.steps++;\n          }\n        }\n      }\n\n      // Render functions\n      function renderAll() {\n        // array display\n        arrayView.textContent = 'Array: ' + formatArrayDisplay(state.arr);\n        // k display\n        kDisplay.textContent = 'k = ' + state.k;\n        kSlider.max = Math.max(1, state.arr.length || 1);\n        kSlider.value = state.k;\n        kInput.value = state.k;\n        // multi-k\n        multiKList.textContent = state.ks.length ? ('Multi windows: ['+state.ks.join(', ')+']') : 'Multi windows: (none)';\n\n        // windowView & resultView\n        if (state.trace.length===0) {\n          windowView.textContent = '(no trace yet)';\n          dequeView.textContent = '';\n          resultView.textContent = '';\n          countersView.textContent = 'Counters: ' + JSON.stringify(state.counters);\n          logView.textContent = '';\n          explainView.textContent = '';\n          return;\n        }\n\n        // Based on current stepIndex show information\n        let si = state.stepIndex;\n        if (si < 0) si = 0;\n        if (si >= state.trace.length) si = state.trace.length-1;\n        const st = state.trace[si];\n\n        // Show window/step context\n        if (state.algorithm === 'deque') {\n          const sb = [];\n          sb.push('Step ' + si + ' / ' + (state.trace.length-1));\n          sb.push('Processing index i = ' + st.i + ' (value = ' + st.val + ')');\n          sb.push('Window range in processed array: start=' + st.windowStart + ' end=' + st.windowEnd);\n          if (st.output) sb.push('Output available: max idx=' + st.output.idx + ' value=' + st.output.val);\n          windowView.textContent = sb.join('\\n');\n          // Deque view\n          const dq = [];\n          dq.push('Deque before step: ' + formatDequeIndices(st.dequeBefore, state.arr, st));\n          dq.push('Removed from back in this step: ' + (st.removedFromBack.length ? st.removedFromBack.map(x=>'['+x.idx+']='+x.val).join(', ') : '(none)'));\n          dq.push('Removed from front in this step: ' + (st.removedFromFront ? ('['+st.removedFromFront.idx+']='+st.removedFromFront.val) : '(none)'));\n          dq.push('Deque after step: ' + formatDequeIndices(st.dequeAfter, state.arr, st));\n          dequeView.textContent = dq.join('\\n');\n\n          // Result view: show outputs up to this step\n          const outputs = [];\n          for (let t=0;t<=si;t++){\n            const s = state.trace[t];\n            if (s.output) {\n              // Map output idx back into original array for circular mode\n              const originalIdx = mapProcessedIdxToOriginal(s.output.idx);\n              outputs.push({ windowEndIdx: s.i, maxIdxProc: s.output.idx, maxVal: s.output.val, maxIdxOrig: originalIdx });\n            }\n          }\n          const resParts = outputs.map((o,ii)=> {\n            const wstart = o.windowEndIdx - (state.k-1);\n            const wstartOrig = mapProcessedIdxToOriginal(Math.max(0,wstart));\n            return 'Window #' + ii + ' (proc end ' + o.windowEndIdx + '): max value=' + o.maxVal + ' (proc idx ' + o.maxIdxProc + ', orig idx ' + o.maxIdxOrig + ')';\n          });\n          resultView.textContent = 'Results so far:\\n' + (resParts.length ? resParts.join('\\n') : '(none)');\n        } else {\n          // brute force\n          const sb = [];\n          sb.push('Brute-force windows: showing step ' + si + ' / ' + (state.trace.length-1));\n          sb.push('Window start = ' + st.start + ' length k=' + st.k);\n          sb.push('Checks: ' + st.checks.map(c=>'['+c.idx+']='+c.val+' vs best='+c.compareWith).join(', '));\n          sb.push('Result: max idx=' + st.maxIdx + ' val=' + st.maxVal);\n          windowView.textContent = sb.join('\\n');\n          dequeView.textContent = '';\n          // Results up to this step\n          const results = state.trace.slice(0, si+1).map((s,idx)=>('Window '+idx+': max='+s.maxVal+' idx='+s.maxIdx));\n          resultView.textContent = results.join('\\n');\n        }\n\n        countersView.textContent = 'Counters: steps=' + state.counters.steps + ' comparisons=' + state.counters.comparisons + ' dequeOps=' + state.counters.dequeOps;\n\n        // Log view: list of steps with short summary\n        const lines = [];\n        for (let t=0;t<state.trace.length;t++){\n          const s = state.trace[t];\n          if (state.algorithm === 'deque') {\n            const out = s.output ? (' -> max '+s.output.val+'(idx:'+s.output.idx+')') : '';\n            lines.push((t===state.stepIndex?'> ':'   ') + 'i=' + s.i + ' val=' + s.val + out);\n          } else {\n            lines.push((t===state.stepIndex?'> ':'   ') + 'start=' + s.start + ' max=' + s.maxVal);\n          }\n        }\n        logView.textContent = lines.join('\\n');\n        // Explain view empty by default (fill when user asks)\n        explainView.textContent = '';\n\n        function formatDequeIndices(deq, baseArr, step) {\n          if (!deq || !deq.length) return '(empty)';\n          // Map processed indices back to original for display if circular\n          return deq.map(idx => {\n            const orig = mapProcessedIdxToOriginal(idx);\n            return '['+idx+']='+ (baseArr[idx]!==undefined?baseArr[idx]:'?') + '(orig:'+orig+')';\n          }).join(', ');\n        }\n      }\n\n      function mapProcessedIdxToOriginal(procIdx) {\n        if (!state.circular) return procIdx;\n        const n = state.arr.length;\n        if (procIdx < n) return procIdx;\n        return procIdx % n;\n      }\n\n      // Rebuild trace and reset step\n      function rebuildTraceAndRender() {\n        buildTrace();\n        if (state.trace.length>0) {\n          state.stepIndex = 0;\n        } else {\n          state.stepIndex = -1;\n        }\n        renderAll();\n      }\n\n      // Play controls\n      function play() {\n        if (state.playing) return;\n        state.playing = true;\n        playPauseBtn.textContent = 'Pause';\n        const tick = () => {\n          if (!state.playing) return;\n          stepForward();\n          if (state.stepIndex >= state.trace.length-1) {\n            // stop at end\n            pause();\n            return;\n          }\n          state.playTimer = setTimeout(tick, Math.max(10, state.playSpeed));\n        };\n        state.playTimer = setTimeout(tick, Math.max(10, state.playSpeed));\n      }\n      function pause() {\n        state.playing = false;\n        playPauseBtn.textContent = 'Play';\n        if (state.playTimer) { clearTimeout(state.playTimer); state.playTimer = null; }\n      }\n\n      function stepForward() {\n        if (state.trace.length===0) return;\n        state.stepIndex = Math.min(state.trace.length-1, (state.stepIndex<0?0:state.stepIndex+1));\n        renderAll();\n      }\n      function stepBack() {\n        if (state.trace.length===0) return;\n        state.stepIndex = Math.max(0, state.stepIndex-1);\n        renderAll();\n      }\n      function resetRun() {\n        if (state.trace.length===0) return;\n        state.stepIndex = 0;\n        renderAll();\n      }\n\n      // Explain current step in more detail\n      function explainCurrentStep() {\n        if (state.trace.length===0 || state.stepIndex<0) { explainView.textContent = '(no step)'; return; }\n        const s = state.trace[state.stepIndex];\n        const lines = [];\n        if (state.algorithm === 'deque') {\n          lines.push('Detailed explanation for step i=' + s.i + ' value=' + s.val);\n          lines.push('Start with deque (indices): ' + (s.dequeBefore.length? s.dequeBefore.join(', ') : '(empty)'));\n          if (s.removedFromBack.length) {\n            lines.push('During this step, from back we removed: ' + s.removedFromBack.map(x=>'['+x.idx+']='+x.val).join(', '));\n          } else {\n            lines.push('No removals from back.');\n          }\n          if (s.removedFromFront) {\n            lines.push('Also removed from front (out of window): ['+s.removedFromFront.idx+']='+s.removedFromFront.val);\n          }\n          lines.push('After operations, deque is: ' + (s.dequeAfter.length? s.dequeAfter.join(', ') : '(empty)'));\n          if (s.output) {\n            const origIdx = mapProcessedIdxToOriginal(s.output.idx);\n            lines.push('Since i >= k-1, we output max = ' + s.output.val + ' (proc idx ' + s.output.idx + ', orig idx ' + origIdx + ')');\n          } else {\n            lines.push('No output yet, window not full.');\n          }\n          if (state.showOps) {\n            lines.push('Notes: ' + (s.notes.length? s.notes.join('; ') : '(none)'));\n          }\n        } else {\n          lines.push('Brute-force detail for window start=' + s.start);\n          lines.push('Comparisons done: ' + (s.checks.length? s.checks.length : 0));\n          s.checks.forEach((c, idx) => {\n            lines.push('Compare proc index ' + c.idx + ' val=' + c.val + ' with current best ' + c.compareWith);\n          });\n          lines.push('Selected max idx=' + s.maxIdx + ' value=' + s.maxVal);\n        }\n        explainView.textContent = lines.join('\\n');\n      }\n\n      // Export/import\n      function exportSnapshot() {\n        const payload = {\n          arr: state.arr.slice(),\n          k: state.k,\n          ks: state.ks.slice(),\n          algorithm: state.algorithm,\n          tieBreak: state.tieBreak,\n          circular: state.circular,\n          streaming: state.streaming\n        };\n        const text = JSON.stringify(payload, null, 2);\n        const win = window.open('', '_blank');\n        win.document.write('<pre>' + text + '</pre>');\n      }\n      function importSnapshotFromText(text) {\n        try {\n          const obj = JSON.parse(text);\n          pushUndoSnapshot();\n          applySnapshot(JSON.stringify(obj));\n        } catch(e){\n          alert('Invalid JSON');\n        }\n      }\n\n      // Helpers for UI-state sync\n      function syncControlsFromState() {\n        arrayInput.value = state.arr.join(', ');\n        kInput.value = state.k;\n        kSlider.value = state.k;\n        algorithmSel.value = state.algorithm;\n        tieBreakSel.value = state.tieBreak;\n        circularChk.checked = state.circular;\n        streamingChk.checked = state.streaming;\n        showIndicesChk.checked = state.showIndices;\n        showValuesChk.checked = state.showValues;\n        showOpsChk.checked = state.showOps;\n      }\n\n      // UI event handlers\n      loadArrayBtn.addEventListener('click', () => {\n        const arr = parseArrayText(arrayInput.value);\n        pushUndoSnapshot();\n        state.arr = arr;\n        state.n = arr.length;\n        if (state.k > state.n) state.k = Math.max(1, state.n);\n        rebuildTraceAndRender();\n      });\n      clearArrayBtn.addEventListener('click', () => {\n        pushUndoSnapshot();\n        state.arr = [];\n        state.n = 0;\n        state.k = 1;\n        rebuildTraceAndRender();\n      });\n      randomizeBtn.addEventListener('click', () => {\n        pushUndoSnapshot();\n        const size = Math.max(1, Number(randomSize.value)||1);\n        const min = Number(randomMin.value) || 0;\n        const max = Number(randomMax.value) || 10;\n        const seed = randomSeed.value || null;\n        let rng;\n        if (seed) {\n          // simple seeded RNG using xmur3 + mulberry32\n          function xmur3(str) {\n            for(var i=0,x=0;i<str.length;i++) x = (x<<5) - x + str.charCodeAt(i);\n            return function() {\n              x += 0x6D2B79F5;\n              var t = Math.imul(x ^ x>>>15, 1 | x);\n              t = t + Math.imul(t ^ t>>>7, 61 | t) ^ t;\n              return ((t ^ t>>>14) >>> 0) / 4294967296;\n            }\n          }\n          rng = xmur3(seed);\n        } else {\n          rng = Math.random;\n        }\n        const arr = [];\n        for (let i=0;i<size;i++) {\n          const r = rng();\n          const val = min + Math.floor(r * ((max-min+1)||1));\n          arr.push(val);\n        }\n        state.arr = arr;\n        state.n = arr.length;\n        if (state.k > state.n) state.k = Math.max(1, state.n);\n        rebuildTraceAndRender();\n      });\n\n      appendBtn.addEventListener('click', () => {\n        const v = Number(appendValue.value);\n        if (appendValue.value==='') return;\n        pushUndoSnapshot();\n        state.arr.push(v);\n        state.n = state.arr.length;\n        if (state.k > state.n) state.k = Math.max(1, state.n);\n        rebuildTraceAndRender();\n      });\n      prependBtn.addEventListener('click', () => {\n        const v = Number(prependValue.value);\n        if (prependValue.value==='') return;\n        pushUndoSnapshot();\n        state.arr.unshift(v);\n        state.n = state.arr.length;\n        if (state.k > state.n) state.k = Math.max(1, state.n);\n        rebuildTraceAndRender();\n      });\n      insertBtn.addEventListener('click', () => {\n        const idx = Number(insertIndex.value);\n        const v = Number(insertValue.value);\n        if (isNaN(idx) || insertValue.value==='') return;\n        pushUndoSnapshot();\n        const clamped = Math.max(0, Math.min(state.arr.length, idx));\n        state.arr.splice(clamped, 0, v);\n        state.n = state.arr.length;\n        if (state.k > state.n) state.k = Math.max(1, state.n);\n        rebuildTraceAndRender();\n      });\n\n      kInput.addEventListener('change', () => {\n        const k = Math.max(1, Math.min(Number(kInput.value)||1, Math.max(1,state.arr.length||1)));\n        state.k = k;\n        kSlider.max = Math.max(1, state.arr.length||1);\n        kSlider.value = k;\n        rebuildTraceAndRender();\n      });\n      kSlider.addEventListener('input', () => {\n        const k = Math.max(1, Math.min(Number(kSlider.value)||1, Math.max(1,state.arr.length||1)));\n        state.k = k;\n        kInput.value = k;\n        rebuildTraceAndRender();\n      });\n\n      algorithmSel.addEventListener('change', () => {\n        state.algorithm = algorithmSel.value;\n        pushUndoSnapshot();\n        rebuildTraceAndRender();\n      });\n      tieBreakSel.addEventListener('change', () => {\n        state.tieBreak = tieBreakSel.value;\n        pushUndoSnapshot();\n        rebuildTraceAndRender();\n      });\n      circularChk.addEventListener('change', () => {\n        state.circular = circularChk.checked;\n        pushUndoSnapshot();\n        rebuildTraceAndRender();\n      });\n      streamingChk.addEventListener('change', () => {\n        state.streaming = streamingChk.checked;\n        pushUndoSnapshot();\n        rebuildTraceAndRender();\n      });\n\n      runFullBtn.addEventListener('click', () => {\n        rebuildTraceAndRender();\n        // jump to end\n        if (state.trace.length>0) {\n          state.stepIndex = state.trace.length-1;\n          renderAll();\n        }\n      });\n      resetRunBtn.addEventListener('click', () => {\n        resetRun();\n      });\n      stepBackBtn.addEventListener('click', () => { stepBack(); });\n      stepForwardBtn.addEventListener('click', () => { stepForward(); });\n      playPauseBtn.addEventListener('click', () => {\n        state.playSpeed = Math.max(10, Number(speedInput.value) || 600);\n        if (state.playing) pause(); else play();\n      });\n      speedInput.addEventListener('change', () => {\n        state.playSpeed = Math.max(10, Number(speedInput.value) || 600);\n      });\n\n      showIndicesChk.addEventListener('change', ()=>{ state.showIndices = showIndicesChk.checked; renderAll(); });\n      showValuesChk.addEventListener('change', ()=>{ state.showValues = showValuesChk.checked; renderAll(); });\n      showOpsChk.addEventListener('change', ()=>{ state.showOps = showOpsChk.checked; renderAll(); });\n\n      stepExplainBtn.addEventListener('click', () => { explainCurrentStep(); });\n\n      exportBtn.addEventListener('click', () => exportSnapshot());\n      importBtn.addEventListener('click', () => {\n        const txt = importText.value;\n        if (!txt) { alert('Paste snapshot JSON into the text box first.'); return; }\n        pushUndoSnapshot();\n        importSnapshotFromText(txt);\n      });\n\n      undoBtn.addEventListener('click', () => {\n        if (state.undoStack.length===0) return;\n        const snap = state.undoStack.pop();\n        state.redoStack.push(JSON.stringify({\n          arr: state.arr.slice(),\n          k: state.k,\n          ks: state.ks.slice(),\n          algorithm: state.algorithm,\n          tieBreak: state.tieBreak,\n          circular: state.circular,\n          streaming: state.streaming\n        }));\n        applySnapshot(snap);\n        updateUndoRedoButtons();\n      });\n      redoBtn.addEventListener('click', () => {\n        if (state.redoStack.length===0) return;\n        const snap = state.redoStack.pop();\n        state.undoStack.push(JSON.stringify({\n          arr: state.arr.slice(),\n          k: state.k,\n          ks: state.ks.slice(),\n          algorithm: state.algorithm,\n          tieBreak: state.tieBreak,\n          circular: state.circular,\n          streaming: state.streaming\n        }));\n        applySnapshot(snap);\n        updateUndoRedoButtons();\n      });\n\n      // Streaming controls\n      let streamAutoTimer = null;\n      streamAddBtn.addEventListener('click', () => {\n        if (!state.streaming) { alert('Enable streaming mode first'); return; }\n        const vStr = nextStreamValue.value;\n        if (vStr==='') {\n          alert('Enter a next value to push into the stream');\n          return;\n        }\n        const v = Number(vStr);\n        // push into arr and rebuild trace but keep sliding as streaming: we want to process only new appended elements\n        pushUndoSnapshot();\n        state.arr.push(v);\n        if (state.arr.length > Number(streamCapacity.value) && Number(streamCapacity.value)>0) {\n          state.arr.shift();\n        }\n        rebuildTraceAndRender();\n        // move stepIndex to last\n        if (state.trace.length>0) state.stepIndex = state.trace.length-1;\n        renderAll();\n      });\n      streamRemoveBtn.addEventListener('click', () => {\n        if (!state.streaming) { alert('Enable streaming mode first'); return; }\n        if (state.arr.length===0) return;\n        pushUndoSnapshot();\n        state.arr.shift();\n        rebuildTraceAndRender();\n      });\n      streamAutoBtn.addEventListener('click', () => {\n        if (!state.streaming) { alert('Enable streaming mode first'); return; }\n        if (streamAutoTimer) return;\n        const interval = Math.max(50, Number(streamInterval.value) || 800);\n        streamAutoTimer = setInterval(() => {\n          // if nextStreamValue has numbers separated by commas we can cycle, otherwise random numbers\n          const vStr = nextStreamValue.value;\n          let v;\n          if (vStr.indexOf(',')>=0) {\n            const parts = vStr.split(',').map(s=>s.trim()).filter(s=>s!=='');\n            if (parts.length) {\n              const p = parts[state.streamIndex % parts.length];\n              v = Number(p);\n            } else v = Math.floor(Math.random()*10);\n          } else if (vStr==='_rand' || vStr==='_random' || vStr==='') {\n            v = Math.floor(Math.random()*20);\n          } else {\n            v = Number(vStr);\n            if (isNaN(v)) v = Math.floor(Math.random()*20);\n          }\n          state.arr.push(v);\n          if (state.arr.length > Number(streamCapacity.value) && Number(streamCapacity.value)>0) {\n            state.arr.shift();\n          }\n          state.streamIndex++;\n          rebuildTraceAndRender();\n          if (state.trace.length>0) state.stepIndex = state.trace.length-1;\n          renderAll();\n        }, interval);\n        streamAutoBtn.disabled = true;\n        streamStopBtn.disabled = false;\n      });\n      streamStopBtn.addEventListener('click', () => {\n        if (streamAutoTimer) {\n          clearInterval(streamAutoTimer);\n          streamAutoTimer = null;\n        }\n        streamAutoBtn.disabled = false;\n        streamStopBtn.disabled = true;\n      });\n\n      // Multi-k management\n      addMultiKBtn.addEventListener('click', () => {\n        const v = Number(kInput.value)||1;\n        if (!state.ks.includes(v)) {\n          state.ks.push(v);\n          rebuildTraceAndRender();\n        }\n      });\n      clearMultiKBtn.addEventListener('click', () => {\n        state.ks = [];\n        rebuildTraceAndRender();\n      });\n\n      // Allow clicking in log to jump to a step (simple: click in logView to set step by line number)\n      logView.addEventListener('click', (ev) => {\n        const txt = logView.textContent;\n        const pos = logView.selectionStart || 0;\n        // approximate: compute clicked line by vertical offset: use caret position approach\n        // fallback: prompt for step\n        const input = prompt('Enter step index to jump to (0..' + Math.max(0, state.trace.length-1) + ')');\n        const num = Number(input);\n        if (!isNaN(num) && num>=0 && num < state.trace.length) {\n          state.stepIndex = num;\n          renderAll();\n        }\n      });\n\n      // Keyboard shortcuts: n=next, p=prev, space=play/pause\n      document.addEventListener('keydown', (e) => {\n        if (e.key === 'n') stepForward();\n        if (e.key === 'p') stepBack();\n        if (e.key === ' ') { e.preventDefault(); if (state.playing) pause(); else play(); }\n      });\n\n      // Utility: map values for multi-k exploration (compute results for each k)\n      function computeMultiWindowResults() {\n        if (!state.ks.length) return null;\n        const results = {};\n        for (let k of state.ks) {\n          const res = runOnceForK(k);\n          results[k] = res;\n        }\n        return results;\n      }\n      function runOnceForK(k) {\n        const arr = state.arr.slice();\n        const n = arr.length;\n        if (n === 0) return [];\n        const kk = Math.max(1, Math.min(k, n));\n        const output = [];\n        if (!state.circular) {\n          if (state.algorithm === 'deque') {\n            const deque = [];\n            for (let i=0;i<n;i++){\n              while (deque.length && (state.tieBreak==='right' ? arr[i] >= arr[deque[deque.length-1]] : arr[i] > arr[deque[deque.length-1]])) deque.pop();\n              deque.push(i);\n              if (deque[0] <= i - kk) deque.shift();\n              if (i >= kk-1) output.push(arr[deque[0]]);\n            }\n          } else {\n            for (let start=0; start+kk<=n; start++) {\n              let best = arr[start];\n              for (let j=1;j<kk;j++){\n                const val = arr[start+j];\n                if (val > best || (val===best && state.tieBreak==='right')) best = val;\n              }\n              output.push(best);\n            }\n          }\n        } else {\n          // circular: extend\n          const ext = arr.concat(arr.slice(0, kk-1));\n          const limit = n;\n          if (state.algorithm === 'deque') {\n            const deque = [];\n            for (let i=0;i<ext.length;i++){\n              while (deque.length && (state.tieBreak==='right' ? ext[i] >= ext[deque[deque.length-1]] : ext[i] > ext[deque[deque.length-1]])) deque.pop();\n              deque.push(i);\n              if (deque[0] <= i - kk) deque.shift();\n              if (i >= kk-1 && i - (kk-1) < limit) output.push(ext[deque[0]]);\n            }\n          } else {\n            for (let start=0; start<limit; start++){\n              let best = ext[start];\n              for (let j=1;j<kk;j++){\n                const val = ext[start+j];\n                if (val > best || (val===best && state.tieBreak==='right')) best = val;\n              }\n              output.push(best);\n            }\n          }\n        }\n        return output;\n      }\n\n      // Helper: when user clicks \"Run Full\" we also compute multi-window results and show summary in explainView\n      runFullBtn.addEventListener('click', () => {\n        rebuildTraceAndRender();\n        const mres = computeMultiWindowResults();\n        if (mres) {\n          const lines = ['Multi-window results:'];\n          for (const k in mres) {\n            lines.push('k=' + k + ' => [' + mres[k].join(', ') + ']');\n          }\n          explainView.textContent = lines.join('\\n');\n        }\n      });\n\n      // Initialize default state and render\n      function init() {\n        // set initial array from input\n        state.arr = parseArrayText(arrayInput.value);\n        state.n = state.arr.length;\n        state.k = Math.max(1, Math.min(Number(kInput.value) || 1, Math.max(1, state.n || 1)));\n        state.playSpeed = Number(speedInput.value) || 600;\n        syncControlsFromState();\n        pushUndoSnapshot();\n        rebuildTraceAndRender();\n        updateUndoRedoButtons();\n        streamStopBtn.disabled = true;\n      }\n\n      init();\n\n      // Expose some debug on window for advanced exploration\n      window._slidingWindowState = state;\n      window._rebuildTrace = rebuildTraceAndRender;\n      window._computeForK = runOnceForK;\n      window._exportState = () => JSON.stringify({\n        arr: state.arr, k: state.k, ks: state.ks, algorithm: state.algorithm, tieBreak:state.tieBreak, circular: state.circular, streaming: state.streaming\n      });\n\n    })();\n  </script>\n</body>\n</html>"
