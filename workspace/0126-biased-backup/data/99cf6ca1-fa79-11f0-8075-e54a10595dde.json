    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Backtracking Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h2>Backtracking Demo</h2>\n    <p>Use the controls to explore backtracking solutions for generating combinations of numbers.</p>\n\n    <label for=\"target\">Target Sum:</label>\n    <input type=\"number\" id=\"target\" value=\"5\" min=\"1\" />\n    <button onclick=\"startBacktracking()\">Start Backtracking</button>\n    <br><br>\n\n    <p>Current Path: <span id=\"currentPath\"></span></p>\n    <p>All Results: <span id=\"results\"></span></p>\n    <p>Status: <span id=\"status\"></span></p>\n    <br>\n\n    <h3>Controls</h3>\n    <button onclick=\"backtrack()\">Backtrack</button>\n    <button onclick=\"reset()\">Reset</button>\n    <button onclick=\"next()\">Next Step</button>\n    <button onclick=\"previous()\">Previous Step</button>\n    \n    <script>\n        let targetSum = 0;\n        let currentPath = [];\n        let results = [];\n        let explorationHistory = [];\n        let currentStep = -1;\n\n        function startBacktracking() {\n            targetSum = Number(document.getElementById(\"target\").value);\n            currentPath = [];\n            results = [];\n            explorationHistory = [];\n            currentStep = -1;\n            document.getElementById(\"status\").innerText = \"Exploring...\";\n            backtrack(0);\n            updateDisplay();\n        }\n\n        function backtrack(start) {\n            if (calculateSum(currentPath) === targetSum) {\n                results.push([...currentPath]);\n            }\n\n            for (let i = start; i <= targetSum; i++) {\n                currentPath.push(i);\n                explorationHistory.push([...currentPath]); // Store exploration history\n                backtrack(i); // Explore with the next number\n                currentPath.pop(); // Backtrack\n            }\n            if (currentStep < explorationHistory.length - 1) {\n                currentStep++;\n            }\n        }\n\n        function calculateSum(arr) {\n            return arr.reduce((a, b) => a + b, 0);\n        }\n\n        function updateDisplay() {\n            document.getElementById(\"currentPath\").innerText = currentStep >= 0 ? explorationHistory[currentStep].join(\", \") : \"\";\n            document.getElementById(\"results\").innerText = results.map(r => r.join(\", \")).join(\" | \") || \"None\";\n            document.getElementById(\"status\").innerText = currentStep < 0 ? \"Ready to explore\" : \"Exploring...\";\n        }\n\n        function backtrack() {\n            if (currentStep > 0) {\n                currentStep--;\n                updateDisplay();\n            }\n        }\n\n        function next() {\n            if (currentStep < explorationHistory.length - 1) {\n                currentStep++;\n                updateDisplay();\n            }\n        }\n\n        function previous() {\n            if (currentStep > 0) {\n                currentStep--;\n                updateDisplay();\n            }\n        }\n\n        function reset() {\n            targetSum = 0;\n            currentPath = [];\n            results = [];\n            explorationHistory = [];\n            currentStep = -1;\n            updateDisplay();\n        }\n    </script>\n</body>\n</html>"
