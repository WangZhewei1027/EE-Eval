    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Symmetric Cryptography — Visual Concept</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #061121;\n    --accent: #7ce7c9;\n    --accent-2: #6ea8ff;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.6);\n    --glass-2: rgba(255,255,255,0.04);\n    --neon: rgba(124,231,201,0.12);\n    --card-radius: 18px;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter,system-ui,-apple-system,'Segoe UI',Roboto,'Helvetica Neue',Arial;\n    background: radial-gradient(1200px 700px at 10% 10%, rgba(110,168,255,0.06), transparent 8%),\n                radial-gradient(900px 600px at 90% 90%, rgba(124,231,201,0.04), transparent 12%),\n                linear-gradient(180deg, var(--bg1) 0%, var(--bg2) 100%);\n    color:#eaf9f4;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n    padding:48px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Subtle particle canvas container */\n  #particle-wrap{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    z-index:0;\n    mix-blend-mode:screen;\n    opacity:0.7;\n  }\n\n  .container{\n    width:100%;\n    max-width:1100px;\n    z-index:2;\n    display:grid;\n    grid-template-columns: 520px 1fr;\n    gap:32px;\n    align-items:center;\n  }\n\n  /* Left hero card */\n  .hero{\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border-radius:var(--card-radius);\n    padding:34px;\n    position:relative;\n    box-shadow: 0 8px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    overflow:visible;\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n  .title{\n    display:flex;\n    gap:18px;\n    align-items:center;\n  }\n  .logo{\n    width:84px;\n    height:84px;\n    border-radius:16px;\n    background: linear-gradient(135deg, rgba(124,231,201,0.12), rgba(110,168,255,0.08));\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    box-shadow: 0 8px 30px rgba(14,30,60,0.35);\n    flex:0 0 84px;\n    position:relative;\n    overflow:visible;\n  }\n  /* Key SVG rotation */\n  .key-wrap{\n    width:66px;height:66px;\n    display:flex;align-items:center;justify-content:center;\n    transform-origin:center;\n    transition:transform 0.9s cubic-bezier(.2,.9,.3,1);\n  }\n  .key-svg{\n    width:52px;height:52px; filter:drop-shadow(0 6px 18px rgba(86,146,255,0.12));\n  }\n\n  h1{\n    margin:0;\n    font-family:'Playfair Display',serif;\n    font-size:28px;\n    line-height:1.02;\n    letter-spacing:-0.02em;\n    color: #f3fff9;\n  }\n  p.lead{\n    margin:8px 0 0 0;\n    color:var(--muted);\n    font-size:13.5px;\n    max-width:360px;\n  }\n\n  /* Connector / diagram area */\n  .diagram{\n    margin-top:28px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.015));\n    border-radius:14px;\n    padding:18px;\n    display:flex;\n    gap:16px;\n    align-items:center;\n    justify-content:space-between;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n\n  .panel{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:12px 14px;\n    min-width:150px;\n    flex:0 0 170px;\n    text-align:center;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    position:relative;\n  }\n  .panel h3{\n    font-size:12px;\n    margin:0 0 6px 0;\n    color:var(--muted);\n    font-weight:600;\n    letter-spacing:0.08em;\n    text-transform:uppercase;\n  }\n  .data-box{\n    font-family:monospace;\n    font-size:18px;\n    letter-spacing:0.12em;\n    color:#e8fff6;\n    display:inline-block;\n    padding:10px 14px;\n    border-radius:10px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    min-width:110px;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n  }\n\n  /* Key central */\n  .center{\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:10px;\n    min-width:220px;\n  }\n  .key-card{\n    width:220px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.025), rgba(255,255,255,0.01));\n    border-radius:12px;\n    padding:12px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:10px;\n    box-shadow: 0 12px 40px rgba(99,157,255,0.06), inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .key-text{\n    font-family:monospace;\n    letter-spacing:0.14em;\n    font-weight:700;\n    color:var(--accent);\n    font-size:16px;\n  }\n  .key-mask{\n    color:rgba(255,255,255,0.18);\n    letter-spacing:0.18em;\n  }\n\n  /* Arrows and path */\n  .arrow{\n    width:160px;\n    height:100%;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n  .arrow svg{filter:drop-shadow(0 8px 24px rgba(110,168,255,0.06));}\n  .path-anim {\n    stroke: url(#gradLine);\n    stroke-width:3;\n    stroke-linecap:round;\n    fill:none;\n    stroke-dasharray: 300;\n    stroke-dashoffset: 300;\n    animation: pathFlow 3.6s linear infinite;\n    opacity:0.9;\n  }\n  @keyframes pathFlow{\n    0%{stroke-dashoffset:300}\n    50%{stroke-dashoffset:0}\n    100%{stroke-dashoffset:300}\n  }\n\n  /* Right info panel */\n  .info{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:var(--card-radius);\n    padding:36px;\n    min-height:480px;\n    box-shadow: 0 30px 80px rgba(2,6,23,0.55);\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    justify-content:space-between;\n  }\n  .info h2{\n    margin:0;\n    font-family:'Playfair Display',serif;\n    font-size:22px;\n    color:#f8fffd;\n  }\n  .info p{\n    margin:8px 0 0 0;\n    color:var(--muted);\n    line-height:1.5;\n    font-size:13.6px;\n    max-width:520px;\n  }\n\n  /* process lane */\n  .lane{\n    margin-top:14px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:flex-start;\n    overflow:hidden;\n  }\n  .pill{\n    min-width:84px;\n    padding:10px 14px;\n    border-radius:999px;\n    background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.02);\n    color:var(--muted);\n    font-size:13px;\n    display:flex;\n    gap:8px;\n    align-items:center;\n  }\n  .pill strong{color:#eaf9f4;font-weight:700}\n\n  /* animated word flows */\n  .flow-viewport{\n    height:120px;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:16px;\n    margin-top:26px;\n  }\n  .flow-box{\n    flex:1;\n    height:100%;\n    background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01));\n    border-radius:14px;\n    padding:18px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    position:relative;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .word{\n    font-family:monospace;\n    font-size:24px;\n    letter-spacing:0.16em;\n    color:#e8fff6;\n    display:flex;\n    gap:8px;\n  }\n  .letter{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    width:40px;height:40px;border-radius:8px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    transform-origin:center;\n    transition:transform 420ms cubic-bezier(.2,.9,.3,1), background 420ms;\n    box-shadow: 0 8px 24px rgba(2,6,23,0.45);\n    color:#eaf9f4;\n    font-weight:700;\n  }\n  .letter.muted{color:rgba(255,255,255,0.16); background:transparent; box-shadow:none; font-weight:600}\n\n  /* controls */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-top:16px;\n  }\n  .btn{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.035);\n    padding:10px 14px;\n    border-radius:12px;\n    color:#e8fff4;\n    cursor:pointer;\n    font-weight:700;\n    letter-spacing:0.04em;\n    transition:transform 180ms ease, box-shadow 180ms ease, background 180ms;\n    box-shadow: 0 8px 26px rgba(2,6,23,0.5);\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n  }\n  .btn:active{transform:translateY(1px)}\n  .btn.secondary{\n    color:var(--muted);\n    background:transparent;\n    border:1px dashed rgba(255,255,255,0.03);\n    box-shadow:none;\n  }\n\n  /* subtle animated glows */\n  .glow-l{\n    position:absolute;\n    left:-80px;top:-60px;\n    width:260px;height:260px;\n    background: radial-gradient(circle at 30% 30%, rgba(110,168,255,0.12), transparent 35%);\n    filter:blur(36px);\n    z-index:0;\n    pointer-events:none;\n  }\n  .glow-r{\n    position:absolute;\n    right:-90px;bottom:-70px;\n    width:320px;height:320px;\n    background: radial-gradient(circle at 70% 70%, rgba(124,231,201,0.08), transparent 35%);\n    filter:blur(40px);\n    z-index:0;\n    pointer-events:none;\n  }\n\n  /* small footer */\n  .foot{\n    font-size:12px;\n    color:var(--muted);\n    display:flex;\n    align-items:center;\n    gap:12px;\n    margin-top:8px;\n  }\n\n  /* Responsive */\n  @media (max-width:980px){\n    .container{grid-template-columns:1fr; padding:0 12px}\n    .hero{order:2}\n    .info{order:1}\n    .logo{display:none}\n  }\n</style>\n</head>\n<body>\n<canvas id=\"particle-wrap\"></canvas>\n\n<div class=\"container\" role=\"main\" aria-label=\"Symmetric cryptography concept visualization\">\n  <div class=\"hero\" aria-hidden=\"false\">\n    <div class=\"glow-l\"></div>\n    <div class=\"glow-r\"></div>\n\n    <div class=\"title\">\n      <div class=\"logo\" aria-hidden=\"true\">\n        <div class=\"key-wrap\" id=\"keyWrap\" title=\"Symmetric key\">\n          <!-- Decorative key SVG -->\n          <svg class=\"key-svg\" viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"gk\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#7CE7C9\" />\n                <stop offset=\"1\" stop-color=\"#6EA8FF\" />\n              </linearGradient>\n              <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur stdDeviation=\"6\" result=\"coloredBlur\"/>\n                <feMerge>\n                  <feMergeNode in=\"coloredBlur\"/>\n                  <feMergeNode in=\"SourceGraphic\"/>\n                </feMerge>\n              </filter>\n            </defs>\n            <g filter=\"url(#glow)\">\n              <path d=\"M54 28a10 10 0 1 0-12 9.8L40.2 51 34 49l-2 4-6-3 2-6-3-2 7.8-7.8A10 10 0 0 0 54 28z\" stroke=\"url(#gk)\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"rgba(124,231,201,0.06)\"/>\n              <circle cx=\"46\" cy=\"28\" r=\"2.6\" fill=\"#eaf9f4\" opacity=\"0.85\"/>\n            </g>\n          </svg>\n        </div>\n      </div>\n\n      <div>\n        <h1>Symmetric Cryptography</h1>\n        <p class=\"lead\">One key, two directions — encrypt & decrypt. This visualization illustrates how identical secrets can transform readable messages into ciphertext and back again.</p>\n      </div>\n    </div>\n\n    <div class=\"diagram\" aria-hidden=\"false\" style=\"margin-top:22px;\">\n      <div class=\"panel\" aria-hidden=\"true\">\n        <h3>Plaintext</h3>\n        <div class=\"data-box\" id=\"plaintextBox\" aria-hidden=\"false\">SECRET</div>\n      </div>\n\n      <div class=\"center\" aria-hidden=\"true\">\n        <div class=\"key-card\" role=\"img\" aria-label=\"Shared key\">\n          <div class=\"key-text\" id=\"keyVisual\">\n            <span class=\"key-mask\">••••••••</span>\n          </div>\n        </div>\n        <small style=\"color:var(--muted); font-size:12px;\">Same key used to encrypt & decrypt</small>\n      </div>\n\n      <div class=\"panel\" aria-hidden=\"true\">\n        <h3>Ciphertext</h3>\n        <div class=\"data-box\" id=\"ciphertextBox\" aria-hidden=\"false\">KHOOR</div>\n      </div>\n    </div>\n\n    <div class=\"flow-viewport\" aria-hidden=\"false\">\n      <div class=\"flow-box\" aria-hidden=\"true\">\n        <div style=\"text-align:left;width:100%;\">\n          <div style=\"color:var(--muted); font-size:12px; margin-bottom:8px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;\">Encrypt →</div>\n          <div class=\"word\" id=\"plainFlow\" aria-hidden=\"true\"></div>\n        </div>\n      </div>\n\n      <div style=\"width:78px;display:flex;flex-direction:column;align-items:center;gap:6px;\">\n        <svg width=\"78\" height=\"78\" viewBox=\"0 0 78 78\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"gradLine\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7CE7C9\"/>\n              <stop offset=\"1\" stop-color=\"#6EA8FF\"/>\n            </linearGradient>\n          </defs>\n          <circle cx=\"39\" cy=\"39\" r=\"36\" stroke=\"url(#gradLine)\" stroke-width=\"1.2\" opacity=\"0.08\"/>\n          <g transform=\"translate(20,20)\">\n            <path d=\"M0 18 L18 0\" stroke=\"url(#gradLine)\" stroke-width=\"3.6\" stroke-linecap=\"round\" />\n            <path d=\"M18 0 L26 8\" stroke=\"url(#gradLine)\" stroke-width=\"3.6\" stroke-linecap=\"round\" />\n          </g>\n        </svg>\n        <small style=\"color:var(--muted); font-size:12px;\">Key</small>\n      </div>\n\n      <div class=\"flow-box\" aria-hidden=\"true\">\n        <div style=\"text-align:right;width:100%;\">\n          <div style=\"color:var(--muted); font-size:12px; margin-bottom:8px; font-weight:600; letter-spacing:0.08em; text-transform:uppercase;\">← Decrypt</div>\n          <div class=\"word\" id=\"cipherFlow\" aria-hidden=\"true\"></div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"controls\" style=\"margin-top:18px;\">\n      <button class=\"btn\" id=\"playBtn\" aria-pressed=\"false\" title=\"Animate the encryption cycle\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(1px);\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"#dffbf2\" /></svg>\n        Animate\n      </button>\n      <button class=\"btn secondary\" id=\"revealBtn\" aria-pressed=\"false\" title=\"Reveal or hide the key\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(1px)\"><path d=\"M12 5c-7 0-10 7-10 7s3 7 10 7 10-7 10-7-3-7-10-7zm0 10a3 3 0 1 1 .001-6.001A3 3 0 0 1 12 15z\" fill=\"#bfeee0\" /></svg>\n        Reveal Key\n      </button>\n    </div>\n\n    <div class=\"foot\" aria-hidden=\"true\">\n      <div style=\"display:flex;align-items:center;gap:10px;\">\n        <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" style=\"opacity:0.9\"><path d=\"M5 12h14\" stroke=\"#b0e9d6\" stroke-width=\"2.2\" stroke-linecap=\"round\" /></svg>\n        <div style=\"font-size:12px;color:var(--muted)\"><strong style=\"color:#eafcf4\">Symmetric key</strong> — shared secret used for both operations</div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"info\" aria-hidden=\"false\">\n    <div>\n      <h2>How it works — in one glance</h2>\n      <p>\n        Symmetric cryptography uses the same secret key to both encrypt and decrypt messages. In this simplified visualization, you can see a plaintext word travel through a shared key producing ciphertext — and the same key allows the original message to be recovered.\n      </p>\n\n      <div class=\"lane\" aria-hidden=\"true\" style=\"margin-top:18px;\">\n        <div class=\"pill\"><strong>Key</strong><span style=\"width:6px;display:inline-block\"></span><span style=\"color:var(--muted)\">Shared secret</span></div>\n        <div class=\"pill\"><strong>Encrypt</strong><span style=\"width:6px;display:inline-block\"></span><span style=\"color:var(--muted)\">Transform</span></div>\n        <div class=\"pill\"><strong>Decrypt</strong><span style=\"width:6px;display:inline-block\"></span><span style=\"color:var(--muted)\">Reverse</span></div>\n      </div>\n    </div>\n\n    <div style=\"display:flex;flex-direction:column;gap:12px;\">\n      <p style=\"font-size:13px;color:var(--muted);margin:0;\">\n        Note: This demo is illustrative. Real symmetric systems use strong algorithms (AES, ChaCha20, etc.) and careful key management. Still, the central idea remains: one key — two directions.\n      </p>\n\n      <div style=\"display:flex;justify-content:space-between;align-items:center;gap:12px;\">\n        <div style=\"color:var(--muted);font-size:12px;\">Visualization by • Aesthetic Crypto</div>\n        <div style=\"display:flex;gap:8px;align-items:center;\">\n          <div style=\"width:10px;height:10px;border-radius:2px;background:linear-gradient(180deg,#7CE7C9,#6EA8FF)\"></div>\n          <small style=\"color:var(--muted);font-size:12px;\">Simple • Educational</small>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n/* Particle background for ambience */\nconst canvas = document.getElementById('particle-wrap');\nconst dpr = Math.max(1, window.devicePixelRatio || 1);\nlet ctx, W, H, particles;\n\nfunction initCanvas(){\n  canvas.width = innerWidth * dpr;\n  canvas.height = innerHeight * dpr;\n  canvas.style.width = innerWidth + 'px';\n  canvas.style.height = innerHeight + 'px';\n  ctx = canvas.getContext('2d');\n  ctx.scale(dpr, dpr);\n  W = innerWidth; H = innerHeight;\n  createParticles();\n}\nfunction createParticles(){\n  particles = [];\n  const count = Math.round((W*H) / 90000);\n  for(let i=0;i<count;i++){\n    particles.push({\n      x: Math.random()*W,\n      y: Math.random()*H,\n      r: Math.random()*1.6 + 0.6,\n      vx: (Math.random()-0.5)*0.1,\n      vy: (Math.random()-0.5)*0.2,\n      hue: Math.random()*360\n    });\n  }\n}\nfunction draw(){\n  ctx.clearRect(0,0,W,H);\n  for(const p of particles){\n    p.x += p.vx;\n    p.y += p.vy;\n    if(p.x < -10) p.x = W+10;\n    if(p.x > W+10) p.x = -10;\n    if(p.y < -10) p.y = H+10;\n    if(p.y > H+10) p.y = -10;\n    const g = ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r*18);\n    g.addColorStop(0, `rgba(110,168,255,0.08)`);\n    g.addColorStop(0.35, `rgba(124,231,201,0.06)`);\n    g.addColorStop(1, `rgba(10,20,40,0)`);\n    ctx.fillStyle = g;\n    ctx.beginPath();\n    ctx.arc(p.x,p.y,p.r*12,0,Math.PI*2);\n    ctx.fill();\n  }\n  requestAnimationFrame(draw);\n}\ninitCanvas();\ndraw();\nwindow.addEventListener('resize', initCanvas);\n\n/* Simple visualization logic - minimal interactive controls */\nconst playBtn = document.getElementById('playBtn');\nconst revealBtn = document.getElementById('revealBtn');\nconst keyWrap = document.getElementById('keyWrap');\nconst keyVisual = document.getElementById('keyVisual');\nconst plainFlow = document.getElementById('plainFlow');\nconst cipherFlow = document.getElementById('cipherFlow');\nconst plaintextBox = document.getElementById('plaintextBox');\nconst ciphertextBox = document.getElementById('ciphertextBox');\n\nlet running = false;\nlet reveal = false;\n\n/* underlying simple symmetric transform (illustrative only) */\nconst KEY = \"BRAVO123\"; // example key (masked by default)\nconst PLAINTEXT = \"SYMMETRIC\";\nlet intervalId = null;\n\n/* util: spread letters as elements */\nfunction renderWords(plain, cipher){\n  plainFlow.innerHTML = '';\n  cipherFlow.innerHTML = '';\n\n  for(let ch of plain){\n    const span = document.createElement('div');\n    span.className = 'letter';\n    span.textContent = ch;\n    plainFlow.appendChild(span);\n  }\n  for(let ch of cipher){\n    const span = document.createElement('div');\n    span.className = 'letter muted';\n    span.textContent = ch;\n    cipherFlow.appendChild(span);\n  }\n}\n\n/* simple shift-by-key algorithm (for demonstration): shift letters by sum of key char codes mod 26 */\nfunction computeCipher(plain, key){\n  const ksum = Array.from(key).reduce((s,c)=>s + c.charCodeAt(0),0);\n  const shift = ksum % 26;\n  let out = '';\n  for(let ch of plain){\n    if(/[A-Z]/.test(ch)){\n      out += String.fromCharCode(((ch.charCodeAt(0)-65 + shift)%26)+65);\n    } else out += ch;\n  }\n  return out;\n}\n\nfunction revealKeyToggle(){\n  reveal = !reveal;\n  revealBtn.setAttribute('aria-pressed', reveal.toString());\n  if(reveal){\n    keyVisual.innerHTML = '<span style=\"color:#bfeee0;font-weight:800;font-family:monospace;letter-spacing:0.14em;\">' + KEY + '</span>';\n  }else{\n    keyVisual.innerHTML = '<span class=\"key-mask\">••••••••</span>';\n  }\n}\n\n/* animate cycle: highlight transformations */\nfunction animateCycle(){\n  if(!running) return;\n  // visible plaintext -> slide to cipher\n  const plainLetters = Array.from(plainFlow.children);\n  const cipherLetters = Array.from(cipherFlow.children);\n  // calculate cipher for current key\n  const cipher = computeCipher(PLAINTEXT, KEY);\n  ciphertextBox.textContent = cipher;\n  ciphertextBox.style.transition = 'transform 420ms ease, opacity 320ms';\n  ciphertextBox.style.transform = 'translateY(6px)';\n  ciphertextBox.style.opacity = '0.85';\n\n  // animate letters in sequence\n  plainLetters.forEach((el, idx) => {\n    el.style.transition = `transform 420ms cubic-bezier(.2,.9,.3,1) ${idx*70}ms, background 320ms`;\n    el.style.transform = 'translateY(-12px) scale(1.08)';\n    el.style.background = 'linear-gradient(180deg, rgba(124,231,201,0.12), rgba(110,168,255,0.06))';\n    setTimeout(()=> {\n      // set corresponding cipher letter visible and animated\n      const c = cipher[idx] || '';\n      const cEl = cipherLetters[idx];\n      if(cEl){\n        cEl.textContent = c;\n        cEl.classList.remove('muted');\n        cEl.style.transform = 'translateY(12px) scale(1.02)';\n        cEl.style.background = 'linear-gradient(180deg, rgba(124,231,201,0.06), rgba(110,168,255,0.04))';\n        cEl.style.transition = 'transform 420ms cubic-bezier(.2,.9,.3,1)';\n        setTimeout(()=> {\n          cEl.style.transform = 'translateY(0) scale(1)';\n        }, 60);\n      }\n    }, idx*100 + 160);\n\n    setTimeout(()=> {\n      el.style.transform = 'translateY(0) scale(1)';\n      el.style.background = '';\n    }, idx*100 + 600);\n  });\n\n  // subtle key rotation\n  keyWrap.style.transform = 'rotate(18deg)';\n  setTimeout(()=> keyWrap.style.transform = 'rotate(0deg)', 900);\n\n  // cleanup for next cycle\n  setTimeout(()=> {\n    ciphertextBox.style.transform = 'translateY(0px)';\n    ciphertextBox.style.opacity = '1.0';\n    // mute cipher letters again for visual reset\n    cipherLetters.forEach((cEl, idx) => {\n      cEl.classList.add('muted');\n      cEl.style.background = '';\n      cEl.style.transform = '';\n    });\n  }, 1400);\n}\n\n/* start/stop toggle */\nfunction togglePlay(){\n  running = !running;\n  playBtn.setAttribute('aria-pressed', running.toString());\n  if(running){\n    playBtn.querySelector('svg path').setAttribute('fill','#7CE7C9');\n    playBtn.style.boxShadow = '0 10px 30px rgba(124,231,201,0.08)';\n    // initial render\n    const cipher = computeCipher(PLAINTEXT, KEY);\n    plaintextBox.textContent = PLAINTEXT;\n    ciphertextBox.textContent = cipher;\n    renderWords(PLAINTEXT, cipher);\n    // run cycles every 2.2s\n    animateCycle();\n    intervalId = setInterval(animateCycle, 2200);\n  }else{\n    playBtn.querySelector('svg path').setAttribute('fill','#dffbf2');\n    playBtn.style.boxShadow = '';\n    clearInterval(intervalId);\n    intervalId = null;\n    // reset visual letters\n    const letters = document.querySelectorAll('.letter');\n    letters.forEach(el=>{ el.style.transform=''; el.style.background=''; el.classList.remove('muted'); });\n    ciphertextBox.style.transition = '';\n  }\n}\n\n/* initialize static state */\n(function init(){\n  // initial compute and render (muted)\n  const cipher = computeCipher(PLAINTEXT, KEY);\n  plaintextBox.textContent = PLAINTEXT;\n  ciphertextBox.textContent = cipher;\n  renderWords(PLAINTEXT, cipher);\n  // initially mask cipher letters\n  const cEls = cipherFlow.children;\n  for(let el of cEls) el.classList.add('muted');\n\n  // attach handlers\n  playBtn.addEventListener('click', togglePlay);\n  revealBtn.addEventListener('click', revealKeyToggle);\n\n  // small breathing for key icon\n  let grow = true;\n  setInterval(()=> {\n    keyWrap.style.transform = grow ? 'translateY(-2px) scale(1.02)' : 'translateY(0) scale(1)';\n    grow = !grow;\n  }, 2300);\n\n})();\n</script>\n</body>\n</html>"
