    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Trie</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f2f2f2;\n            margin: 0;\n            padding: 0;\n        }\n\n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n\n        .header {\n            background-color: #333;\n            color: #fff;\n            padding: 10px;\n            text-align: center;\n        }\n\n        .header h1 {\n            margin: 0;\n        }\n\n        .body {\n            padding: 20px;\n        }\n\n        .button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>Trie Demo</h1>\n        </div>\n        <div class=\"body\">\n            <p>Trie is a data structure that uses a tree-like structure to store a collection of strings.</p>\n            <p>It is commonly used for tasks such as autocomplete, spell checking, and language translation.</p>\n        </div>\n    </div>\n    <script>\n        class TrieNode {\n            constructor() {\n                this.children = {};\n                this.isEndOfWord = false;\n            }\n        }\n\n        class Trie {\n            constructor() {\n                this.root = new TrieNode();\n            }\n\n            insert(word) {\n                let node = this.root;\n                for (let char of word) {\n                    if (!node.children[char]) {\n                        node.children[char] = new TrieNode();\n                    }\n                    node = node.children[char];\n                }\n                node.isEndOfWord = true;\n            }\n\n            search(word) {\n                let node = this.root;\n                for (let char of word) {\n                    if (!node.children[char]) {\n                        return false;\n                    }\n                    node = node.children[char];\n                }\n                return node.isEndOfWord;\n            }\n\n            startsWith(prefix) {\n                let node = this.root;\n                for (let char of prefix) {\n                    if (!node.children[char]) {\n                        return false;\n                    }\n                    node = node.children[char];\n                }\n                return true;\n            }\n        }\n\n        let trie = new Trie();\n        let inputField = document.getElementById('inputField');\n        let searchButton = document.getElementById('searchButton');\n        let startsWithButton = document.getElementById('startsWithButton');\n\n        inputField.addEventListener('input', () => {\n            trie.insert(inputField.value);\n            updateUI();\n        });\n\n        searchButton.addEventListener('click', () => {\n            let word = inputField.value;\n            if (word) {\n                if (trie.search(word)) {\n                    console.log(`Word '${word}' found`);\n                } else {\n                    console.log(`Word '${word}' not found`);\n                }\n            } else {\n                console.log('Please enter a word');\n            }\n        });\n\n        startsWithButton.addEventListener('click', () => {\n            let prefix = inputField.value;\n            if (prefix) {\n                if (trie.startsWith(prefix)) {\n                    console.log(`Prefix '${prefix}' found`);\n                } else {\n                    console.log(`Prefix '${prefix}' not found`);\n                }\n            } else {\n                console.log('Please enter a prefix');\n            }\n        });\n\n        function updateUI() {\n            let output = document.getElementById('output');\n            output.innerHTML = '';\n            for (let word in trie.root.children) {\n                let node = trie.root.children[word];\n                output.innerHTML += `<p>${word}: ${node.isEndOfWord ? 'End of word' : ''} (${node.children ? 'Has children' : ''})</p>`;\n            }\n        }\n    </script>\n</body>\n</html>"
