    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Visual Queue Concept</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&display=swap');\n        \n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n        \n        .container {\n            width: 90%;\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n            position: relative;\n        }\n        \n        h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            margin-bottom: 1.5rem;\n            text-align: center;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            text-shadow: 0 2px 10px rgba(108, 92, 231, 0.1);\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            text-align: center;\n            margin-bottom: 3rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n        }\n        \n        .queue-container {\n            position: relative;\n            height: 400px;\n            width: 100%;\n            background: rgba(255, 255, 255, 0.8);\n            border-radius: 20px;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n            backdrop-filter: blur(5px);\n            overflow: hidden;\n            padding: 2rem;\n            display: flex;\n            flex-direction: column;\n        }\n        \n        .queue-visual {\n            flex: 1;\n            display: flex;\n            align-items: center;\n            justify-content: flex-start;\n            padding: 1rem;\n            position: relative;\n            overflow: hidden;\n        }\n        \n        .queue-line {\n            position: absolute;\n            bottom: 30%;\n            left: 0;\n            width: 100%;\n            height: 4px;\n            background: linear-gradient(to right, var(--secondary), var(--primary));\n            z-index: 1;\n            border-radius: 2px;\n        }\n        \n        .queue-item {\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, var(--primary), var(--accent));\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: 700;\n            font-size: 1.5rem;\n            margin-right: -20px;\n            box-shadow: 0 10px 20px rgba(108, 92, 231, 0.3);\n            transition: var(--transition);\n            position: relative;\n            z-index: 2;\n            opacity: 0;\n            transform: translateY(50px);\n            animation: fadeIn 0.5s forwards;\n        }\n        \n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        .queue-item::before {\n            content: '';\n            position: absolute;\n            top: -5px;\n            left: -5px;\n            right: -5px;\n            bottom: -5px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, var(--primary), var(--accent));\n            z-index: -1;\n            filter: blur(10px);\n            opacity: 0.5;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n        }\n        \n        .btn {\n            padding: 1rem 2rem;\n            border: none;\n            border-radius: 50px;\n            font-size: 1rem;\n            font-weight: 600;\n            cursor: pointer;\n            transition: var(--transition);\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            position: relative;\n            overflow: hidden;\n            color: white;\n        }\n        \n        .btn-enqueue {\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n        }\n        \n        .btn-dequeue {\n            background: linear-gradient(to right, var(--accent), #ff7675);\n        }\n        \n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);\n        }\n        \n        .btn:active {\n            transform: translateY(1px);\n        }\n        \n        .btn::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0));\n            opacity: 0;\n            transition: var(--transition);\n        }\n        \n        .btn:hover::after {\n            opacity: 1;\n        }\n        \n        .info-panel {\n            background: rgba(255, 255, 255, 0.9);\n            border-radius: 15px;\n            padding: 1.5rem;\n            margin-top: 2rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            border: 1px solid rgba(255, 255, 255, 0.3);\n        }\n        \n        .info-title {\n            font-size: 1.2rem;\n            margin-bottom: 1rem;\n            color: var(--primary);\n            font-weight: 600;\n        }\n        \n        .info-text {\n            line-height: 1.6;\n            color: var(--dark);\n            opacity: 0.8;\n        }\n        \n        .dequeue-animation {\n            animation: dequeue 0.8s forwards;\n        }\n        \n        @keyframes dequeue {\n            0% {\n                transform: translateX(0);\n                opacity: 1;\n            }\n            100% {\n                transform: translateX(-200px);\n                opacity: 0;\n            }\n        }\n        \n        .floating-bg {\n            position: absolute;\n            width: 400px;\n            height: 400px;\n            border-radius: 50%;\n            background: linear-gradient(135deg, rgba(108, 92, 231, 0.1), rgba(253, 121, 168, 0.1));\n            z-index: -1;\n            animation: float 15s infinite ease-in-out;\n        }\n        \n        .floating-bg:nth-child(1) {\n            top: -100px;\n            left: -100px;\n            animation-delay: 0s;\n        }\n        \n        .floating-bg:nth-child(2) {\n            bottom: -150px;\n            right: -100px;\n            animation-delay: 2.5s;\n        }\n        \n        @keyframes float {\n            0%, 100% {\n                transform: translate(0, 0) rotate(0deg);\n            }\n            25% {\n                transform: translate(50px, 50px) rotate(5deg);\n            }\n            50% {\n                transform: translate(0, 100px) rotate(0deg);\n            }\n            75% {\n                transform: translate(-50px, 50px) rotate(-5deg);\n            }\n        }\n        \n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n        }\n        \n        .particle {\n            position: absolute;\n            width: 5px;\n            height: 5px;\n            border-radius: 50%;\n            background: rgba(108, 92, 231, 0.3);\n            animation: float 10s infinite ease-in-out;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"floating-bg\"></div>\n    <div class=\"floating-bg\"></div>\n    \n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <div class=\"container\">\n        <h1>Queue Visualization</h1>\n        <p class=\"subtitle\">First In, First Out (FIFO) Data Structure</p>\n        \n        <div class=\"queue-container\">\n            <div class=\"queue-visual\" id=\"queueVisual\">\n                <div class=\"queue-line\"></div>\n                <!-- Queue items will be added here -->\n            </div>\n        </div>\n        \n        <div class=\"controls\">\n            <button class=\"btn btn-enqueue\" id=\"enqueueBtn\">Enqueue</button>\n            <button class=\"btn btn-dequeue\" id=\"dequeueBtn\">Dequeue</button>\n        </div>\n        \n        <div class=\"info-panel\">\n            <h3 class=\"info-title\">About Queues</h3>\n            <p class=\"info-text\">\n                A queue is a linear data structure that follows the First-In-First-Out (FIFO) principle.\n                Elements are added (enqueued) at the rear and removed (dequeued) from the front.\n                This visualization demonstrates the fundamental operations of a queue with elegant animations.\n            </p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const queueVisual = document.getElementById('queueVisual');\n            const enqueueBtn = document.getElementById('enqueueBtn');\n            const dequeueBtn = document.getElementById('dequeueBtn');\n            const particlesContainer = document.getElementById('particles');\n            \n            let queue = [];\n            let counter = 1;\n            \n            // Create floating particles\n            for (let i = 0; i < 20; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.top = `${Math.random() * 100}%`;\n                particle.style.width = `${Math.random() * 5 + 3}px`;\n                particle.style.height = particle.style.width;\n                particle.style.background = `rgba(${Math.floor(Math.random() * 100 + 156)}, ${Math.floor(Math.random() * 100 + 92)}, ${Math.floor(Math.random() * 100 + 231)}, ${Math.random() * 0.3 + 0.1})`;\n                particle.style.animationDuration = `${Math.random() * 10 + 5}s`;\n                particle.style.animationDelay = `${Math.random() * 5}s`;\n                particlesContainer.appendChild(particle);\n            }\n            \n            // Enqueue operation\n            enqueueBtn.addEventListener('click', function() {\n                if (queue.length >= 8) return;\n                \n                const item = document.createElement('div');\n                item.classList.add('queue-item');\n                item.textContent = counter++;\n                item.style.animationDelay = `${queue.length * 0.1}s`;\n                \n                queueVisual.appendChild(item);\n                queue.push(item);\n                \n                // Update positions with smooth transition\n                setTimeout(() => {\n                    queue.forEach((item, index) => {\n                        item.style.transform = `translateX(${index * 100}px)`;\n                    });\n                }, 100);\n            });\n            \n            // Dequeue operation\n            dequeueBtn.addEventListener('click', function() {\n                if (queue.length === 0) return;\n                \n                const firstItem = queue.shift();\n                firstItem.classList.add('dequeue-animation');\n                \n                // Remove item after animation completes\n                setTimeout(() => {\n                    firstItem.remove();\n                    \n                    // Update remaining items' positions\n                    queue.forEach((item, index) => {\n                        item.style.transform = `translateX(${index * 100}px)`;\n                        item.style.transition = 'transform 0.5s ease-out';\n                    });\n                    \n                    // Reset transition after movement\n                    setTimeout(() => {\n                        queue.forEach(item => {\n                            item.style.transition = 'var(--transition)';\n                        });\n                    }, 500);\n                }, 800);\n            });\n            \n            // Initialize with 3 items\n            for (let i = 0; i < 3; i++) {\n                setTimeout(() => {\n                    enqueueBtn.click();\n                }, i * 200);\n            }\n        });\n    </script>\n</body>\n</html>"
