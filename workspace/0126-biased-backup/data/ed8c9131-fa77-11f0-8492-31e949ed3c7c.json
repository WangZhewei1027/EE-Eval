    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Stack Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(to right, #00c6ff, #0072ff);\n            color: #fff;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n            font-size: 18px;\n        }\n\n        h1 {\n            position: absolute;\n            top: 20px;\n            text-align: center;\n            color: #fff;\n            font-size: 3em;\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);\n        }\n\n        .container {\n            position: relative;\n            width: 300px;\n            height: 400px;\n            perspective: 1000px;\n        }\n\n        .stack {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            transform-style: preserve-3d;\n            transform: rotateX(0);\n            transition: transform 0.6s ease;\n        }\n\n        .block {\n            position: absolute;\n            width: 100%;\n            height: calc(100% / 5);\n            border: 1px solid rgba(255, 255, 255, 0.2);\n            font-size: 1.5em;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            opacity: 0.9;\n            border-radius: 8px;\n        }\n\n        .block:nth-child(1) {\n            background-color: #ff6b6b;\n            transform: translateZ(-50px);\n        }\n\n        .block:nth-child(2) {\n            background-color: #ff9474;\n            transform: translateZ(-30px);\n        }\n\n        .block:nth-child(3) {\n            background-color: #ffc65b;\n            transform: translateZ(-10px);\n        }\n\n        .block:nth-child(4) {\n            background-color: #84e0a1;\n            transform: translateZ(10px);\n        }\n\n        .block:nth-child(5) {\n            background-color: #56b7f1;\n            transform: translateZ(30px);\n        }\n\n        .button {\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            padding: 10px 20px;\n            background-color: rgba(255, 255, 255, 0.8);\n            color: #0072ff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            font-size: 1.2em;\n            transition: background-color 0.3s, transform 0.3s;\n        }\n\n        .button:hover {\n            background-color: rgba(255, 255, 255, 1);\n            transform: scale(1.05);\n        }\n\n        .button:focus {\n            outline: none;\n        }\n    </style>\n</head>\n<body>\n    <h1>Stack Visualization</h1>\n    <div class=\"container\">\n        <div class=\"stack\">\n            <div class=\"block\">1</div>\n            <div class=\"block\">2</div>\n            <div class=\"block\">3</div>\n            <div class=\"block\">4</div>\n            <div class=\"block\">5</div>\n        </div>\n    </div>\n    <button class=\"button\" onclick=\"toggleRotate()\">Toggle Rotate</button>\n\n    <script>\n        let rotated = false; // Track rotation state\n        function toggleRotate() {\n            const stack = document.querySelector('.stack');\n            if (!rotated) {\n                stack.style.transform = 'rotateX(360deg)'; // Rotate stack\n            } else {\n                stack.style.transform = 'rotateX(0deg)'; // Reset rotation\n            }\n            rotated = !rotated; // Toggle state\n        }\n    </script>\n</body>\n</html>"
