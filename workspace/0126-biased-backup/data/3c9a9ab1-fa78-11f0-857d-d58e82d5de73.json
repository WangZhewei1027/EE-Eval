    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>REST API — Visual Elegance in Tech</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;600&display=swap');\n  @keyframes pulse {\n    0%, 100% {\n      transform: scale(1);\n      opacity: 0.85;\n    }\n    50% {\n      transform: scale(1.05);\n      opacity: 1;\n    }\n  }\n  @keyframes floatUpDown {\n    0%, 100% {\n      transform: translateY(0);\n      opacity: 1;\n    }\n    50% {\n      transform: translateY(-15px);\n      opacity: 0.85;\n    }\n  }\n  @keyframes rotate360 {\n    from { transform: rotate(0deg);}\n    to { transform: rotate(360deg);}\n  }\n  @keyframes fadeInContent {\n    from {opacity:0; transform: translateY(20px);}\n    to {opacity:1; transform: translateY(0);}\n  }\n  :root {\n    --clr-blue: #005f73;\n    --clr-green: #94d2bd;\n    --clr-lime: #ee9b00;\n    --clr-dark: #0a192f;\n    --clr-light: #e5e5e5;\n    --clr-purple: #9d4edd;\n    --clr-pink: #ff6f91;\n  }\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    background: linear-gradient(135deg, var(--clr-dark) 20%, #142c45 100%);\n    font-family: 'Inter', sans-serif;\n    color: var(--clr-light);\n    overflow-x: hidden;\n  }\n  main {\n    max-width: 900px;\n    margin: 4rem auto 6rem;\n    padding: 0 2rem;\n    text-align: center;\n    animation: fadeInContent 1.4s ease forwards;\n  }\n  header {\n    margin-bottom: 3rem;\n  }\n  h1 {\n    font-weight: 600;\n    font-size: 3.8rem;\n    line-height: 1.1;\n    letter-spacing: -0.03em;\n    text-shadow:\n      0 0 10px rgba(0, 95, 115, 0.8),\n      0 0 20px rgba(148, 210, 189, 0.6);\n  }\n  h2 {\n    font-weight: 300;\n    font-size: 1.7rem;\n    color: var(--clr-green);\n    margin-top: 0.2em;\n    font-style: italic;\n    letter-spacing: 0.03em;\n    text-shadow: 0 0 6px var(--clr-green);\n  }\n  .api-visual {\n    position: relative;\n    margin: 4rem auto 5rem;\n    max-width: 800px;\n    height: 280px;\n    background: radial-gradient(circle at 40% 40%, #112d3a, #0a192f 90%);\n    border-radius: 24px;\n    box-shadow:\n      0 12px 24px rgba(0, 95, 115, 0.4),\n      inset 0 0 60px #415a69;\n    overflow: visible;\n  }\n  /* Endpoint rectangles with smooth shadows and glow */\n  .endpoint {\n    position: absolute;\n    width: 160px;\n    height: 90px;\n    border-radius: 16px;\n    background: linear-gradient(135deg, var(--clr-green) 0%, var(--clr-blue) 100%);\n    box-shadow:\n      0 8px 20px rgba(0, 95, 115, 0.6),\n      0 0 20px var(--clr-green);\n    color: var(--clr-light);\n    font-weight: 600;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    letter-spacing: 0.04em;\n    font-size: 1.2rem;\n    filter: drop-shadow(0 0 3px #94d2bd);\n    animation: pulse 6s ease-in-out infinite;\n  }\n  .endpoint:nth-child(1) {\n    top: 25px;\n    left: 40px;\n    animation-delay: 0s;\n  }\n  .endpoint:nth-child(2) {\n    top: 25px;\n    right: 40px;\n    background: linear-gradient(135deg, var(--clr-pink) 0%, var(--clr-purple) 100%);\n    box-shadow:\n      0 10px 26px rgba(157, 78, 221, 0.8),\n      0 0 26px var(--clr-purple);\n    animation-delay: 2s;\n  }\n  .endpoint:nth-child(3) {\n    bottom: 25px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: linear-gradient(135deg, var(--clr-lime) 0%, var(--clr-green) 100%);\n    box-shadow:\n      0 8px 20px rgba(238, 155, 0, 0.6),\n      0 0 20px var(--clr-lime);\n    animation-delay: 4s;\n  }\n  /* Center \"REST API\" core circle */\n  .api-core {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 160px;\n    height: 160px;\n    background: linear-gradient(145deg, #00b4d8, #0077b6);\n    border-radius: 50%;\n    box-shadow:\n      0 0 40px #00b4d8,\n      inset 0 0 20px #0093c4,\n      0 15px 30px rgba(0, 116, 185, 0.8);\n    transform: translate(-50%, -50%);\n    color: #e0f7fa;\n    font-weight: 700;\n    font-size: 2rem;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    text-shadow:\n      0 0 8px #48cae4,\n      0 0 15px #90e0ef;\n    animation: floatUpDown 6s ease-in-out infinite;\n  }\n  /* Connecting lines with subtle glow */\n  .connector {\n    position: absolute;\n    width: 6px;\n    background: linear-gradient(180deg, #48cae4 0%, transparent 100%);\n    border-radius: 4px;\n    filter: drop-shadow(0 0 8px #48cae4);\n    transform-origin: top center;\n    opacity: 0.8;\n  }\n  .connector-1 {\n    height: 70px;\n    top: 120px;\n    left: 120px;\n    transform: rotate(40deg);\n  }\n  .connector-2 {\n    height: 70px;\n    top: 120px;\n    right: 120px;\n    background: linear-gradient(0deg, #9d4edd 0%, transparent 100%);\n    filter: drop-shadow(0 0 8px #9d4edd);\n    transform: rotate(-40deg);\n  }\n  .connector-3 {\n    height: 70px;\n    bottom: 110px;\n    left: 50%;\n    width: 8px;\n    background: linear-gradient(0deg, #ee9b00 0%, transparent 100%);\n    filter: drop-shadow(0 0 10px #ee9b00);\n    transform: translateX(-50%);\n    border-radius: 5px;\n  }\n  /* Small node circles on connectors */\n  .node {\n    position: absolute;\n    width: 18px;\n    height: 18px;\n    border-radius: 50%;\n    background: var(--clr-light);\n    filter: drop-shadow(0 0 8px #e5e5e5);\n    opacity: 0.85;\n    box-shadow:\n      0 0 5px #eee,\n      inset 0 0 4px #c4d9e7;\n    animation: pulse 5s ease-in-out infinite;\n  }\n  .node-1 { top: 92px; left: 173px; }\n  .node-2 { top: 90px; right: 174px; background: #d4b3ff; box-shadow:\n    0 0 8px #a477ff, inset 0 0 6px #cbb7ff;}\n  .node-3 { bottom: 100px; left: 50%; transform: translateX(-50%); background: #ffd166; box-shadow:\n    0 0 10px #f4c23c, inset 0 0 5px #f9dc7c;}\n  /* Explanation box */\n  .explanation {\n    max-width: 680px;\n    margin: 0 auto 3rem;\n    font-weight: 300;\n    font-size: 1.1rem;\n    line-height: 1.6;\n    color: #c0d3db;\n    background: rgba(12, 34, 54, 0.65);\n    border-radius: 16px;\n    padding: 24px 32px;\n    box-shadow: 0 0 40px #004e63aa;\n    user-select: none;\n    letter-spacing: 0.02em;\n    text-align: justify;\n  }\n  /* Button container */\n  .btn-container {\n    margin-top: 2rem;\n  }\n  button {\n    font-family: 'Inter', sans-serif;\n    background: var(--clr-green);\n    border: none;\n    padding: 12px 28px;\n    margin: 0 12px;\n    border-radius: 30px;\n    font-size: 1rem;\n    font-weight: 600;\n    color: var(--clr-dark);\n    cursor: pointer;\n    box-shadow:\n      0 6px 16px #6dc9b3;\n    transition:\n      background 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.25s ease;\n  }\n  button:hover,\n  button:focus {\n    background: #75d6c3;\n    box-shadow:\n      0 12px 26px #40b49a;\n    transform: scale(1.07);\n    outline: none;\n  }\n  button:active {\n    transform: scale(0.98);\n    box-shadow: 0 4px 10px #2e8272;\n  }\n  /* Footer with subtle info */\n  footer {\n    text-align: center;\n    color: #375a71;\n    font-weight: 300;\n    font-size: 0.9rem;\n    margin-bottom: 18px;\n    user-select: none;\n  }\n</style>\n</head>\n<body>\n<main>\n  <header>\n    <h1>REST API</h1>\n    <h2>Representational State Transfer – The Web's Fluent Language</h2>\n  </header>\n\n  <section class=\"api-visual\" aria-label=\"Visual representation of REST API architecture\">\n    <div class=\"endpoint\" title=\"GET /users\">\n      GET /users\n    </div>\n    <div class=\"endpoint\" title=\"POST /orders\">\n      POST /orders\n    </div>\n    <div class=\"endpoint\" title=\"DELETE /items/:id\">\n      DELETE /items/:id\n    </div>\n\n    <div class=\"connector connector-1\"></div>\n    <div class=\"connector connector-2\"></div>\n    <div class=\"connector connector-3\"></div>\n\n    <div class=\"node node-1\" aria-hidden=\"true\"></div>\n    <div class=\"node node-2\" aria-hidden=\"true\"></div>\n    <div class=\"node node-3\" aria-hidden=\"true\"></div>\n\n    <div class=\"api-core\" title=\"REST API Core Concept\">\n      REST<br />API\n    </div>\n  </section>\n\n  <article class=\"explanation\" aria-live=\"polite\">\n    <p>\n      REST (Representational State Transfer) APIs allow seamless interaction between clients and servers, providing structured endpoints to <span style=\"font-weight:600; color:#ee9b00;\">GET</span>, <span style=\"font-weight:600; color:#9d4edd;\">POST</span>, <span style=\"font-weight:600; color:#ff6f91;\">DELETE</span>, and modify resources over HTTP. This stateless architectural style brings clarity and uniformity to web communications, enabling scalability and easy integration.\n    </p>\n  </article>\n\n  <div class=\"btn-container\" role=\"region\" aria-label=\"Example actions\">\n    <button id=\"btnShowExample\" aria-describedby=\"descExample\">\n      Show Example Response\n    </button>\n    <button id=\"btnReset\" aria-describedby=\"descReset\" disabled>\n      Reset View\n    </button>\n  </div>\n\n  <pre id=\"exampleResponse\" style=\"max-width:700px; margin: 2rem auto 0; padding:1.5rem 2rem; \n    background: rgba(7, 32, 54, 0.85);\n    border-radius: 16px; \n    box-shadow: 0 0 40px #0093c4cc;\n    font-family: 'Fira Mono', monospace, monospace;\n    font-size: 1rem;\n    line-height: 1.5;\n    color: #a0d8ef;\n    white-space: pre-wrap;\n    user-select: text;\n    display: none;\" role=\"region\" aria-live=\"polite\" aria-label=\"Example JSON Response\">\n\n{\n  \"users\": [\n    {\n      \"id\": 101,\n      \"name\": \"Alice Monroe\",\n      \"email\": \"alice@domain.com\",\n      \"role\": \"admin\"\n    },\n    {\n      \"id\": 102,\n      \"name\": \"Bob Smith\",\n      \"email\": \"bob@domain.com\",\n      \"role\": \"user\"\n    }\n  ],\n  \"count\": 2,\n  \"status\": \"success\"\n}\n\n  </pre>\n\n</main>\n<footer>\n  &copy; 2024 · Crafted with aesthetic precision\n</footer>\n\n<script>\n  const btnShow = document.getElementById('btnShowExample');\n  const btnReset = document.getElementById('btnReset');\n  const example = document.getElementById('exampleResponse');\n\n  btnShow.addEventListener('click', () => {\n    example.style.display = 'block';\n    btnShow.disabled = true;\n    btnReset.disabled = false;\n    btnShow.focus();\n  });\n\n  btnReset.addEventListener('click', () => {\n    example.style.display = 'none';\n    btnShow.disabled = false;\n    btnReset.disabled = true;\n    btnReset.blur();\n    btnShow.focus();\n  });\n</script>\n</body>\n</html>"
