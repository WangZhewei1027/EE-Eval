    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Directed Graph Interactive Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #graph { margin-top: 20px; }\n        #inputArea, #controlArea { margin-bottom: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Directed Graph Interactive Demonstration</h1>\n    <div id=\"inputArea\">\n        <label for=\"nodeInput\">Node Name: </label>\n        <input type=\"text\" id=\"nodeInput\">\n        <button onclick=\"addNode()\">Add Node</button>\n        <br>\n        <label for=\"sourceInput\">Source Node: </label>\n        <input type=\"text\" id=\"sourceInput\">\n        <label for=\"targetInput\">Target Node: </label>\n        <input type=\"text\" id=\"targetInput\">\n        <button onclick=\"addEdge()\">Add Edge</button>\n    </div>\n    <div id=\"controlArea\">\n        <button onclick=\"displayGraph()\">Display Graph</button>\n        <button onclick=\"removeNode()\">Remove Node</button>\n        <button onclick=\"removeEdge()\">Remove Edge</button>\n    </div>\n    <div id=\"graph\"></div>\n\n    <script>\n        let nodes = new Set();\n        let edges = new Set();\n\n        function addNode() {\n            const node = document.getElementById(\"nodeInput\").value;\n            if (node) {\n                nodes.add(node);\n                document.getElementById(\"nodeInput\").value = '';\n                updateGraph();\n            }\n        }\n\n        function addEdge() {\n            const source = document.getElementById(\"sourceInput\").value;\n            const target = document.getElementById(\"targetInput\").value;\n            if (source && target && nodes.has(source) && nodes.has(target)) {\n                edges.add(`${source}->${target}`);\n                document.getElementById(\"sourceInput\").value = '';\n                document.getElementById(\"targetInput\").value = '';\n                updateGraph();\n            } else {\n                alert(\"Invalid source or target node!\");\n            }\n        }\n\n        function removeNode() {\n            const node = document.getElementById(\"nodeInput\").value;\n            if (nodes.has(node)) {\n                nodes.delete(node);\n                edges = new Set([...edges].filter(edge => !edge.startsWith(node) && !edge.endsWith(node)));\n                document.getElementById(\"nodeInput\").value = '';\n                updateGraph();\n            } else {\n                alert(\"Node does not exist!\");\n            }\n        }\n\n        function removeEdge() {\n            const source = document.getElementById(\"sourceInput\").value;\n            const target = document.getElementById(\"targetInput\").value;\n            const edge = `${source}->${target}`;\n            if (edges.has(edge)) {\n                edges.delete(edge);\n                document.getElementById(\"sourceInput\").value = '';\n                document.getElementById(\"targetInput\").value = '';\n                updateGraph();\n            } else {\n                alert(\"Edge does not exist!\");\n            }\n        }\n\n        function displayGraph() {\n            let displayArea = document.getElementById(\"graph\");\n            displayArea.innerHTML = \"<strong>Nodes:</strong> \" + Array.from(nodes).join(\", \") + \"<br><strong>Edges:</strong> \" + Array.from(edges).join(\", \");\n        }\n\n        function updateGraph() {\n            displayGraph();\n        }\n    </script>\n</body>\n</html>"
