    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Two Pointers — Visual Intuition</title>\n\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600;800&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #071026;\n      --glass: rgba(255,255,255,0.06);\n      --accent: #7c5cff;\n      --accent-2: #00d4ff;\n      --muted: rgba(255,255,255,0.65);\n      --card: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      --success: #3ee7a7;\n      --danger: #ff6b6b;\n    }\n\n    html,body{\n      height:100%;\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 20%, rgba(124,92,255,0.14), transparent 8%),\n                  radial-gradient(900px 400px at 90% 80%, rgba(0,212,255,0.06), transparent 6%),\n                  linear-gradient(180deg,var(--bg1),var(--bg2));\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      color: #e9eef8;\n      overflow:hidden;\n    }\n\n    /* Floating decorative orbs */\n    .orb{\n      position:absolute;\n      border-radius:50%;\n      filter: blur(28px);\n      opacity:0.9;\n      mix-blend-mode:screen;\n      pointer-events:none;\n      transform: translateZ(0);\n      animation: float 8s ease-in-out infinite;\n    }\n    .orb.a{ width:420px; height:420px; left:-120px; top:-60px; background:linear-gradient(135deg,#7c5cff,#00d4ff); animation-delay:0s; opacity:0.14;}\n    .orb.b{ width:260px; height:260px; right:-70px; bottom:-80px; background:linear-gradient(135deg,#00d4ff,#7c5cff); animation-delay:2s; opacity:0.10;}\n    .orb.c{ width:160px; height:160px; left:20%; bottom:5%; background:linear-gradient(135deg,#ff7ab6,#7c5cff); animation-delay:4s; opacity:0.06;}\n\n    @keyframes float {\n      0% { transform: translateY(0px) translateX(0px) scale(1); }\n      50% { transform: translateY(-18px) translateX(8px) scale(1.02); }\n      100% { transform: translateY(0px) translateX(0px) scale(1); }\n    }\n\n    .container{\n      max-width:1100px;\n      margin:48px auto;\n      padding:36px;\n      border-radius:20px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: 0 8px 40px rgba(2,6,23,0.6);\n      position:relative;\n      overflow:visible;\n      backdrop-filter: blur(6px) saturate(120%);\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n\n    header{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:20px;\n      margin-bottom:26px;\n    }\n\n    .title{\n      display:flex;\n      flex-direction:column;\n      gap:8px;\n    }\n    .title h1{\n      margin:0;\n      font-family: 'Playfair Display', serif;\n      font-weight:700;\n      letter-spacing:-0.6px;\n      color: #fff;\n      font-size:26px;\n    }\n    .title p{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n\n    .btn{\n      border:0;\n      padding:10px 14px;\n      border-radius:10px;\n      font-weight:600;\n      cursor:pointer;\n      color:#061126;\n      background: linear-gradient(180deg,var(--accent), #5a37e6);\n      box-shadow: 0 8px 30px rgba(92,56,236,0.18);\n      transition:transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease;\n      display:inline-flex;\n      align-items:center;\n      gap:8px;\n    }\n    .btn:active{ transform:translateY(1px) }\n    .btn.secondary{\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      color:var(--muted);\n      box-shadow: none;\n      border: 1px solid rgba(255,255,255,0.03);\n      padding:8px 12px;\n    }\n\n    /* Main visual area */\n    .visual{\n      display:flex;\n      gap:28px;\n      align-items:center;\n      justify-content:space-between;\n    }\n\n    .panel{\n      flex:1;\n      min-width:380px;\n      padding:20px;\n      border-radius:14px;\n      background: var(--card);\n      box-shadow: 0 6px 24px rgba(10,12,20,0.45);\n      border: 1px solid rgba(255,255,255,0.025);\n      position:relative;\n      overflow:visible;\n    }\n\n    .left-panel{\n      padding:28px 28px 34px 28px;\n    }\n\n    .array-wrap{\n      display:flex;\n      justify-content:center;\n      align-items:flex-end;\n      gap:14px;\n      padding:28px 12px 18px 12px;\n      position:relative;\n      height:220px;\n      user-select:none;\n    }\n\n    .cell{\n      width:64px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      height:64px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      color: #e9eef8;\n      box-shadow: inset 0 -6px 18px rgba(0,0,0,0.25), 0 6px 24px rgba(2,6,23,0.5);\n      border: 1px solid rgba(255,255,255,0.02);\n      transition:transform 400ms cubic-bezier(.2,.9,.25,1), box-shadow 400ms;\n      position:relative;\n      font-weight:700;\n      font-size:14px;\n    }\n\n    /* Bars show magnitude */\n    .cell .bar{\n      position:absolute;\n      bottom:0;\n      left:8px;\n      right:8px;\n      height:12px;\n      border-radius:6px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      transform-origin:center left;\n      transition:height 700ms cubic-bezier(.2,.9,.25,1), background 700ms;\n      filter:brightness(1);\n    }\n\n    .cell.highlight{\n      transform: translateY(-12px) scale(1.04);\n      box-shadow: 0 18px 40px rgba(124,92,255,0.16);\n    }\n\n    .cell.match{\n      background: linear-gradient(135deg,var(--success), #2dd9a0);\n      color: rgba(3,12,19,0.98);\n      box-shadow: 0 18px 50px rgba(62,231,167,0.12), inset 0 -6px 18px rgba(0,0,0,0.18);\n      transform: translateY(-16px) scale(1.06);\n    }\n\n    /* pointers */\n    .pointer{\n      position:absolute;\n      width:28px;\n      height:28px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      pointer-events:none;\n      transition: transform 820ms cubic-bezier(.18,.88,.28,1), opacity 360ms;\n      z-index:40;\n      opacity:0.98;\n    }\n    .pointer .label{\n      position:absolute;\n      top:-36px;\n      font-size:12px;\n      color:var(--muted);\n      background:rgba(255,255,255,0.03);\n      padding:6px 8px;\n      border-radius:8px;\n      box-shadow:0 6px 18px rgba(2,6,23,0.45);\n      border:1px solid rgba(255,255,255,0.02);\n      transform-origin:center;\n      white-space:nowrap;\n    }\n    .pointer .mark{\n      width:22px;\n      height:22px;\n      border-radius:6px;\n      background:linear-gradient(180deg,#fff,#fff);\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:800;\n      color:var(--bg1);\n      font-size:12px;\n      box-shadow: 0 6px 18px rgba(124,92,255,0.16);\n      transform: translateY(0);\n      border:1px solid rgba(255,255,255,0.06);\n    }\n\n    .pointer.left .mark{ background: linear-gradient(135deg,var(--accent), #6d3ef5); color: white;}\n    .pointer.right .mark{ background: linear-gradient(135deg,#00d4ff,#3fb1ff); color: #061126;}\n\n    /* curved connector */\n    svg.connector{\n      position:absolute;\n      left:0;\n      top:0;\n      width:100%;\n      height:100%;\n      pointer-events:none;\n      overflow:visible;\n      z-index:30;\n    }\n\n    /* Right panel — explanation */\n    .right-panel{\n      width:340px;\n      padding:26px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n    }\n    .card-title{\n      font-weight:700;\n      font-size:15px;\n      color: #fff;\n      font-family: 'Playfair Display', serif;\n    }\n    .meta{\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.5;\n    }\n\n    .status{\n      margin-top:6px;\n      padding:12px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.02);\n      color:var(--muted);\n      font-weight:600;\n      font-size:13px;\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n\n    .pill{\n      padding:8px 12px;\n      border-radius:999px;\n      background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:var(--muted);\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n      font-weight:700;\n      letter-spacing:0.6px;\n      font-size:13px;\n      border:1px solid rgba(255,255,255,0.03);\n    }\n\n    .sum-display{\n      margin-top:6px;\n      font-family: 'Inter', sans-serif;\n      font-weight:800;\n      font-size:22px;\n    }\n\n    .legend{\n      display:flex;\n      gap:10px;\n      align-items:center;\n      margin-top:12px;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    .legend .dot{\n      width:14px;\n      height:14px;\n      border-radius:4px;\n      display:inline-block;\n      margin-right:8px;\n    }\n\n    footer{\n      margin-top:22px;\n      padding-top:12px;\n      border-top:1px dashed rgba(255,255,255,0.02);\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    /* small responsive */\n    @media (max-width:980px){\n      .visual{ flex-direction:column; gap:18px;}\n      .right-panel{ width:100%;}\n      .container{ margin:20px; padding:20px;}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"orb a\"></div>\n  <div class=\"orb b\"></div>\n  <div class=\"orb c\"></div>\n\n  <div class=\"container\" role=\"main\" aria-label=\"Two Pointers visualization\">\n    <header>\n      <div class=\"title\">\n        <h1>Two Pointers — Elegant Visual Intuition</h1>\n        <p>Observe the classic two-pointer technique as two indices traverse an ordered array to find a target sum.</p>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"play\" class=\"btn\" title=\"Play / Pause (space)\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"transform:translateY(1px)\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"white\"/></svg>\n          <span id=\"play-label\">Play</span>\n        </button>\n\n        <button id=\"reset\" class=\"btn secondary\" title=\"Reset visualization\">\n          Reset\n        </button>\n      </div>\n    </header>\n\n    <div class=\"visual\">\n      <div class=\"panel left-panel\" aria-hidden=\"false\">\n        <div style=\"display:flex;justify-content:space-between;align-items:end;\">\n          <div style=\"display:flex;flex-direction:column;\">\n            <div class=\"pill\" style=\"background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\">\n              Target\n              <div id=\"target-pill\" style=\"margin-left:10px;padding:4px 8px;border-radius:8px;background:linear-gradient(90deg,var(--accent),#6d3ef5);color:white;font-weight:800;font-size:13px;\">\n                12\n              </div>\n            </div>\n            <div class=\"meta\" style=\"margin-top:12px;\">\n              Array (sorted) visualized as blocks. Bars indicate value magnitude.\n            </div>\n          </div>\n\n          <div style=\"text-align:right;\">\n            <div class=\"meta\">Step</div>\n            <div class=\"sum-display\" id=\"step-count\">0 / 0</div>\n          </div>\n        </div>\n\n        <!-- array area -->\n        <div class=\"array-wrap\" id=\"arrayWrap\" aria-hidden=\"false\">\n          <!-- cells inserted by JS -->\n          <!-- svg connector overlays this area -->\n          <svg class=\"connector\" id=\"connector\"></svg>\n\n          <!-- pointers -->\n          <div class=\"pointer left\" id=\"pointerLeft\" style=\"top:32px; left:0; transform:translateX(0);\">\n            <div class=\"label\">Left</div>\n            <div class=\"mark\">L</div>\n          </div>\n          <div class=\"pointer right\" id=\"pointerRight\" style=\"bottom:32px; left:0; transform:translateX(0);\">\n            <div class=\"label\">Right</div>\n            <div class=\"mark\">R</div>\n          </div>\n        </div>\n\n        <footer>\n          <div style=\"display:flex;flex-direction:column;\">\n            <div style=\"font-weight:700\">Current Pair</div>\n            <div id=\"current-pair\" style=\"font-size:13px;color:var(--muted);margin-top:6px;\">—</div>\n          </div>\n\n          <div style=\"text-align:right;\">\n            <div style=\"font-weight:700\">Status</div>\n            <div class=\"status\" id=\"status\">Idle — press Play</div>\n          </div>\n        </footer>\n      </div>\n\n      <aside class=\"panel right-panel\" aria-hidden=\"false\">\n        <div>\n          <div class=\"card-title\">What is Two Pointers?</div>\n          <div class=\"meta\" style=\"margin-top:8px;\">\n            Two pointers is an efficient technique for problems on sorted arrays where two indices move towards each other to satisfy conditions (e.g. finding pairs with a target sum).\n          </div>\n        </div>\n\n        <div>\n          <div class=\"card-title\">Visualization Notes</div>\n          <div class=\"meta\" style=\"margin-top:8px;\">\n            Watch the left (L) and right (R) indices evaluate sums. The animation highlights comparisons and shows why movement depends on the sum vs target.\n          </div>\n        </div>\n\n        <div>\n          <div class=\"card-title\">Legend</div>\n          <div class=\"legend\">\n            <div style=\"display:flex;align-items:center;gap:8px;\">\n              <span class=\"dot\" style=\"background:linear-gradient(135deg,var(--accent),#6d3ef5)\"></span><span style=\"color:var(--muted)\">Left pointer</span>\n            </div>\n            <div style=\"display:flex;align-items:center;gap:8px;margin-left:18px;\">\n              <span class=\"dot\" style=\"background:linear-gradient(135deg,#00d4ff,#3fb1ff)\"></span><span style=\"color:var(--muted)\">Right pointer</span>\n            </div>\n          </div>\n        </div>\n\n        <div>\n          <div class=\"card-title\">Example</div>\n          <div class=\"meta\" style=\"margin-top:8px;\">Array: [1, 3, 4, 5, 7, 8, 10] • Target: 12</div>\n        </div>\n\n      </aside>\n    </div>\n  </div>\n\n  <script>\n    // Data\n    const array = [1, 3, 4, 5, 7, 8, 10];\n    const target = 12;\n\n    // UI elements\n    const arrayWrap = document.getElementById('arrayWrap');\n    const connector = document.getElementById('connector');\n    const pointerLeft = document.getElementById('pointerLeft');\n    const pointerRight = document.getElementById('pointerRight');\n    const statusEl = document.getElementById('status');\n    const currentPair = document.getElementById('current-pair');\n    const stepCount = document.getElementById('step-count');\n    const playBtn = document.getElementById('play');\n    const playLabel = document.getElementById('play-label');\n    const resetBtn = document.getElementById('reset');\n    const targetPill = document.getElementById('target-pill');\n\n    targetPill.textContent = target;\n\n    // create array cells\n    const cells = [];\n    array.forEach((v, i) => {\n      const el = document.createElement('div');\n      el.className = 'cell';\n      el.dataset.index = i;\n      el.innerHTML = `<div style=\"position:relative;z-index:2\">${v}</div><div class=\"bar\"></div>`;\n      arrayWrap.appendChild(el);\n      cells.push(el);\n\n      // set bar height relative to max value\n      const max = Math.max(...array);\n      const bar = el.querySelector('.bar');\n      const pct = 12 + Math.round((v / max) * 48); // 12..60 px\n      bar.style.height = pct + 'px';\n      // color mixing for beauty\n      bar.style.background = `linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)), linear-gradient(90deg, ${i < array.length/2 ? 'rgba(124,92,255,0.16)' : 'rgba(0,212,255,0.12)'} , transparent)`;\n    });\n\n    // compute steps (algorithm simulation)\n    function computeSteps(arr, target) {\n      const steps = [];\n      let l = 0, r = arr.length - 1;\n      while (l < r) {\n        const sum = arr[l] + arr[r];\n        const match = sum === target;\n        const action = match ? 'found' : (sum < target ? 'increase_left' : 'decrease_right');\n        steps.push({l, r, sum, action, match});\n        if (match) break;\n        if (action === 'increase_left') l++;\n        else r--;\n      }\n      return steps;\n    }\n\n    let steps = computeSteps(array, target);\n    let totalSteps = steps.length;\n    stepCount.textContent = `0 / ${totalSteps}`;\n\n    // position pointers initially\n    function updatePointerPositions(leftIdx, rightIdx, instant=false) {\n      const leftCell = cells[leftIdx];\n      const rightCell = cells[rightIdx];\n\n      // compute centers relative to arrayWrap\n      const wrapRect = arrayWrap.getBoundingClientRect();\n      const leftRect = leftCell.getBoundingClientRect();\n      const rightRect = rightCell.getBoundingClientRect();\n\n      const leftX = leftRect.left - wrapRect.left + leftRect.width / 2 - 14; // pointer width/2\n      const rightX = rightRect.left - wrapRect.left + rightRect.width / 2 - 14;\n\n      if (instant) {\n        pointerLeft.style.transition = 'none';\n        pointerRight.style.transition = 'none';\n      } else {\n        pointerLeft.style.transition = 'transform 820ms cubic-bezier(.18,.88,.28,1)';\n        pointerRight.style.transition = 'transform 820ms cubic-bezier(.18,.88,.28,1)';\n      }\n\n      // left pointer above\n      pointerLeft.style.transform = `translateX(${leftX}px) translateY(0)`;\n      pointerLeft.style.left = '0px';\n      pointerLeft.style.top = '12px';\n\n      // right pointer below\n      pointerRight.style.transform = `translateX(${rightX}px) translateY(0)`;\n      pointerRight.style.left = '0px';\n      pointerRight.style.bottom = '12px';\n\n      // after moving, reset transition property\n      if (instant) setTimeout(()=>{ pointerLeft.style.transition=''; pointerRight.style.transition=''; }, 40);\n\n      // update connector\n      drawConnector(leftIdx, rightIdx);\n    }\n\n    function drawConnector(li, ri) {\n      const wrapRect = arrayWrap.getBoundingClientRect();\n      const leftRect = cells[li].getBoundingClientRect();\n      const rightRect = cells[ri].getBoundingClientRect();\n\n      const x1 = leftRect.left - wrapRect.left + leftRect.width / 2;\n      const y1 = leftRect.top - wrapRect.top - 10; // above\n      const x2 = rightRect.left - wrapRect.left + rightRect.width / 2;\n      const y2 = rightRect.bottom - wrapRect.top + 10; // below\n\n      const cx = (x1 + x2) / 2;\n      const dy = Math.max(80, Math.abs(x2 - x1) / 2);\n      const path = `M ${x1} ${y1} C ${cx} ${y1 - dy} ${cx} ${y2 + dy} ${x2} ${y2}`;\n      connector.innerHTML = `\n        <defs>\n          <linearGradient id=\"g\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#7c5cff\"/>\n            <stop offset=\"100%\" stop-color=\"#00d4ff\"/>\n          </linearGradient>\n          <filter id=\"glow\">\n            <feGaussianBlur stdDeviation=\"10\" result=\"coloredBlur\"/>\n            <feMerge><feMergeNode in=\"coloredBlur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n        </defs>\n        <path d=\"${path}\" stroke=\"url(#g)\" stroke-width=\"3.8\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\" filter=\"url(#glow)\" opacity=\"0.98\"/>\n      `;\n    }\n\n    // initial layout after DOM ready\n    window.addEventListener('load', ()=> {\n      // ensure connector size covers arrayWrap\n      const rect = arrayWrap.getBoundingClientRect();\n      connector.setAttribute('width', rect.width);\n      connector.setAttribute('height', rect.height);\n      connector.style.width = rect.width + 'px';\n      connector.style.height = rect.height + 'px';\n\n      // initial pointers\n      updatePointerPositions(0, array.length - 1, true);\n    });\n\n    // animation state\n    let idx = 0;\n    let playing = false;\n    let timer = null;\n\n    function highlightPair(l, r, action, match) {\n      cells.forEach(c => c.classList.remove('highlight','match'));\n      cells[l].classList.add(match ? 'match' : 'highlight');\n      cells[r].classList.add(match ? 'match' : 'highlight');\n\n      currentPair.innerHTML = `<span style=\"font-weight:800\">${array[l]}</span> + <span style=\"font-weight:800\">${array[r]}</span> = <span style=\"font-weight:800\">${array[l]+array[r]}</span>`;\n      if (match) {\n        statusEl.innerHTML = `<span style=\"color:${getComputedStyle(document.documentElement).getPropertyValue('--bg1')}\">Found!</span> Pair equals target.`;\n        statusEl.style.background = 'linear-gradient(90deg, rgba(62,231,167,0.08), rgba(124,92,255,0.02))';\n      } else if (action === 'increase_left') {\n        statusEl.textContent = `Sum is less than target → move Left pointer right`;\n        statusEl.style.background = 'linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01))';\n      } else {\n        statusEl.textContent = `Sum is greater than target → move Right pointer left`;\n        statusEl.style.background = 'linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01))';\n      }\n    }\n\n    function showStep(s) {\n      const {l,r,sum,action,match} = s;\n      // move pointers\n      updatePointerPositions(l, r, false);\n\n      // tiny delay to let motion start\n      setTimeout(()=> highlightPair(l, r, action, match), 160);\n    }\n\n    function stepForward() {\n      if (idx >= steps.length) {\n        playing = false;\n        playLabel.textContent = 'Play';\n        playBtn.querySelector('svg path').setAttribute('d','M5 3v18l15-9L5 3z'); // play icon\n        return;\n      }\n      const s = steps[idx];\n      stepCount.textContent = `${Math.min(idx+1, steps.length)} / ${totalSteps}`;\n\n      showStep(s);\n\n      // if match, stop at match\n      if (s.match) {\n        idx = steps.length; // mark done\n        playing = false;\n        playLabel.textContent = 'Play';\n        playBtn.querySelector('svg path').setAttribute('d','M5 3v18l15-9L5 3z');\n        return;\n      }\n\n      // schedule next\n      idx++;\n      timer = setTimeout(()=> {\n        if (playing) stepForward();\n      }, 1200);\n    }\n\n    function play() {\n      if (idx >= steps.length) {\n        // restart automatically\n        reset();\n      }\n      playing = true;\n      playLabel.textContent = 'Pause';\n      playBtn.querySelector('svg path').setAttribute('d','M6 4h4v16H6z M14 4h4v16h-4z'); // pause\n      // small guard to avoid double timers\n      if (timer) clearTimeout(timer);\n      stepForward();\n    }\n\n    function pause() {\n      playing = false;\n      playLabel.textContent = 'Play';\n      playBtn.querySelector('svg path').setAttribute('d','M5 3v18l15-9L5 3z');\n      if (timer) clearTimeout(timer);\n      timer = null;\n      statusEl.textContent = 'Paused';\n    }\n\n    playBtn.addEventListener('click', ()=> {\n      if (!playing) play(); else pause();\n    });\n\n    resetBtn.addEventListener('click', ()=> {\n      reset();\n    });\n\n    // reset animation and UI\n    function reset() {\n      if (timer) clearTimeout(timer);\n      idx = 0;\n      playing = false;\n      playLabel.textContent = 'Play';\n      playBtn.querySelector('svg path').setAttribute('d','M5 3v18l15-9L5 3z');\n      cells.forEach(c=> c.classList.remove('highlight','match'));\n      currentPair.textContent = '—';\n      statusEl.textContent = 'Idle — press Play';\n      stepCount.textContent = `0 /