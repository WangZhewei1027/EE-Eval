    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Hash Table Visualization — Concept</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  * {\n    box-sizing: border-box;\n  }\n  html, body {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(145deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Poppins', sans-serif;\n    color: #eef2f3;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    overflow-x: hidden;\n  }\n  header {\n    text-align: center;\n    padding: 3rem 1rem 1rem 1rem;\n    user-select: none;\n  }\n  header h1 {\n    font-weight: 600;\n    font-size: 3rem;\n    letter-spacing: 0.1em;\n    margin: 0;\n    background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n  header p {\n    color: #9bb7c4dd;\n    font-weight: 300;\n    font-size: 1.1rem;\n    margin-top: 0.3rem;\n    max-width: 480px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  main {\n    display: flex;\n    justify-content: center;\n    align-items: flex-start;\n    padding: 2rem;\n    gap: 5vw;\n    flex-wrap: wrap;\n    max-width: 1200px;\n    margin: 0 auto 4rem auto;\n  }\n  .hash-container {\n    background: rgba(255 255 255 / 0.07);\n    border-radius: 20px;\n    box-shadow:\n      inset 0 0 15px rgb(255 255 255 / 0.1),\n      0 10px 25px rgb(0 0 0 / 0.3);\n    flex: 1 1 440px;\n    min-width: 340px;\n    max-width: 480px;\n    padding: 2rem 2.5rem 3rem 2.5rem;\n    position: relative;\n    overflow: visible;\n  }\n  .hash-container h2 {\n    margin: 0 0 1rem;\n    font-weight: 600;\n    font-size: 2rem;\n    text-align: center;\n    letter-spacing: 0.06em;\n    background: linear-gradient(135deg, #7b92b1, #a5c0dd);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n  }\n  /* Hash Table visual */\n  .table {\n    display: grid;\n    grid-template-columns: 1fr 3fr 2fr;\n    background: rgba(255 255 255 / 0.12);\n    border-radius: 16px;\n    overflow: hidden;\n    box-shadow: 0 8px 20px rgb(0 0 0 / 0.15);\n    user-select:none;\n  }\n  .table-row {\n    display: contents;\n  }\n  .table-cell {\n    padding: 1rem 1.2rem;\n    border-bottom: 1px solid rgba(255 255 255 / 0.12);\n    display: flex;\n    align-items: center;\n    justify-content: flex-start;\n    font-weight: 400;\n    color: #d9e6f2cc;\n  }\n  .table-header {\n    background: linear-gradient(90deg, #2a4e7e, #3b6eab);\n    font-weight: 600;\n    font-size: 1.2rem;\n    color: #d0eaff;\n    border-bottom: 2px solid #92b1dc;\n    justify-content: center;\n  }\n  .index-cell {\n    justify-content: center;\n    color: #a3b7d6;\n    font-size: 1rem;\n  }\n  .key-cell {\n    font-weight: 600;\n    color: #cfd3e7;\n    font-size: 1rem;\n  }\n  .value-cell {\n    justify-content: flex-end;\n    font-size: 1rem;\n    font-weight: 500;\n    color: #b7c9ef;\n  }\n\n  /* Highlight the hash computation steps */\n  .hash-step-container {\n    background: rgba(255 255 255 / 0.06);\n    margin-top: 2rem;\n    border-radius: 14px;\n    padding: 1rem 1.5rem;\n    font-family: monospace;\n    color: #a0bae9;\n    font-size: 0.92rem;\n    line-height: 1.4;\n    box-shadow: inset 0 0 12px rgb(161 191 244 / 0.7);\n    user-select:none;\n  }\n\n  /* Buttons */\n  .controls {\n    text-align: center;\n    margin-top: 1rem;\n    user-select:none;\n  }\n  button {\n    --btn-bg: #3a6db0;\n    --btn-bg-hover: #4799f1;\n    --btn-text: #e6eaf7;\n    padding: 10px 30px;\n    background: var(--btn-bg);\n    border: none;\n    border-radius: 40px;\n    color: var(--btn-text);\n    font-size: 1rem;\n    font-weight: 600;\n    cursor: pointer;\n    box-shadow:\n      0 4px 15px rgb(26 94 178 / 0.7);\n    transition:\n      background-color 0.4s ease,\n      box-shadow 0.3s ease,\n      transform 0.15s ease;\n  }\n  button:hover, button:focus {\n    background: var(--btn-bg-hover);\n    box-shadow:\n      0 6px 30px rgb(46 132 244 / 0.9);\n    outline: none;\n  }\n  button:active {\n    transform: scale(0.96);\n  }\n\n  /* Visual Hash Table UID: Chain Slots, Collisions handle */\n  .slot {\n    position: relative;\n    height: 48px;\n    border-left: 2px solid transparent;\n    transition: border-color 0.7s ease;\n  }\n  .slot.hash-index {\n    border-left-color: #00cff7aa;\n  }\n\n  /* Chain nodes */\n  .chain {\n    position: absolute;\n    top: 50%;\n    left: calc(100% + 8px);\n    transform: translateY(-50%);\n    display: flex;\n    gap: 12px;\n    user-select:none;\n  }\n  .node {\n    background: linear-gradient(145deg, #40659a, #7099d1);\n    border-radius: 12px;\n    padding: 9px 18px;\n    box-shadow:\n      0 7px 18px rgb(41 87 146 / 0.6),\n      inset 0 -3px 5px rgb(63 89 136 / 0.6);\n    color: white;\n    font-weight: 600;\n    font-size: 0.85rem;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    line-height: 1.18;\n    width: 120px;\n    cursor: default;\n  }\n  .node .key {\n    font-size: 1rem;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    color: #cdf3fe;\n    margin-bottom: 2px;\n  }\n  .node .value {\n    font-weight: 500;\n    color: #cbe7ffcf;\n  }\n  .node::after {\n    content: '';\n    position: absolute;\n    top: 50%;\n    left: -28px;\n    width: 28px;\n    height: 4px;\n    background: linear-gradient(90deg, #83c0fc, #4769aa);\n    transform: translateY(-50%);\n    border-radius: 2px;\n    box-shadow:\n      0 0 6px #5ea1ffbb,\n      inset 0 2px 6px #93c2ffbb;\n    opacity: 0;\n    animation: arrowShow 0.7s ease forwards;\n  }\n  .node:last-child::after {\n    display: none;\n    animation: none;\n  }\n  @keyframes arrowShow {\n    0% {\n      opacity: 0;\n      width: 0;\n    }\n    100% {\n      opacity: 1;\n      width: 28px;\n    }\n  }\n\n  /* Hash code container */\n  .hashcode-result {\n    margin-top: 2rem;\n    background: rgba(255 255 255 / 0.05);\n    border-radius: 16px;\n    padding: 1.2rem 1.8rem;\n    font-family: 'Fira Mono', monospace, monospace;\n    color: #bbd5fb;\n    font-size: 1rem;\n    user-select:none;\n    text-align: center;\n    box-shadow: inset 0 0 25px rgb(67 110 166 / 0.35);\n  }\n\n  /* Footer */\n  footer {\n    text-align: center;\n    color: #9bb7c4aa;\n    font-weight: 300;\n    font-size: 0.9rem;\n    padding-bottom: 1.5rem;\n    user-select:none;\n  }\n\n  /* Scrollbar for hash steps */\n  .hash-step-container {\n    max-height: 120px;\n    overflow-y: auto;\n    scrollbar-width: thin;\n    scrollbar-color: #497dbf33 transparent;\n  }\n  .hash-step-container::-webkit-scrollbar {\n    width: 8px;\n  }\n  .hash-step-container::-webkit-scrollbar-thumb {\n    background-color: #497dbf66;\n    border-radius: 8px;\n  }\n  .hash-step-container::-webkit-scrollbar-track {\n    background: transparent;\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>HASH TABLE</h1>\n  <p>Efficient key-value storage data structure with direct addressing by computed hash indices.</p>\n</header>\n<main>\n  <section class=\"hash-container\" aria-label=\"Hash table visualization\">\n    <h2>Hash Table Slots</h2>\n    <div class=\"table\" role=\"table\" aria-readonly=\"true\" aria-label=\"Hash Table Slots\">\n      <div class=\"table-row\" role=\"row\">\n        <div class=\"table-cell table-header\" role=\"columnheader\" scope=\"col\">Index</div>\n        <div class=\"table-cell table-header\" role=\"columnheader\" scope=\"col\">Key</div>\n        <div class=\"table-cell table-header\" role=\"columnheader\" scope=\"col\">Value</div>\n      </div>\n\n      <!-- Slot 0 - empty -->\n      <div class=\"table-row\" role=\"row\" aria-rowindex=\"2\">\n        <div class=\"table-cell index-cell slot\" role=\"rowheader\" aria-colindex=\"1\">0</div>\n        <div class=\"table-cell\" role=\"cell\"></div>\n        <div class=\"table-cell\" role=\"cell\"></div>\n      </div>\n\n      <!-- Slot 1 - single entry -->\n      <div class=\"table-row\" role=\"row\" aria-rowindex=\"3\">\n        <div class=\"table-cell index-cell slot hash-index\" role=\"rowheader\" aria-colindex=\"1\">1</div>\n        <div class=\"table-cell key-cell\" role=\"cell\">apple</div>\n        <div class=\"table-cell value-cell\" role=\"cell\">🍏 Green</div>\n      </div>\n\n      <!-- Slot 2 - collision chain -->\n      <div class=\"table-row\" role=\"row\" aria-rowindex=\"4\" style=\"position:relative;\">\n        <div class=\"table-cell index-cell slot\" role=\"rowheader\" aria-colindex=\"1\">2</div>\n        <div class=\"table-cell\" role=\"cell\"></div>\n        <div class=\"table-cell\" role=\"cell\"></div>\n        <div class=\"chain\" aria-label=\"Collision chain at slot 2\">\n          <div class=\"node\" tabindex=\"0\" role=\"group\" aria-labelledby=\"key-orange value-orange\">\n            <div class=\"key\" id=\"key-orange\">orange</div>\n            <div class=\"value\" id=\"value-orange\">🍊 Tangy</div>\n          </div>\n          <div class=\"node\" tabindex=\"0\" role=\"group\" aria-labelledby=\"key-banana value-banana\">\n            <div class=\"key\" id=\"key-banana\">banana</div>\n            <div class=\"value\" id=\"value-banana\">🍌 Sweet</div>\n          </div>\n          <div class=\"node\" tabindex=\"0\" role=\"group\" aria-labelledby=\"key-grape value-grape\">\n            <div class=\"key\" id=\"key-grape\">grape</div>\n            <div class=\"value\" id=\"value-grape\">🍇 Juicy</div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Slot 3 - single entry -->\n      <div class=\"table-row\" role=\"row\" aria-rowindex=\"5\">\n        <div class=\"table-cell index-cell slot\" role=\"rowheader\" aria-colindex=\"1\">3</div>\n        <div class=\"table-cell key-cell\" role=\"cell\">melon</div>\n        <div class=\"table-cell value-cell\" role=\"cell\">🍈 Refreshing</div>\n      </div>\n\n      <!-- Slot 4 - empty -->\n      <div class=\"table-row\" role=\"row\" aria-rowindex=\"6\">\n        <div class=\"table-cell index-cell slot\" role=\"rowheader\" aria-colindex=\"1\">4</div>\n        <div class=\"table-cell\" role=\"cell\"></div>\n        <div class=\"table-cell\" role=\"cell\"></div>\n      </div>\n\n      <!-- Slot 5 - single entry -->\n      <div class=\"table-row\" role=\"row\" aria-rowindex=\"7\">\n        <div class=\"table-cell index-cell slot\" role=\"rowheader\" aria-colindex=\"1\">5</div>\n        <div class=\"table-cell key-cell\" role=\"cell\">kiwi</div>\n        <div class=\"table-cell value-cell\" role=\"cell\">🥝 Tart</div>\n      </div>\n    </div>\n    <div class=\"controls\" style=\"margin-top:3rem;\">\n      <button id=\"refreshButton\" aria-label=\"Refresh hash computation visualization\">Run Hash Computation</button>\n    </div>\n    <div class=\"hash-step-container\" aria-live=\"polite\" aria-atomic=\"true\" role=\"region\" aria-label=\"Hash computation steps\" id=\"hashSteps\" tabindex=\"0\">\n      Press the button to see hash computation steps scaled to table size.\n    </div>\n  </section>\n\n  <section class=\"hash-container\" aria-label=\"Hash function concept\">\n    <h2>Hash Function Concept</h2>\n    <svg\n      viewBox=\"0 0 440 280\"\n      aria-hidden=\"true\"\n      style=\"width:100%; max-width:440px; height: auto; display:block; margin: 1.5rem auto 0 auto;\"\n      role=\"img\"\n    >\n      <defs>\n        <linearGradient id=\"gradKey\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#6bb0ff\" />\n          <stop offset=\"100%\" stop-color=\"#2e69b7\" />\n        </linearGradient>\n        <filter id=\"glow\" x=\"-40%\" y=\"-40%\" width=\"180%\" height=\"180%\" color-interpolation-filters=\"sRGB\" >\n          <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"2\" flood-color=\"#6bb0ff\" flood-opacity=\"0.7\" />\n          <feDropShadow dx=\"0\" dy=\"0\" stdDeviation=\"4\" flood-color=\"#6bb0ff\" flood-opacity=\"0.5\" />\n        </filter>\n      </defs>\n      <!-- Key rectangle -->\n      <rect x=\"20\" y=\"45\" width=\"120\" height=\"70\" rx=\"18\" ry=\"18\"\n        fill=\"url(#gradKey)\"\n        filter=\"url(#glow)\"\n      />\n      <text x=\"80\" y=\"90\" text-anchor=\"middle\" fill=\"#dce9ff\" font-weight=\"700\" font-size=\"1.7rem\" font-family=\"Poppins, sans-serif\" pointer-events=\"none\" user-select=\"none\" >\n        apple\n      </text>\n\n      <!-- + -->\n      <text x=\"155\" y=\"85\" fill=\"#aad1ffcc\" font-weight=\"800\" font-size=\"3rem\" font-family=\"monospace\" pointer-events=\"none\" user-select=\"none\" >\n        +\n      </text>\n      <!-- Char codes -->\n      <g font-family=\"monospace\" font-weight=\"500\" font-size=\"1.1rem\" fill=\"#aacdffcc\" >\n        <text x=\"190\" y=\"65\" pointer-events=\"none\" user-select=\"none\" >\n          a: 97\n        </text>\n        <text x=\"190\" y=\"95\" pointer-events=\"none\" user-select=\"none\" >\n          p: 112\n        </text>\n        <text x=\"190\" y=\"125\" pointer-events=\"none\" user-select=\"none\" >\n          l: 108\n        </text>\n      </g>\n\n      <!-- Plus signs -->\n      <text x=\"230\" y=\"85\" fill=\"#aacdffcc\" font-weight=\"600\" font-size=\"2rem\" font-family=\"monospace\" pointer-events=\"none\" user-select=\"none\" >\n        +\n      </text>\n      <text x=\"230\" y=\"105\" text-anchor=\"middle\" fill=\"#eef4ff66\" font-family=\"monospace\" font-size=\"0.72rem\" pointer-events=\"none\" user-select=\"none\" >\n        ...\n      </text>\n\n      <!-- Sum box -->\n      <rect x=\"280\" y=\"60\" width=\"120\" height=\"70\" rx=\"18\" ry=\"18\" fill=\"#1e3764\" stroke=\"#65a0ff77\" stroke-width=\"1.9\" />\n      <text x=\"340\" y=\"100\" text-anchor=\"middle\" fill=\"#a3c8ff\" font-weight=\"700\" font-size=\"2.2rem\" font-family=\"Poppins, sans-serif\" pointer-events=\"none\" user-select=\"none\" >\n        532\n      </text>\n\n      <!-- Mod symbol -->\n      <text x=\"410\" y=\"85\" fill=\"#8abfffcc\" font-weight=\"600\" font-size=\"3rem\" font-family=\"monospace\" pointer-events=\"none\" user-select=\"none\" >\n        %\n      </text>\n\n      <!-- Table size circle -->\n      <circle cx=\"460\" cy=\"95\" r=\"32\" fill=\"none\" stroke=\"#4ca0ff88\" stroke-width=\"3\" />\n      <text x=\"460\" y=\"101\" text-anchor=\"middle\" fill=\"#7fc1ffcc\" font-weight=\"600\" font-size=\"1.7rem\" font-family=\"Poppins, sans-serif\" pointer-events=\"none\" user-select=\"none\" >\n        6\n      </text>\n\n      <!-- Arrow for computation -->\n      <path d=\"M140 80 L180 80\" stroke=\"#57acffdd\" stroke-width=\"4\" marker-end=\"url(#arrowhead)\" />\n      <path d=\"M250 95 L305 95\" stroke=\"#57acffdd\" stroke-width=\"4\" marker-end=\"url(#arrowhead)\" />\n\n      <defs>\n        <marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"8\" refX=\"7\" refY=\"3\" orient=\"auto\" markerUnits=\"strokeWidth\">\n          <path d=\"M0,0 L7,3 L0,6 Z\" fill=\"#57acffdd\" />\n        </marker>\n      </defs>\n    </svg>\n    <p style=\"color:#aacfffcc; font-weight: 300; font-size: 1rem; max-width: 340px; margin: 0 auto 0 auto; user-select:none;\">\n      Each key is converted to numeric values (char codes). Sum mod table size gives the slot index.\n    </p>\n  </section>\n</main>\n<footer>\n  &copy; 2024 Concept Visualization — Minimal Interactivity, Maximum Elegance\n</footer>\n<script>\n(() => {\n  'use strict';\n\n  const slotsCount = 6;\n  // Example: key \"apple\" hash steps for sum of char codes\n  const hashComputation = [\n    { char: 'a', code: 97, description: 'Add char code for \"a\": 97' },\n    { char: 'p', code: 112, description: 'Add char code for \"p\": 112' },\n    { char: 'p', code: 112, description: 'Add char code for \"p\": 112' },\n    { char: 'l', code: 108, description: 'Add char code for \"l\": 108' },\n    { char: 'e', code: 101, description: 'Add char code for \"e\": 101' },\n  ];\n\n  const stepsContainer = document.getElementById('hashSteps');\n  const refreshBtn = document.getElementById('refreshButton');\n\n  function animateHashComputation() {\n    stepsContainer.textContent = '';\n    let sum = 0;\n    let i = 0;\n\n    function step() {\n      if (i < hashComputation.length) {\n        const stepObj = hashComputation[i];\n        sum += stepObj.code;\n        const line = document.createElement('div');\n        line.textContent = stepObj.description + ` → Running sum: ${sum}`;\n        line.style.opacity = '0';\n        line.style.transform = 'translateX(-20px)';\n        stepsContainer.appendChild(line);\n        // Animate in\n        requestAnimationFrame(() => {\n          line.style.transition = 'opacity 0.5s ease, transform 0.5s ease';\n          line.style.opacity = '1';\n          line.style.transform = 'translateX(0)';\n        });\n        i++;\n        setTimeout(step, 1000);\n      } else {\n        // Final step: modulo operation\n        const modResult = sum % slotsCount;\n        const modLine = document.createElement('div');\n        modLine.textContent = `Compute index: ${sum} % ${slotsCount} = ${modResult}`;\n        modLine.style.marginTop = '0.8rem';\n        modLine.style.fontWeight = '600';\n        modLine.style.color = '#5ac8fa';\n        modLine.style.opacity = '0';\n        modLine.style.transform = 'translateX(-20px)';\n        stepsContainer.appendChild(modLine);\n        requestAnimationFrame(() => {\n          modLine.style.transition = 'opacity 0.6s ease, transform 0.6s ease';\n          modLine.style.opacity = '1';\n          modLine.style.transform = 'translateX(0)';\n        });\n      }\n      // Scroll newly added content into view\n      stepsContainer.scrollTop = stepsContainer.scrollHeight;\n    }\n\n    step();\n  }\n\n  refreshBtn.addEventListener('click', () => {\n    animateHashComputation();\n    refreshBtn.disabled = true;\n    setTimeout(() => {\n      refreshBtn.disabled = false;\n    }, 6500);\n  });\n})();\n</script>\n</body>\n</html>"
