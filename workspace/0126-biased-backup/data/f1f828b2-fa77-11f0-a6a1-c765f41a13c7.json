    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>HTTPS — Secure by Design</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg-1:#071126;\n    --bg-2:#0b1320;\n    --glass: rgba(255,255,255,0.06);\n    --accent-1: #38d9a9;\n    --accent-2: #7cf7ff;\n    --gold: #ffd27a;\n    --muted: rgba(255,255,255,0.65);\n    --glass-2: rgba(255,255,255,0.04);\n    --card-shadow: 0 8px 30px rgba(2,6,23,0.6);\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;\n    background: radial-gradient(1200px 700px at 10% 10%, rgba(56,217,169,0.06), transparent 6%),\n                radial-gradient(1000px 600px at 90% 90%, rgba(124,247,255,0.04), transparent 6%),\n                linear-gradient(180deg,var(--bg-1), var(--bg-2));\n    color: #eaf6f2;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:40px;\n  }\n\n  /* Subtle animated background orbs */\n  .orbs{\n    position:fixed; inset:0; z-index:0; pointer-events:none; mix-blend-mode:screen; opacity:0.9;\n  }\n  .orb{\n    position:absolute;\n    filter: blur(60px);\n    opacity:0.7;\n    transform:translate3d(0,0,0);\n    animation: float 8s ease-in-out infinite;\n  }\n  .orb.a{ width:420px; height:420px; background:linear-gradient(135deg, rgba(56,217,169,0.18), rgba(124,247,255,0.06)); left:-10%; top:5%; animation-duration:12s}\n  .orb.b{ width:340px; height:340px; background:linear-gradient(135deg, rgba(124,247,255,0.12), rgba(56,217,169,0.04)); right:-8%; bottom:12%; animation-duration:10s}\n  .orb.c{ width:220px; height:220px; background:linear-gradient(135deg, rgba(255,210,122,0.07), rgba(124,247,255,0.03)); left:50%; top:60%; animation-duration:14s; transform:translateX(-50%)}\n  @keyframes float { 0%{transform:translateY(0)} 50%{transform:translateY(-18px)} 100%{transform:translateY(0)} }\n\n  /* Main card */\n  .stage{\n    position:relative;\n    width:1100px;\n    max-width:calc(100% - 80px);\n    background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border-radius:20px;\n    padding:36px;\n    box-shadow:var(--card-shadow);\n    backdrop-filter: blur(8px) saturate(120%);\n    border:1px solid rgba(255,255,255,0.04);\n    z-index:2;\n    overflow:hidden;\n  }\n\n  header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:20px;\n    margin-bottom:18px;\n  }\n  .title{\n    display:flex;\n    gap:18px;\n    align-items:center;\n  }\n  .logo{\n    width:64px; height:64px; border-radius:12px;\n    background:linear-gradient(135deg,var(--accent-1), var(--accent-2));\n    display:flex; align-items:center; justify-content:center;\n    box-shadow:0 6px 20px rgba(10,30,40,0.35), inset 0 -6px 18px rgba(255,255,255,0.08);\n    transform:rotate(-12deg);\n  }\n  .logo svg{filter:drop-shadow(0 6px 12px rgba(8,20,30,0.35))}\n  h1{\n    margin:0; font-family:'Playfair Display', serif; font-weight:700; letter-spacing:-0.6px;\n    font-size:20px; color:#ffffff;\n    line-height:1;\n  }\n  p.lead{margin:0; color:var(--muted); font-size:13px; margin-top:4px}\n\n  .controls{\n    display:flex; gap:12px; align-items:center;\n  }\n  .btn{\n    --btn-bg: rgba(255,255,255,0.03);\n    display:inline-flex; gap:8px; align-items:center; justify-content:center;\n    padding:10px 14px; border-radius:10px; color:var(--muted); font-weight:600;\n    font-size:13px; border:1px solid rgba(255,255,255,0.04); cursor:pointer; backdrop-filter: blur(6px);\n    transition: all .24s cubic-bezier(.2,.9,.3,1), transform .12s ease;\n    background:var(--btn-bg);\n  }\n  .btn:hover{ transform:translateY(-3px); color:#fff; box-shadow:0 6px 22px rgba(5,15,30,0.45)}\n  .btn:active{ transform:translateY(0) }\n\n  /* Visual canvas */\n  .visual{\n    margin-top:18px;\n    display:flex;\n    gap:24px;\n    align-items:center;\n    justify-content:space-between;\n    min-height:420px;\n    position:relative;\n    padding:28px;\n  }\n\n  .side{\n    width:300px; max-width:34%;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.02));\n    border-radius:14px; padding:22px; box-shadow:0 6px 20px rgba(2,6,23,0.45);\n    border:1px solid rgba(255,255,255,0.03);\n    display:flex; flex-direction:column; gap:12px; align-items:center; text-align:center;\n  }\n  .side h3{ margin:0; font-size:16px; font-weight:700; color:#fff; letter-spacing:-0.3px}\n  .side p{margin:0; color:var(--muted); font-size:13px}\n\n  /* center canvas */\n  .center{\n    flex:1;\n    min-height:360px;\n    position:relative;\n    display:flex; align-items:center; justify-content:center;\n    perspective:1000px;\n  }\n\n  /* connection area */\n  .lane{\n    position:relative;\n    width:100%;\n    height:240px;\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:18px;\n  }\n\n  /* device / server icons */\n  .device, .server{\n    width:180px; height:140px; position:relative;\n    display:flex; flex-direction:column; align-items:center; justify-content:center;\n    gap:10px;\n  }\n  .device .icon, .server .icon{\n    width:96px; height:68px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:10px; display:flex; align-items:center; justify-content:center;\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 12px 30px rgba(7,9,20,0.45), inset 0 -6px 18px rgba(255,255,255,0.02);\n  }\n  .device svg, .server svg{width:64px; height:48px; filter:drop-shadow(0 6px 12px rgba(5,20,30,0.35))}\n\n  /* visual connection lines and packets */\n  .wire{\n    position:absolute; left:calc(50% - 180px); right:calc(50% - 180px);\n    height:6px; top:70px; display:block;\n    border-radius:8px; overflow:visible;\n    pointer-events:none;\n  }\n  .wire .track{\n    position:absolute; left:0; right:0; height:6px; border-radius:8px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);\n  }\n\n  /* animated packet */\n  .packet{\n    position:absolute; top:-14px; left:0; width:120px; height:36px;\n    display:flex; align-items:center; gap:10px; padding:8px 12px;\n    border-radius:999px; color:#032; background: linear-gradient(90deg,#e7fff7,#bffcf0);\n    font-weight:700; font-size:13px; transform:translateX(-260px) scale(.92);\n    box-shadow:0 8px 20px rgba(7,12,16,0.45), 0 1px 0 rgba(255,255,255,0.2) inset;\n    opacity:0;\n  }\n  .packet .dot{width:10px; height:10px; border-radius:50%; background:var(--gold); box-shadow:0 6px 12px rgba(255,170,60,0.18)}\n\n  /* server certificate visual */\n  .certificate{\n    width:86px; height:56px; background:linear-gradient(180deg,#fff,#fff9); border-radius:6px;\n    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;\n    padding:8px; box-shadow: 0 10px 30px rgba(0,0,0,0.45), inset 0 -6px 18px rgba(255,255,255,0.7);\n    transform-origin:50% 50%;\n  }\n  .certificate .ribbon{ width:18px; height:18px; background:var(--gold); border-radius:50%; box-shadow:0 6px 14px rgba(255,170,60,0.2)}\n  .certificate .lines{ width:44px; height:6px; background: linear-gradient(90deg, rgba(0,0,0,0.06), rgba(0,0,0,0.02)); border-radius:3px }\n\n  /* lock icon */\n  .lock-wrap{ display:flex; gap:10px; align-items:center }\n  .lock{\n    width:48px; height:64px; display:flex; align-items:center; justify-content:center;\n    border-radius:10px; padding:6px; background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .lock svg{ width:28px; height:28px; opacity:.95; transition:transform .5s cubic-bezier(.18,.9,.3,1), fill .3s ease, stroke .3s ease; }\n\n  /* handshake timeline */\n  .timeline{\n    position:absolute; left:50%; transform:translateX(-50%); bottom:-36px;\n    width:740px; max-width:90%; height:86px; display:flex; align-items:center; justify-content:space-between;\n    gap:8px; background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:16px; padding:12px 18px; border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 10px 40px rgba(3,8,18,0.45);\n  }\n  .step{\n    flex:1; display:flex; flex-direction:column; align-items:center; gap:8px; color:var(--muted);\n    font-size:12px; position:relative;\n  }\n  .step .dot{\n    width:10px; height:10px; border-radius:999px; background:transparent; border:2px solid rgba(255,255,255,0.06);\n    transition: all .28s cubic-bezier(.2,.9,.3,1);\n  }\n  .step .label{ font-weight:700; color:var(--muted); font-size:12px; letter-spacing:0.2px}\n\n  /* completed/active states (animated by JS toggling .play on .stage) */\n  .stage.play .packet{ animation: packet-move 5.2s linear forwards; }\n  .stage.play .packet.client{ animation-delay: 0.4s; }\n  .stage.play .packet.server{ animation: packet-move-back 5.2s linear forwards; opacity:0 }\n  .stage.play .certificate{ animation: cert-flip 2s ease 1.4s forwards; transform-origin: 50% 50%; }\n  .stage.play .lock svg{ transform:rotate(0deg) scale(1.02); }\n  .stage.play .wire .seal{ animation: seal-glow 2s ease 1.8s forwards; }\n\n  @keyframes packet-move {\n    0%{ transform:translateX(-260px) scale(.92); opacity:0 }\n    8%{ opacity:1; transform:translateX(-200px) scale(1) }\n    22%{ transform:translateX(-40px) }\n    40%{ transform:translateX(100px) }\n    62%{ transform:translateX(220px) }\n    80%{ transform:translateX(320px) }\n    100%{ transform:translateX(460px) scale(.98); opacity:0.92 }\n  }\n  @keyframes packet-move-back {\n    0%{ transform:translateX(460px) scale(.9); opacity:0 }\n    8%{ opacity:1; transform:translateX(360px) scale(1) }\n    22%{ transform:translateX(200px) }\n    40%{ transform:translateX(60px) }\n    62%{ transform:translateX(-80px) }\n    80%{ transform:translateX(-220px) }\n    100%{ transform:translateX(-360px) scale(.92); opacity:0 }\n  }\n\n  @keyframes cert-flip {\n    0%{ transform: rotateX(-90deg) translateY(20px) scale(.92); opacity:0 }\n    40%{ transform: rotateX(-20deg) translateY(6px) scale(1.02); opacity:0.9 }\n    100%{ transform: rotateX(0deg) translateY(0) scale(1); opacity:1 }\n  }\n\n  @keyframes seal-glow {\n    0%{ box-shadow:0 0 0 rgba(56,217,169,0) }\n    40%{ box-shadow:0 6px 22px rgba(56,217,169,0.12) }\n    100%{ box-shadow:0 22px 80px rgba(56,217,169,0.18) }\n  }\n\n  /* timeline progress markers animated */\n  .stage.play .step:nth-child(1) .dot{ background:linear-gradient(90deg,var(--accent-1),var(--accent-2)); border-color:transparent; box-shadow:0 6px 18px rgba(56,217,169,0.14) }\n  .stage.play .step:nth-child(1) .label{ color:#fff }\n  .stage.play .step:nth-child(2) .dot{ transition-delay:.6s; background:linear-gradient(90deg,var(--accent-1),var(--accent-2)); border-color:transparent; box-shadow:0 6px 18px rgba(56,217,169,0.12) }\n  .stage.play .step:nth-child(2) .label{ transition:color .28s .6s; color:#fff }\n  .stage.play .step:nth-child(3) .dot{ transition-delay:1.2s; background:linear-gradient(90deg,var(--gold),#ffd787); border-color:transparent; box-shadow:0 6px 18px rgba(255,210,122,0.12) }\n  .stage.play .step:nth-child(3) .label{ transition:color .28s 1.2s; color:#fff }\n  .stage.play .step:nth-child(4) .dot{ transition-delay:1.8s; background:linear-gradient(90deg,#7cf7ff,#38d9a9); border-color:transparent; box-shadow:0 6px 18px rgba(56,217,169,0.12) }\n  .stage.play .step:nth-child(4) .label{ transition:color .28s 1.8s; color:#fff }\n  .stage.play .step:nth-child(5) .dot{ transition-delay:2.6s; background:linear-gradient(90deg,#bffcf0,#38d9a9); border-color:transparent; box-shadow:0 6px 18px rgba(56,217,169,0.16) }\n  .stage.play .step:nth-child(5) .label{ transition:color .28s 2.6s; color:#fff }\n\n  /* Details panel */\n  .info{\n    position:absolute; right:22px; top:22px; width:320px; max-width:38%;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n    border-radius:12px; padding:16px; border:1px solid rgba(255,255,255,0.03);\n    box-shadow: 0 12px 36px rgba(2,6,23,0.45);\n    color:var(--muted); font-size:13px; line-height:1.45;\n    transform:translateY(-10px) scale(.98); opacity:0; pointer-events:none; transition:all .32s cubic-bezier(.2,.9,.3,1);\n  }\n  .info.visible{ transform:translateY(0) scale(1); opacity:1; pointer-events:auto }\n  .info h4{ margin:0 0 8px 0; color:#fff; font-size:15px; font-weight:700; font-family:'Playfair Display', serif}\n  .info p{ margin:0; color:var(--muted); font-size:13px }\n\n  /* Footer small tagline */\n  .tag{\n    margin-top:18px; color:var(--muted); font-size:13px; text-align:center;\n  }\n\n  /* Responsive */\n  @media (max-width:1000px){\n    .visual{ flex-direction:column; gap:16px; padding:8px}\n    .side{ width:100%; max-width:100%}\n    .center{ width:100%}\n    .timeline{ position:static; transform:none; width:100%; margin-top:10px; bottom:auto }\n    .info{ display:none }\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"orbs\" aria-hidden=\"true\">\n    <div class=\"orb a\"></div>\n    <div class=\"orb b\"></div>\n    <div class=\"orb c\"></div>\n  </div>\n\n  <main class=\"stage\" id=\"stage\" role=\"main\" aria-label=\"HTTPS visual explainer\">\n    <header>\n      <div class=\"title\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs><linearGradient id=\"g1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#38d9a9\"/><stop offset=\"1\" stop-color=\"#7cf7ff\"/></linearGradient></defs>\n            <rect x=\"6\" y=\"10\" width=\"52\" height=\"44\" rx=\"10\" fill=\"url(#g1)\"/>\n            <path d=\"M20 24h24M20 32h24M20 40h24\" stroke=\"#002\" stroke-opacity=\"0.14\" stroke-linecap=\"round\" stroke-width=\"2\"/>\n          </svg>\n        </div>\n        <div>\n          <h1>HTTPS — Secure by Design</h1>\n          <p class=\"lead\">Visualizing the TLS handshake, certificate, and secure channel that protect your data.</p>\n        </div>\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button class=\"btn\" id=\"replay\" title=\"Replay the TLS handshake animation\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M20 7v6h-6\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path><path d=\"M20 7a9 9 0 1 0 1 9.9\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg>\n          Replay\n        </button>\n        <button class=\"btn\" id=\"toggleInfo\" title=\"Show or hide short explanation\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"1.2\"/><path d=\"M12 8v4\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\"/><circle cx=\"12\" cy=\"17\" r=\"0.5\" fill=\"currentColor\"/></svg>\n          Details\n        </button>\n      </div>\n    </header>\n\n    <section class=\"visual\" aria-hidden=\"false\">\n      <div class=\"side\" aria-hidden=\"true\">\n        <h3>Client (Browser)</h3>\n        <div class=\"device\" aria-hidden=\"true\">\n          <div class=\"icon\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 64 48\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\">\n              <rect x=\"2\" y=\"6\" width=\"60\" height=\"34\" rx=\"6\" fill=\"rgba(255,255,255,0.02)\"/>\n              <path d=\"M8 18h48\" stroke=\"#bffcf0\" stroke-opacity=\".18\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n              <path d=\"M8 26h32\" stroke=\"#fff\" stroke-opacity=\".06\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n            </svg>\n          </div>\n          <div style=\"font-size:13px;color:var(--muted)\">You request https:// — a secure connection begins</div>\n        </div>\n      </div>\n\n      <div class=\"center\" role=\"img\" aria-label=\"Animated TLS handshake visualization\">\n        <div class=\"lane\" aria-hidden=\"true\">\n          <div class=\"device-left device\" style=\"align-items:flex-end\">\n            <!-- mini browser illustration -->\n            <div style=\"font-weight:700;color:#fff; font-size:13px\">Browser</div>\n          </div>\n\n          <div class=\"wire\" aria-hidden=\"true\">\n            <div class=\"track\"></div>\n\n            <!-- animated packets -->\n            <div class=\"packet client\" id=\"clientPacket\" style=\"left:10px\">\n              <span class=\"dot\" aria-hidden=\"true\"></span>\n              <span style=\"color:#00443d\">ClientHello</span>\n            </div>\n\n            <div class=\"packet server\" id=\"serverPacket\" style=\"left:calc(100% - 140px)\">\n              <span class=\"dot\" aria-hidden=\"true\" style=\"background:var(--accent-2)\"></span>\n              <span style=\"color:#00443d\">ServerHello • Cert</span>\n            </div>\n\n            <!-- seal / endpoint -->\n            <div class=\"seal\" style=\"position:absolute; left:50%; top:-26px; transform:translateX(-50%); width:64px; height:64px; border-radius:12px; display:flex; align-items:center; justify-content:center; background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.03)\">\n              <svg viewBox=\"0 0 48 48\" width=\"36\" height=\"36\" fill=\"none\">\n                <rect x=\"6\" y=\"14\" width=\"36\" height=\"24\" rx=\"4\" fill=\"rgba(255,255,255,0.02)\"></rect>\n                <path d=\"M12 20v-3a8 8 0 0 1 16 0v3\" stroke=\"#bffcf0\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n                <rect x=\"20\" y=\"28\" width=\"8\" height=\"6\" rx=\"2\" fill=\"url(#g2)\"></rect>\n                <defs><linearGradient id=\"g2\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#38d9a9\"/><stop offset=\"1\" stop-color=\"#7cf7ff\"/></linearGradient></defs>\n              </svg>\n            </div>\n\n          </div>\n\n          <div class=\"server-right server\" style=\"align-items:flex-start\">\n            <div style=\"font-weight:700;color:#fff; font-size:13px\">Server</div>\n          </div>\n        </div>\n\n        <!-- certificate + lock group -->\n        <div style=\"position:absolute; right:86px; top:70px; display:flex; gap:12px; align-items:center\">\n          <div class=\"certificate\" id=\"certificate\" aria-hidden=\"true\">\n            <div class=\"ribbon\" aria-hidden=\"true\"></div>\n            <div class=\"lines\" aria-hidden=\"true\"></div>\n          </div>\n          <div class=\"lock-wrap\" aria-hidden=\"true\">\n            <div class=\"lock\" id=\"lock\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\">\n                <rect x=\"5\" y=\"10\" width=\"14\" height=\"10\" rx=\"2.2\" fill=\"#032\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"0.6\"/>\n                <path d=\"M8 10V8a4 4 0 1 1 8 0v2\" stroke=\"#ffd27a\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"/>\n              </svg>\n            </div>\n          </div>\n        </div>\n\n      </div>\n\n      <div class=\"side\" aria-hidden=\"true\">\n        <h3>Server (Origin)</h3>\n        <div style=\"display:flex; flex-direction:column; align-items:center; gap:8px\">\n          <div class=\"icon\" aria-hidden=\"true\" style=\"width:96px; height:76px\">\n            <svg viewBox=\"0 0 64 48\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\">\n              <rect x=\"4\" y=\"2\" width=\"56\" height=\"44\" rx=\"6\" fill=\"rgba(255,255,255,0.02)\"/>\n              <path d=\"M14 18h36\" stroke=\"#ffd27a\" stroke-opacity=\".18\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n              <path d=\"M14 26h24\" stroke=\"#fff\" stroke-opacity=\".04\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n            </svg>\n          </div>\n          <div style=\"font-size:13px;color:var(--muted)\">It proves identity using a certificate, negotiates keys, and encrypts the channel.</div>\n        </div>\n      </div>\n\n      <!-- timeline -->\n      <div class=\"timeline\" aria-hidden=\"true\">\n        <div class=\"step\"><div class=\"dot\"></div><div class=\"label\">ClientHello</div></div>\n        <div class=\"step\"><div class=\"dot\"></div><div class=\"label\">ServerHello</div></div>\n        <div class=\"step\"><div class=\"dot\"></div><div class=\"label\">Certificate</div></div>\n        <div class=\"step\"><div class=\"dot\"></div><div class=\"label\">Key Exchange</div></div>\n        <div class=\"step\"><div class=\"dot\"></div><div class=\"label\">Secure Channel</div></div>\n      </div>\n\n    </section>\n\n    <div class=\"info\" id=\"info\" aria-hidden=\"true\">\n      <h4>How HTTPS protects you</h4>\n      <p><strong>Encryption:</strong> Data is encrypted so eavesdroppers can't read it. <br><strong>Authentication:</strong> The server proves its identity using a digital certificate issued by a trusted authority. <br><strong>Integrity:</strong> Messages are protected from tampering. The TLS handshake negotiates keys and establishes the secure channel illustrated above.</p>\n    </div>\n\n    <div class=\"tag\" aria-hidden=\"true\">Aesthetic explainer • Minimal controls • Observe the TLS handshake animation — then replay or reveal details.</div>\n  </main>\n\n<script>\n  (function(){\n    const stage = document.getElementById('stage');\n    const replay = document.getElementById('replay');\n    const toggle = document.getElementById('toggleInfo');\n    const info = document.getElementById('info');\n    const clientPacket = document.getElementById('clientPacket');\n    const serverPacket = document.getElementById('serverPacket');\n    const certificate = document.getElementById('certificate');\n    const lock = document.getElementById('lock');\n\n    // Utility: restart CSS animations by toggling class\n    function playAnimation(){\n      stage.classList.remove('play');\n      // reset inline animations by forcing reflow\n      void stage.offsetWidth;\n      // small staged timings for subtle UX\n      setTimeout(()=> stage.classList.add('play'), 40);\n    }\n\n    // initial auto-play on load\n    window.addEventListener('load', ()=> {\n      setTimeout(playAnimation, 600);\n    });\n\n    // replay button\n    replay.addEventListener('click', ()=>{\n      playAnimation();\n      replay.animate([{transform:'translateY(-2px)'},{transform:'translateY(0)'}], {duration:220});\n    });\n\n    // toggle details\n    toggle.addEventListener('click', ()=>{\n      const showing = info.classList.toggle('visible');\n      info.setAttribute('aria-hidden', !showing);\n      toggle.animate([{transform:'translateY(-2px)'},{transform:'translateY(0)'}], {duration:220});\n    });\n\n    // subtle lock color transition after handshake completes\n    // simulate end at ~2.6s after animation start\n    function updateLockVisual(){\n      // change lock stroke/fill for secure state\n      const svg = lock.querySelector('svg path, svg rect');\n      // animate a gentle pulse and colorize\n      lock.animate([{transform:'scale(.98)'},{transform:'scale(1.02)'},{transform:'scale(1)'}], {duration:900, easing:'cubic-bezier(.2,.9,.3,1)'});\n      // replace inner svg paths to golden+green\n      const sv = lock.querySelector('svg');\n      if (sv){\n        // give the shackle a green stroke\n        sv.querySelectorAll('path').forEach(p => {\n          p.setAttribute('stroke','#38d9a9');\n          p.setAttribute('stroke-width','1.6');\n        });\n        // set body to greenish\n        sv.querySelectorAll('rect').forEach(r => r.setAttribute('fill','#002d21'));\n      }\n    }\n\n    // Listen for stage play toggle to schedule lock update\n    const observer = new MutationObserver(muts=>{\n      muts.forEach(m=>{\n        if (m.attributeName === 'class'){\n          if (stage.classList.contains('play')){\n            // schedule updates to align with CSS timings\n            setTimeout(()=> updateLockVisual(), 2200);\n          }\n        }\n      });\n    });\n    observer.observe(stage, {attributes:true});\n\n    // Accessibility: keyboard support for buttons (Enter/Space)\n    [replay, toggle].forEach(btn=>{\n      btn.addEventListener('keydown', (e)=>{\n        if (e.key === 'Enter' || e.key === ' ') btn.click();\n      });\n    });\n\n  })();\n</script>\n</body>\n</html>"
