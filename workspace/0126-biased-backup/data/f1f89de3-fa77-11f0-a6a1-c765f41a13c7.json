  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Integration Testing — Visual Simulation</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Space+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --bg1: #0f1724;\n    --bg2: #071829;\n    --glass: rgba(255,255,255,0.05);\n    --muted: rgba(255,255,255,0.6);\n    --accent: #00e5a8;\n    --accent-2: #6dd3ff;\n    --accent-3: #ff8ba7;\n    --card: rgba(255,255,255,0.03);\n    --success: #3be88a;\n    --danger: #ff6b87;\n    --glass-border: rgba(255,255,255,0.06);\n    --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;\n  }\n  * {box-sizing: border-box}\n  html,body {height:100%}\n  body{\n    margin:0;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(6,30,50,0.35), transparent 8%),\n                radial-gradient(900px 500px at 90% 90%, rgba(15,10,30,0.25), transparent 12%),\n                linear-gradient(180deg, var(--bg1), var(--bg2));\n    color: #e8f3ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Decorative floating shapes */\n  .ambient {\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    overflow:hidden;\n  }\n  .blob {\n    position:absolute;\n    width:420px;height:420px;\n    filter:blur(60px);\n    opacity:0.14;\n    transform:translate3d(0,0,0);\n    mix-blend-mode:screen;\n    transition: transform 0.7s cubic-bezier(.2,.9,.25,1);\n  }\n  .blob.a {background:linear-gradient(135deg,var(--accent),var(--accent-2)); top: -6%; left: -4%; transform: rotate(12deg);}\n  .blob.b {background:linear-gradient(135deg,var(--accent-3),#ffb0d6); bottom:-10%; right:-6%; opacity:0.11; width:360px;height:360px; filter:blur(80px)}\n  .blob.c {background:linear-gradient(90deg,#143a6b,#0ba3ff 70%); top:20%; right:6%; width:260px;height:260px; opacity:0.08; filter:blur(40px)}\n\n  /* Layout */\n  .wrap {\n    display:grid;\n    grid-template-columns: 420px 1fr;\n    gap:32px;\n    padding:48px;\n    height:100vh;\n    align-items:center;\n  }\n\n  /* Left panel (explanatory) */\n  .panel {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n    border: 1px solid var(--glass-border);\n    padding:28px;\n    border-radius:16px;\n    box-shadow: var(--shadow);\n    backdrop-filter: blur(8px) saturate(120%);\n    overflow:hidden;\n    min-height:420px;\n  }\n  .brand {\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-bottom:18px;\n  }\n  .logo {\n    width:56px;height:56px;border-radius:12px;\n    background: linear-gradient(135deg,var(--accent),var(--accent-2));\n    display:flex;align-items:center;justify-content:center;\n    font-weight:800;color:white;font-size:20px;\n    box-shadow: 0 6px 20px rgba(3,12,22,0.5);\n    transform:translateZ(0);\n  }\n  .title {\n    font-size:18px;font-weight:700;letter-spacing:-0.2px;\n    color: #fff;\n  }\n  .subtitle {\n    font-size:13px;color:var(--muted);margin-top:4px;\n  }\n\n  .heading {\n    margin-top:12px;\n    font-size:28px;font-weight:800;\n    letter-spacing:-0.6px;\n    line-height:1;\n    color:linear-gradient(90deg,#fff);\n  }\n  .desc {\n    margin-top:12px;color:var(--muted);font-size:14px;line-height:1.5;\n  }\n  .meta {\n    display:flex;gap:12px;margin-top:18px;\n  }\n  .pill {\n    padding:8px 12px;border-radius:999px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.03);\n    font-size:13px;color:var(--muted);display:inline-flex;gap:8px;align-items:center;\n  }\n\n  .controls {\n    margin-top:20px;display:flex;gap:12px;align-items:center;\n  }\n  .btn {\n    padding:10px 16px;border-radius:12px;border:none;cursor:pointer;font-weight:600;\n    background: linear-gradient(90deg,var(--accent),#00c0ff); color:#02111a;\n    box-shadow: 0 8px 26px rgba(0,210,170,0.12), inset 0 -1px 0 rgba(0,0,0,0.08);\n    transition: transform .18s cubic-bezier(.2,.9,.25,1), box-shadow .18s;\n    transform: translateZ(0);\n  }\n  .btn:active{ transform:translateY(2px) }\n  .btn.secondary {\n    background: transparent;color:var(--muted);border:1px solid rgba(255,255,255,0.04);\n    box-shadow:none;\n  }\n  .footnote { margin-top:14px;color:rgba(255,255,255,0.45);font-size:13px }\n\n  /* Right visual area */\n  .stage {\n    position:relative;\n    min-height:520px;\n    border-radius:18px;\n    padding:28px;\n    overflow:hidden;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    box-shadow: 0 18px 50px rgba(2,6,23,0.7);\n  }\n  .stage-grid{\n    display:grid;\n    grid-template-columns: 1fr 340px;\n    gap:22px;\n    height:100%;\n  }\n\n  /* left visual canvas inside stage */\n  .canvas {\n    position:relative;\n    padding:22px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border-radius:14px;\n    overflow:visible;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  /* Node network */\n  .network {\n    width:100%;max-width:960px;height:420px;position:relative;\n  }\n  .node {\n    position:absolute;\n    width:110px;height:60px;border-radius:12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.035);\n    display:flex;flex-direction:column;align-items:center;justify-content:center;\n    color:var(--muted);\n    font-weight:600;font-size:13px;\n    box-shadow: 0 6px 22px rgba(2,6,23,0.6);\n    transition: transform 0.5s cubic-bezier(.2,.9,.25,1), box-shadow .4s;\n    transform-origin:center center;\n    backdrop-filter: blur(6px);\n  }\n  .node .label { font-size:12px;color:var(--muted); font-weight:600 }\n  .node .sub { font-size:11px;color:rgba(255,255,255,0.45); margin-top:6px; font-weight:500; }\n\n  .node.pulse {\n    animation: nodePulse 1.6s ease-in-out infinite;\n    box-shadow: 0 12px 40px rgba(0,200,170,0.07), 0 4px 14px rgba(2,6,23,0.6);\n    transform:translateY(-4px) scale(1.02);\n  }\n  @keyframes nodePulse {\n    0%{ transform:scale(1) }\n    50%{ transform:scale(1.02) }\n    100%{ transform:scale(1) }\n  }\n\n  /* connectors as SVG overlay */\n  .links {\n    position:absolute;inset:0;pointer-events:none;\n  }\n  .flow {\n    stroke: rgba(255,255,255,0.06);\n    stroke-width:4;\n    fill:none;\n    filter: drop-shadow(0 10px 20px rgba(0,160,140,0.08));\n    stroke-linecap:round;\n    transition: stroke 0.24s;\n  }\n  .flow.active {\n    stroke: url(#grad-green);\n    stroke-width:6;\n    opacity:1;\n    filter: drop-shadow(0 10px 40px rgba(0,230,168,0.12));\n  }\n  .flow.fail {\n    stroke: url(#grad-red);\n    stroke-width:6;\n    filter: drop-shadow(0 10px 40px rgba(255,107,135,0.12));\n  }\n\n  /* right side test panel */\n  .panel-right {\n    padding:18px;border-radius:12px;background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    height:100%;display:flex;flex-direction:column;gap:12px;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .progress {\n    display:flex;gap:16px;align-items:center;padding:8px;\n  }\n  .ring {\n    width:92px;height:92px;border-radius:999px;display:grid;place-items:center;\n    background:conic-gradient(rgba(255,255,255,0.04) 0 100%);\n    position:relative;\n  }\n  .ring .inner {\n    width:66px;height:66px;border-radius:999px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    display:grid;place-items:center;font-weight:800;font-size:15px;\n    color:var(--accent-2);\n    border:1px solid rgba(255,255,255,0.03);\n  }\n  .progress-meta {flex:1}\n  .progress-meta .big { font-weight:800;font-size:18px }\n  .progress-meta .muted {color:var(--muted);font-size:13px;margin-top:6px}\n\n  .matrix {\n    display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:8px;flex:1;\n    overflow:auto;padding-right:6px;\n  }\n  .test-tile {\n    border-radius:10px;padding:10px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n    border:1px solid rgba(255,255,255,0.02);display:flex;align-items:center;gap:10px;min-height:56px;\n    transition: transform .28s, background .28s, border-color .28s;\n  }\n  .tile-id {width:44px;height:44;border-radius:10px;display:grid;place-items:center;font-family:'Space Mono', monospace;font-weight:700;color:var(--muted);background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.025)}\n  .tile-desc {flex:1; font-size:13px; color:var(--muted); font-weight:600}\n  .tile-status {width:40px;text-align:center;font-weight:800}\n\n  .tile-pass { background:linear-gradient(90deg, rgba(3,200,150,0.06), rgba(3,200,150,0.02)); border-color: rgba(0,230,168,0.12); color:var(--success) }\n  .tile-fail { background:linear-gradient(90deg, rgba(255,107,135,0.03), rgba(255,107,135,0.01)); border-color: rgba(255,107,135,0.08); color:var(--danger) }\n  .tile-running { box-shadow: 0 8px 30px rgba(0,180,220,0.04); transform:translateY(-6px) scale(1.01) }\n\n  /* subtle animations for connectors drawing */\n  .path-anim { stroke-dasharray: 1000; stroke-dashoffset: 1000; transition: stroke-dashoffset 0.9s cubic-bezier(.2,.9,.25,1) }\n\n  /* tiny footer */\n  .credit {position:absolute;left:22px;bottom:18px;color:rgba(255,255,255,0.12);font-size:12px}\n  @media (max-width:1000px){\n    .wrap{grid-template-columns: 1fr; padding:22px; gap:18px; height:auto}\n    .stage{min-height:620px}\n    .stage-grid{grid-template-columns: 1fr}\n    .canvas{min-height:420px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\">\n    <div class=\"blob a\"></div>\n    <div class=\"blob b\"></div>\n    <div class=\"blob c\"></div>\n  </div>\n\n  <div class=\"wrap\">\n    <div class=\"panel\" role=\"region\" aria-label=\"Explanation\">\n      <div class=\"brand\">\n        <div class=\"logo\" aria-hidden=\"true\">IT</div>\n        <div>\n          <div class=\"title\">Integration Testing</div>\n          <div class=\"subtitle\">Validate interactions across modules — reliably, visually.</div>\n        </div>\n      </div>\n\n      <div class=\"heading\" style=\"font-size:22px\">Observe how components integrate & collaborate</div>\n      <div class=\"desc\">\n        Integration testing verifies how system parts work together: APIs, services, databases, and UI. This\n        visual simulation highlights connection flows, test pass/fail status, and progressive stabilization of the whole system.\n        Sit back and watch the network come alive — run a concise simulation to see the interactions animate.\n      </div>\n\n      <div class=\"meta\">\n        <div class=\"pill\">Stages: Unit → Integration → System</div>\n        <div class=\"pill\">Focus: Interaction & Contracts</div>\n      </div>\n\n      <div class=\"controls\">\n        <button id=\"runBtn\" class=\"btn\" aria-pressed=\"false\">Run Integration Simulation</button>\n        <button id=\"resetBtn\" class=\"btn secondary\">Reset</button>\n      </div>\n\n      <div class=\"footnote\">Only one simulation at a time — animations are intentionally curated for clarity and aesthetics.</div>\n    </div>\n\n    <div class=\"stage\" role=\"main\" aria-label=\"Simulation area\">\n      <div class=\"stage-grid\">\n        <div class=\"canvas\" aria-hidden=\"false\">\n          <div class=\"network\" id=\"network\">\n            <!-- nodes -->\n            <div class=\"node\" id=\"n-ui\" style=\"left:50%;top:10%;transform:translate(-50%,-50%);\">\n              <div class=\"label\">UI</div>\n              <div class=\"sub\">Front-end</div>\n            </div>\n\n            <div class=\"node\" id=\"n-api\" style=\"left:50%;top:32%;transform:translate(-50%,-50%);\">\n              <div class=\"label\">API</div>\n              <div class=\"sub\">Gateway</div>\n            </div>\n\n            <div class=\"node\" id=\"n-auth\" style=\"left:24%;top:52%;transform:translate(-50%,-50%);\">\n              <div class=\"label\">Auth</div>\n              <div class=\"sub\">Service</div>\n            </div>\n\n            <div class=\"node\" id=\"n-svc\" style=\"left:50%;top:52%;transform:translate(-50%,-50%);\">\n              <div class=\"label\">Order</div>\n              <div class=\"sub\">Service</div>\n            </div>\n\n            <div class=\"node\" id=\"n-billing\" style=\"left:76%;top:52%;transform:translate(-50%,-50%);\">\n              <div class=\"label\">Billing</div>\n              <div class=\"sub\">Service</div>\n            </div>\n\n            <div class=\"node\" id=\"n-db\" style=\"left:50%;top:78%;transform:translate(-50%,-50%);\">\n              <div class=\"label\">DB</div>\n              <div class=\"sub\">Storage</div>\n            </div>\n\n            <!-- connectors (SVG) -->\n            <svg class=\"links\" viewBox=\"0 0 1000 520\" preserveAspectRatio=\"none\" id=\"linksSvg\">\n              <defs>\n                <linearGradient id=\"grad-green\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n                  <stop offset=\"0%\" stop-color=\"#00e5a8\"/>\n                  <stop offset=\"100%\" stop-color=\"#6dd3ff\"/>\n                </linearGradient>\n                <linearGradient id=\"grad-red\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n                  <stop offset=\"0%\" stop-color=\"#ff8ba7\"/>\n                  <stop offset=\"100%\" stop-color=\"#ff6b87\"/>\n                </linearGradient>\n              </defs>\n              <!-- UI -> API -->\n              <path id=\"p-ui-api\" class=\"flow path-anim\" d=\"M500 50 C500 120, 500 150, 500 170\" stroke-linecap=\"round\"/>\n              <!-- API -> Auth -->\n              <path id=\"p-api-auth\" class=\"flow path-anim\" d=\"M500 170 C360 200, 360 260, 290 270\"/>\n              <!-- API -> Order -->\n              <path id=\"p-api-svc\" class=\"flow path-anim\" d=\"M500 170 C500 210, 500 240, 500 270\"/>\n              <!-- API -> Billing -->\n              <path id=\"p-api-billing\" class=\"flow path-anim\" d=\"M500 170 C640 200, 640 260, 710 270\"/>\n              <!-- Auth -> DB -->\n              <path id=\"p-auth-db\" class=\"flow path-anim\" d=\"M290 270 C350 310, 470 360, 500 390\"/>\n              <!-- Order -> DB -->\n              <path id=\"p-svc-db\" class=\"flow path-anim\" d=\"M500 270 C500 330, 500 360, 500 390\"/>\n              <!-- Billing -> DB -->\n              <path id=\"p-billing-db\" class=\"flow path-anim\" d=\"M710 270 C650 310, 530 360, 500 390\"/>\n            </svg>\n          </div>\n        </div>\n\n        <div class=\"panel-right\" aria-hidden=\"false\">\n          <div class=\"progress\">\n            <div class=\"ring\" id=\"ring\">\n              <svg viewBox=\"0 0 36 36\" width=\"92\" height=\"92\">\n                <defs>\n                  <linearGradient id=\"g1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                    <stop offset=\"0%\" stop-color=\"#00e5a8\"/><stop offset=\"100%\" stop-color=\"#6dd3ff\"/>\n                  </linearGradient>\n                </defs>\n                <path stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"3\" fill=\"none\" d=\"M18 2.1a15.9 15.9 0 1 0 0 31.8 15.9 15.9 0 1 0 0-31.8\"/>\n                <path id=\"ringPath\" stroke=\"url(#g1)\" stroke-width=\"3\" stroke-linecap=\"round\" fill=\"none\"\n                      stroke-dasharray=\"0 100\" d=\"M18 2.1a15.9 15.9 0 1 0 0 31.8 15.9 15.9 0 1 0 0-31.8\"/>\n              </svg>\n              <div class=\"inner\" id=\"ringLabel\">0%</div>\n            </div>\n            <div class=\"progress-meta\">\n              <div class=\"big\" id=\"progressTitle\">Integration Suite</div>\n              <div class=\"muted\">5 Endpoints • 3 Services • 1 Database</div>\n            </div>\n          </div>\n\n          <div class=\"matrix\" id=\"matrix\">\n            <!-- test tiles will be injected -->\n          </div>\n\n          <div style=\"margin-top:auto;color:rgba(255,255,255,0.1);font-size:12px;padding-top:6px\">Visual Simulation • Curated for clarity</div>\n        </div>\n      </div>\n\n      <div class=\"credit\">© Simulation — Integration Testing</div>\n    </div>\n\n  </div>\n\n<script>\n/* Integration Testing Visual Simulation\n   - Only two UI controls: Run & Reset\n   - Curated animation timeline to visualize integration flows\n*/\n\n(function(){\n  const nodes = {\n    ui: document.getElementById('n-ui'),\n    api: document.getElementById('n-api'),\n    auth: document.getElementById('n-auth'),\n    svc: document.getElementById('n-svc'),\n    billing: document.getElementById('n-billing'),\n    db: document.getElementById('n-db')\n  };\n\n  // Map of path ids to connections (for sequencing)\n  const links = [\n    {id:'p-ui-api', from:'ui', to:'api'},\n    {id:'p-api-auth', from:'api', to:'auth'},\n    {id:'p-api-svc', from:'api', to:'svc'},\n    {id:'p-api-billing', from:'api', to:'billing'},\n    {id:'p-auth-db', from:'auth', to:'db'},\n    {id:'p-svc-db', from:'svc', to:'db'},\n    {id:'p-billing-db', from:'billing', to:'db'}\n  ];\n\n  const tests = [\n    {id:'T01', desc:'UI → API handshake', link:'p-ui-api'},\n    {id:'T02', desc:'API auth routing', link:'p-api-auth'},\n    {id:'T03', desc:'Order service flow', link:'p-api-svc'},\n    {id:'T04', desc:'Billing integration', link:'p-api-billing'},\n    {id:'T05', desc:'Auth persistence', link:'p-auth-db'},\n    {id:'T06', desc:'Order DB integrity', link:'p-svc-db'},\n    {id:'T07', desc:'Billing DB sync', link:'p-billing-db'}\n  ];\n\n  // DOM\n  const matrix = document.getElementById('matrix');\n  const runBtn = document.getElementById('runBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const ring = document.getElementById('ringPath');\n  const ringLabel = document.getElementById('ringLabel');\n\n  // create test tiles\n  function buildTiles(){\n    matrix.innerHTML = '';\n    tests.forEach(t => {\n      const tile = document.createElement('div');\n      tile.className = 'test-tile';\n      tile.id = 'tile-'+t.id;\n      tile.innerHTML = '<div class=\"tile-id\">'+t.id+'</div><div class=\"tile-desc\">'+t.desc+'</div><div class=\"tile-status\">—</div>';\n      matrix.appendChild(tile);\n    });\n  }\n\n  buildTiles();\n\n  // helper to set a path to active / fail / reset\n  function setPathState(pathId, state){\n    const p = document.getElementById(pathId);\n    if(!p) return;\n    p.classList.remove('active','fail');\n    if(state==='active') p.classList.add('active');\n    if(state==='fail') p.classList.add('fail');\n    // animate drawing\n    if(state==='active' || state==='fail'){\n      p.style.strokeDashoffset = 1000;\n      // force reflow\n      void p.getBoundingClientRect();\n      p.style.strokeDashoffset = 0;\n    } else {\n      p.style.strokeDashoffset = 1000;\n    }\n  }\n\n  // animate node highlight\n  function nodePulse(name, on=true){\n    const nd = nodes[name];\n    if(!nd) return;\n    if(on) nd.classList.add('pulse');\n    else nd.classList.remove('pulse');\n  }\n\n  function setTileState(id, state){\n    const tile = document.getElementById('tile-'+id);\n    if(!tile) return;\n    tile.classList.remove('tile-pass','tile-fail','tile-running');\n    const status = tile.querySelector('.tile-status');\n    if(state==='running'){ tile.classList.add('tile-running'); status.textContent = '…'; }\n    if(state==='pass'){ tile.classList.add('tile-pass'); status.textContent = '✓'; }\n    if(state==='fail'){ tile.classList.add('tile-fail'); status.textContent = '✕'; }\n    if(state==='reset'){ status.textContent = '—'; }\n  }\n\n  // progress ring control (0-100)\n  function setProgress(pct){\n    pct = Math.max(0, Math.min(100, pct));\n    const dash = `${pct} ${100-pct}`;\n    ring.setAttribute('stroke-dasharray', dash);\n    ringLabel.textContent = Math.round(pct) + '%';\n  }\n\n  // responsive mapping of SVG points (the SVG uses 1000x520 viewBox)\n  function updatePaths(){\n    // Position points using positions of node elements, then set 'd' attributes for curves\n    const svg = document.getElementById('linksSvg');\n    const vb = svg.viewBox.baseVal;\n    const svgRect = svg.getBoundingClientRect();\n    // compute scale from element coordinates (we positioned nodes with percentages inside a container)\n    // nodes are absolutely positioned inside .network: get their center coords relative to svg\n    function posOf(el){\n      const net = document.getElementById('network').getBoundingClientRect();\n      const r = el.getBoundingClientRect();\n      // map into viewBox coordinates\n      const cx = (r.left + r.right)/2 - net.left;\n      const cy = (r.top + r.bottom)/2 - net.top;\n      const x = (cx / net.width) * vb.width;\n      const y = (cy / net.height) * vb.height;\n      return {x,y};\n    }\n    const p_ui = posOf(nodes.ui), p_api = posOf(nodes.api), p_auth = posOf(nodes.auth),\n          p_svc = posOf(nodes.svc), p_billing = posOf(nodes.billing), p_db = posOf(nodes.db);\n\n    // set path d strings\n    document.getElementById('p-ui-api').setAttribute('d', `M ${p_ui.x} ${p_ui.y} C ${p_ui.x} ${(p_ui.y+p_api.y)/2}, ${p_api.x} ${(p_ui.y+p_api.y)/2}, ${p_api.x} ${p_api.y}`);\n    document.getElementById('p-api-auth').setAttribute('d', `M ${p_api.x} ${p_api.y} C ${p_api.x - 120} ${p_api.y+30}, ${p_auth.x - 20} ${p_auth.y - 10}, ${p_auth.x} ${p_auth.y}`);\n    document.getElementById('p-api-svc').setAttribute('d', `M ${p_api.x} ${p_api.y} C ${p_api.x} ${p_api.y+60}, ${p_svc.x} ${p_svc.y-20}, ${p_svc.x} ${p_svc.y}`);\n    document.getElementById('p-api-billing').setAttribute('d', `M ${p_api.x} ${p_api.y} C ${p_api.x + 120} ${p_api.y+30}, ${p_billing.x + 20} ${p_billing.y - 10}, ${p_billing.x} ${p_billing.y}`);\n    document.getElementById('p-auth-db').setAttribute('d', `M ${p_auth.x} ${p_auth.y} C ${p_auth.x + 60} ${p_auth.y+60}, ${p_db.x - 40} ${p_db.y - 30}, ${p_db.x} ${p_db.y}`);\n    document.getElementById('p-svc-db').setAttribute('d', `M ${p_svc.x} ${p_svc.y} C ${p_svc.x} ${p_svc.y+60}, ${p_db.x} ${p_db.y - 30}, ${p_db.x} ${p_db.y}`);\n    document.getElementById('p-billing-db').setAttribute('d', `M ${p_billing.x} ${p_billing.y} C ${p_billing.x - 60} ${p_billing.y+60}, ${p_db.x + 40} ${p_db.y - 30}, ${p_db.x} ${p_db.y}`);\n\n    // set initial dashoffset for animation reset\n    document.querySelectorAll('.path-anim').forEach(p => {\n      p.style.strokeDasharray = p.getTotalLength() + ' ' + p.getTotalLength();\n      p.style.strokeDashoffset = p.getTotalLength();\n    });\n  }\n\n  // Initialize update on load and on resize\n  function refreshLayout(){\n    updatePaths();\n  }\n  window.addEventListener('resize', () => { window.requestAnimationFrame(refreshLayout); });\n  window.addEventListener('load', refreshLayout);\n\n  // Simulation logic\n  let running = false;\n  let timeline = null;\n\n  function runSimulation(){\n    if(running) return;\n    running = true;\n    runBtn.setAttribute('aria-pressed','true');\n    runBtn.disabled = true;\n    resetBtn.disabled = true;\n\n    // reset visuals\n    tests.forEach(t => setTileState(t.id, 'reset'));\n    links.forEach(l => setPathState(l.id, 'reset'));\n    Object.keys(nodes).forEach(k => nodePulse(k,false));\n    setProgress(2);\n\n    // timeline: iterate tests sequentially with curated timing\n    const total = tests.length;\n    let index = 0;\n    let progress = 3;\n\n    function step(){\n      if(index >= total){\n        // final stabilization\n        setProgress(100);\n        Object.keys(nodes).forEach(k => nodePulse(k,true));\n        runBtn.disabled = true;\n        resetBtn.disabled = false;\n        running = false;\n        return;\n      }\n      const t = tests[index];\n      // mark tile running\n      setTileState(t.id,'running');\n      // highlight involved nodes: find link from mapping\n      const linkObj = links.find(l => l.id === t.link);\n      if(linkObj){\n        nodePulse(linkObj.from, true);\n        nodePulse(linkObj.to, true);\n      }\n\n      // animate link active; simulate pass/fail with slight randomness (mostly pass)\n      setTimeout(() => {\n        // decide pass/fail\n        const failChance = 0.08; // small chance to fail\n        const isFail = Math.random() < failChance;\n        setPathState(t.link, isFail ? 'fail' : 'active');\n        setTileState(t.id, isFail ? 'fail' : 'pass');\n\n        // if fail, briefly highlight red nodes and pause a bit\n        if(isFail){\n          const pathEl = document.getElementById(t.link);\n          pathEl.classList.add('fail');\n          // flash nodes red by toggling styles (simple approach: pulse then remove)\n          if(linkObj){\n            nodePulse(linkObj.from,false);\n            nodePulse(linkObj.to,false);\n          }\n        } else {\n          // successful flow: gentle glow and keep nodes pulsing briefly\n          setTimeout(() => {\n            if(linkObj){\n              nodePulse(linkObj.from,false);\n              nodePulse(linkObj.to,false);\n            }\n          }, 900);\n        }\n\n        // update progress\n        progress += (95 / total);\n        setProgress(Math.min(98, progress));\n\n        index++;\n        // small delay before next step\n        timeline = setTimeout(step, isFail ? 1200 : 700);\n      }, 900);\n    }\n\n    // phased start: UI handshake\n    timeline = setTimeout(step, 400);\n  }\n\n  function resetSimulation(){\n    // stop timeline\n    if(timeline) clearTimeout(timeline);\n    running = false;\n    runBtn.setAttribute('aria-pressed','false');\n    runBtn.disabled = false;\n    resetBtn.disabled = false;\n\n    // reset visuals\n    tests.forEach(t => setTileState(t.id, 'reset'));\n    links.forEach(l => setPathState(l.id, 'reset'));\n    Object.keys(nodes).forEach(k => nodePulse(k,false));\n    setProgress(0);\n  }\n\n  // attach handlers\n  runBtn.addEventListener('click', runSimulation);\n  resetBtn.addEventListener('click', resetSimulation);\n\n  // initial subtle animation for ambience\n  setTimeout(() => {\n    // gently nudge blobs\n    document.querySelector('.blob.a').style.transform = 'translate3d(-10px,6px,0) rotate(6deg)';\n    document.querySelector('.blob.b').style.transform = 'translate3d(8px,-12px,0) rotate(-8deg)';\n    document.querySelector('.blob.c').style.transform = 'translate3d(12px,4px,0)';\n    // small node entrance\n    Object.values(nodes).forEach((n,i) => {\n      n.style.opacity = 0;\n      n.style.transform += ' scale(0.96)';\n      setTimeout(()=> {\n        n.style.opacity = 1;\n        n.style.transform = n.style.transform.replace(' scale(0.96)','');\n      }, 240 + i * 60);\n    });\n  }, 80);\n\n  // ensure initial reset\n  setProgress(0);\n  links.forEach(l => setPathState(l.id,'reset'));\n})();\n</script>\n</body>\n</html>"
