    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>PageRank Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@400;500;600&display=swap');\n        \n        :root {\n            --primary: #3a0ca3;\n            --secondary: #4cc9f0;\n            --accent: #f72585;\n            --light: #f8f9fa;\n            --dark: #212529;\n            --transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 1s ease-out forwards;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            font-weight: 600;\n            color: var(--primary);\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: #6c757d;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualization {\n            position: relative;\n            height: 600px;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            overflow: hidden;\n            padding: 2rem;\n            margin-bottom: 3rem;\n            transform: scale(0.95);\n            opacity: 0;\n            animation: scaleIn 1s 0.3s ease-out forwards;\n        }\n        \n        .graph-container {\n            position: relative;\n            width: 100%;\n            height: 100%;\n        }\n        \n        .node {\n            position: absolute;\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: 600;\n            color: white;\n            cursor: default;\n            transition: var(--transition);\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.15);\n            z-index: 10;\n        }\n        \n        .node:hover {\n            transform: scale(1.1);\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n        }\n        \n        .edge {\n            position: absolute;\n            height: 2px;\n            background: rgba(0, 0, 0, 0.2);\n            transform-origin: left center;\n            z-index: 1;\n        }\n        \n        .edge::after {\n            content: '';\n            position: absolute;\n            right: 0;\n            top: 50%;\n            transform: translateY(-50%);\n            width: 8px;\n            height: 8px;\n            background: var(--dark);\n            border-radius: 50%;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-bottom: 2rem;\n            opacity: 0;\n            animation: fadeIn 0.5s 1s ease-out forwards;\n        }\n        \n        button {\n            padding: 0.8rem 1.8rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(45deg, var(--primary), var(--accent));\n            color: white;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            transition: var(--transition);\n            box-shadow: 0 4px 15px rgba(58, 12, 163, 0.2);\n        }\n        \n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(58, 12, 163, 0.3);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .explanation {\n            background: white;\n            border-radius: 16px;\n            padding: 2rem;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);\n            max-width: 800px;\n            margin: 0 auto;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeInUp 0.8s 0.8s ease-out forwards;\n        }\n        \n        h2 {\n            font-family: 'Playfair Display', serif;\n            font-size: 2rem;\n            color: var(--primary);\n            margin-bottom: 1rem;\n        }\n        \n        p {\n            line-height: 1.8;\n            margin-bottom: 1.5rem;\n            color: #495057;\n        }\n        \n        .pagerank-display {\n            position: absolute;\n            bottom: 2rem;\n            left: 2rem;\n            background: rgba(255, 255, 255, 0.9);\n            border-radius: 12px;\n            padding: 1rem;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n            z-index: 100;\n            opacity: 0;\n            animation: fadeIn 0.5s 1.5s ease-out forwards;\n        }\n        \n        .pagerank-display h3 {\n            font-size: 1rem;\n            color: var(--accent);\n            margin-bottom: 0.5rem;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n        }\n        \n        .rank-item {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 0.5rem;\n            font-size: 0.9rem;\n        }\n        \n        .rank-value {\n            font-weight: 600;\n            color: var(--primary);\n        }\n        \n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: 0;\n        }\n        \n        .particle {\n            position: absolute;\n            width: 3px;\n            height: 3px;\n            background: rgba(74, 201, 240, 0.4);\n            border-radius: 50%;\n        }\n        \n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes scaleIn {\n            to {\n                opacity: 1;\n                transform: scale(1);\n            }\n        }\n        \n        @keyframes fadeInUp {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes pulse {\n            0%, 100% {\n                transform: scale(1);\n            }\n            50% {\n                transform: scale(1.05);\n            }\n        }\n        \n        .pulse {\n            animation: pulse 2s infinite ease-in-out;\n        }\n        \n        .highlight {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            background: rgba(247, 37, 133, 0.1);\n            z-index: 5;\n            pointer-events: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>PageRank</h1>\n            <p class=\"subtitle\">A visual exploration of the algorithm that revolutionized web search by ranking pages based on their link structure and importance in the network.</p>\n        </header>\n        \n        <div class=\"controls\">\n            <button id=\"reset\">Reset Animation</button>\n        </div>\n        \n        <div class=\"visualization\">\n            <div class=\"particles\" id=\"particles\"></div>\n            <div class=\"graph-container\" id=\"graph\"></div>\n            <div class=\"pagerank-display\">\n                <h3>PageRank Values</h3>\n                <div id=\"rankings\"></div>\n            </div>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>Understanding PageRank</h2>\n            <p>PageRank is an algorithm developed by Google's founders that assigns a numerical weighting to each element of a hyperlinked set of documents, such as the World Wide Web, with the purpose of \"measuring\" its relative importance within the set.</p>\n            <p>The algorithm works by counting the number and quality of links to a page to determine a rough estimate of how important the website is. The underlying assumption is that more important websites are likely to receive more links from other websites.</p>\n            <p>In this visualization, larger nodes represent pages with higher PageRank scores, while thicker arrows represent more significant \"votes\" between pages. The algorithm iteratively distributes rank values across the network until equilibrium is reached.</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles\n            const particlesContainer = document.getElementById('particles');\n            for (let i = 0; i < 50; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                particle.style.left = `${Math.random() * 100}%`;\n                particle.style.top = `${Math.random() * 100}%`;\n                particle.style.opacity = Math.random() * 0.5 + 0.1;\n                particle.style.width = `${Math.random() * 4 + 2}px`;\n                particle.style.height = particle.style.width;\n                particle.style.animation = `float ${Math.random() * 10 + 10}s linear infinite`;\n                particlesContainer.appendChild(particle);\n            }\n            \n            // Graph data\n            const nodes = [\n                { id: 'A', rank: 0.3, x: 40, y: 50, color: '#3a0ca3' },\n                { id: 'B', rank: 0.2, x: 20, y: 30, color: '#4cc9f0' },\n                { id: 'C', rank: 0.25, x: 60, y: 30, color: '#4895ef' },\n                { id: 'D', rank: 0.15, x: 30, y: 70, color: '#4361ee' },\n                { id: 'E', rank: 0.1, x: 70, y: 70, color: '#7209b7' }\n            ];\n            \n            const edges = [\n                { from: 'A', to: 'B', strength: 0.6 },\n                { from: 'A', to: 'C', strength: 0.8 },\n                { from: 'B', to: 'C', strength: 0.4 },\n                { from: 'C', to: 'A', strength: 0.9 },\n                { from: 'C', to: 'D', strength: 0.5 },\n                { from: 'D', to: 'E', strength: 0.3 },\n                { from: 'E', to: 'A', strength: 0.7 },\n                { from: 'E', to: 'C', strength: 0.5 }\n            ];\n            \n            const graphContainer = document.getElementById('graph');\n            const rankingsContainer = document.getElementById('rankings');\n            \n            // Create nodes and edges\n            function renderGraph() {\n                graphContainer.innerHTML = '';\n                rankingsContainer.innerHTML = '';\n                \n                // Sort nodes by rank\n                const sortedNodes = [...nodes].sort((a, b) => b.rank - a.rank);\n                \n                // Render edges first (so they appear under nodes)\n                edges.forEach(edge => {\n                    const fromNode = nodes.find(n => n.id === edge.from);\n                    const toNode = nodes.find(n => n.id === edge.to);\n                    \n                    if (fromNode && toNode) {\n                        const edgeElement = document.createElement('div');\n                        edgeElement.classList.add('edge');\n                        \n                        // Calculate edge position and length\n                        const fromX = fromNode.x * graphContainer.offsetWidth / 100;\n                        const fromY = fromNode.y * graphContainer.offsetHeight / 100;\n                        const toX = toNode.x * graphContainer.offsetWidth / 100;\n                        const toY = toNode.y * graphContainer.offsetHeight / 100;\n                        \n                        const length = Math.sqrt(Math.pow(toX - fromX, 2) + Math.pow(toY - fromY, 2));\n                        const angle = Math.atan2(toY - fromY, toX - fromX);\n                        \n                        edgeElement.style.width = `${length}px`;\n                        edgeElement.style.left = `${fromX}px`;\n                        edgeElement.style.top = `${fromY}px`;\n                        edgeElement.style.transform = `rotate(${angle}rad)`;\n                        edgeElement.style.opacity = edge.strength;\n                        edgeElement.style.height = `${edge.strength * 3 + 1}px`;\n                        \n                        graphContainer.appendChild(edgeElement);\n                    }\n                });\n                \n                // Render nodes\n                nodes.forEach(node => {\n                    const nodeElement = document.createElement('div');\n                    nodeElement.classList.add('node');\n                    nodeElement.textContent = node.id;\n                    \n                    // Position node\n                    nodeElement.style.left = `calc(${node.x}% - ${30}px)`;\n                    nodeElement.style.top = `calc(${node.y}% - ${30}px)`;\n                    \n                    // Size based on rank\n                    const size = 40 + node.rank * 40;\n                    nodeElement.style.width = `${size}px`;\n                    nodeElement.style.height = `${size}px`;\n                    \n                    // Color\n                    nodeElement.style.background = node.color;\n                    \n                    // Highlight effect\n                    const highlight = document.createElement('div');\n                    highlight.classList.add('highlight');\n                    highlight.style.left = `calc(${node.x}% - ${40}px)`;\n                    highlight.style.top = `calc(${node.y}% - ${40}px)`;\n                    highlight.style.background = `radial-gradient(circle, ${node.color.replace(')', ', 0.3)')}, ${node.color.replace(')', ', 0)')})`;\n                    \n                    graphContainer.appendChild(highlight);\n                    graphContainer.appendChild(nodeElement);\n                });\n                \n                // Render rankings\n                sortedNodes.forEach(node => {\n                    const rankItem = document.createElement('div');\n                    rankItem.classList.add('rank-item');\n                    rankItem.innerHTML = `\n                        <span>Page ${node.id}</span>\n                        <span class=\"rank-value\">${node.rank.toFixed(3)}</span>\n                    `;\n                    rankingsContainer.appendChild(rankItem);\n                });\n            }\n            \n            // Animate the PageRank calculation\n            function animatePageRank() {\n                // Simulate PageRank iterations\n                let iterations = 0;\n                const maxIterations = 10;\n                \n                const interval = setInterval(() => {\n                    if (iterations >= maxIterations) {\n                        clearInterval(interval);\n                        return;\n                    }\n                    \n                    // In a real implementation, we'd calculate actual PageRank\n                    // For visualization, we'll just animate the existing values\n                    \n                    // Highlight a random node to simulate computation\n                    const randomNode = nodes[Math.floor(Math.random() * nodes.length)];\n                    const highlight = document.createElement('div');\n                    highlight.classList.add('highlight', 'pulse');\n                    highlight.style.left = `calc(${randomNode.x}% - ${40}px)`;\n                    highlight.style.top = `calc(${randomNode.y}% - ${40}px)`;\n                    highlight.style.background = `radial-gradient(circle, ${randomNode.color.replace(')', ', 0.3)')}, ${randomNode.color.replace(')', ', 0)')})`;\n                    graphContainer.appendChild(highlight);\n                    \n                    // Remove highlight after animation\n                    setTimeout(() => {\n                        highlight.remove();\n                    }, 2000);\n                    \n                    iterations++;\n                }, 1000);\n            }\n            \n            // Initialize\n            renderGraph();\n            \n            // Start animation after a delay\n            setTimeout(() => {\n                animatePageRank();\n            }, 2000);\n            \n            // Reset button\n            document.getElementById('reset').addEventListener('click', () => {\n                renderGraph();\n                setTimeout(() => {\n                    animatePageRank();\n                }, 1000);\n            });\n        });\n    </script>\n</body>\n</html>"
