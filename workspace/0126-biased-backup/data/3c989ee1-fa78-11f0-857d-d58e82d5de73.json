    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Understanding Big-O Notation</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Code&display=swap');\n\n  /* Root Variables for Colors */\n  :root {\n    --bg-gradient1: #0f2027;\n    --bg-gradient2: #203a43;\n    --bg-gradient3: #2c5364;\n    --primary-color: #00ffd5;\n    --secondary-color: #ff4cdf;\n    --accent-color: #00ffe7;\n    --text-color-light: #e0f7fa;\n    --shadow-color: rgba(0, 255, 213, 0.3);\n    --font-primary: 'Poppins', sans-serif;\n    --font-mono: 'Fira Code', monospace;\n  }\n\n  /* Reset & base */\n  * {\n    margin: 0; padding: 0; box-sizing: border-box;\n  }\n  body {\n    min-height: 100vh;\n    background: linear-gradient(135deg, var(--bg-gradient1), var(--bg-gradient2), var(--bg-gradient3));\n    color: var(--text-color-light);\n    font-family: var(--font-primary);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 2rem 6rem 2rem;\n    user-select: none;\n  }\n\n  header {\n    text-align: center;\n    margin-bottom: 3rem;\n    max-width: 900px;\n  }\n  header h1 {\n    font-weight: 600;\n    font-size: 3.6rem;\n    background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    letter-spacing: 0.05em;\n    text-shadow: 0 8px 18px rgba(0,255,213,0.6);\n  }\n  header p {\n    font-weight: 300;\n    font-size: 1.3rem;\n    margin-top: 0.6rem;\n    color: #b8faf9dd;\n    max-width: 650px;\n    line-height: 1.6;\n  }\n\n  main {\n    position: relative;\n    max-width: 900px;\n    width: 100%;\n    display: grid;\n    grid-template-columns: 1.5fr 1fr;\n    gap: 3rem;\n  }\n\n  .chart-container {\n    position: relative;\n    background: rgba(0,255,213,0.05);\n    border-radius: 2rem;\n    box-shadow: 0 10px 30px var(--shadow-color);\n    padding: 2.5rem 3rem 3rem 3rem;\n    overflow: visible;\n  }\n\n  /* Axis */\n  svg.big-o-chart {\n    width: 100%;\n    height: 350px;\n    overflow: visible;\n    user-select: none;\n  }\n  .axis-line {\n    stroke: #11ffeeaa;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n  }\n  .axis-label {\n    fill: #00ffe7cc;\n    font-weight: 600;\n    font-size: 0.9rem;\n    font-family: var(--font-mono);\n  }\n  .tick-label {\n    fill: #00ffcbbb;\n    font-size: 0.8rem;\n    font-family: var(--font-mono);\n  }\n\n  /* Curves */\n  .curve {\n    fill: none;\n    stroke-width: 3.4;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 8px);\n    transition: stroke-width 0.4s ease, filter 0.4s ease;\n  }\n\n  .curve.O1 {\n    stroke: var(--primary-color);\n    filter: drop-shadow(0 0 18px var(--primary-color));\n  }\n  .curve.Ologn {\n    stroke: var(--secondary-color);\n    filter: drop-shadow(0 0 18px var(--secondary-color));\n  }\n  .curve.On {\n    stroke: #ffb800;\n    filter: drop-shadow(0 0 18px #ffb800);\n  }\n  .curve.Onlogn {\n    stroke: #ffaa00cc;\n    filter: drop-shadow(0 0 18px #ffaa00cc);\n  }\n  .curve.On2 {\n    stroke: #ff4c00;\n    filter: drop-shadow(0 0 18px #ff4c00);\n  }\n  .curve.O2n {\n    stroke: #ff0055cc;\n    filter: drop-shadow(0 0 18px #ff0055cc);\n  }\n\n  /* Curve Labels */\n  .label {\n    font-family: var(--font-mono);\n    font-weight: 700;\n    font-size: 1.05rem;\n    fill: #e0f7faee;\n    text-shadow:\n      0 0 10px rgba(0,255,213,0.9),\n      0 0 20px rgba(0,255,213,0.7);\n    pointer-events: none;\n    user-select: none;\n  }\n\n  /* Info Box */\n  .info-box {\n    background: rgba(0, 255, 213, 0.08);\n    border-radius: 1.5rem;\n    box-shadow: 0 10px 30px rgba(0,255,213,0.15);\n    padding: 2rem 2.5rem;\n    display: flex;\n    flex-direction: column;\n    gap: 2rem;\n    font-size: 1rem;\n    font-weight: 400;\n    color: #b8faf9cc;\n    line-height: 1.4;\n    font-family: var(--font-primary);\n  }\n\n  .info-box h2 {\n    font-size: 1.8rem;\n    font-weight: 600;\n    background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    margin-bottom: 0.8rem;\n  }\n\n  .info-box p {\n    font-weight: 300;\n  }\n\n  /* Buttons Container */\n  .buttons {\n    margin-top: 4rem;\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n  }\n  button {\n    font-family: var(--font-primary);\n    font-weight: 600;\n    font-size: 1.05rem;\n    padding: 0.8rem 2rem;\n    border-radius: 1.2rem;\n    border: none;\n    cursor: pointer;\n    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));\n    color: #0f2027;\n    box-shadow: 0 7px 15px rgba(0,255,213,0.4);\n    transition: background 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;\n    user-select: none;\n  }\n  button:hover {\n    background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));\n    color: #e0f7fa;\n    box-shadow: 0 12px 30px rgba(255,76,223,0.7);\n  }\n  button:focus {\n    outline: 2px solid var(--accent-color);\n    outline-offset: 3px;\n  }\n\n  /* Footer */\n  footer {\n    margin-top: 5rem;\n    font-family: var(--font-mono);\n    color: #00ffe788;\n    font-size: 0.9rem;\n    user-select: none;\n  }\n\n  /* Animated stroke dash for curves */\n  .curve.animate {\n    animation: drawCurve 2s ease forwards;\n  }\n  @keyframes drawCurve {\n    from {\n      stroke-dashoffset: 1000;\n    }\n    to {\n      stroke-dashoffset: 0;\n    }\n  }\n\n  /* Responsive */\n  @media(max-width:900px) {\n    main {\n      grid-template-columns: 1fr;\n    }\n    .chart-container {\n      margin-bottom: 3rem;\n    }\n  }\n</style>\n</head>\n<body>\n  <header>\n    <h1>Big-O Notation</h1>\n    <p>Visualizing algorithmic time complexities — how runtime grows relative to input size <span style=\"font-weight:600;\">n</span>. Observe the elegant curves depicting the performance of common complexity classes.</p>\n  </header>\n  <main>\n    <section class=\"chart-container\" aria-label=\"Big-O complexity graph\">\n      <svg class=\"big-o-chart\" viewBox=\"0 0 700 350\" aria-hidden=\"true\" role=\"img\" preserveAspectRatio=\"none\">\n        <!-- Axes -->\n        <line class=\"axis-line\" x1=\"50\" y1=\"300\" x2=\"650\" y2=\"300\" /> <!-- X axis -->\n        <line class=\"axis-line\" x1=\"50\" y1=\"300\" x2=\"50\" y2=\"50\" />   <!-- Y axis -->\n\n        <!-- Axis Labels -->\n        <text class=\"axis-label\" x=\"650\" y=\"318\" text-anchor=\"end\" dominant-baseline=\"hanging\">Input Size (n)</text>\n        <text class=\"axis-label\" x=\"30\" y=\"50\" text-anchor=\"end\" dominant-baseline=\"middle\" transform=\"rotate(-90 30,50)\">Time Complexity</text>\n\n        <!-- X Ticks -->\n        <text class=\"tick-label\" x=\"50\" y=\"320\" text-anchor=\"middle\">0</text>\n        <text class=\"tick-label\" x=\"150\" y=\"320\" text-anchor=\"middle\">50</text>\n        <text class=\"tick-label\" x=\"250\" y=\"320\" text-anchor=\"middle\">100</text>\n        <text class=\"tick-label\" x=\"350\" y=\"320\" text-anchor=\"middle\">150</text>\n        <text class=\"tick-label\" x=\"450\" y=\"320\" text-anchor=\"middle\">200</text>\n        <text class=\"tick-label\" x=\"550\" y=\"320\" text-anchor=\"middle\">250</text>\n        <text class=\"tick-label\" x=\"650\" y=\"320\" text-anchor=\"middle\">300</text>\n\n        <!-- Y Ticks -->\n        <text class=\"tick-label\" x=\"40\" y=\"300\" text-anchor=\"end\" dominant-baseline=\"middle\">0</text>\n        <text class=\"tick-label\" x=\"40\" y=\"250\" text-anchor=\"end\" dominant-baseline=\"middle\">20</text>\n        <text class=\"tick-label\" x=\"40\" y=\"200\" text-anchor=\"end\" dominant-baseline=\"middle\">40</text>\n        <text class=\"tick-label\" x=\"40\" y=\"150\" text-anchor=\"end\" dominant-baseline=\"middle\">60</text>\n        <text class=\"tick-label\" x=\"40\" y=\"100\" text-anchor=\"end\" dominant-baseline=\"middle\">80</text>\n        <text class=\"tick-label\" x=\"40\" y=\"50\" text-anchor=\"end\" dominant-baseline=\"middle\">100</text>\n\n        <!-- Curves -->\n        <!-- O(1) Constant -->\n        <path id=\"curve-O1\" class=\"curve O1\" d=\"M 50 250 L 650 250\" stroke-dasharray=\"600\" stroke-dashoffset=\"600\"/>\n\n        <!-- O(log n) -->\n        <path id=\"curve-Ologn\" class=\"curve Ologn\" d=\"M 50 280 \n          C 125 260, 200 230, 275 200\n          C 350 170, 425 140, 500 120\n          C 575 100, 650 85, 650 80\" stroke-dasharray=\"750\" stroke-dashoffset=\"750\"/>\n\n        <!-- O(n) Linear -->\n        <path id=\"curve-On\" class=\"curve On\" d=\"M 50 280 L 650 60\" stroke-dasharray=\"750\" stroke-dashoffset=\"750\"/>\n\n        <!-- O(n log n) -->\n        <path id=\"curve-Onlogn\" class=\"curve Onlogn\" d=\"M 50 280 \n          C 125 230, 200 190, 275 145\n          C 350 110, 425 70, 500 55\n          C 575 40, 650 20, 650 15\" stroke-dasharray=\"780\" stroke-dashoffset=\"780\"/>\n\n        <!-- O(n^2) Quadratic -->\n        <path id=\"curve-On2\" class=\"curve On2\" d=\"M 50 280 \n          Q 350 30 650 15\" stroke-dasharray=\"760\" stroke-dashoffset=\"760\"/>\n\n        <!-- O(2^n) Exponential -->\n        <path id=\"curve-O2n\" class=\"curve O2n\" d=\"M 50 279 \n          C 80 270, 110 230, 140 170\n          C 170 100, 200 50, 230 38\n          C 260 35, 290 30, 320 30\n          C 350 30, 380 35, 410 50\n          C 440 90, 470 140, 500 215\n          C 530 290, 560 350, 590 345\n          C 620 340, 650 300, 650 280\" stroke-dasharray=\"780\" stroke-dashoffset=\"780\" />\n\n        <!-- Curve Labels -->\n        <text class=\"label\" x=\"660\" y=\"255\" fill=\"var(--primary-color)\">O(1)</text>\n        <text class=\"label\" x=\"660\" y=\"75\" fill=\"var(--secondary-color)\">O(log n)</text>\n        <text class=\"label\" x=\"660\" y=\"57\" fill=\"#ffb800\">O(n)</text>\n        <text class=\"label\" x=\"660\" y=\"15\" fill=\"#ffaa00cc\">O(n log n)</text>\n        <text class=\"label\" x=\"660\" y=\"35\" fill=\"#ff4c00\">O(n²)</text>\n        <text class=\"label\" x=\"655\" y=\"290\" fill=\"#ff0055cc\" font-size=\"0.9rem\" >O(2ⁿ)</text>\n      </svg>\n    </section>\n    <section class=\"info-box\" aria-label=\"Information about Big-O notation complexities\">\n      <h2>Big-O Complexity Classes</h2>\n      <p><strong>O(1) - Constant Time</strong><br />\n      Execution time remains constant regardless of input size. Example: Accessing an element in an array.</p>\n      <p><strong>O(log n) - Logarithmic Time</strong><br />\n      Time grows logarithmically with input size. Example: Binary search in a sorted array.</p>\n      <p><strong>O(n) - Linear Time</strong><br />\n      Time grows linearly with input size. Example: Simple loops through data.</p>\n      <p><strong>O(n log n) - Linearithmic Time</strong><br />\n      Typical in efficient sorting algorithms like mergesort and heapsort.</p>\n      <p><strong>O(n²) - Quadratic Time</strong><br />\n      Time grows with the square of input size. Examples: Simple nested loops.</p>\n      <p><strong>O(2ⁿ) - Exponential Time</strong><br />\n      Time doubles with each element added. Examples: Recursive calculation of Fibonacci numbers naïvely.</p>\n    </section>\n  </main>\n\n  <div class=\"buttons\" aria-label=\"Controls\">\n    <button id=\"animateBtn\" aria-pressed=\"false\" aria-label=\"Animate Curves\">Animate Curves</button>\n  </div>\n\n  <footer>© 2024 · Big-O Notation Visualization</footer>\n\n<script>\n  (() => {\n    const animateBtn = document.getElementById('animateBtn');\n    const curves = Array.from(document.querySelectorAll('.curve'));\n    let isAnimating = false;\n\n    // Function to trigger stroke dash offset animation by toggling 'animate' class\n    function animateCurves() {\n      if (isAnimating) return; // Prevent repeated clicks during animation\n\n      isAnimating = true;\n      animateBtn.setAttribute('aria-pressed', 'true');\n      animateBtn.disabled = true;\n\n      curves.forEach(curve => {\n        // Reset to full dash offset before animating\n        const length = curve.getTotalLength ? curve.getTotalLength() : 600;\n        curve.style.strokeDasharray = length;\n        curve.style.strokeDashoffset = length;\n        // Trigger reflow\n        void curve.offsetWidth;\n        // Add animate class which triggers keyframe from offset=length to 0\n        curve.classList.add('animate');\n      });\n\n      // Remove animation after delay and re-enable button\n      setTimeout(() => {\n        curves.forEach(curve => {\n          curve.classList.remove('animate');\n          curve.style.strokeDashoffset = '0';\n        });\n        animateBtn.setAttribute('aria-pressed', 'false');\n        animateBtn.disabled = false;\n        isAnimating = false;\n      }, 2200);\n    }\n\n    animateBtn.addEventListener('click', animateCurves);\n\n    // Animate curves on page load once smoothly\n    window.addEventListener('load', () => {\n      // Delay initial animation slightly for subtle effect\n      setTimeout(() => animateCurves(), 500);\n    });\n  })();\n</script>\n</body>\n</html>"
