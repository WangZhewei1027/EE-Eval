    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Stack Visualization</title>\n    <style>\n        body {\n            font-family: Arial, margin: 0;\n            padding: 20px;\n            background: white;\n            color: black;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        .stack-container {\n            display: flex;\n            flex-direction: column-reverse;\n            align-items: center;\n            min-height: 300px;\n            border: 1px solid #000;\n            padding: 20px;\n        }\n        .stack-item {\n            width: 200px;\n            padding: 10px;\n            text-align: center;\n            border: 1px solid #000;\n            margin-bottom: 5px;\n            background: #f0f0f0;\n        }\n        .stack-top {\n            font-weight: bold;\n            background: #e0e0e0;\n        }\n        .status {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #000;\n        }\n        input, button, select {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Stack</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Stack Operations</h3>\n                <input type=\"text\" id=\"pushValue\" placeholder=\"Enter value to push\">\n                <button onclick=\"pushToStack()\">Push</button>\n                <button onclick=\"popFromStack()\">Pop</button>\n                <button onclick=\"peekStack()\">Peek</button>\n                <button onclick=\"clearStack()\">Clear Stack</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Stack Configuration</h3>\n                <label>Max Size: <input type=\"number\" id=\"maxSize\" min=\"1\" max=\"20\" value=\"10\"></label>\n                <button onclick=\"updateMaxSize()\">Update</button>\n                <div>\n                    <label><input type=\"checkbox\" id=\"autoResize\"> Allow overflow</label>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Stack Simulation</h3>\n                <button onclick=\"generateRandomStack()\">Generate Random Stack</button>\n                <label>Items: <input type=\"number\" id=\"randomCount\" min=\"1\" max=\"20\" value=\"5\"></label>\n                <div>\n                    <label>Operation Speed: \n                        <input type=\"range\" id=\"speed\" min=\"50\" max=\"1000\" value=\"300\">\n                    </label>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Stack Analysis</h3>\n                <button onclick=\"checkEmpty()\">Is Empty?</button>\n                <button onclick=\"checkFull()\">Is Full?</button>\n                <button onclick=\"getSize()\">Get Size</button>\n                <button onclick=\"searchStack()\">Search Value</button>\n                <input type=\"text\" id=\"searchValue\" placeholder=\"Value to search\">\n            </div>\n        </div>\n        \n        <div class=\"stack-container\" id=\"stackVisualization\">\n            <!-- Stack items will be added here dynamically -->\n            <div class=\"stack-message\">Stack is empty</div>\n        </div>\n        \n        <div class=\"status\" id=\"statusMessage\">\n            Ready. Stack operations will be shown here.\n        </div>\n        \n        <div class=\"control-group\">\n            <h3>Operation History</h3>\n            <select id=\"historyList\" size=\"5\" style=\"width: 100%;\"></select>\n            <button onclick=\"undoOperation()\">Undo Last Operation</button>\n            <button onclick=\"replayHistory()\">Replay All Operations</button>\n        </div>\n    </div>\n\n    <script>\n        let stack = [];\n        let maxSize = 10;\n        let operationHistory = [];\n        let operationSpeed = 300;\n        \n        document.getElementById('speed').addEventListener('input', function() {\n            operationSpeed = parseInt(this.value);\n        });\n        \n        function updateStackVisualization() {\n            const stackContainer = document.getElementById('stackVisualization');\n            stackContainer.innerHTML = '';\n            \n            if (stack.length === 0) {\n                stackContainer.innerHTML = '<div class=\"stack-message\">Stack is empty</div>';\n                return;\n            }\n            \n            // Create a copy and reverse to show top at the top\n            const reversedStack = [...stack].reverse();\n            \n            reversedStack.forEach((item, index) => {\n                const stackItem = document.createElement('div');\n                stackItem.className = 'stack-item';\n                if (index === 0) {\n                    stackItem.classList.add('stack-top');\n                }\n                stackItem.textContent = item;\n                stackContainer.appendChild(stackItem);\n            });\n        }\n        \n        function updateStatus(message) {\n            const statusElement = document.getElementById('statusMessage');\n            statusElement.textContent = message;\n            \n            // Add to history\n            const historyEntry = `${new Date().toLocaleTimeString()}: ${message}`;\n            operationHistory.push(historyEntry);\n            const historyList = document.getElementById('historyList');\n            const option = document.createElement('option');\n            option.textContent = historyEntry;\n            historyList.appendChild(option);\n            historyList.scrollTop = historyList.scrollHeight;\n        }\n        \n        function pushToStack() {\n            const value = document.getElementById('pushValue').value.trim();\n            if (!value) {\n                updateStatus('Error: Please enter a value to push');\n                return;\n            }\n            \n            const autoResize = document.getElementById('autoResize').checked;\n            \n            if (stack.length >= maxSize && !autoResize) {\n                updateStatus(`Error: Stack overflow (max size: ${maxSize})`);\n                return;\n            }\n            \n            if (stack.length >= maxSize && autoResize) {\n                maxSize = stack.length + 1;\n                document.getElementById('maxSize').value = maxSize;\n            }\n            \n            stack.push(value);\n            updateStackVisualization();\n            updateStatus(`Pushed \"${value}\" to stack. Size: ${stack.length}/${maxSize}`);\n            document.getElementById('pushValue').value = '';\n        }\n        \n        function popFromStack() {\n            if (stack.length === 0) {\n                updateStatus('Error: Stack underflow (stack is empty)');\n                return;\n            }\n            \n            const value = stack.pop();\n            updateStackVisualization();\n            updateStatus(`Popped \"${value}\" from stack. Size: ${stack.length}/${maxSize}`);\n        }\n        \n        function peekStack() {\n            if (stack.length === 0) {\n                updateStatus('Stack is empty - nothing to peek');\n                return;\n            }\n            \n            const value = stack[stack.length - 1];\n            updateStatus(`Top of stack: \"${value}\"`);\n            \n            // Highlight the top item briefly\n            const stackItems = document.querySelectorAll('.stack-item');\n            if (stackItems.length > 0) {\n                const originalClass = stackItems[0].className;\n                stackItems[0].className = originalClass + ' stack-top-highlight';\n                setTimeout(() => {\n                    stackItems[0].className = originalClass;\n                }, 1000);\n            }\n        }\n        \n        function clearStack() {\n            stack = [];\n            updateStackVisualization();\n            updateStatus('Stack cleared');\n        }\n        \n        function updateMaxSize() {\n            const newSize = parseInt(document.getElementById('maxSize').value);\n            if (isNaN(newSize) || newSize < 1) {\n                updateStatus('Error: Invalid max size');\n                return;\n            }\n            \n            if (newSize < stack.length) {\n                if (confirm(`Reducing stack size will remove ${stack.length - newSize} items. Continue?`)) {\n                    stack = stack.slice(0, newSize);\n                    updateStackVisualization();\n                } else {\n                    document.getElementById('maxSize').value = maxSize;\n                    return;\n                }\n            }\n            \n            maxSize = newSize;\n            updateStatus(`Stack max size updated to ${maxSize}`);\n        }\n        \n        function generateRandomStack() {\n            const count = parseInt(document.getElementById('randomCount').value);\n            if (isNaN(count) || count < 1) {\n                updateStatus('Error: Invalid item count');\n                return;\n            }\n            \n            const autoResize = document.getElementById('autoResize').checked;\n            if (count > maxSize && !autoResize) {\n                updateStatus(`Error: Requested ${count} items exceeds max size of ${maxSize}`);\n                return;\n            }\n            \n            if (count > maxSize && autoResize) {\n                maxSize = count;\n                document.getElementById('maxSize').value = maxSize;\n            }\n            \n            stack = [];\n            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';\n            for (let i = 0; i < count; i++) {\n                const randomValue = 'Item-' + Array.from({length: 4}, () => \n                    chars.charAt(Math.floor(Math.random() * chars.length))).join('');\n                stack.push(randomValue);\n            }\n            \n            updateStackVisualization();\n            updateStatus(`Generated random stack with ${count} items`);\n        }\n        \n        function checkEmpty() {\n            updateStatus(stack.length === 0 ? 'Stack is empty' : 'Stack is not empty');\n        }\n        \n        function checkFull() {\n            updateStatus(stack.length >= maxSize ? `Stack is full (${maxSize}/${maxSize})` : `Stack is not full (${stack.length}/${maxSize})`);\n        }\n        \n        function getSize() {\n            updateStatus(`Stack size: ${stack.length} items (max: ${maxSize})`);\n        }\n        \n        function searchStack() {\n            const value = document.getElementById('searchValue').value.trim();\n            if (!value) {\n                updateStatus('Error: Please enter a value to search');\n                return;\n            }\n            \n            const index = [];\n            for (let i = 0; i < stack.length; i++) {\n                if (stack[i] === value) {\n                    index.push(stack.length - i); // Show position from top\n                }\n            }\n            \n            if (index.length === 0) {\n                updateStatus(`\"${value}\" not found in stack`);\n            } else {\n                updateStatus(`\"${value}\" found at position(s) from top: ${index.join(', ')}`);\n            }\n        }\n        \n        function undoOperation() {\n            if (operationHistory.length === 0) {\n                updateStatus('No operations to undo');\n                return;\n            }\n            \n            // Simple undo - just pop the last item\n            if (stack.length > 0) {\n                stack.pop();\n                updateStackVisualization();\n                updateStatus('Undid last operation (removed top item)');\n            } else {\n                updateStatus('Cannot undo - stack is empty');\n            }\n        }\n        \n        function replayHistory() {\n            if (operationHistory.length === 0) {\n                updateStatus('No operations to replay');\n                return;\n            }\n            \n            updateStatus('Replaying all operations...');\n            stack = [];\n            updateStackVisualization();\n            \n            const history = [...operationHistory];\n            operationHistory = [];\n            document.getElementById('historyList').innerHTML = '';\n            \n            let delay = 0;\n            history.forEach((entry, index) => {\n                setTimeout(() => {\n                    // Simulate operations based on history\n                    if (entry.includes('Pushed')) {\n                        const value = entry.match(/\"([^\"]+)\"/)[1];\n                        stack.push(value);\n                        updateStackVisualization();\n                    } else if (entry.includes('Popped') && stack.length > 0) {\n                        stack.pop();\n                        updateStackVisualization();\n                    } else if (entry.includes('cleared')) {\n                        stack = [];\n                        updateStackVisualization();\n                    }\n                    \n                    // Add back to history\n                    operationHistory.push(entry);\n                    const historyList = document.getElementById('historyList');\n                    const option = document.createElement('option');\n                    option.textContent = entry;\n                    historyList.appendChild(option);\n                    historyList.scrollTop = historyList.scrollHeight;\n                    \n                    if (index === history.length - 1) {\n                        updateStatus('Replay complete');\n                    }\n                }, delay);\n                \n                delay += operationSpeed;\n            });\n        }\n        \n        // Initialize\n        updateStackVisualization();\n    </script>\n</body>\n</html>"
  },
