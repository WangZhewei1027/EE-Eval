    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Hash Functions — Concept Visualized</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');\n\n  /* Root variables for color scheme */\n  :root {\n    --bg-gradient-start: #0f2027;\n    --bg-gradient-mid: #203a43;\n    --bg-gradient-end: #2c5364;\n    --primary-color: #6ce3f4;\n    --secondary-color: #f4a261;\n    --accent-color: #ff6f61;\n    --text-color-light: #f0f3f5;\n    --text-color-dark: #222831;\n    --shadow-glow: rgba(108, 227, 244, 0.8);\n    --shadow-accent: rgba(255, 111, 97, 0.7);\n  }\n\n  /* Global styles */\n  html, body {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, var(--bg-gradient-start), var(--bg-gradient-mid), var(--bg-gradient-end));\n    font-family: 'Poppins', sans-serif;\n    color: var(--text-color-light);\n    overflow-x: hidden;\n  }\n\n  body {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 2rem;\n  }\n\n  main {\n    max-width: 1100px;\n    width: 100%;\n    background: rgba(255 255 255 / 0.06);\n    border-radius: 24px;\n    box-shadow:\n      0 0 16px 2px rgba(0,0,0,0.25),\n      0 8px 40px -8px var(--shadow-glow);\n    padding: 3rem 3.5rem 4rem;\n    user-select: none;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 3.6rem;\n    line-height: 1.1;\n    letter-spacing: -0.02em;\n    margin-bottom: 0.5rem;\n    text-align: center;\n    color: var(--primary-color);\n    text-shadow: 0 0 10px var(--shadow-glow);\n  }\n\n  h2.subtitle {\n    font-weight: 400;\n    font-size: 1.3rem;\n    text-align: center;\n    margin-bottom: 3rem;\n    font-style: italic;\n    color: #a6cfdc;\n    letter-spacing: 0.05em;\n  }\n\n  /* Illustration container */\n  .visualization {\n    position: relative;\n    width: 100%;\n    height: 400px;\n    margin-bottom: 3rem;\n    user-select: none;\n  }\n\n  /* Hash function block */\n  .hash-block {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 240px;\n    height: 240px;\n    background:\n      linear-gradient(135deg, #1e3c72, #2a5298);\n    border-radius: 32px;\n    transform: translate(-50%, -50%);\n    box-shadow:\n      0 0 36px 12px rgba(44,83,100,0.6),\n      inset 0 0 14px 4px #50c8f8;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    color: var(--text-color-light);\n    font-weight: 600;\n    font-size: 1.25rem;\n    text-align: center;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    filter: drop-shadow(0 0 4px var(--primary-color));\n    user-select: none;\n  }\n\n  .hash-block span {\n    display: block;\n    margin-top: 12px;\n    font-size: 0.88rem;\n    font-weight: 400;\n    color: #cce9ff;\n    letter-spacing: 0.12em;\n    text-transform: none;\n    user-select: none;\n  }\n\n  /* Animation: block slight subtle breathe glow */\n  @keyframes breathe {\n    0%, 100% {\n      box-shadow:\n        0 0 36px 12px rgba(44,83,100,0.6),\n        inset 0 0 14px 4px #50c8f8;\n    }\n    50% {\n      box-shadow:\n        0 0 48px 16px rgba(76,174,237,0.8),\n        inset 0 0 22px 6px #90d4fb;\n    }\n  }\n  .hash-block {\n    animation: breathe 4.8s ease-in-out infinite;\n  }\n\n  /* Input blocks container */\n  .inputs {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    display: flex;\n    gap: 64px;\n    user-select: none;\n  }\n\n  .inputs.left {\n    left: 5%;\n  }\n  .inputs.right {\n    right: 5%;\n    flex-direction: column;\n  }\n\n  /* Each input block */\n  .input-block {\n    background: linear-gradient(145deg, #203445, #162730);\n    border-radius: 20px;\n    width: 150px;\n    height: 90px;\n    box-shadow:\n      0 0 12px 1px rgba(25,47,68,0.8),\n      inset 0 0 15px 3px #3fa0f9,\n      0 4px 12px -3px rgba(0,0,0,0.8);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #8ecdf7;\n    font-weight: 500;\n    font-size: 1.1rem;\n    letter-spacing: 0.1em;\n    text-align: center;\n    user-select: none;\n    filter: drop-shadow(0 0 5px #3fa0f9aa);\n  }\n\n  /* Hash output block */\n  .output-block {\n    background: linear-gradient(145deg, #2a3647, #1b2734);\n    border-radius: 20px;\n    width: 180px;\n    height: 110px;\n    box-shadow:\n      0 0 15px 3px rgba(244,162,97,0.8),\n      inset 0 0 18px 5px #f9b15c,\n      0 5px 12px -2px rgba(0,0,0,0.9);\n    margin-top: 32px;\n    color: #f4c28a;\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.14em;\n    line-height: 1.2;\n    user-select: none;\n    filter: drop-shadow(0 0 7px #f9b15cbb);\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding: 0.85rem 1.2rem;\n  }\n\n  .output-title {\n    font-size: 0.88rem;\n    font-weight: 400;\n    color: #f8e9d2cc;\n    letter-spacing: 0.1em;\n    margin-bottom: 8px;\n    text-align: center;\n    text-transform: uppercase;\n  }\n\n  /* Connecting lines with SVG */\n  .connections {\n    position: absolute;\n    top: 0; left: 0; width: 100%; height: 100%;\n    pointer-events: none;\n    user-select: none;\n  }\n\n  /* Controls below */\n  .controls {\n    text-align: center;\n    margin-top: 1.5rem;\n  }\n  button {\n    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));\n    border: none;\n    color: var(--text-color-dark);\n    font-weight: 600;\n    font-size: 1.1rem;\n    letter-spacing: 0.05em;\n    padding: 14px 28px;\n    border-radius: 36px;\n    cursor: pointer;\n    box-shadow: 0 8px 14px -4px var(--shadow-glow);\n    transition: all 0.35s ease;\n    user-select: none;\n  }\n  button:hover, button:focus {\n    background: linear-gradient(135deg, var(--secondary-color), var(--accent-color));\n    box-shadow:\n      0 0 14px 4px var(--shadow-accent),\n      0 10px 24px 2px var(--shadow-accent);\n    outline: none;\n  }\n\n  /* Text section below visualization */\n  .description {\n    max-width: 720px;\n    margin: 0 auto;\n    margin-top: 3rem;\n    font-weight: 400;\n    line-height: 1.6;\n    color: #dbe9f4cc;\n    font-size: 1.05rem;\n    letter-spacing: 0.02em;\n  }\n  .description b {\n    color: var(--secondary-color);\n  }\n\n  /* Subtle floating animation for input blocks */\n  @keyframes floatVertical {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-6px); }\n  }\n\n  .inputs.left .input-block {\n    animation: floatVertical 6s ease-in-out infinite;\n  }\n  .inputs.right .input-block:not(:last-child) {\n    animation: floatVertical 5.5s ease-in-out infinite;\n  }\n\n  /* Hash output pulses */\n  @keyframes pulseGlow {\n    0%, 100% {\n      box-shadow:\n        0 0 15px 3px rgba(244,162,97,0.8),\n        inset 0 0 18px 5px #f9b15c;\n    }\n    50% {\n      box-shadow:\n        0 0 32px 6px rgba(255,190,110,1),\n        inset 0 0 26px 7px #ffd987;\n    }\n  }\n  .output-block {\n    animation: pulseGlow 5.5s ease-in-out infinite;\n  }\n\n  /* Scrollbar hidden */\n  ::-webkit-scrollbar {\n    display: none;\n  }\n  ::-moz-scrollbar {\n    display: none;\n  }\n  ::-ms-scrollbar {\n    display: none;\n  }\n\n</style>\n</head>\n<body>\n<main role=\"main\" aria-label=\"Hash Functions Concept Visualization\">\n  <h1>HASH FUNCTIONS</h1>\n  <h2 class=\"subtitle\">Mapping data to fixed-length fingerprints</h2>\n\n  <div class=\"visualization\" aria-hidden=\"true\">\n    <!-- Inputs Left -->\n    <div class=\"inputs left\">\n      <div class=\"input-block\" style=\"user-select:none;\">Input Data 1</div>\n      <div class=\"input-block\" style=\"margin-top: 32px;\">Input Data 2</div>\n      <div class=\"input-block\" style=\"margin-top: 32px;\">Input Data 3</div>\n    </div>\n\n    <!-- Hash Function Block -->\n    <div class=\"hash-block\" aria-label=\"Hash Function block\">\n      HASH FUNCTION\n      <span>Fixed Length Output</span>\n    </div>\n\n    <!-- Output Right -->\n    <div class=\"inputs right\">\n      <div class=\"output-block\" id=\"hashOutput\" aria-live=\"polite\">\n        <div class=\"output-title\">Hash Output</div>\n        <code id=\"hashText\">--</code>\n      </div>\n    </div>\n\n    <!-- SVG Connections -->\n    <svg class=\"connections\" width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\" >\n      <!-- lines from inputs left to hash block -->\n      <line x1=\"140\" y1=\"90\" x2=\"400\" y2=\"200\" stroke=\"#6ce3f4\" stroke-width=\"2\" stroke-linecap=\"round\" opacity=\"0.5\" />\n      <line x1=\"140\" y1=\"180\" x2=\"400\" y2=\"200\" stroke=\"#6ce3f4\" stroke-width=\"2\" stroke-linecap=\"round\" opacity=\"0.5\" />\n      <line x1=\"140\" y1=\"270\" x2=\"400\" y2=\"200\" stroke=\"#6ce3f4\" stroke-width=\"2\" stroke-linecap=\"round\" opacity=\"0.5\" />\n\n      <!-- line from hash block to output right -->\n      <line x1=\"520\" y1=\"200\" x2=\"860\" y2=\"115\" stroke=\"#f4a261\" stroke-width=\"3\" stroke-linecap=\"round\" opacity=\"0.7\" />\n    </svg>\n  </div>\n\n  <div class=\"controls\" role=\"region\" aria-label=\"Controls\">\n    <button id=\"generateHash\" title=\"Generate a new hash output\">Generate Hash</button>\n  </div>\n\n  <section class=\"description\">\n    <p>\n      A <b>hash function</b> takes <b>input data</b> of arbitrary size and produces a unique, fixed-length <b>hash output</b>, also known as a <i>message digest</i> or fingerprint.\n      This process is <i>deterministic</i>, so the same input always produces the same output, but a tiny change in input leads to a drastically different hash.\n    </p>\n    <p>\n      Hash functions are foundational in <b>data integrity</b>, <b>cryptography</b>, and <b>computer science</b>. They enable quick data comparisons, password storage, digital signatures, and blockchain security.\n    </p>\n  </section>\n</main>\n\n<script>\n  (() => {\n    const outputEl = document.getElementById('hashText');\n    const generateBtn = document.getElementById('generateHash');\n\n    // Predefined example hashes simulating typical hash outputs (SHA-256 style)\n    const exampleHashes = [\n      'e3b0c442 98fc1c14 9afbf4c8 996fb924 27ae41e4 649b934c a495991b 7852b855',\n      'cf83e135 7eefb8bd f1542850 d66d8007 d620e405 0b5715dc 83f4a921 d36ce9ce',\n      'a3f5b1c8 d1ab729e 7f2ec1ca 0beed6a7 17924e0f 576b1ea7 3424cfb2 5a8e9fab',\n      '9c1185a5 c5e9fc54 0dfe19d5 5ae8e6ee 844e1f6d 6d5f3c20 7c406c8b 1a1bb8a2',\n      'da39a3ee 5e6b4b0d 3255bfef 95601890 afd80709 3c6bd33e 5b3f8e30 45c97d63',\n      '2d711642 b726b044 01627ca9 f7c467da ee1616da ed3a5b5c 87e51eac 8f2d9470',\n      '45c48cce 2e2d7fbf af5b0d29 5c4b6c73 7b5a6e52 6ead53d5 67de786e 1c04a78b',\n    ];\n\n    // Animate hash text reveal by typing effect\n    function animateHashText(hash) {\n      outputEl.textContent = '';\n      let index = 0;\n      const cleaned = hash.replace(/\\s+/g, '');\n      const spacedHash = hash;\n\n      let displayed = '';\n\n      function step() {\n        if(index < spacedHash.length) {\n          displayed += spacedHash[index];\n          outputEl.textContent = displayed;\n          index++;\n          setTimeout(step, 40 + Math.random() * 30);\n        }\n      }\n      step();\n    }\n\n    generateBtn.addEventListener('click', () => {\n      // Pick a random example hash\n      const randomHash = exampleHashes[Math.floor(Math.random() * exampleHashes.length)];\n      animateHashText(randomHash);\n    });\n\n    // On load animate one hash initially\n    window.addEventListener('load', () => {\n      const initialHash = exampleHashes[0];\n      animateHashText(initialHash);\n    });\n  })();\n</script>\n</body>\n</html>"
