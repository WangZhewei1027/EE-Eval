  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>B-Tree Index Interactive Demo</title>\n<style>\n  /* Extremely minimal styling: just ensure monospace font for code-like display */\n  body {\n    font-family: monospace, monospace;\n  }\n  button, input, select {\n    font-family: monospace;\n  }\n  #tree-display {\n    white-space: pre;\n    border: 1px solid black;\n    padding: 4px;\n    min-height: 200px;\n    max-height: 400px;\n    overflow: auto;\n  }\n  #log {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    padding: 4px;\n    min-height: 80px;\n    max-height: 150px;\n    overflow: auto;\n  }\n</style>\n</head>\n<body>\n<h1>B-Tree Index Interactive Demo</h1>\n\n<p>\n<b>Concept:</b> A B-Tree is a balanced tree data structure optimized for systems that read and write large blocks of data. It maintains sorted data and allows searches, sequential access, insertions, and deletions in logarithmic time.\n</p>\n\n<p>Use the controls below to build, modify, and explore a B-Tree Index. The current degree can be set. Keys are integers only.</p>\n\n<label for=\"degree-input\">Degree (minimum degree t ≥ 2): </label>\n<input type=\"number\" id=\"degree-input\" min=\"2\" value=\"3\" />\n<button id=\"init-tree\">Initialize New Empty B-Tree</button>\n\n<hr />\n\n<h2>Insert Keys</h2>\n<label for=\"insert-key\">Key to insert:</label>\n<input type=\"number\" id=\"insert-key\" />\n<button id=\"insert-btn\">Insert Key</button>\n\n<h2>Delete Keys</h2>\n<label for=\"delete-key\">Key to delete:</label>\n<input type=\"number\" id=\"delete-key\" />\n<button id=\"delete-btn\">Delete Key</button>\n\n<h2>Search Keys</h2>\n<label for=\"search-key\">Key to search:</label>\n<input type=\"number\" id=\"search-key\" />\n<button id=\"search-btn\">Search</button>\n\n<h2>Tree Visualization and Info</h2>\n<label for=\"display-mode\">Display mode:</label>\n<select id=\"display-mode\">\n  <option value=\"tree\">Indented Tree</option>\n  <option value=\"list\">All keys in-order (sorted list)</option>\n  <option value=\"paths\">All Root-to-Leaf Paths</option>\n</select>\n<button id=\"refresh-display\">Refresh Display</button>\n<div id=\"tree-display\" tabindex=\"0\" aria-label=\"B-Tree visualization area\"></div>\n\n<h2>Advanced Operations and Controls</h2>\n\n<label for=\"bulk-keys\">Bulk Insert (comma-separated integers):</label><br />\n<input type=\"text\" id=\"bulk-keys\" style=\"width:98%\" />\n<button id=\"bulk-insert-btn\">Bulk Insert</button>\n\n<button id=\"clear-tree\">Clear Tree</button>\n\n<h3>Statistics and Analysis</h3>\n<button id=\"tree-stats-btn\">Show Tree Statistics</button>\n<div id=\"stats-display\" style=\"white-space: pre-wrap; border:1px solid black; padding:4px; min-height:50px; max-height:150px; overflow:auto;\"></div>\n\n<h3>Step-By-Step Walkthrough</h3>\n<p>\nYou can perform step-by-step insertion simulation. Enter keys, then advance one step at a time to see node splits and changes.\n</p>\n\n<label for=\"step-keys\">Keys for Step Insert (comma-separated):</label><br />\n<input type=\"text\" id=\"step-keys\" style=\"width:98%\" />\n<button id=\"step-start-btn\">Start Step-By-Step Insert</button>\n<button id=\"step-next-btn\" disabled>Next Step</button>\n<button id=\"step-reset-btn\" disabled>Reset Step Insert</button>\n<div id=\"step-instructions\" style=\"white-space: pre-wrap; border:1px solid black; padding:4px; min-height:70px; max-height:100px; overflow:auto;\"></div>\n\n<hr />\n\n<h3>Raw B-Tree Data Access</h3>\n<button id=\"download-json\">Download Tree Data (JSON)</button>\n<button id=\"load-json-btn\">Load Tree Data (Paste JSON below)</button><br />\n<textarea id=\"json-input\" rows=\"8\" style=\"width:98%;\"></textarea>\n<button id=\"load-json-confirm-btn\" disabled>Load JSON Tree</button>\n\n<hr />\n\n<h3>Log (Operation History)</h3>\n<div id=\"log\" tabindex=\"0\" aria-label=\"Operation log\"></div>\n<button id=\"clear-log-btn\">Clear Log</button>\n\n<script>\n(function() {\n  // --- B-Tree Implementation based on minimum degree t ---\n  // A B-Tree node\n  function BTreeNode(t, leaf = false) {\n    this.t = t;            // Minimum degree\n    this.keys = [];        // Array of keys\n    this.children = [];    // Array of child pointers\n    this.leaf = leaf;      // Is true when node is leaf\n  }\n\n  BTreeNode.prototype.findKeyIndex = function(k) {\n    // Find the first key >= k\n    let idx = 0;\n    while (idx < this.keys.length && this.keys[idx] < k) idx++;\n    return idx;\n  };\n\n  BTreeNode.prototype.traverseIndent = function(level=0, lines=[]) {\n    // Display node keys + recursive children with indentation\n    let prefix = '  '.repeat(level);\n    let line = prefix + \"[\";\n    line += this.keys.join(' ');\n    line += \"]\";\n    lines.push(line);\n    for (let i = 0; i < this.children.length; i++) {\n      this.children[i].traverseIndent(level+1, lines);\n    }\n    return lines;\n  };\n\n  BTreeNode.prototype.traverseInOrder = function(arr=[]) {\n    // Inorder traversal\n    for (let i = 0; i < this.keys.length; i++) {\n      if (!this.leaf) this.children[i].traverseInOrder(arr);\n      arr.push(this.keys[i]);\n    }\n    if (!this.leaf) this.children[this.keys.length].traverseInOrder(arr);\n    return arr;\n  };\n\n  BTreeNode.prototype.traversePaths = function(currentPath=[], allPaths=[]) {\n    // Return all root to leaf paths as arrays of keys per node\n    let path = currentPath.slice();\n    path.push(this.keys.slice());\n    if(this.leaf) {\n      allPaths.push(path);\n    } else {\n      for(let i=0; i < this.children.length; i++) {\n        this.children[i].traversePaths(path, allPaths);\n      }\n    }\n    return allPaths;\n  };\n\n  // Search key k in subtree rooted with this node\n  BTreeNode.prototype.search = function(k) {\n    let i = 0;\n    while (i < this.keys.length && k > this.keys[i]) i++;\n\n    if (i < this.keys.length && this.keys[i] === k) {\n      return {node: this, index: i};\n    }\n\n    if (this.leaf) {\n      return null;\n    }\n\n    return this.children[i].search(k);\n  };\n\n  // Insert a key in a non-full node (assumes node is non-full)\n  BTreeNode.prototype.insertNonFull = function(k, logFn = ()=>{}) {\n    let i = this.keys.length - 1;\n\n    if (this.leaf) {\n      // Insert into leaf node in sorted order\n      while (i >=0 && this.keys[i] > k) i--;\n      if (this.keys[i] === k) {\n        logFn(`Warning: key ${k} already exists; ignoring duplicate insert.`);\n        return false;\n      }\n      this.keys.splice(i+1, 0, k);\n      logFn(`Inserted key ${k} in leaf node.`);\n      return true;\n    } else {\n      // Find child that will receive the key\n      while (i >=0 && this.keys[i] > k) i--;\n      i++;\n      // Check if child full\n      if (this.children[i].keys.length === 2*this.t -1) {\n        logFn(`Child ${i} full; need to split before insertion.`);\n        this.splitChild(i, logFn);\n        if (this.keys[i] < k) i++;\n      }\n      return this.children[i].insertNonFull(k, logFn);\n    }\n  };\n\n  // Split the child y of this node at index i.\n  BTreeNode.prototype.splitChild = function(i, logFn = ()=>{}) {\n    let t = this.t;\n    let y = this.children[i];\n    let z = new BTreeNode(t, y.leaf);\n\n    // z gets t-1 keys from y\n    z.keys = y.keys.splice(t);\n    if (!y.leaf) {\n      z.children = y.children.splice(t);\n    }\n\n    this.children.splice(i+1, 0, z);\n    let middleKey = y.keys.splice(t-1,1)[0];\n    this.keys.splice(i, 0, middleKey);\n\n    logFn(`Split child index ${i}. Promoted key ${middleKey}.`);\n  };\n\n  // Remove a key from the subtree rooted with this node\n  // Returns true if key removed, false if not found\n  BTreeNode.prototype.remove = function(k, logFn = ()=>{}) {\n    let idx = this.findKeyIndex(k);\n\n    if (idx < this.keys.length && this.keys[idx] === k) {\n      // Case 1: key is in this node (internal or leaf)\n      if (this.leaf) {\n        this.keys.splice(idx,1);\n        logFn(`Removed key ${k} from leaf node.`);\n        return true;\n      } else {\n        logFn(`Remove key ${k} from internal node - complex case.`);\n        return this.removeFromInternalNode(idx, logFn);\n      }\n    } else {\n      // Key not in this node\n      if (this.leaf) {\n        logFn(`Key ${k} not found in leaf node.`);\n        return false;\n      }\n\n      // Flag to know if key exists in subtree or not\n      let flag = (idx === this.keys.length);\n\n      if (this.children[idx].keys.length < this.t) {\n        this.fill(idx, logFn);\n      }\n\n      if (flag && idx > this.keys.length) {\n        return this.children[idx-1].remove(k, logFn);\n      } else {\n        return this.children[idx].remove(k, logFn);\n      }\n    }\n  };\n\n  // Remove key from internal node at idx\n  BTreeNode.prototype.removeFromInternalNode = function(idx, logFn = ()=>{}) {\n    let k = this.keys[idx];\n\n    if (this.children[idx].keys.length >= this.t) {\n      let pred = this.getPredecessor(idx);\n      this.keys[idx] = pred;\n      this.children[idx].remove(pred, logFn);\n      logFn(`Replaced key ${k} with predecessor ${pred}.`);\n      return true;\n    } else if (this.children[idx+1].keys.length >= this.t) {\n      let succ = this.getSuccessor(idx);\n      this.keys[idx] = succ;\n      this.children[idx+1].remove(succ, logFn);\n      logFn(`Replaced key ${k} with successor ${succ}.`);\n      return true;\n    } else {\n      this.merge(idx, logFn);\n      this.children[idx].remove(k, logFn);\n      logFn(`Merged children around key ${k} and removed key recursively.`);\n      return true;\n    }\n  };\n\n  BTreeNode.prototype.getPredecessor = function(idx) {\n    let cur = this.children[idx];\n    while (!cur.leaf) cur = cur.children[cur.keys.length];\n    return cur.keys[cur.keys.length -1];\n  };\n\n  BTreeNode.prototype.getSuccessor = function(idx) {\n    let cur = this.children[idx+1];\n    while (!cur.leaf) cur = cur.children[0];\n    return cur.keys[0];\n  };\n\n  BTreeNode.prototype.fill = function(idx, logFn = ()=>{}) {\n    if (idx !==0 && this.children[idx-1].keys.length >= this.t) {\n      this.borrowFromPrev(idx, logFn);\n    } else if (idx !== this.keys.length && this.children[idx+1].keys.length >= this.t) {\n      this.borrowFromNext(idx, logFn);\n    } else {\n      if (idx !== this.keys.length) {\n        this.merge(idx, logFn);\n      } else {\n        this.merge(idx-1, logFn);\n      }\n    }\n  };\n\n  BTreeNode.prototype.borrowFromPrev = function(idx, logFn = ()=>{}) {\n    let child = this.children[idx];\n    let sibling = this.children[idx-1];\n\n    child.keys.unshift(this.keys[idx-1]);\n    if (!child.leaf) {\n      child.children.unshift(sibling.children.pop());\n    }\n    this.keys[idx-1] = sibling.keys.pop();\n    logFn(`Borrowed key from previous sibling for child ${idx}.`);\n  };\n\n  BTreeNode.prototype.borrowFromNext = function(idx, logFn = ()=>{}) {\n    let child = this.children[idx];\n    let sibling = this.children[idx+1];\n\n    child.keys.push(this.keys[idx]);\n    if (!child.leaf) {\n      child.children.push(sibling.children.shift());\n    }\n    this.keys[idx] = sibling.keys.shift();\n    logFn(`Borrowed key from next sibling for child ${idx}.`);\n  };\n\n  BTreeNode.prototype.merge = function(idx, logFn = ()=>{}) {\n    let child = this.children[idx];\n    let sibling = this.children[idx+1];\n\n    child.keys.push(this.keys[idx]);\n    for (let k of sibling.keys) child.keys.push(k);\n    if (!child.leaf) {\n      for (let c of sibling.children) child.children.push(c);\n    }\n    this.keys.splice(idx, 1);\n    this.children.splice(idx+1, 1);\n    logFn(`Merged child ${idx} with sibling ${idx+1}.`);\n  };\n\n  // B-Tree main class\n  function BTree(t) {\n    this.t = t;\n    this.root = new BTreeNode(t, true);\n  }\n\n  BTree.prototype.search = function(k) {\n    if (!this.root) return null;\n    return this.root.search(k);\n  };\n\n  BTree.prototype.insert = function(k, logFn = ()=>{}) {\n    if (this.root.keys.length === 2*this.t -1) {\n      let s = new BTreeNode(this.t, false);\n      s.children.push(this.root);\n      this.root = s;\n      logFn(\"Root full, created new root and split.\");\n      s.splitChild(0, logFn);\n      return s.insertNonFull(k, logFn);\n    } else {\n      return this.root.insertNonFull(k, logFn);\n    }\n  };\n\n  BTree.prototype.remove = function(k, logFn = ()=>{}) {\n    if (!this.root) {\n      logFn(\"The tree is empty.\");\n      return false;\n    }\n    let res = this.root.remove(k, logFn);\n    if (this.root.keys.length === 0) {\n      if (this.root.leaf) {\n        this.root = null;\n        logFn(\"Tree is now empty after removal.\");\n      } else {\n        this.root = this.root.children[0];\n        logFn(\"Changed root after removal.\");\n      }\n    }\n    return res;\n  };\n\n  BTree.prototype.traverseIndent = function() {\n    if (!this.root) return [\"(empty tree)\"];\n    return this.root.traverseIndent();\n  };\n\n  BTree.prototype.traverseInOrder = function() {\n    if (!this.root) return [];\n    return this.root.traverseInOrder();\n  };\n\n  BTree.prototype.traversePaths = function() {\n    if (!this.root) return [];\n    return this.root.traversePaths();\n  };\n\n  BTree.prototype.size = function() {\n    function countKeys(node) {\n      if (!node) return 0;\n      let sum = node.keys.length;\n      for (let c of node.children) sum += countKeys(c);\n      return sum;\n    }\n    return countKeys(this.root);\n  };\n\n  BTree.prototype.height = function() {\n    function nodeHeight(node) {\n      if (!node) return 0;\n      if (node.leaf) return 1;\n      return 1 + nodeHeight(node.children[0]);\n    }\n    return nodeHeight(this.root);\n  };\n\n  // Expose BTree for use inside closure\n  let btree = null;\n  let logDiv = document.getElementById(\"log\");\n  function log(...args) {\n    let msg = args.join(' ');\n    let d = new Date();\n    let ts = d.toLocaleTimeString();\n    logDiv.textContent += `[${ts}] ${msg}\\n`;\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n  function clearLog() {\n    logDiv.textContent = \"\";\n  }\n\n  function validateDegreeInput() {\n    let degInput = document.getElementById(\"degree-input\");\n    let val = parseInt(degInput.value);\n    if (isNaN(val) || val < 2) {\n      alert(\"Degree t must be an integer ≥ 2\");\n      return null;\n    }\n    return val;\n  }\n\n  function refreshTreeDisplay() {\n    if (!btree) {\n      document.getElementById(\"tree-display\").textContent = \"(no tree initialized)\";\n      return;\n    }\n    let mode = document.getElementById(\"display-mode\").value;\n    let out = \"\";\n    if (mode === \"tree\") {\n      out = btree.traverseIndent().join(\"\\n\");\n    } else if (mode === \"list\") {\n      out = btree.traverseInOrder().join(\", \");\n      if (out === \"\") out = \"(tree empty)\";\n    } else if (mode === \"paths\") {\n      let paths = btree.traversePaths();\n      if (paths.length === 0) {\n        out = \"(tree empty)\";\n      } else {\n        // Show all root to leaf paths: one per line, nodes keys separated by \" -> \"\n        // Each node displayed as [k1 k2 k3]\n        out = \"\";\n        for (let i=0;i<paths.length;i++) {\n          let p = paths[i].map(nodeKeys => \"[\" + nodeKeys.join(\" \") + \"]\").join(\" -> \");\n          out += `Path ${i+1}: ${p}\\n`;\n        }\n      }\n    }\n    document.getElementById(\"tree-display\").textContent = out;\n  }\n\n  // Clear the entire tree and reset\n  function clearTree() {\n    btree = null;\n    document.getElementById(\"tree-display\").textContent = \"(no tree initialized)\";\n    document.getElementById(\"stats-display\").textContent = \"\";\n    clearLog();\n    disableStepInsertControls(true);\n  }\n\n  // Show statistics\n  function showStats() {\n    if (!btree) {\n      document.getElementById(\"stats-display\").textContent = \"(no tree initialized)\";\n      return;\n    }\n    let n = btree.size();\n    let h = btree.height();\n    let maxKeys = Math.pow(2*btree.t-1, h);\n    let s = `Tree statistics:\\n`;\n    s += `Minimum degree (t): ${btree.t}\\n`;\n    s += `Height: ${h}\\n`;\n    s += `Number of keys stored: ${n}\\n`;\n    s += `Max keys possible at height: ${maxKeys}\\n`;\n    s += `Root keys count: ${btree.root ? btree.root.keys.length : 0}\\n`;\n    document.getElementById(\"stats-display\").textContent = s;\n  }\n\n  // Bulk insert keys: parse string as comma separated integers\n  function bulkInsertKeys(str) {\n    if (!btree) {\n      alert(\"Initialize the B-Tree first.\");\n      return;\n    }\n    if (!str.trim()) {\n      alert(\"Input is empty\");\n      return;\n    }\n    let parts = str.split(\",\");\n    let inserted = 0;\n    for(let p of parts) {\n      let k = parseInt(p.trim());\n      if (!isNaN(k)) {\n        if (btree.insert(k, log)) inserted++;\n      } else {\n        log(`Skipping invalid input: \"${p.trim()}\"`);\n      }\n    }\n    log(`Bulk inserted ${inserted} keys.`);\n    refreshTreeDisplay();\n  }\n\n  // Step-by-step insertion controls\n  let stepKeysBuffer = [];\n  let stepIndex = 0;\n  let stepBTree = null;\n  let stepLogLines = [];\n  let stepInProgress = false;\n  const stepInstructionsDiv = document.getElementById(\"step-instructions\");\n  // Deep copy function for BTree - for resetting step insert\n  // Since structure is dynamic, and for simplicity, we rebuild a fresh BTree for steps\n\n  function disableStepInsertControls(disable) {\n    document.getElementById(\"step-next-btn\").disabled = disable;\n    document.getElementById(\"step-reset-btn\").disabled = disable;\n  }\n\n  // Step insert: Insert one key at a time, with logs\n  function stepStart() {\n    if (stepInProgress) {\n      alert(\"Step insert already in progress. Reset first.\");\n      return;\n    }\n    let str = document.getElementById(\"step-keys\").value;\n    if (!str.trim()) {\n      alert(\"Enter keys to insert for step-by-step.\");\n      return;\n    }\n    let parts = str.split(\",\");\n    stepKeysBuffer = [];\n    for(let p of parts) {\n      let k = parseInt(p.trim());\n      if (isNaN(k)) {\n        alert(`Invalid integer in input: \"${p.trim()}\"`);\n        return;\n      }\n      stepKeysBuffer.push(k);\n    }\n    if(stepKeysBuffer.length === 0) {\n      alert(\"No valid keys to insert.\");\n      return;\n    }\n    let t = validateDegreeInput();\n    if (t === null) return;\n    stepBTree = new BTree(t);\n    stepIndex = 0;\n    stepLogLines = [];\n    stepInProgress = true;\n    document.getElementById(\"tree-display\").textContent = \"(empty tree)\";\n    stepInstructionsDiv.textContent = \"Step-by-step insertion started.\\nPress 'Next Step' to insert the first key.\";\n    disableStepInsertControls(false);\n  }\n\n  // Step insert next key\n  function stepNext() {\n    if (!stepInProgress) {\n      alert(\"No step insertion in progress.\");\n      return;\n    }\n    if (stepIndex >= stepKeysBuffer.length) {\n      stepInstructionsDiv.textContent += \"\\nAll keys inserted.\";\n      disableStepInsertControls(true);\n      stepInProgress = false;\n      // Update the global btree to the step btree after completion\n      btree = stepBTree;\n      refreshTreeDisplay();\n      log(\"Step-by-step insert finished; tree updated.\");\n      return;\n    }\n\n    let key = stepKeysBuffer[stepIndex];\n    stepLogLines.length = 0;\n    function stepLog(s) {\n      stepLogLines.push(s);\n    }\n    stepLog(`Inserting key ${key}...`);\n    stepBTree.insert(key, stepLog);\n\n    // Display tree under current step\n    let visual = stepBTree.traverseIndent().join(\"\\n\");\n\n    document.getElementById(\"tree-display\").textContent = visual;\n    stepInstructionsDiv.textContent = stepLogLines.join(\"\\n\") + `\\n\\nInserted ${stepIndex+1} / ${stepKeysBuffer.length} keys.`;\n\n    stepIndex++;\n  }\n\n  // Reset step insertion session\n  function stepReset() {\n    stepBTree = null;\n    stepKeysBuffer = [];\n    stepIndex = 0;\n    stepLogLines = [];\n    stepInProgress = false;\n    stepInstructionsDiv.textContent = \"Step-by-step insertion reset.\";\n    document.getElementById(\"tree-display\").textContent = \"(no tree initialized)\";\n    disableStepInsertControls(true);\n  }\n\n  // JSON download and load tree\n  function downloadJSON() {\n    if (!btree) {\n      alert(\"Initialize the tree first.\");\n      return;\n    }\n    // Simple serialization function\n    function serializeNode(node) {\n      if (!node) return null;\n      return {\n        t: node.t,\n        keys: node.keys,\n        leaf: node.leaf,\n        children: node.children.map(serializeNode)\n      };\n    }\n    let data = {\n      t: btree.t,\n      root: serializeNode(btree.root)\n    };\n    let jsonStr = JSON.stringify(data, null, 2);\n    let blob = new Blob([jsonStr], {type: \"application/json\"});\n    let url = URL.createObjectURL(blob);\n    let a = document.createElement(\"a\");\n    a.href = url;\n    a.download = \"btree.json\";\n    a.click();\n    URL.revokeObjectURL(url);\n  }\n\n  function enableLoadJSONBtn() {\n    let txt = document.getElementById(\"json-input\").value.trim();\n    document.getElementById(\"load-json-confirm-btn\").disabled = (txt.length===0);\n  }\n\n  function loadJSONTree() {\n    let txt = document.getElementById(\"json-input\").value.trim();\n    if (txt.length === 0) {\n      alert(\"No JSON data provided\");\n      return;\n    }\n    let obj = null;\n    try {\n      obj = JSON.parse(txt);\n    } catch(e) {\n      alert(\"Invalid JSON: \" + e.message);\n      return;\n    }\n    if (!obj.t || !obj.root) {\n      alert(\"Invalid B-Tree JSON data; missing 't' or 'root'\");\n      return;\n    }\n    function deserializeNode(data) {\n      if (!data) return null;\n      let node = new BTreeNode(data.t, data.leaf);\n      node.keys = data.keys;\n      node.children = [];\n      if (!data.leaf) {\n        for (let c of data.children) {\n          node.children.push(deserializeNode(c));\n        }\n      }\n      return node;\n    }\n    btree = new BTree(obj.t);\n    btree.root = deserializeNode(obj.root);\n    log(\"Loaded B-Tree from JSON input.\");\n    refreshTreeDisplay();\n    showStats();\n  }\n\n  // Event Listeners and Initialization\n\n  document.getElementById(\"init-tree\").addEventListener(\"click\", function() {\n    let t = validateDegreeInput();\n    if (t === null) return;\n    btree = new BTree(t);\n    document.getElementById(\"tree-display\").textContent = \"(empty tree)\";\n    document.getElementById(\"stats-display\").textContent = \"\";\n    log(`Initialized new empty B-Tree with degree t=${t}`);\n    disableStepInsertControls(true);\n  });\n\n  document.getElementById(\"insert-btn\").addEventListener(\"click\", function() {\n    if (!btree) {\n      alert(\"Initialize the B-Tree first.\");\n      return;\n    }\n    let val = parseInt(document.getElementById(\"insert-key\").value);\n    if (isNaN(val)) {\n      alert(\"Enter a valid integer key to insert.\");\n      return;\n    }\n    if (btree.insert(val, log)) {\n      log(`Inserted key ${val} successfully.`);\n    } else {\n      log(`Failed to insert key ${val}. Possibly duplicate.`);\n    }\n    refreshTreeDisplay();\n  });\n\n  document.getElementById(\"delete-btn\").addEventListener(\"click\", function() {\n    if (!btree) {\n      alert(\"Initialize the B-Tree first.\");\n      return;\n    }\n    let val = parseInt(document.getElementById(\"delete-key\").value);\n    if (isNaN(val)) {\n      alert(\"Enter a valid integer key to delete.\");\n      return;\n    }\n    if (btree.remove(val, log)) {\n      log(`Deleted key ${val} successfully.`);\n    } else {\n      log(`Key ${val} not found in tree.`);\n    }\n    refreshTreeDisplay();\n  });\n\n  document.getElementById(\"search-btn\").addEventListener(\"click\", function() {\n    if (!btree) 