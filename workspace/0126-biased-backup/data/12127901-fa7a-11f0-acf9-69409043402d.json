  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Circular Linked List Interactive Demo</title>\n<style>\n  body {\n    background: white;\n    color: black;\n    font-family: monospace, monospace;\n    margin: 1em;\n  }\n  input, button, select {\n    font-family: monospace;\n    font-size: 1em;\n  }\n  #listDisplay {\n    white-space: pre-wrap;\n    font-family: monospace;\n  }\n  fieldset {\n    margin-top: 1em;\n    padding: 0.5em;\n  }\n  legend {\n    font-weight: bold;\n  }\n</style>\n</head>\n<body>\n<h1>Circular Linked List Interactive Demo</h1>\n\n<p>\n  This tool allows you to create and manipulate a circular linked list with rich interaction:\n  insertion, deletion, traversal, searching, and exploring internal pointer logic.\n</p>\n\n<!-- Controls to create the list -->\n<fieldset>\n  <legend>Create / Reset Circular Linked List</legend>\n  <label for=\"initialNodes\">Number of nodes to create initially (0 - 20): </label>\n  <input type=\"number\" id=\"initialNodes\" value=\"0\" min=\"0\" max=\"20\" />\n  <button id=\"createListBtn\">Create Empty / Reset</button>\n  <br />\n  <small>Nodes created will have values 1, 2, 3, ... by default.</small>\n</fieldset>\n\n<!-- Controls for inserting -->\n<fieldset>\n  <legend>Insert Node</legend>\n  <label for=\"insertValue\">New Node Value: </label>\n  <input type=\"text\" id=\"insertValue\" maxlength=\"10\" />\n  <br />\n\n  <label for=\"insertPosition\">Insert position (index): </label>\n  <input type=\"number\" id=\"insertPosition\" value=\"0\" min=\"0\" />\n  <small>(0 = head, max = length)</small>\n  <br />\n  <label>Where to insert relative to position?</label><br />\n  <input type=\"radio\" id=\"before\" name=\"insertRel\" value=\"before\" checked />\n  <label for=\"before\">Before</label>\n  <input type=\"radio\" id=\"after\" name=\"insertRel\" value=\"after\" />\n  <label for=\"after\">After</label>\n  <br />\n  <button id=\"insertBtn\">Insert Node</button>\n</fieldset>\n\n<!-- Controls for deleting -->\n<fieldset>\n  <legend>Delete Node</legend>\n  <label for=\"deletePosition\">Delete node at position (index): </label>\n  <input type=\"number\" id=\"deletePosition\" value=\"0\" min=\"0\" />\n  <small>(0 = head)</small>\n  <br />\n  <button id=\"deleteBtn\">Delete Node</button>\n  <br />\n  <label for=\"deleteValue\">OR delete first node with value: </label>\n  <input type=\"text\" id=\"deleteValue\" maxlength=\"10\" />\n  <button id=\"deleteValueBtn\">Delete by Value</button>\n</fieldset>\n\n<!-- Controls for traversal -->\n<fieldset>\n  <legend>Traversal & Cursor Control</legend>\n  <p>\n    Current Traversal Cursor position: <span id=\"cursorPosDisplay\">N/A</span>\n  </p>\n  <button id=\"moveNextBtn\">Move Cursor Next</button>\n  <button id=\"movePrevBtn\">Move Cursor Prev</button>\n  <button id=\"resetCursorBtn\">Reset Cursor to Head</button>\n  <br /><br />\n  <label for=\"cursorSteps\">Move cursor steps: </label>\n  <input type=\"number\" id=\"cursorSteps\" value=\"1\" min=\"1\" max=\"100\" />\n  <button id=\"moveCursorStepsBtn\">Move Forward Steps</button>\n  <button id=\"moveCursorBackStepsBtn\">Move Backward Steps</button>\n  <br />\n  <button id=\"showCursorNodeBtn\">Show Current Node Value</button>\n  <div id=\"cursorNodeValue\" aria-live=\"polite\"></div>\n</fieldset>\n\n<!-- Controls for searching -->\n<fieldset>\n  <legend>Search for Value</legend>\n  <label for=\"searchValue\">Value to search: </label>\n  <input type=\"text\" id=\"searchValue\" maxlength=\"10\" />\n  <button id=\"searchBtn\">Search</button>\n  <div id=\"searchResult\" aria-live=\"polite\"></div>\n</fieldset>\n\n<!-- Controls for advanced exploration -->\n<fieldset>\n  <legend>Advanced Exploration</legend>\n  <button id=\"showInternalLinksBtn\">Show Raw Links of Nodes</button>\n  <button id=\"showFullStructureBtn\">Show Full List Details</button>\n  <button id=\"reverseListBtn\">Reverse list (pointer directions)</button>\n  <button id=\"rotateListBtn\">Rotate list by N steps</button>\n  <input type=\"number\" id=\"rotateSteps\" value=\"1\" min=\"1\" max=\"100\" />\n  <br /><br />\n  <button id=\"breakLoopBtn\">Break Circular Link (make linear)</button>\n  <button id=\"restoreLoopBtn\">Restore Circular Link (if broken)</button>\n</fieldset>\n\n<!-- Display area -->\n<h2>List and Output</h2>\n<pre id=\"listDisplay\" tabindex=\"0\" aria-label=\"Circular linked list visualization and outputs\">\n[No list created yet]\n</pre>\n\n<script>\n(function() {\n  // Node constructor for circular linked list nodes\n  function Node(value) {\n    this.value = value;\n    this.next = null;\n    this.prev = null; // for bidirectional traversal & reversal\n  }\n\n  // Circular Linked List data structure with deep operations\n  function CircularLinkedList() {\n    this.head = null;\n    this.length = 0;\n    this.cursor = null; // pointer for traversal\n\n    this.isCircular = true; // flag to handle loop broken or not\n  }\n\n  CircularLinkedList.prototype._indexCheck = function(i) {\n    if (typeof i !== \"number\" || i < 0 || i >= this.length) return false;\n    return true;\n  };\n\n  CircularLinkedList.prototype.createList = function(n) {\n    // Reset list\n    this.head = null;\n    this.length = 0;\n    this.cursor = null;\n    this.isCircular = true;\n    if (!Number.isInteger(n) || n < 0) {\n      return;\n    }\n    if (n === 0) {\n      return;\n    }\n    // Create n nodes with default values 1..n\n    var prevNode = null;\n    for (var i = 1; i <= n; i++) {\n      var node = new Node(String(i));\n      if (!this.head) {\n        this.head = node;\n      }\n      if (prevNode) {\n        prevNode.next = node;\n        node.prev = prevNode;\n      }\n      prevNode = node;\n      this.length++;\n    }\n    // Close the loop\n    this.head.prev = prevNode;\n    prevNode.next = this.head;\n    this.cursor = this.head;\n  };\n\n  CircularLinkedList.prototype.toArray = function() {\n    var arr = [];\n    if (this.length === 0 || !this.head) return arr;\n    var cur = this.head;\n    var count = 0;\n    while (count < this.length) {\n      arr.push(cur.value);\n      cur = cur.next;\n      count++;\n    }\n    return arr;\n  };\n\n  CircularLinkedList.prototype.display = function() {\n    if (this.length === 0) return \"[Empty list]\";\n    var arr = this.toArray();\n    return arr.join(\" -> \") + \" -> [back to head]\";\n  };\n\n  CircularLinkedList.prototype._getNodeAt = function(index) {\n    // Returns node at index, or null if invalid index\n    if (!this._indexCheck(index)) return null;\n    var cur = this.head;\n    var i = 0;\n    while (i < index) {\n      cur = cur.next;\n      i++;\n    }\n    return cur;\n  };\n\n  CircularLinkedList.prototype.insertAt = function(index, value, beforeAfter) {\n    // Inserts a new node with value before or after position index\n    // beforeAfter: 'before' or 'after'\n    if (typeof value !== \"string\" || value.length === 0) {\n      return { success: false, msg: \"Value must be a non-empty string\" };\n    }\n    if (!this.isCircular && this.length === 0) {\n      // Just add as single node and keep non-circular version\n      var newNode = new Node(value);\n      this.head = newNode;\n      this.length = 1;\n      this.cursor = newNode;\n      return { success: true };\n    }\n\n    if (this.length === 0) {\n      // Insert into empty - becomes head and circular to self\n      var node = new Node(value);\n      node.next = node;\n      node.prev = node;\n      this.head = node;\n      this.length = 1;\n      this.cursor = node;\n      this.isCircular = true;\n      return { success: true };\n    }\n\n    // Validate index in range 0..length-1 or if index==length and insert after or before accordingly\n    if (index < 0) index = 0;\n    if (index > this.length) index = this.length;\n\n    // If index == length, interpret it as at tail position accordingly\n    if(index === this.length){\n      // index beyond current last: special case insert at end\n      if(beforeAfter === \"before\") {\n        // inserting before index==length means after last node == tail\n        index = this.length - 1;\n        beforeAfter = \"after\";\n      } else {\n        // inserting after index==length means after \"nonexistent\", treat as insert at head (index=0, before)\n        index = 0;\n        beforeAfter = \"before\";\n      }\n    }\n\n    var targetNode = this._getNodeAt(index);\n    if (!targetNode) {\n      return { success: false, msg: \"Invalid index for insertion\" };\n    }\n    var newNode = new Node(value);\n    if (beforeAfter === \"before\") {\n      // Insert before targetNode\n      var prevNode = targetNode.prev;\n\n      // Link newNode with neighbors\n      newNode.next = targetNode;\n      newNode.prev = prevNode;\n\n      prevNode.next = newNode;\n      targetNode.prev = newNode;\n\n      // If inserting before head, update head pointer\n      if (targetNode === this.head) {\n        this.head = newNode;\n      }\n      this.length++;\n      return { success: true };\n    } else if (beforeAfter === \"after\") {\n      // Insert after targetNode\n      var nextNode = targetNode.next;\n\n      newNode.prev = targetNode;\n      newNode.next = nextNode;\n\n      targetNode.next = newNode;\n      nextNode.prev = newNode;\n      this.length++;\n      return { success: true };\n    } else {\n      return { success: false, msg: \"Invalid beforeAfter parameter\" };\n    }\n  };\n\n  CircularLinkedList.prototype.deleteAt = function(index) {\n    // Deletes node at index\n    if (!this._indexCheck(index)) {\n      return { success: false, msg: \"Invalid index\" };\n    }\n    if (this.length === 0) {\n      return { success: false, msg: \"List empty\" };\n    }\n\n    // If only 1 node, remove it all\n    if (this.length === 1) {\n      this.head = null;\n      this.length = 0;\n      this.cursor = null;\n      return { success: true };\n    }\n\n    var nodeToDelete = this._getNodeAt(index);\n    var prevNode = nodeToDelete.prev;\n    var nextNode = nodeToDelete.next;\n\n    // Relink neighbors\n    prevNode.next = nextNode;\n    nextNode.prev = prevNode;\n\n    // Update head if needed\n    if (nodeToDelete === this.head) {\n      this.head = nextNode;\n    }\n\n    // Adjust cursor if points to deleted node\n    if (this.cursor === nodeToDelete) {\n      this.cursor = nextNode;\n    }\n\n    this.length--;\n\n    if (this.length === 0) {\n      this.head = null;\n      this.cursor = null;\n    }\n\n    return { success: true };\n  };\n\n  CircularLinkedList.prototype.deleteByValue = function(value) {\n    if (this.length === 0) {\n      return { success: false, msg: \"List empty\" };\n    }\n    var cur = this.head;\n    var count = 0;\n    while(count < this.length) {\n      if (cur.value === value) {\n        var idx = count;\n        return this.deleteAt(idx);\n      }\n      cur = cur.next;\n      count++;\n    }\n    return { success: false, msg: \"Value not found\" };\n  };\n\n  CircularLinkedList.prototype.moveCursorNext = function(steps) {\n    if (!this.cursor) return false;\n    if (!steps || steps < 1) steps = 1;\n    for (var i=0; i<steps; i++){\n      if (this.cursor.next) {\n        this.cursor = this.cursor.next;\n      } else if (!this.isCircular){\n        // If not circular and at end, stop moving\n        break;\n      }\n    }\n    return true;\n  };\n\n  CircularLinkedList.prototype.moveCursorPrev = function(steps) {\n    if (!this.cursor) return false;\n    if (!steps || steps < 1) steps = 1;\n    for (var i=0; i<steps; i++){\n      if (this.cursor.prev) {\n        this.cursor = this.cursor.prev;\n      } else if (!this.isCircular){\n        break;\n      }\n    }\n    return true;\n  };\n\n  CircularLinkedList.prototype.resetCursor = function() {\n    this.cursor = this.head;\n  };\n\n  CircularLinkedList.prototype.getCursorValue = function() {\n    return this.cursor ? this.cursor.value : null;\n  };\n\n  CircularLinkedList.prototype.searchValue = function(value) {\n    if (this.length === 0) return { found: false };\n    var cur = this.head;\n    var count = 0;\n    while(count < this.length) {\n      if (cur.value === value) {\n        return { found: true, position: count, node: cur };\n      }\n      cur = cur.next;\n      count++;\n    }\n    return { found: false };\n  };\n\n  CircularLinkedList.prototype.getLinksRaw = function() {\n    if (this.length === 0) return \"[Empty list]\";\n    var arr = [];\n    var count = 0;\n    var cur = this.head;\n    while(count < this.length) {\n      arr.push(\"Node #\" + count + \": value='\" + cur.value +\n        \"', prev: '\" + (cur.prev ? cur.prev.value : \"null\") +\n        \"', next: '\" + (cur.next ? cur.next.value : \"null\") + \"'\");\n      cur = cur.next;\n      count++;\n    }\n    return arr.join(\"\\n\");\n  };\n\n  CircularLinkedList.prototype.getFullStructure = function() {\n    // For each node show value, prev value, next value, and indexes, cursor position noted\n    if (this.length === 0) return \"[Empty list]\";\n    var arr = [];\n    var cur = this.head;\n    for (var i=0; i<this.length; i++) {\n      var prevVal = cur.prev ? cur.prev.value : \"null\";\n      var nextVal = cur.next ? cur.next.value : \"null\";\n      var cursorMark = (cur === this.cursor) ? \" <== Cursor here\" : \"\";\n      arr.push(\n        \"Node #\" + i + \":\\n  value = '\" + cur.value + \"'\\n  prev value = '\" + prevVal +\n        \"'\\n  next value = '\" + nextVal + \"'\" + cursorMark);\n      cur = cur.next;\n    }\n    arr.push(\"Head node value = '\" + this.head.value + \"'\");\n    arr.push(\"List length = \" + this.length);\n    arr.push(\"Is circular loop: \" + (this.isCircular ? \"Yes\" : \"No\"));\n    return arr.join(\"\\n\\n\");\n  };\n\n  CircularLinkedList.prototype.reverseList = function() {\n    if (this.length <= 1) return; // nothing to do\n    // Reverse the next and prev links of every node\n    var cur = this.head;\n    var count = 0;\n    while(count < this.length) {\n      var temp = cur.next;\n      cur.next = cur.prev;\n      cur.prev = temp;\n      cur = temp;\n      count++;\n    }\n    // Update head to old tail\n    this.head = this.head.prev;\n    // Cursor moves to new head for clarity\n    this.cursor = this.head;\n  };\n\n  CircularLinkedList.prototype.rotateList = function(steps) {\n    // Rotates list head & cursor forward by steps (mod length)\n    if (this.length <= 1) return;\n    if (!steps || isNaN(steps)) return;\n    steps = steps % this.length;\n    if (steps < 0) steps += this.length;\n    var cur = this.head;\n    for (var i=0; i<steps; i++) {\n      cur = cur.next;\n    }\n    this.head = cur;\n    this.cursor = this.head;\n  };\n\n  CircularLinkedList.prototype.breakLoop = function() {\n    // Turns circular list into linear by breaking last.next and first.prev\n    if (!this.isCircular) return false;\n    if (this.length === 0) return false;\n    if (this.length === 1) {\n      this.head.next = null;\n      this.head.prev = null;\n      this.isCircular = false;\n      return true;\n    }\n    var tail = this.head.prev;\n    tail.next = null;\n    this.head.prev = null;\n    this.isCircular = false;\n    return true;\n  };\n\n  CircularLinkedList.prototype.restoreLoop = function() {\n    // Restore circular loop if broken\n    if (this.isCircular) return false;\n    if (this.length === 0) return false;\n    if (this.length === 1) {\n      this.head.next = this.head;\n      this.head.prev = this.head;\n      this.isCircular = true;\n      return true;\n    }\n    var tail = this.head;\n    while(tail.next !== null) {\n      tail = tail.next;\n    }\n    // Connect tail and head\n    tail.next = this.head;\n    this.head.prev = tail;\n    this.isCircular = true;\n    return true;\n  };\n\n  // === UI and interactions ===\n  var list = new CircularLinkedList();\n\n  var displayEl = document.getElementById('listDisplay');\n  var cursorPosDisplay = document.getElementById('cursorPosDisplay');\n  var cursorNodeValue = document.getElementById('cursorNodeValue');\n  var searchResult = document.getElementById('searchResult');\n\n  function updateCursorPos() {\n    if (!list.cursor) {\n      cursorPosDisplay.textContent = \"N/A\";\n      return;\n    }\n    // Find cursor index\n    var idx = 0;\n    var cur = list.head;\n    for (idx=0; idx<list.length; idx++) {\n      if (cur === list.cursor) break;\n      cur = cur.next;\n    }\n    if (idx === list.length) idx = -1;\n    cursorPosDisplay.textContent = (idx !== -1) ? idx : \"N/A\";\n  }\n\n  function renderList() {\n    var disp = \"\";\n    if (list.length === 0) disp = \"[Empty list]\";\n    else disp = list.display();\n    displayEl.textContent = disp;\n    updateCursorPos();\n  }\n\n  // Create / Reset button\n  document.getElementById('createListBtn').addEventListener('click', function(){\n    var n = parseInt(document.getElementById('initialNodes').value, 10);\n    if (isNaN(n) || n < 0 || n > 20) {\n      alert(\"Please enter a number 0 to 20 for initial nodes.\");\n      return;\n    }\n    list.createList(n);\n    cursorNodeValue.textContent = \"\";\n    searchResult.textContent = \"\";\n    renderList();\n  });\n\n  // Insert button\n  document.getElementById('insertBtn').addEventListener('click', function(){\n    var val = document.getElementById('insertValue').value.trim();\n    var pos = parseInt(document.getElementById('insertPosition').value, 10);\n    var beforeAfter = document.querySelector('input[name=\"insertRel\"]:checked').value;\n\n    if(val.length === 0){\n      alert(\"Enter a value to insert.\");\n      return;\n    }\n    if(isNaN(pos) || pos < 0 || pos > list.length){\n      alert(\"Insert position must be between 0 and \" + list.length);\n      return;\n    }\n\n    var result = list.insertAt(pos, val, beforeAfter);\n\n    if (!result.success) {\n      alert(\"Insert failed: \" + result.msg);\n    } else {\n      document.getElementById('insertValue').value = \"\";\n      document.getElementById('insertPosition').value = \"0\";\n      cursorNodeValue.textContent = \"\";\n      searchResult.textContent = \"\";\n      renderList();\n    }\n  });\n\n  // Delete position button\n  document.getElementById('deleteBtn').addEventListener('click', function(){\n    var pos = parseInt(document.getElementById('deletePosition').value, 10);\n    if(isNaN(pos) || pos < 0 || pos >= list.length){\n      alert(\"Delete position must be between 0 and \" + (list.length-1));\n      return;\n    }\n    var result = list.deleteAt(pos);\n    if (!result.success) {\n      alert(\"Delete failed: \" + result.msg);\n    } else {\n      cursorNodeValue.textContent = \"\";\n      searchResult.textContent = \"\";\n      renderList();\n    }\n  });\n\n  // Delete by value button\n  document.getElementById('deleteValueBtn').addEventListener('click', function(){\n    var val = document.getElementById('deleteValue').value.trim();\n    if(val.length === 0){\n      alert(\"Enter a value to delete by.\");\n      return;\n    }\n    var result = list.deleteByValue(val);\n    if (!result.success) {\n      alert(\"Delete by value failed: \" + result.msg);\n    } else {\n      document.getElementById('deleteValue').value = \"\";\n      cursorNodeValue.textContent = \"\";\n      searchResult.textContent = \"\";\n      renderList();\n    }\n  });\n\n  // Move cursor next\n  document.getElementById('moveNextBtn').addEventListener('click', function(){\n    if (!list.cursor) {\n      alert(\"Cursor not set. Create or reset list first.\");\n      return;\n    }\n    list.moveCursorNext(1);\n    cursorNodeValue.textContent = \"\";\n    renderList();\n  });\n\n  // Move cursor prev\n  document.getElementById('movePrevBtn').addEventListener('click', function(){\n    if (!list.cursor) {\n      alert(\"Cursor not set. Create or reset list first.\");\n      return;\n    }\n    list.moveCursorPrev(1);\n    cursorNodeValue.textContent = \"\";\n    renderList();\n  });\n\n  // Reset cursor to head\n  document.getElementById('resetCursorBtn').addEventListener('click', function(){\n    if (!list.head) {\n      alert(\"List empty.\");\n      return;\n    }\n    list.resetCursor();\n    cursorNodeValue.textContent = \"\";\n    renderList();\n  });\n\n  // Move cursor forward steps\n  document.getElementById('moveCursorStepsBtn').addEventListener('click', function(){\n    if (!list.cursor) {\n      alert(\"Cursor not set. Create or reset list first.\");\n      return;\n    }\n    var steps = parseInt(document.getElementById('cursorSteps').value, 10);\n    if (isNaN(steps) || steps < 1 || steps > 100) {\n      alert(\"Steps must be 1 to 100\");\n      return;\n    }\n    list.moveCursorNext(steps);\n    cursorNodeValue.textContent = \"\";\n    renderList();\n  });\n\n  // Move cursor backward steps\n  document.getElementById('moveCursorBackStepsBtn').addEventListener('click', function(){\n    if (!list.cursor) {\n      alert(\"Cursor not set. Create or reset list first.\");\n      return;\n    }\n    var steps = parseInt(document.getElementById('cursorSteps').value, 10);\n    if (isNaN(steps) || steps < 1 || steps > 100) {\n      alert(\"Steps must be 1 to 100\");\n      return;\n    }\n    list.moveCursorPrev(steps);\n    cursorNodeValue.textContent = \"\";\n    renderList();\n  });\n\n  // Show current cursor node value\n  document.getElementById('showCursorNodeBtn').addEventListener('click', function(){\n    var val = list.getCursorValue();\n    if (val === null) {\n      cursorNodeValue.textContent = \"Cursor not set or list empty.\";\n    } else {\n      cursorNodeValue.textContent = \"Cursor node value: '\" + val + \"'\";\n    }\n  });\n\n  // Search value\n  document.getElementById('searchBtn').addEventListener('click', function(){\n    var val = document.getElementById('searchValue').value.trim();\n    if(val.length === 0) {\n      alert(\"Enter a value to search.\");\n      return;\n    }\n    var res = list.searchValue(val);\n    if (!res.found) {\n      searchResult.textContent = \"Value '\" + val + \"' not found in list.\";\n    } else {\n      searchResult.textContent = \"Value '\" + val + \"' found at position \" + res.position + \".\";\n    }\n  });\n\n  // Show raw links\n  document.getElementById('showInternalLinksBtn').addEventListener('click', function(){\n    var txt = list.getLinksRaw();\n    displayEl.textContent = txt;\n  });\n\n  // Show full structure\n  document.getElementById('showFullStructureBtn').addEventListener('click', function(){\n    var txt = list.getFullStructure();\n    displayEl.textContent = txt;\n  });\n\n  // Reverse list\n  document.getElementById('reverseListBtn').addEventListener('click', function(){\n    if (list.length === 0) {\n      alert(\"Empty list to reverse.\");\n      return;\n    }\n    list.reverseList();\n    cursorNodeValue.textContent = \"\";\n    searchResult.textContent = \"\";\n    renderList();\n  });\n\n  // Rotate list by N steps\n  document.getElementById('rotateListBtn').addEventListener('click', function(){\n    if (list.length === 0) {\n      alert(\"Empty list to rotate.\");\n      return;\n    }\n    var steps = parseInt(document.getElementById('rotateSteps').value, 10);\n    if (isNaN(steps) || steps < 1 || steps > 100) {\n      alert(\"Rotate steps must be 1 to 100\");\n      return;\n    }\n    list.rotateList(steps);\n    cursorNodeValue.textContent = \"\";\n    searchResult.textContent = \"\";\n    renderList();\n  });\n\n  // Break circular loop\n  document.getElementById('breakLoopBtn').addEventListener('click', function(){\n    if (!list.head || list.length === 0){\n      alert(\"Empty list.\");\n      return;\n    }\n    if (!list.isCircular) {\n      alert(\"Loop already broken.\");\n      return;\n    }\n    list.breakLoop();\n    cursorNodeValue.textContent = \"\";\n    searchResult.textContent = \"\";\n    renderList();\n  });\n\n  // Restore circular loop\n  document.getElementById('restoreLoopBtn').addEventListener('click', function(){\n    if (!list.head || list.length === 0){\n      alert(\"Empty list.\");\n      return;\n    }\n    if (list.isCircular) {\n      alert(\"List already circular.\");\n      return;\n    }\n    list.restoreLoop();\n    cursorNodeValue.textContent = \"\";\n    searchResult.textContent = \"\";\n    renderList();\n  });\n\n  // Set initial empty display\n  renderList();\n})();\n</script>\n</body>\n</html>"
  },
