    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Random Forest Visualization</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Playfair+Display:wght@400;700&display=swap');\n        \n        :root {\n            --primary: #2c3e50;\n            --secondary: #3498db;\n            --accent: #e74c3c;\n            --light: #ecf0f1;\n            --dark: #1a252f;\n            --shadow: 0 15px 30px rgba(0,0,0,0.1);\n            --transition: all 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            opacity: 0;\n            transform: translateY(-20px);\n            animation: fadeIn 1s 0.3s forwards;\n        }\n        \n        h1 {\n            font-family: 'Playfair Display', serif;\n            font-size: 3.5rem;\n            font-weight: 700;\n            color: var(--primary);\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--primary);\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualization {\n            background: white;\n            border-radius: 15px;\n            box-shadow: var(--shadow);\n            padding: 2rem;\n            margin-bottom: 3rem;\n            position: relative;\n            overflow: hidden;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s 0.6s forwards;\n        }\n        \n        .forest-container {\n            display: flex;\n            flex-wrap: wrap;\n            justify-content: center;\n            gap: 2rem;\n            margin: 2rem 0;\n            min-height: 400px;\n        }\n        \n        .tree {\n            width: 120px;\n            height: 250px;\n            position: relative;\n            transition: var(--transition);\n            cursor: pointer;\n        }\n        \n        .tree:hover {\n            transform: translateY(-10px);\n        }\n        \n        .tree-trunk {\n            width: 20px;\n            height: 80px;\n            background: linear-gradient(to right, #8B4513, #A0522D);\n            margin: 0 auto;\n            border-radius: 5px;\n            position: relative;\n            z-index: 2;\n        }\n        \n        .tree-crown {\n            width: 100%;\n            height: 180px;\n            position: absolute;\n            top: 0;\n            left: 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            z-index: 1;\n        }\n        \n        .tree-layer {\n            width: 80%;\n            height: 60px;\n            background: linear-gradient(to bottom right, #27ae60, #2ecc71);\n            border-radius: 50% 50% 20% 20%;\n            margin-bottom: -30px;\n            box-shadow: inset 0 0 10px rgba(0,0,0,0.1);\n        }\n        \n        .tree-layer:nth-child(2) {\n            width: 90%;\n        }\n        \n        .tree-layer:nth-child(3) {\n            width: 100%;\n        }\n        \n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-bottom: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s 0.9s forwards;\n        }\n        \n        button {\n            background: var(--secondary);\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            transition: var(--transition);\n            box-shadow: 0 5px 15px rgba(52, 152, 219, 0.3);\n        }\n        \n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(52, 152, 219, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .explanation {\n            background: white;\n            border-radius: 15px;\n            box-shadow: var(--shadow);\n            padding: 2rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeIn 1s 1.2s forwards;\n        }\n        \n        h2 {\n            font-family: 'Playfair Display', serif;\n            color: var(--primary);\n            margin-bottom: 1rem;\n        }\n        \n        p {\n            line-height: 1.8;\n            margin-bottom: 1rem;\n        }\n        \n        .highlight {\n            color: var(--secondary);\n            font-weight: 600;\n        }\n        \n        .particles {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: 0;\n        }\n        \n        .particle {\n            position: absolute;\n            background: rgba(52, 152, 219, 0.3);\n            border-radius: 50%;\n            pointer-events: none;\n        }\n        \n        @keyframes fadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        @keyframes float {\n            0%, 100% {\n                transform: translateY(0);\n            }\n            50% {\n                transform: translateY(-10px);\n            }\n        }\n        \n        .decoration {\n            position: absolute;\n            opacity: 0.1;\n            z-index: 0;\n        }\n        \n        .decoration-1 {\n            top: 50px;\n            left: 50px;\n            width: 150px;\n            height: 150px;\n            border-radius: 50%;\n            background: var(--secondary);\n            animation: float 6s ease-in-out infinite;\n        }\n        \n        .decoration-2 {\n            bottom: 70px;\n            right: 80px;\n            width: 200px;\n            height: 200px;\n            border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;\n            background: var(--accent);\n            animation: float 8s ease-in-out infinite 1s;\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 3rem;\n            color: var(--primary);\n            opacity: 0.7;\n            font-size: 0.9rem;\n            opacity: 0;\n            animation: fadeIn 1s 1.5s forwards;\n        }\n        \n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .tree {\n                width: 80px;\n                height: 180px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles\"></div>\n    \n    <div class=\"container\">\n        <header>\n            <h1>Random Forest</h1>\n            <p class=\"subtitle\">An ensemble learning method that operates by constructing multiple decision trees during training and outputting the class that is the mode of the classes or mean prediction of the individual trees.</p>\n        </header>\n        \n        <div class=\"visualization\">\n            <div class=\"decoration decoration-1\"></div>\n            <div class=\"decoration decoration-2\"></div>\n            \n            <div class=\"controls\">\n                <button id=\"growBtn\">Grow Forest</button>\n                <button id=\"highlightBtn\">Highlight Decision Path</button>\n            </div>\n            \n            <div class=\"forest-container\" id=\"forest\">\n                <!-- Trees will be generated here -->\n            </div>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>How Random Forest Works</h2>\n            <p>The <span class=\"highlight\">Random Forest</span> algorithm creates a \"forest\" of decision trees, each trained on random subsets of the data and features. This randomness helps make the model more robust than a single decision tree.</p>\n            \n            <p>When making predictions, each tree in the forest votes on the outcome, and the <span class=\"highlight\">most popular result</span> becomes the model's prediction. For regression tasks, the average of all tree predictions is used.</p>\n            \n            <p>The power of Random Forest comes from its ability to <span class=\"highlight\">reduce overfitting</span> (through feature and data sampling) while maintaining good predictive performance. It's widely used for both classification and regression tasks in machine learning.</p>\n        </div>\n        \n        <footer>\n            <p>A visual exploration of machine learning's powerful ensemble method</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Create particles\n            createParticles();\n            \n            // Generate initial forest\n            generateForest(5);\n            \n            // Button event listeners\n            document.getElementById('growBtn').addEventListener('click', function() {\n                generateForest(10);\n                animateTrees();\n            });\n            \n            document.getElementById('highlightBtn').addEventListener('click', function() {\n                highlightRandomPath();\n            });\n        });\n        \n        function createParticles() {\n            const container = document.getElementById('particles');\n            const particleCount = 30;\n            \n            for (let i = 0; i < particleCount; i++) {\n                const particle = document.createElement('div');\n                particle.classList.add('particle');\n                \n                // Random properties\n                const size = Math.random() * 10 + 5;\n                const posX = Math.random() * 100;\n                const posY = Math.random() * 100;\n                const opacity = Math.random() * 0.3 + 0.1;\n                const animationDuration = Math.random() * 15 + 10;\n                const animationDelay = Math.random() * 5;\n                \n                particle.style.width = `${size}px`;\n                particle.style.height = `${size}px`;\n                particle.style.left = `${posX}%`;\n                particle.style.top = `${posY}%`;\n                particle.style.opacity = opacity;\n                particle.style.animation = `float ${animationDuration}s ease-in-out infinite ${animationDelay}s`;\n                \n                container.appendChild(particle);\n            }\n        }\n        \n        function generateForest(treeCount) {\n            const forest = document.getElementById('forest');\n            forest.innerHTML = '';\n            \n            // Create trees\n            for (let i = 0; i < treeCount; i++) {\n                const tree = document.createElement('div');\n                tree.classList.add('tree');\n                tree.style.opacity = '0';\n                tree.style.transform = 'translateY(20px)';\n                tree.style.animation = `fadeIn 0.5s ${i * 0.1}s forwards`;\n                \n                // Create tree parts\n                const treeCrown = document.createElement('div');\n                treeCrown.classList.add('tree-crown');\n                \n                for (let j = 0; j < 3; j++) {\n                    const layer = document.createElement('div');\n                    layer.classList.add('tree-layer');\n                    treeCrown.appendChild(layer);\n                }\n                \n                const trunk = document.createElement('div');\n                trunk.classList.add('tree-trunk');\n                \n                tree.appendChild(treeCrown);\n                tree.appendChild(trunk);\n                forest.appendChild(tree);\n            }\n        }\n        \n        function animateTrees() {\n            const trees = document.querySelectorAll('.tree');\n            \n            trees.forEach((tree, index) => {\n                setTimeout(() => {\n                    tree.style.transform = 'translateY(-10px)';\n                    setTimeout(() => {\n                        tree.style.transform = 'translateY(0)';\n                    }, 300);\n                }, index * 100);\n            });\n        }\n        \n        function highlightRandomPath() {\n            const trees = document.querySelectorAll('.tree');\n            const randomTree = trees[Math.floor(Math.random() * trees.length)];\n            \n            // Reset all trees\n            trees.forEach(tree => {\n                tree.querySelectorAll('.tree-layer').forEach(layer => {\n                    layer.style.background = 'linear-gradient(to bottom right, #27ae60, #2ecc71)';\n                });\n            });\n            \n            // Highlight random tree\n            const layers = randomTree.querySelectorAll('.tree-layer');\n            \n            layers.forEach((layer, index) => {\n                setTimeout(() => {\n                    layer.style.background = 'linear-gradient(to bottom right, #f39c12, #f1c40f)';\n                    \n                    setTimeout(() => {\n                        layer.style.background = 'linear-gradient(to bottom right, #27ae60, #2ecc71)';\n                    }, 1000 + index * 200);\n                }, index * 200);\n            });\n        }\n    </script>\n</body>\n</html>"
