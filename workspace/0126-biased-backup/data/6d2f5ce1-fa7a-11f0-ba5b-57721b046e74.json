  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Branch and Bound Algorithm</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #ccc; padding: 15px; }\n        .row { display: flex; gap: 10px; margin-bottom: 10px; }\n        button, input, select { padding: 5px; }\n        table { border-collapse: collapse; width: 100%; }\n        td, th { border: 1px solid #ddd; padding: 8px; text-align: center; }\n        .active { background-color: #f0f0f0; }\n        .pruned { color: #999; text-decoration: line-through; }\n        .solution { font-weight: bold; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Branch and Bound Algorithm</h1>\n        \n        <div class=\"panel\">\n            <h2>Problem Setup</h2>\n            <div class=\"row\">\n                <label>Problem Type:</label>\n                <select id=\"problemType\">\n                    <option value=\"knapsack\">0/1 Knapsack</option>\n                    <option value=\"tsp\">Traveling Salesman</option>\n                </select>\n            </div>\n            \n            <div id=\"knapsackSetup\">\n                <div class=\"row\">\n                    <label>Capacity:</label>\n                    <input type=\"number\" id=\"capacity\" value=\"10\" min=\"1\">\n                </div>\n                <div class=\"row\">\n                    <label>Items (weight,value):</label>\n                    <input type=\"text\" id=\"items\" value=\"2,5 3,8 5,10 7,15\">\n                    <button id=\"randomItems\">Random Items</button>\n                </div>\n            </div>\n            \n            <div id=\"tspSetup\" style=\"display:none;\">\n                <div class=\"row\">\n                    <label>Cities:</label>\n                    <input type=\"number\" id=\"numCities\" value=\"4\" min=\"2\" max=\"8\">\n                    <button id=\"randomMatrix\">Generate Distance Matrix</button>\n                </div>\n                <div id=\"distanceMatrix\"></div>\n            </div>\n            \n            <div class=\"row\">\n                <button id=\"initProblem\">Initialize Problem</button>\n            </div>\n        </div>\n        \n        <div class=\"panel\" id=\"executionPanel\" style=\"display:none;\">\n            <h2>Algorithm Execution</h2>\n            <div class=\"row\">\n                <button id=\"stepForward\">Step Forward</button>\n                <button id=\"stepBackward\">Step Backward</button>\n                <button id=\"runToEnd\">Run to Completion</button>\n                <button id=\"reset\">Reset</button>\n            </div>\n            <div class=\"row\">\n                <label>Speed:</label>\n                <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"500\">\n                <span id=\"speedValue\">500ms</span>\n            </div>\n            <div class=\"row\">\n                <label>Branching Strategy:</label>\n                <select id=\"branchStrategy\">\n                    <option value=\"depth\">Depth-First</option>\n                    <option value=\"breadth\">Breadth-First</option>\n                    <option value=\"best\">Best-Bound First</option>\n                </select>\n            </div>\n        </div>\n        \n        <div class=\"panel\" id=\"visualizationPanel\" style=\"display:none;\">\n            <h2>Search Tree Visualization</h2>\n            <div id=\"treeContainer\" style=\"overflow: auto; max-height: 400px;\"></div>\n            <div class=\"row\">\n                <label>Current Best Solution:</label>\n                <span id=\"bestSolution\">None</span>\n                <label>Value:</label>\n                <span id=\"bestValue\">-∞</span>\n            </div>\n        </div>\n        \n        <div class=\"panel\" id=\"explorationPanel\" style=\"display:none;\">\n            <h2>Node Exploration</h2>\n            <div class=\"row\">\n                <label>Selected Node:</label>\n                <span id=\"selectedNode\">None</span>\n            </div>\n            <div class=\"row\">\n                <label>Node Details:</label>\n                <textarea id=\"nodeDetails\" rows=\"4\" style=\"width:100%;\" readonly></textarea>\n            </div>\n            <div class=\"row\">\n                <button id=\"exploreNode\">Explore This Node</button>\n                <button id=\"pruneNode\">Prune This Node</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // Global state\n        let state = {\n            problem: null,\n            tree: null,\n            currentNode: null,\n            bestSolution: null,\n            bestValue: -Infinity,\n            history: [],\n            currentStep: -1,\n            running: false,\n            timer: null\n        };\n\n        // DOM elements\n        const elements = {\n            problemType: document.getElementById('problemType'),\n            knapsackSetup: document.getElementById('knapsackSetup'),\n            tspSetup: document.getElementById('tspSetup'),\n            capacity: document.getElementById('capacity'),\n            items: document.getElementById('items'),\n            randomItems: document.getElementById('randomItems'),\n            numCities: document.getElementById('numCities'),\n            randomMatrix: document.getElementById('randomMatrix'),\n            distanceMatrix: document.getElementById('distanceMatrix'),\n            initProblem: document.getElementById('initProblem'),\n            executionPanel: document.getElementById('executionPanel'),\n            visualizationPanel: document.getElementById('visualizationPanel'),\n            explorationPanel: document.getElementById('explorationPanel'),\n            stepForward: document.getElementById('stepForward'),\n            stepBackward: document.getElementById('stepBackward'),\n            runToEnd: document.getElementById('runToEnd'),\n            reset: document.getElementById('reset'),\n            speed: document.getElementById('speed'),\n            speedValue: document.getElementById('speedValue'),\n            branchStrategy: document.getElementById('branchStrategy'),\n            treeContainer: document.getElementById('treeContainer'),\n            bestSolution: document.getElementById('bestSolution'),\n            bestValue: document.getElementById('bestValue'),\n            selectedNode: document.getElementById('selectedNode'),\n            nodeDetails: document.getElementById('nodeDetails'),\n            exploreNode: document.getElementById('exploreNode'),\n            pruneNode: document.getElementById('pruneNode')\n        };\n\n        // Event listeners\n        elements.problemType.addEventListener('change', toggleProblemType);\n        elements.randomItems.addEventListener('click', generateRandomItems);\n        elements.randomMatrix.addEventListener('click', generateRandomMatrix);\n        elements.initProblem.addEventListener('click', initializeProblem);\n        elements.stepForward.addEventListener('click', stepForward);\n        elements.stepBackward.addEventListener('click', stepBackward);\n        elements.runToEnd.addEventListener('click', runToEnd);\n        elements.reset.addEventListener('click', resetAlgorithm);\n        elements.speed.addEventListener('input', updateSpeed);\n        elements.exploreNode.addEventListener('click', exploreSelectedNode);\n        elements.pruneNode.addEventListener('click', pruneSelectedNode);\n        elements.treeContainer.addEventListener('click', handleTreeClick);\n\n        // Problem classes\n        class KnapsackProblem {\n            constructor(capacity, items) {\n                this.type = 'knapsack';\n                this.capacity = capacity;\n                this.items = items;\n            }\n            \n            getInitialNode() {\n                return {\n                    level: -1,\n                    taken: [],\n                    weight: 0,\n                    value: 0,\n                    bound: this.calculateBound([], 0, 0)\n                };\n            }\n            \n            calculateBound(taken, currentWeight, currentValue) {\n                let bound = currentValue;\n                let weight = currentWeight;\n                let nextItem = taken.length;\n                \n                while (nextItem < this.items.length && weight + this.items[nextItem].weight <= this.capacity) {\n                    weight += this.items[nextItem].weight;\n                    bound += this.items[nextItem].value;\n                    nextItem++;\n                }\n                \n                if (nextItem < this.items.length) {\n                    bound += (this.capacity - weight) * (this.items[nextItem].value / this.items[nextItem].weight);\n                }\n                \n                return bound;\n            }\n            \n            branch(node) {\n                const nextLevel = node.level + 1;\n                if (nextLevel >= this.items.length) return [];\n                \n                const leftNode = {\n                    level: nextLevel,\n                    taken: [...node.taken, 0],\n                    weight: node.weight,\n                    value: node.value,\n                    bound: this.calculateBound([...node.taken, 0], node.weight, node.value)\n                };\n                \n                const rightNode = {\n                    level: nextLevel,\n                    taken: [...node.taken, 1],\n                    weight: node.weight + this.items[nextLevel].weight,\n                    value: node.value + this.items[nextLevel].value,\n                    bound: this.calculateBound([...node.taken, 1], \n                        node.weight + this.items[nextLevel].weight, \n                        node.value + this.items[nextLevel].value)\n                };\n                \n                return [leftNode, rightNode];\n            }\n            \n            isSolution(node) {\n                return node.level === this.items.length - 1;\n            }\n            \n            nodeToString(node) {\n                return `Level: ${node.level}\\nTaken: ${node.taken.join('')}\\nWeight: ${node.weight}/${this.capacity}\\nValue: ${node.value}\\nBound: ${node.bound}`;\n            }\n        }\n\n        class TSPProblem {\n            constructor(distances) {\n                this.type = 'tsp';\n                this.distances = distances;\n                this.numCities = distances.length;\n            }\n            \n            getInitialNode() {\n                return {\n                    path: [0],\n                    cost: 0,\n                    bound: this.calculateBound([0], 0)\n                };\n            }\n            \n            calculateBound(path, currentCost) {\n                // Simplified lower bound calculation\n                let bound = currentCost;\n                const n = this.numCities;\n                const visited = new Set(path);\n                \n                // Add minimum outgoing edge for each unvisited city\n                for (let i = 0; i < n; i++) {\n                    if (!visited.has(i)) {\n                        let minEdge = Infinity;\n                        for (let j = 0; j < n; j++) {\n                            if (i !== j && (path.length === n || j !== path[0])) {\n                                minEdge = Math.min(minEdge, this.distances[i][j]);\n                            }\n                        }\n                        bound += minEdge;\n                    }\n                }\n                \n                return bound;\n            }\n            \n            branch(node) {\n                if (node.path.length === this.numCities) return [];\n                \n                const visited = new Set(node.path);\n                const children = [];\n                \n                for (let i = 0; i < this.numCities; i++) {\n                    if (!visited.has(i)) {\n                        const newPath = [...node.path, i];\n                        const newCost = node.cost + this.distances[node.path[node.path.length-1]][i];\n                        children.push({\n                            path: newPath,\n                            cost: newCost,\n                            bound: this.calculateBound(newPath, newCost)\n                        });\n                    }\n                }\n                \n                return children;\n            }\n            \n            isSolution(node) {\n                return node.path.length === this.numCities;\n            }\n            \n            nodeToString(node) {\n                return `Path: ${node.path.join('→')}\\nCost: ${node.cost}\\nBound: ${node.bound}`;\n            }\n        }\n\n        // UI functions\n        function toggleProblemType() {\n            if (elements.problemType.value === 'knapsack') {\n                elements.knapsackSetup.style.display = 'block';\n                elements.tspSetup.style.display = 'none';\n            } else {\n                elements.knapsackSetup.style.display = 'none';\n                elements.tspSetup.style.display = 'block';\n                generateRandomMatrix();\n            }\n        }\n\n        function generateRandomItems() {\n            const numItems = 4 + Math.floor(Math.random() * 3);\n            let items = [];\n            for (let i = 0; i < numItems; i++) {\n                const weight = 1 + Math.floor(Math.random() * 10);\n                const value = 1 + Math.floor(Math.random() * 20);\n                items.push(`${weight},${value}`);\n            }\n            elements.items.value = items.join(' ');\n        }\n\n        function generateRandomMatrix() {\n            const n = parseInt(elements.numCities.value);\n            let matrix = '<table><tr><th></th>';\n            \n            for (let i = 0; i < n; i++) {\n                matrix += `<th>${i}</th>`;\n            }\n            matrix += '</tr>';\n            \n            for (let i = 0; i < n; i++) {\n                matrix += `<tr><th>${i}</th>`;\n                for (let j = 0; j < n; j++) {\n                    if (i === j) {\n                        matrix += '<td>0</td>';\n                    } else {\n                        const dist = 1 + Math.floor(Math.random() * 20);\n                        matrix += `<td>${dist}</td>`;\n                    }\n                }\n                matrix += '</tr>';\n            }\n            \n            matrix += '</table>';\n            elements.distanceMatrix.innerHTML = matrix;\n        }\n\n        function initializeProblem() {\n            if (elements.problemType.value === 'knapsack') {\n                const capacity = parseInt(elements.capacity.value);\n                const items = elements.items.value.split(' ')\n                    .map(pair => pair.split(','))\n                    .map(([w, v]) => ({ weight: parseInt(w), value: parseInt(v) }));\n                \n                // Sort items by value/weight ratio in non-increasing order\n                items.sort((a, b) => (b.value / b.weight) - (a.value / a.weight));\n                \n                state.problem = new KnapsackProblem(capacity, items);\n            } else {\n                const rows = elements.distanceMatrix.querySelectorAll('tr:not(:first-child)');\n                const distances = [];\n                \n                for (let i = 0; i < rows.length; i++) {\n                    const cells = rows[i].querySelectorAll('td');\n                    const row = [];\n                    for (let j = 0; j < cells.length; j++) {\n                        if (j > 0) { // Skip first cell (header)\n                            row.push(parseInt(cells[j].textContent));\n                        }\n                    }\n                    distances.push(row);\n                }\n                \n                state.problem = new TSPProblem(distances);\n            }\n            \n            state.tree = {\n                nodes: [state.problem.getInitialNode()],\n                active: [0],\n                pruned: [],\n                children: {}\n            };\n            \n            state.currentNode = 0;\n            state.bestSolution = null;\n            state.bestValue = -Infinity;\n            state.history = [JSON.parse(JSON.stringify(state.tree))];\n            state.currentStep = 0;\n            \n            elements.executionPanel.style.display = 'block';\n            elements.visualizationPanel.style.display = 'block';\n            elements.explorationPanel.style.display = 'block';\n            \n            updateVisualization();\n            updateNodeDetails();\n        }\n\n        function stepForward() {\n            if (state.currentStep >= state.history.length - 1) {\n                performStep();\n            } else {\n                state.currentStep++;\n                state.tree = JSON.parse(JSON.stringify(state.history[state.currentStep]));\n                updateVisualization();\n                updateNodeDetails();\n            }\n        }\n\n        function stepBackward() {\n            if (state.currentStep > 0) {\n                state.currentStep--;\n                state.tree = JSON.parse(JSON.stringify(state.history[state.currentStep]));\n                updateVisualization();\n                updateNodeDetails();\n            }\n        }\n\n        function runToEnd() {\n            if (state.running) {\n                clearInterval(state.timer);\n                state.running = false;\n                elements.runToEnd.textContent = 'Run to Completion';\n                return;\n            }\n            \n            state.running = true;\n            elements.runToEnd.textContent = 'Stop';\n            \n            state.timer = setInterval(() => {\n                if (state.currentStep >= state.history.length - 1) {\n                    if (!performStep()) {\n                        clearInterval(state.timer);\n                        state.running = false;\n                        elements.runToEnd.textContent = 'Run to Completion';\n                    }\n                } else {\n                    state.currentStep++;\n                    state.tree = JSON.parse(JSON.stringify(state.history[state.currentStep]));\n                    updateVisualization();\n                    updateNodeDetails();\n                }\n            }, elements.speed.value);\n        }\n\n        function resetAlgorithm() {\n            if (state.running) {\n                clearInterval(state.timer);\n                state.running = false;\n                elements.runToEnd.textContent = 'Run to Completion';\n            }\n            \n            if (state.problem) {\n                state.tree = {\n                    nodes: [state.problem.getInitialNode()],\n                    active: [0],\n                    pruned: [],\n                    children: {}\n                };\n                \n                state.currentNode = 0;\n                state.bestSolution = null;\n                state.bestValue = -Infinity;\n                state.history = [JSON.parse(JSON.stringify(state.tree))];\n                state.currentStep = 0;\n                \n                updateVisualization();\n                updateNodeDetails();\n            }\n        }\n\n        function updateSpeed() {\n            elements.speedValue.textContent = `${elements.speed.value}ms`;\n            if (state.running) {\n                clearInterval(state.timer);\n                state.timer = setInterval(() => {\n                    if (state.currentStep >= state.history.length - 1) {\n                        if (!performStep()) {\n                            clearInterval(state.timer);\n                            state.running = false;\n                            elements.runToEnd.textContent = 'Run to Completion';\n                        }\n                    } else {\n                        state.currentStep++;\n                        state.tree = JSON.parse(JSON.stringify(state.history[state.currentStep]));\n                        updateVisualization();\n                        updateNodeDetails();\n                    }\n                }, elements.speed.value);\n            }\n        }\n\n        function exploreSelectedNode() {\n            if (state.selectedNode.textContent !== 'None') {\n                state.currentNode = parseInt(state.selectedNode.textContent);\n                performStep();\n            }\n        }\n\n        function pruneSelectedNode() {\n            const nodeId = parseInt(state.selectedNode.textContent);\n            if (!isNaN(nodeId) && state.tree.active.includes(nodeId)) {\n                state.tree.active = state.tree.active.filter(id => id !== nodeId);\n                state.tree.pruned.push(nodeId);\n                \n                // Save to history\n                state.history = state.history.slice(0, state.currentStep + 1);\n                state.history.push(JSON.parse(JSON.stringify(state.tree)));\n                state.currentStep++;\n                \n                updateVisualization();\n                updateNodeDetails();\n            }\n        }\n\n        function handleTreeClick(event) {\n            const nodeElement = event.target.closest('.node');\n            if (nodeElement) {\n                const nodeId = parseInt(nodeElement.dataset.nodeId);\n                state.selectedNode.textContent = nodeId;\n                \n                const node = state.tree.nodes[nodeId];\n                if (node) {\n                    elements.nodeDetails.value = state.problem.nodeToString(node);\n                }\n            }\n        }\n\n        // Algorithm functions\n        function performStep() {\n            if (state.tree.active.length === 0) {\n                return false; // No more nodes to explore\n            }\n            \n            // Select next node based on strategy\n            let nextIndex;\n            switch (elements.branchStrategy.value) {\n                case 'depth':\n                    nextIndex = state.tree.active.length - 1;\n                    break;\n                case 'breadth':\n                    nextIndex = 0;\n                    break;\n                case 'best':\n                    nextIndex = 0;\n                    let bestBound = -Infinity;\n                    for (let i = 0; i < state.tree.active.length; i++) {\n                        const node = state.tree.nodes[state.tree.active[i]];\n                        if (node.bound > bestBound) {\n                            bestBound = node.bound;\n                            nextIndex = i;\n                        }\n                    }\n                    break;\n            }\n            \n            const nodeId = state.tree.active[nextIndex];\n            state.currentNode = nodeId;\n            const node = state.tree.nodes[nodeId];\n            \n            // Remove from active list\n            state.tree.active.splice(nextIndex, 1);\n            \n            // Check if node can be pruned\n            if (node.bound <= state.bestValue) {\n                state.tree.pruned.push(nodeId);\n                \n                // Save to history\n                state.history = state.history.slice(0, state.currentStep + 1);\n                state.history.push(JSON.parse(JSON.stringify(state.tree)));\n                state.currentStep++;\n                \n                updateVisualization();\n                updateNodeDetails();\n                return true;\n            }\n            \n            // Check if node is a solution\n            if (state.problem.isSolution(node)) {\n                let nodeValue;\n                if (state.problem.type === 'knapsack') {\n                    nodeValue = node.value;\n                } else { // TSP\n                    // Add return to start cost\n                    nodeValue = node.cost + state.problem.distances[node.path[node.path.length-1]][0];\n                }\n                \n                if (nodeValue > state.bestValue) {\n                    state.bestValue = nodeValue;\n                    state.bestSolution = nodeId;\n                }\n                \n                // Save to history\n                state.history = state.history.slice(0, state.currentStep + 1);\n                state.history.push(JSON.parse(JSON.stringify(state.tree)));\n                state.currentStep++;\n                \n                updateVisualization();\n                updateNodeDetails();\n                return true;\n            }\n            \n            // Branch the node\n            const children = state.problem.branch(node);\n            const childIds = [];\n            \n            for (const child of children) {\n                const childId = state.tree.nodes.length;\n                state.tree.nodes.push(child);\n                state.tree.active.push(childId);\n                childIds.push(childId);\n            }\n            \n            state.tree.children[nodeId] = childIds;\n            \n            // Save to history\n            state.history = state.history.slice(0, state.currentStep + 1);\n            state.history.push(JSON.parse(JSON.stringify(state.tree)));\n            state.currentStep++;\n            \n            updateVisualization();\n            updateNodeDetails();\n            return true;\n        }\n\n        // Visualization functions\n        function updateVisualization() {\n            let html = '<div class=\"tree\">';\n            \n            // Build tree structure\n            const rootId = 0;\n            html += buildTreeLevel(rootId, 0);\n            \n            html += '</div>';\n            elements.treeContainer.innerHTML = html;\n            \n            // Update best solution display\n            if (state.bestSolution !== null) {\n                const solution = state.tree.nodes[state.bestSolution];\n                if (state.problem.type === 'knapsack') {\n                    elements.bestSolution.textContent = solution.taken.join('');\n                    elements.bestValue.textContent = solution.value;\n                } else {\n                    elements.bestSolution.textContent = solution.path.join('→') + '→0';\n                    elements.bestValue.textContent = solution.cost + state.problem.distances[solution.path[solution.path.length-1]][0];\n                }\n            } else {\n                elements.bestSolution.textContent = 'None';\n                elements.bestValue.textContent = '-∞';\n            }\n        }\n\n        function buildTreeLevel(nodeId, depth) {\n            const node = state.tree.nodes[nodeId];\n            let classes = ['node'];\n            \n            if (nodeId === state.currentNode) classes.push('active');\n            if (state.tree.pruned.includes(nodeId)) classes.push('pruned');\n            if (nodeId === state.bestSolution) classes.push('solution');\n            \n            let nodeContent;\n            if (state.problem.type === 'knapsack') {\n                nodeContent = `Node ${nodeId}<br>${node.taken.join('')}<br>V:${node.value} B:${node.bound.toFixed(1)}`;\n            } else {\n                nodeContent = `Node ${nodeId}<br>${node.path.join('→')}<br>C:${node.cost} B:${node.bound.toFixed(1)}`;\n            }\n            \n            let html = `<div class=\"${classes.join(' ')}\" data-node-id=\"${nodeId}\">${nodeContent}</div>`;\n            \n            if (state.tree.children[nodeId]) {\n                html += '<div class=\"children\">';\n                for (const childId of state.tree.children[nodeId]) {\n                    html += buildTreeLevel(childId, depth + 1);\n                }\n                html += '</div>';\n            }\n            \n            return html;\n        }\n\n        function updateNodeDetails() {\n            if (state.currentNode !== null && state.tree.nodes[state.currentNode]) {\n                const node = state.tree.nodes[state.currentNode];\n                elements.nodeDetails.value = state.problem.nodeToString(node);\n            } else {\n                elements.nodeDetails.value = 'No node selected';\n            }\n        }\n\n        // Initialize\n        toggleProblemType();\n    </script>\n</body>\n</html>"
  },
