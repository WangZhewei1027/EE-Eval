    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Big-O Notation — Visualized</title>\n\n  <!-- Elegant typography -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Cormorant+Garamond:wght@500;700&display=swap\" rel=\"stylesheet\">\n\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #071129;\n      --glass: rgba(255,255,255,0.06);\n      --accent: #7de3ff;\n      --muted: rgba(255,255,255,0.65);\n      --card-glow: 0 8px 40px rgba(125,227,255,0.08);\n      --glass-border: rgba(255,255,255,0.06);\n      --glass-2: rgba(10,14,20,0.45);\n    }\n\n    *{box-sizing:border-box}\n    html,body{\n      height:100%;\n      margin:0;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(125,227,255,0.06), transparent 6%),\n                  radial-gradient(900px 500px at 90% 90%, rgba(255,112,149,0.03), transparent 6%),\n                  linear-gradient(180deg,var(--bg-1), var(--bg-2));\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color: #e6f7ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Subtle ambient shapes */\n    .ambient{\n      position:fixed;\n      inset: -10% -10% auto auto;\n      width:70vmax;\n      height:70vmax;\n      pointer-events:none;\n      mix-blend-mode:overlay;\n      opacity:0.18;\n      filter: blur(60px) saturate(120%);\n      background: conic-gradient(from 120deg at 50% 50%, rgba(125,227,255,0.9), rgba(170,120,255,0.9), rgba(255,120,180,0.9), rgba(125,227,255,0.9));\n      transform: rotate(18deg);\n    }\n\n    /* Layout */\n    .stage{\n      display:grid;\n      grid-template-columns: 1fr 420px;\n      gap:32px;\n      align-items:center;\n      height:100vh;\n      padding:48px;\n      position:relative;\n    }\n\n    .panel