:relative;\n      border-radius:14px;\n      padding:18px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n      border: 1px solid rgba(255,255,255,0.03);\n      overflow:visible;\n      flex:1;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n    }\n\n    /* Grid lines */\n    .grid{\n      position:absolute;\n      inset:24px 24px 24px 24px;\n      border-radius:10px;\n      pointer-events:none;\n      opacity:0.9;\n    }\n\n    /* Legend / Info */\n    .legend{\n      display:flex;\n      flex-direction:column;\n      gap:14px;\n    }\n\n    .legend .card{\n      padding:18px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(10,20,30,0.45), rgba(6,12,20,0.28));\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n\n    .legend h3{\n      margin:0 0 8px 0;\n      font-size:15px;\n      font-weight:700;\n      color:#e9fbff;\n      font-family: 'Cormorant Garamond', serif;\n    }\n\n    .legend p{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.5;\n    }\n\n    /* List of complexities */\n    .keys{\n      display:flex;\n      flex-direction:column;\n      gap:10px;\n      margin-top:6px;\n    }\n\n    .key{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      padding:10px;\n      border-radius:10px;\n      transition:transform .12s ease, background .12s ease;\n      cursor:default;\n    }\n\n    .led{\n      width:44px;\n      height:40px;\n      display:inline-grid;\n      place-items:center;\n      font-weight:700;\n      border-radius:10px;\n      color:#042126;\n      font-family: 'Cormorant Garamond', serif;\n      font-size:14px;\n    }\n\n    /* Colors for each curve matching CSS variables used in path stroke */\n    .led.c-const{ background: linear-gradient(180deg,#ffd86f,#ffb86f); color: #2a1b00; }\n    .led.c-log  { background: linear-gradient(180deg,#c7f9ff,#7de3ff); color:#012026; }\n    .led.c-linear{ background: linear-gradient(180deg,#a4ffd8,#74f4b2); color:#01311a; }\n    .led.c-nlogn{ background: linear-gradient(180deg,#d9c6ff,#bda8ff); color:#150032; }\n    .led.c-quad { background: linear-gradient(180deg,#ffb3e6,#ff86d0); color:#2a0022; }\n    .led.c-exp  { background: linear-gradient(180deg,#ffd6d6,#ffb3b3); color:#2a0000; }\n\n    .klabel{ font-size:13px; color:#eaffff; font-weight:700; }\n\n    .kdesc{ font-size:12px; color:var(--muted); }\n\n    /* Footer flourish */\n    .footer{\n      margin-top:18px;\n      display:flex;\n      gap:10px;\n      align-items:center;\n      opacity:0.95;\n    }\n\n    .sig{\n      display:flex;\n      gap:10px;\n      align-items:center;\n      color:var(--muted);\n      font-size:12px;\n    }\n\n    /* Info overlay (toggle) */\n    .info-overlay{\n      position:fixed;\n      right:40px;\n      bottom:40px;\n      width:420px;\n      max-width:calc(100% - 48px);\n      border-radius:14px;\n      padding:18px;\n      background: linear-gradient(180deg, rgba(8,12,16,0.86), rgba(10,14,20,0.68));\n      border:1px solid rgba(255,255,255,0.04);\n      box-shadow: 0 18px 60px rgba(2,8,20,0.6);\n      transform: translateY(28px) scale(.98);\n      opacity:0;\n      pointer-events:none;\n      transition:all .26s cubic-bezier(.2,.9,.3,1);\n      backdrop-filter: blur(10px);\n    }\n\n    .info-overlay.open{\n      transform: translateY(0) scale(1);\n      opacity:1;\n      pointer-events:auto;\n    }\n\n    .info-overlay h4{\n      margin:0 0 8px 0;\n      font-family: 'Cormorant Garamond', serif;\n      font-size:18px;\n      color:#eaffff;\n    }\n\n    .info-overlay p{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.5;\n    }\n\n    /* Responsive */\n    @media (max-width:980px){\n      .stage{ grid-template-columns: 1fr; padding:28px; gap:18px; }\n      .legend{ order:2; }\n      .visual{ order:1; min-height:420px; }\n      .info-overlay{ right:24px; left:24px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"ambient\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\" role=\"main\" aria-label=\"Big O Notation Visualization\">\n    <div class=\"panel visual\" style=\"--accent:var(--accent);\">\n      <div class=\"header\">\n        <div class=\"title\">\n          <h1>Big‑O Notation</h1>\n          <div class=\"subtitle\">Growth rates visualized — observe algorithmic complexity</div>\n        </div>\n\n        <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n          <button id=\"playBtn\" class=\"btn\" aria-pressed=\"false\" title=\"Play / Pause animation\">\n            <svg id=\"playIcon\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"></path></svg>\n            <span id=\"playLabel\">Play</span>\n          </button>\n          <button id=\"infoBtn\" class=\"btn\" aria-pressed=\"false\" title=\"Show explanation\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 2a10 10 0 100 20 10 10 0 000-20zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z\" fill=\"currentColor\"/></svg>\n            <span>Info</span>\n          </button>\n        </div>\n      </div>\n\n      <div class=\"graph-wrap\" aria-hidden=\"false\">\n        <!-- Decorative soft glow behind graph -->\n        <div style=\"position:absolute; left:-10%; top:-20%; width:60%; height:140%; background:radial-gradient(circle at 25% 25%, rgba(125,227,255,0.06), transparent 20%), radial-gradient(circle at 80% 80%, rgba(255,120,180,0.04), transparent 20%); filter:blur(40px); z-index:0;\"></div>\n\n        <!-- SVG graph -->\n        <svg id=\"graph\" width=\"100%\" height=\"100%\" viewBox=\"0 0 900 520\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Graph of complexity curves\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7de3ff\"/>\n              <stop offset=\"1\" stop-color=\"#c7f9ff\"/>\n            </linearGradient>\n            <linearGradient id=\"g2\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#a4ffd8\"/>\n              <stop offset=\"1\" stop-color=\"#74f4b2\"/>\n            </linearGradient>\n            <linearGradient id=\"g3\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#d9c6ff\"/>\n              <stop offset=\"1\" stop-color=\"#bda8ff\"/>\n            </linearGradient>\n            <linearGradient id=\"g4\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#ffb3e6\"/>\n              <stop offset=\"1\" stop-color=\"#ff86d0\"/>\n            </linearGradient>\n            <linearGradient id=\"g5\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#ffd86f\"/>\n              <stop offset=\"1\" stop-color=\"#ffb86f\"/>\n            </linearGradient>\n            <linearGradient id=\"g6\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#ffd6d6\"/>\n              <stop offset=\"1\" stop-color=\"#ffb3b3\"/>\n            </linearGradient>\n            <filter id=\"glow\" x=\"-200%\" y=\"-200%\" width=\"400%\" height=\"400%\">\n              <feGaussianBlur stdDeviation=\"8\" result=\"coloredBlur\"/>\n              <feMerge>\n                <feMergeNode in=\"coloredBlur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n          </defs>\n\n          <!-- subtle grid -->\n          <g id=\"grid\" stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"1\">\n            <!-- vertical lines -->\n            <!-- generated in JS if needed, fallback static ones -->\n            <line x1=\"80\" x2=\"80\" y1=\"36\" y2=\"472\" />\n            <line x1=\"160\" x2=\"160\" y1=\"36\" y2=\"472\" />\n            <line x1=\"240\" x2=\"240\" y1=\"36\" y2=\"472\" />\n            <line x1=\"320\" x2=\"320\" y1=\"36\" y2=\"472\" />\n            <line x1=\"400\" x2=\"400\" y1=\"36\" y2=\"472\" />\n            <line x1=\"480\" x2=\"480\" y1=\"36\" y2=\"472\" />\n            <line x1=\"560\" x2=\"560\" y1=\"36\" y2=\"472\" />\n            <line x1=\"640\" x2=\"640\" y1=\"36\" y2=\"472\" />\n            <line x1=\"720\" x2=\"720\" y1=\"36\" y2=\"472\" />\n            <line x1=\"800\" x2=\"800\" y1=\"36\" y2=\"472\" />\n            <!-- horizontal lines -->\n            <line x1=\"40\" x2=\"860\" y1=\"92\" y2=\"92\" />\n            <line x1=\"40\" x2=\"860\" y1=\"156\" y2=\"156\" />\n            <line x1=\"40\" x2=\"860\" y1=\"220\" y2=\"220\" />\n            <line x1=\"40\" x2=\"860\" y1=\"284\" y2=\"284\" />\n            <line x1=\"40\" x2=\"860\" y1=\"348\" y2=\"348\" />\n            <line x1=\"40\" x2=\"860\" y1=\"412\" y2=\"412\" />\n          </g>\n\n          <!-- axes -->\n          <g stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1.5\">\n            <line x1=\"40\" y1=\"472\" x2=\"860\" y2=\"472\" />\n            <line x1=\"40\" y1=\"36\" x2=\"40\" y2=\"472\" />\n          </g>\n\n          <!-- labels -->\n          <g fill=\"rgba(255,255,255,0.6)\" font-size=\"11\" font-family=\"Inter, sans-serif\">\n            <text x=\"44\" y=\"28\" fill=\"rgba(255,255,255,0.45)\">Cost</text>\n            <text x=\"860\" y=\"494\" fill=\"rgba(255,255,255,0.45)\" text-anchor=\"end\">Input size (n)</text>\n          </g>\n\n          <!-- complexity paths (empty to be filled by JS) -->\n          <g id=\"paths\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"></g>\n\n          <!-- labels for curves -->\n          <g id=\"curveLabels\" font-family=\"Inter, sans-serif\" font-weight=\"700\" font-size=\"12\"></g>\n\n          <!-- moving markers group -->\n          <g id=\"markers\"></g>\n\n          <!-- decorative soft highlight -->\n          <rect x=\"36\" y=\"32\" width=\"828\" height=\"444\" rx=\"10\" fill=\"transparent\" stroke=\"rgba(125,227,255,0.02)\"></rect>\n\n        </svg>\n      </div>\n\n      <div class=\"footer\">\n        <div class=\"sig\">\n          <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 3L2 9l10 6 10-6-10-6z\" fill=\"#7de3ff\"/><path d=\"M2 15l10 6 10-6\" stroke=\"#7de3ff\" stroke-width=\"1.2\" fill=\"none\"/></svg>\n          <div style=\"font-size:13px; color:var(--muted)\">Aesthetic learning • algorithm intuition</div>\n        </div>\n      </div>\n    </div>\n\n    <aside class=\"panel legend\" aria-label=\"Legend and descriptions\">\n      <div class=\"card\">\n        <h3>Complexity Classes</h3>\n        <p style=\"margin-bottom:10px; color:var(--muted);\">A curated set of common time complexities plotted over increasing input size. Colors correspond to curves on the graph — watch how tiny differences at small n become enormous with scale.</p>\n\n        <div class=\"keys\" aria-hidden=\"true\">\n          <div class=\"key\">\n            <div class=\"led c-const\">O(1)</div>\n            <div>\n              <div class=\"klabel\">Constant</div>\n              <div class=\"kdesc\">Time independent of input size.</div>\n            </div>\n          </div>\n\n          <div class=\"key\">\n            <div class=\"led c-log\">O(log n)</div>\n            <div>\n              <div class=\"klabel\">Logarithmic</div>\n              <div class=\"kdesc\">Divide-and-conquer reductions.</div>\n            </div>\n          </div>\n\n          <div class=\"key\">\n            <div class=\"led c-linear\">O(n)</div>\n            <div>\n              <div class=\"klabel\">Linear</div>\n              <div class=\"kdesc\">Single pass through data.</div>\n            </div>\n          </div>\n\n          <div class=\"key\">\n            <div class=\"led c-nlogn\">O(n log n)</div>\n            <div>\n              <div class=\"klabel\">Linearithmic</div>\n              <div class=\"kdesc\">Efficient sorts and merges.</div>\n            </div>\n          </div>\n\n          <div class=\"key\">\n            <div class=\"led c-quad\">O(n²)</div>\n            <div>\n              <div class=\"klabel\">Quadratic</div>\n              <div class=\"kdesc\">Nested loops — beware scaling.</div>\n            </div>\n          </div>\n\n          <div class=\"key\">\n            <div class=\"led c-exp\">O(2ⁿ)</div>\n            <div>\n              <div class=\"klabel\">Exponential</div>\n              <div class=\"kdesc\">Rapid blow-up; infeasible for large n.</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"height:18px\"></div>\n\n      <div class=\"card\">\n        <h3>Observe</h3>\n        <p>Click Play to animate markers along each curve. Notice how functions that appear close at first diverge quickly — a core insight of Big‑O: the dominant term dictates growth as n → ∞.</p>\n      </div>\n    </aside>\n  </div>\n\n  <!-- Info overlay toggled by Info button -->\n  <div id=\"infoOverlay\" class=\"info-overlay\" role=\"dialog\" aria-hidden=\"true\" aria-label=\"Big O explanation\">\n    <h4>Quick Reference</h4>\n    <p>\n      Big‑O describes the upper bound growth of an algorithm's running time or space. It abstracts constant factors and lower-order terms — focusing on how performance scales. Use this visualization to develop an intuition: small inputs can mask large asymptotic differences.\n    </p>\n  </div>\n\n  <script>\n    /* Minimal JS: draws curves into SVG and animates markers along them.\n       Interactivity: Play/Pause and Info toggle buttons only. */\n\n    (function(){\n      const svg = document.getElementById('graph');\n      const pathsGroup = document.getElementById('paths');\n      const markersGroup = document.getElementById('markers');\n      const playBtn = document.getElementById('playBtn');\n      const playIcon = document.getElementById('playIcon');\n      const playLabel = document.getElementById('playLabel');\n      const infoBtn = document.getElementById('infoBtn');\n      const infoOverlay = document.getElementById('infoOverlay');\n\n      // Settings\n      const width = 900;\n      const height = 520;\n      const padding = {left:40, right:40, top:36, bottom:48};\n      const plotWidth = width - padding.left - padding.right;\n      const plotHeight = height - padding.top - padding.bottom;\n\n      // Complexity definitions (name, function, color, label offset)\n      const complexities = [\n        {id:'const',  name:'O(1)',     fn: (n)=> 1,                color:'url(#g5)', label:'Constant', offset:-8},\n        {id:'log',    name:'O(log n)', fn: (n)=> Math.log2(n+1), color:'url(#g1)', label:'Logarithmic', offset:-22},\n        {id:'linear', name:'O(n)',     fn: (n)=> n,                color:'url(#g2)', label:'Linear', offset:-10},\n        {id:'nlogn',  name:'O(n log n)', fn:(n)=> n*Math.log2(n+1), color:'url(#g3)', label:'N log N', offset:0},\n        {id:'quad',   name:'O(n²)',    fn: (n)=> n*n,              color:'url(#g4)', label:'Quadratic', offset:10},\n        {id:'exp',    name:'O(2ⁿ)',    fn: (n)=> Math.pow(2, n/6), color:'url(#g6)', label:'Exponential', offset:30},\n      ];\n\n      // Prepare N domain (sample points)\n      const sampleCount = 140;\n      const domain = [];\n      for(let i=0;i<sampleCount;i++){\n        // Use nonlinear spacing to emphasize early region but still cover end\n        const t = i/(sampleCount-1);\n        const n = Math.pow(200, t); // n ranges ~1 .. 200\n        domain.push(n);\n      }\n\n      // Compute raw values for all complexities\n      const rawValues = complexities.map(c => domain.map(d => c.fn(d)));\n\n      // Normalize each series to a common displayed scale (0..1)\n      // We want curves to fit nicely: map min..max -> 0.02..0.98 (vertical)\n      const normalized = rawValues.map(vals => {\n        const max = Math.max(...vals);\n        const min = Math.min(...vals);\n        // Avoid divide by zero\n        return vals.map(v => (v - min) / (max - min + 1e-12) * 0.94 + 0.03);\n      });\n\n      // Create path strings\n      const pathElements = [];\n      for(let i=0;i<complexities.length;i++){\n        const points = normalized[i].map((nv, idx)=>{\n          const x = padding.left + (idx/(sampleCount-1)) * plotWidth;\n          const y = padding.top + (1 - nv) * plotHeight;\n          return [x,y];\n        });\n\n        // Smooth path using cubic bezier through points (simple smoothing)\n        const d = points.reduce((acc, p, idx, arr)=>{\n          if(idx===0) return `M ${p[0].toFixed(2)} ${p[1].toFixed(2)}`;\n          const prev = arr[idx-1];\n          const midX = (prev[0] + p[0]) / 2;\n          const midY = (prev[1] + p[1]) / 2;\n          if(idx===1) acc += ` Q ${prev[0].toFixed(2)} ${prev[1].toFixed(2)} ${midX.toFixed(2)} ${midY.toFixed(2)}`;\n          else acc += ` T ${midX.toFixed(2)} ${midY.toFixed(2)}`;\n          if(idx===arr.length-1) acc += ` T ${p[0].toFixed(2)} ${p[1].toFixed(2)}`;\n          return acc;\n        }, '');\n\n        const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n        g.setAttribute('filter','url(#glow)');\n\n        const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n        path.setAttribute('d', d);\n        path.setAttribute('stroke', complexities[i].color);\n        path.setAttribute('stroke-width', 3.2);\n        path.setAttribute('opacity', 0.98);\n        path.setAttribute('fill','none');\n        path.setAttribute('class','curve');\n        path.setAttribute('id', 'path-'+complexities[i].id);\n        path.style.transition = 'opacity .24s ease';\n\n        // Add faint stroke underneath for depth\n        const base = document.createElementNS('http://www.w3.org/2000/svg','path');\n        base.setAttribute('d', d);\n        base.setAttribute('stroke', 'rgba(2,8,20,0.6)');\n        base.setAttribute('stroke-width', 6);\n        base.setAttribute('stroke-linecap','round');\n        base.setAttribute('fill','none');\n        base.setAttribute('opacity',0.06);\n\n        g.appendChild(base);\n        g.appendChild(path);\n        pathsGroup.appendChild(g);\n        pathElements.push({path,points});\n      }\n\n      // Add labels anchored near the curves' ends\n      const labelsGroup = document.getElementById('curveLabels');\n      pathElements.forEach((pObj, idx)=>{\n        const lastPoint = pObj.points[pObj.points.length-1];\n        const lbl = document.createElementNS('http://www.w3.org/2000/svg','text');\n        lbl.setAttribute('x', (lastPoint[0] - 6).toFixed(2));\n        lbl.setAttribute('y', (lastPoint[1] + complexities[idx].offset).toFixed(2));\n        lbl.setAttribute('fill','white');\n        lbl.setAttribute('opacity', 0.95);\n        lbl.setAttribute('font-size','12');\n        lbl.setAttribute('font-family','Inter, sans-serif');\n        lbl.setAttribute('text-anchor','end');\n        lbl.setAttribute('pointer-events','none');\n        lbl.textContent = complexities[idx].name;\n        labelsGroup.appendChild(lbl);\n      });\n\n      // Create a small glowing marker for each curve\n      const markers = pathElements.map((pObj, idx)=>{\n        const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n        g.setAttribute('pointer-events','none');\n        const glow = document.createElementNS('http://www.w3.org/2000/svg','circle');\n        glow.setAttribute('r', 8);\n        glow.setAttribute('fill', complexities[idx].color);\n        glow.setAttribute('opacity', 0.18);\n        glow.setAttribute('filter','url(#glow)');\n        const dot = document.createElementNS('http://www.w3.org/2000/svg','circle');\n        dot.setAttribute('r', 3.6);\n        dot.setAttribute('fill', '#04161a');\n        dot.setAttribute('stroke', '#e9ffff');\n        dot.setAttribute('stroke-width', 1.2);\n        g.appendChild(glow);\n        g.appendChild(dot);\n        markersGroup.appendChild(g);\n        return {g, glow, dot, pathEl: pObj.path};\n      });\n\n      // Animation loop: move markers along path lengths\n      let running = false;\n      let tStart = null;\n      const speedFactor = 0.0006; // controls marker speed\n      const loopPeriod = 11000; // milliseconds per full sweep baseline\n\n      function animate(ts){\n        if(!tStart) tStart = ts;\n        const elapsed = ts - tStart;\n        // For each marker, compute its position along its path\n        markers.forEach((mObj, idx)=>{\n          const path = mObj.pathEl;\n          const len = path.getTotalLength();\n          // Use different speeds slightly per curve for pleasing motion\n          const factor = 1 + idx * 0.06;\n          // Compute progress as looping value [0..1]\n          const baseProgress = ((elapsed * speedFactor * factor) % (loopPeriod * speedFactor)) / (loopPeriod * speedFactor);\n          // Slight offset to separate markers visually\n          const progress = (baseProgress + idx*0.03) % 1;\n          const pt = path.getPointAtLength(progress * len);\n          mObj.g.setAttribute('transform', `translate(${pt.x} ${pt.y}) rotate(${progress*360})`);\n          // subtle breathing of glow\n          const breathe = 0.7 + 0.3*Math.sin((elapsed/600) + idx*0.7);\n          mObj.glow.setAttribute('opacity', (0.06 * breathe).toFixed(3));\n          mObj.glow.setAttribute('r', (6 + 6*breathe).toFixed(2));\n        });\n\n        if(running) requestAnimationFrame(animate);\n      }\n\n      // Play/pause control\n      function setRunning(val){\n        running = val;\n        playBtn.setAttribute('aria-pressed', String(!!val));\n        playBtn.dataset.active = !!val;\n        playLabel.textContent = val ? 'Pause' : 'Play';\n        // change icon: play or pause\n        if(val){\n          playIcon.innerHTML = '<rect x=\"6\" y=\"5\" width=\"3.5\" height=\"14\" fill=\"currentColor\"></rect><rect x=\"14.5\" y=\"5\" width=\"3.5\" height=\"14\" fill=\"currentColor\"></rect>';\n          requestAnimationFrame(animate);\n        }else{\n          playIcon.innerHTML = '<path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\"></path>';\n        }\n      }\n      setRunning(false);\n\n      playBtn.addEventListener('click', ()=>{\n        setRunning(!running);\n      });\n\n      // Info overlay toggle (second control)\n      let infoOpen = false;\n      infoBtn.addEventListener('click', ()=>{\n        infoOpen = !infoOpen;\n        infoOverlay.classList.toggle('open', infoOpen);\n        infoBtn.setAttribute('aria-pressed', String(infoOpen));\n        infoOverlay.setAttribute('aria-hidden', String(!infoOpen));\n      });\n\n      // Subtle entrance animation for markers/curves: fade-in and slight draw\n      function entrance(){\n        pathElements.forEach((pObj, idx)=>{\n          const path = pObj.path;\n          const el = path;\n          const total = el.getTotalLength();\n          el.style.strokeDasharray = total;\n          el.style.strokeDashoffset = total*0.98;\n          el.style.opacity = 0;\n          setTimeout(()=> {\n            el.style.transition = 'stroke-dashoffset 1400ms cubic-bezier(.2,.9,.25,1), opacity 900ms ease';\n            el.style.strokeDashoffset = '0';\n            el.style.opacity = 1;\n          }, 120 + idx*90);\n        });\n\n        // markers fade in\n        markers.forEach((m,i)=>{\n          m.g.style.opacity = 0;\n          m.g.style.transition = 'opacity 900ms ease';\n          setTimeout(()=> m.g.style.opacity = 1, 600 + i*80);\n        });\n      }\n      entrance();\n\n      // Make view responsive: adjust SVG view on resize (labels reposition)\n      function repositionLabels(){\n        // recompute points positions (in case of responsive resizing, but our svg viewBox is fixed so generally static)\n        // This function could be extended for dynamic recalculation; kept minimal to satisfy limited interactivity.\n      }\n      window.addEventListener('resize', repositionLabels);\n\n      // Accessibility: keyboard space toggles play/pause\n      window.addEventListener('keydown', (e)=>{\n        if(e.code === 'Space'){\n          e.preventDefault();\n          setRunning(!running);\n        }\n      });\n\n    })();\n  </script>\n</body>\n</html>"
