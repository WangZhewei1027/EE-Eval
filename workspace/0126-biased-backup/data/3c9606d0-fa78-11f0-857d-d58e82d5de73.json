    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Hash Map Visualization — Elegant Concept Exploration</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  :root {\n    --color-bg: #0f1c2f;\n    --color-primary: #4a90e2;\n    --color-secondary: #50e3c2;\n    --color-accent: #f5a623;\n    --color-text-light: #e1e9f0;\n    --color-text-dark: #25313c;\n    --color-shadow: rgba(10, 25, 47, 0.4);\n\n    --shadow-glow: 0 0 20px rgba(74,144,226,0.6);\n    --transition-speed: 0.4s ease-in-out;\n  }\n\n  * {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin:0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #0f1c2f 0%, #142a53 100%);\n    font-family: 'Poppins', sans-serif;\n    color: var(--color-text-light);\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 40px 20px;\n  }\n\n  .container {\n    max-width: 960px;\n    width: 100%;\n    background: linear-gradient(145deg, #162a4d, #1e3b6d);\n    border-radius: 28px;\n    box-shadow:\n      0 8px 30px var(--color-shadow),\n      inset 0 0 15px #316ab6cc;\n    overflow: hidden;\n    user-select: none;\n  }\n\n  header {\n    padding: 24px 40px 12px;\n    text-align: center;\n    border-bottom: 1px solid #316ab6aa;\n    background: linear-gradient(90deg, #21497a 0%, #2e5f9b 100%);\n  }\n\n  header h1 {\n    font-weight: 600;\n    font-size: 2.75rem;\n    letter-spacing: 0.08em;\n    color: var(--color-secondary);\n    text-shadow:\n      0 0 8px var(--color-secondary),\n      0 0 15px var(--color-primary);\n  }\n\n  header p {\n    margin-top: 4px;\n    font-weight: 300;\n    font-size: 1.1rem;\n    color: #a2cddfcc;\n    letter-spacing: 0.04em;\n    font-style: italic;\n  }\n\n  main {\n    padding: 36px 48px 48px;\n    display: flex;\n    flex-direction: column;\n    gap: 40px;\n  }\n\n  /* Hash Map Visualization Container */\n  .hashmap-visual {\n    position: relative;\n    background: #172b56;\n    border-radius: 22px;\n    padding: 28px 28px 38px;\n    box-shadow:\n      inset 0 0 20px #1b3b7f,\n      0 12px 24px rgba(17,31,59,0.6);\n  }\n\n  /* Title on hashmap */\n  .hashmap-visual h2 {\n    color: var(--color-accent);\n    font-weight: 600;\n    font-size: 1.9rem;\n    margin-bottom: 24px;\n    letter-spacing: 0.06em;\n    text-shadow:\n      0 0 8px var(--color-accent);\n  }\n\n  /* The table/gird for buckets */\n  .buckets {\n    display: grid;\n    grid-template-columns: repeat(8, 1fr);\n    gap: 18px 18px;\n  }\n\n  /* Single bucket */\n  .bucket {\n    background: linear-gradient(145deg, #284c89, #1d366f);\n    border-radius: 16px;\n    min-height: 120px;\n    box-shadow:\n      inset 0 0 10px #406db8,\n      0 6px 10px #132a5a88;\n    position: relative;\n    transition: box-shadow var(--transition-speed);\n    cursor: default;\n    overflow: visible;\n  }\n\n  .bucket.highlighted {\n    box-shadow:\n      inset 0 0 24px #50e3c299,\n      0 8px 25px #50e3c2cc;\n    background: linear-gradient(145deg, #395ea9, #2b4a8c);\n  }\n\n  /* Bucket index number */\n  .bucket-index {\n    position: absolute;\n    top: 10px;\n    left: 12px;\n    font-size: 0.95rem;\n    font-weight: 600;\n    color: var(--color-secondary);\n    text-shadow: 0 0 6px #387f7aaa;\n    user-select: none;\n    letter-spacing: 0.05em;\n  }\n\n  /* Linked List inside a bucket (chained items) */\n  .bucket .chain {\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n    align-items: center;\n    margin-top: 34px;\n    perspective: 1400px;\n  }\n\n  /* Single key-value pair in the bucket */\n  .pair {\n    background: linear-gradient(145deg, #3b73d0, #1a4bb9);\n    padding: 10px 16px;\n    min-width: 85px;\n    border-radius: 14px;\n    box-shadow:\n      0 3px 7px #1f4493cc,\n      inset 0 2px 6px #5a90e5cc;\n    color: var(--color-text-light);\n    font-weight: 600;\n    font-size: 0.95rem;\n    letter-spacing: 0.04em;\n    text-align: center;\n    position: relative;\n    user-select: none;\n    transform-style: preserve-3d;\n    animation: fadeInUp 0.6s ease forwards;\n  }\n\n  /* keys and values style */\n  .pair .key {\n    color: #81d4fa;\n    text-shadow: 0 0 6px #81d4fa99;\n    font-weight: 700;\n    font-size: 1.1rem;\n    letter-spacing: 0.06em;\n  }\n\n  .pair .value {\n    margin-top: 2px;\n    color: #cbdcffcc;\n    font-weight: 500;\n    font-size: 0.88rem;\n    font-style: italic;\n    text-shadow: 0 0 4px #3b6ed9aa;\n  }\n\n  /* Arrows between pairs for chaining */\n  .chain .pair:not(:last-child)::after {\n    content: \"\";\n    position: absolute;\n    right: -36px;\n    top: 50%;\n    width: 32px;\n    height: 4px;\n    background:\n      linear-gradient(90deg, var(--color-secondary), var(--color-primary));\n    border-radius: 10px;\n    transform: translateY(-50%);\n    filter: drop-shadow(0 0 3px var(--color-secondary));\n    animation: pulseArrow 1.9s infinite;\n  }\n\n  /* Arrows vertical when bucket has more than one pair */\n  @media (min-width: 450px) {\n    .chain {\n      flex-direction: row;\n    }\n    .chain .pair:not(:last-child)::after {\n      top: 50%;\n      left: 100%;\n      transform: translate(12px, -50%);\n    }\n  }\n\n  /* Hash function bar */\n  .hash-function {\n    margin-top: 40px;\n    padding: 18px 32px;\n    border-radius: 24px;\n    background: linear-gradient(145deg, #375f96, #2b4a83);\n    box-shadow:\n      inset 0 0 14px #5481d3cc,\n      0 5px 20px rgba(0, 109, 243, 0.45);\n    color: var(--color-accent);\n    font-weight: 600;\n    font-size: 1.3rem;\n    text-align: center;\n    letter-spacing: 0.06em;\n    user-select: none;\n    font-family: 'Courier New', Courier, monospace;\n    position: relative;\n  }\n\n  .hash-function::before {\n    content: \"hash(key) = \";\n    position: absolute;\n    left: 24px;\n    top: 50%;\n    transform: translateY(-50%);\n    color: #88c9f9;\n    font-weight: 700;\n    font-size: 1.5rem;\n    text-shadow: 0 0 8px #55acffba;\n  }\n\n  /* Button controls */\n  .controls {\n    margin-top: 40px;\n    text-align: center;\n  }\n\n  button {\n    background: linear-gradient(145deg, #50e3c2cc, #4ac2bbcc);\n    border: none;\n    padding: 14px 28px;\n    border-radius: 34px;\n    font-weight: 600;\n    font-size: 1.15rem;\n    color: var(--color-text-dark);\n    cursor: pointer;\n    box-shadow:\n      0 8px 20px #42b8b8cc,\n      inset 0 3px 6px #7febf2aa;\n    transition:\n      background-color 0.32s ease,\n      box-shadow 0.32s ease,\n      transform 0.3s ease;\n    user-select: none;\n    letter-spacing: 0.06em;\n  }\n\n  button:hover {\n    background: linear-gradient(145deg, #50e3c249, #48c8b7bb);\n    box-shadow:\n      0 12px 28px #34aaa4dd,\n      inset 0 4px 9px #82f0e5cc;\n    transform: translateY(-2px);\n  }\n\n  button:active {\n    background: linear-gradient(145deg, #44b9abcc, #3ca495cc);\n    box-shadow:\n      0 4px 10px #298b7cbb,\n      inset 0 2px 5px #5cb8a9bb;\n    transform: translateY(0);\n  }\n\n  /* Animations */\n  @keyframes fadeInUp {\n    0% {\n      opacity: 0;\n      transform: translateY(10px) translateZ(0);\n    }\n    100% {\n      opacity: 1;\n      transform: translateY(0) translateZ(0);\n    }\n  }\n\n  @keyframes pulseArrow {\n    0% {\n      opacity: 0.4;\n      filter: drop-shadow(0 0 3px var(--color-secondary));\n    }\n    50% {\n      opacity: 1;\n      filter: drop-shadow(0 0 8px var(--color-primary));\n    }\n    100% {\n      opacity: 0.4;\n      filter: drop-shadow(0 0 3px var(--color-secondary));\n    }\n  }\n\n  /* Footer credit */\n  footer {\n    margin-top: 40px;\n    text-align: center;\n    font-weight: 300;\n    font-size: 0.9rem;\n    letter-spacing: 0.07em;\n    color: #314e80bb;\n    user-select: none;\n  }\n\n  footer a {\n    color: #50d1c6cc;\n    font-weight: 600;\n    text-decoration: none;\n    transition: color 0.3s ease;\n  }\n\n  footer a:hover {\n    color: #79e8d1ff;\n    text-shadow: 0 0 5px #6de3cebb;\n  }\n</style>\n</head>\n<body>\n  <section class=\"container\" role=\"main\" aria-label=\"Hash Map Visualization\">\n    <header>\n      <h1>HASH MAP</h1>\n      <p>Efficient Key-Value Lookup Structure</p>\n    </header>\n    <main>\n      <section class=\"hashmap-visual\" aria-label=\"Hash Map buckets and chains\">\n        <h2>Buckets (Hash Table)</h2>\n        <div class=\"buckets\" id=\"buckets\" aria-live=\"polite\" aria-relevant=\"additions removals\">\n          <!-- Buckets will be populated here by JS -->\n        </div>\n        <div class=\"hash-function\" aria-label=\"Hash function\">\n          <code> (key &times; 2654435761) mod 8 </code>\n        </div>\n      </section>\n\n      <div class=\"controls\" aria-label=\"Interactive controls\">\n        <button id=\"shuffleBtn\" aria-pressed=\"false\" aria-live=\"polite\">Shuffle Values</button>\n      </div>\n    </main>\n    <footer>\n      <small>Concept visualization by &copy; 2024 - <a href=\"https://github.com\" target=\"_blank\" rel=\"noopener noreferrer\">Creative Dev</a></small>\n    </footer>\n  </section>\n\n<script>\n  (() => {\n    const bucketsCount = 8;\n\n    // Sample fixed keys with initial values for display\n    // Keys and values mimic typical hash map example data\n    // Collisions deliberately present: keys share same bucket index\n    const entries = [\n      { key: \"apple\", value: \"fruit\" },\n      { key: \"car\", value: \"vehicle\" },\n      { key: \"dog\", value: \"animal\" },\n      { key: \"blue\", value: \"color\" },\n      { key: \"table\", value: \"furniture\" },\n      { key: \"java\", value: \"language\" },\n      { key: \"cat\", value: \"animal\" },\n      { key: \"dogma\", value: \"belief\" },\n      { key: \"ruby\", value: \"gem\" },\n      { key: \"fish\", value: \"animal\" },\n      { key: \"green\", value: \"color\" },\n      { key: \"bus\", value: \"vehicle\" },\n    ];\n\n    // Simple hash function mod bucketsCount:\n    // (String char codes sum * prime) mod bucketsCount\n    function hashKey(key) {\n      let sum = 0;\n      for(let i = 0; i < key.length; i++) {\n        sum += key.charCodeAt(i);\n      }\n      return (sum * 2654435761) % bucketsCount; // multiplicative hash constant\n    }\n\n    // Structure buckets as array of arrays (chains)\n    const chains = Array.from({ length: bucketsCount }, () => []);\n\n    entries.forEach(({key, value}) => {\n      const index = hashKey(key) >>> 0 % bucketsCount;\n      chains[index].push({ key, value });\n    });\n\n    const bucketsContainer = document.getElementById(\"buckets\");\n\n    // Create bucket elements with chained pairs visual\n    function renderBuckets() {\n      bucketsContainer.innerHTML = \"\";\n      chains.forEach((bucketItems, idx) => {\n        const bucketEl = document.createElement(\"section\");\n        bucketEl.classList.add(\"bucket\");\n        bucketEl.setAttribute(\"aria-label\", `Bucket index ${idx}, contains ${bucketItems.length} item${bucketItems.length !== 1 ? \"s\" : \"\"}`);\n        bucketEl.setAttribute(\"role\", \"list\");\n        bucketEl.dataset.idx = idx;\n\n        const indexLabel = document.createElement(\"div\");\n        indexLabel.className = \"bucket-index\";\n        indexLabel.textContent = `#${idx}`;\n        bucketEl.appendChild(indexLabel);\n\n        if(bucketItems.length === 0) {\n          // Empty bucket placeholder - subtle glow\n          const emptyMsg = document.createElement(\"div\");\n          emptyMsg.style = \"color:#425a92bb; font-style: italic; font-weight: 400; font-size: 0.94rem; padding-top: 44px; user-select:none; text-align:center\";\n          emptyMsg.textContent = \"Empty\";\n          bucketEl.appendChild(emptyMsg);\n        } else {\n          // Show chain of pairs\n          const chainEl = document.createElement(\"div\");\n          chainEl.className = \"chain\";\n          bucketItems.forEach(({key, value}) => {\n            const pairEl = document.createElement(\"div\");\n            pairEl.className = \"pair\";\n            pairEl.setAttribute(\"role\", \"listitem\");\n            pairEl.title = `Key: ${key}, Value: ${value}`;\n\n            const keySpan = document.createElement(\"div\");\n            keySpan.className = \"key\";\n            keySpan.textContent = key;\n\n            const valueSpan = document.createElement(\"div\");\n            valueSpan.className = \"value\";\n            valueSpan.textContent = value;\n\n            pairEl.appendChild(keySpan);\n            pairEl.appendChild(valueSpan);\n            chainEl.appendChild(pairEl);\n          });\n          bucketEl.appendChild(chainEl);\n        }\n        bucketsContainer.appendChild(bucketEl);\n      });\n    }\n\n    // Animate a highlight for buckets on shuffle\n    function highlightRandomBucket() {\n      // Remove any current highlight\n      Array.from(bucketsContainer.children).forEach(b => b.classList.remove(\"highlighted\"));\n      // Pick random bucket index with items\n      let candidateBuckets = [];\n      chains.forEach((chain, idx) => {\n        if(chain.length > 0) candidateBuckets.push(idx);\n      });\n      if(candidateBuckets.length === 0) return;\n      const randomIdx = candidateBuckets[Math.floor(Math.random() * candidateBuckets.length)];\n      const bucketEl = bucketsContainer.querySelector(`.bucket[data-idx=\"${randomIdx}\"]`);\n      if(bucketEl) {\n        bucketEl.classList.add(\"highlighted\");\n      }\n    }\n\n    // Shuffle values within chains randomly\n    function shuffleValues() {\n      chains.forEach(chain => {\n        if(chain.length > 1) {\n          for(let i = chain.length - 1; i > 0; i--) {\n            const j = Math.floor(Math.random() * (i + 1));\n            [chain[i].value, chain[j].value] = [chain[j].value, chain[i].value];\n          }\n        }\n      });\n    }\n\n    // Initialize visualization\n    function init() {\n      renderBuckets();\n      highlightRandomBucket();\n    }\n\n    // Button to shuffle values (limited interactivity)\n    const shuffleBtn = document.getElementById(\"shuffleBtn\");\n    shuffleBtn.addEventListener(\"click\", () => {\n      shuffleValues();\n      renderBuckets();\n      highlightRandomBucket();\n    });\n\n    // On load\n    window.requestAnimationFrame(init);\n  })();\n</script>\n</body>\n</html>"
