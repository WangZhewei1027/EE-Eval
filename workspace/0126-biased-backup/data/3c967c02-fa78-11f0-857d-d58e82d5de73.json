    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Priority Queue Visualization — Elegant Showcase</title>\n<style>\n  /* Importing a refined serif font for headings and a clean sans-serif for body */\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body, html {\n    margin: 0; padding: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #1f2937, #111827);\n    font-family: 'Inter', sans-serif;\n    color: #e0e7ff;\n    overflow-x: hidden;\n  }\n\n  /* Container */\n  .container {\n    max-width: 980px;\n    margin: 3.5rem auto 5rem;\n    padding: 0 2rem;\n    text-align: center;\n  }\n\n  /* Header */\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.5rem;\n    letter-spacing: 0.06em;\n    margin-bottom: 0.25em;\n    color: #a5b4fc;\n    text-shadow:\n      0 0 6px #818cf8aa,\n      0 2px 8px #4338ca88;\n  }\n  h2 {\n    font-weight: 600;\n    font-size: 1.25rem;\n    color: #c7d2fe;\n    margin-bottom: 3rem;\n    font-style: italic;\n    letter-spacing: 0.01em;\n  }\n\n  /* Priority Queue Visualization */\n\n  .pq-container {\n    position: relative;\n    margin: 0 auto 4rem;\n    width: 100%;\n    max-width: 880px;\n    height: 240px;\n    padding: 2rem 1rem;\n    background: linear-gradient(120deg, #3730a3, #4f46e5);\n    border-radius: 24px;\n    box-shadow:\n      0 12px 40px #4338ca88,\n      inset 0 0 30px #818cf8aa;\n  }\n\n  /* Priority queue label - subtle top text */\n  .pq-label {\n    position: absolute;\n    top: 18px;\n    left: 2.5rem;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: #dbeafeee;\n    text-shadow: 0 0 7px #c7d2fee0;\n    letter-spacing: 0.06em;\n  }\n\n  /* The queue \"slots\" container horizontally aligned */\n  .queue-slots {\n    height: 100%;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    gap: 1.05rem;\n    perspective: 900px;\n  }\n\n  /* Individual slot */\n  .slot {\n    position: relative;\n    width: 75px;\n    height: 180px;\n    background: linear-gradient(180deg, #312e81, #6366f1);\n    border-radius: 16px;\n    box-shadow:\n      inset 0 7px 10px #a5b4fcaa,\n      0 8px 20px #292a73bb;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    overflow: visible;\n    user-select: none;\n    transform-style: preserve-3d;\n    transition:\n      transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.4s ease;\n  }\n  .slot:hover {\n    transform: translateY(-12px) rotateX(8deg) rotateY(15deg);\n    box-shadow:\n      0 16px 35px #a5b4fccc,\n      inset 0 9px 22px #c7d2feee;\n  }\n  .slot:nth-child(even) {\n    transform-origin: center bottom;\n  }\n  .slot:nth-child(odd) {\n    transform-origin: center bottom;\n  }\n\n  /* Priority value bar (height corresponds to priority) */\n  .priority-bar {\n    margin: 0 auto 1.1rem;\n    width: 62px;\n    border-radius: 12px;\n    background: linear-gradient(145deg, #a5b4fc, #818cf8);\n    box-shadow: 0 4px 9px #818cf833;\n    transition: height 0.8s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  /* The content block with item number & priority on \"glass panel\" */\n  .info-panel {\n    font-weight: 600;\n    font-family: 'Inter', sans-serif;\n    font-size: 1rem;\n    color: #eef2ffee;\n    padding: 0.3rem 0.6rem;\n    border-radius: 12px;\n    backdrop-filter: blur(10px);\n    background: rgba(255 255 255 / 0.10);\n    box-shadow:\n      inset 0 0 7px #c7d2fe55,\n      0 0 8px #a5b4fc99;\n    user-select: none;\n  }\n  .info-panel span {\n    display: block;\n    letter-spacing: 0.04em;\n  }\n  .info-panel .item-id {\n    font-size: 1.3rem;\n    font-weight: 700;\n    color: #eef2ffdd;\n  }\n\n  /* Fade in animation */\n  @keyframes fadeInUp {\n    from {\n      opacity: 0;\n      transform: translateY(35px);\n    }\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n  .slot {\n    animation: fadeInUp 1s ease forwards;\n  }\n  .slot:nth-child(1) { animation-delay: 0.1s; }\n  .slot:nth-child(2) { animation-delay: 0.15s; }\n  .slot:nth-child(3) { animation-delay: 0.2s; }\n  .slot:nth-child(4) { animation-delay: 0.25s; }\n  .slot:nth-child(5) { animation-delay: 0.3s; }\n  .slot:nth-child(6) { animation-delay: 0.35s; }\n  .slot:nth-child(7) { animation-delay: 0.4s; }\n\n  /* Controls at bottom */\n  .controls {\n    margin-top: 3rem;\n    display: flex;\n    justify-content: center;\n    gap: 2rem;\n  }\n  button {\n    padding: 0.8rem 2.5rem;\n    border-radius: 30px;\n    border: none;\n    font-weight: 600;\n    font-family: 'Inter', sans-serif;\n    font-size: 1.05rem;\n    cursor: pointer;\n    transition:\n      background-color 0.3s ease,\n      transform 0.2s ease,\n      box-shadow 0.3s ease;\n    box-shadow:\n      0 5px 15px #6366fbbf;\n    user-select: none;\n  }\n  button:focus-visible {\n    outline: 3px solid #a5b4fcff;\n    outline-offset: 2px;\n  }\n  button:active {\n    transform: scale(0.96);\n    box-shadow: 0 3px 8px #4f46e5cc;\n  }\n\n  button#enqueue {\n    background-color: #6366f1;\n    color: #eef2ffee;\n    filter: drop-shadow(0 0 4px #818cf8);\n  }\n  button#enqueue:hover {\n    background-color: #818cf8;\n    box-shadow: 0 8px 24px #818cfeba;\n  }\n  button#dequeue {\n    background-color: #474973;\n    color: #c7d2fecc;\n    filter: drop-shadow(0 0 3px #474973aa);\n  }\n  button#dequeue:hover {\n    background-color: #6366f1;\n    color: #eef2ffdd;\n    box-shadow: 0 8px 20px #6366f1cc;\n  }\n\n  /* Footer tiny textual note */\n  footer {\n    font-size: 0.85rem;\n    color: #94a3b8;\n    text-align: center;\n    margin-bottom: 2rem;\n    user-select: none;\n    font-style: italic;\n  }\n  \n  /* Tooltip styling for priority explanation */\n  .tooltip {\n    position: fixed;\n    bottom: 1rem;\n    right: 1rem;\n    max-width: 320px;\n    font-size: 0.9rem;\n    background: #1e40afdd;\n    color: #dbeafe;\n    border-radius: 16px;\n    padding: 1rem 1.3rem;\n    backdrop-filter: blur(16px);\n    box-shadow: 0 4px 24px #3442bcaa;\n    text-align: left;\n    line-height: 1.35;\n    font-family: 'Inter', sans-serif;\n    user-select: none;\n    pointer-events: none;\n    filter: drop-shadow(0 2px 6px #1e40af99);\n  }\n  .tooltip strong {\n    color: #c7d2fe;\n  }\n</style>\n</head>\n<body>\n  <main class=\"container\" role=\"main\" aria-label=\"Priority Queue Demonstration\">\n    <h1>Priority Queue</h1>\n    <h2>An Elegant Visualization of Priority Ordering</h2>\n\n    <section class=\"pq-container\" aria-label=\"Priority queue visual representation\">\n      <div class=\"pq-label\">Queue (Highest Priority → Lowest Priority)</div>\n      <div class=\"queue-slots\" id=\"queueSlots\" aria-live=\"polite\" aria-relevant=\"additions removals\">\n        <!-- Dynamically populated -->\n      </div>\n    </section>\n\n    <section class=\"controls\" aria-label=\"Priority queue controls\">\n      <button id=\"enqueue\" type=\"button\" title=\"Add new item with random priority to the queue\">Enqueue Item</button>\n      <button id=\"dequeue\" type=\"button\" title=\"Remove highest priority item from the queue\">Dequeue Item</button>\n    </section>\n  </main>\n\n  <aside class=\"tooltip\" aria-hidden=\"true\" role=\"note\">\n    <strong>Priority Queue Concept:</strong><br />\n    Items are ordered by <em>priority</em>. The highest priority elements are served before lower priority ones.<br />\n    Here, each block’s height visually encodes its priority level.\n  </aside>\n\n<script>\n  /*\n  Priority Queue Visualization with minimal interactivity:\n  - Enqueue: adds an item with random priority (1-9)\n  - Dequeue: removes the highest priority item (lowest number)\n  */\n\n  const MAX_PRIORITY = 9;\n  const MIN_PRIORITY = 1;\n\n  // Container holding queue slots\n  const queueSlots = document.getElementById('queueSlots');\n  const enqueueBtn = document.getElementById('enqueue');\n  const dequeueBtn = document.getElementById('dequeue');\n\n  // Internal queue structure: array of {id:Number, priority:Number}\n  // Smaller priority number = higher priority\n  let itemIdCounter = 0;\n  let priorityQueue = [];\n\n  // Smooth ease function for height scale (for aesthetics)\n  function scalePriorityToHeight(priority) {\n    // priority from 1 (highest) to 9 (lowest)\n    // want taller bar for lower number, max 160px height down to 30px\n    return 160 - ((priority - 1) / (MAX_PRIORITY - 1)) * 130;\n  }\n\n  // Create HTML element for one queue slot\n  function createSlot(item) {\n    const slot = document.createElement('article');\n    slot.classList.add('slot');\n    slot.setAttribute('tabindex', '-1');\n    slot.setAttribute('aria-label', `Item ${item.id}, Priority ${item.priority}`);\n\n    const bar = document.createElement('div');\n    bar.classList.add('priority-bar');\n    bar.style.height = scalePriorityToHeight(item.priority) + 'px';\n    bar.style.background = createGradientForPriority(item.priority);\n\n    const infoPanel = document.createElement('div');\n    infoPanel.classList.add('info-panel');\n    infoPanel.innerHTML = `\n      <span class=\"item-id\">#${item.id}</span>\n      <span class=\"item-priority\">Priority: ${item.priority}</span>\n    `;\n\n    slot.appendChild(bar);\n    slot.appendChild(infoPanel);\n\n    return slot;\n  }\n\n  // Gradient colors reflecting high to low priority (cool blue → violet → soft purple)\n  function createGradientForPriority(priority) {\n    const blueStart = [101, 116, 247]; // #6574f7\n    const violetMid = [139, 92, 246]; // #8b5cf6\n    const purpleEnd = [129, 140, 248]; //\" #818cf8\"\n\n    // Interpolate color depending on priority range (1-9)\n    // Priority 1 → blueStart, Priority 5 → violetMid, Priority 9 → purpleEnd\n    let r, g, b;\n    if(priority <= 5) {\n      const t = (priority - 1) / 4;\n      r = lerp(blueStart[0], violetMid[0], t);\n      g = lerp(blueStart[1], violetMid[1], t);\n      b = lerp(blueStart[2], violetMid[2], t);\n    } else {\n      const t = (priority - 5) / 4;\n      r = lerp(violetMid[0], purpleEnd[0], t);\n      g = lerp(violetMid[1], purpleEnd[1], t);\n      b = lerp(violetMid[2], purpleEnd[2], t);\n    }\n    return `linear-gradient(145deg, rgb(${r},${g},${b}) 30%, rgba(${r},${g},${b},0.8) 90%)`;\n  }\n  // Linear interpolation helper\n  function lerp(a,b,t) {\n    return Math.round(a + (b - a) * t);\n  }\n\n  // Render entire queue UI from priorityQueue array\n  function renderQueue() {\n    // Clear container\n    queueSlots.innerHTML = '';\n\n    // Sort by priority ascending (lowest first)\n    priorityQueue.sort((a,b) => a.priority - b.priority || a.id - b.id);\n\n    // For smooth animation & visual spacing, stagger insertions\n    priorityQueue.forEach(item => {\n      const slot = createSlot(item);\n      queueSlots.appendChild(slot);\n    });\n\n    // Controls enable: Enqueue always enabled, dequeue enabled if queue not empty\n    dequeueBtn.disabled = priorityQueue.length === 0;\n  }\n\n  // Enqueue: add new random item with random priority and unique ID\n  function enqueueItem() {\n    if(priorityQueue.length >= 7) {\n      // Limit at 7 for visual clarity\n      alert('Maximum of 7 items in queue reached.');\n      return;\n    }\n    itemIdCounter++;\n    const randomPriority = randomInt(MIN_PRIORITY, MAX_PRIORITY);\n    priorityQueue.push({id: itemIdCounter, priority: randomPriority});\n    renderQueue();\n  }\n\n  // Dequeue: remove item with highest priority (lowest priority number)\n  function dequeueItem() {\n    if(priorityQueue.length === 0) return;\n    // Find highest priority item (lowest priority value)\n    priorityQueue.sort((a,b) => a.priority - b.priority || a.id - b.id);\n    priorityQueue.shift();\n    renderQueue();\n  }\n\n  // Random integer in range [min, max]\n  function randomInt(min, max) {\n    return Math.floor(Math.random() * (max - min + 1)) + min;\n  }\n\n  // Initialize with some items for demonstration on load\n  function initQueue() {\n    priorityQueue = [\n      {id: ++itemIdCounter, priority: 2},\n      {id: ++itemIdCounter, priority: 4},\n      {id: ++itemIdCounter, priority: 1},\n      {id: ++itemIdCounter, priority: 7},\n      {id: ++itemIdCounter, priority: 3},\n      {id: ++itemIdCounter, priority: 6},\n    ];\n    renderQueue();\n  }\n\n  // Event listeners\n  enqueueBtn.addEventListener('click', () => {\n    enqueueItem();\n  });\n\n  dequeueBtn.addEventListener('click', () => {\n    dequeueItem();\n  });\n\n  // Initialize on page load\n  window.addEventListener('load', () => {\n    initQueue();\n  });\n</script>\n</body>\n</html>"
