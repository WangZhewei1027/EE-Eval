    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Logistic Regression</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/numeric@1.2.6/numeric.min.js\"></script>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .container { display: flex; flex-wrap: wrap; gap: 20px; }\n        .panel { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; }\n        canvas { border: 1px solid #000; }\n        button, input, select { margin: 5px; }\n        .data-point { cursor: pointer; }\n    </style>\n</head>\n<body>\n    <h1>Interactive Logistic Regression</h1>\n    \n    <div class=\"container\">\n        <div class=\"panel\" style=\"flex: 1;\">\n            <h2>Data Configuration</h2>\n            <div>\n                <button id=\"addRandomData\">Add Random Data</button>\n                <button id=\"clearData\">Clear Data</button>\n                <button id=\"toggleClass\">Toggle Class (Click Mode)</button>\n                <div>\n                    Points per class: <input type=\"number\" id=\"pointsPerClass\" value=\"20\" min=\"1\" max=\"100\">\n                    Noise level: <input type=\"number\" id=\"noiseLevel\" value=\"0.2\" min=\"0\" max=\"1\" step=\"0.05\">\n                </div>\n            </div>\n            \n            <h2>Model Parameters</h2>\n            <div>\n                Learning rate: <input type=\"number\" id=\"learningRate\" value=\"0.1\" min=\"0.001\" max=\"1\" step=\"0.01\">\n                <button id=\"trainOneStep\">Train One Step</button>\n                <button id=\"trainMultiple\">Train 100 Steps</button>\n                <button id=\"resetWeights\">Reset Weights</button>\n            </div>\n            \n            <h2>Decision Boundary</h2>\n            <div>\n                Threshold: <input type=\"range\" id=\"threshold\" min=\"0\" max=\"1\" value=\"0.5\" step=\"0.01\">\n                <span id=\"thresholdValue\">0.5</span>\n                <button id=\"toggleBoundary\">Show/Hide Boundary</button>\n            </div>\n            \n            <h2>Current Weights</h2>\n            <div id=\"weightsDisplay\">\n                w0: <span id=\"w0\">0.00</span>,\n                w1: <span id=\"w1\">0.00</span>,\n                w2: <span id=\"w2\">0.00</span>\n            </div>\n            \n            <h2>Model Evaluation</h2>\n            <div id=\"metrics\">\n                Accuracy: <span id=\"accuracy\">0%</span><br>\n                Loss: <span id=\"loss\">-</span><br>\n                Precision: <span id=\"precision\">-</span><br>\n                Recall: <span id=\"recall\">-</span>\n            </div>\n        </div>\n        \n        <div class=\"panel\" style=\"flex: 2;\">\n            <canvas id=\"scatterPlot\" width=\"600\" height=\"500\"></canvas>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let dataPoints = [];\n        let currentClass = 0;\n        let weights = [0, 0, 0]; // w0 (bias), w1, w2\n        let showBoundary = true;\n        let scatterChart;\n        let boundaryLine = null;\n        \n        // Initialize chart\n        function initChart() {\n            const ctx = document.getElementById('scatterPlot').getContext('2d');\n            scatterChart = new Chart(ctx, {\n                type: 'scatter',\n                data: {\n                    datasets: [\n                        {\n                            label: 'Class 0',\n                            data: [],\n                            backgroundColor: 'rgba(0, 0, 0, 0.7)',\n                            pointRadius: 6\n                        },\n                        {\n                            label: 'Class 1',\n                            data: [],\n                            backgroundColor: 'rgba(150, 150, 150, 0.7)',\n                            pointRadius: 6\n                        }\n                    ]\n                },\n                options: {\n                    responsive: false,\n                    scales: {\n                        x: { min: -5, max: 5 },\n                        y: { min: -5, max: 5 }\n                    },\n                    onClick: (e) => addDataPoint(e),\n                    plugins: {\n                        tooltip: {\n                            callbacks: {\n                                label: (context) => {\n                                    const point = dataPoints.find(p => \n                                        Math.abs(p.x - context.parsed.x) < 0.01 && \n                                        Math.abs(p.y - context.parsed.y) < 0.01\n                                    );\n                                    return `Class: ${point.class}, X: ${point.x.toFixed(2)}, Y: ${point.y.toFixed(2)}`;\n                                }\n                            }\n                        }\n                    }\n                }\n            });\n        }\n        \n        // Add data point on click\n        function addDataPoint(event) {\n            if (!document.getElementById('toggleClass').classList.contains('active')) return;\n            \n            const rect = scatterChart.canvas.getBoundingClientRect();\n            const x = (event.clientX - rect.left) / rect.width * 10 - 5;\n            const y = 5 - (event.clientY - rect.top) / rect.height * 10;\n            \n            dataPoints.push({ x, y, class: currentClass });\n            updateChart();\n            updateMetrics();\n        }\n        \n        // Add random data\n        function addRandomData() {\n            const count = parseInt(document.getElementById('pointsPerClass').value);\n            const noise = parseFloat(document.getElementById('noiseLevel').value);\n            \n            for (let c = 0; c <= 1; c++) {\n                for (let i = 0; i < count; i++) {\n                    let x, y;\n                    if (Math.random() < noise) {\n                        // Noise point\n                        x = (Math.random() * 8) - 4;\n                        y = (Math.random() * 8) - 4;\n                    } else {\n                        // Class-specific distribution\n                        x = (Math.random() * 3) - 1.5 + (c * 2);\n                        y = (Math.random() * 3) - 1.5 + (c * 2);\n                    }\n                    dataPoints.push({ x, y, class: c });\n                }\n            }\n            updateChart();\n            updateMetrics();\n        }\n        \n        // Clear all data\n        function clearData() {\n            dataPoints = [];\n            updateChart();\n            updateMetrics();\n        }\n        \n        // Toggle class for new points\n        function toggleClass() {\n            const btn = document.getElementById('toggleClass');\n            currentClass = 1 - currentClass;\n            btn.classList.toggle('active');\n            btn.textContent = `Add to Class ${currentClass} (Click Mode)`;\n        }\n        \n        // Update chart with current data\n        function updateChart() {\n            scatterChart.data.datasets[0].data = dataPoints\n                .filter(p => p.class === 0)\n                .map(p => ({ x: p.x, y: p.y }));\n                \n            scatterChart.data.datasets[1].data = dataPoints\n                .filter(p => p.class === 1)\n                .map(p => ({ x: p.x, y: p.y }));\n                \n            scatterChart.update();\n            \n            if (showBoundary) {\n                drawDecisionBoundary();\n            } else if (boundaryLine) {\n                boundaryLine.remove();\n                boundaryLine = null;\n            }\n        }\n        \n        // Draw decision boundary\n        function drawDecisionBoundary() {\n            if (boundaryLine) boundaryLine.remove();\n            \n            const threshold = parseFloat(document.getElementById('threshold').value);\n            const ctx = scatterChart.canvas.getContext('2d');\n            \n            // For logistic regression, the decision boundary is w0 + w1*x + w2*y = 0\n            // We'll draw this line across the chart\n            \n            const w0 = weights[0], w1 = weights[1], w2 = weights[2];\n            \n            if (w1 === 0 && w2 === 0) return; // No boundary yet\n            \n            // Find two points on the boundary line\n            let x1 = -5, y1, x2 = 5, y2;\n            \n            if (w2 !== 0) {\n                y1 = (-w0 - w1 * x1) / w2;\n                y2 = (-w0 - w1 * x2) / w2;\n            } else {\n                // Vertical line\n                x1 = x2 = -w0 / w1;\n                y1 = -5;\n                y2 = 5;\n            }\n            \n            // Convert to canvas coordinates\n            const rect = scatterChart.canvas.getBoundingClientRect();\n            const scaleX = rect.width / 10;\n            const scaleY = rect.height / 10;\n            \n            const canvasX1 = (x1 + 5) * scaleX;\n            const canvasY1 = (5 - y1) * scaleY;\n            const canvasX2 = (x2 + 5) * scaleX;\n            const canvasY2 = (5 - y2) * scaleY;\n            \n            // Draw the line\n            ctx.beginPath();\n            ctx.moveTo(canvasX1, canvasY1);\n            ctx.lineTo(canvasX2, canvasY2);\n            ctx.strokeStyle = 'red';\n            ctx.lineWidth = 2;\n            ctx.stroke();\n            \n            boundaryLine = { remove: () => {\n                scatterChart.update(); // Forces redraw without the line\n            }};\n        }\n        \n        // Sigmoid function\n        function sigmoid(z) {\n            return 1 / (1 + Math.exp(-z));\n        }\n        \n        // Compute predictions for all points\n        function predictAll() {\n            return dataPoints.map(point => {\n                const z = weights[0] + weights[1] * point.x + weights[2] * point.y;\n                return sigmoid(z);\n            });\n        }\n        \n        // Train one step of gradient descent\n        function trainOneStep() {\n            if (dataPoints.length === 0) return;\n            \n            const learningRate = parseFloat(document.getElementById('learningRate').value);\n            const predictions = predictAll();\n            \n            // Initialize gradients\n            let dw0 = 0, dw1 = 0, dw2 = 0;\n            \n            // Compute gradients\n            for (let i = 0; i < dataPoints.length; i++) {\n                const point = dataPoints[i];\n                const error = predictions[i] - point.class;\n                \n                dw0 += error;\n                dw1 += error * point.x;\n                dw2 += error * point.y;\n            }\n            \n            // Update weights\n            weights[0] -= learningRate * dw0 / dataPoints.length;\n            weights[1] -= learningRate * dw1 / dataPoints.length;\n            weights[2] -= learningRate * dw2 / dataPoints.length;\n            \n            updateWeightsDisplay();\n            updateChart();\n            updateMetrics();\n        }\n        \n        // Train multiple steps\n        function trainMultiple() {\n            const steps = 100;\n            for (let i = 0; i < steps; i++) {\n                trainOneStep();\n            }\n        }\n        \n        // Reset weights to zero\n        function resetWeights() {\n            weights = [0, 0, 0];\n            updateWeightsDisplay();\n            updateChart();\n            updateMetrics();\n        }\n        \n        // Toggle decision boundary visibility\n        function toggleBoundary() {\n            showBoundary = !showBoundary;\n            updateChart();\n        }\n        \n        // Update weights display\n        function updateWeightsDisplay() {\n            document.getElementById('w0').textContent = weights[0].toFixed(4);\n            document.getElementById('w1').textContent = weights[1].toFixed(4);\n            document.getElementById('w2').textContent = weights[2].toFixed(4);\n        }\n        \n        // Update model metrics\n        function updateMetrics() {\n            if (dataPoints.length === 0) {\n                document.getElementById('accuracy').textContent = '0%';\n                document.getElementById('loss').textContent = '-';\n                document.getElementById('precision').textContent = '-';\n                document.getElementById('recall').textContent = '-';\n                return;\n            }\n            \n            const threshold = parseFloat(document.getElementById('threshold').value);\n            const predictions = predictAll();\n            \n            let truePos = 0, trueNeg = 0, falsePos = 0, falseNeg = 0;\n            \n            for (let i = 0; i < dataPoints.length; i++) {\n                const predictedClass = predictions[i] >= threshold ? 1 : 0;\n                const actualClass = dataPoints[i].class;\n                \n                if (predictedClass === 1 && actualClass === 1) truePos++;\n                if (predictedClass === 0 && actualClass === 0) trueNeg++;\n                if (predictedClass === 1 && actualClass === 0) falsePos++;\n                if (predictedClass === 0 && actualClass === 1) falseNeg++;\n            }\n            \n            const accuracy = (truePos + trueNeg) / dataPoints.length;\n            const precision = truePos / (truePos + falsePos) || 0;\n            const recall = truePos / (truePos + falseNeg) || 0;\n            \n            // Calculate cross-entropy loss\n            let loss = 0;\n            for (let i = 0; i < dataPoints.length; i++) {\n                const y = dataPoints[i].class;\n                const p = predictions[i];\n                loss += y * Math.log(p) + (1 - y) * Math.log(1 - p);\n            }\n            loss = -loss / dataPoints.length;\n            \n            document.getElementById('accuracy').textContent = `${(accuracy * 100).toFixed(1)}%`;\n            document.getElementById('loss').textContent = loss.toFixed(4);\n            document.getElementById('precision').textContent = precision.toFixed(3);\n            document.getElementById('recall').textContent = recall.toFixed(3);\n        }\n        \n        // Event listeners\n        document.getElementById('addRandomData').addEventListener('click', addRandomData);\n        document.getElementById('clearData').addEventListener('click', clearData);\n        document.getElementById('toggleClass').addEventListener('click', toggleClass);\n        document.getElementById('trainOneStep').addEventListener('click', trainOneStep);\n        document.getElementById('trainMultiple').addEventListener('click', trainMultiple);\n        document.getElementById('resetWeights').addEventListener('click', resetWeights);\n        document.getElementById('toggleBoundary').addEventListener('click', toggleBoundary);\n        document.getElementById('threshold').addEventListener('input', function() {\n            document.getElementById('thresholdValue').textContent = this.value;\n            updateChart();\n            updateMetrics();\n        });\n        \n        // Initialize\n        initChart();\n        updateWeightsDisplay();\n        updateMetrics();\n    </script>\n</body>\n</html>"
  },
