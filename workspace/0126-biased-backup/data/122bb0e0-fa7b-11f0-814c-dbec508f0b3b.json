    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bucket Sort</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #f0f0f0;\n            margin: 20px;\n        }\n        label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        input[type=\"number\"] {\n            width: 100px;\n            margin-bottom: 20px;\n        }\n        button {\n            width: 100px;\n            height: 30px;\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <h1>Bucket Sort</h1>\n    <p>Enter the number of elements:</p>\n    <input type=\"number\" id=\"numElements\" value=\"10\">\n    <button id=\"sortButton\">Sort</button>\n    <p id=\"sortedArray\"></p>\n    <p id=\"errorMessage\"></p>\n\n    <script>\n        const numElements = parseInt(document.getElementById('numElements').value);\n        if (isNaN(numElements) || numElements <= 0) {\n            document.getElementById('errorMessage').textContent = 'Please enter a positive integer.';\n            return;\n        }\n\n        const array = Array.from({ length: numElements }, () => Math.floor(Math.random() * 101));\n        document.getElementById('sortedArray').textContent = 'Unsorted Array: ';\n        for (const element of array) {\n            document.getElementById('sortedArray').textContent += element + ' ';\n        }\n        document.getElementById('sortedArray').textContent += '\\n';\n\n        const errorElement = document.getElementById('errorMessage');\n        errorElement.textContent = '';\n\n        const sortButton = document.getElementById('sortButton');\n        sortButton.addEventListener('click', () => {\n            try {\n                const sortedArray = bucketSort(array);\n                document.getElementById('sortedArray').textContent = 'Sorted Array: ';\n                for (const element of sortedArray) {\n                    document.getElementById('sortedArray').textContent += element + ' ';\n                }\n                document.getElementById('sortedArray').textContent += '\\n';\n                errorElement.textContent = '';\n            } catch (error) {\n                document.getElementById('errorMessage').textContent = error.message;\n            }\n        });\n    </script>\n\n    function bucketSort(array) {\n        const bucket = [];\n        for (const element of array) {\n            const index = Math.floor(element / 10);\n            if (index >= 0) {\n                bucket.push(element % 10);\n            } else {\n                bucket.push(element % 10);\n            }\n        }\n        return bucket;\n    }\n</body>\n</html>"
