    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Big-O Notation Visualizer</title>\n    <style>\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n        }\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(135deg, #4a90e2, #d4d4d4);\n            color: #333;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        h1 {\n            font-size: 3rem;\n            color: #fff;\n            margin-bottom: 20px;\n            text-align: center;\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);\n        }\n        h2 {\n            font-size: 2rem;\n            color: #fff;\n            margin-bottom: 30px;\n            text-align: center;\n        }\n        .graph-container {\n            width: 60%;\n            max-width: 800px;\n            height: 400px;\n            position: relative;\n            overflow: hidden;\n            border-radius: 15px;\n            background-color: rgba(255, 255, 255, 0.8);\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);\n        }\n        .line {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            height: 0;\n            background: linear-gradient(to right, #ff6b6b, #f7c6c7);\n            z-index: 1;\n            transition: height 0.5s ease-in-out;\n        }\n        button {\n            margin-top: 20px;\n            background-color: #4a90e2;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            font-size: 1.2rem;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n        }\n        button:hover {\n            background-color: #0056b3;\n        }\n        footer {\n            position: absolute;\n            bottom: 10px;\n            font-size: 0.8rem;\n            color: #fff;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Big-O Notation Visualizer</h1>\n    <h2>Observe Different Growth Rates</h2>\n    \n    <div class=\"graph-container\">\n        <div class=\"line\" id=\"line1\" style=\"width: 20%; opacity: 0.8;\"></div>\n        <div class=\"line\" id=\"line2\" style=\"width: 30%; opacity: 0.6;\"></div>\n        <div class=\"line\" id=\"line3\" style=\"width: 40%; opacity: 0.4;\"></div>\n    </div>\n    \n    <button id=\"startAnimation\">Start Animation</button>\n    \n    <footer>Visualizing Big-O Notation | © 2023</footer>\n\n    <script>\n        function animateGraphs() {\n            const line1 = document.getElementById(\"line1\");\n            const line2 = document.getElementById(\"line2\");\n            const line3 = document.getElementById(\"line3\");\n\n            line1.style.height = '40%';  // O(n)\n            line2.style.height = '70%';  // O(n log n)\n            line3.style.height = '90%';  // O(n^2)\n        }\n\n        document.getElementById(\"startAnimation\").onclick = animateGraphs;\n    </script>\n\n</body>\n</html>"
