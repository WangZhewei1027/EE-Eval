    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Overfitting</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #000;\n        }\n        input, button, select {\n            width: 100%;\n            padding: 10px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);\n        }\n        button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n        select {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);\n        }\n        select:hover {\n            background-color: #3e8e41;\n        }\n        .error {\n            color: #ff0000;\n            font-size: 12px;\n            margin-top: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Overfitting</h1>\n    <div id=\"controls\">\n        <label for=\"learning_rate\">Learning Rate:</label>\n        <input type=\"range\" id=\"learning_rate\" min=\"0.01\" max=\"0.1\" value=\"0.05\">\n        <span id=\"learning_rate_value\">0.05</span>\n        <br>\n        <label for=\"batch_size\">Batch Size:</label>\n        <input type=\"range\" id=\"batch_size\" min=\"32\" max=\"1024\" value=\"128\">\n        <span id=\"batch_size_value\">128</span>\n        <br>\n        <label for=\"epochs\">Epochs:</label>\n        <input type=\"range\" id=\"epochs\" min=\"1\" max=\"100\" value=\"10\">\n        <span id=\"epochs_value\">10</span>\n        <br>\n        <label for=\"optimizer\">Optimizer:</label>\n        <select id=\"optimizer\">\n            <option value=\"adam\">Adam</option>\n            <option value=\"sgd\">SGD</option>\n            <option value=\"rmsprop\">RMSProp</option>\n        </select>\n        <br>\n        <button id=\"train_button\">Train</button>\n    </div>\n    <div id=\"output\">\n        <h2>Output:</h2>\n        <div id=\"graph\"></div>\n    </div>\n\n    <script>\n        let learning_rate = 0.05;\n        let batch_size = 128;\n        let epochs = 10;\n        let optimizer = \"adam\";\n        let graph = document.getElementById(\"graph\");\n\n        document.getElementById(\"train_button\").addEventListener(\"click\", train);\n\n        function train() {\n            // Simulate data generation\n            let data = [];\n            for (let i = 0; i < 100; i++) {\n                data.push({\n                    x: i,\n                    y: Math.sin(i * 0.1) + Math.random() * 2 - 1\n                });\n            }\n\n            // Train model\n            let model = new Model(learning_rate, batch_size, epochs, optimizer);\n            model.fit(data);\n\n            // Plot data\n            let x = Array.from({length: data.length}, (_, i) => i);\n            let y = data.map(d => d.y);\n            graph.innerHTML = \"\";\n            graph.appendChild(new Graph(x, y));\n        }\n\n        function newGraph(x, y) {\n            let graph = document.createElement(\"canvas\");\n            graph.style.width = \"800\";\n            graph.style.height = \"400\";\n            graph.style.border = \"1px solid black\";\n            graph.style.position = \"absolute\";\n            graph.style.top = \"10px\";\n            graph.style.left = \"10px\";\n            graph.style.zIndex = \"1000\";\n            return graph;\n        }\n\n        function Model(learningRate, batchSize, epochs, optimizer) {\n            this.learningRate = learningRate;\n            this.batchSize = batchSize;\n            this.epochs = epochs;\n            this.optimizer = optimizer;\n            this.model = new NeuralNetwork(this.learningRate, this.batchSize, this.epochs, this.optimizer);\n        }\n\n        function NeuralNetwork(learningRate, batchSize, epochs, optimizer) {\n            this.learningRate = learningRate;\n            this.batchSize = batchSize;\n            this.epochs = epochs;\n            this.optimizer = optimizer;\n            this.weights = new Array(784).fill(0).map(() => new Array(784).fill(0));\n            this.bias = new Array(784).fill(0);\n\n            this.fit = function(data) {\n                let predictions = new Array(data.length);\n                for (let i = 0; i < data.length; i++) {\n                    let input = new Input(this.weights, this.bias, data[i].x);\n                    let output = this.model.predict(input);\n                    predictions[i] = output;\n                }\n                return predictions;\n            }\n\n            this.predict = function(input) {\n                let output = new Output(this.weights, this.bias, input);\n                return output.output;\n            }\n\n            this.train = function(data) {\n                for (let i = 0; i < data.length; i++) {\n                    let prediction = this.predict(new Input(this.weights, this.bias, data[i].x));\n                    let error = prediction.output - data[i].y;\n                    this.updateWeights(error);\n                }\n            }\n\n            this.updateWeights = function(error) {\n                for (let i = 0; i < this.weights.length; i++) {\n                    for (let j = 0; j < this.weights[i].length; j++) {\n                        this.weights[i][j] += error * data[i].x * this.learningRate;\n                    }\n                }\n                for (let i = 0; i < this.bias.length; i++) {\n                    this.bias[i] += error * this.learningRate;\n                }\n            }\n\n            this.model = new NeuralNetwork(this.learningRate, this.batchSize, this.epochs, this.optimizer);\n        }\n    </script>\n\n    <script>\n        function Input(weights, bias, x) {\n            return new Input(weights, bias, x);\n        }\n\n        function Output(weights, bias, x) {\n            return new Output(weights, bias, x);\n        }\n\n        class NeuralNetwork {\n            constructor(learningRate, batchSize, epochs, optimizer) {\n                this.learningRate = learningRate;\n                this.batchSize = batchSize;\n                this.epochs = epochs;\n                this.optimizer = optimizer;\n                this.weights = new Array(784).fill(0).map(() => new Array(784).fill(0));\n                this.bias = new Array(784).fill(0);\n            }\n\n            predict(input) {\n                let output = new Output(this.weights, this.bias, input);\n                return output.output;\n            }\n\n            updateWeights(error) {\n                for (let i = 0; i < this.weights.length; i++) {\n                    for (let j = 0; j < this.weights[i].length; j++) {\n                        this.weights[i][j] += error * this.learningRate;\n                    }\n                }\n                for (let i = 0; i < this.bias.length; i++) {\n                    this.bias[i] += error * this.learningRate;\n                }\n            }\n        }\n\n        class Input {\n            constructor(weights, bias, x) {\n                this.weights = weights;\n                this.bias = bias;\n                this.x = x;\n            }\n        }\n\n        class Output {\n            constructor(weights, bias, x) {\n                this.weights = weights;\n                this.bias = bias;\n                this.x = x;\n            }\n        }\n    </script>\n</body>\n</html>"
