  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Software Development Life Cycle — Visual Exploration</title>\n<style>\n  :root{\n    --bg-1: #071028;\n    --bg-2: #081030;\n    --accent-1: #7c5cff;\n    --accent-2: #35d0c1;\n    --glass: rgba(255,255,255,0.06);\n    --muted: rgba(255,255,255,0.65);\n    --soft: rgba(255,255,255,0.04);\n    --card: rgba(255,255,255,0.03);\n    --font-sans: ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n\n  /* Page layout */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family:var(--font-sans);\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(124,92,255,0.12), transparent),\n                radial-gradient(1000px 500px at 95% 80%, rgba(53,208,193,0.06), transparent),\n                linear-gradient(180deg, var(--bg-1), var(--bg-2));\n    color: #f3f6fb;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Subtle animated starfield (pure CSS) */\n  .starfield{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    background-image:\n      radial-gradient(circle at 10% 20%, rgba(255,255,255,0.04) 0, transparent 40%),\n      radial-gradient(circle at 90% 80%, rgba(255,255,255,0.025) 0, transparent 30%);\n    mix-blend-mode:screen;\n    z-index:0;\n  }\n\n  .container{\n    position:relative;\n    z-index:1;\n    min-height:100vh;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    justify-content:center;\n    padding:48px 28px;\n    gap:28px;\n  }\n\n  /* Header */\n  header{\n    text-align:center;\n    margin-bottom:8px;\n    pointer-events:none;\n  }\n  h1{\n    margin:0;\n    font-size: clamp(26px, 3.8vw, 44px);\n    letter-spacing:-0.02em;\n    background: linear-gradient(90deg, #fff, rgba(255,255,255,0.85));\n    -webkit-background-clip:text;\n    background-clip:text;\n    color:transparent;\n    text-shadow: 0 6px 30px rgba(124,92,255,0.12);\n  }\n  p.lead{\n    margin:8px 0 0;\n    color:var(--muted);\n    font-size:14px;\n    opacity:0.95;\n  }\n\n  /* Visual stage area */\n  .stage-scene{\n    width: min(1100px, calc(100vw - 56px));\n    aspect-ratio: 16/9;\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap:28px;\n    align-items:center;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n    border-radius:22px;\n    padding:28px;\n    box-shadow: 0 10px 40px rgba(3,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    overflow:visible;\n    position:relative;\n  }\n\n  /* Left: the orbital wheel */\n  .orbital{\n    position:relative;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    height:100%;\n    min-height:380px;\n  }\n\n  .orbit-wrap{\n    position:relative;\n    width:min(72vmin, 720px);\n    height: min(72vmin, 720px);\n    display:grid;\n    place-items:center;\n    animation: gentle-rotate 24s linear infinite;\n    transition: transform 0.9s cubic-bezier(.22,.9,.36,1);\n  }\n\n  @keyframes gentle-rotate{\n    0%{ transform: rotate(0deg) }\n    100%{ transform: rotate(360deg) }\n  }\n\n  /* Glowing central core */\n  .core{\n    width:180px;\n    height:180px;\n    border-radius:999px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    flex-direction:column;\n    z-index:5;\n    background: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.06), transparent 10%),\n                linear-gradient(180deg, rgba(124,92,255,0.16), rgba(53,208,193,0.06));\n    border: 1px solid rgba(255,255,255,0.06);\n    box-shadow: 0 10px 40px rgba(53,80,160,0.25), 0 0 60px rgba(124,92,255,0.08);\n    backdrop-filter: blur(8px) saturate(120%);\n    transform-origin:center;\n    transition: transform 0.6s cubic-bezier(.22,.9,.36,1), box-shadow 0.4s ease;\n  }\n  .core .title{\n    font-size:16px;\n    color: #fff;\n    letter-spacing: 0.02em;\n    font-weight:700;\n  }\n  .core .subtitle{\n    font-size:12px;\n    color: rgba(255,255,255,0.85);\n    margin-top:6px;\n    opacity:0.9;\n  }\n  .core .pulse{\n    position:absolute;\n    width:260px;\n    height:260px;\n    border-radius:999px;\n    filter: blur(30px);\n    background: conic-gradient(from 180deg at 50% 50%, rgba(124,92,255,0.14), rgba(53,208,193,0.08));\n    z-index:3;\n    opacity:0.9;\n    transition: opacity .6s ease, transform .6s ease;\n  }\n\n  /* Orbit ring */\n  .orbit-ring{\n    position:absolute;\n    width:100%;\n    height:100%;\n    border-radius:999px;\n    z-index:1;\n    mix-blend-mode:screen;\n    opacity:0.75;\n    pointer-events:none;\n  }\n  .orbit-ring::before{\n    content:\"\";\n    position:absolute;\n    inset:6%;\n    border-radius:999px;\n    border:1px dashed rgba(255,255,255,0.03);\n    box-shadow: 0 0 80px rgba(124,92,255,0.06), inset 0 0 40px rgba(53,208,193,0.02);\n  }\n\n  /* Stage nodes around the orbit */\n  .nodes{\n    position:absolute;\n    inset:2%;\n    display:block;\n    width:96%;\n    height:96%;\n    pointer-events:none;\n  }\n  .node{\n    --size:128px;\n    width:var(--size);\n    height:var(--size);\n    position:absolute;\n    transform-origin:center;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transition: transform 600ms cubic-bezier(.22,.9,.36,1), opacity 420ms ease, filter 420ms ease;\n    opacity:0.92;\n    pointer-events:none;\n  }\n\n  .node-card{\n    width:100%;\n    height:100%;\n    border-radius:18px;\n    padding:14px;\n    display:flex;\n    flex-direction:column;\n    gap:6px;\n    align-items:flex-start;\n    justify-content:center;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 8px 30px rgba(2,6,23,0.6);\n    backdrop-filter: blur(6px) saturate(120%);\n    color:var(--muted);\n    transform: translateZ(0);\n  }\n\n  .node-ico{\n    width:36px;\n    height:36px;\n    border-radius:10px;\n    display:grid;\n    place-items:center;\n    background: linear-gradient(135deg, rgba(124,92,255,0.14), rgba(53,208,193,0.06));\n    border: 1px solid rgba(255,255,255,0.03);\n    margin-bottom:4px;\n  }\n  .node h3{\n    font-size:13px;\n    margin:0;\n    color:#fff;\n    font-weight:700;\n  }\n  .node p{\n    margin:0;\n    font-size:11px;\n    color:var(--muted);\n    opacity:0.95;\n  }\n\n  /* Position nodes evenly in a circle using data-angle */\n  .node[data-angle]{\n    transform: rotate(calc(var(--angle) * 1deg)) translateY(calc(-40% - var(--offset,0px))) rotate(calc(var(--angle) * -1deg));\n  }\n\n  /* Selected/highlighted node look */\n  .node.is-active{\n    transform: scale(1.12) translateZ(0);\n    z-index:12;\n    filter: drop-shadow(0 18px 40px rgba(53,80,160,0.38));\n  }\n  .node.is-active .node-card{\n    background: linear-gradient(180deg, rgba(124,92,255,0.16), rgba(53,208,193,0.06));\n    border: 1px solid rgba(255,255,255,0.06);\n  }\n  .node.is-active .node-ico{\n    transform: translateY(-2px);\n    box-shadow: 0 8px 30px rgba(124,92,255,0.12);\n  }\n\n  /* Right: details card */\n  .panel{\n    position:relative;\n    padding:26px;\n    border-radius:16px;\n    height:100%;\n    display:flex;\n    flex-direction:column;\n    align-items:stretch;\n    justify-content:flex-start;\n    gap:14px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.04);\n    box-shadow: 0 8px 30px rgba(2,6,23,0.55);\n    backdrop-filter: blur(8px) saturate(120%);\n  }\n\n  .panel .phase-title{\n    display:flex;\n    gap:12px;\n    align-items:center;\n  }\n  .phase-badge{\n    min-width:48px;\n    height:48px;\n    border-radius:12px;\n    display:grid;\n    place-items:center;\n    background: linear-gradient(135deg, rgba(124,92,255,0.18), rgba(53,208,193,0.06));\n    border: 1px solid rgba(255,255,255,0.04);\n    font-weight:700;\n    color:#fff;\n    font-size:12px;\n  }\n  .phase-heading{\n    font-size:18px;\n    font-weight:800;\n    margin:0;\n  }\n  .phase-desc{\n    color:var(--muted);\n    line-height:1.5;\n    font-size:13px;\n  }\n\n  .bullets{\n    margin-top:6px;\n    display:grid;\n    gap:8px;\n  }\n  .bullets .item{\n    display:flex;\n    gap:12px;\n    align-items:flex-start;\n    color:var(--muted);\n    font-size:13px;\n  }\n  .dot{\n    width:10px;\n    height:10px;\n    border-radius:999px;\n    margin-top:6px;\n    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));\n    box-shadow: 0 6px 20px rgba(124,92,255,0.14);\n  }\n\n  /* Controls: single toggle button */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    margin-top:6px;\n  }\n  .toggle{\n    -webkit-tap-highlight-color: transparent;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.06);\n    color:#fff;\n    padding:10px 14px;\n    border-radius:12px;\n    display:inline-flex;\n    gap:10px;\n    align-items:center;\n    cursor:pointer;\n    transition: transform 220ms cubic-bezier(.22,.9,.36,1), box-shadow 200ms ease;\n    font-weight:700;\n    font-size:13px;\n    box-shadow: 0 6px 20px rgba(3,6,23,0.5);\n  }\n  .toggle:hover{ transform: translateY(-4px); }\n  .toggle svg{display:block}\n\n  /* stage timeline at bottom (decorative) */\n  .timeline{\n    position:absolute;\n    bottom:-24px;\n    left:50%;\n    transform:translateX(-50%);\n    width:60%;\n    height:6px;\n    background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:999px;\n    box-shadow: 0 8px 30px rgba(2,6,23,0.45);\n    opacity:0.6;\n    z-index:0;\n  }\n  .timeline .fill{\n    height:100%;\n    width:0%;\n    background: linear-gradient(90deg, var(--accent-1), var(--accent-2));\n    border-radius:999px;\n    transition: width 700ms cubic-bezier(.22,.9,.36,1);\n    box-shadow: 0 8px 40px rgba(124,92,255,0.12);\n  }\n\n  /* Entrance animations for nodes */\n  .node{ opacity:0; transform: scale(.9) translateY(12px); animation: node-appear 900ms forwards ease; }\n  .node:nth-child(1){ animation-delay:120ms }\n  .node:nth-child(2){ animation-delay:200ms }\n  .node:nth-child(3){ animation-delay:280ms }\n  .node:nth-child(4){ animation-delay:360ms }\n  .node:nth-child(5){ animation-delay:440ms }\n  .node:nth-child(6){ animation-delay:520ms }\n  .node:nth-child(7){ animation-delay:600ms }\n\n  @keyframes node-appear{\n    to{ opacity:0.94; transform: scale(1) translateY(0) }\n  }\n\n  /* subtle floating */\n  @keyframes float {\n    0% { transform: translateY(0px) }\n    50% { transform: translateY(-8px) }\n    100% { transform: translateY(0px) }\n  }\n  .node-card{ animation: float 6s ease-in-out infinite; }\n\n  /* responsive adjustments */\n  @media (max-width:980px){\n    .stage-scene{\n      grid-template-columns: 1fr;\n      aspect-ratio: 1/1;\n      padding:20px;\n    }\n    .panel{ order:2; width:100%; padding:18px; height:auto }\n    .orbital{ order:1; width:100%; height:100% }\n    .orbit-wrap{ width:92vmin; height:92vmin }\n    .node{ --size:110px }\n  }\n\n  /* Reduced motion */\n  @media (prefers-reduced-motion: reduce){\n    .orbit-wrap, .node-card, .starfield, .node, .core, .orbit-wrap { animation: none !important; transition: none !important; }\n    .node{ opacity:1; transform: none !important }\n  }\n\n  /* Tiny footer note */\n  .note{\n    margin-top:12px;\n    color:rgba(255,255,255,0.25);\n    font-size:12px;\n    text-align:center;\n    pointer-events:none;\n  }\n</style>\n</head>\n<body>\n  <div class=\"starfield\" aria-hidden=\"true\"></div>\n\n  <div class=\"container\" role=\"main\">\n    <header>\n      <h1>Software Development Life Cycle</h1>\n      <p class=\"lead\">A visual, elegant exploration of development stages — from idea to continuous evolution.</p>\n    </header>\n\n    <section class=\"stage-scene\" aria-label=\"Software development life cycle visualization\">\n      <div class=\"orbital\" aria-hidden=\"false\">\n        <div class=\"orbit-wrap\" id=\"orbitWrap\" role=\"img\" aria-label=\"Orbital visualization of SDLC\">\n          <div class=\"orbit-ring\" aria-hidden=\"true\"></div>\n\n          <!-- Central core -->\n          <div class=\"core\" id=\"core\">\n            <div class=\"pulse\" id=\"corePulse\" aria-hidden=\"true\"></div>\n            <div class=\"title\">SDLC</div>\n            <div class=\"subtitle\" id=\"coreSubtitle\">Planning • Requirements • Design • Implementation • Testing • Deployment • Maintenance</div>\n          </div>\n\n          <!-- Nodes: we will position them with JS using data-angle attributes -->\n          <div class=\"nodes\" id=\"nodesContainer\" aria-hidden=\"false\">\n            <!-- Nodes will be injected by JS for crisp control -->\n          </div>\n        </div>\n      </div>\n\n      <aside class=\"panel\" aria-label=\"Stage details\">\n        <div class=\"phase-title\">\n          <div class=\"phase-badge\" id=\"phaseBadge\">PLN</div>\n          <div style=\"flex:1\">\n            <h2 class=\"phase-heading\" id=\"phaseHeading\">Planning</h2>\n            <div class=\"phase-desc\" id=\"phaseDesc\">Establish vision, goals, scope, and feasibility. Align stakeholders and set success metrics.</div>\n          </div>\n        </div>\n\n        <div class=\"bullets\" id=\"phaseBullets\" aria-hidden=\"true\">\n          <div class=\"item\"><span class=\"dot\"></span><div>Define objectives, constraints & deliverables.</div></div>\n          <div class=\"item\"><span class=\"dot\"></span><div>Assess risks and resources.</div></div>\n          <div class=\"item\"><span class=\"dot\"></span><div>Formulate roadmap and milestones.</div></div>\n        </div>\n\n        <div style=\"flex:1\"></div>\n\n        <div class=\"controls\" aria-hidden=\"false\">\n          <button class=\"toggle\" id=\"toggleAuto\" aria-pressed=\"false\" title=\"Toggle automatic stage highlight\">\n            <svg id=\"iconPlay\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\" style=\"transform:translateX(-1px)\">\n              <path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\" />\n            </svg>\n            <span id=\"toggleLabel\">Autoplay</span>\n          </button>\n        </div>\n      </aside>\n\n      <div class=\"timeline\" aria-hidden=\"true\">\n        <div class=\"fill\" id=\"timelineFill\"></div>\n      </div>\n    </section>\n\n    <div class=\"note\">This is a primarily visual representation — animations demonstrate flow; interaction is intentionally minimal.</div>\n  </div>\n\n<script>\n(function(){\n  // Stage data\n  const stages = [\n    { id: 'planning', short:'PLN', title:'Planning', desc:'Establish vision, goals, scope, and feasibility. Align stakeholders and set success metrics.', bullets:[\n      'Define objectives, constraints & deliverables.',\n      'Assess risks and resources.',\n      'Formulate roadmap and milestones.'\n    ], icon: `<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\"><path d=\"M12 2v8l6 3\" stroke=\"white\" stroke-opacity=\".95\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"white\" stroke-opacity=\".06\" stroke-width=\"1.6\"/></svg>` },\n    { id: 'requirements', short:'REQ', title:'Requirements', desc:'Capture user needs and technical constraints; transform goals into actionable requirements.', bullets:[\n      'Elicit user stories & use cases.',\n      'Prioritize features.',\n      'Specify acceptance criteria.'\n    ], icon: `<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\"><path d=\"M4 7h16M6 11h12M8 15h8\" stroke=\"white\" stroke-opacity=\".95\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"4\" stroke=\"white\" stroke-opacity=\".06\" stroke-width=\"1.6\"/></svg>` },\n    { id: 'design', short:'DSN', title:'Design', desc:'Architect solutions, create interfaces and system designs that meet requirements.', bullets:[\n      'High-level architecture & low-level components.',\n      'UI/UX mockups and workflows.',\n      'Define APIs and data models.'\n    ], icon: `<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\"><path d=\"M12 20V4\" stroke=\"white\" stroke-opacity=\".95\" stroke-width=\"1.6\" stroke-linecap=\"round\"/><path d=\"M6 8h12\" stroke=\"white\" stroke-opacity=\".95\" stroke-width=\"1.6\" stroke-linecap=\"round\"/><circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"white\" stroke-opacity=\".06\" stroke-width=\"1.6\"/></svg>` },\n    { id: 'implementation', short:'IMP', title:'Implementation', desc:'Write code, build features, integrate components and evolve prototypes into working software.', bullets:[\n      'Adopt coding standards and practices.',\n      'Iterative development with frequent commits.',\n      'Continuous integration pipelines.'\n    ], icon: `<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\"><path d=\"M16 18l4-6-4-6M8 6L4 12l4 6\" stroke=\"white\" stroke-opacity=\".95\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M12 3v18\" stroke=\"white\" stroke-opacity=\".06\" stroke-width=\"1.6\"/></svg>` },\n    { id: 'testing', short:'TST', title:'Testing', desc:'Validate functionality, performance, and reliability to ensure quality meets expectations.', bullets:[\n      'Unit, integration, and end-to-end tests.',\n      'Performance & security testing.',\n      'Regression detection & bug triage.'\n    ], icon: `<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\"><path d=\"M20 6L9 17l-5-5\" stroke=\"white\" stroke-opacity=\".95\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" stroke=\"white\" stroke-opacity=\".06\" stroke-width=\"1.6\"/></svg>` },\n    { id: 'deployment', short:'DEP', title:'Deployment', desc:'Deliver software to production, ensuring smooth rollout and operational readiness.', bullets:[\n      'Automated deployment scripts & IaC.',\n      'Canary/frequency-based rollouts.',\n      'Monitoring & alerting setup.'\n    ], icon: `<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\"><path d=\"M21 15V8a2 2 0 0 0-2-2h-5V3L7 8v5\" stroke=\"white\" stroke-opacity=\".95\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"4\" stroke=\"white\" stroke-opacity=\".06\" stroke-width=\"1.6\"/></svg>` },\n    { id: 'maintenance', short:'MNT', title:'Maintenance', desc:'Operate, monitor, iterate and improve the product in response to user feedback and changing needs.', bullets:[\n      'Bug fixes & hotfix workflows.',\n      'Feature enhancements & refactoring.',\n      'Sustained reliability and optimization.'\n    ], icon: `<svg viewBox=\"0 0 24 24\" width=\"18\" height=\"18\" fill=\"none\"><path d=\"M12 8v8M8 12h8\" stroke=\"white\" stroke-opacity=\".95\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><circle cx=\"12\" cy=\"12\" r=\"9\" stroke=\"white\" stroke-opacity=\".06\" stroke-width=\"1.6\"/></svg>` }\n  ];\n\n  const nodesContainer = document.getElementById('nodesContainer');\n  const phaseHeading = document.getElementById('phaseHeading');\n  const phaseDesc = document.getElementById('phaseDesc');\n  const phaseBadge = document.getElementById('phaseBadge');\n  const phaseBullets = document.getElementById('phaseBullets');\n  const timelineFill = document.getElementById('timelineFill');\n  const toggleAuto = document.getElementById('toggleAuto');\n  const toggleLabel = document.getElementById('toggleLabel');\n  const core = document.getElementById('core');\n  const corePulse = document.getElementById('corePulse');\n\n  // Create nodes\n  const nodeElements = [];\n  const total = stages.length;\n  const radiusPercent = 40; // how far from center (percent)\n  stages.forEach((s, i)=>{\n    const angleDeg = (360 / total) * i - 90; // start at top\n    // wrapper\n    const node = document.createElement('div');\n    node.className = 'node';\n    node.dataset.angle = angleDeg;\n    node.style.setProperty('--angle', angleDeg);\n    // compute initial offset to pull nodes slightly outward\n    const offsetPx = 0;\n    node.style.setProperty('--offset', offsetPx + 'px');\n\n    // inner card\n    const card = document.createElement('div');\n    card.className = 'node-card';\n    card.innerHTML = `\n      <div class=\"node-ico\">${s.icon}</div>\n      <h3>${s.title}</h3>\n      <p>${s.desc.split('.')[0]}.</p>\n    `;\n    node.appendChild(card);\n    nodesContainer.appendChild(node);\n\n    // position node using polar coordinates relative to container\n    // We'll set transform via inline style (left/top)\n    node.style.position = 'absolute';\n    node.style.left = '50%';\n    node.style.top = '50%';\n    // compute x,y coordinates in percentage\n    const angleRad = angleDeg * Math.PI / 180;\n    const r = radiusPercent;\n    const x = Math.cos(angleRad) * r;\n    const y = Math.sin(angleRad) * r;\n    node.style.transform = `translate(-50%, -50%) translate(${x}%, ${y}%) rotate(0deg)`;\n    node.dataset.index = i;\n\n    // small floating variation based on index\n    const floatDelay = (i*120) % 900;\n    card.style.animationDelay = floatDelay + 'ms';\n\n    nodeElements.push(node);\n  });\n\n  // Center nodes' rotate animation is handled; but to highlight, we'll manage classes\n  let current = 0;\n  let playing = false;\n  let interval = null;\n  const stepDuration = 2600;\n\n  // Utility: update active node and right panel\n  function setActive(index, animateCore=true){\n    current = index % total;\n    nodeElements.forEach((n, idx)=>{\n      if(idx === current) n.classList.add('is-active');\n      else n.classList.remove('is-active');\n    });\n    const s = stages[current];\n    phaseHeading.textContent = s.title;\n    phaseDesc.textContent = s.desc;\n    phaseBadge.textContent = s.short;\n    // bullets\n    phaseBullets.innerHTML = '';\n    s.bullets.forEach(b=>{\n      const item = document.createElement('div');\n      item.className = 'item';\n      item.innerHTML = `<span class=\"dot\" aria-hidden=\"true\"></span><div>${b}</div>`;\n      phaseBullets.appendChild(item);\n    });\n    // timeline fill\n    const pct = Math.round(((current + 1) / total) * 100);\n    timelineFill.style.width = pct + '%';\n\n    // animate core gently to emphasize selection\n    if(animateCore){\n      core.style.transform = 'scale(1.04)';\n      corePulse.style.opacity = '1';\n      setTimeout(()=>{ core.style.transform = ''; corePulse.style.opacity = '0.9'; }, 700);\n    }\n  }\n\n  // initial active\n  setActive(0, false);\n\n  // autoplay toggle\n  function startAuto(){\n    if(playing) return;\n    playing = true;\n    toggleAuto.setAttribute('aria-pressed','true');\n    toggleLabel.textContent = 'Autoplay: On';\n    // animate icon to pause - replace inner svg\n    toggleAuto.querySelector('svg').innerHTML = `<path d=\"M6 5h4v14H6zM14 5h4v14h-4z\" fill=\"currentColor\"/>`;\n    interval = setInterval(()=>{\n      setActive((current + 1) % total);\n    }, stepDuration);\n  }\n  function stopAuto(){\n    if(!playing) return;\n    playing = false;\n    toggleAuto.setAttribute('aria-pressed','false');\n    toggleLabel.textContent = 'Autoplay';\n    toggleAuto.querySelector('svg').innerHTML = `<path d=\"M5 3v18l15-9L5 3z\" fill=\"currentColor\" />`;\n    clearInterval(interval);\n    interval = null;\n  }\n\n  // toggle button event (single control)\n  toggleAuto.addEventListener('click', ()=>{\n    if(playing) stopAuto(); else startAuto();\n  });\n\n  // Accessibility: allow keyboard toggle (Enter/Space)\n  toggleAuto.addEventListener('keydown', (e)=>{\n    if(e.key === 'Enter' || e.key === ' '){\n      e.preventDefault();\n      toggleAuto.click();\n    }\n  });\n\n  // Optional subtle auto-start after a short delay (but keep off by default)\n  // Uncomment to enable auto-play on load:\n  // setTimeout(()=> startAuto(), 900);\n\n  // Tiny parallax for mouse move for depth illusion (non-intrusive)\n  const orbitWrap = document.getElementById('orbitWrap');\n  let lastX = 0, lastY = 0;\n  window.addEventListener('mousemove', (e)=>{\n    const w = window.innerWidth;\n    const h = window.innerHeight;\n    const nx = (e.clientX / w) - 0.5;\n    const ny = (e.clientY / h) - 0.5;\n    // small transforms\n    orbitWrap.style.transform = `rotate(${nx * 6}deg)`;\n    core.style.transform = `translate(${nx * 6}px, ${ny * 6}px) scale(${playing?1.04:1})`;\n  });\n\n  // Respect reduced motion: if user prefers reduced motion, disable animations\n  const mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');\n  if(mediaQuery.matches){\n    // stop orbit animation\n    orbitWrap.style.animation = 'none';\n  }\n\n  // Make nodes slowly reposition on resize to maintain circular layout\n  window.addEventListener('resize', () => {\n    // recompute positions similarly to initial creation in case container size changed (kept percentage based)\n    nodeElements.forEach((node, i)=>{\n      const angleDeg = (360 / total) * i - 90;\n      const angleRad = angleDeg * Math.PI / 180;\n      const r = 40;\n      const x = Math.cos(angleRad) * r;\n      const y = Math.sin(angleRad) * r;\n      node.style.transform = `translate(-50%, -50%) translate(${x}%, ${y}%) rotate(0deg)`;\n    });\n  });\n\n  // Expose nothing globally\n})();\n</script>\n</body>\n</html>"
