    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>HTTPS — Secure by Design</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Reset */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n\n  body {\n    margin: 0; padding: 0;\n    background: linear-gradient(135deg, #12223e 0%, #1c2f57 45%, #2158a6 100%);\n    font-family: 'Poppins', sans-serif;\n    color: #e6eaf0;\n    overflow-x: hidden;\n  }\n\n  main {\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    padding: 2rem;\n    text-align: center;\n    position: relative;\n    z-index: 10;\n  }\n\n  h1 {\n    font-weight: 600;\n    font-size: 4.5rem;\n    margin: 0 0 0.4em;\n    letter-spacing: 0.03em;\n    color: #57d6ff;\n    text-shadow: 0 0 12px #57d6ff88;\n  }\n\n  h2 {\n    font-weight: 300;\n    font-size: 1.4rem;\n    color: #a8c9e8cc;\n    margin: 0 0 2.5rem;\n    letter-spacing: 0.02em;\n  }\n\n  p.description {\n    max-width: 480px;\n    font-size: 1.15rem;\n    line-height: 1.6;\n    margin-bottom: 3rem;\n    color: #cbdff7dd;\n    text-shadow: 0 0 4px #0a182e88;\n  }\n\n  /* Button styles */\n  .btn {\n    display: inline-block;\n    padding: 0.75em 2em;\n    margin: 0 1em;\n    font-weight: 600;\n    font-size: 1rem;\n    color: #12223e;\n    background: linear-gradient(90deg, #a0eaffe8, #57d6ff);\n    border: none;\n    border-radius: 36px;\n    cursor: pointer;\n    box-shadow:\n      0 0 18px #57d6ffaa,\n      inset 0 0 12px #a0eaffcc;\n    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n    user-select: none;\n    text-shadow: 0 0 6px #12223e;\n  }\n  .btn:hover, .btn:focus {\n    outline: none;\n    box-shadow:\n      0 0 28px #57d6ffee,\n      inset 0 0 20px #a0eaffee;\n    background: linear-gradient(90deg, #57d6ff, #a0eaffcc);\n    transform: scale(1.07);\n    color: #fff;\n    text-shadow: 0 0 12px #0d3455;\n  }\n\n  /* HTTPS Globe Graphic */\n  .globe-container {\n    position: relative;\n    width: 320px;\n    height: 320px;\n    margin-bottom: 4rem;\n    filter: drop-shadow(0 3px 8px #0d345566);\n    perspective: 1000px;\n  }\n\n  .globe {\n    width: 320px;\n    height: 320px;\n    border-radius: 50%;\n    background: radial-gradient(circle at center, #1857c0 0%, #08244a 85%);\n    overflow: visible;\n    box-shadow:\n      inset 0 6px 14px #1e68dfff,\n      0 0 30px #4eb0ff88;\n    position: relative;\n    animation: slowRotate 60s linear infinite;\n    transform-style: preserve-3d;\n  }\n\n  @keyframes slowRotate {\n    from { transform: rotateY(0deg) rotateX(7deg); }\n    to { transform: rotateY(360deg) rotateX(7deg); }\n  }\n\n  /* Latitude lines */\n  .lat-line {\n    position: absolute;\n    border: 1.4px solid rgba(255,255,255,0.15);\n    border-radius: 50%;\n    left: 50%;\n    top: 50%;\n    transform-style: preserve-3d;\n    transform-origin: center center;\n  }\n  /* Different latitudes with slight 3d effect */\n  .lat-line1 {\n    width: 290px; height: 290px;\n    margin-left: -145px;\n    margin-top: -145px;\n    transform: translateZ(32px);\n    animation: latAnim 120s linear infinite;\n  }\n  .lat-line2 {\n    width: 255px; height: 255px;\n    margin-left: -127.5px;\n    margin-top: -127.5px;\n    transform: translateZ(16px);\n    animation: latAnimReverse 110s linear infinite;\n  }\n  .lat-line3 {\n    width: 220px; height: 220px;\n    margin-left: -110px;\n    margin-top: -110px;\n    transform: translateZ(0);\n    animation: latAnim 130s linear infinite;\n  }\n  .lat-line4 {\n    width: 185px; height: 185px;\n    margin-left: -92.5px;\n    margin-top: -92.5px;\n    transform: translateZ(-16px);\n    animation: latAnimReverse 100s linear infinite;\n  }\n  .lat-line5 {\n    width: 150px; height: 150px;\n    margin-left: -75px;\n    margin-top: -75px;\n    transform: translateZ(-32px);\n    animation: latAnim 125s linear infinite;\n  }\n\n  @keyframes latAnim {\n    0% { transform: translateZ(var(--z)) rotateX(0deg) rotateY(0deg); }\n    100% { transform: translateZ(var(--z)) rotateX(0deg) rotateY(360deg); }\n  }\n  @keyframes latAnimReverse {\n    0% { transform: translateZ(var(--z)) rotateX(0deg) rotateY(360deg); }\n    100% { transform: translateZ(var(--z)) rotateX(0deg) rotateY(0deg); }\n  }\n\n  /* Longitude lines */\n  .long-line {\n    position: absolute;\n    border: 1.4px solid rgba(255,255,255,0.08);\n    border-radius: 50% 50% 50% 50% / 100% 100% 0 0;\n    left: 50%;\n    top: 50%;\n    width: 320px;\n    height: 160px;\n    margin-left: -160px;\n    margin-top: -80px;\n    transform-style: preserve-3d;\n    animation: longRotate 90s linear infinite;\n    box-shadow: 0 0 4px #57d6ff33 inset;\n  }\n\n  @keyframes longRotate {\n    from { transform: rotateX(7deg) rotateY(0deg); }\n    to { transform: rotateX(7deg) rotateY(360deg); }\n  }\n\n  /* Lock Icon */\n  .lock-icon {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    width: 112px;\n    height: 112px;\n    margin-left: -56px;\n    margin-top: -56px;\n    filter: drop-shadow(0 0 6px #57d6ffcc);\n    animation: pulseGlow 4s ease-in-out infinite;\n    z-index: 20;\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {\n      filter: drop-shadow(0 0 20px #57d6ffcc);\n      transform: scale(1);\n      opacity: 1;\n    }\n    50% {\n      filter: drop-shadow(0 0 28px #a0eaffee);\n      transform: scale(1.06);\n      opacity: 0.88;\n    }\n  }\n\n  /* Lock parts */\n\n  .lock-body {\n    fill: url(#lockGradient);\n    stroke: #d0efffdd;\n    stroke-width: 2;\n    filter: drop-shadow(0 0 2px #87caffbb);\n    transition: fill 0.4s ease;\n  }\n\n  .lock-shackle {\n    fill: none;\n    stroke: #a0eaffcc;\n    stroke-width: 3.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    filter: drop-shadow(0 0 4px #57d6ff99);\n    transition: stroke 0.4s ease;\n  }\n\n  /* Footer footnote */\n  footer {\n    position: fixed;\n    bottom: 12px;\n    width: 100%;\n    text-align: center;\n    font-weight: 300;\n    color: #57d6ff88;\n    font-size: 0.9rem;\n    user-select: none;\n    pointer-events: none;\n    letter-spacing: 0.06em;\n  }\n\n  /* Info modal */\n  #infoModal {\n    position: fixed;\n    top: 50%; left: 50%;\n    transform: translate(-50%, -50%) scale(0);\n    background: #0f213aee;\n    border-radius: 14px;\n    box-shadow: 0 0 40px #235abbcc;\n    padding: 2rem 2.5rem;\n    color: #b6d8fdcc;\n    max-width: 480px;\n    font-size: 1rem;\n    z-index: 120;\n    text-align: left;\n    line-height: 1.5;\n    font-weight: 300;\n    backdrop-filter: blur(18px);\n    transition: transform 0.45s cubic-bezier(0.6, 0, 0.2, 1), opacity 0.45s ease;\n    opacity: 0;\n  }\n  #infoModal.show {\n    transform: translate(-50%, -50%) scale(1);\n    opacity: 1;\n  }\n\n  #infoModal button.close-btn {\n    position: absolute;\n    top: 1em;\n    right: 1em;\n    background: transparent;\n    border: none;\n    font-size: 1.3rem;\n    color: #88bbffcc;\n    cursor: pointer;\n    font-weight: 700;\n    user-select: none;\n    transition: color 0.25s;\n  }\n  #infoModal button.close-btn:hover {\n    color: #57d6ff;\n  }\n\n  /* Text selection style */\n  ::selection {\n    background: #57d6ff44;\n  }\n</style>\n</head>\n<body>\n<main role=\"main\" aria-label=\"Explanation and visualization of HTTPS secure connection\">\n  <h1>HTTPS</h1>\n  <h2>Secure by Design</h2>\n\n  <div class=\"globe-container\" aria-hidden=\"true\">\n    <div class=\"globe\" aria-hidden=\"true\">\n      <div class=\"lat-line lat-line1\" style=\"--z: 32px\"></div>\n      <div class=\"lat-line lat-line2\" style=\"--z: 16px\"></div>\n      <div class=\"lat-line lat-line3\" style=\"--z: 0px\"></div>\n      <div class=\"lat-line lat-line4\" style=\"--z: -16px\"></div>\n      <div class=\"lat-line lat-line5\" style=\"--z: -32px\"></div>\n      <div class=\"long-line\"></div>\n    </div>\n\n    <svg class=\"lock-icon\" role=\"img\" aria-label=\"Padlock symbolizing security\" viewBox=\"0 0 64 64\" xmlns=\"http://www.w3.org/2000/svg\" >\n      <defs>\n        <linearGradient id=\"lockGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#57d6ff\"/>\n          <stop offset=\"100%\" stop-color=\"#1857c0\"/>\n        </linearGradient>\n      </defs>\n      <!-- Shackle -->\n      <path class=\"lock-shackle\" d=\"M20 26c0-7 24-7 24 0\" />\n      <!-- Body -->\n      <rect class=\"lock-body\" x=\"16\" y=\"26\" width=\"32\" height=\"34\" rx=\"6\" ry=\"6\" />\n      <!-- Keyhole -->\n      <circle cx=\"32\" cy=\"46\" r=\"5\" fill=\"#12223e\" filter=\"drop-shadow(0 0 1px #0008)\" />\n      <rect x=\"30\" y=\"39\" width=\"4\" height=\"7\" rx=\"1.8\" ry=\"1.8\" fill=\"#57d6ffcc\"/>\n    </svg>\n  </div>\n\n  <p class=\"description\" aria-live=\"polite\">\n    HTTPS (HyperText Transfer Protocol Secure) encrypts communication between your browser and websites,\n    protecting your data from eavesdroppers and tampering. It ensures privacy, integrity, and authentication,\n    making our online world safer.\n  </p>\n\n  <div>\n    <button class=\"btn\" id=\"btnMoreInfo\" aria-controls=\"infoModal\" aria-expanded=\"false\" aria-haspopup=\"dialog\">Why HTTPS Matters</button>\n    <button class=\"btn\" id=\"btnRefresh\" aria-label=\"Refresh globe animation\">Refresh Animation</button>\n  </div>\n</main>\n\n<div id=\"infoModal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"modalTitle\" aria-describedby=\"modalDesc\" tabindex=\"-1\">\n  <button class=\"close-btn\" aria-label=\"Close information modal\">&times;</button>\n  <h3 id=\"modalTitle\" style=\"margin-top:0; font-weight:600; font-size:1.6rem; color:#57d6ff\">Why HTTPS Matters</h3>\n  <p id=\"modalDesc\">\n    Without HTTPS, data sent over the internet is vulnerable to interception and modification, risking your privacy and security.\n    HTTPS uses SSL/TLS encryption to create a secure channel, verifying website identities and keeping your information safe even on untrusted networks.\n  </p>\n</div>\n\n<script>\n  const btnMoreInfo = document.getElementById('btnMoreInfo');\n  const btnRefresh = document.getElementById('btnRefresh');\n  const infoModal = document.getElementById('infoModal');\n  const closeBtn = infoModal.querySelector('.close-btn');\n  const globe = document.querySelector('.globe');\n\n  // Show modal on button click\n  btnMoreInfo.addEventListener('click', () => {\n    infoModal.classList.add('show');\n    btnMoreInfo.setAttribute('aria-expanded', 'true');\n    infoModal.focus();\n  });\n\n  // Close modal handlers\n  closeBtn.addEventListener('click', closeInfoModal);\n  infoModal.addEventListener('keydown', e => {\n    if (e.key === 'Escape' || e.key === 'Esc') {\n      closeInfoModal();\n    }\n  });\n\n  function closeInfoModal() {\n    infoModal.classList.remove('show');\n    btnMoreInfo.setAttribute('aria-expanded', 'false');\n    btnMoreInfo.focus();\n  }\n\n  // Refresh globe animation (retrigger slowRotate)\n  btnRefresh.addEventListener('click', () => {\n    globe.style.animation = 'none';\n    // Reflow trick\n    void globe.offsetWidth;\n    globe.style.animation = '';\n  });\n</script>\n</body>\n</html>"
