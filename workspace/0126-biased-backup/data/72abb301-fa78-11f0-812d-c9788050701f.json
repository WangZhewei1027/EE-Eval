    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Semaphore Visual Symphony</title>\n    <style>\n        :root {\n            --primary: #2c3e50;\n            --secondary: #3498db;\n            --accent: #e74c3c;\n            --light: #ecf0f1;\n            --dark: #2c3e50;\n            --highlight: #f39c12;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, var(--primary), var(--dark));\n            color: var(--light);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            overflow-x: hidden;\n            perspective: 1000px;\n        }\n\n        .header {\n            text-align: center;\n            margin-bottom: 3rem;\n            transform: translateY(-20px);\n            opacity: 0;\n            animation: fadeInDown 1.5s ease-out forwards;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--light), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            font-weight: 300;\n            opacity: 0.8;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n\n        .semaphore-container {\n            position: relative;\n            width: 400px;\n            height: 400px;\n            margin: 2rem auto;\n            transform-style: preserve-3d;\n        }\n\n        .semaphore-disc {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            border-radius: 50%;\n            background: rgba(255, 255, 255, 0.05);\n            box-shadow: 0 0 30px rgba(0, 0, 0, 0.3),\n                        inset 0 0 20px rgba(255, 255, 255, 0.1);\n            backdrop-filter: blur(5px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            transform: rotateX(10deg);\n            transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n        }\n\n        .semaphore-arm {\n            position: absolute;\n            width: 12px;\n            height: 180px;\n            background: var(--light);\n            border-radius: 6px;\n            top: 50%;\n            left: 50%;\n            transform-origin: top center;\n            box-shadow: 0 0 15px rgba(0, 0, 0, 0.5);\n            transition: all 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);\n        }\n\n        .arm-left {\n            transform: translate(-50%, -50%) rotate(-45deg);\n        }\n\n        .arm-right {\n            transform: translate(-50%, -50%) rotate(45deg);\n        }\n\n        .semaphore-center {\n            position: absolute;\n            width: 40px;\n            height: 40px;\n            background: var(--accent);\n            border-radius: 50%;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            box-shadow: 0 0 20px var(--accent);\n            z-index: 10;\n        }\n\n        .semaphore-light {\n            position: absolute;\n            width: 80px;\n            height: 80px;\n            background: radial-gradient(circle, var(--highlight), transparent 70%);\n            border-radius: 50%;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%) scale(0);\n            opacity: 0;\n            transition: all 0.4s ease-out;\n            z-index: 5;\n        }\n\n        .active .semaphore-light {\n            transform: translate(-50%, -50%) scale(1);\n            opacity: 0.6;\n        }\n\n        .code-display {\n            background: rgba(0, 0, 0, 0.3);\n            padding: 1.5rem;\n            border-radius: 10px;\n            margin-top: 2rem;\n            max-width: 600px;\n            text-align: center;\n            font-family: 'Fira Code', monospace;\n            font-size: 1.1rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: fadeInUp 1.5s ease-out 0.5s forwards;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .code-display::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, \n                        transparent, \n                        rgba(255, 255, 255, 0.05), \n                        transparent);\n            animation: shine 3s infinite;\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out 1s forwards;\n        }\n\n        button {\n            background: rgba(255, 255, 255, 0.1);\n            color: var(--light);\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-family: inherit;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            backdrop-filter: blur(5px);\n            border: 1px solid rgba(255, 255, 255, 0.2);\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n        }\n\n        button:hover {\n            background: rgba(255, 255, 255, 0.2);\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .footer {\n            margin-top: 3rem;\n            font-size: 0.9rem;\n            opacity: 0.6;\n            text-align: center;\n            animation: fadeIn 1s ease-out 1.5s forwards;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes fadeInDown {\n            from { \n                opacity: 0;\n                transform: translateY(-20px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes fadeInUp {\n            from { \n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes shine {\n            0% { transform: translateX(-100%); }\n            100% { transform: translateX(100%); }\n        }\n\n        @keyframes pulse {\n            0%, 100% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n        }\n\n        .pulse {\n            animation: pulse 2s infinite ease-in-out;\n        }\n\n        @media (max-width: 600px) {\n            .semaphore-container {\n                width: 300px;\n                height: 300px;\n            }\n\n            .semaphore-arm {\n                height: 140px;\n            }\n\n            h1 {\n                font-size: 2.5rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Semaphore Visualizer</h1>\n        <p class=\"subtitle\">A mesmerizing demonstration of communication through signaling</p>\n    </div>\n\n    <div class=\"semaphore-container pulse\">\n        <div class=\"semaphore-disc\"></div>\n        <div class=\"semaphore-arm arm-left\"></div>\n        <div class=\"semaphore-arm arm-right\"></div>\n        <div class=\"semaphore-center\"></div>\n        <div class=\"semaphore-light\"></div>\n    </div>\n\n    <div class=\"code-display\">\n        <p>Semaphore signaling allows communication through visual positions...</p>\n        <p>Each arm position encodes a different letter or message</p>\n    </div>\n\n    <div class=\"controls\">\n        <button id=\"signal-btn\">Activate Signal</button>\n        <button id=\"reset-btn\">Reset Position</button>\n    </div>\n\n    <div class=\"footer\">\n        <p>A visual exploration of semaphore communication | Designed for aesthetic appreciation</p>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            const semaphore = document.querySelector('.semaphore-container');\n            const leftArm = document.querySelector('.arm-left');\n            const rightArm = document.querySelector('.arm-right');\n            const light = document.querySelector('.semaphore-light');\n            const signalBtn = document.getElementById('signal-btn');\n            const resetBtn = document.getElementById('reset-btn');\n            \n            // Predefined semaphore positions for letters A, B, C\n            const positions = [\n                { left: -45, right: 135 },  // A\n                { left: 0, right: 90 },     // B\n                { left: -90, right: 45 }    // C\n            ];\n            \n            let currentPos = 0;\n            \n            // Animate semaphore arms to random positions\n            const animateSemaphore = () => {\n                semaphore.classList.add('active');\n                \n                currentPos = (currentPos + 1) % positions.length;\n                const pos = positions[currentPos];\n                \n                leftArm.style.transform = `translate(-50%, -50%) rotate(${pos.left}deg)`;\n                rightArm.style.transform = `translate(-50%, -50%) rotate(${pos.right}deg)`;\n                \n                // Random color for the light effect\n                const colors = ['#f39c12', '#e74c3c', '#3498db', '#2ecc71'];\n                const randomColor = colors[Math.floor(Math.random() * colors.length)];\n                light.style.background = `radial-gradient(circle, ${randomColor}, transparent 70%)`;\n                \n                setTimeout(() => {\n                    semaphore.classList.remove('active');\n                }, 2000);\n            };\n            \n            // Reset to default position\n            const resetSemaphore = () => {\n                leftArm.style.transform = 'translate(-50%, -50%) rotate(-45deg)';\n                rightArm.style.transform = 'translate(-50%, -50%) rotate(45deg)';\n                semaphore.classList.remove('active');\n            };\n            \n            // Event listeners for minimal interactivity\n            signalBtn.addEventListener('click', animateSemaphore);\n            resetBtn.addEventListener('click', resetSemaphore);\n            \n            // Auto-cycle through positions every 3 seconds\n            let autoCycle = setInterval(animateSemaphore, 3000);\n            \n            // Pause auto-cycling when interacting\n            signalBtn.addEventListener('mousedown', () => {\n                clearInterval(autoCycle);\n            });\n            \n            resetBtn.addEventListener('mousedown', () => {\n                clearInterval(autoCycle);\n            });\n            \n            // Restart auto-cycling after 10 seconds of inactivity\n            let timeout;\n            const restartAutoCycle = () => {\n                clearTimeout(timeout);\n                timeout = setTimeout(() => {\n                    autoCycle = setInterval(animateSemaphore, 3000);\n                }, 10000);\n            };\n            \n            document.addEventListener('mousemove', restartAutoCycle);\n            restartAutoCycle();\n        });\n    </script>\n</body>\n</html>"
