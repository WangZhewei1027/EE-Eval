    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Socket Programming — Visual Exploration</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Space+Grotesk:wght@300;400;600&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1:#071021;\n      --bg-2:#0b2540;\n      --accent-1:#4ee1c1;\n      --accent-2:#7e5cff;\n      --muted:#95a0b8;\n      --glass: rgba(255,255,255,0.04);\n      --card: rgba(255,255,255,0.03);\n      --shadow: 0 10px 30px rgba(2,6,23,0.6);\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(126,92,255,0.12), transparent),\n                  radial-gradient(800px 500px at 90% 90%, rgba(78,225,193,0.06), transparent),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      color:#e6eef8;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Floating particle orbs */\n    .orbs{\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      z-index:0;\n      mix-blend-mode:screen;\n      opacity:0.8;\n    }\n    .orb{\n      position:absolute;\n      width:360px;height:360px;\n      border-radius:50%;\n      filter: blur(56px);\n      transform: translate3d(0,0,0);\n      animation: float 10s ease-in-out infinite;\n      opacity:0.7;\n    }\n    .orb.a{left:-5%;top:5%; background:linear-gradient(130deg,var(--accent-2), rgba(126,92,255,0.25)); animation-duration:14s;}\n    .orb.b{right:-10%;bottom:-8%; background:linear-gradient(130deg,var(--accent-1), rgba(78,225,193,0.15)); animation-duration:18s; animation-delay:2s;}\n    .orb.c{left:40%;top:40%; width:220px;height:220px; background:linear-gradient(130deg, rgba(126,92,255,0.18), rgba(78,225,193,0.08)); animation-duration:22s; opacity:0.5;}\n\n    @keyframes float{\n      0%{transform:translateY(0) translateX(0) scale(1)}\n      50%{transform:translateY(-40px) translateX(20px) scale(1.04)}\n      100%{transform:translateY(0) translateX(0) scale(1)}\n    }\n\n    /* Main layout */\n    .wrap{\n      position:relative;\n      z-index:1;\n      max-width:1200px;\n      margin:48px auto;\n      padding:42px;\n      display:grid;\n      grid-template-columns: 420px 1fr;\n      gap:32px;\n    }\n\n    .panel{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.015));\n      border-radius:18px;\n      padding:28px;\n      box-shadow:var(--shadow);\n      border: 1px solid rgba(255,255,255,0.03);\n      overflow:hidden;\n    }\n\n    /* Left info card */\n    .info{\n      min-height:520px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n    }\n\n    .title{\n      display:flex;\n      align-items:center;\n      gap:14px;\n    }\n    .logo{\n      width:64px;height:64px;border-radius:14px;\n      background:linear-gradient(135deg,var(--accent-1),var(--accent-2));\n      display:flex;align-items:center;justify-content:center;\n      box-shadow: 0 6px 20px rgba(126,92,255,0.16), inset 0 -6px 18px rgba(0,0,0,0.12);\n      font-weight:800;color:#071021;font-family:\"Space Grotesk\",sans-serif;\n      font-size:20px;\n    }\n    h1{\n      margin:0;font-size:20px;line-height:1.05;font-weight:800;\n      letter-spacing:-0.02em;\n      color: #eef6ff;\n    }\n    p.lead{\n      margin:0;color:var(--muted);font-size:13px;\n      line-height:1.5;\n    }\n\n    .meta{\n      display:flex;flex-wrap:wrap;gap:10px;margin-top:6px;\n    }\n    .chip{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:999px;padding:8px 12px;font-size:13px;color:var(--muted);\n      display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,0.02);\n    }\n    .chip .dot{width:10px;height:10px;border-radius:50%;background:var(--accent-1);box-shadow:0 2px 8px rgba(78,225,193,0.16)}\n\n    /* Buttons area */\n    .controls{margin-top:auto;display:flex;gap:12px;align-items:center}\n    .btn{\n      appearance:none;border:0;padding:12px 18px;border-radius:12px;font-weight:600;cursor:pointer;\n      color:#071021;background:linear-gradient(90deg,var(--accent-1),var(--accent-2));\n      box-shadow: 0 8px 30px rgba(126,92,255,0.18);\n      transition:transform .22s cubic-bezier(.2,.9,.25,1), box-shadow .2s;\n    }\n    .btn:active{transform:translateY(1px) scale(0.998)}\n    .btn.secondary{\n      background:transparent;color:var(--muted);border:1px solid rgba(255,255,255,0.03);\n      box-shadow:none;padding:10px 14px;border-radius:12px;\n    }\n\n    /* Right visualization panel */\n    .visual{\n      min-height:520px; position:relative; padding:32px; display:flex; flex-direction:column; gap:18px;\n      align-items:stretch; justify-content:flex-start;\n    }\n\n    .viewport{\n      position:relative; flex:1; background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n      border-radius:14px; padding:28px; overflow:hidden; display:flex; align-items:center; justify-content:center;\n      border:1px solid rgba(255,255,255,0.025);\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n\n    /* network canvas */\n    .network{\n      width:100%; height:380px; position:relative;\n      display:flex; align-items:center; justify-content:space-between;\n      gap:40px; padding:0 48px;\n    }\n    .node{\n      width:220px; height:160px; border-radius:14px; background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03); padding:18px; display:flex; flex-direction:column; gap:8px;\n      align-items:flex-start; justify-content:center; position:relative;\n      box-shadow: 0 10px 30px rgba(2,6,23,0.5);\n      transform:translateZ(0);\n    }\n    .node .label{font-weight:700;font-size:14px; color:#eaf7ff}\n    .node .sub{font-size:12px;color:var(--muted)}\n    .node.server{align-items:flex-end;}\n    .node .ports{display:flex;gap:8px; margin-top:8px}\n    .port{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:8px;padding:6px 8px;font-size:12px;color:var(--muted);\n      border:1px solid rgba(255,255,255,0.02);\n    }\n\n    /* connection line */\n    .wire{\n      position:absolute;left:50%;top:50%;width:56%;height:2px;background:linear-gradient(90deg,var(--accent-1),var(--accent-2));\n      transform:translate(-50%,-50%); border-radius:4px; box-shadow: 0 6px 20px rgba(126,92,255,0.12);\n      filter:blur(0.2px);\n      display:flex;align-items:center;justify-content:center;\n    }\n    .wire.thin{height:1px;opacity:0.2; background:linear-gradient(90deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));}\n\n    .status-badge{\n      position:absolute;left:50%;top:44%;transform:translateX(-50%);\n      background:rgba(11,20,34,0.7); padding:8px 14px;border-radius:999px;font-size:12px;color:var(--muted);\n      border:1px solid rgba(255,255,255,0.03);\n      transition:all .36s cubic-bezier(.2,.9,.25,1);\n      backdrop-filter: blur(6px);\n    }\n\n    /* packets */\n    .packet{\n      position:absolute; width:36px;height:36px;border-radius:10px;\n      background:linear-gradient(180deg,#ffffff, rgba(255,255,255,0.9));\n      display:flex;align-items:center;justify-content:center;font-weight:700;color:#071021;\n      box-shadow:0 8px 24px rgba(7,16,33,0.6);\n      transform:translate3d(0,0,0);\n      transition:transform .8s cubic-bezier(.2,.95,.18,1), opacity .4s;\n      opacity:0;\n      pointer-events:none;\n    }\n    .packet.tag{\n      font-size:11px;padding-left:2px;\n    }\n    .packet.syn{background:linear-gradient(90deg, #ffb86b, #ff6b6b); color:#071021}\n    .packet.ack{background:linear-gradient(90deg, #a9f1d3, #4ee1c1); color:#071021}\n    .packet.data{background:linear-gradient(90deg, rgba(255,255,255,0.92), rgba(255,255,255,0.88)); color:#071021; font-weight:700}\n    .packet.fin{background:linear-gradient(90deg, #ffd8f0, #ff7ab6); color:#071021}\n\n    /* animations applied by classes */\n    .move-right { transform: translateX(42%); opacity:1; }\n    .move-left  { transform: translateX(-42%); opacity:1; }\n\n    /* timeline indicators */\n    .timeline{\n      display:flex;gap:12px;align-items:center;justify-content:center;margin-top:10px;\n    }\n    .step{\n      min-width:86px;height:46px;border-radius:10px;padding:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.02); display:flex;flex-direction:column;align-items:center;justify-content:center;\n      color:var(--muted); font-size:12px;transition:all .26s;\n    }\n    .step.active{ background:linear-gradient(90deg, rgba(126,92,255,0.12), rgba(78,225,193,0.06)); color: #eafcff; transform:scale(1.04); box-shadow:0 10px 30px rgba(12,16,30,0.6) }\n\n    /* small code card */\n    .code{\n      margin-top:12px;padding:12px;border-radius:10px;background:linear-gradient(180deg, rgba(0,0,0,0.12), rgba(255,255,255,0.02));\n      border:1px solid rgba(255,255,255,0.02); color:#dceffd; font-family: \"Space Grotesk\", monospace; font-size:13px;\n      line-height:1.5;\n    }\n    .muted-note{font-size:12px;color:var(--muted); margin-top:6px}\n\n    /* small label landing */\n    .legend{display:flex;gap:10px;align-items:center; justify-content:center; margin-top:10px}\n    .legend .item{display:flex;gap:8px;align-items:center;color:var(--muted); font-size:13px}\n    .swatch{width:12px;height:12px;border-radius:3px;box-shadow:0 6px 20px rgba(0,0,0,0.5)}\n\n    /* responsiveness */\n    @media (max-width:980px){\n      .wrap{grid-template-columns:1fr; padding:20px}\n      .network{padding:0 20px}\n      .node{width:44%}\n    }\n  </style>\n</head>\n<body>\n  <!-- Ambient orbs -->\n  <div class=\"orbs\" aria-hidden=\"true\">\n    <div class=\"orb a\"></div>\n    <div class=\"orb b\"></div>\n    <div class=\"orb c\"></div>\n  </div>\n\n  <div class=\"wrap\" role=\"main\">\n    <div class=\"panel info\" aria-labelledby=\"title\">\n      <div class=\"title\">\n        <div class=\"logo\">SP</div>\n        <div>\n          <h1 id=\"title\">Socket Programming — Visual Guide</h1>\n          <p class=\"lead\">A distilled, animated depiction of how sockets enable two endpoints to establish a connection, exchange data, and close gracefully.</p>\n        </div>\n      </div>\n\n      <div class=\"meta\" aria-hidden=\"true\">\n        <div class=\"chip\"><span class=\"dot\"></span> TCP-like handshake</div>\n        <div class=\"chip\">Full-duplex data flow</div>\n        <div class=\"chip\">Sequence & ACK visualization</div>\n      </div>\n\n      <div style=\"margin-top:10px; font-size:13px; color:var(--muted); line-height:1.6\">\n        Sockets provide the endpoint abstraction for network communication. This illustration animates the lifecycle:\n        initiating a connection (SYN), acknowledging (SYN-ACK / ACK), exchanging data packets, and performing a clean close (FIN).\n      </div>\n\n      <div style=\"margin-top:12px; font-weight:700; color:#dffaf0\">Minimal controls</div>\n      <div class=\"muted-note\">Click Start to run the neat, self-contained animation. Reset stops and returns to the initial state.</div>\n\n      <div class=\"controls\">\n        <button id=\"startBtn\" class=\"btn\" aria-pressed=\"false\" title=\"Start animation\">Start</button>\n        <button id=\"resetBtn\" class=\"btn secondary\" title=\"Reset animation\">Reset</button>\n      </div>\n\n      <div class=\"code\" aria-hidden=\"true\">\n        // Pseudo socket lifecycle (in many languages)<br>\n        socket = socket(domain, type, protocol);<br>\n        socket.connect(address); // SYN → SYN-ACK → ACK<br>\n        socket.send(data); // reliable, ordered stream<br>\n        socket.close(); // FIN → ACK → FIN → ACK\n      </div>\n\n    </div>\n\n    <div class=\"panel visual\" aria-hidden=\"false\">\n      <div class=\"viewport\" role=\"img\" aria-label=\"Animated representation of socket connection lifecycle\">\n        <div class=\"network\" id=\"network\">\n          <!-- Client Node -->\n          <div class=\"node client\" id=\"clientNode\" style=\"transform:translateZ(0);\">\n            <div class=\"label\">Client</div>\n            <div class=\"sub\">127.0.0.1 : 49152</div>\n            <div class=\"ports\">\n              <div class=\"port\">socket()</div>\n              <div class=\"port\">connect()</div>\n            </div>\n            <div style=\"position:absolute;left:18px;bottom:12px;font-size:12px;color:var(--muted)\">Application</div>\n          </div>\n\n          <!-- Wire -->\n          <div class=\"wire thin\" style=\"top:50%; left:50%; width:40%;\"></div>\n          <div class=\"wire\" id=\"mainWire\" style=\"top:50%; left:50%; width:56%; opacity:0.18;\"></div>\n\n          <!-- Server Node -->\n          <div class=\"node server\" id=\"serverNode\">\n            <div class=\"label\">Server</div>\n            <div class=\"sub\">0.0.0.0 : 8080</div>\n            <div class=\"ports\" style=\"justify-content:flex-end\">\n              <div class=\"port\">bind()</div>\n              <div class=\"port\">listen()</div>\n            </div>\n            <div style=\"position:absolute;right:18px;bottom:12px;font-size:12px;color:var(--muted)\">Process</div>\n          </div>\n\n          <!-- Moving packets container -->\n          <div id=\"packets\"></div>\n\n          <!-- status -->\n          <div class=\"status-badge\" id=\"statusBadge\">Idle</div>\n        </div>\n\n      </div>\n\n      <div class=\"timeline\" id=\"timeline\" aria-hidden=\"true\">\n        <div class=\"step\" data-step=\"0\">SYN</div>\n        <div class=\"step\" data-step=\"1\">SYN-ACK</div>\n        <div class=\"step\" data-step=\"2\">ACK</div>\n        <div class=\"step\" data-step=\"3\">Established</div>\n        <div class=\"step\" data-step=\"4\">Data</div>\n        <div class=\"step\" data-step=\"5\">FIN</div>\n      </div>\n\n      <div class=\"legend\" aria-hidden=\"true\">\n        <div class=\"item\"><span class=\"swatch\" style=\"background:linear-gradient(90deg,#ffb86b,#ff6b6b)\"></span> Control (SYN)</div>\n        <div class=\"item\"><span class=\"swatch\" style=\"background:linear-gradient(90deg,#a9f1d3,#4ee1c1)\"></span> Acknowledgement (ACK)</div>\n        <div class=\"item\"><span class=\"swatch\" style=\"background:linear-gradient(90deg,#fff, #f7f7f9)\"></span> Data</div>\n      </div>\n\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      // Minimal, deliberate interactivity: Start and Reset\n      const startBtn = document.getElementById('startBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const packetsRoot = document.getElementById('packets');\n      const status = document.getElementById('statusBadge');\n      const timeline = document.getElementById('timeline');\n      const steps = Array.from(timeline.querySelectorAll('.step'));\n\n      let timers = [];\n      let running = false;\n\n      // Utility to clear all packets and timers\n      function resetAll(){\n        timers.forEach(t => clearTimeout(t));\n        timers = [];\n        packetsRoot.innerHTML = '';\n        status.textContent = 'Idle';\n        steps.forEach(s => s.classList.remove('active'));\n        startBtn.disabled = false;\n        startBtn.setAttribute('aria-pressed','false');\n        running = false;\n      }\n\n      // Create a packet element with given label and class\n      function makePacket(label, cls){\n        const el = document.createElement('div');\n        el.className = 'packet ' + cls;\n        el.textContent = label;\n        // position initial near left side (client)\n        // We'll place centrally and animate via transform\n        const net = document.getElementById('network');\n        el.style.left = '50%';\n        el.style.top = '50%';\n        el.style.transform = 'translateX(-50%) translateY(-50%)';\n        // Compact offset to align visually\n        packetsRoot.appendChild(el);\n        return el;\n      }\n\n      // Activate timeline step\n      function markStep(i){\n        steps.forEach((s,idx)=> s.classList.toggle('active', idx === i));\n      }\n\n      function runSequence(){\n        if (running) return;\n        running = true;\n        startBtn.disabled = true;\n        startBtn.setAttribute('aria-pressed','true');\n\n        // Sequence timings (ms)\n        const seq = [\n          { t: 400, fn: () => { // SYN from client to server\n            status.textContent = 'Sending SYN';\n            markStep(0);\n            const p = makePacket('SYN', 'syn');\n            // animate to server (move-right)\n            requestAnimationFrame(()=> p.classList.add('move-right'));\n            timers.push(setTimeout(()=> { p.remove(); }, 1400));\n          }},\n          { t: 1600, fn: () => { // SYN-ACK from server to client\n            status.textContent = 'SYN-ACK';\n            markStep(1);\n            const p = makePacket('SYN-ACK', 'ack');\n            // start near right and move-left\n            p.style.transform = 'translateX(50%) translateY(-50%)';\n            requestAnimationFrame(()=> p.classList.add('move-left'));\n            timers.push(setTimeout(()=> { p.remove(); }, 1400));\n          }},\n          { t: 3000, fn: () => { // ACK from client\n            status.textContent = 'ACK';\n            markStep(2);\n            const p = makePacket('ACK', 'ack');\n            requestAnimationFrame(()=> p.classList.add('move-right'));\n            timers.push(setTimeout(()=> { p.remove(); }, 1000));\n          }},\n          { t: 3800, fn: () => { // Established\n            status.textContent = 'Connection Established';\n            markStep(3);\n            const wire = document.getElementById('mainWire');\n            wire.style.opacity = '1';\n            wire.style.filter = 'drop-shadow(0 6px 22px rgba(78,225,193,0.12))';\n          }},\n          { t: 4800, fn: () => { // Data exchange - multiple data packets\n            markStep(4);\n            status.textContent = 'Exchanging Data';\n            // generate a ping-pong of packets\n            let offset = 0;\n            for (let i=0;i<6;i++){\n              const delay = i*380;\n              timers.push(setTimeout(()=> {\n                const isEven = i%2===0;\n                const label = isEven ? 'DATA' : 'DATA';\n                const p = makePacket(label, 'data');\n                // slight vertical offset to make it pleasing\n                p.style.top = isEven ? '45%' : '55%';\n                if (isEven){\n                  p.style.transform = 'translateX(-50%) translateY(-50%)';\n                  requestAnimationFrame(()=> p.classList.add('move-right'));\n                } else {\n                  p.style.transform = 'translateX(50%) translateY(-50%)';\n                  requestAnimationFrame(()=> p.classList.add('move-left'));\n                }\n                // add small fade after transit\n                timers.push(setTimeout(()=> { p.remove(); }, 900));\n              }, delay));\n              offset = delay;\n            }\n          }},\n          { t: 7600, fn: () => { // Client initiates close: FIN\n            markStep(5);\n            status.textContent = 'Closing (FIN)';\n            const p = makePacket('FIN', 'fin');\n            requestAnimationFrame(()=> p.classList.add('move-right'));\n            timers.push(setTimeout(()=> { p.remove(); }, 1100));\n          }},\n          { t: 8800, fn: () => { // Server ACK then FIN\n            status.textContent = 'FIN-ACK / Server FIN';\n            // ACK from server (back)\n            const a = makePacket('ACK', 'ack');\n            a.style.transform = 'translateX(50%) translateY(-50%)';\n            requestAnimationFrame(()=> a.classList.add('move-left'));\n            timers.push(setTimeout(()=> { a.remove(); }, 700));\n            // server FIN shortly after\n            timers.push(setTimeout(()=> {\n              const f = makePacket('FIN', 'fin');\n              f.style.transform = 'translateX(50%) translateY(-50%)';\n              requestAnimationFrame(()=> f.classList.add('move-left'));\n              timers.push(setTimeout(()=> f.remove(), 900));\n            }, 240));\n          }},\n          { t: 9800, fn: () => { // Final ACK\n            status.textContent = 'Final ACK — Closed';\n            const p = makePacket('ACK', 'ack');\n            requestAnimationFrame(()=> p.classList.add('move-right'));\n            timers.push(setTimeout(()=> { p.remove(); }, 900));\n            // visual end state\n            timers.push(setTimeout(()=> {\n              status.textContent = 'Closed';\n              const wire = document.getElementById('mainWire');\n              wire.style.opacity = '0.18';\n              wire.style.filter = 'none';\n              markStep(-1);\n              // small glow around nodes to signal end\n              pulseNodes();\n              // allow restart\n              startBtn.disabled = false;\n              startBtn.setAttribute('aria-pressed','false');\n              running = false;\n            }, 900));\n          }}\n        ];\n\n        // schedule events\n        seq.forEach(item => {\n          const t = setTimeout(item.fn, item.t);\n          timers.push(t);\n        });\n      }\n\n      function pulseNodes(){\n        const client = document.getElementById('clientNode');\n        const server = document.getElementById('serverNode');\n        client.animate([{boxShadow: '0 10px 30px rgba(2,6,23,0.5)'},{boxShadow: '0 18px 50px rgba(78,225,193,0.12)'},{boxShadow: '0 10px 30px rgba(2,6,23,0.5)'}],{duration:800,iterations:2});\n        server.animate([{boxShadow: '0 10px 30px rgba(2,6,23,0.5)'},{boxShadow: '0 18px 50px rgba(126,92,255,0.12)'},{boxShadow:'0 10px 30px rgba(2,6,23,0.5)'}],{duration:900,iterations:2});\n      }\n\n      startBtn.addEventListener('click', runSequence);\n      resetBtn.addEventListener('click', resetAll);\n\n      // Initialize to clean state\n      resetAll();\n\n      // Small accessibility: keyboard activation\n      startBtn.addEventListener('keydown', (e)=>{\n        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); runSequence(); }\n      });\n      resetBtn.addEventListener('keydown', (e)=>{\n        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); resetAll(); }\n      });\n\n    })();\n  </script>\n</body>\n</html>"
  },
