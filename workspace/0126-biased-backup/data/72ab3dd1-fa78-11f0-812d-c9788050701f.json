    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Big-Omega Notation Visualizer</title>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Source+Code+Pro:wght@400;600&display=swap');\n        \n        :root {\n            --primary: #6C63FF;\n            --secondary: #FF6584;\n            --dark: #2D3748;\n            --light: #F7FAFC;\n            --accent: #4FD1C5;\n        }\n        \n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            font-family: 'Montserrat', sans-serif;\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n        \n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n        \n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n        }\n        \n        h1 {\n            font-size: 3.5rem;\n            font-weight: 700;\n            margin-bottom: 1rem;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            position: relative;\n            display: inline-block;\n        }\n        \n        h1::after {\n            content: '';\n            position: absolute;\n            bottom: -10px;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 150px;\n            height: 4px;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            border-radius: 2px;\n        }\n        \n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n        \n        .visualization-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin: 3rem 0;\n            perspective: 1000px;\n        }\n        \n        .graph-container {\n            width: 100%;\n            max-width: 800px;\n            height: 500px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            position: relative;\n            overflow: hidden;\n            transform-style: preserve-3d;\n            transition: transform 0.5s ease;\n            margin-bottom: 2rem;\n        }\n        \n        .graph-container:hover {\n            transform: translateY(-5px) rotateX(5deg);\n        }\n        \n        .graph {\n            width: 100%;\n            height: 100%;\n            position: relative;\n        }\n        \n        .axis {\n            position: absolute;\n            background: var(--dark);\n        }\n        \n        .x-axis {\n            width: 80%;\n            height: 2px;\n            bottom: 50px;\n            left: 50px;\n        }\n        \n        .y-axis {\n            width: 2px;\n            height: 80%;\n            bottom: 50px;\n            left: 50px;\n        }\n        \n        .axis-label {\n            position: absolute;\n            font-family: 'Source Code Pro', monospace;\n            font-weight: 600;\n            color: var(--dark);\n        }\n        \n        .x-label {\n            bottom: 30px;\n            right: 50px;\n        }\n        \n        .y-label {\n            transform: rotate(-90deg);\n            transform-origin: left top;\n            top: 50%;\n            left: 20px;\n        }\n        \n        .function-line {\n            position: absolute;\n            height: 3px;\n            background: var(--primary);\n            bottom: 50px;\n            left: 50px;\n            transform-origin: left center;\n            animation: drawLine 2s ease-out forwards;\n            opacity: 0;\n            border-radius: 3px;\n        }\n        \n        .omega-line {\n            background: var(--secondary);\n            animation-delay: 0.5s;\n        }\n        \n        .line-label {\n            position: absolute;\n            font-family: 'Source Code Pro', monospace;\n            font-weight: 600;\n            padding: 0.3rem 0.6rem;\n            border-radius: 20px;\n            transform: translateY(-50%);\n            right: -5px;\n            white-space: nowrap;\n        }\n        \n        .function-label {\n            background: linear-gradient(90deg, rgba(108, 99, 255, 0.2), rgba(108, 99, 255, 0.1));\n            color: var(--primary);\n        }\n        \n        .omega-label {\n            background: linear-gradient(90deg, rgba(255, 101, 132, 0.2), rgba(255, 101, 132, 0.1));\n            color: var(--secondary);\n        }\n        \n        .data-point {\n            position: absolute;\n            width: 8px;\n            height: 8px;\n            background: var(--accent);\n            border-radius: 50%;\n            transform: translate(-50%, -50%);\n            opacity: 0;\n            animation: fadeInPoints 2s ease-out forwards;\n            animation-delay: 1s;\n        }\n        \n        .point-connector {\n            position: absolute;\n            height: 1px;\n            background: rgba(79, 209, 197, 0.3);\n            bottom: 50px;\n            left: 50px;\n            transform-origin: left center;\n        }\n        \n        .control-panel {\n            display: flex;\n            justify-content: center;\n            margin: 2rem 0;\n        }\n        \n        .btn {\n            padding: 0.8rem 1.5rem;\n            margin: 0 1rem;\n            border: none;\n            border-radius: 50px;\n            font-family: 'Montserrat', sans-serif;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n        }\n        \n        .btn-primary {\n            background: var(--primary);\n            color: white;\n        }\n        \n        .btn-secondary {\n            background: white;\n            color: var(--primary);\n            border: 2px solid var(--primary);\n        }\n        \n        .btn:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);\n        }\n        \n        .btn:active {\n            transform: translateY(0);\n        }\n        \n        .explanation {\n            max-width: 800px;\n            margin: 3rem auto;\n            background: white;\n            padding: 2rem;\n            border-radius: 20px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n        }\n        \n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.8rem;\n        }\n        \n        .explanation p {\n            line-height: 1.8;\n            margin-bottom: 1.5rem;\n            color: var(--dark);\n            opacity: 0.9;\n        }\n        \n        .code-block {\n            background: rgba(45, 55, 72, 0.05);\n            padding: 1rem;\n            border-radius: 10px;\n            font-family: 'Source Code Pro', monospace;\n            margin: 1.5rem 0;\n            overflow-x: auto;\n        }\n        \n        .formula {\n            font-size: 1.5rem;\n            text-align: center;\n            margin: 2rem 0;\n            color: var(--primary);\n            font-family: 'Source Code Pro', monospace;\n        }\n        \n        footer {\n            text-align: center;\n            margin-top: 4rem;\n            padding: 2rem;\n            color: var(--dark);\n            opacity: 0.7;\n            font-size: 0.9rem;\n        }\n        \n        @keyframes drawLine {\n            0% {\n                width: 0;\n                opacity: 0;\n            }\n            100% {\n                width: 80%;\n                opacity: 1;\n            }\n        }\n        \n        @keyframes fadeInPoints {\n            0% {\n                opacity: 0;\n            }\n            100% {\n                opacity: 1;\n            }\n        }\n        \n        .pulse {\n            animation: pulse 2s infinite;\n        }\n        \n        @keyframes pulse {\n            0% {\n                box-shadow: 0 0 0 0 rgba(108, 99, 255, 0.4);\n            }\n            70% {\n                box-shadow: 0 0 0 15px rgba(108, 99, 255, 0);\n            }\n            100% {\n                box-shadow: 0 0 0 0 rgba(108, 99, 255, 0);\n            }\n        }\n        \n        .gradient-bg {\n            position: absolute;\n            width: 300px;\n            height: 300px;\n            border-radius: 50%;\n            filter: blur(60px);\n            opacity: 0.5;\n            z-index: -1;\n        }\n        \n        .bg-1 {\n            background: var(--primary);\n            top: -100px;\n            right: -100px;\n        }\n        \n        .bg-2 {\n            background: var(--secondary);\n            bottom: -100px;\n            left: -100px;\n        }\n        \n        @media (max-width: 768px) {\n            h1 {\n                font-size: 2.5rem;\n            }\n            \n            .graph-container {\n                height: 400px;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"gradient-bg bg-1\"></div>\n    <div class=\"gradient-bg bg-2\"></div>\n    \n    <div class=\"container\">\n        <header>\n            <h1>Big-Ω Notation</h1>\n            <p class=\"subtitle\">Understanding asymptotic lower bounds in algorithm analysis through intuitive visualizations</p>\n        </header>\n        \n        <div class=\"visualization-container\">\n            <div class=\"graph-container pulse\">\n                <div class=\"graph\">\n                    <div class=\"axis x-axis\"></div>\n                    <div class=\"axis y-axis\"></div>\n                    <span class=\"axis-label x-label\">Input Size (n)</span>\n                    <span class=\"axis-label y-label\">Time Complexity</span>\n                    \n                    <div class=\"function-line\" style=\"transform: rotate(30deg); width: 0;\"></div>\n                    <span class=\"line-label function-label\" style=\"top: calc(100% - 50px - 15px); right: 50px;\">f(n) = n log n</span>\n                    \n                    <div class=\"function-line omega-line\" style=\"transform: rotate(15deg); width: 0;\"></div>\n                    <span class=\"line-label omega-label\" style=\"top: calc(100% - 50px - 40px); right: 50px;\">Ω(n)</span>\n                    \n                    <div class=\"point-connector\" style=\"transform: rotate(15deg); width: 50%;\"></div>\n                    <div class=\"data-point\" style=\"left: 60%; top: calc(100% - 50px - 15px);\"></div>\n                    \n                    <div class=\"point-connector\" style=\"transform: rotate(30deg); width: 50%;\"></div>\n                    <div class=\"data-point\" style=\"left: 60%; top: calc(100% - 50px - 40px);\"></div>\n                </div>\n            </div>\n            \n            <div class=\"control-panel\">\n                <button class=\"btn btn-primary\" id=\"animateBtn\">Animate</button>\n                <button class=\"btn btn-secondary\" id=\"resetBtn\">Reset</button>\n            </div>\n        </div>\n        \n        <div class=\"explanation\">\n            <h2>What is Big-Omega Notation?</h2>\n            <p>Big-Omega (Ω) notation is used in computer science to describe the asymptotic lower bound of an algorithm's running time. It provides a way to express the minimum amount of time an algorithm will take to complete as the input size grows.</p>\n            \n            <p>When we say an algorithm is <em>Ω(f(n))</em>, we mean that the algorithm's running time grows <em>at least as fast as</em> f(n) as n becomes very large. In other words, the algorithm can't do better than this lower bound in the worst case.</p>\n            \n            <div class=\"formula\">\n                Ω(f(n)) = { g(n) | ∃ c > 0, n₀ > 0 : 0 ≤ c·f(n) ≤ g(n) ∀ n ≥ n₀ }\n            </div>\n            \n            <h2>Key Characteristics</h2>\n            <p>Big-Omega notation represents the best-case scenario for an algorithm's running time. Some important points:</p>\n            \n            <div class=\"code-block\">\n                // Common Big-Omega classifications<br>\n                Ω(1) - Constant time (best possible)<br>\n                Ω(log n) - Logarithmic time<br>\n                Ω(n) - Linear time<br>\n                Ω(n log n) - Linearithmic time<br>\n                Ω(n²) - Quadratic time<br>\n                Ω(2ⁿ) - Exponential time\n            </div>\n            \n            <p>Unlike Big-O notation which provides an upper bound, Big-Omega gives a lower bound. When an algorithm has the same upper and lower bound (Θ notation), we can be precise about its performance characteristics.</p>\n        </div>\n    </div>\n    \n    <footer>\n        <p>Big-Omega Notation Visualizer | Designed for algorithm analysis</p>\n    </footer>\n    \n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const animateBtn = document.getElementById('animateBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const graphContainer = document.querySelector('.graph-container');\n            const functionLines = document.querySelectorAll('.function-line');\n            const dataPoints = document.querySelectorAll('.data-point');\n            const pointConnectors = document.querySelectorAll('.point-connector');\n            \n            animateBtn.addEventListener('click', function() {\n                // Reset animations first\n                resetAnimations();\n                \n                // Animate the graph container\n                graphContainer.classList.remove('pulse');\n                graphContainer.style.transform = 'translateY(-5px) rotateX(5deg)';\n                \n                // Animate function lines\n                functionLines.forEach(line => {\n                    line.style.width = '80%';\n                    line.style.opacity = '1';\n                });\n                \n                // Animate data points and connectors\n                setTimeout(() => {\n                    dataPoints.forEach(point => {\n                        point.style.opacity = '1';\n                    });\n                    \n                    pointConnectors.forEach(connector => {\n                        connector.style.width = '80%';\n                    });\n                }, 1000);\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                resetAnimations();\n                graphContainer.classList.add('pulse');\n                graphContainer.style.transform = '';\n            });\n            \n            function resetAnimations() {\n                functionLines.forEach(line => {\n                    line.style.width = '0';\n                    line.style.opacity = '0';\n                });\n                \n                dataPoints.forEach(point => {\n                    point.style.opacity = '0';\n                });\n                \n                pointConnectors.forEach(connector => {\n                    connector.style.width = '0';\n                });\n            }\n            \n            // Initial animation\n            setTimeout(() => {\n                animateBtn.click();\n            }, 500);\n        });\n    </script>\n</body>\n</html>"
