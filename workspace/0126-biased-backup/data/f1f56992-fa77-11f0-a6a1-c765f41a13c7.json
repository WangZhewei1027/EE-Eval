    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Graph (Undirected) — Visual Concept</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@400;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg1: #0f1724;\n      --bg2: #081024;\n      --accent: #7be3ff;\n      --accent-2: #8affc1;\n      --glass: rgba(255,255,255,0.06);\n      --muted: rgba(255,255,255,0.6);\n      --card-radius: 20px;\n    }\n\n    html,body{\n      height:100%;\n      margin:0;\n      background: radial-gradient(1200px 600px at 10% 20%, rgba(60,90,120,0.12), transparent),\n                  radial-gradient(1000px 500px at 90% 80%, rgba(100,40,160,0.07), transparent),\n                  linear-gradient(180deg,var(--bg1),var(--bg2));\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color: #eaf6ff;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    .stage{\n      height:100%;\n      display:grid;\n      place-items:center;\n      padding:48px;\n      box-sizing:border-box;\n    }\n\n    .card{\n      width:min(1100px,94vw);\n      height:min(720px,86vh);\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));\n      border-radius:var(--card-radius);\n      box-shadow: 0 8px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n      border: 1px solid rgba(255,255,255,0.03);\n      backdrop-filter: blur(8px) saturate(1.05);\n      overflow:hidden;\n      position:relative;\n      display:flex;\n      flex-direction:column;\n      padding:28px;\n    }\n\n    .header{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:20px;\n      margin-bottom:14px;\n    }\n\n    .title{\n      display:flex;\n      gap:18px;\n      align-items:center;\n    }\n\n    .logo{\n      width:72px;\n      height:72px;\n      border-radius:14px;\n      background: linear-gradient(135deg, rgba(123,227,255,0.14), rgba(138,255,193,0.08));\n      display:grid;\n      place-items:center;\n      box-shadow: 0 6px 20px rgba(80,150,200,0.06), inset 0 1px 0 rgba(255,255,255,0.03);\n      flex-shrink:0;\n    }\n\n    .logo .monogram{\n      font-family: \"Playfair Display\", serif;\n      font-weight:700;\n      color: transparent;\n      -webkit-text-stroke: 1px rgba(255,255,255,0.18);\n      font-size:22px;\n      letter-spacing:0.6px;\n    }\n\n    .heading{\n      display:flex;\n      flex-direction:column;\n      line-height:1;\n    }\n\n    .heading .main{\n      font-family: \"Playfair Display\", serif;\n      font-size:20px;\n      font-weight:700;\n      color: #ffffff;\n      letter-spacing:0.2px;\n    }\n\n    .heading .sub{\n      font-size:12.5px;\n      color: var(--muted);\n      margin-top:6px;\n      max-width:620px;\n    }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n    }\n\n    .btn{\n      appearance:none;\n      border:0;\n      padding:10px 14px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:var(--muted);\n      font-weight:600;\n      font-size:13px;\n      cursor:pointer;\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n      box-shadow: 0 6px 18px rgba(5,8,16,0.5);\n      transition: all 280ms cubic-bezier(.2,.9,.2,1);\n      backdrop-filter: blur(6px);\n    }\n\n    .btn:active{ transform: translateY(1px) scale(.998); }\n    .btn.primary{\n      background: linear-gradient(90deg, rgba(123,227,255,0.14), rgba(138,255,193,0.06));\n      color: #00121a;\n      box-shadow: 0 8px 30px rgba(50,200,220,0.06);\n    }\n\n    .btn.toggle.active{\n      box-shadow: 0 10px 30px rgba(43,200,200,0.12);\n      transform: translateY(-2px);\n    }\n\n    /* Canvas area */\n    .canvas-wrap{\n      flex:1;\n      position:relative;\n      display:flex;\n      gap:18px;\n      align-items:stretch;\n    }\n\n    .canvas{\n      flex:1;\n      border-radius:14px;\n      overflow:hidden;\n      position:relative;\n      display:flex;\n      align-items:stretch;\n      justify-content:stretch;\n      padding:18px;\n    }\n\n    svg{\n      width:100%;\n      height:100%;\n      display:block;\n    }\n\n    /* Side info */\n    .info{\n      width:260px;\n      padding:18px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: 0 6px 20px rgba(0,0,0,0.45);\n      border:1px solid rgba(255,255,255,0.02);\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.5;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n\n    .info h4{\n      margin:0;\n      font-size:13px;\n      color:#dff8ff;\n      letter-spacing:0.2px;\n      font-weight:600;\n      font-family: \"Playfair Display\", serif;\n    }\n\n    .info p{ margin:0; color:var(--muted); font-size:13px; }\n\n    .stats{\n      margin-top:auto;\n      display:flex;\n      gap:10px;\n      align-items:center;\n      justify-content:space-between;\n    }\n\n    .stat{\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      padding:10px;\n      border-radius:10px;\n      text-align:center;\n      flex:1;\n      border: 1px solid rgba(255,255,255,0.02);\n    }\n\n    .stat .num{\n      font-weight:700;\n      font-size:16px;\n      color:#dff8ff;\n    }\n\n    .muted-small{ color:var(--muted); font-size:12px; margin-top:6px; }\n\n    /* Node and edge styles (fallback) */\n    .node-label{\n      pointer-events:none;\n      font-weight:600;\n      font-size:12px;\n      fill:#00121a;\n      text-anchor:middle;\n      dominant-baseline:middle;\n      transform-origin:center center;\n      opacity:0.98;\n    }\n\n    .edge{\n      stroke-linecap:round;\n      stroke-linejoin:round;\n      mix-blend-mode: screen;\n    }\n\n    /* subtle floating vignette */\n    .vignette{\n      position:absolute;\n      inset:0;\n      pointer-events:none;\n      background: radial-gradient(800px 400px at 30% 20%, rgba(255,255,255,0.02), transparent),\n                  radial-gradient(600px 360px at 80% 80%, rgba(150,60,180,0.03), transparent);\n      mix-blend-mode: overlay;\n    }\n\n    /* small responsive tweaks */\n    @media (max-width:980px){\n      .info{ display:none; }\n      .logo{ width:58px; height:58px; }\n      .heading .main{ font-size:18px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"stage\" role=\"main\">\n    <div class=\"card\" aria-label=\"Undirected graph demonstration\">\n      <div class=\"header\">\n        <div class=\"title\">\n          <div class=\"logo\" aria-hidden=\"true\">\n            <div class=\"monogram\">G</div>\n          </div>\n          <div class=\"heading\">\n            <div class=\"main\">Graph (Undirected)</div>\n            <div class=\"sub\">A polished visual concept showcasing an undirected graph — nodes connected by symmetrical edges. Observe the structure, flow and balance; interactions are intentionally minimal.</div>\n          </div>\n        </div>\n\n        <div class=\"controls\" role=\"toolbar\" aria-label=\"Graph controls\">\n          <button id=\"toggleAnimate\" class=\"btn toggle primary active\" aria-pressed=\"true\" title=\"Toggle animation\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"display:block\">\n              <path d=\"M2 12a10 10 0 1 0 20 0 10 10 0 0 0-20 0z\" stroke=\"#00262b\" stroke-width=\"1.2\" opacity=\"0.9\" />\n              <path d=\"M8 12c0-2.2 1.8-4 4-4v8c-2.2 0-4-1.8-4-4z\" fill=\"#00262b\"/>\n            </svg>\n            Animate\n          </button>\n\n          <button id=\"toggleLabels\" class=\"btn\" aria-pressed=\"true\" title=\"Toggle labels\">\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"display:block\">\n              <path d=\"M4 7h16M4 12h9M4 17h7\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n            </svg>\n            Labels\n          </button>\n        </div>\n      </div>\n\n      <div class=\"canvas-wrap\">\n        <div class=\"canvas\" aria-hidden=\"false\">\n          <svg id=\"graphSvg\" viewBox=\"0 0 1000 640\" preserveAspectRatio=\"xMidYMid meet\" role=\"img\" aria-label=\"Undirected graph visualization\">\n            <defs>\n              <linearGradient id=\"edgeGrad\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0%\" stop-color=\"#7be3ff\" stop-opacity=\"0.9\" />\n                <stop offset=\"100%\" stop-color=\"#8affc1\" stop-opacity=\"0.7\" />\n              </linearGradient>\n\n              <radialGradient id=\"nodeGlow\" cx=\"50%\" cy=\"40%\">\n                <stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\"0.95\"/>\n                <stop offset=\"35%\" stop-color=\"#7be3ff\" stop-opacity=\"0.18\"/>\n                <stop offset=\"100%\" stop-color=\"#00121a\" stop-opacity=\"0\"/>\n              </radialGradient>\n\n              <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur in=\"SourceGraphic\" stdDeviation=\"8\" result=\"blur\"/>\n                <feMerge>\n                  <feMergeNode in=\"blur\"/>\n                  <feMergeNode in=\"SourceGraphic\"/>\n                </feMerge>\n              </filter>\n\n              <filter id=\"shadow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feDropShadow dx=\"0\" dy=\"8\" stdDeviation=\"14\" flood-color=\"#000000\" flood-opacity=\"0.45\"/>\n              </filter>\n\n              <filter id=\"edgeGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur in=\"SourceGraphic\" stdDeviation=\"4\" result=\"blur1\"/>\n                <feColorMatrix in=\"blur1\" type=\"matrix\" values=\"0 0 0 0 0.48 0 0 0 0 0.89 0 0 0 0 0.82 0 0 0 0.9 0\" />\n                <feMerge>\n                  <feMergeNode/>\n                  <feMergeNode in=\"SourceGraphic\"/>\n                </feMerge>\n              </filter>\n\n              <filter id=\"glass\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                <feGaussianBlur in=\"SourceGraphic\" stdDeviation=\"2\" result=\"blur\"/>\n                <feComponentTransfer in=\"blur\">\n                  <feFuncA type=\"table\" tableValues=\"0 0.6\"/>\n                </feComponentTransfer>\n                <feMerge>\n                  <feMergeNode in=\"blur\" />\n                  <feMergeNode in=\"SourceGraphic\" />\n                </feMerge>\n              </filter>\n            </defs>\n\n            <!-- decorative backdrop circle -->\n            <g id=\"backdrop\" transform=\"translate(500,320)\">\n              <circle r=\"260\" fill=\"url(#nodeGlow)\" opacity=\"0.07\" />\n              <circle r=\"340\" fill=\"none\" stroke=\"rgba(255,255,255,0.02)\" stroke-width=\"1\" />\n            </g>\n\n            <!-- graph group -->\n            <g id=\"graphGroup\" transform=\"translate(500,320)\"></g>\n\n            <!-- subtle grid / orbital rings -->\n            <g opacity=\"0.06\" stroke-linecap=\"round\" stroke=\"#ffffff\">\n              <circle cx=\"500\" cy=\"320\" r=\"120\" fill=\"none\" stroke-width=\"1\" />\n              <circle cx=\"500\" cy=\"320\" r=\"220\" fill=\"none\" stroke-width=\"1\" />\n            </g>\n\n            <!-- caption -->\n            <g transform=\"translate(32,600)\">\n              <text x=\"0\" y=\"0\" font-size=\"12\" fill=\"rgba(255,255,255,0.7)\" style=\"font-weight:600\">Undirected — symmetric edges • no arrows</text>\n              <text x=\"0\" y=\"18\" font-size=\"11\" fill=\"rgba(255,255,255,0.45)\">Nodes are arranged to emphasise balance; edges drawn as soft glowing links.</text>\n            </g>\n\n          </svg>\n          <div class=\"vignette\" aria-hidden=\"true\"></div>\n        </div>\n\n        <aside class=\"info\" aria-hidden=\"true\">\n          <h4>Concept</h4>\n          <p>This visualization presents an undirected graph: every connection is symmetric — there are no directed arrows. The design focuses on clarity, balance, and visual hierarchy.</p>\n\n          <h4 style=\"margin-top:8px\">Structure</h4>\n          <p>Nodes represent entities. Edges indicate relationships. Heavier visual weight emphasizes hubs and pathways.</p>\n\n          <div class=\"stats\">\n            <div class=\"stat\">\n              <div class=\"num\" id=\"nodeCount\">12</div>\n              <div class=\"muted-small\">Nodes</div>\n            </div>\n            <div class=\"stat\">\n              <div class=\"num\" id=\"edgeCount\">16</div>\n              <div class=\"muted-small\">Edges</div>\n            </div>\n          </div>\n        </aside>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Data for undirected graph (12 nodes, edges symmetric)\n    const nodes = [\n      {id: 'A'}, {id: 'B'}, {id: 'C'}, {id: 'D'},\n      {id: 'E'}, {id: 'F'}, {id: 'G'}, {id: 'H'},\n      {id: 'I'}, {id: 'J'}, {id: 'K'}, {id: 'L'}\n    ];\n\n    // Undirected edges (pairs of indices)\n    const edges = [\n      ['A','B'], ['A','C'], ['A','D'],\n      ['B','E'], ['B','F'],\n      ['C','G'], ['D','G'],\n      ['E','H'], ['F','H'], ['G','H'],\n      ['H','I'], ['I','J'], ['I','K'],\n      ['J','L'], ['K','L'], ['E','F']\n    ];\n\n    // Update counts\n    document.getElementById('nodeCount').textContent = nodes.length;\n    document.getElementById('edgeCount').textContent = edges.length;\n\n    const svg = document.getElementById('graphSvg');\n    const g = document.getElementById('graphGroup');\n\n    // Graph visual parameters\n    const R = 240; // base radius\n    const nodeRadius = 18;\n    const center = {x:0, y:0};\n\n    // Derived node positions (radial layout with slight perturbations)\n    const angleStep = (Math.PI*2) / nodes.length;\n    const baseAngles = nodes.map((n,i) => i * angleStep - Math.PI/2);\n    const nodeState = nodes.map((n,i) => {\n      const angle = baseAngles[i];\n      // each node will have its own wobble parameters\n      return {\n        id: n.id,\n        angle,\n        r: R * (0.6 + 0.3 * Math.sin(i * 1.2 + 0.3)),\n        ox: Math.cos(angle) * (R * 0.9),\n        oy: Math.sin(angle) * (R * 0.9),\n        // dynamic offsets\n        phase: Math.random()*Math.PI*2,\n        speed: 0.2 + Math.random()*0.7\n      };\n    });\n\n    // Create a map for quick index lookup\n    const nodeIndexById = {};\n    nodeState.forEach((n,i)=> nodeIndexById[n.id] = i);\n\n    // Build edges as references\n    const edgesState = edges.map(([a,b]) => {\n      return {a: nodeState[nodeIndexById[a]], b: nodeState[nodeIndexById[b]]};\n    });\n\n    // Create SVG elements\n    // Draw edges first (so nodes on top)\n    edgesState.forEach((e,i) => {\n      const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n      path.classList.add('edge');\n      path.setAttribute('data-edge', i);\n      path.setAttribute('fill','none');\n      path.setAttribute('stroke','url(#edgeGrad)');\n      path.setAttribute('stroke-width','4');\n      path.setAttribute('stroke-opacity','0.95');\n      path.setAttribute('filter','url(#edgeGlow)');\n      path.setAttribute('stroke-linecap','round');\n      path.setAttribute('stroke-linejoin','round');\n      // subtle variation\n      path.style.transition = 'stroke-width 300ms ease, opacity 300ms ease';\n      g.appendChild(path);\n      e.el = path;\n    });\n\n    // Draw nodes\n    nodeState.forEach((n,i) => {\n      const group = document.createElementNS('http://www.w3.org/2000/svg','g');\n      group.setAttribute('data-node', n.id);\n      group.style.cursor = 'default';\n      group.style.transition = 'transform 260ms cubic-bezier(.2,.9,.2,1), opacity 320ms ease';\n      // shadow halo\n      const halo = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      halo.setAttribute('r', nodeRadius + 10);\n      halo.setAttribute('fill','none');\n      halo.setAttribute('stroke','url(#edgeGrad)');\n      halo.setAttribute('stroke-opacity','0.09');\n      halo.setAttribute('stroke-width','18');\n      halo.setAttribute('filter','url(#softGlow)');\n      halo.style.pointerEvents = 'none';\n      group.appendChild(halo);\n\n      // glassy main circle\n      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      circle.setAttribute('r', nodeRadius);\n      circle.setAttribute('fill','url(#nodeGlow)');\n      circle.setAttribute('stroke','rgba(255,255,255,0.18)');\n      circle.setAttribute('stroke-width','1.1');\n      circle.setAttribute('filter','url(#glass)');\n      circle.style.transition = 'transform 260ms cubic-bezier(.2,.9,.2,1), opacity 300ms ease';\n      group.appendChild(circle);\n\n      // subtle inner sheen\n      const sheen = document.createElementNS('http://www.w3.org/2000/svg','ellipse');\n      sheen.setAttribute('cx',-6);\n      sheen.setAttribute('cy',-6);\n      sheen.setAttribute('rx',8);\n      sheen.setAttribute('ry',4);\n      sheen.setAttribute('fill','rgba(255,255,255,0.35)');\n      sheen.setAttribute('opacity','0.6');\n      sheen.style.mixBlendMode = 'screen';\n      group.appendChild(sheen);\n\n      // label (hidden by default toggled)\n      const labelBg = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      labelBg.setAttribute('x',-28);\n      labelBg.setAttribute('y',26);\n      labelBg.setAttribute('rx',8);\n      labelBg.setAttribute('ry',8);\n      labelBg.setAttribute('width',56);\n      labelBg.setAttribute('height',28);\n      labelBg.setAttribute('fill','rgba(0,18,26,0.9)');\n      labelBg.setAttribute('opacity','0.0');\n      labelBg.style.transition = 'opacity 220ms ease, transform 280ms cubic-bezier(.2,.9,.2,1)';\n      labelBg.style.pointerEvents = 'none';\n\n      const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n      label.setAttribute('class','node-label');\n      label.setAttribute('x',0);\n      label.setAttribute('y',44);\n      label.setAttribute('font-family','Inter, sans-serif');\n      label.setAttribute('font-size','12');\n      label.textContent = n.id;\n      label.style.fill = '#00121a';\n      label.style.fontWeight = 700;\n      label.style.opacity = 0;\n      label.style.transition = 'opacity 220ms ease, transform 280ms cubic-bezier(.2,.9,.2,1)';\n      label.style.pointerEvents = 'none';\n\n      group.appendChild(labelBg);\n      group.appendChild(label);\n\n      g.appendChild(group);\n      n.el = group;\n      n.labelEl = label;\n      n.labelBg = labelBg;\n      n.circleEl = circle;\n    });\n\n    // initial rendering position\n    function updatePositions(t){\n      // t in seconds\n      nodeState.forEach((n,i) => {\n        // gentle breathing/oscillation around radial orbit\n        const wobble = Math.sin(t * n.speed + n.phase) * 12; // radial wobble\n        const wobbleAngle = Math.cos(t * (0.6 + (n.speed*0.2)) + n.phase/1.5) * 0.06;\n        const r = n.r + wobble;\n        const angle = n.angle + wobbleAngle;\n        const x = Math.cos(angle) * r;\n        const y = Math.sin(angle) * r * 0.92;\n\n        n.cx = x;\n        n.cy = y;\n        // apply transform\n        n.el.setAttribute('transform', `translate(${x},${y})`);\n      });\n\n      // update edges (smooth quadratic curves)\n      edgesState.forEach((e,i) => {\n        const ax = e.a.cx, ay = e.a.cy;\n        const bx = e.b.cx, by = e.b.cy;\n        // control point is midpoint + small perpendicular offset for aesthetic curvature\n        const mx = (ax + bx)/2;\n        const my = (ay + by)/2;\n        const dx = bx - ax;\n        const dy = by - ay;\n        const len = Math.sqrt(dx*dx + dy*dy) || 1;\n        const nx = -dy/len;\n        const ny = dx/len;\n        const offset = 12 * Math.sin((ax+bx+ay+by)/80 + t*0.8 + i);\n        const cx = mx + nx * offset;\n        const cy = my + ny * offset;\n\n        const d = `M ${ax} ${ay} Q ${cx} ${cy} ${bx} ${by}`;\n        e.el.setAttribute('d', d);\n\n        // edge thickness relative to distance (closer nodes = stronger)\n        const thickness = 3 + Math.max(0, 7 - len / 28);\n        e.el.setAttribute('stroke-width', thickness.toFixed(2));\n        e.el.style.opacity = 0.95 - Math.min(0.55, (len/380));\n      });\n    }\n\n    // Animation loop\n    let start = null;\n    let animating = true;\n    let rotateAngle = 0;\n    const graphGroup = g;\n\n    function render(ts){\n      if (!start) start = ts;\n      const t = (ts - start) / 1000;\n      if (animating){\n        // gentle group rotation\n        rotateAngle = (t * 6) % 360;\n        graphGroup.setAttribute('transform', `translate(500,320) rotate(${rotateAngle})`);\n      } else {\n        graphGroup.setAttribute('transform', `translate(500,320) rotate(${rotateAngle})`);\n      }\n      updatePositions(t);\n      requestAnimationFrame(render);\n    }\n\n    // Initial tick to get positions\n    updatePositions(0);\n    requestAnimationFrame(render);\n\n    // Controls\n    const btnAnim = document.getElementById('toggleAnimate');\n    const btnLabels = document.getElementById('toggleLabels');\n\n    btnAnim.addEventListener('click', () => {\n      animating = !animating;\n      btnAnim.classList.toggle('active', animating);\n      btnAnim.setAttribute('aria-pressed', animating ? 'true' : 'false');\n      // small visual cue\n      if (animating){\n        btnAnim.animate([{transform:'translateY(0) scale(1)'},{transform:'translateY(-4px) scale(1.02)'}], {duration:260, fill:'forwards', easing:'cubic-bezier(.2,.9,.2,1)'});\n      } else {\n        btnAnim.animate([{transform:'translateY(-2px) scale(1.02)'},{transform:'translateY(0) scale(1)'}], {duration:240, fill:'forwards', easing:'cubic-bezier(.2,.9,.2,1)'});\n      }\n    });\n\n    // Label toggle (show/hide)\n    let labelsOn = true;\n    btnLabels.addEventListener('click', () => {\n      labelsOn = !labelsOn;\n      btnLabels.setAttribute('aria-pressed', labelsOn ? 'true' : 'false');\n      btnLabels.classList.toggle('active', labelsOn);\n      // transition labels\n      nodeState.forEach(n => {\n        if (labelsOn){\n          n.labelEl.style.opacity = 1;\n          n.labelBg.setAttribute('opacity', '0.9');\n        } else {\n          n.labelEl.style.opacity = 0;\n          n.labelBg.setAttribute('opacity', '0.0');\n        }\n      });\n    });\n\n    // Initial label state\n    nodeState.forEach(n => { n.labelEl.style.opacity = 1; n.labelBg.setAttribute('opacity','0.9'); });\n\n    // Subtle hover: when mouse moves near a node, highlight it lightly. This is minimal interactivity.\n    const svgRect = svg.getBoundingClientRect();\n    let lastHover = null;\n    svg.addEventListener('mousemove', (ev) => {\n      const rect = svg.getBoundingClientRect();\n      const svgX = (ev.clientX - rect.left) * (1000 / rect.width) - 500;\n      const svgY = (ev.clientY - rect.top) * (640 / rect.height) - 320;\n      // find nearest node within threshold\n      let nearest = null;\n      let bestD = 9999;\n      nodeState.forEach(n => {\n        const dx = svgX - n.cx;\n        const dy = svgY - n.cy;\n        const d = Math.sqrt(dx*dx + dy*dy);\n        if (d < bestD){ bestD = d; nearest = n; }\n      });\n      if (bestD < 40){\n        if (lastHover && lastHover !== nearest){\n          // reset previous\n          lastHover.circleEl.setAttribute('transform','scale(1)');\n          lastHover.labelEl.style.opacity = labelsOn ? 1 : 0;\n          lastHover.labelBg.setAttribute('opacity', labelsOn ? '0.9' : '0.0');\n        }\n        // emphasize current\n        nearest.circleEl.setAttribute('transform','scale(1.12)');\n        nearest.