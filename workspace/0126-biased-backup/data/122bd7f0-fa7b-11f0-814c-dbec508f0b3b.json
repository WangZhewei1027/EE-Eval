    "content": "<html>\n<head>\n    <title>Interpolation Search</title>\n    <style>\n        body {\n            background-color: #f0f0f0;\n        }\n        input, button, select, textarea {\n            width: 50%;\n            padding: 10px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n        select, textarea {\n            width: 100%;\n            padding: 10px;\n            margin: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        .error {\n            color: #f00;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interpolation Search</h1>\n    <p>Interpolation Search is a search algorithm that uses interpolation to estimate the location of the target element. It is particularly useful when the search space is large or unbounded.</p>\n    <button id=\"search-button\">Search</button>\n    <input id=\"search-input\" type=\"text\" placeholder=\"Enter search term\">\n    <select id=\"search-type\">\n        <option value=\"linear\">Linear Search</option>\n        <option value=\"interpolation\">Interpolation Search</option>\n    </select>\n    <button id=\"interpolation-button\">Interpolation Search</button>\n    <div id=\"result\"></div>\n\n    <script>\n        let searchType = 'linear';\n        let searchInput = document.getElementById('search-input');\n        let searchTypeSelect = document.getElementById('search-type');\n        let resultDiv = document.getElementById('result');\n        let searchButton = document.getElementById('search-button');\n        let interpolationButton = document.getElementById('interpolation-button');\n\n        searchButton.addEventListener('click', searchLinear);\n        interpolationButton.addEventListener('click', searchInterpolation);\n\n        function searchLinear() {\n            let input = searchInput.value;\n            let max = 100;\n            let min = 0;\n            while (max - min > 1) {\n                let mid = Math.floor((min + max) / 2);\n                if (input === String(mid)) {\n                    resultDiv.innerText = `Found ${input} at index ${mid}`;\n                    break;\n                } else if (input < String(mid)) {\n                    min = mid;\n                } else {\n                    max = mid;\n                }\n            }\n            if (input !== String(mid)) {\n                resultDiv.innerText = `Not found at index ${mid}`;\n            }\n        }\n\n        function searchInterpolation() {\n            let input = searchInput.value;\n            let max = 100;\n            let min = 0;\n            let x = 0;\n            let y = 0;\n            while (max - min > 1) {\n                let mid = Math.floor((min + max) / 2);\n                x = input.length - 1 - mid;\n                y = Math.floor(mid / 2);\n                if (input[x] === String(mid)) {\n                    resultDiv.innerText = `Found ${input} at index ${mid}`;\n                    break;\n                } else if (input[x] < String(mid)) {\n                    min = mid;\n                } else {\n                    max = mid;\n                }\n            }\n            if (input !== String(mid)) {\n                resultDiv.innerText = `Not found at index ${mid}`;\n            }\n        }\n    </script>\n</body>\n</html>"
