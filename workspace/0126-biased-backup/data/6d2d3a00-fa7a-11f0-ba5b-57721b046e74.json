    "content": "<html>\n<head>\n    <title>Interactive B-Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        .tree-container {\n            min-height: 300px;\n            border: 1px solid #ccc;\n            padding: 20px;\n            overflow: auto;\n        }\n        .node {\n            border: 1px solid black;\n            display: inline-block;\n            margin: 5px;\n            padding: 5px;\n            vertical-align: top;\n        }\n        .key {\n            display: inline-block;\n            padding: 5px;\n            margin: 2px;\n            border: 1px solid #999;\n        }\n        .child-pointer {\n            display: block;\n            margin-top: 5px;\n            font-size: 0.8em;\n            color: #666;\n        }\n        .highlight {\n            background-color: #eee;\n        }\n        .operation-log {\n            margin-top: 20px;\n            border: 1px solid #ccc;\n            padding: 10px;\n            max-height: 200px;\n            overflow-y: auto;\n            font-family: monospace;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive B-Tree</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Tree Configuration</h3>\n                <div>\n                    <label>Minimum Degree (t): <input type=\"number\" id=\"degree-input\" min=\"2\" max=\"10\" value=\"2\"></label>\n                    <button id=\"init-btn\">Initialize Tree</button>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Node Operations</h3>\n                <div>\n                    <label>Key: <input type=\"number\" id=\"key-input\"></label>\n                    <button id=\"insert-btn\">Insert</button>\n                    <button id=\"delete-btn\">Delete</button>\n                    <button id=\"search-btn\">Search</button>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Bulk Operations</h3>\n                <div>\n                    <label>Keys (comma separated): <input type=\"text\" id=\"bulk-input\"></label>\n                    <button id=\"bulk-insert-btn\">Bulk Insert</button>\n                    <button id=\"bulk-delete-btn\">Bulk Delete</button>\n                    <button id=\"random-btn\">Random Tree</button>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Visualization</h3>\n                <div>\n                    <button id=\"expand-btn\">Expand All</button>\n                    <button id=\"collapse-btn\">Collapse All</button>\n                    <label><input type=\"checkbox\" id=\"show-pointers\"> Show Pointers</label>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"tree-container\" id=\"tree-container\">\n            <p>Initialize a B-Tree by setting the minimum degree and clicking \"Initialize Tree\"</p>\n        </div>\n        \n        <div class=\"operation-log\" id=\"operation-log\">\n            <p>Operation log will appear here...</p>\n        </div>\n    </div>\n\n    <script>\n        class BTreeNode {\n            constructor(leaf = false) {\n                this.keys = [];\n                this.children = [];\n                this.leaf = leaf;\n                this.parent = null;\n                this.id = Math.random().toString(36).substr(2, 9);\n            }\n        }\n\n        class BTree {\n            constructor(t) {\n                this.root = new BTreeNode(true);\n                this.t = t;\n                this.highlightedNodes = new Set();\n            }\n\n            search(node, key, path = []) {\n                let i = 0;\n                while (i < node.keys.length && key > node.keys[i]) {\n                    i++;\n                }\n                \n                path.push({node: node, index: i});\n                \n                if (i < node.keys.length && key === node.keys[i]) {\n                    return { node: node, index: i, path: path };\n                } else if (node.leaf) {\n                    return null;\n                } else {\n                    return this.search(node.children[i], key, path);\n                }\n            }\n\n            insert(key) {\n                const root = this.root;\n                if (root.keys.length === (2 * this.t) - 1) {\n                    const newRoot = new BTreeNode();\n                    this.root = newRoot;\n                    newRoot.children.push(root);\n                    root.parent = newRoot;\n                    this.splitChild(newRoot, 0);\n                    this.insertNonFull(newRoot, key);\n                } else {\n                    this.insertNonFull(root, key);\n                }\n            }\n\n            insertNonFull(node, key) {\n                let i = node.keys.length - 1;\n                if (node.leaf) {\n                    while (i >= 0 && key < node.keys[i]]) {\n                        i--;\n                    }\n                    node.keys.splice(i + 1, 0, key);\n                } else {\n                    while (i >= 0 && key < node.keys[i]) {\n                        i--;\n                    }\n                    i++;\n                    if (node.children[i].keys.length === (2 * this.t) - 1) {\n                        this.splitChild(node, i);\n                        if (key > node.keys[i]) {\n                            i++;\n                        }\n                    }\n                    this.insertNonFull(node.children[i], key);\n                }\n            }\n\n            splitChild(parent, i) {\n                const t = this.t;\n                const child = parent.children[i];\n                const newChild = new BTreeNode(child.leaf);\n                newChild.parent = parent;\n                \n                parent.keys.splice(i, 0, child.keys[t - 1]);\n                parent.children.splice(i + 1, 0, newChild);\n                \n                newChild.keys = child.keys.slice(t);\n                child.keys = child.keys.slice(0, t - 1);\n                \n                if (!child.leaf) {\n                    newChild.children = child.children.slice(t);\n                    child.children = child.children.slice(0, t);\n                    for (const c of newChild.children) {\n                        c.parent = newChild;\n                    }\n                }\n            }\n\n            delete(key) {\n                this.deleteKey(this.root, key);\n                if (this.root.keys.length === 0 && !this.root.leaf) {\n                    this.root = this.root.children[0];\n                    this.root.parent = null;\n                }\n            }\n\n            deleteKey(node, key) {\n                const t = this.t;\n                let idx = node.keys.findIndex(k => k === key);\n                \n                if (idx !== -1) {\n                    if (node.leaf) {\n                        node.keys.splice(idx, 1);\n                    } else {\n                        const predecessor = this.getPredecessor(node, idx);\n                        if (predecessor.keys.length >= t) {\n                            node.keys[idx] = predecessor.keys.pop();\n                        } else {\n                            const successor = this.getSuccessor(node, idx);\n                            if (successor.keys.length >= t) {\n                                node.keys[idx] = successor.keys.shift();\n                            } else {\n                                this.merge(node, idx);\n                                this.deleteKey(node.children[idx], key);\n                            }\n                        }\n                    }\n                } else {\n                    if (node.leaf) {\n                        return;\n                    }\n                    \n                    let childIdx = 0;\n                    while (childIdx < node.keys.length && key > node.keys[childIdx]) {\n                        childIdx++;\n                    }\n                    \n                    const child = node.children[childIdx];\n                    if (child.keys.length >= t) {\n                        this.deleteKey(child, key);\n                    } else {\n                        if (childIdx > 0 && node.children[childIdx - 1].keys.length >= t) {\n                            this.borrowFromLeft(node, childIdx);\n                        } else if (childIdx < node.children.length - 1 && node.children[childIdx + 1].keys.length >= t) {\n                            this.borrowFromRight(node, childIdx);\n                        } else {\n                            if (childIdx < node.children.length - 1) {\n                                this.merge(node, childIdx);\n                            } else {\n                                this.merge(node, childIdx - 1);\n                                childIdx--;\n                            }\n                            this.deleteKey(node.children[childIdx], key);\n                        }\n                    }\n                }\n            }\n\n            getPredecessor(node, idx) {\n                let current = node.children[idx];\n                while (!current.leaf) {\n                    current = current.children[current.children.length - 1];\n                }\n                return current;\n            }\n\n            getSuccessor(node, idx) {\n                let current = node.children[idx + 1];\n                while (!current.leaf) {\n                    current = current.children[0];\n                }\n                return current;\n            }\n\n            borrowFromLeft(parent, idx) {\n                const child = parent.children[idx];\n                const sibling = parent.children[idx - 1];\n                \n                child.keys.unshift(parent.keys[idx - 1]);\n                parent.keys[idx - 1] = sibling.keys.pop();\n                \n                if (!child.leaf) {\n                    child.children.unshift(sibling.children.pop());\n                    child.children[0].parent = child;\n                }\n            }\n\n            borrowFromRight(parent, idx) {\n                const child = parent.children[idx];\n                const sibling = parent.children[idx + 1];\n                \n                child.keys.push(parent.keys[idx]);\n                parent.keys[idx] = sibling.keys.shift();\n                \n                if (!child.leaf) {\n                    child.children.push(sibling.children.shift());\n                    child.children[child.children.length - 1].parent = child;\n                }\n            }\n\n            merge(parent, idx) {\n                const t = this.t;\n                const child = parent.children[idx];\n                const sibling = parent.children[idx + 1];\n                \n                child.keys.push(parent.keys[idx]);\n                child.keys = child.keys.concat(sibling.keys);\n                \n                if (!child.leaf) {\n                    for (const c of sibling.children) {\n                        c.parent = child;\n                        child.children.push(c);\n                    }\n                }\n                \n                parent.keys.splice(idx, 1);\n                parent.children.splice(idx + 1, 1);\n            }\n\n            traverse(node = this.root, level = 0, expanded = new Set()) {\n                if (!node) return [];\n                \n                const isExpanded = expanded.has(node.id);\n                const items = [];\n                \n                items.push({\n                    node: node,\n                    level: level,\n                    expanded: isExpanded\n                });\n                \n                if (isExpanded && !node.leaf) {\n                    for (let i = 0; i < node.children.length; i++) {\n                        items.push(...this.traverse(node.children[i], level + 1, expanded));\n                        if (i < node.keys.length) {\n                            items.push({\n                                key: node.keys[i],\n                                level: level + 1\n                            });\n                        }\n                    }\n                }\n                \n                return items;\n            }\n        }\n\n        class BTreeVisualizer {\n            constructor(container, logContainer) {\n                this.tree = null;\n                this.treeContainer = treeContainer;\n                this.logContainer = logContainer;\n                this.expandedNodes = new Set();\n                this.showPointers = false;\n            }\n\n            initialize(t) {\n                this.tree = new BTree(t);\n                this.expandedNodes = new Set();\n                this.log('Initialized B-Tree with minimum degree ' + t);\n                this.render();\n            }\n\n            insert(key) {\n                if (!this.tree) {\n                    this.log('Please initialize the tree first');\n                    return;\n                }\n                \n                this.log('Inserting key: ' + key);\n                this.tree.insert(parseInt(key));\n                this.expandedNodes.add(this.tree.root.id);\n                this.render();\n            }\n\n            delete(key) {\n                if (!this.tree) {\n                    this.log('Please initialize the tree first');\n                    return;\n                }\n                \n                const result = this.tree.search(this.tree.root, parseInt(key));\n                if (!result) {\n                    this.log('Key ' + key + ' not found in tree');\n                    return;\n                }\n                \n                this.log('Deleting key: ' + key);\n                this.tree.delete(parseInt(key));\n                this.render();\n            }\n\n            search(key) {\n                if (!this.tree) {\n                    this.log('Please initialize the tree first');\n                    return;\n                }\n                \n                this.log('Searching for key: ' + key);\n                const result = this.tree.search(this.tree.root, parseInt(key));\n                \n                // Clear previous highlights\n                this.tree.highlightedNodes.clear();\n                \n                if (result) {\n                    this.log('Key ' + key + ' found in the tree');\n                    // Highlight the path\n                    for (const step of result.path) {\n                        this.tree.highlightedNodes.add(step.node.id);\n                    }\n                    // Highlight the found node\n                    this.tree.highlightedNodes.add(result.node.id);\n                } else {\n                    this.log('Key ' + key + ' not found in the tree');\n                }\n                \n                this.render();\n            }\n\n            bulkInsert(keysStr) {\n                if (!this.tree) {\n                    this.log('Please initialize the tree first');\n                    return;\n                }\n                \n                const keys = keysStr.split(',').map(k => parseInt(k.trim())).filter(k => !isNaN(k));\n                if (keys.length === 0) {\n                    this.log('No valid keys provided');\n                    return;\n                }\n                \n                this.log('Bulk inserting keys: ' + keys.join(', '));\n                for (const key of keys) {\n                    this.tree.insert(key);\n                }\n                this.expandedNodes.add(this.tree.root.id);\n                this.render();\n            }\n\n            bulkDelete(keysStr) {\n                if (!this.tree) {\n                    this.log('Please initialize the tree first');\n                    return;\n                }\n                \n                const keys = keysStr.split(',').map(k => parseInt(k.trim())).filter(k => !isNaN(k));\n                if (keys.length === 0) {\n                    this.log('No valid keys provided');\n                    return;\n                }\n                \n                this.log('Bulk deleting keys: ' + keys.join(', '));\n                for (const key of keys) {\n                    this.tree.delete(key);\n                }\n                this.render();\n            }\n\n            generateRandom() {\n                if (!this.tree) {\n                    this.log('Please initialize the tree first');\n                    return;\n                }\n                \n                const count = Math.floor(Math.random() * 15) + 5;\n                const keys = [];\n                for (let i = 0; i < count; i++) {\n                    keys.push(Math.floor(Math.random() * 100));\n                }\n                \n                this.log('Generating random tree with keys: ' + keys.join(', '));\n                this.tree = new BTree(this.tree.t);\n                for (const key of keys) {\n                    this.tree.insert(key);\n                }\n                this.expandedNodes.add(this.tree.root.id);\n                this.render();\n            }\n\n            toggleNode(nodeId) {\n                if (this.expandedNodes.has(nodeId)) {\n                    this.expandedNodes.delete(nodeId);\n                } else {\n                    this.expandedNodes.add(nodeId);\n                }\n                this.render();\n            }\n\n            expandAll() {\n                if (!this.tree) return;\n                \n                const queue = [this.tree.root];\n                while (queue.length > 0) {\n                    const node = queue.shift();\n                    this.expandedNodes.add(node.id);\n                    if (!node.leaf) {\n                        queue.push(...node.children);\n                    }\n                }\n                this.log('Expanded all nodes');\n                this.render();\n            }\n\n            collapseAll() {\n                this.expandedNodes.clear();\n                if (this.tree) {\n                    this.expandedNodes.add(this.tree.root.id);\n                }\n                this.log('Collapsed all nodes');\n                this.render();\n            }\n\n            togglePointers() {\n                this.showPointers = !this.showPointers;\n                this.render();\n            }\n\n            render() {\n                if (!this.tree) {\n                    this.treeContainer.innerHTML = '<p>Initialize a B-Tree by setting the minimum degree and clicking \"Initialize Tree\"</p>';\n                    return;\n                }\n                \n                const items = this.tree.traverse(this.tree.root, 0, this.expandedNodes);\n                let html = '<div class=\"tree\">';\n                \n                for (const item of items) {\n                    if (item.node) {\n                        const node = item.node;\n                        const isHighlighted = this.tree.highlightedNodes.has(node.id);\n                        const isExpanded = this.expandedNodes.has(node.id);\n                        \n                        html += `<div style=\"margin-left: ${item.level * 40}px;\">`;\n                        html += `<div class=\"node ${isHighlighted ? 'highlight' : ''}\" onclick=\"visualizer.toggleNode('${node.id}')\">`;\n                        \n                        // Keys\n                        for (const key of node.keys) {\n                            html += `<span class=\"key\">${key}</span>`;\n                        }\n                        \n                        // Child pointers (if enabled)\n                        if (this.showPointers && !node.leaf) {\n                            html += '<div class=\"child-pointers\">';\n                            for (let i = 0; i < node.children.length; i++) {\n                                const child = node.children[i];\n                                const arrow = isExpanded ? '↓' : '→';\n                                html += `<div class=\"child-pointer\">${arrow} Child ${i+1} (ID: ${child.id.substr(0,4)})</div>`;\n                            }\n                            html += '</div>';\n                        }\n                        \n                        html += '</div></div>';\n                    }\n                }\n                \n                html += '</div>';\n                this.treeContainer.innerHTML = html;\n            }\n\n            log(message) {\n                const entry = document.createElement('div');\n                entry.textContent = '> ' + message;\n                this.logContainer.appendChild(entry);\n                this.logContainer.scrollTop = this.logContainer.scrollHeight;\n            }\n\n            clearLog() {\n                this.logContainer.innerHTML = '';\n            }\n        }\n\n        // Initialize visualizer\n        const visualizer = new BTreeVisualizer(\n            document.getElementById('tree-container'),\n            document.getElementById('operation-log')\n        );\n\n        // Event listeners\n        document.getElementById('init-btn').addEventListener('click', () => {\n            const t = parseInt(document.getElementById('degree-input').value);\n            if (t >= 2) {\n                visualizer.initialize(t);\n            } else {\n                visualizer.log('Minimum degree must be at least 2');\n            }\n        });\n\n        document.getElementById('insert-btn').addEventListener('click', () => {\n            const key = document.getElementById('key-input').value;\n            if (key) {\n                visualizer.insert(key);\n                document.getElementById('key-input').value = '';\n            }\n        });\n\n        document.getElementById('delete-btn').addEventListener('click', () => {\n            const key = document.getElementById('key-input').value;\n            if (key) {\n                visualizer.delete(key);\n                document.getElementById('key-input').value = '';\n            }\n        });\n\n        document.getElementById('search-btn').addEventListener('click', () => {\n            const key = document.getElementById('key-input').value;\n            if (key) {\n                visualizer.search(key);\n                document.getElementById('key-input').value = '';\n            }\n        });\n\n        document.getElementById('bulk-insert-btn').addEventListener('click', () => {\n            const keys = document.getElementById('bulk-input').value;\n            visualizer.bulkInsert(keys);\n        });\n\n        document.getElementById('bulk-delete-btn').addEventListener('click', () => {\n            const keys = document.getElementById('bulk-input').value;\n            visualizer.bulkDelete(keys);\n        });\n\n        document.getElementById('random-btn').addEventListener('click', () => {\n            visualizer.generateRandom();\n        });\n\n        document.getElementById('expand-btn').addEventListener('click', () => {\n            visualizer.expandAll();\n        });\n\n        document.getElementById('collapse-btn').addEventListener('click', () => {\n            visualizer.collapseAll();\n        });\n\n        document.getElementById('show-pointers').addEventListener('change', (e) => {\n            visualizer.togglePointers();\n        });\n\n        // Allow pressing Enter in key input\n        document.getElementById('key-input').addEventListener('keypress', (e) => {\n            if (e.key === 'Enter') {\n                document.getElementById('insert-btn').click();\n            }\n        });\n    </script>\n</body>\n</html>"
