  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Linear Regression Interactive Lab</title>\n  <style>\n    /* Extremely minimal: plain black text on white background.\n       No colors, no animations, minimal layout only. */\n    body { margin: 10px; font-family: sans-serif; color: black; background: white; }\n    .row { display: flex; gap: 12px; align-items: flex-start; }\n    .col { display: inline-block; vertical-align: top; }\n    .controls { width: 360px; max-width: 40vw; }\n    .canvascol { flex: 1 1 auto; min-width: 420px; }\n    .field { margin-bottom: 6px; }\n    label { display: inline-block; min-width: 120px; }\n    input[type=\"text\"], input[type=\"number\"], textarea, select { width: 200px; }\n    textarea { width: 330px; height: 80px; }\n    button { margin-right: 6px; margin-top: 4px; }\n    .small { font-size: 0.9em; }\n    canvas { background: white; display: block; }\n    .stats { white-space: pre-wrap; font-family: monospace; font-size: 12px; }\n    hr { border: none; border-top: 1px solid black; margin: 8px 0; }\n  </style>\n</head>\n<body>\n  <h2>Linear Regression Interactive Lab (Plain UI)</h2>\n  <div class=\"row\">\n    <div class=\"col controls\">\n      <div class=\"field\">\n        <strong>Data Controls</strong>\n      </div>\n      <div class=\"field\">\n        <label>Canvas mode:</label>\n        <select id=\"mode\">\n          <option value=\"add\">Add points (click)</option>\n          <option value=\"drag\">Drag points</option>\n          <option value=\"delete\">Delete (shift+click)</option>\n          <option value=\"select\">Select single</option>\n        </select>\n      </div>\n      <div class=\"field\">\n        <label>Point radius:</label>\n        <input id=\"ptRadius\" type=\"number\" value=\"6\" min=\"1\" max=\"20\">\n      </div>\n      <div class=\"field\">\n        <button id=\"clearBtn\">Clear Data</button>\n        <button id=\"undoBtn\">Undo</button>\n        <button id=\"redoBtn\">Redo</button>\n      </div>\n\n      <div class=\"field\">\n        <label>Generate synthetic:</label>\n        <div style=\"display:inline-block;\">\n          slope <input id=\"genSlope\" type=\"number\" value=\"1.2\" step=\"0.1\" style=\"width:60px;\">\n          intercept <input id=\"genIntercept\" type=\"number\" value=\"0.5\" step=\"0.1\" style=\"width:60px;\">\n        </div>\n      </div>\n      <div class=\"field\">\n        <label>Points / noise:</label>\n        <input id=\"genN\" type=\"number\" value=\"50\" min=\"1\" style=\"width:60px;\">\n        <input id=\"genNoise\" type=\"number\" value=\"0.5\" step=\"0.1\" style=\"width:60px;\">\n        <button id=\"genBtn\">Generate</button>\n      </div>\n      <div class=\"field\">\n        <label>Add outliers:</label>\n        <input id=\"outlierFrac\" type=\"number\" value=\"0.1\" step=\"0.01\" style=\"width:60px;\">\n        <input id=\"outlierMag\" type=\"number\" value=\"5\" step=\"0.5\" style=\"width:60px;\">\n        <button id=\"outlierBtn\">Add</button>\n      </div>\n\n      <hr>\n\n      <div class=\"field\">\n        <strong>Model & Fits</strong>\n      </div>\n      <div class=\"field\">\n        <label>Basis degree:</label>\n        <input id=\"degree\" type=\"number\" value=\"1\" min=\"1\" max=\"6\">\n      </div>\n      <div class=\"field\">\n        <label>Include intercept:</label>\n        <input id=\"interceptCheck\" type=\"checkbox\" checked>\n      </div>\n      <div class=\"field\">\n        <label>Standardize X:</label>\n        <input id=\"standardizeX\" type=\"checkbox\">\n      </div>\n\n      <div class=\"field\">\n        <label>Method:</label>\n        <select id=\"method\">\n          <option value=\"ols\">Closed-form OLS</option>\n          <option value=\"ridge\">Closed-form Ridge</option>\n          <option value=\"gd\">Gradient Descent (batch)</option>\n          <option value=\"sgd\">SGD</option>\n          <option value=\"minibatch\">Mini-batch GD</option>\n          <option value=\"ransac\">RANSAC</option>\n          <option value=\"wls\">Weighted LS</option>\n        </select>\n      </div>\n\n      <div id=\"ridgeParams\" class=\"field small\">\n        <label>Ridge lambda:</label>\n        <input id=\"ridgeLambda\" type=\"number\" value=\"1.0\" step=\"0.1\" style=\"width:80px;\">\n      </div>\n\n      <div id=\"gdParams\" class=\"field small\">\n        <label>LR / iter:</label>\n        <input id=\"lr\" type=\"number\" value=\"0.1\" step=\"0.01\" style=\"width:70px;\">\n        <input id=\"iter\" type=\"number\" value=\"200\" step=\"1\" style=\"width:70px;\">\n      </div>\n\n      <div id=\"sgdParams\" class=\"field small\">\n        <label>Batch size:</label>\n        <input id=\"batchSize\" type=\"number\" value=\"1\" min=\"1\" style=\"width:60px;\">\n        <label>momentum:</label>\n        <input id=\"momentum\" type=\"number\" value=\"0.0\" step=\"0.05\" style=\"width:60px;\">\n      </div>\n\n      <div id=\"ransacParams\" class=\"field small\">\n        <label>RANSAC iter:</label>\n        <input id=\"ransacIter\" type=\"number\" value=\"200\" min=\"1\" style=\"width:70px;\">\n        <label>threshold:</label>\n        <input id=\"ransacThresh\" type=\"number\" value=\"0.5\" step=\"0.1\" style=\"width:70px;\">\n      </div>\n\n      <div class=\"field\">\n        <button id=\"fitBtn\">Fit (single)</button>\n        <button id=\"stepBtn\">Step (GD / SGD)</button>\n        <button id=\"runBtn\">Run (GD / SGD)</button>\n        <button id=\"stopBtn\">Stop</button>\n      </div>\n\n      <div class=\"field\">\n        <label>Manual slope:</label>\n        <input id=\"manualSlope\" type=\"number\" value=\"0\" step=\"0.1\" style=\"width:90px;\">\n        <label>intercept:</label>\n        <input id=\"manualIntercept\" type=\"number\" value=\"0\" step=\"0.1\" style=\"width:90px;\">\n        <button id=\"applyManual\">Apply</button>\n      </div>\n\n      <hr>\n\n      <div class=\"field\">\n        <strong>Diagnostics & Analysis</strong>\n      </div>\n      <div class=\"field\">\n        <button id=\"showResiduals\">Toggle Residuals</button>\n        <button id=\"bootstrapBtn\">Bootstrap params</button>\n        <input id=\"bootstrapN\" type=\"number\" value=\"200\" min=\"10\" style=\"width:80px;\">\n      </div>\n\n      <div class=\"field\">\n        <label>Cross-val k:</label>\n        <input id=\"cvK\" type=\"number\" value=\"5\" min=\"2\" style=\"width:60px;\">\n        <button id=\"cvBtn\">Run CV</button>\n      </div>\n\n      <div class=\"field\">\n        <label>Grid search (lr x lambda):</label>\n        <input id=\"gridLRs\" type=\"text\" value=\"0.01,0.05,0.1\" style=\"width:140px;\">\n        <input id=\"gridLams\" type=\"text\" value=\"0,0.1,1\" style=\"width:120px;\">\n        <button id=\"gridBtn\">Grid</button>\n      </div>\n\n      <hr>\n\n      <div class=\"field\">\n        <strong>Persistence / Import-Export</strong>\n      </div>\n      <div class=\"field\">\n        <button id=\"exportBtn\">Export Data</button>\n        <button id=\"importBtn\">Import Data</button>\n      </div>\n      <div class=\"field\">\n        <textarea id=\"dataArea\" placeholder='JSON dataset appears here'></textarea>\n      </div>\n\n      <hr>\n\n      <div class=\"field small\">\n        <strong>Tips:</strong>\n        <div class=\"small\">Click canvas to add points. Shift+click deletes nearest. Use \"drag\" mode to move points. Try different methods and see metrics update. Use bootstrap to estimate parameter variability.</div>\n      </div>\n    </div>\n\n    <div class=\"col canvascol\">\n      <div>\n        <canvas id=\"plot\" width=\"760\" height=\"520\"></canvas>\n      </div>\n      <div style=\"display:flex; gap:12px; margin-top:8px;\">\n        <div style=\"flex:1;\">\n          <div class=\"small\">Model parameters & metrics</div>\n          <div id=\"metrics\" class=\"stats\"></div>\n        </div>\n        <div style=\"width:220px;\">\n          <div class=\"small\">Bootstrap parameter histogram (slope or first param)</div>\n          <canvas id=\"hist\" width=\"220\" height=\"120\"></canvas>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // Minimal, plain UI interactive linear regression lab.\n  // Data and state\n  let data = []; // {x: number, y: number, id: number}\n  let idCounter = 1;\n  let undoStack = [], redoStack = [];\n\n  // Canvas and drawing\n  const canvas = document.getElementById('plot');\n  const ctx = canvas.getContext('2d');\n  const histCanvas = document.getElementById('hist');\n  const histCtx = histCanvas.getContext('2d');\n\n  // UI elements\n  const modeSel = document.getElementById('mode');\n  const ptRadiusInput = document.getElementById('ptRadius');\n  const clearBtn = document.getElementById('clearBtn');\n  const undoBtn = document.getElementById('undoBtn');\n  const redoBtn = document.getElementById('redoBtn');\n\n  const genBtn = document.getElementById('genBtn');\n  const genSlope = document.getElementById('genSlope');\n  const genIntercept = document.getElementById('genIntercept');\n  const genN = document.getElementById('genN');\n  const genNoise = document.getElementById('genNoise');\n\n  const outlierBtn = document.getElementById('outlierBtn');\n  const outlierFrac = document.getElementById('outlierFrac');\n  const outlierMag = document.getElementById('outlierMag');\n\n  const methodSel = document.getElementById('method');\n  const degreeInput = document.getElementById('degree');\n  const interceptCheck = document.getElementById('interceptCheck');\n  const standardizeX = document.getElementById('standardizeX');\n\n  const ridgeLambda = document.getElementById('ridgeLambda');\n  const lrInput = document.getElementById('lr');\n  const iterInput = document.getElementById('iter');\n  const batchSizeInput = document.getElementById('batchSize');\n  const momentumInput = document.getElementById('momentum');\n\n  const ransacIter = document.getElementById('ransacIter');\n  const ransacThresh = document.getElementById('ransacThresh');\n\n  const fitBtn = document.getElementById('fitBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const runBtn = document.getElementById('runBtn');\n  const stopBtn = document.getElementById('stopBtn');\n\n  const manualSlope = document.getElementById('manualSlope');\n  const manualIntercept = document.getElementById('manualIntercept');\n  const applyManual = document.getElementById('applyManual');\n\n  const showResidualsBtn = document.getElementById('showResiduals');\n  const bootstrapBtn = document.getElementById('bootstrapBtn');\n  const bootstrapN = document.getElementById('bootstrapN');\n\n  const cvK = document.getElementById('cvK');\n  const cvBtn = document.getElementById('cvBtn');\n\n  const gridLRs = document.getElementById('gridLRs');\n  const gridLams = document.getElementById('gridLams');\n  const gridBtn = document.getElementById('gridBtn');\n\n  const exportBtn = document.getElementById('exportBtn');\n  const importBtn = document.getElementById('importBtn');\n  const dataArea = document.getElementById('dataArea');\n\n  const metricsDiv = document.getElementById('metrics');\n\n  // Internal model state\n  let fitted = null; // {theta: [], method: 'ols', history: [...], name: ''}\n  let gdState = null; // {theta, iter, lr, momentum, v}\n  let runTimer = null;\n  let showResiduals = false;\n  let bootstrapParams = null; // array of arrays\n\n  // Visual mapping\n  function dataBounds() {\n    if (data.length === 0) return {xmin: -1, xmax: 1, ymin: -1, ymax: 1};\n    let xmin = Infinity, xmax = -Infinity, ymin = Infinity, ymax = -Infinity;\n    for (const p of data) {\n      xmin = Math.min(xmin, p.x);\n      xmax = Math.max(xmax, p.x);\n      ymin = Math.min(ymin, p.y);\n      ymax = Math.max(ymax, p.y);\n    }\n    if (xmin === xmax) { xmin -= 1; xmax += 1; }\n    if (ymin === ymax) { ymin -= 1; ymax += 1; }\n    const padX = (xmax - xmin) * 0.12;\n    const padY = (ymax - ymin) * 0.12;\n    return {xmin: xmin - padX, xmax: xmax + padX, ymin: ymin - padY, ymax: ymax + padY};\n  }\n\n  function toScreen(x, y) {\n    const b = dataBounds();\n    const w = canvas.width, h = canvas.height;\n    const sx = (x - b.xmin) / (b.xmax - b.xmin) * w;\n    const sy = h - (y - b.ymin) / (b.ymax - b.ymin) * h;\n    return {sx, sy};\n  }\n  function toData(sx, sy) {\n    const b = dataBounds();\n    const w = canvas.width, h = canvas.height;\n    const x = b.xmin + (sx / w) * (b.xmax - b.xmin);\n    const y = b.ymin + ((h - sy) / h) * (b.ymax - b.ymin);\n    return {x, y};\n  }\n\n  // Drawing\n  function draw() {\n    ctx.clearRect(0,0,canvas.width,canvas.height);\n    drawAxes();\n    drawDataPoints();\n    if (fitted) drawModelLines();\n    if (showResiduals && fitted) drawResiduals();\n  }\n\n  function drawAxes() {\n    const b = dataBounds();\n    const w = canvas.width, h = canvas.height;\n    ctx.save();\n    ctx.beginPath();\n    ctx.lineWidth = 1;\n    // axes lines at data x=0 and y=0 if inside bounds\n    if (b.xmin <= 0 && b.xmax >= 0) {\n      const sx = toScreen(0, b.ymin).sx;\n      ctx.moveTo(sx, 0); ctx.lineTo(sx, h);\n      ctx.stroke();\n    }\n    if (b.ymin <= 0 && b.ymax >= 0) {\n      const sy = toScreen(b.xmin, 0).sy;\n      ctx.moveTo(0, sy); ctx.lineTo(w, sy);\n      ctx.stroke();\n    }\n    // tick marks (simple)\n    ctx.font = \"10px sans-serif\";\n    ctx.fillStyle = \"black\";\n    for (let i = 0; i <= 4; i++) {\n      const tx = b.xmin + (i/4)*(b.xmax - b.xmin);\n      const p = toScreen(tx, b.ymin);\n      ctx.fillText(tx.toFixed(2), p.sx+2, canvas.height-2);\n      const ty = b.ymin + (i/4)*(b.ymax - b.ymin);\n      const q = toScreen(b.xmin, ty);\n      ctx.fillText(ty.toFixed(2), 2, q.sy-2);\n    }\n    ctx.restore();\n  }\n\n  function drawDataPoints() {\n    const r = Number(ptRadiusInput.value) || 6;\n    for (const p of data) {\n      const s = toScreen(p.x, p.y);\n      ctx.beginPath();\n      ctx.arc(s.sx, s.sy, r, 0, Math.PI*2);\n      ctx.fill();\n      ctx.stroke();\n      // id label when selected?\n      if (p._selected) {\n        ctx.font = \"11px sans-serif\";\n        ctx.fillText(\"id:\"+p.id, s.sx + r + 4, s.sy - r - 2);\n      }\n    }\n  }\n\n  function drawModelLines() {\n    // We can draw multiple models: fitted (current) and optionally previous history\n    const deg = Math.max(1, Number(degreeInput.value) || 1);\n    // draw the fitted curve by sampling\n    const theta = fitted.theta;\n    if (!theta) return;\n    const b = dataBounds();\n    ctx.save();\n    ctx.beginPath();\n    ctx.lineWidth = 2;\n    // build sample points\n    let first = true;\n    for (let sx = 0; sx <= canvas.width; sx += 2) {\n      const d = toData(sx, 0);\n      const x = d.x;\n      const preds = predictFromTheta(theta, x, deg);\n      const py = preds;\n      const sc = toScreen(x, py);\n      if (first) { ctx.moveTo(sc.sx, sc.sy); first = false; } else ctx.lineTo(sc.sx, sc.sy);\n    }\n    ctx.stroke();\n    ctx.restore();\n  }\n\n  function drawResiduals() {\n    ctx.save();\n    ctx.lineWidth = 1;\n    for (const p of data) {\n      const pred = predictPoint(fitted.theta, p.x);\n      const sP = toScreen(p.x, p.y);\n      const sPred = toScreen(p.x, pred);\n      ctx.beginPath();\n      ctx.moveTo(sP.sx, sP.sy);\n      ctx.lineTo(sPred.sx, sPred.sy);\n      ctx.stroke();\n    }\n    ctx.restore();\n  }\n\n  // Utility linear algebra (small)\n  function transpose(A) {\n    return A[0].map((_,c)=>A.map(r=>r[c]));\n  }\n  function matMul(A,B) {\n    const m=A.length, n=B[0].length, p=A[0].length;\n    const C = Array.from({length:m}, ()=>Array(n).fill(0));\n    for (let i=0;i<m;i++) for (let k=0;k<p;k++) {\n      for (let j=0;j<n;j++) C[i][j] += A[i][k]*B[k][j];\n    }\n    return C;\n  }\n  function vecAdd(a,b){ return a.map((v,i)=>v+b[i]); }\n  function scalarVecMul(s,a){ return a.map(v=>s*v); }\n  function dot(a,b){ return a.reduce((s,v,i)=>s+v*b[i],0); }\n  function invMatrix(A) {\n    // Gauss-Jordan inversion for small matrices\n    const n = A.length;\n    const M = A.map((row,i)=>row.concat(Array.from({length:n}, (_,j)=>(i===j?1:0))));\n    for (let i=0;i<n;i++) {\n      let pivot=i;\n      for (let r=i;r<n;r++) if (Math.abs(M[r][i])>Math.abs(M[pivot][i])) pivot=r;\n      if (Math.abs(M[pivot][i])<1e-12) return null;\n      if (pivot!==i) {\n        const tmp=M[i]; M[i]=M[pivot]; M[pivot]=tmp;\n      }\n      const div=M[i][i];\n      for (let j=0;j<2*n;j++) M[i][j]/=div;\n      for (let r=0;r<n;r++) if (r!==i) {\n        const mult = M[r][i];\n        for (let j=0;j<2*n;j++) M[r][j] -= mult*M[i][j];\n      }\n    }\n    return M.map(row=>row.slice(n));\n  }\n\n  // Design matrix and feature transforms\n  function buildDesignMatrix(points, degree, includeIntercept, standardize) {\n    // returns X (n x p) and y vector\n    const n = points.length;\n    const p = degree + (includeIntercept ? 1 : 0);\n    let X = Array.from({length:n}, ()=>Array(p).fill(0));\n    const y = Array.from({length:n}, (_,i)=>points[i].y);\n    for (let i=0;i<n;i++) {\n      let col = 0;\n      if (includeIntercept) { X[i][col++] = 1; }\n      for (let d=1; d<=degree; d++) {\n        X[i][col++] = Math.pow(points[i].x, d);\n      }\n    }\n    // optional standardization: standardize non-intercept columns\n    let means = null, stds = null;\n    if (standardize) {\n      const cols = X[0].length;\n      means = Array(cols).fill(0);\n      stds = Array(cols).fill(1);\n      for (let j=0;j<cols;j++) {\n        if (includeIntercept && j===0) { means[j]=0; stds[j]=1; continue; }\n        let sum=0;\n        for (let i=0;i<n;i++) sum += X[i][j];\n        means[j] = sum/n;\n        let sq=0;\n        for (let i=0;i<n;i++) sq += (X[i][j]-means[j])**2;\n        stds[j] = Math.sqrt(Math.max(1e-12, sq/n));\n        for (let i=0;i<n;i++) X[i][j] = (X[i][j]-means[j])/stds[j];\n      }\n    }\n    return {X, y, means, stds};\n  }\n\n  function solveOLS(X, y, lambda=0, weights=null) {\n    // Returns theta array (p)\n    // X: n x p\n    const Xt = transpose(X);\n    let XtX = matMul(Xt, X);\n    const p = XtX.length;\n    if (lambda && lambda !== 0) {\n      for (let i=0;i<p;i++) XtX[i][i] += lambda;\n    }\n    // if weights provided, use weighted LS: solve (X^T W X) theta = X^T W y\n    let Xty;\n    if (weights) {\n      const W = weights; // array length n\n      const Xtw = Xt.map(row => row.map((_,j)=>0)); // just to keep shape, adjust below\n      // compute X^T W X\n      XtX = Array.from({length:p}, ()=>Array(p).fill(0));\n      for (let i=0;i<p;i++) for (let j=0;j<p;j++) {\n        for (let k=0;k<X.length;k++) XtX[i][j] += Xt[i][k] * (W[k] * X[k][j]);\n      }\n      Xty = Array(p).fill(0);\n      for (let i=0;i<p;i++) for (let k=0;k<X.length;k++) Xty[i] += Xt[i][k] * (W[k] * y[k]);\n      if (lambda && lambda !== 0) for (let i=0;i<p;i++) XtX[i][i] += lambda;\n    } else {\n      Xty = Xt.map(row => dot(row, y));\n    }\n    const inv = invMatrix(XtX);\n    if (!inv) return null;\n    const thetaMat = matMul(inv, Xty.map(v=>[v]));\n    return thetaMat.map(r=>r[0]);\n  }\n\n  function predictFromTheta(theta, x, degree) {\n    // apply polynomial basis; assumes intercept included if theta length = degree+1\n    let y = 0;\n    const len = theta.length;\n    let idx = 0;\n    if (len === degree + 1) {\n      // intercept first\n      y += theta[idx++];\n    } else if (len === degree) {\n      // no intercept\n    } else {\n      // generic: assume intercept if first theta corresponds to 1.\n      // We'll try intercept if theta[0] corresponds to constant term (user choice ensures).\n      if (len === degree + (1)) { y += theta[idx++]; }\n    }\n    for (let d=1; d<=degree; d++) {\n      if (idx >= theta.length) break;\n      y += theta[idx++] * Math.pow(x, d);\n    }\n    return y;\n  }\n\n  function predictPoint(theta, x) {\n    const deg = Math.max(1, Number(degreeInput.value) || 1);\n    return predictFromTheta(theta, x, deg);\n  }\n\n  // Loss and metrics\n  function computeMetrics(theta) {\n    if (!theta) return null;\n    const n = data.length;\n    if (n===0) return null;\n    let sse = 0, sa = 0, sst = 0;\n    const ys = data.map(p=>p.y);\n    const ym = ys.reduce((a,b)=>a+b,0)/ys.length;\n    for (const p of data) {\n      const pred = predictPoint(theta, p.x);\n      const err = p.y - pred;\n      sse += err*err;\n      sa += Math.abs(err);\n      sst += (p.y - ym)*(p.y - ym);\n    }\n    const mse = sse / n;\n    const mae = sa / n;\n    const r2 = 1 - (sse / (sst || 1e-12));\n    return {mse, mae, r2, sse};\n  }\n\n  // Fit methods\n  function fitOLS() {\n    const deg = Number(degreeInput.value) || 1;\n    const includeIntercept = interceptCheck.checked;\n    const standardize = standardizeX.checked;\n    const {X, y, means, stds} = buildDesignMatrix(data, deg, includeIntercept, standardize);\n    const lambda = Number(ridgeLambda.value) || 0;\n    const theta = solveOLS(X, y, lambda);\n    if (!theta) {\n      alert('Matrix inversion failed (singular). Try regularization or different data.');\n      return null;\n    }\n    fitted = {theta, method: 'ols', deg, includeIntercept, standardize, means, stds};\n    updateMetrics();\n    draw();\n    return fitted;\n  }\n\n  function fitRidge() {\n    const deg = Number(degreeInput.value) || 1;\n    const includeIntercept = interceptCheck.checked;\n    const standardize = standardizeX.checked;\n    const {X, y, means, stds} = buildDesignMatrix(data, deg, includeIntercept, standardize);\n    const lambda = Number(ridgeLambda.value) || 0;\n    const theta = solveOLS(X, y, lambda);\n    fitted = {theta, method: 'ridge', deg, includeIntercept, standardize, means, stds};\n    updateMetrics();\n    draw();\n    return fitted;\n  }\n\n  function fitGDInit() {\n    const deg = Number(degreeInput.value) || 1;\n    const includeIntercept = interceptCheck.checked;\n    const standardize = standardizeX.checked;\n    const {X, y, means, stds} = buildDesignMatrix(data, deg, includeIntercept, standardize);\n    const p = X[0].length;\n    // init theta zeros\n    let theta = Array(p).fill(0);\n    // optionally initialize to OLS for faster convergence\n    const ols = solveOLS(X, y, 0);\n    if (ols) theta = ols.slice();\n    gdState = {theta, iter:0, X, y, lr: Number(lrInput.value)||0.1, momentum: Number(momentumInput.value)||0, v: Array(p).fill(0), deg, includeIntercept, standardize, means, stds};\n    fitted = {theta: gdState.theta, method: 'gd', deg, includeIntercept, standardize, means, stds};\n    updateMetrics();\n    draw();\n  }\n\n  function fitGDStep() {\n    if (!gdState) fitGDInit();\n    const {X, y, theta, lr, momentum} = gdState;\n    const n = X.length, p = theta.length;\n    // gradient = (2/n) X^T (X theta - y)\n    const preds = X.map((row,i)=>dot(row, theta));\n    const grad = Array(p).fill(0);\n    for (let j=0;j<p;j++) {\n      for (let i=0;i<n;i++) grad[j] += (preds[i] - y[i]) * X[i][j];\n      grad[j] = (2/n) * grad[j];\n    }\n    // momentum update\n    for (let j=0;j<p;j++) {\n      gdState.v[j] = momentum*gdState.v[j] + lr*grad[j];\n      theta[j] -= gdState.v[j];\n    }\n    gdState.iter++;\n    fitted = {theta: gdState.theta, method: 'gd', deg: gdState.deg, includeIntercept: gdState.includeIntercept, standardize: gdState.standardize, means: gdState.means, stds: gdState.stds};\n    updateMetrics();\n    draw();\n  }\n\n  function fitSGDStep() {\n    const batch = Number(batchSizeInput.value) || 1;\n    if (!gdState) {\n      // for SGD, we still initialize similar to GD\n      const deg = Number(degreeInput.value) || 1;\n      const includeIntercept = interceptCheck.checked;\n      const standardize = standardizeX.checked;\n      const {X, y, means, stds} = buildDesignMatrix(data, deg, includeIntercept, standardize);\n      const p = X[0].length;\n      let theta = Array(p).fill(0);\n      const ols = solveOLS(X, y, 0);\n      if (ols) theta = ols.slice();\n      gdState = {theta, iter:0, X, y, lr: Number(lrInput.value)||0.01, momentum: Number(momentumInput.value)||0, v: Array(p).fill(0), deg, includeIntercept, standardize, means, stds};\n    }\n    // random batch\n    const n = gdState.X.length;\n    if (n === 0) return;\n    const idxs = [];\n    for (let k=0;k<batch;k++) idxs.push(Math.floor(Math.random()*n));\n    const p = gdState.theta.length;\n    const grad = Array(p).fill(0);\n    for (const i of idxs) {\n      const xi = gdState.X[i];\n      const pred = dot(xi, gdState.theta);\n      for (let j=0;j<p;j++) grad[j] += (pred - gdState.y[i]) * xi[j];\n    }\n    for (let j=0;j<p;j++) grad[j] = (2/idxs.length) * grad[j];\n    // momentum\n    for (let j=0;j<p;j++) {\n      gdState.v[j] = gdState.momentum*gdState.v[j] + gdState.lr*grad[j];\n      gdState.theta[j] -= gdState.v[j];\n    }\n    gdState.iter++;\n    fitted = {theta: gdState.theta, method: 'sgd', deg: gdState.deg, includeIntercept: gdState.includeIntercept, standardize: gdState.standardize, means: gdState.means, stds: gdState.stds};\n    updateMetrics();\n    draw();\n  }\n\n  function fitMiniBatchStep() { fitSGDStep(); }\n\n  function runGD(steps, callback) {\n    if (!gdState) fitGDInit();\n    let i = 0;\n    function step() {\n      if (i>=steps) { if (callback) callback(); return; }\n      fitGDStep();\n      i++;\n      runTimer = setTimeout(step, 10);\n    }\n    step();\n  }\n\n  function fitRANSAC() {\n    if (data.length < 2) return null;\n    const iters = Number(ransacIter.value) || 200;\n    const thresh = Number(ransacThresh.value) || 0.5;\n    const deg = Number(degreeInput.value) || 1;\n    const includeIntercept = interceptCheck.checked;\n    const standardize = standardizeX.checked;\n    let best = null;\n    for (let it=0; it<iters; it++) {\n      // sample minimal subset\n      const sample = [];\n      const idxs = new Set();\n      while (idxs.size < Math.min(deg+1, data.length)) idxs.add(Math.floor(Math.random()*data.length));\n      for (const i of idxs) sample.push(data[i]);\n      const {X: Xs, y: ys} = buildDesignMatrix(sample, deg, includeIntercept, false);\n      const theta = solveOLS(Xs, ys, 0);\n      if (!theta) continue;\n      // count inliers on full data\n      let inliers = [];\n      for (const p of data) {\n        const pred = predictFromTheta(theta, p.x, deg);\n        if (Math.abs(p.y - pred) <= thresh) inliers.push(p);\n      }\n      if (inliers.length >= (best ? best.inliers.length : 0)) {\n        best = {theta, inliers};\n      }\n    }\n    if (!best) return null;\n    // refine by fitting to inliers\n    const {X, y} = buildDesignMatrix(best.inliers, deg, includeIntercept, standardize);\n    const thetaFinal = solveOLS(X, y, 0);\n    fitted = {theta: thetaFinal || best.theta, method: 'ransac', deg, includeIntercept, standardize};\n    updateMetrics();\n    draw();\n    return fitted;\n  }\n\n  function fitWeighted() {\n    // weighted least squares: user can provide weights via textarea as comma separated, or default to 1.\n    const deg = Number(degreeInput.value) || 1;\n    const includeIntercept = interceptCheck.checked;\n    const standardize = standardizeX.checked;\n    const {X, y, means, stds} = buildDesignMatrix(data, deg, includeIntercept, standardize);\n    // get weights from dataArea if present: try parse numbers\n    const txt = dataArea.value.trim();\n    let weights = null;\n    if (txt) {\n      try {\n        const arr = JSON.parse(txt);\n        if (Array.isArray(arr) && arr.length === data.length) weights = arr.map(Number);\n      } catch(e) {\n        // ignore, user didn't provide proper weights\n      }\n    }\n    if (!weights) weights = Array(data.length).fill(1);\n    const theta = solveOLS(X, y, 0, weights);\n    fitted = {theta, method: 'wls', deg, includeIntercept, standardize, means, stds};\n    updateMetrics();\n    draw();\n    return fitted;\n  }\n\n  // General fit dispatch\n  function fitOnce() {\n    if (data.length === 0) { alert('No data'); return; }\n    const method = methodSel.value;\n    if (method === 'ols') fitOLS();\n    else if (method === 'ridge') fitRidge();\n    else if (method === 'gd') { fitGDInit(); runGD(Number(iterInput.value)||100); }\n    else if (method === 'sgd') { gdState = null; // will initialize in step\n      const steps = Number(iterInput.value)||200;\n      let c=0;\n      function sgdLoop() {\n        if (c>=steps) return;\n        fitSGDStep();\n        c++;\n        runTimer = setTimeout(sgdLoop, 10);\n      }\n      sgdLoop();\n    }\n    else if (method === 'minibatch') {\n      gdState = null;\n      const steps = Number(iterInput.value)||200;\n      let c=0;\n      function loop() {\n        if (c>=steps) return;\n        fitMiniBatchStep(); c++;\n        runTimer = setTimeout(loop, 10);\n      }\n      loop();\n    }\n    else if (method === 'ransac') fitRANSAC();\n    else if (method === 'wls') fitWeighted();\n  }\n\n  // UI actions\n  function pushUndo() { undoStack.push(JSON.stringify(data)); if (undoStack.length>100) undoStack.shift(); redoStack=[]; }\n  function undo() { if (undoStack.length===0) return; redoStack.push(JSON.stringify(data)); const txt = undoStack.pop(); data = JSON.parse(txt); draw(); updateMetrics(); }\n  function redo() { if (redoStack.length===0) return; undoStack.push(JSON.stringify(data)); const txt = redoStack.pop(); data = JSON.parse(txt); draw(); updateMetrics(); }\n\n  clearBtn.addEventListener('click', ()=>{ pushUndo(); data = []; fitted=null; draw(); updateMetrics(); });\n  undoBtn.addEventListener('click', undo);\n  redoBtn.addEventListener('click', redo);\n\n  genBtn.addEventListener('click', ()=>{\n    pushUndo();\n    const n = Number(genN.value)||50;\n    const slope = Number(genSlope.value)||1;\n    const intercept = Number(genIntercept.value)||0;\n    const noise = Number(genNoise.value)||0.5;\n    const xmin = -5, xmax = 5;\n    for (let i=0;i<n;i++) {\n      const x = xmin + Math.random()*(xmax-xmin);\n      const y = slope*x + intercept + randn()*noise;\n      data.push({x,y,id:idCounter++});\n    }\n    fitted = null; draw(); updateMetrics();\n  });\n\n  outlierBtn.addEventListener('click', ()=>{\n    if (data.length===0) return;\n    pushUndo();\n    const frac = Number(outlierFrac.value)||0.1;\n    const mag = Number(outlierMag.value)||5;\n    const count = Math.max(1, Math.floor(data.length*frac));\n    for (let i=0;i<count;i++) {\n      const idx = Math.floor(Math.random()*data.length);\n      data[idx].y += (Math.random()<0.5 ? -1 : 1)*(Math.random()*mag + mag*0.2);\n    }\n    fitted = null; draw(); updateMetrics();\n  });\n\n  fitBtn.addEventListener('click', ()=>{ stopRun(); fitOnce(); });\n  stepBtn.addEventListener('click', ()=>{ stopRun(); const m = methodSel.value; if (m==='gd') fitGDStep(); else if (m==='sgd') fitSGDStep(); else if (m==='minibatch') fitMiniBatchStep(); else alert('Step works for GD/SGD/minibatch only'); });\n  runBtn.addEventListener('click', ()=>{ stopRun(); const m = methodSel.value; if (m==='gd') runGD(Number(iterInput.value)||100); else if (m==='sgd' || m==='minibatch') {\n    // start running many step calls\n    const total = Number(iterInput.value)||200;\n    let c=0;\n    function loop() {\n      if (c>=total) return;\n      if (m==='sgd') fitSGDStep(); else fitMiniBatchStep();\n      c++;\n      runTimer = setTimeout(loop, 10);\n    }\n    loop();\n  } else { alert('Run supports GD/SGD/minibatch only'); }});\n  stopBtn.addEventListener('click', stopRun);\n  function stopRun() { if (runTimer) { clearTimeout(runTimer); runTimer = null; } }\n\n  applyManual.addEventListener('click', ()=>{\n    pushUndo();\n    const s = Number(manualSlope.value)||0;\n    const b = Number(manualIntercept.value)||0;\n    // set fitted theta for degree 1 with intercept assumed\n    const deg = Number(degreeInput.value) || 1;\n    if (deg === 1 && interceptCheck.checked) {\n      fitted = {theta: [b, s], method: 'manual', deg, includeIntercept: true};\n    } else {\n      // create theta with slope applied to x^1 coefficient\n      const p = deg + (interceptCheck.checked?1:0);\n      const theta = Array(p).fill(0);\n      if (interceptCheck.checked) theta[0] = b;\n      const idx = (interceptCheck.checked ? 1 : 0);\n      theta[idx] = s;\n      fitted = {theta, method: 'manual', deg};\n    }\n    updateMetrics();\n    draw();\n  });\n\n  showResidualsBtn.addEventListener('click', ()=>{ showResiduals = !showResiduals; draw(); });\n\n  bootstrapBtn.addEventListener('click', ()=>{\n    if (data.length===0) return;\n    const n = Number(bootstrapN.value) || 200;\n    // sample with replacement, fit OLS each time, collect first non-intercept param (slope)\n    const deg = Number(degreeInput.value) || 1;\n    const includeIntercept = interceptCheck.checked;\n    const standardize = standardizeX.checked;\n    const results = [];\n    for (let i=0;i<n;i++) {\n      const sample = [];\n      for (let j=0;j<data.length;j++) sample.push(data[Math.floor(Math.random()*data.length)]);\n      const {X, y} = buildDesignMatrix(sample, deg, includeIntercept, standardize);\n      const theta = solveOLS(X, y, 0);\n      if (theta) results.push(theta.slice()); // store full theta\n    }\n    bootstrapParams = results;\n    drawHistogram(results);\n  });\n\n  cvBtn.addEventListener('click', ()=>{\n    if (data.length===0) return;\n    const k = Number(cvK.value) || 5;\n    const indices = data.map((_,i)=>i);\n    shuffle(indices);\n    const folds = Array.from({length:k}, ()=>[]);\n    for (let i=0;i<indices.length;i++) folds[i%k].push(indices[i]);\n    const metrics = [];\n    for (let i=0;i<k;i++) {\n      const testIdx = new Set(folds[i]);\n      const train = data.filter((_,idx)=>!testIdx.has(idx));\n      const test = data.filter((_,idx)=>testIdx.has(idx));\n      const {X: Xt, y: yt} = buildDesignMatrix(train, Number(degreeInput.value)||1, interceptCheck.checked, standardizeX.checked);\n      const theta = solveOLS(Xt, yt, Number(ridgeLambda.value)||0);\n      if (!theta) continue;\n      // compute metrics on test\n      let sse=0, sa=0;\n      for (const p of test) {\n        const pred = predictFromTheta(theta, p.x, Number(degreeInput.value)||1);\n        const err = p.y - pred;\n        sse += err*err; sa += Math.abs(err);\n      }\n      metrics.push({mse: sse/test.length, mae: sa/test.length});\n    }\n    metricsDiv.textContent = 'Cross-val results (per fold):\\n' + metrics.map((m,i)=>`fold ${i+1}: mse=${m.mse.toFixed(4)}, mae=${m.mae.toFixed(4)}`).join('\\n');\n  });\n\n  gridBtn.addEventListener('click', ()=>{\n    // grid search over LR and lambda for GD or ridge, compute final MSE for each\n    if (data.length===0) return;\n    const lrs = gridLRs.value.split(',').map(s=>Number(s.trim())).filter(x=>!isNaN(x));\n    const lams = gridLams.value.split(',').map(s=>Number(s.trim())).filter(x=>!isNaN(x));\n    const results = [];\n    for (const lr of lrs) for (const lam of lams) {\n      // run small number of GD steps starting from OLS solution\n      const deg = Number(degreeInput.value)||1;\n      const includeIntercept = interceptCheck.checked;\n      const standardize = standardizeX.checked;\n      const {X, y} = buildDesignMatrix(data, deg, includeIntercept, standardize);\n      const p = X[0].length;\n      let theta = Array(p).fill(0);\n      const ols = solveOLS(X, y, lam);\n      if (ols) theta = ols.slice();\n      // run a few GD steps with lr\n      for (let it=0; it<50; it++) {\n        const preds = X.map((row,i)=>dot(row, theta));\n        const grad = Array(p).fill(0);\n        for (let j=0;j<p;j++) {\n          for (let i=0;i<X.length;i++) grad[j] += (preds[i] - y[i]) * X[i][j];\n          grad[j] = (2/X.length)*grad[j];\n        }\n        for (let j=0;j<p;j++) theta[j] -= lr*grad[j];\n      }\n      const m = computeMetrics(theta);\n      results.push({lr, lam, mse: m.mse});\n    }\n    // show table textually\n    results.sort((a,b)=>a.mse-b.mse);\n    metricsDiv.textContent = 'Grid search results (sorted by mse):\\n' + results.map(r=>`lr=${r.lr}, lam=${r.lam}, mse=${r.mse.toFixed(4)}`).join('\\n');\n  });\n\n  exportBtn.addEventListener('click', ()=>{\n    const out = JSON.stringify(data, null, 2);\n    dataArea.value = out;\n  });\n\n  importBtn.addEventListener('click', ()=>{\n    try {\n      const obj = JSON.parse(dataArea.value);\n      if (!Array.isArray(obj)) { alert('Expecting JSON array of points {x,y}'); return; }\n      pushUndo();\n      data = obj.map(o=>({x:Number(o.x), y:Number(o.y), id: idCounter++}));\n      draw(); updateMetrics();\n    } catch(e) {\n      alert('Invalid JSON');\n    }\n  });\n\n  // Event handling for canvas (add, drag, delete)\n  let dragging = null;\n  canvas.addEventListener('mousedown', (ev)=>{\n    const rect = canvas.getBoundingClientRect();\n    const sx = ev.clientX - rect.left, sy = ev.clientY - rect.top;\n    const dpt = toData(sx, sy);\n    const mode = modeSel.value;\n    // detect nearest point\n    const nearest = findNearestPoint(sx, sy);\n    if (mode === 'add') {\n      pushUndo();\n      data.push({x:dpt.x, y:dpt.y, id: idCounter++});\n      fitted = null; draw(); updateMetrics();\n    } else if (mode === 'drag') {\n      if (nearest && nearest.dist <= (Number(ptRadiusInput.value)||6) + 4) {\n        dragging = nearest.p;\n        dragging._dragOffset = {sx: sx - toScreen(dragging.x, dragging.y).sx, sy: sy - toScreen(dragging.x, dragging.y).sy};\n      } else {\n        // add if no point near\n        pushUndo();\n        data.push({x:dpt.x, y:dpt.y, id: idCounter++});\n        fitted = null; draw(); updateMetrics();\n      }\n    } else if (mode === 'delete') {\n      if (ev.shiftKey && nearest && nearest.dist <= (Number(ptRadiusInput.value)||6) + 6) {\n        pushUndo();\n        data = data.filter(p=>p.id !== nearest.p.id);\n        fitted = null; draw(); updateMetrics();\n      }\n    } else if (mode === 'select') {\n      for (const p of data) p._selected = false;\n      if (nearest && nearest.dist <= (Number(ptRadiusInput.value)||6) + 6) nearest.p._selected = true;\n      draw();\n    }\n  });\n\n  canvas.addEventListener('mousemove', (ev)=>{\n    if (!dragging) return;\n    const rect = canvas.getBoundingClientRect();\n    const sx = ev.clientX - rect.left, sy = ev.clientY - rect.top;\n    const pt = toData(sx - dragging._dragOffset.sx, sy - dragging._dragOffset.sy);\n    dragging.x = pt.x; dragging.y = pt.y;\n    fitted = null;\n    draw();\n    updateMetrics();\n  });\n\n  canvas.addEventListener('mouseup', (ev)=>{\n    if (dragging) { pushUndo(); dragging = null; }\n  });\n\n  canvas.addEventListener('mouseleave', (ev)=>{ if (dragging) { pushUndo(); dragging=null; } });\n\n  canvas.addEventListener('click', (ev)=>{\n    // support shift+click deletion quickly\n    if (!ev.shiftKey) return;\n    const rect = canvas.getBoundingClientRect();\n    const sx = ev.clientX - rect.left, sy = ev.clientY - rect.top;\n    const nearest = findNearestPoint(sx, sy);\n    if (nearest && nearest.dist <= (Number(ptRadiusInput.value)||6) + 6) {\n      pushUndo();\n      data = data.filter(p=>p.id !== nearest.p.id);\n      fitted = null; draw(); updateMetrics();\n    }\n  });\n\n  function findNearestPoint(sx, sy) {\n    let best = null;\n    for (const p of data) {\n      const s = toScreen(p.x, p.y);\n      const dx = s.sx - sx, dy = s.sy - sy;\n      const dist = Math.sqrt(dx*dx + dy*dy);\n      if (!best || dist < best.dist) best = {p, dist};\n    }\n    return best;\n  }\n\n  // Helpers\n  function randn() {\n    // Box-Muller\n    let u=0,v=0;\n    while(u===0) u=Math.random();\n    while(v===0) v=Math.random();\n    return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);\n  }\n\n  function shuffle(array) {\n    for (let i=array.length-1;i>0;i--) {\n      const j=Math.floor(Math.random()*(i+1));\n      [array[i],array[j]]=[array[j],array[i]];\n    }\n  }\n\n  // Metrics update\n  function updateMetrics() {\n    if (!fitted || !fitted.theta) {\n      metricsDiv.textContent = 'No fitted model';\n      return;\n    }\n    const m = computeMetrics(fitted.theta);\n    let s = 'Method: ' + (fitted.method||'') + '\\n';\n    s += 'Parameters: ' + fitted.theta.map((v,i)=>`t${i}=${v.toFixed(4)}`).join(', ') + '\\n';\n    if (m) s += `MSE: ${m.mse.toFixed(4)}, MAE: ${m.mae.toFixed(4)}, R2: ${m.r2.toFixed(4)}\\n`;\n    s += 'Data points: ' + data.length + '\\n';\n    s += 'Degree: ' + (fitted.deg || degreeInput.value) + '\\n';\n    metricsDiv.textContent = s;\n  }\n\n  // Draw histogram for bootstrap results\n  function drawHistogram(results) {\n    histCtx.clearRect(0,0,histCanvas.width,histCanvas.height);\n    if (!results || results.length===0) return;\n    // take first meaningful parameter: if intercept present, show first slope (index 1) else index 0\n    const idx = (fitted && fitted.includeIntercept) ? 1 : 0;\n    const vals = results.map(th=> th[idx] !== undefined ? th[idx] : th[0]).filter(v=>!isNaN(v));\n    if (vals.length===0) return;\n    const min = Math.min(...vals), max = Math.max(...vals);\n    const bins = 16;\n    const counts = Array(bins).fill(0);\n    for (const v of vals) {\n      const b = Math.min(bins-1, Math.floor((v - min) / (max - min + 1e-12) * bins));\n      counts[b]++;\n    }\n    const w = histCanvas.width, h = histCanvas.height;\n    const maxc = Math.max(...counts);\n    histCtx.beginPath();\n    for (let i=0;i<bins;i++) {\n      const bw = w/bins;\n      const bh = (counts[i]/maxc) * (h-10);\n      histCtx.fillRect(i*bw, h-bh, bw-1, bh);\n    }\n    // draw mean line\n    const mean = vals.reduce((a,b)=>a+b,0)/vals.length;\n    const mx = (mean - min)/(max-min+1e-12)*w;\n    histCtx.beginPath(); histCtx.moveTo(mx,0); histCtx.lineTo(mx,h); histCtx.stroke();\n  }\n\n  // Initial draw\n  draw();\n  updateMetrics();\n\n  // Fit once when method changes to update visible params area\n  methodSel.addEventListener('change', ()=>{ /* no styling changes required in minimal UI */ });\n\n  // Stop run when window unloads\n  window.addEventListener('beforeunload', ()=>{ stopRun(); });\n\n  // Expose compute button for solving directly when needed\n  // For simplicity, mapping from dispatch options is in fitOnce\n\n  // End of main closure\n})();\n</script>\n</body>\n</html>"
