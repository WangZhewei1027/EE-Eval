    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>B+ Tree Interactive Demo</title>\n  <style>\n    /* Minimal: only layout spacing so elements don't overlap. No colors, no fancy styling. */\n    body { font-family: Arial, sans-serif; margin: 12px; color: #000; background: #fff; }\n    .row { margin-bottom: 8px; }\n    input[type=\"text\"], input[type=\"number\"], select { width: 220px; }\n    button { margin-right: 6px; }\n    pre { white-space: pre-wrap; }\n    .controls { max-width: 1000px; }\n    .panel { border: 1px solid #000; padding: 6px; margin-bottom: 8px; }\n    .small { font-size: 12px; }\n    .nodeBox { display: inline-block; padding: 4px; margin: 6px; border: 1px solid #000; }\n  </style>\n</head>\n<body>\n  <h2>B+ Tree Interactive Demo</h2>\n\n  <div class=\"controls\">\n    <div class=\"panel\">\n      <div class=\"row\">\n        Order (m): <input id=\"orderInput\" type=\"number\" min=\"3\" value=\"4\"> (maximum children per internal node)\n        <button id=\"initBtn\">Initialize Tree</button>\n        <button id=\"resetBtn\">Reset & Clear History</button>\n      </div>\n      <div class=\"small\">Notes: This demo uses order m where each internal node can have at most m children and m-1 keys. Leaves store up to m-1 keys. Many algorithmic variants exist; this implementation picks conventional split/borrow/merge rules and records detailed steps.</div>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"row\">\n        Insert key: <input id=\"keyInput\" type=\"number\" value=\"10\">\n        <button id=\"insertBtn\">Insert (Immediate)</button>\n        <button id=\"insertStepBtn\">Insert (Step Mode)</button>\n        Insert multiple (comma-separated): <input id=\"multiInsertInput\" type=\"text\" placeholder=\"e.g. 5,12,7\">\n        <button id=\"multiInsertBtn\">Insert Bulk (Immediate)</button>\n        <button id=\"multiInsertStepBtn\">Insert Bulk (Step Mode)</button>\n      </div>\n\n      <div class=\"row\">\n        Delete key: <input id=\"delInput\" type=\"number\">\n        <button id=\"delBtn\">Delete (Immediate)</button>\n        <button id=\"delStepBtn\">Delete (Step Mode)</button>\n      </div>\n\n      <div class=\"row\">\n        Find key: <input id=\"findInput\" type=\"number\">\n        <button id=\"findBtn\">Find</button>\n        Range search: from <input id=\"rfrom\" type=\"number\" style=\"width:90px\"> to <input id=\"rto\" type=\"number\" style=\"width:90px\">\n        <button id=\"rangeBtn\">Range Search</button>\n      </div>\n\n      <div class=\"row\">\n        Quick slider insert: <input id=\"slider\" type=\"range\" min=\"0\" max=\"100\" value=\"10\"> <span id=\"sliderVal\">10</span>\n        <button id=\"insertSliderBtn\">Insert Slider Value</button>\n      </div>\n\n      <div class=\"row\">\n        Random bulk: count <input id=\"randCount\" type=\"number\" value=\"10\" min=\"1\" style=\"width:80px\"> range max <input id=\"randMax\" type=\"number\" value=\"100\" style=\"width:80px\">\n        <button id=\"randBtn\">Random Insert (Immediate)</button>\n        <button id=\"randStepBtn\">Random Insert (Step Mode)</button>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      Step controls:\n      <div class=\"row\">\n        <button id=\"stepPrev\">Prev Step</button>\n        <button id=\"stepNext\">Next Step</button>\n        <button id=\"stepFirst\">First</button>\n        <button id=\"stepLast\">Last</button>\n        <button id=\"commitSteps\">Commit Steps to Tree</button>\n        <button id=\"discardSteps\">Discard Steps</button>\n        Autoplay: <input id=\"autoPlay\" type=\"checkbox\"> Interval (ms): <input id=\"interval\" type=\"number\" value=\"800\" style=\"width:80px\">\n      </div>\n      <div class=\"row\">\n        Speed slider: <input id=\"speedSlider\" type=\"range\" min=\"100\" max=\"2000\" value=\"800\"> <span id=\"speedVal\">800ms</span>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      History & State:\n      <div class=\"row\">\n        <button id=\"undoBtn\">Undo</button>\n        <button id=\"redoBtn\">Redo</button>\n        <button id=\"exportBtn\">Export JSON</button>\n        <input id=\"importArea\" type=\"text\" placeholder='Paste JSON here' style=\"width:420px\">\n        <button id=\"importBtn\">Import</button>\n        <button id=\"clearLogBtn\">Clear Operation Log</button>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      View options:\n      <div class=\"row\">\n        <label><input id=\"showNodeIds\" type=\"checkbox\" checked> Show node ids</label>\n        <label style=\"margin-left:12px\"><input id=\"showCapacity\" type=\"checkbox\"> Show capacity info</label>\n        <label style=\"margin-left:12px\"><input id=\"showLeafList\" type=\"checkbox\" checked> Show leaf linked list</label>\n      </div>\n    </div>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Current Tree View:</strong>\n    <div id=\"treeView\"></div>\n    <div id=\"leafListView\"></div>\n  </div>\n\n  <hr>\n\n  <div>\n    <strong>Operation Log / Algorithm Trace:</strong>\n    <pre id=\"log\" style=\"height:200px; overflow:auto; border:1px solid #000; padding:6px;\"></pre>\n  </div>\n\n  <script>\n    // B+ Tree Interactive Demo - minimal visuals, maximal interactivity\n    (function(){\n      // Utility\n      function clone(obj) { return JSON.parse(JSON.stringify(obj)); }\n      function idGen() { return 'n' + (++idCounter); }\n      function logLine(s){ logs.push(s); renderLog(); }\n      function renderLog(){ document.getElementById('log').textContent = logs.join('\\\\n'); }\n\n      // state\n      var idCounter = 0;\n      var tree = null;\n      var logs = [];\n      var history = [];\n      var future = [];\n\n      // Step mode\n      var currentSteps = []; // snapshots {state, desc}\n      var stepIndex = -1;\n      var autoplayInterval = null;\n\n      // UI elements\n      var orderInput = document.getElementById('orderInput');\n      var initBtn = document.getElementById('initBtn');\n      var resetBtn = document.getElementById('resetBtn');\n\n      var keyInput = document.getElementById('keyInput');\n      var insertBtn = document.getElementById('insertBtn');\n      var insertStepBtn = document.getElementById('insertStepBtn');\n      var multiInsertInput = document.getElementById('multiInsertInput');\n      var multiInsertBtn = document.getElementById('multiInsertBtn');\n      var multiInsertStepBtn = document.getElementById('multiInsertStepBtn');\n\n      var delInput = document.getElementById('delInput');\n      var delBtn = document.getElementById('delBtn');\n      var delStepBtn = document.getElementById('delStepBtn');\n\n      var findInput = document.getElementById('findInput');\n      var findBtn = document.getElementById('findBtn');\n\n      var rfrom = document.getElementById('rfrom'), rto = document.getElementById('rto'), rangeBtn = document.getElementById('rangeBtn');\n\n      var slider = document.getElementById('slider');\n      var sliderVal = document.getElementById('sliderVal');\n      var insertSliderBtn = document.getElementById('insertSliderBtn');\n\n      var randCount = document.getElementById('randCount');\n      var randMax = document.getElementById('randMax');\n      var randBtn = document.getElementById('randBtn');\n      var randStepBtn = document.getElementById('randStepBtn');\n\n      var stepPrev = document.getElementById('stepPrev'), stepNext = document.getElementById('stepNext'),\n          stepFirst = document.getElementById('stepFirst'), stepLast = document.getElementById('stepLast'),\n          commitSteps = document.getElementById('commitSteps'), discardSteps = document.getElementById('discardSteps'),\n          autoPlay = document.getElementById('autoPlay'), intervalInput = document.getElementById('interval'),\n          speedSlider = document.getElementById('speedSlider'), speedVal = document.getElementById('speedVal');\n\n      var undoBtn = document.getElementById('undoBtn'), redoBtn = document.getElementById('redoBtn'),\n          exportBtn = document.getElementById('exportBtn'), importBtn = document.getElementById('importBtn'),\n          importArea = document.getElementById('importArea'),\n          clearLogBtn = document.getElementById('clearLogBtn');\n\n      var showNodeIds = document.getElementById('showNodeIds'), showCapacity = document.getElementById('showCapacity'),\n          showLeafList = document.getElementById('showLeafList');\n\n      var treeView = document.getElementById('treeView'), leafListView = document.getElementById('leafListView');\n\n      // B+ Tree Implementation\n      function BPlusTree(m){\n        this.m = m;\n        this.maxKeys = m - 1;\n        this.minKeys = Math.ceil(this.maxKeys / 2);\n        this.nodeMap = {}; // id -> node\n        // create root leaf\n        var root = this._createNode(true);\n        this.root = root.id;\n      }\n      BPlusTree.prototype._createNode = function(isLeaf){\n        var n = { id: idGen(), isLeaf: !!isLeaf, keys: [], children: [], parent: null, next: null };\n        this.nodeMap[n.id] = n;\n        return n;\n      };\n\n      BPlusTree.prototype._getNode = function(id){ return this.nodeMap[id] || null; };\n\n      BPlusTree.prototype.findLeaf = function(key){\n        var node = this._getNode(this.root);\n        var path = [node.id];\n        while(!node.isLeaf){\n          var i = 0;\n          while(i < node.keys.length && key >= node.keys[i]) i++;\n          var childId = node.children[i];\n          node = this._getNode(childId);\n          path.push(node.id);\n        }\n        return {leaf: node, path: path};\n      };\n\n      BPlusTree.prototype.search = function(key){\n        var r = this.findLeaf(key);\n        var leaf = r.leaf;\n        for(var i=0;i<leaf.keys.length;i++){\n          if(leaf.keys[i] === key) return {found:true, node:leaf, index:i, path:r.path};\n        }\n        return {found:false, node:leaf, index:-1, path:r.path};\n      };\n\n      // snapshot: plain serializable state\n      BPlusTree.prototype.snapshot = function(){\n        return { root: this.root, m: this.m, nodes: clone(this.nodeMap) };\n      };\n\n      BPlusTree.prototype.restoreFromSnapshot = function(snap){\n        this.m = snap.m;\n        this.maxKeys = this.m - 1;\n        this.minKeys = Math.ceil(this.maxKeys / 2);\n        this.nodeMap = clone(snap.nodes);\n        this.root = snap.root;\n      };\n\n      // Insert (immediate) with full algorithm and logging, returns array of step snapshots for debugging (not used here)\n      BPlusTree.prototype.insert = function(key, stepRecorder){\n        // ignore duplicates: allow duplicates but store multiple entries (B+ trees often allow duplicates)\n        var res = this.findLeaf(key);\n        var leaf = res.leaf;\n        var insertIndex = 0;\n        while(insertIndex < leaf.keys.length && leaf.keys[insertIndex] < key) insertIndex++;\n        leaf.keys.splice(insertIndex,0,key);\n        if(stepRecorder) stepRecorder(\"Inserted key \" + key + \" into leaf \" + leaf.id);\n        // check overflow\n        if(leaf.keys.length > this.maxKeys){\n          this._splitLeaf(leaf, stepRecorder);\n        }\n      };\n\n      BPlusTree.prototype._splitLeaf = function(leaf, stepRecorder){\n        // split into two leaves\n        var total = leaf.keys.length;\n        var splitAt = Math.ceil(total / 2);\n        var rightKeys = leaf.keys.splice(splitAt);\n        var right = this._createNode(true);\n        right.keys = rightKeys;\n        right.next = leaf.next;\n        leaf.next = right.id;\n        right.parent = leaf.parent;\n        if(stepRecorder) stepRecorder(\"Split leaf \" + leaf.id + \" into \" + leaf.id + \" and \" + right.id + \". Promote key \" + right.keys[0]);\n        var promoteKey = right.keys[0];\n        this._insertIntoParent(leaf, promoteKey, right, stepRecorder);\n      };\n\n      BPlusTree.prototype._insertIntoParent = function(leftNode, key, rightNode, stepRecorder){\n        if(leftNode.id === this.root){\n          // create new root\n          var newRoot = this._createNode(false);\n          newRoot.keys = [key];\n          newRoot.children = [leftNode.id, rightNode.id];\n          leftNode.parent = newRoot.id;\n          rightNode.parent = newRoot.id;\n          this.root = newRoot.id;\n          if(stepRecorder) stepRecorder(\"Created new root \" + newRoot.id + \" with key \" + key);\n          return;\n        }\n        var parent = this._getNode(leftNode.parent);\n        // find position to insert key\n        var idx = 0;\n        while(idx < parent.keys.length && parent.keys[idx] <= key) idx++;\n        parent.keys.splice(idx,0,key);\n        parent.children.splice(idx+1,0,rightNode.id);\n        rightNode.parent = parent.id;\n        if(stepRecorder) stepRecorder(\"Inserted key \" + key + \" into parent \" + parent.id);\n        if(parent.keys.length > this.maxKeys){\n          this._splitInternal(parent, stepRecorder);\n        }\n      };\n\n      BPlusTree.prototype._splitInternal = function(node, stepRecorder){\n        var totalKeys = node.keys.length;\n        var splitIdx = Math.ceil(totalKeys / 2);\n        var promoteKey = node.keys[splitIdx];\n        // left keeps keys[0..splitIdx-1], right gets keys[splitIdx+1..]\n        var right = this._createNode(false);\n        right.keys = node.keys.splice(splitIdx+1);\n        // children: right gets corresponding children\n        var movedChildren = node.children.splice(splitIdx+1);\n        right.children = movedChildren;\n        right.children.forEach(function(cid){\n          var c = this._getNode(cid); if(c) c.parent = right.id;\n        }, this);\n        // remove promoteKey from left.keys (it was at position splitIdx)\n        node.keys.splice(splitIdx,1); // remove promoteKey from left\n        if(stepRecorder) stepRecorder(\"Split internal node \" + node.id + \" into \" + node.id + \" and \" + right.id + \". Promote key \" + promoteKey);\n        // insert promoteKey into parent\n        this._insertIntoParent(node, promoteKey, right, stepRecorder);\n      };\n\n      // Delete (immediate) with merge/borrow algorithm\n      BPlusTree.prototype.delete = function(key, stepRecorder){\n        var searchRes = this.search(key);\n        if(!searchRes.found){\n          if(stepRecorder) stepRecorder(\"Key \" + key + \" not found (no deletion).\");\n          return;\n        }\n        var leaf = searchRes.node;\n        var idx = searchRes.index;\n        leaf.keys.splice(idx,1);\n        if(stepRecorder) stepRecorder(\"Removed key \" + key + \" from leaf \" + leaf.id);\n        // if leaf is root and now empty, handle\n        if(leaf.id === this.root){\n          // nothing to do further\n          if(leaf.keys.length === 0){\n            // keep empty root leaf (allowed)\n            if(stepRecorder) stepRecorder(\"Root leaf is empty but remains root.\");\n          }\n          return;\n        }\n        // check underflow\n        if(leaf.keys.length < this.minKeys){\n          this._rebalanceAfterDelete(leaf, stepRecorder);\n        }\n      };\n\n      BPlusTree.prototype._rebalanceAfterDelete = function(node, stepRecorder){\n        if(node.id === this.root) return;\n        var parent = this._getNode(node.parent);\n        // find index of node in parent.children\n        var idx = parent.children.indexOf(node.id);\n        var leftSibling = idx > 0 ? this._getNode(parent.children[idx-1]) : null;\n        var rightSibling = idx < parent.children.length-1 ? this._getNode(parent.children[idx+1]) : null;\n\n        // try borrow from left\n        if(leftSibling && leftSibling.keys.length > this.minKeys){\n          // borrow last key from left\n          if(node.isLeaf){\n            var borrowed = leftSibling.keys.pop();\n            node.keys.unshift(borrowed);\n            // update parent key separating them\n            parent.keys[idx-1] = node.keys[0];\n            if(stepRecorder) stepRecorder(\"Borrowed key \" + borrowed + \" from left sibling \" + leftSibling.id + \" into leaf \" + node.id + \". Updated parent key \" + parent.keys[idx-1]);\n          } else {\n            // internal: borrow child from left\n            var borrowedKey = leftSibling.keys.pop();\n            var borrowedChildId = leftSibling.children.pop();\n            node.keys.unshift(parent.keys[idx-1]);\n            node.children.unshift(borrowedChildId);\n            parent.keys[idx-1] = borrowedKey;\n            var bc = this._getNode(borrowedChildId); if(bc) bc.parent = node.id;\n            if(stepRecorder) stepRecorder(\"Borrowed child \" + borrowedChildId + \" from left internal \" + leftSibling.id + \" into \" + node.id + \". Moved up key.\");\n          }\n          return;\n        }\n\n        // try borrow from right\n        if(rightSibling && rightSibling.keys.length > this.minKeys){\n          if(node.isLeaf){\n            var borrowed = rightSibling.keys.shift();\n            node.keys.push(borrowed);\n            parent.keys[idx] = rightSibling.keys[0];\n            if(stepRecorder) stepRecorder(\"Borrowed key \" + borrowed + \" from right sibling \" + rightSibling.id + \" into leaf \" + node.id + \". Updated parent key \" + parent.keys[idx]);\n          } else {\n            var borrowedKey = rightSibling.keys.shift();\n            var borrowedChildId = rightSibling.children.shift();\n            node.keys.push(parent.keys[idx]);\n            node.children.push(borrowedChildId);\n            parent.keys[idx] = borrowedKey;\n            var bc2 = this._getNode(borrowedChildId); if(bc2) bc2.parent = node.id;\n            if(stepRecorder) stepRecorder(\"Borrowed child \" + borrowedChildId + \" from right internal \" + rightSibling.id + \" into \" + node.id + \". Moved up key.\");\n          }\n          return;\n        }\n\n        // else merge\n        if(leftSibling){\n          // merge node into leftSibling\n          if(node.isLeaf){\n            leftSibling.keys = leftSibling.keys.concat(node.keys);\n            leftSibling.next = node.next;\n            // remove node from parent\n            parent.children.splice(idx,1);\n            parent.keys.splice(idx-1,1);\n            delete this.nodeMap[node.id];\n            if(stepRecorder) stepRecorder(\"Merged leaf \" + node.id + \" into left sibling \" + leftSibling.id + \". Removed separator key in parent.\");\n          } else {\n            // internal: left + parent separator + node\n            var sep = parent.keys[idx-1];\n            leftSibling.keys.push(sep);\n            leftSibling.keys = leftSibling.keys.concat(node.keys);\n            leftSibling.children = leftSibling.children.concat(node.children);\n            leftSibling.children.forEach(function(cid){ var c = this._getNode(cid); if(c) c.parent = leftSibling.id; }, this);\n            parent.children.splice(idx,1);\n            parent.keys.splice(idx-1,1);\n            delete this.nodeMap[node.id];\n            if(stepRecorder) stepRecorder(\"Merged internal \" + node.id + \" into left sibling \" + leftSibling.id + \". Pulled down separator \" + sep);\n          }\n        } else if(rightSibling){\n          // merge rightSibling into node\n          if(node.isLeaf){\n            node.keys = node.keys.concat(rightSibling.keys);\n            node.next = rightSibling.next;\n            parent.children.splice(idx+1,1);\n            parent.keys.splice(idx,1);\n            delete this.nodeMap[rightSibling.id];\n            if(stepRecorder) stepRecorder(\"Merged right leaf \" + rightSibling.id + \" into \" + node.id + \". Removed separator in parent.\");\n          } else {\n            var sep2 = parent.keys[idx];\n            node.keys.push(sep2);\n            node.keys = node.keys.concat(rightSibling.keys);\n            node.children = node.children.concat(rightSibling.children);\n            node.children.forEach(function(cid){ var c = this._getNode(cid); if(c) c.parent = node.id; }, this);\n            parent.children.splice(idx+1,1);\n            parent.keys.splice(idx,1);\n            delete this.nodeMap[rightSibling.id];\n            if(stepRecorder) stepRecorder(\"Merged right internal \" + rightSibling.id + \" into \" + node.id + \". Pulled down separator \" + sep2);\n          }\n        }\n\n        // after merge, parent may underflow\n        if(parent.id === this.root && parent.keys.length === 0){\n          // collapse root\n          this.root = parent.children[0];\n          var newRoot = this._getNode(this.root);\n          newRoot.parent = null;\n          delete this.nodeMap[parent.id];\n          if(stepRecorder) stepRecorder(\"Collapsed empty root \" + parent.id + \". New root is \" + newRoot.id);\n          return;\n        }\n\n        if(parent.keys.length < this.minKeys){\n          this._rebalanceAfterDelete(parent, stepRecorder);\n        }\n      };\n\n      // Utility: pretty render tree by levels\n      function renderTreeFromSnapshot(snap){\n        // snap: { root, nodes: {id:node...} }\n        var output = document.createElement('div');\n        var nodes = snap.nodes;\n        if(!snap.root || !nodes[snap.root]) {\n          var p = document.createElement('div'); p.textContent = \"(empty tree)\"; output.appendChild(p); return output;\n        }\n        var q = [snap.root];\n        var nextLevel = [];\n        var levels = [];\n        var visited = {};\n        while(q.length){\n          var levelNodes = [];\n          for(var i=0;i<q.length;i++){\n            var nid = q[i];\n            var n = nodes[nid];\n            if(!n) continue;\n            levelNodes.push(n);\n            if(!n.isLeaf){\n              for(var j=0;j<n.children.length;j++){\n                nextLevel.push(n.children[j]);\n              }\n            }\n          }\n          levels.push(levelNodes);\n          q = nextLevel; nextLevel = [];\n          // break on infinite loops\n          if(levels.length > 100) break;\n        }\n        // create simple textual representation\n        levels.forEach(function(level, idx){\n          var row = document.createElement('div');\n          row.style.marginBottom = '6px';\n          var label = document.createElement('div'); label.textContent = 'Level ' + idx + ':';\n          row.appendChild(label);\n          var container = document.createElement('div');\n          level.forEach(function(n){\n            var nb = document.createElement('div');\n            nb.className = 'nodeBox';\n            var t = '[' + n.keys.join(', ') + ']';\n            if(showNodeIds.checked) t = n.id + ' ' + t;\n            if(showCapacity.checked){\n              t += ' (k=' + n.keys.length + ')';\n              if(!n.isLeaf) t += ' (c=' + n.children.length + ')';\n            }\n            if(!n.isLeaf){\n              t += '\\\\nchildren: (' + n.children.join(',') + ')';\n            } else {\n              if(showLeafList.checked) t += ' -> ' + (n.next || 'null');\n            }\n            nb.textContent = t;\n            container.appendChild(nb);\n          });\n          row.appendChild(container);\n          output.appendChild(row);\n        });\n        return output;\n      }\n\n      // Render current tree or current step snapshot\n      function renderCurrentView(){\n        var snap;\n        if(stepIndex >= 0 && currentSteps.length){\n          snap = currentSteps[stepIndex].state;\n        } else {\n          snap = tree.snapshot();\n        }\n        // render tree\n        treeView.innerHTML = '';\n        treeView.appendChild(renderTreeFromSnapshot(snap));\n        // render leaf linked list optionally\n        leafListView.innerHTML = '';\n        if(showLeafList.checked){\n          var nodes = snap.nodes;\n          var rootNode = nodes[snap.root];\n          if(rootNode){\n            // find leftmost leaf\n            var cur = rootNode;\n            while(cur && !cur.isLeaf){\n              cur = nodes[cur.children[0]];\n            }\n            var listDiv = document.createElement('div');\n            listDiv.textContent = 'Leaf linked list order: ';\n            while(cur){\n              var s = (showNodeIds.checked ? (cur.id + ' ') : '') + '[' + cur.keys.join(',') + ']';\n              var span = document.createElement('span'); span.textContent = s;\n              listDiv.appendChild(span);\n              if(!cur.next) break;\n              cur = nodes[cur.next];\n            }\n            leafListView.appendChild(listDiv);\n          }\n        }\n      }\n\n      // Step recorder: creates snapshots at key points\n      function createStepRecorder(prefix){\n        var steps = [];\n        return {\n          record: function(desc){\n            var snap = tree.snapshot();\n            steps.push({state: snap, desc: desc});\n            logLine((prefix?prefix+': ':'') + desc);\n          },\n          getSteps: function(){ return steps; }\n        };\n      }\n\n      // For step-mode wrapper on a sequence of keys\n      function performInsertWithSteps(keys, onComplete){\n        currentSteps = []; stepIndex = -1;\n        var recorder = createStepRecorder(\"InsertSequence\");\n        recorder.record(\"Starting insertion sequence: [\" + keys.join(', ') + \"]\");\n        // We'll perform each insertion but record snapshots after each microaction\n        keys.forEach(function(k){\n          recorder.record(\"Locate leaf for key \" + k);\n          var res = tree.findLeaf(k);\n          var leaf = res.leaf;\n          var idx = 0;\n          while(idx < leaf.keys.length && leaf.keys[idx] < k) idx++;\n          leaf.keys.splice(idx,0,k);\n          recorder.record(\"Inserted key \" + k + \" into leaf \" + leaf.id);\n          if(leaf.keys.length > tree.maxKeys){\n            // handle splits iteratively, inner functions will record\n            handleLeafSplitStepwise(leaf, recorder);\n          }\n        });\n        recorder.record(\"Finished insertion sequence.\");\n        currentSteps = recorder.getSteps();\n        stepIndex = 0;\n        renderCurrentView();\n        if(onComplete) onComplete();\n      }\n\n      function handleLeafSplitStepwise(leaf, recorder){\n        // while overflow, split and propagate\n        var cur = leaf;\n        while(cur.keys.length > tree.maxKeys){\n          var total = cur.keys.length;\n          var splitAt = Math.ceil(total/2);\n          var rightKeys = cur.keys.splice(splitAt);\n          var right = tree._createNode(true);\n          right.keys = rightKeys;\n          right.next = cur.next;\n          cur.next = right.id;\n          right.parent = cur.parent;\n          recorder.record(\"Split leaf \" + cur.id + \" into \" + cur.id + \" and \" + right.id + \". Promote key \" + right.keys[0]);\n          var promoteKey = right.keys[0];\n          // insert into parent stepwise\n          cur = insertIntoParentStepwise(cur, promoteKey, right, recorder);\n        }\n      }\n\n      function insertIntoParentStepwise(leftNode, key, rightNode, recorder){\n        if(leftNode.id === tree.root){\n          var newRoot = tree._createNode(false);\n          newRoot.keys = [key];\n          newRoot.children = [leftNode.id, rightNode.id];\n          leftNode.parent = newRoot.id;\n          rightNode.parent = newRoot.id;\n          tree.root = newRoot.id;\n          recorder.record(\"Created new root \" + newRoot.id + \" with key \" + key);\n          return newRoot;\n        }\n        var parent = tree._getNode(leftNode.parent);\n        var idx = 0;\n        while(idx < parent.keys.length && parent.keys[idx] <= key) idx++;\n        parent.keys.splice(idx,0,key);\n        parent.children.splice(idx+1,0,rightNode.id);\n        rightNode.parent = parent.id;\n        recorder.record(\"Inserted key \" + key + \" into parent \" + parent.id);\n        if(parent.keys.length > tree.maxKeys){\n          return splitInternalStepwise(parent, recorder);\n        }\n        return parent;\n      }\n\n      function splitInternalStepwise(node, recorder){\n        var totalKeys = node.keys.length;\n        var splitIdx = Math.ceil(totalKeys/2);\n        var promoteKey = node.keys[splitIdx];\n        var right = tree._createNode(false);\n        right.keys = node.keys.splice(splitIdx+1);\n        var movedChildren = node.children.splice(splitIdx+1);\n        right.children = movedChildren;\n        right.children.forEach(function(cid){ var c = tree._getNode(cid); if(c) c.parent = right.id; });\n        node.keys.splice(splitIdx,1);\n        recorder.record(\"Split internal node \" + node.id + \" into \" + node.id + \" and \" + right.id + \". Promote key \" + promoteKey);\n        return insertIntoParentStepwise(node, promoteKey, right, recorder);\n      }\n\n      // For deletion step-mode\n      function performDeleteWithSteps(keys, onComplete){\n        currentSteps = []; stepIndex = -1;\n        var recorder = createStepRecorder(\"DeleteSequence\");\n        recorder.record(\"Starting deletion sequence: [\" + keys.join(', ') + \"]\");\n        keys.forEach(function(k){\n          var s = tree.search(k);\n          if(!s.found){\n            recorder.record(\"Key \" + k + \" not found; skip deletion.\");\n            return;\n          }\n          var leaf = s.node;\n          leaf.keys.splice(s.index,1);\n          recorder.record(\"Deleted key \" + k + \" from leaf \" + leaf.id);\n          if(leaf.id === tree.root){\n            recorder.record(\"Root leaf modified.\");\n          } else if(leaf.keys.length < tree.minKeys){\n            // rebalance stepwise\n            rebalanceDeleteStepwise(leaf, recorder);\n          }\n        });\n        recorder.record(\"Finished deletion sequence.\");\n        currentSteps = recorder.getSteps();\n        stepIndex = 0;\n        renderCurrentView();\n        if(onComplete) onComplete();\n      }\n\n      function rebalanceDeleteStepwise(node, recorder){\n        var cur = node;\n        while(true){\n          if(cur.id === tree.root) break;\n          var parent = tree._getNode(cur.parent);\n          var idx = parent.children.indexOf(cur.id);\n          var leftSibling = idx > 0 ? tree._getNode(parent.children[idx-1]) : null;\n          var rightSibling = idx < parent.children.length-1 ? tree._getNode(parent.children[idx+1]) : null;\n          if(leftSibling && leftSibling.keys.length > tree.minKeys){\n            if(cur.isLeaf){\n              var borrowed = leftSibling.keys.pop();\n              cur.keys.unshift(borrowed);\n              parent.keys[idx-1] = cur.keys[0];\n              recorder.record(\"Borrowed key \" + borrowed + \" from left sibling \" + leftSibling.id + \" into leaf \" + cur.id + \". Updated parent key.\");\n            } else {\n              var borrowedKey = leftSibling.keys.pop();\n              var borrowedChildId = leftSibling.children.pop();\n              cur.keys.unshift(parent.keys[idx-1]);\n              cur.children.unshift(borrowedChildId);\n              parent.keys[idx-1] = borrowedKey;\n              var bc = tree._getNode(borrowedChildId); if(bc) bc.parent = cur.id;\n              recorder.record(\"Borrowed child \" + borrowedChildId + \" from left internal \" + leftSibling.id + \" into \" + cur.id + \".\");\n            }\n            break;\n          } else if(rightSibling && rightSibling.keys.length > tree.minKeys){\n            if(cur.isLeaf){\n              var borrowed2 = rightSibling.keys.shift();\n              cur.keys.push(borrowed2);\n              parent.keys[idx] = rightSibling.keys[0];\n              recorder.record(\"Borrowed key \" + borrowed2 + \" from right sibling \" + rightSibling.id + \" into leaf \" + cur.id + \". Updated parent key.\");\n            } else {\n              var borrowedKey2 = rightSibling.keys.shift();\n              var borrowedChildId2 = rightSibling.children.shift();\n              cur.keys.push(parent.keys[idx]);\n              cur.children.push(borrowedChildId2);\n              parent.keys[idx] = borrowedKey2;\n              var bc2 = tree._getNode(borrowedChildId2); if(bc2) bc2.parent = cur.id;\n              recorder.record(\"Borrowed child \" + borrowedChildId2 + \" from right internal \" + rightSibling.id + \" into \" + cur.id + \".\");\n            }\n            break;\n          } else {\n            // merge\n            if(leftSibling){\n              if(cur.isLeaf){\n                leftSibling.keys = leftSibling.keys.concat(cur.keys);\n                leftSibling.next = cur.next;\n                parent.children.splice(idx,1);\n                parent.keys.splice(idx-1,1);\n                delete tree.nodeMap[cur.id];\n                recorder.record(\"Merged leaf \" + cur.id + \" into left sibling \" + leftSibling.id + \".\");\n                cur = parent;\n              } else {\n                var sep = parent.keys[idx-1];\n                leftSibling.keys.push(sep);\n                leftSibling.keys = leftSibling.keys.concat(cur.keys);\n                leftSibling.children = leftSibling.children.concat(cur.children);\n                leftSibling.children.forEach(function(cid){ var c = tree._getNode(cid); if(c) c.parent = leftSibling.id; });\n                parent.children.splice(idx,1);\n                parent.keys.splice(idx-1,1);\n                delete tree.nodeMap[cur.id];\n                recorder.record(\"Merged internal \" + cur.id + \" into left sibling \" + leftSibling.id + \".\");\n                cur = parent;\n              }\n            } else if(rightSibling){\n              if(cur.isLeaf){\n                cur.keys = cur.keys.concat(rightSibling.keys);\n                cur.next = rightSibling.next;\n                parent.children.splice(idx+1,1);\n                parent.keys.splice(idx,1);\n                delete tree.nodeMap[rightSibling.id];\n                recorder.record(\"Merged right leaf \" + rightSibling.id + \" into \" + cur.id + \".\");\n                cur = parent;\n              } else {\n                var sep2 = parent.keys[idx];\n                cur.keys.push(sep2);\n                cur.keys = cur.keys.concat(rightSibling.keys);\n                cur.children = cur.children.concat(rightSibling.children);\n                cur.children.forEach(function(cid){ var c = tree._getNode(cid); if(c) c.parent = cur.id; });\n                parent.children.splice(idx+1,1);\n                parent.keys.splice(idx,1);\n                delete tree.nodeMap[rightSibling.id];\n                recorder.record(\"Merged internal \" + rightSibling.id + \" into \" + cur.id + \".\");\n                cur = parent;\n              }\n            } else {\n              // no siblings - shouldn't happen\n              break;\n            }\n            if(cur.id === tree.root && cur.keys.length === 0){\n              tree.root = cur.children ? cur.children[0] : cur.id;\n              var newRoot = tree._getNode(tree.root);\n              if(newRoot) newRoot.parent = null;\n              delete tree.nodeMap[cur.id];\n              recorder.record(\"Collapsed root after merge. New root: \" + tree.root);\n              break;\n            }\n            if(cur.keys.length >= tree.minKeys) break;\n            // continue up\n          }\n        }\n      }\n\n      // History management\n      function pushHistory(note){\n        history.push(tree.snapshot());\n        future = [];\n      }\n\n      // UI wiring\n      function initTree(){\n        idCounter = 0;\n        var m = parseInt(orderInput.value) || 4;\n        if(m < 3) m = 3; orderInput.value = m;\n        tree = new BPlusTree(m);\n        logs = [];\n        currentSteps = []; stepIndex = -1;\n        history = []; future = [];\n        pushHistory();\n        logLine(\"Initialized B+ tree with order m=\" + m);\n        renderCurrentView(); renderLog();\n      }\n\n      initBtn.addEventListener('click', function(){ initTree(); });\n\n      resetBtn.addEventListener('click', function(){\n        idCounter = 0; tree = null; logs = []; history = []; future = []; currentSteps = []; stepIndex = -1;\n        document.getElementById('log').textContent = '';\n        treeView.innerHTML = ''; leafListView.innerHTML = '';\n        logLine(\"Reset demo. Please initialize tree.\");\n      });\n\n      insertBtn.addEventListener('click', function(){\n        var k = Number(keyInput.value);\n        if(isNaN(k)) return;\n        pushHistory();\n        tree.insert(k, function(desc){ logLine(desc); });\n        logLine(\"Completed insertion of \" + k);\n        renderCurrentView();\n      });\n\n      insertStepBtn.addEventListener('click', function(){\n        var k = Number(keyInput.value);\n        if(isNaN(k)) return;\n        performInsertWithSteps([k]);\n        logLine(\"Step-mode insertion prepared for key \" + k + \". Use step controls to advance and commit.\");\n      });\n\n      multiInsertBtn.addEventListener('click', function(){\n        var s = multiInsertInput.value.trim();\n        if(!s) return;\n        var items = s.split(',').map(function(x){ return Number(x.trim()); }).filter(function(x){ return !isNaN(x); });\n        if(items.length===0) return;\n        pushHistory();\n        items.forEach(function(k){\n          tree.insert(k, function(desc){ logLine(desc); });\n        });\n        logLine(\"Bulk immediate insert completed: [\" + items.join(',') + \"]\");\n        renderCurrentView();\n      });\n\n      multiInsertStepBtn.addEventListener('click', function(){\n        var s = multiInsertInput.value.trim();\n        if(!s) return;\n        var items = s.split(',').map(function(x){ return Number(x.trim()); }).filter(function(x){ return !isNaN(x); });\n        if(items.length===0) return;\n        performInsertWithSteps(items);\n        logLine(\"Prepared step-mode bulk insertion of \" + items.length + \" keys.\");\n      });\n\n      delBtn.addEventListener('click', function(){\n        var k = Number(delInput.value);\n        if(isNaN(k)) return;\n        pushHistory();\n        tree.delete(k, function(desc){ logLine(desc); });\n        logLine(\"Completed deletion of \" + k);\n        renderCurrentView();\n      });\n\n      delStepBtn.addEventListener('click', function(){\n        var k = Number(delInput.value);\n        if(isNaN(k)) return;\n        performDeleteWithSteps([k]);\n        logLine(\"Prepared step-mode deletion for key \" + k);\n      });\n\n      findBtn.addEventListener('click', function(){\n        var k = Number(findInput.value);\n        if(isNaN(k)) return;\n        var res = tree.search(k);\n        if(res.found){\n          logLine(\"Found key \" + k + \" in leaf \" + res.node.id + \" at index \" + res.index + \". Path: \" + res.path.join('->'));\n        } else {\n          logLine(\"Key \" + k + \" not found. Would be at leaf \" + res.node.id + \". Path: \" + res.path.join('->'));\n        }\n        renderCurrentView();\n      });\n\n      rangeBtn.addEventListener('click', function(){\n        var a = Number(rfrom.value), b = Number(rto.value);\n        if(isNaN(a) || isNaN(b)) return;\n        if(a > b) { var t = a; a = b; b = t; }\n        var start = tree.findLeaf(a).leaf;\n        var out = [];\n        var cur = start;\n        while(cur){\n          for(var i=0;i<cur.keys.length;i++){\n            var k = cur.keys[i];\n            if(k >= a && k <= b) out.push(k);\n            if(k > b) break;\n          }\n          if(cur.keys.length && cur.keys[cur.keys.length-1] > b) break;\n          if(!cur.next) break;\n          cur = tree._getNode(cur.next);\n        }\n        logLine(\"Range search [\" + a + \",\" + b + \"] => \" + out.join(', '));\n      });\n\n      slider.addEventListener('input', function(){\n        sliderVal.textContent = slider.value;\n      });\n\n      insertSliderBtn.addEventListener('click', function(){\n        var v = Number(slider.value);\n        pushHistory();\n        tree.insert(v, function(desc){ logLine(desc); });\n        logLine(\"Inserted value from slider: \" + v);\n        renderCurrentView();\n      });\n\n      randBtn.addEventListener('click', function(){\n        var cnt = Math.max(1, Number(randCount.value));\n        var maxi = Math.max(1, Number(randMax.value));\n        var arr = [];\n        for(var i=0;i<cnt;i++){\n          arr.push(Math.floor(Math.random()*maxi));\n        }\n        pushHistory();\n        arr.forEach(function(k){ tree.insert(k, function(desc){ logLine(desc); }); });\n        logLine(\"Random inserted \" + cnt + \" keys.\");\n        renderCurrentView();\n      });\n\n      randStepBtn.addEventListener('click', function(){\n        var cnt = Math.max(1, Number(randCount.value));\n        var maxi = Math.max(1, Number(randMax.value));\n        var arr = [];\n        for(var i=0;i<cnt;i++){\n          arr.push(Math.floor(Math.random()*maxi));\n        }\n        performInsertWithSteps(arr);\n        logLine(\"Prepared step-mode random insertion of \" + cnt + \" keys.\");\n      });\n\n      stepPrev.addEventListener('click', function(){\n        if(currentSteps.length===0) return;\n        stepIndex = Math.max(0, stepIndex-1);\n        logLine(\"STEP: \" + (currentSteps[stepIndex].desc || ''));\n        renderCurrentView();\n      });\n      stepNext.addEventListener('click', function(){\n        if(currentSteps.length===0) return;\n        stepIndex = Math.min(currentSteps.length-1, stepIndex+1);\n        logLine(\"STEP: \" + (currentSteps[stepIndex].desc || ''));\n        renderCurrentView();\n      });\n      stepFirst.addEventListener('click', function(){\n        if(currentSteps.length===0) return;\n        stepIndex = 0;\n        logLine(\"STEP: \" + (currentSteps[stepIndex].desc || ''));\n        renderCurrentView();\n      });\n      stepLast.addEventListener('click', function(){\n        if(currentSteps.length===0) return;\n        stepIndex = currentSteps.length-1;\n        logLine(\"STEP: \" + (currentSteps[stepIndex].desc || ''));\n        renderCurrentView();\n      });\n\n      commitSteps.addEventListener('click', function(){\n        if(currentSteps.length===0) { logLine(\"No steps to commit.\"); return; }\n        pushHistory();\n        var lastSnap = currentSteps[currentSteps.length-1].state;\n        tree.restoreFromSnapshot(lastSnap);\n        logLine(\"Committed step sequence. Tree updated to last step.\");\n        currentSteps = []; stepIndex = -1;\n        renderCurrentView();\n      });\n\n      discardSteps.addEventListener('click', function(){\n        if(currentSteps.length===0) return;\n        logLine(\"Discarded current step sequence.\");\n        currentSteps = []; stepIndex = -1;\n        renderCurrentView();\n      });\n\n      autoPlay.addEventListener('change', function(){\n        if(autoPlay.checked){\n          var intv = Number(intervalInput.value) || Number(speedSlider.value) || 800;\n          autoplayInterval = setInterval(function(){\n            if(currentSteps.length===0) { clearInterval(autoplayInterval); autoPlay.checked = false; return; }\n            if(stepIndex < currentSteps.length-1) {\n              stepIndex++;\n              logLine(\"AUTOPLAY STEP: \" + currentSteps[stepIndex].desc);\n              renderCurrentView();\n            } else {\n              clearInterval(autoplayInterval);\n              autoPlay.checked = false;\n              logLine(\"Autoplay finished.\");\n            }\n          }, intv);\n        } else {\n          if(autoplayInterval) clearInterval(autoplayInterval);\n        }\n      });\n\n      intervalInput.addEventListener('input', function(){\n        if(autoPlay.checked){\n          autoPlay.checked = false;\n          if(autoplayInterval) clearInterval(autoplayInterval);\n        }\n      });\n\n      speedSlider.addEventListener('input', function(){\n        speedVal.textContent = speedSlider.value + 'ms';\n        intervalInput.value = speedSlider.value;\n      });\n\n      undoBtn.addEventListener('click', function(){\n        if(history.length <= 1){\n          logLine(\"Nothing to undo.\");\n          return;\n        }\n        var last = history.pop();\n        future.push(last);\n        var prev = history[history.length-1];\n        tree.restoreFromSnapshot(prev);\n        logLine(\"Undo applied.\");\n        renderCurrentView();\n      });\n\n      redoBtn.addEventListener('click', function(){\n        if(future.length === 0){ logLine(\"Nothing to redo.\"); return; }\n        var s = future.pop();\n        history.push(s);\n        tree.restoreFromSnapshot(s);\n        logLine(\"Redo applied.\");\n        renderCurrentView();\n      });\n\n      exportBtn.addEventListener('click', function(){\n        var data = JSON.stringify(tree.snapshot());\n        logLine(\"Exported tree JSON (copied to import area).\");\n        importArea.value = data;\n      });\n\n      importBtn.addEventListener('click', function(){\n        var s = importArea.value.trim();\n        if(!s) { logLine(\"No JSON to import.\"); return; }\n        try{\n          var obj = JSON.parse(s);\n          idCounter = 0;\n          // try to update idCounter to avoid collisions\n          Object.keys(obj.nodes || {}).forEach(function(k){\n            var nid = k.replace(/^n/, '');\n            var vi = parseInt(nid);\n            if(!isNaN(vi) && vi > idCounter) idCounter = vi;\n          });\n          tree.restoreFromSnapshot(obj);\n          history.push(tree.snapshot());\n          logLine(\"Imported tree from JSON.\");\n          renderCurrentView();\n        } catch(e){\n          logLine(\"Import error: \" + e.message);\n        }\n      });\n\n      clearLogBtn.addEventListener('click', function(){\n        logs = []; renderLog();\n      });\n\n      showNodeIds.addEventListener('change', renderCurrentView);\n      showCapacity.addEventListener('change', renderCurrentView);\n      showLeafList.addEventListener('change', renderCurrentView);\n\n      // Initialize default\n      initTree();\n      logLine(\"Demo ready. Use the controls above to interact with the B+ tree.\");\n\n      // Expose some debug functions in console for power users\n      window._bptree_debug = {\n        tree: function(){ return tree; },\n        snapshot: function(){ return tree.snapshot(); },\n        steps: function(){ return currentSteps; },\n        logs: function(){ return logs; }\n      };\n    })();\n  </script>\n</body>\n</html>"
