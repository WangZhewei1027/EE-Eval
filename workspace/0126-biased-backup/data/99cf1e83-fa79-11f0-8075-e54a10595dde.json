    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Floyd-Warshall Algorithm Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        table { border-collapse: collapse; margin: 20px 0; }\n        td, th { border: 1px solid black; padding: 5px; text-align: center; }\n    </style>\n</head>\n<body>\n    <h1>Floyd-Warshall Algorithm Interactive Demo</h1>\n    <p>\n        Enter the number of vertices: <input type=\"number\" id=\"vertexCount\" value=\"3\" min=\"1\" max=\"10\">\n        <button onclick=\"initializeGraph()\">Initialize Graph</button>\n    </p>\n    <table id=\"graphTable\"></table>\n    <button onclick=\"calculateFloydWarshall()\">Calculate Shortest Paths</button>\n    \n    <h2>Results:</h2>\n    <table id=\"resultTable\"></table>\n\n    <script>\n        let graph = [];\n        let vertices = 0;\n\n        function initializeGraph() {\n            vertices = document.getElementById('vertexCount').value;\n            graph = Array.from({ length: vertices }, () => Array(vertices).fill(Infinity));\n            for (let i = 0; i < vertices; i++) {\n                graph[i][i] = 0; // Distance to self is 0\n            }\n            renderGraphInput();\n        }\n\n        function renderGraphInput() {\n            const table = document.getElementById('graphTable');\n            table.innerHTML = '';\n            for (let i = 0; i < vertices; i++) {\n                const row = table.insertRow();\n                for (let j = 0; j < vertices; j++) {\n                    const cell = row.insertCell();\n                    if (i !== j) {\n                        cell.innerHTML = `<input type=\"number\" id=\"edge-${i}-${j}\" value=\"${graph[i][j] === Infinity ? '' : graph[i][j]}\"/>`;\n                    } else {\n                        cell.innerHTML = '0';\n                    }\n                }\n            }\n        }\n\n        function calculateFloydWarshall() {\n            for (let i = 0; i < vertices; i++) {\n                for (let j = 0; j < vertices; j++) {\n                    const edgeValue = document.getElementById(`edge-${i}-${j}`).value;\n                    graph[i][j] = edgeValue !== '' ? parseInt(edgeValue) : Infinity;\n                }\n            }\n\n            const result = floydWarshall(graph);\n            renderResult(result);\n        }\n\n        function floydWarshall(graph) {\n            const dist = graph.map(row => row.slice()); // Deep copy\n            for (let k = 0; k < vertices; k++) {\n                for (let i = 0; i < vertices; i++) {\n                    for (let j = 0; j < vertices; j++) {\n                        if (dist[i][k] + dist[k][j] < dist[i][j]) {\n                            dist[i][j] = dist[i][k] + dist[k][j];\n                        }\n                    }\n                }\n            }\n            return dist;\n        }\n\n        function renderResult(result) {\n            const table = document.getElementById('resultTable');\n            table.innerHTML = '';\n            for (let i = 0; i < result.length; i++) {\n                const row = table.insertRow();\n                for (let j = 0; j < result[i].length; j++) {\n                    const cell = row.insertCell();\n                    cell.innerHTML = result[i][j] === Infinity ? '∞' : result[i][j];\n                }\n            }\n        }\n    </script>\n</body>\n</html>"
