    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Queue</title>\n    <style>\n        /* Custom styles */\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 0;\n        }\n\n        #queue {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 300px;\n            background-color: #f5f5f5;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        #queue button {\n            width: 20px;\n            height: 20px;\n            background-color: white;\n            border: none;\n            cursor: pointer;\n        }\n\n        #queue button:hover {\n            background-color: #d9d9d9;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"queue\"></div>\n\n    <button onclick=\"addToQueue()\">Add to Queue</button>\n\n    <button onclick=\"removeFromQueue()\">Remove from Queue</button>\n\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js\"></script>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/materialize/5.0.4/dist/materialize.min.js\"></script>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/bootstrap/3.6.0/js/bootstrap.min.js\"></script>\n\n    <script>\n        $(document).ready(function(){\n            // Add functionality to queue\n            function addToQueue() {\n                var queue = document.getElementById(\"queue\");\n                var element = document.createElement(\"div\");\n                element.classList.add(\"queue-item\");\n\n                queue.appendChild(element);\n\n                // Add event listener for when a new item is added to the queue\n                queue.addEventListener(\"click\", function(){\n                    // Call addToQueue function\n                    addToQueue();\n                });\n            }\n\n            function removeFromQueue() {\n                var queue = document.getElementById(\"queue\");\n                var element = document.createElement(\"div\");\n                element.classList.remove(\"queue-item\");\n\n                queue.removeChild(element);\n\n                // Call removeFromQueue function\n                removeFromQueue();\n            }\n\n            // Call addToQueue function every time the page loads\n            setInterval(addToQueue, 1000);\n        });\n    </script>\n</body>\n</html>"
