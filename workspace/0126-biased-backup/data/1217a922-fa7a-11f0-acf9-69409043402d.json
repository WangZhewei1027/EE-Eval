  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Encryption Interactive Demo</title>\n</head>\n<body>\n\n<h1>Encryption Interactive Demonstration</h1>\n\n<p>\n  This demonstration explores basic encryption concepts and multiple algorithms allowing you to encrypt, decrypt, and manipulate data.\n</p>\n\n<section id=\"input-section\">\n  <h2>1. Input Text</h2>\n  <label for=\"plaintext\">Plaintext to encrypt:</label><br />\n  <textarea id=\"plaintext\" rows=\"4\" cols=\"60\" placeholder=\"Enter text here\"></textarea><br />\n  <label for=\"ciphertext\">Ciphertext to decrypt:</label><br />\n  <textarea id=\"ciphertext\" rows=\"4\" cols=\"60\" placeholder=\"Enter text here\"></textarea><br />\n</section>\n\n<section id=\"algorithm-selection\">\n  <h2>2. Select Encryption Algorithm</h2>\n  <select id=\"algorithm\">\n    <option value=\"caesar\">Caesar Cipher</option>\n    <option value=\"vigenere\">Vigenère Cipher</option>\n    <option value=\"xor\">XOR Cipher</option>\n    <option value=\"base64\">Base64 Encode/Decode</option>\n    <option value=\"aes\">AES (Browser Crypto, AES-GCM)</option>\n  </select>\n</section>\n\n<section id=\"parameters\">\n  <h2>3. Algorithm Parameters</h2>\n\n  <div id=\"param-caesar\" class=\"param-group\">\n    <label for=\"caesar-shift\">Shift (integer): </label>\n    <input type=\"number\" id=\"caesar-shift\" value=\"3\" />\n  </div>\n\n  <div id=\"param-vigenere\" class=\"param-group\" style=\"display:none;\">\n    <label for=\"vigenere-key\">Key (letters only): </label>\n    <input type=\"text\" id=\"vigenere-key\" value=\"KEY\" />\n  </div>\n\n  <div id=\"param-xor\" class=\"param-group\" style=\"display:none;\">\n    <label for=\"xor-key\">Key (string): </label>\n    <input type=\"text\" id=\"xor-key\" value=\"secret\" />\n    <p>Note: XOR cipher is symmetric and requires same key for encrypt/decrypt.</p>\n  </div>\n\n  <div id=\"param-base64\" class=\"param-group\" style=\"display:none;\">\n    <p>No parameters needed for Base64.</p>\n  </div>\n\n  <div id=\"param-aes\" class=\"param-group\" style=\"display:none;\">\n    <label for=\"aes-password\">Password: </label>\n    <input type=\"password\" id=\"aes-password\" /><br />\n    <label for=\"aes-iv\">IV (Base64, optional for decryption): </label>\n    <input type=\"text\" id=\"aes-iv\" placeholder=\"Leave empty to use generated IV\" size=\"64\" />\n    <p>IV will be randomly generated on encryption if left empty.</p>\n  </div>\n</section>\n\n<section id=\"control-buttons\">\n  <h2>4. Control</h2>\n  <button id=\"encrypt-btn\">Encrypt &rarr;</button>\n  <button id=\"decrypt-btn\">&larr; Decrypt</button>\n  <button id=\"clear-btn\">Clear Fields</button>\n</section>\n\n<section id=\"output-section\">\n  <h2>5. Output</h2>\n  <label for=\"output-text\">Output Text:</label><br />\n  <textarea id=\"output-text\" rows=\"6\" cols=\"60\" readonly></textarea><br />\n</section>\n\n<section id=\"exploration\">\n  <h2>6. Exploration and Tools</h2>\n\n  <button id=\"copy-output\">Copy Output to Clipboard</button>\n  <button id=\"swap-texts\">Swap Input Fields</button>\n  <button id=\"auto-decode-base64\">Try Auto Base64 Decode Input</button>\n  <button id=\"auto-decode-hex\">Try Auto Hex Decode Input</button>\n\n  <h3>Hex Encode/Decode</h3>\n  <textarea id=\"hex-input\" rows=\"3\" cols=\"60\" placeholder=\"Text to hex encode or hex to decode\"></textarea><br />\n  <button id=\"hex-encode-btn\">Hex Encode</button>\n  <button id=\"hex-decode-btn\">Hex Decode</button>\n  <textarea id=\"hex-output\" rows=\"3\" cols=\"60\" readonly></textarea>\n\n  <h3>Statistical Analysis of Input</h3>\n  <button id=\"analyze-plaintext\">Analyze Plaintext</button>\n  <button id=\"analyze-ciphertext\">Analyze Ciphertext</button>\n  <pre id=\"analysis-output\" style=\"white-space: pre-wrap;\"></pre>\n</section>\n\n<script>\n(function(){\n\n  // Utility functions\n  function isLetter(c){ return /^[A-Za-z]$/.test(c); }\n  function mod(n, m){ return ((n % m) + m) % m; }\n\n  // Caesar Cipher\n  function caesarEncrypt(text, shift){\n    let result = '';\n    for(let i=0; i<text.length; i++){\n      let c = text.charCodeAt(i);\n      if(c >= 65 && c <= 90){\n        result += String.fromCharCode(mod(c - 65 + shift, 26) + 65);\n      } else if(c >= 97 && c <= 122){\n        result += String.fromCharCode(mod(c - 97 + shift, 26) + 97);\n      } else {\n        result += text.charAt(i);\n      }\n    }\n    return result;\n  }\n  function caesarDecrypt(text, shift){\n    return caesarEncrypt(text, -shift);\n  }\n\n  // Vigenere Cipher (letters only)\n  function vigenereEncrypt(text, key){\n    let result = '';\n    let j = 0;\n    let keyUpper = key.toUpperCase().replace(/[^A-Z]/g,'');\n    if(keyUpper.length === 0) return text;\n    for(let i=0;i<text.length;i++){\n      let c = text.charCodeAt(i);\n      let k = keyUpper.charCodeAt(j % keyUpper.length) - 65;\n      if(c >=65 && c<=90){\n        result += String.fromCharCode(mod(c - 65 + k, 26) + 65);\n        j++;\n      } else if(c >=97 && c<=122){\n        result += String.fromCharCode(mod(c - 97 + k, 26) + 97);\n        j++;\n      } else {\n        result += text.charAt(i);\n      }\n    }\n    return result;\n  }\n  function vigenereDecrypt(text, key){\n    let result = '';\n    let j = 0;\n    let keyUpper = key.toUpperCase().replace(/[^A-Z]/g,'');\n    if(keyUpper.length === 0) return text;\n    for(let i=0;i<text.length;i++){\n      let c = text.charCodeAt(i);\n      let k = keyUpper.charCodeAt(j % keyUpper.length) - 65;\n      if(c >=65 && c<=90){\n        result += String.fromCharCode(mod(c - 65 - k, 26) + 65);\n        j++;\n      } else if(c >=97 && c<=122){\n        result += String.fromCharCode(mod(c - 97 - k, 26) + 97);\n        j++;\n      } else {\n        result += text.charAt(i);\n      }\n    }\n    return result;\n  }\n\n  // XOR cipher (symmetric)\n  function xorCipher(text, key){\n    if(key.length===0) return text;\n    let result = '';\n    for(let i=0; i<text.length; i++){\n      let c = text.charCodeAt(i);\n      let k = key.charCodeAt(i % key.length);\n      result += String.fromCharCode(c ^ k);\n    }\n    return result;\n  }\n\n  // Base64 Encode/Decode\n  function base64Encode(text){\n    try {\n      // Encode as UTF-8 then Base64\n      return btoa(unescape(encodeURIComponent(text)));\n    } catch(e) {\n      return \"Error encoding to Base64\";\n    }\n  }\n  function base64Decode(text){\n    try {\n      return decodeURIComponent(escape(atob(text)));\n    } catch(e){\n      return \"Error decoding Base64 string\";\n    }\n  }\n\n  // Hex encode/decode\n  function hexEncode(text){\n    let result = '';\n    for(let i=0; i<text.length; i++){\n      let h = text.charCodeAt(i).toString(16);\n      if(h.length<2) h = \"0\"+h;\n      result += h;\n    }\n    return result;\n  }\n  function hexDecode(hex){\n    let result = '';\n    hex = hex.replace(/[^0-9a-fA-F]/g,'');\n    if(hex.length%2 !== 0) return \"Invalid hex string length\";\n    for(let i=0; i<hex.length; i+=2){\n      result += String.fromCharCode(parseInt(hex.substr(i,2),16));\n    }\n    return result;\n  }\n\n  // Tools for AES-GCM encryption/decryption using WebCrypto\n  async function aesEncrypt(text, password){\n    try {\n      const enc = new TextEncoder();\n      const encoded = enc.encode(text);\n      const pwKey = enc.encode(password);\n\n      const key = await crypto.subtle.importKey(\n        \"raw\",\n        pwKey,\n        {name:\"PBKDF2\"},\n        false,\n        [\"deriveKey\"]\n      );\n\n      // Derive AES-GCM key from password\n      const salt = enc.encode(\"fixedSaltForDemo\"); // Fixed salt for demo; real apps use random salt stored with ciphertext\n      const derivedKey = await crypto.subtle.deriveKey(\n        {\n          name:\"PBKDF2\",\n          salt:salt,\n          iterations:100000,\n          hash:\"SHA-256\"\n        },\n        key,\n        {name:\"AES-GCM\", length:256},\n        false,\n        [\"encrypt\",\"decrypt\"]\n      );\n\n      // Generate random IV or use UI IV\n      let ivInput = document.getElementById(\"aes-iv\").value.trim();\n      let iv;\n      if(ivInput!==\"\"){\n        try {\n          iv = Uint8Array.from(atob(ivInput), c=>c.charCodeAt(0));\n          if(iv.length!==12) return {error: \"IV must be 12 bytes in Base64 encoding for AES-GCM.\"};\n        } catch(e){\n          return {error: \"Invalid IV Base64 string.\"};\n        }\n      } else {\n        iv = crypto.getRandomValues(new Uint8Array(12));\n        document.getElementById(\"aes-iv\").value = btoa(String.fromCharCode(...iv));\n      }\n\n      const ciphertext = await crypto.subtle.encrypt(\n        {\n          name:\"AES-GCM\",\n          iv: iv\n        },\n        derivedKey,\n        encoded\n      );\n\n      // Return Base64 representation of ciphertext and IV (IV is output in UI)\n      const cArray = new Uint8Array(ciphertext);\n      const base64Ciphertext = btoa(String.fromCharCode(...cArray));\n      return {ciphertext: base64Ciphertext, iv: document.getElementById(\"aes-iv\").value};\n    } catch(e){\n      return {error: e.toString()};\n    }\n  }\n\n  async function aesDecrypt(base64Ciphertext, password, ivValue){\n    try {\n      const enc = new TextEncoder();\n      const pwKey = enc.encode(password);\n\n      const key = await crypto.subtle.importKey(\n        \"raw\",\n        pwKey,\n        {name:\"PBKDF2\"},\n        false,\n        [\"deriveKey\"]\n      );\n\n      const salt = enc.encode(\"fixedSaltForDemo\");\n      const derivedKey = await crypto.subtle.deriveKey(\n        {\n          name:\"PBKDF2\",\n          salt:salt,\n          iterations:100000,\n          hash:\"SHA-256\"\n        },\n        key,\n        {name:\"AES-GCM\", length:256},\n        false,\n        [\"encrypt\",\"decrypt\"]\n      );\n\n      // Decode base64 ciphertext\n      let ctArray;\n      try {\n        ctArray = Uint8Array.from(atob(base64Ciphertext), c=>c.charCodeAt(0));\n      } catch(e){\n        return {error:\"Invalid Base64 ciphertext.\"};\n      }\n\n      // Decode IV Base64 string (must be 12 bytes)\n      if(!ivValue || ivValue.length===0) return {error:\"IV is required for decryption\"};\n      let iv;\n      try {\n        iv = Uint8Array.from(atob(ivValue), c=>c.charCodeAt(0));\n        if(iv.length!==12) return {error:\"IV must be 12 bytes in Base64 encoding for AES-GCM.\"};\n      } catch(e){\n        return {error:\"Invalid IV Base64 string.\"};\n      }\n\n      const decrypted = await crypto.subtle.decrypt(\n        {\n          name:\"AES-GCM\",\n          iv: iv\n        },\n        derivedKey,\n        ctArray\n      );\n\n      const dec = new TextDecoder();\n      return {plaintext: dec.decode(decrypted)};\n    } catch(e){\n      return {error:e.toString()};\n    }\n  }\n\n  // Analysis - character frequencies and letter distributions\n  function analyzeText(text){\n    const frequencies = {};\n    for(let i=0; i<text.length; i++){\n      let c = text.charAt(i);\n      frequencies[c] = (frequencies[c]||0) + 1;\n    }\n    const entries = Object.entries(frequencies).sort((a,b) => b[1]-a[1]);\n    const length = text.length;\n    let analysis = `Total characters: ${length}\\n\\nFrequency count:\\n`;\n    entries.forEach(([char, count])=>{\n      let displayChar = char===' ' ? '[space]' : char==='\\n' ? '[newline]' : char;\n      analysis += `${displayChar}: ${count} (${((count/length)*100).toFixed(2)}%)\\n`;\n    });\n    return analysis;\n  }\n\n\n  // DOM Elements\n  const algSelect = document.getElementById(\"algorithm\");\n  const paramGroups = {\n    caesar: document.getElementById(\"param-caesar\"),\n    vigenere: document.getElementById(\"param-vigenere\"),\n    xor: document.getElementById(\"param-xor\"),\n    base64: document.getElementById(\"param-base64\"),\n    aes: document.getElementById(\"param-aes\")\n  };\n\n  function updateParamVisibility(){\n    const val = algSelect.value;\n    Object.keys(paramGroups).forEach(k => {\n      paramGroups[k].style.display = (k===val) ? \"block\" : \"none\";\n    });\n  }\n\n  algSelect.addEventListener(\"change\", updateParamVisibility);\n  updateParamVisibility();\n\n  const plaintextEl = document.getElementById(\"plaintext\");\n  const ciphertextEl = document.getElementById(\"ciphertext\");\n  const outputEl = document.getElementById(\"output-text\");\n\n  const encryptBtn = document.getElementById(\"encrypt-btn\");\n  const decryptBtn = document.getElementById(\"decrypt-btn\");\n  const clearBtn = document.getElementById(\"clear-btn\");\n\n  encryptBtn.addEventListener(\"click\",async function(){\n    outputEl.value = \"\";\n    const alg = algSelect.value;\n    const plain = plaintextEl.value;\n\n    if(plain.length===0){\n      outputEl.value = \"Please enter plaintext to encrypt.\";\n      return;\n    }\n\n    switch(alg){\n      case \"caesar\":\n        var shift = parseInt(document.getElementById(\"caesar-shift\").value);\n        if(isNaN(shift)){\n          outputEl.value = \"Shift must be an integer.\";\n          return;\n        }\n        outputEl.value = caesarEncrypt(plain, shift);\n        break;\n\n      case \"vigenere\":\n        var key = document.getElementById(\"vigenere-key\").value;\n        if(!/^[a-zA-Z]+$/.test(key)){\n          outputEl.value = \"Vigenère key must contain letters only.\";\n          return;\n        }\n        outputEl.value = vigenereEncrypt(plain, key);\n        break;\n\n      case \"xor\":\n        var key = document.getElementById(\"xor-key\").value;\n        if(key.length===0){\n          outputEl.value = \"XOR key must not be empty.\";\n          return;\n        }\n        // Result might be unprintable chars, convert to hex for display\n        let encXor = xorCipher(plain, key);\n        outputEl.value = hexEncode(encXor);\n        break;\n\n      case \"base64\":\n        outputEl.value = base64Encode(plain);\n        break;\n\n      case \"aes\":\n        var password = document.getElementById(\"aes-password\").value;\n        if(password.length === 0){\n          outputEl.value = \"Password required for AES.\";\n          return;\n        }\n        outputEl.value = \"Encrypting...\";\n        let encResult = await aesEncrypt(plain, password);\n        if(encResult.error){\n          outputEl.value = \"Error: \" + encResult.error;\n        } else {\n          outputEl.value = encResult.ciphertext;\n          // The IV field is updated by the aesEncrypt function too\n        }\n        break;\n\n      default:\n        outputEl.value = \"Unknown algorithm.\";\n    }\n  });\n\n\n  decryptBtn.addEventListener(\"click\", async function(){\n    outputEl.value = \"\";\n    const alg = algSelect.value;\n    const cipher = ciphertextEl.value;\n\n    if(cipher.length===0){\n      outputEl.value = \"Please enter ciphertext to decrypt.\";\n      return;\n    }\n\n    switch(alg){\n      case \"caesar\":\n        var shift = parseInt(document.getElementById(\"caesar-shift\").value);\n        if(isNaN(shift)){\n          outputEl.value = \"Shift must be an integer.\";\n          return;\n        }\n        outputEl.value = caesarDecrypt(cipher, shift);\n        break;\n\n      case \"vigenere\":\n        var key = document.getElementById(\"vigenere-key\").value;\n        if(!/^[a-zA-Z]+$/.test(key)){\n          outputEl.value = \"Vigenère key must contain letters only.\";\n          return;\n        }\n        outputEl.value = vigenereDecrypt(cipher, key);\n        break;\n\n      case \"xor\":\n        var key = document.getElementById(\"xor-key\").value;\n        if(key.length===0){\n          outputEl.value = \"XOR key must not be empty.\";\n          return;\n        }\n        // Input is hex encoded - must decode and then XOR decrypt\n        let decoded = hexDecode(cipher);\n        if(decoded.startsWith(\"Invalid hex\")){\n          outputEl.value = decoded;\n          return;\n        }\n        outputEl.value = xorCipher(decoded, key);\n        break;\n\n      case \"base64\":\n        outputEl.value = base64Decode(cipher);\n        break;\n\n      case \"aes\":\n        var password = document.getElementById(\"aes-password\").value;\n        if(password.length === 0){\n          outputEl.value = \"Password required for AES.\";\n          return;\n        }\n        let ivValue = document.getElementById(\"aes-iv\").value.trim();\n        if(ivValue.length===0){\n          outputEl.value = \"IV is required for AES decryption.\";\n          return;\n        }\n        outputEl.value = \"Decrypting...\";\n        let decResult = await aesDecrypt(cipher, password, ivValue);\n        if(decResult.error){\n          outputEl.value = \"Error: \" + decResult.error;\n        } else {\n          outputEl.value = decResult.plaintext;\n        }\n        break;\n\n      default:\n        outputEl.value = \"Unknown algorithm.\";\n    }\n  });\n\n  clearBtn.addEventListener(\"click\", function(){\n    plaintextEl.value = \"\";\n    ciphertextEl.value = \"\";\n    outputEl.value = \"\";\n    document.getElementById(\"caesar-shift\").value = 3;\n    document.getElementById(\"vigenere-key\").value = \"KEY\";\n    document.getElementById(\"xor-key\").value = \"secret\";\n    document.getElementById(\"aes-password\").value = \"\";\n    document.getElementById(\"aes-iv\").value = \"\";\n    document.getElementById(\"hex-input\").value = \"\";\n    document.getElementById(\"hex-output\").value = \"\";\n    document.getElementById(\"analysis-output\").textContent = \"\";\n  });\n\n  // Exploration buttons\n  document.getElementById(\"copy-output\").addEventListener(\"click\", function(){\n    if(outputEl.value.length===0) return;\n    navigator.clipboard.writeText(outputEl.value).catch(() => alert(\"Clipboard write failed\"));\n  });\n\n  document.getElementById(\"swap-texts\").addEventListener(\"click\", function(){\n    const tmp = plaintextEl.value;\n    plaintextEl.value = ciphertextEl.value;\n    ciphertextEl.value = tmp;\n  });\n\n  document.getElementById(\"auto-decode-base64\").addEventListener(\"click\", function(){\n    let input = plaintextEl.value.trim();\n    try {\n      let decoded = base64Decode(input);\n      plaintextEl.value = decoded;\n    } catch {\n      alert(\"Input is not valid Base64 or decoding failed.\");\n    }\n  });\n\n  document.getElementById(\"auto-decode-hex\").addEventListener(\"click\", function(){\n    let input = plaintextEl.value.trim();\n    let decoded = hexDecode(input);\n    if(decoded.startsWith(\"Invalid hex\")){\n      alert(\"Invalid hex input\");\n    } else {\n      plaintextEl.value = decoded;\n    }\n  });\n\n  // Hex encode/decode buttons\n  const hexInput = document.getElementById(\"hex-input\");\n  const hexOutput = document.getElementById(\"hex-output\");\n\n  document.getElementById(\"hex-encode-btn\").addEventListener(\"click\", function(){\n    let t = hexInput.value;\n    if(t.length===0){\n      hexOutput.value = \"\";\n      return;\n    }\n    hexOutput.value = hexEncode(t);\n  });\n\n  document.getElementById(\"hex-decode-btn\").addEventListener(\"click\", function(){\n    let t = hexInput.value.trim();\n    if(t.length===0){\n      hexOutput.value = \"\";\n      return;\n    }\n    hexOutput.value = hexDecode(t);\n  });\n\n  // Analyze text buttons\n  const analysisOutput = document.getElementById(\"analysis-output\");\n\n  document.getElementById(\"analyze-plaintext\").addEventListener(\"click\", function(){\n    let text = plaintextEl.value;\n    analysisOutput.textContent = analyzeText(text);\n  });\n\n  document.getElementById(\"analyze-ciphertext\").addEventListener(\"click\", function(){\n    let text = ciphertextEl.value;\n    analysisOutput.textContent = analyzeText(text);\n  });\n\n})();\n</script>\n\n</body>\n</html>"
  },
