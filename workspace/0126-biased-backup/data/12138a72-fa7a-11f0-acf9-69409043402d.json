  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Graph (Undirected) Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 10px;\n    user-select: none;\n  }\n  #canvas {\n    border: 1px solid black;\n    touch-action: none;\n    display: block;\n    margin-bottom: 10px;\n  }\n  input[type=\"number\"] {\n    width: 4em;\n  }\n  label {\n    display: inline-block;\n    min-width: 130px;\n  }\n  button {\n    min-width: 70px;\n  }\n  #messages {\n    white-space: pre-wrap;\n    font-size: 0.85em;\n    min-height: 5em;\n    border: 1px solid black;\n    margin-top: 10px;\n    padding: 4px;\n    overflow-y: auto;\n  }\n  .section {\n    margin-bottom: 15px;\n  }\n  fieldset {\n    margin-bottom: 15px;\n  }\n</style>\n</head>\n<body>\n<h1>Graph (Undirected) Interactive Demo</h1>\n\n<canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n\n<div class=\"section\">\n  <fieldset>\n    <legend>Node Controls</legend>\n    <label for=\"nodeNameInput\">Node Name:</label>\n    <input id=\"nodeNameInput\" type=\"text\" maxlength=\"10\" placeholder=\"e.g. A\" />\n    <button id=\"addNodeBtn\">Add Node</button>\n    <button id=\"deleteNodeBtn\" disabled>Delete Node</button>\n    <button id=\"moveNodeModeBtn\">Move Node Mode: OFF</button>\n  </fieldset>\n</div>\n\n<div class=\"section\">\n  <fieldset>\n    <legend>Edge Controls</legend>\n    <label for=\"edgeNode1Input\">Node 1:</label>\n    <input id=\"edgeNode1Input\" type=\"text\" maxlength=\"10\" placeholder=\"e.g. A\" />\n    <label for=\"edgeNode2Input\">Node 2:</label>\n    <input id=\"edgeNode2Input\" type=\"text\" maxlength=\"10\" placeholder=\"e.g. B\" />\n    <button id=\"addEdgeBtn\">Add Edge</button>\n    <button id=\"deleteEdgeBtn\" disabled>Delete Edge</button>\n  </fieldset>\n</div>\n\n<div class=\"section\">\n  <fieldset>\n    <legend>Graph Exploration & Algorithms</legend>\n    <label for=\"startNodeInput\">Start Node:</label>\n    <input id=\"startNodeInput\" type=\"text\" maxlength=\"10\" placeholder=\"e.g. A\" />\n    <button id=\"bfsBtn\">BFS Traversal</button>\n    <button id=\"dfsBtn\">DFS Traversal</button>\n    <button id=\"clearHighlightsBtn\">Clear Highlights</button>\n  </fieldset>\n</div>\n\n<div class=\"section\">\n  <fieldset>\n    <legend>Graph Properties</legend>\n    <button id=\"checkConnectedBtn\">Check Connected</button>\n    <button id=\"checkCycleBtn\">Check Cycle</button>\n    <button id=\"clearGraphBtn\">Clear Graph</button>\n  </fieldset>\n  <div id=\"resultOutput\" aria-live=\"polite\" style=\"margin-top:5px;min-height:3em;\"></div>\n</div>\n\n<div class=\"section\">\n  <fieldset>\n    <legend>Instructions & Tips</legend>\n    <ul>\n      <li>Click on canvas background to add nodes (same as Add Node button).</li>\n      <li>Node names must be unique, max 10 chars, case sensitive.</li>\n      <li>To move nodes, toggle \"Move Node Mode\" and drag nodes on canvas.</li>\n      <li>Select a node by clicking it to delete it or use in edges.</li>\n      <li>Edges are undirected and defined by two existing nodes.</li>\n      <li>Highlighted nodes/edges indicate traversal path or cycle detection.</li>\n    </ul>\n  </fieldset>\n</div>\n\n<div id=\"messages\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<script>\n(() => {\n  \"use strict\";\n\n  // Data structures\n  let nodes = {}; // key: name string, value: {x: number, y: number, name: string}\n  let edges = []; // each edge: {n1: string, n2: string, id: string}\n  // For convenience, edge id = n1<n2 sorted joined by '--'\n\n  const canvas = document.getElementById(\"canvas\");\n  const ctx = canvas.getContext(\"2d\");\n\n  // UI Elements\n  const nodeNameInput = document.getElementById(\"nodeNameInput\");\n  const addNodeBtn = document.getElementById(\"addNodeBtn\");\n  const deleteNodeBtn = document.getElementById(\"deleteNodeBtn\");\n  const moveNodeModeBtn = document.getElementById(\"moveNodeModeBtn\");\n\n  const edgeNode1Input = document.getElementById(\"edgeNode1Input\");\n  const edgeNode2Input = document.getElementById(\"edgeNode2Input\");\n  const addEdgeBtn = document.getElementById(\"addEdgeBtn\");\n  const deleteEdgeBtn = document.getElementById(\"deleteEdgeBtn\");\n\n  const startNodeInput = document.getElementById(\"startNodeInput\");\n  const bfsBtn = document.getElementById(\"bfsBtn\");\n  const dfsBtn = document.getElementById(\"dfsBtn\");\n  const clearHighlightsBtn = document.getElementById(\"clearHighlightsBtn\");\n\n  const checkConnectedBtn = document.getElementById(\"checkConnectedBtn\");\n  const checkCycleBtn = document.getElementById(\"checkCycleBtn\");\n  const clearGraphBtn = document.getElementById(\"clearGraphBtn\");\n  const resultOutput = document.getElementById(\"resultOutput\");\n\n  const messages = document.getElementById(\"messages\");\n\n  // State\n  let selectedNodeName = null;\n  let selectedEdgeId = null;\n  let moveNodeMode = false;\n  let draggingNode = null;\n  let dragOffset = {x: 0, y:0};\n\n  // Highlight info: node and edge sets\n  let highlightNodes = new Set();\n  let highlightEdges = new Set();\n\n  // Constants for drawing\n  const NODE_RADIUS = 15;\n  const FONT_SIZE = 12;\n\n  // Utility functions\n  function logMessage(msg) {\n    messages.textContent = msg;\n  }\n\n  function edgeId(n1, n2) {\n    return [n1,n2].sort().join(\"--\");\n  }\n\n  function addNode(name, x, y) {\n    if (!name || typeof name !== 'string') return false;\n    if (name in nodes) return false;\n    nodes[name] = {x, y, name};\n    return true;\n  }\n\n  function deleteNode(name) {\n    if (!(name in nodes)) return false;\n    delete nodes[name];\n    // remove all edges connected to this node\n    edges = edges.filter(e => e.n1 !== name && e.n2 !== name);\n    if (selectedNodeName === name) selectedNodeName = null;\n    return true;\n  }\n\n  function addEdge(n1, n2) {\n    if (!(n1 in nodes) || !(n2 in nodes)) return false;\n    if (n1 === n2) return false;\n    let id = edgeId(n1,n2);\n    if (edges.some(e => e.id === id)) return false;\n    edges.push({n1, n2, id});\n    return true;\n  }\n\n  function deleteEdge(id) {\n    let idx = edges.findIndex(e => e.id === id);\n    if (idx === -1) return false;\n    edges.splice(idx, 1);\n    if (selectedEdgeId === id) selectedEdgeId = null;\n    return true;\n  }\n\n  // redraw the whole canvas\n  function drawGraph() {\n    ctx.clearRect(0,0,canvas.width,canvas.height);\n    ctx.lineWidth = 1;\n    ctx.textAlign = \"center\";\n    ctx.textBaseline = \"middle\";\n    ctx.font = FONT_SIZE + \"px monospace\";\n\n    // Draw edges\n    for (let e of edges) {\n      const {n1, n2, id} = e;\n      const pt1 = nodes[n1];\n      const pt2 = nodes[n2];\n      if (!pt1 || !pt2) continue;\n      ctx.beginPath();\n      ctx.moveTo(pt1.x, pt1.y);\n      ctx.lineTo(pt2.x, pt2.y);\n      ctx.strokeStyle = highlightEdges.has(id) ? \"black\" : \"black\";\n      ctx.lineWidth = highlightEdges.has(id) ? 3 : 1;\n      ctx.stroke();\n    }\n\n    // Draw nodes\n    for (let name in nodes) {\n      const node = nodes[name];\n      ctx.beginPath();\n      ctx.arc(node.x, node.y, NODE_RADIUS, 0, Math.PI*2);\n      if (highlightNodes.has(name)) {\n        ctx.lineWidth = 3;\n      } else {\n        ctx.lineWidth = 1;\n      }\n      if (name === selectedNodeName) {\n        // thicker stroke for selected node\n        ctx.lineWidth = Math.max(ctx.lineWidth, 3);\n        ctx.stroke();\n      } else {\n        ctx.stroke();\n      }\n      ctx.fillStyle = \"white\";\n      ctx.fill();\n      ctx.fillStyle = \"black\";\n      ctx.fillText(name, node.x, node.y);\n    }\n  }\n\n  // Given pixel coordinates, find node name if inside a node circle\n  function getNodeAt(x,y) {\n    for (let name in nodes) {\n      const node = nodes[name];\n      let dx = x - node.x;\n      let dy = y - node.y;\n      if (dx*dx + dy*dy <= NODE_RADIUS*NODE_RADIUS) {\n        return name;\n      }\n    }\n    return null;\n  }\n\n  // Given pixel coordinates, find edge id if near an edge line (within 8px)\n  function getEdgeAt(x,y) {\n    for (let e of edges) {\n      const pt1 = nodes[e.n1];\n      const pt2 = nodes[e.n2];\n      if (!pt1 || !pt2) continue;\n      // Compute distance from point (x,y) to segment pt1-pt2\n      let dist = pointLineDistance(x, y, pt1.x, pt1.y, pt2.x, pt2.y);\n      if (dist <= 8) return e.id;\n    }\n    return null;\n  }\n\n  // Compute point-line segment distance helper\n  // (px, py) point, (x1,y1),(x2,y2) segment endpoints\n  function pointLineDistance(px, py, x1, y1, x2, y2) {\n    let A = px - x1;\n    let B = py - y1;\n    let C = x2 - x1;\n    let D = y2 - y1;\n\n    let dot = A*C + B*D;\n    let len_sq = C*C + D*D;\n    let param = -1;\n    if (len_sq !== 0) param = dot / len_sq;\n\n    let xx, yy;\n\n    if (param < 0) {\n      xx = x1;\n      yy = y1;\n    } else if (param > 1) {\n      xx = x2;\n      yy = y2;\n    } else {\n      xx = x1 + param * C;\n      yy = y1 + param * D;\n    }\n\n    let dx = px - xx;\n    let dy = py - yy;\n    return Math.sqrt(dx*dx + dy*dy);\n  }\n\n  // UI event handlers\n\n  // Canvas click handler:\n  // If Move Node Mode ON and dragging: do nothing on click\n  // Else if click on node: select node and enable delete node button\n  // Else if click on edge: select edge and enable delete edge button\n  // Else (background): add node with input name if possible or prompt user\n  canvas.addEventListener(\"mousedown\", (e) => {\n    const rect = canvas.getBoundingClientRect();\n    const cx = e.clientX - rect.left;\n    const cy = e.clientY - rect.top;\n\n    if (moveNodeMode) {\n      let nodeName = getNodeAt(cx, cy);\n      if (nodeName) {\n        draggingNode = nodeName;\n        dragOffset.x = cx - nodes[nodeName].x;\n        dragOffset.y = cy - nodes[nodeName].y;\n        e.preventDefault();\n      }\n      return;\n    }\n\n    // Not move mode: selection or add node on background\n    let nodeName = getNodeAt(cx, cy);\n    if (nodeName) {\n      selectNode(nodeName);\n      selectEdge(null);\n      e.preventDefault();\n      return;\n    }\n\n    let edgeIdFound = getEdgeAt(cx, cy);\n    if (edgeIdFound) {\n      selectEdge(edgeIdFound);\n      selectNode(null);\n      e.preventDefault();\n      return;\n    }\n\n    // Clicked empty space: add node with default name or user input \n    let proposedName = nodeNameInput.value.trim();\n    if (!proposedName) {\n      proposedName = generateNextNodeName();\n    }\n    if (nodes[proposedName]) {\n      logMessage(\"Node name '\" + proposedName + \"' already exists. Enter unique name.\");\n      return;\n    }\n\n    if (!addNode(proposedName, cx, cy)) {\n      logMessage(\"Failed to add node. Name must be unique and non-empty.\");\n      return;\n    }\n    logMessage(\"Node '\" + proposedName + \"' added at (\"+Math.round(cx)+\", \"+Math.round(cy)+\")\");\n    nodeNameInput.value = \"\";\n    selectNode(proposedName);\n    selectEdge(null);\n    drawGraph();\n  });\n\n  canvas.addEventListener(\"mousemove\", (e) => {\n    if (moveNodeMode && draggingNode) {\n      const rect = canvas.getBoundingClientRect();\n      const cx = e.clientX - rect.left;\n      const cy = e.clientY - rect.top;\n      let nx = cx - dragOffset.x;\n      let ny = cy - dragOffset.y;\n      // constrain within canvas\n      nx = Math.min(Math.max(NODE_RADIUS, nx), canvas.width - NODE_RADIUS);\n      ny = Math.min(Math.max(NODE_RADIUS, ny), canvas.height - NODE_RADIUS);\n      nodes[draggingNode].x = nx;\n      nodes[draggingNode].y = ny;\n      drawGraph();\n      e.preventDefault();\n    }\n  });\n\n  canvas.addEventListener(\"mouseup\", (e) => {\n    if (moveNodeMode && draggingNode) {\n      draggingNode = null;\n      e.preventDefault();\n    }\n  });\n\n  addNodeBtn.addEventListener(\"click\", () => {\n    let name = nodeNameInput.value.trim();\n    if (!name) {\n      logMessage(\"Enter a unique node name in the input.\");\n      return;\n    }\n    if (nodes[name]) {\n      logMessage(\"Node '\" + name + \"' already exists. Choose another name.\");\n      return;\n    }\n    // Add in center-ish by default\n    let x = canvas.width / 2 + (Math.random()*80 - 40);\n    let y = canvas.height / 2 + (Math.random()*80 - 40);\n    addNode(name, x, y);\n    logMessage(\"Node '\"+name+\"' added.\");\n    selectNode(name);\n    drawGraph();\n    nodeNameInput.value = \"\";\n  });\n\n  deleteNodeBtn.addEventListener(\"click\", () => {\n    if (!selectedNodeName) {\n      logMessage(\"No node selected.\");\n      return;\n    }\n    deleteNode(selectedNodeName);\n    logMessage(\"Node '\"+selectedNodeName+\"' deleted.\");\n    selectedNodeName = null;\n    deleteNodeBtn.disabled = true;\n    drawGraph();\n  });\n\n  addEdgeBtn.addEventListener(\"click\", () => {\n    let n1 = edgeNode1Input.value.trim();\n    let n2 = edgeNode2Input.value.trim();\n    if (!n1 || !n2) {\n      logMessage(\"Enter names of two nodes for the edge.\");\n      return;\n    }\n    if (!(n1 in nodes)) {\n      logMessage(\"Node '\"+n1+\"' does not exist.\");\n      return;\n    }\n    if (!(n2 in nodes)) {\n      logMessage(\"Node '\"+n2+\"' does not exist.\");\n      return;\n    }\n    if (n1 === n2) {\n      logMessage(\"Cannot add edge between the same node.\");\n      return;\n    }\n    if (edges.some(e => e.id === edgeId(n1,n2))) {\n      logMessage(\"Edge between '\"+n1+\"' and '\"+n2+\"' already exists.\");\n      return;\n    }\n    if (addEdge(n1, n2)) {\n      logMessage(\"Edge added between '\"+n1+\"' and '\"+n2+\"'.\");\n      drawGraph();\n      selectEdge(edgeId(n1,n2));\n      selectNode(null);\n    } else {\n      logMessage(\"Failed to add edge.\");\n    }\n  });\n\n  deleteEdgeBtn.addEventListener(\"click\", () => {\n    if (!selectedEdgeId) {\n      logMessage(\"No edge selected.\");\n      return;\n    }\n    if (deleteEdge(selectedEdgeId)) {\n      logMessage(\"Edge '\"+selectedEdgeId+\"' deleted.\");\n      selectedEdgeId = null;\n      deleteEdgeBtn.disabled = true;\n      drawGraph();\n    } else {\n      logMessage(\"Failed to delete edge.\");\n    }\n  });\n\n  moveNodeModeBtn.addEventListener(\"click\", () => {\n    moveNodeMode = !moveNodeMode;\n    moveNodeModeBtn.textContent = \"Move Node Mode: \" + (moveNodeMode ? \"ON\" : \"OFF\");\n    if (moveNodeMode) {\n      // disables selection deletes\n      selectNode(null);\n      selectEdge(null);\n      deleteNodeBtn.disabled = true;\n      deleteEdgeBtn.disabled = true;\n      logMessage(\"Move Node Mode enabled: drag nodes on canvas.\");\n    } else {\n      logMessage(\"Move Node Mode disabled.\");\n    }\n  });\n\n  bfsBtn.addEventListener(\"click\", () => {\n    let start = startNodeInput.value.trim();\n    if (!(start in nodes)) {\n      logMessage(\"Start node '\"+start+\"' does not exist.\");\n      return;\n    }\n    let order = bfsTraversal(start);\n    highlightTraversal(order);\n    logMessage(\"BFS Traversal order: \" + order.join(\" → \"));\n  });\n\n  dfsBtn.addEventListener(\"click\", () => {\n    let start = startNodeInput.value.trim();\n    if (!(start in nodes)) {\n      logMessage(\"Start node '\"+start+\"' does not exist.\");\n      return;\n    }\n    let order = dfsTraversal(start);\n    highlightTraversal(order);\n    logMessage(\"DFS Traversal order: \" + order.join(\" → \"));\n  });\n\n  clearHighlightsBtn.addEventListener(\"click\", () => {\n    highlightNodes.clear();\n    highlightEdges.clear();\n    resultOutput.textContent = \"\";\n    logMessage(\"Highlights cleared.\");\n    drawGraph();\n  });\n\n  checkConnectedBtn.addEventListener(\"click\", () => {\n    if (Object.keys(nodes).length === 0) {\n      resultOutput.textContent = \"Graph is empty.\";\n      logMessage(\"Graph is empty.\");\n      return;\n    }\n    // check connectivity from a random node\n    let start = Object.keys(nodes)[0];\n    let visited = new Set();\n    dfsVisit(start, visited);\n    let connected = (visited.size === Object.keys(nodes).length);\n    resultOutput.textContent = connected ? \"Graph is connected.\" : \"Graph is NOT connected.\";\n    logMessage(resultOutput.textContent);\n    // highlight connected component of start node:\n    highlightNodes.clear();\n    highlightEdges.clear();\n    visited.forEach(n => highlightNodes.add(n));\n    // highlight edges in subgraph induced by visited nodes\n    edges.forEach(e => {\n      if (highlightNodes.has(e.n1) && highlightNodes.has(e.n2)) {\n        highlightEdges.add(e.id);\n      }\n    });\n    drawGraph();\n  });\n\n  checkCycleBtn.addEventListener(\"click\", () => {\n    let cyclePath = detectCycle();\n    if (cyclePath === null) {\n      resultOutput.textContent = \"No cycle detected.\";\n      logMessage(\"No cycle detected.\");\n      highlightNodes.clear();\n      highlightEdges.clear();\n    } else {\n      resultOutput.textContent = \"Cycle detected: \" + cyclePath.join(\" → \") + \" → \" + cyclePath[0];\n      logMessage(resultOutput.textContent);\n      highlightNodes.clear();\n      highlightEdges.clear();\n      cyclePath.forEach(n => highlightNodes.add(n));\n      for(let i=0; i<cyclePath.length; i++) {\n        let n1 = cyclePath[i];\n        let n2 = cyclePath[(i+1)%cyclePath.length];\n        highlightEdges.add(edgeId(n1,n2));\n      }\n    }\n    drawGraph();\n  });\n\n  clearGraphBtn.addEventListener(\"click\", () => {\n    nodes = {};\n    edges = [];\n    selectedNodeName = null;\n    selectedEdgeId = null;\n    highlightNodes.clear();\n    highlightEdges.clear();\n    deleteNodeBtn.disabled = true;\n    deleteEdgeBtn.disabled = true;\n    resultOutput.textContent = \"\";\n    logMessage(\"Graph cleared.\");\n    drawGraph();\n  });\n\n  // Select node routine\n  function selectNode(name) {\n    if (moveNodeMode) return;\n    if (name && !(name in nodes)) {\n      name = null;\n    }\n    selectedNodeName = name;\n    deleteNodeBtn.disabled = !name;\n    if (name) {\n      // fill nodeNameInput with selected node name for convenience\n      nodeNameInput.value = name;\n    }\n    drawGraph();\n  }\n\n  // Select edge routine\n  function selectEdge(id) {\n    if (moveNodeMode) return;\n    if (id && !edges.some(e => e.id === id)) id = null;\n    selectedEdgeId = id;\n    deleteEdgeBtn.disabled = !id;\n    drawGraph();\n  }\n\n  // BFS returns array of nodes visited in order\n  function bfsTraversal(start) {\n    let visited = new Set();\n    let queue = [start];\n    let order = [];\n    visited.add(start);\n    while(queue.length) {\n      let u = queue.shift();\n      order.push(u);\n      let neighbors = getNeighbors(u);\n      for(let v of neighbors) {\n        if(!visited.has(v)) {\n          visited.add(v);\n          queue.push(v);\n        }\n      }\n    }\n    return order;\n  }\n\n  // DFS returns array of nodes visited in order\n  function dfsTraversal(start) {\n    let visited = new Set();\n    let order = [];\n    function dfs(u) {\n      visited.add(u);\n      order.push(u);\n      let neighbors = getNeighbors(u);\n      for(let v of neighbors) {\n        if (!visited.has(v)) dfs(v);\n      }\n    }\n    dfs(start);\n    return order;\n  }\n\n  // Highlight traversal path: nodes and edges\n  function highlightTraversal(order) {\n    highlightNodes.clear();\n    highlightEdges.clear();\n    for(let i=0; i<order.length; i++) {\n      highlightNodes.add(order[i]);\n      if (i > 0) {\n        let eId = edgeId(order[i-1], order[i]);\n        if (edges.some(e => e.id === eId)) highlightEdges.add(eId);\n      }\n    }\n    drawGraph();\n  }\n\n  // Get neighbors of a node\n  function getNeighbors(n) {\n    let neighbors = [];\n    for(let e of edges) {\n      if (e.n1 === n) neighbors.push(e.n2);\n      else if (e.n2 === n) neighbors.push(e.n1);\n    }\n    return neighbors;\n  }\n\n  // DFS visit for connectivity check\n  function dfsVisit(start, visited) {\n    visited.add(start);\n    for(let v of getNeighbors(start)) {\n      if (!visited.has(v)) dfsVisit(v, visited);\n    }\n  }\n\n  // Detect cycle in undirected graph: returns array of nodes forming cycle or null\n  function detectCycle() {\n    let visited = new Set();\n    let parent = {};\n\n    function dfs(u, p) {\n      visited.add(u);\n      for(let v of getNeighbors(u)) {\n        if (v === p) continue;\n        if (!visited.has(v)) {\n          parent[v] = u;\n          let res = dfs(v,u);\n          if (res) return res;\n        } else {\n          // cycle detected, backtrack path\n          let cyclePath = [v,u];\n          let cur = u;\n          while(cur !== v && cur !== undefined) {\n            cur = parent[cur];\n            if (cur !== undefined) cyclePath.push(cur);\n          }\n          cyclePath.reverse();\n          return cyclePath;\n        }\n      }\n      return null;\n    }\n\n    for(let n of Object.keys(nodes)) {\n      if (!visited.has(n)) {\n        parent[n] = null;\n        let c = dfs(n, null);\n        if (c) return c;\n      }\n    }\n    return null;\n  }\n\n  // Generate next node name: A-Z, then AA, AB, ...\n  function generateNextNodeName() {\n    let existing = new Set(Object.keys(nodes));\n    let chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\";\n    // Try single letter\n    for(let i=0; i<chars.length; i++) {\n      if (!existing.has(chars[i])) return chars[i];\n    }\n    // Try two letters\n    for(let i=0; i<chars.length; i++) {\n      for(let j=0; j<chars.length; j++) {\n        let s = chars[i]+chars[j];\n        if (!existing.has(s)) return s;\n      }\n    }\n    return \"N\" + (Object.keys(nodes).length+1);\n  }\n\n  // Keyboard accessibility: Enter in nodeNameInput adds node, Enter in edgeNode inputs adds edge\n  nodeNameInput.addEventListener(\"keydown\", (e) => {\n    if (e.key === \"Enter\") {\n      addNodeBtn.click();\n      e.preventDefault();\n    }\n  });\n  edgeNode1Input.addEventListener(\"keydown\", (e) => {\n    if (e.key === \"Enter\") {\n      addEdgeBtn.click();\n      e.preventDefault();\n    }\n  });\n  edgeNode2Input.addEventListener(\"keydown\", (e) => {\n    if (e.key === \"Enter\") {\n      addEdgeBtn.click();\n      e.preventDefault();\n    }\n  });\n  startNodeInput.addEventListener(\"keydown\", (e) => {\n    if (e.key === \"Enter\") {\n      bfsBtn.click();\n      e.preventDefault();\n    }\n  });\n\n  // Initial draw\n  drawGraph();\n  logMessage(\"Use canvas click or controls to add nodes and edges.\");\n\n})();\n</script>\n\n</body>\n</html>"
  },
