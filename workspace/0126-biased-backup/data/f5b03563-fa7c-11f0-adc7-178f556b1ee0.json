    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Heap (Max) Explanation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .text {\n            font-size: 16px;\n            margin-bottom: 10px;\n        }\n        .button {\n            margin-top: 20px;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <h1>Heap (Max) Explanation</h1>\n    <p id=\"text\"></p>\n    <button id=\"demonstration-button\">Demonstrate Heap (Max) Operation</button>\n\n    <script>\n        const textElement = document.getElementById('text');\n        const demonstrationButton = document.getElementById('demonstration-button');\n\n        // Define the Heap (Max) data structure\n        class Heap {\n            constructor() {\n                this.heap = [];\n            }\n\n            // Insert a new element into the heap\n            insert(element) {\n                this.heap.push(element);\n                this.heapifyUp(this.heap.length - 1);\n            }\n\n            // Remove and return the maximum element from the heap\n            extractMax() {\n                if (this.heap.length === 0) {\n                    return null;\n                }\n                if (this.heap.length === 1) {\n                    return this.heap.pop();\n                }\n                const maxElement = this.heap[0];\n                this.heap[0] = this.heap.pop();\n                this.heapifyDown(0);\n                return maxElement;\n            }\n\n            // Heapify the heap upwards from the given index\n            heapifyUp(index) {\n                if (index === 0) {\n                    return;\n                }\n                const parentIndex = Math.floor((index - 1) / 2);\n                if (this.heap[parentIndex] <= this.heap[index]) {\n                    return;\n                }\n                this.swap(parentIndex, index);\n                this.heapifyUp(parentIndex);\n            }\n\n            // Heapify the heap downwards from the given index\n            heapifyDown(index) {\n                const leftChildIndex = 2 * index + 1;\n                const rightChildIndex = 2 * index + 2;\n                let largestIndex = index;\n                if (leftChildIndex < this.heap.length && this.heap[leftChildIndex] > this.heap[largestIndex]) {\n                    largestIndex = leftChildIndex;\n                }\n                if (rightChildIndex < this.heap.length && this.heap[rightChildIndex] > this.heap[largestIndex]) {\n                    largestIndex = rightChildIndex;\n                }\n                if (largestIndex !== index) {\n                    this.swap(largestIndex, index);\n                    this.heapifyDown(largestIndex);\n                }\n            }\n\n            // Swap two elements in the heap\n            swap(i, j) {\n                const temp = this.heap[i];\n                this.heap[i] = this.heap[j];\n                this.heap[j] = temp;\n            }\n        }\n\n        // Example usage\n        function demonstrateHeapMax() {\n            const heap = new Heap();\n            heap.insert(5);\n            heap.insert(10);\n            heap.insert(3);\n            heap.insert(8);\n            heap.insert(1);\n            console.log(\"Heap (Max) elements:\", heap.heap);\n            const maxElement = heap.extractMax();\n            console.log(\"Extracted maximum element:\", maxElement);\n            console.log(\"Updated heap:\", heap.heap);\n            maxElement = heap.extractMax();\n            console.log(\"Extracted maximum element:\", maxElement);\n            console.log(\"Updated heap:\", heap.heap);\n            maxElement = heap.extractMax();\n            console.log(\"Extracted maximum element:\", maxElement);\n            console.log(\"Updated heap:\", heap.heap);\n        }\n\n        demonstrationButton.addEventListener('click', demonstrateHeapMax);\n    </script>\n</body>\n</html>"
