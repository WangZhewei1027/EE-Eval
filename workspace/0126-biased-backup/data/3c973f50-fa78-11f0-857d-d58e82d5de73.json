    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Linear Search Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600&family=Playfair+Display&family=Poppins:wght@400;600&display=swap');\n\n  /* Root Variables for Colors */\n  :root {\n    --bg-color: #0e141b;\n    --primary-color: #76c7c0;\n    --accent-color: #f8b500;\n    --text-light: #eaeaea;\n    --text-dark: #1f2937;\n    --search-highlight: #f57c00;\n    --found-color: #4caf50;\n    --notfound-color: #e53935;\n    --box-bg: #19232f;\n    --box-border: #2e3a49;\n    --shadow-color: rgba(118, 199, 192, 0.4);\n  }\n\n  /* Reset and Base */\n  * {\n    margin: 0; padding: 0; box-sizing: border-box;\n  }\n\n  body {\n    background: var(--bg-color);\n    color: var(--text-light);\n    font-family: 'Poppins', 'IBM Plex Sans Arabic', sans-serif;\n    overflow-x: hidden;\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 3rem 1.5rem 5rem;\n  }\n\n\n  /* Header */\n  header {\n    text-align: center;\n    margin-bottom: 2rem;\n    user-select: none;\n  }\n\n  header h1 {\n    font-family: 'Playfair Display', serif;\n    font-size: 3rem;\n    color: var(--primary-color);\n    letter-spacing: 0.04em;\n    text-shadow: 0 3px 10px rgba(118,199,192,0.35);\n  }\n\n  header p {\n    font-weight: 600;\n    font-size: 1.2rem;\n    color: #a0b9bd;\n    margin-top: 0.6rem;\n    font-style: italic;\n  }\n\n\n  /* The array container */\n  #array-container {\n    margin-top: 1.5rem;\n    display: flex;\n    gap: 1.2rem;\n    justify-content: center;\n    flex-wrap: wrap;\n    max-width: 860px;\n  }\n\n  /* Each array item — stylized card */\n  .array-item {\n    width: 60px;\n    height: 60px;\n    background: var(--box-bg);\n    border-radius: 12px;\n    border: 2.5px solid var(--box-border);\n    box-shadow:\n      0 8px 15px rgba(0,0,0,0.15),\n      inset 0 -2px 8px rgba(255 255 255 / 0.08);\n    color: var(--text-light);\n    font-weight: 600;\n    font-size: 1.6rem;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: relative;\n    user-select: none;\n\n    /* subtle emboss effect */\n    filter: drop-shadow(0 1px 0 rgb(255 255 255 / 0.06));\n    transition:\n      border-color 0.35s ease,\n      box-shadow 0.35s ease,\n      color 0.35s ease,\n      transform 0.35s cubic-bezier(0.4,0,0.2,1);\n  }\n\n  /* Index label below each item */\n  .array-item::after {\n    content: attr(data-index);\n    position: absolute;\n    bottom: -22px;\n    font-size: 0.72rem;\n    color: #658092;\n    font-weight: 400;\n    letter-spacing: 0.05em;\n    font-family: 'IBM Plex Sans Arabic', sans-serif;\n    user-select: none;\n  }\n\n  /* Highlight currently checked */\n  .current {\n    border-color: var(--accent-color);\n    box-shadow:\n      0 0 12px 3px var(--accent-color),\n      0 0 30px 8px var(--accent-color) inset;\n    transform: scale(1.08);\n    font-weight: 700;\n  }\n\n  /* Found item highlight */\n  .found {\n    border-color: var(--found-color);\n    box-shadow:\n      0 0 18px 5px var(--found-color),\n      inset 0 0 16px var(--found-color);\n    color: var(--found-color);\n    transform: scale(1.2);\n    font-weight: 700;\n  }\n\n  /* Not found highlight */\n  .notfound {\n    border-color: var(--notfound-color);\n    color: var(--notfound-color);\n    font-weight: 700;\n    transform: scale(1.05);\n  }\n\n\n  /* Search Controls */\n  #controls {\n    margin-top: 3.5rem;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 1.2rem;\n    justify-content: center;\n    max-width: 600px;\n  }\n\n  .btn {\n    appearance: none;\n    background: var(--primary-color);\n    color: var(--text-dark);\n    border: none;\n    border-radius: 28px;\n    padding: 0.7rem 1.8rem;\n    font-weight: 700;\n    font-size: 1.08rem;\n    cursor: pointer;\n    box-shadow:\n      0 5px 12px rgb(118 199 192 / 0.6);\n    transition: \n      background-color 0.35s ease,\n      box-shadow 0.3s ease,\n      transform 0.25s cubic-bezier(0.4,0,0.2,1);\n  }\n\n  .btn:hover {\n    background: #4ca9a3;\n    box-shadow: 0 10px 28px rgb(76 169 163 / 0.75);\n    transform: translateY(-3px);\n  }\n\n  .btn:active {\n    transform: scale(0.95);\n    box-shadow: 0 4px 8px rgb(76 169 163 / 0.6);\n  }\n\n\n  /* Input field style */\n  input[type=\"number\"] {\n    border-radius: 28px;\n    border: 2.5px solid var(--box-border);\n    background: var(--box-bg);\n    color: var(--text-light);\n    font-weight: 600;\n    font-size: 1.1rem;\n    padding: 0.7rem 1.6rem;\n    width: 140px;\n    text-align: center;\n    box-shadow:\n      0 8px 12px rgba(0,0,0,0.2),\n      inset 0 -3px 8px rgba(255 255 255 / 0.06);\n    transition:\n      border-color 0.3s ease,\n      box-shadow 0.3s ease;\n  }\n\n  input[type=\"number\"]::placeholder {\n    color: #55717a;\n  }\n\n  input[type=\"number\"]:focus {\n    outline: none;\n    border-color: var(--accent-color);\n    box-shadow: 0 0 12px 1px var(--accent-color), inset 0 0 15px var(--accent-color);\n    color: var(--text-light);\n  }\n\n\n  /* Explanation text area */\n  #explanation {\n    margin-top: 4rem;\n    font-weight: 600;\n    max-width: 730px;\n    text-align: center;\n    line-height: 1.5;\n    font-size: 1.1rem;\n    color: #98b4bb;\n    font-style: italic;\n    user-select: none;\n    min-height: 3.8rem;\n  }\n\n  /* Footer - subtle */\n  footer {\n    margin-top: 6rem;\n    font-size: 0.9rem;\n    color: #3a4b56;\n    font-weight: 400;\n    font-family: 'IBM Plex Sans Arabic', sans-serif;\n    user-select: none;\n  }\n\n\n  /* Loading shimmer pattern on current */\n  .current::before {\n    content: '';\n    position: absolute;\n    left: -60%;\n    top: 0;\n    width: 70%;\n    height: 100%;\n    background: linear-gradient(120deg, transparent 0%, rgba(255 255 255 / 0.15) 50%, transparent 100%);\n    animation: shimmer 1.8s ease-in-out infinite;\n    border-radius: 12px;\n    pointer-events: none;\n    z-index: 1;\n  }\n  @keyframes shimmer {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(300%); }\n  }\n\n\n  /* Responsive */\n  @media (max-width: 640px){\n    .array-item {\n      width: 48px;\n      height: 48px;\n      font-size: 1.3rem;\n    }\n    .array-item::after {\n      bottom: -18px;\n      font-size: 0.58rem;\n    }\n    #controls {\n      gap: 1rem;\n    }\n    input[type=\"number\"] {\n      width: 110px;\n      font-size: 1rem;\n    }\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Linear Search</h1>\n  <p>An Elegant Step-by-Step Visualization</p>\n</header>\n\n<main>\n  <div id=\"array-container\" aria-label=\"Array visualization\" role=\"list\"></div>\n\n  <div id=\"controls\" aria-label=\"Search controls\">\n    <input type=\"number\" min=\"0\" max=\"99\" id=\"search-input\" placeholder=\"Enter target\" aria-label=\"Target value for Linear Search\" />\n    <button id=\"start-btn\" class=\"btn\" aria-live=\"polite\" aria-label=\"Start linear search animation\">Start Search</button>\n  </div>\n\n  <p id=\"explanation\" aria-live=\"polite\"></p>\n</main>\n\n<footer>\n  &copy; 2024 &bull; Designed with care by AI\n</footer>\n\n<script>\n  (() => {\n    const arrayContainer = document.getElementById('array-container');\n    const explanation = document.getElementById('explanation');\n    const startBtn = document.getElementById('start-btn');\n    const searchInput = document.getElementById('search-input');\n\n    // Example array - artificial but visually balanced\n    const arr = [15, 3, 27, 8, 34, 23, 42, 10, 5, 7, 18, 30, 28, 46, 4];\n\n    // Clear previous\n    function clearArrayItems(){\n      arrayContainer.innerHTML = '';\n    }\n\n    // Build array blocks\n    function buildArray(){\n      clearArrayItems();\n      arr.forEach((num, idx) => {\n        const div = document.createElement('div');\n        div.classList.add('array-item');\n        div.setAttribute('role', 'listitem');\n        div.setAttribute('data-index', idx);\n        div.textContent = num;\n        arrayContainer.appendChild(div);\n      });\n      explanation.textContent = 'Enter a target number above and press \"Start Search\" to see linear search in action.';\n    }\n\n    // Animation & Search Logic\n    async function linearSearch(target) {\n      const items = arrayContainer.children;\n      explanation.textContent = `Starting linear search for ${target}...`;\n      startBtn.disabled = true;\n      searchInput.disabled = true;\n      searchInput.setAttribute('aria-disabled', 'true');\n      startBtn.textContent = 'Searching...';\n      const delay = ms => new Promise(res => setTimeout(res, ms));\n\n      // Clear previous states\n      for(let i=0; i < items.length; i++){\n        items[i].classList.remove('current','found','notfound');\n      }\n\n      for (let i=0; i < arr.length; i++){\n        items[i].classList.add('current');\n        explanation.textContent = `Checking element at index ${i} (value: ${arr[i]})...`;\n        await delay(1200);\n\n        if(arr[i] === target){\n          items[i].classList.remove('current');\n          items[i].classList.add('found');\n          explanation.textContent = `Found ${target} at index ${i}. Search complete!`;\n          break;\n        } else{\n          items[i].classList.remove('current');\n        }\n      }\n\n      // If not found after full pass\n      if(!Array.from(items).some(el => el.classList.contains('found'))){\n        explanation.textContent = `Target value ${target} not found in the array.`;\n        // Subtly highlight all as not found\n        for(let j=0; j < items.length; j++){\n          items[j].classList.add('notfound');\n        }\n      }\n\n      startBtn.disabled = false;\n      searchInput.disabled = false;\n      searchInput.setAttribute('aria-disabled', 'false');\n      startBtn.textContent = 'Start Search';\n    }\n\n    // Validate and start\n    function startSearch(){\n      let val = parseInt(searchInput.value, 10);\n      if(isNaN(val)){\n        explanation.textContent = 'Please enter a valid number to search for.';\n        return;\n      }\n      if(val < 0 || val > 99){\n        explanation.textContent = 'Please enter a number between 0 and 99.';\n        return;\n      }\n      // Remove previous notfound\n      const items = arrayContainer.children;\n      for(let i=0; i < items.length; i++){\n        items[i].classList.remove('notfound','found','current');\n      }\n      linearSearch(val);\n    }\n\n    // Initialize\n    buildArray();\n\n    // Events\n    startBtn.addEventListener('click', startSearch);\n    searchInput.addEventListener('keydown', e => {\n      if(e.key === 'Enter'){\n        startSearch();\n        e.preventDefault();\n      }\n    });\n  })();\n</script>\n</body>\n</html>"
