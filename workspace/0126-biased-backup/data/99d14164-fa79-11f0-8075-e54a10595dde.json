    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Overfitting Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Overfitting Demonstration</h1>\n    \n    <label for=\"data-points\">Number of Data Points:</label>\n    <input type=\"number\" id=\"data-points\" value=\"10\" min=\"1\" max=\"100\" />\n    <button id=\"generate-data\">Generate Data</button>\n    <button id=\"clear-data\">Clear Data</button>\n\n    <label for=\"model-complexity\">Model Complexity:</label>\n    <input type=\"range\" id=\"model-complexity\" min=\"1\" max=\"10\" value=\"1\" />\n    <span id=\"complexity-value\">1</span>\n\n    <button id=\"train-model\">Train Model</button>\n    <button id=\"show-plot\">Show Plot</button>\n    \n    <h2>Data Visualization</h2>\n    <div id=\"data-visualization\"></div>\n\n    <h2>Model Evaluation</h2>\n    <div id=\"evaluation-result\">Training Result: <span id=\"result\">N/A</span></div>\n\n    <script>\n        let dataPoints = [];\n        let modelComplexity = 1;\n\n        document.getElementById('generate-data').onclick = function() {\n            const numPoints = parseInt(document.getElementById('data-points').value);\n            dataPoints = Array.from({ length: numPoints }, () => Math.random());\n            document.getElementById('result').innerText = 'Data generated. ' + numPoints + ' points created.';\n        };\n\n        document.getElementById('clear-data').onclick = function() {\n            dataPoints = [];\n            document.getElementById('result').innerText = 'Data cleared.';\n        };\n        \n        document.getElementById('model-complexity').oninput = function() {\n            modelComplexity = parseInt(this.value);\n            document.getElementById('complexity-value').innerText = modelComplexity;\n        };\n\n        document.getElementById('train-model').onclick = function() {\n            if (dataPoints.length === 0) {\n                alert('Please generate data points before training the model.');\n                return;\n            }\n            const errorRate = Math.random() / modelComplexity; // Simulate overfitting scenario\n            document.getElementById('result').innerText = `Model trained with complexity ${modelComplexity}. Error rate: ${errorRate.toFixed(4)}`;\n        };\n\n        document.getElementById('show-plot').onclick = function() {\n            let visual = 'Data Visualization:\\n' + dataPoints.map((d, i) => `Point ${i + 1}: ${d.toFixed(2)}`).join('\\n');\n            alert(visual);\n        };\n    </script>\n</body>\n</html>"
