    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interpolation Search Interactive Demo</title>\n    <script>\n        let array = [];\n        let searchValue = 0;\n        let currentStep = 0;\n        let steps = [];\n        let isRunning = false;\n        let speed = 500;\n        let arraySize = 20;\n        let minValue = 0;\n        let maxValue = 100;\n        let isSorted = true;\n\n        function generateArray() {\n            arraySize = parseInt(document.getElementById('arraySize').value);\n            minValue = parseInt(document.getElementById('minValue').value);\n            maxValue = parseInt(document.getElementById('maxValue').value);\n            isSorted = document.getElementById('sortedCheckbox').checked;\n            \n            array = [];\n            for (let i = 0; i < arraySize; i++) {\n                array.push(Math.floor(Math.random() * (maxValue - minValue + 1)) + minValue);\n            }\n            \n            if (isSorted) {\n                array.sort((a, b) => a - b);\n            }\n            \n            resetSearch();\n            updateArrayDisplay();\n        }\n\n        function updateArrayDisplay() {\n            const arrayContainer = document.getElementById('arrayContainer');\n            arrayContainer.innerHTML = '';\n            \n            array.forEach((value, index) => {\n                const element = document.createElement('div');\n                element.className = 'array-element';\n                element.textContent = value;\n                element.id = `element-${index}`;\n                arrayContainer.appendChild(element);\n            });\n        }\n\n        function highlightElements(low, high, pos) {\n            // Reset all highlights\n            document.querySelectorAll('.array-element').forEach(el => {\n                el.style.backgroundColor = '';\n                el.style.fontWeight = '';\n            });\n            \n            // Highlight current range\n            for (let i = low; i <= high; i++) {\n                const element = document.getElementById(`element-${i}`);\n                if (element) element.style.backgroundColor = '#f0f0f0';\n            }\n            \n            // Highlight current position\n            if (pos >= 0 && pos < array.length) {\n                const posElement = document.getElementById(`element-${pos}`);\n                if (posElement) {\n                    posElement.style.backgroundColor = '#d0d0d0';\n                    posElement.style.fontWeight = 'bold';\n                }\n            }\n        }\n\n        function interpolationSearchSteps(arr, x) {\n            let steps = [];\n            let low = 0;\n            let high = arr.length - 1;\n            \n            while (low <= high && x >= arr[low] && x <= arr[high]) {\n                if (low === high) {\n                    steps.push({low, high, pos: low, found: arr[low] === x});\n                    break;\n                }\n                \n                // Calculate position\n                const pos = Math.floor(\n                    low + ((x - arr[low]) * (high - low)) / (arr[high] - arr[low])\n                );\n                \n                steps.push({low, high, pos, found: arr[pos] === x});\n                \n                if (arr[pos] === x) {\n                    break;\n                } else if (arr[pos] < x) {\n                    low = pos + 1;\n                } else {\n                    high = pos - 1;\n                }\n            }\n            \n            return steps;\n        }\n\n        function startSearch() {\n            if (!isSorted) {\n                alert(\"Array must be sorted for interpolation search!\");\n                return;\n            }\n            \n            searchValue = parseInt(document.getElementById('searchValue').value);\n            if (isNaN(searchValue)) {\n                alert(\"Please enter a valid number to search for\");\n                return;\n            }\n            \n            steps = interpolationSearchSteps(array, searchValue);\n            currentStep = 0;\n            isRunning = true;\n            \n            document.getElementById('nextStep').disabled = false;\n            document.getElementById('prevStep').disabled = true;\n            document.getElementById('runSearch').disabled = true;\n            \n            updateStepDisplay();\n        }\n\n        function resetSearch() {\n            currentStep = 0;\n            steps = [];\n            isRunning = false;\n            \n            document.getElementById('nextStep').disabled = true;\n            document.getElementById('prevStep').disabled = true;\n            document.getElementById('runSearch').disabled = false;\n            \n            document.querySelectorAll('.array-element').forEach(el => {\n                el.style.backgroundColor = '';\n                el.style.fontWeight = '';\n            });\n            \n            document.getElementById('stepInfo').textContent = 'Search not started';\n        }\n\n        function nextStep() {\n            if (currentStep < steps.length - 1) {\n                currentStep++;\n                updateStepDisplay();\n                document.getElementById('prevStep').disabled = false;\n                \n                if (currentStep === steps.length - 1) {\n                    document.getElementById('nextStep').disabled = true;\n                }\n            }\n        }\n\n        function prevStep() {\n            if (currentStep > 0) {\n                currentStep--;\n                updateStepDisplay();\n                document.getElementById('nextStep').disabled = false;\n                \n                if (currentStep === 0) {\n                    document.getElementById('prevStep').disabled = true;\n                }\n            }\n        }\n\n        function updateStepDisplay() {\n            if (steps.length === 0 || currentStep >= steps.length) return;\n            \n            const step = steps[currentStep];\n            highlightElements(step.low, step.high, step.pos);\n            \n            let infoText = `Step ${currentStep + 1}/${steps.length}: `;\n            infoText += `Searching between indices ${step.low} (${array[step.low]}) and ${step.high} (${array[step.high]}) `;\n            infoText += `- Position: ${step.pos} (${array[step.pos]}) `;\n            \n            if (step.found) {\n                infoText += `- FOUND at index ${step.pos}`;\n            } else if (array[step.pos] < searchValue) {\n                infoText += `- Value at ${step.pos} (${array[step.pos]}) is LESS than search value`;\n            } else {\n                infoText += `- Value at ${step.pos} (${array[step.pos]}) is GREATER than search value`;\n            }\n            \n            document.getElementById('stepInfo').textContent = infoText;\n        }\n\n        function runSearch() {\n            startSearch();\n            if (!isRunning) return;\n            \n            document.getElementById('nextStep').disabled = true;\n            document.getElementById('prevStep').disabled = true;\n            \n            let interval = setInterval(() => {\n                if (currentStep < steps.length - 1) {\n                    currentStep++;\n                    updateStepDisplay();\n                } else {\n                    clearInterval(interval);\n                    document.getElementById('nextStep').disabled = true;\n                    document.getElementById('prevStep').disabled = false;\n                }\n            }, speed);\n        }\n\n        function updateSpeed() {\n            speed = 1000 - document.getElementById('speedSlider').value;\n        }\n    </script>\n</head>\n<body>\n    <h1>Interpolation Search Interactive Demo</h1>\n    \n    <div>\n        <h2>Array Configuration</h2>\n        <div>\n            <label>Array Size: </label>\n            <input type=\"number\" id=\"arraySize\" min=\"5\" max=\"50\" value=\"20\">\n        </div>\n        <div>\n            <label>Min Value: </label>\n            <input type=\"number\" id=\"minValue\" value=\"0\">\n        </div>\n        <div>\n            <label>Max Value: </label>\n            <input type=\"number\" id=\"maxValue\" value=\"100\">\n        </div>\n        <div>\n            <label>\n                <input type=\"checkbox\" id=\"sortedCheckbox\" checked> Sorted Array\n            </label>\n        </div>\n        <button onclick=\"generateArray()\">Generate New Array</button>\n    </div>\n    \n    <div>\n        <h2>Array Display</h2>\n        <div id=\"arrayContainer\" style=\"display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 20px;\"></div>\n    </div>\n    \n    <div>\n        <h2>Search Controls</h2>\n        <div>\n            <label>Search Value: </label>\n            <input type=\"number\" id=\"searchValue\">\n            <button id=\"runSearch\" onclick=\"startSearch()\">Start Search</button>\n            <button onclick=\"resetSearch()\">Reset</button>\n        </div>\n        <div>\n            <button id=\"prevStep\" onclick=\"prevStep()\" disabled>Previous Step</button>\n            <button id=\"nextStep\" onclick=\"nextStep()\" disabled>Next Step</button>\n            <button onclick=\"runSearch()\">Run Full Search</button>\n        </div>\n        <div>\n            <label>Animation Speed: </label>\n            <input type=\"range\" id=\"speedSlider\" min=\"0\" max=\"900\" value=\"500\" oninput=\"updateSpeed()\">\n        </div>\n    </div>\n    \n    <div>\n        <h2>Search Information</h2>\n        <div id=\"stepInfo\">Search not started</div>\n    </div>\n    \n    <div>\n        <h2>Interpolation Search Explanation</h2>\n        <p>\n            Interpolation search is an improved variant of binary search for uniformly distributed, sorted arrays.\n            Instead of always dividing the search space in half, it estimates the position of the target value\n            using linear interpolation formula:\n        </p>\n        <p>\n            <code>pos = low + ((x - arr[low]) * (high - low)) / (arr[high] - arr[low])</code>\n        </p>\n        <p>\n            This makes it an O(log log n) algorithm in the best case, though it can degrade to O(n) in worst cases.\n        </p>\n    </div>\n    \n    <script>\n        // Initialize on load\n        generateArray();\n    </script>\n</body>\n</html>"
