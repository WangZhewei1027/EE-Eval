    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Radix Sort Visualization</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --light: #f8f9fa;\n            --dark: #2d3436;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1s ease-out;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 700;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n        }\n\n        .container {\n            width: 90%;\n            max-width: 1200px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 2rem;\n        }\n\n        .visualization {\n            width: 100%;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            position: relative;\n            overflow: hidden;\n            animation: slideUp 0.8s ease-out;\n        }\n\n        .visualization::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 10px;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n        }\n\n        .array-container {\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            height: 300px;\n            margin: 2rem 0;\n            position: relative;\n        }\n\n        .array-bar {\n            width: 40px;\n            margin: 0 5px;\n            background: var(--primary);\n            border-radius: 5px 5px 0 0;\n            transition: all 0.3s ease;\n            position: relative;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n        }\n\n        .array-bar::after {\n            content: attr(data-value);\n            position: absolute;\n            bottom: -25px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-weight: bold;\n            color: var(--dark);\n        }\n\n        .buckets-container {\n            display: flex;\n            justify-content: space-between;\n            width: 100%;\n            margin-top: 2rem;\n            gap: 1rem;\n        }\n\n        .bucket {\n            flex: 1;\n            min-height: 200px;\n            background: rgba(255, 255, 255, 0.7);\n            border-radius: 10px;\n            padding: 1rem;\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            transition: all 0.3s ease;\n        }\n\n        .bucket-header {\n            font-weight: bold;\n            margin-bottom: 1rem;\n            color: var(--primary);\n        }\n\n        .bucket-items {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 0.5rem;\n            justify-content: center;\n            align-items: flex-end;\n            flex-grow: 1;\n            width: 100%;\n        }\n\n        .bucket-item {\n            width: 30px;\n            background: var(--secondary);\n            border-radius: 3px 3px 0 0;\n            transition: all 0.3s ease;\n            position: relative;\n        }\n\n        .bucket-item::after {\n            content: attr(data-value);\n            position: absolute;\n            bottom: -20px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 0.8rem;\n            color: var(--dark);\n        }\n\n        .controls {\n            display: flex;\n            gap: 1rem;\n            margin-top: 1rem;\n        }\n\n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            background: var(--primary);\n            color: white;\n            font-weight: bold;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.4);\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.5);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .explanation {\n            width: 100%;\n            background: white;\n            border-radius: 20px;\n            padding: 2rem;\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);\n            margin-top: 2rem;\n            animation: fadeIn 1s ease-out 0.3s both;\n        }\n\n        .explanation h2 {\n            color: var(--primary);\n            margin-bottom: 1rem;\n            font-size: 1.8rem;\n        }\n\n        .explanation p {\n            line-height: 1.6;\n            margin-bottom: 1rem;\n            color: var(--dark);\n            opacity: 0.9;\n        }\n\n        .step-indicator {\n            position: absolute;\n            top: 1rem;\n            right: 1rem;\n            background: var(--accent);\n            color: white;\n            padding: 0.5rem 1rem;\n            border-radius: 50px;\n            font-weight: bold;\n            box-shadow: 0 5px 15px rgba(253, 121, 168, 0.4);\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(50px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        .digit-highlight {\n            position: absolute;\n            top: -25px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-weight: bold;\n            color: var(--accent);\n            font-size: 1.2rem;\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n\n        .active-digit {\n            opacity: 1;\n        }\n\n        .sorted {\n            background: var(--success) !important;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Radix Sort</h1>\n        <p class=\"subtitle\">A beautiful visualization of the digit-by-digit sorting algorithm</p>\n    </header>\n\n    <div class=\"container\">\n        <div class=\"visualization\">\n            <div class=\"step-indicator\">Initial Array</div>\n            <div class=\"array-container\" id=\"array-container\"></div>\n            <div class=\"buckets-container\" id=\"buckets-container\"></div>\n            <div class=\"controls\">\n                <button id=\"start-btn\">Start Sorting</button>\n                <button id=\"reset-btn\">Reset</button>\n            </div>\n        </div>\n\n        <div class=\"explanation\">\n            <h2>About Radix Sort</h2>\n            <p>Radix Sort is a non-comparative sorting algorithm that processes integer numbers by grouping them by individual digits which share the same significant position and value. It sorts numbers digit by digit starting from the least significant digit (rightmost) to the most significant digit (leftmost).</p>\n            <p>The algorithm uses counting sort as a subroutine to sort the digits at each position. This visualization shows how numbers are distributed into buckets based on each digit and then collected back into an array in sorted order.</p>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            const arrayContainer = document.getElementById('array-container');\n            const bucketsContainer = document.getElementById('buckets-container');\n            const startBtn = document.getElementById('start-btn');\n            const resetBtn = document.getElementById('reset-btn');\n\n            let array = generateRandomArray(10, 100, 999);\n            let isSorting = false;\n            let currentDigit = 0;\n            let maxDigits = 3;\n\n            function generateRandomArray(size, min, max) {\n                return Array.from({length: size}, () => \n                    Math.floor(Math.random() * (max - min + 1)) + min\n                );\n            }\n\n            function renderArray(arr, highlightIndices = []) {\n                arrayContainer.innerHTML = '';\n                const maxValue = Math.max(...arr);\n                \n                arr.forEach((num, i) => {\n                    const bar = document.createElement('div');\n                    bar.className = 'array-bar';\n                    if (highlightIndices.includes(i)) {\n                        bar.style.background = 'var(--accent)';\n                    }\n                    bar.style.height = `${(num / maxValue) * 250}px`;\n                    bar.setAttribute('data-value', num);\n                    \n                    const digitLabel = document.createElement('div');\n                    digitLabel.className = 'digit-highlight';\n                    digitLabel.textContent = getDigit(num, currentDigit);\n                    if (highlightIndices.includes(i)) {\n                        digitLabel.classList.add('active-digit');\n                    }\n                    \n                    bar.appendChild(digitLabel);\n                    arrayContainer.appendChild(bar);\n                });\n            }\n\n            function renderBuckets(buckets) {\n                bucketsContainer.innerHTML = '';\n                \n                for (let i = 0; i < 10; i++) {\n                    const bucket = document.createElement('div');\n                    bucket.className = 'bucket';\n                    \n                    const header = document.createElement('div');\n                    header.className = 'bucket-header';\n                    header.textContent = `Digit ${i}`;\n                    bucket.appendChild(header);\n                    \n                    const items = document.createElement('div');\n                    items.className = 'bucket-items';\n                    \n                    if (buckets[i]) {\n                        const maxValue = Math.max(...buckets[i].concat([1]));\n                        buckets[i].forEach(num => {\n                            const item = document.createElement('div');\n                            item.className = 'bucket-item';\n                            item.style.height = `${(num / maxValue) * 150}px`;\n                            item.setAttribute('data-value', num);\n                            items.appendChild(item);\n                        });\n                    }\n                    \n                    bucket.appendChild(items);\n                    bucketsContainer.appendChild(bucket);\n                }\n            }\n\n            function getDigit(num, place) {\n                return Math.floor(Math.abs(num) / Math.pow(10, place)) % 10;\n            }\n\n            function getMaxDigits(nums) {\n                return Math.max(...nums.map(num => num.toString().length));\n            }\n\n            async function radixSort() {\n                if (isSorting) return;\n                isSorting = true;\n                startBtn.disabled = true;\n                \n                maxDigits = getMaxDigits(array);\n                \n                for (currentDigit = 0; currentDigit < maxDigits; currentDigit++) {\n                    document.querySelector('.step-indicator').textContent = \n                        `Sorting by digit ${currentDigit + 1} (${['ones', 'tens', 'hundreds'][currentDigit]} place)`;\n                    \n                    // Create 10 buckets (0-9)\n                    const buckets = Array.from({length: 10}, () => []);\n                    \n                    // Distribute numbers into buckets based on current digit\n                    for (let i = 0; i < array.length; i++) {\n                        const digit = getDigit(array[i], currentDigit);\n                        buckets[digit].push(array[i]);\n                        \n                        renderArray(array, [i]);\n                        renderBuckets(buckets);\n                        await sleep(500);\n                    }\n                    \n                    // Flatten buckets back into array\n                    array = [].concat(...buckets);\n                    \n                    renderArray(array);\n                    renderBuckets(buckets);\n                    await sleep(1000);\n                }\n                \n                // Mark all as sorted\n                document.querySelector('.step-indicator').textContent = 'Sorting Complete';\n                const bars = document.querySelectorAll('.array-bar');\n                bars.forEach(bar => bar.classList.add('sorted'));\n                \n                isSorting = false;\n                startBtn.disabled = false;\n            }\n\n            function reset() {\n                if (isSorting) return;\n                array = generateRandomArray(10, 100, 999);\n                currentDigit = 0;\n                document.querySelector('.step-indicator').textContent = 'Initial Array';\n                renderArray(array);\n                renderBuckets(Array.from({length: 10}, () => []));\n            }\n\n            function sleep(ms) {\n                return new Promise(resolve => setTimeout(resolve, ms));\n            }\n\n            startBtn.addEventListener('click', radixSort);\n            resetBtn.addEventListener('click', reset);\n\n            // Initial render\n            reset();\n        });\n    </script>\n</body>\n</html>"
