  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Transaction Simulator</title>\n<style>\n/* Intentionally minimal: no styling beyond basic layout reset */\n/* Keep interface plain: black text on white background, default fonts */\nbody { margin: 12px; font-family: sans-serif; color: black; background: white; }\nsection { margin-bottom: 18px; padding: 6px; border: 1px solid #00000010; }\nlabel { display: inline-block; margin-right: 6px; }\ninput, select, button, textarea { margin: 2px 6px 6px 0; }\ntextarea { width: 100%; height: 140px; }\npre { white-space: pre-wrap; word-wrap: break-word; }\n</style>\n</head>\n<body>\n<h2>Transaction Simulator (Plain Interface)</h2>\n<p>This simulator demonstrates transaction concepts: begin/commit/rollback, nested transactions, savepoints, isolation levels, locking modes, concurrency scheduling, two-phase commit, crash & recovery, and many interactive controls. The design is intentionally plain.</p>\n\n<section>\n  <h3>Accounts</h3>\n  <div>\n    <label>Account name: <input id=\"acctName\" value=\"A\"/></label>\n    <label>Initial balance: <input id=\"acctBal\" type=\"number\" value=\"100\"/></label>\n    <button id=\"addAcct\">Add Account</button>\n    <button id=\"resetAccounts\">Reset to defaults</button>\n  </div>\n  <div>\n    <label>Select account: \n      <select id=\"acctSelect\"></select>\n    </label>\n    <button id=\"viewAcct\">View details</button>\n    <button id=\"depositDirect\">Deposit (direct commit)</button>\n    <input id=\"depositAmt\" type=\"number\" value=\"10\" style=\"width:80px;\">\n    <button id=\"withdrawDirect\">Withdraw (direct commit)</button>\n    <input id=\"withdrawAmt\" type=\"number\" value=\"5\" style=\"width:80px;\">\n  </div>\n  <div>\n    <strong>Accounts (committed balances):</strong>\n    <pre id=\"accountsView\"></pre>\n  </div>\n</section>\n\n<section>\n  <h3>Transactions</h3>\n  <div>\n    <label>Transaction name: <input id=\"txName\" value=\"T1\"/></label>\n    <label>Isolation:\n      <select id=\"isolationSelect\">\n        <option>READ UNCOMMITTED</option>\n        <option>READ COMMITTED</option>\n        <option>REPEATABLE READ</option>\n        <option>SERIALIZABLE</option>\n      </select>\n    </label>\n    <label>Locking:\n      <select id=\"lockingMode\">\n        <option>OPTIMISTIC</option>\n        <option>PESSIMISTIC</option>\n      </select>\n    </label>\n    <button id=\"beginTx\">Begin Transaction</button>\n    <button id=\"beginNested\">Begin Nested Transaction (child)</button>\n    <label>Parent TX ID: <input id=\"parentTxId\" style=\"width:60px;\"></label>\n  </div>\n\n  <div>\n    <label>Select transaction: <select id=\"txSelect\"></select></label>\n    <button id=\"refreshTx\">Refresh</button>\n    <button id=\"commitTx\">Commit</button>\n    <button id=\"rollbackTx\">Rollback</button>\n    <button id=\"prepareTx\">Prepare (2PC)</button>\n    <button id=\"commitPreparedTx\">Commit Prepared</button>\n    <button id=\"abortPreparedTx\">Abort Prepared</button>\n  </div>\n\n  <div>\n    <h4>Add Operation to Selected Transaction</h4>\n    <label>Type:\n      <select id=\"opType\">\n        <option value=\"transfer\">Transfer</option>\n        <option value=\"deposit\">Deposit</option>\n        <option value=\"withdraw\">Withdraw</option>\n        <option value=\"custom\">Custom Script (JS)</option>\n      </select>\n    </label>\n    <label>From:\n      <select id=\"opFrom\"></select>\n    </label>\n    <label>To:\n      <select id=\"opTo\"></select>\n    </label>\n    <label>Amount: <input id=\"opAmount\" type=\"number\" value=\"10\" style=\"width:80px;\"></label>\n    <button id=\"addOp\">Add Operation (staged)</button>\n    <div>\n      <label>Savepoint name: <input id=\"savepointName\" style=\"width:120px;\"></label>\n      <button id=\"createSavepoint\">Create Savepoint</button>\n      <button id=\"rollbackToSavepoint\">Rollback to Savepoint</button>\n    </div>\n    <div>\n      <label>Custom script (JS):</label><br>\n      <textarea id=\"customScript\" placeholder=\"Example: staged['A'] = (staged['A']||snap['A']) + 50;\"></textarea>\n      <button id=\"addCustomOp\">Add Custom Operation (staged)</button>\n    </div>\n  </div>\n\n  <div>\n    <h4>Transaction Details</h4>\n    <pre id=\"txDetails\"></pre>\n  </div>\n</section>\n\n<section>\n  <h3>Concurrency Scheduler & Execution</h3>\n  <div>\n    <label>Auto-step delay (ms): <input id=\"autoDelay\" type=\"range\" min=\"0\" max=\"2000\" value=\"200\"></label>\n    <span id=\"autoDelayVal\">200</span>\n    <button id=\"stepOnce\">Step Once (execute next op of each selected tx)</button>\n    <button id=\"runAuto\">Run Auto</button>\n    <button id=\"stopAuto\">Stop Auto</button>\n    <label>Pick txs to step (comma list of tx ids): <input id=\"stepList\" placeholder=\"all\"></label>\n  </div>\n  <div>\n    <h4>Locks</h4>\n    <pre id=\"locksView\"></pre>\n  </div>\n</section>\n\n<section>\n  <h3>Two-Phase Commit Simulator</h3>\n  <div>\n    <label>Participant nodes: <input id=\"nodeCount\" type=\"number\" value=\"2\" min=\"1\" style=\"width:60px;\"></label>\n    <button id=\"createNodes\">Create Nodes</button>\n    <label>Distributed TX Name: <input id=\"distTxName\" value=\"DT1\"></label>\n    <button id=\"beginDistributed\">Begin Distributed Transaction</button>\n    <div>\n      <label>Fail participant on prepare (node id): <input id=\"failNodePrepare\" style=\"width:40px\"></label>\n      <label>Fail participant on commit (node id): <input id=\"failNodeCommit\" style=\"width:40px\"></label>\n    </div>\n    <div>\n      <button id=\"prepareDistributed\">Prepare Distributed TX</button>\n      <button id=\"commitDistributed\">Commit Distributed TX (coordinator)</button>\n      <button id=\"abortDistributed\">Abort Distributed TX (coordinator)</button>\n    </div>\n    <pre id=\"nodesView\"></pre>\n  </div>\n</section>\n\n<section>\n  <h3>Crash & Recovery</h3>\n  <div>\n    <button id=\"simulateCrash\">Simulate Crash (clear runtime, keep log)</button>\n    <button id=\"recover\">Recover from log</button>\n    <button id=\"clearLog\">Clear transaction log (danger)</button>\n    <div>\n      <strong>Committed Transaction Log:</strong>\n      <pre id=\"logView\"></pre>\n    </div>\n  </div>\n</section>\n\n<section>\n  <h3>Random / Stress Tools</h3>\n  <div>\n    <label>Random tx count: <input id=\"randCount\" type=\"number\" value=\"5\" style=\"width:60px;\"></label>\n    <label>Ops per tx: <input id=\"randOps\" type=\"number\" value=\"4\" style=\"width:60px;\"></label>\n    <label>Max amount: <input id=\"randMaxAmt\" type=\"number\" value=\"25\" style=\"width:60px;\"></label>\n    <button id=\"generateRandom\">Generate Random Transactions</button>\n    <button id=\"runRandomAuto\">Run All Random Auto</button>\n  </div>\n</section>\n\n<section>\n  <h3>Utilities</h3>\n  <div>\n    <button id=\"exportLog\">Export Log (copy to clipboard)</button>\n    <button id=\"importLogBtn\">Import Log (paste below)</button>\n    <button id=\"showState\">Show Full State</button>\n    <textarea id=\"importArea\" placeholder=\"Paste exported log JSON here\"></textarea>\n  </div>\n  <div>\n    <strong>Console / Activity</strong>\n    <pre id=\"consoleView\"></pre>\n  </div>\n</section>\n\n<script>\n/*\n  Transaction Simulator - Plain Interface\n  Features implemented:\n  - Accounts add/reset, direct deposit/withdraw (committed immediately)\n  - Begin transactions (with isolation levels and locking mode)\n  - Nested transactions and savepoints\n  - Staged operations: transfer, deposit, withdraw, custom JS script\n  - Pessimistic locking (exclusive locks per account)\n  - Optimistic locking (conflict detection on commit)\n  - Prepare/Commit for 2PC (simple simulation)\n  - Scheduler to step operations across transactions and auto-run\n  - Crash simulation and recovery from committed log\n  - Random transaction generator and stress runner\n  - Logs, export/import\n  - Many interaction paths and states\n*/\n\n(function(){\n  // Core state\n  let accounts = {}; // committed balances\n  let txCounter = 1;\n  let transactions = {}; // active and prepared, keyed by txId\n  let committedLog = []; // array of committed transaction entries (persisted across crash)\n  let locks = {}; // account -> txId (exclusive)\n  let nodes = {}; // for 2PC simulation: nodeId -> {accounts, log}\n  let distributedTxs = {}; // id -> {coordinator, participants, state}\n  let autoTimer = null;\n  let generatedTxs = [];\n  const consoleEl = document.getElementById('consoleView');\n\n  // Utilities\n  function log(msg) {\n    const time = new Date().toISOString().slice(11,23);\n    consoleEl.textContent = time + \" - \" + msg + \"\\n\" + consoleEl.textContent;\n  }\n\n  function updateAccountsView() {\n    const el = document.getElementById('accountsView');\n    let s = '';\n    Object.keys(accounts).sort().forEach(k => s += k + ': ' + accounts[k] + '\\n');\n    el.textContent = s || '(no accounts)';\n    updateAccountSelectors();\n    updateLocksView();\n  }\n\n  function updateAccountSelectors() {\n    const sel = document.getElementById('acctSelect');\n    const from = document.getElementById('opFrom');\n    const to = document.getElementById('opTo');\n    const acctList = [Object.keys(accounts)].flat()[0] ? Object.keys(accounts).sort() : [];\n    [sel, from, to].forEach(s => {\n      const current = s.value;\n      s.innerHTML = '';\n      acctList.forEach(a => {\n        const opt = document.createElement('option'); opt.value = a; opt.textContent = a;\n        s.appendChild(opt);\n      });\n      if (acctList.includes(current)) s.value = current;\n    });\n  }\n\n  function updateTxSelect() {\n    const sel = document.getElementById('txSelect');\n    const current = sel.value;\n    sel.innerHTML = '';\n    const ids = Object.keys(transactions).sort((a,b)=>a-b);\n    ids.forEach(id => {\n      const t = transactions[id];\n      const opt = document.createElement('option');\n      opt.value = id;\n      opt.textContent = id + (t.name ? ' ('+t.name+')' : '') + ' ['+t.state+']';\n      sel.appendChild(opt);\n    });\n    if (ids.includes(current)) sel.value = current;\n    updateTxDetails();\n  }\n\n  function updateTxDetails() {\n    const sel = document.getElementById('txSelect');\n    const id = sel.value;\n    const el = document.getElementById('txDetails');\n    if (!id || !transactions[id]) { el.textContent = '(no transaction selected)'; return; }\n    const t = transactions[id];\n    let s = 'Transaction ID: ' + id + '\\n';\n    s += 'Name: ' + (t.name||'') + '\\n';\n    s += 'State: ' + t.state + '\\n';\n    s += 'Isolation: ' + t.isolation + ' | Locking: ' + t.locking + '\\n';\n    s += 'Parent: ' + (t.parent||'none') + ' | Nested children: ' + (t.children.length) + '\\n';\n    s += 'Snapshot: ' + JSON.stringify(t.snapshot) + '\\n';\n    s += 'Staged balances: ' + JSON.stringify(t.staged) + '\\n';\n    s += 'Operations (' + t.operations.length + '):\\n';\n    t.operations.forEach((op,i) => {\n      s += '  ['+i+'] ' + JSON.stringify(op) + '\\n';\n    });\n    s += 'Savepoints: ' + JSON.stringify(t.savepoints) + '\\n';\n    el.textContent = s;\n  }\n\n  function updateLocksView() {\n    const el = document.getElementById('locksView');\n    let s = '';\n    Object.keys(locks).forEach(acc => s += acc + ' -> TX ' + locks[acc] + '\\n');\n    el.textContent = s || '(no locks)';\n  }\n\n  function updateLogView() {\n    const el = document.getElementById('logView');\n    el.textContent = JSON.stringify(committedLog, null, 2);\n  }\n\n  function showNodes() {\n    const el = document.getElementById('nodesView');\n    let s = 'Nodes:\\n';\n    Object.keys(nodes).forEach(id => {\n      s += 'Node ' + id + ' accounts: ' + JSON.stringify(nodes[id].accounts) + '\\n';\n    });\n    el.textContent = s;\n  }\n\n  // Account management\n  function addAccount(name, bal) {\n    accounts[name] = Number(bal);\n    log('Added account ' + name + ' = ' + bal);\n    updateAccountsView();\n  }\n\n  function resetAccounts() {\n    accounts = { A:100, B:100, C:100 };\n    transactions = {};\n    txCounter = 1;\n    locks = {};\n    committedLog = [];\n    nodes = {};\n    distributedTxs = {};\n    generatedTxs = [];\n    log('Reset accounts to default (A,B,C = 100)');\n    updateAccountsView(); updateTxSelect(); updateLogView(); showNodes();\n  }\n\n  function directDeposit(account, amount) {\n    if (!(account in accounts)) { alert('Account not found'); return; }\n    accounts[account] += Number(amount);\n    const entry = {type:'direct_deposit', account, amount:Number(amount), timestamp: Date.now()};\n    committedLog.push(entry);\n    log('Direct deposit ' + amount + ' to ' + account);\n    updateAccountsView(); updateLogView();\n  }\n\n  function directWithdraw(account, amount) {\n    if (!(account in accounts)) { alert('Account not found'); return; }\n    accounts[account] -= Number(amount);\n    const entry = {type:'direct_withdraw', account, amount:Number(amount), timestamp: Date.now()};\n    committedLog.push(entry);\n    log('Direct withdraw ' + amount + ' from ' + account);\n    updateAccountsView(); updateLogView();\n  }\n\n  // Transaction model\n  function beginTransaction(opts={name:'', isolation:'READ COMMITTED', locking:'OPTIMISTIC', parent:null}) {\n    const id = String(txCounter++);\n    const snapshot = JSON.parse(JSON.stringify(accounts)); // copy committed snapshot\n    const t = {\n      id, name: opts.name||('tx'+id), state: 'active',\n      isolation: opts.isolation, locking: opts.locking,\n      snapshot, staged: {}, operations: [], parent: opts.parent || null,\n      children: [], savepoints: {},\n      prepared: false\n    };\n    transactions[id] = t;\n    if (t.parent) {\n      if (transactions[t.parent]) transactions[t.parent].children.push(id);\n      else log('Warning: parent tx not found: ' + t.parent);\n    }\n    log('Begin transaction ' + id + ' name=' + t.name + ' isolation=' + t.isolation + ' locking=' + t.locking + (t.parent?(' parent='+t.parent):''));\n    updateTxSelect();\n    return id;\n  }\n\n  function beginNestedTransaction() {\n    const parent = document.getElementById('parentTxId').value;\n    if (!parent || !transactions[parent]) { alert('Parent tx id invalid'); return; }\n    const name = document.getElementById('txName').value || '';\n    const isolation = transactions[parent].isolation;\n    const locking = transactions[parent].locking;\n    const id = beginTransaction({name, isolation, locking, parent});\n    updateTxSelect();\n    document.getElementById('txSelect').value = id;\n    updateTxDetails();\n  }\n\n  function addOperationToTx(txId, op) {\n    const t = transactions[txId];\n    if (!t) { alert('Transaction not found'); return; }\n    if (t.state !== 'active') { alert('Cannot add op: transaction not active'); return; }\n    t.operations.push(op);\n    // For convenience: apply to staged immediately in transaction view (not the committed state)\n    // But in pessimistic locking, acquire locks now if needed.\n    if (t.locking === 'PESSIMISTIC') {\n      const accts = opAccounts(op);\n      for (let a of accts) {\n        if (!locks[a]) {\n          locks[a] = txId;\n        } else if (locks[a] !== txId) {\n          // conflict: block and mark\n          t.blocked = true;\n          log('TX ' + txId + ' blocked acquiring lock on ' + a + ' (held by ' + locks[a] + ')');\n        }\n      }\n      updateLocksView();\n    }\n    // update staged view if possible\n    applyOpToStaged(t, op);\n    log('Added operation to TX ' + txId + ': ' + JSON.stringify(op));\n    updateTxDetails();\n  }\n\n  function opAccounts(op) {\n    if (op.type === 'transfer') return [op.from, op.to].filter(Boolean);\n    if (op.type === 'deposit' || op.type === 'withdraw') return [op.account];\n    if (op.type === 'custom') return []; // custom might target anything\n    return [];\n  }\n\n  function applyOpToStaged(t, op) {\n    // staged holds changes applied on top of snapshot\n    // For reads, resolution depends on isolation, but staged reflects transaction's own writes.\n    if (op.type === 'transfer') {\n      const from = op.from, to = op.to, amount = Number(op.amount);\n      // ensure base balances\n      const baseFrom = resolveRead(t, from);\n      const baseTo = resolveRead(t, to);\n      // staged modifications\n      t.staged[from] = (t.staged[from] !== undefined ? t.staged[from] : baseFrom) - amount;\n      t.staged[to] = (t.staged[to] !== undefined ? t.staged[to] : baseTo) + amount;\n    } else if (op.type === 'deposit') {\n      const a = op.account, amount = Number(op.amount);\n      const base = resolveRead(t, a);\n      t.staged[a] = (t.staged[a] !== undefined ? t.staged[a] : base) + amount;\n    } else if (op.type === 'withdraw') {\n      const a = op.account, amount = Number(op.amount);\n      const base = resolveRead(t, a);\n      t.staged[a] = (t.staged[a] !== undefined ? t.staged[a] : base) - amount;\n    } else if (op.type === 'custom') {\n      // execute JS code in a sandboxed way with staged, snap, accounts\n      try {\n        const staged = t.staged, snap = t.snapshot, committed = accounts;\n        const fn = new Function('staged','snap','committed','op','txId', op.script || '');\n        fn(staged, snap, committed, op, t.id);\n      } catch (e) {\n        log('Error in custom op script: ' + e);\n      }\n    }\n  }\n\n  function resolveRead(t, acct) {\n    // based on isolation level, determine what read returns\n    if (t.staged[acct] !== undefined) return t.staged[acct];\n    if (t.isolation === 'READ UNCOMMITTED') {\n      // include latest committed and also uncommitted changes from other txs (pessimistic)\n      // we'll check other transactions' staged values and merge last writer based on ops order\n      for (let id of Object.keys(transactions)) {\n        if (id === t.id) continue;\n        const other = transactions[id];\n        if (other && other.staged[acct] !== undefined) {\n          return other.staged[acct];\n        }\n      }\n      return accounts[acct];\n    } else if (t.isolation === 'READ COMMITTED') {\n      return accounts[acct];\n    } else if (t.isolation === 'REPEATABLE READ' || t.isolation === 'SERIALIZABLE') {\n      return t.snapshot[acct];\n    } else {\n      return accounts[acct];\n    }\n  }\n\n  function commitTransaction(txId) {\n    const t = transactions[txId];\n    if (!t) { alert('Transaction not found'); return; }\n    if (t.state !== 'active') { alert('Cannot commit: tx not active'); return; }\n\n    // If pessimistic locking: ensure locks are held as needed\n    if (t.locking === 'PESSIMISTIC') {\n      // verify no conflicting locks\n      for (let a in locks) {\n        if (locks[a] && locks[a] !== txId && t.operations.some(op=>opAccounts(op).includes(a))) {\n          alert('Cannot commit: lock conflict on ' + a + ' held by ' + locks[a]);\n          return;\n        }\n      }\n    }\n\n    // If optimistic: conflict detection\n    if (t.locking === 'OPTIMISTIC') {\n      // If any account we wrote has changed in committed state since snapshot, it's a write-write conflict\n      const writeAccounts = Object.keys(t.staged);\n      for (let a of writeAccounts) {\n        if (accounts[a] !== t.snapshot[a]) {\n          // conflict\n          log('Optimistic commit conflict for TX ' + txId + ' on account ' + a + ' (committed changed)');\n          alert('Optimistic commit failed due to conflict on ' + a + '. Transaction will be rolled back.');\n          rollbackTransaction(txId);\n          return;\n        }\n      }\n    }\n\n    // Apply staged modifications to committed state\n    for (let a in t.staged) {\n      accounts[a] = (accounts[a]!==undefined ? accounts[a] : 0) + (t.staged[a] - (t.snapshot[a]!==undefined ? t.snapshot[a] : 0));\n      // Another way: replace by staged absolute value if snapshot used as base:\n      // For our model, staged holds absolute values relative to snapshot; we'll compute delta\n    }\n\n    t.state = 'committed';\n    const entry = {id:txId, name:t.name, operations:t.operations, staged:t.staged, timestamp: Date.now()};\n    committedLog.push(entry);\n    // release locks held by this tx\n    for (let a in locks) if (locks[a] === txId) delete locks[a];\n    log('Committed TX ' + txId);\n    delete transactions[txId]; // remove from active map\n    updateTxSelect(); updateAccountsView(); updateLogView();\n  }\n\n  function rollbackTransaction(txId) {\n    const t = transactions[txId];\n    if (!t) { alert('Transaction not found'); return; }\n    // release locks\n    for (let a in locks) if (locks[a] === txId) delete locks[a];\n    t.state = 'rolledback';\n    log('Rolled back TX ' + txId);\n    delete transactions[txId];\n    updateTxSelect(); updateAccountsView();\n  }\n\n  function createSavepoint(txId, name) {\n    const t = transactions[txId];\n    if (!t) return;\n    t.savepoints[name] = {opsLen: t.operations.length, staged: JSON.parse(JSON.stringify(t.staged))};\n    log('Created savepoint ' + name + ' in TX ' + txId);\n    updateTxDetails();\n  }\n\n  function rollbackToSavepoint(txId, name) {\n    const t = transactions[txId];\n    if (!t) { alert('TX not found'); return; }\n    const sp = t.savepoints[name];\n    if (!sp) { alert('Savepoint not found'); return; }\n    t.operations = t.operations.slice(0, sp.opsLen);\n    t.staged = JSON.parse(JSON.stringify(sp.staged));\n    log('Rolled back TX ' + txId + ' to savepoint ' + name);\n    updateTxDetails();\n  }\n\n  // Prepare/2PC on single transaction in this simple model (marks prepared)\n  function prepareTransaction(txId) {\n    const t = transactions[txId];\n    if (!t) { alert('TX not found'); return; }\n    if (t.state !== 'active') { alert('TX not active'); return; }\n    // Do local checks similar to commit but do not apply to committed state\n    if (t.locking === 'OPTIMISTIC') {\n      const writeAccounts = Object.keys(t.staged);\n      for (let a of writeAccounts) {\n        if (accounts[a] !== t.snapshot[a]) {\n          alert('Prepare failed due to conflict on ' + a);\n          return;\n        }\n      }\n    }\n    // For pessimistic, assume locks were acquired earlier\n    t.prepared = true;\n    t.state = 'prepared';\n    log('Prepared TX ' + txId);\n    updateTxSelect();\n  }\n\n  function commitPreparedTransaction(txId) {\n    const t = transactions[txId];\n    if (!t) { alert('TX not found'); return; }\n    if (!t.prepared && t.state !== 'prepared') { alert('TX not prepared'); return; }\n    // Apply staged\n    for (let a in t.staged) {\n      accounts[a] = (accounts[a]!==undefined ? accounts[a] : 0) + (t.staged[a] - (t.snapshot[a]!==undefined ? t.snapshot[a] : 0));\n    }\n    t.state = 'committed';\n    committedLog.push({id:txId, name:t.name, staged:t.staged, prepared:true, timestamp:Date.now()});\n    for (let a in locks) if (locks[a] === txId) delete locks[a];\n    delete transactions[txId];\n    log('Committed prepared TX ' + txId);\n    updateAccountsView(); updateLogView(); updateTxSelect();\n  }\n\n  function abortPreparedTransaction(txId) {\n    const t = transactions[txId];\n    if (!t) { alert('TX not found'); return; }\n    for (let a in locks) if (locks[a] === txId) delete locks[a];\n    t.state = 'rolledback';\n    delete transactions[txId];\n    log('Aborted prepared TX ' + txId);\n    updateTxSelect(); updateAccountsView();\n  }\n\n  // Scheduler\n  function stepOnce() {\n    const listText = document.getElementById('stepList').value.trim();\n    let toStep = [];\n    if (!listText) {\n      toStep = Object.keys(transactions).filter(id => transactions[id].state==='active');\n    } else {\n      toStep = listText.split(',').map(s=>s.trim()).filter(Boolean).filter(id=>transactions[id] && transactions[id].state==='active');\n    }\n    if (toStep.length === 0) { log('No transactions to step'); return; }\n    toStep.forEach(id => {\n      const t = transactions[id];\n      if (!t) return;\n      // execute next op (we interpret operations array as staged operations added but can be \"executed\" one by one)\n      if (t.operations.length === 0) {\n        log('TX ' + id + ' has no operations to execute (staged)');\n        return;\n      }\n      // For our simulation, operations are staged upon addition. But to show scheduler interleaving, we'll allow \"apply op index\" semantics:\n      // We'll keep an execution pointer on transaction\n      t.execPtr = t.execPtr||0;\n      if (t.execPtr >= t.operations.length) {\n        log('TX ' + id + ' has no more ops to execute');\n        return;\n      }\n      const op = t.operations[t.execPtr];\n      // In pessimistic mode, ensure lock available now (acquire if free)\n      if (t.locking === 'PESSIMISTIC') {\n        const accts = opAccounts(op);\n        let blocked = false;\n        for (let a of accts) {\n          if (!locks[a]) locks[a] = id;\n          else if (locks[a] !== id) { blocked = true; log('TX ' + id + ' blocked executing op due to lock on ' + a); }\n        }\n        if (blocked) { t.blocked = true; return; }\n      }\n      // Apply op to staged representation and advance pointer\n      applyOpToStaged(t, op);\n      log('TX ' + id + ' executed op ['+t.execPtr+'] ' + JSON.stringify(op));\n      t.execPtr++;\n      updateTxDetails();\n      updateLocksView();\n    });\n  }\n\n  function runAuto() {\n    if (autoTimer) return;\n    const delay = Number(document.getElementById('autoDelay').value);\n    autoTimer = setInterval(() => {\n      stepOnce();\n    }, delay);\n    log('Auto-run started');\n  }\n\n  function stopAuto() {\n    if (autoTimer) {\n      clearInterval(autoTimer);\n      autoTimer = null;\n      log('Auto-run stopped');\n    }\n  }\n\n  // Two-phase commit simulation with multiple nodes\n  function createNodes(count) {\n    nodes = {};\n    for (let i=1;i<=count;i++) {\n      nodes[String(i)] = {accounts: JSON.parse(JSON.stringify(accounts)), log: []};\n    }\n    log('Created ' + count + ' nodes (cloned current committed accounts into each node)');\n    showNodes();\n  }\n\n  function beginDistributed(txName) {\n    const id = 'dtx' + Date.now();\n    // coordinator creates a distributed tx with participants\n    const parts = Object.keys(nodes);\n    if (parts.length === 0) { alert('No nodes; create nodes first'); return null; }\n    distributedTxs[id] = {id, name: txName, participants: {}, coordinator: 'coord', state: 'active'};\n    parts.forEach(p => {\n      const txId = 'p' + id + '_' + p;\n      // create a local transaction on node: simulated as simple structure\n      distributedTxs[id].participants[p] = {node:p, txId, operations: [], prepared:false, state:'active'};\n    });\n    log('Begin distributed TX ' + id + ' participants: ' + parts.join(','));\n    showNodes();\n    return id;\n  }\n\n  function addOpToDistributed(dtxId, nodeId, op) {\n    const d = distributedTxs[dtxId];\n    if (!d) { alert('Distributed TX not found'); return; }\n    if (!d.participants[nodeId]) { alert('Participant not found'); return; }\n    d.participants[nodeId].operations.push(op);\n    log('Added op to distributed TX ' + dtxId + ' on node ' + nodeId + ': ' + JSON.stringify(op));\n  }\n\n  function prepareDistributed(dtxId, failNode=null) {\n    const d = distributedTxs[dtxId];\n    if (!d) { alert('Distributed TX not found'); return; }\n    // Coordinator asks each participant to prepare\n    let ok = true;\n    const parts = Object.keys(d.participants);\n    for (let p of parts) {\n      const part = d.participants[p];\n      // On node p, simulate checking operations for conflicts with node committed state\n      const node = nodes[p];\n      if (!node) { ok = false; part.state='aborted'; continue; }\n      // Apply operations tentatively to node snapshot to see if any negative balances (simple check)\n      const temp = JSON.parse(JSON.stringify(node.accounts));\n      try {\n        for (let op of part.operations) {\n          if (op.type === 'transfer') {\n            temp[op.from] = (temp[op.from]||0) - Number(op.amount);\n            temp[op.to] = (temp[op.to]||0) + Number(op.amount);\n          } else if (op.type === 'deposit') {\n            temp[op.account] = (temp[op.account]||0) + Number(op.amount);\n          } else if (op.type === 'withdraw') {\n            temp[op.account] = (temp[op.account]||0) - Number(op.amount);\n          }\n        }\n      } catch(e) { ok=false; }\n      // Check negative balances\n      const neg = Object.keys(temp).find(k=>temp[k] < 0);\n      if (neg) {\n        ok = false;\n        part.state = 'aborted';\n        log('Participant ' + p + ' refused prepare due to negative balance on ' + neg);\n      } else {\n        if (failNode && String(failNode) === String(p)) {\n          ok = false;\n          part.state = 'aborted';\n          log('Participant ' + p + ' simulated failure on prepare');\n        } else {\n          part.state = 'prepared';\n          part.temp = temp; // store tentative state\n          log('Participant ' + p + ' prepared successfully');\n        }\n      }\n    }\n    d.state = ok ? 'prepared' : 'aborted';\n    log('Distributed prepare completed: coordinator decision ' + (ok ? 'YES' : 'NO'));\n    return ok;\n  }\n\n  function commitDistributed(dtxId, failNodeCommit=null) {\n    const d = distributedTxs[dtxId];\n    if (!d) { alert('Distributed TX not found'); return; }\n    if (d.state !== 'prepared') { alert('Distributed TX not ready to commit (not prepared)'); return; }\n    const parts = Object.keys(d.participants);\n    for (let p of parts) {\n      const part = d.participants[p];\n      if (part.state !== 'prepared') { log('Skipping participant ' + p + ' (state='+part.state+')'); continue; }\n      // commit temp state to node accounts\n      if (failNodeCommit && String(failNodeCommit) === String(p)) {\n        // simulate crash during commit, participant does not apply and goes down\n        part.state = 'failed_on_commit';\n        log('Participant ' + p + ' failed during commit (simulated)');\n        continue;\n      }\n      nodes[p].accounts = part.temp;\n      nodes[p].log.push({dtxId, committed:true});\n      part.state = 'committed';\n      log('Participant ' + p + ' committed distributed changes');\n    }\n    d.state = 'committed';\n    log('Distributed TX ' + dtxId + ' committed by coordinator');\n    showNodes();\n  }\n\n  function abortDistributed(dtxId) {\n    const d = distributedTxs[dtxId];\n    if (!d) { alert('Distributed TX not found'); return; }\n    const parts = Object.keys(d.participants);\n    for (let p of parts) {\n      const part = d.participants[p];\n      part.state = 'aborted';\n      log('Participant ' + p + ' aborted distributed TX ' + dtxId);\n    }\n    d.state = 'aborted';\n    log('Distributed TX ' + dtxId + ' aborted by coordinator');\n  }\n\n  // Crash & recovery\n  function simulateCrash() {\n    // Simulate clearing volatile memory: transactions, locks, nodes etc remain but may lose in-memory runtime except committedLog\n    transactions = {}; locks = {}; nodes = {}; distributedTxs = {};\n    txCounter = 1;\n    log('Simulated crash: cleared active transactions, locks, nodes. Committed log remains.');\n    updateTxSelect(); updateLocksView(); updateAccountsView(); showNodes();\n  }\n\n  function recoverFromLog() {\n    // Rebuild accounts from committedLog\n    accounts = {};\n    committedLog.forEach(entry => {\n      if (entry.type === 'direct_deposit') accounts[entry.account] = (accounts[entry.account]||0) + entry.amount;\n      else if (entry.type === 'direct_withdraw') accounts[entry.account] = (accounts[entry.account]||0) - entry.amount;\n      else {\n        // transaction entries with staged deltas: staged holds absolute or deltas depending on model; we'll simplify:\n        if (entry.staged) {\n          // if staged holds absolute values relative to snapshot, compute as apply staged absolute over previous snapshot unknown.\n          // Simpler: if staged holds deltas relative to snapshot (as computed earlier), apply as delta by summing staged - snapshot isn't stored.\n          // To keep recovery simple: if staged contains numeric values, we will merge them into accounts (overwrite)\n          Object.keys(entry.staged).forEach(a => {\n            accounts[a] = entry.staged[a]; // best-effort recovery\n          });\n        }\n      }\n    });\n    log('Recovered committed state from log (best-effort)');\n    updateAccountsView(); updateLogView();\n  }\n\n  // Random generator\n  function generateRandomTransactions(count, opsPerTx, maxAmt) {\n    const acctNames = Object.keys(accounts);\n    generatedTxs = [];\n    for (let i=0;i<count;i++) {\n      const name = 'rand' + (i+1);\n      const id = beginTransaction({name, isolation: ['READ UNCOMMITTED','READ COMMITTED','REPEATABLE READ','SERIALIZABLE'][Math.floor(Math.random()*4)], locking: Math.random()<0.5?'OPTIMISTIC':'PESSIMISTIC'});\n      const t = transactions[id];\n      for (let j=0;j<opsPerTx;j++) {\n        const type = Math.random() < 0.6 ? 'transfer' : (Math.random()<0.5?'withdraw':'deposit');\n        if (type === 'transfer') {\n          const from = acctNames[Math.floor(Math.random()*acctNames.length)];\n          let to = acctNames[Math.floor(Math.random()*acctNames.length)];\n          if (to === from) to = acctNames[(acctNames.indexOf(to)+1)%acctNames.length] || to;\n          const amount = Math.ceil(Math.random()*maxAmt);\n          addOperationToTx(id, {type:'transfer', from, to, amount});\n        } else if (type === 'deposit') {\n          const a = acctNames[Math.floor(Math.random()*acctNames.length)];\n          const amount = Math.ceil(Math.random()*maxAmt);\n          addOperationToTx(id, {type:'deposit', account:a, amount});\n        } else {\n          const a = acctNames[Math.floor(Math.random()*acctNames.length)];\n          const amount = Math.ceil(Math.random()*maxAmt);\n          addOperationToTx(id, {type:'withdraw', account:a, amount});\n        }\n      }\n      generatedTxs.push(id);\n    }\n    log('Generated ' + count + ' random transactions: ' + generatedTxs.join(','));\n    updateTxSelect();\n    return generatedTxs;\n  }\n\n  function runAllRandomAuto() {\n    if (!generatedTxs || generatedTxs.length === 0) { alert('No generated transactions'); return; }\n    // set stepList to comma list and run auto\n    document.getElementById('stepList').value = generatedTxs.join(',');\n    runAuto();\n    // Let auto run and stop after many steps\n    setTimeout(() => { stopAuto(); log('Random auto run complete (timed stop)'); }, 5000);\n  }\n\n  // Export / Import\n  function exportLogToClipboard() {\n    const text = JSON.stringify(committedLog, null, 2);\n    navigator.clipboard && navigator.clipboard.writeText(text).then(()=>alert('Log copied to clipboard'), ()=>{ prompt('Copy the log JSON', text);});\n  }\n\n  function importLogFromArea() {\n    try {\n      const txt = document.getElementById('importArea').value;\n      const arr = JSON.parse(txt);\n      if (!Array.isArray(arr)) throw new Error('Expecting array');\n      committedLog = arr;\n      updateLogView();\n      log('Imported log from area (overwrote committed log)');\n    } catch(e) {\n      alert('Import failed: ' + e);\n    }\n  }\n\n  // UI wiring\n  document.getElementById('addAcct').addEventListener('click', ()=>{\n    const name = document.getElementById('acctName').value.trim();\n    const bal = Number(document.getElementById('acctBal').value);\n    if (!name) { alert('Name required'); return; }\n    addAccount(name, bal);\n  });\n  document.getElementById('resetAccounts').addEventListener('click', resetAccounts);\n\n  document.getElementById('viewAcct').addEventListener('click', ()=>{\n    const a = document.getElementById('acctSelect').value;\n    alert('Account: ' + a + ' balance: ' + (accounts[a]!==undefined ? accounts[a] : '(not found)'));\n  });\n\n  document.getElementById('depositDirect').addEventListener('click', ()=>{\n    const a = document.getElementById('acctSelect').value;\n    const amt = Number(document.getElementById('depositAmt').value);\n    directDeposit(a, amt);\n  });\n  document.getElementById('withdrawDirect').addEventListener('click', ()=>{\n    const a = document.getElementById('acctSelect').value;\n    const amt = Number(document.getElementById('withdrawAmt').value);\n    directWithdraw(a, amt);\n  });\n\n  document.getElementById('beginTx').addEventListener('click', ()=>{\n    const name = document.getElementById('txName').value;\n    const isolation = document.getElementById('isolationSelect').value;\n    const locking = document.getElementById('lockingMode').value;\n    const id = beginTransaction({name, isolation, locking});\n    document.getElementById('txSelect').value = id;\n    updateTxSelect();\n    updateTxDetails();\n  });\n\n  document.getElementById('beginNested').addEventListener('click', beginNestedTransaction);\n\n  document.getElementById('addOp').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    if (!txId) { alert('No tx selected'); return; }\n    const type = document.getElementById('opType').value;\n    if (type === 'transfer') {\n      const from = document.getElementById('opFrom').value;\n      const to = document.getElementById('opTo').value;\n      const amount = Number(document.getElementById('opAmount').value);\n      if (!from || !to) { alert('Select from and to'); return; }\n      addOperationToTx(txId, {type:'transfer', from, to, amount});\n    } else if (type === 'deposit') {\n      const account = document.getElementById('opTo').value;\n      const amount = Number(document.getElementById('opAmount').value);\n      addOperationToTx(txId, {type:'deposit', account, amount});\n    } else if (type === 'withdraw') {\n      const account = document.getElementById('opFrom').value;\n      const amount = Number(document.getElementById('opAmount').value);\n      addOperationToTx(txId, {type:'withdraw', account, amount});\n    } else {\n      alert('For custom use the custom script area');\n    }\n    updateTxDetails();\n  });\n\n  document.getElementById('txSelect').addEventListener('change', updateTxDetails);\n  document.getElementById('refreshTx').addEventListener('click', updateTxDetails);\n\n  document.getElementById('commitTx').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    if (!txId) { alert('No tx selected'); return; }\n    commitTransaction(txId);\n  });\n  document.getElementById('rollbackTx').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    if (!txId) { alert('No tx selected'); return; }\n    rollbackTransaction(txId);\n  });\n  document.getElementById('prepareTx').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    prepareTransaction(txId);\n  });\n  document.getElementById('commitPreparedTx').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    commitPreparedTransaction(txId);\n  });\n  document.getElementById('abortPreparedTx').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    abortPreparedTransaction(txId);\n  });\n\n  document.getElementById('createSavepoint').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    const name = document.getElementById('savepointName').value;\n    if (!txId || !name) { alert('Tx and savepoint name required'); return; }\n    createSavepoint(txId, name);\n  });\n\n  document.getElementById('rollbackToSavepoint').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    const name = document.getElementById('savepointName').value;\n    if (!txId || !name) { alert('Tx and savepoint name required'); return; }\n    rollbackToSavepoint(txId, name);\n  });\n\n  document.getElementById('addCustomOp').addEventListener('click', ()=>{\n    const txId = document.getElementById('txSelect').value;\n    const script = document.getElementById('customScript').value;\n    if (!txId || !script) { alert('TX and script required'); return; }\n    addOperationToTx(txId, {type:'custom', script});\n    updateTxDetails();\n  });\n\n  document.getElementById('autoDelay').addEventListener('input', (e)=>{ document.getElementById('autoDelayVal').textContent = e.target.value; });\n\n  document.getElementById('stepOnce').addEventListener('click', stepOnce);\n  document.getElementById('runAuto').addEventListener('click', runAuto);\n  document.getElementById('stopAuto').addEventListener('click', stopAuto);\n\n  // Nodes / 2PC\n  document.getElementById('createNodes').addEventListener('click', ()=>{\n    const c = Number(document.getElementById('nodeCount').value) || 1;\n    createNodes(c);\n  });\n  document.getElementById('beginDistributed').addEventListener('click', ()=>{\n    const name = document.getElementById('distTxName').value;\n    const id = beginDistributed(name);\n    if (id) alert('Distributed TX created: ' + id);\n  });\n  document.getElementById('prepareDistributed').addEventListener('click', ()=>{\n    const failNode = document.getElementById('failNodePrepare').value || null;\n    const dtxs = Object.keys(distributedTxs);\n    if (dtxs.length===0) { alert('No distributed transactions'); return; }\n    const id = dtxs[dtxs.length-1];\n    prepareDistributed(id, failNode);\n    showNodes();\n  });\n  document.getElementById('commitDistributed').addEventListener('click', ()=>{\n    const failNode = document.getElementById('failNodeCommit').value || null;\n    const dtxs = Object.keys(distributedTxs);\n    if (dtxs.length===0) { alert('No distributed transactions'); return; }\n    const id = dtxs[dtxs.length-1];\n    commitDistributed(id, failNode);\n    showNodes();\n  });\n  document.getElementById('abortDistributed').addEventListener('click', ()=>{\n    const dtxs = Object.keys(distributedTxs);\n    if (dtxs.length===0) { alert('No distributed transactions'); return; }\n    const id = dtxs[dtxs.length-1];\n    abortDistributed(id);\n    showNodes();\n  });\n\n  // Crash & recovery\n  document.getElementById('simulateCrash').addEventListener('click', simulateCrash);\n  document.getElementById('recover').addEventListener('click', recoverFromLog);\n  document.getElementById('clearLog').addEventListener('click', ()=>{\n    if (!confirm('Clear committed log? This is destructive')) return;\n    committedLog = [];\n    updateLogView();\n    log('Committed log cleared');\n  });\n\n  // Random\n  document.getElementById('generateRandom').addEventListener('click', ()=>{\n    const count = Number(document.getElementById('randCount').value);\n    const ops = Number(document.getElementById('randOps').value);\n    const maxAmt = Number(document.getElementById('randMaxAmt').value);\n    generateRandomTransactions(count, ops, maxAmt);\n  });\n  document.getElementById('runRandomAuto').addEventListener('click', runAllRandomAuto);\n\n  // Utilities\n  document.getElementById('exportLog').addEventListener('click', exportLogToClipboard);\n  document.getElementById('importLogBtn').addEventListener('click', importLogFromArea);\n  document.getElementById('showState').addEventListener('click', ()=>{\n    alert('Accounts: ' + JSON.stringify(accounts) + '\\nTransactions: ' + Object.keys(transactions).join(',') + '\\nLog size: ' + committedLog.length);\n  });\n\n  // Init\n  resetAccounts();\n  updateTxSelect();\n  updateLogView();\n  updateLocksView();\n\n  // Expose some test helper to console for advanced exploration\n  window._sim = {\n    accounts, transactions, committedLog, beginTransaction, addOperationToTx, commitTransaction, rollbackTransaction, locks, nodes, distributedTxs\n  };\n\n  log('Simulator ready. Start by adding accounts or begin transactions.');\n})();\n</script>\n</body>\n</html>"
