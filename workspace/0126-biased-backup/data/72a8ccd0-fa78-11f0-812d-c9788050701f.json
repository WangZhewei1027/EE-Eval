    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Visual Hash Table</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --accent: #fd79a8;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 2rem;\n            opacity: 0;\n            animation: fadeIn 1s ease-out forwards;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 800;\n            color: var(--primary);\n            margin-bottom: 0.5rem;\n            background: linear-gradient(to right, #6c5ce7, #a29bfe);\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-shadow: 0 2px 10px rgba(108, 92, 231, 0.1);\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 900px;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);\n            padding: 2rem;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: slideUp 0.8s 0.3s ease-out forwards;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .container::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 8px;\n            height: 100%;\n            background: linear-gradient(to bottom, var(--primary), var(--accent));\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 2rem;\n            gap: 1rem;\n        }\n\n        button {\n            background: var(--primary);\n            color: white;\n            border: none;\n            padding: 0.8rem 1.5rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 5px 15px rgba(108, 92, 231, 0.3);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 20px rgba(108, 92, 231, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            width: 5px;\n            height: 5px;\n            background: rgba(255, 255, 255, 0.5);\n            opacity: 0;\n            border-radius: 100%;\n            transform: scale(1, 1) translate(-50%, -50%);\n            transform-origin: 50% 50%;\n        }\n\n        button:focus:not(:active)::after {\n            animation: ripple 1s ease-out;\n        }\n\n        .hash-table {\n            display: flex;\n            flex-direction: column;\n            gap: 1rem;\n        }\n\n        .bucket {\n            display: flex;\n            background: rgba(108, 92, 231, 0.05);\n            border-radius: 10px;\n            padding: 1rem;\n            transition: all 0.3s ease;\n            border: 1px solid rgba(108, 92, 231, 0.1);\n        }\n\n        .bucket-header {\n            min-width: 100px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 1rem;\n            background: rgba(108, 92, 231, 0.1);\n            border-radius: 8px;\n            margin-right: 1rem;\n            font-weight: 600;\n            color: var(--primary);\n        }\n\n        .bucket-items {\n            display: flex;\n            flex-grow: 1;\n            gap: 0.5rem;\n            flex-wrap: wrap;\n        }\n\n        .item {\n            background: white;\n            border-radius: 8px;\n            padding: 0.8rem 1.2rem;\n            font-weight: 500;\n            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.05);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            border: 1px solid rgba(0, 0, 0, 0.05);\n            position: relative;\n            transition: all 0.3s ease;\n        }\n\n        .item:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n        }\n\n        .item-key {\n            font-weight: 700;\n            color: var(--dark);\n        }\n\n        .item-value {\n            font-size: 0.9rem;\n            color: var(--primary);\n        }\n\n        .hash-function {\n            margin-top: 2rem;\n            padding: 1rem;\n            background: rgba(0, 184, 148, 0.1);\n            border-radius: 10px;\n            border: 1px solid rgba(0, 184, 148, 0.2);\n            font-family: monospace;\n            position: relative;\n        }\n\n        .hash-function-label {\n            position: absolute;\n            top: -10px;\n            left: 15px;\n            background: white;\n            padding: 0 0.5rem;\n            font-size: 0.8rem;\n            color: var(--success);\n            font-weight: 600;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(20px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes ripple {\n            0% {\n                transform: scale(0, 0);\n                opacity: 1;\n            }\n            20% {\n                transform: scale(25, 25);\n                opacity: 1;\n            }\n            100% {\n                opacity: 0;\n                transform: scale(40, 40);\n            }\n        }\n\n        @keyframes highlight {\n            0% {\n                background: rgba(253, 121, 168, 0);\n            }\n            50% {\n                background: rgba(253, 121, 168, 0.3);\n            }\n            100% {\n                background: rgba(253, 121, 168, 0);\n            }\n        }\n\n        .highlight {\n            animation: highlight 1.5s ease-out;\n        }\n\n        .explanation {\n            margin-top: 2rem;\n            font-size: 1rem;\n            line-height: 1.6;\n            color: var(--dark);\n            opacity: 0.8;\n            max-width: 700px;\n            text-align: center;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Hash Table Visualization</h1>\n        <p class=\"subtitle\">A visual demonstration of key-value storage</p>\n    </header>\n\n    <div class=\"container\">\n        <div class=\"controls\">\n            <button id=\"insert-btn\">Insert Random Item</button>\n            <button id=\"highlight-btn\">Show Hash Function</button>\n        </div>\n\n        <div class=\"hash-table\" id=\"hash-table\">\n            <!-- Buckets will be inserted here -->\n        </div>\n\n        <div class=\"hash-function\">\n            <span class=\"hash-function-label\">Hash Function</span>\n            <code>hash(key) = key.charCodeAt(0) % 5</code>\n        </div>\n    </div>\n\n    <div class=\"explanation\">\n        A hash table stores key-value pairs by computing an index from the key using a hash function. \n        This visualization shows how different keys map to different buckets based on their hash value.\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const hashTable = document.getElementById('hash-table');\n            const insertBtn = document.getElementById('insert-btn');\n            const highlightBtn = document.getElementById('highlight-btn');\n\n            // Sample data\n            const sampleItems = [\n                { key: 'apple', value: 'red fruit' },\n                { key: 'banana', value: 'yellow fruit' },\n                { key: 'cherry', value: 'red fruit' },\n                { key: 'date', value: 'sweet fruit' },\n                { key: 'elderberry', value: 'dark fruit' },\n                { key: 'fig', value: 'purple fruit' },\n                { key: 'grape', value: 'small fruit' },\n                { key: 'honeydew', value: 'melon' },\n                { key: 'kiwi', value: 'green fruit' },\n                { key: 'lemon', value: 'citrus' }\n            ];\n\n            // Initialize hash table with 5 buckets\n            const buckets = Array(5).fill().map(() => []);\n\n            // Simple hash function\n            function hash(key) {\n                return key.charCodeAt(0) % 5;\n            }\n\n            // Render the hash table\n            function renderHashTable() {\n                hashTable.innerHTML = '';\n                \n                buckets.forEach((items, index) => {\n                    const bucketEl = document.createElement('div');\n                    bucketEl.className = 'bucket';\n                    \n                    const headerEl = document.createElement('div');\n                    headerEl.className = 'bucket-header';\n                    headerEl.textContent = `Bucket ${index}`;\n                    \n                    const itemsEl = document.createElement('div');\n                    itemsEl.className = 'bucket-items';\n                    \n                    items.forEach(item => {\n                        const itemEl = document.createElement('div');\n                        itemEl.className = 'item';\n                        itemEl.innerHTML = `\n                            <div class=\"item-key\">${item.key}</div>\n                            <div class=\"item-value\">${item.value}</div>\n                        `;\n                        itemsEl.appendChild(itemEl);\n                    });\n                    \n                    bucketEl.appendChild(headerEl);\n                    bucketEl.appendChild(itemsEl);\n                    hashTable.appendChild(bucketEl);\n                });\n            }\n\n            // Insert a random item\n            function insertRandomItem() {\n                if (sampleItems.length === 0) {\n                    alert('No more sample items available!');\n                    return;\n                }\n                \n                const randomIndex = Math.floor(Math.random() * sampleItems.length);\n                const item = sampleItems.splice(randomIndex, 1)[0];\n                const bucketIndex = hash(item.key);\n                \n                buckets[bucketIndex].push(item);\n                renderHashTable();\n                \n                // Highlight the inserted item\n                const allItems = document.querySelectorAll('.item');\n                const insertedItem = Array.from(allItems).find(el => \n                    el.querySelector('.item-key').textContent === item.key\n                );\n                \n                if (insertedItem) {\n                    insertedItem.classList.add('highlight');\n                    setTimeout(() => {\n                        insertedItem.classList.remove('highlight');\n                    }, 1500);\n                }\n            }\n\n            // Highlight the hash function process\n            function highlightHashFunction() {\n                const keys = document.querySelectorAll('.item-key');\n                \n                keys.forEach(keyEl => {\n                    const key = keyEl.textContent;\n                    const bucketIndex = hash(key);\n                    const bucketHeaders = document.querySelectorAll('.bucket-header');\n                    \n                    keyEl.parentElement.classList.add('highlight');\n                    bucketHeaders[bucketIndex].classList.add('highlight');\n                    \n                    setTimeout(() => {\n                        keyEl.parentElement.classList.remove('highlight');\n                        bucketHeaders[bucketIndex].classList.remove('highlight');\n                    }, 1500);\n                });\n            }\n\n            // Initialize with 3 random items\n            for (let i = 0; i < 3; i++) {\n                insertRandomItem();\n            }\n\n            // Event listeners\n            insertBtn.addEventListener('click', insertRandomItem);\n            highlightBtn.addEventListener('click', highlightHashFunction);\n        });\n    </script>\n</body>\n</html>"
