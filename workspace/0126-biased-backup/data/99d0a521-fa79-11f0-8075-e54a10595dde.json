    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Git Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .output { margin-top: 20px; }\n        .button { cursor: pointer; }\n        .input-group { margin-bottom: 10px; }\n    </style>\n</head>\n<body>\n\n<h1>Interactive Git Demo</h1>\n\n<div class=\"input-group\">\n    <label for=\"commitMessage\">Commit Message:</label>\n    <input type=\"text\" id=\"commitMessage\" />\n</div>\n\n<div class=\"input-group\">\n    <label for=\"branchName\">Branch Name:</label>\n    <input type=\"text\" id=\"branchName\" />\n</div>\n\n<button class=\"button\" onclick=\"createBranch()\">Create Branch</button>\n<button class=\"button\" onclick=\"commitChanges()\">Commit Changes</button>\n<button class=\"button\" onclick=\"mergeBranches()\">Merge Branches</button>\n<button class=\"button\" onclick=\"viewLogs()\">View Logs</button>\n\n<div class=\"output\" id=\"output\"></div>\n\n<script>\n    const repository = {\n        branches: {},\n        currentBranch: 'main',\n        commitHistory: [],\n    };\n\n    function createBranch() {\n        const branchName = document.getElementById('branchName').value;\n        if (branchName) {\n            repository.branches[branchName] = [];\n            appendOutput(`Branch '${branchName}' created.`);\n        } else {\n            appendOutput(\"Please enter a branch name.\");\n        }\n    }\n\n    function commitChanges() {\n        const message = document.getElementById('commitMessage').value;\n        if (message) {\n            if (!repository.branches[repository.currentBranch]) {\n                repository.branches[repository.currentBranch] = [];\n            }\n            repository.branches[repository.currentBranch].push(message);\n            repository.commitHistory.push({ branch: repository.currentBranch, message });\n            appendOutput(`Committed to '${repository.currentBranch}': ${message}`);\n        } else {\n            appendOutput(\"Please enter a commit message.\");\n        }\n    }\n\n    function mergeBranches() {\n        const branchToMerge = document.getElementById('branchName').value;\n        if (repository.branches[branchToMerge]) {\n            const commits = repository.branches[branchToMerge];\n            commits.forEach(commit => {\n                repository.branches[repository.currentBranch].push(commit);\n                repository.commitHistory.push({ branch: repository.currentBranch, message: commit });\n            });\n            appendOutput(`Merged branch '${branchToMerge}' into '${repository.currentBranch}'.`);\n        } else {\n            appendOutput(`Branch '${branchToMerge}' does not exist.`);\n        }\n    }\n\n    function viewLogs() {\n        let logs = \"Commit Logs:\\n\";\n        repository.commitHistory.forEach(entry => {\n            logs += `${entry.branch}: ${entry.message}\\n`;\n        });\n        appendOutput(logs.replace(/\\n/g, '<br/>'));\n    }\n\n    function appendOutput(message) {\n        const outputDiv = document.getElementById('output');\n        outputDiv.innerHTML += message + '<br/>';\n    }\n</script>\n\n</body>\n</html>"
