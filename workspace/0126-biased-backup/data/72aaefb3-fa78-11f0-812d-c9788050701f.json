    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Branch and Bound Visualization</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --light: #f8f9fa;\n            --dark: #2d3436;\n            --success: #00b894;\n            --warning: #fdcb6e;\n            --danger: #d63031;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 2rem;\n            color: var(--dark);\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3rem;\n            font-weight: 300;\n            margin-bottom: 0.5rem;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            letter-spacing: 1px;\n        }\n\n        .subtitle {\n            font-size: 1.1rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 300;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n\n        .container {\n            width: 100%;\n            max-width: 900px;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);\n            padding: 2rem;\n            position: relative;\n            overflow: hidden;\n            animation: slideUp 1s cubic-bezier(0.22, 1, 0.36, 1);\n        }\n\n        .container::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 8px;\n            background: linear-gradient(90deg, var(--primary), var(--accent));\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 3rem;\n            gap: 1rem;\n        }\n\n        button {\n            padding: 0.8rem 2rem;\n            border: none;\n            border-radius: 50px;\n            background: linear-gradient(90deg, var(--primary), var(--secondary));\n            color: white;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(108, 92, 231, 0.3);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 25px rgba(108, 92, 231, 0.4);\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, rgba(255,255,255,0.1), rgba(255,255,255,0.2));\n            transform: translateX(-100%);\n            transition: transform 0.3s ease;\n        }\n\n        button:hover::after {\n            transform: translateX(0);\n        }\n\n        .visualization {\n            width: 100%;\n            min-height: 500px;\n            position: relative;\n        }\n\n        .tree-container {\n            width: 100%;\n            overflow: auto;\n            padding: 2rem 0;\n            display: flex;\n            justify-content: center;\n        }\n\n        .node {\n            width: 60px;\n            height: 60px;\n            border-radius: 50%;\n            background: white;\n            border: 3px solid var(--primary);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            position: relative;\n            font-weight: bold;\n            color: var(--primary);\n            transition: all 0.5s ease;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            z-index: 2;\n        }\n\n        .node.active {\n            background: var(--primary);\n            color: white;\n            transform: scale(1.1);\n            box-shadow: 0 8px 25px rgba(108, 92, 231, 0.4);\n        }\n\n        .node.pruned {\n            border-color: var(--danger);\n            color: var(--danger);\n            opacity: 0.6;\n            transform: scale(0.9);\n        }\n\n        .node.solution {\n            border-color: var(--success);\n            background: var(--success);\n            color: white;\n            box-shadow: 0 8px 25px rgba(0, 184, 148, 0.4);\n        }\n\n        .connector {\n            position: absolute;\n            background: var(--secondary);\n            height: 2px;\n            transform-origin: left center;\n            z-index: 1;\n        }\n\n        .level {\n            display: flex;\n            justify-content: center;\n            gap: 80px;\n            margin-bottom: 40px;\n            position: relative;\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n            flex-wrap: wrap;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n            font-size: 0.9rem;\n        }\n\n        .legend-color {\n            width: 20px;\n            height: 20px;\n            border-radius: 4px;\n        }\n\n        .bound-value {\n            position: absolute;\n            top: -30px;\n            font-size: 0.8rem;\n            background: white;\n            padding: 0.2rem 0.5rem;\n            border-radius: 4px;\n            box-shadow: 0 2px 5px rgba(0,0,0,0.1);\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n\n        .bound-value.show {\n            opacity: 1;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @keyframes slideUp {\n            from { \n                opacity: 0;\n                transform: translateY(50px);\n            }\n            to { \n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        .pulse {\n            animation: pulse 2s infinite;\n        }\n\n        footer {\n            margin-top: 4rem;\n            text-align: center;\n            color: var(--dark);\n            opacity: 0.7;\n            font-size: 0.9rem;\n            animation: fadeIn 2s ease-out;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Branch and Bound</h1>\n        <p class=\"subtitle\">A visual demonstration of the optimization algorithm that systematically searches solution spaces while pruning unpromising branches</p>\n    </header>\n\n    <div class=\"container\">\n        <div class=\"controls\">\n            <button id=\"startBtn\">Start Visualization</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n\n        <div class=\"visualization\">\n            <div class=\"tree-container\" id=\"tree\"></div>\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--primary);\"></div>\n                <span>Active Node</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"background: var(--success);\"></div>\n                <span>Optimal Solution</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"border: 2px solid var(--danger); background: white;\"></div>\n                <span>Pruned Branch</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color\" style=\"border: 2px solid var(--primary); background: white;\"></div>\n                <span>Unexplored Node</span>\n            </div>\n        </div>\n    </div>\n\n    <footer>\n        <p>Branch and Bound Visualization • Aesthetic Algorithm Demonstration</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const treeContainer = document.getElementById('tree');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            \n            // Create the tree structure\n            const tree = {\n                value: 0,\n                bound: 0,\n                level: 0,\n                children: [\n                    {\n                        value: 5,\n                        bound: 25,\n                        level: 1,\n                        children: [\n                            {\n                                value: 8,\n                                bound: 18,\n                                level: 2,\n                                children: [\n                                    { value: 12, bound: 12, level: 3, children: [] },\n                                    { value: 10, bound: 10, level: 3, children: [] }\n                                ]\n                            },\n                            {\n                                value: 7,\n                                bound: 20,\n                                level: 2,\n                                children: [\n                                    { value: 11, bound: 11, level: 3, children: [] },\n                                    { value: 9, bound: 9, level: 3, children: [] }\n                                ]\n                            }\n                        ]\n                    },\n                    {\n                        value: 6,\n                        bound: 22,\n                        level: 1,\n                        children: [\n                            {\n                                value: 9,\n                                bound: 19,\n                                level: 2,\n                                children: [\n                                    { value: 13, bound: 13, level: 3, children: [] },\n                                    { value: 11, bound: 11, level: 3, children: [] }\n                                ]\n                            },\n                            {\n                                value: 8,\n                                bound: 21,\n                                level: 2,\n                                children: [\n                                    { value: 12, bound: 12, level: 3, children: [] },\n                                    { value: 14, bound: 14, level: 3, children: [], isSolution: true }\n                                ]\n                            }\n                        ]\n                    }\n                ]\n            };\n\n            let currentBound = Infinity;\n            let optimalSolution = null;\n            let visitedNodes = [];\n            let prunedNodes = [];\n            let timeoutIds = [];\n\n            // Render the initial tree\n            renderTree();\n\n            startBtn.addEventListener('click', startVisualization);\n            resetBtn.addEventListener('click', resetVisualization);\n\n            function startVisualization() {\n                startBtn.disabled = true;\n                performBranchAndBound(tree);\n            }\n\n            function resetVisualization() {\n                // Clear all timeouts\n                timeoutIds.forEach(id => clearTimeout(id));\n                timeoutIds = [];\n                \n                visitedNodes = [];\n                prunedNodes = [];\n                currentBound = Infinity;\n                optimalSolution = null;\n                \n                // Reset all nodes\n                document.querySelectorAll('.node').forEach(node => {\n                    node.classList.remove('active', 'pruned', 'solution');\n                });\n                \n                document.querySelectorAll('.bound-value').forEach(el => {\n                    el.classList.remove('show');\n                });\n                \n                startBtn.disabled = false;\n            }\n\n            function performBranchAndBound(node) {\n                if (!node) return;\n\n                // Mark node as visited\n                visitedNodes.push(node);\n                \n                // Highlight current node\n                const delay = visitedNodes.length * 1000;\n                \n                timeoutIds.push(setTimeout(() => {\n                    highlightNode(node, 'active');\n                    \n                    // Show bound value\n                    const boundEl = document.querySelector(`.node[data-id=\"${node.value}\"] + .bound-value`);\n                    if (boundEl) boundEl.classList.add('show');\n                    \n                    // Check if this node is a solution\n                    if (node.children.length === 0) {\n                        if (!optimalSolution || node.value > optimalSolution.value) {\n                            if (optimalSolution) {\n                                const prevOptimal = document.querySelector(`.node[data-id=\"${optimalSolution.value}\"]`);\n                                prevOptimal.classList.remove('solution');\n                            }\n                            optimalSolution = node;\n                            currentBound = node.value;\n                            \n                            timeoutIds.push(setTimeout(() => {\n                                highlightNode(node, 'solution');\n                                pulseSolution(node);\n                            }, 1000));\n                        }\n                    } else {\n                        // Explore children if their bound is better than current solution\n                        node.children.forEach(child => {\n                            if (child.bound >= (optimalSolution ? optimalSolution.value : 0)) {\n                                timeoutIds.push(setTimeout(() => {\n                                    performBranchAndBound(child);\n                                }, 1000));\n                            } else {\n                                prunedNodes.push(child);\n                                timeoutIds.push(setTimeout(() => {\n                                    highlightNode(child, 'pruned');\n                                }, 1000));\n                            }\n                        });\n                    }\n                }, delay));\n            }\n\n            function highlightNode(node, className) {\n                const nodeEl = document.querySelector(`.node[data-id=\"${node.value}\"]`);\n                if (nodeEl) {\n                    nodeEl.classList.remove('active', 'pruned', 'solution');\n                    nodeEl.classList.add(className);\n                }\n            }\n\n            function pulseSolution(node) {\n                const nodeEl = document.querySelector(`.node[data-id=\"${node.value}\"]`);\n                if (nodeEl) {\n                    nodeEl.classList.add('pulse');\n                }\n            }\n\n            function renderTree() {\n                treeContainer.innerHTML = '';\n                const maxLevel = getMaxLevel(tree);\n                \n                // Create levels\n                for (let i = 0; i <= maxLevel; i++) {\n                    const levelEl = document.createElement('div');\n                    levelEl.className = 'level';\n                    levelEl.dataset.level = i;\n                    treeContainer.appendChild(levelEl);\n                }\n                \n                // Render nodes recursively\n                renderNode(tree, null);\n                \n                // Position nodes and connectors\n                positionNodes();\n            }\n\n            function renderNode(node, parent) {\n                const levelEl = document.querySelector(`.level[data-level=\"${node.level}\"]`);\n                \n                // Create node element\n                const nodeEl = document.createElement('div');\n                nodeEl.className = 'node';\n                nodeEl.dataset.id = node.value;\n                nodeEl.textContent = node.value;\n                \n                // Create bound value element\n                const boundEl = document.createElement('div');\n                boundEl.className = 'bound-value';\n                boundEl.textContent = `Bound: ${node.bound}`;\n                \n                levelEl.appendChild(nodeEl);\n                levelEl.appendChild(boundEl);\n                \n                // Create connector if there's a parent\n                if (parent) {\n                    const connector = document.createElement('div');\n                    connector.className = 'connector';\n                    treeContainer.appendChild(connector);\n                }\n                \n                // Render children\n                node.children.forEach(child => renderNode(child, node));\n            }\n\n            function positionNodes() {\n                const levels = document.querySelectorAll('.level');\n                const nodePositions = {};\n                \n                // Calculate vertical positions for levels\n                levels.forEach((level, levelIndex) => {\n                    const nodes = level.querySelectorAll('.node');\n                    const levelHeight = levelIndex * 120 + 50;\n                    \n                    // Calculate horizontal positions for nodes in level\n                    nodes.forEach((node, nodeIndex) => {\n                        const nodeId = node.dataset.id;\n                        const nodeWidth = 60;\n                        const spacing = 80;\n                        const totalWidth = (nodes.length - 1) * spacing + nodeWidth;\n                        const startX = (treeContainer.offsetWidth - totalWidth) / 2;\n                        const nodeX = startX + nodeIndex * spacing;\n                        \n                        node.style.left = `${nodeX}px`;\n                        node.style.top = `${levelHeight}px`;\n                        \n                        // Store position for connectors\n                        nodePositions[nodeId] = {\n                            x: nodeX + nodeWidth / 2,\n                            y: levelHeight + nodeWidth / 2\n                        };\n                        \n                        // Position bound value\n                        const boundValue = node.nextElementSibling;\n                        if (boundValue && boundValue.classList.contains('bound-value')) {\n                            boundValue.style.left = `${nodeX}px`;\n                            boundValue.style.top = `${levelHeight - 30}px`;\n                        }\n                    });\n                });\n                \n                // Position connectors\n                const connectors = document.querySelectorAll('.connector');\n                let connectorIndex = 0;\n                \n                document.querySelectorAll('.level').forEach(level => {\n                    const nodes = level.querySelectorAll('.node');\n                    \n                    nodes.forEach(node => {\n                        const nodeId = node.dataset.id;\n                        const childNodes = node.parentNode.querySelectorAll('.node');\n                        \n                        if (childNodes.length > 0 && connectors[connectorIndex]) {\n                            const parentPos = nodePositions[nodeId];\n                            \n                            childNodes.forEach(childNode => {\n                                const childId = childNode.dataset.id;\n                                const childPos = nodePositions[childId];\n                                \n                                if (parentPos && childPos) {\n                                    const connector = connectors[connectorIndex];\n                                    const length = Math.sqrt(\n                                        Math.pow(childPos.x - parentPos.x, 2) + \n                                        Math.pow(childPos.y - parentPos.y, 2)\n                                    );\n                                    const angle = Math.atan2(\n                                        childPos.y - parentPos.y, \n                                        childPos.x - parentPos.x\n                                    );\n                                    \n                                    connector.style.width = `${length}px`;\n                                    connector.style.left = `${parentPos.x}px`;\n                                    connector.style.top = `${parentPos.y}px`;\n                                    connector.style.transform = `rotate(${angle}rad)`;\n                                    \n                                    connectorIndex++;\n                                }\n                            });\n                        }\n                    });\n                });\n            }\n\n            function getMaxLevel(node) {\n                if (node.children.length === 0) return node.level;\n                let max = node.level;\n                node.children.forEach(child => {\n                    const childMax = getMaxLevel(child);\n                    if (childMax > max) max = childMax;\n                });\n                return max;\n            }\n        });\n    </script>\n</body>\n</html>"
