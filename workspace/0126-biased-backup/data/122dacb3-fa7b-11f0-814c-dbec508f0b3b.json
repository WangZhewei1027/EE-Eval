    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Refactoring Demo</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #fff;\n        }\n        input[type=\"text\"], input[type=\"password\"], input[type=\"date\"] {\n            width: 100%;\n            padding: 10px;\n            margin: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        button {\n            padding: 10px 20px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: #fff;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #3e8e41;\n        }\n        input[type=\"submit\"] {\n            padding: 10px 20px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: #fff;\n            cursor: pointer;\n        }\n        input[type=\"submit\"]:hover {\n            background-color: #3e8e41;\n        }\n        .error {\n            color: #f00;\n        }\n    </style>\n</head>\n<body>\n    <h1>Refactoring Demo</h1>\n    <p id=\"error\"></p>\n    <button id=\"save-btn\">Save</button>\n    <form id=\"refactoring-form\">\n        <input type=\"text\" id=\"name\" placeholder=\"Name\">\n        <input type=\"password\" id=\"password\" placeholder=\"Password\">\n        <input type=\"date\" id=\"birthdate\" placeholder=\"Birthdate\">\n        <textarea id=\"message\" placeholder=\"Message\"></textarea>\n        <button id=\"submit-btn\">Refactor</button>\n        <button id=\"clear-btn\">Clear</button>\n    </form>\n    <script>\n        const form = document.getElementById('refactoring-form');\n        const saveBtn = document.getElementById('save-btn');\n        const submitBtn = document.getElementById('submit-btn');\n        const clearBtn = document.getElementById('clear-btn');\n        const errorDiv = document.getElementById('error');\n\n        saveBtn.addEventListener('click', saveRefactoring);\n        submitBtn.addEventListener('click', submitRefactoring);\n        clearBtn.addEventListener('click', clearRefactoring);\n\n        function saveRefactoring() {\n            const name = document.getElementById('name').value;\n            const password = document.getElementById('password').value;\n            const birthdate = document.getElementById('birthdate').value;\n            const message = document.getElementById('message').value;\n\n            if (name && password && birthdate && message) {\n                console.log('Refactoring saved successfully!');\n                errorDiv.textContent = '';\n            } else {\n                errorDiv.textContent = 'Please fill in all fields.';\n            }\n        }\n\n        function submitRefactoring() {\n            const refactoring = {\n                name: document.getElementById('name').value,\n                password: document.getElementById('password').value,\n                birthdate: document.getElementById('birthdate').value,\n                message: document.getElementById('message').value\n            };\n\n            console.log('Refactoring submitted:', refactoring);\n\n            errorDiv.textContent = '';\n        }\n\n        function clearRefactoring() {\n            form.reset();\n            errorDiv.textContent = '';\n        }\n    </script>\n</body>\n</html>"
