    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Digital Signatures — Visual Concept</title>\n<style>\n  :root{\n    --bg1:#071029;\n    --bg2:#0b1230;\n    --accent-1:#6ef0c4;\n    --accent-2:#84a9ff;\n    --muted:#9aa7c2;\n    --glass: rgba(255,255,255,0.06);\n    --glass-2: rgba(255,255,255,0.03);\n    --card: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n    --glass-border: rgba(255,255,255,0.06);\n    --success: #39d98a;\n    --danger: #ff6b6b;\n    font-synthesis: none;\n  }\n\n  /* Reset */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 20%, rgba(12,22,58,0.7), transparent 8%),\n                radial-gradient(900px 400px at 90% 80%, rgba(18,14,40,0.6), transparent 8%),\n                linear-gradient(180deg,var(--bg1),var(--bg2));\n    color: #eaf1ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    overflow:hidden;\n  }\n\n  /* Decorative floating shapes */\n  .orb {\n    position:absolute;\n    width:420px;height:420px;\n    border-radius:50%;\n    filter: blur(60px) saturate(115%);\n    opacity:0.14;\n    transform:translate3d(0,0,0);\n    mix-blend-mode:screen;\n  }\n  .orb.one{\n    background: radial-gradient(circle at 30% 30%, var(--accent-1) 0%, rgba(134,169,255,0.08) 40%, transparent 60%);\n    left:-120px; top:-60px; transform:scale(1.1);\n  }\n  .orb.two{\n    background: radial-gradient(circle at 60% 60%, var(--accent-2) 0%, rgba(108,192,160,0.06) 30%, transparent 60%);\n    right:-160px; bottom:-80px; transform:scale(1.1);\n  }\n\n  /* Layout */\n  .wrap{\n    position:relative;\n    padding:48px;\n    min-height:100vh;\n    display:grid;\n    grid-template-columns: 520px 1fr;\n    gap:32px;\n    align-items:center;\n  }\n\n  /* Left Panel: Title & Controls */\n  .panel {\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid var(--glass-border);\n    border-radius:20px;\n    padding:36px;\n    box-shadow: 0 8px 40px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    backdrop-filter: blur(8px) saturate(120%);\n    position:relative;\n    overflow:hidden;\n  }\n\n  .title{\n    display:flex;\n    gap:16px;\n    align-items:center;\n    margin-bottom:18px;\n  }\n  .logo{\n    width:72px;height:72px;border-radius:16px;\n    background: linear-gradient(135deg,var(--accent-1),var(--accent-2));\n    display:grid;place-items:center;\n    box-shadow: 0 6px 30px rgba(82,145,255,0.12), inset 0 -6px 18px rgba(255,255,255,0.06);\n    transform: translateZ(0);\n  }\n  .logo svg{filter:drop-shadow(0 6px 20px rgba(0,0,0,0.35));}\n  h1{\n    font-size:22px;margin:0;\n    letter-spacing:-0.02em;\n  }\n  p.lead{margin:6px 0 0;color:var(--muted);font-size:13px;line-height:1.4}\n\n  .meta{\n    margin-top:22px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:flex-start;\n  }\n  .chip{\n    background:var(--glass);\n    border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);\n    padding:8px 12px;border-radius:999px;font-size:13px;\n    display:inline-flex;align-items:center; gap:8px;\n    box-shadow: 0 4px 18px rgba(2,6,23,0.45);\n  }\n  .chip strong{color:#fff;font-weight:600}\n\n  /* Buttons */\n  .controls{\n    margin-top:28px;\n    display:flex;gap:12px;\n  }\n  .btn{\n    appearance:none;border:0;padding:12px 18px;border-radius:12px;font-weight:700;\n    display:inline-flex;align-items:center;gap:10px;cursor:pointer;\n    transition: all .28s cubic-bezier(.2,.9,.3,1);\n    box-shadow: 0 8px 30px rgba(2,6,23,0.45);\n    font-size:14px;\n  }\n  .btn:active{transform:translateY(2px) scale(.998)}\n  .btn.primary{\n    background: linear-gradient(90deg,var(--accent-2),var(--accent-1));\n    color:#031029;padding-left:18px;padding-right:18px;\n    border:1px solid rgba(255,255,255,0.06);\n  }\n  .btn.ghost{\n    background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted);\n  }\n\n  /* Right Panel: Visual Canvas */\n  .canvas{\n    height:76vh;\n    border-radius:20px;\n    background:\n      linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005)),\n      radial-gradient(600px 200px at 10% 0%, rgba(130,170,255,0.03), transparent 15%),\n      radial-gradient(500px 150px at 90% 100%, rgba(120,230,190,0.02), transparent 10%);\n    border:1px solid var(--glass-border);\n    padding:28px;\n    position:relative;\n    overflow:hidden;\n    box-shadow: 0 12px 60px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;align-items:center;justify-content:center;\n  }\n\n  /* SVG board */\n  .board{\n    width:100%;height:100%;\n    max-width:1100px;max-height:720px;\n    position:relative;\n  }\n\n  /* Node styles */\n  .node{\n    fill:var(--glass);\n    stroke:rgba(255,255,255,0.04);\n    stroke-width:1;\n    filter:drop-shadow(0 8px 30px rgba(0,0,0,0.6));\n  }\n  .node .title{\n    fill:#eaf1ff;font-weight:700;font-size:15px;\n  }\n  .node .sub{\n    fill:var(--muted);font-size:12px;\n  }\n\n  /* Path and glow */\n  .flow-path{\n    stroke: rgba(132,169,255,0.35);\n    stroke-width:3.5;\n    fill:none;\n    stroke-linecap:round;\n    stroke-linejoin:round;\n    stroke-dasharray:1000;\n    stroke-dashoffset:1000;\n    transition: stroke-dashoffset 1.1s cubic-bezier(.2,.9,.3,1);\n    filter: drop-shadow(0 8px 30px rgba(108,169,255,0.08));\n  }\n  .flow-path.active{\n    stroke-dashoffset:0;\n  }\n\n  .glow-token{\n    r:10;\n    fill: url(#ggrad);\n    filter: drop-shadow(0 10px 24px rgba(108,169,255,0.25));\n    transform-origin:center;\n  }\n\n  /* Step indicators */\n  .step{\n    opacity:0.18;transition:opacity .4s ease, transform .45s cubic-bezier(.2,.9,.3,1);\n    transform:translateY(8px);\n  }\n  .step.active{opacity:1; transform:translateY(0);}\n  .label{\n    font-size:12px;fill:#dbe9ff;opacity:0.95;font-weight:700;\n  }\n  .value{\n    font-size:11px; fill:var(--muted);\n  }\n\n  /* Hash box style */\n  .hash{\n    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Courier New\", monospace;\n    font-size:12px;fill:#bfe6d9;\n  }\n\n  /* small explanatory card */\n  .explain{\n    position:absolute; left:36px; bottom:36px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;padding:14px 16px;border:1px solid rgba(255,255,255,0.03);\n    color:var(--muted);font-size:13px;width:340px;\n    box-shadow: 0 10px 40px rgba(2,6,23,0.5);\n    backdrop-filter: blur(6px) saturate(120%);\n  }\n  .explain b{color:#fff;font-weight:700}\n\n  /* Footer micro details */\n  .micro{\n    position:absolute; right:24px; bottom:28px;color:var(--muted);font-size:12px;\n    display:flex;gap:12px;align-items:center;\n  }\n\n  /* Animations */\n  @keyframes floaty {\n    0% { transform: translateY(0px) }\n    50% { transform: translateY(-8px) }\n    100% { transform: translateY(0px) }\n  }\n  .float{animation: floaty 4.2s ease-in-out infinite;}\n\n  /* Responsive */\n  @media (max-width:1100px){\n    .wrap{grid-template-columns:1fr; padding:28px; gap:20px}\n    .canvas{height:66vh}\n    .explain{left:18px; bottom:18px; width:unset; right:18px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"orb one\"></div>\n  <div class=\"orb two\"></div>\n\n  <div class=\"wrap\">\n    <div class=\"panel\">\n      <div class=\"title\">\n        <div class=\"logo float\" aria-hidden=\"true\">\n          <!-- Icon: stylized pen + lock -->\n          <svg width=\"38\" height=\"38\" viewBox=\"0 0 64 64\" xmlns=\"http://www.w3.org/2000/svg\">\n            <defs>\n              <linearGradient id=\"lg\" x1=\"0\" x2=\"1\">\n                <stop offset=\"0\" stop-color=\"#6EF0C4\"/>\n                <stop offset=\"1\" stop-color=\"#84A9FF\"/>\n              </linearGradient>\n            </defs>\n            <rect width=\"64\" height=\"64\" rx=\"12\" fill=\"url(#lg)\"/>\n            <g opacity=\"0.96\" transform=\"translate(8,10)\" fill=\"#031029\">\n              <path d=\"M34 5.2c1.6 0 3 1.4 3 3v6.3c0 .5-.4.9-.9.9s-.9-.4-.9-.9V8.2c0-.7-.6-1.2-1.2-1.2h-18.6c-.4 0-.8.2-1 .6l-6.2 18c-.3.9.2 1.8 1.1 2.1.2.1.4.1.6.1.7 0 1.3-.5 1.5-1.2L15.1 17h14.7c.6 0 1.1-.4 1.2-1V8.2c0-.3.3-.5.5-.6z\"/>\n              <path d=\"M22.8 31.6l-6.1 6.1c-1.2 1.2-1.2 3.1 0 4.2l2.2 2.2c1.2 1.2 3.1 1.2 4.2 0l6.1-6.1-6.4-6.4zM39.2 22.6l-4.8-4.8 3.3-3.3c1.1-1.1 2.9-1.1 4 0l1.9 1.9c1.1 1.1 1.1 2.9 0 4l-4.4 4.2z\"/>\n            </g>\n          </svg>\n        </div>\n\n        <div>\n          <h1>Digital Signatures</h1>\n          <p class=\"lead\">A visual explanation of how a message is signed, transmitted, and verified using cryptographic keys.</p>\n        </div>\n      </div>\n\n      <div class=\"meta\">\n        <div class=\"chip\"><strong>Asymmetric</strong> • Public / Private keys</div>\n        <div class=\"chip\">Integrity • Non-repudiation</div>\n      </div>\n\n      <div class=\"controls\">\n        <button class=\"btn primary\" id=\"playBtn\" title=\"Play the signing flow\">\n          ▶ Play animation\n        </button>\n        <button class=\"btn ghost\" id=\"resetBtn\" title=\"Reset visualization\">⟲ Reset</button>\n      </div>\n\n      <div style=\"margin-top:22px;color:var(--muted);font-size:13px;line-height:1.52\">\n        <div style=\"margin-bottom:8px\"><b>Step-by-step</b> — Watch a golden token travel through the signing pipeline. Observe hashing, signing with the private key, and verification with the public key.</div>\n        <div style=\"font-size:12px;color:#9fb7da\">Interactivity is intentionally minimal — press Play and watch the concept come alive.</div>\n      </div>\n    </div>\n\n    <div class=\"canvas\">\n      <div class=\"board\" aria-hidden=\"false\">\n        <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 1200 720\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <linearGradient id=\"ggrad\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"#84A9FF\"/>\n              <stop offset=\"1\" stop-color=\"#6EF0C4\"/>\n            </linearGradient>\n            <filter id=\"softGlow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"12\" result=\"blur\"/>\n              <feMerge>\n                <feMergeNode in=\"blur\"/>\n                <feMergeNode in=\"SourceGraphic\"/>\n              </feMerge>\n            </filter>\n            <linearGradient id=\"boxGrad\" x1=\"0\" x2=\"1\">\n              <stop offset=\"0\" stop-color=\"rgba(255,255,255,0.03)\"/>\n              <stop offset=\"1\" stop-color=\"rgba(255,255,255,0.01)\"/>\n            </linearGradient>\n            <filter id=\"shadow2\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feDropShadow dx=\"0\" dy=\"10\" stdDeviation=\"24\" flood-color=\"#0b1830\" flood-opacity=\"0.7\"/>\n            </filter>\n          </defs>\n\n          <!-- Background faint grid -->\n          <g opacity=\"0.04\" stroke=\"#ffffff\" stroke-width=\"1\" fill=\"none\" transform=\"translate(40,40)\">\n            <rect x=\"0\" y=\"0\" width=\"1120\" height=\"640\" rx=\"18\" />\n            <g stroke-dasharray=\"0 10 0 10\">\n              <path d=\"M0 90 H1120\" />\n              <path d=\"M0 180 H1120\" />\n              <path d=\"M0 270 H1120\" />\n              <path d=\"M0 360 H1120\" />\n              <path d=\"M0 450 H1120\" />\n              <path d=\"M0 540 H1120\" />\n            </g>\n          </g>\n\n          <!-- Nodes -->\n          <!-- Message -->\n          <g id=\"node-message\" transform=\"translate(80,160)\">\n            <rect class=\"node\" x=\"0\" y=\"0\" rx=\"16\" width=\"300\" height=\"120\" />\n            <text x=\"20\" y=\"36\" class=\"title\">Message</text>\n            <text x=\"20\" y=\"64\" class=\"sub\">The content to be sent</text>\n            <text x=\"20\" y=\"96\" class=\"hash\">\"Hello, world!\"</text>\n            <rect x=\"16\" y=\"18\" width=\"268\" height=\"78\" rx=\"12\" fill=\"none\" stroke=\"rgba(255,255,255,0.02)\"/>\n          </g>\n\n          <!-- Hash -->\n          <g id=\"node-hash\" transform=\"translate(420,120)\" >\n            <rect class=\"node\" x=\"0\" y=\"0\" rx=\"16\" width=\"220\" height=\"80\" />\n            <text x=\"20\" y=\"32\" class=\"title\">Hash</text>\n            <text x=\"20\" y=\"56\" class=\"sub\">Digest (SHA-like)</text>\n            <text x=\"20\" y=\"72\" class=\"hash\" id=\"hashValue\">e3b0c442...</text>\n          </g>\n\n          <!-- Private Key (Signer) -->\n          <g id=\"node-private\" transform=\"translate(720,60)\">\n            <rect class=\"node\" x=\"0\" y=\"0\" rx=\"16\" width=\"300\" height=\"120\" />\n            <text x=\"20\" y=\"36\" class=\"title\">Private Key</text>\n            <text x=\"20\" y=\"64\" class=\"sub\">Kept secret by signer</text>\n            <rect x=\"220\" y=\"16\" width=\"60\" height=\"36\" rx=\"10\" fill=\"#031029\" opacity=\"0.06\"/>\n            <text x=\"226\" y=\"38\" class=\"value\" fill=\"#9fb7da\">key••••</text>\n          </g>\n\n          <!-- Signature -->\n          <g id=\"node-signature\" transform=\"translate(720,240)\" opacity=\"0.95\">\n            <rect class=\"node\" x=\"0\" y=\"0\" rx=\"16\" width=\"300\" height=\"92\" />\n            <text x=\"20\" y=\"32\" class=\"title\">Signature</text>\n            <text x=\"20\" y=\"56\" class=\"sub\">Encrypted digest</text>\n            <text x=\"20\" y=\"76\" class=\"hash\" id=\"sigVal\">0x7f2a9c...</text>\n          </g>\n\n          <!-- Public Key (Verifier) -->\n          <g id=\"node-public\" transform=\"translate(420,360)\">\n            <rect class=\"node\" x=\"0\" y=\"0\" rx=\"16\" width=\"220\" height=\"92\" />\n            <text x=\"20\" y=\"36\" class=\"title\">Public Key</text>\n            <text x=\"20\" y=\"64\" class=\"sub\">Used to verify signature</text>\n            <text x=\"20\" y=\"86\" class=\"value\">key_pub_ABC123</text>\n          </g>\n\n          <!-- Verification -->\n          <g id=\"node-verify\" transform=\"translate(80,360)\">\n            <rect class=\"node\" x=\"0\" y=\"0\" rx=\"16\" width=\"300\" height=\"92\" />\n            <text x=\"20\" y=\"32\" class=\"title\">Verification</text>\n            <text x=\"20\" y=\"60\" class=\"sub\">Check signature & integrity</text>\n            <g transform=\"translate(220,18)\" id=\"verifyMark\" opacity=\"0.0\" style=\"transition:opacity .5s ease, transform .5s ease;\">\n              <circle cx=\"36\" cy=\"22\" r=\"22\" fill=\"rgba(108,192,160,0.12)\" stroke=\"rgba(108,192,160,0.6)\" />\n              <path d=\"M26 22 l5 5 12 -12\" stroke=\"#39d98a\" stroke-width=\"4\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </g>\n          </g>\n\n          <!-- Flow paths -->\n          <path id=\"p-msg-hash\" class=\"flow-path\" d=\"M380 210 C 402 210, 418 176, 420 160\" />\n          <path id=\"p-hash-private\" class=\"flow-path\" d=\"M540 160 C 620 160, 700 120, 720 120\" />\n          <path id=\"p-private-sign\" class=\"flow-path\" d=\"M780 180 C 720 190, 760 260, 780 260\" />\n          <path id=\"p-sign-public\" class=\"flow-path\" d=\"M720 296 C 660 326, 600 330, 540 370\" />\n          <path id=\"p-public-verify\" class=\"flow-path\" d=\"M420 415 C 300 415, 200 415, 170 415\" />\n\n          <!-- Animated token -->\n          <g id=\"tokenLayer\">\n            <circle id=\"token\" cx=\"28\" cy=\"28\" r=\"14\" fill=\"url(#ggrad)\" filter=\"url(#softGlow)\" opacity=\"0\" />\n            <circle id=\"tokenHalo\" cx=\"28\" cy=\"28\" r=\"28\" fill=\"none\" stroke=\"rgba(134,169,255,0.18)\" stroke-width=\"6\" opacity=\"0\" />\n          </g>\n\n          <!-- Step titles along the path -->\n          <g id=\"tips\">\n            <text x=\"220\" y=\"110\" class=\"label step\" id=\"s-hash\">Hashing</text>\n            <text x=\"770\" y=\"90\" class=\"label step\" id=\"s-sign\">Signing</text>\n            <text x=\"920\" y=\"170\" class=\"label step\" id=\"s-sig\" transform=\"translate(0,8)\">Signature Created</text>\n            <text x=\"520\" y=\"320\" class=\"label step\" id=\"s-verify\">Verification</text>\n          </g>\n\n          <!-- Decorative strokes -->\n          <g opacity=\"0.12\">\n            <path d=\"M64 80 C 240 0, 760 0, 1100 80\" stroke=\"#fff\" stroke-width=\"1.2\" fill=\"none\" stroke-linecap=\"round\"/>\n          </g>\n\n        </svg>\n      </div>\n\n      <div class=\"explain\">\n        <div style=\"font-weight:700;margin-bottom:6px\">How it works — quick summary</div>\n        <div><b>1.</b> A message is hashed into a fixed-size digest. <br><b>2.</b> The signer uses their private key to encrypt the digest producing a signature. <br><b>3.</b> The recipient uses the signer's public key to decrypt and compare — if the hash matches, the signature is valid.</div>\n      </div>\n\n      <div class=\"micro\">Illustration • Flow animation • Minimal controls</div>\n\n    </div>\n  </div>\n\n<script>\n(function(){\n  const playBtn = document.getElementById('playBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Elements\n  const paths = [\n    document.getElementById('p-msg-hash'),\n    document.getElementById('p-hash-private'),\n    document.getElementById('p-private-sign'),\n    document.getElementById('p-sign-public'),\n    document.getElementById('p-public-verify')\n  ];\n  const token = document.getElementById('token');\n  const tokenHalo = document.getElementById('tokenHalo');\n  const tokenLayer = document.getElementById('tokenLayer');\n  const sHash = document.getElementById('s-hash');\n  const sSign = document.getElementById('s-sign');\n  const sSig = document.getElementById('s-sig');\n  const sVerify = document.getElementById('s-verify');\n  const hashValue = document.getElementById('hashValue');\n  const sigVal = document.getElementById('sigVal');\n  const verifyMark = document.getElementById('verifyMark');\n\n  let animating = false;\n  let timeouts = [];\n\n  // Compute total path lengths\n  const pathLengths = paths.map(p => {\n    try { return p.getTotalLength(); } catch(e){ return 500; }\n  });\n\n  function resetVisuals(){\n    // Reset path dashoffsets\n    paths.forEach(p=>{\n      p.classList.remove('active');\n    });\n    // Hide token\n    token.setAttribute('opacity', 0);\n    tokenHalo.setAttribute('opacity', 0);\n    // Reset steps\n    [sHash,sSign,sSig,sVerify].forEach(s=>s.classList.remove('active'));\n    // Reset texts\n    hashValue.textContent = 'e3b0c442...';\n    sigVal.textContent = '0x7f2a9c...';\n    // Hide verify mark\n    verifyMark.style.opacity = '0';\n    verifyMark.style.transform = 'translateY(6px)';\n    // clear timeouts\n    timeouts.forEach(t=>clearTimeout(t));\n    timeouts = [];\n    animating = false;\n    playBtn.disabled = false;\n  }\n\n  function animateTokenAlongPath(pathEl, duration = 900, easing = t=>t){\n    // Show path\n    pathEl.classList.add('active');\n    // position token at start of path\n    const len = pathEl.getTotalLength();\n    const steps = Math.max(60, Math.floor(duration / 16));\n    let start = performance.now();\n    token.setAttribute('opacity', 1);\n    tokenHalo.setAttribute('opacity', 1);\n    return new Promise(resolve=>{\n      function frame(now){\n        let t = Math.min(1, (now-start)/duration);\n        t = easing(t);\n        const p = pathEl.getPointAtLength(len * t);\n        token.setAttribute('cx', p.x);\n        token.setAttribute('cy', p.y);\n        tokenHalo.setAttribute('cx', p.x);\n        tokenHalo.setAttribute('cy', p.y);\n        if(t < 1){\n          requestAnimationFrame(frame);\n        } else {\n          resolve();\n        }\n      }\n      requestAnimationFrame(frame);\n    });\n  }\n\n  function easeCos(t){ return (1 - Math.cos(Math.PI * t)) / 2; }\n  function easeOut(t){ return (--t)*t*t + 1; }\n\n  async function playSequence(){\n    if(animating) return;\n    animating = true;\n    playBtn.disabled = true;\n    resetVisuals();\n\n    // Step 1: Message -> Hash\n    sHash.classList.add('active');\n    await animateTokenAlongPath(paths[0], 900, easeCos);\n\n    // Reveal hash (animated dots)\n    let hashStrs = ['e3b0c442', '9b1a7f6d', '4cae2b7f', 'a9f8d3c1'];\n    for(let i=0;i<hashStrs.length;i++){\n      ((i)=>{\n        timeouts.push(setTimeout(()=>{ hashValue.textContent = hashStrs[i] + '...'; }, i*180));\n      })(i);\n    }\n    await new Promise(r=>timeouts.push(setTimeout(r, 900)));\n\n    // Step 2: Hash -> Private key (signing)\n    sHash.classList.remove('active');\n    sSign.classList.add('active');\n    await animateTokenAlongPath(paths[1], 850, easeCos);\n\n    // Simulate signing glow around private key\n    const privateNode = document.getElementById('node-private');\n    privateNode.animate([\n      { boxShadow: '0 6px 30px rgba(0,0,0,0.6)' },\n      { boxShadow: '0 18px 70px rgba(108,169,255,0.12)' }\n    ], { duration: 650, easing: 'ease-out', fill:'forwards' });\n\n    await animateTokenAlongPath(paths[2], 700, t=>t);\n\n    // Signature appears\n    sSign.classList.remove('active');\n    sSig.classList.add('active');\n\n    // reveal signature gradually\n    const sigCandidates = ['0x7f2a9c', '0x7f2a9c9b', '0x7f2a9c9b1d', '0x7f2a9c9b1d5e'];\n    sigCandidates.forEach((s,i)=>timeouts.push(setTimeout(()=>{ sigVal.textContent = s + '...'; }, i*220)));\n    await new Promise(r=>timeouts.push(setTimeout(r, 900)));\n\n    // token travels to public key\n    await animateTokenAlongPath(paths[3], 900, easeCos);\n\n    // Step 4: Verify\n    sSig.classList.remove('active');\n    sVerify.classList.add('active');\n\n    // reveal verification\n    await animateTokenAlongPath(paths[4], 700, easeOut);\n\n    // show check\n    verifyMark.style.opacity = '1';\n    verifyMark.style.transform = 'translateY(0)';\n    // pulse halo\n    tokenHalo.animate([\n      { opacity: 0.22, r: 28 },\n      { opacity: 0.06, r: 64 },\n      { opacity: 0.0, r: 110 }\n    ], { duration: 900, easing: 'ease-out', fill: 'forwards' });\n\n    // final micro flourish\n    timeouts.push(setTimeout(()=>{\n      document.querySelectorAll('.flow-path').forEach(p=>{\n        p.style.stroke = 'rgba(110,240,196,0.28)';\n      });\n    }, 200));\n\n    // finish\n    timeouts.push(setTimeout(()=>{\n      animating = false;\n      playBtn.disabled = false;\n    }, 1200));\n  }\n\n  // Simple Reset\n  resetBtn.addEventListener('click', ()=>{\n    resetVisuals();\n  });\n\n  playBtn.addEventListener('click', () => {\n    playSequence();\n  });\n\n  // Initialize state\n  resetVisuals();\n\n  // Gentle entrance animations\n  window.requestAnimationFrame(()=> {\n    document.querySelectorAll('.panel, .canvas').forEach((el,i)=>{\n      el.style.opacity = 0; el.style.transform = 'translateY(8px)';\n      setTimeout(()=> {\n        el.style.transition = 'opacity .9s cubic-bezier(.2,.9,.3,1), transform .9s cubic-bezier(.2,.9,.3,1)';\n        el.style.opacity = 1; el.style.transform = 'translateY(0)';\n      }, 120 + i*80);\n    });\n  });\n\n})();\n</script>\n</body>\n</html>"
