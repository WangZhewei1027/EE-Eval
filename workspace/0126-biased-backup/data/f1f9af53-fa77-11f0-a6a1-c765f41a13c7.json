    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Hash Functions — Visual Exploration</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Playfair+Display:wght@600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root{\n      --bg-1: #0f1724;\n      --bg-2: #071020;\n      --glass: rgba(255,255,255,0.06);\n      --accent: linear-gradient(135deg,#6EE7B7 0%,#3B82F6 40%,#8B5CF6 100%);\n      --muted: rgba(255,255,255,0.6);\n      --card-bg: rgba(255,255,255,0.03);\n      --glass-2: rgba(255,255,255,0.025);\n      --soft-shadow: 0 8px 30px rgba(2,6,23,0.6);\n      --glass-border: rgba(255,255,255,0.04);\n    }\n    *{box-sizing:border-box}\n    html,body{\n      height:100%;\n      margin:0;\n      font-family:Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: radial-gradient(1200px 600px at 10% 10%, rgba(59,130,246,0.08), transparent),\n                  radial-gradient(900px 500px at 90% 90%, rgba(139,92,246,0.06), transparent),\n                  linear-gradient(180deg,var(--bg-1),var(--bg-2));\n      color: #EAF2FF;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      overflow:hidden;\n    }\n\n    /* Soft floating blobs */\n    .blobs{\n      position:fixed;\n      inset:0;\n      pointer-events:none;\n      z-index:0;\n      mix-blend-mode:overlay;\n    }\n    .blob{\n      position:absolute;\n      filter: blur(80px) saturate(1.4);\n      opacity:0.6;\n      transform: translate3d(0,0,0);\n      animation: float 10s ease-in-out infinite;\n      will-change: transform;\n      border-radius: 50%;\n    }\n    .blob.b1{width:560px;height:560px;background:linear-gradient(135deg,#6EE7B7,#3B82F6);left:-8%;top:-12%; animation-duration:18s}\n    .blob.b2{width:420px;height:420px;background:linear-gradient(135deg,#8B5CF6,#3B82F6);right:-6%;bottom:-8%; animation-duration:22s}\n    .blob.b3{width:360px;height:360px;background:linear-gradient(135deg,#FF7AB6,#8B5CF6);left:22%;bottom:6%; animation-duration:26s;opacity:0.45}\n    @keyframes float { 0%{transform:translateY(0) translateX(0)}50%{transform:translateY(-30px) translateX(20px)}100%{transform:translateY(0) translateX(0)}}\n\n    /* Layout */\n    .wrap{\n      position:relative;\n      max-width:1200px;\n      margin:40px auto;\n      padding:40px;\n      z-index:1;\n    }\n    header{\n      display:flex;\n      align-items:center;\n      gap:24px;\n      margin-bottom:28px;\n    }\n    .logo{\n      width:78px;\n      height:78px;\n      background:linear-gradient(135deg,#3B82F6,#8B5CF6);\n      border-radius:16px;\n      display:grid;\n      place-items:center;\n      box-shadow: 0 6px 30px rgba(67,56,202,0.22), inset 0 -6px 20px rgba(255,255,255,0.05);\n      flex:0 0 78px;\n    }\n    .logo svg{filter:drop-shadow(0 6px 18px rgba(59,130,246,0.28))}\n\n    h1{\n      margin:0;\n      font-family:'Playfair Display', serif;\n      font-weight:700;\n      letter-spacing:-0.02em;\n      font-size:28px;\n      color: #FFFFFF;\n      text-shadow: 0 2px 12px rgba(13, 27, 49, 0.6);\n    }\n    p.lead{\n      margin:4px 0 0 0;\n      font-size:13px;\n      color:var(--muted);\n      max-width:760px;\n    }\n\n    .stage{\n      margin-top:22px;\n      display:grid;\n      grid-template-columns: 1fr 420px 1fr;\n      gap:28px;\n      align-items:center;\n    }\n\n    /* Cards */\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border: 1px solid var(--glass-border);\n      padding:26px;\n      border-radius:16px;\n      box-shadow: var(--soft-shadow);\n      backdrop-filter: blur(8px) saturate(1.05);\n    }\n\n    .input-card{\n      min-height:320px;\n      display:flex;\n      flex-direction:column;\n      justify-content:space-between;\n      gap:18px;\n    }\n    .label{\n      font-size:12px;\n      color:var(--muted);\n      letter-spacing:0.08em;\n      text-transform:uppercase;\n      display:flex;\n      align-items:center;\n      gap:8px;\n    }\n\n    .message{\n      font-size:20px;\n      font-weight:600;\n      letter-spacing:0.01em;\n      color:#FFF;\n      display:flex;\n      gap:8px;\n      flex-wrap:wrap;\n    }\n    .message .chip{\n      padding:8px 12px;\n      border-radius:12px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 4px 18px rgba(3,7,18,0.6);\n      transform-origin:center;\n      transition:all 420ms cubic-bezier(.2,.9,.2,1);\n      font-weight:600;\n    }\n\n    .meta{\n      color:var(--muted);\n      font-size:13px;\n    }\n\n    /* Center engine */\n    .engine{\n      min-height:420px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      position:relative;\n      overflow:visible;\n    }\n\n    .gland{\n      width:360px;\n      height:360px;\n      border-radius:50%;\n      background: conic-gradient(from 120deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      display:grid;\n      place-items:center;\n      position:relative;\n      box-shadow: 0 30px 80px rgba(3,7,18,0.7), inset 0 -16px 30px rgba(0,0,0,0.35);\n      transition:transform 800ms cubic-bezier(.2,.9,.2,1);\n    }\n\n    .gland:hover{transform:translateY(-6px) scale(1.01)}\n\n    .engine-core{\n      width:200px;\n      height:200px;\n      border-radius:50%;\n      background: radial-gradient(circle at 30% 20%, rgba(59,130,246,0.18), rgba(139,92,246,0.12) 40%, rgba(255,255,255,0.02) 100%);\n      border: 1px solid rgba(255,255,255,0.05);\n      display:grid;\n      place-items:center;\n      position:relative;\n      box-shadow: 0 20px 60px rgba(3,7,18,0.5), inset 0 6px 20px rgba(255,255,255,0.02);\n    }\n\n    .core-label{\n      font-weight:800;\n      font-size:16px;\n      letter-spacing:0.05em;\n      color:white;\n      mix-blend-mode:screen;\n      text-shadow:0 8px 36px rgba(59,130,246,0.18);\n    }\n\n    .gear{\n      position:absolute;\n      width:78px;height:78px;\n      top:42px;left:42px;\n      opacity:0.12;\n      transform-origin:center;\n      filter:blur(0.2px) drop-shadow(0 8px 18px rgba(11,22,45,0.35));\n      animation: spin 11s linear infinite;\n    }\n    .gear.g2{width:110px;height:110px;top:auto;bottom:38px;right:34px;left:auto;opacity:0.09;animation-duration:16s}\n    @keyframes spin {to{transform:rotate(360deg)}}\n\n    .pulse{\n      position:absolute;\n      width:100%;\n      height:100%;\n      border-radius:50%;\n      pointer-events:none;\n      opacity:0;\n      box-shadow: 0 0 80px rgba(59,130,246,0.18), inset 0 0 40px rgba(139,92,246,0.06);\n      transform:scale(0.8);\n    }\n    .pulsing{\n      animation: pulse 1200ms ease-out both;\n    }\n    @keyframes pulse{0%{opacity:0;transform:scale(0.9)}40%{opacity:0.85;transform:scale(1.08)}100%{opacity:0;transform:scale(1.18)}}\n\n    /* Output */\n    .output-card{\n      min-height:320px;\n      display:flex;\n      flex-direction:column;\n      gap:18px;\n      justify-content:space-between;\n    }\n\n    .tiles{\n      display:grid;\n      grid-template-columns:repeat(8,1fr);\n      gap:8px;\n      align-items:center;\n      justify-items:center;\n    }\n    .tile{\n      width:44px;height:44px;border-radius:8px;\n      display:grid;place-items:center;\n      color:rgba(255,255,255,0.95);\n      font-weight:700;\n      font-size:11px;\n      transform:translateY(12px) scale(0.98);\n      opacity:0;\n      transition:all 520ms cubic-bezier(.2,.9,.2,1);\n      box-shadow: 0 8px 20px rgba(2,6,23,0.6), inset 0 -4px 8px rgba(0,0,0,0.15);\n      border:1px solid rgba(255,255,255,0.04);\n    }\n    .tile.show{opacity:1;transform:translateY(0) scale(1);}\n\n    .hex{\n      font-family:monospace;\n      font-size:12px;\n      color:var(--muted);\n      letter-spacing:0.06em;\n      display:block;\n      white-space:nowrap;\n      overflow:hidden;\n    }\n\n    /* Controls */\n    .controls{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-top:12px;\n    }\n    .btn{\n      background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.02));\n      border:1px solid rgba(255,255,255,0.05);\n      color:#fff;\n      padding:10px 16px;\n      border-radius:12px;\n      cursor:pointer;\n      font-weight:600;\n      transition:all 240ms cubic-bezier(.2,.9,.2,1);\n      display:inline-flex;\n      align-items:center;\n      gap:10px;\n      box-shadow: 0 8px 26px rgba(2,6,23,0.45);\n    }\n    .btn:hover{transform:translateY(-4px); box-shadow: 0 16px 40px rgba(2,6,23,0.6)}\n    .btn:active{transform:translateY(-2px)}\n\n    .accent-btn{\n      background:var(--accent);\n      padding:12px 18px;\n      border-radius:14px;\n      border:0;\n      color:#051025;\n      box-shadow: 0 10px 36px rgba(67,56,202,0.22);\n      font-weight:800;\n      letter-spacing:0.02em;\n    }\n\n    /* Info panel */\n    .info{\n      margin-top:30px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border-radius:14px;\n      padding:18px;\n      border:1px solid rgba(255,255,255,0.02);\n      display:flex;\n      gap:18px;\n      align-items:center;\n    }\n    .prop{\n      flex:1;\n    }\n    .prop h3{margin:0;font-size:13px;font-weight:700;color:#fff;font-family:'Playfair Display',serif}\n    .prop p{margin:6px 0 0 0;color:var(--muted);font-size:13px;line-height:1.45}\n\n    /* small */\n    .note{color:var(--muted);font-size:12px;margin-top:6px}\n\n    /* Responsive */\n    @media (max-width:1100px){\n      .stage{grid-template-columns:1fr;align-items:stretch}\n      .engine{order:2}\n      .input-card{order:1}\n      .output-card{order:3}\n    }\n\n    /* Tiny flourish */\n    .spark{\n      position:absolute;\n      width:6px;height:6px;border-radius:50%;\n      background:rgba(255,255,255,0.9);\n      box-shadow:0 0 12px rgba(255,255,255,0.9);\n      transform:translate3d(-50%,-50%,0);\n      pointer-events:none;\n      opacity:0;\n    }\n\n  </style>\n</head>\n<body>\n  <div class=\"blobs\" aria-hidden=\"true\">\n    <div class=\"blob b1\"></div>\n    <div class=\"blob b2\"></div>\n    <div class=\"blob b3\"></div>\n  </div>\n\n  <div class=\"wrap\">\n    <header>\n      <div class=\"logo\" aria-hidden=\"true\">\n        <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"g\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#6EE7B7\"/>\n              <stop offset=\"0.45\" stop-color=\"#3B82F6\"/>\n              <stop offset=\"1\" stop-color=\"#8B5CF6\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" fill=\"url(#g)\"/>\n          <path d=\"M7 12h10M7 8h10M7 16h6\" stroke=\"#021428\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </div>\n      <div>\n        <h1>Hash Functions</h1>\n        <p class=\"lead\">Aesthetic, animated demonstration of cryptographic hashing — deterministic mapping, fixed-size digest, and the avalanche effect. Observe how small changes ripple into completely different digests.</p>\n      </div>\n    </header>\n\n    <section class=\"stage\" aria-hidden=\"false\">\n      <!-- Input/Card -->\n      <div class=\"card input-card\" aria-labelledby=\"inputTitle\">\n        <div>\n          <div class=\"label\" id=\"inputTitle\">Message</div>\n          <div class=\"message\" id=\"messageDisplay\" aria-live=\"polite\">\n            <!-- chips injected -->\n          </div>\n          <div class=\"meta\" id=\"messageMeta\">Length: — bytes</div>\n        </div>\n\n        <div class=\"note\">\n          The interface cycles through curated example messages. Press \"Generate Next\" to step through and watch the hashing animation. Minimal controls — mostly observe.\n        </div>\n      </div>\n\n      <!-- Engine -->\n      <div class=\"engine\" aria-hidden=\"false\">\n        <div class=\"gland\" id=\"gland\">\n          <div class=\"pulse\" id=\"pulse\"></div>\n          <svg class=\"gear\" viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n            <g fill=\"none\" stroke=\"white\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <path d=\"M34 2v6M30 62v-6M60 34h-6M10 30h6M51.5 12.5l-4.3 4.3M16.8 47.2l4.3-4.3M51.5 55.5l-4.3-4.3M16.8 16.8l4.3 4.3\"/>\n              <circle cx=\"32\" cy=\"32\" r=\"8\" fill=\"rgba(255,255,255,0.03)\" stroke=\"rgba(255,255,255,0.09)\"/>\n            </g>\n          </svg>\n          <svg class=\"gear g2\" viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n            <g fill=\"none\" stroke=\"white\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <path d=\"M34 2v6M30 62v-6M60 34h-6M10 30h6M51.5 12.5l-4.3 4.3M16.8 47.2l4.3-4.3M51.5 55.5l-4.3-4.3M16.8 16.8l4.3 4.3\"/>\n              <circle cx=\"32\" cy=\"32\" r=\"12\" fill=\"rgba(255,255,255,0.02)\" stroke=\"rgba(255,255,255,0.06)\"/>\n            </g>\n          </svg>\n\n          <div class=\"engine-core\" id=\"engineCore\">\n            <div class=\"core-label\" id=\"coreLabel\">SHA-256</div>\n          </div>\n        </div>\n\n        <!-- a subtle spark travels -->\n        <div class=\"spark\" id=\"spark\" aria-hidden=\"true\"></div>\n      </div>\n\n      <!-- Output/Card -->\n      <div class=\"card output-card\">\n        <div>\n          <div class=\"label\">Digest (visual)</div>\n          <div class=\"tiles\" id=\"tiles\" aria-hidden=\"true\">\n            <!-- 32 tiles -->\n          </div>\n        </div>\n\n        <div>\n          <div class=\"label\">Digest (hex)</div>\n          <div class=\"hex\" id=\"hexOutput\">—</div>\n\n          <div class=\"controls\">\n            <button class=\"btn accent-btn\" id=\"generateBtn\" aria-label=\"Generate next example\">Generate Next</button>\n            <div style=\"flex:1\"></div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"info\" aria-hidden=\"false\">\n      <div class=\"prop\">\n        <h3>Deterministic</h3>\n        <p>Given the same input, a hash function always produces the same fixed-size output. The digest is a compact \"fingerprint\" of the message.</p>\n      </div>\n      <div class=\"prop\">\n        <h3>Avalanche Effect</h3>\n        <p>Small differences in the input (even a single bit) cause large, unpredictable differences in the output. This is visible as a totally different color pattern for similar messages.</p>\n      </div>\n      <div class=\"prop\">\n        <h3>Fixed Output Length</h3>\n        <p>No matter the input size, the digest length remains constant (SHA‑256 produces 256 bits, i.e., 32 bytes). The visualization maps each byte to a colored tile.</p>\n      </div>\n    </section>\n  </div>\n\n  <script>\n    // Curated example messages emphasizing avalanche\n    const examples = [\n      \"Hello, world!\",\n      \"Hello, wordl!\", // tiny change, strong avalanche\n      \"Hash Functions\",\n      \"Hash Functions.\",\n      \"The quick brown fox jumps over the lazy dog\",\n      \"The quick brown fox jumps over the lazy cat\", // similar but different\n      \"OpenAI\",\n      \"OpenAi\"\n    ];\n\n    // Elements\n    const messageDisplay = document.getElementById('messageDisplay');\n    const messageMeta = document.getElementById('messageMeta');\n    const generateBtn = document.getElementById('generateBtn');\n    const tilesContainer = document.getElementById('tiles');\n    const hexOutput = document.getElementById('hexOutput');\n    const pulse = document.getElementById('pulse');\n    const spark = document.getElementById('spark');\n    const engineCore = document.getElementById('engineCore');\n\n    // state\n    let idx = -1;\n    let isAnimating = false;\n\n    // create 32 tile elements (for 32 bytes SHA-256)\n    for (let i = 0; i < 32; i++) {\n      const t = document.createElement('div');\n      t.className = 'tile';\n      t.dataset.i = i;\n      t.textContent = '';\n      tilesContainer.appendChild(t);\n    }\n    const tiles = Array.from(document.querySelectorAll('.tile'));\n\n    // helper: convert buffer to hex\n    function toHex(buffer){\n      const bytes = new Uint8Array(buffer);\n      return Array.from(bytes).map(b => b.toString(16).padStart(2,'0')).join('');\n    }\n\n    // Map a byte to a pleasant color\n    function colorFromByte(b){\n      // Map byte to hue and lightness based on position\n      const hue = Math.round((b / 256) * 360);\n      const sat = 62 + (b % 6); // slight variation\n      const light = 44 + (b % 12);\n      return `hsl(${hue}deg ${sat}% ${light}%)`;\n    }\n\n    // Animate spark traveling from message to engine then to tiles\n    function animateSpark(fromEl, toEl, duration = 950){\n      const fromRect = fromEl.getBoundingClientRect();\n      const toRect = toEl.getBoundingClientRect();\n      const startX = fromRect.left + fromRect.width/2;\n      const startY = fromRect.top + fromRect.height/2;\n      const endX = toRect.left + toRect.width/2;\n      const endY = toRect.top + toRect.height/2;\n      spark.style.left = startX + 'px';\n      spark.style.top = startY + 'px';\n      spark.style.opacity = 1;\n      spark.style.transform = 'translate3d(-50%,-50%,0) scale(1)';\n      spark.animate([\n        { transform: `translate3d(${startX - startX}px, ${startY - startY}px, 0) scale(1)`, opacity:1 },\n        { transform: `translate3d(${endX - startX}px, ${endY - startY}px, 0) scale(.6)`, opacity:0.02 }\n      ], { duration: duration, easing: 'cubic-bezier(.2,.9,.2,1)' });\n      setTimeout(()=>spark.style.opacity = 0, duration);\n    }\n\n    // Show message chips with subtle stagger\n    function showMessageChips(text){\n      messageDisplay.innerHTML = '';\n      const chars = Array.from(text);\n      chars.forEach((ch,i) => {\n        const chip = document.createElement('div');\n        chip.className = 'chip';\n        chip.textContent = ch === ' ' ? '␣' : ch;\n        chip.style.transitionDelay = (i*30) + 'ms';\n        messageDisplay.appendChild(chip);\n      });\n      messageMeta.textContent = `Length: ${new TextEncoder().encode(text).length} bytes`;\n      // small entrance\n      requestAnimationFrame(()=> {\n        document.querySelectorAll('.chip').forEach((el, i) => {\n          el.style.transform = 'translateY(0)';\n          el.style.opacity = '1';\n        });\n      });\n    }\n\n    // Compute SHA-256 (uses SubtleCrypto). Returns a hex digest string and raw bytes.\n    async function computeDigest(message){\n      const enc = new TextEncoder();\n      const data = enc.encode(message);\n      try {\n        const hashBuffer = await crypto.subtle.digest('SHA-256', data);\n        return { hex: toHex(hashBuffer), bytes: new Uint8Array(hashBuffer) };\n      } catch (e) {\n        // fallback: simple non-cryptographic fallback if Subtle isn't available\n        const fallback = simpleFallbackHash(message);\n        return { hex: fallback.hex, bytes: fallback.bytes };\n      }\n    }\n\n    // A tiny fallback hash (not cryptographic) to use if subtle isn't available (keeps visuals working)\n    function simpleFallbackHash(str){\n      let h1=0xdeadbeef, h2=0x41c6ce57;\n      for(let i=0;i<str.length;i++){\n        h1 = Math.imul(h1 ^ str.charCodeAt(i), 2654435761);\n        h2 = Math.imul(h2 ^ str.charCodeAt(i), 1597334677);\n      }\n      const bytes = new Uint8Array(32);\n      for(let i=0;i<16;i++){\n        bytes[i] = (h1 >> (i%4*8)) & 0xff;\n        bytes[i+16] = (h2 >> (i%4*8)) & 0xff;\n      }\n      return { hex: Array.from(bytes).map(b=>b.toString(16).padStart(2,'0')).join(''), bytes };\n    }\n\n    // Animate digest display: pulse engine, animate tiles expanding and color fill, reveal hex string elegantly\n    function revealDigest(bytes, hex){\n      // pulse engine\n      pulse.classList.remove('pulsing');\n      void pulse.offsetWidth;\n      pulse.classList.add('pulsing');\n\n      // animate tiles: staggered reveal based on index\n      tiles.forEach((tile, i) => {\n        const b = bytes[i];\n        tile.style.background = colorFromByte(b);\n        tile.style.color = (b > 140 ? 'rgba(0,0,0,0.82)' : 'rgba(255,255,255,0.96)');\n        tile.textContent = b.toString(16).padStart(2,'0').toUpperCase();\n        tile.classList.remove('show');\n        tile.style.transitionDelay = (i * 28) + 'ms';\n        // Slight 3D pop\n        tile.style.transform = 'translateY(12px) scale(0.96)';\n        setTimeout(()=> tile.classList.add('show'), 40 + i*28);\n      });\n\n      // reveal hex text with subtle typing effect\n      hexOutput.textContent = '';\n      const group = hex.match(/.{1,8}/g) || [hex];\n      let pos = 0;\n      const revealSpeed = 14;\n      const total = hex.length;\n      function step(){\n        pos++;\n        if (pos > total) { return; }\n        hexOutput.textContent = hex.slice(0,pos);\n        setTimeout(step, revealSpeed);\n      }\n      setTimeout(step, 280);\n\n      // tiny spark fling from engine to tiles center\n      setTimeout(()=> {\n        animateSpark(engineCore, tilesContainer, 900);\n      }, 200);\n    }\n\n    // Primary generate function\n    async function generateNext(){\n      if (isAnimating) return;\n      isAnimating = true;\n      idx = (idx + 1) % examples.length;\n      const message = examples[idx];\n      showMessageChips(message);\n\n      // animate chips flying into engine (visual only)\n      // pick element to animate from (first visible chip) to engine center\n      const fromEl = messageDisplay.children[0] || messageDisplay;\n      animateSpark(fromEl, engineCore, 860);\n\n      // small delay to simulate processing\n      engineCore.animate([{ transform:'scale(1)'},{ transform:'scale(0.98)'},{ transform:'scale(1)'}], { duration: 800, easing:'cubic-bezier(.2,.9,.2,1)' });\n\n      // compute digest while showing subtle busy effect\n      generateBtn.disabled = true;\n      generateBtn.style.opacity = 0.9;\n      const coreLabelText = document.getElementById('coreLabel');\n      coreLabelText.textContent = 'SHA-256';\n      const pre = Date.now();\n      const digest = await computeDigest(message);\n      const took = Date.now() - pre;\n\n      // Consider adding a tiny delay for smoother timing\n      await new Promise(r => setTimeout(r, 180));\n\n      revealDigest(digest.bytes, digest.hex);\n\n      // Show avalanche hint if this example is similar to previous (one char diff)\n      if (idx > 0 && areSimilar(examples[idx-1], examples[idx])){\n        const hint = document.createElement('div');\n        hint.className = 'note';\n        hint.style.marginTop = '8px';\n        hint.style.fontWeight = '700';\n        hint.style.color = '#BDE7FF';\n        hint.textContent = 'Avalanche: small input change → large digest change';\n        document.querySelector('.input-card').appendChild(hint);\n        setTimeout(()=> {\n          hint.style.transition = 'opacity 600ms';\n          hint.style.opacity = 0;\n          setTimeout(()=> hint.remove(), 700);\n        }, 2000);\n      }\n\n      generateBtn.disabled = false;\n      isAnimating = false;\n    }\n\n    // similarity heuristic: small edit distance (1 or 2) based on length and char diff\n    function areSimilar(a,b){\n      if (Math.abs(a.length - b.length) > 2) return false;\n      let diff = 0;\n      const n = Math.max(a.length,b.length);\n      for (let i=0;i<n;i++){\n        if (a[i] !== b[i]) diff++;\n        if (diff > 2) return false;\n      }\n      return diff <= 2;\n    }\n\n    // Initial render\n    function init(){\n      // initial message\n      generateNext();\n      // attach handler\n      generateBtn.addEventListener('click', generateNext);\n      // small keyboard shortcut (space) for accessibility\n      window.addEventListener('keydown', (e) => {\n        if (e.code === 'Space') {\n          e.preventDefault();\n          generateBtn.click();\n        }\n      });\n    }\n\n    // Start after DOM ready\n    document.addEventListener('DOMContentLoaded', init);\n  </script>\n</body>\n</html>"
