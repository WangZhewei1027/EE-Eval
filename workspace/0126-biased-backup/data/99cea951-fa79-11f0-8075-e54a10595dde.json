    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Bubble Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #arrayDisplay {\n            margin: 20px 0;\n        }\n    </style>\n</head>\n<body>\n    <h1>Bubble Sort Visualization</h1>\n    <label for=\"arrayInput\">Enter Numbers (comma-separated): </label>\n    <input type=\"text\" id=\"arrayInput\" value=\"64,34,25,12,22,11,90\">\n    <button id=\"startButton\">Start Sorting</button>\n    <button id=\"stepButton\">Next Step</button>\n    <button id=\"resetButton\">Reset</button>\n    <label for=\"speedSlider\">Set Speed (ms): </label>\n    <input type=\"range\" id=\"speedSlider\" min=\"100\" max=\"1000\" value=\"500\">\n    <span id=\"speedValue\">500 ms</span>\n\n    <div id=\"arrayDisplay\"></div>\n    <script>\n        let array = [];\n        let currentStep = 0;\n        let isSorted = false;\n        let speed = 500;\n\n        document.getElementById('startButton').addEventListener('click', startSorting);\n        document.getElementById('stepButton').addEventListener('click', nextStep);\n        document.getElementById('resetButton').addEventListener('click', reset);\n        document.getElementById('speedSlider').addEventListener('input', changeSpeed);\n\n        function displayArray() {\n            document.getElementById('arrayDisplay').innerText = 'Current Array: ' + array.join(', ');\n        }\n\n        function startSorting() {\n            const input = document.getElementById('arrayInput').value;\n            array = input.split(',').map(Number);\n            currentStep = 0;\n            isSorted = false;\n            displayArray();\n            bubbleSort();\n        }\n\n        function bubbleSort() {\n            const n = array.length;\n            const steps = [];\n            for (let i = 0; i < n-1; i++) {\n                for (let j = 0; j < n-i-1; j++) {\n                    steps.push(j);\n                    if (array[j] > array[j+1]) {\n                        [array[j], array[j+1]] = [array[j+1], array[j]];\n                    }\n                }\n            }\n            isSorted = true;\n            array = steps;\n            displayArray();\n        }\n\n        function nextStep() {\n            if (isSorted) {\n                alert('Sorting is complete.');\n                return;\n            }\n            const j = array[currentStep];\n            if (j < array.length - 1 && array[j] > array[j + 1]) {\n                [array[j], array[j + 1]] = [array[j + 1], array[j]];\n            }\n            currentStep++;\n            displayArray();\n            if (currentStep >= array.length - 1) {\n                isSorted = true;\n                alert('One pass completed.');\n                currentStep = 0;\n            }\n        }\n\n        function reset() {\n            array = [];\n            currentStep = 0;\n            isSorted = false;\n            document.getElementById('arrayInput').value = '64,34,25,12,22,11,90';\n            displayArray();\n        }\n\n        function changeSpeed() {\n            speed = parseInt(document.getElementById('speedSlider').value);\n            document.getElementById('speedValue').innerText = speed + ' ms';\n        }\n    </script>\n</body>\n</html>"
