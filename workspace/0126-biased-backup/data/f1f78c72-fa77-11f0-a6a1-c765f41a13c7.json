  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Monitor — Visual Concept</title>\n<style>\n  :root{\n    --bg-1:#0f1724;\n    --bg-2:#071025;\n    --accent-1:#4ee3d6;\n    --accent-2:#6f7bff;\n    --glass: rgba(255,255,255,0.04);\n    --muted: rgba(255,255,255,0.12);\n    --bezel:#0b1020;\n    --screen-border: linear-gradient(145deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n    --on: 1; /* toggled by JS */\n    --ease: cubic-bezier(.2,.9,.3,1);\n  }\n\n  /* Page base */\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background:\n      radial-gradient(1200px 600px at 10% 10%, rgba(111,123,255,0.12), transparent 8%),\n      radial-gradient(900px 450px at 90% 85%, rgba(78,227,214,0.05), transparent 5%),\n      linear-gradient(180deg,var(--bg-1),var(--bg-2));\n    color:#e6f2ff;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:4vh 4vw;\n    overflow:hidden;\n  }\n\n  /* Subtle animated particles */\n  .sky{\n    position:fixed;\n    inset:0;\n    pointer-events:none;\n    mix-blend-mode:screen;\n    opacity:.85;\n    z-index:0;\n  }\n  .particle{\n    position:absolute;\n    width:6px;height:6px;border-radius:999px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.9), rgba(255,255,255,0.35));\n    filter:blur(.6px);\n    transform:translate3d(0,0,0);\n    animation: drift linear infinite;\n    opacity:.6;\n  }\n  @keyframes drift{\n    from{transform:translateY(0) translateX(0) scale(.7)}\n    to{transform:translateY(-1200px) translateX(200px) scale(1.3)}\n  }\n\n  /* Layout */\n  .stage{\n    position:relative;\n    width:min(1100px,95vw);\n    max-width:1200px;\n    z-index:2;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    gap:34px;\n  }\n\n  /* Info card left */\n  .info{\n    width:320px;\n    min-width:240px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:18px;\n    padding:26px;\n    box-shadow: 0 8px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    border:1px solid rgba(255,255,255,0.03);\n    backdrop-filter: blur(6px) saturate(110%);\n    display:flex;\n    flex-direction:column;\n    gap:18px;\n    transform:translateY(10px);\n  }\n  .brand{\n    display:flex;\n    align-items:center;\n    gap:12px;\n  }\n  .logo{\n    width:56px;height:56px;border-radius:12px;\n    background:linear-gradient(135deg,var(--accent-2),var(--accent-1));\n    box-shadow: 0 6px 18px rgba(111,123,255,0.18), inset 0 -6px 18px rgba(0,0,0,0.2);\n    display:grid;place-items:center;font-weight:700;\n    color:#021023;font-size:20px;\n  }\n  .title{\n    line-height:1;\n  }\n  .title h1{\n    margin:0;font-size:18px;font-weight:700;letter-spacing:1px;\n    color:#eaf7ff;\n  }\n  .title p{\n    margin:0;font-size:12px;color:rgba(255,255,255,0.45);\n  }\n\n  .meta{\n    display:flex;\n    gap:12px;\n    flex-wrap:wrap;\n  }\n  .meta .stat{\n    background:linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    padding:10px 12px;border-radius:12px;flex:1;\n    border:1px solid rgba(255,255,255,0.02);\n  }\n  .stat small{display:block;font-size:11px;color:rgba(255,255,255,0.42)}\n  .stat strong{display:block;margin-top:6px;font-size:16px;color:#dffcff}\n\n  .desc{\n    font-size:13px;color:rgba(255,255,255,0.43);line-height:1.4;\n    margin-top:4px;\n  }\n\n  .controls{\n    display:flex;gap:10px;margin-top:8px;\n  }\n  .btn{\n    appearance:none;border:0;padding:10px 14px;border-radius:12px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    color:#dffffa;font-size:13px;cursor:pointer;\n    box-shadow: 0 6px 16px rgba(3,7,20,0.45);\n    transition:transform .18s var(--ease), box-shadow .18s var(--ease);\n    border:1px solid rgba(255,255,255,0.03);\n    display:inline-flex;align-items:center;gap:10px;\n  }\n  .btn:active{transform:translateY(1px) scale(.998)}\n  .btn.secondary{opacity:.9;color:rgba(255,255,255,0.7)}\n\n  /* Monitor */\n  .monitor-wrap{\n    flex:1;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    perspective:1200px;\n  }\n\n  .monitor{\n    width:min(760px,70vw);\n    aspect-ratio: 16/10;\n    position:relative;\n    border-radius:18px;\n    background: linear-gradient(180deg, #071424 12%, #071425 55%, #01040a 100%);\n    box-shadow:\n      0 40px 60px rgba(2,8,23,0.6),\n      0 16px 28px rgba(2,6,23,0.5),\n      inset 0 1px 0 rgba(255,255,255,0.02);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    transform-style:preserve-3d;\n    transition: transform 700ms var(--ease), box-shadow 700ms var(--ease);\n  }\n\n  /* slight tilt */\n  .monitor::before{\n    content:\"\";\n    position:absolute;inset:0;border-radius:18px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.12));\n    pointer-events:none;\n    mix-blend-mode:overlay;\n  }\n\n  .monitor.off{\n    filter:grayscale(.25) brightness(.35) contrast(.85);\n    transform: translateZ(-20px) rotateX(4deg) scale(.99);\n    box-shadow: 0 22px 50px rgba(2,8,23,0.7);\n  }\n\n  /* bezel */\n  .bezel{\n    width:94%;height:86%;\n    border-radius:12px;\n    background:linear-gradient(180deg, rgba(7,17,34,0.58), rgba(6,9,20,0.15));\n    border:1px solid rgba(255,255,255,0.03);\n    padding:18px;\n    box-shadow: inset 0 4px 30px rgba(3,8,20,0.5);\n    display:flex;flex-direction:column;gap:14px;\n    transform: translateZ(40px);\n  }\n\n  /* screen area */\n  .screen{\n    flex:1;\n    background:\n      radial-gradient(1200px 400px at 20% 0%, rgba(111,123,255,0.07), transparent 8%),\n      linear-gradient(180deg, rgba(10,20,36,0.95), rgba(4,8,18,0.85));\n    border-radius:8px;\n    overflow:hidden;\n    position:relative;\n    display:flex;\n    padding:22px;\n    gap:20px;\n    align-items:stretch;\n    transition: filter .5s var(--ease), opacity .5s var(--ease);\n    box-shadow: 0 18px 40px rgba(3,8,22,0.45) inset;\n  }\n\n  .monitor.off .screen{ filter:grayscale(.6) opacity:.35 }\n\n  /* scan overlay */\n  .screen::after{\n    content:\"\";position:absolute;inset:0;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.002));\n    pointer-events:none;\n    mix-blend-mode:overlay;\n  }\n  .scanline{\n    position:absolute;inset:0;\n    background:linear-gradient(transparent, rgba(255,255,255,0.02) 48%, rgba(255,255,255,0.05) 50%, rgba(255,255,255,0.02) 52%, transparent 100%);\n    background-size:100% 6px;\n    mix-blend-mode:overlay;\n    pointer-events:none;\n    opacity:.6;\n    animation: scan 10s linear infinite;\n  }\n  @keyframes scan{\n    from{background-position:0 0}\n    to{background-position:0 30px}\n  }\n\n  /* left (wave) and right (widgets) */\n  .panel{\n    flex:1;\n    display:flex;\n    gap:18px;\n    align-items:stretch;\n  }\n  .wave-wrap{\n    flex:1;\n    background: linear-gradient(180deg, rgba(78,227,214,0.04), rgba(111,123,255,0.02));\n    border-radius:12px;\n    padding:18px;\n    position:relative;\n    overflow:hidden;\n    border:1px solid rgba(255,255,255,0.03);\n  }\n\n  .wave-head{\n    display:flex;align-items:center;gap:12px;margin-bottom:6px;\n  }\n  .chip{\n    width:48px;height:48px;border-radius:8px;background:linear-gradient(135deg,#06202c,#071426);\n    border:1px solid rgba(255,255,255,0.02);\n    display:grid;place-items:center;font-weight:700;color:var(--accent-1);\n    box-shadow: 0 8px 20px rgba(78,227,214,0.06), inset 0 -6px 20px rgba(0,0,0,0.4);\n  }\n  .meta-text{\n    display:flex;flex-direction:column;\n  }\n  .meta-text small{color:rgba(255,255,255,0.45);font-size:12px}\n  .meta-text strong{font-size:18px;color:#eaffff}\n\n  /* Animated waveform (SVG) */\n  .wave-svg{width:100%;height:calc(100% - 70px); display:block; background:linear-gradient(180deg, rgba(6,19,33,0.0), rgba(4,10,18,0.0)); border-radius:8px; position:relative; overflow:visible;}\n  svg{width:100%;height:100%}\n\n  .grid-lines{\n    stroke:rgba(255,255,255,0.03);\n    stroke-width:1;\n  }\n  .wave{\n    stroke: url(#grad1);\n    stroke-width:3.6;\n    fill:none;\n    stroke-linecap:round;\n    filter:drop-shadow(0 8px 24px rgba(78,227,214,0.08));\n    stroke-dasharray: 1200;\n    stroke-dashoffset: 0;\n    animation: moveWave 3.2s linear infinite;\n    transform-origin:left center;\n  }\n  .wave.alt{\n    stroke: url(#grad2);\n    stroke-width:2.8;\n    opacity:.8;\n    filter:drop-shadow(0 5px 18px rgba(111,123,255,0.06));\n    animation: moveWave 4.2s linear infinite reverse;\n    stroke-dasharray: 800;\n  }\n  @keyframes moveWave {\n    from{stroke-dashoffset: 0;}\n    to{stroke-dashoffset: 1600;}\n  }\n\n  /* right widgets */\n  .widgets{\n    width:260px;\n    display:flex;\n    flex-direction:column;\n    gap:14px;\n  }\n  .widget{\n    background: linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0.01));\n    border-radius:12px;padding:12px;border:1px solid rgba(255,255,255,0.03);\n    display:flex;flex-direction:column;gap:10px;\n  }\n  .gauge{\n    display:flex;gap:12px;align-items:center;\n  }\n  .radial{\n    width:82px;height:82px;border-radius:999px;\n    background: conic-gradient(from 120deg, rgba(111,123,255,0.18), rgba(78,227,214,0.18), rgba(111,123,255,0.18));\n    display:grid;place-items:center;\n    box-shadow: inset 0 6px 16px rgba(0,0,0,0.45);\n    position:relative;\n  }\n  .radial .core{\n    width:56px;height:56px;border-radius:999px;background:linear-gradient(180deg,#021924,#042034);\n    display:grid;place-items:center;color:var(--accent-1);font-weight:700;font-size:14px;\n    box-shadow:0 6px 14px rgba(2,6,23,0.6);\n  }\n  .bar{\n    flex:1;display:flex;flex-direction:column;gap:8px;\n  }\n  .bar .rows{display:flex;gap:8px;align-items:center;}\n  .bar .col{flex:1;height:10px;background:linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));border-radius:999px;overflow:hidden;}\n  .bar .fill{height:100%;background:linear-gradient(90deg,var(--accent-1),var(--accent-2));transform-origin:left;transition:transform .6s var(--ease);}\n\n  /* logs */\n  .logs{font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace; font-size:12px; color:rgba(255,255,255,0.42); line-height:1.6; height:66px; overflow:hidden; opacity:.95}\n  .logs p{margin:0}\n\n  /* base / stand */\n  .stand{\n    position:absolute;bottom:-38px;left:50%;transform:translateX(-50%);width:34%;\n    display:flex;flex-direction:column;align-items:center;gap:8px;\n  }\n  .neck{width:18px;height:42px;background:linear-gradient(180deg,#060914,#071425);border-radius:8px;box-shadow:0 10px 18px rgba(0,0,0,0.6)}\n  .foot{width:170px;height:18px;border-radius:10px;background:linear-gradient(90deg,#041226,#071425);box-shadow:0 10px 30px rgba(0,0,0,0.6);border:1px solid rgba(255,255,255,0.02)}\n\n  /* power lamp */\n  .lamp{\n    position:absolute;right:22px;top:22px;width:12px;height:12px;border-radius:999px;\n    background:radial-gradient(closest-side, var(--accent-1), rgba(2,10,15,0.6));\n    box-shadow:0 6px 18px rgba(78,227,214,0.12), 0 0 18px rgba(78,227,214,0.12);\n    transition:opacity .2s linear, transform .25s var(--ease);\n  }\n  .monitor.off .lamp{opacity:.08; transform: scale(.6); box-shadow:none}\n\n  /* overlay flash (snapshot) */\n  .flash{\n    position:absolute;inset:0;background:#ffffff;border-radius:12px;opacity:0;pointer-events:none;\n  }\n  .flash.ignite{animation: snap .68s ease-out forwards;}\n  @keyframes snap{\n    0%{opacity:0}\n    8%{opacity:0.92}\n    45%{opacity:0.45}\n    100%{opacity:0}\n  }\n\n  /* subtle corner watermark */\n  .mark{\n    position:absolute;left:24px;bottom:20px;opacity:.06;font-weight:700;letter-spacing:6px;font-size:22px;color:#fff;\n    transform:translateY(4px);\n  }\n\n  /* small responsive tweaks */\n  @media (max-width:920px){\n    .stage{flex-direction:column-reverse;gap:26px}\n    .info{width:92%}\n    .monitor{width:92%}\n    .widgets{width:100%}\n  }\n</style>\n</head>\n<body>\n  <div class=\"sky\" aria-hidden=\"true\"></div>\n\n  <div class=\"stage\" role=\"main\" aria-label=\"Monitor concept visualization\">\n    <aside class=\"info\" aria-hidden=\"false\">\n      <div class=\"brand\">\n        <div class=\"logo\">MN</div>\n        <div class=\"title\">\n          <h1>Monitor</h1>\n          <p>Active observability & visual telemetry</p>\n        </div>\n      </div>\n\n      <div class=\"meta\">\n        <div class=\"stat\">\n          <small>Throughput</small>\n          <strong id=\"throughput\">3.6k/s</strong>\n        </div>\n        <div class=\"stat\">\n          <small>Latency (p95)</small>\n          <strong id=\"latency\">42 ms</strong>\n        </div>\n        <div class=\"stat\">\n          <small>Health</small>\n          <strong id=\"health\">98%</strong>\n        </div>\n      </div>\n\n      <div class=\"desc\">\n        An elegant, ambient monitor design that balances clarity with motion — a living surface for system telemetry and signal patterns. Observe the waveforms, gauges, and logs reflecting continuous activity.\n      </div>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button class=\"btn\" id=\"power\" aria-pressed=\"false\" title=\"Toggle power\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"display:block\">\n            <path d=\"M12 2v10\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <path d=\"M17.657 6.343A8 8 0 1 1 6.343 17.657\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n          Power\n        </button>\n\n        <button class=\"btn secondary\" id=\"snapshot\" title=\"Snapshot\">\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"display:block\">\n            <path d=\"M3 7h3l2-3h8l2 3h3v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <circle cx=\"12\" cy=\"13\" r=\"3\" stroke=\"currentColor\" stroke-width=\"1.4\"/>\n          </svg>\n          Snapshot\n        </button>\n      </div>\n\n    </aside>\n\n    <div class=\"monitor-wrap\" aria-hidden=\"false\">\n      <div class=\"monitor\" id=\"monitor\">\n        <div class=\"bezel\">\n          <div class=\"lamp\" aria-hidden=\"true\"></div>\n          <div class=\"screen\" role=\"img\" aria-label=\"Active monitoring display\">\n            <div class=\"panel\" style=\"flex:1 1 auto;\">\n              <div class=\"wave-wrap\">\n                <div class=\"wave-head\">\n                  <div class=\"chip\">IO</div>\n                  <div class=\"meta-text\">\n                    <small>Signal</small>\n                    <strong id=\"signalState\">Normal</strong>\n                  </div>\n                </div>\n\n                <div class=\"wave-svg\" aria-hidden=\"true\">\n                  <svg viewBox=\"0 0 1000 300\" preserveAspectRatio=\"none\">\n                    <!-- subtle grid -->\n                    <defs>\n                      <linearGradient id=\"grad1\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n                        <stop offset=\"0%\" stop-color=\"#4ee3d6\" stop-opacity=\"0.92\" />\n                        <stop offset=\"50%\" stop-color=\"#6f7bff\" stop-opacity=\"0.94\" />\n                        <stop offset=\"100%\" stop-color=\"#4ee3d6\" stop-opacity=\"0.9\" />\n                      </linearGradient>\n                      <linearGradient id=\"grad2\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"0%\">\n                        <stop offset=\"0%\" stop-color=\"#8eead0\" stop-opacity=\"0.7\" />\n                        <stop offset=\"100%\" stop-color=\"#c2c6ff\" stop-opacity=\"0.7\" />\n                      </linearGradient>\n                      <filter id=\"glow1\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n                        <feGaussianBlur stdDeviation=\"10\" result=\"coloredBlur\"/>\n                        <feMerge><feMergeNode in=\"coloredBlur\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n                      </filter>\n                    </defs>\n\n                    <!-- grid -->\n                    <g stroke=\"rgba(255,255,255,0.03)\" stroke-width=\"1\">\n                      <line class=\"grid-lines\" x1=\"0\" y1=\"30\" x2=\"1000\" y2=\"30\"></line>\n                      <line class=\"grid-lines\" x1=\"0\" y1=\"90\" x2=\"1000\" y2=\"90\"></line>\n                      <line class=\"grid-lines\" x1=\"0\" y1=\"150\" x2=\"1000\" y2=\"150\"></line>\n                      <line class=\"grid-lines\" x1=\"0\" y1=\"210\" x2=\"1000\" y2=\"210\"></line>\n                    </g>\n\n                    <!-- animated wave (two layers for depth) -->\n                    <g filter=\"url(#glow1)\">\n                      <path class=\"wave alt\" d=\"M0 150 C 60 120, 120 90, 180 160 S 300 220, 360 140 S 480 60, 540 140 S 660 220, 720 140 S 840 40, 900 140 S 980 240, 1000 150\"></path>\n                      <path class=\"wave\" d=\"M0 150 C 50 150, 110 150, 170 120 S 290 70, 350 140 S 470 220, 530 140 S 650 40, 710 160 S 830 220, 890 120 S 980 50, 1000 150\"></path>\n                    </g>\n\n                    <!-- floating points -->\n                    <g id=\"dots\" opacity=\"0.92\">\n                      <circle cx=\"120\" cy=\"133\" r=\"3.8\" fill=\"#6f7bff\" opacity=\"0.9\"/>\n                      <circle cx=\"236\" cy=\"150\" r=\"2.6\" fill=\"#4ee3d6\" opacity=\"0.95\"/>\n                      <circle cx=\"402\" cy=\"142\" r=\"2.8\" fill=\"#7fded1\" opacity=\"0.85\"/>\n                      <circle cx=\"678\" cy=\"162\" r=\"3.2\" fill=\"#aab0ff\" opacity=\"0.78\"/>\n                      <circle cx=\"812\" cy=\"152\" r=\"2.6\" fill=\"#6f7bff\" opacity=\"0.92\"/>\n                    </g>\n\n                  </svg>\n                </div>\n\n                <div class=\"scanline\" aria-hidden=\"true\"></div>\n              </div>\n\n              <div class=\"widgets\" style=\"min-width:260px;\">\n                <div class=\"widget\">\n                  <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n                    <small style=\"color:rgba(255,255,255,0.45)\">Performance</small>\n                    <strong style=\"font-size:13px;color:#dffffa\">Realtime</strong>\n                  </div>\n                  <div class=\"gauge\">\n                    <div class=\"radial\" aria-hidden=\"true\">\n                      <div class=\"core\" id=\"gaugeValue\">64%</div>\n                    </div>\n                    <div class=\"bar\">\n                      <div style=\"display:flex;align-items:center;justify-content:space-between;font-size:12px;color:rgba(255,255,255,0.45)\">\n                        <span>CPU</span><span style=\"font-weight:700;color:#dffffa\">61%</span>\n                      </div>\n                      <div class=\"rows\">\n                        <div class=\"col\"><div class=\"fill\" id=\"cpuFill\" style=\"transform:translateX(-39%);\"></div></div>\n                      </div>\n\n                      <div style=\"display:flex;align-items:center;justify-content:space-between;font-size:12px;color:rgba(255,255,255,0.45)\">\n                        <span>Memory</span><span style=\"font-weight:700;color:#dffffa\">72%</span>\n                      </div>\n                      <div class=\"rows\">\n                        <div class=\"col\"><div class=\"fill\" id=\"memFill\" style=\"transform:translateX(-28%);background:linear-gradient(90deg,#6f7bff,#4ee3d6);\"></div></div>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                <div class=\"widget\">\n                  <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n                    <small style=\"color:rgba(255,255,255,0.45)\">Activity Log</small>\n                    <strong style=\"font-size:12px;color:#dffffa\">live</strong>\n                  </div>\n                  <div class=\"logs\" id=\"logs\" aria-live=\"polite\">\n                    <p>• 14:23:18 — recv: 3.2k items/s · OK</p>\n                    <p>• 14:23:21 — route: /api/ingest · 200</p>\n                    <p>• 14:23:27 — alert: latency spike · resolved</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"flash\" id=\"flash\"></div>\n          <div class=\"mark\">MONITOR</div>\n\n        </div>\n\n        <div class=\"stand\" aria-hidden=\"true\">\n          <div class=\"neck\"></div>\n          <div class=\"foot\"></div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n\n<script>\n  // Create decorative particles\n  (function createParticles(){\n    const sky = document.querySelector('.sky');\n    const n = 22;\n    for(let i=0;i<n;i++){\n      const p = document.createElement('div');\n      p.className='particle';\n      const left = Math.random()*100;\n      const size = 3 + Math.random()*9;\n      p.style.left = left+'%';\n      p.style.bottom = -10 - Math.random()*200 + 'px';\n      p.style.width = p.style.height = size+'px';\n      p.style.opacity = (0.18 + Math.random()*0.7).toFixed(2);\n      p.style.animationDuration = (14 + Math.random()*26) + 's';\n      p.style.animationDelay = -(Math.random()*26) + 's';\n      sky.appendChild(p);\n    }\n  })();\n\n  // Simple interactions: power toggle and snapshot\n  const monitor = document.getElementById('monitor');\n  const powerBtn = document.getElementById('power');\n  const snapshot = document.getElementById('snapshot');\n  const flash = document.getElementById('flash');\n  const gaugeValue = document.getElementById('gaugeValue');\n  const cpuFill = document.getElementById('cpuFill');\n  const memFill = document.getElementById('memFill');\n  const logs = document.getElementById('logs');\n  const throughput = document.getElementById('throughput');\n  const latency = document.getElementById('latency');\n  const health = document.getElementById('health');\n  const signalState = document.getElementById('signalState');\n\n  let on = true;\n  powerBtn.addEventListener('click', ()=>{\n    on = !on;\n    if(!on){\n      monitor.classList.add('off');\n      powerBtn.setAttribute('aria-pressed','true');\n      powerBtn.style.opacity = '.92';\n    } else {\n      monitor.classList.remove('off');\n      powerBtn.setAttribute('aria-pressed','false');\n    }\n  });\n\n  snapshot.addEventListener('click', ()=>{\n    // simple flash animation\n    flash.classList.remove('ignite');\n    // force reflow to restart\n    void flash.offsetWidth;\n    flash.classList.add('ignite');\n\n    // small visual pulse on monitor\n    monitor.animate([\n      { transform: 'scale(1)'},\n      { transform: 'scale(0.996)'},\n      { transform: 'scale(1)'}\n    ], {duration:320, easing:'ease-out'});\n\n    // append a log line\n    const now = new Date();\n    const hh = String(now.getHours()).padStart(2,'0');\n    const mm = String(now.getMinutes()).padStart(2,'0');\n    const ss = String(now.getSeconds()).padStart(2,'0');\n    const p = document.createElement('p');\n    p.textContent = `• ${hh}:${mm}:${ss} — snapshot saved · success`;\n    logs.prepend(p);\n    // keep only latest 6\n    while(logs.children.length>6) logs.removeChild(logs.lastChild);\n  });\n\n  // subtle live simulation (non-interactive)\n  (function simulate(){\n    function rand(min,max){return Math.floor(min + Math.random()*(max-min+1))}\n    setInterval(()=>{\n      // random small fluctuations\n      const cpu = rand(42,74);\n      const mem = rand(55,82);\n      const gauge = Math.round((cpu*0.6 + mem*0.4));\n      gaugeValue.textContent = gauge + '%';\n      cpuFill.style.transform = `translateX(-${100-cpu}%)`;\n      memFill.style.transform = `translateX(-${100-mem}%)`;\n\n      // update throughput/latency/health pseudo-randomly\n      throughput.textContent = (3 + Math.random()*2.4).toFixed(1) + 'k/s';\n      latency.textContent = (30 + Math.floor(Math.random()*50)) + ' ms';\n      health.textContent = (96 + Math.floor(Math.random()*4)) + '%';\n\n      const state = gauge > 75 ? 'High' : (gauge < 50 ? 'Low' : 'Normal');\n      signalState.textContent = state;\n\n      // occasionally push a log\n      if(Math.random() < 0.28){\n        const now = new Date();\n        const hh = String(now.getHours()).padStart(2,'0');\n        const mm = String(now.getMinutes()).padStart(2,'0');\n        const ss = String(now.getSeconds()).padStart(2,'0');\n        const messages = [\n          'route: /api/ingest · 200',\n          'recv buffer stable',\n          'commit: new snapshot',\n          'gc: cycle complete',\n          'alert: latency spike · resolved',\n          'autoscale triggered · +2 nodes'\n        ];\n        const p = document.createElement('p');\n        p.textContent = `• ${hh}:${mm}:${ss} — ${messages[Math.floor(Math.random()*messages.length)]}`;\n        logs.prepend(p);\n        while(logs.children.length>6) logs.removeChild(logs.lastChild);\n      }\n    }, 2400);\n  })();\n\n  // small accessibility: toggle with keyboard\n  powerBtn.addEventListener('keydown', (e)=>{\n    if(e.key === 'Enter' || e.key === ' '){\n      e.preventDefault();\n      powerBtn.click();\n    }\n  });\n  snapshot.addEventListener('keydown', (e)=>{\n    if(e.key === 'Enter' || e.key === ' '){\n      e.preventDefault();\n      snapshot.click();\n    }\n  });\n\n  // initial subtle entrance animations\n  window.addEventListener('load', ()=>{\n    document.querySelectorAll('.monitor, .info').forEach((el,i)=>{\n      el.animate([\n        {opacity:0, transform:'translateY(14px) scale(.996)'},\n        {opacity:1, transform:'translateY(0) scale(1)'}\n      ], {duration:700 + i*120, easing:'cubic-bezier(.2,.9,.3,1)', fill:'forwards'});\n    });\n  });\n</script>\n</body>\n</html>"
