    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Big-Theta Notation — Visualized Elegance</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;700&family=Playfair+Display&display=swap');\n  /* Root and reset */\n  * {\n    box-sizing: border-box;\n    margin: 0; padding: 0;\n  }\n  html, body {\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Fira Sans', sans-serif;\n    color: #e0e6f0;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n  body {\n    display: flex;\n    flex-direction: column;\n    min-height: 100vh;\n  }\n  /* Container */\n  .container {\n    max-width: 980px;\n    margin: 3.5rem auto 5rem;\n    padding: 0 1.5rem;\n    text-align: center;\n    position: relative;\n    user-select: none;\n  }\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.75rem;\n    letter-spacing: 0.04em;\n    margin-bottom: 0.25em;\n    color: #f2f6ff;\n    text-shadow:\n      0 0 12px #89cff0aa,\n      0 0 24px #00a1ffcc;\n    line-height: 1.1;\n  }\n  h2 {\n    font-weight: 400;\n    font-size: 1.125rem;\n    color: #a8bbd5aa;\n    margin-bottom: 2.75rem;\n    font-style: italic;\n    font-family: 'Fira Sans', sans-serif;\n  }\n\n  /* Big Theta formula in serif monospace style */\n  .notation {\n    font-family: 'Fira Mono', monospace;\n    font-weight: 700;\n    font-size: 3rem;\n    color: #12d8fa;\n    text-shadow:\n      0 0 10px #12d8faaa,\n      0 0 30px #00a1ffdd;\n    margin-bottom: 1rem;\n    letter-spacing: 0.02em;\n  }\n  .subtext {\n    font-size: 1.125rem;\n    color: #b7c5e9dd;\n    max-width: 600px;\n    margin: 0 auto 3.5rem;\n    line-height: 1.4;\n  }\n\n  /* Animated graph container */\n  .graph-container {\n    position: relative;\n    width: 100%;\n    max-width: 720px;\n    height: 420px;\n    margin: 0 auto 4.5rem;\n    background:\n      radial-gradient(circle at 40% 90%, #111b2b, transparent 40%),\n      radial-gradient(circle at 90% 10%, #144e7c88, transparent 30%),\n      radial-gradient(circle at 25% 15%, #2e90ff55, transparent 35%);\n    border-radius: 1.25rem;\n    box-shadow:\n      0 0 30px #005ea0cc,\n      inset 0 0 48px #1177dbcc;\n    overflow: visible;\n  }\n\n  svg {\n    display: block;\n    margin: 0 auto;\n    width: 100%;\n    height: 100%;\n    overflow: visible;\n  }\n\n  /* Axes Styling */\n  .axis {\n    stroke: #9fb6d4cc;\n    stroke-width: 2;\n    shape-rendering: geometricPrecision;\n  }\n  .grid-line {\n    stroke: #58718c44;\n    stroke-width: 1;\n    vector-effect: non-scaling-stroke;\n  }\n  .grid-text {\n    fill: #7d8db2aa;\n    font-family: 'Fira Sans', sans-serif;\n    font-size: 0.75rem;\n    user-select: none;\n  }\n\n  /* Graph lines */\n  .function-line {\n    fill: none;\n    stroke-width: 3;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 6px);\n  }\n  /* Theta bounding lines */\n  .lower-bound {\n    stroke: #1ee3ff;\n    stroke-dasharray: 14 12;\n    opacity: 0.8;\n    filter: drop-shadow(0 0 14px #1cc7ffdd);\n  }\n  .upper-bound {\n    stroke: #12d8fa;\n    stroke-dasharray: 8 14;\n    opacity: 0.9;\n    filter: drop-shadow(0 0 14px #12d8fadd);\n  }\n  /* Main function */\n  .main-f {\n    stroke: #ffd05b;\n    filter: drop-shadow(0 0 12px #ffcb47cc);\n    opacity: 1;\n  }\n\n  /* Colors legend */\n  .legend {\n    display: flex;\n    justify-content: center;\n    gap: 2.5rem;\n    margin-top: 0.2rem;\n    user-select: none;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 0.4rem;\n    font-size: 1rem;\n    color: #d6dbf2cc;\n    font-weight: 500;\n    text-shadow: 0 0 3px #5a84baaa;\n  }\n  .legend-color {\n    width: 22px;\n    height: 5px;\n    border-radius: 3px;\n    box-shadow: 0 0 8px #4689d8cc;\n  }\n  .color-lower {\n    background: #1ee3ff;\n  }\n  .color-upper {\n    background: #12d8fa;\n  }\n  .color-main {\n    background: #ffd05b;\n  }\n\n  /* Explanation box */\n  .explanation {\n    max-width: 640px;\n    margin: 0 auto;\n    font-size: 1.125rem;\n    line-height: 1.6;\n    color: #cad1e8ee;\n    font-weight: 500;\n    background: #1a2a48ee;\n    border-radius: 0.75rem;\n    padding: 1.75rem 2rem;\n    box-shadow:\n      inset 0 0 14px #1e4cc844,\n      0 0 24px #1e4cc877;\n    letter-spacing: 0.02em;\n    user-select: text;\n  }\n\n  /* Buttons container */\n  .btnbar {\n    margin-top: 3rem;\n    display: flex;\n    justify-content: center;\n    gap: 2.5rem;\n  }\n  /* Simple elegant buttons */\n  button {\n    background: linear-gradient(145deg, #264a72, #1b2d4d);\n    border: none;\n    border-radius: 0.6rem;\n    padding: 0.45rem 1.35rem;\n    font-size: 1rem;\n    font-family: 'Fira Sans', sans-serif;\n    font-weight: 600;\n    color: #c4d1f2cc;\n    cursor: pointer;\n    box-shadow:\n      inset 2px 2px 6px #1d3a62,\n      2px 2px 9px #1a2c4bac;\n    transition:\n      box-shadow 0.3s ease,\n      color 0.3s ease;\n    letter-spacing: 0.04em;\n    user-select: none;\n    text-shadow: 0 0 4px #12385dcc;\n  }\n  button:hover, button:focus {\n    color: #a8cdf9;\n    box-shadow:\n      inset 3px 3px 10px #1465c3,\n      3px 3px 15px #2f68e6bb;\n    outline: none;\n  }\n  button:active {\n    transform: translateY(1px);\n    box-shadow:\n      inset 1px 1px 4px #11365b,\n      1px 1px 5px #1b3173cc;\n  }\n\n  /* Animated glow on notation */\n  @keyframes subtleGlow {\n    0%, 100% {\n      text-shadow:\n        0 0 10px #12d8faaa,\n        0 0 30px #00a1ffcc;\n      color: #12d8fa;\n    }\n    50% {\n      text-shadow:\n        0 0 20px #3dceffee,\n        0 0 50px #00baffee;\n      color: #4fc8ff;\n    }\n  }\n  .notation {\n    animation: subtleGlow 6s ease-in-out infinite;\n  }\n\n  /* Tooltip on hover for notation */\n  .notation[title] {\n    cursor: help;\n    position: relative;\n  }\n  .notation[title]:hover::after {\n    content: attr(title);\n    position: absolute;\n    bottom: 110%;\n    left: 50%;\n    transform: translateX(-50%);\n    background: rgba(18, 216, 250, 0.95);\n    color: #003f5c;\n    font-weight: 700;\n    font-family: 'Fira Sans', sans-serif;\n    font-size: 0.85rem;\n    padding: 0.3rem 0.8rem;\n    border-radius: 0.3rem;\n    white-space: nowrap;\n    pointer-events: none;\n    user-select: none;\n    box-shadow:\n      0 0 14px rgba(18, 216, 250, 0.8);\n    z-index: 10;\n  }\n</style>\n</head>\n<body>\n  <main class=\"container\" role=\"main\" aria-label=\"Big-Theta Notation visualization\">\n    <h1>Big-Theta Notation <span aria-hidden=\"true\">Θ</span></h1>\n    <h2 class=\"notation\" title=\"f(n) is bounded both above and below asymptotically by g(n)\">&nbsp;&Theta;(g(n)) = \\{ f(n) : f(n) \\text{ grows asymptotically as } g(n) \\}</h2>\n    <p class=\"subtext\" aria-live=\"polite\">\n      Big-Theta notation (Θ) characterizes an asymptotically tight bound on the growth rate of a function.<br />\n      It means an algorithm’s running time grows at the exact same rate, both upper and lower bounded by the given function.\n    </p>\n\n    <section class=\"graph-container\" aria-label=\"Graph visualizing Big-Theta bounds and main function\">\n      <svg viewBox=\"0 0 720 420\" role=\"img\" aria-labelledby=\"title desc\" >\n        <title id=\"title\">Graph showing functions and their Big-Theta bounds</title>\n        <desc id=\"desc\">Coordinate axes with three curves: lower bound, main function, upper bound.</desc>\n        <!-- Axes -->\n        <line class=\"axis\" x1=\"60\" y1=\"360\" x2=\"660\" y2=\"360\" />\n        <line class=\"axis\" x1=\"60\" y1=\"360\" x2=\"60\" y2=\"40\" />\n        <!-- Grid lines and labels on X (n) -->\n        <g aria-hidden=\"true\" >\n          <line class=\"grid-line\" x1=\"180\" y1=\"360\" x2=\"180\" y2=\"40\" />\n          <line class=\"grid-line\" x1=\"300\" y1=\"360\" x2=\"300\" y2=\"40\" />\n          <line class=\"grid-line\" x1=\"420\" y1=\"360\" x2=\"420\" y2=\"40\" />\n          <line class=\"grid-line\" x1=\"540\" y1=\"360\" x2=\"540\" y2=\"40\" />\n          <text class=\"grid-text\" x=\"60\" y=\"380\" text-anchor=\"middle\" dominant-baseline=\"hanging\">0</text>\n          <text class=\"grid-text\" x=\"180\" y=\"380\" text-anchor=\"middle\" dominant-baseline=\"hanging\">n=10</text>\n          <text class=\"grid-text\" x=\"300\" y=\"380\" text-anchor=\"middle\" dominant-baseline=\"hanging\">n=20</text>\n          <text class=\"grid-text\" x=\"420\" y=\"380\" text-anchor=\"middle\" dominant-baseline=\"hanging\">n=30</text>\n          <text class=\"grid-text\" x=\"540\" y=\"380\" text-anchor=\"middle\" dominant-baseline=\"hanging\">n=40</text>\n\n          <!-- Grid lines and labels on Y (time) -->\n          <line class=\"grid-line\" x1=\"60\" y1=\"300\" x2=\"660\" y2=\"300\" />\n          <line class=\"grid-line\" x1=\"60\" y1=\"240\" x2=\"660\" y2=\"240\" />\n          <line class=\"grid-line\" x1=\"60\" y1=\"180\" x2=\"660\" y2=\"180\" />\n          <line class=\"grid-line\" x1=\"60\" y1=\"120\" x2=\"660\" y2=\"120\" />\n          <line class=\"grid-line\" x1=\"60\" y1=\"60\"  x2=\"660\" y2=\"60\" />\n          <text class=\"grid-text\" x=\"38\" y=\"360\" text-anchor=\"end\" dominant-baseline=\"middle\">0</text>\n          <text class=\"grid-text\" x=\"38\" y=\"300\" text-anchor=\"end\" dominant-baseline=\"middle\">10k</text>\n          <text class=\"grid-text\" x=\"38\" y=\"240\" text-anchor=\"end\" dominant-baseline=\"middle\">20k</text>\n          <text class=\"grid-text\" x=\"38\" y=\"180\" text-anchor=\"end\" dominant-baseline=\"middle\">30k</text>\n          <text class=\"grid-text\" x=\"38\" y=\"120\" text-anchor=\"end\" dominant-baseline=\"middle\">40k</text>\n          <text class=\"grid-text\" x=\"38\" y=\"60\"  text-anchor=\"end\" dominant-baseline=\"middle\">50k</text>\n          <text class=\"grid-text\" x=\"38\" y=\"40\"  text-anchor=\"end\" dominant-baseline=\"middle\">60k</text>\n          <!-- Axis labels -->\n          <text class=\"grid-text\" x=\"660\" y=\"390\" aria-hidden=\"true\" font-weight=\"700\" fill=\"#a1baffcc\">Input size n →</text>\n          <text class=\"grid-text\" x=\"20\" y=\"40\" aria-hidden=\"true\" font-weight=\"700\" fill=\"#a1baffcc\" transform=\"rotate(-90 20,40)\">Running Time T(n) →</text>\n        </g>\n\n        <!-- Curves: we'll plot three parametric lines -->\n        <path id=\"lowerBound\" class=\"function-line lower-bound\" d=\"\"/>\n        <path id=\"upperBound\" class=\"function-line upper-bound\" d=\"\"/>\n        <path id=\"mainFunc\" class=\"function-line main-f\" d=\"\"/>\n      </svg>\n      <div class=\"legend\" aria-label=\"Legend for graph lines\">\n        <div class=\"legend-item\"><span class=\"legend-color color-lower\"></span> Lower Bound (c₁·g(n))</div>\n        <div class=\"legend-item\"><span class=\"legend-color color-main\"></span> Main Function f(n)</div>\n        <div class=\"legend-item\"><span class=\"legend-color color-upper\"></span> Upper Bound (c₂·g(n))</div>\n      </div>\n    </section>\n\n    <p class=\"explanation\" id=\"explanation\" aria-live=\"polite\">\n      The function <code>f(n)</code> is bounded below and above by the functions <code>c₁·g(n)</code> and <code>c₂·g(n)</code> respectively, for sufficiently large <code>n</code>.<br />\n      This visually expresses Big-Theta, showing that <code>f(n)</code> grows “tightly” within those bounds, defining the exact asymptotic rate.\n    </p>\n\n    <nav class=\"btnbar\" aria-label=\"Controls\">\n      <button id=\"toggleLinear\" aria-pressed=\"false\" aria-label=\"Switch graph between quadratic and linear scales\">Toggle Function Type</button>\n      <button id=\"toggleDark\" aria-pressed=\"false\" aria-label=\"Toggle to light color scheme\">Toggle Light/Dark Mode</button>\n    </nav>\n  </main>\n\n<script>\n/**\n * We will draw three cubic Bezier approximated curves representing:\n * Lower bound: c₁·g(n)\n * Main function: f(n)\n * Upper bound: c₂·g(n)\n * \n * We implement two function types for demonstration:\n * 1) Quadratic growth: g(n) = n²  (default)\n * 2) Linear growth: g(n) = n\n * \n * For realistic aesthetics, points and smooth curves, we plot sampled points and connect.\n */\n\n(function(){\n  'use strict';\n\n  const svgWidth = 720;\n  const svgHeight = 420;\n  const margin = { top: 40, right: 60, bottom: 60, left: 60 };\n  const plotWidth = svgWidth - margin.left - margin.right;  // 600\n  const plotHeight = svgHeight - margin.top - margin.bottom; // 320\n\n  // Scaling helper\n  function scaleX(n, maxN) {\n    return margin.left + (n / maxN) * plotWidth;\n  }\n  function scaleY(t, maxT) {\n    return margin.top + plotHeight - (t / maxT) * plotHeight;\n  }\n\n  // Functions for g(n), c1*g(n), c2*g(n), and main f(n)\n  // f(n) will be in between c1*g(n) and c2*g(n)\n\n  // Default parameters:\n  // c1 = 0.7, c2 = 1.3\n  // n range: 0 to maxN (40)\n  // We'll generate 80 points for smoothness.\n\n  // Function variants:\n  const functions = {\n    quadratic: {\n      g: (n) => n*n,\n      f: (n) => 0.9*n*n + 12*n + 40,  // slight offset, close shape\n      c1: 0.7,\n      c2: 1.3,\n      maxN: 40,\n      maxT: 60*60,  // approx max g(n) * c2\n    },\n    linear: {\n      g: (n) => n,\n      f: (n) => 1.1*n + 6*Math.sin(0.3*n) + 8,\n      c1: 0.7,\n      c2: 1.3,\n      maxN: 80,\n      maxT: 120, // because g(n) * c2 up to 80 * 1.3 = 104 max, with margin\n    }\n  };\n\n  // State\n  let currentFunc = 'quadratic';\n  let darkMode = true;\n\n  const lowerBoundPath = document.getElementById('lowerBound');\n  const upperBoundPath = document.getElementById('upperBound');\n  const mainFuncPath = document.getElementById('mainFunc');\n  const toggleBtn = document.getElementById('toggleLinear');\n  const toggleDarkBtn = document.getElementById('toggleDark');\n  const explanation = document.getElementById('explanation');\n\n  // Generate path data for a function f(n) over 0...maxN sampled points\n  function generatePath(f, maxN, maxT, steps = 80) {\n    const pts = [];\n    for(let i = 0; i <= steps; i++) {\n      let n = (i / steps) * maxN;\n      let t = f(n);\n      if(t > maxT) t = maxT;\n      pts.push([scaleX(n, maxN), scaleY(t, maxT)]);\n    }\n    return smoothPath(pts);\n  }\n\n  // Smooth path generator using Catmull-Rom splines approximation with Bezier\n  // Reference: https://www.iquilezles.org/www/articles/catmullrom/catmullrom.htm\n\n  function smoothPath(points) {\n    if(points.length < 2) return '';\n    let d = `M${points[0][0].toFixed(2)} ${points[0][1].toFixed(2)}`;\n    for(let i = 0; i < points.length - 1; i++) {\n      const p0 = points[i === 0 ? i : i-1];\n      const p1 = points[i];\n      const p2 = points[i+1];\n      const p3 = points[i+2 >= points.length ? points.length -1 : i+2];\n\n      const cp1x = p1[0] + (p2[0] - p0[0]) / 6;\n      const cp1y = p1[1] + (p2[1] - p0[1]) / 6;\n      const cp2x = p2[0] - (p3[0] - p1[0]) / 6;\n      const cp2y = p2[1] - (p3[1] - p1[1]) / 6;\n\n      d += ` C${cp1x.toFixed(2)} ${cp1y.toFixed(2)},${cp2x.toFixed(2)} ${cp2y.toFixed(2)},${p2[0].toFixed(2)} ${p2[1].toFixed(2)}`;\n    }\n    return d;\n  }\n\n  // Update paths for current function set\n  function updateGraph() {\n    const {g, f, c1, c2, maxN, maxT} = functions[currentFunc];\n\n    const lowerF = (n) => c1 * g(n);\n    const upperF = (n) => c2 * g(n);\n\n    const lowerPath = generatePath(lowerF, maxN, maxT);\n    const upperPath = generatePath(upperF, maxN, maxT);\n    const mainPath = generatePath(f, maxN, maxT);\n\n    lowerBoundPath.setAttribute('d', lowerPath);\n    upperBoundPath.setAttribute('d', upperPath);\n    mainFuncPath.setAttribute('d', mainPath);\n\n    // Update axis grid and labels dynamically for better fit\n    // For simplicity, update only the bottom X labels and left Y labels\n\n    const svg = lowerBoundPath.ownerSVGElement;\n    const gridGroup = svg.querySelector('g');\n    // Clear previous grid lines and labels (except axes lines)\n    while(gridGroup.firstChild) gridGroup.removeChild(gridGroup.firstChild);\n\n    // Draw vertical grid lines and labels on X-axis\n    const xTicksCount = 5;\n    for(let i=0; i<=xTicksCount; i++) {\n      const nVal = (i/xTicksCount)*maxN;\n      const x = scaleX(nVal, maxN);\n      const line = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n      line.setAttribute(\"class\", \"grid-line\");\n      line.setAttribute(\"x1\", x);\n      line.setAttribute(\"y1\", margin.top);\n      line.setAttribute(\"x2\", x);\n      line.setAttribute(\"y2\", svgHeight - margin.bottom);\n      gridGroup.appendChild(line);\n\n      const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n      text.setAttribute(\"class\",\"grid-text\");\n      text.setAttribute(\"x\", x);\n      text.setAttribute(\"y\", svgHeight - margin.bottom + 20);\n      text.setAttribute(\"text-anchor\", \"middle\");\n      text.setAttribute(\"dominant-baseline\", \"hanging\");\n      if(currentFunc === 'quadratic') {\n        text.textContent = `n=${Math.round(nVal)}`;\n      } else {\n        text.textContent = `n=${Math.round(nVal)}`;\n      }\n      gridGroup.appendChild(text);\n    }\n\n    // Draw horizontal grid lines and labels on Y-axis\n    // For Y, split maxT into 6 segments\n    const ySegments = 6;\n    const yStep = maxT / ySegments;\n\n    for(let i=0; i<=ySegments; i++) {\n      const yVal = i * yStep;\n      const y = scaleY(yVal, maxT);\n      const line = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n      line.setAttribute(\"class\", \"grid-line\");\n      line.setAttribute(\"x1\", margin.left);\n      line.setAttribute(\"y1\", y);\n      line.setAttribute(\"x2\", svgWidth - margin.right);\n      line.setAttribute(\"y2\", y);\n      gridGroup.appendChild(line);\n\n      const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n      text.setAttribute(\"class\",\"grid-text\");\n      text.setAttribute(\"x\", margin.left - 10);\n      text.setAttribute(\"y\", y);\n      text.setAttribute(\"text-anchor\", \"end\");\n      text.setAttribute(\"dominant-baseline\", \"middle\");\n\n      // Format yVal\n      const suffix = currentFunc === 'quadratic' ? 'k' : '';\n      // Convert big numbers into k-scale for quadratic case:\n      const displayVal = currentFunc === 'quadratic' ? Math.round(yVal/1000) + suffix : Math.round(yVal) + suffix;\n      text.textContent = displayVal;\n      gridGroup.appendChild(text);\n    }\n\n    // Update explanation text for current function\n    if(currentFunc === \"quadratic\") {\n      explanation.innerHTML = `The function <code>f(n)</code> is bounded below and above by two quadratic functions, <code>c₁·n²</code> and <code>c₂·n²</code>, for sufficiently large <code>n</code>.<br />\n      This visually expresses Big-Theta for quadratic growth, showing that <code>f(n)</code> grows tightly within those bounds, defining the exact asymptotic rate.`;\n      toggleBtn.textContent = \"Toggle Function Type: Quadratic\";\n      toggleBtn.setAttribute(\"aria-pressed\", \"true\");\n    } else {\n      explanation.innerHTML = `The function <code>f(n)</code> is bounded below and above by two linear functions, <code>c₁·n</code> and <code>c₂·n</code>, for sufficiently large <code>n</code>.<br />\n      This visually expresses Big-Theta for linear growth, showing that <code>f(n)</code> grows tightly within those bounds, an exact asymptotic rate.`;\n      toggleBtn.textContent = \"Toggle Function Type: Linear\";\n      toggleBtn.setAttribute(\"aria-pressed\", \"false\");\n    }\n  }\n\n  // Initialize graph\n  updateGraph();\n\n  // Button events\n  toggleBtn.addEventListener(\"click\", () => {\n    if(currentFunc === \"quadratic\") {\n      currentFunc = \"linear\";\n    } else {\n      currentFunc = \"quadratic\";\n    }\n    updateGraph();\n  });\n\n  // Dark / Light mode toggle\n\n  toggleDarkBtn.addEventListener(\"click\", () => {\n    darkMode = !darkMode;\n    if(darkMode) {\n      document.body.style.background = \"linear-gradient(135deg, #0f2027, #203a43, #2c5364)\";\n      document.body.style.color = \"#e0e6f0\";\n      toggleDarkBtn.textContent = \"Toggle Light/Dark Mode\";\n      toggleDarkBtn.setAttribute(\"aria-pressed\", \"false\");\n    } else {\n      document.body.style.background = \"linear-gradient(135deg, #f1f5fe, #d0d9f2, #a8bff7)\";\n      document.body.style.color = \"#333\";\n      toggleDarkBtn.textContent = \"Toggle Dark/Light Mode\";\n      toggleDarkBtn.setAttribute(\"aria-pressed\", \"true\");\n    }\n  });\n\n  // Accessibility note: we keep aria-live polite on explanations to reflect changes\n})();\n</script>\n</body>\n</html>"
  },
