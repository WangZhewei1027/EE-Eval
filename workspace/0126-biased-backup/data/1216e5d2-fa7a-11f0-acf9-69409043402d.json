    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interpreter Demonstration</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea, input[type=text] {\n    width: 100%;\n    box-sizing: border-box;\n    font-family: monospace, monospace;\n    font-size: 14px;\n  }\n  .row {\n    margin: 0.5em 0;\n  }\n  label {\n    display: block;\n  }\n  button {\n    margin: 0.25em 0.25em 0.25em 0;\n  }\n  #output {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    min-height: 6em;\n    padding: 0.5em;\n    margin-top: 0.5em;\n    overflow-y: auto;\n  }\n  select {\n    font-family: monospace, monospace;\n  }\n  #stepInfo {\n    margin-top: 0.3em;\n    font-size: 0.9em;\n  }\n</style>\n</head>\n<body>\n\n<h1>Interactive Interpreter Demo</h1>\n\n<p>This is a simple, but feature-rich interpreter for a minimal imperative language with variables, arithmetic, conditionals, loops, input/output, and functions. You can write code below, run, step through, inspect state, and manipulate variables.</p>\n\n<label for=\"codeArea\">Enter your program code:</label>\n<textarea id=\"codeArea\" rows=\"15\" spellcheck=\"false\">\n// Sample program:\n// Computes factorial of input number n\nprint \"Enter a number:\";\nn = input();\nfact = 1;\ni = 1;\nwhile (i <= n) {\n  fact = fact * i;\n  i = i + 1;\n}\nprint \"Factorial is:\";\nprint fact;\n</textarea>\n\n<div class=\"row\">\n  <button id=\"btnReset\">Reset Environment</button>\n  <button id=\"btnRun\">Run to End</button>\n  <button id=\"btnStep\">Step</button>\n  <button id=\"btnPause\">Pause</button>\n  <button id=\"btnResetStack\">Reset Call Stack</button>\n  <button id=\"btnClearOutput\">Clear Output</button>\n</div>\n\n<div class=\"row\">\n  <label for=\"speedSlider\">Auto-run speed (step delay ms): <span id=\"speedVal\">500</span></label>\n  <input type=\"range\" id=\"speedSlider\" min=\"50\" max=\"2000\" step=\"50\" value=\"500\" />\n</div>\n\n<div class=\"row\">\n  <label for=\"inputValue\">Provide Input value(s) (comma-separated):</label>\n  <input type=\"text\" id=\"inputValue\" placeholder=\"e.g. 5\" />\n  <button id=\"btnAddInput\">Add Input(s)</button>\n  <button id=\"btnClearInputBuffer\">Clear Input Buffer</button>\n</div>\n\n<div class=\"row\">\n<label for=\"varSelect\">Inspect Variables</label>\n<select id=\"varSelect\" size=\"6\" style=\"width: 100%;\"></select>\n<div id=\"varDetails\"></div>\n</div>\n\n<div class=\"row\">\n<label for=\"callStack\">Call Stack</label>\n<select id=\"callStack\" size=\"6\" style=\"width:100%;\"></select>\n<div id=\"stackDetails\"></div>\n</div>\n\n<label for=\"output\">Program Output:</label>\n<div id=\"output\" tabindex=\"0\" aria-label=\"Program output console\" role=\"region\"></div>\n\n<script>\n(() => {\n  \"use strict\";\n\n  // === Language Grammar & Features ===\n  // Minimal imperative language:\n  // Statements:\n  //   - variable assignment: x = expr;\n  //   - print expr;\n  //   - input() returns integer input from buffer\n  //   - if (expr) { stmts } else { stmts }\n  //   - while (expr) { stmts }\n  //   - function f(args) { stmts }\n  //   - return expr;\n  // Expressions:\n  //   - integer literals\n  //   - variables\n  //   - arithmetic + - * / %\n  //   - parentheses\n  //   - comparison operators: == != < <= > >=\n  //   - logical: && || ! (short circuit)\n  //   - function calls: f(expr, ...)\n  //\n  // This interpreter supports local variable scopes+stack frames.\n  //\n  // INPUT is fed by user into input buffer; input() reads next value or waits.\n  // PRINT outputs text/numbers.\n\n  // === Lexer ===\n  // Token types: IDENT, NUMBER, STRING, SYMBOL, KEYWORD, EOF\n\n  class Lexer {\n    constructor(input) {\n      this.input = input;\n      this.pos = 0;\n      this.len = input.length;\n      this.line = 1;\n      this.col = 1;\n      this.currentChar = input[0] || null;\n\n      this.keywords = new Set([\n        \"if\", \"else\", \"while\", \"print\", \"input\", \"function\", \"return\", \"true\", \"false\"\n      ]);\n    }\n    advance() {\n      if (this.currentChar === \"\\n\") {\n        this.line++;\n        this.col = 0;\n      }\n      this.pos++;\n      this.col++;\n      this.currentChar = this.pos < this.len ? this.input[this.pos] : null;\n    }\n    skipWhitespaceAndComments() {\n      while (this.currentChar !== null) {\n        if (this.currentChar === \" \" || this.currentChar === \"\\t\" || this.currentChar === \"\\n\" || this.currentChar === \"\\r\") {\n          this.advance();\n        } else if (this.currentChar === \"/\" && this.peek() === \"/\") {\n          // comment to end of line\n          while (this.currentChar !== null && this.currentChar !== \"\\n\") {\n            this.advance();\n          }\n        } else {\n          break;\n        }\n      }\n    }\n    peek() {\n      return this.pos + 1 < this.len ? this.input[this.pos + 1] : null;\n    }\n    number() {\n      let numStr = \"\";\n      while (this.currentChar !== null && /[0-9]/.test(this.currentChar)) {\n        numStr += this.currentChar;\n        this.advance();\n      }\n      return { type: \"NUMBER\", value: parseInt(numStr, 10) };\n    }\n    identifierOrKeyword() {\n      let id = \"\";\n      while (this.currentChar !== null && /[a-zA-Z0-9_]/.test(this.currentChar)) {\n        id += this.currentChar;\n        this.advance();\n      }\n      if (this.keywords.has(id)) {\n        return { type: \"KEYWORD\", value: id };\n      }\n      return { type: \"IDENT\", value: id };\n    }\n    stringLiteral() {\n      // strings quoted with \" only\n      let str = \"\";\n      this.advance(); // skip opening quote\n      while (this.currentChar !== null && this.currentChar !== '\"') {\n        if (this.currentChar === \"\\\\\") {\n          this.advance();\n          if (this.currentChar === \"n\") str += \"\\n\";\n          else if (this.currentChar === \"t\") str += \"\\t\";\n          else if (this.currentChar === '\"') str += '\"';\n          else if (this.currentChar === \"\\\\\") str += \"\\\\\";\n          else str += this.currentChar;\n          this.advance();\n        } else {\n          str += this.currentChar;\n          this.advance();\n        }\n      }\n      if (this.currentChar === '\"') {\n        this.advance();\n      } else {\n        throw new Error(`Unterminated string literal at line ${this.line}`);\n      }\n      return { type: \"STRING\", value: str };\n    }\n    symbol() {\n      // Multi-char symbols: ==, !=, <=, >=, &&, ||\n      // Single char: + - * / % = ; , ( ) { } ! < >\n      let ch = this.currentChar;\n      let twoChar = ch + (this.peek() || \"\");\n\n      const multiCharSymbols = [\"==\", \"!=\", \"<=\", \">=\", \"&&\", \"||\"];\n      if (multiCharSymbols.includes(twoChar)) {\n        this.advance();\n        this.advance();\n        return { type: \"SYMBOL\", value: twoChar };\n      }\n      this.advance();\n      return { type: \"SYMBOL\", value: ch };\n    }\n    getNextToken() {\n      this.skipWhitespaceAndComments();\n      if (this.currentChar === null) return { type: \"EOF\" };\n\n      if (/[0-9]/.test(this.currentChar)) {\n        return this.number();\n      }\n\n      if (/[a-zA-Z_]/.test(this.currentChar)) {\n        return this.identifierOrKeyword();\n      }\n\n      if (this.currentChar === '\"') {\n        return this.stringLiteral();\n      }\n\n      // Else symbol\n      return this.symbol();\n    }\n    tokenize() {\n      const tokens = [];\n      let token = this.getNextToken();\n      while (token.type !== \"EOF\") {\n        tokens.push(token);\n        token = this.getNextToken();\n      }\n      tokens.push({ type: \"EOF\" });\n      return tokens;\n    }\n  }\n\n  // === Parser ===\n  // Produces an AST (abstract syntax tree)\n\n  // Grammar sketch (simplified):\n  // program := stmtList\n  // stmtList := stmt*\n  // stmt :=\n  //     variable = expr ;\n  //   | print expr ;\n  //   | if (expr) { stmtList } [ else { stmtList } ]\n  //   | while (expr) { stmtList }\n  //   | function IDENT ( [IDENT [, IDENT]*] ) { stmtList }\n  //   | return expr? ;\n  //   | expr ;   (expr by itself, e.g. function call)\n  //\n  // expr := logicOr\n  // logicOr := logicAnd ( \"||\" logicAnd )*\n  // logicAnd := equality ( \"&&\" equality )*\n  // equality := relational ( ( \"==\" | \"!=\" ) relational )*\n  // relational := additive ( ( \"<\" | \"<=\" | \">\" | \">=\" ) additive )*\n  // additive := multiplicative ( ( \"+\" | \"-\" ) multiplicative )*\n  // multiplicative := unary ( ( \"*\" | \"/\" | \"%\" ) unary )*\n  // unary := ( \"!\" | \"-\" ) unary | primary\n  // primary := NUMBER | STRING | IDENT | functionCall | \"(\" expr \")\"\n  // functionCall := IDENT \"(\" [expr (\",\" expr)* ] \")\"\n\n  class Parser {\n    constructor(tokens) {\n      this.tokens = tokens;\n      this.pos = 0;\n      this.len = tokens.length;\n    }\n    current() {\n      return this.tokens[this.pos];\n    }\n    next() {\n      if (this.pos < this.len -1) this.pos++;\n      return this.current();\n    }\n    eat(type, value=null) {\n      let t = this.current();\n      if (t.type === type && (value === null || t.value === value)) {\n        this.pos++;\n        return t;\n      }\n      throw new Error(`Expected token ${value||type} but got ${t.type} ${t.value} at token index ${this.pos}`);\n    }\n\n    parseProgram() {\n      const stmts = [];\n      while (this.current().type !== \"EOF\") {\n        stmts.push(this.parseStmt());\n      }\n      return { type: \"Program\", body: stmts };\n    }\n    parseStmt() {\n      let t = this.current();\n\n      if (t.type === \"KEYWORD\") {\n        switch(t.value) {\n          case \"print\":\n            this.eat(\"KEYWORD\",\"print\");\n            let expPrint = this.parseExpr();\n            this.eat(\"SYMBOL\",\";\");\n            return { type:\"PrintStatement\", expression: expPrint };\n\n          case \"if\":\n            this.eat(\"KEYWORD\",\"if\");\n            this.eat(\"SYMBOL\",\"(\");\n            let cond = this.parseExpr();\n            this.eat(\"SYMBOL\",\")\");\n            this.eat(\"SYMBOL\",\"{\");\n            let thenStmts = this.parseBlock();\n            let elseStmts = null;\n            if (this.current().type === \"KEYWORD\" && this.current().value === \"else\") {\n              this.eat(\"KEYWORD\",\"else\");\n              this.eat(\"SYMBOL\",\"{\");\n              elseStmts = this.parseBlock();\n            }\n            return { type:\"IfStatement\", condition: cond, then: thenStmts, else: elseStmts };\n\n          case \"while\":\n            this.eat(\"KEYWORD\",\"while\");\n            this.eat(\"SYMBOL\",\"(\");\n            let wcond = this.parseExpr();\n            this.eat(\"SYMBOL\",\")\");\n            this.eat(\"SYMBOL\",\"{\");\n            let body = this.parseBlock();\n            return { type:\"WhileStatement\", condition: wcond, body: body };\n\n          case \"function\":\n            this.eat(\"KEYWORD\", \"function\");\n            let nameTok = this.eat(\"IDENT\");\n            this.eat(\"SYMBOL\",\"(\");\n            let params = [];\n            if (this.current().type === \"IDENT\") {\n              params.push(this.eat(\"IDENT\").value);\n              while(this.current().type === \"SYMBOL\" && this.current().value === \",\") {\n                this.eat(\"SYMBOL\", \",\");\n                params.push(this.eat(\"IDENT\").value);\n              }\n            }\n            this.eat(\"SYMBOL\", \")\");\n            this.eat(\"SYMBOL\",\"{\");\n            let funBody = this.parseBlock();\n            return { type: \"FunctionDeclaration\", name: nameTok.value, params: params, body: funBody };\n\n          case \"return\":\n            this.eat(\"KEYWORD\",\"return\");\n            let rexpr = null;\n            if (!(this.current().type === \"SYMBOL\" && this.current().value === \";\")) {\n              rexpr = this.parseExpr();\n            }\n            this.eat(\"SYMBOL\",\";\");\n            return { type: \"ReturnStatement\", expression: rexpr };\n\n          default:\n            throw new Error(`Unknown keyword statement: ${t.value}`);\n        }\n      }\n\n      // lookahead for assignment or expr stmt\n      // If ident followed by '=' => assignment\n      if (t.type === \"IDENT\" && this.tokens[this.pos+1] && this.tokens[this.pos+1].type === \"SYMBOL\" && this.tokens[this.pos+1].value === \"=\") {\n        let varName = t.value;\n        this.eat(\"IDENT\");\n        this.eat(\"SYMBOL\", \"=\");\n        let expr = this.parseExpr();\n        this.eat(\"SYMBOL\", \";\");\n        return { type: \"Assignment\", name: varName, expression: expr };\n      }\n\n      // Otherwise expr statement (function call, etc.)\n      let exp = this.parseExpr();\n      this.eat(\"SYMBOL\",\";\");\n      return { type: \"ExprStatement\", expression: exp };\n    }\n\n    parseBlock() {\n      // parse zero or more statements until matching \"}\"\n      const stmts = [];\n      while(!(this.current().type === \"SYMBOL\" && this.current().value === \"}\")) {\n        if (this.current().type === \"EOF\") throw new Error(\"Unexpected EOF inside block\");\n        stmts.push(this.parseStmt());\n      }\n      this.eat(\"SYMBOL\",\"}\");\n      return stmts;\n    }\n\n    // Expression parsing according to precedence\n\n    parseExpr() {\n      return this.parseLogicOr();\n    }\n    parseLogicOr() {\n      let node = this.parseLogicAnd();\n      while(this.current().type === \"SYMBOL\" && this.current().value === \"||\") {\n        let op = this.eat(\"SYMBOL\").value;\n        let right = this.parseLogicAnd();\n        node = { type:\"LogicalExpression\", operator: op, left: node, right: right };\n      }\n      return node;\n    }\n    parseLogicAnd() {\n      let node = this.parseEquality();\n      while(this.current().type === \"SYMBOL\" && this.current().value === \"&&\") {\n        let op = this.eat(\"SYMBOL\").value;\n        let right = this.parseEquality();\n        node = { type:\"LogicalExpression\", operator: op, left: node, right: right };\n      }\n      return node;\n    }\n    parseEquality() {\n      let node = this.parseRelational();\n      while(this.current().type === \"SYMBOL\" && (this.current().value === \"==\" || this.current().value === \"!=\")) {\n        let op = this.eat(\"SYMBOL\").value;\n        let right = this.parseRelational();\n        node = { type:\"BinaryExpression\", operator: op, left: node, right: right };\n      }\n      return node;\n    }\n    parseRelational() {\n      let node = this.parseAdditive();\n      while(this.current().type === \"SYMBOL\" && [\"<\", \"<=\", \">\", \">=\"].includes(this.current().value)) {\n        let op = this.eat(\"SYMBOL\").value;\n        let right = this.parseAdditive();\n        node = { type:\"BinaryExpression\", operator: op, left: node, right: right };\n      }\n      return node;\n    }\n    parseAdditive() {\n      let node = this.parseMultiplicative();\n      while(this.current().type === \"SYMBOL\" && (this.current().value === \"+\" || this.current().value === \"-\")) {\n        let op = this.eat(\"SYMBOL\").value;\n        let right = this.parseMultiplicative();\n        node = { type:\"BinaryExpression\", operator: op, left: node, right: right };\n      }\n      return node;\n    }\n    parseMultiplicative() {\n      let node = this.parseUnary();\n      while(this.current().type === \"SYMBOL\" && (this.current().value === \"*\" || this.current().value === \"/\" || this.current().value === \"%\")) {\n        let op = this.eat(\"SYMBOL\").value;\n        let right = this.parseUnary();\n        node = { type:\"BinaryExpression\", operator: op, left: node, right: right };\n      }\n      return node;\n    }\n    parseUnary() {\n      if (this.current().type === \"SYMBOL\" && (this.current().value === \"!\" || this.current().value === \"-\")) {\n        let op = this.eat(\"SYMBOL\").value;\n        let argument = this.parseUnary();\n        return { type:\"UnaryExpression\", operator: op, argument: argument };\n      }\n      return this.parsePrimary();\n    }\n    parsePrimary() {\n      let t = this.current();\n      if (t.type === \"NUMBER\") {\n        this.eat(\"NUMBER\");\n        return { type:\"Literal\", value: t.value };\n      }\n      if (t.type === \"STRING\") {\n        this.eat(\"STRING\");\n        return { type:\"Literal\", value: t.value };\n      }\n      if (t.type === \"KEYWORD\") {\n        if(t.value === \"true\") {\n          this.eat(\"KEYWORD\", \"true\");\n          return {type:\"Literal\", value:true};\n        }\n        if(t.value === \"false\") {\n          this.eat(\"KEYWORD\", \"false\");\n          return {type:\"Literal\", value:false};\n        }\n      }\n      if (t.type === \"IDENT\") {\n        // could be function call or variable\n        let idName = t.value;\n        this.eat(\"IDENT\");\n        if(this.current().type === \"SYMBOL\" && this.current().value === \"(\") {\n          // function call\n          this.eat(\"SYMBOL\", \"(\");\n          let args = [];\n          if (!(this.current().type === \"SYMBOL\" && this.current().value === \")\")) {\n            args.push(this.parseExpr());\n            while(this.current().type === \"SYMBOL\" && this.current().value === \",\") {\n              this.eat(\"SYMBOL\", \",\");\n              args.push(this.parseExpr());\n            }\n          }\n          this.eat(\"SYMBOL\", \")\");\n          return { type:\"CallExpression\", callee: idName, arguments: args };\n        } else {\n          return { type: \"Identifier\", name: idName };\n        }\n      }\n      if(t.type === \"SYMBOL\" && t.value === \"(\") {\n        this.eat(\"SYMBOL\", \"(\");\n        let node = this.parseExpr();\n        this.eat(\"SYMBOL\", \")\");\n        return node;\n      }\n      throw new Error(`Unexpected token ${t.type} ${t.value} in expression at pos ${this.pos}`);\n    }\n  }\n\n  // === Interpreter ===\n  // Runs the AST in interactive, step-by-step manner\n  //\n  // Features:\n  // - Global environment + call stack\n  // - Support for built-in input(), print()\n  // - Step mode + run mode + pause\n  // - Handling errors gracefully\n\n  class RuntimeError extends Error {}\n\n  class Environment {\n    constructor(outer=null) {\n      this.vars = new Map();\n      this.outer = outer;\n    }\n    has(name) {\n      if(this.vars.has(name)) return true;\n      if(this.outer !== null) return this.outer.has(name);\n      return false;\n    }\n    get(name) {\n      if(this.vars.has(name)) return this.vars.get(name);\n      if(this.outer !== null) return this.outer.get(name);\n      throw new RuntimeError(`Variable ${name} is not defined`);\n    }\n    set(name, val) {\n      if(this.vars.has(name)) {\n        this.vars.set(name, val);\n      } else if(this.outer !== null && this.outer.has(name)) {\n        this.outer.set(name, val);\n      } else {\n        this.vars.set(name, val);\n      }\n    }\n    define(name,val) {\n      this.vars.set(name,val);\n    }\n    keys() {\n      const s = new Set(this.vars.keys());\n      if(this.outer) {\n        for(let k of this.outer.keys()) s.add(k);\n      }\n      return Array.from(s);\n    }\n  }\n\n  class ReturnValue {\n    constructor(val) { this.val = val; }\n  }\n\n  class Interpreter {\n    constructor() {\n      this.globalEnv = new Environment();\n      this.callStack = [];\n      this.functions = new Map();\n      this.inputBuffer = [];\n      this.outputBuffer = [];\n      this.running = false;\n      this.paused = false;\n      this.ast = null;\n      this.currentStatementIndex = 0;\n      this.currentStatementList = null;\n      this.currentEnv = this.globalEnv;\n      this.awaitingInput = false;\n      this.stepMode = true; // if false, run to end / until pause\n      this.onOutputCallback = null;\n      this.onStateChangeCallback = null;\n\n      this.callStack.push({\n        env: this.globalEnv,\n        stmts: [],\n        index: 0,\n        funcName: \"<global>\",\n      });\n    }\n\n    reset() {\n      this.globalEnv = new Environment();\n      this.callStack = [];\n      this.functions = new Map();\n      this.inputBuffer = [];\n      this.outputBuffer = [];\n      this.running = false;\n      this.paused = false;\n      this.ast = null;\n      this.currentStatementIndex = 0;\n      this.currentStatementList = null;\n      this.currentEnv = this.globalEnv;\n      this.awaitingInput = false;\n      this.stepMode = true;\n\n      this.callStack.push({\n        env: this.globalEnv,\n        stmts: [],\n        index: 0,\n        funcName: \"<global>\",\n      });\n    }\n\n    loadProgram(ast) {\n      this.ast = ast;\n      // scan for function declarations and remove them from global statements\n      let globalStmts = [];\n      for(const stmt of ast.body) {\n        if(stmt.type === \"FunctionDeclaration\") {\n          this.functions.set(stmt.name, stmt);\n        } else {\n          globalStmts.push(stmt);\n        }\n      }\n      this.callStack = [{\n        env: this.globalEnv,\n        stmts: globalStmts,\n        index: 0,\n        funcName: \"<global>\"\n      }];\n    }\n\n    enqueueInput(val) {\n      this.inputBuffer.push(val);\n      if(this.awaitingInput) {\n        this.awaitingInput = false;\n      }\n    }\n\n    clearInput() {\n      this.inputBuffer.length = 0;\n      this.awaitingInput = false;\n    }\n\n    appendOutput(o) {\n      this.outputBuffer.push(o);\n      if(this.onOutputCallback) this.onOutputCallback(o);\n    }\n\n    getOutput() {\n      return this.outputBuffer.join(\"\");\n    }\n\n    clearOutput() {\n      this.outputBuffer.length = 0;\n      if(this.onOutputCallback) this.onOutputCallback(null,true);\n    }\n\n    isRunning() {\n      return this.running;\n    }\n\n    pause() {\n      this.paused = true;\n      this.running = false;\n    }\n\n    resume() {\n      this.paused = false;\n      if(!this.running) {\n        this.runLoop();\n      }\n    }\n\n    stepConfig(stepMode) {\n      this.stepMode = stepMode;\n    }\n\n    async runLoop() {\n      this.running = true;\n      while(this.running && !this.paused) {\n        try {\n          if(this.awaitingInput) {\n            // wait for user input\n            await new Promise(r => setTimeout(r, 100));\n            continue;\n          }\n          let finished = this.step();\n          if(finished) {\n            this.running = false;\n            break;\n          }\n          if(this.stepMode) {\n            // step mode => pause after each step\n            this.running = false;\n            this.paused = true;\n            break;\n          }\n          // delay according to speed setting\n          await new Promise(r => setTimeout(r, state.stepDelay));\n        } catch(e) {\n          this.running = false;\n          this.paused = true;\n          this.appendOutput(`\\nRuntime Error: ${e.message}\\n`);\n          break;\n        }\n      }\n      if(this.onStateChangeCallback) this.onStateChangeCallback();\n    }\n\n    step() {\n      // returns true if program finished\n      if(this.callStack.length === 0) {\n        return true;\n      }\n      let frame = this.callStack[this.callStack.length-1];\n      if(frame.index >= frame.stmts.length) {\n        this.callStack.pop();\n        if(this.callStack.length === 0) {\n          return true;\n        }\n        return false;\n      }\n      let stmt = frame.stmts[frame.index];\n      frame.index++;\n      this.currentEnv = frame.env;\n\n      // console.log(\"Executing stmt\", stmt);\n      return this.executeStatement(stmt);\n    }\n\n    executeStatement(stmt) {\n      try {\n        switch(stmt.type) {\n          case \"Assignment\": {\n            let val = this.evalExpr(stmt.expression, this.currentEnv);\n            this.currentEnv.set(stmt.name, val);\n            break;\n          }\n          case \"PrintStatement\": {\n            let val = this.evalExpr(stmt.expression, this.currentEnv);\n            this.appendOutput(valToString(val) + \"\\n\");\n            break;\n          }\n          case \"IfStatement\": {\n            let cond = this.evalExpr(stmt.condition, this.currentEnv);\n            let truthy = toBoolean(cond);\n            let stmtsToPush = truthy ? stmt.then : stmt.else || [];\n            this.callStack.push({\n              env: new Environment(this.currentEnv),\n              stmts: stmtsToPush,\n              index: 0,\n              funcName: frameFuncName(this.callStack)\n            });\n            break;\n          }\n          case \"WhileStatement\": {\n            // We rewrite the while into a function call frame that loops\n            let condExpr = stmt.condition;\n            let bodyStmts = stmt.body;\n            // We'll use a special looping approach:\n            // Instead of pushing body always, we do this:\n            let condVal = this.evalExpr(condExpr, this.currentEnv);\n            if (toBoolean(condVal)) {\n              // push body followed by while again (simulate loop)\n              this.callStack.push({\n                env: new Environment(this.currentEnv),\n                stmts: bodyStmts.concat([stmt]), // we append the same while statement to continue loop\n                index: 0,\n                funcName: frameFuncName(this.callStack)\n              });\n            } else {\n              // do nothing, exit loop\n            }\n            break;\n          }\n\n          case \"FunctionDeclaration\": {\n            // function declarations already loaded in this.functions,\n            // skip here.\n            break;\n          }\n\n          case \"ReturnStatement\": {\n            if (stmt.expression == null) {\n              throw new ReturnValue(null);\n            } else {\n              let val = this.evalExpr(stmt.expression, this.currentEnv);\n              throw new ReturnValue(val);\n            }\n          }\n          case \"ExprStatement\": {\n            this.evalExpr(stmt.expression, this.currentEnv);\n            break;\n          }\n          default:\n            throw new RuntimeError(`Unknown statement type: ${stmt.type}`);\n        }\n      } catch(retval) {\n        if(retval instanceof ReturnValue) {\n          // Return from function call\n          this.callStack.pop();\n          if(this.callStack.length === 0) {\n            // returned from global? ignore\n            return true;\n          }\n          let callerFrame = this.callStack[this.callStack.length-1];\n          if(retval.val !== undefined) {\n            callerFrame.returnValue = retval.val;\n          }\n          return false;\n        } else {\n          throw retval;\n        }\n      }\n      return false;\n    }\n\n    evalExpr(expr, env) {\n      switch(expr.type) {\n        case \"Literal\": return expr.value;\n        case \"Identifier\": return env.get(expr.name);\n        case \"BinaryExpression\": {\n          let left = this.evalExpr(expr.left, env);\n          let right = this.evalExpr(expr.right, env);\n          switch(expr.operator) {\n            case \"+\": return numericOp(left, right, (a,b) => a + b);\n            case \"-\": return numericOp(left, right, (a,b) => a - b);\n            case \"*\": return numericOp(left, right, (a,b) => a * b);\n            case \"/\": return numericOp(left, right, (a,b) => {\n              if(b === 0) throw new RuntimeError(\"Division by zero\");\n              return Math.floor(a / b);\n            });\n            case \"%\": return numericOp(left, right, (a,b) => {\n              if(b === 0) throw new RuntimeError(\"Modulo by zero\");\n              return a % b;\n            });\n            case \"==\": return deepEquals(left, right);\n            case \"!=\": return !deepEquals(left, right);\n            case \"<\": return numericOp(left, right, (a,b)=>a < b ? true : false);\n            case \"<=\": return numericOp(left, right, (a,b)=>a <= b ? true : false);\n            case \">\": return numericOp(left, right, (a,b)=>a > b ? true : false);\n            case \">=\": return numericOp(left, right, (a,b)=>a >= b ? true : false);\n            default:\n              throw new RuntimeError(`Unknown binary operator: ${expr.operator}`);\n          }\n        }\n        case \"LogicalExpression\": {\n          let left = this.evalExpr(expr.left, env);\n          switch(expr.operator) {\n            case \"&&\":\n              if(!toBoolean(left)) return false; // short-circuit\n              return toBoolean(this.evalExpr(expr.right, env));\n            case \"||\":\n              if(toBoolean(left)) return true;\n              return toBoolean(this.evalExpr(expr.right, env));\n            default:\n              throw new RuntimeError(`Unknown logical operator: ${expr.operator}`);\n          }\n        }\n        case \"UnaryExpression\": {\n          let val = this.evalExpr(expr.argument, env);\n          switch(expr.operator) {\n            case \"!\": return !toBoolean(val);\n            case \"-\": return numericOp(val, null, (a,_) => -a);\n            default:\n              throw new RuntimeError(`Unknown unary operator: ${expr.operator}`);\n          }\n        }\n        case \"CallExpression\": {\n          // Builtins: input, print replaced (print is statement)\n          if(expr.callee === \"input\") {\n            // input returns next integer from inputBuffer (if empty, pause)\n            if(this.inputBuffer.length === 0) {\n              this.awaitingInput = true;\n              throw new RuntimeError(\"Input required but input buffer empty. Please provide input and continue.\");\n            }\n            let v = this.inputBuffer.shift();\n            this.awaitingInput = false;\n            return v;\n          }\n          // user functions:\n          if(!this.functions.has(expr.callee)) {\n            throw new RuntimeError(`Function ${expr.callee} is not defined`);\n          }\n          let func = this.functions.get(expr.callee);\n          if(expr.arguments.length !== func.params.length) {\n            throw new RuntimeError(`Function ${expr.callee} expects ${func.params.length} arguments, got ${expr.arguments.length}`);\n          }\n          let newEnv = new Environment(this.globalEnv);\n          for(let i=0; i < func.params.length; i++) {\n            let argval = this.evalExpr(expr.arguments[i], env);\n            newEnv.define(func.params[i], argval);\n          }\n          this.callStack.push({\n            env: newEnv,\n            stmts: func.body,\n            index: 0,\n            funcName: expr.callee,\n            returnValue: undefined,\n          });\n          // immediately proceed into first statement of function on next step\n          return undefined;\n        }\n        default:\n          throw new RuntimeError(`Unknown expression type: ${expr.type}`);\n      }\n    }\n  }\n\n  // === Utility functions ===\n\n  function numericOp(left, right, op) {\n    if (typeof left !== \"number\" || (right !== null && typeof right !== \"number\")) {\n      throw new RuntimeError(`Operands must be numbers`);\n    }\n    return op(left,right);\n  }\n  function toBoolean(val) {\n    if(val === false || val === 0 || val === null || val === undefined) return false;\n    return true;\n  }\n  function deepEquals(a, b) {\n    return a === b;\n  }\n  function valToString(v) {\n    if(typeof v === \"string\") return v;\n    if(typeof v === \"number\") return v.toString();\n    if(typeof v === \"boolean\") return v ? \"true\" : \"false\";\n    if(v === null || v === undefined) return \"null\";\n    return JSON.stringify(v);\n  }\n  function frameFuncName(callstack) {\n    if(callstack.length === 0) return \"<global>\";\n    return callstack[callstack.length-1].funcName;\n  }\n\n  // === UI and Main Logic ===\n\n  const codeArea = document.getElementById(\"codeArea\");\n  const btnReset = document.getElementById(\"btnReset\");\n  const btnRun = document.getElementById(\"btnRun\");\n  const btnStep = document.getElementById(\"btnStep\");\n  const btnPause = document.getElementById(\"btnPause\");\n  const btnClearOutput = document.getElementById(\"btnClearOutput\");\n  const btnAddInput = document.getElementById(\"btnAddInput\");\n  const btnClearInputBuffer = document.getElementById(\"btnClearInputBuffer\");\n  const inputValue = document.getElementById(\"inputValue\");\n  const outputDiv = document.getElementById(\"output\");\n  const speedSlider = document.getElementById(\"speedSlider\");\n  const speedVal = document.getElementById(\"speedVal\");\n  const varSelect = document.getElementById(\"varSelect\");\n  const varDetails = document.getElementById(\"varDetails\");\n  const callStackSelect = document.getElementById(\"callStack\");\n  const stackDetails = document.getElementById(\"stackDetails\");\n  const btnResetStack = document.getElementById(\"btnResetStack\");\n\n  const state = {\n    interpreter: null,\n    stepDelay: parseInt(speedSlider.value, 10),\n  };\n\n  function refreshOutput(clear=false) {\n    if(clear) {\n      outputDiv.textContent = \"\";\n    } else {\n      outputDiv.textContent = state.interpreter.getOutput();\n    }\n    outputDiv.scrollTop = outputDiv.scrollHeight;\n  }\n\n  function resetInterpreter() {\n    try {\n      let code = codeArea.value;\n      let lexer = new Lexer(code);\n      let tokens = lexer.tokenize();\n      let parser = new Parser(tokens);\n      let ast = parser.parseProgram();\n\n      state.interpreter = new Interpreter();\n      state.interpreter.loadProgram(ast);\n      state.interpreter.clearOutput();\n\n      state.interpreter.onOutputCallback = (output, clear) => {\n        if(clear) {\n          refreshOutput(true);\n        } else {\n          refreshOutput();\n        }\n      };\n      state.interpreter.onStateChangeCallback = refreshUI;\n\n      refreshOutput(true);\n      refreshUI();\n      appendStatus(\"Program loaded successfully.\");\n    } catch(e) {\n      appendStatus(\"Error loading program: \" + e.message);\n    }\n  }\n\n  function refreshUI() {\n    // Refresh variable list and call stack list\n\n    if(!state.interpreter) return;\n    // collect vars from current environment stack frames combined (latest frame first)\n    let vars = {};\n    for(let i=state.interpreter.callStack.length-1; i >= 0; i--) {\n      let frame = state.interpreter.callStack[i];\n      for(let [k,v] of frame.env.vars) {\n        if(!(k in vars)) vars[k] = v;\n      }\n    }\n    // Clear and add vars to select\n    varSelect.innerHTML = \"\";\n    let keys = Object.keys(vars).sort();\n    for(let k of keys) {\n      let opt = document.createElement(\"option\");\n      opt.value = k;\n      opt.textContent = k;\n      varSelect.appendChild(opt);\n    }\n    varDetails.textContent = \"\";\n    if(varSelect.options.length > 0) {\n      varSelect.selectedIndex = 0;\n      showVarDetails(varSelect.options[0].value, vars);\n    }\n\n    // Call stack display\n    callStackSelect.innerHTML = \"\";\n    for(let i = state.interpreter.callStack.length-1; i >= 0; i--) {\n      let f = state.interpreter.callStack[i];\n      let opt = document.createElement(\"option\");\n      opt.value = i.toString();\n      opt.textContent = `${f.funcName} (Stmt: ${f.index}/${f.stmts.length})`;\n      callStackSelect.appendChild(opt);\n    }\n    stackDetails.textContent = \"\";\n    if(callStackSelect.options.length > 0) {\n      callStackSelect.selectedIndex = 0;\n      showStackDetails(state.interpreter.callStack.length-1);\n    }\n\n    // Buttons enable/disable\n    let running = state.interpreter.isRunning();\n    btnRun.disabled = running;\n    btnStep.disabled = running;\n    btnPause.disabled = !running;\n  }\n\n  function showVarDetails(name, vars=null) {\n    if(!vars && state.interpreter) {\n      // reconstruct vars as above\n      vars = {};\n      for(let i=state.interpreter.callStack.length-1; i >= 0; i--) {\n        let frame = state.interpreter.callStack[i];\n        for(let [k,v] of frame.env.vars) {\n          if(!(k in vars)) vars[k] = v;\n        }\n      }\n    }\n    if(name in vars) {\n      let v = vars[name];\n      varDetails.textContent = `Variable \"${name}\": ${valToString(v)} (${typeof v})`;\n    } else {\n      varDetails.textContent = \"\";\n    }\n  }\n\n  function showStackDetails(frameIndex) {\n    if(!state.interpreter) return;\n    const fi = parseInt(frameIndex, 10);\n    if(isNaN(fi) || fi <0 || fi >= state.interpreter.callStack.length) {\n      stackDetails.textContent = \"\";\n      return;\n    }\n    let frame = state.interpreter.callStack[fi];\n    let varsArray = [];\n    for(let [k,v] of frame.env.vars) {\n      varsArray.push(`${k} = ${valToString(v)}`);\n    }\n    stackDetails.textContent = `Function: ${frame.funcName}\\nLocal Variables:\\n${varsArray.join(\"\\n\")}`;\n  }\n\n  function appendStatus(text) {\n    outputDiv.textContent += \"\\n[Status] \" + text + \"\\n\";\n    outputDiv.scrollTop = outputDiv.scrollHeight;\n  }\n\n  // Event handlers\n  btnReset.addEventListener(\"click\", () => {\n    state.interpreter && state.interpreter.pause();\n    resetInterpreter();\n  });\n  btnRun.addEventListener(\"click\", () => {\n    if(!state.interpreter) return;\n    state.interpreter.stepConfig(false);\n    state.interpreter.running = true;\n    state.interpreter.paused = false;\n    state.interpreter.runLoop();\n    refreshUI();\n  });\n  btnStep.addEventListener(\"click\", () => {\n    if(!state.interpreter) return;\n    state.interpreter.stepConfig(true);\n    if(state.interpreter.isRunning()) return;\n    try {\n      let finished = state.interpreter.step();\n      refreshOutput();\n      refreshUI();\n      if(finished) appendStatus(\"Program execution finished.\");\n      else appendStatus(\"Step executed.\");\n    } catch(e) {\n      appendStatus(\"Runtime Error: \" + e.message);\n    }\n  });\n  btnPause.addEventListener(\"click\", () => {\n    if(!state.interpreter) return;\n    state.interpreter.pause();\n    appendStatus(\"Execution paused.\");\n    refreshUI();\n  });\n  btnClearOutput.addEventListener(\"click\", () => {\n    if(!state.interpreter) return;\n    state.interpreter.clearOutput();\n    refreshOutput(true);\n  });\n  btnAddInput.addEventListener(\"click\", () => {\n    if(!state.interpreter) return;\n    let text = inputValue.value.trim();\n    if(text.length === 0) return;\n    let parts = text.split(\",\");\n    for(let p of parts) {\n      let val = p.trim();\n      if(val !== \"\") {\n        // try number first\n        let num = parseInt(val,10);\n        if(!Number.isNaN(num)) {\n          state.interpreter.enqueueInput(num);\n        } else {\n          appendStatus(`Invalid input (not integer): \"${val}\"`);\n        }\n      }\n    }\n    inputValue.value = \"\";\n    appendStatus(\"Input values added.\");\n  });\n  btnClearInputBuffer.addEventListener(\"click\", () => {\n    if(!state.interpreter) return;\n    state.interpreter.clearInput();\n    appendStatus(\"Input buffer cleared.\");\n  });\n  speedSlider.addEventListener(\"input\", () => {\n    state.stepDelay = parseInt(speedSlider.value, 10);\n    speedVal.textContent = state.stepDelay.toString();\n  });\n  varSelect.addEventListener(\"change\", e => {\n    let name = varSelect.value;\n    showVarDetails(name);\n  });\n  callStackSelect.addEventListener(\"change\", e => {\n    let idx = callStackSelect.value;\n    showStackDetails(idx);\n  });\n  btnResetStack.addEventListener(\"click\", () => {\n    if(!state.interpreter) return;\n    // reset the call stack to global only\n    let globalFrame = state.interpreter.callStack[0];\n    globalFrame.index = 0;\n    globalFrame.env = state.interpreter.globalEnv;\n    state.interpreter.callStack.splice(1);\n    appendStatus(\"Call stack reset to global frame.\");\n    refreshUI();\n  });\n\n  // Initialize\n  resetInterpreter();\n\n})();\n</script>\n\n</body>\n</html>"
  },
