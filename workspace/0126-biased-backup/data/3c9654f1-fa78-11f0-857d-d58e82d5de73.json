    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>B-Tree Visualization — Exceptional Design</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@600&family=Quicksand:wght@400;700&display=swap');\n\n  /* Reset */\n  * {\n    box-sizing: border-box;\n  }\n  html, body {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #0d1b2a 0%, #1b263b 50%, #415a77 100%);\n    color: #e0e6f1;\n    font-family: 'Quicksand', sans-serif;\n    overflow-x: hidden;\n  }\n\n  body {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 4rem 2rem 6rem;\n    user-select: none;\n  }\n\n  /* Title */\n  h1 {\n    font-family: 'Josefin Sans', sans-serif;\n    font-weight: 600;\n    font-size: 3.5rem;\n    margin-bottom: 0.25em;\n    letter-spacing: 0.1em;\n    color: #f0f4ff;\n    text-shadow:\n      0 0 8px #64ffda94,\n      0 0 20px #64ffda94,\n      0 0 30px #12fff7bb;\n  }\n\n  h2 {\n    font-weight: 400;\n    font-size: 1.25rem;\n    color: #a3b1c6cc;\n    margin-bottom: 3.5rem;\n    letter-spacing: 0.06em;\n  }\n\n  /* Main container */\n  #tree-container {\n    position: relative;\n    width: 100%;\n    max-width: 900px;\n    min-height: 420px;\n    background: radial-gradient(circle at center, #1b2a47 80%, #152036ff 100%);\n    border-radius: 24px;\n    box-shadow:\n      inset 0 0 40px #0ff6cc33,\n      0 8px 32px -4px #00ffdacc;\n    padding: 3rem 2rem 5rem;\n    overflow: visible;\n    display: flex;\n    justify-content: center;\n  }\n\n  /* SVG styling */\n  svg {\n    overflow: visible;\n    user-select: none;\n  }\n\n  /* Node styling */\n  .bnode {\n    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);\n    cursor: default;\n    filter: drop-shadow(0 0 3px #1affd8cc);\n  }\n\n  .bnode rect {\n    fill: linear-gradient(135deg, #004d40, #00796b);\n    stroke: #12fff7;\n    stroke-width: 2px;\n    filter:\n      drop-shadow(0 2px 4px rgba(0,255,222,0.45));\n    rx: 12;\n    ry: 12;\n    transition: fill 0.4s ease, filter 0.4s ease;\n  }\n\n  .bnode:hover rect {\n    fill: #00ffe6;\n    filter: drop-shadow(0 0 12px #00ffe6cc);\n  }\n\n  text.bkey {\n    fill: #e0f7fa;\n    font-weight: 700;\n    font-family: 'Josefin Sans', sans-serif;\n    font-size: 1.15rem;\n    user-select: none;\n    pointer-events: none;\n    text-shadow:\n      0 0 2px #00fce344,\n      0 0 4px #00ffe6aa;\n    transition: fill 0.3s ease;\n  }\n\n  /* Edges styling */\n  .edge {\n    stroke: #00ffc4cc;\n    stroke-width: 4;\n    stroke-linejoin: round;\n    fill: none;\n    filter:\n      drop-shadow(0 0 8px #00ffc477);\n    opacity: 0.8;\n    transition: stroke-width 0.3s ease;\n  }\n\n  /* Button styling */\n  #controls {\n    margin-top: 3rem;\n    display: flex;\n    gap: 1.25rem;\n  }\n\n  button {\n    background: #00ffe6;\n    border: none;\n    color: #042a2b;\n    font-family: 'Josefin Sans', sans-serif;\n    font-weight: 700;\n    font-size: 1.1rem;\n    padding: 0.75rem 2rem;\n    border-radius: 30px;\n    box-shadow:\n      0 0 10px #00ffe6cc,\n      inset 0 -3px 10px #00a38866;\n    cursor: pointer;\n    transition:\n      background-color 0.35s ease,\n      box-shadow 0.35s ease,\n      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);\n    user-select: none;\n  }\n  button:hover {\n    background: #00c6b0;\n    box-shadow:\n      0 0 20px #00ffe6dd,\n      inset 0 -5px 15px #00a388cc;\n    transform: scale(1.05);\n  }\n  button:focus {\n    outline: none;\n    box-shadow:\n      0 0 28px #00ffe6ff,\n      0 0 40px #00ffe6ff inset;\n  }\n\n  /* Tooltip */\n  #description {\n    max-width: 900px;\n    font-family: 'Quicksand', sans-serif;\n    color: #9cd3e8cc;\n    font-weight: 400;\n    font-size: 1.1rem;\n    line-height: 1.55;\n    margin: 0 0 2rem 0;\n    text-align: center;\n    user-select: none;\n    mix-blend-mode: screen;\n  }\n\n  /* Node group container to separate keys horizontally */\n  .node-group {\n    display: flex;\n    gap: 0.7rem;\n  }\n\n  /* Bounce ease */\n  @keyframes bounceIn {\n    0% {\n      transform: translateY(30px) scale(0.7);\n      opacity: 0;\n    }\n    80% {\n      transform: translateY(-6px) scale(1.05);\n      opacity: 1;\n    }\n    100% {\n      transform: translateY(0) scale(1);\n      opacity: 1;\n    }\n  }\n\n</style>\n</head>\n<body>\n<h1>B-TREE</h1>\n<h2>Balanced Multiway Search Tree Visualization</h2>\n\n<div id=\"tree-container\" aria-label=\"B-Tree Visualization\">\n  <svg id=\"btree-svg\" width=\"860\" height=\"400\" viewBox=\"0 0 860 400\" role=\"img\" aria-labelledby=\"treeTitle\" >\n    <title id=\"treeTitle\">B-Tree Structure</title>\n\n    <!-- Edges -->\n    <path class=\"edge\" d=\"\" id=\"edge-0-1\" />\n    <path class=\"edge\" d=\"\" id=\"edge-0-2\" />\n    <path class=\"edge\" d=\"\" id=\"edge-0-3\" />\n\n    <path class=\"edge\" d=\"\" id=\"edge-1-4\" />\n    <path class=\"edge\" d=\"\" id=\"edge-1-5\" />\n    <path class=\"edge\" d=\"\" id=\"edge-1-6\" />\n\n    <path class=\"edge\" d=\"\" id=\"edge-2-7\" />\n    <path class=\"edge\" d=\"\" id=\"edge-2-8\" />\n    <path class=\"edge\" d=\"\" id=\"edge-2-9\" />\n\n    <path class=\"edge\" d=\"\" id=\"edge-3-10\" />\n    <path class=\"edge\" d=\"\" id=\"edge-3-11\" />\n    <path class=\"edge\" d=\"\" id=\"edge-3-12\" />\n\n\n    <!-- Nodes -->\n\n    <!-- Root -->\n    <g class=\"bnode\" id=\"node0\" transform=\"translate(430 50)\" aria-label=\"Node with keys 17, 35, 53\" role=\"group\" tabindex=\"0\">\n      <rect width=\"204\" height=\"56\" x=\"-102\" y=\"-28\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-62\" y=\"12\">17</text>\n      <text class=\"bkey\" x=\"-2\" y=\"12\">35</text>\n      <text class=\"bkey\" x=\"58\" y=\"12\">53</text>\n    </g>\n\n    <!-- Level 1 -->\n    <g class=\"bnode\" id=\"node1\" transform=\"translate(140 140)\" aria-label=\"Node with keys 5, 11\" role=\"group\" tabindex=\"0\">\n      <rect width=\"132\" height=\"48\" x=\"-66\" y=\"-24\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-42\" y=\"10\">5</text>\n      <text class=\"bkey\" x=\"18\" y=\"10\">11</text>\n    </g>\n    <g class=\"bnode\" id=\"node2\" transform=\"translate(410 140)\" aria-label=\"Node with keys 23, 29, 31\" role=\"group\" tabindex=\"0\">\n      <rect width=\"180\" height=\"48\" x=\"-90\" y=\"-24\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-66\" y=\"10\">23</text>\n      <text class=\"bkey\" x=\"-6\" y=\"10\">29</text>\n      <text class=\"bkey\" x=\"54\" y=\"10\">31</text>\n    </g>\n    <g class=\"bnode\" id=\"node3\" transform=\"translate(670 140)\" aria-label=\"Node with keys 41, 47\" role=\"group\" tabindex=\"0\">\n      <rect width=\"132\" height=\"48\" x=\"-66\" y=\"-24\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-42\" y=\"10\">41</text>\n      <text class=\"bkey\" x=\"18\" y=\"10\">47</text>\n    </g>\n\n    <!-- Level 2 -->\n    <!-- children of node1 -->\n    <g class=\"bnode\" id=\"node4\" transform=\"translate(40 230)\" aria-label=\"Leaf node with key 1\" role=\"group\" tabindex=\"0\">\n      <rect width=\"72\" height=\"40\" x=\"-36\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-10\" y=\"8\">1</text>\n    </g>\n    <g class=\"bnode\" id=\"node5\" transform=\"translate(110 230)\" aria-label=\"Leaf node with key 7\" role=\"group\" tabindex=\"0\">\n      <rect width=\"72\" height=\"40\" x=\"-36\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-10\" y=\"8\">7</text>\n    </g>\n    <g class=\"bnode\" id=\"node6\" transform=\"translate(195 230)\" aria-label=\"Leaf node with key 15\" role=\"group\" tabindex=\"0\">\n      <rect width=\"72\" height=\"40\" x=\"-36\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-12\" y=\"8\">15</text>\n    </g>\n    <!-- children of node2 -->\n    <g class=\"bnode\" id=\"node7\" transform=\"translate(340 230)\" aria-label=\"Leaf node with key 19\" role=\"group\" tabindex=\"0\">\n      <rect width=\"72\" height=\"40\" x=\"-36\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-12\" y=\"8\">19</text>\n    </g>\n    <g class=\"bnode\" id=\"node8\" transform=\"translate(410 230)\" aria-label=\"Leaf node with key 25\" role=\"group\" tabindex=\"0\">\n      <rect width=\"72\" height=\"40\" x=\"-36\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-12\" y=\"8\">25</text>\n    </g>\n    <g class=\"bnode\" id=\"node9\" transform=\"translate(480 230)\" aria-label=\"Leaf node with keys 27, 30\" role=\"group\" tabindex=\"0\">\n      <rect width=\"108\" height=\"40\" x=\"-54\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-32\" y=\"8\">27</text>\n      <text class=\"bkey\" x=\"18\" y=\"8\">30</text>\n    </g>\n    <!-- children of node3 -->\n    <g class=\"bnode\" id=\"node10\" transform=\"translate(595 230)\" aria-label=\"Leaf node with key 37\" role=\"group\" tabindex=\"0\">\n      <rect width=\"72\" height=\"40\" x=\"-36\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-12\" y=\"8\">37</text>\n    </g>\n    <g class=\"bnode\" id=\"node11\" transform=\"translate(670 230)\" aria-label=\"Leaf node with key 43\" role=\"group\" tabindex=\"0\">\n      <rect width=\"72\" height=\"40\" x=\"-36\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-12\" y=\"8\">43</text>\n    </g>\n    <g class=\"bnode\" id=\"node12\" transform=\"translate(740 230)\" aria-label=\"Leaf node with key 49\" role=\"group\" tabindex=\"0\">\n      <rect width=\"72\" height=\"40\" x=\"-36\" y=\"-20\" rx=\"14\" ry=\"14\" />\n      <text class=\"bkey\" x=\"-12\" y=\"8\">49</text>\n    </g>\n\n  </svg>\n</div>\n\n<div id=\"description\" aria-live=\"polite\">\n  A <strong>B-Tree</strong> is a self-balancing multiway search tree allowing efficient insertion, deletion, and search operations. Nodes store multiple keys, keeping the tree balanced by redistributing keys and children during updates.\n</div>\n\n<div id=\"controls\" role=\"region\" aria-label=\"B-Tree Controls\">\n  <button id=\"btnHighlightLeaves\" aria-pressed=\"false\" aria-label=\"Highlight leaf nodes\">Highlight Leaves</button>\n  <button id=\"btnReset\" aria-label=\"Reset highlight\">Reset</button>\n</div>\n\n<script>\n  (() => {\n    const svg = document.getElementById('btree-svg');\n    const nodes = Array.from(svg.querySelectorAll('.bnode'));\n    const edges = Array.from(svg.querySelectorAll('.edge'));\n    const btnHighlight = document.getElementById('btnHighlightLeaves');\n    const btnReset = document.getElementById('btnReset');\n\n    // Node positions stored for edges drawing\n    const nodeCenters = {};\n\n    function getNodeCenter(node) {\n      // <g> transform translate(x y)\n      const tr = node.getAttribute('transform');\n      if (!tr) return {x: 0, y: 0};\n      const match = tr.match(/translate\\(([-\\d.]+)[ ,]+([-\\d.]+)\\)/);\n      if (!match) return {x: 0, y: 0};\n      return {x: +match[1], y: +match[2]};\n    }\n\n    function setupCenters() {\n      nodes.forEach(node => {\n        const center = getNodeCenter(node);\n        nodeCenters[node.id] = center;\n      });\n    }\n\n    function drawEdge(id, fromId, toId) {\n      const edge = document.getElementById(id);\n      if (!edge) return;\n      const from = nodeCenters[fromId];\n      const to = nodeCenters[toId];\n      if (!from || !to) {\n        edge.setAttribute('d', '');\n        return;\n      }\n      const offsetYParent = 28; // half rect height approx\n      const offsetYChild = 20;  // half leaf height approx\n\n      // Start point bottom center of from node\n      const startX = from.x;\n      const startY = from.y + offsetYParent;\n      // End point top center of to node\n      const endX = to.x;\n      const endY = to.y - offsetYChild;\n\n      // Create a smooth Bezier curve path\n      const ctrlY = (startY + endY)/2;\n      const d = `M${startX},${startY} C${startX},${ctrlY} ${endX},${ctrlY} ${endX},${endY}`;\n      edge.setAttribute('d', d);\n    }\n\n    // Draw all edges according to known structure:\n    // Format: edge id, from node id, to node id\n    const edgesMap = [\n      ['edge-0-1','node0','node1'],\n      ['edge-0-2','node0','node2'],\n      ['edge-0-3','node0','node3'],\n\n      ['edge-1-4','node1','node4'],\n      ['edge-1-5','node1','node5'],\n      ['edge-1-6','node1','node6'],\n\n      ['edge-2-7','node2','node7'],\n      ['edge-2-8','node2','node8'],\n      ['edge-2-9','node2','node9'],\n\n      ['edge-3-10','node3','node10'],\n      ['edge-3-11','node3','node11'],\n      ['edge-3-12','node3','node12'],\n    ];\n\n    function drawAllEdges() {\n      edgesMap.forEach(([eid,fid,tid]) => {\n        drawEdge(eid,fid,tid);\n      });\n    }\n\n    // On load:\n    setupCenters();\n    drawAllEdges();\n\n    // Highlight leaves handler - leaves are nodes 4 to 12 inclusive\n    const leafNodes = [];\n    for (let i=4; i<=12; i++) leafNodes.push(document.getElementById(`node${i}`));\n\n    function highlightLeaves() {\n      leafNodes.forEach(node => {\n        const rect = node.querySelector('rect');\n        rect.style.transition = 'fill 0.6s ease';\n        rect.style.fill = '#00ffdbbb';\n        rect.style.filter = 'drop-shadow(0 0 16px #00ffdacc)';\n      });\n      // Also dim internal nodes and edges gracefully\n      nodes.filter(n => !leafNodes.includes(n)).forEach(n => {\n        n.style.opacity = '0.5';\n      });\n      edges.forEach(e => e.style.opacity = '0.3');\n      btnHighlight.setAttribute('aria-pressed', 'true');\n      btnHighlight.disabled = true;\n      btnReset.disabled = false;\n    }\n    function resetHighlight() {\n      leafNodes.forEach(node => {\n        const rect = node.querySelector('rect');\n        rect.style.transition = 'fill 0.8s ease';\n        rect.style.fill = '';\n        rect.style.filter = '';\n      });\n      nodes.forEach(n => (n.style.opacity = '1'));\n      edges.forEach(e => (e.style.opacity = '0.8'));\n      btnHighlight.setAttribute('aria-pressed', 'false');\n      btnHighlight.disabled = false;\n      btnReset.disabled = true;\n    }\n\n    btnHighlight.addEventListener('click', highlightLeaves);\n    btnReset.addEventListener('click', resetHighlight);\n    btnReset.disabled = true;\n\n    // Animate nodes on page load with subtle bounce\n    nodes.forEach((node, i) => {\n      node.style.opacity = '0';\n      node.style.transformOrigin = 'center center';\n      node.style.animation = `bounceIn 0.75s cubic-bezier(0.22, 1, 0.36, 1) forwards`;\n      node.style.animationDelay = (i * 0.08) + 's';\n    });\n  })();\n</script>\n</body>\n</html>"
