    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Counting Sort Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #f4f4f9;\n            color: #333;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n\n        .container {\n            text-align: center;\n        }\n\n        h1 {\n            font-size: 3rem;\n            color: #4A90E2;\n            margin-bottom: 20px;\n        }\n\n        .bars {\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            height: 300px;\n            width: 80%;\n            border: 2px solid #4A90E2;\n            border-radius: 10px;\n            overflow: hidden;\n        }\n\n        .bar {\n            width: calc(100% / 10);\n            background-color: #6BBF59;\n            margin: 0 1px;\n            transition: height 0.5s ease, background-color 0.5s ease;\n        }\n\n        .bar-sorted {\n            background-color: #FF6F61;\n        }\n\n        .button {\n            background-color: #4A90E2;\n            color: white;\n            padding: 15px 30px;\n            margin-top: 20px;\n            border: none;\n            border-radius: 5px;\n            font-size: 1.2rem;\n            cursor: pointer;\n            transition: background-color 0.3s ease;\n        }\n\n        .button:hover {\n            background-color: #2A6F95;\n        }\n\n        @keyframes pulse {\n            0% {\n                transform: scale(1);\n            }\n            50% {\n                transform: scale(1.05);\n            }\n            100% {\n                transform: scale(1);\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Counting Sort Visualization</h1>\n        <div class=\"bars\" id=\"barsContainer\"></div>\n        <button class=\"button\" id=\"startButton\">Start Sorting</button>\n    </div>\n\n    <script>\n        const barsContainer = document.getElementById('barsContainer');\n        const startButton = document.getElementById('startButton');\n\n        // Example input array\n        const inputArray = [3, 6, 4, 8, 1, 3, 9, 5, 2, 7];\n\n        function renderBars(array, sortedIndex = -1) {\n            barsContainer.innerHTML = '';\n            for (let i = 0; i < array.length; i++) {\n                const bar = document.createElement('div');\n                bar.className = 'bar';\n                bar.style.height = (array[i] * 30) + 'px';\n                if (i <= sortedIndex) {\n                    bar.classList.add('bar-sorted');\n                }\n                barsContainer.appendChild(bar);\n            }\n        }\n\n        function countingSort(array) {\n            let maxVal = Math.max(...array);\n            let count = new Array(maxVal + 1).fill(0);\n            let sortedIndex = -1;\n\n            // Count occurrences\n            for (let num of array) {\n                count[num]++;\n            }\n\n            // Update original array\n            for (let i = 0; i <= maxVal; i++) {\n                while (count[i] > 0) {\n                    sortedIndex++;\n                    array[sortedIndex] = i;\n                    count[i]--;\n\n                    // Render bars for each step\n                    renderBars(array, sortedIndex);\n                }\n            }\n        }\n\n        startButton.onclick = () => {\n            renderBars([...inputArray]); // Render initial bars\n            countingSort([...inputArray]); // Start sorting after rendering\n        };\n    </script>\n</body>\n</html>"
