h({\n      array: array.slice(),\n      config: Object.assign({}, config),\n      target: target\n    });\n    array = item.array;\n    config = item.config;\n    target = item.target;\n    renderArray();\n    renderState();\n    log('Redo applied.');\n  }\n\n  function storeUndoPoint() {\n    undoStack.push({\n      array: array.slice(),\n      config: Object.assign({}, config),\n      target: target\n    });\n    if (undoStack.length>50) undoStack.shift();\n    redoStack = [];\n  }\n\n  // Handlers for UI controls\n  document.getElementById('genRandom').addEventListener('click', ()=>{\n    updateConfigFromUI();\n    let len = Math.max(1, Number(document.getElementById('length').value) || 11);\n    let seed = document.getElementById('seed').value || null;\n    storeUndoPoint();\n    array = generateRandomArray(len, seed);\n    renderArray();\n    log('Generated random array of length '+len);\n  });\n\n  document.getElementById('fillRange').addEventListener('click', ()=>{\n    updateConfigFromUI();\n    let len = Math.max(1, Number(document.getElementById('length').value) || 11);\n    storeUndoPoint();\n    array = fillRange(len);\n    renderArray();\n    log('Filled range array length '+len);\n  });\n\n  document.getElementById('clearArray').addEventListener('click', ()=>{\n    storeUndoPoint();\n    array = [];\n    renderArray();\n    log('Array cleared.');\n  });\n\n  document.getElementById('applyCustom').addEventListener('click', ()=>{\n    let txt = document.getElementById('customArray').value;\n    storeUndoPoint();\n    array = parseArrayInput(txt);\n    // if sorted required, sort:\n    updateConfigFromUI();\n    if (config.sorted) {\n      array.sort((a,b)=> comparatorCompare(a,b));\n      if (config.order==='desc') array.reverse();\n    }\n    renderArray();\n    log('Custom array applied with '+array.length+' elements.');\n  });\n\n  document.getElementById('initSearch').addEventListener('click', ()=>{ updateConfigFromUI(); initSearch(); });\n\n  document.getElementById('stepForward').addEventListener('click', ()=>{\n    stepForward();\n    challenge.usedSteps++;\n  });\n\n  document.getElementById('stepBack').addEventListener('click', stepBack);\n\n  document.getElementById('autoRun').addEventListener('click', ()=>{\n    autoRunToggle();\n  });\n\n  document.getElementById('pauseRun').addEventListener('click', ()=>{\n    if (autoTimer) { clearInterval(autoTimer); autoTimer=null; log('Auto-run paused'); }\n    else log('Auto-run not running.');\n  });\n\n  document.getElementById('fastForward').addEventListener('click', fastForward);\n  document.getElementById('resetSearch').addEventListener('click', resetSearch);\n  document.getElementById('probeSelected').addEventListener('click', probeSelected);\n  document.getElementById('forceSetMid').addEventListener('click', forceSetMid);\n  document.getElementById('clearSelection').addEventListener('click', clearSelection);\n\n  document.getElementById('speed').addEventListener('input', (e)=> {\n    document.getElementById('speedVal').textContent = e.target.value;\n    if (autoTimer) {\n      clearInterval(autoTimer);\n      autoTimer = null;\n      autoRunToggle();\n    }\n  });\n\n  document.getElementById('jumpBtn').addEventListener('click', ()=>{\n    let idx = Number(document.getElementById('jumpStep').value);\n    if (!search.initialized) { log('Init first'); return; }\n    if (isNaN(idx) || idx < 0 || idx >= search.steps.length) { log('Invalid step index.'); return; }\n    search.stepIndex = idx;\n    restoreSnapshot(search.steps[idx]);\n    renderState();\n    log('Jumped to step '+idx);\n  });\n\n  document.getElementById('saveState').addEventListener('click', saveStateToFile);\n  document.getElementById('exportTrace').addEventListener('click', exportTrace);\n\n  document.getElementById('importTrace').addEventListener('change', (e)=>{\n    importTraceFile(e.target.files[0]);\n    e.target.value = '';\n  });\n\n  document.getElementById('loadState').addEventListene