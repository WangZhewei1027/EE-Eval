  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Binary Search Interactive Lab</title>\n  <style>\n  /* Intentionally minimal - no colors, no animations, default browser styling. */\n  body { font-family: sans-serif; margin: 12px; color: black; background: white; }\n  .controls { margin-bottom: 8px; }\n  fieldset { margin-bottom: 10px; }\n  .array-row { white-space: pre; font-family: monospace; margin: 8px 0; }\n  button { margin-right: 4px; margin-bottom: 4px; }\n  input[type=\"text\"] { width: 260px; }\n  textarea { width: 100%; height: 80px; }\n  .small { font-size: 0.9em; }\n  .log { max-height: 220px; overflow:auto; border: 1px solid #ccc; padding: 6px; }\n  </style>\n</head>\n<body>\n\n<h1>Binary Search Interactive Lab</h1>\n<div class=\"controls\">\n  <fieldset>\n    <legend>Array Generation / Input</legend>\n    Length: <input id=\"length\" type=\"number\" value=\"11\" min=\"1\" style=\"width:60px\"> \n    Seed (optional): <input id=\"seed\" type=\"text\" placeholder=\"e.g. 123\"> \n    <label><input id=\"allowDup\" type=\"checkbox\"> allow duplicates</label>\n    <label><input id=\"sorted\" type=\"checkbox\" checked> sorted</label>\n    Order:\n    <label><input name=\"order\" type=\"radio\" value=\"asc\" checked> asc</label>\n    <label><input name=\"order\" type=\"radio\" value=\"desc\"> desc</label>\n    <button id=\"genRandom\">Generate Random</button>\n    <button id=\"fillRange\">Fill Range</button>\n    <button id=\"clearArray\">Clear</button>\n    <div style=\"margin-top:6px\">\n      Custom CSV (comma or space separated): <input id=\"customArray\" type=\"text\" placeholder=\"e.g. 1,2,3,5,8\"> \n      <button id=\"applyCustom\">Apply</button>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>Search & Comparator Settings</legend>\n    Target: <input id=\"targetInput\" type=\"text\" placeholder=\"target value\"> \n    <label><input id=\"useClickTarget\" type=\"checkbox\"> set target by clicking array</label>\n    Variant:\n    <select id=\"variant\">\n      <option value=\"any\">Find any matching index</option>\n      <option value=\"leftmost\">Find leftmost (first) index</option>\n      <option value=\"rightmost\">Find rightmost (last) index</option>\n      <option value=\"insert\">Find insertion position (where to insert to keep sorted)</option>\n    </select>\n    Comparator:\n    <select id=\"comparator\">\n      <option value=\"number\">Numeric</option>\n      <option value=\"string\">Lexicographic</option>\n    </select>\n    Indexing:\n    <label><input name=\"indexing\" type=\"radio\" value=\"0\" checked> 0-based</label>\n    <label><input name=\"indexing\" type=\"radio\" value=\"1\"> 1-based</label>\n    <label><input id=\"midCeil\" type=\"checkbox\"> mid = ceil((low+high)/2)</label>\n    <label><input id=\"offByOneBug\" type=\"checkbox\"> simulate off-by-one bug</label>\n  </fieldset>\n</div>\n\n<fieldset>\n  <legend>Array Visualization and Manual Interaction</legend>\n  <div class=\"small\">Click an element to toggle its selection or, if \"set target by clicking array\" is enabled, set the target.</div>\n  <div id=\"arrayArea\" class=\"array-row\"></div>\n  <div>\n    Click to probe manually: <label><input id=\"manualProbe\" type=\"checkbox\"> Manual probe mode</label>\n    <button id=\"probeSelected\">Probe selected (compare mid)</button>\n    <button id=\"forceSetMid\">Force mid to selected</button>\n    <button id=\"clearSelection\">Clear selection</button>\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Execution Controls</legend>\n  <button id=\"initSearch\">Initialize Search</button>\n  <button id=\"stepBack\">Step Back</button>\n  <button id=\"stepForward\">Step Forward</button>\n  <button id=\"autoRun\">Run Auto</button>\n  <button id=\"pauseRun\">Pause</button>\n  <button id=\"fastForward\">Complete</button>\n  <button id=\"resetSearch\">Reset</button>\n  Speed (ms): <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"400\">\n  <span id=\"speedVal\">400</span>\n  <div style=\"margin-top:6px\">\n    Jump to step: <input id=\"jumpStep\" type=\"number\" style=\"width:80px\"> <button id=\"jumpBtn\">Jump</button>\n    Save state: <button id=\"saveState\">Save</button> Load: <input id=\"loadState\" type=\"file\">\n    Export trace: <button id=\"exportTrace\">Export Trace JSON</button>\n    Import trace: <input id=\"importTrace\" type=\"file\">\n  </div>\n</fieldset>\n\n<fieldset>\n  <legend>Modes & Tools</legend>\n  <button id=\"linearCompare\">Run Linear Search (compare)</button>\n  <button id=\"explainStep\">Explain Current Step</button>\n  <label><input id=\"hints\" type=\"checkbox\"> Hints on step</label>\n  <button id=\"toggleLog\">Toggle Log Visibility</button>\n  <button id=\"undo\">Undo last change</button>\n  <button id=\"redo\">Redo</button>\n  <button id=\"simulateBug\">Inject common bug (mid wrong)</button>\n</fieldset>\n\n<fieldset>\n  <legend>Challenge Mode</legend>\n  <div class=\"small\">Try to minimize steps. A random target may be present or absent.</div>\n  <button id=\"startChallenge\">Start Challenge</button>\n  <button id=\"submitAnswer\">Submit Answer</button>\n  <div>Challenge status: <span id=\"challengeStatus\">idle</span></div>\n  <div>Score: <span id=\"challengeScore\">0</span></div>\n</fieldset>\n\n<fieldset>\n  <legend>State, Trace & Logs</legend>\n  <div>Current state: <span id=\"stateLabel\">idle</span></div>\n  <div>Low: <span id=\"lowVal\">-</span>, Mid: <span id=\"midVal\">-</span>, High: <span id=\"highVal\">-</span>, Comparisons: <span id=\"compVal\">0</span>, Steps: <span id=\"stepCount\">0</span></div>\n  <div>Result indices (found): <span id=\"resultIndices\">[]</span></div>\n  <div>Optimal bound log2(n): <span id=\"logBound\">-</span></div>\n  <div id=\"logBox\" class=\"log\"></div>\n</fieldset>\n\n<script>\n(function(){\n  // State and configuration\n  let array = [];\n  let selectedIndices = new Set();\n  let target = null;\n  let config = {\n    allowDup: false,\n    sorted: true,\n    order: 'asc',\n    comparator: 'number',\n    variant: 'any',\n    indexingBase: 0,\n    midCeil: false,\n    manualProbe: false,\n    offByOneBug: false\n  };\n\n  // Search runtime state (snapshots for undo/redo/step)\n  let search = {\n    initialized: false,\n    low: 0,\n    high: -1,\n    mid: null,\n    comparisons: 0,\n    steps: [],\n    stepIndex: -1, // points to current snapshot in steps\n    done: false,\n    foundIndices: [],\n    trace: [] // trace entries {low,mid,high,compOutcome,desc}\n  };\n\n  // Undo/Redo stacks for editing array or settings\n  let undoStack = [];\n  let redoStack = [];\n\n  // Auto-run timer\n  let autoTimer = null;\n\n  // Challenge mode\n  let challenge = {\n    running: false,\n    targetIndex: null,\n    optimalSteps: null,\n    usedSteps: 0,\n    startedAtSteps: 0\n  };\n\n  // Utility functions\n  function log(msg) {\n    const box = document.getElementById('logBox');\n    const time = new Date().toLocaleTimeString();\n    box.appendChild(document.createTextNode('['+time+'] '+msg));\n    box.appendChild(document.createElement('br'));\n    box.scrollTop = box.scrollHeight;\n  }\n\n  function clearLog() {\n    document.getElementById('logBox').innerHTML = '';\n  }\n\n  function parseArrayInput(text) {\n    if (!text) return [];\n    // split by comma or whitespace\n    let parts = text.split(/[\\s,]+/).filter(p=>p.length>0);\n    // interpret as numbers if comparator is numeric\n    return parts.map(p=>{\n      let num = Number(p);\n      return isFinite(num) ? num : p;\n    });\n  }\n\n  function shuffle(seed) {\n    // simple pseudo RNG, reproducible if seed provided\n    let s = seed ? hashCode(String(seed)) : Math.floor(Math.random()*1e9);\n    function rnd() { s = (s * 9301 + 49297) % 233280; return s / 233280; }\n    return rnd;\n  }\n  function hashCode(str) {\n    let h = 2166136261 >>> 0;\n    for (let i=0;i<str.length;i++) {\n      h ^= str.charCodeAt(i); h = Math.imul(h, 16777619) >>> 0;\n    }\n    return h;\n  }\n\n  function generateRandomArray(len, seed) {\n    let rnd = shuffle(seed);\n    let arr = [];\n    for (let i=0;i<len;i++) {\n      // generate values with some duplicates optionally\n      arr.push(Math.floor(rnd()*100));\n    }\n    if (config.sorted) {\n      arr.sort((a,b)=> (config.order==='asc' ? a-b : b-a));\n      if (config.allowDup) {\n        // optionally duplicate some\n        if (len > 1 && Math.random() < 0.5) {\n          for (let i=0;i<Math.floor(len/5);i++) {\n            let idx = Math.floor(rnd()*len);\n            let j = Math.min(len-1, idx+Math.floor(rnd()*3));\n            arr[j] = arr[idx];\n          }\n        }\n      }\n    }\n    return arr;\n  }\n\n  function fillRange(len) {\n    let arr = [];\n    for (let i=0;i<len;i++) arr.push(i*2);\n    if (config.order === 'desc') arr.reverse();\n    return arr;\n  }\n\n  function updateConfigFromUI() {\n    config.allowDup = document.getElementById('allowDup').checked;\n    config.sorted = document.getElementById('sorted').checked;\n    config.order = document.querySelector('input[name=\"order\"]:checked').value;\n    config.comparator = document.getElementById('comparator').value;\n    config.variant = document.getElementById('variant').value;\n    config.indexingBase = Number(document.querySelector('input[name=\"indexing\"]:checked').value);\n    config.midCeil = document.getElementById('midCeil').checked;\n    config.manualProbe = document.getElementById('manualProbe').checked;\n    config.offByOneBug = document.getElementById('offByOneBug').checked;\n  }\n\n  function renderArray() {\n    const area = document.getElementById('arrayArea');\n    area.innerHTML = '';\n    if (array.length === 0) { area.textContent = '(empty)'; return; }\n    // Build textual representation with indices and markers\n    // We'll create clickable spans (buttons would be styled but okay)\n    array.forEach((v,i)=>{\n      let wrapper = document.createElement('span');\n      wrapper.style.cursor = 'pointer';\n      wrapper.style.display = 'inline-block';\n      wrapper.style.paddingRight = '8px';\n      wrapper.dataset.index = i;\n      // marker strings\n      let markers = [];\n      if (search.initialized) {\n        if (i === search.low) markers.push('L');\n        if (i === search.mid) markers.push('M');\n        if (i === search.high) markers.push('H');\n      }\n      if (selectedIndices.has(i)) {\n        markers.push('S');\n      }\n      let idxDisplay = (config.indexingBase === 0) ? i : (i+1);\n      wrapper.textContent = '['+idxDisplay+'] '+String(v) + (markers.length ? ' <'+markers.join(',')+'>' : '');\n      wrapper.addEventListener('click', onArrayClick);\n      area.appendChild(wrapper);\n      area.appendChild(document.createTextNode(' '));\n    });\n  }\n\n  function onArrayClick(e) {\n    let i = Number(e.currentTarget.dataset.index);\n    let useClickTarget = document.getElementById('useClickTarget').checked;\n    if (useClickTarget) {\n      // set target to this element's value\n      target = array[i];\n      document.getElementById('targetInput').value = String(target);\n      log('Target set by clicking array: index '+i+' value '+target);\n      // optionally re-initialize\n    } else {\n      if (selectedIndices.has(i)) selectedIndices.delete(i);\n      else selectedIndices.add(i);\n    }\n    renderArray();\n  }\n\n  function comparatorCompare(a,b) {\n    if (config.comparator === 'number') {\n      let na = Number(a), nb = Number(b);\n      if (isNaN(na) || isNaN(nb)) {\n        // fallback to string compare\n        return String(a) < String(b) ? -1 : (String(a) > String(b) ? 1 : 0);\n      }\n      return na < nb ? -1 : (na > nb ? 1 : 0);\n    } else {\n      let sa = String(a), sb = String(b);\n      return sa < sb ? -1 : (sa > sb ? 1 : 0);\n    }\n  }\n\n  function computeMid(low, high) {\n    if (config.midCeil) {\n      let mid = Math.ceil((low + high) / 2);\n      if (config.offByOneBug) mid = Math.min(high, mid+1);\n      return mid;\n    } else {\n      let mid = Math.floor((low + high) / 2);\n      if (config.offByOneBug) mid = Math.max(low, mid-1);\n      return mid;\n    }\n  }\n\n  function snapshotState(desc) {\n    // store deep copy of relevant state\n    return {\n      low: search.low,\n      high: search.high,\n      mid: search.mid,\n      comparisons: search.comparisons,\n      done: search.done,\n      foundIndices: search.foundIndices.slice(),\n      desc: desc || ''\n    };\n  }\n\n  function pushStep(desc) {\n    let snap = snapshotState(desc);\n    // if we stepped forward after some undos, cut tail\n    if (search.stepIndex < search.steps.length - 1) {\n      search.steps = search.steps.slice(0, search.stepIndex + 1);\n    }\n    search.steps.push(snap);\n    search.stepIndex = search.steps.length - 1;\n    renderState();\n  }\n\n  function initSearch() {\n    updateConfigFromUI();\n    // read target input\n    let t = document.getElementById('targetInput').value;\n    target = t.length ? (config.comparator === 'number' ? Number(t) : t) : null;\n    if (target !== null && config.comparator === 'number' && isNaN(target)) {\n      // keep as string\n      target = t;\n    }\n    // initialize bounds\n    search.low = 0;\n    search.high = Math.max(0, array.length-1);\n    search.mid = null;\n    search.comparisons = 0;\n    search.done = false;\n    search.foundIndices = [];\n    search.trace = [];\n    search.steps = [];\n    search.stepIndex = -1;\n    search.initialized = true;\n    pushStep('initialized');\n    log('Search initialized. array length='+array.length+', target='+String(target));\n    // compute optimal bound\n    document.getElementById('logBound').textContent = (array.length>0) ? Math.ceil(Math.log2(array.length+1)) : '-';\n    renderArray();\n    renderState();\n    challenge.startedAtSteps = getTotalStepCount();\n  }\n\n  function stepForward() {\n    if (!search.initialized) { log('Search not initialized. Click Initialize Search first.'); return; }\n    if (search.done) { log('Search already completed.'); return; }\n    // perform one comparison step\n    let low = search.low, high = search.high;\n    if (low > high) {\n      // termination case: not found\n      search.done = true;\n      if (search.variant === 'insert') {\n        // insertion point is low\n        search.foundIndices = [low];\n        log('Terminated: insertion position '+low);\n      } else {\n        search.foundIndices = [];\n        log('Terminated: target not found.');\n      }\n      pushStep('terminated');\n      renderState();\n      return;\n    }\n    let mid = computeMid(low, high);\n    search.mid = mid;\n    let arrVal = array[mid];\n    search.comparisons++;\n    let cmp = comparatorCompare(arrVal, target);\n    let outcomeDesc = '';\n    if (cmp === 0) {\n      outcomeDesc = 'equal';\n      // handle variants\n      if (search.variant === 'any') {\n        search.foundIndices = [mid];\n        search.done = true;\n        log('Comparison at mid='+mid+' value='+arrVal+' => equal; finished');\n      } else if (search.variant === 'leftmost') {\n        // move left to find first occurrence\n        search.foundIndices = [mid];\n        // continue search on left half to find earlier equal\n        high = mid - 1;\n        search.high = high;\n        outcomeDesc += '; move high to mid-1 to find leftmost';\n        log('Comparison at mid='+mid+' value='+arrVal+' => equal; continue left to find leftmost');\n      } else if (search.variant === 'rightmost') {\n        search.foundIndices = [mid];\n        low = mid + 1;\n        search.low = low;\n        outcomeDesc += '; move low to mid+1 to find rightmost';\n        log('Comparison at mid='+mid+' value='+arrVal+' => equal; continue right to find rightmost');\n      } else if (search.variant === 'insert') {\n        // insertion - equal means found, but insertion point may be before duplicates\n        search.foundIndices = [mid];\n        // For insertion position, we might want first index of equals\n        high = mid - 1;\n        search.high = high;\n        outcomeDesc += '; equal - for insertion find earliest equal';\n        log('Comparison at mid='+mid+' value='+arrVal+' => equal; continue left for insertion position');\n      }\n    } else if (cmp < 0) {\n      // arrVal < target => move right\n      low = mid + 1;\n      search.low = low;\n      outcomeDesc = 'less -> move low to mid+1';\n      log('Comparison at mid='+mid+' value='+arrVal+' < target => move low to '+search.low);\n    } else { // cmp > 0\n      high = mid - 1;\n      search.high = high;\n      outcomeDesc = 'greater -> move high to mid-1';\n      log('Comparison at mid='+mid+' value='+arrVal+' > target => move high to '+search.high);\n    }\n    // save trace\n    search.trace.push({low, mid, high, comp: cmp, val: arrVal, desc: outcomeDesc, step: search.comparisons});\n    // check termination conditions for leftmost/rightmost/insert after moving bounds\n    if (!search.done && search.low > search.high) {\n      // concluded\n      search.done = true;\n      if (search.variant === 'insert') {\n        search.foundIndices = [search.low];\n        log('Ended: insertion position '+search.low);\n      } else {\n        // if we had captured foundIndices (equal case) but continued to find boundaries, we already have result\n        if (search.foundIndices.length>0) {\n          // For leftmost/rightmost, foundIndices hold last matched index (may not be final leftmost/rightmost)\n          // After termination, refine accordingly:\n          if (search.variant === 'leftmost') {\n            // we tracked the last equal we saw; but if we moved high leftwards, the earliest equal is the min foundIndices\n            // reconstruct: find leftmost equal in array by scanning left from previous found one\n            let f = search.foundIndices[0];\n            while (f>0 && comparatorCompare(array[f-1], target)===0) f--;\n            search.foundIndices = [f];\n            log('Leftmost resolved to index '+f);\n          } else if (search.variant === 'rightmost') {\n            let f = search.foundIndices[0];\n            while (f < array.length-1 && comparatorCompare(array[f+1], target)===0) f++;\n            search.foundIndices = [f];\n            log('Rightmost resolved to index '+f);\n          }\n        } else {\n          log('Target not found.');\n        }\n      }\n      pushStep('terminated');\n    } else {\n      pushStep('step '+search.comparisons+': mid='+mid+' cmp='+outcomeDesc);\n    }\n    renderState();\n  }\n\n  function stepBack() {\n    if (!search.initialized) { log('Search not initialized'); return; }\n    if (search.stepIndex <= 0) {\n      log('At initial state; cannot step back further.');\n      return;\n    }\n    search.stepIndex--;\n    let snap = search.steps[search.stepIndex];\n    restoreSnapshot(snap);\n    renderState();\n    log('Stepped back to index '+search.stepIndex+' desc: '+snap.desc);\n  }\n\n  function restoreSnapshot(snap) {\n    search.low = snap.low;\n    search.high = snap.high;\n    search.mid = snap.mid;\n    search.comparisons = snap.comparisons;\n    search.done = snap.done;\n    search.foundIndices = snap.foundIndices.slice();\n    // Note: trace is not rewound; trace is purely additive for illustration. We could slice it though:\n    search.trace = search.trace.slice(0, snap.comparisons);\n  }\n\n  function renderState() {\n    document.getElementById('stateLabel').textContent = search.initialized ? (search.done ? 'done' : 'running') : 'idle';\n    document.getElementById('lowVal').textContent = search.initialized ? ( (search.low!=null)?search.low:'-') : '-';\n    document.getElementById('midVal').textContent = search.initialized ? ( (search.mid!=null)?search.mid:'-') : '-';\n    document.getElementById('highVal').textContent = search.initialized ? ( (search.high!=null)?search.high:'-') : '-';\n    document.getElementById('compVal').textContent = search.comparisons;\n    document.getElementById('stepCount').textContent = search.steps.length;\n    document.getElementById('resultIndices').textContent = JSON.stringify(search.foundIndices);\n    renderArray();\n    // If hints enabled, show next hint\n    if (document.getElementById('hints').checked) {\n      let hint = explainCurrentStep(true);\n      if (hint) log('HINT: '+hint);\n    }\n  }\n\n  function explainCurrentStep(shortOnly) {\n    if (!search.initialized) return 'Search not initialized.';\n    if (search.stepIndex < 0) return 'Search initialized, no steps yet.';\n    let snap = search.steps[search.stepIndex];\n    let low = snap.low, high = snap.high, mid = snap.mid;\n    if (snap.desc) {\n      return snap.desc;\n    }\n    if (low > high) return 'Bounds crossed: low > high. Terminated.';\n    let midCalc = computeMid(low, high);\n    let s = 'Bounds ['+low+','+high+'] mid='+midCalc;\n    if (!shortOnly) {\n      s += '. Use comparator '+config.comparator+'. Variant: '+config.variant;\n    }\n    return s;\n  }\n\n  function explainStepBtn() {\n    let ex = explainCurrentStep(false);\n    log('Explanation: '+ex);\n    return ex;\n  }\n\n  function autoRunToggle() {\n    if (autoTimer) {\n      clearInterval(autoTimer); autoTimer = null; log('Auto-run paused'); return;\n    }\n    let speed = Number(document.getElementById('speed').value);\n    autoTimer = setInterval(()=>{\n      if (!search.initialized) { clearInterval(autoTimer); autoTimer=null; return; }\n      if (search.done) { clearInterval(autoTimer); autoTimer=null; log('Auto-run completed'); return; }\n      stepForward();\n      challenge.usedSteps++;\n    }, speed);\n    log('Auto-run started at '+speed+'ms');\n  }\n\n  function fastForward() {\n    if (!search.initialized) { log('Not initialized'); return; }\n    let loops = 0;\n    while (!search.done && loops < 100000) { stepForward(); loops++; }\n    log('Fast-forwarded to completion in '+loops+' steps (bounded).');\n  }\n\n  function resetSearch() {\n    search = {\n      initialized: false,\n      low: 0,\n      high: -1,\n      mid: null,\n      comparisons: 0,\n      steps: [],\n      stepIndex: -1,\n      done: false,\n      foundIndices: [],\n      trace: []\n    };\n    document.getElementById('stateLabel').textContent = 'idle';\n    renderState();\n    log('Search reset.');\n  }\n\n  function probeSelected() {\n    if (!search.initialized) { log('Initialize search first.'); return; }\n    if (!config.manualProbe) { log('Manual probe mode not enabled.'); return; }\n    if (selectedIndices.size === 0) { log('No selected index to probe.'); return; }\n    // use the first selected index as mid\n    let mid = Array.from(selectedIndices)[0];\n    search.mid = mid;\n    search.comparisons++;\n    let arrVal = array[mid];\n    let cmp = comparatorCompare(arrVal, target);\n    let desc = 'manual probe at mid='+mid+' compares val='+arrVal;\n    if (cmp === 0) {\n      log('Manual probe: equal at mid='+mid);\n      if (config.variant === 'any') {\n        search.foundIndices = [mid];\n        search.done = true;\n      } else {\n        // continue by rules: adjust bounds so the algorithm may proceed\n        if (config.variant === 'leftmost') {\n          search.foundIndices = [mid];\n          search.high = mid - 1;\n          log('Continue left to find leftmost');\n        } else if (config.variant === 'rightmost') {\n          search.foundIndices = [mid];\n          search.low = mid + 1;\n          log('Continue right to find rightmost');\n        } else if (config.variant === 'insert') {\n          search.foundIndices = [mid];\n          search.high = mid - 1;\n          log('Continue left for insertion position');\n        }\n      }\n    } else if (cmp < 0) {\n      search.low = mid + 1;\n      log('Manual probe: value < target; move low to '+search.low);\n    } else {\n      search.high = mid - 1;\n      log('Manual probe: value > target; move high to '+search.high);\n    }\n    search.trace.push({low: search.low, mid: mid, high: search.high, comp: cmp, val: arrVal, desc: desc, step: search.comparisons});\n    pushStep('manual probe mid='+mid);\n    renderState();\n  }\n\n  function forceSetMid() {\n    if (!search.initialized) { log('Init first'); return; }\n    if (selectedIndices.size === 0) { log('Select an index first'); return; }\n    let mid = Array.from(selectedIndices)[0];\n    search.mid = mid;\n    pushStep('forced mid='+mid);\n    renderState();\n    log('Forced mid to '+mid);\n  }\n\n  function clearSelection() {\n    selectedIndices.clear();\n    renderArray();\n  }\n\n  function linearCompare() {\n    let t = document.getElementById('targetInput').value;\n    let comp = config.comparator === 'number' ? Number(t) : t;\n    let steps = 0, found = -1;\n    for (let i=0;i<array.length;i++) {\n      steps++;\n      if (comparatorCompare(array[i], comp) === 0) { found = i; break; }\n    }\n    log('Linear search steps='+steps+' found index='+found);\n    alert('Linear search result: steps='+steps+' found index='+found);\n  }\n\n  function saveStateToFile() {\n    let obj = {\n      array: array,\n      config: config,\n      target: target,\n      search: search\n    };\n    let blob = new Blob([JSON.stringify(obj, null, 2)], {type:'application/json'});\n    let url = URL.createObjectURL(blob);\n    let a = document.createElement('a');\n    a.href = url; a.download = 'binary_search_state.json';\n    document.body.appendChild(a); a.click(); document.body.removeChild(a);\n    URL.revokeObjectURL(url);\n    log('State saved to file.');\n  }\n\n  function exportTrace() {\n    let blob = new Blob([JSON.stringify(search.trace, null, 2)], {type:'application/json'});\n    let url = URL.createObjectURL(blob);\n    let a = document.createElement('a');\n    a.href = url; a.download = 'binary_search_trace.json';\n    document.body.appendChild(a); a.click(); document.body.removeChild(a);\n    URL.revokeObjectURL(url);\n    log('Trace exported.');\n  }\n\n  function importTraceFile(file) {\n    if (!file) return;\n    let reader = new FileReader();\n    reader.onload = function(e) {\n      try {\n        let tr = JSON.parse(e.target.result);\n        search.trace = tr;\n        log('Trace imported with '+tr.length+' entries.');\n        // reflect last state if possible\n        if (tr.length>0) {\n          let last = tr[tr.length-1];\n          search.low = last.low; search.high = last.high; search.mid = last.mid;\n          pushStep('imported trace');\n        }\n      } catch(err) { log('Import failed: '+err.message); }\n    };\n    reader.readAsText(file);\n  }\n\n  function importStateFile(file) {\n    if (!file) return;\n    let reader = new FileReader();\n    reader.onload = function(e) {\n      try {\n        let obj = JSON.parse(e.target.result);\n        array = obj.array || [];\n        config = Object.assign(config, obj.config || {});\n        target = obj.target;\n        search = obj.search || search;\n        log('State imported.');\n        renderArray();\n        renderState();\n      } catch(err) { log('Import failed: '+err.message); }\n    };\n    reader.readAsText(file);\n  }\n\n  function getTotalStepCount() {\n    return search.comparisons;\n  }\n\n  function startChallenge() {\n    // generate random array and target\n    let len = Math.max(5, Number(document.getElementById('length').value) || 11);\n    array = generateRandomArray(len, Math.random());\n    // decide target present or absent\n    let present = Math.random() < 0.6;\n    let t;\n    if (present) {\n      let idx = Math.floor(Math.random()*array.length);\n      t = array[idx];\n      challenge.targetIndex = idx;\n    } else {\n      // choose a value guaranteed not in array (use high sentinel)\n      t = '__absent__'+Math.random();\n      challenge.targetIndex = null;\n    }\n    document.getElementById('targetInput').value = String(t);\n    updateConfigFromUI();\n    target = t;\n    initSearch();\n    challenge.running = true;\n    challenge.usedSteps = 0;\n   