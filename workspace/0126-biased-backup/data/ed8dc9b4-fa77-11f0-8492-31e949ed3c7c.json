    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Floyd-Warshall Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background-color: #1c1c1c;\n            color: #e5e5e5;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n        h1 {\n            font-size: 2.5rem;\n            margin-bottom: 20px;\n            text-align: center;\n            color: #ffcc00;\n        }\n        #canvas {\n            border: 2px solid #ffcc00;\n            border-radius: 10px;\n            box-shadow: 0 0 15px rgba(255, 204, 0, 0.5);\n            transition: transform 0.2s;\n        }\n        #canvas:hover {\n            transform: scale(1.05);\n        }\n        .controls {\n            position: absolute;\n            top: 20px;\n            left: 20px;\n        }\n        .button {\n            background-color: #ffcc00;\n            border: none;\n            padding: 10px 20px;\n            border-radius: 5px;\n            cursor: pointer;\n            font-size: 1rem;\n            color: black;\n            transition: background-color 0.3s, transform 0.2s;\n        }\n        .button:hover {\n            background-color: #e5e5e5;\n            color: #1c1c1c;\n            transform: scale(1.1);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"controls\">\n        <button class=\"button\" id=\"startBtn\">Start Visualization</button>\n    </div>\n    <canvas id=\"canvas\" width=\"600\" height=\"600\"></canvas>\n\n    <script>\n        const canvas = document.getElementById(\"canvas\");\n        const ctx = canvas.getContext(\"2d\");\n\n        const graph = [\n            [0, 3, 8, Infinity, -4],\n            [Infinity, 0, Infinity, 1, 7],\n            [Infinity, 4, 0, Infinity, Infinity],\n            [2, Infinity, -5, 0, Infinity],\n            [Infinity, Infinity, Infinity, 6, 0]\n        ];\n        \n        const numVertices = graph.length;\n        const distance = JSON.parse(JSON.stringify(graph));\n\n        function drawGraph() {\n            const w = 600 / (numVertices + 1);\n            const h = 600 / (numVertices + 1);\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            ctx.fillStyle = '#1c1c1c';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n            for (let i = 0; i < numVertices; i++) {\n                for (let j = 0; j < numVertices; j++) {\n                    const x1 = (i + 1) * w;\n                    const y1 = (j + 1) * h;\n                    ctx.fillStyle = '#ffcc00';\n                    ctx.fillRect(x1 - 15, y1 - 15, 30, 30);\n                    ctx.fillStyle = '#1c1c1c';\n                    ctx.textAlign = \"center\";\n                    ctx.fillText(distance[i][j] === Infinity ? \"∞\" : distance[i][j], x1, y1 + 10);\n                }\n            }\n        }\n\n        function floydWarshall() {\n            for (let k = 0; k < numVertices; k++) {\n                for (let i = 0; i < numVertices; i++) {\n                    for (let j = 0; j < numVertices; j++) {\n                        if (distance[i][j] > distance[i][k] + distance[k][j]) {\n                            distance[i][j] = distance[i][k] + distance[k][j];\n                            drawGraph();\n                        }\n                    }\n                }\n            }\n        }\n\n        document.getElementById('startBtn').addEventListener('click', () => {\n            floydWarshall();\n        });\n\n        drawGraph(); // Initial drawing\n    </script>\n</body>\n</html>"
