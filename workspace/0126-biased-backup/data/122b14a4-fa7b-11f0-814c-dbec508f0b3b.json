    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree</title>\n    <style>\n        body {\n            font-family: monospace;\n            background-color: #fff;\n            text-align: center;\n        }\n        #tree {\n            width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #tree div {\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #tree div:hover {\n            background-color: #f0f0f0;\n        }\n        #input {\n            width: 100%;\n            padding: 10px;\n            margin-bottom: 20px;\n            border: 1px solid #ccc;\n        }\n        #input label {\n            display: block;\n            margin-bottom: 10px;\n        }\n        #buttons {\n            margin-top: 20px;\n            text-align: right;\n        }\n        #buttons button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        #buttons button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tree\"></div>\n    <input id=\"input\" type=\"text\" placeholder=\"Enter key-value pair\">\n    <div id=\"buttons\">\n        <button id=\"add-btn\">Add</button>\n        <button id=\"remove-btn\">Remove</button>\n        <button id=\"update-btn\">Update</button>\n        <button id=\"clear-btn\">Clear</button>\n    </div>\n\n    <script>\n        class BTreeNode {\n            constructor() {\n                this.keys = [];\n                this.values = [];\n                this.children = [];\n                this.size = 0;\n                this.max = 1;\n            }\n\n            add(key, value) {\n                this.keys.push(key);\n                this.values.push(value);\n            }\n\n            remove(key) {\n                const index = this.keys.indexOf(key);\n                if (index !== -1) {\n                    this.keys.splice(index, 1);\n                    this.values.splice(index, 1);\n                    this.size -= 2;\n                }\n            }\n\n            update(key, value) {\n                const index = this.keys.indexOf(key);\n                if (index !== -1) {\n                    this.values[index] = value;\n                }\n            }\n\n            getKeys() {\n                return this.keys;\n            }\n\n            getValues() {\n                return this.values;\n            }\n\n            getChildren() {\n                return this.children;\n            }\n        }\n\n        class BTree {\n            constructor() {\n                this.root = new BTreeNode();\n            }\n\n            add(key, value) {\n                this.root.add(key, value);\n            }\n\n            remove(key) {\n                this.root.remove(key);\n            }\n\n            update(key, value) {\n                this.root.update(key, value);\n            }\n\n            getKeys() {\n                return this.root.getKeys();\n            }\n\n            getValues() {\n                return this.root.getValues();\n            }\n\n            getChildren() {\n                return this.root.getChildren();\n            }\n\n            search(key) {\n                return this.root.search(key);\n            }\n        }\n\n        const btree = new BTree();\n\n        const addBtn = document.getElementById('add-btn');\n        const removeBtn = document.getElementById('remove-btn');\n        const updateBtn = document.getElementById('update-btn');\n        const clearBtn = document.getElementById('clear-btn');\n\n        addBtn.addEventListener('click', () => {\n            const input = document.getElementById('input');\n            const key = input.value;\n            const value = input.value;\n            btree.add(key, value);\n            input.value = '';\n        });\n\n        removeBtn.addEventListener('click', () => {\n            const input = document.getElementById('input');\n            const key = input.value;\n            btree.remove(key);\n            input.value = '';\n        });\n\n        updateBtn.addEventListener('click', () => {\n            const input = document.getElementById('input');\n            const key = input.value;\n            const value = input.value;\n            btree.update(key, value);\n            input.value = '';\n        });\n\n        clearBtn.addEventListener('click', () => {\n            btree.root = new BTreeNode();\n        });\n\n        const treeDiv = document.getElementById('tree');\n        const input = document.getElementById('input');\n\n        function printTree(node, level = 0) {\n            if (node) {\n                treeDiv.innerHTML = '';\n                for (const child of node.getChildren()) {\n                    const div = document.createElement('div');\n                    div.style.width = `${level * 20}px`;\n                    div.style.padding = `${level * 10}px`;\n                    div.style.border = '1px solid #ccc';\n                    div.style.marginBottom = `${level * 10}px`;\n                    treeDiv.appendChild(div);\n                    printTree(child, level + 1);\n                }\n                if (node.keys.length > 0) {\n                    const div = document.createElement('div');\n                    div.style.width = `${level * 20}px`;\n                    div.style.padding = `${level * 10}px`;\n                    div.style.border = '1px solid #ccc';\n                    div.style.marginBottom = `${level * 10}px`;\n                    div.innerHTML = 'Keys: ' + node.keys.join(', ');\n                    treeDiv.appendChild(div);\n                }\n                if (node.values.length > 0) {\n                    const div = document.createElement('div');\n                    div.style.width = `${level * 20}px`;\n                    div.style.padding = `${level * 10}px`;\n                    div.style.border = '1px solid #ccc';\n                    div.style.marginBottom = `${level * 10}px`;\n                    div.innerHTML = 'Values: ' + node.values.join(', ');\n                    treeDiv.appendChild(div);\n                }\n            }\n        }\n\n        input.addEventListener('input', () => {\n            printTree(btree.root);\n        });\n\n        for (const child of btree.root.getChildren()) {\n            const div = document.createElement('div');\n            div.style.width = '100%';\n            div.style.padding = '10px';\n            div.style.border = '1px solid #ccc';\n            div.style.marginBottom = '10px';\n            treeDiv.appendChild(div);\n            div.innerHTML = 'Child ' + child.max;\n            for (let i = 0; i < child.max; i++) {\n                const div = document.createElement('div');\n                div.style.width = '20px';\n                div.style.padding = '5px';\n                div.style.border = '1px solid #ccc';\n                div.style.marginBottom = '5px';\n                treeDiv.appendChild(div);\n                div.innerHTML = i;\n            }\n        }\n    </script>\n</body>\n</html>"
