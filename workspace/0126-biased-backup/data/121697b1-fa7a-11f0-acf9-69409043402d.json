  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive REST API Explorer</title>\n<style>\n  /* Minimal styling: basic black text on white background */\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 1em;\n  }\n  label, input, select, button, textarea {\n    font-size: 1em;\n    font-family: monospace, monospace;\n    margin: 0.2em 0;\n  }\n  textarea {\n    width: 100%;\n    height: 8em;\n    font-family: monospace, monospace;\n  }\n  fieldset {\n    margin-top: 1em;\n    padding: 0.5em;\n  }\n  legend {\n    font-weight: bold;\n  }\n  #history {\n    max-height: 12em;\n    overflow-y: auto;\n    white-space: pre-wrap;\n    border: 1px solid black;\n    padding: 0.3em;\n    margin-top: 0.5em;\n    font-size: 0.9em;\n    background: #fff;\n  }\n  #responseBody {\n    width: 100%;\n    min-height: 10em;\n    font-family: monospace, monospace;\n  }\n  #errorOutput {\n    color: black;\n    font-weight: normal;\n  }\n</style>\n</head>\n<body>\n<h1>Interactive REST API Explorer</h1>\n\n<section id=\"endpointConfig\">\n  <fieldset>\n    <legend>Endpoint Configuration</legend>\n    <label for=\"urlInput\">URL:</label><br />\n    <input type=\"text\" id=\"urlInput\" placeholder=\"https://api.example.com/items\" size=\"60\" value=\"https://jsonplaceholder.typicode.com/posts\" /><br />\n\n    <label for=\"methodSelect\">HTTP Method:</label><br />\n    <select id=\"methodSelect\" aria-label=\"Select HTTP method\">\n      <option value=\"GET\" selected>GET</option>\n      <option value=\"POST\">POST</option>\n      <option value=\"PUT\">PUT</option>\n      <option value=\"PATCH\">PATCH</option>\n      <option value=\"DELETE\">DELETE</option>\n      <option value=\"HEAD\">HEAD</option>\n      <option value=\"OPTIONS\">OPTIONS</option>\n    </select><br />\n\n    <fieldset id=\"queryParamsFieldset\">\n      <legend>Query Parameters</legend>\n      <button type=\"button\" id=\"addQueryParam\">Add Query Parameter</button>\n      <div id=\"queryParamsContainer\"></div>\n    </fieldset>\n\n    <fieldset id=\"headersFieldset\">\n      <legend>Request Headers</legend>\n      <button type=\"button\" id=\"addHeader\">Add Header</button>\n      <div id=\"headersContainer\"></div>\n    </fieldset>\n\n    <fieldset id=\"bodyFieldset\" style=\"display:none\">\n      <legend>Request Body (JSON)</legend>\n      <textarea id=\"requestBody\" placeholder='{\"key\": \"value\"}' aria-label=\"Request body JSON\"></textarea>\n      <div id=\"bodyError\" style=\"color: darkred; font-weight: normal;\"></div>\n      <label><input type=\"checkbox\" id=\"prettyPrintRequest\" /> Pretty print body</label>\n    </fieldset>\n\n    <button type=\"button\" id=\"sendRequest\">Send Request</button>\n  </fieldset>\n</section>\n\n<section id=\"responseSection\" style=\"margin-top:1em\">\n  <fieldset>\n    <legend>Response</legend>\n    <div><b>Status:</b> <span id=\"responseStatus\">N/A</span></div>\n    <div><b>Headers:</b></div>\n    <textarea id=\"responseHeaders\" readonly aria-label=\"Response headers\"></textarea>\n\n    <div><b>Body:</b></div>\n    <textarea id=\"responseBody\" readonly aria-label=\"Response body\"></textarea>\n\n    <button type=\"button\" id=\"copyResponse\">Copy Body to Clipboard</button>\n    <button type=\"button\" id=\"clearResponse\">Clear Response</button>\n  </fieldset>\n</section>\n\n<section id=\"historySection\" style=\"margin-top:1em\">\n  <fieldset>\n    <legend>Request History (click to load)</legend>\n    <button type=\"button\" id=\"clearHistory\">Clear History</button>\n    <div id=\"history\" tabindex=\"0\" aria-label=\"Request history\"></div>\n  </fieldset>\n</section>\n\n<script>\n(() => {\n  // State\n  let history = [];\n  const maxHistoryEntries = 100;\n\n  // Cached elements\n  const urlInput = document.getElementById(\"urlInput\");\n  const methodSelect = document.getElementById(\"methodSelect\");\n  const queryParamsContainer = document.getElementById(\"queryParamsContainer\");\n  const headersContainer = document.getElementById(\"headersContainer\");\n  const addQueryParamBtn = document.getElementById(\"addQueryParam\");\n  const addHeaderBtn = document.getElementById(\"addHeader\");\n  const bodyFieldset = document.getElementById(\"bodyFieldset\");\n  const requestBodyTextarea = document.getElementById(\"requestBody\");\n  const bodyErrorDiv = document.getElementById(\"bodyError\");\n  const prettyPrintCheckbox = document.getElementById(\"prettyPrintRequest\");\n  const sendRequestBtn = document.getElementById(\"sendRequest\");\n  const responseStatusSpan = document.getElementById(\"responseStatus\");\n  const responseHeadersTextarea = document.getElementById(\"responseHeaders\");\n  const responseBodyTextarea = document.getElementById(\"responseBody\");\n  const copyResponseBtn = document.getElementById(\"copyResponse\");\n  const clearResponseBtn = document.getElementById(\"clearResponse\");\n  const historyDiv = document.getElementById(\"history\");\n  const clearHistoryBtn = document.getElementById(\"clearHistory\");\n\n  // Functions to create input sets for query params and headers\n  function createKeyValueInputPair(container, keyPlaceholder, valuePlaceholder, keyAria) {\n    // wrapper div\n    const wrapper = document.createElement(\"div\");\n\n    const keyInput = document.createElement(\"input\");\n    keyInput.type = \"text\";\n    keyInput.placeholder = keyPlaceholder || \"key\";\n    keyInput.setAttribute(\"aria-label\", keyAria || \"Key\");\n    keyInput.size = 20;\n\n    const valueInput = document.createElement(\"input\");\n    valueInput.type = \"text\";\n    valueInput.placeholder = valuePlaceholder || \"value\";\n    valueInput.setAttribute(\"aria-label\", valuePlaceholder || \"Value\");\n    valueInput.size = 30;\n\n    const removeBtn = document.createElement(\"button\");\n    removeBtn.type = \"button\";\n    removeBtn.textContent = \"Remove\";\n    removeBtn.addEventListener(\"click\", () => {\n      container.removeChild(wrapper);\n    });\n\n    wrapper.appendChild(keyInput);\n    wrapper.appendChild(document.createTextNode(\" = \"));\n    wrapper.appendChild(valueInput);\n    wrapper.appendChild(removeBtn);\n\n    container.appendChild(wrapper);\n    return { wrapper, keyInput, valueInput };\n  }\n\n  // Add initial row in query params and headers for usability\n  function addInitialRows() {\n    createKeyValueInputPair(queryParamsContainer, \"param\", \"value\", \"Query parameter key\");\n    createKeyValueInputPair(headersContainer, \"Header-Name\", \"Header-Value\", \"Header value\");\n  }\n\n  addInitialRows();\n\n  // Add event listeners for add buttons\n  addQueryParamBtn.addEventListener(\"click\", () => {\n    createKeyValueInputPair(queryParamsContainer, \"param\", \"value\", \"Query parameter key\");\n  });\n\n  addHeaderBtn.addEventListener(\"click\", () => {\n    createKeyValueInputPair(headersContainer, \"Header-Name\", \"Header-Value\", \"Header value\");\n  });\n\n  // Show/Hide body fieldset based on HTTP method\n  function updateBodyFieldsetVisibility() {\n    const method = methodSelect.value.toUpperCase();\n    if ([\"POST\", \"PUT\", \"PATCH\", \"DELETE\"].includes(method)) {\n      bodyFieldset.style.display = \"\";\n    } else {\n      bodyFieldset.style.display = \"none\";\n      // Clear body error and textarea if hidden\n      bodyErrorDiv.textContent = \"\";\n    }\n  }\n\n  methodSelect.addEventListener(\"change\", updateBodyFieldsetVisibility);\n  updateBodyFieldsetVisibility();\n\n  // Validate and pretty print request body if checkbox is checked\n  function validateRequestBody() {\n    const val = requestBodyTextarea.value.trim();\n    if (!val) {\n      bodyErrorDiv.textContent = \"\";\n      return true;\n    }\n    try {\n      const obj = JSON.parse(val);\n      bodyErrorDiv.textContent = \"\";\n      if (prettyPrintCheckbox.checked) {\n        requestBodyTextarea.value = JSON.stringify(obj, null, 2);\n      }\n      return true;\n    } catch (e) {\n      bodyErrorDiv.textContent = \"INVALID JSON: \" + e.message;\n      return false;\n    }\n  }\n\n  prettyPrintCheckbox.addEventListener(\"change\", () => {\n    validateRequestBody();\n  });\n\n  requestBodyTextarea.addEventListener(\"input\", () => {\n    // Remove body error as user types\n    bodyErrorDiv.textContent = \"\";\n  });\n\n  // Compose URL with query params\n  function composeUrlWithQueryParams(url, queryParams) {\n    if (!queryParams.length) return url;\n    let separator = url.includes(\"?\") ? \"&\" : \"?\";\n    const parts = [];\n    for (const { key, value } of queryParams) {\n      if (key !== \"\") parts.push(encodeURIComponent(key) + \"=\" + encodeURIComponent(value));\n    }\n    return url + (parts.length ? separator + parts.join(\"&\") : \"\");\n  }\n\n  // Parse query params from DOM inputs\n  function parseQueryParams() {\n    const params = [];\n    for (const div of queryParamsContainer.children) {\n      if (div.children.length < 3) continue;\n      const key = div.children[0].value.trim();\n      const value = div.children[2].value.trim();\n      if (key !== \"\") params.push({ key, value });\n    }\n    return params;\n  }\n\n  // Parse headers from DOM inputs\n  function parseHeaders() {\n    const hdrs = {};\n    for (const div of headersContainer.children) {\n      if (div.children.length < 3) continue;\n      const key = div.children[0].value.trim();\n      const value = div.children[2].value.trim();\n      if (key !== \"\") hdrs[key] = value;\n    }\n    return hdrs;\n  }\n\n  // Clear response display\n  function clearResponse() {\n    responseStatusSpan.textContent = \"N/A\";\n    responseHeadersTextarea.value = \"\";\n    responseBodyTextarea.value = \"\";\n  }\n\n  clearResponseBtn.addEventListener(\"click\", clearResponse);\n\n  // Copy response body to clipboard\n  copyResponseBtn.addEventListener(\"click\", () => {\n    if (responseBodyTextarea.value.trim() === \"\") return;\n    navigator.clipboard.writeText(responseBodyTextarea.value).then(() => {\n      alert(\"Response body copied to clipboard.\");\n    }).catch(() => {\n      alert(\"Failed to copy to clipboard.\");\n    });\n  });\n\n  // Store request+response in history\n  function storeInHistory(entry) {\n    history.unshift(entry);\n    if (history.length > maxHistoryEntries) history.pop();\n    refreshHistoryDom();\n  }\n\n  // Refresh history DOM list\n  function refreshHistoryDom() {\n    historyDiv.innerHTML = \"\";\n    if (!history.length) {\n      historyDiv.textContent = \"(No history)\";\n      return;\n    }\n    history.forEach((entry, idx) => {\n      const div = document.createElement(\"div\");\n      div.tabIndex = 0;\n      div.style.cursor = \"pointer\";\n      div.setAttribute(\"role\", \"button\");\n      div.setAttribute(\"aria-pressed\", \"false\");\n      let endpoint = entry.url.split(\"?\")[0];\n      if (endpoint.length > 60) endpoint = endpoint.slice(0, 60) + \"...\";\n      div.textContent = `${entry.method} ${endpoint} (Status: ${entry.status || \"N/A\"}, Req #${history.length - idx})`;\n      div.title = `${entry.method} ${entry.url}\\nStatus: ${entry.status || \"N/A\"}\\n\\nClick to load this request.`;\n      div.addEventListener(\"click\", () => {\n        loadEntryToInputs(entry);\n      });\n      div.addEventListener(\"keydown\", e => {\n        if (e.key === \"Enter\" || e.key === \" \") {\n          e.preventDefault();\n          div.click();\n        }\n      });\n      historyDiv.appendChild(div);\n    });\n  }\n\n  // Load entry from history to inputs\n  function loadEntryToInputs(entry) {\n    urlInput.value = entry.url.split(\"?\")[0];\n    // parse query params from URL (overrides)\n    const urlObj = new URL(entry.url);\n    const qparams = [];\n    for (const [k,v] of urlObj.searchParams) {\n      qparams.push({ key: k, value: v });\n    }\n    // Clear and fill queryParamsContainer\n    queryParamsContainer.innerHTML = \"\";\n    qparams.forEach(({key,value}) => {\n      createKeyValueInputPair(queryParamsContainer, \"param\", \"value\", \"Query parameter key\").keyInput.value = key;\n      queryParamsContainer.lastChild.children[2].value = value;\n    });\n    if (!qparams.length) addInitialRowsQueryParamsIfEmpty();\n\n    methodSelect.value = entry.method.toUpperCase();\n    updateBodyFieldsetVisibility();\n\n    // Clear and fill headers\n    headersContainer.innerHTML = \"\";\n    if (entry.requestHeaders && typeof entry.requestHeaders === \"object\") {\n      for (const [k, v] of Object.entries(entry.requestHeaders)) {\n        createKeyValueInputPair(headersContainer, \"Header-Name\", \"Header-Value\", \"Header value\").keyInput.value = k;\n        headersContainer.lastChild.children[2].value = v;\n      }\n    }\n    if (!headersContainer.children.length) addInitialRowsHeadersIfEmpty();\n\n    // Fill body (if any)\n    if (entry.requestBody) {\n      if (typeof entry.requestBody === \"object\") {\n        requestBodyTextarea.value = JSON.stringify(entry.requestBody, null, 2);\n      } else if (typeof entry.requestBody === \"string\") {\n        requestBodyTextarea.value = entry.requestBody;\n      } else {\n        requestBodyTextarea.value = \"\";\n      }\n    } else {\n      requestBodyTextarea.value = \"\";\n    }\n\n    // Fill response\n    responseStatusSpan.textContent = entry.status || \"N/A\";\n\n    if (entry.responseHeaders) {\n      try {\n        let hdrText = \"\";\n        for (const [k, v] of Object.entries(entry.responseHeaders)) {\n          hdrText += `${k}: ${v}\\n`;\n        }\n        responseHeadersTextarea.value = hdrText.trim();\n      } catch {\n        responseHeadersTextarea.value = \"\";\n      }\n    } else {\n      responseHeadersTextarea.value = \"\";\n    }\n\n    if (entry.responseBody) {\n      if (typeof entry.responseBody === \"object\") {\n        responseBodyTextarea.value = JSON.stringify(entry.responseBody, null, 2);\n      } else if (typeof entry.responseBody === \"string\") {\n        responseBodyTextarea.value = entry.responseBody;\n      } else {\n        responseBodyTextarea.value = \"\";\n      }\n    } else {\n      responseBodyTextarea.value = \"\";\n    }\n  }\n\n  function addInitialRowsQueryParamsIfEmpty() {\n    if (queryParamsContainer.children.length === 0) {\n      createKeyValueInputPair(queryParamsContainer, \"param\", \"value\", \"Query parameter key\");\n    }\n  }\n  function addInitialRowsHeadersIfEmpty() {\n    if (headersContainer.children.length === 0) {\n      createKeyValueInputPair(headersContainer, \"Header-Name\", \"Header-Value\", \"Header value\");\n    }\n  }\n  addInitialRowsQueryParamsIfEmpty();\n  addInitialRowsHeadersIfEmpty();\n\n  // Clear history on button click\n  clearHistoryBtn.addEventListener(\"click\", () => {\n    if (!confirm(\"Clear all request history?\")) return;\n    history = [];\n    refreshHistoryDom();\n  });\n\n  // Deep exploration: Support chaining requests by allowing viewing/copying response data,\n  // also provide small helper to extract JSON values for use in next request params\n  // Provide navigation for: on response, user can select JSON keys and copy their values for later use\n\n  // Parse JSON in response body for exploration if possible\n  function tryParseResponseBodyJson() {\n    const val = responseBodyTextarea.value.trim();\n    if (!val) return null;\n    try {\n      return JSON.parse(val);\n    } catch {\n      return null;\n    }\n  }\n\n  // Interactive JSON explorer: show keys in response JSON, click to copy value\n\n  // We’ll add a simple explorer below response body\n  const jsonExplorerContainer = document.createElement(\"details\");\n  const summary = document.createElement(\"summary\");\n  summary.textContent = \"Explore Response JSON\";\n  jsonExplorerContainer.appendChild(summary);\n  const explorerContent = document.createElement(\"pre\");\n  explorerContent.style.whiteSpace = \"pre-wrap\";\n  explorerContent.style.maxHeight = \"200px\";\n  explorerContent.style.overflowY = \"auto\";\n  explorerContent.style.border = \"1px solid black\";\n  explorerContent.style.padding = \"0.3em\";\n  jsonExplorerContainer.appendChild(explorerContent);\n  document.getElementById(\"responseSection\").appendChild(jsonExplorerContainer);\n\n  function buildJsonExplorer(obj, path=[]) {\n    if (typeof obj !== \"object\" || obj === null) return;\n    const container = document.createElement(\"ul\");\n    container.style.listStyle = \"none\";\n    container.style.paddingLeft = \"1em\";\n\n    for (const key of Object.keys(obj)) {\n      const li = document.createElement(\"li\");\n      const value = obj[key];\n      const spanKey = document.createElement(\"span\");\n      spanKey.textContent = key + \": \";\n      spanKey.style.cursor = \"pointer\";\n      spanKey.title = \"Click key path to copy its JSON path\";\n\n      spanKey.addEventListener(\"click\", e => {\n        const fullPath = [...path, key];\n        // JSON path string in dot notation\n        let jsonPath = fullPath.map(p => {\n          if (/^[a-zA-Z_$][a-zA-Z0-9_$]*$/.test(p)) return \".\" + p;\n          else return \"[\" + JSON.stringify(p) + \"]\";\n        }).join(\"\");\n        if (jsonPath.startsWith(\".\")) jsonPath = jsonPath.slice(1);\n        navigator.clipboard.writeText(jsonPath).then(() => {\n          alert(`JSON path copied: ${jsonPath}`);\n        }).catch(() => {\n          alert(\"Clipboard copy failed.\");\n        });\n        e.stopPropagation();\n      });\n      li.appendChild(spanKey);\n\n      if (typeof value === \"object\" && value !== null) {\n        li.appendChild(document.createTextNode(typeof value === \"object\" && Array.isArray(value) ? \"[Array]\" : \"[Object]\"));\n        const childList = buildJsonExplorer(value, [...path, key]);\n        if (childList) li.appendChild(childList);\n      } else {\n        const spanVal = document.createElement(\"span\");\n        let valDisplay = value === null ? \"null\" : value.toString();\n        if (typeof value === \"string\") valDisplay = `\"${valDisplay}\"`;\n        spanVal.textContent = valDisplay;\n        spanVal.style.cursor = \"pointer\";\n        spanVal.title = \"Click value to copy\";\n\n        spanVal.addEventListener(\"click\", e => {\n          let copyText = \"\";\n          if (typeof value === \"string\") copyText = value;\n          else copyText = JSON.stringify(value);\n          navigator.clipboard.writeText(copyText).then(() => {\n            alert(`Value copied: ${copyText}`);\n          }).catch(() => {\n            alert(\"Clipboard copy failed.\");\n          });\n          e.stopPropagation();\n        });\n\n        li.appendChild(spanVal);\n      }\n      container.appendChild(li);\n    }\n    return container;\n  }\n\n  // Update explorer on response update\n  function updateJsonExplorer() {\n    const json = tryParseResponseBodyJson();\n    if (!json) {\n      explorerContent.textContent = \"(Response is not valid JSON)\";\n      jsonExplorerContainer.open = false;\n      jsonExplorerContainer.style.display = \"none\";\n      return;\n    }\n    jsonExplorerContainer.style.display = \"\";\n    explorerContent.innerHTML = \"\";\n    const explorerTree = buildJsonExplorer(json);\n    if (!explorerTree) {\n      explorerContent.textContent = \"(Empty JSON Object)\";\n      jsonExplorerContainer.open = false;\n      return;\n    }\n    explorerContent.appendChild(explorerTree);\n    jsonExplorerContainer.open = false;\n  }\n\n\n  // On sendRequest click:\n  sendRequestBtn.addEventListener(\"click\", async () => {\n    clearResponse();\n    updateJsonExplorer();\n\n    const method = methodSelect.value.toUpperCase();\n    let urlStr = urlInput.value.trim();\n    if (!urlStr) {\n      alert(\"URL is required.\");\n      return;\n    }\n    // Compose URL with query parameters\n    const queryParams = parseQueryParams();\n    urlStr = composeUrlWithQueryParams(urlStr, queryParams);\n\n    // Parse headers\n    const headers = parseHeaders();\n\n    // Prepare body\n    let bodyPayload = null;\n    if ([\"POST\", \"PUT\", \"PATCH\", \"DELETE\"].includes(method)) {\n      if (!validateRequestBody()) {\n        alert(\"Invalid JSON body.\");\n        return;\n      }\n      const rawBody = requestBodyTextarea.value.trim();\n      if (rawBody) {\n        try {\n          // Send raw text for JSON body if valid JSON, it's safest to send stringified JSON with correct header\n          bodyPayload = rawBody;\n          if (!headers[\"Content-Type\"] && !headers[\"content-type\"]) {\n            // Assume JSON content type if not manually set\n            headers[\"Content-Type\"] = \"application/json; charset=utf-8\";\n          }\n        } catch {\n          alert(\"Failed to parse request body.\");\n          return;\n        }\n      }\n    }\n\n    sendRequestBtn.disabled = true;\n    sendRequestBtn.textContent = \"Sending...\";\n    try {\n      const fetchOptions = { method, headers };\n\n      // Use body only if method supports and bodyPayload is defined\n      if ([\"POST\", \"PUT\", \"PATCH\", \"DELETE\"].includes(method) && bodyPayload !== null) {\n        fetchOptions.body = bodyPayload;\n      }\n\n      const response = await fetch(urlStr, fetchOptions);\n      // Status\n      responseStatusSpan.textContent = response.status + \" \" + response.statusText;\n\n      // Headers\n      let hdrsText = \"\";\n      response.headers.forEach((value, key) => {\n        hdrsText += `${key}: ${value}\\n`;\n      });\n      responseHeadersTextarea.value = hdrsText.trim();\n\n      // Body\n      let respText = \"\";\n      let respBody = null;\n      try {\n        // Attempt JSON parse by default if content-type is JSON\n        const cType = response.headers.get(\"content-type\") || \"\";\n        if (cType.includes(\"json\")) {\n          respBody = await response.json();\n          respText = JSON.stringify(respBody, null, 2);\n        } else {\n          // fallback to text\n          respText = await response.text();\n          // Try parse JSON anyway (some APIs mislabel content-type)\n          try {\n            respBody = JSON.parse(respText);\n          } catch {}\n        }\n      } catch {\n        respText = \"(Error reading response body)\";\n      }\n      responseBodyTextarea.value = respText;\n\n      // Show explorer\n      updateJsonExplorer();\n\n      // Store in history\n      storeInHistory({\n        url: urlStr,\n        method,\n        requestHeaders: headers,\n        requestBody: (() => {\n          try {\n            return JSON.parse(requestBodyTextarea.value.trim());\n          } catch {\n            return requestBodyTextarea.value.trim() || null;\n          }\n        })(),\n        status: response.status + \" \" + response.statusText,\n        responseHeaders: (() => {\n          const h = {};\n          response.headers.forEach((v, k) => { h[k]=v; });\n          return h;\n        })(),\n        responseBody: respBody !== null ? respBody : responseBodyTextarea.value\n      });\n    } catch (e) {\n      responseStatusSpan.textContent = \"Network/Fetch Error\";\n      responseHeadersTextarea.value = \"\";\n      responseBodyTextarea.value = e.message || \"(Error)\";\n      updateJsonExplorer();\n      storeInHistory({\n        url: urlStr,\n        method,\n        requestHeaders: headers,\n        requestBody: requestBodyTextarea.value.trim() || null,\n        status: \"Network/Fetch Error\",\n        responseHeaders: null,\n        responseBody: e.message || \"(Error)\"\n      });\n      alert(\"Network error or fetch failed: \" + e.message);\n    } finally {\n      sendRequestBtn.disabled = false;\n      sendRequestBtn.textContent = \"Send Request\";\n    }\n\n  });\n\n  // Initial refresh history empty state\n  refreshHistoryDom();\n\n  // Accessibility notes:\n  // We ensured all interactive elements have labels or aria-labels,\n  // keyboard navigation for history,\n  // buttons have focus and tab indices by default.\n\n})();\n</script>\n</body>\n</html>"
  },
