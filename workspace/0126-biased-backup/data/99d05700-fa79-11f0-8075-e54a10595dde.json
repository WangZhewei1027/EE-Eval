    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Query Optimization Simulator</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .hidden {\n            display: none;\n        }\n        #results {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Query Optimization Simulator</h1>\n\n<div>\n    <label for=\"select-table\">Select Table:</label>\n    <select id=\"select-table\">\n        <option value=\"users\">Users</option>\n        <option value=\"orders\">Orders</option>\n        <option value=\"products\">Products</option>\n    </select>\n</div>\n\n<div>\n    <label for=\"filters\">Add Filters:</label>\n    <input type=\"text\" id=\"filters\" placeholder=\"e.g. age>30\"/>\n    <button id=\"add-filter\">Add Filter</button>\n</div>\n\n<div>\n    <label for=\"sort-order\">Sort Order:</label>\n    <select id=\"sort-order\">\n        <option value=\"asc\">Ascending</option>\n        <option value=\"desc\">Descending</option>\n    </select>\n</div>\n\n<div>\n    <label for=\"limit\">Limit Results:</label>\n    <input type=\"number\" id=\"limit\" placeholder=\"e.g. 10\" value=\"10\"/>\n</div>\n\n<button id=\"execute-query\">Execute Query</button>\n\n<div id=\"results\" class=\"hidden\">\n    <h2>Query Results:</h2>\n    <pre id=\"output\"></pre>\n</div>\n\n<script>\n    let filters = [];\n\n    document.getElementById('add-filter').addEventListener('click', () => {\n        const filter = document.getElementById('filters').value;\n        if (filter) {\n            filters.push(filter);\n            document.getElementById('filters').value = '';\n            updateOutput();\n        }\n    });\n\n    document.getElementById('execute-query').addEventListener('click', () => {\n        const table = document.getElementById('select-table').value;\n        const sortOrder = document.getElementById('sort-order').value;\n        const limit = document.getElementById('limit').value;\n\n        const query = `SELECT * FROM ${table} WHERE ${filters.join(' AND ')} ORDER BY id ${sortOrder} LIMIT ${limit};`;\n        document.getElementById('output').textContent = query;\n        document.getElementById('results').classList.remove('hidden');\n    });\n\n    function updateOutput() {\n        const table = document.getElementById('select-table').value;\n        const sortOrder = document.getElementById('sort-order').value;\n        const limit = document.getElementById('limit').value;\n\n        const query = `SELECT * FROM ${table} WHERE ${filters.join(' AND ')} ORDER BY id ${sortOrder} LIMIT ${limit};`;\n        document.getElementById('output').textContent = query;\n    }\n</script>\n\n</body>\n</html>"
