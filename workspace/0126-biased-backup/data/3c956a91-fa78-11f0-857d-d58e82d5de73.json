    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Doubly Linked List Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap');\n\n  /* Reset and base */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(135deg, #2c3e50, #4ca1af);\n    font-family: 'Poppins', sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    color: #eef4f7;\n    overflow-x: hidden;\n    user-select: none;\n  }\n  h1 {\n    margin: 2rem 0 1rem;\n    font-weight: 600;\n    font-size: 2.8rem;\n    letter-spacing: 1.2px;\n    text-shadow:\n      1px 1px 2px #16313d,\n      0 0 12px #72c6d1aa;\n  }\n  p.description {\n    font-weight: 300;\n    max-width: 600px;\n    text-align: center;\n    font-size: 1.1rem;\n    line-height: 1.5;\n    margin: 0 0 3rem 0;\n    color: #d9e6eddd;\n    filter: drop-shadow(0 0 3px #9ad4e099);\n  }\n\n  /* Container for linked list */\n  .dll-container {\n    position: relative;\n    width: 90vw;\n    max-width: 900px;\n    height: 170px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 36px;\n    padding: 0 24px;\n    user-select: none;\n  }\n\n  /* Each node box */\n  .node {\n    position: relative;\n    background: linear-gradient(145deg, #355a7c, #2d4661);\n    border-radius: 18px;\n    width: 110px;\n    height: 130px;\n    box-shadow:\n      4px 4px 16px #233a52,\n      inset 0 0 9px #4a738f,\n      inset 0 4px 16px #3676a1;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-evenly;\n    align-items: center;\n    cursor: default;\n    transition: box-shadow 0.4s ease;\n  }\n\n  .node:hover {\n    box-shadow:\n      0 0 24px 2px #7ad1f2cc,\n      inset 0 0 18px #87c2e7ff,\n      0 8px 20px rgba(80,155,200,0.8);\n    z-index: 10;\n  }\n\n  /* Node title */\n  .node .value {\n    font-weight: 600;\n    font-size: 3rem;\n    color: #c9e7fc;\n    text-shadow:\n      0 0 6px #50b5f5cc,\n      0 0 20px #72c6d1cc;\n  }\n\n  /* Labels (Prev / Next) */\n  .node .label {\n    font-weight: 600;\n    font-size: 0.85rem;\n    text-transform: uppercase;\n    color: #6ab7dbbb;\n    letter-spacing: 1.8px;\n    user-select: none;\n  }\n\n  /* Links container (Prev/Next) */\n  .links {\n    width: 90%;\n    display: flex;\n    justify-content: space-between;\n    margin-top: 8px;\n    pointer-events: none;\n  }\n\n  /* Prev and Next boxes */\n  .links > div {\n    background: #4a7bab99;\n    border-radius: 10px;\n    width: 38px;\n    height: 40px;\n    box-shadow:\n      inset 0 2px 4px #acd4ffaa,\n      1px 2px 7px #2e546d77;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    color: #c0d8f2cc;\n    font-weight: 600;\n    font-size: 1.2rem;\n    user-select: none;\n  }\n\n  /* Arrow shapes are separate for crispness */\n  svg.arrow {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    fill: none;\n    stroke: #7dd8ffcc;\n    stroke-width: 3;\n    filter: drop-shadow(0 0 3px #4ab0ffaa);\n    opacity: 0.85;\n    transition: stroke 0.3s ease;\n  }\n  svg.arrow.prev {\n    left: -60px;\n    width: 50px;\n    height: 28px;\n  }\n  svg.arrow.next {\n    right: -60px;\n    width: 50px;\n    height: 28px;\n  }\n  .node:hover > svg.arrow {\n    stroke: #a6dfff;\n    filter: drop-shadow(0 0 8px #9ededfff);\n    opacity: 1;\n  }\n\n  /* Arrows paths */\n  path.arrow-prev {\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n  path.arrow-next {\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* Circular highlight for head and tail */\n  .head-tail-indicator {\n    position: absolute;\n    top: -38px;\n    font-weight: 700;\n    font-size: 0.9rem;\n    padding: 3px 12px;\n    border-radius: 28px;\n    background: linear-gradient(135deg, #5aced5ff, #0a7fb8ff);\n    box-shadow:\n      0 0 12px #21b0eccc,\n      inset 0 2px 8px #7cd9f5dd;\n    color: #f0faff;\n    user-select: none;\n    pointer-events: none;\n    letter-spacing: 1.4px;\n    text-shadow: 0 0 4px #47c7f9cc;\n    transition: background 0.5s ease;\n  }\n\n  /* Controls panel */\n  .controls {\n    margin: 3rem 0 4rem;\n    display: flex;\n    gap: 2rem;\n  }\n  button {\n    background: linear-gradient(135deg, #518bc4, #2d4e82);\n    border: none;\n    border-radius: 32px;\n    padding: 14px 34px;\n    color: #d7eaf7;\n    font-weight: 600;\n    font-size: 1.1rem;\n    cursor: pointer;\n    box-shadow:\n      0 3px 10px #214c85bb,\n      inset 0 2px 6px #75a3dbcc;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.4s ease,\n      transform 0.25s ease;\n    user-select: none;\n  }\n  button:hover {\n    background: linear-gradient(135deg, #7fcaff, #3b72b6);\n    box-shadow:\n      0 5px 20px #7ed2ffcc,\n      inset 0 3px 9px #c6e1ffcc;\n    transform: scale(1.05);\n  }\n  button:active {\n    transform: scale(1);\n    box-shadow:\n      0 2px 6px #5191ccaa,\n      inset 0 1px 3px #4d82b8cc;\n  }\n\n  /* Footer minimal */\n  footer {\n    font-size: 0.85rem;\n    color: #a1bddbee;\n    margin-bottom: 2rem;\n  }\n\n  /* Animations */\n  @keyframes pulseGlow {\n    0%, 100% {\n      box-shadow:\n        0 0 16px #3db0eaff,\n        0 0 32px #7fd5ffff;\n    }\n    50% {\n      box-shadow:\n        0 0 8px #2491da88,\n        0 0 20px #56b5f299;\n    }\n  }\n  .highlighted {\n    animation: pulseGlow 3.8s ease-in-out infinite;\n  }\n</style>\n</head>\n<body>\n  <h1>Doubly Linked List</h1>\n  <p class=\"description\">\n    A <em>doubly linked list</em> is a data structure consisting of nodes<br />\n    where each node contains <strong>value</strong>, a pointer to the <strong>previous</strong> node and a pointer to the <strong>next</strong> node.<br />\n    Here’s a polished visualization illustrating the connections and flow.\n  </p>\n\n  <div class=\"dll-container\" aria-label=\"Doubly linked list visualization\" role=\"list\">\n    <!-- Node 0 / Head -->\n    <div class=\"node\" role=\"listitem\" aria-label=\"Node with value 10, head of list\" id=\"node0\">\n      <div class=\"value\">10</div>\n      <div class=\"links\">\n        <div class=\"prev\" aria-label=\"Previous pointer is null\">∅</div>\n        <div class=\"next\" aria-label=\"Next pointer exists\">→</div>\n      </div>\n      <!-- Prev arrow: none for head -->\n      <!-- Next arrow -->\n      <svg class=\"arrow next\" viewBox=\"0 0 50 28\" aria-hidden=\"true\" >\n        <path class=\"arrow-next\" d=\"M2 14 L46 14 M40 8 L46 14 L40 20\" />\n      </svg>\n      <div class=\"head-tail-indicator\">HEAD</div>\n    </div>\n\n    <!-- Node 1 -->\n    <div class=\"node\" role=\"listitem\" aria-label=\"Node with value 22\" id=\"node1\">\n      <div class=\"value\">22</div>\n      <div class=\"links\">\n        <div class=\"prev\" aria-label=\"Previous pointer exists\">←</div>\n        <div class=\"next\" aria-label=\"Next pointer exists\">→</div>\n      </div>\n      <!-- Prev arrow -->\n      <svg class=\"arrow prev\" viewBox=\"0 0 50 28\" aria-hidden=\"true\" >\n        <path class=\"arrow-prev\" d=\"M48 14 L4 14 M10 8 L4 14 L10 20\" />\n      </svg>\n      <!-- Next arrow -->\n      <svg class=\"arrow next\" viewBox=\"0 0 50 28\" aria-hidden=\"true\" >\n        <path class=\"arrow-next\" d=\"M2 14 L46 14 M40 8 L46 14 L40 20\" />\n      </svg>\n    </div>\n\n    <!-- Node 2 -->\n    <div class=\"node\" role=\"listitem\" aria-label=\"Node with value 35\" id=\"node2\">\n      <div class=\"value\">35</div>\n      <div class=\"links\">\n        <div class=\"prev\" aria-label=\"Previous pointer exists\">←</div>\n        <div class=\"next\" aria-label=\"Next pointer exists\">→</div>\n      </div>\n      <!-- Prev arrow -->\n      <svg class=\"arrow prev\" viewBox=\"0 0 50 28\" aria-hidden=\"true\" >\n        <path class=\"arrow-prev\" d=\"M48 14 L4 14 M10 8 L4 14 L10 20\" />\n      </svg>\n      <!-- Next arrow -->\n      <svg class=\"arrow next\" viewBox=\"0 0 50 28\" aria-hidden=\"true\" >\n        <path class=\"arrow-next\" d=\"M2 14 L46 14 M40 8 L46 14 L40 20\" />\n      </svg>\n    </div>\n\n    <!-- Node 3 -->\n    <div class=\"node\" role=\"listitem\" aria-label=\"Node with value 47\" id=\"node3\">\n      <div class=\"value\">47</div>\n      <div class=\"links\">\n        <div class=\"prev\" aria-label=\"Previous pointer exists\">←</div>\n        <div class=\"next\" aria-label=\"Next pointer exists\">→</div>\n      </div>\n      <!-- Prev arrow -->\n      <svg class=\"arrow prev\" viewBox=\"0 0 50 28\" aria-hidden=\"true\" >\n        <path class=\"arrow-prev\" d=\"M48 14 L4 14 M10 8 L4 14 L10 20\" />\n      </svg>\n      <!-- Next arrow -->\n      <svg class=\"arrow next\" viewBox=\"0 0 50 28\" aria-hidden=\"true\" >\n        <path class=\"arrow-next\" d=\"M2 14 L46 14 M40 8 L46 14 L40 20\" />\n      </svg>\n    </div>\n\n    <!-- Node 4 / Tail -->\n    <div class=\"node\" role=\"listitem\" aria-label=\"Node with value 59, tail of list\" id=\"node4\">\n      <div class=\"value\">59</div>\n      <div class=\"links\">\n        <div class=\"prev\" aria-label=\"Previous pointer exists\">←</div>\n        <div class=\"next\" aria-label=\"Next pointer is null\">∅</div>\n      </div>\n      <!-- Prev arrow -->\n      <svg class=\"arrow prev\" viewBox=\"0 0 50 28\" aria-hidden=\"true\" >\n        <path class=\"arrow-prev\" d=\"M48 14 L4 14 M10 8 L4 14 L10 20\" />\n      </svg>\n      <!-- Next arrow: none for tail -->\n      <div class=\"head-tail-indicator\" style=\"background: linear-gradient(135deg, #db4b4b, #a32020); box-shadow: 0 0 18px #ff6060aa inset, 0 0 14px #e13c3ccc; text-shadow: 0 0 6px #f4565622;\">\n        TAIL\n      </div>\n    </div>\n  </div>\n\n  <div class=\"controls\" aria-label=\"Controls to highlight node\">\n    <button id=\"highlight-prev\" aria-label=\"Highlight previous node\">← Highlight Prev</button>\n    <button id=\"highlight-next\" aria-label=\"Highlight next node\">Highlight Next →</button>\n  </div>\n\n  <footer>\n    Visualization by AI &mdash; Inspired by classic data structures.\n  </footer>\n\n<script>\n  (function(){\n    const nodes = [\n      document.getElementById('node0'),\n      document.getElementById('node1'),\n      document.getElementById('node2'),\n      document.getElementById('node3'),\n      document.getElementById('node4'),\n    ];\n    let currentIndex = 0;\n\n    // Initially highlight HEAD\n    nodes[currentIndex].classList.add('highlighted');\n\n    const highlightPrevBtn = document.getElementById('highlight-prev');\n    const highlightNextBtn = document.getElementById('highlight-next');\n\n    function updateHighlight(newIndex) {\n      if(newIndex < 0 || newIndex >= nodes.length) return;\n      nodes[currentIndex].classList.remove('highlighted');\n      currentIndex = newIndex;\n      nodes[currentIndex].classList.add('highlighted');\n      // Scroll node into center smoothly\n      nodes[currentIndex].scrollIntoView({\n        behavior: 'smooth',\n        block: 'nearest',\n        inline: 'center'\n      });\n    }\n\n    highlightPrevBtn.addEventListener('click', () => {\n      if(currentIndex > 0){\n        updateHighlight(currentIndex - 1);\n      }\n    });\n    highlightNextBtn.addEventListener('click', () => {\n      if(currentIndex < nodes.length -1){\n        updateHighlight(currentIndex + 1);\n      }\n    });\n\n  })();\n</script>\n</body>\n</html>"
