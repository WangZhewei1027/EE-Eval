    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Circular Linked List Visualization</title>\n    <style>\n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background: linear-gradient(135deg, #6a11cb, #2575fc);\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            overflow: hidden;\n        }\n        .container {\n            position: relative;\n            width: 600px;\n            height: 600px;\n            border-radius: 50%;\n            overflow: hidden;\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);\n        }\n        .node {\n            position: absolute;\n            width: 100px;\n            height: 100px;\n            border-radius: 50%;\n            background-color: #FFCE54;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 24px;\n            font-weight: bold;\n            color: #333;\n            transition: transform 0.3s, box-shadow 0.3s;\n        }\n        .node:hover {\n            transform: scale(1.1);\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);\n        }\n        .button-container {\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            display: flex;\n            gap: 20px;\n        }\n        .button {\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            background-color: #FF6F61;\n            color: white;\n            font-size: 16px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n        }\n        .button:hover {\n            background-color: #FF4C31;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\" id=\"circle\">\n        <div class=\"node\" style=\"transform: rotate(0deg) translate(250px) rotate(0deg);\">A</div>\n        <div class=\"node\" style=\"transform: rotate(60deg) translate(250px) rotate(-60deg);\">B</div>\n        <div class=\"node\" style=\"transform: rotate(120deg) translate(250px) rotate(-120deg);\">C</div>\n        <div class=\"node\" style=\"transform: rotate(180deg) translate(250px) rotate(-180deg);\">D</div>\n        <div class=\"node\" style=\"transform: rotate(240deg) translate(250px) rotate(-240deg);\">E</div>\n        <div class=\"node\" style=\"transform: rotate(300deg) translate(250px) rotate(-300deg);\">F</div>\n    </div>\n    <div class=\"button-container\">\n        <button class=\"button\" onclick=\"startAnimation()\">Start Animation</button>\n        <button class=\"button\" onclick=\"resetAnimation()\">Reset</button>\n    </div>\n\n    <script>\n        let angle = 0;\n        let intervalId;\n\n        function startAnimation() {\n            if (intervalId) return; // Prevent multiple intervals\n            intervalId = setInterval(() => {\n                angle = (angle + 6) % 360; // Rotate by 6 degrees\n                document.querySelectorAll('.node').forEach((node, index) => {\n                    node.style.transform = `rotate(${angle + (index * 60)}deg) translate(250px) rotate(-${angle + (index * 60)}deg)`;\n                });\n            }, 100);\n        }\n\n        function resetAnimation() {\n            clearInterval(intervalId);\n            intervalId = null;\n            angle = 0;\n            document.querySelectorAll('.node').forEach((node, index) => {\n                node.style.transform = `rotate(${(index * 60)}deg) translate(250px) rotate(-${(index * 60)}deg)`;\n            });\n        }\n    </script>\n</body>\n</html>"
