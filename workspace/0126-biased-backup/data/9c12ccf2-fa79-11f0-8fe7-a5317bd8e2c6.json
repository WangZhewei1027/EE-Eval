    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Doubly Linked List Explorer</title>\n<style>\n/* Extremely minimal styling: only basic spacing and monospace for clarity */\nbody { font-family: monospace; margin: 10px; }\nsection { margin-bottom: 12px; }\n.controls { display: block; }\n.row { display: block; margin: 6px 0; }\n.small { font-size: 12px; }\ntextarea { width: 100%; height: 120px; }\ninput[type=\"range\"] { width: 220px; }\nbutton { margin-right: 6px; }\n.table { white-space: pre; font-family: monospace; }\n.nodeButton { margin: 2px; padding: 2px 6px; }\n</style>\n</head>\n<body>\n\n<h1>Doubly Linked List Explorer</h1>\n\n<section>\n  <div class=\"controls\">\n    <div class=\"row\">\n      Build node value: <input id=\"valInput\" type=\"text\" value=\"A\">\n      Insert at:\n      <select id=\"posSelect\">\n        <option value=\"head\">Head</option>\n        <option value=\"tail\" selected>Tail</option>\n        <option value=\"index\">Index</option>\n        <option value=\"after\">After Node ID</option>\n        <option value=\"before\">Before Node ID</option>\n      </select>\n      Index/Node ID: <input id=\"posIndex\" type=\"number\" style=\"width:80px\" value=\"0\">\n      <button id=\"insertBtn\">Insert</button>\n      <button id=\"createHeadBtn\">Create New List (clear)</button>\n      <button id=\"randomBtn\">Random Populate</button>\n      Size: <input type=\"number\" id=\"randSize\" value=\"6\" style=\"width:60px\">\n    </div>\n\n    <div class=\"row\">\n      Delete by:\n      <select id=\"delMode\">\n        <option value=\"id\">Node ID</option>\n        <option value=\"index\">Index</option>\n        <option value=\"value\">First with Value</option>\n      </select>\n      <input id=\"delInput\" type=\"text\" value=\"0\" style=\"width:120px\">\n      <button id=\"deleteBtn\">Delete</button>\n\n      Find value: <input id=\"findVal\" type=\"text\" style=\"width:100px\" value=\"A\">\n      <button id=\"findBtn\">Find (first)</button>\n      <button id=\"findAllBtn\">Find All</button>\n    </div>\n\n    <div class=\"row\">\n      Move Node ID: <input id=\"moveId\" type=\"number\" style=\"width:70px\" value=\"0\">\n      To index: <input id=\"moveIndex\" type=\"number\" style=\"width:70px\" value=\"0\">\n      <button id=\"moveBtn\">Move</button>\n\n      Swap IDs: <input id=\"swapA\" type=\"number\" style=\"width:60px\" value=\"0\">\n      <input id=\"swapB\" type=\"number\" style=\"width:60px\" value=\"1\">\n      <button id=\"swapBtn\">Swap</button>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"reverseBtn\">Reverse List</button>\n      <button id=\"rotateBtn\">Rotate Right by k</button>\n      k: <input id=\"rotK\" type=\"number\" style=\"width:60px\" value=\"1\">\n      <label><input type=\"checkbox\" id=\"circularToggle\"> Make Circular (toggle)</label>\n      <label><input type=\"checkbox\" id=\"sentinelToggle\"> Use Sentinel Head</label>\n      <button id=\"repairBtn\">Repair Pointers (try)</button>\n      <button id=\"clearBrokenBtn\">Remove Broken Links (safe repair)</button>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"splitBtn\">Split at index</button>\n      index: <input id=\"splitIndex\" type=\"number\" style=\"width:60px\" value=\"2\">\n      <button id=\"mergeBtn\">Merge with secondary list</button>\n      <button id=\"cloneBtn\">Clone Selected Node (create copy)</button>\n      Selected node id: <input id=\"selectedIdInput\" type=\"number\" style=\"width:80px\" value=\"-1\">\n    </div>\n\n    <div class=\"row\">\n      Algorithm:\n      <select id=\"algoSelect\">\n        <option value=\"bubble\">Bubble Sort (step)</option>\n        <option value=\"insertion\">Insertion Sort (step)</option>\n        <option value=\"none\">None</option>\n      </select>\n      <button id=\"algoPrepareBtn\">Prepare Algorithm Steps</button>\n      <button id=\"algoStepBtn\">Step Algorithm</button>\n      <button id=\"algoResetBtn\">Reset Algorithm</button>\n      <span class=\"small\"> (Sorts by node value lexicographically)</span>\n    </div>\n\n    <div class=\"row\">\n      Export/Import JSON:\n      <button id=\"exportBtn\">Export</button>\n      <button id=\"importBtn\">Import (paste below)</button>\n    </div>\n\n  </div>\n</section>\n\n<section>\n  <div class=\"row\">\n    History controls:\n    <button id=\"undoBtn\">Undo</button>\n    <button id=\"redoBtn\">Redo</button>\n    <button id=\"snapshotBtn\">Save Snapshot</button>\n    <input id=\"historySlider\" type=\"range\" min=\"0\" max=\"0\" value=\"0\">\n    <span id=\"historyLabel\">0 / 0</span>\n    <button id=\"playBtn\">Play</button>\n    <button id=\"pauseBtn\">Pause</button>\n    Interval ms: <input id=\"playInterval\" type=\"number\" value=\"600\" style=\"width:80px\">\n  </div>\n\n  <div class=\"row\">\n    Quick workflow recorder name: <input id=\"macroName\" type=\"text\" value=\"session\">\n    <button id=\"startMacro\">Start Recording</button>\n    <button id=\"stopMacro\">Stop & Save</button>\n    <button id=\"playMacro\">Play Macro</button>\n    <select id=\"macroList\"></select>\n    <button id=\"clearMacros\">Clear Macros</button>\n  </div>\n\n</section>\n\n<section>\n  Visualization:\n  <div id=\"visual\" class=\"table\"></div>\n  <div id=\"details\" class=\"table\"></div>\n  <div id=\"nodeButtons\"></div>\n</section>\n\n<section>\n  Inspector:\n  <div id=\"inspector\" class=\"table\"></div>\n  <div class=\"row\">\n    Edit selected node value: <input id=\"editVal\" type=\"text\" style=\"width:140px\">\n    <button id=\"applyEditBtn\">Apply</button>\n\n    Manually edit pointers:\n    Prev ID: <input id=\"manPrev\" type=\"number\" style=\"width:70px\" value=\"-1\">\n    Next ID: <input id=\"manNext\" type=\"number\" style=\"width:70px\" value=\"-1\">\n    <button id=\"applyPtrBtn\">Apply Pointers</button>\n  </div>\n</section>\n\n<section>\n  Diagnostics & tools:\n  <div class=\"row\">\n    <button id=\"checkInvBtn\">Check Invariants</button>\n    <button id=\"detectCycleBtn\">Detect Cycles</button>\n    <button id=\"toArrayBtn\">Convert to Array</button>\n    <button id=\"fromArrayBtn\">Build from Array (paste below)</button>\n  </div>\n  <div class=\"row\">\n    Paste/Export JSON:\n    <textarea id=\"jsonIO\"></textarea>\n  </div>\n</section>\n\n<script>\n// Doubly Linked List Explorer - heavy on interactivity, minimal visuals\n\n// Node factory id generator\nlet nextId = 0;\nfunction genId() { return nextId++; }\n\n// Node structure\nfunction createNode(value) {\n  return { id: genId(), value: value, prev: null, next: null };\n}\n\n// Main List object (not circular by default)\nfunction DList() {\n  this.head = null;\n  this.tail = null;\n  this.length = 0;\n  this.useSentinel = false;\n  this.isCircular = false;\n  this.nodes = {}; // map id->node\n}\nDList.prototype.clear = function() {\n  this.head = this.tail = null;\n  this.length = 0;\n  this.nodes = {};\n};\nDList.prototype.pushNode = function(node) {\n  this.nodes[node.id] = node;\n  if (!this.head) { this.head = node; this.tail = node; node.prev = null; node.next = null; }\n  else {\n    node.prev = this.tail.id;\n    node.next = null;\n    this.tail.next = node.id;\n    this.tail = node;\n  }\n  this.length++;\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id; this.tail.next = this.head.id;\n  }\n};\nDList.prototype.insertAtHead = function(node) {\n  this.nodes[node.id] = node;\n  if (!this.head) { this.head = this.tail = node; node.prev = null; node.next = null; }\n  else {\n    node.next = this.head.id;\n    node.prev = null;\n    this.head.prev = node.id;\n    this.head = node;\n  }\n  this.length++;\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id; this.tail.next = this.head.id;\n  }\n};\nDList.prototype.getNodeById = function(id) {\n  if (id === null || id === undefined) return null;\n  return this.nodes.hasOwnProperty(id) ? this.nodes[id] : null;\n};\nDList.prototype.indexOfId = function(id) {\n  let idx = 0;\n  let cur = this.head;\n  while (cur) {\n    if (cur.id === id) return idx;\n    cur = this.getNodeById(cur.next);\n    idx++;\n    if (this.isCircular && cur && idx > 10000) break; // safe guard\n  }\n  return -1;\n};\nDList.prototype.getNodeAtIndex = function(index) {\n  if (index < 0) return null;\n  let cur = this.head;\n  let i = 0;\n  while (cur && i < index) {\n    cur = this.getNodeById(cur.next);\n    i++;\n    if (this.isCircular && i > 10000) break;\n  }\n  return cur;\n};\nDList.prototype.insertAtIndex = function(node, index) {\n  if (index <= 0) { this.insertAtHead(node); return; }\n  if (index >= this.length) { this.pushNode(node); return; }\n  let cur = this.getNodeAtIndex(index);\n  if (!cur) { this.pushNode(node); return; }\n  // insert before cur\n  let prev = this.getNodeById(cur.prev);\n  this.nodes[node.id] = node;\n  node.next = cur.id;\n  node.prev = prev ? prev.id : null;\n  cur.prev = node.id;\n  if (prev) prev.next = node.id;\n  else this.head = node;\n  this.length++;\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id;\n    this.tail.next = this.head.id;\n  }\n};\nDList.prototype.insertAfterId = function(node, id) {\n  const target = this.getNodeById(id);\n  if (!target) { this.pushNode(node); return; }\n  const next = this.getNodeById(target.next);\n  this.nodes[node.id] = node;\n  node.prev = target.id;\n  node.next = next ? next.id : null;\n  target.next = node.id;\n  if (next) next.prev = node.id;\n  else this.tail = node;\n  this.length++;\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id; this.tail.next = this.head.id;\n  }\n};\nDList.prototype.insertBeforeId = function(node, id) {\n  const target = this.getNodeById(id);\n  if (!target) { this.insertAtHead(node); return; }\n  const prev = this.getNodeById(target.prev);\n  this.nodes[node.id] = node;\n  node.next = target.id;\n  node.prev = prev ? prev.id : null;\n  target.prev = node.id;\n  if (prev) prev.next = node.id;\n  else this.head = node;\n  this.length++;\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id; this.tail.next = this.head.id;\n  }\n};\nDList.prototype.deleteById = function(id) {\n  const node = this.getNodeById(id);\n  if (!node) return false;\n  const prev = this.getNodeById(node.prev);\n  const next = this.getNodeById(node.next);\n  if (prev) prev.next = next ? next.id : null;\n  else this.head = next || null;\n  if (next) next.prev = prev ? prev.id : null;\n  else this.tail = prev || null;\n  delete this.nodes[id];\n  this.length = Math.max(0, this.length - 1);\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id; this.tail.next = this.head.id;\n  }\n  return true;\n};\nDList.prototype.deleteAtIndex = function(index) {\n  const node = this.getNodeAtIndex(index);\n  if (!node) return false;\n  return this.deleteById(node.id);\n};\nDList.prototype.findByValue = function(value) {\n  const res = [];\n  let cur = this.head;\n  let visited = new Set();\n  while (cur) {\n    if (String(cur.value) === String(value)) res.push(cur);\n    if (this.isCircular) {\n      if (visited.has(cur.id)) break;\n      visited.add(cur.id);\n    }\n    cur = this.getNodeById(cur.next);\n  }\n  return res;\n};\nDList.prototype.moveIdToIndex = function(id, index) {\n  const node = this.getNodeById(id);\n  if (!node) return false;\n  // remove node linkages\n  const prev = this.getNodeById(node.prev);\n  const next = this.getNodeById(node.next);\n  if (prev) prev.next = next ? next.id : null;\n  else this.head = next || null;\n  if (next) next.prev = prev ? prev.id : null;\n  else this.tail = prev || null;\n  this.length = Math.max(0, this.length - 1);\n  delete this.nodes[node.id];\n  // detach node\n  node.prev = node.next = null;\n  // insert at index fresh\n  this.insertAtIndex(node, index);\n  return true;\n};\nDList.prototype.swapIds = function(a, b) {\n  if (a === b) return false;\n  const A = this.getNodeById(a), B = this.getNodeById(b);\n  if (!A || !B) return false;\n  // swap values only to keep ids stable (safer)\n  const t = A.value; A.value = B.value; B.value = t;\n  return true;\n};\nDList.prototype.reverse = function() {\n  // reverse links\n  let cur = this.head;\n  let visited = new Set();\n  while (cur) {\n    const n = this.getNodeById(cur.next);\n    const p = cur.prev;\n    const id = cur.id;\n    // swap prev/next (they contain ids)\n    const tmp = cur.next;\n    cur.next = cur.prev;\n    cur.prev = tmp;\n    if (this.isCircular) {\n      if (visited.has(cur.id)) break;\n      visited.add(cur.id);\n    }\n    cur = n;\n  }\n  // swap head/tail\n  const oldHead = this.head;\n  this.head = this.tail;\n  this.tail = oldHead;\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id; this.tail.next = this.head.id;\n  }\n};\nDList.prototype.rotateRight = function(k) {\n  if (this.length <= 1) return;\n  k = ((k % this.length) + this.length) % this.length;\n  if (k === 0) return;\n  // new tail is at length-k-1 index, new head at length-k index\n  const newHeadIndex = (this.length - k) % this.length;\n  const newHead = this.getNodeAtIndex(newHeadIndex);\n  const newTail = this.getNodeById(newHead.prev);\n  if (!newHead) return;\n  newHead.prev = null;\n  newTail.next = null;\n  const oldTail = this.tail;\n  const oldHead = this.head;\n  // attach old head after old tail (we will append existing segment)\n  oldTail.next = oldHead.id; oldHead.prev = oldTail.id;\n  // Now set head to newHead and tail to newTail\n  this.head = newHead;\n  this.tail = newTail;\n  // But we created cycle; fix by walking\n  // rebuild prev/next continuity for safety\n  let cur = this.head, prev = null;\n  let visited = new Set();\n  while (cur) {\n    cur.prev = prev ? prev.id : null;\n    prev = cur;\n    cur = this.getNodeById(cur.next);\n    if (this.isCircular) {\n      if (visited.has(prev.id)) break;\n      visited.add(prev.id);\n    }\n  }\n  this.tail = prev || this.tail;\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id; this.tail.next = this.head.id;\n  }\n};\nDList.prototype.splitAtIndex = function(index) {\n  // split into two lists: first contains 0..index-1, second contains index..\n  const second = new DList();\n  if (index <= 0) {\n    // first empty, all to second\n    second.head = this.head; second.tail = this.tail; second.length = this.length; second.nodes = Object.assign({}, this.nodes);\n    this.clear();\n    return second;\n  }\n  if (index >= this.length) {\n    // second empty\n    return second;\n  }\n  const cutNode = this.getNodeAtIndex(index);\n  if (!cutNode) return second;\n  const prev = this.getNodeById(cutNode.prev);\n  // detach\n  if (prev) prev.next = null; else this.head = null;\n  cutNode.prev = null;\n  // build node sets for new lists by scanning\n  const left = new DList();\n  const right = new DList();\n  let cur = this.head;\n  while (cur) {\n    const copy = cur;\n    left.nodes[copy.id] = copy;\n    left.tail = copy;\n    left.length++;\n    left.head = left.head || copy;\n    cur = this.getNodeById(copy.next);\n  }\n  cur = cutNode;\n  while (cur) {\n    const copy = cur;\n    right.nodes[copy.id] = copy;\n    right.tail = copy;\n    right.length++;\n    right.head = right.head || copy;\n    cur = this.getNodeById(copy.next);\n  }\n  // set proper prev/next for left/right tail/head\n  if (left.tail) left.tail.next = null;\n  if (right.head) right.head.prev = null;\n  // assign\n  this.head = left.head; this.tail = left.tail; this.length = left.length; this.nodes = left.nodes;\n  second.head = right.head; second.tail = right.tail; second.length = right.length; second.nodes = right.nodes;\n  return second;\n};\nDList.prototype.mergeWith = function(other) {\n  if (!other.head) return;\n  // append other onto this\n  const rhsHead = other.head, rhsTail = other.tail;\n  if (!this.head) {\n    this.head = rhsHead; this.tail = rhsTail; this.length = other.length; this.nodes = Object.assign({}, other.nodes);\n    return;\n  }\n  this.tail.next = rhsHead.id;\n  rhsHead.prev = this.tail.id;\n  this.tail = rhsTail;\n  this.length += other.length;\n  // merge nodes map\n  for (let k in other.nodes) this.nodes[k] = other.nodes[k];\n  if (this.isCircular && this.head && this.tail) {\n    this.head.prev = this.tail.id; this.tail.next = this.head.id;\n  }\n};\nDList.prototype.toArrayValues = function() {\n  const arr = [];\n  let cur = this.head;\n  let visited = new Set();\n  while (cur) {\n    arr.push(cur.value);\n    if (this.isCircular) {\n      if (visited.has(cur.id)) break;\n      visited.add(cur.id);\n    }\n    cur = this.getNodeById(cur.next);\n  }\n  return arr;\n};\nDList.prototype.fromArray = function(values) {\n  this.clear();\n  for (let v of values) this.pushNode(createNode(v));\n};\nDList.prototype.detectCycle = function() {\n  // Floyd's algorithm over id graph following next pointers\n  let slow = this.head ? this.getNodeById(this.head.next) : null;\n  let fast = this.head ? this.getNodeById(this.head.next) : null;\n  if (!this.head) return false;\n  fast = this.getNodeById(fast ? fast.next : null);\n  while (slow && fast) {\n    if (slow.id === fast.id) return true;\n    slow = this.getNodeById(slow.next);\n    fast = this.getNodeById(fast.next);\n    fast = fast ? this.getNodeById(fast.next) : null;\n  }\n  return false;\n};\nDList.prototype.checkInvariants = function() {\n  // returns array of discovered issues or empty if ok\n  const issues = [];\n  // check head/tail consistency\n  if (!this.head && this.length !== 0) issues.push(\"head is null but length != 0\");\n  if (!this.tail && this.length !== 0) issues.push(\"tail is null but length != 0\");\n  // check nodes map vs traversal count\n  let count = 0;\n  const seen = new Set();\n  let cur = this.head;\n  while (cur) {\n    count++;\n    if (seen.has(cur.id)) { issues.push(\"cycle detected during forward traversal at id \" + cur.id); break; }\n    seen.add(cur.id);\n    // verify pointers link to known nodes or null\n    if (cur.next && !this.nodes.hasOwnProperty(cur.next)) issues.push(\"node \" + cur.id + \" next points to missing id \" + cur.next);\n    if (cur.prev && !this.nodes.hasOwnProperty(cur.prev)) issues.push(\"node \" + cur.id + \" prev points to missing id \" + cur.prev);\n    // cross-check prev/next relation\n    const nextNode = this.getNodeById(cur.next);\n    if (nextNode && nextNode.prev !== cur.id) issues.push(\"mismatch: node \" + cur.id + \" -> next \" + cur.next + \" but that node.prev is \" + nextNode.prev);\n    cur = nextNode;\n    if (this.isCircular && count > 10000) break;\n  }\n  if (!this.isCircular && count !== this.length) issues.push(\"length mismatch: traversed \" + count + \" but length property is \" + this.length);\n  return issues;\n};\n\n// Global state\nlet mainList = new DList();\nlet history = [];\nlet historyIndex = -1;\nlet historyPlaying = false;\nlet playTimer = null;\nlet macros = {}; // name -> array of actions\nlet recordingMacro = null;\nlet algoSteps = [];\nlet algoIndex = -1;\n\n// Utility helpers for snapshots\nfunction snapshotPush(reason) {\n  // deep-ish clone of list state (store nodes shallow but values/ids)\n  const snap = {\n    head: mainList.head ? mainList.head.id : null,\n    tail: mainList.tail ? mainList.tail.id : null,\n    length: mainList.length,\n    isCircular: mainList.isCircular,\n    useSentinel: mainList.useSentinel,\n    nodes: {}\n  };\n  for (let id in mainList.nodes) {\n    const n = mainList.nodes[id];\n    snap.nodes[id] = { id: n.id, value: n.value, prev: n.prev === null ? null : n.prev, next: n.next === null ? null : n.next };\n  }\n  // truncate future if we undid\n  if (historyIndex < history.length - 1) history = history.slice(0, historyIndex + 1);\n  history.push({ state: snap, reason: reason || '' });\n  historyIndex = history.length - 1;\n  updateHistoryUI();\n}\nfunction snapshotRestore(index) {\n  if (index < 0 || index >= history.length) return;\n  const snap = history[index].state;\n  // rebuild list from snapshot\n  mainList.clear();\n  mainList.isCircular = snap.isCircular;\n  mainList.useSentinel = snap.useSentinel;\n  const nodeMap = {};\n  // ensure nextId remains >= any id\n  let maxId = -1;\n  for (let id in snap.nodes) {\n    const n = snap.nodes[id];\n    nodeMap[id] = { id: n.id, value: n.value, prev: n.prev, next: n.next };\n    if (n.id > maxId) maxId = n.id;\n  }\n  // set nextId to avoid collision\n  nextId = Math.max(nextId, maxId + 1);\n  mainList.nodes = nodeMap;\n  mainList.head = snap.head ? mainList.nodes[snap.head] : null;\n  mainList.tail = snap.tail ? mainList.nodes[snap.tail] : null;\n  mainList.length = snap.length;\n  updateAll();\n}\n\nfunction updateHistoryUI() {\n  const slider = document.getElementById('historySlider');\n  const label = document.getElementById('historyLabel');\n  slider.max = Math.max(0, history.length - 1);\n  slider.value = historyIndex;\n  label.textContent = (historyIndex + 1) + \" / \" + history.length + (history[historyIndex] ? \"  (\" + history[historyIndex].reason + \")\" : \"\");\n}\n\n// Rendering\nfunction renderList() {\n  const v = document.getElementById('visual');\n  const d = document.getElementById('details');\n  const btns = document.getElementById('nodeButtons');\n  v.textContent = '';\n  d.textContent = '';\n  btns.innerHTML = '';\n  // build linear representation\n  let parts = [];\n  let cur = mainList.head;\n  let visited = new Set();\n  let idx = 0;\n  while (cur) {\n    const repr = \"[\" + cur.id + \":\" + String(cur.value) + \"]\";\n    parts.push(repr);\n    // create quick node button\n    const b = document.createElement('button');\n    b.textContent = \"(\" + idx + \") id=\" + cur.id;\n    b.className = 'nodeButton';\n    b.onclick = (function(id){\n      return function(){\n        document.getElementById('selectedIdInput').value = id;\n        updateInspector();\n      };\n    })(cur.id);\n    btns.appendChild(b);\n    if (mainList.isCircular) {\n      if (visited.has(cur.id)) { parts.push(\"...\"); break; }\n      visited.add(cur.id);\n    }\n    cur = mainList.getNodeById(cur.next);\n    idx++;\n    if (idx > 2000) break;\n  }\n  if (parts.length === 0) v.textContent = \"(empty list)\";\n  else v.textContent = parts.join(\" <-> \");\n  // details table: show columns: index, id, value, prev, next\n  let tableLines = [];\n  tableLines.push(\"index | id | value | prev | next\");\n  tableLines.push(\"------|----|-------|------|-----\");\n  cur = mainList.head;\n  idx = 0;\n  visited.clear();\n  while (cur) {\n    tableLines.push(String(idx).padEnd(5) + \" | \" + String(cur.id).padEnd(2) + \" | \" + String(cur.value).padEnd(5) + \" | \" + String(cur.prev).padEnd(4) + \" | \" + String(cur.next));\n    if (mainList.isCircular) {\n      if (visited.has(cur.id)) { tableLines.push(\"... (circular)\"); break; }\n      visited.add(cur.id);\n    }\n    cur = mainList.getNodeById(cur.next);\n    idx++;\n    if (idx > 2000) break;\n  }\n  d.textContent = tableLines.join(\"\\n\");\n}\n\nfunction updateInspector() {\n  const id = parseInt(document.getElementById('selectedIdInput').value, 10);\n  const insp = document.getElementById('inspector');\n  if (isNaN(id)) { insp.textContent = \"(no node selected)\"; return; }\n  const node = mainList.getNodeById(id);\n  if (!node) { insp.textContent = \"node id \" + id + \" not found\"; return; }\n  insp.textContent = \"id: \" + node.id + \"\\nvalue: \" + String(node.value) + \"\\nprev: \" + String(node.prev) + \"\\nnext: \" + String(node.next) + \"\\nindex: \" + mainList.indexOfId(node.id);\n  document.getElementById('editVal').value = String(node.value);\n  document.getElementById('manPrev').value = node.prev === null ? -1 : node.prev;\n  document.getElementById('manNext').value = node.next === null ? -1 : node.next;\n}\n\nfunction updateAll() {\n  renderList();\n  updateInspector();\n  updateHistoryUI();\n}\n\n// Hook up UI controls and actions\ndocument.getElementById('createHeadBtn').addEventListener('click', function(){\n  mainList = new DList();\n  snapshotPush('create new list');\n  updateAll();\n  recordMacro('create_new_list');\n});\ndocument.getElementById('insertBtn').addEventListener('click', function(){\n  const val = document.getElementById('valInput').value;\n  const pos = document.getElementById('posSelect').value;\n  const idxInput = document.getElementById('posIndex').value;\n  const idx = parseInt(idxInput, 10);\n  const node = createNode(val);\n  if (pos === 'head') mainList.insertAtHead(node);\n  else if (pos === 'tail') mainList.pushNode(node);\n  else if (pos === 'index') mainList.insertAtIndex(node, isNaN(idx) ? 0 : idx);\n  else if (pos === 'after') mainList.insertAfterId(node, isNaN(idx) ? null : idx);\n  else if (pos === 'before') mainList.insertBeforeId(node, isNaN(idx) ? null : idx);\n  snapshotPush('insert ' + val + ' at ' + pos);\n  updateAll();\n  recordMacro('insert|' + val + '|' + pos + '|' + idxInput);\n});\ndocument.getElementById('randomBtn').addEventListener('click', function(){\n  const sz = parseInt(document.getElementById('randSize').value, 10) || 0;\n  mainList = new DList();\n  const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\";\n  for (let i=0;i<sz;i++){\n    const v = chars[Math.floor(Math.random()*chars.length)];\n    mainList.pushNode(createNode(v));\n  }\n  snapshotPush('random populate ' + sz);\n  updateAll();\n  recordMacro('random|' + sz);\n});\ndocument.getElementById('deleteBtn').addEventListener('click', function(){\n  const mode = document.getElementById('delMode').value;\n  const input = document.getElementById('delInput').value;\n  let ok = false;\n  if (mode === 'id') {\n    const id = parseInt(input,10);\n    ok = mainList.deleteById(id);\n  } else if (mode === 'index') {\n    const idx = parseInt(input,10);\n    ok = mainList.deleteAtIndex(idx);\n  } else if (mode === 'value') {\n    const found = mainList.findByValue(input);\n    if (found.length>0) { ok = mainList.deleteById(found[0].id); }\n  }\n  snapshotPush('delete ' + input + ' mode ' + mode);\n  updateAll();\n  recordMacro('delete|' + mode + '|' + input);\n});\ndocument.getElementById('findBtn').addEventListener('click', function(){\n  const v = document.getElementById('findVal').value;\n  const found = mainList.findByValue(v);\n  if (found.length===0) alert('not found');\n  else { document.getElementById('selectedIdInput').value = found[0].id; updateInspector(); alert('found id ' + found[0].id); }\n});\ndocument.getElementById('findAllBtn').addEventListener('click', function(){\n  const v = document.getElementById('findVal').value;\n  const found = mainList.findByValue(v);\n  alert('found ' + found.length + ' nodes: ' + found.map(n=>n.id).join(', '));\n});\ndocument.getElementById('moveBtn').addEventListener('click', function(){\n  const id = parseInt(document.getElementById('moveId').value,10);\n  const idx = parseInt(document.getElementById('moveIndex').value,10);\n  const ok = mainList.moveIdToIndex(id, isNaN(idx)?0:idx);\n  snapshotPush('move id ' + id + ' to index ' + idx);\n  updateAll();\n  recordMacro('move|' + id + '|' + idx);\n});\ndocument.getElementById('swapBtn').addEventListener('click', function(){\n  const a = parseInt(document.getElementById('swapA').value,10);\n  const b = parseInt(document.getElementById('swapB').value,10);\n  mainList.swapIds(a,b);\n  snapshotPush('swap ' + a + ' ' + b);\n  updateAll();\n  recordMacro('swap|' + a + '|' + b);\n});\ndocument.getElementById('reverseBtn').addEventListener('click', function(){\n  mainList.reverse();\n  snapshotPush('reverse');\n  updateAll();\n  recordMacro('reverse');\n});\ndocument.getElementById('rotateBtn').addEventListener('click', function(){\n  const k = parseInt(document.getElementById('rotK').value,10) || 0;\n  mainList.rotateRight(k);\n  snapshotPush('rotate ' + k);\n  updateAll();\n  recordMacro('rotate|' + k);\n});\ndocument.getElementById('circularToggle').addEventListener('change', function(){\n  mainList.isCircular = this.checked;\n  if (mainList.isCircular && mainList.head && mainList.tail) {\n    mainList.head.prev = mainList.tail.id; mainList.tail.next = mainList.head.id;\n  } else {\n    // make linear: remove tail.next and head.prev if they pointed around\n    if (mainList.head) mainList.head.prev = mainList.head.prev;\n    if (mainList.tail) mainList.tail.next = mainList.tail.next;\n  }\n  snapshotPush('toggle circular ' + mainList.isCircular);\n  updateAll();\n});\ndocument.getElementById('sentinelToggle').addEventListener('change', function(){\n  mainList.useSentinel = this.checked;\n  snapshotPush('toggle sentinel ' + mainList.useSentinel);\n  updateAll();\n});\ndocument.getElementById('repairBtn').addEventListener('click', function(){\n  // try to rebuild prev pointers by scanning forward\n  let cur = mainList.head;\n  let prev = null;\n  let count = 0;\n  while (cur) {\n    cur.prev = prev ? prev.id : null;\n    prev = cur;\n    cur = mainList.getNodeById(cur.next);\n    count++;\n    if (count>10000) break;\n  }\n  mainList.tail = prev;\n  snapshotPush('repair pointers');\n  updateAll();\n  recordMacro('repair');\n});\ndocument.getElementById('clearBrokenBtn').addEventListener('click', function(){\n  // remove references to missing nodes\n  for (let id in mainList.nodes) {\n    const n = mainList.nodes[id];\n    if (n.prev !== null && !mainList.nodes.hasOwnProperty(n.prev)) n.prev = null;\n    if (n.next !== null && !mainList.nodes.hasOwnProperty(n.next)) n.next = null;\n  }\n  // attempt to rebuild head/tail via scanning nodes with no prev\n  let start = null;\n  for (let id in mainList.nodes) {\n    if (mainList.nodes[id].prev === null) { start = mainList.nodes[id]; break; }\n  }\n  mainList.head = start;\n  // recalc length\n  let len = 0;\n  let cur = mainList.head;\n  let visited = new Set();\n  while (cur) {\n    len++;\n    visited.add(cur.id);\n    cur = mainList.getNodeById(cur.next);\n    if (visited.has(cur && cur.id)) break;\n    if (len>10000) break;\n  }\n  mainList.length = len;\n  snapshotPush('clear broken links');\n  updateAll();\n  recordMacro('clearbroken');\n});\ndocument.getElementById('splitBtn').addEventListener('click', function(){\n  const idx = parseInt(document.getElementById('splitIndex').value,10);\n  const second = mainList.splitAtIndex(isNaN(idx)?0:idx);\n  // store second in json area for user to inspect\n  document.getElementById('jsonIO').value = JSON.stringify({\n    main: { head: mainList.head ? mainList.head.id : null, length: mainList.length, nodes: mainList.nodes },\n    second: { head: second.head ? second.head.id : null, length: second.length, nodes: second.nodes }\n  }, null, 2);\n  snapshotPush('split at ' + idx);\n  updateAll();\n  recordMacro('split|' + idx);\n});\ndocument.getElementById('mergeBtn').addEventListener('click', function(){\n  // build secondary list from json IO if present, else random small\n  try {\n    const txt = document.getElementById('jsonIO').value.trim();\n    let other = null;\n    if (txt) {\n      const parsed = JSON.parse(txt);\n      other = new DList();\n      // if structure has nodes, try to rebuild\n      const nodes = parsed.nodes || parsed;\n      for (let id in nodes) {\n        const n = nodes[id];\n        const copy = { id: n.id, value: n.value, prev: n.prev, next: n.next };\n        other.nodes[copy.id] = copy;\n      }\n      other.head = parsed.head ? other.nodes[parsed.head] : null;\n      other.tail = parsed.tail ? other.nodes[parsed.tail] : null;\n      other.length = parsed.length || Object.keys(other.nodes).length;\n    } else {\n      other = new DList();\n      other.pushNode(createNode('X'));\n      other.pushNode(createNode('Y'));\n      other.pushNode(createNode('Z'));\n    }\n    mainList.mergeWith(other);\n    snapshotPush('merge with other');\n    updateAll();\n    recordMacro('merge');\n  } catch (e) {\n    alert('failed to parse JSON for merge: ' + e.message);\n  }\n});\ndocument.getElementById('cloneBtn').addEventListener('click', function(){\n  const id = parseInt(document.getElementById('selectedIdInput').value,10);\n  const node = mainList.getNodeById(id);\n  if (!node) { alert('no node to clone'); return; }\n  const copy = createNode(node.value);\n  // insert after original\n  mainList.insertAfterId(copy, node.id);\n  snapshotPush('clone ' + id);\n  updateAll();\n  recordMacro('clone|' + id);\n});\ndocument.getElementById('applyEditBtn').addEventListener('click', function(){\n  const id = parseInt(document.getElementById('selectedIdInput').value,10);\n  const node = mainList.getNodeById(id);\n  if (!node) { alert('no node selected'); return; }\n  node.value = document.getElementById('editVal').value;\n  snapshotPush('edit value ' + id);\n  updateAll();\n  recordMacro('edit|' + id + '|' + node.value);\n});\ndocument.getElementById('applyPtrBtn').addEventListener('click', function(){\n  const id = parseInt(document.getElementById('selectedIdInput').value,10);\n  const node = mainList.getNodeById(id);\n  if (!node) { alert('no node selected'); return; }\n  let p = parseInt(document.getElementById('manPrev').value,10);\n  let n = parseInt(document.getElementById('manNext').value,10);\n  node.prev = (isNaN(p) || p < 0) ? null : p;\n  node.next = (isNaN(n) || n < 0) ? null : n;\n  snapshotPush('manual pointers ' + id);\n  updateAll();\n  recordMacro('manualptr|' + id + '|' + node.prev + '|' + node.next);\n});\ndocument.getElementById('checkInvBtn').addEventListener('click', function(){\n  const issues = mainList.checkInvariants();\n  if (issues.length===0) alert('No invariants detected: list OK (subject to circular flag)');\n  else alert('Issues:\\n' + issues.join('\\n'));\n});\ndocument.getElementById('detectCycleBtn').addEventListener('click', function(){\n  const c = mainList.detectCycle();\n  alert('cycle detected? ' + c);\n});\ndocument.getElementById('toArrayBtn').addEventListener('click', function(){\n  const arr = mainList.toArrayValues();\n  document.getElementById('jsonIO').value = JSON.stringify(arr);\n});\ndocument.getElementById('fromArrayBtn').addEventListener('click', function(){\n  try {\n    const txt = document.getElementById('jsonIO').value;\n    const arr = JSON.parse(txt);\n    if (!Array.isArray(arr)) { alert('not an array'); return; }\n    mainList = new DList();\n    for (let v of arr) mainList.pushNode(createNode(v));\n    snapshotPush('build from array');\n    updateAll();\n    recordMacro('fromarray|' + JSON.stringify(arr));\n  } catch (e) { alert('invalid JSON'); }\n});\ndocument.getElementById('exportBtn').addEventListener('click', function(){\n  const snap = { head: mainList.head?mainList.head.id:null, tail: mainList.tail?mainList.tail.id:null, length: mainList.length, nodes: mainList.nodes, isCircular: mainList.isCircular };\n  document.getElementById('jsonIO').value = JSON.stringify(snap, null, 2);\n});\ndocument.getElementById('importBtn').addEventListener('click', function(){\n  try {\n    const txt = document.getElementById('jsonIO').value;\n    const p = JSON.parse(txt);\n    mainList = new DList();\n    mainList.isCircular = p.isCircular || false;\n    // build nodes\n    for (let id in p.nodes) {\n      const n = p.nodes[id];\n      mainList.nodes[id] = { id: n.id, value: n.value, prev: n.prev, next: n.next };\n    }\n    mainList.head = p.head ? mainList.nodes[p.head] : null;\n    mainList.tail = p.tail ? mainList.nodes[p.tail] : null;\n    mainList.length = p.length || Object.keys(mainList.nodes).length;\n    snapshotPush('import');\n    updateAll();\n    recordMacro('import');\n  } catch (e) { alert('bad json'); }\n});\n\n// History controls\ndocument.getElementById('snapshotBtn').addEventListener('click', function(){\n  snapshotPush('manual snapshot');\n});\ndocument.getElementById('undoBtn').addEventListener('click', function(){\n  if (historyIndex <= 0) return;\n  historyIndex--;\n  snapshotRestore(historyIndex);\n});\ndocument.getElementById('redoBtn').addEventListener('click', function(){\n  if (historyIndex >= history.length - 1) return;\n  historyIndex++;\n  snapshotRestore(historyIndex);\n});\ndocument.getElementById('historySlider').addEventListener('input', function(){\n  const idx = parseInt(this.value,10);\n  if (isNaN(idx)) return;\n  historyIndex = idx;\n  snapshotRestore(historyIndex);\n});\ndocument.getElementById('playBtn').addEventListener('click', function(){\n  if (historyPlaying) return;\n  historyPlaying = true;\n  const interval = parseInt(document.getElementById('playInterval').value,10) || 500;\n  playTimer = setInterval(function(){\n    if (historyIndex < history.length - 1) {\n      historyIndex++;\n      snapshotRestore(historyIndex);\n    } else {\n      clearInterval(playTimer); historyPlaying = false;\n    }\n  }, interval);\n});\ndocument.getElementById('pauseBtn').addEventListener('click', function(){\n  if (playTimer) clearInterval(playTimer);\n  historyPlaying = false;\n});\n\n// Macro recording (simple)\ndocument.getElementById('startMacro').addEventListener('click', function(){\n  const name = document.getElementById('macroName').value || 'macro';\n  recordingMacro = { name: name, actions: [] };\n  alert('macro recording started: ' + name);\n});\ndocument.getElementById('stopMacro').addEventListener('click', function(){\n  if (!recordingMacro) { alert('no recording in progress'); return; }\n  macros[recordingMacro.name] = recordingMacro.actions.slice();\n  recordingMacro = null;\n  refreshMacroList();\n  alert('macro saved');\n});\ndocument.getElementById('playMacro').addEventListener('click', function(){\n  const sel = document.getElementById('macroList').value;\n  if (!sel || !macros[sel]) { alert('no macro selected'); return; }\n  const acts = macros[sel];\n  // play actions sequentially with small delay\n  let i=0;\n  function next() {\n    if (i >= acts.length) { alert('macro complete'); return; }\n    const a = acts[i++];\n    execMacroAction(a);\n    setTimeout(next, 200);\n  }\n  next();\n});\ndocument.getElementById('clearMacros').addEventListener('click', function(){\n  macros = {};\n  refreshMacroList();\n});\n\nfunction recordMacro(action) {\n  if (recordingMacro) recordingMacro.actions.push(action);\n}\nfunction refreshMacroList() {\n  const sel = document.getElementById('macroList');\n  sel.innerHTML = '';\n  for (let k in macros) {\n    const o = document.createElement('option');\n    o.value = k; o.textContent = k + ' (' + macros[k].length + ')';\n    sel.appendChild(o);\n  }\n}\n\nfunction execMacroAction(action) {\n  // simple parsing of recorded actions\n  if (!action) return;\n  const parts = action.split('|');\n  const cmd = parts[0];\n  if (cmd === 'insert') {\n    const val = parts[1]; const pos = parts[2]; const idx = parseInt(parts[3],10);\n    const node = createNode(val);\n    if (pos === 'head') mainList.insertAtHead(node);\n    else if (pos === 'tail') mainList.pushNode(node);\n    else if (pos === 'index') mainList.insertAtIndex(node, isNaN(idx)?0:idx);\n    else if (pos === 'after') mainList.insertAfterId(node, isNaN(idx)?null:idx);\n    else if (pos === 'before') mainList.insertBeforeId(node, isNaN(idx)?null:idx);\n    snapshotPush('macro insert');\n  } else if (cmd === 'delete') {\n    const mode = parts[1]; const input = parts[2];\n    if (mode === 'id') mainList.deleteById(parseInt(input,10));\n    else if (mode === 'index') mainList.deleteAtIndex(parseInt(input,10));\n    else if (mode === 'value') {\n      const f = mainList.findByValue(input);\n      if (f.length) mainList.deleteById(f[0].id);\n    }\n    snapshotPush('macro delete');\n  } else if (cmd === 'random') {\n    const sz = parseInt(parts[1],10);\n    mainList = new DList();\n    const chars = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\";\n    for (let i=0;i<sz;i++) mainList.pushNode(createNode(chars[Math.floor(Math.random()*chars.length)]));\n    snapshotPush('macro random');\n  } else if (cmd === 'reverse') { mainList.reverse(); snapshotPush('macro reverse'); }\n  else if (cmd === 'repair') { document.getElementById('repairBtn').click(); }\n  else if (cmd === 'merge') { document.getElementById('mergeBtn').click(); }\n  else if (cmd === 'clearbroken') { document.getElementById('clearBrokenBtn').click(); }\n  else if (cmd === 'clone') {\n    const id = parseInt(parts[1],10);\n    const node = mainList.getNodeById(id);\n    if (node) mainList.insertAfterId(createNode(node.value), id);\n    snapshotPush('macro clone');\n  } else if (cmd === 'edit') {\n    const id = parseInt(parts[1],10);\n    const val = parts[2];\n    const node = mainList.getNodeById(id);\n    if (node) node.value = val;\n    snapshotPush('macro edit');\n  } else if (cmd === 'manualptr') {\n    const id = parseInt(parts[1],10), p = parseInt(parts[2],10), n = parseInt(parts[3],10);\n    const node = mainList.getNodeById(id);\n    if (node) { node.prev = isNaN(p) ? null : p; node.next = isNaN(n) ? null : n; snapshotPush('macro manual ptr'); }\n  } else if (cmd === 'create_new_list') {\n    mainList = new DList(); snapshotPush('macro new list');\n  } else if (cmd === 'fromarray') {\n    try {\n      const arr = JSON.parse(parts.slice(1).join('|'));\n      mainList = new DList(); arr.forEach(v=>mainList.pushNode(createNode(v)));\n      snapshotPush('macro from array');\n    } catch(e){}\n  } else if (cmd === 'import') {\n    document.getElementById('importBtn').click();\n  }\n  updateAll();\n}\n\n// Algorithm stepper (bubble/insertion) - records high-level steps into algoSteps\ndocument.getElementById('algoPrepareBtn').addEventListener('click', function(){\n  const algo = document.getElementById('algoSelect').value;\n  algoSteps = [];\n  algoIndex = -1;\n  if (algo === 'bubble') prepareBubbleSortSteps();\n  else if (algo === 'insertion') prepareInsertionSortSteps();\n  else { alert('no algorithm selected'); return; }\n  alert('prepared ' + algoSteps.length + ' steps');\n});\ndocument.getElementById('algoStepBtn').addEventListener('click', function(){\n  if (algoSteps.length === 0) { alert('no steps prepared'); return; }\n  algoIndex++;\n  if (algoIndex >= algoSteps.length) { alert('algorithm finished'); algoIndex = algoSteps.length - 1; return; }\n  executeAlgoStep(algoSteps[algoIndex]);\n  snapshotPush('algo step ' + (algoIndex+1) + '/' + algoSteps.length);\n  updateAll();\n});\ndocument.getElementById('algoResetBtn').addEventListener('click', function(){\n  algoSteps = []; algoIndex = -1;\n  alert('algorithm reset');\n});\n\n// Prepare bubble sort steps by values (not stable): we record swaps of ids/values\nfunction prepareBubbleSortSteps() {\n  // convert nodes to array of references\n  const arr = [];\n  let cur = mainList.head;\n  let visited = new Set();\n  while (cur) {\n    arr.push(cur);\n    if (mainList.isCircular) {\n      if (visited.has(cur.id)) break;\n      visited.add(cur.id);\n    }\n    cur = mainList.getNodeById(cur.next);\n  }\n  // bubble compare adjacent as values\n  for (let i=0;i<arr.length;i++) {\n    for (let j=0;j< arr.length - 1 - i; j++) {\n      const a = arr[j], b = arr[j+1];\n      if (String(a.value) > String(b.value)) {\n        // record swap by ids\n        algoSteps.push({ type: 'swapValues', a: a.id, b: b.id });\n        // reflect swap locally in arr\n        const tv = a.value; a.value = b.value; b.value = tv;\n      } else {\n        algoSteps.push({ type: 'compare', a: a.id, b: b.id });\n      }\n    }\n  }\n}\nfunction prepareInsertionSortSteps() {\n  const arr = [];\n  let cur = mainList.head;\n  let visited = new Set();\n  while (cur) {\n    arr.push(cur);\n    if (mainList.isCircular) {\n      if (visited.has(cur.id)) break;\n      visited.add(cur.id);\n    }\n    cur = mainList.getNodeById(cur.next);\n  }\n  // insertion sort simulated on values\n  for (let i=1;i<arr.length;i++) {\n    let j = i-1;\n    const key = arr[i].value;\n    algoSteps.push({ type: 'pick', id: arr[i].id, value: key });\n    while (j >= 0 && String(arr[j].value) > String(key)) {\n      algoSteps.push({ type: 'shift', fromId: arr[j].id, toId: arr[j+1].id });\n      arr[j+1].value = arr[j].value;\n      j--;\n    }\n    arr[j+1].value = key;\n    algoSteps.push({ type: 'place', id: arr[j+1].id, value: key });\n  }\n}\n\nfunction executeAlgoStep(step) {\n  if (!step) return;\n  if (step.type === 'swapValues') {\n    mainList.swapIds(step.a, step.b);\n  } else if (step.type === 'compare') {\n    // no change, but reveal comparison\n    alert('compare nodes ' + step.a + ' and ' + step.b);\n  } else if (step.type === 'pick') {\n    alert('pick node ' + step.id + ' value ' + step.value);\n  } else if (step.type === 'shift') {\n    const f = mainList.getNodeById(step.fromId), t = mainList.getNodeById(step.toId);\n    if (f && t) {\n      t.value = f.value;\n    }\n  } else if (step.type === 'place') {\n    const n = mainList.getNodeById(step.id);\n    if (n) n.value = step.value;\n  }\n}\n\n// Export/Import core json and manual IO are above\n\n// Initialize with a small sample and snapshot\n(function init(){\n  mainList = new DList();\n  mainList.pushNode(createNode('A'));\n  mainList.pushNode(createNode('B'));\n  mainList.pushNode(createNode('C'));\n  mainList.pushNode(createNode('D'));\n  snapshotPush('init sample');\n  updateAll();\n})();\n\n</script>\n\n</body>\n</html>"
