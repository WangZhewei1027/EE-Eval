    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Kruskal's Algorithm Interactive Demo</title>\n    <style>\n        /* Minimal styling for layout - no colors, no animations */\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #controls {\n            margin-bottom: 20px;\n        }\n        .node, .edge {\n            padding: 5px;\n            border: 1px solid black;\n            margin: 2px;\n            display: inline-block;\n        }\n    </style>\n</head>\n<body>\n\n<h2>Kruskal's Algorithm Demo</h2>\n\n<div id=\"controls\">\n    <input type=\"text\" id=\"node-input\" placeholder=\"Node (e.g. A)\">\n    <input type=\"text\" id=\"edge-input\" placeholder=\"Edge (e.g. A-B:3)\">\n    <button id=\"add-node\">Add Node</button>\n    <button id=\"add-edge\">Add Edge</button>\n    <button id=\"run-algorithm\">Run Kruskal's Algorithm</button>\n</div>\n\n<div>\n    <h4>Graph Nodes:</h4>\n    <div id=\"nodes-area\"></div>\n</div>\n<div>\n    <h4>Graph Edges:</h4>\n    <div id=\"edges-area\"></div>\n</div>\n<div>\n    <h4>Minimum Spanning Tree Edges:</h4>\n    <div id=\"mst-area\"></div>\n</div>\n\n<script>\n    let nodes = [];\n    let edges = [];\n    \n    document.getElementById('add-node').onclick = function() {\n        const nodeInput = document.getElementById('node-input').value.trim();\n        if (nodeInput && !nodes.includes(nodeInput)) {\n            nodes.push(nodeInput);\n            document.getElementById('nodes-area').innerHTML += `<div class=\"node\">${nodeInput}</div>`;\n            document.getElementById('node-input').value = '';\n        } else {\n            alert(\"Invalid or duplicate node.\");\n        }\n    };\n\n    document.getElementById('add-edge').onclick = function() {\n        const edgeInput = document.getElementById('edge-input').value.trim();\n        const edgeParts = edgeInput.split(':');\n        if (edgeParts.length === 2) {\n            const edgeNodes = edgeParts[0].trim().split('-');\n            const weight = parseInt(edgeParts[1].trim());\n            if (edgeNodes.length === 2 && !isNaN(weight)) {\n                const edge = {nodes: edgeNodes.map(n => n.trim()), weight};\n                edges.push(edge);\n                document.getElementById('edges-area').innerHTML += `<div class=\"edge\">${edgeNodes.join('-')}:${weight}</div>`;\n                document.getElementById('edge-input').value = '';\n            } else {\n                alert(\"Invalid edge format.\");\n            }\n        } else {\n            alert(\"Invalid edge format.\");\n        }\n    };\n\n    document.getElementById('run-algorithm').onclick = function() {\n        const mst = kruskalAlgorithm(nodes, edges);\n        document.getElementById('mst-area').innerHTML = mst.map(e => e.nodes.join('-') + ':' + e.weight).join(', ');\n    };\n\n    function kruskalAlgorithm(nodes, edges) {\n        // Sort edges by weight\n        edges.sort((a, b) => a.weight - b.weight);\n        \n        // Create a parent map for union-find\n        const parent = {};\n        nodes.forEach(node => parent[node] = node);\n        \n        const find = (node) => {\n            if (parent[node] !== node) {\n                parent[node] = find(parent[node]);\n            }\n            return parent[node];\n        };\n\n        const union = (node1, node2) => {\n            const root1 = find(node1);\n            const root2 = find(node2);\n            if (root1 !== root2) {\n                parent[root1] = root2;\n            }\n        };\n\n        const mst = [];\n        for (const edge of edges) {\n            const [node1, node2] = edge.nodes;\n            if (find(node1) !== find(node2)) {\n                mst.push(edge);\n                union(node1, node2);\n            }\n        }\n        return mst;\n    }\n</script>\n\n</body>\n</html>"
