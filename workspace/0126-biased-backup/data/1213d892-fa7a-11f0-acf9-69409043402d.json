    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Radix Sort Interactive Demonstration</title>\n<style>\n  /* Minimal styling: basic black text on white, no advanced styling */\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    white-space: pre-wrap;\n  }\n  input, button, select {\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  textarea {\n    width: 100%;\n    height: 5em;\n    font-family: monospace, monospace;\n    font-size: 1em;\n  }\n  label {\n    user-select: none;\n  }\n  .section {\n    margin-bottom: 1.5em;\n  }\n  .flex-row > * {\n    margin-right: 0.5em;\n  }\n  #debuglog {\n    border: 1px solid #ccc;\n    height: 8em;\n    overflow-y: auto;\n    font-family: monospace, monospace;\n    font-size: 0.9em;\n    padding: 0.2em 0.4em;\n  }\n  table {\n    border-collapse: collapse;\n  }\n  td, th {\n    padding: 0.15em 0.4em;\n    border: 1px solid black;\n    text-align: center;\n    min-width: 2.2em;\n    user-select: none;\n  }\n  .highlight {\n    font-weight: bold;\n    text-decoration: underline;\n  }\n</style>\n</head>\n<body>\n<h1>Radix Sort Interactive Demonstration</h1>\n\n<div class=\"section\">\n  <strong>Step 1:</strong> Input your array of non-negative integers (comma or space separated).\n  <br />\n  &gt; <input type=\"text\" id=\"inputArray\" size=\"60\" aria-label=\"Input array\" value=\"170, 45, 75, 90, 802, 24, 2, 66\" />\n  <button id=\"btnSetArray\">Set Array</button>\n  <button id=\"btnRandomArray\">Random Array</button> \n  <small>(Random array length and max value below)</small>\n  <br />\n  Length: <input type=\"number\" id=\"randomLength\" value=\"10\" min=\"1\" max=\"50\" size=\"3\" aria-label=\"Random array length\" />\n  Max value: <input type=\"number\" id=\"randomMax\" value=\"999\" min=\"1\" max=\"999999\" size=\"6\" aria-label=\"Random max value\" />\n</div>\n\n<div class=\"section\">\n  <strong>Current Array:</strong>\n  <div id=\"currentArrayDisplay\"></div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Step 2:</strong> Configure Radix Sort options:\n  <div>\n    <label><input type=\"checkbox\" id=\"optStable\" checked /> Stable Sort (default)</label><br />\n    <label><input type=\"checkbox\" id=\"optLsd\" checked /> Use LSD (Least Significant Digit) Radix Sort</label><br />\n    <label><input type=\"checkbox\" id=\"optMsd\" /> Use MSD (Most Significant Digit) Radix Sort</label><br />\n    <small>(Choose exactly one between LSD and MSD.)</small>\n  </div>\n  <div>\n    Base (Radix): \n    <select id=\"radixBase\">\n      <option value=\"2\">2</option>\n      <option value=\"4\">4</option>\n      <option value=\"8\">8</option>\n      <option value=\"10\" selected>10</option>\n      <option value=\"16\">16</option>\n      <option value=\"256\">256</option>\n    </select>\n    <small>(Base for digit extraction)</small>\n  </div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Step 3:</strong> Visualize and step through Radix Sort.\n  <div>\n    <button id=\"btnStartSort\">Start Sort</button>\n    <button id=\"btnNextStep\" disabled>Next Step</button>\n    <button id=\"btnPrevStep\" disabled>Previous Step</button>\n    <button id=\"btnAutoRun\" disabled>Auto Run</button>\n    <button id=\"btnPause\" disabled>Pause</button>\n    <button id=\"btnReset\" disabled>Reset Sort</button>\n  </div>\n  <div>\n    Delay between steps (ms): <input type=\"number\" id=\"stepDelay\" value=\"700\" min=\"10\" max=\"10000\" size=\"5\" />\n  </div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Step 4:</strong> Current Sorting State Visualization:\n  <div id=\"sortStepInfo\" style=\"white-space: pre-wrap; font-family: monospace, monospace;\"></div>\n  <br />\n  <div id=\"arrayTableDiv\"></div>\n  <br />\n  <div><strong>Buckets at Current Pass:</strong> (Each column represents a bucket)</div>\n  <div id=\"bucketsDiv\"></div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Additional Exploration Controls:</strong>\n  <button id=\"btnJumpToPass\">Jump to Pass #:</button> \n  <input type=\"number\" id=\"jumpPassNumber\" min=\"0\" size=\"3\" value=\"0\" aria-label=\"Pass number\" />\n  &nbsp;&nbsp;\n  <button id=\"btnJumpToStep\">Jump to Step # within Pass:</button> \n  <input type=\"number\" id=\"jumpStepNumber\" min=\"0\" size=\"3\" value=\"0\" aria-label=\"Step number\" />\n  <br />\n  <button id=\"btnShowFullHistory\">Show Full Step History</button> \n  <button id=\"btnHideFullHistory\" style=\"display:none;\">Hide Full Step History</button>\n  <div id=\"fullHistoryDiv\" style=\"max-height: 300px; overflow-y: auto; white-space: pre-wrap; font-family: monospace, monospace;\"></div>\n</div>\n\n<hr />\n\n<div class=\"section\">\n  <strong>Debug / Logs:</strong>\n  <div id=\"debuglog\"></div>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // === Data and State ===\n  let originalArray = [];\n  let currentArray = [];\n  let radixBase = 10;\n  let useStable = true;\n  let isLSD = true; // LSD by default if LSD checked else MSD\n  let isMSD = false;\n  let sortingStarted = false;\n  let sortingPaused = false;\n  let autoRunTimer = null;\n  let stepDelay = 700;\n\n  // Structure to hold sort states by passes and steps:\n  // For LSD:\n  // passes: each digit place (from LSD to MSD)\n  // steps per pass: usually one step - placing into buckets and then collecting\n  //\n  // For MSD:\n  // more complex, recursive subdivision\n  //\n  // We'll structure as:\n  // history = [ {passNumber, digitIndex, buckets:[...], afterCollectArray, description, ... } ... ]\n  //\n  // For MSD: the passNumber increases per recursive call\n  //\n  let history = [];\n  let currentHistoryIndex = -1;\n\n  // For MSD sorting we need a recursive approach and a way to store states for interactive stepping.\n  // We'll flatten the recursion with a stack approach for the sake of interactivity.\n\n  // Helper: parse input array from string\n  function parseInputArray(text) {\n    // Accept comma or space separated; trim and parse integers; only non-negatives allowed\n    let parts = text.split(/[\\s,]+/);\n    let arr = [];\n    for(let p of parts){\n      if(p.trim()===\"\") continue;\n      let n = Number(p.trim());\n      if(!Number.isInteger(n) || n < 0) return null;\n      arr.push(n);\n    }\n    return arr.length > 0 ? arr : null;\n  }\n  // Helpers for digit extraction\n  function getMaxNumber(arr){\n    if(arr.length===0)return 0;\n    return Math.max(...arr);\n  }\n  function getDigit(number, base, digitIndex){\n    // digitIndex: 0 = LSD (lowest), 1= next digit in base, etc.\n    return Math.floor(number / Math.pow(base, digitIndex)) % base;\n  }\n  // MSD digit extraction: highest digit index depends on max number:\n  // MSD digit index 0 = MSD digit\n  // So we figure max digit length, then digitIndex = maxDigitLength - 1 - i for LSD order\n  // We'll adapt as needed.\n\n  // === DOM Elements ===\n  const inputArrayEl = document.getElementById(\"inputArray\");\n  const btnSetArray = document.getElementById(\"btnSetArray\");\n  const btnRandomArray = document.getElementById(\"btnRandomArray\");\n  const randomLengthEl = document.getElementById(\"randomLength\");\n  const randomMaxEl = document.getElementById(\"randomMax\");\n  const currentArrayDisplayEl = document.getElementById(\"currentArrayDisplay\");\n\n  const optStableEl = document.getElementById(\"optStable\");\n  const optLsdEl = document.getElementById(\"optLsd\");\n  const optMsdEl = document.getElementById(\"optMsd\");\n  const radixBaseEl = document.getElementById(\"radixBase\");\n\n  const btnStartSort = document.getElementById(\"btnStartSort\");\n  const btnNextStep = document.getElementById(\"btnNextStep\");\n  const btnPrevStep = document.getElementById(\"btnPrevStep\");\n  const btnAutoRun = document.getElementById(\"btnAutoRun\");\n  const btnPause = document.getElementById(\"btnPause\");\n  const btnReset = document.getElementById(\"btnReset\");\n  const stepDelayEl = document.getElementById(\"stepDelay\");\n\n  const sortStepInfoEl = document.getElementById(\"sortStepInfo\");\n  const arrayTableDiv = document.getElementById(\"arrayTableDiv\");\n  const bucketsDiv = document.getElementById(\"bucketsDiv\");\n\n  const btnJumpToPass = document.getElementById(\"btnJumpToPass\");\n  const jumpPassNumberEl = document.getElementById(\"jumpPassNumber\");\n  const btnJumpToStep = document.getElementById(\"btnJumpToStep\");\n  const jumpStepNumberEl = document.getElementById(\"jumpStepNumber\");\n  const btnShowFullHistory = document.getElementById(\"btnShowFullHistory\");\n  const btnHideFullHistory = document.getElementById(\"btnHideFullHistory\");\n  const fullHistoryDiv = document.getElementById(\"fullHistoryDiv\");\n\n  const debuglogEl = document.getElementById(\"debuglog\");\n\n  // === Utility ===\n  function logDebug(msg){\n    let dt = new Date().toLocaleTimeString();\n    debuglogEl.textContent += `[${dt}] ${msg}\\n`;\n    debuglogEl.scrollTop = debuglogEl.scrollHeight;\n  }\n\n  // === Display ===\n  function displayCurrentArray(){\n    currentArrayDisplayEl.textContent = currentArray.length > 0 ? currentArray.join(\", \") : \"(empty)\";\n  }\n  // Show array in table with possible highlights (highlightIndices: array of indices to highlight)\n  function renderArrayTable(arr, highlightIndices){\n    highlightIndices = highlightIndices || [];\n    let html = \"<table><tr>\";\n    for(let i=0; i<arr.length; i++){\n      let cls = highlightIndices.indexOf(i)>=0 ? \"highlight\" : \"\";\n      html += `<td class=\"${cls}\">${arr[i]}</td>`;\n    }\n    html += \"</tr><tr>\";\n    for(let i=0; i<arr.length; i++){\n      html += `<td>${i}</td>`;\n    }\n    html += \"</tr></table>\";\n    arrayTableDiv.innerHTML = html;\n  }\n  // Render buckets, buckets is array of arrays, base is radix base\n  function renderBuckets(buckets){\n    if(!buckets || buckets.length===0){\n      bucketsDiv.textContent = \"(no buckets)\";\n      return;\n    }\n    let columns = buckets.length;\n    // Find max bucket length\n    let maxLen = buckets.reduce((max,c)=>Math.max(max,c.length),0);\n    let html = \"<table><thead><tr>\";\n    for(let i=0; i<columns; i++){\n      html += `<th>${i}</th>`;\n    }\n    html += \"</tr></thead><tbody>\";\n    for(let r=0; r<maxLen; r++){\n      html += \"<tr>\";\n      for(let c=0; c<columns; c++){\n        html += `<td>${buckets[c][r] !== undefined ? buckets[c][r] : \"\"}</td>`;\n      }\n      html += \"</tr>\";\n    }\n    html += \"</tbody></table>\";\n    bucketsDiv.innerHTML = html;\n  }\n\n  // === Radix Sort Implementation with step-by-step state saving ===\n\n  // We must generate a complete \"history\" of sort steps, and then allow moving forward/back through them.\n\n  // For LSD Radix Sort:\n  // Algorithm:\n  // for digitIndex from 0 (LSD) to maxDigitIndex:\n  //   place all elements into buckets by digit at digitIndex\n  //   collect from buckets back into array (preserving order if stable)\n  // We'll store states before bucket placement, after bucket placement, after collection.\n\n  // Each pass can have multiple steps:\n  // Step 0: start of pass with array state\n  // Step 1: buckets (after placement)\n  // Step 2: array after collection (ready for next pass)\n\n  // We keep history as array of objects each describing such a step.\n\n  function buildLsdHistory(arr, base, stable){\n    history = [];\n    if(arr.length === 0) return;\n    let workingArray = arr.slice();\n    let maxNum = getMaxNumber(workingArray);\n    let maxDigitIndex = maxNum === 0 ? 0 : Math.floor(Math.log(maxNum)/Math.log(base));\n\n    for(let digitIndex=0; digitIndex <= maxDigitIndex; digitIndex++){\n      // Step 0: start pass\n      history.push({\n        passNumber: digitIndex,\n        stepNumber: 0,\n        digitIndex: digitIndex,\n        description: `Pass ${digitIndex}: Start with array`,\n        array: workingArray.slice(),\n        buckets: null,\n      });\n\n      // Prepare buckets\n      let buckets = [];\n      for(let i=0; i<base; i++) buckets.push([]);\n      // Place elements in buckets\n      for(let val of workingArray){\n        let d = getDigit(val, base, digitIndex);\n        buckets[d].push(val);\n      }\n      // Step 1: buckets after placement\n      history.push({\n        passNumber: digitIndex,\n        stepNumber: 1,\n        digitIndex: digitIndex,\n        description: `Pass ${digitIndex}: Buckets after placing elements`,\n        array: workingArray.slice(),\n        buckets: buckets.map(b=>b.slice()),\n      });\n\n      // Collect from buckets preserving order if stable\n      let collected;\n      if(stable){\n        collected = [];\n        for(let b of buckets){\n          collected = collected.concat(b);\n        }\n      } else {\n        // Non-stable could do in any order - simulate as buckets collected in reverse order for variety\n        collected = [];\n        for(let i=base-1; i>=0; i--){\n          collected = collected.concat(buckets[i]);\n        }\n      }\n      \n      // Step 2: after collection\n      history.push({\n        passNumber: digitIndex,\n        stepNumber: 2,\n        digitIndex: digitIndex,\n        description: `Pass ${digitIndex}: Array after collecting from buckets`,\n        array: collected.slice(),\n        buckets: buckets.map(b=>b.slice()),\n      });\n\n      workingArray = collected;\n    }\n  }\n\n  // MSD Radix Sort with detailed stepping:\n  //\n  // MSD Radix Sort (recursive):\n  // 1. Find max digitIndex = highest digit position (based on max number)\n  // 2. Starting at digitIndex = maxDigitIndex, split array into buckets by digit at digitIndex\n  // 3. For each bucket that has >1 element and digitIndex > 0, recursively sort with digitIndex-1\n  // 4. Collect buckets in order\n  //\n  // To keep it interactive, we'll flatten recursion using a stack and store states before and after splits/sorts.\n\n  // We'll emit steps:\n  // Step 0: start of pass at digitIndex with current subarray and global pass number\n  // Step 1: bucket placement\n  // Step 2: after recursion on bucket (if needed)\n  // Step 3: after collection\n  \n  // To manage global state, we'll maintain an incrementing passNumber.\n\n  function buildMsdHistory(arr, base, stable){\n    history = [];\n    if(arr.length === 0) return;\n    let maxNum = getMaxNumber(arr);\n    let maxDigitIndex = maxNum === 0 ? 0 : Math.floor(Math.log(maxNum)/Math.log(base));\n    \n    let workingArray = arr.slice();\n\n    // We'll keep a global pass number to identify passes distinctly\n    let passCounter = 0;\n\n    // Structure on stack: \n    // {array: [], digitIndex: n, description: string, fromIndex: index in original array (global?), depth: int, collectedArray: [] }\n    // fromIndex is used to track position for visualizations\n\n    // For MSD, we sort recursively by digitIndex starting from maxDigitIndex (MSD)\n    // We'll simulate recursion by a stack, pushing contexts on the stack and unfolding them step by step.\n\n    // Data structure to hold intermediate states for output\n    // We'll create a recursive helper that pushes all states in order.\n\n    function msdSortRecursive(arrPart, digitIndex, depth) {\n      // depth is recursion depth for info\n\n      if(arrPart.length <=1 || digitIndex < 0){\n        // No sorting needed, just emit a pass with single step showing array as is\n        history.push({\n          passNumber: passCounter++,\n          stepNumber: 0,\n          digitIndex: digitIndex,\n          description: `Depth ${depth}, digitIndex ${digitIndex}: Single or no element, no sorting needed`,\n          array: arrPart.slice(),\n          buckets: null,\n        });\n        return arrPart.slice();\n      }\n\n      // 1. Step 0: start pass with arr\n      let currentPass = passCounter++;\n      history.push({\n        passNumber: currentPass,\n        stepNumber: 0,\n        digitIndex: digitIndex,\n        description: `Depth ${depth}, digitIndex ${digitIndex}: Start with array`,\n        array: arrPart.slice(),\n        buckets: null,\n      });\n\n      // 2. Place into buckets\n      let buckets = [];\n      for(let i=0; i<base; i++) buckets.push([]);\n      for(let v of arrPart){\n        let d = getDigit(v, base, digitIndex);\n        buckets[d].push(v);\n      }\n\n      // 3. Step 1: buckets after placement\n      history.push({\n        passNumber: currentPass,\n        stepNumber: 1,\n        digitIndex: digitIndex,\n        description: `Depth ${depth}, digitIndex ${digitIndex}: Buckets after placing elements`,\n        array: arrPart.slice(),\n        buckets: buckets.map(b=>b.slice()),\n      });\n\n      // 4. Recursively sort each bucket (except buckets with length ≤1)\n      // We will remember array after each recursive sort call of bucket\n      for(let i=0; i<base; i++){\n        if(buckets[i].length > 1 && digitIndex > 0){\n          // Recursive sort of bucket i with digitIndex-1\n          // Step before recursion: (optional)\n          history.push({\n            passNumber: currentPass,\n            stepNumber: 1.5 + i*0.1, // fractional steps to keep order\n            digitIndex: digitIndex-1,\n            description: `Depth ${depth+1}, digitIndex ${digitIndex-1}: Recursively sorting bucket ${i} with ${buckets[i].length} elements`,\n            array: buckets[i].slice(),\n            buckets: null,\n          });\n          buckets[i] = msdSortRecursive(buckets[i], digitIndex-1, depth+1);\n          // Step after recursion:\n          history.push({\n            passNumber: currentPass,\n            stepNumber: 1.6 + i*0.1,\n            digitIndex: digitIndex-1,\n            description: `Depth ${depth+1}, digitIndex ${digitIndex-1}: Completed sorting bucket ${i}`,\n            array: buckets[i].slice(),\n            buckets: null,\n          });\n        }\n      }\n\n      // 5. Collect buckets (in order, stable)\n      let collected = [];\n      if(stable){\n        for(let b of buckets){\n          collected = collected.concat(b);\n        }\n      } else {\n        for(let i=base-1; i>=0; i--){\n          collected = collected.concat(buckets[i]);\n        }\n      }\n\n      // 6. Step 3: after collection (end of pass)\n      history.push({\n        passNumber: currentPass,\n        stepNumber: 3,\n        digitIndex: digitIndex,\n        description: `Depth ${depth}, digitIndex ${digitIndex}: Array after collecting buckets`,\n        array: collected.slice(),\n        buckets: buckets.map(b=>b.slice()),\n      });\n      return collected;\n    }\n\n    let sorted = msdSortRecursive(workingArray, maxDigitIndex, 0);\n  }\n\n  // === Main control functions ===\n\n  // Validate LSD/MSD selection: exactly one\n  function validateSortOptions(){\n    if(optLsdEl.checked && optMsdEl.checked){\n      alert(\"Choose exactly one between LSD and MSD Radix Sort.\");\n      return false;\n    }\n    if(!optLsdEl.checked && !optMsdEl.checked){\n      alert(\"Choose exactly one between LSD and MSD Radix Sort.\");\n      return false;\n    }\n    return true;\n  }\n\n  // Set current array from input\n  function setArrayFromInput(){\n    let arrText = inputArrayEl.value;\n    let arr = parseInputArray(arrText);\n    if(arr === null){\n      alert(\"Invalid input array. Enter a list of non-negative integers separated by commas or spaces.\");\n      return false;\n    }\n    originalArray = arr;\n    currentArray = arr.slice();\n    displayCurrentArray();\n    logDebug(\"Array set to: \"+currentArray.join(\", \"));\n    resetSortStateToReady();\n    return true;\n  }\n\n  // Generate random array and set input & current\n  function generateRandomArray(){\n    let len = Number(randomLengthEl.value);\n    let maxv = Number(randomMaxEl.value);\n    if(!Number.isInteger(len) || len < 1 || len > 50){\n      alert(\"Length must be an integer between 1 and 50.\");\n      return false;\n    }\n    if(!Number.isInteger(maxv) || maxv < 1 || maxv > 999999){\n      alert(\"Max value must be an integer between 1 and 999999.\");\n      return false;\n    }\n    let arr = [];\n    for(let i=0; i<len; i++){\n      arr.push(Math.floor(Math.random()*(maxv+1)));\n    }\n    originalArray = arr;\n    currentArray = arr.slice();\n    inputArrayEl.value = arr.join(\", \");\n    displayCurrentArray();\n    logDebug(\"Random array generated: \"+currentArray.join(\", \"));\n    resetSortStateToReady();\n    return true;\n  }\n\n  // Reset sort states and controls\n  function resetSortStateToReady(){\n    sortingStarted = false;\n    sortingPaused = false;\n    history = [];\n    currentHistoryIndex = -1;\n    updateSortControls();\n    clearVisualization();\n  }\n\n  // Update enabled states of buttons depending on current sort phase\n  function updateSortControls(){\n    btnStartSort.disabled = sortingStarted;\n    btnNextStep.disabled = !sortingStarted || currentHistoryIndex >= history.length-1;\n    btnPrevStep.disabled = !sortingStarted || currentHistoryIndex <= 0;\n    btnAutoRun.disabled = !sortingStarted || currentHistoryIndex >= history.length-1 || sortingPaused===false;\n    btnPause.disabled = !sortingStarted || sortingPaused===true;\n    btnReset.disabled = !sortingStarted;\n\n    // Exploration jump buttons enabled only if sortingStarted\n    btnJumpToPass.disabled = !sortingStarted;\n    btnJumpToStep.disabled = !sortingStarted;\n  }\n\n  // Clear visualization\n  function clearVisualization(){\n    sortStepInfoEl.textContent = \"\";\n    arrayTableDiv.innerHTML = \"\";\n    bucketsDiv.innerHTML = \"\";\n    fullHistoryDiv.textContent = \"\";\n    btnShowFullHistory.style.display = \"\";\n    btnHideFullHistory.style.display = \"none\";\n  }\n\n  // Render current step in history by currentHistoryIndex\n  function renderCurrentStep(){\n    if(currentHistoryIndex < 0 || currentHistoryIndex >= history.length){\n      sortStepInfoEl.textContent = \"No sort steps to show.\";\n      arrayTableDiv.innerHTML = \"\";\n      bucketsDiv.innerHTML = \"\";\n      return;\n    }\n    let stepObj = history[currentHistoryIndex];\n    let s = \"\";\n    s += `Pass #${stepObj.passNumber}, Step #${stepObj.stepNumber}\\n`;\n    s += `Digit Index (base ${radixBase}): ${stepObj.digitIndex}\\n`;\n    s += `Description:\\n${stepObj.description}\\n`;\n    sortStepInfoEl.textContent = s;\n    renderArrayTable(stepObj.array);\n    if(stepObj.buckets){\n      renderBuckets(stepObj.buckets);\n    } else {\n      bucketsDiv.innerHTML = \"(no buckets to show)\";\n    }\n  }\n\n  // Start sorting: build history and initialize\n  function startSort(){\n    // Validate options\n    if(!validateSortOptions()) return false;\n    if(currentArray.length===0){\n      alert(\"Array is empty. Set an array first.\");\n      return false;\n    }\n    radixBase = Number(radixBaseEl.value);\n    useStable = optStableEl.checked;\n    isLSD = optLsdEl.checked;\n    isMSD = optMsdEl.checked;\n\n    // Build history depending on selected type\n    history = [];\n    currentHistoryIndex = -1;\n    if(isLSD){\n      buildLsdHistory(currentArray, radixBase, useStable);\n      logDebug(`Started LSD Radix Sort with base=${radixBase}, stable=${useStable}`);\n    } else {\n      buildMsdHistory(currentArray, radixBase, useStable);\n      logDebug(`Started MSD Radix Sort with base=${radixBase}, stable=${useStable}`);\n    }\n\n    if(history.length === 0){\n      alert(\"No steps generated - array may be empty.\");\n      return false;\n    }\n    sortingStarted = true;\n    sortingPaused = true;\n    stepDelay = Number(stepDelayEl.value);\n    if(!Number.isInteger(stepDelay) || stepDelay < 10) stepDelay = 700;\n    currentHistoryIndex = 0;\n    renderCurrentStep();\n    updateSortControls();\n    return true;\n  }\n\n  // Advance one step forward\n  function nextStep(){\n    if(!sortingStarted) return;\n    if(currentHistoryIndex < history.length-1){\n      currentHistoryIndex++;\n      renderCurrentStep();\n      updateSortControls();\n    }\n  }\n  // Move one step backward\n  function prevStep(){\n    if(!sortingStarted) return;\n    if(currentHistoryIndex > 0){\n      currentHistoryIndex--;\n      renderCurrentStep();\n      updateSortControls();\n    }\n  }\n\n  // Auto run timer handler\n  function autoRunStep(){\n    if(!sortingStarted || sortingPaused) return;\n    if(currentHistoryIndex >= history.length-1){\n      pauseAutoRun();\n      return;\n    }\n    nextStep();\n  }\n  // Start auto run\n  function startAutoRun(){\n    if(!sortingStarted) return;\n    sortingPaused = false;\n    updateSortControls();\n    stepDelay = Number(stepDelayEl.value);\n    if(!Number.isInteger(stepDelay) || stepDelay < 10) stepDelay = 700;\n    autoRunTimer = setInterval(autoRunStep, stepDelay);\n  }\n  // Pause auto run\n  function pauseAutoRun(){\n    sortingPaused = true;\n    updateSortControls();\n    if(autoRunTimer){\n      clearInterval(autoRunTimer);\n      autoRunTimer = null;\n    }\n  }\n  // Reset sort: undo sorting session\n  function resetSort(){\n    sortingStarted = false;\n    sortingPaused = false;\n    history = [];\n    currentHistoryIndex = -1;\n    currentArray = originalArray.slice();\n    displayCurrentArray();\n    clearVisualization();\n    updateSortControls();\n    if(autoRunTimer){\n      clearInterval(autoRunTimer);\n      autoRunTimer = null;\n    }\n    logDebug(\"Sort reset.\");\n  }\n\n  // Jump to pass number in history (first matching pass)\n  function jumpToPass(passNumber){\n    passNumber = Number(passNumber);\n    if(!sortingStarted) return false;\n    if(!Number.isInteger(passNumber) || passNumber < 0) return false;\n    let index = history.findIndex(h => h.passNumber === passNumber);\n    if(index < 0) return false;\n    currentHistoryIndex = index;\n    renderCurrentStep();\n    updateSortControls();\n    return true;\n  }\n  // Jump to step number within current pass\n  function jumpToStepWithinPass(stepNumber){\n    stepNumber = Number(stepNumber);\n    if(!sortingStarted) return false;\n    if(!Number.isInteger(stepNumber) || stepNumber < 0) return false;\n    let passNum = history[currentHistoryIndex] ? history[currentHistoryIndex].passNumber : null;\n    if(passNum === null) return false;\n    // find history entry with same passNumber and stepNumber\n    let index = history.findIndex(h => (h.passNumber === passNum && h.stepNumber === stepNumber));\n    if(index < 0) return false;\n    currentHistoryIndex = index;\n    renderCurrentStep();\n    updateSortControls();\n    return true;\n  }\n\n  // Show full history formatted in textarea\n  function showFullHistory(){\n    if(history.length === 0){\n      fullHistoryDiv.textContent = \"(No history to show)\";\n    } else {\n      let txt = \"\";\n      for(let i=0; i<history.length; i++){\n        let h = history[i];\n        txt += `Step ${i} | Pass ${h.passNumber} Step ${h.stepNumber} | Digit: ${h.digitIndex}\\n`;\n        txt += `Description: ${h.description}\\n`;\n        txt += `Array: ${h.array.join(\", \")}\\n`;\n        if(h.buckets){\n          txt += `Buckets:\\n`;\n          for(let b=0; b<h.buckets.length; b++){\n            txt += `  Bucket ${b}: ${h.buckets[b].join(\", \")}\\n`;\n          }\n        }\n        txt += \"\\n\";\n      }\n      fullHistoryDiv.textContent = txt;\n    }\n    btnShowFullHistory.style.display = \"none\";\n    btnHideFullHistory.style.display = \"\";\n  }\n  function hideFullHistory(){\n    fullHistoryDiv.textContent = \"\";\n    btnShowFullHistory.style.display = \"\";\n    btnHideFullHistory.style.display = \"none\";\n  }\n\n  // === Set event handlers ===\n\n  btnSetArray.addEventListener(\"click\", function(){\n    if(sortingStarted){\n      if(!confirm(\"Sorting already started. Setting a new array will reset the sort. Continue?\")){\n        return;\n      }\n    }\n    setArrayFromInput();\n  });\n\n  btnRandomArray.addEventListener(\"click\", function(){\n    if(sortingStarted){\n      if(!confirm(\"Sorting already started. Generating a new random array will reset the sort. Continue?\")){\n        return;\n      }\n    }\n    generateRandomArray();\n  });\n\n  // Mutually exclusive LSD / MSD checkboxes handler:\n  optLsdEl.addEventListener(\"change\", function(){\n    if(optLsdEl.checked){\n      optMsdEl.checked = false;\n    } else if(!optMsdEl.checked){\n      // prevent both unchecked, force MSD checked\n      optMsdEl.checked = true;\n    }\n  });\n  optMsdEl.addEventListener(\"change\", function(){\n    if(optMsdEl.checked){\n      optLsdEl.checked = false;\n    } else if(!optLsdEl.checked){\n      optLsdEl.checked = true;\n    }\n  });\n\n  btnStartSort.addEventListener(\"click\", function(){\n    if(startSort()){\n      logDebug(\"Sort started.\");\n    }\n  });\n  btnNextStep.addEventListener(\"click\", function(){\n    nextStep();\n  });\n  btnPrevStep.addEventListener(\"click\", function(){\n    prevStep();\n  });\n  btnAutoRun.addEventListener(\"click\", function(){\n    startAutoRun();\n  });\n  btnPause.addEventListener(\"click\", function(){\n    pauseAutoRun();\n  });\n  btnReset.addEventListener(\"click\", function(){\n    if(confirm(\"Reset the sorting session?\")){\n      resetSort();\n    }\n  });\n\n  stepDelayEl.addEventListener(\"change\", function(){\n    let v = Number(stepDelayEl.value);\n    if(!Number.isInteger(v) || v < 10){\n      stepDelayEl.value = stepDelay;\n    } else {\n      stepDelay = v;\n      if(!sortingPaused && sortingStarted){\n        pauseAutoRun();\n        startAutoRun();\n      }\n    }\n  });\n\n  btnJumpToPass.addEventListener(\"click\", function(){\n    let pn = Number(jumpPassNumberEl.value);\n    if(!jumpToPass(pn)){\n      alert(\"Invalid pass number or pass not found.\");\n    }\n  });\n  btnJumpToStep.addEventListener(\"click\", function(){\n    let sn = Number(jumpStepNumberEl.value);\n    if(!jumpToStepWithinPass(sn)){\n      alert(\"Invalid step number for current pass or not found.\");\n    }\n  });\n\n  btnShowFullHistory.addEventListener(\"click\", showFullHistory);\n  btnHideFullHistory.addEventListener(\"click\", hideFullHistory);\n\n  // Initialize with default array display\n  if(parseInputArray(inputArrayEl.value)){\n    setArrayFromInput();\n  } else {\n    currentArrayDisplayEl.textContent = \"(invalid default array)\";\n  }\n\n})();\n</script>\n</body>\n</html>"
