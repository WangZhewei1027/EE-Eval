  "question": "Dynamic Array",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>Dynamic Array Interactive Demo</title>\n<style>\n  /* Extremely minimal: plain black text on white bg, no styling beyond layout basics */\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  textarea, input[type=number] {\n    font-family: monospace, monospace;\n  }\n  .section {\n    margin-bottom: 1.5em;\n  }\n  .flex-row {\n    display: flex;\n    gap: 0.5em;\n    align-items: center;\n    flex-wrap: wrap;\n  }\n  button, input[type=number], input[type=text] {\n    font-size: 1em;\n  }\n  label {\n    user-select: none;\n  }\n  pre {\n    white-space: pre-wrap;\n  }\n</style>\n</head>\n<body>\n<h1>Dynamic Array Interactive Exploration</h1>\n\n<div class=\"section\" id=\"array-state-section\">\n  <h2>Current Array State</h2>\n  <pre id=\"arrayOutput\">[ ]</pre>\n  <div>\n    <label>Array size: <span id=\"arraySize\">0</span></label>\n  </div>\n</div>\n\n<div class=\"section\" id=\"basic-operations-section\">\n  <h2>Basic Operations</h2>\n  <div class=\"flex-row\">\n    <input type=\"text\" id=\"inputValue\" placeholder=\"Value to add\" />\n    <button id=\"pushBtn\" title=\"Append value to end (push)\">Push</button>\n    <button id=\"popBtn\" title=\"Remove last element (pop)\">Pop</button>\n    <button id=\"unshiftBtn\" title=\"Add value to front (unshift)\">Unshift</button>\n    <button id=\"shiftBtn\" title=\"Remove first element (shift)\">Shift</button>\n  </div>\n</div>\n\n<div class=\"section\" id=\"random-operations-section\">\n  <h2>Random / Bulk Operations</h2>\n  <div class=\"flex-row\">\n    <label for=\"bulkCount\">Number of elements:</label>\n    <input type=\"number\" id=\"bulkCount\" value=\"5\" min=\"1\" max=\"100\" step=\"1\" />\n    <button id=\"bulkPushRandom\">Push N Random Numbers</button>\n    <button id=\"bulkUnshiftRandom\">Unshift N Random Numbers</button>\n  </div>\n  <div class=\"flex-row\" style=\"margin-top: 0.5em;\">\n    <label for=\"rangeMin\">Random min:</label>\n    <input type=\"number\" id=\"rangeMin\" value=\"0\" step=\"1\" style=\"width:5em\" />\n    <label for=\"rangeMax\">max:</label>\n    <input type=\"number\" id=\"rangeMax\" value=\"100\" step=\"1\" style=\"width:5em\" />\n  </div>\n</div>\n\n<div class=\"section\" id=\"manual-insert-section\">\n  <h2>Insert / Remove at Index</h2>\n  <div class=\"flex-row\">\n    <label for=\"insertIndex\">Index:</label>\n    <input type=\"number\" id=\"insertIndex\" value=\"0\" min=\"0\" step=\"1\" style=\"width:5em\" />\n    <input type=\"text\" id=\"insertValue\" placeholder=\"Value to insert\" />\n    <button id=\"insertAtBtn\" title=\"Insert value at index\">Insert At</button>\n  </div>\n  <div class=\"flex-row\" style=\"margin-top: 0.5em;\">\n    <label for=\"removeIndex\">Index to remove:</label>\n    <input type=\"number\" id=\"removeIndex\" value=\"0\" min=\"0\" step=\"1\" style=\"width:5em\" />\n    <button id=\"removeAtBtn\" title=\"Remove value at index\">Remove At</button>\n  </div>\n</div>\n\n<div class=\"section\" id=\"resize-array-section\">\n  <h2>Resize Array</h2>\n  <div class=\"flex-row\">\n    <label for=\"resizeSize\">New size:</label>\n    <input type=\"number\" id=\"resizeSize\" value=\"0\" min=\"0\" step=\"1\" style=\"width:5em\" />\n    <button id=\"resizeBtn\" title=\"Resize array length\">Resize</button>\n  </div>\n  <div class=\"flex-row\" style=\"margin-top: 0.5em;\">\n    <label for=\"resizeFill\">Fill new elements with:</label>\n    <input type=\"text\" id=\"resizeFill\" placeholder=\"Default is undefined\" />\n  </div>\n</div>\n\n<div class=\"section\" id=\"transition-section\">\n  <h2>Array State Transitions and History</h2>\n  <button id=\"undoBtn\" disabled>Undo</button>\n  <button id=\"redoBtn\" disabled>Redo</button>\n  <button id=\"resetBtn\">Reset to empty</button>\n  <div style=\"margin-top:0.5em;\">\n    <label><input type=\"checkbox\" id=\"autoSnapshot\" checked /> Auto snapshot after each operation (for undo)</label>\n  </div>\n</div>\n\n<div class=\"section\" id=\"search-section\">\n  <h2>Search and Query</h2>\n  <div class=\"flex-row\">\n    <input type=\"text\" id=\"searchValue\" placeholder=\"Value to search\" />\n    <button id=\"indexOfBtn\" title=\"Find first index of value\">Index Of</button>\n    <button id=\"includesBtn\" title=\"Test if value exists\">Includes</button>\n    <button id=\"lastIndexOfBtn\" title=\"Find last index of value\">Last Index Of</button>\n  </div>\n  <div style=\"margin-top: 0.5em;\">\n    <pre id=\"searchResult\" style=\"min-height:1.2em;\"></pre>\n  </div>\n</div>\n\n<div class=\"section\" id=\"slice-splice-section\">\n  <h2>Slice and Splice</h2>\n  <div class=\"flex-row\">\n    <label for=\"sliceStart\">Slice Start:</label>\n    <input type=\"number\" id=\"sliceStart\" value=\"0\" step=\"1\" style=\"width:5em\" />\n    <label for=\"sliceEnd\">End (exclusive):</label>\n    <input type=\"number\" id=\"sliceEnd\" value=\"0\" step=\"1\" style=\"width:5em\" />\n    <button id=\"sliceBtn\">Slice</button>\n  </div>\n  <div style=\"margin-top: 0.5em;\">\n    <label>Slice result:</label>\n    <pre id=\"sliceResult\">[ ]</pre>\n  </div>\n  <hr />\n  <div class=\"flex-row\" style=\"margin-top: 1em;\">\n    <label for=\"spliceStart\">Splice Start:</label>\n    <input type=\"number\" id=\"spliceStart\" value=\"0\" step=\"1\" style=\"width:5em\" />\n    <label for=\"spliceDeleteCount\">Delete Count:</label>\n    <input type=\"number\" id=\"spliceDeleteCount\" value=\"0\" step=\"1\" style=\"width:5em\" />\n    <input type=\"text\" id=\"spliceInsertValues\" placeholder=\"Comma-separated values to insert\" style=\"min-width:14em\" />\n    <button id=\"spliceBtn\">Splice</button>\n  </div>\n  <div style=\"margin-top: 0.5em;\">\n    <label>Splice removed elements:</label>\n    <pre id=\"spliceResult\">[ ]</pre>\n  </div>\n</div>\n\n<div class=\"section\" id=\"map-filter-reduce-section\">\n  <h2>Map, Filter, Reduce</h2>\n  <div>\n    <label for=\"mapExpr\">Map expression (value = x):</label><br />\n    <input type=\"text\" id=\"mapExpr\" placeholder=\"e.g. x * 2\" style=\"width: 30em;\" />\n    <button id=\"applyMapBtn\">Apply Map</button>\n  </div>\n  <div style=\"margin-top:0.8em;\">\n    <label for=\"filterExpr\">Filter expression (value = x):</label><br />\n    <input type=\"text\" id=\"filterExpr\" placeholder=\"e.g. x > 10\" style=\"width: 30em;\" />\n    <button id=\"applyFilterBtn\">Apply Filter</button>\n  </div>\n  <div style=\"margin-top:0.8em;\">\n    <label for=\"reduceExpr\">Reduce expression (acc, value):</label><br />\n    <input type=\"text\" id=\"reduceExpr\" placeholder=\"e.g. acc + x\" style=\"width: 30em;\" />\n    <label for=\"reduceInitial\">Initial value:</label>\n    <input type=\"text\" id=\"reduceInitial\" placeholder=\"e.g. 0\" style=\"width:8em\" />\n    <button id=\"applyReduceBtn\">Apply Reduce</button>\n  </div>\n  <div style=\"margin-top:0.5em;\">\n    <label>Reduce result:</label>\n    <pre id=\"reduceResult\" style=\"min-height:1.2em;\"></pre>\n  </div>\n</div>\n\n<div class=\"section\" id=\"sort-section\">\n  <h2>Sort Array</h2>\n  <div class=\"flex-row\">\n    <label for=\"sortMode\">Sort Mode:</label>\n    <select id=\"sortMode\">\n      <option value=\"default\">Default (string Unicode)</option>\n      <option value=\"numeric-asc\">Numeric Ascending</option>\n      <option value=\"numeric-desc\">Numeric Descending</option>\n      <option value=\"custom\">Custom Function</option>\n    </select>\n  </div>\n  <div style=\"margin-top:0.5em;\">\n    <label for=\"customSortFn\" style=\"display:block;\">Custom comparator function (a,b):</label>\n    <input type=\"text\" id=\"customSortFn\" placeholder=\"e.g. return a.length - b.length;\" style=\"width: 30em;\" disabled />\n  </div>\n  <button id=\"sortBtn\" style=\"margin-top:0.5em;\">Sort</button>\n</div>\n\n<div class=\"section\" id=\"other-utilities-section\">\n  <h2>Other Utilities</h2>\n  <button id=\"reverseBtn\">Reverse</button>\n  <button id=\"clearBtn\">Clear Array</button>\n  <button id=\"shuffleBtn\">Shuffle</button>\n  <button id=\"uniqueBtn\">Remove Duplicates</button>\n</div>\n\n<script>\n(() => {\n  /**\n   * State:\n   * - array: current array contents (mixed types)\n   * - history: array snapshots for undo/redo\n   * - historyIndex: current pointer in history stack\n   * - autoSnapshot: boolean to create snapshots after operations automatically\n   */\n  let array = [];\n  let history = [];\n  let historyIndex = -1;\n  let autoSnapshot = true;\n\n  // Elements from DOM\n  const arrayOutput = document.getElementById('arrayOutput');\n  const arraySizeLabel = document.getElementById('arraySize');\n\n  // Inputs and buttons\n  const inputValue = document.getElementById('inputValue');\n  const pushBtn = document.getElementById('pushBtn');\n  const popBtn = document.getElementById('popBtn');\n  const unshiftBtn = document.getElementById('unshiftBtn');\n  const shiftBtn = document.getElementById('shiftBtn');\n\n  const bulkCount = document.getElementById('bulkCount');\n  const bulkPushRandom = document.getElementById('bulkPushRandom');\n  const bulkUnshiftRandom = document.getElementById('bulkUnshiftRandom');\n  const rangeMin = document.getElementById('rangeMin');\n  const rangeMax = document.getElementById('rangeMax');\n\n  const insertIndex = document.getElementById('insertIndex');\n  const insertValue = document.getElementById('insertValue');\n  const insertAtBtn = document.getElementById('insertAtBtn');\n\n  const removeIndex = document.getElementById('removeIndex');\n  const removeAtBtn = document.getElementById('removeAtBtn');\n\n  const resizeSize = document.getElementById('resizeSize');\n  const resizeFill = document.getElementById('resizeFill');\n  const resizeBtn = document.getElementById('resizeBtn');\n\n  const undoBtn = document.getElementById('undoBtn');\n  const redoBtn = document.getElementById('redoBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const autoSnapshotCheckbox = document.getElementById('autoSnapshot');\n\n  const searchValue = document.getElementById('searchValue');\n  const indexOfBtn = document.getElementById('indexOfBtn');\n  const includesBtn = document.getElementById('includesBtn');\n  const lastIndexOfBtn = document.getElementById('lastIndexOfBtn');\n  const searchResult = document.getElementById('searchResult');\n\n  const sliceStart = document.getElementById('sliceStart');\n  const sliceEnd = document.getElementById('sliceEnd');\n  const sliceBtn = document.getElementById('sliceBtn');\n  const sliceResult = document.getElementById('sliceResult');\n\n  const spliceStart = document.getElementById('spliceStart');\n  const spliceDeleteCount = document.getElementById('spliceDeleteCount');\n  const spliceInsertValues = document.getElementById('spliceInsertValues');\n  const spliceBtn = document.getElementById('spliceBtn');\n  const spliceResult = document.getElementById('spliceResult');\n\n  const mapExpr = document.getElementById('mapExpr');\n  const applyMapBtn = document.getElementById('applyMapBtn');\n\n  const filterExpr = document.getElementById('filterExpr');\n  const applyFilterBtn = document.getElementById('applyFilterBtn');\n\n  const reduceExpr = document.getElementById('reduceExpr');\n  const reduceInitial = document.getElementById('reduceInitial');\n  const applyReduceBtn = document.getElementById('applyReduceBtn');\n  const reduceResult = document.getElementById('reduceResult');\n\n  const sortMode = document.getElementById('sortMode');\n  const customSortFn = document.getElementById('customSortFn');\n  const sortBtn = document.getElementById('sortBtn');\n\n  const reverseBtn = document.getElementById('reverseBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const shuffleBtn = document.getElementById('shuffleBtn');\n  const uniqueBtn = document.getElementById('uniqueBtn');\n\n  // --- Utility Functions ---\n\n  function parseValue(str) {\n    // Try to parse input string into appropriate type\n    if (str === '') return undefined;\n    if (str.toLowerCase() === 'undefined') return undefined;\n    if (str.toLowerCase() === 'null') return null;\n    if (str.toLowerCase() === 'true') return true;\n    if (str.toLowerCase() === 'false') return false;\n    if (!isNaN(Number(str))) return Number(str);\n    // JSON parse attempt for arrays/objects - silently fail on error\n    try {\n      const parsed = JSON.parse(str);\n      return parsed;\n    } catch {\n      // fallback string\n      return str;\n    }\n  }\n\n  function arrayToString(arr) {\n    return JSON.stringify(arr, (key, val) => {\n      if (typeof val === 'undefined') return \"undefined\";\n      if (typeof val === 'function') return \"[Function]\";\n      if (val === null) return null;\n      return val;\n    }, 2).replace(/\"undefined\"/g, \"undefined\");\n  }\n\n  function updateArrayDisplay() {\n    arrayOutput.textContent = arrayToString(array);\n    arraySizeLabel.textContent = array.length;\n\n    // Update undo/redo buttons status\n    undoBtn.disabled = historyIndex <= 0;\n    redoBtn.disabled = historyIndex >= history.length - 1;\n  }\n\n  // Deep clone array for history states to avoid mutation issues\n  function cloneArray(arr) {\n    return arr.map(v => {\n      // For primitives and simple objects this is fine, just shallow clone\n      // For functions or complex objects, they will be stringified in display only\n      if (v && typeof v === 'object') {\n        try {\n          return JSON.parse(JSON.stringify(v));\n        } catch {\n          return v;\n        }\n      }\n      return v;\n    });\n  }\n\n  function saveSnapshot() {\n    if (!autoSnapshot) return;\n    // If we've undone some states, cut forward history branches on new snapshot\n    if (historyIndex < history.length - 1) {\n      history = history.slice(0, historyIndex + 1);\n    }\n    history.push(cloneArray(array));\n    historyIndex = history.length - 1;\n    updateArrayDisplay();\n  }\n\n  function setArray(newArray, save=true) {\n    array = newArray;\n    if (save) saveSnapshot();\n    else updateArrayDisplay();\n  }\n\n  // --- Event Handlers ---\n\n  // Basic ops\n  pushBtn.addEventListener('click', () => {\n    const val = parseValue(inputValue.value.trim());\n    array.push(val);\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  popBtn.addEventListener('click', () => {\n    if (array.length === 0) {\n      alert('Array is empty - cannot pop');\n      return;\n    }\n    array.pop();\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  unshiftBtn.addEventListener('click', () => {\n    const val = parseValue(inputValue.value.trim());\n    array.unshift(val);\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  shiftBtn.addEventListener('click', () => {\n    if (array.length === 0) {\n      alert('Array is empty - cannot shift');\n      return;\n    }\n    array.shift();\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  // Bulk random push/unshift\n  function generateRandomNumber(min, max) {\n    return Math.floor(Math.random() * (max - min + 1)) + min;\n  }\n\n  bulkPushRandom.addEventListener('click', () => {\n    let n = +bulkCount.value;\n    if (isNaN(n) || n < 1) {\n      alert('Invalid number of elements');\n      return;\n    }\n    let min = +rangeMin.value;\n    let max = +rangeMax.value;\n    if (isNaN(min)) min = 0;\n    if (isNaN(max)) max = 100;\n    if (min > max) [min, max] = [max, min];\n    for (let i = 0; i < n; i++) {\n      array.push(generateRandomNumber(min, max));\n    }\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  bulkUnshiftRandom.addEventListener('click', () => {\n    let n = +bulkCount.value;\n    if (isNaN(n) || n < 1) {\n      alert('Invalid number of elements');\n      return;\n    }\n    let min = +rangeMin.value;\n    let max = +rangeMax.value;\n    if (isNaN(min)) min = 0;\n    if (isNaN(max)) max = 100;\n    if (min > max) [min, max] = [max, min];\n    for (let i = 0; i < n; i++) {\n      array.unshift(generateRandomNumber(min, max));\n    }\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  // Insert at index\n  insertAtBtn.addEventListener('click', () => {\n    let idx = +insertIndex.value;\n    if (isNaN(idx) || idx < 0) {\n      alert('Invalid insert index');\n      return;\n    }\n    if (idx > array.length) {\n      alert('Insert index beyond array length will append at end');\n      idx = array.length;\n    }\n    const val = parseValue(insertValue.value.trim());\n    array.splice(idx, 0, val);\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  // Remove at index\n  removeAtBtn.addEventListener('click', () => {\n    let idx = +removeIndex.value;\n    if (isNaN(idx) || idx < 0 || idx >= array.length) {\n      alert('Invalid remove index');\n      return;\n    }\n    array.splice(idx, 1);\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  // Resize Array\n  resizeBtn.addEventListener('click', () => {\n    let newSize = +resizeSize.value;\n    if (isNaN(newSize) || newSize < 0) {\n      alert('Invalid new size');\n      return;\n    }\n    let fillVal = resizeFill.value.trim();\n    let valToFill = fillVal === '' ? undefined : parseValue(fillVal);\n\n    if (newSize < array.length) {\n      array.length = newSize;\n    } else if (newSize > array.length) {\n      while (array.length < newSize) {\n        array.push(valToFill);\n      }\n    }\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  // Undo / Redo / Reset\n  undoBtn.addEventListener('click', () => {\n    if (historyIndex > 0) {\n      historyIndex--;\n      array = cloneArray(history[historyIndex]);\n      updateArrayDisplay();\n    }\n  });\n\n  redoBtn.addEventListener('click', () => {\n    if (historyIndex < history.length - 1) {\n      historyIndex++;\n      array = cloneArray(history[historyIndex]);\n      updateArrayDisplay();\n    }\n  });\n\n  resetBtn.addEventListener('click', () => {\n    array = [];\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  autoSnapshotCheckbox.addEventListener('change', () => {\n    autoSnapshot = autoSnapshotCheckbox.checked;\n  });\n\n  // Search / Query\n  function looseEqual(a,b) {\n    return a == b; // allows string '3' == number 3 etc\n  }\n\n  indexOfBtn.addEventListener('click', () => {\n    const val = parseValue(searchValue.value.trim());\n    const idx = array.findIndex(x => looseEqual(x, val));\n    searchResult.textContent = idx >= 0 ? `Index: ${idx}` : 'Not found (-1)';\n  });\n\n  includesBtn.addEventListener('click', () => {\n    const val = parseValue(searchValue.value.trim());\n    const found = array.some(x => looseEqual(x, val));\n    searchResult.textContent = found ? 'Includes: true' : 'Includes: false';\n  });\n\n  lastIndexOfBtn.addEventListener('click', () => {\n    const val = parseValue(searchValue.value.trim());\n    let idx = -1;\n    for(let i = array.length -1; i >= 0; i--) {\n      if(looseEqual(array[i], val)) {\n        idx = i;\n        break;\n      }\n    }\n    searchResult.textContent = idx >= 0 ? `Last Index: ${idx}` : 'Not found (-1)';\n  });\n\n  // Slice\n  sliceBtn.addEventListener('click', () => {\n    let start = parseInt(sliceStart.value);\n    let end = parseInt(sliceEnd.value);\n    if (isNaN(start)) start = 0;\n    if (isNaN(end)) end = array.length;\n    const res = array.slice(start, end);\n    sliceResult.textContent = arrayToString(res);\n  });\n\n  // Splice\n  spliceBtn.addEventListener('click', () => {\n    let start = parseInt(spliceStart.value);\n    let deleteCount = parseInt(spliceDeleteCount.value);\n    if (isNaN(start) || start < 0 || start > array.length) {\n      alert('Invalid splice start index');\n      return;\n    }\n    if (isNaN(deleteCount) || deleteCount < 0) {\n      alert('Invalid splice delete count');\n      return;\n    }\n    // Parse insert values from comma separated list\n    let inserts = spliceInsertValues.value.trim();\n    let insertArr = [];\n    if (inserts !== '') {\n      insertArr = inserts.split(',').map(s => parseValue(s.trim()));\n    }\n    const removed = array.splice(start, deleteCount, ...insertArr);\n    spliceResult.textContent = arrayToString(removed);\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  // Map\n  applyMapBtn.addEventListener('click', () => {\n    const expr = mapExpr.value.trim();\n    if (!expr) {\n      alert('Enter a map expression like: x * 2');\n      return;\n    }\n    try {\n      // Use Function constructor to safely evaluate expression - parameter 'x' is the value\n      // Return the result of the expression\n      const mapFunc = new Function('x', `return (${expr});`);\n      const mapped = array.map(v => mapFunc(v));\n      setArray(mapped);\n    } catch (e) {\n      alert('Invalid map expression: ' + e.message);\n    }\n  });\n\n  // Filter\n  applyFilterBtn.addEventListener('click', () => {\n    const expr = filterExpr.value.trim();\n    if (!expr) {\n      alert('Enter a filter expression like: x > 10');\n      return;\n    }\n    try {\n      const filterFunc = new Function('x', `return (${expr});`);\n      const filtered = array.filter(v => filterFunc(v));\n      setArray(filtered);\n    } catch(e) {\n      alert('Invalid filter expression: ' + e.message);\n    }\n  });\n\n  // Reduce\n  applyReduceBtn.addEventListener('click', () => {\n    const expr = reduceExpr.value.trim();\n    if (!expr) {\n      alert('Enter a reduce expression like: acc + x');\n      return;\n    }\n    const initialRaw = reduceInitial.value.trim();\n    try {\n      const reduceFunc = new Function('acc', 'x', `return (${expr});`);\n      const initialVal = initialRaw === '' ? undefined : parseValue(initialRaw);\n      let result;\n      if (array.length === 0 && initialVal === undefined) {\n        reduceResult.textContent = 'Reduce error: empty array with no initial value';\n        return;\n      }\n      if (initialRaw === '') {\n        result = array.reduce((acc, x) => reduceFunc(acc, x));\n      } else {\n        result = array.reduce((acc, x) => reduceFunc(acc, x), initialVal);\n      }\n      reduceResult.textContent = JSON.stringify(result);\n    } catch(e) {\n      alert('Invalid reduce expression: ' + e.message);\n    }\n  });\n\n  // Sort\n  sortMode.addEventListener('change', () => {\n    if(sortMode.value === 'custom') {\n      customSortFn.disabled = false;\n    } else {\n      customSortFn.disabled = true;\n      customSortFn.value = '';\n    }\n  });\n\n  sortBtn.addEventListener('click', () => {\n    try {\n      if (sortMode.value === 'default') {\n        array.sort();\n      } else if (sortMode.value === 'numeric-asc') {\n        array.sort((a,b) => {\n          let na = Number(a);\n          let nb = Number(b);\n          if (isNaN(na) && isNaN(nb)) return 0;\n          if (isNaN(na)) return 1;\n          if (isNaN(nb)) return -1;\n          return na - nb;\n        });\n      } else if (sortMode.value === 'numeric-desc') {\n        array.sort((a,b) => {\n          let na = Number(a);\n          let nb = Number(b);\n          if (isNaN(na) && isNaN(nb)) return 0;\n          if (isNaN(na)) return 1;\n          if (isNaN(nb)) return -1;\n          return nb - na;\n        });\n      } else if (sortMode.value === 'custom') {\n        const fnText = customSortFn.value.trim();\n        if (!fnText) {\n          alert('Enter a custom comparator function body');\n          return;\n        }\n        // Create comparator function a,b\n        // Since user enters only the body, wrap with function constructor\n        const cmpFunc = new Function('a', 'b', fnText);\n        array.sort(cmpFunc);\n      }\n      saveSnapshot();\n      updateArrayDisplay();\n    } catch(e) {\n      alert('Sort failed: ' + e.message);\n    }\n  });\n\n  // Other utilities\n  reverseBtn.addEventListener('click', () => {\n    array.reverse();\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  clearBtn.addEventListener('click', () => {\n    array = [];\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  shuffleBtn.addEventListener('click', () => {\n    // Fisher-Yates shuffle\n    for(let i = array.length - 1; i > 0; i--) {\n      const j = Math.floor(Math.random() * (i+1));\n      [array[i], array[j]] = [array[j], array[i]];\n    }\n    saveSnapshot();\n    updateArrayDisplay();\n  });\n\n  uniqueBtn.addEventListener('click', () => {\n    const seen = new Set();\n    const filtered = [];\n    for(let v of array) {\n      // Use loose equality string form as key for duplicates\n      // To distinguish undefined and 'undefined', use type marker\n      let key;\n      if (v === undefined) key = '__undefined__';\n      else if (v === null) key = '__null__';\n      else if (typeof v === 'object') key = JSON.stringify(v);\n      else key = v + '::' + typeof v;\n      if(!seen.has(key)) {\n        seen.add(key);\n        filtered.push(v);\n      }\n    }\n    setArray(filtered);\n  });\n\n  // Initialization\n  function init() {\n    array = [];\n    saveSnapshot();\n    updateArrayDisplay();\n  }\n\n  init();\n})();\n</script>\n</body>\n</html>"
  },
