    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linked List</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        #list {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n        #list li {\n            padding: 0;\n            margin: 0;\n            border-bottom: 1px solid black;\n            cursor: pointer;\n        }\n        #list li:hover {\n            background-color: #ccc;\n        }\n        #input-field {\n            padding: 0 10px;\n            margin: 10px 0;\n            width: 50%;\n        }\n        #buttons {\n            padding: 0 10px;\n            margin: 10px 0;\n            width: 50%;\n        }\n    </style>\n</head>\n<body>\n\n<button id=\"add-button\">Add</button>\n<button id=\"remove-button\">Remove</button>\n<button id=\"clear-button\">Clear</button>\n<input id=\"input-field\" type=\"text\" placeholder=\"Enter value\">\n<div id=\"list\"></div>\n\n<script>\n    let list = document.getElementById('list');\n    let inputField = document.getElementById('input-field');\n    let buttons = document.getElementById('buttons');\n\n    function addValue(value) {\n        let li = document.createElement('li');\n        li.textContent = value;\n        list.appendChild(li);\n    }\n\n    function removeValue(index) {\n        list.removeChild(list.childNodes[index]);\n    }\n\n    function clearList() {\n        list.innerHTML = '';\n    }\n\n    let currentValue = '';\n\n    function handleAddClick() {\n        addValue(currentValue);\n        currentValue = '';\n        inputField.value = '';\n        list.innerHTML = '';\n    }\n\n    function handleRemoveClick(index) {\n        removeValue(index);\n    }\n\n    function handleClearClick() {\n        clearList();\n    }\n\n    let currentValueInput = document.getElementById('input-field');\n    currentValueInput.addEventListener('input', () => {\n        currentValue = currentValueInput.value;\n    });\n\n    buttons.addEventListener('click', () => {\n        if (currentValue !== '') {\n            addValue(currentValue);\n        }\n    });\n\n    inputField.addEventListener('input', handleAddClick);\n\n    document.getElementById('add-button').addEventListener('click', handleAddClick);\n    document.getElementById('remove-button').addEventListener('click', handleRemoveClick);\n    document.getElementById('clear-button').addEventListener('click', handleClearClick);\n</script>\n\n</body>\n</html>"
