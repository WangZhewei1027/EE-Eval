    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Exponential Search | Visual Exploration</title>\n    <style>\n        :root {\n            --primary: #6C63FF;\n            --secondary: #FF6584;\n            --dark: #2D3748;\n            --light: #F7FAFC;\n            --accent: #48BB78;\n            --transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n            background-color: var(--light);\n            color: var(--dark);\n            line-height: 1.6;\n            overflow-x: hidden;\n        }\n\n        @supports (font-variation-settings: normal) {\n            body { font-family: 'Inter var', -apple-system, BlinkMacSystemFont, sans-serif; }\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 3rem;\n            position: relative;\n            z-index: 2;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 800;\n            background: linear-gradient(45deg, var(--primary), var(--secondary));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            margin-bottom: 1rem;\n            line-height: 1.2;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            color: var(--dark);\n            opacity: 0.8;\n            font-weight: 400;\n            max-width: 700px;\n            margin: 0 auto;\n        }\n\n        .visualization {\n            position: relative;\n            height: 500px;\n            background: white;\n            border-radius: 16px;\n            box-shadow: 0 20px 40px rgba(0,0,0,0.08);\n            padding: 2rem;\n            margin-bottom: 3rem;\n            overflow: hidden;\n            transition: var(--transition);\n        }\n\n        .array-container {\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            height: 300px;\n            margin-top: 2rem;\n            position: relative;\n        }\n\n        .array-element {\n            width: 40px;\n            background: var(--primary);\n            margin: 0 2px;\n            transition: var(--transition);\n            display: flex;\n            align-items: flex-end;\n            justify-content: center;\n            color: white;\n            font-weight: 600;\n            border-top-left-radius: 4px;\n            border-top-right-radius: 4px;\n            position: relative;\n        }\n\n        .array-element.highlight {\n            background: var(--secondary);\n            transform: translateY(-5px);\n            box-shadow: 0 10px 20px rgba(255, 101, 132, 0.3);\n        }\n\n        .array-element.current {\n            background: var(--accent);\n            transform: translateY(-10px) scale(1.05);\n            box-shadow: 0 15px 30px rgba(72, 187, 120, 0.4);\n            z-index: 2;\n        }\n\n        .array-element.found {\n            animation: pulse 1.5s infinite;\n        }\n\n        @keyframes pulse {\n            0% { box-shadow: 0 0 0 0 rgba(72, 187, 120, 0.7); }\n            70% { box-shadow: 0 0 0 15px rgba(72, 187, 120, 0); }\n            100% { box-shadow: 0 0 0 0 rgba(72, 187, 120, 0); }\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        button {\n            background: var(--primary);\n            color: white;\n            border: none;\n            padding: 0.8rem 1.8rem;\n            font-size: 1rem;\n            font-weight: 500;\n            border-radius: 8px;\n            cursor: pointer;\n            transition: var(--transition);\n            box-shadow: 0 4px 6px rgba(108, 99, 255, 0.2);\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 8px 12px rgba(108, 99, 255, 0.3);\n        }\n\n        button:disabled {\n            background: #CBD5E0;\n            cursor: not-allowed;\n            transform: none;\n            box-shadow: none;\n        }\n\n        .explanation {\n            max-width: 800px;\n            margin: 3rem auto 0;\n            background: white;\n            padding: 2rem;\n            border-radius: 16px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.05);\n        }\n\n        h2 {\n            font-size: 1.8rem;\n            margin-bottom: 1rem;\n            color: var(--primary);\n        }\n\n        p {\n            margin-bottom: 1rem;\n        }\n\n        .steps {\n            margin-top: 2rem;\n        }\n\n        .step {\n            margin-bottom: 1rem;\n            padding-left: 1.5rem;\n            position: relative;\n        }\n\n        .step:before {\n            content: '';\n            position: absolute;\n            left: 0;\n            top: 0.5rem;\n            width: 8px;\n            height: 8px;\n            background: var(--primary);\n            border-radius: 50%;\n        }\n\n        .decoration {\n            position: absolute;\n            z-index: 0;\n            opacity: 0.1;\n        }\n\n        .dec-1 {\n            top: 0;\n            right: 0;\n            width: 200px;\n            height: 200px;\n            background: radial-gradient(circle, var(--primary) 0%, transparent 70%);\n        }\n\n        .dec-2 {\n            bottom: -100px;\n            left: -50px;\n            width: 300px;\n            height: 300px;\n            background: radial-gradient(circle, var(--secondary) 0%, transparent 70%);\n        }\n\n        .range-indicator {\n            position: absolute;\n            bottom: 0;\n            height: 10px;\n            background: rgba(108, 99, 255, 0.3);\n            border-radius: 5px;\n            transition: var(--transition);\n        }\n    </style>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Exponential Search</h1>\n            <p class=\"subtitle\">A visual exploration of this efficient searching algorithm that works on sorted arrays by finding the range where the element may be present and then performing binary search.</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"decoration dec-1\"></div>\n            <div class=\"decoration dec-2\"></div>\n            \n            <div class=\"array-container\" id=\"arrayContainer\">\n                <!-- Array elements will be generated by JavaScript -->\n            </div>\n            <div class=\"range-indicator\" id=\"rangeIndicator\"></div>\n\n            <div class=\"controls\">\n                <button id=\"startBtn\">Start Search</button>\n                <button id=\"resetBtn\" disabled>Reset</button>\n            </div>\n        </div>\n\n        <div class=\"explanation\">\n            <h2>How Exponential Search Works</h2>\n            <p>Exponential search is particularly useful for unbounded searches (size of array is infinite) and performs better than binary search for bounded arrays when the element to be searched is closer to the first element.</p>\n            \n            <div class=\"steps\">\n                <div class=\"step\">Find the range where the element is present by repeatedly doubling the index value until we find a value that's greater than the search key.</div>\n                <div class=\"step\">Perform binary search on the identified range (from previous index/2 to current index).</div>\n                <div class=\"step\">This approach reduces the time complexity to O(Log n) while maintaining the benefits of binary search.</div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', () => {\n            const arrayContainer = document.getElementById('arrayContainer');\n            const startBtn = document.getElementById('startBtn');\n            const resetBtn = document.getElementById('resetBtn');\n            const rangeIndicator = document.getElementById('rangeIndicator');\n\n            // Create a sorted array of random numbers (for demo purposes)\n            const array = Array.from({length: 20}, (_, i) => Math.floor(Math.random() * 90) + 10).sort((a, b) => a - b);\n            const target = array[Math.floor(Math.random() * array.length)];\n            \n            let elements = [];\n            let isSearching = false;\n            let currentIndex = 0;\n            let boundLeft = 0;\n            let boundRight = 1;\n\n            // Initialize the array visualization\n            function initArray() {\n                arrayContainer.innerHTML = '';\n                elements = [];\n                \n                // Create array elements\n                array.forEach((value, i) => {\n                    const element = document.createElement('div');\n                    element.className = 'array-element';\n                    element.style.height = `${value * 2.5}px`;\n                    element.innerHTML = `<span style=\"position: absolute; bottom: -25px;\">${value}</span>`;\n                    \n                    if (value === target) {\n                        element.dataset.target = true;\n                    }\n                    \n                    arrayContainer.appendChild(element);\n                    elements.push(element);\n                });\n                \n                updateRangeIndicator();\n            }\n\n            // Update the range indicator visualization\n            function updateRangeIndicator() {\n                if (elements.length === 0) return;\n                \n                const firstElement = elements[0];\n                const lastElement = elements[Math.min(boundRight, elements.length - 1)];\n                \n                rangeIndicator.style.left = `${firstElement.offsetLeft}px`;\n                rangeIndicator.style.width = `${lastElement.offsetLeft + lastElement.offsetWidth - firstElement.offsetLeft}px`;\n            }\n\n            // Perform exponential search steps\n            async function exponentialSearch() {\n                isSearching = true;\n                startBtn.disabled = true;\n                \n                // Step 1: Find the range by doubling index\n                elements[currentIndex].classList.add('current');\n                \n                while (currentIndex < array.length && array[currentIndex] <= target) {\n                    await new Promise(resolve => setTimeout(resolve, 800));\n                    \n                    if (currentIndex > 0) {\n                        elements[currentIndex - 1].classList.remove('current');\n                    }\n                    \n                    if (array[currentIndex] === target) {\n                        elements[currentIndex].classList.add('found');\n                        resetBtn.disabled = false;\n                        isSearching = false;\n                        return;\n                    }\n                    \n                    boundLeft = currentIndex;\n                    boundRight = Math.min(currentIndex * 2, array.length - 1);\n                    updateRangeIndicator();\n                    \n                    if (currentIndex * 2 >= array.length || array[currentIndex * 2] > target) {\n                        break;\n                    }\n                    \n                    currentIndex = currentIndex === 0 ? 1 : currentIndex * 2;\n                    \n                    // Highlight elements between previous and current index\n                    for (let i = boundLeft; i <= currentIndex; i++) {\n                        elements[i].classList.add('highlight');\n                        await new Promise(resolve => setTimeout(resolve, 100));\n                    }\n                    \n                    elements[currentIndex].classList.add('current');\n                }\n                \n                // Binary search on the found range\n                await binarySearch(boundLeft, Math.min(currentIndex, array.length - 1));\n                \n                resetBtn.disabled = false;\n                isSearching = false;\n            }\n\n            // Binary search within the identified range\n            async function binarySearch(left, right) {\n                while (left <= right) {\n                    const mid = Math.floor((left + right) / 2);\n                    \n                    elements[mid].classList.add('current');\n                    await new Promise(resolve => setTimeout(resolve, 800));\n                    \n                    if (array[mid] === target) {\n                        elements[mid].classList.add('found');\n                        return;\n                    }\n                    \n                    elements[mid].classList.remove('current');\n                    \n                    if (array[mid] < target) {\n                        left = mid + 1;\n                    } else {\n                        right = mid - 1;\n                    }\n                    \n                    // Highlight the new search range\n                    for (let i = left; i <= right; i++) {\n                        elements[i].classList.add('highlight');\n                    }\n                    \n                    boundLeft = left;\n                    boundRight = right;\n                    updateRangeIndicator();\n                    await new Promise(resolve => setTimeout(resolve, 500));\n                }\n            }\n\n            // Reset the visualization\n            function reset() {\n                elements.forEach(el => {\n                    el.className = 'array-element';\n                    if (el.dataset.target) {\n                        el.classList.remove('found');\n                    }\n                });\n                \n                currentIndex = 0;\n                boundLeft = 0;\n                boundRight = 1;\n                updateRangeIndicator();\n                \n                startBtn.disabled = false;\n                resetBtn.disabled = true;\n            }\n\n            // Event listeners\n            startBtn.addEventListener('click', exponentialSearch);\n            resetBtn.addEventListener('click', reset);\n\n            // Initialize\n            initArray();\n        });\n    </script>\n</body>\n</html>"
