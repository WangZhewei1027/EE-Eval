  "question": "Counting Sort",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Interactive Counting Sort Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    white-space: pre-wrap;\n  }\n  button, input[type=number], input[type=text] {\n    font-family: monospace, monospace;\n    font-size: 1em;\n    margin: 0 0.2em 0.3em 0.2em;\n    padding: 0.15em 0.3em;\n  }\n  input[type=range] {\n    width: 100px;\n    vertical-align: middle;\n  }\n  .step-info {\n    margin: 0.5em 0;\n  }\n  .array-container {\n    margin: 0.5em 0 1em 0;\n  }\n  .array-item {\n    display: inline-block;\n    width: 2.5em;\n    text-align: center;\n    border: 1px solid black;\n    margin: 0 0.1em;\n    padding: 0.3em 0;\n    user-select:none;\n  }\n  .array-item.highlight {\n    font-weight: bold;\n    text-decoration: underline;\n  }\n  .array-item.current {\n    border: 2px solid black;\n  }\n  #log {\n    margin-top: 1em;\n    max-height: 120px;\n    overflow-y: auto;\n    border: 1px solid black;\n    padding: 0.3em 0.5em;\n    font-size: 0.9em;\n    background: white;\n  }\n  label {\n    user-select:none;\n  }\n</style>\n</head>\n<body>\n<h1>Counting Sort Interactive Demonstration</h1>\n\n<div>\n  <label for=\"inputArray\">Enter initial array (comma/space-separated integers):</label><br />\n  <input type=\"text\" id=\"inputArray\" size=\"50\" aria-label=\"Array input\" placeholder=\"e.g. 4,3,2,8,3\" />\n  <button id=\"btnLoadArray\">Load Array</button>\n  <button id=\"btnRandomArray\">Generate Random Array</button>\n</div>\n\n<div>\n  <label for=\"minValue\">Minimum Value (inclusive):</label>\n  <input type=\"number\" id=\"minValue\" value=\"0\" step=\"1\" />\n  <label for=\"maxValue\">Maximum Value (inclusive):</label>\n  <input type=\"number\" id=\"maxValue\" value=\"10\" step=\"1\" />\n</div>\n\n<div>\n  <label for=\"arraySize\">Array size:</label>\n  <input type=\"number\" id=\"arraySize\" value=\"10\" min=\"1\" max=\"10000\" step=\"1\" />\n</div>\n\n<hr />\n\n<div>\n  <button id=\"btnStartSort\" disabled>Start Counting Sort</button>\n  <button id=\"btnStepBackward\" disabled>Step Backward</button>\n  <button id=\"btnStepForward\" disabled>Step Forward</button>\n  <button id=\"btnRunToEnd\" disabled>Run to End</button>\n  <button id=\"btnReset\" disabled>Reset</button>\n</div>\n\n<div>\n  <label for=\"speedRange\">Automatic run speed (ms delay):</label>\n  <input type=\"range\" id=\"speedRange\" min=\"100\" max=\"2000\" value=\"500\" step=\"50\" />\n  <span id=\"speedDisplay\">500</span> ms\n  <button id=\"btnToggleAuto\" disabled>Start Auto</button>\n</div>\n\n<hr />\n\n<div>\n  <div><strong>Current Step:</strong><span id=\"stepDesc\">Not started</span></div>\n</div>\n\n<div class=\"array-container\" aria-label=\"Input array container\" id=\"inputArrayDisplay\" role=\"region\" aria-live=\"polite\"></div>\n<div class=\"array-container\" aria-label=\"Count array container\" id=\"countArrayDisplay\" role=\"region\" aria-live=\"polite\"></div>\n<div class=\"array-container\" aria-label=\"Output array container\" id=\"outputArrayDisplay\" role=\"region\" aria-live=\"polite\"></div>\n\n<hr />\n\n<div>\n  <strong>Controls to explore states:</strong>\n  <div>\n    <button id=\"btnViewInput\">View Input Array</button>\n    <button id=\"btnViewCount\">View Count Array</button>\n    <button id=\"btnViewOutput\">View Output Array</button>\n  </div>\n  <div>\n    <label for=\"viewIndexInput\">Highlight element at index:</label>\n    <input type=\"number\" id=\"viewIndexInput\" min=\"0\" step=\"1\" />\n    <button id=\"btnHighlightIndex\">Highlight</button>\n    <button id=\"btnClearHighlight\">Clear Highlight</button>\n  </div>\n</div>\n\n<hr />\n<div>\n  <strong>Log / Explanation</strong>\n  <div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\" role=\"log\"></div>\n</div>\n\n<script>\n(function() {\n  'use strict';\n\n  // Data containers\n  let stateHistory = [];\n  let currentStepIndex = -1;\n  let autoRunnerId = null;\n\n  // State format:\n  // {\n  //  phase: \"init\"|\"counting\"|\"accumulating\"|\"place\"|\"finished\"\n  //  stepDetail: string\n  //  inputArray: [...]\n  //  countArray: [...]\n  //  outputArray: [...]\n  //  variables: object storing indices, values relevant to step\n  // }\n\n  // Elements references\n  const inputArrayInput = document.getElementById('inputArray');\n  const btnLoadArray = document.getElementById('btnLoadArray');\n  const btnRandomArray = document.getElementById('btnRandomArray');\n  const minValueInput = document.getElementById('minValue');\n  const maxValueInput = document.getElementById('maxValue');\n  const arraySizeInput = document.getElementById('arraySize');\n\n  const btnStartSort = document.getElementById('btnStartSort');\n  const btnStepForward = document.getElementById('btnStepForward');\n  const btnStepBackward = document.getElementById('btnStepBackward');\n  const btnRunToEnd = document.getElementById('btnRunToEnd');\n  const btnReset = document.getElementById('btnReset');\n\n  const speedRange = document.getElementById('speedRange');\n  const speedDisplay = document.getElementById('speedDisplay');\n  const btnToggleAuto = document.getElementById('btnToggleAuto');\n\n  const stepDesc = document.getElementById('stepDesc');\n  const inputArrayDisplay = document.getElementById('inputArrayDisplay');\n  const countArrayDisplay = document.getElementById('countArrayDisplay');\n  const outputArrayDisplay = document.getElementById('outputArrayDisplay');\n\n  const btnViewInput = document.getElementById('btnViewInput');\n  const btnViewCount = document.getElementById('btnViewCount');\n  const btnViewOutput = document.getElementById('btnViewOutput');\n  const viewIndexInput = document.getElementById('viewIndexInput');\n  const btnHighlightIndex = document.getElementById('btnHighlightIndex');\n  const btnClearHighlight = document.getElementById('btnClearHighlight');\n\n  const logArea = document.getElementById('log');\n\n  // Current \"view mode\" determines which array is displayed highlighted\n  //  \"input\" | \"count\" | \"output\"\n  let currentViewMode = \"input\";\n  // Highlight index, for display\n  let highlightIndex = null;\n\n  // State management and helper functions\n\n  // Parsing input array (returns null if invalid values)\n  function parseInputArray(text) {\n    // Split on comma or whitespace, ignoring empty parts\n    const parts = text.split(/[\\s,]+/).filter(p => p.length>0);\n    const vals = [];\n    for(let p of parts) {\n      if(!/^[-+]?\\d+$/.test(p)) {\n        return null;\n      }\n      vals.push(parseInt(p,10));\n    }\n    return vals;\n  }\n\n  // Clamp a number between min and max (if min>max return null)\n  function clampNum(n,min,max) {\n    if(min>max) return null;\n    if(n<min) return min;\n    if(n>max) return max;\n    return n;\n  }\n\n  // Log helper\n  function log(message) {\n    // Append message + newline\n    logArea.textContent += message + \"\\n\";\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  // Clear log\n  function clearLog() {\n    logArea.textContent = \"\";\n  }\n\n  // Display an array in the container - array parameter is array of numbers\n  // highlightIndex - index to highlight with bold/underline\n  // currentIndex - index with thicker border\n  // container is the container element to hold the array items\n  function displayArray(container, arr, highlightIndex=null, currentIndex=null) {\n    container.innerHTML = \"\";\n    if(!arr || arr.length === 0) {\n      container.textContent = \"(empty)\";\n      return;\n    }\n    for(let i=0; i<arr.length; i++) {\n      const div = document.createElement('div');\n      div.textContent = arr[i];\n      div.className = 'array-item';\n      div.setAttribute('data-index', i);\n      if(i === highlightIndex) div.classList.add('highlight');\n      if(i === currentIndex) div.classList.add('current');\n      container.appendChild(div);\n    }\n  }\n\n  // Show array view based on currentViewMode with highlightIndex if any\n  function showCurrentView() {\n    if(currentViewMode === \"input\") {\n      const state = stateHistory[currentStepIndex];\n      if(!state) {\n        inputArrayDisplay.innerHTML = \"(no input array)\";\n      } else {\n        displayArray(inputArrayDisplay, state.inputArray, highlightIndex, state.variables && state.variables.inputIndex);\n      }\n      countArrayDisplay.innerHTML = \"\";\n      outputArrayDisplay.innerHTML = \"\";\n    } else if(currentViewMode === \"count\") {\n      const state = stateHistory[currentStepIndex];\n      if(!state) {\n        countArrayDisplay.innerHTML = \"(no count array)\";\n      } else {\n        displayArray(countArrayDisplay, state.countArray, highlightIndex, state.variables && state.variables.countIndex);\n      }\n      inputArrayDisplay.innerHTML = \"\";\n      outputArrayDisplay.innerHTML = \"\";\n    } else if(currentViewMode === \"output\") {\n      const state = stateHistory[currentStepIndex];\n      if(!state) {\n        outputArrayDisplay.innerHTML = \"(no output array)\";\n      } else {\n        displayArray(outputArrayDisplay, state.outputArray, highlightIndex, state.variables && state.variables.outputIndex);\n      }\n      inputArrayDisplay.innerHTML = \"\";\n      countArrayDisplay.innerHTML = \"\";\n    }\n  }\n\n  // Disable or enable main controls based on active state\n  function updateControlState() {\n    const hasHistory = stateHistory.length > 0;\n    btnStartSort.disabled = hasHistory;\n    btnStepForward.disabled = !hasHistory || currentStepIndex >= stateHistory.length-1;\n    btnStepBackward.disabled = !hasHistory || currentStepIndex <= 0;\n    btnRunToEnd.disabled = !hasHistory || currentStepIndex >= stateHistory.length-1;\n    btnReset.disabled = !hasHistory;\n    btnToggleAuto.disabled = !hasHistory;\n    btnViewInput.disabled = !hasHistory;\n    btnViewCount.disabled = !hasHistory;\n    btnViewOutput.disabled = !hasHistory;\n    btnHighlightIndex.disabled = !hasHistory;\n    btnClearHighlight.disabled = !hasHistory;\n  }\n\n  // Validate min/max for counting sort\n  function validateMinMax() {\n    const minV = parseInt(minValueInput.value,10);\n    const maxV = parseInt(maxValueInput.value,10);\n    if(isNaN(minV) || isNaN(maxV) || minV > maxV) return false;\n    return true;\n  }\n\n  // Validate array size\n  function validateArraySize() {\n    const sizeV = parseInt(arraySizeInput.value,10);\n    if(isNaN(sizeV) || sizeV < 1 || sizeV > 10000) return false;\n    return true;\n  }\n\n  // Generate random array respecting range and size, returns array\n  function generateRandomArray(size, min, max) {\n    const arr = [];\n    for(let i=0; i<size; i++) {\n      arr.push(Math.floor(Math.random()*(max - min +1)) + min);\n    }\n    return arr;\n  }\n\n  // ##########################\n  // Counting Sort Algorithm and Step Generation\n  // ##########################\n  // We model the counting sort as a sequence of small-step states with descriptions.\n  // This allows very fine-grained stepping and exploring the internal arrays.\n\n  // We store all steps in stateHistory and move forward/backward on them.\n\n  // Counting sort steps overview:\n  // 1. Start - load input array, initialize count array to zeros\n  // 2. Counting phase - For each element in input array, increment count array bucket\n  // 3. Accumulating phase - For i in [1..count.length-1], accumulate counts into prefix sums\n  // 4. Output building phase - traverse input array backward, place elements to output array per count, decrement count\n  // 5. Finished\n\n  // We implement a step generator that from input array and min/max generates the full sequence of states.\n\n  // Helper to create deep copy\n  function deepCopy(obj) {\n    return JSON.parse(JSON.stringify(obj));\n  }\n\n  // Create base initial state with arrays initialized\n  function createInitialState(inputArray, minVal, maxVal) {\n    const countLength = maxVal - minVal +1;\n    const countArray = new Array(countLength).fill(0);\n    const outputArray = new Array(inputArray.length).fill(null);\n    return {\n      phase: \"init\",\n      stepDetail: \"Initial state before counting.\",\n      inputArray: inputArray.slice(),\n      countArray: countArray,\n      outputArray: outputArray,\n      variables: {\n        minVal: minVal,\n        maxVal: maxVal,\n        countLength: countLength,\n        inputIndex: -1,\n        countIndex: -1,\n        outputIndex: -1,\n        placeInputIndex: -1,\n        placeCountIndex: -1\n      }\n    };\n  }\n\n  // Generate all states step by step returns an array of states\n  function generateCountingSortStates(inputArray, minVal, maxVal) {\n    const states = [];\n    const countLength = maxVal - minVal +1;\n    const n = inputArray.length;\n    const countArray = new Array(countLength).fill(0);\n    const outputArray = new Array(n).fill(null);\n\n    let variables = {\n      minVal: minVal,\n      maxVal: maxVal,\n      countLength: countLength,\n      inputIndex: -1,\n      countIndex: -1,\n      outputIndex: -1,\n      placeInputIndex: -1,\n      placeCountIndex: -1\n    };\n\n    // Initial state\n    states.push({\n      phase: \"init\",\n      stepDetail: \"Initial state before counting. Count array initialized to zeros.\",\n      inputArray: inputArray.slice(),\n      countArray: countArray.slice(),\n      outputArray: outputArray.slice(),\n      variables: deepCopy(variables)\n    });\n\n    // 1. Counting phase: count occurrences\n    for(let i=0; i<n; i++) {\n      variables.inputIndex = i;\n      const val = inputArray[i];\n      const countPos = val - minVal;\n      variables.countIndex = countPos;\n      countArray[countPos]++;\n      states.push({\n        phase: \"counting\",\n        stepDetail: `Counting phase: processing input index ${i} (value ${val}). Increment countArray[${countPos}] to ${countArray[countPos]}.`,\n        inputArray: inputArray.slice(),\n        countArray: countArray.slice(),\n        outputArray: outputArray.slice(),\n        variables: deepCopy(variables)\n      });\n    }\n\n    // 2. Accumulating phase: prefix sums in count array\n    variables.inputIndex = -1;\n    variables.countIndex = 0;\n    for(let i=1; i<countLength; i++) {\n      variables.countIndex = i;\n      const oldVal = countArray[i];\n      countArray[i] = countArray[i] + countArray[i-1];\n      states.push({\n        phase: \"accumulating\",\n        stepDetail: `Accumulating phase: updating countArray[${i}] = countArray[${i}] (${oldVal}) + countArray[${i-1}] (${countArray[i-1]}) = ${countArray[i]}.`,\n        inputArray: inputArray.slice(),\n        countArray: countArray.slice(),\n        outputArray: outputArray.slice(),\n        variables: deepCopy(variables)\n      });\n    }\n    variables.countIndex = -1;\n\n    // 3. Output building phase:\n    // Traverse input array backwards placing elements correctly\n    for(let i=n-1; i>=0; i--) {\n      variables.placeInputIndex = i;\n      const val = inputArray[i];\n      const pos = val - minVal;\n      variables.placeCountIndex = pos;\n      // The index for placement in output is countArray[pos]-1\n      const placeIndex = countArray[pos] - 1;\n      variables.outputIndex = placeIndex;\n      outputArray[placeIndex] = val;\n      countArray[pos] = countArray[pos] - 1;\n\n      states.push({\n        phase: \"place\",\n        stepDetail: `Output building phase: placing input[${i}] = ${val} at output[${placeIndex}]. Decrement countArray[${pos}] to ${countArray[pos]}.`,\n        inputArray: inputArray.slice(),\n        countArray: countArray.slice(),\n        outputArray: outputArray.slice(),\n        variables: deepCopy(variables)\n      });\n    }\n    variables.placeInputIndex = -1;\n    variables.placeCountIndex = -1;\n    variables.outputIndex = -1;\n\n    // 4. Finished\n    states.push({\n      phase: \"finished\",\n      stepDetail: \"Counting sort completed successfully. Output array is sorted.\",\n      inputArray: inputArray.slice(),\n      countArray: countArray.slice(),\n      outputArray: outputArray.slice(),\n      variables: deepCopy(variables)\n    });\n\n    return states;\n  }\n\n\n  // Update the UI for current step index\n  function updateUIForCurrentStep() {\n    if(currentStepIndex < 0 || currentStepIndex >= stateHistory.length) {\n      stepDesc.textContent = \"No sorting steps available.\";\n      inputArrayDisplay.innerHTML = \"\";\n      countArrayDisplay.innerHTML = \"\";\n      outputArrayDisplay.innerHTML = \"\";\n      highlightIndex = null;\n      updateControlState();\n      return;\n    }\n    const state = stateHistory[currentStepIndex];\n    stepDesc.textContent = `[${currentStepIndex+1} / ${stateHistory.length}] ${state.stepDetail}`;\n\n    showCurrentView();\n\n    // Scroll log to bottom to see last message (already done in log)\n    updateControlState();\n  }\n\n  // Advance forward one step if possible\n  function stepForward() {\n    if(currentStepIndex < stateHistory.length-1) {\n      currentStepIndex++;\n      updateUIForCurrentStep();\n    }\n  }\n\n  // Step backward one step if possible\n  function stepBackward() {\n    if(currentStepIndex > 0) {\n      currentStepIndex--;\n      updateUIForCurrentStep();\n    }\n  }\n\n  // Reset everything\n  function resetAll() {\n    if(autoRunnerId) {\n      clearInterval(autoRunnerId);\n      autoRunnerId = null;\n      btnToggleAuto.textContent = \"Start Auto\";\n    }\n    stateHistory = [];\n    currentStepIndex = -1;\n    highlightIndex = null;\n    currentViewMode = \"input\";\n    clearLog();\n    inputArrayDisplay.innerHTML = \"\";\n    countArrayDisplay.innerHTML = \"\";\n    outputArrayDisplay.innerHTML = \"\";\n    stepDesc.textContent = \"Not started\";\n    updateControlState();\n  }\n\n  // Auto runner start/stop toggle\n  function toggleAutoRun() {\n    if(autoRunnerId) {\n      clearInterval(autoRunnerId);\n      autoRunnerId = null;\n      btnToggleAuto.textContent = \"Start Auto\";\n      btnStepForward.disabled = false;\n      btnStepBackward.disabled = false;\n      btnRunToEnd.disabled = false;\n      btnStartSort.disabled = true;\n    } else {\n      const delay = parseInt(speedRange.value, 10);\n      btnToggleAuto.textContent = \"Stop Auto\";\n      btnStepForward.disabled = true;\n      btnStepBackward.disabled = true;\n      btnRunToEnd.disabled = true;\n      btnStartSort.disabled = true;\n      autoRunnerId = setInterval(() => {\n        if(currentStepIndex >= stateHistory.length -1) {\n          clearInterval(autoRunnerId);\n          autoRunnerId = null;\n          btnToggleAuto.textContent = \"Start Auto\";\n          updateControlState();\n          return;\n        }\n        stepForward();\n      }, delay);\n    }\n  }\n\n  // Handle controls event listeners\n\n  btnLoadArray.addEventListener('click', () => {\n    resetAll();\n    clearLog();\n    const arr = parseInputArray(inputArrayInput.value);\n    if(arr === null) {\n      alert(\"Invalid array input. Use only integers separated by commas or spaces.\");\n      return;\n    }\n    // Validate min/max\n    if(!validateMinMax()) {\n      alert(\"Invalid minimum or maximum value inputs.\");\n      return;\n    }\n    const minV = parseInt(minValueInput.value, 10);\n    const maxV = parseInt(maxValueInput.value, 10);\n    // Check if all values within min/max range\n    for(let v of arr) {\n      if(v < minV || v > maxV) {\n        alert(`Array element ${v} is out of range [${minV}, ${maxV}].`);\n        return;\n      }\n    }\n    stateHistory = [];\n    currentStepIndex = -1;\n    highlightIndex = null;\n    currentViewMode = \"input\";\n    clearLog();\n    log(\"Loaded input array: \" + arr.join(\", \"));\n    displayArray(inputArrayDisplay, arr);\n    countArrayDisplay.innerHTML = \"\";\n    outputArrayDisplay.innerHTML = \"\";\n    stepDesc.textContent = \"Array loaded. Ready to start Counting Sort.\";\n    btnStartSort.disabled = false;\n    btnStepForward.disabled = true;\n    btnStepBackward.disabled = true;\n    btnRunToEnd.disabled = true;\n    btnReset.disabled = true;\n    btnToggleAuto.disabled = true;\n    btnViewInput.disabled = true;\n    btnViewCount.disabled = true;\n    btnViewOutput.disabled = true;\n    btnHighlightIndex.disabled = true;\n    btnClearHighlight.disabled = true;\n  });\n\n  btnRandomArray.addEventListener('click', () => {\n    resetAll();\n    clearLog();\n    if(!validateMinMax() || !validateArraySize()) {\n      alert(\"Invalid inputs for min, max, or array size.\");\n      return;\n    }\n    const minV = parseInt(minValueInput.value,10);\n    const maxV = parseInt(maxValueInput.value,10);\n    const sizeV = parseInt(arraySizeInput.value,10);\n    const arr = generateRandomArray(sizeV, minV, maxV);\n    inputArrayInput.value = arr.join(\", \");\n    stateHistory = [];\n    currentStepIndex = -1;\n    highlightIndex = null;\n    currentViewMode = \"input\";\n    clearLog();\n    log(\"Random array generated: \" + arr.join(\", \"));\n    displayArray(inputArrayDisplay, arr);\n    countArrayDisplay.innerHTML = \"\";\n    outputArrayDisplay.innerHTML = \"\";\n    stepDesc.textContent = \"Random array loaded. Ready to start Counting Sort.\";\n    btnStartSort.disabled = false;\n    btnStepForward.disabled = true;\n    btnStepBackward.disabled = true;\n    btnRunToEnd.disabled = true;\n    btnReset.disabled = true;\n    btnToggleAuto.disabled = true;\n    btnViewInput.disabled = true;\n    btnViewCount.disabled = true;\n    btnViewOutput.disabled = true;\n    btnHighlightIndex.disabled = true;\n    btnClearHighlight.disabled = true;\n  });\n\n  btnStartSort.addEventListener('click', () => {\n    clearLog();\n    const arr = parseInputArray(inputArrayInput.value);\n    if(arr === null) {\n      alert(\"Invalid array input before sorting.\");\n      return;\n    }\n    if(!validateMinMax()) {\n      alert(\"Invalid minimum or maximum value inputs.\");\n      return;\n    }\n    const minV = parseInt(minValueInput.value, 10);\n    const maxV = parseInt(maxValueInput.value, 10);\n    // Check if all values within min/max range\n    for(let v of arr) {\n      if(v < minV || v > maxV) {\n        alert(`Array element ${v} is out of range [${minV}, ${maxV}].`);\n        return;\n      }\n    }\n    stateHistory = generateCountingSortStates(arr, minV, maxV);\n    currentStepIndex = 0;\n    highlightIndex = null;\n    currentViewMode = \"input\";\n    log(\"Counting Sort started.\");\n    updateUIForCurrentStep();\n    btnStartSort.disabled = true;\n    btnReset.disabled = false;\n  });\n\n  btnStepForward.addEventListener('click', () => {\n    stepForward();\n  });\n\n  btnStepBackward.addEventListener('click', () => {\n    stepBackward();\n  });\n\n  btnRunToEnd.addEventListener('click', () => {\n    while(currentStepIndex < stateHistory.length-1) {\n      currentStepIndex++;\n    }\n    updateUIForCurrentStep();\n  });\n\n  btnReset.addEventListener('click', () => {\n    resetAll();\n    inputArrayDisplay.innerHTML = \"\";\n    countArrayDisplay.innerHTML = \"\";\n    outputArrayDisplay.innerHTML = \"\";\n    stepDesc.textContent = \"Reset done. Load or generate array.\";\n    inputArrayInput.value = \"\";\n    btnStartSort.disabled = true;\n  });\n\n  speedRange.addEventListener('input', () => {\n    speedDisplay.textContent = speedRange.value;\n    // If running auto adjust interval\n    if(autoRunnerId) {\n      clearInterval(autoRunnerId);\n      autoRunnerId = setInterval(() => {\n        if(currentStepIndex >= stateHistory.length -1) {\n          clearInterval(autoRunnerId);\n          autoRunnerId = null;\n          btnToggleAuto.textContent = \"Start Auto\";\n          updateControlState();\n          return;\n        }\n        stepForward();\n      }, parseInt(speedRange.value,10));\n    }\n  });\n\n  btnToggleAuto.addEventListener('click', () => {\n    toggleAutoRun();\n  });\n\n  // View mode controls and highlight\n\n  btnViewInput.addEventListener('click', () => {\n    currentViewMode = \"input\";\n    highlightIndex = null;\n    showCurrentView();\n  });\n  btnViewCount.addEventListener('click', () => {\n    currentViewMode = \"count\";\n    highlightIndex = null;\n    showCurrentView();\n  });\n  btnViewOutput.addEventListener('click', () => {\n    currentViewMode = \"output\";\n    highlightIndex = null;\n    showCurrentView();\n  });\n\n  btnHighlightIndex.addEventListener('click', () => {\n    const idx = Number(viewIndexInput.value);\n    if(isNaN(idx) || idx < 0) {\n      alert(\"Highlight index must be a non-negative integer.\");\n      return;\n    }\n    // Check bounds for current view\n    const state = stateHistory[currentStepIndex];\n    if(!state) {\n      alert(\"No sorting state loaded.\");\n      return;\n    }\n    let maxLen = 0;\n    if(currentViewMode === \"input\") maxLen = state.inputArray.length;\n    else if(currentViewMode === \"count\") maxLen = state.countArray.length;\n    else if(currentViewMode === \"output\") maxLen = state.outputArray.length;\n    else {\n      alert(\"Invalid view mode for highlight.\");\n      return;\n    }\n    if(idx >= maxLen) {\n      alert(`Highlight index out of bounds for current view (max index ${maxLen-1}).`);\n      return;\n    }\n    highlightIndex = idx;\n    showCurrentView();\n  });\n\n  btnClearHighlight.addEventListener('click', () => {\n    highlightIndex = null;\n    showCurrentView();\n  });\n\n  // Initial setup\n  resetAll();\n\n  // Accessibility notes:\n  // - aria-live for outputs ensures messages are read by screen readers.\n  // - inputs and buttons have labels.\n  // - monospace font and minimal styles to keep clarity.\n\n})();\n</script>\n</body>\n</html>"
  },
