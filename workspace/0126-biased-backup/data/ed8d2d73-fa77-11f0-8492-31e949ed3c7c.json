    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Suffix Tree Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            background: linear-gradient(to bottom right, #283c86, #45a247);\n            color: #ffffff;\n            margin: 0;\n            overflow: hidden;\n        }\n\n        header {\n            text-align: center;\n            padding: 20px;\n            background: rgba(0, 0, 0, 0.7);\n            box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);\n        }\n\n        h1 {\n            font-size: 3em;\n            margin: 0;\n        }\n\n        #canvas {\n            display: block;\n            margin: 0 auto;\n            width: 80%;\n            height: 70vh;\n            border: 5px solid rgba(255, 255, 255, 0.2);\n            border-radius: 15px;\n            background-color: rgba(0, 0, 0, 0.5);\n            box-shadow: 0 0 30px rgba(0, 255, 255, 0.3);\n            transition: transform 0.5s;\n        }\n\n        #canvas.hover {\n            transform: scale(1.05);\n        }\n\n        .buttons {\n            display: flex;\n            justify-content: center;\n            margin: 20px 0;\n        }\n\n        .button {\n            background-color: #45a247;\n            border: none;\n            color: white;\n            padding: 15px 30px;\n            font-size: 1.2em;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n            margin: 0 10px;\n        }\n\n        .button:hover {\n            background-color: #283c86;\n            box-shadow: 0 0 20px rgba(255, 255, 255, 0.5);\n        }\n\n        footer {\n            text-align: center;\n            padding: 20px;\n            font-size: 0.8em;\n            background: rgba(0, 0, 0, 0.7);\n            position: fixed;\n            bottom: 0;\n            width: 100%;\n        }\n    </style>\n</head>\n\n<body>\n    <header>\n        <h1>Suffix Tree Visualization</h1>\n        <p>Observe the beauty of suffix trees in action.</p>\n    </header>\n    \n    <canvas id=\"canvas\"></canvas>\n\n    <div class=\"buttons\">\n        <button class=\"button\" id=\"drawBtn\">Draw Suffix Tree</button>\n        <button class=\"button\" id=\"clearBtn\">Clear Canvas</button>\n    </div>\n\n    <footer>\n        &copy; 2023 Suffix Tree Visualization. All rights reserved.\n    </footer>\n\n    <script>\n        const canvas = document.getElementById('canvas');\n        const ctx = canvas.getContext('2d');\n\n        // Suffix Tree example for \"banana\"\n        const text = \"banana\";\n        const suffixes = [];\n        \n        for (let i = 0; i < text.length; i++) {\n            suffixes.push(text.slice(i));\n        }\n\n        const drawTree = () => {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            const radius = 20;\n            const startX = canvas.width / 2;\n            const startY = 50;\n\n            suffixes.forEach((suffix, i) => {\n                const posX = startX + (i * 40) - (suffixes.length * 20);\n                ctx.fillStyle = `hsl(${(i * 360) / suffixes.length}, 100%, 50%)`;\n                ctx.beginPath();\n                ctx.arc(posX, startY + 50, radius, 0, Math.PI * 2);\n                ctx.fill();\n\n                ctx.fillStyle = '#ffffff';\n                ctx.fillText(suffix, posX - 15, startY + 60);\n            });\n\n            // Show hover effect\n            canvas.classList.add('hover');\n            setTimeout(() => {\n                canvas.classList.remove('hover');\n            }, 500);\n        };\n\n        const clearCanvas = () => {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n        };\n\n        document.getElementById('drawBtn').onclick = drawTree;\n        document.getElementById('clearBtn').onclick = clearCanvas;\n    </script>\n</body>\n\n</html>"
