    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>PageRank Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .container { margin: 20px; }\n        .node { display: inline-block; width: 100px; text-align: center; padding: 5px; margin: 5px; border: 1px solid black; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive PageRank Demo</h1>\n        <div>\n            <label for=\"nodeCount\">Number of Nodes:</label>\n            <input type=\"number\" id=\"nodeCount\" value=\"5\" min=\"2\" max=\"20\">\n            <button id=\"createGraph\">Create Graph</button>\n        </div>\n        <div id=\"graphContainer\"></div>\n        <div>\n            <button id=\"calculatePageRank\">Calculate PageRank</button>\n        </div>\n        <h3>PageRank Values</h3>\n        <div id=\"pageRankResults\"></div>\n    </div>\n\n    <script>\n        let graph = [];\n        const graphContainer = document.getElementById('graphContainer');\n        const pageRankResults = document.getElementById('pageRankResults');\n\n        document.getElementById('createGraph').onclick = () => {\n            const nodeCount = parseInt(document.getElementById('nodeCount').value);\n            graph = Array.from({ length: nodeCount }, (_, i) => ({ id: i, links: [] }));\n            graphContainer.innerHTML = '';\n\n            for (let i = 0; i < nodeCount; i++) {\n                const nodeDiv = document.createElement('div');\n                nodeDiv.className = 'node';\n                nodeDiv.innerText = `Node ${i}`;\n                const linkInput = document.createElement('input');\n                linkInput.placeholder = 'Link to nodes (comma-sep)';\n                linkInput.onchange = () => {\n                    const links = linkInput.value.split(',').map(Number);\n                    graph[i].links = links.filter(link => link >= 0 && link < nodeCount);\n                };\n                nodeDiv.appendChild(linkInput);\n                graphContainer.appendChild(nodeDiv);\n            }\n        };\n\n        document.getElementById('calculatePageRank').onclick = () => {\n            const dampingFactor = 0.85;\n            const iterations = 100;\n            const pageRank = Array(graph.length).fill(1 / graph.length);\n            const N = graph.length;\n\n            for (let iter = 0; iter < iterations; iter++) {\n                const newPageRank = Array(N).fill(0);\n                for (const node of graph) {\n                    const numLinks = node.links.length;\n                    if (numLinks === 0) {\n                        continue;\n                    }\n                    const shareRank = pageRank[node.id] / numLinks;\n                    for (const link of node.links) {\n                        newPageRank[link] += shareRank;\n                    }\n                }\n                for (let i = 0; i < N; i++) {\n                    newPageRank[i] = (1 - dampingFactor) / N + dampingFactor * newPageRank[i];\n                }\n                for (let i = 0; i < N; i++) {\n                    pageRank[i] = newPageRank[i];\n                }\n            }\n\n            pageRankResults.innerHTML = pageRank.map((rank, index) => `Node ${index}: ${rank.toFixed(4)}`).join('<br>');\n        };\n    </script>\n</body>\n</html>"
  },
