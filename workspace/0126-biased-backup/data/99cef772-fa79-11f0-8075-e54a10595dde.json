    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interpolation Search Demo</title>\n</head>\n<body>\n    <h1>Interpolation Search Demo</h1>\n    \n    <label for=\"arrayInput\">Enter Sorted Array (comma separated):</label>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 10, 20, 30, 40, 50\" />\n    \n    <label for=\"searchInput\">Enter Value to Search:</label>\n    <input type=\"number\" id=\"searchInput\" placeholder=\"e.g. 30\" />\n    \n    <button id=\"searchButton\">Search</button>\n    <button id=\"clearButton\">Clear</button>\n    \n    <h2 id=\"result\"></h2>\n    \n    <script>\n        document.getElementById('searchButton').onclick = function() {\n            const arrayInput = document.getElementById('arrayInput').value;\n            const searchValue = parseInt(document.getElementById('searchInput').value);\n            const resultElement = document.getElementById('result');\n\n            if (!arrayInput) {\n                resultElement.innerText = \"Please enter a sorted array.\";\n                return;\n            }\n\n            const array = arrayInput.split(',').map(Number).sort((a, b) => a - b);\n            const index = interpolationSearch(array, searchValue);\n\n            if (index === -1) {\n                resultElement.innerText = `Value ${searchValue} not found.`;\n            } else {\n                resultElement.innerText = `Value ${searchValue} found at index ${index}.`;\n            }\n        };\n\n        document.getElementById('clearButton').onclick = function() {\n            document.getElementById('arrayInput').value = '';\n            document.getElementById('searchInput').value = '';\n            document.getElementById('result').innerText = '';\n        };\n\n        function interpolationSearch(arr, x) {\n            let low = 0;\n            let high = arr.length - 1;\n\n            while (low <= high && x >= arr[low] && x <= arr[high]) {\n                if (low === high) {\n                    return arr[low] === x ? low : -1;\n                }\n\n                const pos = low + Math.floor(((high - low) / (arr[high] - arr[low])) * (x - arr[low]));\n\n                if (arr[pos] === x) {\n                    return pos;\n                }\n\n                if (arr[pos] < x) {\n                    low = pos + 1;\n                } else {\n                    high = pos - 1;\n                }\n            }\n            return -1;\n        }\n    </script>\n</body>\n</html>"
