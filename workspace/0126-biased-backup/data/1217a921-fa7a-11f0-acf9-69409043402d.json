  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Overfitting Exploration</title>\n</head>\n<body>\n<h1>Overfitting Exploration Simulator</h1>\n\n<p>\nThis interactive tool demonstrates how underfitting, appropriate fitting, and overfitting appear on simple regression problems.\nYou can generate datasets, change noise levels, select model complexity, train models, and test generalization.\nUse the controls below to explore fitting behavior deeply.\n</p>\n\n<section>\n<h2>1. Data Generation</h2>\n<div>\n<label for=\"data-function\">Select true underlying function:</label>\n<select id=\"data-function\">\n<option value=\"sin\">y = sin(2πx)</option>\n<option value=\"quad\">y = 4x² - 2x + 1</option>\n<option value=\"linear\">y = 3x + 1</option>\n<option value=\"piecewise\">y = piecewise linear</option>\n</select>\n</div>\n\n<div>\n<label for=\"noise-level\">Noise standard deviation (sigma): </label>\n<input type=\"number\" id=\"noise-level\" min=\"0\" max=\"2\" step=\"0.01\" value=\"0.1\"/>\n</div>\n\n<div>\n<label for=\"num-points\">Number of data points: </label>\n<input type=\"number\" id=\"num-points\" min=\"5\" max=\"100\" step=\"1\" value=\"20\" />\n</div>\n\n<div>\n<button id=\"generate-data\">Generate Data</button>\n<span id=\"data-status\"></span>\n</div>\n</section>\n\n<hr/>\n\n<section>\n<h2>2. Model Selection</h2>\n\n<div>\n<label for=\"model-type\">Select model type:</label>\n<select id=\"model-type\">\n<option value=\"poly\">Polynomial Regression</option>\n<option value=\"knn\">k-Nearest Neighbors Regression</option>\n<option value=\"piecewise-linear\">Piecewise Linear Regression</option>\n<option value=\"moving-average\">Moving Average Regression</option>\n</select>\n</div>\n\n<div id=\"model-params\">\n<!-- populated dynamically -->\n</div>\n\n<div>\n<button id=\"train-model\" disabled>Train Model</button>\n<span id=\"train-status\"></span>\n</div>\n\n</section>\n\n<hr/>\n\n<section>\n<h2>3. Evaluation & Visualization</h2>\n\n<div>\n<label for=\"eval-range-from\">Evaluation range from:</label>\n<input type=\"number\" id=\"eval-range-from\" step=\"0.01\" value=\"0\" min=\"0\" max=\"1\"/>\n<label for=\"eval-range-to\">to:</label>\n<input type=\"number\" id=\"eval-range-to\" step=\"0.01\" value=\"1\" min=\"0\" max=\"1\"/>\n</div>\n\n<div>\n<label for=\"eval-points\">Number of points on evaluation grid:</label>\n<input type=\"number\" id=\"eval-points\" min=\"10\" max=\"1000\" step=\"10\" value=\"200\" />\n</div>\n\n<div>\n<button id=\"evaluate-model\" disabled>Evaluate Model</button>\n<span id=\"eval-status\"></span>\n</div>\n\n<div>\n<label><input type=\"checkbox\" id=\"show-true-function\" checked> Show True Function</label>\n<label><input type=\"checkbox\" id=\"show-noisy-data\" checked> Show Noisy Data Points</label>\n<label><input type=\"checkbox\" id=\"show-predictions\" checked> Show Model Predictions</label>\n</div>\n\n<div style=\"width: 640px; height: 400px; border: 1px solid black; margin-top: 10px;\">\n<canvas id=\"plot\" width=\"640\" height=\"400\" style=\"display: block;\"></canvas>\n</div>\n</section>\n\n<hr/>\n\n<section>\n<h2>4. Advanced Controls</h2>\n<p>Manipulate training data manually and retrain.</p>\n<button id=\"add-point\" disabled>Add Training Point</button>\n<button id=\"clear-data\" disabled>Clear Training Data</button>\n\n<div>\n<label for=\"manual-x\">X coordinate (0 to 1): </label><input type=\"number\" id=\"manual-x\" min=\"0\" max=\"1\" step=\"0.01\" value=\"0.5\" />\n<label for=\"manual-y\">Y coordinate: </label><input type=\"number\" id=\"manual-y\" step=\"0.01\" value=\"0\" />\n</div>\n\n<p>Data points can be removed by clicking on them in the plot once enabled below.</p>\n<label><input type=\"checkbox\" id=\"enable-point-removal\"> Enable point removal by clicking points</label>\n\n</section>\n\n<hr/>\n\n<section>\n<h2>5. Metrics and Diagnostics</h2>\n\n<div>\n<button id=\"compute-train-error\" disabled>Compute Training MSE</button>\n<span id=\"train-error\"></span>\n</div>\n\n<div>\n<button id=\"compute-val-error\" disabled>Compute Validation MSE</button>\n<span id=\"val-error\"></span>\n</div>\n\n<div>\n<button id=\"split-data\" disabled>Split Data into Training/Validation Sets</button>\n<label for=\"val-ratio\">Validation Ratio</label>\n<input type=\"number\" id=\"val-ratio\" min=\"0\" max=\"0.9\" step=\"0.05\" value=\"0.2\" />\n</div>\n\n<div>\n<p>Tip: Experiment with model complexity and noise to observe overfitting and underfitting.</p>\n</div>\n\n</section>\n\n<script>\n// ***********************\n// UTILITIES\n// ***********************\n\nfunction linspace(start, end, num) {\n  const arr = [];\n  if (num === 1) return [start];\n  const step = (end - start) / (num -1);\n  for(let i=0; i<num; i++) {\n    arr.push(start + step*i);\n  }\n  return arr;\n}\n\nfunction mean(arr) {\n  if(arr.length === 0) return 0;\n  return arr.reduce((a,b)=>a+b,0)/arr.length;\n}\n\nfunction mse(yTrue, yPred) {\n  if(yTrue.length !== yPred.length) throw new Error(\"Arrays have different lengths\");\n  let sum = 0;\n  for(let i=0; i<yTrue.length; i++) {\n    const diff = yTrue[i]-yPred[i];\n    sum+=diff*diff;\n  }\n  return sum/yTrue.length;\n}\n\nfunction randomChoice(arr) {\n  return arr[Math.floor(Math.random()*arr.length)];\n}\n\nfunction shuffleArray(array) {\n  for(let i=array.length -1; i>0; i--) {\n    const j = Math.floor(Math.random()*(i+1));\n    [array[i], array[j]] = [array[j], array[i]];\n  }\n  return array;\n}\n\n// ***********************\n// TRUE FUNCTIONS\n// ***********************\n\nfunction trueFunctionFactory(type) {\n  switch(type) {\n    case \"sin\":\n      // y = sin(2pi x), x in [0,1]\n      return (x) => Math.sin(2*Math.PI*x);\n    case \"quad\":\n      // y = 4x^2 - 2x + 1\n      return (x) => 4*x*x - 2*x + 1;\n    case \"linear\":\n      // y = 3x +1\n      return (x) => 3*x + 1;\n    case \"piecewise\":\n      // piecewise linear:\n      // [0,0.3]: y=2x\n      // (0.3,0.7]: y=1-x\n      // (0.7,1]: y=3x-2\n      return (x) => {\n        if(x<=0.3) return 2*x;\n        else if(x<=0.7) return 1 - x;\n        else return 3*x - 2;\n      };\n    default:\n      return (x) => 0;\n  }\n}\n\n\n// ***********************\n// DATA STORAGE & STATE\n// ***********************\n\nlet dataset = {\n  X: [], // inputs in [0,1]\n  Y: [], // noisy outputs\n  YTrue: [], // noiseless outputs\n  split: {train: [], val: []}, // indices of training and validation samples\n};\n\nlet noiseLevel = 0.1;\nlet trueFunctionType = \"sin\";\nlet trueFunction = trueFunctionFactory(trueFunctionType);\nlet modelType = \"poly\";\n\nlet modelParams = {}; // params adjusted dynamically by UI and read by functions\nlet trainedModel = null;\n\nlet evalPointsX = [];\nlet evalPointsYTrue = [];\nlet evalPointsYPred = [];\n\nlet valSplitRatio = 0.2;\n\nlet pointRemovalEnabled = false;\n\n// ***********************\n// DATA GENERATION\n// ***********************\n\nfunction generateData() {\n  noiseLevel = parseFloat(document.getElementById(\"noise-level\").value);\n  let n = parseInt(document.getElementById(\"num-points\").value);\n  if (n < 5) n = 5;\n  if (n > 100) n = 100;\n\n  trueFunctionType = document.getElementById(\"data-function\").value;\n  trueFunction = trueFunctionFactory(trueFunctionType);\n\n  // Generate uniform points in [0,1]\n  let X = [];\n  let attempts = 0;\n  while(X.length < n && attempts < n*10) {\n    // generate random points in [0,1]\n    const x = Math.random();\n    X.push(x);\n    attempts++;\n  }\n  X.sort((a,b)=>a-b);\n  \n  // Compute noiseless and noisy Y\n  let YTrue = X.map(trueFunction);\n  let Y = YTrue.map(y => y + (noiseLevel>0 ? randNormal(0, noiseLevel) : 0));\n\n  dataset.X = X;\n  dataset.YTrue = YTrue;\n  dataset.Y = Y;\n\n  // Reset splits\n  dataset.split.train = [...Array(n).keys()];\n  dataset.split.val = [];\n\n  trainedModel = null;\n  evalPointsX = [];\n  evalPointsYTrue = [];\n  evalPointsYPred = [];\n\n  updateTrainingStatus(\"Data generated with \" + n + \" points.\");\n  document.getElementById(\"train-model\").disabled = false;\n  document.getElementById(\"evaluate-model\").disabled = true;\n  document.getElementById(\"compute-train-error\").disabled = true;\n  document.getElementById(\"compute-val-error\").disabled = true;\n  document.getElementById(\"split-data\").disabled = false;\n  document.getElementById(\"add-point\").disabled = false;\n  document.getElementById(\"clear-data\").disabled = false;\n  drawPlot();\n}\n\n// Normal random variable using Box-Muller transform\nfunction randNormal(mu=0, sigma=1){\n  let u1 = 0, u2=0;\n  // Convert [0,1) to (0,1)\n  while(u1 === 0) u1 = Math.random();\n  while(u2 === 0) u2 = Math.random();\n  let z0 = Math.sqrt(-2.0 * Math.log(u1)) * Math.cos(2.0*Math.PI*u2);\n  return z0 * sigma + mu;\n}\n\n\n// ***********************\n// MODEL PARAMETER UI\n// ***********************\n\nfunction updateModelParamsUI() {\n  const container = document.getElementById(\"model-params\");\n  container.innerHTML = \"\";\n  modelType = document.getElementById(\"model-type\").value;\n  modelParams = {};\n\n  if(modelType === \"poly\") {\n    // degree slider 0 to 20\n    const label = document.createElement(\"label\");\n    label.textContent = \"Degree (polynomial degree): \";\n    label.setAttribute(\"for\",\"poly-degree\");\n    const input = document.createElement(\"input\");\n    input.type = \"number\";\n    input.id = \"poly-degree\";\n    input.min = \"0\";\n    input.max = \"20\";\n    input.value = \"3\";\n    input.step = \"1\";\n    input.addEventListener(\"change\", ()=>{\n      modelParams.degree = parseInt(input.value);\n      trainedModel = null;\n      updateTrainingStatus(\"\");\n      document.getElementById(\"evaluate-model\").disabled = true;\n    });\n    label.appendChild(input);\n    container.appendChild(label);\n    modelParams.degree = 3;\n  }\n  else if(modelType === \"knn\"){\n    // k slider 1 to dataset size or max 20\n    // max 20 to keep calc reasonable\n    const label = document.createElement(\"label\");\n    label.textContent = \"k (number of neighbors): \";\n    label.setAttribute(\"for\",\"knn-k\");\n    const input = document.createElement(\"input\");\n    input.type = \"number\";\n    input.id = \"knn-k\";\n    input.min = \"1\";\n    input.max = \"20\";\n    input.value = \"3\";\n    input.step = \"1\";\n    input.addEventListener(\"change\", ()=>{\n      let val = parseInt(input.value);\n      if(val < 1) val = 1;\n      if(val > 20) val = 20;\n      input.value = val;\n      modelParams.k = val;\n      trainedModel = null;\n      updateTrainingStatus(\"\");\n      document.getElementById(\"evaluate-model\").disabled = true;\n    });\n    label.appendChild(input);\n    container.appendChild(label);\n    modelParams.k = 3;\n  }\n  else if(modelType === \"piecewise-linear\"){\n    // number of pieces (breakpoints between 1 to 10)\n    const label = document.createElement(\"label\");\n    label.textContent = \"Number of pieces: \";\n    label.setAttribute(\"for\",\"pw-pieces\");\n    const input = document.createElement(\"input\");\n    input.type = \"number\";\n    input.id = \"pw-pieces\";\n    input.min = \"1\";\n    input.max = \"10\";\n    input.value = \"3\";\n    input.step = \"1\";\n    input.addEventListener(\"change\", ()=>{\n      let val = parseInt(input.value);\n      if(val < 1) val=1;\n      if(val >10) val=10;\n      input.value = val;\n      modelParams.pieces = val;\n      trainedModel = null;\n      updateTrainingStatus(\"\");\n      document.getElementById(\"evaluate-model\").disabled = true;\n    });\n    label.appendChild(input);\n    container.appendChild(label);\n    modelParams.pieces = 3;\n  }\n  else if(modelType === \"moving-average\"){\n    // Window size 1 to 20\n    const label = document.createElement(\"label\");\n    label.textContent = \"Window size: \";\n    label.setAttribute(\"for\",\"ma-window\");\n    const input = document.createElement(\"input\");\n    input.type = \"number\";\n    input.id = \"ma-window\";\n    input.min = \"1\";\n    input.max = \"20\";\n    input.value = \"3\";\n    input.step = \"1\";\n    input.addEventListener(\"change\", ()=>{\n      let val = parseInt(input.value);\n      if(val<1) val=1;\n      if(val>20) val=20;\n      input.value = val;\n      modelParams.window = val;\n      trainedModel = null;\n      updateTrainingStatus(\"\");\n      document.getElementById(\"evaluate-model\").disabled = true;\n    });\n    label.appendChild(input);\n    container.appendChild(label);\n    modelParams.window = 3;\n  }\n  document.getElementById(\"train-model\").disabled = false;\n  document.getElementById(\"evaluate-model\").disabled = true;\n}\n\ndocument.getElementById(\"model-type\").addEventListener(\"change\", updateModelParamsUI);\n\nupdateModelParamsUI();\n\n\n// ***********************\n// MODEL TRAINING\n// ***********************\n\n/**\n * Trains the selected model on current training data subset.\n * Stores the trained model in trainedModel variable.\n * Supported models:\n *  - Polynomial regression (least squares)\n *  - k-NN regression (lazy, no training step needed but prepare sorted dataset)\n *  - Piecewise linear regression (break domain into equal intervals, fit line on each segment)\n *  - Moving average regression (simple smoothing, no training needed)\n */\n\nfunction trainModel() {\n  if(dataset.X.length === 0) {\n    updateTrainingStatus(\"No data to train on.\");\n    return;\n  }\n  \n  // Select training indices from split, or full dataset if none\n  const trainIdx = dataset.split.train.length > 0 ? dataset.split.train : [...Array(dataset.X.length).keys()];\n\n  if(trainIdx.length === 0) {\n    updateTrainingStatus(\"Training set is empty. Please split data or add points.\");\n    return;\n  }\n\n  const Xtrain = trainIdx.map(i => dataset.X[i]);\n  const Ytrain = trainIdx.map(i => dataset.Y[i]);\n\n  modelType = document.getElementById(\"model-type\").value;\n\n  if(modelType === \"poly\") {\n    // Polynomial regression\n    // Build Vandermonde matrix, solve least squares\n    const degree = modelParams.degree || 3;\n    // Design matrix\n    let A = [];\n    for(let i=0; i<Xtrain.length; i++){\n      let row = [];\n      for(let d=0; d<=degree; d++) {\n        row.push(Math.pow(Xtrain[i], d));\n      }\n      A.push(row);\n    }\n\n    // Least squares: solve (A^T A) w = A^T y\n    // Compute AtA (deg+1 x deg+1)\n    let AtA = [];\n    for(let j=0; j<=degree; j++){\n      AtA[j] = [];\n      for(let k=0; k<=degree; k++){\n        let s=0;\n        for(let i=0; i<Xtrain.length; i++) {\n          s+= A[i][j] * A[i][k];\n        }\n        AtA[j][k] = s;\n      }\n    }\n    // Compute A^T y (deg+1)\n    let Aty = [];\n    for(let j=0; j<=degree; j++) {\n      let s=0;\n      for(let i=0; i<Xtrain.length; i++) {\n        s += A[i][j]*Ytrain[i];\n      }\n      Aty[j] = s;\n    }\n\n    // Solve linear system AtA * w = Aty by Gaussian elimination (simple)\n    // Deep copy AtA\n    let M = JSON.parse(JSON.stringify(AtA));\n    let b = Aty.slice();\n\n    let n = degree+1;\n\n    // Forward elimination\n    for(let i=0; i<n; i++) {\n      // Partial pivot\n      let maxRow = i;\n      for(let r=i+1; r<n; r++) {\n        if(Math.abs(M[r][i]) > Math.abs(M[maxRow][i])) maxRow = r;\n      }\n      if(maxRow !== i) {\n        let tmp = M[i]; M[i]=M[maxRow]; M[maxRow]=tmp;\n        let tmpb = b[i]; b[i] = b[maxRow]; b[maxRow] = tmpb;\n      }\n      // Singular or near singular check\n      if(Math.abs(M[i][i]) < 1e-12) {\n        updateTrainingStatus(\"Polynomial regression failed: matrix singular.\");\n        trainedModel = null;\n        document.getElementById(\"evaluate-model\").disabled = true;\n        return;\n      }\n      // Eliminate below\n      for(let r=i+1; r<n; r++) {\n        let f = M[r][i]/M[i][i];\n        for(let c=i; c<n; c++) {\n          M[r][c] -= f*M[i][c];\n        }\n        b[r] -= f*b[i];\n      }\n    }\n    // Back substitution\n    let w = new Array(n).fill(0);\n    for(let i=n-1; i>=0; i--) {\n      let sum =0;\n      for(let j=i+1; j<n; j++) {\n        sum += M[i][j]*w[j];\n      }\n      w[i] = (b[i]-sum)/M[i][i];\n    }\n\n    trainedModel = {type:\"poly\", degree:degree, weights:w};\n\n  }\n  else if(modelType === \"knn\") {\n    // kNN regression: Store train data sorted according to X (for fast window selection)\n    const k = modelParams.k || 3;\n    // clamp k if needed\n    let kclamped = Math.min(k, Xtrain.length);\n    kclamped = Math.max(1,kclamped);\n\n    // Sort training data by X\n    let pairs = Xtrain.map((x,i) => ({x:x, y:Ytrain[i]}));\n    pairs.sort((a,b) => a.x - b.x);\n\n    trainedModel = {type:\"knn\", k:kclamped, data: pairs, N:pairs.length};\n  }\n  else if(modelType === \"piecewise-linear\") {\n    // Break domain [0,1] into equal segments: pieces equal intervals\n    let pieces = modelParams.pieces || 3;\n    pieces = Math.min(pieces, dataset.X.length);\n    pieces = Math.max(1, pieces);\n\n    // Sort training data by X\n    let pairs = [];\n    for(let i=0; i<Xtrain.length; i++) pairs.push({x:Xtrain[i], y:Ytrain[i]});\n    pairs.sort((a,b)=>a.x-b.x);\n\n    // Determine breakpoints: equal length intervals over [0,1]\n    let breaks = linspace(0,1,pieces+1);\n\n    // For each piece, find training points inside range and fit linear regression\n    let coeffs = []; // [{a,b}] linear function y = a*x + b, per piece\n\n    for(let i=0; i<pieces; i++) {\n      let xs_in_piece = pairs.filter(p => p.x >= breaks[i] && p.x <= breaks[i+1]).map(p=>p.x);\n      let ys_in_piece = pairs.filter(p => p.x >= breaks[i] && p.x <= breaks[i+1]).map(p=>p.y);\n\n      if(xs_in_piece.length == 0){\n        // no data in piece, fallback to average y=0\n        coeffs.push({a:0,b:0});\n        continue;\n      }\n      else if(xs_in_piece.length == 1){\n        // only one point: constant function = y of the point\n        coeffs.push({a:0,b:ys_in_piece[0]});\n        continue;\n      }\n\n      // Fit linear regression y = a x + b on points in this piece\n      let xs = xs_in_piece;\n      let ys = ys_in_piece;\n      const n = xs.length;\n      let meanX = mean(xs);\n      let meanY = mean(ys);\n      let denom=0; let numer=0;\n      for(let j=0; j<n; j++){\n        denom += (xs[j] - meanX)*(xs[j] - meanX);\n        numer += (xs[j] - meanX)*(ys[j] - meanY);\n      }\n      let a= denom ===0 ? 0 : numer/denom;\n      let b= meanY - a*meanX;\n      coeffs.push({a:a, b:b});\n    }\n\n    trainedModel = {type:\"piecewise-linear\", breaks: breaks, coeffs: coeffs};\n  }\n  else if(modelType === \"moving-average\") {\n    // Moving average smoothing on sorted training data Y (X sorted too)\n    let w = modelParams.window || 3;\n    w = Math.max(1,w);\n    w = Math.min(w, dataset.X.length);\n\n    // Sort training data by X\n    let pairs = [];\n    for(let i=0; i<Xtrain.length; i++) pairs.push({x:Xtrain[i], y:Ytrain[i]});\n    pairs.sort((a,b)=>a.x-b.x);\n\n    // Store data and window size\n    trainedModel = {type:\"moving-average\", data:pairs, window:w};\n  }\n  else {\n    updateTrainingStatus(\"Unknown model type.\");\n    trainedModel = null;\n    document.getElementById(\"evaluate-model\").disabled = true;\n    return;\n  }\n\n  updateTrainingStatus(\"Model trained: \" + modelTypeDescription());\n  document.getElementById(\"evaluate-model\").disabled = false;\n  document.getElementById(\"compute-train-error\").disabled = false;\n\n}\n\nfunction modelTypeDescription() {\n  if(!trainedModel) return \"(none)\";\n  switch(trainedModel.type){\n    case \"poly\": return \"Polynomial regression degree \" + trainedModel.degree;\n    case \"knn\": return \"k-NN regression k=\" + trainedModel.k;\n    case \"piecewise-linear\": return \"Piecewise linear regression with \"+(trainedModel.coeffs.length) + \" pieces\";\n    case \"moving-average\": return \"Moving average regression window size \" + trainedModel.window;\n    default: return \"unknown model\";\n  }\n}\n\ndocument.getElementById(\"train-model\").addEventListener(\"click\", trainModel);\n\n\n// ***********************\n// MODEL PREDICTION\n// ***********************\n\n/**\n * Predict function values for input array xs.\n * Returns array of predicted ys.\n * returns null if no model trained\n */\nfunction predict(xs) {\n  if(!trainedModel) return null;\n\n  let ys = [];\n\n  switch(trainedModel.type) {\n    case \"poly\":\n      // Evaluate polynomial sum w_i x^i\n      let w = trainedModel.weights;\n      for(let i=0; i<xs.length; i++) {\n        let x = xs[i];\n        let y=0;\n        for(let d=0; d<=trainedModel.degree; d++) {\n          y += w[d]*Math.pow(x,d);\n        }\n        ys.push(y);\n      }\n      break;\n\n    case \"knn\":\n      // For each x: find k nearest training points by x coordinate, average their y\n      let data = trainedModel.data; // sorted by x\n      let k = trainedModel.k;\n\n      // Binary search helper for index\n      function findInsertionIndex(arr,x){\n        let left=0; let right=arr.length;\n        while(left<right){\n          let mid = Math.floor((left+right)/2);\n          if(arr[mid].x < x) left=mid+1;\n          else right=mid;\n        }\n        return left;\n      }\n\n      for(let i=0; i<xs.length; i++){\n        let x = xs[i];\n        if(data.length === 0) {\n          ys.push(0);\n          continue;\n        }\n        // Find closest idx to x\n        let idx = findInsertionIndex(data, x);\n        let candidates = [];\n\n        // Collect candidates to left and right so we can pick closest k\n        let leftIdx = idx-1;\n        let rightIdx = idx;\n        while(candidates.length < k){\n          let leftDist = (leftIdx >=0) ? Math.abs(x - data[leftIdx].x) : Number.MAX_SAFE_INTEGER;\n          let rightDist = (rightIdx < data.length) ? Math.abs(x - data[rightIdx].x) : Number.MAX_SAFE_INTEGER;\n\n          if(leftDist<=rightDist && leftIdx >=0) {\n            candidates.push(data[leftIdx]);\n            leftIdx--;\n          }\n          else if(rightIdx < data.length) {\n            candidates.push(data[rightIdx]);\n            rightIdx++;\n          }\n          else {\n            // no more points\n            break;\n          }\n        }\n\n        if(candidates.length===0) ys.push(0);\n        else {\n          let avg = candidates.reduce((acc,c)=>acc+c.y,0)/candidates.length;\n          ys.push(avg);\n        }\n      }\n      break;\n\n    case \"piecewise-linear\":\n      // For each x find which piece:\n      // y = a*x + b for piece containing x\n      let breaks = trainedModel.breaks;\n      let coeffs = trainedModel.coeffs;\n      for(let i=0; i<xs.length; i++){\n        let x = xs[i];\n        // Clamp x to [0,1]\n        if(x < 0) x=0;\n        if(x > 1) x=1;\n        // Find piece index\n        let pieceIdx = 0;\n        for(let j=0; j<breaks.length-1; j++){\n          if(x >= breaks[j] && x <= breaks[j+1]){\n            pieceIdx = j;\n            break;\n          }\n        }\n        let a = coeffs[pieceIdx].a;\n        let b = coeffs[pieceIdx].b;\n        ys.push(a*x + b);\n      }\n      break;\n\n    case \"moving-average\":\n      // Approximate predicted y by moving average smoothing of training data y, at x.\n      // We do weighted average of training points y with weights depending on closeness in x\n      // Simpler: find window-size nearest points and average their y.\n      let d = trainedModel.data;\n      let wsize = trainedModel.window;\n\n      // Binary search helper\n      function findIdx(x){\n        let left=0, right=d.length;\n        while(left<right){\n          let mid = Math.floor((left+right)/2);\n          if(d[mid].x < x) left=mid+1;\n          else right=mid;\n        }\n        return left;\n      }\n\n      for(let i=0; i<xs.length; i++) {\n        let x = xs[i];\n        if(d.length === 0) {\n          ys.push(0);\n          continue;\n        }\n        let idx = findIdx(x);\n\n        // Gather wsize nearest by distance in x\n        let leftIdx = idx-1;\n        let rightIdx = idx;\n        let candidates = [];\n\n        while(candidates.length < wsize){\n          let leftDist = (leftIdx >=0) ? Math.abs(x - d[leftIdx].x) : Number.MAX_SAFE_INTEGER;\n          let rightDist = (rightIdx < d.length) ? Math.abs(x - d[rightIdx].x) : Number.MAX_SAFE_INTEGER;\n\n          if(leftDist <= rightDist && leftIdx >=0) {\n            candidates.push(d[leftIdx]);\n            leftIdx--;\n          }\n          else if(rightIdx < d.length){\n            candidates.push(d[rightIdx]);\n            rightIdx++;\n          }\n          else break;\n        }\n        if(candidates.length ===0) {\n          ys.push(0);\n        }\n        else {\n          // Uniform average\n          let avg = candidates.reduce((acc,c)=>acc+c.y,0)/candidates.length;\n          ys.push(avg);\n        }\n      }\n      break;\n\n    default:\n      return null;\n  }\n\n\n  return ys;\n}\n\n\n// ***********************\n// EVALUATE MODEL ON GRID\n// ***********************\n\nfunction evaluateModel() {\n  if(!trainedModel) {\n    updateEvalStatus(\"No model trained.\");\n    return;\n  }\n\n  let from = parseFloat(document.getElementById(\"eval-range-from\").value);\n  let to = parseFloat(document.getElementById(\"eval-range-to\").value);\n  if(from > to){\n    // swap\n    let tmp = from; from=to; to=tmp;\n  }\n  if(from < 0) from = 0;\n  if(to > 1) to = 1;\n\n  let pts = parseInt(document.getElementById(\"eval-points\").value);\n  if(pts < 10) pts = 10;\n  if(pts > 1000) pts = 1000;\n\n  evalPointsX = linspace(from, to, pts);\n  evalPointsYTrue = evalPointsX.map(trueFunction);\n  evalPointsYPred = predict(evalPointsX) || [];\n\n  if(evalPointsYPred.length === 0){\n    updateEvalStatus(\"Model prediction failed.\");\n    return;\n  }\n\n  updateEvalStatus(\"Model evaluated on grid.\");\n  drawPlot();\n}\n\n// ***********************\n// PLOT DRAWING\n// ***********************\n\nconst canvas = document.getElementById(\"plot\");\nconst ctx = canvas.getContext(\"2d\");\nconst WIDTH = canvas.width;\nconst HEIGHT = canvas.height;\nconst MARGIN = 40;\n\nfunction drawPlot() {\n  // Clear\n  ctx.clearRect(0, 0, WIDTH, HEIGHT);\n\n  // Draw axes\n  ctx.beginPath();\n  ctx.moveTo(MARGIN, MARGIN);\n  ctx.lineTo(MARGIN, HEIGHT - MARGIN);\n  ctx.lineTo(WIDTH - MARGIN, HEIGHT - MARGIN);\n  ctx.stroke();\n\n  // Labels\n  ctx.textAlign = \"center\";\n  ctx.textBaseline = \"middle\";\n  ctx.fillText(\"x\", WIDTH/2, HEIGHT - MARGIN/2);\n  ctx.fillText(\"y\", MARGIN/2, HEIGHT/2);\n\n  // Determine y range\n  // from dataset + eval points\n  let ys = [];\n\n  if(document.getElementById(\"show-true-function\").checked){\n    ys = ys.concat(evalPointsYTrue);\n  }\n  if(document.getElementById(\"show-predictions\").checked){\n    ys = ys.concat(evalPointsYPred);\n  }\n  if(document.getElementById(\"show-noisy-data\").checked){\n    ys = ys.concat(dataset.Y);\n  }\n  if(dataset.split.val.length > 0){\n    ys = ys.concat(dataset.split.val.map(i=>dataset.Y[i])); // val data shown by default as noisy\n  }\n  if(dataset.split.train.length > 0){\n    ys = ys.concat(dataset.split.train.map(i=>dataset.Y[i]));\n  }\n  if(ys.length === 0) ys = [0];\n\n  let yMin = Math.min(...ys);\n  let yMax = Math.max(...ys);\n\n  // Add padding\n  let yRange = yMax - yMin;\n  if(yRange === 0) yRange = 1;\n  yMin = yMin - 0.1*yRange;\n  yMax = yMax + 0.1*yRange;\n\n  // Helper to map x,y to canvas coords\n  function px(x) {\n    return MARGIN + (WIDTH - 2*MARGIN)* (x - 0)/(1 - 0);\n  }\n  function py(y) {\n    return HEIGHT - MARGIN - (HEIGHT - 2*MARGIN) * (y - yMin)/(yMax - yMin);\n  }\n\n  // Draw true function if checked\n  if(document.getElementById(\"show-true-function\").checked && evalPointsX.length>1){\n    ctx.beginPath();\n    ctx.lineWidth = 1;\n    for(let i=0; i<evalPointsX.length; i++){\n      let cx = px(evalPointsX[i]);\n      let cy = py(evalPointsYTrue[i]);\n      if(i===0) ctx.moveTo(cx, cy);\n      else ctx.lineTo(cx, cy);\n    }\n    ctx.stroke();\n  }\n\n  // Draw model predictions if checked\n  if(document.getElementById(\"show-predictions\").checked && evalPointsX.length>1){\n    ctx.beginPath();\n    ctx.lineWidth = 1;\n    for(let i=0; i<evalPointsX.length; i++){\n      let cx = px(evalPointsX[i]);\n      let cy = py(evalPointsYPred[i]);\n      if(i===0) ctx.moveTo(cx, cy);\n      else ctx.lineTo(cx, cy);\n    }\n    ctx.stroke();\n  }\n\n  // Draw noisy data points if checked\n  if(document.getElementById(\"show-noisy-data\").checked){\n    // Show all points\n    for(let i=0; i<dataset.X.length; i++){\n      let x=dataset.X[i];\n      let y=dataset.Y[i];\n      let cx = px(x);\n      let cy = py(y);\n\n      // Draw circle for training or validation with different radius\n      let radius = 5;\n      if(dataset.split.train.includes(i)) radius = 5;\n      else if(dataset.split.val.includes(i)) radius = 7;\n\n      ctx.beginPath();\n      ctx.arc(cx, cy, radius, 0, 2*Math.PI);\n      if(dataset.split.val.includes(i)){\n        ctx.stroke();\n      } else {\n        ctx.fill();\n      }\n    }\n  }\n\n  // Highlight points hovered / for removal if enabled\n  if(pointRemovalEnabled) {\n    // Draw instructions text top-left\n    ctx.fillStyle = \"black\";\n    ctx.font = \"12px monospace\";\n    ctx.fillText(\"Click points to remove training data.\", MARGIN, MARGIN/2);\n  }\n}\n\n// ***********************\n// EVENTS ON DATA GENERATION\n// ***********************\n\ndocument.getElementById(\"generate-data\").addEventListener(\"click\", generateData);\n\n\n// ***********************\n// EVENTS ON EVAL BUTTON\n// ***********************\n\ndocument.getElementById(\"evaluate-model\").addEventListener(\"click\", evaluateModel);\n\n// ***********************\n// TRAINING STATUS UPDATE\n// ***********************\n\nfunction updateTrainingStatus(msg) {\n  document.getElementById(\"train-status\").textContent = msg;\n}\n\nfunction updateEvalStatus(msg) {\n  document.getElementById(\"eval-status\").textContent = msg;\n}\n\n// ***********************\n// ADD POINT MANUALLY\n// ***********************\n\ndocument.getElementById(\"add-point\").addEventListener(\"click\", ()=>{\n  let x = parseFloat(document.getElementById(\"manual-x\").value);\n  let y = parseFloat(document.getElementById(\"manual-y\").value);\n\n  if(isNaN(x) || isNaN(y)) return;\n  if(x < 0) x = 0;\n  if(x > 1) x = 1;\n\n  dataset.X.push(x);\n  dataset.Y.push(y);\n  // Add true y as NaN - unknown for manual point - treat as noisy\n  dataset.YTrue.push(NaN);\n\n  // Add to training set\n  dataset.split.train.push(dataset.X.length - 1);\n\n  // Sort data arrays by X ascending\n  let zipped = dataset.X.map((v,i)=> ({x:v,y:dataset.Y[i], yTrue: dataset.YTrue[i]}));\n  zipped.sort((a,b)=> a.x - b.x);\n  dataset.X = zipped.map(p=>p.x);\n  dataset.Y = zipped.map(p=>p.y);\n  dataset.YTrue = zipped.map(p=>p.yTrue);\n\n  // Update splits indices for new dataset order\n  // The training set now is all points except those in val set already which is not changed\n  // We'll rebuild train and val respecting val set elements\n  let newTrain = [];\n  let newVal = [];\n  for(let i=0; i<dataset.X.length; i++){\n    let origIdx = dataset.split.train.concat(dataset.split.val).map(idx=>{\n      return {orig: idx, val: dataset.X[idx]};\n    });\n  }\n  // We can't really track old indices after sort easily. So simplest:\n  // Let validation set remain indices as references to pre-sort data - but that no longer matches.\n  // We'll clear validation set for safety to avoid bugs.\n  dataset.split.val = [];\n  dataset.split.train = [...Array(dataset.X.length).keys()];\n\n  trainedModel = null;\n  updateTrainingStatus(\"Added point (\" + x.toFixed(3) + \", \" + y.toFixed(3) + \"); model invalidated.\");\n  document.getElementById(\"train-model\").disabled = false;\n  document.getElementById(\"evaluate-model\").disabled = true;\n  document.getElementById(\"compute-train-error\").disabled = true;\n  document.getElementById(\"compute-val-error\").disabled = true;\n  drawPlot();\n});\n\ndocument.getElementById(\"clear-data\").addEventListener(\"click\", ()=>{\n  dataset.X = [];\n  dataset.Y = [];\n  dataset.YTrue = [];\n  dataset.split.train = [];\n  dataset.split.val = [];\n  trainedModel = null;\n  evalPointsX = [];\n  evalPointsYTrue = [];\n  evalPointsYPred = [];\n  updateTrainingStatus(\"Dataset cleared.\");\n  document.getElementById(\"train-model\").disabled = true;\n  document.getElementById(\"evaluate-model\").disabled = true;\n  document.getElementById(\"compute-train-error\").disabled = true;\n  document.getElementById(\"compute-val-error\").disabled = true;\n  document.getElementById(\"split-data\").disabled = true;\n  document.getElementById(\"add-point\").disabled = true;\n  document.getElementById(\"clear-data\").disabled = true;\n  drawPlot();\n});\n\n// ***********************\n// DATA SPLITTING\n// ***********************\n\ndocument.getElementById(\"split-data\").addEventListener(\"click\", ()=>{\n  let ratio = parseFloat(document.getElementById(\"val-ratio\").value);\n  if(ratio < 0) ratio = 0;\n  if(ratio > 0.9) ratio = 0.9;\n  valSplitRatio = ratio;\n\n  const n = dataset.X.length;\n  let indices = [...Array(n).keys()];\n  indices = shuffleArray(indices);\n\n  const nVal = Math.floor(n*valSplitRatio);\n  dataset.split.val = indices.slice(0,nVal);\n  dataset.split.train = indices.slice(nVal);\n\n  trainedModel = null;\n  updateTrainingStatus(\"Data split into train (\"+dataset.split.train.length+\") and validation (\"+dataset.split.val.length+\")\");\n  document.getElementById(\"train-model\").disabled = dataset.split.train.length === 0;\n  document.getElementById(\"evaluate-model\").disabled = true;\n  document.getElementById(\"compute-train-error\").disabled = true;\n  document.getElementById(\"compute-val-error\").disabled = true;\n  drawPlot();\n});\n\n\n// ***********************\n// ERROR COMPUTATION\n// ***********************\n\ndocument.getElementById(\"compute-train-error\").addEventListener(\"click\", () => {\n  if(!trainedModel) {\n    document.getElementById(\"train-error\").textContent = \"No trained model.\";\n    return;\n  }\n  if(dataset.split.train.length===0){\n    document.getElementById(\"train-error\").textContent = \"Training set empty.\";\n    return;\n  }\n  let Xtrain = dataset.split.train.map(i=>dataset.X[i]);\n  let Ytrain = dataset.split.train.map(i=>dataset.Y[i]);\n  let Ypred = predict(Xtrain);\n  if(!Ypred){\n    document.getElementById(\"train-error\").textContent = \"Model prediction failed.\";\n    return;\n  }\n  let err = mse(Ytrain, Ypred);\n  document.getElementById(\"train-error\").textContent = \"Training MSE: \" + err.toFixed(5);\n});\n\ndocument.getElementById(\"compute-val-error\").addEventListener(\"click\", () => {\n  if(!trainedModel) {\n    document.getElementById(\"val-error\").textContent = \"No trained model.\";\n    return;\n  }\n  if(dataset.split.val.length===0){\n    document.getElementById(\"val-error\").textContent = \"Validation set empty or no split.\";\n    return;\n  }\n  let Xval = dataset.split.val.map(i=>dataset.X[i]);\n  let Yval = dataset.split.val.map(i=>dataset.Y[i]);\n  let Ypred = predict(Xval);\n  if(!Ypred){\n    document.getElementById(\"val-error\").textContent = \"Model prediction failed.\";\n    return;\n  }\n  let err = mse(Yval, Ypred);\n  document.getElementById(\"val-error\").textContent = \"Validation MSE: \" + err.toFixed(5);\n});\n\n// Enable val error button only if val set exists and model trained\ndocument.getElementById(\"compute-val-error\").disabled = true;\n\nfunction updateValErrorButton() {\n  let enabled = (dataset.split.val.length>0) && (trainedModel !== null);\n  document.getElementById(\"compute-val-error\").disabled = !enabled;\n}\n[\"split-data\", \"train-model\"].forEach(id=>{\n  document.getElementById(id).addEventListener(\"click\", ()=> {\n    updateValErrorButton();\n  });\n});\ndocument.getElementById(\"compute-val-error\").addEventListener(\"click\", ()=>{});\n\n// ***********************\n// POINT REMOVAL\n// ***********************\n\ndocument.getElementById(\"enable-point-removal\").addEventListener(\"change\", function(){\n  pointRemovalEnabled = this.checked;\n  if(pointRemovalEnabled){\n    canvas.style.cursor = \"crosshair\";\n  } else {\n    canvas.style.cursor = \"default\";\n  }\n  drawPlot();\n});\n\ncanvas.addEventListener(\"click\", function(evt){\n  if(!pointRemovalEnabled) return;\n  if(dataset.X.length === 0) return;\n  // Map mouse click to data coordinates\n  const rect = canvas.getBoundingClientRect();\n  const mx = evt.clientX - rect.left;\n  const my = evt.clientY - rect.top;\n\n  // helper for coord mapping\n  // Need yMin, yMax used by drawPlot for conversion\n  let ys = [];\n\n  if(document.getElementById(\"show-true-function\").checked){\n    ys = ys.concat(evalPointsYTrue);\n  }\n  if(document.getElementById(\"show-predictions\").checked){\n    ys = ys.concat(evalPointsYPred);\n  }\n  if(document.getElementById(\"show-noisy-data\").checked){\n    ys = ys.concat(dataset.Y);\n  }\n  if(dataset.split.val.length > 0){\n    ys = ys.concat(dataset.split.val.map(i=>dataset.Y[i]));\n  }\n  if(dataset.split.train.length > 0){\n    ys = ys.concat(dataset.split.train.map(i=>dataset.Y[i]));\n  }\n  if(ys.length === 0) ys = [0];\n\n  let yMin = Math.min(...ys);\n  let yMax = Math.max(...ys);\n  let yRange = yMax - yMin;\n  if(yRange === 0) yRange=1;\n  yMin = yMin - 0.1*yRange;\n  yMax = yMax + 0.1*yRange;\n\n  function px_inv(px) {\n    return (px - MARGIN)/(WIDTH - 2*MARGIN);\n  }\n  function py_inv(py) {\n    return yMax - (py - MARGIN) * (yMax - yMin) / (HEIGHT - 2*MARGIN);\n  }\n\n  let xClicked = (mx - MARGIN)/(WIDTH - 2*MARGIN);\n  let yClicked = yMax - (my - MARGIN)*(yMax - yMin)/(HEIGHT - 2*MARGIN);\n\n  // Find closest point within radius in pixels\n  let radiusPixels = 8;\n  let foundIdx = -1;\n  let minDist = 1e9;\n\n  for(let i=0; i<dataset.X.length; i++){\n    // Only allow removal of training points, not validation points (for safety)\n    if(!dataset.split.train.includes(i)) continue;\n\n    let cx = MARGIN + (WIDTH - 2*MARGIN)*dataset.X[i];\n    let cy = HEIGHT - MARGIN - (HEIGHT - 2*MARGIN)*(dataset.Y[i] - yMin)/(yMax - yMin);\n\n    let dist = Math.sqrt((cx - mx)*(cx - mx) + (cy - my)*(cy - my));\n    if(dist < radiusPixels && dist < minDist){\n      minDist = dist;\n      foundIdx = i;\n    }\n  }\n\n  if(foundIdx >= 0){\n    // Remove point foundIdx from dataset and update splits\n    dataset.X.splice(foundIdx, 1);\n    dataset.Y.splice(foundIdx, 1);\n    dataset.YTrue.splice(foundIdx,1);\n\n    // Remove from train\n    let trainSet = dataset.split.train.filter(i => i !== foundIdx);\n    // Decrement indices greater than foundIdx (due to removal)\n    trainSet = trainSet.map(i => i > foundIdx ? i -1 : i);\n\n    // Update val indices similarly\n    let valSet = dataset.split.val.filter(i => i !== foundIdx);\n    valSet = valSet.map(i => i > foundIdx ? i -1 : i);\n\n    dataset.split.train = trainSet;\n    dataset.split.val = valSet;\n\n    // Model now invalid\n    trainedModel = null;\n    updateTrainingStatus(\"Removed training point at index \" + foundIdx + \", retrain model.\");\n    document.getElementById(\"train-model\").disabled = false;\n    document.getElementById(\"evaluate-model\").disabled = true;\n    document.getElementById(\"compute-train-error\").disabled = true;\n    document.getElementById(\"compute-val-error\").disabled = true;\n    drawPlot();\n  }\n});\n\n// ***********************\n// INITIAL DRAW\n// ***********************\n\ndrawPlot();\n\n</script>\n\n</body>\n</html>"
