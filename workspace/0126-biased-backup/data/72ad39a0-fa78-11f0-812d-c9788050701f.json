    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Type System | A Visual Exploration</title>\n    <style>\n        :root {\n            --primary: #2a3f5f;\n            --secondary: #4f6d9a;\n            --accent: #f05454;\n            --light: #f5f7fa;\n            --dark: #1a2639;\n            --transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n            background: linear-gradient(135deg, var(--light), #e0e5ec);\n            color: var(--dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        @font-face {\n            font-family: 'Inter';\n            src: url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 5rem;\n            animation: fadeIn 1.5s ease-out;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            font-weight: 700;\n            color: var(--primary);\n            margin-bottom: 1rem;\n            letter-spacing: -0.05em;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n        }\n\n        .subtitle {\n            font-size: 1.25rem;\n            color: var(--secondary);\n            font-weight: 300;\n            max-width: 700px;\n            margin: 0 auto;\n            line-height: 1.6;\n        }\n\n        .types-container {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 3rem;\n            margin-top: 4rem;\n        }\n\n        .type-card {\n            background: white;\n            border-radius: 1.5rem;\n            padding: 2.5rem;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);\n            transition: var(--transition);\n            position: relative;\n            overflow: hidden;\n            z-index: 1;\n        }\n\n        .type-card:hover {\n            transform: translateY(-10px);\n            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);\n        }\n\n        .type-card::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 8px;\n            background: linear-gradient(to right, var(--primary), var(--accent));\n        }\n\n        .type-title {\n            font-size: 1.8rem;\n            color: var(--primary);\n            margin-bottom: 1.5rem;\n            font-weight: 600;\n        }\n\n        .type-description {\n            color: var(--secondary);\n            line-height: 1.7;\n            margin-bottom: 2rem;\n        }\n\n        .type-example {\n            background: rgba(74, 108, 175, 0.05);\n            padding: 1.2rem;\n            border-radius: 0.75rem;\n            font-family: 'Menlo', monospace;\n            font-size: 0.9rem;\n            overflow-x: auto;\n            margin-bottom: 1.5rem;\n        }\n\n        .example-title {\n            display: block;\n            margin-bottom: 0.5rem;\n            font-weight: 600;\n            color: var(--accent);\n            font-size: 0.85rem;\n            text-transform: uppercase;\n            letter-spacing: 0.1em;\n        }\n\n        .visualization {\n            height: 200px;\n            background: linear-gradient(135deg, rgba(255,255,255,0.2), rgba(255,255,255,0.4));\n            border-radius: 0.75rem;\n            margin: 2rem 0;\n            position: relative;\n            overflow: hidden;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .visualization svg {\n            width: 80%;\n            height: 80%;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            margin-top: 4rem;\n        }\n\n        .toggle-btn {\n            background: var(--primary);\n            color: white;\n            border: none;\n            padding: 1rem 2rem;\n            border-radius: 0.5rem;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: var(--transition);\n            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);\n            font-weight: 500;\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .toggle-btn:hover {\n            background: var(--secondary);\n            transform: translateY(-2px);\n            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);\n        }\n\n        .toggle-btn svg {\n            width: 18px;\n            height: 18px;\n            fill: currentColor;\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 6rem;\n            color: var(--secondary);\n            font-size: 0.9rem;\n            animation: fadeIn 2s ease-out;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; transform: translateY(20px); }\n            to { opacity: 1; transform: translateY(0); }\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-10px); }\n        }\n\n        /* Dynamic visualization styles */\n        .type-visual {\n            position: relative;\n            width: 100%;\n            height: 100%;\n        }\n\n        .type-node {\n            position: absolute;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            font-size: 0.8rem;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);\n            transition: all 0.5s ease;\n        }\n\n        .type-connection {\n            position: absolute;\n            height: 2px;\n            background: rgba(255, 255, 255, 0.3);\n            transform-origin: left center;\n        }\n\n        /* Animation states */\n        .type-card:nth-child(1) .visualization {\n            background: linear-gradient(135deg, rgba(42, 63, 95, 0.05), rgba(42, 63, 95, 0.1));\n        }\n\n        .type-card:nth-child(2) .visualization {\n            background: linear-gradient(135deg, rgba(240, 84, 84, 0.05), rgba(240, 84, 84, 0.1));\n        }\n\n        .type-card:nth-child(3) .visualization {\n            background: linear-gradient(135deg, rgba(79, 109, 154, 0.05), rgba(79, 109, 154, 0.1));\n        }\n\n        .active .type-node {\n            animation: float 3s ease-in-out infinite;\n        }\n\n        .active .type-node:nth-child(1) { animation-delay: 0s; }\n        .active .type-node:nth-child(2) { animation-delay: 0.5s; }\n        .active .type-node:nth-child(3) { animation-delay: 1s; }\n        .active .type-node:nth-child(4) { animation-delay: 1.5s; }\n        .active .type-node:nth-child(5) { animation-delay: 2s; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <header>\n            <h1>Type System</h1>\n            <p class=\"subtitle\">A visual exploration of how programming languages classify and manipulate data through static and dynamic typing paradigms.</p>\n        </header>\n\n        <div class=\"types-container\">\n            <!-- Static Typing Card -->\n            <div class=\"type-card\">\n                <h2 class=\"type-title\">Static Typing</h2>\n                <p class=\"type-description\">Types are checked at compile-time. Variables must be declared with their type before use, and type mismatches are caught early in development.</p>\n                \n                <div class=\"type-example\">\n                    <span class=\"example-title\">Example (TypeScript)</span>\n                    let message: string = \"Hello\";\n                    <br>message = 42; // Error: Type 'number' is not assignable to type 'string'\n                </div>\n\n                <div class=\"visualization\">\n                    <div class=\"type-visual\" id=\"static-visual\">\n                        <div class=\"type-node\" style=\"width: 60px; height: 60px; background: #2a3f5f; top: 30%; left: 20%;\">String</div>\n                        <div class=\"type-node\" style=\"width: 50px; height: 50px; background: #4f6d9a; top: 60%; left: 70%;\">Number</div>\n                        <div class=\"type-node\" style=\"width: 70px; height: 70px; background: #f05454; top: 20%; left: 65%;\">Boolean</div>\n                        <div class=\"type-connection\" style=\"width: 150px; transform: rotate(-20deg); top: 40%; left: 25%;\"></div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Dynamic Typing Card -->\n            <div class=\"type-card\">\n                <h2 class=\"type-title\">Dynamic Typing</h2>\n                <p class=\"type-description\">Types are checked at runtime. Variables can hold values of any type, and type checking occurs as the program executes.</p>\n                \n                <div class=\"type-example\">\n                    <span class=\"example-title\">Example (Python)</span>\n                    message = \"Hello\"  # This works\n                    <br>message = 42    # This also works\n                </div>\n\n                <div class=\"visualization\">\n                    <div class=\"type-visual\" id=\"dynamic-visual\">\n                        <div class=\"type-node\" style=\"width: 80px; height: 80px; background: #f05454; top: 50%; left: 50%; transform: translate(-50%, -50%);\">Any</div>\n                        <div class=\"type-node\" style=\"width: 50px; height: 50px; background: #4f6d9a; top: 30%; left: 30%;\">42</div>\n                        <div class=\"type-node\" style=\"width: 50px; height: 50px; background: #2a3f5f; top: 30%; left: 70%;\">\"Hello\"</div>\n                        <div class=\"type-node\" style=\"width: 50px; height: 50px; background: #4f6d9a; top: 70%; left: 30%;\">true</div>\n                        <div class=\"type-node\" style=\"width: 50px; height: 50px; background: #2a3f5f; top: 70%; left: 70%;\">[1,2,3]</div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Type Inference Card -->\n            <div class=\"type-card\">\n                <h2 class=\"type-title\">Type Inference</h2>\n                <p class=\"type-description\">The compiler automatically deduces the type of an expression, reducing the need for explicit type annotations while maintaining type safety.</p>\n                \n                <div class=\"type-example\">\n                    <span class=\"example-title\">Example (Swift)</span>\n                    let message = \"Hello\" // Compiler infers String\n                    <br>let count = 42    // Compiler infers Int\n                </div>\n\n                <div class=\"visualization\">\n                    <div class=\"type-visual\" id=\"inference-visual\">\n                        <div class=\"type-node\" style=\"width: 70px; height: 70px; background: #4f6d9a; top: 50%; left: 35%;\">\"Hello\"</div>\n                        <div class=\"type-node\" style=\"width: 70px; height: 70px; background: #f05454; top: 50%; left: 65%;\">42</div>\n                        <div class=\"type-connection\" style=\"width: 80px; transform: rotate(0deg); top: 60%; left: 45%;\"></div>\n                        <div class=\"type-node\" style=\"width: 90px; height: 90px; background: #2a3f5f; top: 20%; left: 50%; transform: translateX(-50%);\">String</div>\n                        <div class=\"type-node\" style=\"width: 90px; height: 90px; background: #2a3f5f; top: 80%; left: 50%; transform: translateX(-50%);\">Int</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button class=\"toggle-btn\" id=\"animate-btn\">\n                <svg viewBox=\"0 0 24 24\">\n                    <path d=\"M12,16A2,2 0 0,1 14,18A2,2 0 0,1 12,20A2,2 0 0,1 10,18A2,2 0 0,1 12,16M12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12A2,2 0 0,1 12,10M12,4A2,2 0 0,1 14,6A2,2 0 0,1 12,8A2,2 0 0,1 10,6A2,2 0 0,1 12,4Z\"/>\n                </svg>\n                Toggle Animations\n            </button>\n        </div>\n\n        <footer>\n            <p>© 2023 Type System Visualization | Designed for aesthetic education</p>\n        </footer>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const animateBtn = document.getElementById('animate-btn');\n            const visualizations = document.querySelectorAll('.type-visual');\n\n            // Set initial animations\n            visualizations.forEach(vis => vis.classList.add('active'));\n\n            // Toggle animation on button click\n            animateBtn.addEventListener('click', function() {\n                visualizations.forEach(vis => {\n                    vis.classList.toggle('active');\n                });\n                \n                // Update button text\n                const isActive = document.querySelector('.type-visual.active');\n                animateBtn.innerHTML = isActive ? \n                    `<svg viewBox=\"0 0 24 24\"><path d=\"M12,16A2,2 0 0,1 14,18A2,2 0 0,1 12,20A2,2 0 0,1 10,18A2,2 0 0,1 12,16M12,10A2,2 0 0,1 14,12A2,2 0 0,1 12,14A2,2 0 0,1 10,12A2,2 0 0,1 12,10M12,4A2,2 0 0,1 14,6A2,2 0 0,1 12,8A2,2 0 0,1 10,6A2,2 0 0,1 12,4Z\"/></svg> Toggle Animations` : \n                    `<svg viewBox=\"0 0 24 24\"><path d=\"M12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z\"/></svg> Toggle Animations`;\n            });\n\n            // Create floating effect for type nodes\n            function createFloatingEffect() {\n                const nodes = document.querySelectorAll('.type-node');\n                nodes.forEach(node => {\n                    const duration = Math.random() * 3 + 2;\n                    const delay = Math.random() * 2;\n                    node.style.animation = `float ${duration}s ease-in-out ${delay}s infinite`;\n                });\n            }\n\n            createFloatingEffect();\n        });\n    </script>\n</body>\n</html>"
