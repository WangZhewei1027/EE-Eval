    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Runtime Environment — Visualized</title>\n<style>\n  /* RESET */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  html, body {\n    margin: 0; padding: 0;\n    height: 100%;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    color: #e0e6f3;\n    font-family: 'Inter', -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen,\n      Ubuntu, Cantarell, \"Open Sans\", \"Helvetica Neue\", sans-serif;\n    overflow-x: hidden;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n  \n  /* Container */\n  .container {\n    max-width: 1024px;\n    margin: 3rem auto 5rem;\n    padding: 0 1.5rem;\n    user-select: none;\n  }\n  \n  /* Heading */\n  h1 {\n    font-weight: 900;\n    font-size: 3.8rem;\n    letter-spacing: -0.02em;\n    text-align: center;\n    background: linear-gradient(90deg, #b9f3fc, #00aaff, #185a9d);\n    background-clip: text;\n    -webkit-background-clip: text;\n    color: transparent;\n    margin-bottom: 0.25rem;\n    filter: drop-shadow(0 0 6px rgba(0, 170, 255, 0.9));\n  }\n  h2 {\n    text-align: center;\n    font-weight: 600;\n    font-size: 1.4rem;\n    color: #a6bcd5;\n    margin-bottom: 4rem;\n    letter-spacing: 0.1em;\n  }\n  \n  /* Visualization Canvas */\n  .env-visualizer {\n    position: relative;\n    width: 100%;\n    max-width: 900px;\n    height: 520px;\n    margin: 0 auto 5rem;\n    background: #112f48;\n    border-radius: 28px;\n    box-shadow:\n      0 4px 30px rgba(0,120,255,0.35),\n      inset 0 0 48px rgb(24 90 157 / 0.9);\n    overflow: visible;\n  }\n  /* Glow and reflection layers */\n  .env-visualizer::before {\n    content: \"\";\n    position: absolute;\n    top: -14px; left: -14px; right: -14px; bottom: -14px;\n    border-radius: 32px;\n    background:\n      linear-gradient(135deg, #35aee0, #2c8ac7, #2c5364, #0f2027);\n    filter: blur(12px);\n    opacity: 0.5;\n    z-index: 0;\n    pointer-events: none;\n  }\n  .env-visualizer::after {\n    content: \"\";\n    position: absolute;\n    top: 60px; left: 48px;\n    width: 60%;\n    height: 240px;\n    background:\n      radial-gradient(ellipse at center, rgba(0,170,255,0.2), transparent 68%);\n    filter: blur(42px);\n    pointer-events: none;\n    z-index: 0;\n  }\n  \n  /* Layers and nodes */\n  .layer {\n    position: absolute;\n    left: 50%;\n    transform: translateX(-50%);\n    background: linear-gradient(145deg, #0c2133, #143e61);\n    border-radius: 20px;\n    box-shadow:\n      0 4px 15px rgba(0,120,255,0.3),\n      inset 0 0 12px rgba(0,170,255,0.35);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 2rem 1.75rem 2.5rem;\n    width: 260px;\n    color: #a5c8e7cc;\n    font-weight: 600;\n    font-size: 1.03rem;\n    letter-spacing: 0.04em;\n    user-select: none;\n    z-index: 4;\n    cursor: default;\n    transition: box-shadow 0.35s ease;\n  }\n  .layer:hover {\n    box-shadow:\n      0 0 35px #00aaffcc,\n      inset 0 0 22px #00aaff;\n    color: #c0e1ffdd;\n  }\n  \n  /* Layer vertical positioning */\n  .layer.environment {\n    top: 30px;\n  }\n  .layer.process {\n    top: 210px;\n  }\n  .layer.runtime {\n    top: 390px;\n  }\n  \n  /* Layer titles */\n  .layer .title {\n    font-size: 1.25rem;\n    color: #44baff;\n    margin-bottom: 1.1rem;\n    text-shadow: 0 0 8px #44baffbb;\n  }\n  \n  /* Node list inside each layer */\n  .node-list {\n    list-style: none;\n    margin: 0; padding: 0;\n    width: 100%;\n  }\n  .node-list li {\n    position: relative;\n    padding-left: 28px;\n    margin-bottom: 0.85rem;\n    line-height: 1.3;\n    color: #a8c3ddcc;\n    font-weight: 500;\n    user-select: text;\n  }\n  .node-list li::before {\n    content: \"\";\n    position: absolute;\n    left: 8px; top: 8px;\n    width: 12px; height: 12px;\n    background: linear-gradient(135deg, #00b0ff, #005eaa);\n    box-shadow:\n      0 0 6px #00b0ffaa,\n      inset 0 0 4px #74c9ff;\n    border-radius: 50%;\n  }\n  \n  /* SVG Connectors container */\n  .connectors {\n    position: absolute;\n    top: 0; left: 0; right: 0; bottom: 0;\n    pointer-events: none;\n    z-index: 2;\n  }\n  \n  /* Animated glowing lines between layers */\n  .glow-line {\n    stroke: url(#lineGradient);\n    stroke-width: 3;\n    fill: none;\n    filter: drop-shadow(0 0 6px #009effaa);\n    paint-order: stroke;\n    stroke-linecap: round;\n    animation: pulseLine 3.6s ease-in-out infinite;\n  }\n  \n  /* Highlight lines when toggled */\n  .glow-line.highlight {\n    stroke-width: 5;\n    filter: drop-shadow(0 0 15px #00d4ffcc);\n    animation: pulseLineHighlight 2.4s ease-in-out infinite;\n  }\n  \n  @keyframes pulseLine {\n    0%, 100% {\n      stroke-opacity: 0.55;\n      stroke-dashoffset: 0;\n    }\n    50% {\n      stroke-opacity: 1;\n      stroke-dashoffset: 12;\n    }\n  }\n  @keyframes pulseLineHighlight {\n    0%, 100% {\n      stroke-opacity: 0.9;\n      stroke-dashoffset: 0;\n    }\n    50% {\n      stroke-opacity: 1;\n      stroke-dashoffset: 24;\n    }\n  }\n  \n  /* Buttons container */\n  .btn-container {\n    display: flex;\n    justify-content: center;\n    gap: 1.25rem;\n    margin-top: -2rem;\n    margin-bottom: 2.5rem;\n    user-select: none;\n  }\n  \n  /* Buttons */\n  button {\n    cursor: pointer;\n    background: linear-gradient(145deg, #004c81, #007ffc);\n    color: #d6eaff;\n    border: none;\n    border-radius: 28px;\n    padding: 0.72rem 2.2rem;\n    font-weight: 700;\n    font-family: 'Inter', sans-serif;\n    font-size: 1.04rem;\n    text-transform: uppercase;\n    letter-spacing: 0.12em;\n    box-shadow:\n      0 6px 12px #007fffdd,\n      inset 0 -3px 4px #005a9ecc;\n    transition:\n      background-color 0.28s ease,\n      box-shadow 0.28s ease,\n      filter 0.28s ease;\n    filter: drop-shadow(0 0 6px #009aff80);\n    user-select: none;\n  }\n  button:hover {\n    background: linear-gradient(145deg, #00aaff, #00d4ff);\n    box-shadow:\n      0 8px 25px #00d4ffee,\n      inset 0 -3px 10px #00baffcc;\n    filter: drop-shadow(0 0 11px #00d4ffcc);\n  }\n  button:active {\n    background: linear-gradient(145deg, #0089cc, #009fee);\n    box-shadow:\n      0 4px 10px #0089cccc,\n      inset 0 -2px 6px #0077ccaa;\n    filter: drop-shadow(0 0 7px #0089ccdd);\n    transform: translateY(1px);\n  }\n  \n  /* Description text */\n  .description {\n    max-width: 720px;\n    margin: 0 auto 4rem;\n    font-weight: 500;\n    font-size: 1.14rem;\n    line-height: 1.58;\n    letter-spacing: 0.02em;\n    color: #a8bed8dd;\n    text-align: center;\n    user-select: text;\n  }\n  \n  /* Footer */\n  footer {\n    text-align: center;\n    font-size: 0.88rem;\n    color: #5490c8aa;\n    margin-bottom: 3rem;\n  }\n  \n  /* Responsive */\n  @media (max-width: 720px) {\n    .env-visualizer {\n      height: 660px;\n    }\n    .layer {\n      left: 50% !important;\n      width: 90vw;\n      padding: 1.75rem 1.25rem 2rem;\n    }\n    .layer.environment { top: 15px;}\n    .layer.process { top: 250px;}\n    .layer.runtime { top: 510px;}\n  }\n</style>\n</head>\n<body>\n  <main class=\"container\" role=\"main\" aria-label=\"Runtime Environment Visualization\">\n    <h1>Runtime Environment</h1>\n    <h2>Where Code Meets Life</h2>\n    <p class=\"description\">\n      The runtime environment acts as the invisible stage where programs meet resources, \n      system services, and memory — silently orchestrating code execution, ensuring all parts \n      connect and interact harmoniously.\n    </p>\n\n    <section aria-label=\"Runtime environment layers and visualization\" style=\"position:relative;\">\n      <div class=\"env-visualizer\" aria-hidden=\"true\">\n        <!-- Layers -->\n        <article class=\"layer environment\" aria-label=\"Environment Layer\">\n          <div class=\"title\">Environment</div>\n          <ul class=\"node-list\">\n            <li>Operating System</li>\n            <li>Environment Variables</li>\n            <li>File System</li>\n            <li>Hardware Interfaces</li>\n            <li>Libraries & SDKs</li>\n          </ul>\n        </article>\n        <article class=\"layer process\" aria-label=\"Process Layer\">\n          <div class=\"title\">Process</div>\n          <ul class=\"node-list\">\n            <li>Program & Threads</li>\n            <li>Memory & Stack</li>\n            <li>Process Scheduler</li>\n            <li>Inter-process Communication</li>\n            <li>Runtime APIs</li>\n          </ul>\n        </article>\n        <article class=\"layer runtime\" aria-label=\"Runtime Layer\">\n          <div class=\"title\">Runtime</div>\n          <ul class=\"node-list\">\n            <li>Bytecode Interpreter</li>\n            <li>JIT Compiler</li>\n            <li>Garbage Collector</li>\n            <li>Exception Handler</li>\n            <li>Runtime Heap</li>\n          </ul>\n        </article>\n\n        <!-- SVG Connectors -->\n        <svg class=\"connectors\" viewBox=\"0 0 900 520\" preserveAspectRatio=\"none\" aria-hidden=\"true\" focusable=\"false\">\n          <defs>\n            <linearGradient id=\"lineGradient\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#00b0ff\" />\n              <stop offset=\"100%\" stop-color=\"#005eaa\" />\n            </linearGradient>\n          </defs>\n          <path id=\"env-to-proc\" class=\"glow-line\" d=\"M 450 130 Q 450 170 450 210\" />\n          <path id=\"proc-to-runtime\" class=\"glow-line\" d=\"M 450 330 Q 450 370 450 410\" />\n          <circle cx=\"450\" cy=\"210\" r=\"9\" fill=\"#00aaff\" filter=\"url(#glow)\" />\n          <circle cx=\"450\" cy=\"410\" r=\"9\" fill=\"#00aaff\" filter=\"url(#glow)\" />\n        </svg>\n      </div>\n\n      <div class=\"btn-container\" aria-label=\"Controls\">\n        <button id=\"btnToggleAnim\" aria-pressed=\"true\" aria-label=\"Toggle line animation\">\n          Pause Animation\n        </button>\n      </div>\n    </section>\n\n    <footer>\n      Crafted with care by AI &ndash; Visualizing the heartbeat of program execution\n    </footer>\n  </main>\n<script>\n  (() => {\n    const button = document.getElementById('btnToggleAnim');\n    const lines = document.querySelectorAll('.glow-line');\n\n    let isAnimating = true;\n    button.addEventListener('click', () => {\n      isAnimating = !isAnimating;\n\n      lines.forEach(line => {\n        if(isAnimating) {\n          line.style.animationPlayState = 'running';\n        } else {\n          line.style.animationPlayState = 'paused';\n        }\n      });\n      button.textContent = isAnimating ? 'Pause Animation' : 'Play Animation';\n      button.setAttribute('aria-pressed', String(isAnimating));\n    });\n\n    // Start with animation running\n    lines.forEach(line => line.style.animationPlayState = 'running');\n  })();\n</script>\n</body>\n</html>"
