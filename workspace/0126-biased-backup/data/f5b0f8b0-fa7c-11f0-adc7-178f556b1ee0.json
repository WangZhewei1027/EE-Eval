    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        h1 {\n            color: #00698f;\n            font-size: 36px;\n            margin-bottom: 10px;\n        }\n        p {\n            margin-bottom: 20px;\n        }\n        #binary-search-explanation {\n            font-size: 18px;\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Binary Search</h1>\n    <p id=\"binary-search-explanation\"></p>\n\n    <div id=\"binary-search-algorithm\"></div>\n\n    <button id=\"binary-search-demo-button\">Run Binary Search Demo</button>\n\n    <script>\n        // Binary Search Algorithm\n        function binarySearch(arr, target) {\n            let low = 0;\n            let high = arr.length - 1;\n\n            while (low <= high) {\n                let mid = Math.floor((low + high) / 2);\n\n                if (arr[mid] === target) {\n                    return mid;\n                } else if (arr[mid] < target) {\n                    low = mid + 1;\n                } else {\n                    high = mid - 1;\n                }\n            }\n\n            return -1;\n        }\n\n        // Explanation Text\n        function binarySearchExplanation() {\n            let explanation = `\n                Binary Search is an efficient algorithm for finding an item from a sorted list of items. It works by repeatedly dividing in half the portion of the list that could contain the item, until you've narrowed down the possible locations to just one.\n\n                The process begins with a list of items, sorted in ascending order. The algorithm starts at the first item and checks if it's the target. If it is, the algorithm returns the index of the item.\n\n                If the item is less than the target, the algorithm moves to the right half of the list. If the item is greater than the target, the algorithm moves to the left half.\n\n                This process continues until the algorithm finds the target or determines that it's not in the list.\n\n                Binary Search has a time complexity of O(log n), making it much faster than linear search for large lists.\n            `;\n\n            document.getElementById(\"binary-search-explanation\").innerHTML = explanation;\n        }\n\n        // Demo Button Click Event\n        document.getElementById(\"binary-search-demo-button\").addEventListener(\"click\", function() {\n            let arr = [2, 5, 8, 12, 16, 23, 38, 56, 72, 91];\n            let target = 23;\n\n            let index = binarySearch(arr, target);\n\n            if (index !== -1) {\n                console.log(`Target ${target} found at index ${index}`);\n            } else {\n                console.log(`Target ${target} not found in the list`);\n            }\n\n            binarySearchExplanation();\n        });\n    </script>\n</body>\n</html>"
