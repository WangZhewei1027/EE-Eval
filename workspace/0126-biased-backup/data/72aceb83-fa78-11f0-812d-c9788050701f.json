    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Refactoring: The Art of Code Transformation</title>\n    <style>\n        :root {\n            --primary: #5e35b1;\n            --secondary: #3949ab;\n            --accent: #7c4dff;\n            --light: #f5f5f7;\n            --dark: #1a1a2e;\n            --success: #4caf50;\n            --warning: #ff9800;\n            --error: #f44336;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            background-color: var(--light);\n            color: var(--dark);\n            line-height: 1.6;\n            overflow-x: hidden;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 2rem;\n        }\n\n        header {\n            background: linear-gradient(135deg, var(--primary), var(--secondary));\n            color: white;\n            padding: 3rem 0;\n            text-align: center;\n            border-radius: 0 0 50px 50px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n            margin-bottom: 4rem;\n            position: relative;\n            overflow: hidden;\n        }\n\n        header::before {\n            content: '';\n            position: absolute;\n            top: -50px;\n            left: -50px;\n            width: 200px;\n            height: 200px;\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 50%;\n        }\n\n        header::after {\n            content: '';\n            position: absolute;\n            bottom: -30px;\n            right: -30px;\n            width: 150px;\n            height: 150px;\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 50%;\n        }\n\n        h1 {\n            font-size: 3.5rem;\n            margin-bottom: 1rem;\n            font-weight: 700;\n            position: relative;\n            z-index: 2;\n            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);\n        }\n\n        .subtitle {\n            font-size: 1.5rem;\n            opacity: 0.9;\n            position: relative;\n            z-index: 2;\n        }\n\n        .refactoring-concept {\n            display: flex;\n            justify-content: space-between;\n            margin: 5rem 0;\n            align-items: center;\n            opacity: 0;\n            transform: translateY(30px);\n            transition: all 0.8s ease;\n        }\n\n        .refactoring-concept.visible {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        .concept-text {\n            flex: 1;\n            padding: 2rem;\n            background: white;\n            border-radius: 20px;\n            box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);\n            position: relative;\n            z-index: 1;\n        }\n\n        .concept-text::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 5px;\n            height: 100%;\n            background: linear-gradient(to bottom, var(--accent), var(--secondary));\n            border-radius: 5px 0 0 5px;\n        }\n\n        h2 {\n            color: var(--primary);\n            margin-bottom: 1.5rem;\n            font-size: 2rem;\n        }\n\n        p {\n            margin-bottom: 1rem;\n            color: #555;\n        }\n\n        .code-visualization {\n            flex: 1;\n            padding: 2rem;\n            position: relative;\n            min-height: 300px;\n        }\n\n        .code-block {\n            position: absolute;\n            width: 90%;\n            background: var(--dark);\n            color: white;\n            padding: 1.5rem;\n            border-radius: 10px;\n            font-family: 'Courier New', Courier, monospace;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);\n            transition: all 0.5s ease;\n            transform-origin: top left;\n        }\n\n        .code-block.before {\n            top: 0;\n            left: 0;\n            z-index: 3;\n            background: linear-gradient(135deg, #424242, #212121);\n        }\n\n        .code-block.after {\n            bottom: 0;\n            right: 0;\n            z-index: 2;\n            background: linear-gradient(135deg, var(--secondary), var(--primary));\n            transform: scale(0.95);\n        }\n\n        .code-keyword {\n            color: #ff9d45;\n        }\n\n        .code-function {\n            color: #82aaff;\n        }\n\n        .code-string {\n            color: #9ccc65;\n        }\n\n        .code-comment {\n            color: #676e79;\n            font-style: italic;\n        }\n\n        .refactoring-button {\n            display: block;\n            margin: 3rem auto;\n            padding: 1rem 2.5rem;\n            background: linear-gradient(135deg, var(--accent), var(--primary));\n            color: white;\n            border: none;\n            border-radius: 50px;\n            font-size: 1.1rem;\n            font-weight: 600;\n            cursor: pointer;\n            box-shadow: 0 5px 20px rgba(94, 53, 177, 0.3);\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .refactoring-button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 8px 25px rgba(94, 53, 177, 0.4);\n        }\n\n        .refactoring-button:active {\n            transform: translateY(0);\n        }\n\n        .refactoring-button::after {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: linear-gradient(\n                to right,\n                rgba(255, 255, 255, 0) 0%,\n                rgba(255, 255, 255, 0.1) 50%,\n                rgba(255, 255, 255, 0) 100%\n            );\n            transform: rotate(30deg);\n            transition: all 0.3s ease;\n        }\n\n        .refactoring-button:hover::after {\n            left: 100%;\n        }\n\n        footer {\n            text-align: center;\n            margin-top: 5rem;\n            padding: 2rem;\n            color: #666;\n            font-size: 0.9rem;\n        }\n\n        .arrow {\n            position: absolute;\n            width: 100px;\n            height: 50px;\n            left: 50%;\n            transform: translateX(-50%);\n            z-index: 5;\n            opacity: 0;\n            transition: all 0.5s ease 0.3s;\n        }\n\n        .arrow svg {\n            width: 100%;\n            height: 100%;\n            fill: var(--accent);\n        }\n\n        .arrow.visible {\n            opacity: 1;\n        }\n\n        .transition-line {\n            position: absolute;\n            height: 2px;\n            background: var(--accent);\n            top: 50%;\n            left: 0;\n            width: 0;\n            z-index: 1;\n            transition: width 0.8s ease;\n        }\n\n        .transition-line.active {\n            width: 100%;\n        }\n\n        @media (max-width: 768px) {\n            .refactoring-concept {\n                flex-direction: column;\n            }\n            \n            .code-block {\n                width: 100%;\n                position: relative;\n                margin-bottom: 1rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <div class=\"container\">\n            <h1>The Art of Refactoring</h1>\n            <p class=\"subtitle\">Transforming code while preserving functionality</p>\n        </div>\n    </header>\n\n    <div class=\"container\">\n        <div class=\"refactoring-concept\">\n            <div class=\"concept-text\">\n                <h2>Extract Method</h2>\n                <p>Turn a code fragment into a method with a name that explains the purpose. This improves readability and makes the code more maintainable by breaking down complex operations into named, reusable components.</p>\n                <p>The new method name serves as documentation for what the code does, making it easier to understand at a glance.</p>\n            </div>\n            <div class=\"code-visualization\">\n                <div class=\"code-block before\">\n                    <pre><code><span class=\"code-keyword\">function</span> <span class=\"code-function\">processOrder</span>(order) {\n    <span class=\"code-comment\">// Validate order</span>\n    <span class=\"code-keyword\">if</span> (!order.items || order.items.length === 0) {\n        <span class=\"code-keyword\">throw new</span> <span class=\"code-function\">Error</span>(<span class=\"code-string\">\"Order must have items\"</span>);\n    }\n    <span class=\"code-comment\">// Calculate total</span>\n    <span class=\"code-keyword\">let</span> total = 0;\n    <span class=\"code-keyword\">for</span> (<span class=\"code-keyword\">const</span> item <span class=\"code-keyword\">of</span> order.items) {\n        total += item.price * item.quantity;\n    }\n    <span class=\"code-comment\">// Apply discount</span>\n    <span class=\"code-keyword\">if</span> (order.customer.isPremium) {\n        total *= 0.9;\n    }\n    <span class=\"code-comment\">// ... more processing ...</span>\n}</code></pre>\n                </div>\n                <div class=\"code-block after\">\n                    <pre><code><span class=\"code-keyword\">function</span> <span class=\"code-function\">processOrder</span>(order) {\n    <span class=\"code-function\">validateOrder</span>(order);\n    <span class=\"code-keyword\">const</span> total = <span class=\"code-function\">calculateTotal</span>(order);\n    <span class=\"code-comment\">// ... more processing ...</span>\n}\n\n<span class=\"code-keyword\">function</span> <span class=\"code-function\">validateOrder</span>(order) {\n    <span class=\"code-keyword\">if</span> (!order.items || order.items.length === 0) {\n        <span class=\"code-keyword\">throw new</span> <span class=\"code-function\">Error</span>(<span class=\"code-string\">\"Order must have items\"</span>);\n    }\n}\n\n<span class=\"code-keyword\">function</span> <span class=\"code-function\">calculateTotal</span>(order) {\n    <span class=\"code-keyword\">let</span> total = 0;\n    <span class=\"code-keyword\">for</span> (<span class=\"code-keyword\">const</span> item <span class=\"code-keyword\">of</span> order.items) {\n        total += item.price * item.quantity;\n    }\n    <span class=\"code-keyword\">if</span> (order.customer.isPremium) {\n        total *= 0.9;\n    }\n    <span class=\"code-keyword\">return</span> total;\n}</code></pre>\n                </div>\n                <div class=\"arrow\">\n                    <svg viewBox=\"0 0 24 24\">\n                        <path d=\"M5,12H19M19,12L12,5M19,12L12,19\"/>\n                    </svg>\n                </div>\n                <div class=\"transition-line\"></div>\n            </div>\n        </div>\n\n        <div class=\"refactoring-concept\">\n            <div class=\"concept-text\">\n                <h2>Replace Temp with Query</h2>\n                <p>Replace temporary variables with method calls. This eliminates variables that are only used once and can make the code more expressive by giving meaningful names to calculations.</p>\n                <p>By moving the calculation into a method, it becomes reusable and the intention becomes clearer through the method name.</p>\n            </div>\n            <div class=\"code-visualization\">\n                <div class=\"code-block before\">\n                    <pre><code><span class=\"code-keyword\">function</span> <span class=\"code-function\">calculatePrice</span>(order) {\n    <span class=\"code-keyword\">const</span> basePrice = order.quantity * order.itemPrice;\n    <span class=\"code-keyword\">if</span> (basePrice > 1000) {\n        <span class=\"code-keyword\">return</span> basePrice * 0.95;\n    }\n    <span class=\"code-keyword\">else</span> {\n        <span class=\"code-keyword\">return</span> basePrice * 0.98;\n    }\n}</code></pre>\n                </div>\n                <div class=\"code-block after\">\n                    <pre><code><span class=\"code-keyword\">function</span> <span class=\"code-function\">calculatePrice</span>(order) {\n    <span class=\"code-keyword\">if</span> (<span class=\"code-function\">basePrice</span>(order) > 1000) {\n        <span class=\"code-keyword\">return</span> <span class=\"code-function\">basePrice</span>(order) * 0.95;\n    }\n    <span class=\"code-keyword\">else</span> {\n        <span class=\"code-keyword\">return</span> <span class=\"code-function\">basePrice</span>(order) * 0.98;\n    }\n}\n\n<span class=\"code-keyword\">function</span> <span class=\"code-function\">basePrice</span>(order) {\n    <span class=\"code-keyword\">return</span> order.quantity * order.itemPrice;\n}</code></pre>\n                </div>\n                <div class=\"arrow\">\n                    <svg viewBox=\"0 0 24 24\">\n                        <path d=\"M5,12H19M19,12L12,5M19,12L12,19\"/>\n                    </svg>\n                </div>\n                <div class=\"transition-line\"></div>\n            </div>\n        </div>\n\n        <button class=\"refactoring-button\" id=\"animateBtn\">Animate Refactoring</button>\n\n        <div class=\"refactoring-concept\">\n            <div class=\"concept-text\">\n                <h2>Introduce Parameter Object</h2>\n                <p>When a group of parameters naturally go together, replace them with an object. This reduces parameter lists and makes the relationship between parameters explicit.</p>\n                <p>Parameter objects often become meaningful concepts in your codebase, making the code more expressive and easier to understand.</p>\n            </div>\n            <div class=\"code-visualization\">\n                <div class=\"code-block before\">\n                    <pre><code><span class=\"code-keyword\">function</span> <span class=\"code-function\">bookConcertTickets</span>(\n    customerName, \n    customerEmail, \n    concertId, \n    seatNumbers, \n    isVIP, \n    paymentMethod\n) {\n    <span class=\"code-comment\">// booking logic...</span>\n}</code></pre>\n                </div>\n                <div class=\"code-block after\">\n                    <pre><code><span class=\"code-keyword\">function</span> <span class=\"code-function\">bookConcertTickets</span>(\n    customer, \n    bookingDetails\n) {\n    <span class=\"code-comment\">// booking logic...</span>\n}</code></pre>\n                </div>\n                <div class=\"arrow\">\n                    <svg viewBox=\"0 0 24 24\">\n                        <path d=\"M5,12H19M19,12L12,5M19,12L12,19\"/>\n                    </svg>\n                </div>\n                <div class=\"transition-line\"></div>\n            </div>\n        </div>\n    </div>\n\n    <footer>\n        <p>Refactoring improves code structure without changing external behavior</p>\n        <p>© 2023 The Art of Clean Code</p>\n    </footer>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Intersection Observer for scroll animations\n            const observer = new IntersectionObserver((entries) => {\n                entries.forEach(entry => {\n                    if (entry.isIntersecting) {\n                        entry.target.classList.add('visible');\n                        const arrow = entry.target.querySelector('.arrow');\n                        const line = entry.target.querySelector('.transition-line');\n                        if (arrow && line) {\n                            setTimeout(() => {\n                                arrow.classList.add('visible');\n                                line.classList.add('active');\n                            }, 300);\n                        }\n                    }\n                });\n            }, { threshold: 0.1 });\n\n            document.querySelectorAll('.refactoring-concept').forEach(el => {\n                observer.observe(el);\n            });\n\n            // Button animation\n            const animateBtn = document.getElementById('animateBtn');\n            animateBtn.addEventListener('click', function() {\n                document.querySelectorAll('.refactoring-concept').forEach(el => {\n                    el.classList.remove('visible');\n                    const arrow = el.querySelector('.arrow');\n                    const line = el.querySelector('.transition-line');\n                    if (arrow && line) {\n                        arrow.classList.remove('visible');\n                        line.classList.remove('active');\n                    }\n                });\n\n                setTimeout(() => {\n                    document.querySelectorAll('.refactoring-concept').forEach((el, i) => {\n                        setTimeout(() => {\n                            el.classList.add('visible');\n                            const arrow = el.querySelector('.arrow');\n                            const line = el.querySelector('.transition-line');\n                            if (arrow && line) {\n                                setTimeout(() => {\n                                    arrow.classList.add('visible');\n                                    line.classList.add('active');\n                                }, 300);\n                            }\n                        }, i * 300);\n                    });\n                }, 50);\n            });\n        });\n    </script>\n</body>\n</html>"
