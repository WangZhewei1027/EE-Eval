  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Min Heap Interactive Demo</title>\n    <style>\n        body {\n            font-family: monospace;\n            margin: 20px;\n            line-height: 1.5;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #000;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        button, input, select {\n            margin: 5px;\n            padding: 5px;\n        }\n        .heap-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        .heap-level {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 20px;\n        }\n        .heap-node {\n            border: 1px solid #000;\n            padding: 10px;\n            margin: 0 5px;\n            min-width: 40px;\n            text-align: center;\n            position: relative;\n        }\n        .heap-node.highlight {\n            background-color: #eee;\n        }\n        .heap-node.active {\n            font-weight: bold;\n        }\n        .heap-lines {\n            position: absolute;\n            width: 100%;\n            height: 20px;\n            top: -20px;\n            left: 0;\n        }\n        .line {\n            position: absolute;\n            height: 20px;\n            border-left: 1px solid #000;\n        }\n        .stats {\n            margin-top: 20px;\n            border-top: 1px solid #000;\n            padding-top: 10px;\n        }\n        .explanation {\n            margin-top: 20px;\n            border: 1px solid #000;\n            padding: 10px;\n            max-width: 600px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Min Heap Interactive Demo</h1>\n        \n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Heap Operations</h3>\n                <button id=\"insert-btn\">Insert Random Value</button>\n                <button id=\"extract-min-btn\">Extract Min</button>\n                <button id=\"peek-btn\">Peek Min</button>\n                <button id=\"heapify-btn\">Heapify Random Array</button>\n                <button id=\"clear-btn\">Clear Heap</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Manual Insert</h3>\n                <input type=\"number\" id=\"insert-value\" placeholder=\"Enter value\">\n                <button id=\"manual-insert-btn\">Insert</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Heap Size</h3>\n                <input type=\"range\" id=\"heap-size-slider\" min=\"0\" max=\"20\" value=\"10\">\n                <span id=\"heap-size-value\">10</span>\n                <button id=\"apply-size-btn\">Apply Size</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Visualization</h3>\n                <select id=\"view-mode\">\n                    <option value=\"tree\">Tree View</option>\n                    <option value=\"array\">Array View</option>\n                </select>\n                <button id=\"toggle-highlight\">Toggle Highlight</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Step-by-Step</h3>\n                <button id=\"step-insert-btn\">Step: Insert</button>\n                <button id=\"step-extract-btn\">Step: Extract</button>\n                <button id=\"reset-steps-btn\">Reset Steps</button>\n            </div>\n        </div>\n        \n        <div class=\"heap-container\" id=\"heap-display\">\n            <!-- Heap visualization will be rendered here -->\n        </div>\n        \n        <div class=\"stats\">\n            <h3>Heap Statistics</h3>\n            <div>Size: <span id=\"heap-size-stat\">0</span></div>\n            <div>Height: <span id=\"heap-height-stat\">0</span></div>\n            <div>Min Value: <span id=\"heap-min-stat\">-</span></div>\n            <div>Last Operation: <span id=\"last-op-stat\">None</span></div>\n            <div>Operations Count: <span id=\"op-count-stat\">0</span></div>\n        </div>\n        \n        <div class=\"explanation\" id=\"current-explanation\">\n            <h3>Explanation</h3>\n            <p>Welcome to the Min Heap interactive demo. A min heap is a complete binary tree where each node is smaller than or equal to its children.</p>\n            <p>Use the controls above to interact with the heap.</p>\n        </div>\n    </div>\n\n    <script>\n        class MinHeap {\n            constructor() {\n                this.heap = [];\n                this.highlightedNodes = new Set();\n                this.steps = [];\n                this.currentStep = 0;\n                this.operationsCount = 0;\n            }\n            \n            size() {\n                return this.heap.length;\n            }\n            \n            height() {\n                return Math.floor(Math.log2(this.size())) + 1;\n            }\n            \n            isEmpty() {\n                return this.size() === 0;\n            }\n            \n            peek() {\n                return this.isEmpty() ? null : this.heap[0];\n            }\n            \n            insert(value) {\n                this.heap.push(value);\n                this.bubbleUp(this.size() - 1);\n                this.operationsCount++;\n            }\n            \n            stepInsert(value) {\n                this.steps = [];\n                this.steps.push({action: 'start-insert', value});\n                let current = this.heap.length;\n                this.heap.push(value);\n                this.steps.push({action: 'add-node', index: current, value});\n                \n                while (current > 0) {\n                    const parent = Math.floor((current - 1) / 2);\n                    this.steps.push({action: 'compare', index1: current, index2: parent});\n                    \n                    if (this.heap[current] < this.heap[parent]) {\n                        this.steps.push({action: 'swap', index1: current, index2: parent});\n                        [this.heap[current], this.heap[parent]] = [this.heap[parent], this.heap[current]];\n                        current = parent;\n                    } else {\n                        break;\n                    }\n                }\n                \n                this.steps.push({action: 'end-insert'});\n                this.currentStep = 0;\n                this.operationsCount++;\n                return this.steps;\n            }\n            \n            extractMin() {\n                if (this.isEmpty()) return null;\n                \n                const min = this.heap[0];\n                const last = this.heap.pop();\n                \n                if (!this.isEmpty()) {\n                    this.heap[0] = last;\n                    this.sinkDown(0);\n                }\n                \n                this.operationsCount++;\n                return min;\n            }\n            \n            stepExtract() {\n                this.steps = [];\n                if (this.isEmpty()) return [];\n                \n                this.steps.push({action: 'start-extract'});\n                const min = this.heap[0];\n                this.steps.push({action: 'remove-min', value: min});\n                \n                const last = this.heap.pop();\n                this.steps.push({action: 'remove-last', value: last});\n                \n                if (!this.isEmpty()) {\n                    this.heap[0] = last;\n                    this.steps.push({action: 'move-last-to-root', value: last});\n                    \n                    let current = 0;\n                    const heapSize = this.size();\n                    \n                    while (true) {\n                        const left = 2 * current + 1;\n                        const right = 2 * current + 2;\n                        let smallest = current;\n                        \n                        if (left < heapSize) {\n                            this.steps.push({action: 'compare', index1: current, index2: left});\n                            if (this.heap[left] < this.heap[smallest]) {\n                                smallest = left;\n                            }\n                        }\n                        \n                        if (right < heapSize) {\n                            this.steps.push({action: 'compare', index1: current, index2: right});\n                            if (this.heap[right] < this.heap[smallest]) {\n                                smallest = right;\n                            }\n                        }\n                        \n                        if (smallest !== current) {\n                            this.steps.push({action: 'swap', index1: current, index2: smallest});\n                            [this.heap[current], this.heap[smallest]] = [this.heap[smallest], this.heap[current]];\n                            current = smallest;\n                        } else {\n                            break;\n                        }\n                    }\n                }\n                \n                this.steps.push({action: 'end-extract'});\n                this.currentStep = 0;\n                this.operationsCount++;\n                return this.steps;\n            }\n            \n            bubbleUp(index) {\n                while (index > 0) {\n                    const parent = Math.floor((index - 1) / 2);\n                    if (this.heap[index] < this.heap[parent]) {\n                        [this.heap[index], this.heap[parent]] = [this.heap[parent], this.heap[index]];\n                        index = parent;\n                    } else {\n                        break;\n                    }\n                }\n            }\n            \n            sinkDown(index) {\n                const heapSize = this.size();\n                while (true) {\n                    const left = 2 * index + 1;\n                    const right = 2 * index + 2;\n                    let smallest = index;\n                    \n                    if (left < heapSize && this.heap[left] < this.heap[smallest]) {\n                        smallest = left;\n                    }\n                    \n                    if (right < heapSize && this.heap[right] < this.heap[smallest]) {\n                        smallest = right;\n                    }\n                    \n                    if (smallest !== index) {\n                        [this.heap[index], this.heap[smallest]] = [this.heap[smallest], this.heap[index]];\n                        index = smallest;\n                    } else {\n                        break;\n                    }\n                }\n            }\n            \n            heapify(array) {\n                this.heap = [...array];\n                for (let i = Math.floor(this.size() / 2); i >= 0; i--) {\n                    this.sinkDown(i);\n                }\n                this.operationsCount++;\n            }\n            \n            clear() {\n                this.heap = [];\n                this.highlightedNodes.clear();\n                this.steps = [];\n                this.currentStep = 0;\n                this.operationsCount = 0;\n            }\n            \n            toggleHighlight(index) {\n                if (this.highlightedNodes.has(index)) {\n                    this.highlightedNodes.delete(index);\n                } else {\n                    this.highlightedNodes.add(index);\n                }\n            }\n            \n            getArrayRepresentation() {\n                return [...this.heap];\n            }\n            \n            getTreeRepresentation() {\n                if (this.isEmpty()) return [];\n                \n                const levels = [];\n                const height = this.height();\n                \n                for (let level = 0; level < height; level++) {\n                    const start = Math.pow(2, level) - 1;\n                    const end = Math.pow(2, level + 1) - 1;\n                    levels.push(this.heap.slice(start, end));\n                }\n                \n                return levels;\n            }\n        }\n\n        // Initialize heap and UI\n        const heap = new MinHeap();\n        let viewMode = 'tree';\n        let lastOperation = 'None';\n        \n        // DOM elements\n        const heapDisplay = document.getElementById('heap-display');\n        const heapSizeStat = document.getElementById('heap-size-stat');\n        const heapHeightStat = document.getElementById('heap-height-stat');\n        const heapMinStat = document.getElementById('heap-min-stat');\n        const lastOpStat = document.getElementById('last-op-stat');\n        const opCountStat = document.getElementById('op-count-stat');\n        const explanationDiv = document.getElementById('current-explanation');\n        const heapSizeSlider = document.getElementById('heap-size-slider');\n        const heapSizeValue = document.getElementById('heap-size-value');\n        \n        // Event listeners\n        document.getElementById('insert-btn').addEventListener('click', () => {\n            const value = Math.floor(Math.random() * 100) + 1;\n            heap.insert(value);\n            lastOperation = `Inserted ${value}`;\n            updateDisplay();\n        });\n        \n        document.getElementById('extract-min-btn').addEventListener('click', () => {\n            const min = heap.extractMin();\n            lastOperation = min !== null ? `Extracted ${min}` : 'Heap is empty';\n            updateDisplay();\n        });\n        \n        document.getElementById('peek-btn').addEventListener('click', () => {\n            const min = heap.peek();\n            lastOperation = min !== null ? `Min is ${min}` : 'Heap is empty';\n            updateDisplay();\n        });\n        \n        document.getElementById('heapify-btn').addEventListener('click', () => {\n            const size = parseInt(heapSizeSlider.value);\n            const array = Array.from({length: size}, () => Math.floor(Math.random() * 100) + 1);\n            heap.heapify(array);\n            lastOperation = `Heapified array: [${array.join(', ')}]`;\n            updateDisplay();\n        });\n        \n        document.getElementById('clear-btn').addEventListener('click', () => {\n            heap.clear();\n            lastOperation = 'Heap cleared';\n            updateDisplay();\n        });\n        \n        document.getElementById('manual-insert-btn').addEventListener('click', () => {\n            const valueInput = document.getElementById('insert-value');\n            const value = parseInt(valueInput.value);\n            if (!isNaN(value)) {\n                heap.insert(value);\n                lastOperation = `Inserted ${value}`;\n                valueInput.value = '';\n                updateDisplay();\n            }\n        });\n        \n        document.getElementById('view-mode').addEventListener('change', (e) => {\n            viewMode = e.target.value;\n            updateDisplay();\n        });\n        \n        document.getElementById('toggle-highlight').addEventListener('click', () => {\n            if (viewMode === 'array') {\n                for (let i = 0; i < heap.size(); i++) {\n                    heap.toggleHighlight(i);\n                }\n            }\n            updateDisplay();\n        });\n        \n        document.getElementById('step-insert-btn').addEventListener('click', () => {\n            const value = Math.floor(Math.random() * 100) + 1;\n            heap.stepInsert(value);\n            lastOperation = `Step-by-step insert ${value}`;\n            updateDisplay();\n        });\n        \n        document.getElementById('step-extract-btn').addEventListener('click', () => {\n            heap.stepExtract();\n            lastOperation = 'Step-by-step extract min';\n            updateDisplay();\n        });\n        \n        document.getElementById('reset-steps-btn').addEventListener('click', () => {\n            heap.steps = [];\n            heap.currentStep = 0;\n            updateDisplay();\n        });\n        \n        heapSizeSlider.addEventListener('input', () => {\n            heapSizeValue.textContent = heapSizeSlider.value;\n        });\n        \n        document.getElementById('apply-size-btn').addEventListener('click', () => {\n            updateDisplay();\n        });\n        \n        // Display functions\n        function updateDisplay() {\n            updateStats();\n            \n            if (viewMode === 'tree') {\n                renderTree();\n            } else {\n                renderArray();\n            }\n            \n            updateExplanation();\n        }\n        \n        function updateStats() {\n            heapSizeStat.textContent = heap.size();\n            heapHeightStat.textContent = heap.height();\n            heapMinStat.textContent = heap.peek() !== null ? heap.peek() : '-';\n            lastOpStat.textContent = lastOperation;\n            opCountStat.textContent = heap.operationsCount;\n        }\n        \n        function renderTree() {\n            heapDisplay.innerHTML = '';\n            \n            if (heap.isEmpty()) {\n                heapDisplay.innerHTML = '<p>Heap is empty</p>';\n                return;\n            }\n            \n            const levels = [];\n            const height = heap.height();\n            \n            for (let level = 0; level < height; level++) {\n                const start = Math.pow(2, level) - 1;\n                const end = Math.pow(2, level + 1) - 1;\n                levels.push(heap.heap.slice(start, end));\n            }\n            \n            levels.forEach((levelNodes, levelIndex) => {\n                const levelDiv = document.createElement('div');\n                levelDiv.className = 'heap-level';\n                \n                levelNodes.forEach((value, nodeIndex) => {\n                    const globalIndex = Math.pow(2, levelIndex) - 1 + nodeIndex;\n                    const nodeDiv = document.createElement('div');\n                    nodeDiv.className = 'heap-node';\n                    \n                    if (heap.highlightedNodes.has(globalIndex)) {\n                        nodeDiv.classList.add('highlight');\n                    }\n                    \n                    // Check if this node is involved in current step\n                    if (heap.steps.length > 0 && heap.currentStep < heap.steps.length) {\n                        const step = heap.steps[heap.currentStep];\n                        if ((step.action === 'compare' && (step.index1 === globalIndex || step.index2 === globalIndex)) ||\n                            (step.action === 'swap' && (step.index1 === globalIndex || step.index2 === globalIndex)) ||\n                            (step.action === 'add-node' && step.index === globalIndex) ||\n                            (step.action === 'remove-min' && globalIndex === 0) ||\n                            (step.action === 'move-last-to-root' && globalIndex === 0)) {\n                            nodeDiv.classList.add('active');\n                        }\n                    }\n                    \n                    nodeDiv.textContent = value;\n                    nodeDiv.dataset.index = globalIndex;\n                    \n                    // Add click handler for highlighting\n                    nodeDiv.addEventListener('click', () => {\n                        heap.toggleHighlight(globalIndex);\n                        updateDisplay();\n                    });\n                    \n                    // Add lines for children\n                    if (levelIndex > 0) {\n                        const linesDiv = document.createElement('div');\n                        linesDiv.className = 'heap-lines';\n                        \n                        const parentIndex = Math.floor((globalIndex - 1) / 2);\n                        const isLeftChild = globalIndex % 2 === 1;\n                        \n                        const line = document.createElement('div');\n                        line.className = 'line';\n                        line.style.width = '1px';\n                        line.style.left = '50%';\n                        line.style.height = '20px';\n                        \n                        linesDiv.appendChild(line);\n                        nodeDiv.appendChild(linesDiv);\n                    }\n                    \n                    levelDiv.appendChild(nodeDiv);\n                });\n                \n                heapDisplay.appendChild(levelDiv);\n            });\n        }\n        \n        function renderArray() {\n            heapDisplay.innerHTML = '';\n            \n            if (heap.isEmpty()) {\n                heapDisplay.innerHTML = '<p>Heap is empty</p>';\n                return;\n            }\n            \n            const arrayDiv = document.createElement('div');\n            arrayDiv.style.display = 'flex';\n            arrayDiv.style.flexWrap = 'wrap';\n            arrayDiv.style.gap = '5px';\n            \n            heap.heap.forEach((value, index) => {\n                const nodeDiv = document.createElement('div');\n                nodeDiv.className = 'heap-node';\n                \n                if (heap.highlightedNodes.has(index)) {\n                    nodeDiv.classList.add('highlight');\n                }\n                \n                // Check if this node is involved in current step\n                if (heap.steps.length > 0 && heap.currentStep < heap.steps.length) {\n                    const step = heap.steps[heap.currentStep];\n                    if ((step.action === 'compare' && (step.index1 === index || step.index2 === index)) ||\n                        (step.action === 'swap' && (step.index1 === index || step.index2 === index)) ||\n                        (step.action === 'add-node' && step.index === index) ||\n                        (step.action === 'remove-min' && index === 0) ||\n                        (step.action === 'move-last-to-root' && index === 0)) {\n                        nodeDiv.classList.add('active');\n                    }\n                }\n                \n                nodeDiv.textContent = value;\n                nodeDiv.dataset.index = index;\n                \n                // Add click handler for highlighting\n                nodeDiv.addEventListener('click', () => {\n                    heap.toggleHighlight(index);\n                    updateDisplay();\n                });\n                \n                arrayDiv.appendChild(nodeDiv);\n            });\n            \n            heapDisplay.appendChild(arrayDiv);\n        }\n        \n        function updateExplanation() {\n            if (heap.steps.length === 0 || heap.currentStep >= heap.steps.length) {\n                if (heap.isEmpty()) {\n                    explanationDiv.innerHTML = '<h3>Explanation</h3><p>The heap is currently empty. Use the controls to insert elements or heapify an array.</p>';\n                } else {\n                    explanationDiv.innerHTML = `\n                        <h3>Explanation</h3>\n                        <p>The heap currently contains ${heap.size()} elements with a minimum value of ${heap.peek()}.</p>\n                        <p>Click on nodes to highlight them for comparison.</p>\n                        <p>Use the step-by-step buttons to see how insert and extract operations work.</p>\n                    `;\n                }\n                return;\n            }\n            \n            const step = heap.steps[heap.currentStep];\n            let explanation = '<h3>Step Explanation</h3>';\n            \n            switch (step.action) {\n                case 'start-insert':\n                    explanation += `<p>Starting to insert value ${step.value} into the heap.</p>`;\n                    break;\n                case 'add-node':\n                    explanation += `<p>Added new node with value ${step.value} at position ${step.index}.</p>`;\n                    break;\n                case 'compare':\n                    explanation += `<p>Comparing nodes at positions ${step.index1} (value ${heap.heap[step.index1]}) and ${step.index2} (value ${heap.heap[step.index2]}).</p>`;\n                    break;\n                case 'swap':\n                    explanation += `<p>Swapping nodes at positions ${step.index1} and ${step.index2} to maintain heap property.</p>`;\n                    break;\n                case 'end-insert':\n                    explanation += `<p>Insertion complete. The heap property is maintained.</p>`;\n                    break;\n                case 'start-extract':\n                    explanation += `<p>Starting to extract the minimum value from the root.</p>`;\n                    break;\n                case 'remove-min':\n                    explanation += `<p>Removing the minimum value ${step.value} from the root.</p>`;\n                    break;\n                case 'remove-last':\n                    explanation += `<p>Removing the last node with value ${step.value} to replace the root.</p>`;\n                    break;\n                case 'move-last-to-root':\n                    explanation += `<p>Moving the last node with value ${step.value} to the root position.</p>`;\n                    break;\n                case 'end-extract':\n                    explanation += `<p>Extraction complete. The heap property is maintained.</p>`;\n                    break;\n                default:\n                    explanation += `<p>Performing operation: ${step.action}.</p>`;\n            }\n            \n            explanation += `<p>Step ${heap.currentStep + 1} of ${heap.steps.length}.</p>`;\n            explanation += `<button id=\"next-step-btn\">Next Step</button>`;\n            \n            explanationDiv.innerHTML = explanation;\n            \n            document.getElementById('next-step-btn')?.addEventListener('click', () => {\n                heap.currentStep++;\n                updateDisplay();\n            });\n        }\n        \n        // Initial display\n        updateDisplay();\n    </script>\n</body>\n</html>"
  },
