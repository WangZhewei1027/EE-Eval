    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Backtracking Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            padding: 0;\n            background: #f0f4f8;\n            color: #333;\n            overflow: hidden;\n        }\n        header {\n            text-align: center;\n            padding: 20px;\n            background: #3f51b5;\n            color: white;\n            border-bottom: 5px solid #303f9f;\n        }\n        h1 {\n            font-size: 2.5em;\n            margin: 0;\n            animation: fadeIn 1s forwards;\n        }\n        #visualization {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: calc(100vh - 100px);\n            position: relative;\n            overflow: hidden;\n        }\n        .node {\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background: #4caf50;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            transition: transform 0.5s, background 0.5s;\n            position: absolute;\n        }\n        .node.active {\n            background: #ff9800;\n            transform: scale(1.1);\n        }\n        .node.visited {\n            background: #2196f3;\n        }\n        .button {\n            background: #3f51b5;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            padding: 10px 20px;\n            font-size: 1em;\n            cursor: pointer;\n            margin: 20px;\n            transition: background 0.3s;\n        }\n        .button:hover {\n            background: #303f9f;\n        }\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>Backtracking Visualization</h1>\n    </header>\n    <div id=\"visualization\"></div>\n    <div style=\"text-align: center;\">\n        <button class=\"button\" id=\"start-btn\">Start Visualization</button>\n    </div>\n\n    <script>\n        const visualization = document.getElementById('visualization');\n        const startButton = document.getElementById('start-btn');\n\n        const nodes = [];\n        const gridSize = 5;\n\n        function createGrid() {\n            for (let i = 0; i < gridSize; i++) {\n                for (let j = 0; j < gridSize; j++) {\n                    const node = document.createElement('div');\n                    node.classList.add('node');\n                    node.style.left = `${j * 60}px`;\n                    node.style.top = `${i * 60}px`;\n                    visualization.appendChild(node);\n                    nodes.push(node);\n                }\n            }\n        }\n\n        function backtracking(index = 0) {\n            if (index >= nodes.length) return;\n\n            nodes[index].classList.add('active');\n            setTimeout(() => {\n                nodes[index].classList.add('visited');\n                if (index > 0) nodes[index - 1].classList.remove('active');\n                backtracking(index + 1);\n            }, 1000);\n        }\n\n        startButton.addEventListener('click', () => {\n            nodes.forEach(node => node.classList.remove('visited', 'active'));\n            backtracking();\n        });\n\n        createGrid();\n    </script>\n</body>\n</html>"
