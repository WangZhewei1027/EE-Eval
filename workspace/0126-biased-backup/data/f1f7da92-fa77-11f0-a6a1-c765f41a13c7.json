  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>ACID Properties — Visual Demonstration</title>\n<style>\n  :root{\n    --bg-1:#0f1724;\n    --bg-2:#071029;\n    --glass: rgba(255,255,255,0.06);\n    --accent-1: #7c5cff;\n    --accent-2: #00d4ff;\n    --accent-3: #6ee7b7;\n    --muted: rgba(255,255,255,0.55);\n    --glass-border: rgba(255,255,255,0.08);\n    --card-radius: 18px;\n    --card-padding: 26px;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background: radial-gradient(1200px 600px at 10% 10%, rgba(124,92,255,0.12), transparent 8%),\n                radial-gradient(1000px 500px at 90% 90%, rgba(0,212,255,0.06), transparent 6%),\n                linear-gradient(180deg,var(--bg-1) 0%, var(--bg-2) 100%);\n    color: #e6eef8;\n    -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding:48px;\n    overflow:hidden;\n  }\n\n  /* Floating decorative blobs */\n  .bg-blob{\n    position:absolute;\n    filter: blur(60px) saturate(120%);\n    opacity:0.18;\n    z-index:0;\n    border-radius:50%;\n    transform: translate3d(0,0,0);\n  }\n  .blob-1{width:560px;height:560px;left:-150px;top:-80px;background:linear-gradient(135deg,var(--accent-1), #4a9bff);}\n  .blob-2{width:420px;height:420px;right:-120px;bottom:-120px;background:linear-gradient(135deg,var(--accent-2), #6ee7b7);}\n\n  .stage{\n    position:relative;\n    z-index:3;\n    max-width:1100px;\n    width:100%;\n    margin:0 auto;\n    display:flex;\n    flex-direction:column;\n    gap:22px;\n  }\n\n  header{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap:16px;\n  }\n  .title{\n    display:flex;\n    gap:18px;\n    align-items:baseline;\n  }\n  h1{\n    margin:0;\n    font-weight:700;\n    font-size:28px;\n    letter-spacing:-0.02em;\n    line-height:1;\n    color: #f7f9ff;\n  }\n  p.lead{\n    margin:0;\n    color:var(--muted);\n    font-size:13px;\n    max-width:700px;\n  }\n\n  /* Main glass panel */\n  .glass{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius: calc(var(--card-radius) + 6px);\n    border: 1px solid var(--glass-border);\n    box-shadow: 0 10px 40px rgba(3,10,25,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    padding: 26px;\n    display:grid;\n    grid-template-columns: 1fr;\n  }\n\n  .panel{\n    display:flex;\n    gap:20px;\n    align-items:center;\n    justify-content:center;\n    padding: 28px;\n  }\n\n  /* Pillars container */\n  .pillars{\n    display:flex;\n    gap:18px;\n    align-items:stretch;\n    width:100%;\n    justify-content:space-between;\n    position:relative;\n  }\n\n  .pillar{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius: 14px;\n    padding:18px;\n    flex:1;\n    min-width:180px;\n    display:flex;\n    flex-direction:column;\n    align-items:center;\n    gap:12px;\n    transition: transform 450ms cubic-bezier(.2,.9,.2,1), box-shadow 350ms;\n    position:relative;\n    border: 1px solid rgba(255,255,255,0.03);\n    backdrop-filter: blur(6px) saturate(120%);\n  }\n\n  .pillar:hover{transform: translateY(-6px); box-shadow: 0 12px 40px rgba(2,8,20,0.55);}\n\n  .icon-wrap{\n    width:92px;height:92px;border-radius:20px;\n    display:flex;align-items:center;justify-content:center;\n    background: linear-gradient(135deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border: 1px solid rgba(255,255,255,0.03);\n    position:relative;\n    overflow:visible;\n  }\n\n  .icon{\n    width:56px;height:56px;display:block;\n    filter: drop-shadow(0 6px 18px rgba(20,30,60,0.45));\n    transition: transform 350ms;\n  }\n\n  .pillar h3{\n    margin:0;font-size:15px;font-weight:700;color:#f7f9ff;\n    text-align:center;\n  }\n  .pillar p{\n    margin:0;font-size:12px;color:var(--muted);text-align:center;line-height:1.35;\n  }\n\n  /* path & token */\n  .path{\n    position:absolute;\n    left:14px;right:14px;top:36px;height:120px;\n    pointer-events:none;\n  }\n  .path svg{width:100%;height:100%}\n\n  .token{\n    position:absolute;\n    top:52px;\n    left:34px;\n    width:34px;height:34px;border-radius:50%;\n    background: radial-gradient(circle at 35% 25%, #ffffff, rgba(255,255,255,0.9) 5%, rgba(0,0,0,0) 40%),\n                linear-gradient(135deg,var(--accent-1),var(--accent-2));\n    box-shadow: 0 10px 30px rgba(124,92,255,0.22), 0 2px 8px rgba(0,0,0,0.45);\n    transform-origin:center;\n    display:flex;align-items:center;justify-content:center;\n    color:#051124;font-weight:700;font-size:13px;\n    transition: transform 500ms cubic-bezier(.2,.9,.2,1), box-shadow 350ms;\n    z-index:5;\n  }\n\n  .token.glow{\n    box-shadow: 0 18px 60px rgba(124,92,255,0.34), 0 6px 18px rgba(0,0,0,0.6);\n    transform: scale(1.06) rotateZ(6deg);\n  }\n\n  /* Pillar active state (triggered) */\n  .pillar.active{transform: translateY(-10px); box-shadow: 0 18px 50px rgba(6,12,32,0.65); border-color: rgba(255,255,255,0.06);}\n  .pillar.success{border-left:4px solid rgba(110,231,183,0.18); }\n  .pillar.warn{border-left:4px solid rgba(255,120,120,0.12); }\n\n  /* micro effects inside icons */\n  .icon .pulse{\n    position:absolute; inset:0; border-radius:12px; z-index:-1;\n    box-shadow: 0 0 0 0 rgba(124,92,255,0.2);\n    animation: none;\n    pointer-events:none;\n  }\n  .pillar.active .icon .pulse{ animation: pulse 1100ms ease-out; }\n  @keyframes pulse{\n    0%{box-shadow:0 0 0 0 rgba(124,92,255,0.18)}\n    70%{box-shadow:0 0 50px 18px rgba(124,92,255,0.04)}\n    100%{box-shadow:0 0 0 0 rgba(124,92,255,0)}\n  }\n\n  /* Mini descriptive overlay */\n  .desc{\n    position:absolute; left:50%; transform:translateX(-50%);\n    bottom:-54px; background:linear-gradient(180deg, rgba(6,12,20,0.7), rgba(6,12,20,0.55));\n    padding:10px 14px;border-radius:10px;font-size:13px; color:var(--muted);\n    box-shadow: 0 8px 30px rgba(2,6,18,0.6);\n    border:1px solid rgba(255,255,255,0.03);\n    min-width:220px; text-align:center; opacity:0; transform-origin:50% 100%;\n    transition: opacity 350ms, transform 350ms cubic-bezier(.2,.9,.2,1);\n  }\n  .pillar.show-desc .desc{ opacity:1; transform: translateX(-50%) translateY(-6px); color:#ecf9f4; }\n\n  /* control bar */\n  .controls{\n    display:flex;\n    gap:12px;\n    align-items:center;\n    justify-content:center;\n    margin-top:6px;\n  }\n  .btn{\n    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border:1px solid rgba(255,255,255,0.04);\n    padding:10px 14px;border-radius:12px;\n    color:#f1f7ff;font-weight:700; cursor:pointer; font-size:13px;\n    display:inline-flex;align-items:center;gap:10px;\n    transition: transform 220ms, background 220ms, box-shadow 220ms;\n    backdrop-filter: blur(6px);\n    box-shadow: 0 8px 22px rgba(3,8,18,0.55);\n  }\n  .btn:active{transform:translateY(2px)}\n  .btn .dot{\n    width:10px;height:10px;border-radius:50%; background:linear-gradient(135deg,var(--accent-1),var(--accent-2));\n    box-shadow: 0 6px 18px rgba(124,92,255,0.28);\n  }\n  .btn.secondary{\n    background:transparent;border:1px solid rgba(255,255,255,0.04); color:var(--muted); font-weight:600;\n    box-shadow:none;\n  }\n\n  /* descriptive footer */\n  .footer{\n    margin-top:12px; color:var(--muted); font-size:13px; text-align:center;\n  }\n\n  /* small responsive rules */\n  @media (max-width:980px){\n    .pillars{flex-direction:column; gap:14px;}\n    .path{display:none}\n    .token{display:none}\n    .panel{padding:18px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"bg-blob blob-1\" aria-hidden=\"true\"></div>\n  <div class=\"bg-blob blob-2\" aria-hidden=\"true\"></div>\n\n  <main class=\"stage\" role=\"main\">\n    <header>\n      <div class=\"title\">\n        <svg width=\"56\" height=\"56\" viewBox=\"0 0 48 48\" fill=\"none\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"g1\" x1=\"0\" x2=\"1\" y1=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n              <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"2\" y=\"2\" width=\"44\" height=\"44\" rx=\"12\" fill=\"url(#g1)\" opacity=\"0.14\" />\n          <path d=\"M14 30c2-6 8-10 14-10\" stroke=\"url(#g1)\" stroke-width=\"2.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <circle cx=\"14\" cy=\"30\" r=\"4\" fill=\"#f7fbff\"/>\n          <circle cx=\"28\" cy=\"20\" r=\"4\" fill=\"#f7fbff\" opacity=\"0.9\"/>\n        </svg>\n        <div>\n          <h1>ACID Properties</h1>\n          <p class=\"lead\">A refined, animated visualization of Atomicity, Consistency, Isolation, and Durability — the pillars of reliable transactions.</p>\n        </div>\n      </div>\n\n      <div style=\"display:flex;align-items:center;gap:10px\">\n        <div style=\"font-size:12px;color:var(--muted);text-align:right\">\n          <div style=\"font-weight:700;color:#f7f9ff\">Transaction Flow</div>\n          <div>Observe the lifecycle — press Play to begin</div>\n        </div>\n      </div>\n    </header>\n\n    <section class=\"glass\" aria-hidden=\"false\">\n      <div class=\"panel\">\n        <div class=\"pillars\" id=\"pillars\">\n\n          <!-- decorative path -->\n          <div class=\"path\" aria-hidden=\"true\">\n            <svg viewBox=\"0 0 1000 120\" preserveAspectRatio=\"none\">\n              <defs>\n                <linearGradient id=\"pathGrad\" x1=\"0\" x2=\"1\">\n                  <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n                  <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n                </linearGradient>\n              </defs>\n              <path d=\"M40 60 C200 20, 300 20, 420 60 S680 100, 960 60\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"8\" fill=\"none\" stroke-linecap=\"round\" />\n              <path id=\"glowPath\" d=\"M40 60 C200 20, 300 20, 420 60 S680 100, 960 60\" stroke=\"url(#pathGrad)\" stroke-width=\"4\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.9\" stroke-linejoin=\"round\" stroke-dasharray=\"7 12\">\n                <animate attributeName=\"stroke-dashoffset\" from=\"0\" to=\"100\" dur=\"6s\" repeatCount=\"indefinite\"/>\n              </path>\n            </svg>\n          </div>\n\n          <!-- Pillar: Atomicity -->\n          <article class=\"pillar\" data-key=\"atomic\" id=\"p-atomic\" aria-labelledby=\"a-atomic\">\n            <div class=\"icon-wrap\">\n              <svg class=\"icon\" viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n                <defs>\n                  <linearGradient id=\"ag1\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n                    <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n                  </linearGradient>\n                </defs>\n                <rect x=\"6\" y=\"6\" width=\"52\" height=\"52\" rx=\"12\" fill=\"rgba(255,255,255,0.02)\"/>\n                <g transform=\"translate(7,7)\">\n                  <circle cx=\"12\" cy=\"18\" r=\"6\" fill=\"url(#ag1)\"/>\n                  <circle cx=\"30\" cy=\"18\" r=\"6\" fill=\"#fff\" opacity=\"0.95\"/>\n                  <rect x=\"14\" y=\"8\" width=\"10\" height=\"18\" rx=\"4\" fill=\"#fff\" opacity=\"0.12\"/>\n                  <g class=\"pulse\" />\n                </g>\n              </svg>\n            </div>\n            <h3 id=\"a-atomic\">Atomicity</h3>\n            <p>All-or-nothing: a transaction either fully completes or is fully rolled back. No partial results.</p>\n            <div class=\"desc\">Atomicity ensures a transaction is indivisible — either everything is applied, or nothing changes.</div>\n          </article>\n\n          <!-- Pillar: Consistency -->\n          <article class=\"pillar\" data-key=\"consistency\" id=\"p-consistency\" aria-labelledby=\"a-consistency\">\n            <div class=\"icon-wrap\">\n              <svg class=\"icon\" viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n                <defs>\n                  <linearGradient id=\"cg1\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#6ee7b7\"/>\n                    <stop offset=\"1\" stop-color=\"#00d4ff\"/>\n                  </linearGradient>\n                </defs>\n                <rect x=\"6\" y=\"6\" width=\"52\" height=\"52\" rx=\"12\" fill=\"rgba(255,255,255,0.02)\"/>\n                <g transform=\"translate(9,9)\">\n                  <rect x=\"2\" y=\"6\" width=\"36\" height=\"22\" rx=\"3\" fill=\"url(#cg1)\" opacity=\"0.12\"/>\n                  <path d=\"M6 18 L14 26 L30 10\" stroke=\"#fff\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n                  <g class=\"pulse\" />\n                </g>\n              </svg>\n            </div>\n            <h3 id=\"a-consistency\">Consistency</h3>\n            <p>Preserves rules & constraints: transactions move the system from one valid state to another.</p>\n            <div class=\"desc\">Consistency enforces integrity — constraints, invariants, and rules remain true before and after a transaction.</div>\n          </article>\n\n          <!-- Pillar: Isolation -->\n          <article class=\"pillar\" data-key=\"isolation\" id=\"p-isolation\" aria-labelledby=\"a-isolation\">\n            <div class=\"icon-wrap\">\n              <svg class=\"icon\" viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n                <defs>\n                  <linearGradient id=\"ig1\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#7c5cff\"/>\n                    <stop offset=\"1\" stop-color=\"#6ee7b7\"/>\n                  </linearGradient>\n                </defs>\n                <rect x=\"6\" y=\"6\" width=\"52\" height=\"52\" rx=\"12\" fill=\"rgba(255,255,255,0.02)\"/>\n                <g transform=\"translate(10,10)\">\n                  <rect x=\"0\" y=\"0\" width=\"12\" height=\"28\" rx=\"2\" fill=\"rgba(255,255,255,0.06)\" />\n                  <rect x=\"16\" y=\"0\" width=\"12\" height=\"28\" rx=\"2\" fill=\"rgba(255,255,255,0.06)\" />\n                  <rect x=\"32\" y=\"0\" width=\"12\" height=\"28\" rx=\"2\" fill=\"rgba(255,255,255,0.06)\" />\n                  <g class=\"pulse\" />\n                </g>\n              </svg>\n            </div>\n            <h3 id=\"a-isolation\">Isolation</h3>\n            <p>Concurrent transactions don’t interfere with each other — each behaves as if it's alone.</p>\n            <div class=\"desc\">Isolation prevents interference: intermediate states of transactions are hidden from others.</div>\n          </article>\n\n          <!-- Pillar: Durability -->\n          <article class=\"pillar\" data-key=\"durability\" id=\"p-durability\" aria-labelledby=\"a-durability\">\n            <div class=\"icon-wrap\">\n              <svg class=\"icon\" viewBox=\"0 0 64 64\" aria-hidden=\"true\">\n                <defs>\n                  <linearGradient id=\"dg1\" x1=\"0\" x2=\"1\">\n                    <stop offset=\"0\" stop-color=\"#ffcc6a\"/>\n                    <stop offset=\"1\" stop-color=\"#6ee7b7\"/>\n                  </linearGradient>\n                </defs>\n                <rect x=\"6\" y=\"6\" width=\"52\" height=\"52\" rx=\"12\" fill=\"rgba(255,255,255,0.02)\"/>\n                <g transform=\"translate(9,9)\">\n                  <rect x=\"4\" y=\"8\" width=\"28\" height=\"12\" rx=\"2\" fill=\"rgba(255,255,255,0.06)\"/>\n                  <rect x=\"2\" y=\"22\" width=\"36\" height=\"6\" rx=\"3\" fill=\"rgba(255,255,255,0.04)\"/>\n                  <circle cx=\"30\" cy=\"12\" r=\"4\" fill=\"url(#dg1)\"/>\n                  <g class=\"pulse\" />\n                </g>\n              </svg>\n            </div>\n            <h3 id=\"a-durability\">Durability</h3>\n            <p>Once committed, the effects are permanent — changes survive crashes and failures.</p>\n            <div class=\"desc\">Durability guarantees persistence — committed transactions are safely recorded.</div>\n          </article>\n\n        </div>\n\n        <!-- floating token that moves across the path -->\n        <div class=\"token\" id=\"token\" role=\"img\" aria-label=\"Transaction token\">TX</div>\n      </div>\n\n      <div class=\"controls\" role=\"toolbar\" aria-label=\"Animation controls\">\n        <button class=\"btn\" id=\"playBtn\" aria-pressed=\"false\" title=\"Play/Pause animation\">\n          <span class=\"dot\" id=\"statusDot\" style=\"box-shadow: 0 6px 18px rgba(124,92,255,0.28)\"></span>\n          <span id=\"playLabel\">Play</span>\n        </button>\n        <button class=\"btn secondary\" id=\"replayBtn\" title=\"Restart animation\">Replay</button>\n      </div>\n\n      <div class=\"footer\">Tip: Hover a pillar for a quick highlight. The animation demonstrates how a single transaction interacts with each property in order.</div>\n    </section>\n  </main>\n\n<script>\n(() => {\n  const playBtn = document.getElementById('playBtn');\n  const replayBtn = document.getElementById('replayBtn');\n  const token = document.getElementById('token');\n  const pillars = Array.from(document.querySelectorAll('.pillar'));\n  const playLabel = document.getElementById('playLabel');\n  const statusDot = document.getElementById('statusDot');\n\n  // Positions: compute token positions across the path relative to the container\n  function computePositions(){\n    const container = document.querySelector('.pillars');\n    const rect = container.getBoundingClientRect();\n    const count = pillars.length;\n    // get center x of each pillar card\n    const positions = pillars.map(p => {\n      const r = p.getBoundingClientRect();\n      return {\n        x: (r.left - rect.left) + (r.width/2),\n        y: (r.top - rect.top) + 10 // slight top offset\n      };\n    });\n    return {rect, positions};\n  }\n\n  let timeline = null;\n  let running = false;\n  let progress = 0;\n  let startTime = null;\n  let duration = 5200; // total ms\n\n  // animation steps and triggers for each pillar\n  function resetVisuals(){\n    pillars.forEach(p=>{\n      p.classList.remove('active','success','warn','show-desc');\n    });\n    token.classList.remove('glow');\n    token.style.transition = 'none';\n  }\n\n  function animateOnce(){\n    const info = computePositions();\n    const pos = info.positions;\n    resetVisuals();\n\n    // Sequence: token travels to each pillar with stops\n    const stops = [\n      {idx:0, t:0.08, action: atomicAnim},\n      {idx:1, t:0.33, action: consistencyAnim},\n      {idx:2, t:0.60, action: isolationAnim},\n      {idx:3, t:0.80, action: durabilityAnim}\n    ];\n\n    // move token along with easing\n    const ease = t => (--t)*t*t+1; // easeOutCubic-ish\n    const total = duration;\n    startTime = performance.now();\n\n    token.style.transition = ''; // ensure css transitions apply\n    function raf(now){\n      if(!running) return;\n      const elapsed = now - startTime;\n      const clamped = Math.min(elapsed, total);\n      const p = clamped/total;\n      // Interpolate position across full path (linear in stops)\n      // find which segment\n      let segStartPx = pos[0].x;\n      let segEndPx = pos[pos.length-1].x;\n      let x = segStartPx + (segEndPx - segStartPx) * ease(p);\n      // y slightly oscillate to give organic movement\n      const yBase = info.rect.top + 36;\n      const y = yBase + Math.sin(p*Math.PI*2)*4;\n      token.style.transform = `translate3d(${Math.round(x)}px, ${Math.round(y)}px, 0) translateX(-50%)`;\n\n      // Trigger stops\n      stops.forEach(s=>{\n        if(!s._fired && p >= s.t){\n          s._fired = true;\n          const pillar = pillars[s.idx];\n          pillar.classList.add('active','show-desc');\n          token.classList.add('glow');\n          // run associated micro animation\n          s.action(pillar);\n          // clear after a short while\n          setTimeout(()=> {\n            pillar.classList.remove('active');\n            pillar.classList.add('success');\n            pillar.classList.remove('show-desc');\n          }, 1400);\n        }\n      });\n\n      if(elapsed < total){\n        timeline = requestAnimationFrame(raf);\n      } else {\n        // finalize at rightmost pillar\n        token.classList.add('glow');\n        pillars.forEach((p,i)=>p.classList.remove('active'));\n        setTimeout(()=> { running=false; playBtn.setAttribute('aria-pressed','false'); playLabel.textContent='Play'; statusDot.style.boxShadow='0 6px 18px rgba(124,92,255,0.28)'; }, 700);\n      }\n    }\n\n    timeline = requestAnimationFrame(raf);\n  }\n\n  // micro animations for each property\n  function atomicAnim(pillar){\n    // flash to indicate commit/rollback. We'll alternate success/fail visually once.\n    pillar.classList.add('warn');\n    setTimeout(()=> pillar.classList.remove('warn'), 800);\n  }\n\n  function consistencyAnim(pillar){\n    // show checks\n    const check = document.createElement('div');\n    check.style.position='absolute';\n    check.style.right='8px';\n    check.style.top='8px';\n    check.style.width='22px';\n    check.style.height='22px';\n    check.style.borderRadius='6px';\n    check.style.background = 'linear-gradient(135deg, rgba(110,231,183,0.12), rgba(0,212,255,0.06))';\n    check.style.display='flex';\n    check.style.alignItems='center';\n    check.style.justifyContent='center';\n    check.style.color='#eafff4';\n    check.style.fontWeight='700';\n    check.style.fontSize='12px';\n    check.textContent='✓';\n    check.style.opacity=0;\n    check.style.transition='opacity 320ms, transform 400ms cubic-bezier(.2,.9,.2,1)';\n    pillar.appendChild(check);\n    requestAnimationFrame(()=>{ check.style.opacity=1; check.style.transform='translateY(-4px)' });\n    setTimeout(()=>{ check.style.opacity=0; check.style.transform='translateY(0)'; }, 1200);\n    setTimeout(()=> pillar.removeChild(check), 1600);\n  }\n\n  function isolationAnim(pillar){\n    // spawn two small tokens behind; they pass without merging\n    const lane = document.createElement('div');\n    lane.style.position='absolute';\n    lane.style.left='12px';\n    lane.style.bottom='12px';\n    lane.style.width='calc(100% - 24px)';\n    lane.style.height='8px';\n    lane.style.pointerEvents='none';\n    pillar.appendChild(lane);\n\n    const t1 = document.createElement('div');\n    const t2 = document.createElement('div');\n    [t1,t2].forEach((t,i)=>{\n      t.style.position='absolute';\n      t.style.width='10px'; t.style.height='10px'; t.style.borderRadius='50%';\n      t.style.background = i===0 ? 'linear-gradient(135deg,#7c5cff,#00d4ff)' : 'linear-gradient(135deg,#6ee7b7,#00d4ff)';\n      t.style.left = i===0 ? '-6px' : '-20px';\n      t.style.opacity = '0.95';\n      t.style.boxShadow = '0 6px 16px rgba(6,10,30,0.5)';\n      lane.appendChild(t);\n    });\n\n    // animate across the lane with slight z-index interplay\n    t1.animate([{left:'-10px'},{left:'80%'}],{duration:900, easing:'cubic-bezier(.2,.9,.2,1)'});\n    t2.animate([{left:'-24px'},{left:'100%'}],{duration:1200, easing:'cubic-bezier(.2,.9,.2,1)'});\n    setTimeout(()=> pillar.removeChild(lane), 1400);\n  }\n\n  function durabilityAnim(pillar){\n    // deposit effect: small archive shot into vault\n    const vaultGlow = document.createElement('div');\n    vaultGlow.style.position='absolute';\n    vaultGlow.style.left='50%';\n    vaultGlow.style.top='8px';\n    vaultGlow.style.transform='translateX(-50%)';\n    vaultGlow.style.width='18px';\n    vaultGlow.style.height='18px';\n    vaultGlow.style.borderRadius='6px';\n    vaultGlow.style.background='linear-gradient(135deg,#ffcc6a,#6ee7b7)';\n    vaultGlow.style.boxShadow='0 12px 36px rgba(110,231,183,0.18)';\n    vaultGlow.style.opacity='0';\n    vaultGlow.style.transition='opacity 260ms, transform 260ms';\n    pillar.appendChild(vaultGlow);\n    setTimeout(()=> { vaultGlow.style.opacity='1'; vaultGlow.style.transform='translateX(-50%) translateY(-3px)'; }, 30);\n    setTimeout(()=> { vaultGlow.style.opacity='0'; vaultGlow.style.transform='translateX(-50%) translateY(-10px)'; }, 900);\n    setTimeout(()=> pillar.removeChild(vaultGlow), 1200);\n  }\n\n  // Public controls\n  playBtn.addEventListener('click', ()=>{\n    if(running){\n      // pause\n      running = false;\n      playBtn.setAttribute('aria-pressed','false');\n      playLabel.textContent = 'Play';\n      statusDot.style.boxShadow = '0 6px 18px rgba(120,120,140,0.12)';\n      if(timeline) cancelAnimationFrame(timeline);\n    } else {\n      // start fresh\n      running = true;\n      // reset fired flags\n      document.querySelectorAll('.pillar').forEach(p => { p.classList.remove('success','warn','active','show-desc') });\n      document.querySelectorAll('[data-key]').forEach(el=> el._flag = false);\n      document.querySelectorAll('.pillar').forEach((p)=> p._flag=false );\n      document.querySelectorAll('.pillar').forEach((p)=> { p._fired = false; });\n      playBtn.setAttribute('aria-pressed','true');\n      playLabel.textContent = 'Pause';\n      statusDot.style.boxShadow = '0 12px 36px rgba(110,231,183,0.18)';\n      // small prep transition\n      token.style.transition = 'transform 420ms cubic-bezier(.2,.9,.2,1), box-shadow 260ms';\n      // ensure token starts leftmost\n      const info = computePositions();\n      token.style.transform = `translate3d(${Math.round(info.positions[0].x)}px, ${Math.round(info.rect.top + 36)}px, 0) translateX(-50%)`;\n      // slight delay then animate\n      setTimeout(()=> animateOnce(), 120);\n    }\n  });\n\n  replayBtn.addEventListener('click', ()=>{\n    // restart: stop and immediately restart\n    if(timeline) cancelAnimationFrame(timeline);\n    running=false;\n    setTimeout(()=> {\n      playBtn.click();\n    }, 60);\n  });\n\n  // responsive: reposition token to start\n  function layoutInit(){\n    const info = computePositions();\n    token.style.transition = 'none';\n    token.style.transform = `translate3d(${Math.round(info.positions[0].x)}px, ${Math.round(info.rect.top + 36)}px, 0) translateX(-50%)`;\n    setTimeout(()=> token.style.transition = '', 50);\n  }\n\n  window.addEventListener('resize', layoutInit);\n  window.addEventListener('load', layoutInit);\n\n  // Hover effects: reveal desc quickly (very limited interactivity)\n  pillars.forEach(p=>{\n    p.addEventListener('mouseenter', ()=>{\n      p.classList.add('show-desc');\n    });\n    p.addEventListener('mouseleave', ()=>{\n      p.classList.remove('show-desc');\n    });\n  });\n\n  // initialize position on startup\n  layoutInit();\n})();\n</script>\n</body>\n</html>"
