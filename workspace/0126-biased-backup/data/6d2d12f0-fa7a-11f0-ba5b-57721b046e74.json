  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Interactive Binary Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .controls {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        canvas {\n            border: 1px solid #000;\n            margin-top: 20px;\n        }\n        input, button, select {\n            margin: 5px;\n        }\n        .node-info {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interactive Binary Tree</h1>\n    <div class=\"container\">\n        <div class=\"controls\">\n            <div class=\"control-group\">\n                <h3>Tree Construction</h3>\n                <input type=\"number\" id=\"insertValue\" placeholder=\"Enter value\">\n                <button onclick=\"insertNode()\">Insert Node</button>\n                <button onclick=\"deleteNode()\">Delete Node</button>\n                <button onclick=\"generateRandomTree()\">Random Tree</button>\n                <button onclick=\"clearTree()\">Clear Tree</button>\n            </div>\n\n            <div class=\"control-group\">\n                <h3>Traversal</h3>\n                <button onclick=\"traverse('inorder')\">Inorder</button>\n                <button onclick=\"traverse('preorder')\">Preorder</button>\n                <button onclick=\"traverse('postorder')\">Postorder</button>\n                <button onclick=\"traverse('levelorder')\">Level Order</button>\n            </div>\n\n            <div class=\"control-group\">\n                <h3>Tree Properties</h3>\n                <button onclick=\"showHeight()\">Show Height</button>\n                <button onclick=\"showSize()\">Show Size</button>\n                <button onclick=\"showMinMax()\">Show Min/Max</button>\n                <button onclick=\"checkBalanced()\">Check Balanced</button>\n                <button onclick=\"checkBST()\">Check BST</button>\n            </div>\n\n            <div class=\"control-group\">\n                <h3>Visual Settings</h3>\n                <label>Node Radius: <input type=\"range\" id=\"nodeSize\" min=\"10\" max=\"50\" value=\"20\" onchange=\"redrawTree()\"></label>\n                <label>Level Spacing: <input type=\"range\" id=\"levelSpacing\" min=\"30\" max=\"150\" value=\"80\" onchange=\"redrawTree()\"></label>\n                <label>Horizontal Spacing: <input type=\"range\" id=\"horizontalSpacing\" min=\"20\" max=\"100\" value=\"50\" onchange=\"redrawTree()\"></label>\n                <select id=\"treeStyle\" onchange=\"redrawTree()\">\n                    <option value=\"standard\">Standard</option>\n                    <option value=\"compact\">Compact</option>\n                    <option value=\"wide\">Wide</option>\n                </select>\n            </div>\n\n            <div class=\"control-group\">\n                <h3>Search & Path</h3>\n                <input type=\"number\" id=\"searchValue\" placeholder=\"Enter value\">\n                <button onclick=\"findNode()\">Find Node</button>\n                <button onclick=\"findPath()\">Find Path to Node</button>\n                <button onclick=\"findLCA()\">Find Lowest Common Ancestor</button>\n            </div>\n        </div>\n\n        <canvas id=\"treeCanvas\" width=\"1000\" height=\"600\"></canvas>\n\n        <div class=\"node-info\" id=\"nodeInfo\">\n            Node information will appear here\n        </div>\n\n        <div class=\"control-group\">\n            <h3>Tree Operations</h3>\n            <button onclick=\"mirrorTree()\">Mirror Tree</button>\n            <button onclick=\"invertTree()\">Invert Tree</button>\n            <button onclick=\"doubleTree()\">Double Tree</button>\n            <button onclick=\"convertToBST()\">Convert to BST</button>\n            <div>\n                <input type=\"number\" id=\"kthValue\" placeholder=\"Enter k\">\n                <button onclick=\"findKthSmallest()\">Find k-th Smallest</button>\n                <button onclick=\"findKthLargest()\">Find k-th Largest</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // Binary Tree implementation\n        class TreeNode {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n                this.x = 0;\n                this.y = 0;\n                this.highlighted = false;\n                this.visited = false;\n            }\n        }\n\n        let root = null;\n        const canvas = document.getElementById('treeCanvas');\n        const ctx = canvas.getContext('2d');\n        let traversalResult = [];\n        let traversalIndex = 0;\n        let traversalInterval = null;\n\n        // Tree operations\n        function insertNode() {\n            const value = parseInt(document.getElementById('insertValue').value);\n            if (isNaN(value)) return;\n            \n            if (!root) {\n                root = new TreeNode(value);\n            } else {\n                insertNodeRecursive(root, value);\n            }\n            redrawTree();\n            document.getElementById('insertValue').value = '';\n        }\n\n        function insertNodeRecursive(node, value) {\n            if (value < node.value) {\n                if (node.left === null) {\n                    node.left = new TreeNode(value);\n                } else {\n                    insertNodeRecursive(node.left, value);\n                }\n            } else {\n                if (node.right === null) {\n                    node.right = new TreeNode(value);\n                } else {\n                    insertNodeRecursive(node.right, value);\n                }\n            }\n        }\n\n        function deleteNode() {\n            const value = parseInt(document.getElementById('insertValue').value);\n            if (isNaN(value)) return;\n            \n            root = deleteNodeRecursive(root, value);\n            redrawTree();\n            document.getElementById('insertValue').value = '';\n        }\n\n        function deleteNodeRecursive(node, value) {\n            if (node === null) return null;\n            \n            if (value < node.value) {\n                node.left = deleteNodeRecursive(node.left, value);\n            } else if (value > node.value) {\n                node.right = deleteNodeRecursive(node.right, value);\n            } else {\n                if (node.left === null) return node.right;\n                if (node.right === null) return node.left;\n                \n                const minNode = findMin(node.right);\n                node.value = minNode.value;\n                node.right = deleteNodeRecursive(node.right, minNode.value);\n            }\n            return node;\n        }\n\n        function findMin(node) {\n            while (node.left !== null) node = node.left;\n            return node;\n        }\n\n        function generateRandomTree() {\n            clearTree();\n            const nodeCount = Math.floor(Math.random() * 15) + 5;\n            for (let i = 0; i < nodeCount; i++) {\n                const value = Math.floor(Math.random() * 100);\n                if (!root) {\n                    root = new TreeNode(value);\n                } else {\n                    insertNodeRecursive(root, value);\n                }\n            }\n            redrawTree();\n        }\n\n        function clearTree() {\n            root = null;\n            clearTraversal();\n            redrawTree();\n        }\n\n        // Traversals\n        function traverse(type) {\n            clearTraversal();\n            traversalResult = [];\n            \n            switch (type) {\n                case 'inorder':\n                    inorderTraversal(root);\n                    break;\n                case 'preorder':\n                    preorderTraversal(root);\n                    break;\n                case 'postorder':\n                    postorderTraversal(root);\n                    break;\n                case 'levelorder':\n                    levelOrderTraversal(root);\n                    break;\n            }\n            \n            startTraversalAnimation();\n        }\n\n        function inorderTraversal(node) {\n            if (node === null) return;\n            inorderTraversal(node.left);\n            traversalResult.push(node);\n            inorderTraversal(node.right);\n        }\n\n        function preorderTraversal(node) {\n            if (node === null) return;\n            traversalResult.push(node);\n            preorderTraversal(node.left);\n            preorderTraversal(node.right);\n        }\n\n        function postorderTraversal(node) {\n            if (node === null) return;\n            postorderTraversal(node.left);\n            postorderTraversal(node.right);\n            traversalResult.push(node);\n        }\n\n        function levelOrderTraversal(node) {\n            if (node === null) return;\n            const queue = [node];\n            while (queue.length > 0) {\n                const current = queue.shift();\n                traversalResult.push(current);\n                if (current.left) queue.push(current.left);\n                if (current.right) queue.push(current.right);\n            }\n        }\n\n        function startTraversalAnimation() {\n            if (traversalInterval) clearInterval(traversalInterval);\n            \n            traversalIndex = 0;\n            traversalInterval = setInterval(() => {\n                if (traversalIndex >= traversalResult.length) {\n                    clearTraversal();\n                    return;\n                }\n                \n                // Reset all nodes\n                resetNodeHighlights();\n                \n                // Highlight current node\n                const node = traversalResult[traversalIndex];\n                node.highlighted = true;\n                document.getElementById('nodeInfo').textContent = `Traversal Step ${traversalIndex + 1}/${traversalResult.length}: Node ${node.value}`;\n                \n                redrawTree();\n                traversalIndex++;\n            }, 800);\n        }\n\n        function clearTraversal() {\n            if (traversalInterval) clearInterval(traversalInterval);\n            traversalInterval = null;\n            traversalResult = [];\n            traversalIndex = 0;\n            resetNodeHighlights();\n            document.getElementById('nodeInfo').textContent = 'Node information will appear here';\n            redrawTree();\n        }\n\n        function resetNodeHighlights() {\n            function reset(node) {\n                if (node === null) return;\n                node.highlighted = false;\n                node.visited = false;\n                reset(node.left);\n                reset(node.right);\n            }\n            reset(root);\n        }\n\n        // Tree properties\n        function showHeight() {\n            const height = calculateHeight(root);\n            document.getElementById('nodeInfo').textContent = `Tree height: ${height}`;\n        }\n\n        function calculateHeight(node) {\n            if (node === null) return 0;\n            return 1 + Math.max(calculateHeight(node.left), calculateHeight(node.right));\n        }\n\n        function showSize() {\n            const size = calculateSize(root);\n            document.getElementById('nodeInfo').textContent = `Tree size: ${size} nodes`;\n        }\n\n        function calculateSize(node) {\n            if (node === null) return 0;\n            return 1 + calculateSize(node.left) + calculateSize(node.right);\n        }\n\n        function showMinMax() {\n            if (!root) {\n                document.getElementById('nodeInfo').textContent = 'Tree is empty';\n                return;\n            }\n            \n            const min = findMinValue(root);\n            const max = findMaxValue(root);\n            document.getElementById('nodeInfo').textContent = `Min value: ${min}, Max value: ${max}`;\n        }\n\n        function findMinValue(node) {\n            while (node.left !== null) node = node.left;\n            return node.value;\n        }\n\n        function findMaxValue(node) {\n            while (node.right !== null) node = node.right;\n            return node.value;\n        }\n\n        function checkBalanced() {\n            const isBalanced = isTreeBalanced(root);\n            document.getElementById('nodeInfo').textContent = isBalanced ? \n                'Tree is balanced' : 'Tree is not balanced';\n        }\n\n        function isTreeBalanced(node) {\n            if (node === null) return true;\n            \n            const leftHeight = calculateHeight(node.left);\n            const rightHeight = calculateHeight(node.right);\n            \n            return Math.abs(leftHeight - rightHeight) <= 1 && \n                   isTreeBalanced(node.left) && \n                   isTreeBalanced(node.right);\n        }\n\n        function checkBST() {\n            const isBST = isBinarySearchTree(root);\n            document.getElementById('nodeInfo').textContent = isBST ? \n                'Tree is a Binary Search Tree' : 'Tree is NOT a Binary Search Tree';\n        }\n\n        function isBinarySearchTree(node, min = -Infinity, max = Infinity) {\n            if (node === null) return true;\n            \n            if (node.value <= min || node.value >= max) return false;\n            \n            return isBinarySearchTree(node.left, min, node.value) && \n                   isBinarySearchTree(node.right, node.value, max);\n        }\n\n        // Search operations\n        function findNode() {\n            const value = parseInt(document.getElementById('searchValue').value);\n            if (isNaN(value)) return;\n            \n            const node = findNodeRecursive(root, value);\n            if (node) {\n                resetNodeHighlights();\n                node.highlighted = true;\n                redrawTree();\n                document.getElementById('nodeInfo').textContent = `Found node with value ${value}`;\n            } else {\n                document.getElementById('nodeInfo').textContent = `Node with value ${value} not found`;\n            }\n        }\n\n        function findNodeRecursive(node, value) {\n            if (node === null) return null;\n            if (node.value === value) return node;\n            \n            if (value < node.value) {\n                return findNodeRecursive(node.left, value);\n            } else {\n                return findNodeRecursive(node.right, value);\n            }\n        }\n\n        function findPath() {\n            const value = parseInt(document.getElementById('searchValue').value);\n            if (isNaN(value)) return;\n            \n            const path = [];\n            const found = findPathRecursive(root, value, path);\n            \n            if (found) {\n                resetNodeHighlights();\n                path.forEach(node => node.highlighted = true);\n                redrawTree();\n                const pathValues = path.map(node => node.value).join(' → ');\n                document.getElementById('nodeInfo').textContent = `Path to ${value}: ${pathValues}`;\n            } else {\n                document.getElementById('nodeInfo').textContent = `Node with value ${value} not found`;\n            }\n        }\n\n        function findPathRecursive(node, value, path) {\n            if (node === null) return false;\n            \n            path.push(node);\n            \n            if (node.value === value) return true;\n            \n            if (findPathRecursive(node.left, value, path) || \n                findPathRecursive(node.right, value, path)) {\n                return true;\n            }\n            \n            path.pop();\n            return false;\n        }\n\n        function findLCA() {\n            const value1 = parseInt(prompt(\"Enter first node value:\"));\n            const value2 = parseInt(prompt(\"Enter second node value:\"));\n            \n            if (isNaN(value1) || isNaN(value2)) return;\n            \n            const node1 = findNodeRecursive(root, value1);\n            const node2 = findNodeRecursive(root, value2);\n            \n            if (!node1 || !node2) {\n                document.getElementById('nodeInfo').textContent = \n                    `One or both nodes (${value1}, ${value2}) not found`;\n                return;\n            }\n            \n            const lca = findLCARecursive(root, node1, node2);\n            \n            resetNodeHighlights();\n            node1.highlighted = true;\n            node2.highlighted = true;\n            lca.highlighted = true;\n            redrawTree();\n            \n            document.getElementById('nodeInfo').textContent = \n                `Lowest Common Ancestor of ${value1} and ${value2} is ${lca.value}`;\n        }\n\n        function findLCARecursive(node, node1, node2) {\n            if (node === null) return null;\n            if (node === node1 || node === node2) return node;\n            \n            const left = findLCARecursive(node.left, node1, node2);\n            const right = findLCARecursive(node.right, node1, node2);\n            \n            if (left && right) return node;\n            return left ? left : right;\n        }\n\n        // Tree operations\n        function mirrorTree() {\n            mirrorTreeRecursive(root);\n            redrawTree();\n            document.getElementById('nodeInfo').textContent = 'Tree has been mirrored';\n        }\n\n        function mirrorTreeRecursive(node) {\n            if (node === null) return;\n            \n            const temp = node.left;\n            node.left = node.right;\n            node.right = temp;\n            \n            mirrorTreeRecursive(node.left);\n            mirrorTreeRecursive(node.right);\n        }\n\n        function invertTree() {\n            root = invertTreeRecursive(root);\n            redrawTree();\n            document.getElementById('nodeInfo').textContent = 'Tree has been inverted';\n        }\n\n        function invertTreeRecursive(node) {\n            if (node === null) return null;\n            \n            const left = invertTreeRecursive(node.left);\n            const right = invertTreeRecursive(node.right);\n            \n            node.left = right;\n            node.right = left;\n            \n            return node;\n        }\n\n        function doubleTree() {\n            doubleTreeRecursive(root);\n            redrawTree();\n            document.getElementById('nodeInfo').textContent = 'Tree has been doubled';\n        }\n\n        function doubleTreeRecursive(node) {\n            if (node === null) return;\n            \n            doubleTreeRecursive(node.left);\n            doubleTreeRecursive(node.right);\n            \n            const oldLeft = node.left;\n            node.left = new TreeNode(node.value);\n            node.left.left = oldLeft;\n        }\n\n        function convertToBST() {\n            const nodes = [];\n            storeInorder(root, nodes);\n            root = buildBSTFromSortedArray(nodes);\n            redrawTree();\n            document.getElementById('nodeInfo').textContent = 'Tree converted to BST';\n        }\n\n        function storeInorder(node, nodes) {\n            if (node === null) return;\n            storeInorder(node.left, nodes);\n            nodes.push(node.value);\n            storeInorder(node.right, nodes);\n        }\n\n        function buildBSTFromSortedArray(nodes) {\n            return buildBSTFromSortedArrayRecursive(nodes, 0, nodes.length - 1);\n        }\n\n        function buildBSTFromSortedArrayRecursive(nodes, start, end) {\n            if (start > end) return null;\n            \n            const mid = Math.floor((start + end) / 2);\n            const node = new TreeNode(nodes[mid]);\n            \n            node.left = buildBSTFromSortedArrayRecursive(nodes, start, mid - 1);\n            node.right = buildBSTFromSortedArrayRecursive(nodes, mid + 1, end);\n            \n            return node;\n        }\n\n        function findKthSmallest() {\n            const k = parseInt(document.getElementById('kthValue').value);\n            if (isNaN(k)) return;\n            \n            const result = {count: 0, value: null};\n            findKthSmallestRecursive(root, k, result);\n            \n            if (result.value !== null) {\n                const node = findNodeRecursive(root, result.value);\n                if (node) {\n                    resetNodeHighlights();\n                    node.highlighted = true;\n                    redrawTree();\n                }\n                document.getElementById('nodeInfo').textContent = `${k}-th smallest element: ${result.value}`;\n            } else {\n                document.getElementById('nodeInfo').textContent = `Tree has fewer than ${k} nodes`;\n            }\n        }\n\n        function findKthSmallestRecursive(node, k, result) {\n            if (node === null || result.count >= k) return;\n            \n            findKthSmallestRecursive(node.left, k, result);\n            \n            result.count++;\n            if (result.count === k) {\n                result.value = node.value;\n                return;\n            }\n            \n            findKthSmallestRecursive(node.right, k, result);\n        }\n\n        function findKthLargest() {\n            const k = parseInt(document.getElementById('kthValue').value);\n            if (isNaN(k)) return;\n            \n            const size = calculateSize(root);\n            if (k > size) {\n                document.getElementById('nodeInfo').textContent = `Tree has fewer than ${k} nodes`;\n                return;\n            }\n            \n            findKthSmallest(); // Reuse the smallest function with size - k + 1\n            document.getElementById('kthValue').value = size - k + 1;\n        }\n\n        // Drawing functions\n        function redrawTree() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            \n            if (!root) return;\n            \n            const nodeSize = parseInt(document.getElementById('nodeSize').value);\n            const levelSpacing = parseInt(document.getElementById('levelSpacing').value);\n            const horizontalSpacing = parseInt(document.getElementById('horizontalSpacing').value);\n            \n            // Calculate positions\n            calculatePositions(root, canvas.width / 2, 50, levelSpacing, horizontalSpacing);\n            \n            // Draw lines first\n            drawTreeLines(root);\n            \n            // Then draw nodes\n            drawTreeNodes(root, nodeSize);\n        }\n\n        function calculatePositions(node, x, y, levelSpacing, horizontalSpacing) {\n            if (node === null) return;\n            \n            node.x = x;\n            node.y = y;\n            \n            if (node.left) {\n                calculatePositions(node.left, x - horizontalSpacing, y + levelSpacing, levelSpacing, horizontalSpacing / 1.5);\n            }\n            if (node.right) {\n                calculatePositions(node.right, x + horizontalSpacing, y + levelSpacing, levelSpacing, horizontalSpacing / 1.5);\n            }\n        }\n\n        function drawTreeLines(node) {\n            if (node === null) return;\n            \n            if (node.left) {\n                ctx.beginPath();\n                ctx.moveTo(node.x, node.y);\n                ctx.lineTo(node.left.x, node.left.y);\n                ctx.stroke();\n                drawTreeLines(node.left);\n            }\n            \n            if (node.right) {\n                ctx.beginPath();\n                ctx.moveTo(node.x, node.y);\n                ctx.lineTo(node.right.x, node.right.y);\n                ctx.stroke();\n                drawTreeLines(node.right);\n            }\n        }\n\n        function drawTreeNodes(node, nodeSize) {\n            if (node === null) return;\n            \n            // Draw node\n            ctx.beginPath();\n            ctx.arc(node.x, node.y, nodeSize, 0, 2 * Math.PI);\n            \n            if (node.highlighted) {\n                ctx.fillStyle = 'rgba(255, 0, 0, 0.3)';\n                ctx.fill();\n            }\n            \n            ctx.stroke();\n            \n            // Draw value\n            ctx.font = '14px Arial';\n            ctx.textAlign = 'center';\n            ctx.textBaseline = 'middle';\n            ctx.fillStyle = '#000';\n            ctx.fillText(node.value, node.x, node.y);\n            \n            // Recursively draw child nodes\n            drawTreeNodes(node.left, nodeSize);\n            drawTreeNodes(node.right, nodeSize);\n        }\n\n        // Initialize with a small tree\n        function init() {\n            root = new TreeNode(50);\n            root.left = new TreeNode(30);\n            root.right = new TreeNode(70);\n            root.left.left = new TreeNode(20);\n            root.left.right = new TreeNode(40);\n            root.right.left = new TreeNode(60);\n            root.right.right = new TreeNode(80);\n            redrawTree();\n        }\n\n        // Initialize on load\n        window.onload = init;\n    </script>\n</body>\n</html>"
  },
