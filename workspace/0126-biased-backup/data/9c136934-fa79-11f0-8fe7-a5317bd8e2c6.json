  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>B-Tree Interactive Demo</title>\n<style>\n/* Extremely minimal visual design: plain black text on white background, basic elements only. */\nhtml,body { font-family: Arial, sans-serif; margin: 8px; padding: 8px; color: #000; background: #fff; }\ninput, select, button, textarea { font: inherit; margin: 2px; }\n.panel { display:block; margin:6px 0; padding:6px; border:1px solid #000; }\n.controls { display:flex; flex-wrap:wrap; gap:6px; align-items:center; }\n.node { display:inline-block; padding:6px; border:1px solid #000; margin:6px; min-width:40px; text-align:center; }\n.node-children { margin-left:16px; display:flex; flex-wrap:wrap; }\n.small { font-size:12px; }\ntextarea { width:100%; height:80px; }\n#visual { white-space:nowrap; }\nkbd { border:1px solid #000; padding:2px 4px; background:transparent; }\nlegend { font-weight:bold; margin-top:8px; display:block; }\nhr { border: none; border-top: 1px solid #000; margin:6px 0; }\n</style>\n</head>\n<body>\n<h2>B-Tree Interactive Demo</h2>\n\n<div class=\"panel\">\n  <div class=\"controls\">\n    <label>Max children (order m): <input id=\"inputOrder\" type=\"number\" min=\"3\" max=\"10\" value=\"4\" style=\"width:60px\"></label>\n    <label>Initial keys (comma list): <input id=\"inputSeed\" type=\"text\" placeholder=\"e.g. 10,20,5\" style=\"width:200px\"></label>\n    <button id=\"btnCreate\">Create B-Tree</button>\n    <button id=\"btnClear\">Clear Tree</button>\n    <label><input type=\"checkbox\" id=\"chkAutoSort\" checked> Auto-sort inserts</label>\n    <label><input type=\"checkbox\" id=\"chkStepMode\"> Step mode (record snapshots)</label>\n  </div>\n  <div class=\"small\">Notes: Use order m = max children per node. Minimum degree is ceil(m/2).</div>\n</div>\n\n<div class=\"panel\">\n  <div class=\"controls\">\n    <label>Insert key: <input id=\"inputInsert\" type=\"number\" style=\"width:100px\"></label>\n    <button id=\"btnInsert\">Insert</button>\n    <button id=\"btnBulkRandom\">Bulk Random</button>\n    <label>count: <input id=\"inputBulkCount\" type=\"number\" min=\"1\" value=\"10\" style=\"width:60px\"></label>\n    <label>range 0.. <input id=\"inputBulkMax\" type=\"number\" min=\"1\" value=\"100\" style=\"width:80px\"></label>\n    <button id=\"btnSortedSequence\">Sorted Sequence</button>\n    <label>start: <input id=\"inputSeqStart\" type=\"number\" value=\"1\" style=\"width:60px\"></label>\n    <label>step: <input id=\"inputSeqStep\" type=\"number\" value=\"1\" style=\"width:60px\"></label>\n  </div>\n\n  <hr>\n\n  <div class=\"controls\">\n    <label>Delete key: <input id=\"inputDelete\" type=\"number\" style=\"width:100px\"></label>\n    <button id=\"btnDelete\">Delete</button>\n    <button id=\"btnDeleteAll\">Delete All (clear structure)</button>\n    <label>Search key: <input id=\"inputSearch\" type=\"number\" style=\"width:100px\"></label>\n    <button id=\"btnSearch\">Search</button>\n    <label>Traversal: \n      <select id=\"selectTraversal\">\n        <option value=\"inorder\">In-order (sorted)</option>\n        <option value=\"level\">Level-order</option>\n        <option value=\"preorder\">Pre-order</option>\n      </select>\n    </label>\n    <button id=\"btnTraverse\">Traverse</button>\n  </div>\n</div>\n\n<div class=\"panel\">\n  <div class=\"controls\">\n    <button id=\"btnValidate\">Validate B-Tree</button>\n    <button id=\"btnCount\">Count & Height</button>\n    <button id=\"btnExport\">Export JSON</button>\n    <label>Import JSON: <input id=\"fileImport\" type=\"file\" accept=\".json\"></label>\n    <button id=\"btnRestoreSnapshot\">Restore Selected Snapshot</button>\n    <label>Select snapshot index: <input id=\"inputSnapshotIndex\" type=\"number\" min=\"0\" value=\"0\" style=\"width:80px\"></label>\n  </div>\n  <div class=\"small\">You can restore the tree to any recorded snapshot saved during step-mode operations.</div>\n</div>\n\n<div class=\"panel\">\n  <legend>Manual Node Editing and Manual Operations</legend>\n  <div class=\"controls\">\n    <label>Node id: <input id=\"inputNodeId\" type=\"text\" placeholder=\"e.g. 0-0\" style=\"width:120px\"></label>\n    <label>Keys (comma): <input id=\"inputNodeKeys\" type=\"text\" placeholder=\"e.g. 5,10\" style=\"width:220px\"></label>\n    <label><input id=\"chkLeafFlag\" type=\"checkbox\"> Set Leaf</label>\n    <button id=\"btnApplyNodeEdit\">Apply Edit</button>\n    <button id=\"btnForceSplit\">Force Split Node</button>\n    <button id=\"btnForceMerge\">Force Merge Node with Sibling (left)</button>\n    <button id=\"btnBalance\">Try Borrow From Sibling</button>\n  </div>\n  <div class=\"small\">Manual edits bypass B-tree invariants; use Validate to check. Forcing split/merge/balance applies B-tree internal ops using selected node context.</div>\n</div>\n\n<div class=\"panel\">\n  <legend>Step Control & History</legend>\n  <div class=\"controls\">\n    <label><input id=\"chkAutoPlay\" type=\"checkbox\"> Auto-play</label>\n    <label>Speed (ms): <input id=\"inputSpeed\" type=\"range\" min=\"100\" max=\"3000\" value=\"800\" style=\"width:200px\"></label>\n    <button id=\"btnStepPrev\">Step ◀</button>\n    <button id=\"btnStepNext\">Step ▶</button>\n    <button id=\"btnJumpStart\">Jump to Start</button>\n    <button id=\"btnJumpEnd\">Jump to End</button>\n    <button id=\"btnClearHistory\">Clear History</button>\n  </div>\n  <div class=\"small\">History contains snapshots describing each significant operation. Restore any recorded snapshot to the tree using Restore button above.</div>\n</div>\n\n<div class=\"panel\">\n  <legend>Visualization</legend>\n  <div id=\"visual\"></div>\n</div>\n\n<div class=\"panel\">\n  <legend>Inspector / Logs</legend>\n  <div class=\"controls\">\n    <button id=\"btnShowStructure\">Show structure JSON</button>\n    <button id=\"btnShowNodesList\">Show nodes list</button>\n    <button id=\"btnShowLastAction\">Show last action</button>\n    <button id=\"btnClearLog\">Clear Log</button>\n  </div>\n  <textarea id=\"log\" readonly></textarea>\n</div>\n\n<div class=\"panel\">\n  <legend>Snapshots (recorded steps)</legend>\n  <div class=\"controls\">\n    <label>Snapshots count: <span id=\"snapCount\">0</span></label>\n    <label>Current index: <span id=\"snapIndex\">-</span></label>\n    <label>Filter description contains: <input id=\"inputSnapFilter\" type=\"text\" style=\"width:200px\"></label>\n    <button id=\"btnListSnapshots\">List Snapshots</button>\n    <button id=\"btnExportSnapshots\">Export Snapshots JSON</button>\n    <button id=\"btnLoadSnapshots\">Load Snapshots JSON</button>\n    <input id=\"fileLoadSnapshots\" type=\"file\" accept=\".json\" style=\"display:none\">\n  </div>\n  <div id=\"snapList\" class=\"small\"></div>\n</div>\n\n<script>\n/*\n  B-Tree interactive demo\n  - Implements general B-Tree with order m (max children).\n  - Records snapshots of tree state and actions when \"Step mode\" is on.\n  - Provides many interactive controls for exploring behaviors.\n*/\n\n/* ----- Utility helpers ----- */\nfunction log(s) {\n  const ta = document.getElementById('log');\n  ta.value = (new Date()).toLocaleTimeString() + ' - ' + s + '\\\\n' + ta.value;\n}\nfunction deepClone(obj) {\n  return JSON.parse(JSON.stringify(obj));\n}\nfunction uid() { return Math.random().toString(36).slice(2,9); }\n\n/* ----- B-Tree Implementation ----- */\nclass BTreeNode {\n  constructor(keys = [], children = [], isLeaf = true) {\n    this.keys = keys; // array of numbers\n    this.children = children; // array of BTreeNode\n    this.isLeaf = isLeaf;\n    this.id = uid(); // unique id for reference\n  }\n}\n\nclass BTree {\n  constructor(order = 4) {\n    if (order < 3) order = 3;\n    this.order = order; // max children\n    this.minChildren = Math.ceil(order / 2);\n    this.minKeys = this.minChildren - 1;\n    this.maxKeys = order - 1;\n    this.root = new BTreeNode([], [], true);\n  }\n\n  // Utility find index of key or child path\n  findKeyIndex(node, key) {\n    let i = 0;\n    while (i < node.keys.length && key > node.keys[i]) i++;\n    return i;\n  }\n\n  // Search returns {node, index, path}\n  search(key) {\n    let path = [];\n    let node = this.root;\n    while (node) {\n      let i = this.findKeyIndex(node, key);\n      path.push({nodeId: node.id, nodeKeys: node.keys.slice()});\n      if (i < node.keys.length && node.keys[i] === key) {\n        return {found: true, node, index: i, path};\n      } else if (node.isLeaf) {\n        return {found: false, node, index: i, path};\n      } else {\n        node = node.children[i];\n      }\n    }\n    return {found: false, node: null, index: -1, path};\n  }\n\n  // Split child y of node x at index i: y has maxKeys, split into two nodes\n  splitChild(x, i) {\n    let y = x.children[i];\n    const t = this.minChildren;\n    // new node z will have keys from y.keys[t .. end]\n    const zKeys = y.keys.slice(t);\n    const zChildren = y.isLeaf ? [] : y.children.slice(t);\n    const z = new BTreeNode(zKeys, zChildren, y.isLeaf);\n    // reduce y\n    const median = y.keys[t - 1];\n    y.keys = y.keys.slice(0, t - 1);\n    if (!y.isLeaf) {\n      y.children = y.children.slice(0, t);\n    }\n    // insert median into x.keys at i\n    x.keys.splice(i, 0, median);\n    x.children.splice(i + 1, 0, z);\n    return {y, z, median, parent: x};\n  }\n\n  // Insert key into tree (non-step recording; snapshotting handled externally)\n  insert(key) {\n    if (typeof key !== 'number' || Number.isNaN(key)) {\n      throw new Error('Key must be a number');\n    }\n    const r = this.root;\n    if (r.keys.length === this.maxKeys) {\n      // root full -> split\n      const s = new BTreeNode([], [r], false);\n      this.root = s;\n      this.splitChild(s, 0);\n      this._insertNonFull(s, key);\n    } else {\n      this._insertNonFull(r, key);\n    }\n  }\n\n  _insertNonFull(node, key) {\n    let i = node.keys.length - 1;\n    if (node.isLeaf) {\n      // insert key into keys keeping sorted order\n      node.keys.splice(this.findKeyIndex(node, key), 0, key);\n      return;\n    } else {\n      // find child\n      i = this.findKeyIndex(node, key);\n      const child = node.children[i];\n      if (child.keys.length === this.maxKeys) {\n        // split child then determine which child to go down\n        this.splitChild(node, i);\n        if (key > node.keys[i]) i++;\n      }\n      this._insertNonFull(node.children[i], key);\n    }\n  }\n\n  // Traversals\n  inorder() {\n    const res = [];\n    function traverse(node) {\n      if (!node) return;\n      for (let i = 0; i < node.keys.length; i++) {\n        if (!node.isLeaf) traverse(node.children[i]);\n        res.push(node.keys[i]);\n      }\n      if (!node.isLeaf) traverse(node.children[node.keys.length]);\n    }\n    traverse(this.root);\n    return res;\n  }\n\n  preorder() {\n    const res = [];\n    function traverse(node) {\n      if (!node) return;\n      res.push(node.keys.slice());\n      if (!node.isLeaf) {\n        for (let i = 0; i < node.children.length; i++) traverse(node.children[i]);\n      }\n    }\n    traverse(this.root);\n    return res;\n  }\n\n  levelOrder() {\n    const res = [];\n    const q = [this.root];\n    while (q.length) {\n      const node = q.shift();\n      res.push(node.keys.slice());\n      if (!node.isLeaf) q.push(...node.children);\n    }\n    return res;\n  }\n\n  // Deletion based on CLRS algorithm for B-trees\n  delete(key) {\n    if (!this.root) return;\n    this._deleteInternal(this.root, key);\n    // adjust root if has no keys\n    if (this.root.keys.length === 0 && !this.root.isLeaf) {\n      this.root = this.root.children[0];\n    }\n  }\n\n  _deleteInternal(node, key) {\n    const idx = this.findKeyIndex(node, key);\n    // Case 1: Key present in this node\n    if (idx < node.keys.length && node.keys[idx] === key) {\n      if (node.isLeaf) {\n        // simply remove\n        node.keys.splice(idx, 1);\n        return;\n      } else {\n        // internal node\n        const predChild = node.children[idx];\n        const succChild = node.children[idx + 1];\n        if (predChild.keys.length >= this.minChildren) {\n          // find predecessor\n          let cur = predChild;\n          while (!cur.isLeaf) cur = cur.children[cur.children.length - 1];\n          const predKey = cur.keys[cur.keys.length - 1];\n          node.keys[idx] = predKey;\n          this._deleteInternal(predChild, predKey);\n        } else if (succChild.keys.length >= this.minChildren) {\n          // find successor\n          let cur = succChild;\n          while (!cur.isLeaf) cur = cur.children[0];\n          const succKey = cur.keys[0];\n          node.keys[idx] = succKey;\n          this._deleteInternal(succChild, succKey);\n        } else {\n          // merge key and succChild into predChild\n          this._mergeChildren(node, idx);\n          this._deleteInternal(predChild, key);\n        }\n        return;\n      }\n    } else {\n      // Key not present in this node\n      if (node.isLeaf) {\n        // not found\n        return;\n      }\n      let child = node.children[idx];\n      // if child has too few keys, fix\n      if (child.keys.length < this.minChildren) {\n        this._fillChild(node, idx);\n        // maybe merged, so choose proper child again\n        if (idx >= node.children.length) {\n          child = node.children[idx - 1];\n        } else {\n          child = node.children[idx];\n        }\n      }\n      this._deleteInternal(child, key);\n    }\n  }\n\n  _mergeChildren(node, idx) {\n    const child = node.children[idx];\n    const sibling = node.children[idx + 1];\n    const mergeKey = node.keys[idx];\n    // combine: child.keys + [mergeKey] + sibling.keys\n    child.keys.push(mergeKey, ...sibling.keys);\n    if (!child.isLeaf) {\n      child.children.push(...sibling.children);\n    }\n    // remove key from node and remove sibling child\n    node.keys.splice(idx, 1);\n    node.children.splice(idx + 1, 1);\n  }\n\n  _borrowFromPrev(node, idx) {\n    const child = node.children[idx];\n    const sibling = node.children[idx - 1];\n    // shift in one key from sibling\n    child.keys.unshift(node.keys[idx - 1]);\n    if (!child.isLeaf) {\n      child.children.unshift(sibling.children.pop());\n    }\n    node.keys[idx - 1] = sibling.keys.pop();\n  }\n\n  _borrowFromNext(node, idx) {\n    const child = node.children[idx];\n    const sibling = node.children[idx + 1];\n    child.keys.push(node.keys[idx]);\n    if (!child.isLeaf) {\n      child.children.push(sibling.children.shift());\n    }\n    node.keys[idx] = sibling.keys.shift();\n  }\n\n  _fillChild(node, idx) {\n    const child = node.children[idx];\n    if (idx !== 0 && node.children[idx - 1].keys.length >= this.minChildren) {\n      this._borrowFromPrev(node, idx);\n    } else if (idx !== node.children.length - 1 && node.children[idx + 1].keys.length >= this.minChildren) {\n      this._borrowFromNext(node, idx);\n    } else {\n      if (idx !== node.children.length - 1) {\n        this._mergeChildren(node, idx);\n      } else {\n        this._mergeChildren(node, idx - 1);\n      }\n    }\n  }\n\n  // manual operations for user: find sibling left/right\n  findNodeById(id) {\n    let found = null;\n    function traverse(n) {\n      if (!n || found) return;\n      if (n.id === id) { found = n; return; }\n      if (!n.isLeaf) for (let c of n.children) traverse(c);\n    }\n    traverse(this.root);\n    return found;\n  }\n\n  // gather nodes in array with parent info\n  listNodes() {\n    const arr = [];\n    function traverse(node, parent) {\n      arr.push({id: node.id, keys: node.keys.slice(), isLeaf: node.isLeaf, parentId: parent ? parent.id : null});\n      if (!node.isLeaf) for (let c of node.children) traverse(c, node);\n    }\n    traverse(this.root, null);\n    return arr;\n  }\n\n  height() {\n    let h = 0;\n    let node = this.root;\n    while (node) {\n      h++;\n      if (node.isLeaf) break;\n      node = node.children[0];\n    }\n    return h;\n  }\n\n  countNodes() {\n    let n = 0;\n    function traverse(node) {\n      if (!node) return;\n      n++;\n      if (!node.isLeaf) for (let c of node.children) traverse(c);\n    }\n    traverse(this.root);\n    return n;\n  }\n\n  leafCount() {\n    let c = 0;\n    function traverse(node) {\n      if (!node) return;\n      if (node.isLeaf) c++;\n      else for (let ch of node.children) traverse(ch);\n    }\n    traverse(this.root);\n    return c;\n  }\n\n  // Validate B-tree properties and report violations\n  validate() {\n    const issues = [];\n    const t = this.minChildren;\n    const minKeys = this.minKeys;\n    const maxKeys = this.maxKeys;\n\n    function traverse(node) {\n      if (!node) return {min: Infinity, max: -Infinity, height: 1};\n      // keys sorted?\n      for (let i = 1; i < node.keys.length; i++) {\n        if (node.keys[i-1] >= node.keys[i]) issues.push('Keys out of order in node ' + node.id + ' : ' + node.keys.join(','));\n      }\n      // key count constraints (root allowed fewer)\n      if (node !== tree.root) {\n        if (node.keys.length < minKeys) issues.push('Node ' + node.id + ' has too few keys: ' + node.keys.length);\n      } else {\n        // root can have zero keys but must be leaf or have at least 2 children\n        if (node.keys.length === 0 && !node.isLeaf && node.children.length < 2) issues.push('Root with no keys must have 0 or >=2 children');\n      }\n      if (node.keys.length > maxKeys) issues.push('Node ' + node.id + ' has too many keys: ' + node.keys.length);\n      // children count\n      if (!node.isLeaf) {\n        if (node.children.length !== node.keys.length + 1) issues.push('Number of children mismatch in node ' + node.id);\n      }\n      // recursively validate subtrees and key bounds\n      if (node.isLeaf) return {min: node.keys.length ? node.keys[0] : Infinity, max: node.keys.length ? node.keys[node.keys.length-1] : -Infinity, height: 1};\n      let heights = [];\n      for (let i = 0; i < node.children.length; i++) {\n        const ch = node.children[i];\n        const r = traverse(ch);\n        heights.push(r.height);\n        // key bounds: child's max < node.keys[i] for left children\n        if (i < node.keys.length) {\n          if (r.max >= node.keys[i]) issues.push('Key ordering violation: child ' + ch.id + ' max ' + r.max + ' >= parent key ' + node.keys[i]);\n        }\n        if (i > 0) {\n          // previous key < child.min\n          if (r.min <= node.keys[i-1]) issues.push('Key ordering violation: child ' + ch.id + ' min ' + r.min + ' <= parent key ' + node.keys[i-1]);\n        }\n      }\n      // all children heights equal?\n      const allSame = heights.every(h => h === heights[0]);\n      if (!allSame) issues.push('Children heights differ in node ' + node.id + ': ' + heights.join(','));\n      return {min: Infinity, max: -Infinity, height: heights[0] + 1};\n    }\n\n    const tree = this;\n    traverse(this.root);\n    return issues;\n  }\n}\n\n/* ----- Application State ----- */\nconst App = {\n  tree: null,\n  snapshots: [], // {desc, treeJSON}\n  lastAction: null,\n  playingTimer: null\n};\n\n/* ----- UI Wiring ----- */\nfunction readOrder() {\n  const v = parseInt(document.getElementById('inputOrder').value, 10);\n  return Number.isNaN(v) ? 4 : Math.max(3, Math.min(10, v));\n}\n\nfunction createTreeFromSeed(order, seedArr) {\n  const t = new BTree(order);\n  seedArr.forEach(k => {\n    try { t.insert(k); } catch(e) { log('Insert failed: ' + e.message); }\n  });\n  return t;\n}\n\nfunction renderTreeVisual(tree, optHighlightId) {\n  const container = document.getElementById('visual');\n  container.innerHTML = '';\n  if (!tree) { container.textContent = '(empty)'; return; }\n  // render recursively with indentation representing tree shape (plain)\n  function renderNode(node) {\n    const el = document.createElement('div');\n    el.className = 'node';\n    el.dataset.nodeId = node.id;\n    const keysText = node.keys.length ? node.keys.join(' | ') : '(empty)';\n    el.textContent = keysText;\n    // small id\n    const idEl = document.createElement('div');\n    idEl.className = 'small';\n    idEl.textContent = 'id:' + node.id + (node.isLeaf ? ' (leaf)' : '');\n    el.appendChild(idEl);\n    if (!node.isLeaf) {\n      const cwrap = document.createElement('div');\n      cwrap.className = 'node-children';\n      for (const ch of node.children) {\n        const childEl = renderNode(ch);\n        cwrap.appendChild(childEl);\n      }\n      el.appendChild(cwrap);\n    }\n    // add click behavior to populate node id field\n    el.addEventListener('click', function(e) {\n      document.getElementById('inputNodeId').value = node.id;\n      e.stopPropagation();\n    });\n    return el;\n  }\n  container.appendChild(renderNode(tree.root));\n}\n\nfunction updateSnapshotDisplay() {\n  document.getElementById('snapCount').textContent = App.snapshots.length;\n  const idx = App.snapshots._currentIndex;\n  document.getElementById('snapIndex').textContent = (typeof idx === 'number' ? idx : '-');\n  const listEl = document.getElementById('snapList');\n  listEl.textContent = '';\n}\n\nfunction pushSnapshot(desc) {\n  // record deep clone of tree structure\n  if (!App.tree) return;\n  const json = JSON.parse(JSON.stringify(App.tree));\n  App.snapshots.push({desc: String(desc), treeJSON: json, timestamp: (new Date()).toISOString()});\n  App.snapshots._currentIndex = App.snapshots.length - 1;\n  updateSnapshotDisplay();\n  log('Snapshot saved: ' + desc);\n}\n\nfunction saveLastAction(desc) {\n  App.lastAction = {desc, time: (new Date()).toISOString()};\n}\n\nfunction restoreSnapshotAt(index) {\n  if (index < 0 || index >= App.snapshots.length) { log('Invalid snapshot index'); return; }\n  const snap = App.snapshots[index];\n  // load JSON into BTree instance\n  const obj = snap.treeJSON;\n  // reconstruct BTree\n  const tree = new BTree(obj.order || readOrder());\n  function rebuild(nodeObj) {\n    const node = new BTreeNode(nodeObj.keys.slice(), [], nodeObj.isLeaf);\n    node.id = nodeObj.id || uid();\n    if (!node.isLeaf) {\n      node.children = nodeObj.children.map(ch => rebuild(ch));\n    }\n    return node;\n  }\n  tree.root = rebuild(obj.root);\n  tree.order = obj.order || tree.order;\n  tree.minChildren = Math.ceil(tree.order / 2);\n  tree.minKeys = tree.minChildren - 1;\n  tree.maxKeys = tree.order - 1;\n  App.tree = tree;\n  renderTreeVisual(App.tree);\n  log('Restored snapshot ' + index + ': ' + snap.desc);\n  saveLastAction('Restore snapshot #' + index);\n}\n\n/* ----- Control Handlers ----- */\ndocument.getElementById('btnCreate').addEventListener('click', () => {\n  const order = readOrder();\n  const seedStr = document.getElementById('inputSeed').value.trim();\n  const seedArr = seedStr ? seedStr.split(',').map(s => parseInt(s.trim(),10)).filter(x=>!Number.isNaN(x)) : [];\n  App.tree = createTreeFromSeed(order, seedArr);\n  App.tree.order = order;\n  App.tree.minChildren = Math.ceil(order / 2);\n  App.tree.minKeys = App.tree.minChildren - 1;\n  App.tree.maxKeys = order - 1;\n  renderTreeVisual(App.tree);\n  log('Created new B-Tree order=' + order + ' seed=' + JSON.stringify(seedArr));\n  saveLastAction('Create tree');\n  if (document.getElementById('chkStepMode').checked) {\n    pushSnapshot('Initial tree');\n  } else {\n    App.snapshots = [];\n    updateSnapshotDisplay();\n  }\n});\n\ndocument.getElementById('btnClear').addEventListener('click', () => {\n  App.tree = null;\n  renderTreeVisual(null);\n  log('Cleared tree');\n});\n\ndocument.getElementById('btnInsert').addEventListener('click', () => {\n  const val = parseInt(document.getElementById('inputInsert').value,10);\n  if (Number.isNaN(val)) { log('Insert: invalid number'); return; }\n  if (!App.tree) {\n    // create default tree\n    const order = readOrder();\n    App.tree = new BTree(order);\n    App.tree.order = order;\n    App.tree.minChildren = Math.ceil(order / 2);\n    App.tree.minKeys = App.tree.minChildren - 1;\n    App.tree.maxKeys = order - 1;\n  }\n  // if step mode is enabled, we will record snapshots at key moments\n  const step = document.getElementById('chkStepMode').checked;\n  if (step) {\n    // record before\n    pushSnapshot('Before inserting ' + val);\n  }\n  try {\n    App.tree.insert(val);\n    renderTreeVisual(App.tree);\n    log('Inserted ' + val);\n    saveLastAction('Insert ' + val);\n    if (step) pushSnapshot('After inserting ' + val);\n  } catch (e) {\n    log('Insert error: ' + e.message);\n  }\n});\n\ndocument.getElementById('btnBulkRandom').addEventListener('click', () => {\n  const count = parseInt(document.getElementById('inputBulkCount').value,10) || 10;\n  const max = parseInt(document.getElementById('inputBulkMax').value,10) || 100;\n  const arr = [];\n  for (let i=0;i<count;i++) arr.push(Math.floor(Math.random()*max));\n  if (!App.tree) {\n    App.tree = new BTree(readOrder());\n  }\n  const autoSort = document.getElementById('chkAutoSort').checked;\n  const step = document.getElementById('chkStepMode').checked;\n  if (step) pushSnapshot('Before bulk random insert');\n  for (const k of (autoSort ? arr.sort((a,b)=>a-b) : arr)) {\n    try {\n      App.tree.insert(k);\n      if (step) pushSnapshot('Inserted ' + k);\n    } catch(e) {\n      log('Bulk insert error: ' + e.message);\n    }\n  }\n  renderTreeVisual(App.tree);\n  log('Bulk random insert done: [' + arr.join(',') + ']');\n  saveLastAction('Bulk random insert ' + count);\n});\n\ndocument.getElementById('btnSortedSequence').addEventListener('click', () => {\n  const start = parseInt(document.getElementById('inputSeqStart').value,10) || 1;\n  const stepv = parseInt(document.getElementById('inputSeqStep').value,10) || 1;\n  const count = parseInt(document.getElementById('inputBulkCount').value,10) || 10;\n  if (!App.tree) App.tree = new BTree(readOrder());\n  const stepMode = document.getElementById('chkStepMode').checked;\n  if (stepMode) pushSnapshot('Before sorted sequence');\n  let val = start;\n  for (let i=0;i<count;i++) {\n    App.tree.insert(val);\n    if (stepMode) pushSnapshot('Inserted ' + val);\n    val += stepv;\n  }\n  renderTreeVisual(App.tree);\n  log('Inserted sequence starting ' + start + ' step ' + stepv + ' count ' + count);\n  saveLastAction('Sorted sequence insert');\n});\n\ndocument.getElementById('btnDelete').addEventListener('click', () => {\n  const val = parseInt(document.getElementById('inputDelete').value,10);\n  if (Number.isNaN(val) || !App.tree) { log('Delete: invalid or no tree'); return; }\n  const step = document.getElementById('chkStepMode').checked;\n  if (step) pushSnapshot('Before delete ' + val);\n  App.tree.delete(val);\n  renderTreeVisual(App.tree);\n  log('Delete requested for ' + val);\n  saveLastAction('Delete ' + val);\n  if (step) pushSnapshot('After delete ' + val);\n});\n\ndocument.getElementById('btnDeleteAll').addEventListener('click', () => {\n  App.tree = null;\n  renderTreeVisual(null);\n  log('Deleted entire tree');\n});\n\ndocument.getElementById('btnSearch').addEventListener('click', () => {\n  const v = parseInt(document.getElementById('inputSearch').value,10);\n  if (Number.isNaN(v) || !App.tree) { log('Search: invalid or no tree'); return; }\n  const res = App.tree.search(v);\n  if (res.found) {\n    log('Search: found ' + v + ' in node ' + res.node.id + ' at index ' + res.index);\n    // restore tree visualization and indicate selected node by filling node id field\n    document.getElementById('inputNodeId').value = res.node.id;\n  } else {\n    log('Search: ' + v + ' not found. Suggested child id: ' + (res.node ? res.node.id : 'none'));\n    document.getElementById('inputNodeId').value = res.node ? res.node.id : '';\n  }\n  saveLastAction('Search ' + v);\n});\n\ndocument.getElementById('btnTraverse').addEventListener('click', () => {\n  if (!App.tree) { log('No tree'); return; }\n  const type = document.getElementById('selectTraversal').value;\n  let out;\n  if (type === 'inorder') out = App.tree.inorder();\n  else if (type === 'preorder') out = App.tree.preorder();\n  else out = App.tree.levelOrder();\n  log('Traversal ' + type + ': ' + JSON.stringify(out));\n  saveLastAction('Traverse ' + type);\n});\n\ndocument.getElementById('btnValidate').addEventListener('click', () => {\n  if (!App.tree) { log('No tree'); return; }\n  const issues = App.tree.validate();\n  if (issues.length === 0) log('Validation: OK (no issues found)');\n  else {\n    log('Validation: FOUND ' + issues.length + ' issues:\\\\n' + issues.join('\\\\n'));\n  }\n  saveLastAction('Validate');\n});\n\ndocument.getElementById('btnCount').addEventListener('click', () => {\n  if (!App.tree) { log('No tree'); return; }\n  const nodes = App.tree.countNodes();\n  const height = App.tree.height();\n  const leaves = App.tree.leafCount();\n  log('Counts: nodes=' + nodes + ' height=' + height + ' leaves=' + leaves);\n  saveLastAction('Count & height');\n});\n\ndocument.getElementById('btnExport').addEventListener('click', () => {\n  if (!App.tree) { log('No tree'); return; }\n  const data = JSON.stringify(App.tree, null, 2);\n  const blob = new Blob([data], {type: 'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url; a.download = 'btree_export.json';\n  a.click();\n  URL.revokeObjectURL(url);\n  log('Exported tree to JSON');\n});\n\ndocument.getElementById('fileImport').addEventListener('change', (e) => {\n  const f = e.target.files[0];\n  if (!f) return;\n  const reader = new FileReader();\n  reader.onload = function(ev) {\n    try {\n      const obj = JSON.parse(ev.target.result);\n      // rebuild BTree\n      const tree = new BTree(obj.order || readOrder());\n      function rebuild(nodeObj) {\n        const node = new BTreeNode(nodeObj.keys.slice(), [], nodeObj.isLeaf);\n        node.id = nodeObj.id || uid();\n        if (!node.isLeaf) node.children = nodeObj.children.map(ch => rebuild(ch));\n        return node;\n      }\n      tree.root = rebuild(obj.root);\n      tree.order = obj.order || tree.order;\n      tree.minChildren = Math.ceil(tree.order / 2);\n      tree.minKeys = tree.minChildren - 1;\n      tree.maxKeys = tree.order - 1;\n      App.tree = tree;\n      renderTreeVisual(App.tree);\n      log('Imported tree from file');\n    } catch (err) {\n      log('Import error: ' + err.message);\n    }\n  };\n  reader.readAsText(f);\n});\n\n/* Manual node edit handlers */\ndocument.getElementById('btnApplyNodeEdit').addEventListener('click', () => {\n  const id = document.getElementById('inputNodeId').value.trim();\n  if (!id || !App.tree) { log('No node id or no tree'); return; }\n  const node = App.tree.findNodeById(id);\n  if (!node) { log('Node not found: ' + id); return; }\n  const keysStr = document.getElementById('inputNodeKeys').value.trim();\n  const keys = keysStr ? keysStr.split(',').map(s=>parseInt(s.trim(),10)).filter(x=>!Number.isNaN(x)) : [];\n  node.keys = keys;\n  node.isLeaf = document.getElementById('chkLeafFlag').checked;\n  renderTreeVisual(App.tree);\n  log('Applied manual edit to node ' + id);\n  saveLastAction('Manual edit ' + id);\n});\n\ndocument.getElementById('btnForceSplit').addEventListener('click', () => {\n  const id = document.getElementById('inputNodeId').value.trim();\n  if (!id || !App.tree) { log('No node id or no tree'); return; }\n  // find parent and index\n  let parent = null; let parentIndex = -1;\n  function findParent(node, pid) {\n    if (node.isLeaf) return null;\n    for (let i=0;i<node.children.length;i++) {\n      if (node.children[i].id === pid) return {parent: node, index: i};\n      const res = findParent(node.children[i], pid);\n      if (res) return res;\n    }\n    return null;\n  }\n  const res = findParent(App.tree.root, id);\n  if (!res) {\n    log('Cannot force split root without replacing root. Selecting root if id matches root id.');\n    if (App.tree.root.id === id) {\n      // force split root: if root keys exceed max or even otherwise split roughly\n      const root = App.tree.root;\n      const medianIndex = Math.floor(root.keys.length/2);\n      const median = root.keys[medianIndex];\n      const leftKeys = root.keys.slice(0, medianIndex);\n      const rightKeys = root.keys.slice(medianIndex+1);\n      const leftChildren = root.isLeaf ? [] : root.children.slice(0, medianIndex+1);\n      const rightChildren = root.isLeaf ? [] : root.children.slice(medianIndex+1);\n      const left = new BTreeNode(leftKeys, leftChildren, root.isLeaf);\n      const right = new BTreeNode(rightKeys, rightChildren, root.isLeaf);\n      const newRoot = new BTreeNode([median], [left, right], false);\n      App.tree.root = newRoot;\n      renderTreeVisual(App.tree);\n      log('Forced split root into new root with median ' + median);\n      saveLastAction('Force split root');\n      return;\n    }\n    log('Parent not found for node ' + id);\n    return;\n  }\n  parent = res.parent; parentIndex = res.index;\n  const child = parent.children[parentIndex];\n  if (child.keys.length < 2) { log('Child has too few keys to split meaningfully'); return; }\n  // perform split at its median\n  const t = Math.ceil(child.keys.length / 2);\n  const medianIndex = t - 1;\n  const median = child.keys[medianIndex];\n  const leftKeys = child.keys.slice(0, medianIndex);\n  const rightKeys = child.keys.slice(medianIndex+1);\n  const leftChildren = child.isLeaf ? [] : child.children.slice(0, t);\n  const rightChildren = child.isLeaf ? [] : child.children.slice(t);\n  const left = new BTreeNode(leftKeys, leftChildren, child.isLeaf);\n  const right = new BTreeNode(rightKeys, rightChildren, child.isLeaf);\n  parent.keys.splice(parentIndex, 0, median);\n  parent.children.splice(parentIndex, 1, left, right);\n  renderTreeVisual(App.tree);\n  log('Forced split of node ' + id + ' with median ' + median + ' into nodes ' + left.id + ' and ' + right.id);\n  saveLastAction('Force split ' + id);\n});\n\ndocument.getElementById('btnForceMerge').addEventListener('click', () => {\n  const id = document.getElementById('inputNodeId').value.trim();\n  if (!id || !App.tree) { log('No node id or no tree'); return; }\n  // merge with left sibling\n  function findParent(node, pid) {\n    if (node.isLeaf) return null;\n    for (let i=0;i<node.children.length;i++) {\n      if (node.children[i].id === pid) return {parent: node, index: i};\n      const res = findParent(node.children[i], pid);\n      if (res) return res;\n    }\n    return null;\n  }\n  const res = findParent(App.tree.root, id);\n  if (!res) { log('Parent not found or root selected'); return; }\n  const parent = res.parent; const idx = res.index;\n  if (idx === 0) { log('No left sibling to merge with (this is first child)'); return; }\n  const left = parent.children[idx - 1];\n  const cur = parent.children[idx];\n  // merge parent key into left and append cur's keys\n  const mergeKey = parent.keys[idx - 1];\n  left.keys.push(mergeKey, ...cur.keys);\n  if (!left.isLeaf) left.children.push(...cur.children);\n  parent.keys.splice(idx - 1, 1);\n  parent.children.splice(idx, 1);\n  renderTreeVisual(App.tree);\n  log('Merged node ' + cur.id + ' into left sibling ' + left.id + ' using parent key ' + mergeKey);\n  saveLastAction('Force merge ' + id);\n});\n\ndocument.getElementById('btnBalance').addEventListener('click', () => {\n  const id = document.getElementById('inputNodeId').value.trim();\n  if (!id || !App.tree) { log('No node id or no tree'); return; }\n  // attempt to borrow from neighbor siblings if possible\n  function findParent(node, pid) {\n    if (node.isLeaf) return null;\n    for (let i=0;i<node.children.length;i++) {\n      if (node.children[i].id === pid) return {parent: node, index: i};\n      const res = findParent(node.children[i], pid);\n      if (res) return res;\n    }\n    return null;\n  }\n  const res = findParent(App.tree.root, id);\n  if (!res) { log('Parent not found or root selected'); return; }\n  const parent = res.parent; const idx = res.index;\n  const child = parent.children[idx];\n  const t = App.tree.minChildren;\n  if (idx > 0 && parent.children[idx - 1].keys.length >= t) {\n    // borrow from prev\n    App.tree._borrowFromPrev(parent, idx);\n    renderTreeVisual(App.tree);\n    log('Borrowed from previous sibling for node ' + id);\n    saveLastAction('Borrow prev ' + id);\n    return;\n  }\n  if (idx < parent.children.length - 1 && parent.children[idx + 1].keys.length >= t) {\n    App.tree._borrowFromNext(parent, idx);\n    renderTreeVisual(App.tree);\n    log('Borrowed from next sibling for node ' + id);\n    saveLastAction('Borrow next ' + id);\n    return;\n  }\n  log('Cannot borrow: siblings do not have enough keys; consider merging');\n});\n\n/* Snapshot and step controls */\ndocument.getElementById('btnStepNext').addEventListener('click', () => {\n  if (App.snapshots.length === 0) { log('No snapshots'); return; }\n  if (typeof App.snapshots._currentIndex !== 'number') App.snapshots._currentIndex = -1;\n  if (App.snapshots._currentIndex < App.snapshots.length - 1) {\n    App.snapshots._currentIndex++;\n    const s = App.snapshots[App.snapshots._currentIndex];\n    document.getElementById('snapIndex').textContent = App.snapshots._currentIndex;\n    document.getElementById('inputSnapshotIndex').value = App.snapshots._currentIndex;\n    // show snapshot summary\n    log('Snapshot #' + App.snapshots._currentIndex + ': ' + s.desc);\n    // preview snapshot tree visually without modifying App.tree\n    const obj = s.treeJSON;\n    const previewTree = reconstructTreeFromJSON(obj);\n    renderTreeVisual(previewTree);\n  } else {\n    log('Already at last snapshot');\n  }\n});\n\ndocument.getElementById('btnStepPrev').addEventListener('click', () => {\n  if (App.snapshots.length === 0) { log('No snapshots'); return; }\n  if (typeof App.snapshots._currentIndex !== 'number') App.snapshots._currentIndex = App.snapshots.length - 1;\n  if (App.snapshots._currentIndex > 0) {\n    App.snapshots._currentIndex--;\n    const s = App.snapshots[App.snapshots._currentIndex];\n    document.getElementById('snapIndex').textContent = App.snapshots._currentIndex;\n    document.getElementById('inputSnapshotIndex').value = App.snapshots._currentIndex;\n    log('Snapshot #' + App.snapshots._currentIndex + ': ' + s.desc);\n    const previewTree = reconstructTreeFromJSON(s.treeJSON);\n    renderTreeVisual(previewTree);\n  } else {\n    log('Already at first snapshot');\n  }\n});\n\ndocument.getElementById('btnJumpStart').addEventListener('click', () => {\n  if (App.snapshots.length === 0) { log('No snapshots'); return; }\n  App.snapshots._currentIndex = 0;\n  document.getElementById('snapIndex').textContent = 0;\n  const s = App.snapshots[0];\n  renderTreeVisual(reconstructTreeFromJSON(s.treeJSON));\n  log('Jumped to snapshot 0: ' + s.desc);\n});\n\ndocument.getElementById('btnJumpEnd').addEventListener('click', () => {\n  if (App.snapshots.length === 0) { log('No snapshots'); return; }\n  App.snapshots._currentIndex = App.snapshots.length - 1;\n  document.getElementById('snapIndex').textContent = App.snapshots._currentIndex;\n  const s = App.snapshots[App.snapshots._currentIndex];\n  renderTreeVisual(reconstructTreeFromJSON(s.treeJSON));\n  log('Jumped to last snapshot: ' + s.desc);\n});\n\ndocument.getElementById('btnClearHistory').addEventListener('click', () => {\n  App.snapshots = [];\n  App.snapshots._currentIndex = undefined;\n  updateSnapshotDisplay();\n  log('Cleared snapshots history');\n});\n\ndocument.getElementById('chkAutoPlay').addEventListener('change', (e) => {\n  if (e.target.checked) {\n    startAutoPlay();\n  } else stopAutoPlay();\n});\n\nfunction startAutoPlay() {\n  stopAutoPlay();\n  const speed = parseInt(document.getElementById('inputSpeed').value,10) || 800;\n  App.playingTimer = setInterval(() => {\n    const count = App.snapshots.length;\n    if (!count) { stopAutoPlay(); return; }\n    if (typeof App.snapshots._currentIndex !== 'number') App.snapshots._currentIndex = -1;\n    if (App.snapshots._currentIndex < count - 1) {\n      document.getElementById('btnStepNext').click();\n    } else {\n      stopAutoPlay();\n    }\n  }, speed);\n}\n\nfunction stopAutoPlay() {\n  if (App.playingTimer) clearInterval(App.playingTimer);\n  App.playingTimer = null;\n  document.getElementById('chkAutoPlay').checked = false;\n}\n\ndocument.getElementById('inputSpeed').addEventListener('input', () => {\n  if (document.getElementById('chkAutoPlay').checked) startAutoPlay();\n});\n\ndocument.getElementById('btnListSnapshots').addEventListener('click', () => {\n  const filter = document.getElementById('inputSnapFilter').value.trim().toLowerCase();\n  const out = App.snapshots.map((s, i) => i + ': ' + s.desc + ' @ ' + s.timestamp).filter(s => s.toLowerCase().includes(filter));\n  document.getElementById('snapList').textContent = out.length ? out.join('\\\\n') : '(no snapshots)';\n});\n\ndocument.getElementById('btnExportSnapshots').addEventListener('click', () => {\n  const data = JSON.stringify(App.snapshots, null, 2);\n  const blob = new Blob([data], {type:'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url; a.download = 'btree_snapshots.json';\n  a.click();\n  URL.revokeObjectURL(url);\n  log('Exported snapshots JSON');\n});\n\ndocument.getElementById('btnLoadSnapshots').addEventListener('click', () => {\n  document.getElementById('fileLoadSnapshots').click();\n});\n\ndocument.getElementById('fileLoadSnapshots').addEventListener('change', (e) => {\n  const f = e.target.files[0];\n  if (!f) return;\n  const reader = new FileReader();\n  reader.onload = (ev) => {\n    try {\n      const arr = JSON.parse(ev.target.result);\n      if (!Array.isArray(arr)) { log('Invalid snapshots file'); return; }\n      App.snapshots = arr;\n      App.snapshots._currentIndex = arr.length - 1;\n      updateSnapshotDisplay();\n      log('Loaded snapshots, count=' + arr.length);\n    } catch (err) {\n      log('Load snapshots error: ' + err.message);\n    }\n  };\n  reader.readAsText(f);\n});\n\ndocument.getElementById('btnRestoreSnapshot').addEventListener('click', () => {\n  const idx = parseInt(document.getElementById('inputSnapshotIndex').value,10);\n  if (Number.isNaN(idx)) { log('Invalid snapshot index'); return; }\n  restoreSnapshotAt(idx);\n});\n\ndocument.getElementById('btnShowStructure').addEventListener('click', () => {\n  if (!App.tree) { log('No tree'); return; }\n  const s = JSON.stringify(App.tree, null, 2);\n  document.getElementById('log').value = s + '\\\\n' + document.getElementById('log').value;\n  saveLastAction('Show structure');\n});\n\ndocument.getElementById('btnShowNodesList').addEventListener('click', () => {\n  if (!App.tree) { log('No tree'); return; }\n  const list = App.tree.listNodes();\n  document.getElementById('log').value = JSON.stringify(list, null, 2) + '\\\\n' + document.getElementById('log').value;\n  saveLastAction('Show nodes list');\n});\n\ndocument.getElementById('btnShowLastAction').addEventListener('click', () => {\n  if (!App.lastAction) log('No last action recorded');\n  else log('Last action: ' + JSON.stringify(App.lastAction));\n});\n\ndocument.getElementById('btnClearLog').addEventListener('click', () => {\n  document.getElementById('log').value = '';\n});\n\n/* Utility to reconstruct tree instance from JSON snapshot for preview */\nfunction reconstructTreeFromJSON(obj) {\n  if (!obj || !obj.root) return null;\n  const tre = new BTree(obj.order || readOrder());\n  function rebuild(nodeObj) {\n    const node = new BTreeNode(nodeObj.keys.slice(), [], nodeObj.isLeaf);\n    node.id = nodeObj.id || uid();\n    if (!node.isLeaf) node.children = nodeObj.children.map(ch => rebuild(ch));\n    return node;\n  }\n  tre.root = rebuild(obj.root);\n  tre.order = obj.order || tre.order;\n  tre.minChildren = Math.ceil(tre.order / 2);\n  tre.minKeys = tre.minChildren - 1;\n  tre.maxKeys = tre.order - 1;\n  return tre;\n}\n\n/* Initialize: create a default tree */\n(function init() {\n  const order = readOrder();\n  App.tree = new BTree(order);\n  renderTreeVisual(App.tree);\n  log('Initialized demo with empty B-Tree order=' + order);\n})();\n\n</script>\n</body>\n</html>"
