    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Thread Interaction Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        input, button, select { margin: 5px; }\n    </style>\n</head>\n<body>\n\n<h1>Thread Interaction Demo</h1>\n\n<div>\n    <h2>Control Input</h2>\n    <label for=\"textInput\">Type something:</label>\n    <input type=\"text\" id=\"textInput\" placeholder=\"Enter text here\">\n</div>\n\n<div>\n    <h2>Choose an Option</h2>\n    <select id=\"optionsSelect\">\n        <option value=\"none\">Select an option</option>\n        <option value=\"show\">Show Input</option>\n        <option value=\"count\">Count Chars</option>\n        <option value=\"clear\">Clear Input</option>\n    </select>\n    <button id=\"selectOptionButton\">Submit</button>\n</div>\n\n<div>\n    <h2>Character Count</h2>\n    <button id=\"countButton\">Count Characters</button>\n    <span id=\"charCount\">0</span>\n</div>\n\n<div>\n    <h2>Number Slider</h2>\n    <label for=\"numberSlider\">Choose a number:</label>\n    <input type=\"range\" id=\"numberSlider\" min=\"1\" max=\"100\" value=\"50\">\n    <span id=\"sliderValue\">50</span>\n</div>\n\n<div>\n    <h2>Thread Creation</h2>\n    <input type=\"text\" id=\"threadInput\" placeholder=\"Type thread message\">\n    <button id=\"createThreadButton\">Create Thread</button>\n    <div id=\"threadOutput\"></div>\n</div>\n\n<script>\n    document.getElementById(\"textInput\").addEventListener(\"input\", function() {\n        document.getElementById(\"charCount\").innerText = this.value.length;\n    });\n\n    document.getElementById(\"selectOptionButton\").addEventListener(\"click\", function() {\n        const option = document.getElementById(\"optionsSelect\").value;\n        const inputText = document.getElementById(\"textInput\").value;\n\n        if (option === \"show\") {\n            alert(\"You entered: \" + inputText);\n        } else if (option === \"count\") {\n            alert(\"Character count: \" + inputText.length);\n        } else if (option === \"clear\") {\n            document.getElementById(\"textInput\").value = '';\n            document.getElementById(\"charCount\").innerText = '0';\n        }\n    });\n\n    document.getElementById(\"countButton\").addEventListener(\"click\", function() {\n        const charCount = document.getElementById(\"textInput\").value.length;\n        alert(\"Character count in input: \" + charCount);\n    });\n\n    document.getElementById(\"numberSlider\").addEventListener(\"input\", function() {\n        document.getElementById(\"sliderValue\").innerText = this.value;\n    });\n\n    document.getElementById(\"createThreadButton\").addEventListener(\"click\", function() {\n        const threadMessage = document.getElementById(\"threadInput\").value;\n        if (threadMessage) {\n            const threadOutput = document.getElementById(\"threadOutput\");\n            const newThread = document.createElement(\"p\");\n            newThread.innerText = threadMessage;\n            threadOutput.appendChild(newThread);\n            document.getElementById(\"threadInput\").value = '';\n        }\n    });\n</script>\n\n</body>\n</html>"
