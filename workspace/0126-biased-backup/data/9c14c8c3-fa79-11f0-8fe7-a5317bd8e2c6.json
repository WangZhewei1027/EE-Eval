  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Branch and Bound Interactive Demonstration</title>\n<style>\n  /* Extremely minimal plain design: black text on white background, basic HTML elements only */\n  html,body { margin:10px; padding:0; font-family: sans-serif; color: #000; background: #fff; }\n  h1,h2,h3 { margin:6px 0; font-weight:normal; }\n  .row { display:flex; gap:10px; align-items:flex-start; }\n  .col { display:flex; flex-direction:column; gap:8px; }\n  .panel { border:1px solid #000; padding:8px; }\n  table { border-collapse:collapse; width:100%; }\n  th,td { border:1px solid #000; padding:4px; font-size:12px; text-align:left; }\n  input[type=\"number\"], input[type=\"text\"], select { width:100px; }\n  button { padding:4px 8px; }\n  textarea { width:100%; height:120px; }\n  .nodes { max-height:320px; overflow:auto; border:1px solid #000; padding:4px; }\n  .mini { font-size:12px; }\n  .controls-row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }\n  label { font-size:12px; }\n  .small { width:60px; }\n  .wide { width:200px; }\n  .muted { font-size:12px; color:#000; opacity:0.7;}\n</style>\n</head>\n<body>\n  <h1>Branch and Bound — Interactive Demonstration</h1>\n\n  <div class=\"row\">\n    <div class=\"col\" style=\"flex:1\">\n      <div class=\"panel\">\n        <h2>Problem Setup (0-1 Knapsack)</h2>\n        <div class=\"controls-row\">\n          <label>Items:\n            <input id=\"itemCount\" type=\"number\" min=\"1\" value=\"6\" class=\"small\">\n          </label>\n          <label>Capacity:\n            <input id=\"capacity\" type=\"number\" min=\"1\" value=\"15\" class=\"small\">\n          </label>\n          <button id=\"generateRandom\">Generate Random Items</button>\n          <button id=\"resetProblem\">Reset Problem</button>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <button id=\"addItem\">Add Item</button>\n          <button id=\"removeLast\">Remove Last</button>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <table id=\"itemsTable\">\n            <thead><tr><th>#</th><th>Value</th><th>Weight</th><th>Value/Weight</th><th>Actions</th></tr></thead>\n            <tbody></tbody>\n          </table>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <small class=\"muted\">Edit values and weights directly in the table. Click \"Generate Random\" to randomize.</small>\n        </div>\n      </div>\n\n      <div class=\"panel\" style=\"margin-top:10px;\">\n        <h2>Branch & Bound Controls</h2>\n\n        <div class=\"controls-row\">\n          <label>Node selection:\n            <select id=\"nodeStrategy\">\n              <option value=\"best\">Best-bound (choose highest upper bound)</option>\n              <option value=\"dfs\">Depth-first (stack)</option>\n              <option value=\"bfs\">Breadth-first (queue)</option>\n            </select>\n          </label>\n\n          <label>Branch variable:\n            <select id=\"branchStrategy\">\n              <option value=\"first\">First free variable</option>\n              <option value=\"fractional\">Most fractional from relaxation</option>\n              <option value=\"highestRatio\">Highest value/weight</option>\n            </select>\n          </label>\n\n          <label>Bound type:\n            <select id=\"boundType\">\n              <option value=\"fractional\">Fractional (greedy) upper bound</option>\n              <option value=\"greedyLower\">Greedy integer lower bound (heuristic)</option>\n              <option value=\"exact\">Exact (exhaustive when small)</option>\n            </select>\n          </label>\n        </div>\n\n        <div style=\"margin-top:8px;\" class=\"controls-row\">\n          <button id=\"init\">Initialize Root Node</button>\n          <button id=\"step\">Step (expand one)</button>\n          <button id=\"autoRun\">Auto Run</button>\n          <button id=\"pause\">Pause</button>\n          <button id=\"solveAll\">Solve to Completion</button>\n          <button id=\"stepBack\">Step Back</button>\n          <label>Speed:\n            <input id=\"speed\" type=\"range\" min=\"50\" max=\"2000\" value=\"800\">\n          </label>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <button id=\"exportState\">Export State</button>\n          <button id=\"importState\">Import State</button>\n          <input id=\"importData\" type=\"text\" placeholder='{\"...\":...}' style=\"width:320px;\">\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <small class=\"muted\">You can manually expand, branch, prune, compute exact bound for any node in the node list shown below. Extensive manual control enables deep exploration.</small>\n        </div>\n      </div>\n\n      <div class=\"panel\" style=\"margin-top:10px;\">\n        <h2>Stats and Incumbent</h2>\n        <div id=\"stats\" class=\"mini\">\n          <div>Nodes created: <span id=\"statNodes\">0</span></div>\n          <div>Nodes expanded: <span id=\"statExpanded\">0</span></div>\n          <div>Nodes pruned: <span id=\"statPruned\">0</span></div>\n          <div>Frontier size: <span id=\"statFrontier\">0</span></div>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <h3>Current Incumbent (best integer solution found)</h3>\n          <div id=\"incumbentInfo\" class=\"mini\">None</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"col\" style=\"width:520px;\">\n      <div class=\"panel\">\n        <h2>Nodes (Frontier & Explored)</h2>\n        <div class=\"nodes\" id=\"nodesList\">\n          <!-- Node items will appear here -->\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <small class=\"muted\">Click a node to inspect and use action buttons that appear for the selected node.</small>\n        </div>\n      </div>\n\n      <div class=\"panel\" style=\"margin-top:10px;\">\n        <h2>Selected Node Details</h2>\n        <div id=\"nodeDetails\" class=\"mini\">None selected.</div>\n        <div style=\"margin-top:8px;\" id=\"nodeActions\"></div>\n      </div>\n\n      <div class=\"panel\" style=\"margin-top:10px;\">\n        <h2>Log & History</h2>\n        <textarea id=\"log\" readonly></textarea>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  Branch and Bound interactive demo (0-1 Knapsack).\n  - Plain UI, many controls for exploring branching, bounding, strategies.\n  - Minimal design, heavy interactivity and many paths.\n*/\n\n/* ---------- Problem data and utilities ---------- */\n\nlet items = []; // each item: {value, weight, ratio}\nlet capacity = 15;\nlet nextNodeId = 1;\n\n// B&B state\nlet state = {\n  nodes: {},           // id -> node\n  frontier: [],        // list of node ids (depending on selection strategy)\n  createdCount: 0,\n  expandedCount: 0,\n  prunedCount: 0,\n  incumbent: null,     // {value, assignment, nodeId}\n  selectedNodeId: null,\n  history: [],\n  historyIndex: -1\n};\n\n// node object: { id, parent, fixed: array (-1 free, 0,1), bound, heuristic, status, depth }\n\nconst maxExactFree = 20; // threshold for exact exhaustive bound\n\n// DOM references\nconst itemsTableBody = document.querySelector(\"#itemsTable tbody\");\nconst itemCountInput = document.getElementById(\"itemCount\");\nconst capacityInput = document.getElementById(\"capacity\");\nconst generateRandomBtn = document.getElementById(\"generateRandom\");\nconst resetProblemBtn = document.getElementById(\"resetProblem\");\nconst addItemBtn = document.getElementById(\"addItem\");\nconst removeLastBtn = document.getElementById(\"removeLast\");\nconst initBtn = document.getElementById(\"init\");\nconst stepBtn = document.getElementById(\"step\");\nconst autoRunBtn = document.getElementById(\"autoRun\");\nconst pauseBtn = document.getElementById(\"pause\");\nconst solveAllBtn = document.getElementById(\"solveAll\");\nconst stepBackBtn = document.getElementById(\"stepBack\");\nconst nodesListDiv = document.getElementById(\"nodesList\");\nconst nodeDetailsDiv = document.getElementById(\"nodeDetails\");\nconst nodeActionsDiv = document.getElementById(\"nodeActions\");\nconst logArea = document.getElementById(\"log\");\nconst statNodes = document.getElementById(\"statNodes\");\nconst statExpanded = document.getElementById(\"statExpanded\");\nconst statPruned = document.getElementById(\"statPruned\");\nconst statFrontier = document.getElementById(\"statFrontier\");\nconst incumbentInfo = document.getElementById(\"incumbentInfo\");\nconst nodeStrategySelect = document.getElementById(\"nodeStrategy\");\nconst branchStrategySelect = document.getElementById(\"branchStrategy\");\nconst boundTypeSelect = document.getElementById(\"boundType\");\nconst speedSlider = document.getElementById(\"speed\");\nconst exportStateBtn = document.getElementById(\"exportState\");\nconst importStateBtn = document.getElementById(\"importState\");\nconst importInput = document.getElementById(\"importData\");\n\nlet autoRunTimer = null;\n\n/* ---------- Utility functions ---------- */\n\nfunction log(msg) {\n  const t = new Date().toLocaleTimeString();\n  logArea.value = `[${t}] ${msg}\\n` + logArea.value;\n}\n\nfunction deepClone(obj) {\n  return JSON.parse(JSON.stringify(obj));\n}\n\nfunction updateItemsTable() {\n  itemsTableBody.innerHTML = \"\";\n  items.forEach((it, idx) => {\n    const tr = document.createElement(\"tr\");\n    tr.innerHTML = `<td>${idx}</td>\n      <td><input data-idx=\"${idx}\" data-field=\"value\" type=\"number\" value=\"${it.value}\"></td>\n      <td><input data-idx=\"${idx}\" data-field=\"weight\" type=\"number\" value=\"${it.weight}\"></td>\n      <td>${(it.ratio).toFixed(3)}</td>\n      <td><button data-idx=\"${idx}\" class=\"deleteItem\">Delete</button></td>`;\n    itemsTableBody.appendChild(tr);\n  });\n  // attach listeners\n  itemsTableBody.querySelectorAll('input[data-field]').forEach(inp => {\n    inp.addEventListener('change', (e) => {\n      const idx = Number(e.target.getAttribute('data-idx'));\n      const field = e.target.getAttribute('data-field');\n      const val = Number(e.target.value);\n      if (field === 'value') items[idx].value = Math.max(0, val);\n      if (field === 'weight') items[idx].weight = Math.max(1, val);\n      items[idx].ratio = items[idx].value / items[idx].weight;\n      refreshAllDisplays();\n    });\n  });\n  itemsTableBody.querySelectorAll('.deleteItem').forEach(btn => {\n    btn.addEventListener('click', (e) => {\n      const idx = Number(e.target.getAttribute('data-idx'));\n      items.splice(idx,1);\n      refreshAllDisplays();\n    });\n  });\n}\n\nfunction randomInt(min,max) { return Math.floor(Math.random()*(max-min+1))+min; }\n\nfunction generateRandomProblem(n, cap) {\n  items = [];\n  for (let i=0;i<n;i++){\n    const weight = randomInt(1, Math.max(2,Math.floor(cap/2)));\n    const value = randomInt(1, weight*5);\n    items.push({value, weight, ratio: value/weight});\n  }\n  capacity = cap;\n  capacityInput.value = capacity;\n  updateItemsTable();\n  log(`Generated random problem with ${n} items, capacity ${cap}.`);\n}\n\nfunction resetProblem() {\n  items = [\n    {value:10, weight:6, ratio:10/6},\n    {value:6, weight:3, ratio:6/3},\n    {value:5, weight:4, ratio:5/4},\n    {value:7, weight:4, ratio:7/4},\n    {value:2, weight:1, ratio:2/1},\n    {value:8, weight:5, ratio:8/5}\n  ];\n  capacity = 15;\n  itemCountInput.value = items.length;\n  capacityInput.value = capacity;\n  updateItemsTable();\n  log('Reset to default example problem.');\n}\n\n/* ---------- Bound and heuristics ---------- */\n\nfunction computeFractionalUpperBoundForNode(node) {\n  // node.fixed: -1 free, 0,1 fixed\n  const fixed = node.fixed;\n  let sumW = 0, sumV = 0;\n  for (let i=0;i<fixed.length;i++){\n    if (fixed[i]===1) {\n      sumW += items[i].weight;\n      sumV += items[i].value;\n    }\n  }\n  if (sumW > capacity) return -Infinity;\n  let capRem = capacity - sumW;\n  // list remaining items sorted by ratio desc\n  const rem = [];\n  for (let i=0;i<fixed.length;i++){\n    if (fixed[i]!==1) rem.push({i, ratio: items[i].ratio, value: items[i].value, weight: items[i].weight});\n  }\n  rem.sort((a,b)=>b.ratio - a.ratio);\n  let ub = sumV;\n  for (const r of rem){\n    if (r.weight <= capRem) {\n      capRem -= r.weight;\n      ub += r.value;\n    } else {\n      // fractional part\n      ub += r.ratio * capRem;\n      capRem = 0;\n      break;\n    }\n  }\n  return ub;\n}\n\n// Greedy integer heuristic for a feasible solution under node constraints\nfunction greedyIntegerSolutionForNode(node) {\n  const fixed = node.fixed;\n  let assignment = fixed.slice();\n  let sumW = 0, sumV = 0;\n  for (let i=0;i<fixed.length;i++){\n    if (fixed[i]===1) { sumW += items[i].weight; sumV += items[i].value; }\n    if (fixed[i]===0) assignment[i]=0;\n  }\n  if (sumW > capacity) return null;\n  // sort free items by ratio\n  const rem = [];\n  for (let i=0;i<fixed.length;i++){\n    if (fixed[i]===-1) rem.push({i, ratio: items[i].ratio, value: items[i].value, weight: items[i].weight});\n  }\n  rem.sort((a,b)=>b.ratio - a.ratio);\n  for (const r of rem){\n    if (sumW + r.weight <= capacity){\n      sumW += r.weight;\n      sumV += r.value;\n      assignment[r.i] = 1;\n    } else {\n      assignment[r.i] = 0;\n    }\n  }\n  return {value: sumV, weight: sumW, assignment};\n}\n\n// Exact exhaustive search for remaining free variables (only when small)\nfunction exactExhaustiveForNode(node) {\n  const fixed = node.fixed;\n  let baseW = 0, baseV = 0;\n  const freeIdx = [];\n  for (let i=0;i<fixed.length;i++){\n    if (fixed[i]===1) { baseW += items[i].weight; baseV += items[i].value; }\n    else if (fixed[i]===-1) freeIdx.push(i);\n  }\n  if (baseW > capacity) return {value:-Infinity};\n  const nFree = freeIdx.length;\n  if (nFree > maxExactFree) return {error: 'too many free variables for exhaustive search'};\n  let bestV = -Infinity;\n  let bestAssign = null;\n  const total = 1<<nFree;\n  for (let mask=0; mask<total; mask++){\n    let w = baseW, v = baseV;\n    const assign = fixed.slice();\n    for (let j=0;j<nFree;j++){\n      const idx = freeIdx[j];\n      if (mask & (1<<j)) {\n        w += items[idx].weight;\n        v += items[idx].value;\n        assign[idx] = 1;\n      } else assign[idx] = 0;\n      if (w > capacity) break;\n    }\n    if (w <= capacity && v > bestV){\n      bestV = v;\n      bestAssign = assign.slice();\n    }\n  }\n  if (bestV === -Infinity) return {value:-Infinity};\n  return {value: bestV, assignment: bestAssign};\n}\n\n/* ---------- Node management ---------- */\n\nfunction makeRootNode() {\n  const n = items.length;\n  const fixed = new Array(n).fill(-1);\n  const node = {\n    id: nextNodeId++,\n    parent: null,\n    fixed,\n    bound: null,\n    heuristic: null,\n    status: 'frontier',\n    depth: 0\n  };\n  state.nodes = {};\n  state.frontier = [];\n  state.createdCount = 0;\n  state.expandedCount = 0;\n  state.prunedCount = 0;\n  state.incumbent = null;\n  state.selectedNodeId = null;\n  state.history = [];\n  state.historyIndex = -1;\n  addNode(node);\n  pushHistory('Initialized root node');\n  refreshAllDisplays();\n  log('Root node created (all variables free).');\n  return node;\n}\n\nfunction addNode(node) {\n  state.nodes[node.id] = node;\n  state.frontier.push(node.id);\n  state.createdCount++;\n  statNodes.textContent = state.createdCount;\n}\n\nfunction removeFromFrontier(nodeId) {\n  const idx = state.frontier.indexOf(nodeId);\n  if (idx>=0) state.frontier.splice(idx,1);\n}\n\nfunction snapshotState(actionLabel) {\n  // store deep clone of essential state for step back capability\n  const snap = {\n    nodes: deepClone(state.nodes),\n    frontier: deepClone(state.frontier),\n    createdCount: state.createdCount,\n    expandedCount: state.expandedCount,\n    prunedCount: state.prunedCount,\n    incumbent: deepClone(state.incumbent),\n    selectedNodeId: state.selectedNodeId\n  };\n  // truncate future history on new actions\n  if (state.historyIndex < state.history.length - 1) {\n    state.history = state.history.slice(0, state.historyIndex + 1);\n  }\n  state.history.push({snap, label: actionLabel});\n  state.historyIndex = state.history.length - 1;\n}\n\nfunction pushHistory(label) {\n  snapshotState(label);\n}\n\nfunction restoreHistoryIndex(idx) {\n  if (idx < 0 || idx >= state.history.length) return;\n  const snap = state.history[idx].snap;\n  state.nodes = deepClone(snap.nodes);\n  state.frontier = deepClone(snap.frontier);\n  state.createdCount = snap.createdCount;\n  state.expandedCount = snap.expandedCount;\n  state.prunedCount = snap.prunedCount;\n  state.incumbent = deepClone(snap.incumbent);\n  state.selectedNodeId = snap.selectedNodeId;\n  state.historyIndex = idx;\n  refreshAllDisplays();\n  log(`Restored history: ${state.history[idx].label}`);\n}\n\n/* ---------- Node selection and branching ---------- */\n\nfunction chooseNodeToExpand() {\n  if (state.frontier.length === 0) return null;\n  const strat = nodeStrategySelect.value;\n  if (strat === 'dfs') {\n    return state.frontier[state.frontier.length - 1];\n  } else if (strat === 'bfs') {\n    return state.frontier[0];\n  } else { // best-bound\n    // ensure bounds are computed\n    let bestId = null, bestBound = -Infinity;\n    for (const id of state.frontier) {\n      const node = state.nodes[id];\n      if (node.bound === null) {\n        node.bound = computeFractionalUpperBoundForNode(node);\n      }\n      if (node.bound > bestBound) {\n        bestBound = node.bound; bestId = id;\n      }\n    }\n    return bestId;\n  }\n}\n\nfunction chooseBranchVariable(node) {\n  const strat = branchStrategySelect.value;\n  const fixed = node.fixed;\n  if (strat === 'first') {\n    for (let i=0;i<fixed.length;i++) if (fixed[i]===-1) return i;\n  } else if (strat === 'highestRatio') {\n    let bestIdx = -1, bestRatio = -Infinity;\n    for (let i=0;i<fixed.length;i++) if (fixed[i]===-1) {\n      if (items[i].ratio > bestRatio) { bestRatio = items[i].ratio; bestIdx = i; }\n    }\n    return bestIdx;\n  } else if (strat === 'fractional') {\n    // compute fractional solution to detect fractional selection\n    // We'll simulate greedy fractional selection and see if a fractional item appears\n    const fixedCopy = fixed.slice();\n    let sumW = 0;\n    for (let i=0;i<fixedCopy.length;i++){\n      if (fixedCopy[i]===1) sumW += items[i].weight;\n    }\n    let capRem = capacity - sumW;\n    const rem = [];\n    for (let i=0;i<fixedCopy.length;i++){\n      if (fixedCopy[i]!==1) rem.push({i, ratio: items[i].ratio, value: items[i].value, weight: items[i].weight});\n    }\n    rem.sort((a,b)=>b.ratio - a.ratio);\n    for (const r of rem) {\n      if (r.weight <= capRem) { capRem -= r.weight; continue; }\n      // fractional item found\n      return r.i;\n    }\n    // fallback\n    for (let i=0;i<fixed.length;i++) if (fixed[i]===-1) return i;\n  }\n  return null;\n}\n\n/* ---------- Expand single node ---------- */\n\nfunction expandOneNode(manualNodeId=null) {\n  const nodeId = manualNodeId !== null ? manualNodeId : chooseNodeToExpand();\n  if (nodeId === null || nodeId === undefined) {\n    log('No node available to expand.');\n    return;\n  }\n  const node = state.nodes[nodeId];\n  // snapshot before action\n  pushHistory(`Expand node ${nodeId}`);\n  // compute bound if not yet\n  if (node.bound === null) node.bound = computeFractionalUpperBoundForNode(node);\n  // compute heuristic value\n  node.heuristic = greedyIntegerSolutionForNode(node);\n  // Check prune by bound\n  if (state.incumbent && node.bound !== -Infinity && node.bound <= state.incumbent.value) {\n    node.status = 'pruned';\n    state.prunedCount++;\n    removeFromFrontier(node.id);\n    log(`Node ${node.id} pruned by bound (ub=${node.bound.toFixed(3)}) <= incumbent ${state.incumbent.value}`);\n    refreshAllDisplays();\n    return;\n  }\n  // if all fixed -> feasible leaf\n  const allFixed = node.fixed.every(v => v!==-1);\n  if (allFixed) {\n    // check feasibility\n    const wt = node.fixed.reduce((acc,v,i)=>acc + (v===1?items[i].weight:0),0);\n    const val = node.fixed.reduce((acc,v,i)=>acc + (v===1?items[i].value:0),0);\n    if (wt <= capacity) {\n      node.status = 'feasible';\n      removeFromFrontier(node.id);\n      state.expandedCount++;\n      state.nodes[node.id] = node;\n      log(`Node ${node.id} is a feasible leaf with value ${val} weight ${wt}.`);\n      if (!state.incumbent || val > state.incumbent.value) {\n        state.incumbent = {value: val, assignment: node.fixed.slice(), nodeId: node.id};\n        log(`Incumbent updated to value ${val} at node ${node.id}.`);\n      }\n      refreshAllDisplays();\n      return;\n    } else {\n      node.status = 'infeasible';\n      removeFromFrontier(node.id);\n      state.prunedCount++;\n      log(`Node ${node.id} infeasible (weight ${wt} > capacity). Pruned.`);\n      refreshAllDisplays();\n      return;\n    }\n  }\n\n  // Expand node: branch on selected variable\n  const branchIdx = chooseBranchVariable(node);\n  if (branchIdx === null) {\n    // no variable to branch on (?) treat as expanded\n    node.status = 'expanded';\n    removeFromFrontier(node.id);\n    state.expandedCount++;\n    log(`Node ${node.id} expanded (no branch variable found).`);\n    refreshAllDisplays();\n    return;\n  }\n\n  // Create child where variable=1 first (try to find better incumbent quickly), then 0\n  const child1 = {\n    id: nextNodeId++,\n    parent: node.id,\n    fixed: node.fixed.slice(),\n    bound: null,\n    heuristic: null,\n    status: 'frontier',\n    depth: node.depth + 1\n  };\n  child1.fixed[branchIdx] = 1;\n\n  const child2 = {\n    id: nextNodeId++,\n    parent: node.id,\n    fixed: node.fixed.slice(),\n    bound: null,\n    heuristic: null,\n    status: 'frontier',\n    depth: node.depth + 1\n  };\n  child2.fixed[branchIdx] = 0;\n\n  // Mark expanded and remove from frontier\n  node.status = 'expanded';\n  removeFromFrontier(node.id);\n  // Add children according to ordering (we will add both to frontier)\n  addNode(child1);\n  addNode(child2);\n\n  state.expandedCount++;\n  log(`Expanded node ${node.id} branching on variable ${branchIdx} -> created nodes ${child1.id} (x${branchIdx}=1) and ${child2.id} (x${branchIdx}=0).`);\n\n  refreshAllDisplays();\n}\n\n/* ---------- Manual node operations ---------- */\n\nfunction computeExactForSelected() {\n  const id = state.selectedNodeId;\n  if (!id) return;\n  const node = state.nodes[id];\n  pushHistory(`Compute exact for node ${id}`);\n  const res = exactExhaustiveForNode(node);\n  if (res.error) {\n    log(`Exact bound not computed for node ${id}: ${res.error}`);\n    alert('Exact exhaustive bound skipped: too many free variables.');\n  } else {\n    node.bound = res.value;\n    if (res.assignment) node.heuristic = {value: res.value, assignment: res.assignment};\n    log(`Exact value for node ${id} = ${res.value}`);\n  }\n  refreshAllDisplays();\n}\n\nfunction pruneSelected() {\n  const id = state.selectedNodeId;\n  if (!id) return;\n  const node = state.nodes[id];\n  pushHistory(`Manual prune node ${id}`);\n  if (node.status !== 'pruned') {\n    node.status = 'pruned';\n    removeFromFrontier(id);\n    state.prunedCount++;\n    log(`Node ${id} manually pruned.`);\n    refreshAllDisplays();\n  }\n}\n\nfunction setSelectedAsIncumbent() {\n  const id = state.selectedNodeId;\n  if (!id) return;\n  const node = state.nodes[id];\n  // need to have a feasible assignment\n  if (node.fixed.every(v => v!==-1)) {\n    const wt = node.fixed.reduce((acc,v,i)=>acc + (v===1?items[i].weight:0),0);\n    const val = node.fixed.reduce((acc,v,i)=>acc + (v===1?items[i].value:0),0);\n    if (wt <= capacity) {\n      pushHistory(`Manual incumbent set from node ${id}`);\n      state.incumbent = {value: val, assignment: node.fixed.slice(), nodeId: id};\n      log(`Manually set incumbent to value ${val} from node ${id}.`);\n      refreshAllDisplays();\n    } else {\n      alert('Selected node assignment is infeasible (weight exceeds capacity).');\n    }\n  } else {\n    // try to get a greedy integer solution if possible\n    const greedy = greedyIntegerSolutionForNode(node);\n    if (greedy) {\n      pushHistory(`Manual incumbent set from greedy at node ${id}`);\n      state.incumbent = {value: greedy.value, assignment: greedy.assignment.slice(), nodeId: id};\n      log(`Manually set incumbent to greedy value ${greedy.value} from node ${id}.`);\n      refreshAllDisplays();\n    } else {\n      alert('Cannot create feasible incumbent for this node.');\n    }\n  }\n}\n\n/* ---------- Interface rendering ---------- */\n\nfunction renderNodesList() {\n  nodesListDiv.innerHTML = '';\n  const allIds = Object.keys(state.nodes).map(x=>Number(x)).sort((a,b)=>a-b);\n  // show frontier first then others\n  const present = new Set(state.frontier);\n  // render frontier items first\n  for (const id of state.frontier) {\n    const node = state.nodes[id];\n    nodesListDiv.appendChild(renderNodeRow(node, true));\n  }\n  // then other nodes not in frontier\n  for (const id of allIds) {\n    if (!present.has(id)) {\n      const node = state.nodes[id];\n      nodesListDiv.appendChild(renderNodeRow(node, false));\n    }\n  }\n}\n\nfunction renderNodeRow(node, isFrontier) {\n  const div = document.createElement('div');\n  div.style.borderTop = '1px solid #000';\n  div.style.padding = '6px 2px';\n  div.style.fontSize = '12px';\n  const shortFixed = node.fixed.map(v=>v===-1?'.':v).join('');\n  const boundText = node.bound === null ? 'n/a' : (node.bound===-Infinity?'-inf':node.bound.toFixed(3));\n  const heurText = node.heuristic ? (node.heuristic.value !== undefined ? node.heuristic.value : '-') : '-';\n  div.innerHTML = `ID:${node.id} [${shortFixed}] depth:${node.depth} status:${node.status} ub:${boundText} heuristic:${heurText}`;\n  div.addEventListener('click', () => {\n    state.selectedNodeId = node.id;\n    renderNodeDetails(node.id);\n    renderNodesList();\n  });\n  if (state.selectedNodeId === node.id) {\n    div.style.background = '#eee';\n  }\n  return div;\n}\n\nfunction renderNodeDetails(nodeId) {\n  const node = state.nodes[nodeId];\n  if (!node) {\n    nodeDetailsDiv.textContent = 'None selected.';\n    nodeActionsDiv.innerHTML = '';\n    return;\n  }\n  const fixedStr = node.fixed.map((v,i)=>`${i}:${v===-1?'.':v}`).join(' ');\n  const boundText = node.bound === null ? 'n/a' : (node.bound===-Infinity?'-inf':node.bound.toFixed(3));\n  const heurText = node.heuristic ? (node.heuristic.value !== undefined ? node.heuristic.value : '-') : '-';\n  nodeDetailsDiv.innerHTML = `\n    <div>ID: ${node.id}</div>\n    <div>Parent: ${node.parent}</div>\n    <div>Depth: ${node.depth}</div>\n    <div>Fixed: ${fixedStr}</div>\n    <div>Upper bound: ${boundText}</div>\n    <div>Heuristic value: ${heurText}</div>\n    <div>Status: ${node.status}</div>\n  `;\n  // actions\n  nodeActionsDiv.innerHTML = '';\n  const btnExpand = document.createElement('button'); btnExpand.textContent = 'Expand this node'; btnExpand.addEventListener('click', ()=>expandOneNode(nodeId));\n  const btnCompute = document.createElement('button'); btnCompute.textContent = 'Compute fractional bound'; btnCompute.addEventListener('click', ()=>{\n    pushHistory(`Compute fractional bound for node ${nodeId}`);\n    node.bound = computeFractionalUpperBoundForNode(node);\n    node.heuristic = greedyIntegerSolutionForNode(node);\n    log(`Computed fractional bound for node ${nodeId}: ${node.bound}`);\n    refreshAllDisplays();\n  });\n  const btnExact = document.createElement('button'); btnExact.textContent = 'Compute exact (exhaustive)'; btnExact.addEventListener('click', ()=>computeExactForSelected());\n  const btnPrune = document.createElement('button'); btnPrune.textContent = 'Prune this node'; btnPrune.addEventListener('click', ()=>pruneSelected());\n  const btnInc = document.createElement('button'); btnInc.textContent = 'Set as incumbent (manual)'; btnInc.addEventListener('click', ()=>setSelectedAsIncumbent());\n  const btnEdit = document.createElement('button'); btnEdit.textContent = 'Edit fixed vars'; btnEdit.addEventListener('click', ()=>editFixedVars(nodeId));\n\n  nodeActionsDiv.appendChild(btnExpand);\n  nodeActionsDiv.appendChild(btnCompute);\n  nodeActionsDiv.appendChild(btnExact);\n  nodeActionsDiv.appendChild(btnPrune);\n  nodeActionsDiv.appendChild(btnInc);\n  nodeActionsDiv.appendChild(btnEdit);\n}\n\nfunction editFixedVars(nodeId) {\n  const node = state.nodes[nodeId];\n  if (!node) return;\n  const newFixedStr = prompt('Enter fixed variable vector as sequence with -,0,1 (e.g. \"-1-01\" or \".01.1\")', node.fixed.map(v=>v===-1?'.':v).join(''));\n  if (newFixedStr === null) return;\n  // parse\n  const arr = newFixedStr.split('');\n  if (arr.length !== node.fixed.length) {\n    alert('Length mismatch.');\n    return;\n  }\n  const newFixed = [];\n  for (const ch of arr) {\n    if (ch === '.' || ch === '-' ) newFixed.push(-1);\n    else if (ch === '0') newFixed.push(0);\n    else if (ch === '1') newFixed.push(1);\n    else { alert('Invalid symbol: use 0,1 or .'); return; }\n  }\n  pushHistory(`Edit fixed vars node ${nodeId}`);\n  node.fixed = newFixed;\n  node.bound = null; node.heuristic = null;\n  log(`Node ${nodeId} fixed variables edited.`);\n  refreshAllDisplays();\n}\n\nfunction refreshIncumbentDisplay() {\n  if (!state.incumbent) {\n    incumbentInfo.textContent = 'None';\n    return;\n  }\n  const a = state.incumbent.assignment.map((v,i)=>v===1?i:'').filter(x=>x!=='').join(',');\n  incumbentInfo.innerHTML = `Value: ${state.incumbent.value} at node ${state.incumbent.nodeId} <div class=\"mini\">Items selected: ${a || '(none)'}</div>`;\n}\n\nfunction refreshStats() {\n  statNodes.textContent = state.createdCount;\n  statExpanded.textContent = state.expandedCount;\n  statPruned.textContent = state.prunedCount;\n  statFrontier.textContent = state.frontier.length;\n}\n\n/* Overall refresh */\nfunction refreshAllDisplays() {\n  updateItemsTable();\n  renderNodesList();\n  renderNodeDetails(state.selectedNodeId);\n  refreshIncumbentDisplay();\n  refreshStats();\n}\n\n/* ---------- Control button handlers ---------- */\n\ngenerateRandomBtn.addEventListener('click', () => {\n  const n = Number(itemCountInput.value) || 6;\n  const cap = Number(capacityInput.value) || 15;\n  generateRandomProblem(n, cap);\n});\n\nresetProblemBtn.addEventListener('click', () => {\n  resetProblem();\n});\n\naddItemBtn.addEventListener('click', () => {\n  const val = randomInt(1,10); const wt = randomInt(1,6);\n  items.push({value: val, weight: wt, ratio: val/wt});\n  itemCountInput.value = items.length;\n  updateItemsTable();\n});\n\nremoveLastBtn.addEventListener('click', () => {\n  if (items.length>0) items.pop();\n  itemCountInput.value = items.length;\n  updateItemsTable();\n});\n\ncapacityInput.addEventListener('change', () => {\n  capacity = Math.max(1, Number(capacityInput.value));\n  pushHistory('Capacity changed');\n  log(`Capacity changed to ${capacity}`);\n  refreshAllDisplays();\n});\n\ninitBtn.addEventListener('click', () => {\n  // update capacity and itemCount fields\n  capacity = Math.max(1, Number(capacityInput.value));\n  itemCountInput.value = items.length;\n  const root = makeRootNode();\n  // compute root bound and heuristic if requested\n  root.bound = computeFractionalUpperBoundForNode(root);\n  root.heuristic = greedyIntegerSolutionForNode(root);\n  refreshAllDisplays();\n});\n\nstepBtn.addEventListener('click', () => {\n  expandOneNode();\n});\n\nautoRunBtn.addEventListener('click', () => {\n  if (autoRunTimer) { clearInterval(autoRunTimer); autoRunTimer=null; }\n  const interval = Number(speedSlider.value) || 800;\n  autoRunTimer = setInterval(() => {\n    if (state.frontier.length === 0) {\n      clearInterval(autoRunTimer); autoRunTimer = null;\n      log('Auto run finished: frontier empty.');\n      return;\n    }\n    // before expanding, optionally prune nodes by bound using current incumbent\n    if (state.incumbent) {\n      // prune all frontier nodes with bound <= incumbent\n      for (const id of [...state.frontier]) {\n        const node = state.nodes[id];\n        if (node.bound === null) node.bound = computeFractionalUpperBoundForNode(node);\n        if (node.bound !== -Infinity && node.bound <= state.incumbent.value) {\n          pushHistory('Auto prune by bound');\n          node.status = 'pruned';\n          removeFromFrontier(id);\n          state.prunedCount++;\n          log(`Auto-pruned node ${id} (ub=${node.bound} <= incumbent ${state.incumbent.value}).`);\n        }\n      }\n    }\n    if (state.frontier.length === 0) {\n      clearInterval(autoRunTimer); autoRunTimer=null;\n      log('Auto run finished: frontier empty after pruning.');\n      refreshAllDisplays();\n      return;\n    }\n    expandOneNode();\n  }, interval);\n  log('Auto run started.');\n});\n\npauseBtn.addEventListener('click', () => {\n  if (autoRunTimer) {\n    clearInterval(autoRunTimer); autoRunTimer=null;\n    log('Auto run paused.');\n  } else {\n    log('Auto run was not running.');\n  }\n});\n\nsolveAllBtn.addEventListener('click', () => {\n  // iterative loop until frontier empty or fully explored\n  pushHistory('Solve to completion');\n  // caution: this may be long; we will run steps synchronously but with a safety iteration limit\n  let iterations = 0;\n  const maxIter = 200000;\n  while (state.frontier.length > 0 && iterations < maxIter) {\n    // prune by bound using current incumbent\n    if (state.incumbent) {\n      for (const id of [...state.frontier]) {\n        const node = state.nodes[id];\n        if (node.bound === null) node.bound = computeFractionalUpperBoundForNode(node);\n        if (node.bound !== -Infinity && node.bound <= state.incumbent.value) {\n          node.status = 'pruned';\n          removeFromFrontier(id);\n          state.prunedCount++;\n        }\n      }\n    }\n    if (state.frontier.length === 0) break;\n    expandOneNode();\n    iterations++;\n  }\n  if (iterations >= maxIter) log('Solve aborted: reached iteration limit.');\n  else log('Solve to completion finished.');\n});\n\nstepBackBtn.addEventListener('click', () => {\n  if (state.historyIndex <= 0) {\n    alert('No earlier history to restore.');\n    return;\n  }\n  restoreHistoryIndex(state.historyIndex - 1);\n});\n\nexportStateBtn.addEventListener('click', () => {\n  const exportObj = {\n    items, capacity, state\n  };\n  const txt = JSON.stringify(exportObj);\n  importInput.value = txt;\n  alert('State exported to the import box (you can copy it).');\n});\n\nimportStateBtn.addEventListener('click', () => {\n  try {\n    const txt = importInput.value.trim();\n    if (!txt) { alert('Enter JSON into the import box.'); return; }\n    const obj = JSON.parse(txt);\n    if (obj.items && Array.isArray(obj.items)) {\n      items = obj.items;\n      capacity = obj.capacity || capacity;\n      // restore state (careful)\n      if (obj.state) {\n        state = obj.state;\n        // restore functions/refs\n        if (!state.history) state.history = [];\n        // ensure any missing fields\n        state.nodes = state.nodes || {};\n        state.frontier = state.frontier || [];\n        nextNodeId = Math.max(nextNodeId, ...Object.keys(state.nodes).map(x=>Number(x)).concat([0])) + 1;\n        log('Imported state from JSON.');\n      }\n      updateItemsTable();\n      refreshAllDisplays();\n    } else {\n      alert('Invalid JSON format.');\n    }\n  } catch (e) {\n    alert('Error parsing JSON: ' + e.message);\n  }\n});\n\n/* ---------- Boot / initial content ---------- */\n\nresetProblem();\nupdateItemsTable();\nrefreshAllDisplays();\nlog('Interactive Branch and Bound demo ready.');\n\n// provide keyboard shortcuts for quick exploration\ndocument.addEventListener('keydown', (e) => {\n  if (e.key === ' ') { e.preventDefault(); expandOneNode(); }\n  else if (e.key === 'a') { autoRunBtn.click(); }\n  else if (e.key === 'p') { pauseBtn.click(); }\n  else if (e.key === 's') { stepBackBtn.click(); }\n});\n\n</script>\n</body>\n</html>"
