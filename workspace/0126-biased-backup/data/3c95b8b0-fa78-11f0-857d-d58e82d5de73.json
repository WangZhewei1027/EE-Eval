    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Queue Visualization — Elegant Data Structure</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&family=Playfair+Display&display=swap');\n\n  /* Reset and base */\n  *, *::before, *::after {\n    box-sizing: border-box;\n  }\n  html, body {\n    height: 100%;\n    margin: 0;\n    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);\n    font-family: 'Montserrat', sans-serif;\n    color: #e0e6f0;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    overflow: hidden;\n    user-select: none;\n  }\n\n  /* Container */\n  .container {\n    width: 95vw;\n    max-width: 960px;\n    text-align: center;\n    position: relative;\n    padding: 2rem 1rem 4rem;\n  }\n\n  /* Header */\n  h1 {\n    font-family: 'Playfair Display', serif;\n    font-weight: 700;\n    font-size: 3.2rem;\n    color: #a6d1e6;\n    letter-spacing: 0.04em;\n    margin-bottom: 0.15em;\n    text-shadow:\n      0 0 5px #a6d1e6cc,\n      0 0 10px #a6d1e6bb,\n      0 0 20px #a6d1e6cc,\n      0 0 30px #58a6d4dd;\n    user-select: none;\n  }\n  h2 {\n    font-weight: 500;\n    font-size: 1.1rem;\n    font-style: italic;\n    color: #89b4d9cc;\n    margin-bottom: 3rem;\n    letter-spacing: 0.03em;\n  }\n\n  /* Queue visualization wrapper */\n  .queue-wrapper {\n    perspective: 1200px;\n  }\n\n  /* Queue container */\n  .queue {\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n    padding: 1.6rem 1.2rem;\n    background: radial-gradient(ellipse at center, #1e3c55dd 0%, #0a1c2fcc 85%);\n    border-radius: 2rem;\n    box-shadow:\n      inset 0 0 35px #1162a062,\n      0 0 25px #2079c8aa;\n    min-height: 120px;\n    max-width: 100%;\n    overflow-x: auto;\n  }\n\n  /* Queue item */\n  .queue-item {\n    flex: 0 0 80px;\n    height: 80px;\n    background: linear-gradient(145deg, #3a86ff, #023e8a);\n    border-radius: 1rem;\n    box-shadow:\n      0 4px 15px #1d5be466,\n      inset 0 0 12px #61a4f165;\n    color: #e0f0ff;\n    font-weight: 700;\n    font-size: 1.8rem;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    position: relative;\n    overflow: visible;\n    cursor: default;\n    user-select: none;\n    transition:\n      transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),\n      box-shadow 0.4s ease,\n      background 0.4s ease;\n  }\n\n  .queue-item::before {\n    content: attr(data-label);\n    position: absolute;\n    top: -1.3rem;\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 0.75rem;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    font-weight: 600;\n    color: #aaddffaa;\n    font-family: 'Montserrat', sans-serif;\n    user-select: none;\n    pointer-events: none;\n  }\n\n  /* Entrance and Exit labels for front and rear */\n  .queue-item.front::before {\n    content: \"Front\";\n    color: #93c5fd;\n    text-shadow: 0 0 3px #4f8bffcc;\n  }\n  .queue-item.rear::before {\n    content: \"Rear\";\n    color: #7ee5fcd9;\n    text-shadow: 0 0 6px #68c9f7dd;\n  }\n\n  /* Hover effect for the front and rear to highlight */\n  .queue-item.front:hover,\n  .queue-item.rear:hover {\n    transform: scale(1.15);\n    box-shadow:\n      0 0 30px #7ed0ffcc,\n      inset 0 0 25px #62a7f99c;\n    z-index: 2;\n  }\n\n  /* Subtle glow pulse animation */\n  @keyframes gentlePulse {\n    0%, 100% { box-shadow:\n      0 4px 15px #1d5be466,\n      inset 0 0 12px #61a4f165;\n    }\n    50% { box-shadow:\n      0 6px 25px #3f8beca1,\n      inset 0 0 18px #74b7f27c;\n    }\n  }\n\n  .queue-item {\n    animation: gentlePulse 4.5s ease-in-out infinite;\n  }\n\n  /* Buttons container */\n  .controls {\n    position: absolute;\n    bottom: 1.8rem;\n    width: 100%;\n    max-width: 480px;\n    left: 50%;\n    transform: translateX(-50%);\n    display: flex;\n    justify-content: center;\n    gap: 2.8rem;\n  }\n\n  /* Button style */\n  button {\n    padding: 0.9rem 3rem;\n    border-radius: 2rem;\n    border: none;\n    font-weight: 700;\n    font-size: 1.2rem;\n    font-family: 'Montserrat', sans-serif;\n    cursor: pointer;\n    background: linear-gradient(135deg, #0288d1, #026aa7);\n    color: #d7e9ff;\n    box-shadow:\n      0 8px 20px #0266a6cc;\n    user-select: none;\n    transition:\n      background 0.3s ease,\n      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),\n      box-shadow 0.3s ease;\n  }\n  button:focus {\n    outline: none;\n    box-shadow:\n      0 0 8px 3px #74baffaa,\n      0 8px 22px #0288d1ee;\n  }\n  button:hover:not(:disabled) {\n    background: linear-gradient(135deg, #4dabf7, #0288d1);\n    transform: translateY(-3px);\n    box-shadow:\n      0 12px 26px #1493f9cc;\n  }\n  button:active:not(:disabled) {\n    transform: translateY(-1px);\n    box-shadow:\n      0 6px 14px #0271becc;\n  }\n  button:disabled {\n    background: #1d3a5c88;\n    box-shadow: none;\n    cursor: default;\n    color: #8caad8aa;\n  }\n\n  /* Queue flow visualization */\n  .arrow-container {\n    position: absolute;\n    top: 54%;\n    left: 50%;\n    width: 100%;\n    max-width: 900px;\n    height: 30px;\n    pointer-events: none;\n    user-select: none;\n    overflow: visible;\n    transform: translateX(-50%);\n    filter: drop-shadow(0 0 1.5px #80bfff55);\n  }\n\n  svg {\n    width: 100%;\n    height: 100%;\n  }\n\n  /* Label below */\n  .desc {\n    margin-top: 3.8rem;\n    font-style: italic;\n    font-weight: 400;\n    font-size: 1rem;\n    color: #b8ceeaaa;\n    user-select: none;\n    max-width: 700px;\n    margin-left: auto;\n    margin-right: auto;\n    letter-spacing: 0.04em;\n  }\n\n  /* Scrollbar styling for overflow-x */\n  .queue::-webkit-scrollbar {\n    height: 8px;\n  }\n  .queue::-webkit-scrollbar-track {\n    background: #0a203539;\n    border-radius: 2rem;\n  }\n  .queue::-webkit-scrollbar-thumb {\n    background: #1162a0bb;\n    border-radius: 2rem;\n  }\n\n</style>\n</head>\n<body>\n  <div class=\"container\" aria-label=\"Queue Data Structure visualization\">\n    <h1>Queue</h1>\n    <h2>First-In, First-Out (FIFO) Data Structure</h2>\n\n    <div class=\"queue-wrapper\" aria-live=\"polite\">\n      <div class=\"queue\" id=\"queue\" aria-label=\"Queue elements\">\n        <!-- Queue items inserted by script -->\n      </div>\n      <div class=\"arrow-container\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 900 30\" preserveAspectRatio=\"none\" aria-hidden=\"true\" focusable=\"false\">\n          <defs>\n            <linearGradient id=\"arrowGradient\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\" stop-color=\"#7bd0ff\" stop-opacity=\"0\" />\n              <stop offset=\"30%\" stop-color=\"#7bd0ff\" stop-opacity=\"0.7\" />\n              <stop offset=\"70%\" stop-color=\"#7bd0ff\" stop-opacity=\"0.7\" />\n              <stop offset=\"100%\" stop-color=\"#7bd0ff\" stop-opacity=\"0\" />\n            </linearGradient>\n            <marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"8\" refX=\"6\" refY=\"3\" orient=\"auto\" markerUnits=\"strokeWidth\">\n              <path d=\"M0,0 L6,3 L0,6\" fill=\"#74bffe\"/>\n            </marker>\n          </defs>\n          <line x1=\"40\" y1=\"15\" x2=\"860\" y2=\"15\" stroke=\"url(#arrowGradient)\" stroke-width=\"4\" marker-end=\"url(#arrowhead)\" />\n          <circle cx=\"40\" cy=\"15\" r=\"5\" fill=\"#74bffe\" filter=\"url(#glow)\" />\n          <text x=\"10\" y=\"23\" fill=\"#88c8ff\" font-family=\"Montserrat,sans-serif\" font-size=\"12\" letter-spacing=\"0.05em\" user-select=\"none\">Front (Dequeue)</text>\n          <text x=\"750\" y=\"23\" fill=\"#bde4ff\" font-family=\"Montserrat,sans-serif\" font-size=\"12\" user-select=\"none\">Rear (Enqueue)</text>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"controls\" aria-label=\"Queue controls\">\n      <button id=\"enqueueBtn\" aria-label=\"Enqueue an element\">Enqueue</button>\n      <button id=\"dequeueBtn\" aria-label=\"Dequeue front element\">Dequeue</button>\n    </div>\n\n    <p class=\"desc\">Observe how elements enter at the rear and exit from the front, maintaining the sequence order.</p>\n  </div>\n\n<script>\n  (() => {\n    const queueEl = document.getElementById('queue');\n    const enqueueBtn = document.getElementById('enqueueBtn');\n    const dequeueBtn = document.getElementById('dequeueBtn');\n\n    // Initialize queue with a few numbers for neat visual start\n    let queue = [10, 20, 30, 40, 50];\n\n    // Maximum queue size for display (to keep design neat)\n    const MAX_SIZE = 10;\n\n    // Update the queue display\n    function renderQueue() {\n      queueEl.innerHTML = '';\n      if (queue.length === 0) {\n        const emptyMsg = document.createElement('div');\n        emptyMsg.textContent = 'Queue is empty';\n        emptyMsg.style.color = '#3b6fb3aa';\n        emptyMsg.style.fontWeight = '600';\n        emptyMsg.style.letterSpacing = '0.1em';\n        emptyMsg.style.fontSize = '1.1rem';\n        emptyMsg.style.textShadow = '0 0 6px #74bffe99';\n        emptyMsg.style.userSelect = 'none';\n        queueEl.appendChild(emptyMsg);\n        dequeueBtn.disabled = true;\n        return;\n      }\n\n      for (let i=0; i<queue.length; i++) {\n        const div = document.createElement('div');\n        div.className = 'queue-item';\n        div.textContent = queue[i];\n        // Label front and rear visually\n        if (i === 0) div.classList.add('front');\n        if (i === queue.length - 1) div.classList.add('rear');\n        queueEl.appendChild(div);\n      }\n      dequeueBtn.disabled = false;\n    }\n\n    // Generate a random number (2 digit) to enqueue\n    function randomNumber() {\n      return Math.floor(Math.random() * 90) + 10;\n    }\n\n    // Enqueue operation with animation\n    function enqueue() {\n      if (queue.length >= MAX_SIZE) {\n        enqueueBtn.disabled = true;\n        return;\n      }\n      const newVal = randomNumber();\n      queue.push(newVal);\n      renderQueue();\n      enqueueBtn.disabled = queue.length >= MAX_SIZE;\n      dequeueBtn.disabled = queue.length === 0;\n    }\n\n    // Dequeue operation with animation\n    function dequeue() {\n      if (queue.length === 0) {\n        dequeueBtn.disabled = true;\n        return;\n      }\n      queue.shift();\n      renderQueue();\n      enqueueBtn.disabled = false;\n      dequeueBtn.disabled = queue.length === 0;\n    }\n\n    // Attach listeners with subtle debounce for elegance\n    enqueueBtn.addEventListener('click', () => {\n      enqueueBtn.disabled = true;\n      enqueue();\n      setTimeout(() => {\n        enqueueBtn.disabled = queue.length >= MAX_SIZE;\n      }, 400);\n    });\n\n    dequeueBtn.addEventListener('click', () => {\n      dequeueBtn.disabled = true;\n      dequeue();\n      setTimeout(() => {\n        dequeueBtn.disabled = queue.length === 0;\n      }, 400);\n    });\n\n    // Initial render\n    renderQueue();\n\n  })();\n</script>\n</body>\n</html>"
