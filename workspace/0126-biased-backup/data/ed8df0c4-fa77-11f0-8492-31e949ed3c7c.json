    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Recursion Visualizer</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            overflow: hidden;\n            background: linear-gradient(to bottom right, #1a2a6c, #b21f1f, #fdbb2d);\n            color: white;\n        }\n        \n        .container {\n            display: flex;\n            height: 100vh;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n            position: relative;\n            text-align: center;\n        }\n        \n        h1 {\n            font-size: 3em;\n            margin-bottom: 0.5em;\n            text-shadow: 2px 2px 10px rgba(0,0,0,0.3);\n        }\n        \n        p {\n            font-size: 1.2em;\n            margin-bottom: 1.5em;\n        }\n        \n        #visualization {\n            position: relative;\n            width: 400px;\n            height: 400px;\n            border: 5px solid rgba(255, 255, 255, 0.6);\n            border-radius: 15px;\n            overflow: hidden;\n        }\n        \n        .circle {\n            position: absolute;\n            border: 5px solid rgba(255, 255, 255, 0.8);\n            border-radius: 50%;\n            animation: fade-in 2s ease-in;\n        }\n        \n        @keyframes fade-in {\n            0% {\n                opacity: 0;\n            }\n            100% {\n                opacity: 1;\n            }\n        }\n        \n        button {\n            background-color: rgba(255, 255, 255, 0.2);\n            border: none;\n            color: white;\n            padding: 10px 20px;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n            font-size: 1em;\n        }\n        \n        button:hover {\n            background-color: rgba(255, 255, 255, 0.4);\n        }\n        \n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Recursion Visualizer</h1>\n        <p>Observe the beauty of recursion through this animated visualization.</p>\n        <div id=\"visualization\"></div>\n        <button onclick=\"startRecursion()\">Start Visualization</button>\n    </div>\n\n    <script>\n        let depth = 0;\n\n        function drawCircle(x, y, radius) {\n            const circle = document.createElement('div');\n            circle.className = 'circle';\n            circle.style.width = circle.style.height = (radius * 2) + 'px';\n            circle.style.left = (x - radius) + 'px';\n            circle.style.top = (y - radius) + 'px';\n            document.getElementById('visualization').appendChild(circle);\n        }\n\n        function recursion(x, y, radius) {\n            if (radius < 5) return;\n            drawCircle(x, y, radius);\n            const newRadius = radius * 0.5;\n            recursion(x + newRadius, y, newRadius); // Right\n            recursion(x - newRadius, y, newRadius); // Left\n            recursion(x, y + newRadius, newRadius); // Down\n            recursion(x, y - newRadius, newRadius); // Up\n        }\n\n        function startRecursion() {\n            depth++;\n            const startRadius = 100;\n            document.getElementById('visualization').innerHTML = '';\n            recursion(200, 200, startRadius);\n        }\n    </script>\n</body>\n</html>"
