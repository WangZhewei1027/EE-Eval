n-bottom: 3rem;\n  }\n\n  /* The rotating outer ring with dashes */\n  .ring {\n    position: absolute;\n    border-radius: 50%;\n    top: 50%;\n    left: 50%;\n    width: 300px;\n    height: 300px;\n    margin-left: -150px;\n    margin-top: -150px;\n    box-shadow:\n      0 0 15px var(--secondary),\n      inset 0 0 20px var(--accent1);\n    animation: ringSpin 40s linear infinite;\n  }\n\n  .ring::before {\n    content: '';\n    position: absolute;\n    width: 280px;\n    height: 280px;\n    border-radius: 50%;\n    top: 10px;\n    left: 10px;\n    box-shadow:\n      0 0 25px var(--accent2),\n      inset 0 0 30px var(--accent2);\n    filter: drop-shadow(0 0 5px var(--accent2));\n  }\n\n  /* The text ring */\n  .text-ring {\n    position: absolute;\n    width: 300px;\n    height: 300px;\n    top: 50%;\n    left: 50%;\n    margin-left: -150px;\n    margin-top: -150px;\n    pointer-events: none;\n  }\n\n  .text-ring span {\n    filter: drop-shadow(0 0 3px var(--primary));\n    font-family: var(--font-mono);\n    font-weight: 600;\n    font-size: 1.05rem;\n    color: var(--primary);\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform-origin: 0 120px;\n    user-select: none;\n  }\n\n  /* Inner core */\n  .core {\n    position: relative;\n    width: 180px;\n    height: 180px;\n    border-radius: 50%;\n    background: radial-gradient(circle at center, #0e1623 35%, #132334 90%);\n    box-shadow:\n      inset 0 0 18px #0b1b2a,\n      0 0 18px var(--accent1);\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    color: var(--accent1);\n    font-family: var(--font-mono);\n    text-align: center;\n    filter: drop-shadow(0 0 6px var(--accent1));\n    animation: pulseGlow 4s ease-in-out infinite;\n  }\n\n  .core .lock-icon {\n    margin-bottom: 1rem;\n    width: 64px;\n    height: 64px;\n    fill: var(--accent1);\n    filter: drop-shadow(0 0 6px var(--accent1));\n    animation: lockPulse 3.6s ease-in-out infinite;\n  }\n\n  .core strong {\n    font-weight: 700;\n    font-size: 1.6rem;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n  }\n\n  /* Subtitle below core */\n  .core .desc {\n    margin-top: 0.3rem;\n    font-size: 0.9rem;\n    color: var(--text-lighter);\n    font-style: italic;\n    user-select: none;\n  }\n\n  /* Button style */\n  .btn {\n    padding: 0.85rem 2.5rem;\n    border: none;\n    outline: none;\n    border-radius: 36px;\n    background: linear-gradient(135deg, var(--secondary), var(--accent2));\n    color: #111827;\n    font-family: var(--font-mono);\n    font-weight: 700;\n    font-size: 1.1rem;\n    cursor: pointer;\n    box-shadow:\n      0 5px 15px rgba(255, 117, 143, 0.6),\n      inset 0 -3px 6px rgba(255, 255, 255, 0.25);\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    user-select: none;\n    letter-spacing: 0.08em;\n  }\n\n  .btn:hover,\n  .btn:focus {\n    background: linear-gradient(135deg, var(--accent2), var(--secondary));\n    box-shadow:\n      0 8px 20px rgba(80, 227, 194, 0.9),\n      inset 0 -3px 10px rgba(255, 255, 255, 0.4);\n    transform: scale(1.05);\n  }\n\n  /* Footer note */\n  .footer-note {\n    margin-top: 3rem;\n    font-size: 0.85rem;\n    font-style: italic;\n    color: var(--text-lighter);\n    font-family: var(--font-mono);\n    letter-spacing: 0.06em;\n    user-select: none;\n  }\n\n  /* Animations */\n  @keyframes ringSpin {\n    0% {\n      transform: translate(-50%, -50%) rotate(0deg);\n    }\n    100% {\n      transform: translate(-50%, -50%) rotate(360deg);\n    }\n  }\n\n  @keyframes pulseGlow {\n    0%, 100% {\n      box-shadow:\n      inset 0 0 18px #0b1b2a,\n      0 0 18px var(--accent1);\n    }\n    50% {\n      box-shadow:\n      inset 0 0 28px #0b1b2a,\n      0 0 28px var(--accent1);\n    }\n  }\n\n  @keyframes lockPulse {\n    0%, 100% {\n      filter: drop-shadow(0 0 6px var(--accent1));\n      transform: scale(1);\n    }\n    50% {\n      filter: drop-shadow(0 0 16px var(--accent1));\n      transform: scale(1.08);\n    }\n  }\n\n</style>\n</head>\n<body>\n  <h1>ENCRYPTION</h1>\n  <h2>The Art of Secrets</h2>\n\n  <div class=\"circle-container\" aria-label=\"Encryption Cipher Graphic\">\n    <div class=\"ring\"></div>\n\n    <div class=\"text-ring\" aria-hidden=\"true\">\n      <!-- We'll create a circular text with the phrase repeating -->\n    </div>\n\n    <div class=\"core\" aria-label=\"Lock symbolizing encryption\">\n      <svg class=\"lock-icon\" viewBox=\"0 0 64 64\" aria-hidden=\"true\" focusable=\"false\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M44 26h-4v-8a8 8 0 0 0-16 0v8h-4a4 4 0 0 0-4 4v22a4 4 0 0 0 4 4h24a4 4 0 0 0 4-4V30a4 4 0 0 0-4-4zm-16-8a4 4 0 0 1 8 0v8h-8zm16 34H24V30h20z\"/>\n      </svg>\n      <strong>SECURE</strong>\n      <div class=\"desc\">Confidentiality & Trust</div>\n    </div>\n  </div>\n\n  <button class=\"btn\" id=\"toggleRing\">Pause Rotation</button>\n\n  <div class=\"footer-note\">Experience the unseen protection of encrypted secrets.</div>\n\n  <script>\n    // Create circular text\n    const phrase = \" ENCRYPTION  \";\n    const repeatCount = 16;\n    const textRing = document.querySelector('.text-ring');\n    const chars = (phrase.repeat(repeatCount)).split('');\n    const charCount = chars.length;\n    const radius = 120;\n\n    chars.forEach((ch, i) => {\n      const span = document.createElement('span');\n      span.textContent = ch;\n      const angle = (360 / charCount) * i;\n      span.style.transform = `rotate(${angle}deg) translate(${radius}px) rotate(${angle * -1}deg)`;\n      textRing.appendChild(span);\n    });\n\n    // Button interaction - pause/resume ring rotation\n    const ring = document.querySelector('.ring');\n    const btn = document.getElementById('toggleRing');\n    let rotating = true;\n\n    btn.addEventListener('click', () => {\n      if (rotating) {\n        ring.style.animationPlayState = 'paused';\n        btn.textContent = 'Resume Rotation';\n      } else {\n        ring.style.animationPlayState = 'running';\n        btn.textContent = 'Pause Rotation';\n      }\n      rotating = !rotating;\n    });\n  </script>\n</body>\n</html>"
