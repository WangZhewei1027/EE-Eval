    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dijkstra's Algorithm Interactive Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #graph { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Dijkstra's Algorithm Interactive Demo</h1>\n\n    <label for=\"nodes\">Enter Nodes (comma separated):</label>\n    <input type=\"text\" id=\"nodes\" placeholder=\"A,B,C,D,E\" />\n    \n    <label for=\"edges\">Enter Edges (e.g., A-B:1,B-C:2,...):</label>\n    <input type=\"text\" id=\"edges\" placeholder=\"A-B:1,B-C:2\" />\n    \n    <button id=\"createGraph\">Create Graph</button>\n    <button id=\"findShortestPath\">Find Shortest Path</button>\n    \n    <div id=\"graph\"></div>\n    <div id=\"result\"></div>\n\n    <script>\n        let graph = {};\n        let startNode = '';\n        let endNode = '';\n\n        document.getElementById(\"createGraph\").onclick = function() {\n            const nodesInput = document.getElementById(\"nodes\").value.split(',').map(n => n.trim());\n            const edgesInput = document.getElementById(\"edges\").value.split(',').map(e => e.trim());\n\n            graph = {};\n            nodesInput.forEach(node => {\n                graph[node] = {};\n            });\n\n            edgesInput.forEach(edge => {\n                const [connection, weight] = edge.split(':');\n                const [nodeA, nodeB] = connection.split('-');\n                graph[nodeA][nodeB] = parseInt(weight);\n                graph[nodeB][nodeA] = parseInt(weight); // undirected graph\n            });\n\n            document.getElementById(\"result\").innerText = \"Graph created. You can now find the shortest path.\";\n        };\n\n        document.getElementById(\"findShortestPath\").onclick = function() {\n            startNode = prompt(\"Enter start node:\");\n            endNode = prompt(\"Enter end node:\");\n            const shortestPath = dijkstra(graph, startNode, endNode);\n            document.getElementById(\"result\").innerText = shortestPath \n                ? `Shortest path from ${startNode} to ${endNode}: ${shortestPath.path.join(\" -> \")} with cost ${shortestPath.cost}` \n                : \"Path not found.\";\n        };\n\n        function dijkstra(graph, start, end) {\n            const distances = {};\n            const previous = {};\n            const unvisited = new Set();\n\n            for (let node in graph) {\n                distances[node] = Infinity;\n                previous[node] = null;\n                unvisited.add(node);\n            }\n\n            distances[start] = 0;\n\n            while (unvisited.size > 0) {\n                const currentNode = Array.from(unvisited).reduce((minNode, node) => \n                    distances[node] < distances[minNode] ? node : minNode);\n                \n                if (currentNode === end) {\n                    const path = [];\n                    let cost = distances[currentNode];\n                    while (currentNode) {\n                        path.push(currentNode);\n                        currentNode = previous[currentNode];\n                    }\n                    return { path: path.reverse(), cost: cost };\n                }\n\n                unvisited.delete(currentNode);\n                for (let neighbor in graph[currentNode]) {\n                    const edgeWeight = graph[currentNode][neighbor];\n                    const newDistance = distances[currentNode] + edgeWeight;\n\n                    if (newDistance < distances[neighbor]) {\n                        distances[neighbor] = newDistance;\n                        previous[neighbor] = currentNode;\n                    }\n                }\n            }\n            return null; // If no path found\n        }\n    </script>\n</body>\n</html>"
