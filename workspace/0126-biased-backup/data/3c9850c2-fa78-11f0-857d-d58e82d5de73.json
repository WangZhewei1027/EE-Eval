    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Greedy Algorithms — Elegant Visualization</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@500&family=Montserrat:wght@400;700&display=swap');\n\n  /* Reset */\n  * {\n    box-sizing: border-box;\n  }\n  body {\n    margin: 0;\n    min-height: 100vh;\n    background: linear-gradient(130deg, #1e3c72 0%, #2a5298 50%, #1f4037 100%);\n    color: #f4f4f9;\n    font-family: 'Montserrat', sans-serif;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  header {\n    margin: 2.5rem 1rem 1rem;\n    text-align: center;\n  }\n  header h1 {\n    font-family: 'Roboto Slab', serif;\n    font-size: 3.75rem;\n    font-weight: 700;\n    line-height: 1.1;\n    letter-spacing: 0.03em;\n    color: #ecf0f1;\n    text-shadow:\n       2px 2px 8px rgba(0,0,0,0.4),\n       0 0 10px rgba(56,149,243,0.8);\n    margin-bottom: 0.25rem;\n  }\n  header p {\n    font-size: 1.15rem;\n    font-weight: 400;\n    max-width: 420px;\n    margin: 0 auto;\n    color: #dbe9f4cc;\n    letter-spacing: 0.02em;\n  }\n\n  main {\n    position: relative;\n    overflow: visible;\n    max-width: 900px;\n    width: 90vw;\n    margin: 4rem auto 5rem;\n    padding: 2rem 2.5rem 3rem;\n    background: linear-gradient(145deg, #253244 0%, #3a536b 100%);\n    border-radius: 32px;\n    box-shadow:\n       inset 0 0 12px 2px rgba(0, 111, 255, 0.33),\n       0 16px 40px rgba(0, 0, 0, 0.4);\n  }\n\n  /* Algorithm Description */\n  main .description {\n    font-size: 1.125rem;\n    font-weight: 300;\n    line-height: 1.6;\n    color: #abb7c3cc;\n    text-align: center;\n    margin-bottom: 3rem;\n  }\n\n  /* Visualization Container */\n  #viz {\n    position: relative;\n    width: 100%;\n    height: 280px;\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-end;\n    gap: 20px;\n    padding: 0 6px;\n  }\n\n  /* Item Bars - Inputs */\n  .bar {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    cursor: default;\n    user-select: none;\n  }\n\n  .bar .rect {\n    width: 52px;\n    background: linear-gradient(180deg, #457b9d 0%, #1d3557 100%);\n    border-radius: 12px 12px 4px 4px;\n    box-shadow: 0 6px 10px rgba(17, 50, 81, 0.7);\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    color: #a8dadc;\n    font-weight: 600;\n    font-family: 'Roboto Slab', serif;\n    font-size: 1rem;\n    letter-spacing: 0.04em;\n    transition: background 0.5s ease;\n    position: relative;\n    overflow: visible;\n    user-select: none;\n  }\n\n  .bar .rect::after {\n    content: attr(data-weight);\n    position: absolute;\n    bottom: calc(100% + 10px);\n    left: 50%;\n    transform: translateX(-50%);\n    font-size: 0.875rem;\n    font-weight: 500;\n    color: #e0f7faee;\n    text-shadow: 0 0 3px #12a4ceaa;\n  }\n\n  .bar .label {\n    margin-top: 14px;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: #caf0f8cc;\n    letter-spacing: 0.06em;\n    user-select: none;\n  }\n\n  /* Selected bars style */\n  .selected .rect {\n    background: linear-gradient(180deg, #ffb703cc 0%, #fb8500ee 100%);\n    box-shadow: 0 10px 26px #ff8c0077;\n    color: #fff8f0;\n  }\n  .selected .rect::after {\n    color: #ffddb1cc;\n    text-shadow: 0 0 6px #ff9f01bb;\n  }\n\n  /* Capacity Bar & Label */\n  #capacityDisplay {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-top: 2rem;\n    font-family: 'Roboto Slab', serif;\n    font-weight: 600;\n    font-size: 1.3rem;\n    color: #fefefecc;\n    letter-spacing: 0.05em;\n    filter: drop-shadow(0 0 2px #15a0db99);\n    user-select: none;\n  }\n  #capacityDisplay span {\n    margin-left: 0.6rem;\n    font-weight: 700;\n    color: #49a6e9;\n    text-shadow: 0 0 8px #1b81b533;\n  }\n\n  /* Buttons Container */\n  #buttons {\n    display: flex;\n    justify-content: center;\n    gap: 2.5rem;\n    margin-top: 3.5rem;\n  }\n\n  button {\n    background: linear-gradient(145deg, #4895efdd, #3a6fccff);\n    border: none;\n    border-radius: 14px;\n    padding: 0.85rem 2.2rem;\n    font-family: 'Montserrat', sans-serif;\n    font-weight: 700;\n    font-size: 1.1rem;\n    color: #e1e9ff;\n    cursor: pointer;\n    box-shadow:\n      0 4px 10px #2d5da8cc,\n      inset 0 2px 5px #a3befeaa;\n    transition:\n      background 0.4s ease,\n      box-shadow 0.3s ease,\n      transform 0.3s ease;\n    user-select: none;\n  }\n  button:hover {\n    background: linear-gradient(145deg, #47a9ffee, #2f70c5ff);\n    box-shadow:\n      0 5px 15px #2d5da8ff,\n      inset 0 3px 8px #a3befecc;\n    transform: translateY(-3px);\n  }\n  button:active {\n    transform: translateY(-1px);\n    box-shadow:\n      0 3px 7px #1d3e66cc,\n      inset 0 1px 4px #82b4ffcc;\n  }\n  button:focus-visible {\n    outline: 3px solid #66b2ffaa;\n    outline-offset: 4px;\n  }\n\n  /* Footer credit */\n  footer {\n    font-size: 0.875rem;\n    font-weight: 400;\n    color: #748ca0cc;\n    font-family: 'Montserrat', sans-serif;\n    margin-bottom: 1.5rem;\n    user-select: none;\n  }\n\n  /* Animations */\n  @keyframes growBar {\n    from { height: 0; }\n    to { height: var(--height); }\n  }\n  @keyframes pulseSelected {\n    0%, 100% { box-shadow: 0 10px 26px #ff8c0077; filter: brightness(1); }\n    50% { box-shadow: 0 20px 34px #ffb200cc; filter: brightness(1.1); }\n  }\n\n  .selected .rect {\n    animation: pulseSelected 2.6s infinite ease-in-out;\n  }\n\n</style>\n</head>\n<body>\n  <header>\n    <h1>Greedy Algorithms</h1>\n    <p>A visual journey into how greedy algorithms build optimal solutions step-by-step.</p>\n  </header>\n\n  <main role=\"main\" aria-label=\"Greedy algorithms visualization\">\n    <div class=\"description\">\n      Consider a simplified <em>knapsack style</em> problem, where items have weights, and we want to fill the knapsack without exceeding capacity by picking largest weight items first (a simple greedy approach).\n    </div>\n\n    <section id=\"viz\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n      <!-- Bars are generated by JS -->\n    </section>\n\n    <div id=\"capacityDisplay\" aria-label=\"Current knapsack capacity\">\n      Capacity left:\n      <span id=\"capacityValue\">50</span>\n    </div>\n\n    <div id=\"buttons\">\n      <button id=\"stepBtn\" aria-label=\"Perform one greedy selection step\">Step</button>\n      <button id=\"resetBtn\" aria-label=\"Reset the visualization\">Reset</button>\n    </div>\n  </main>\n\n  <footer>&copy; 2024 &nbsp;&middot;&nbsp; Elegant Algorithms Visualized</footer>\n\n<script>\n(() => {\n  // Items with weights (random but fixed for demo)\n  const items = [\n    { id: 'A', weight: 12 },\n    { id: 'B', weight: 25 },\n    { id: 'C', weight: 10 },\n    { id: 'D', weight: 18 },\n    { id: 'E', weight: 7  },\n    { id: 'F', weight: 22 },\n    { id: 'G', weight: 20 },\n  ];\n\n  // Maximum capacity\n  const MAX_CAPACITY = 50;\n\n  // Sorting by descending weight greedy style\n  const sortedItems = [...items].sort((a, b) => b.weight - a.weight);\n\n  // Dynamically create bars in viz container\n  const viz = document.getElementById('viz');\n  const capacityDisplay = document.getElementById('capacityValue');\n  const stepBtn = document.getElementById('stepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Store bars and state\n  let bars = [];\n  let capacityLeft = MAX_CAPACITY;\n  let selectedIndices = new Set();\n\n  // Utility: Height scale (max height 160px for largest weight)\n  const MAX_BAR_HEIGHT = 160;\n  const maxWeight = Math.max(...items.map(it => it.weight));\n  const weightToHeight = weight => (weight / maxWeight) * MAX_BAR_HEIGHT + 30; // min height 30px\n\n  function createBar(item, index) {\n    const bar = document.createElement('div');\n    bar.classList.add('bar');\n    bar.setAttribute('role', 'listitem');\n    bar.setAttribute('aria-label', `Item ${item.id} with weight ${item.weight}`);\n\n    const rect = document.createElement('div');\n    rect.classList.add('rect');\n    rect.dataset.weight = item.weight;\n    const h = weightToHeight(item.weight).toFixed(1) + 'px';\n    rect.style.setProperty('--height', h);\n    rect.style.height = '0px'; // animate grow\n    // Animate grow with delay based on index for smooth cascade\n    setTimeout(() => {\n      rect.style.transition = 'height 0.8s cubic-bezier(0.4, 0, 0.2, 1)';\n      rect.style.height = h;\n    }, 250 + index * 130);\n\n    // Label below bar\n    const label = document.createElement('div');\n    label.classList.add('label');\n    label.textContent = item.id;\n\n    bar.appendChild(rect);\n    bar.appendChild(label);\n\n    return bar;\n  }\n\n  // Initialize visualization\n  function initViz() {\n    viz.innerHTML = '';\n    bars = [];\n\n    // Sorted items for visual clarity\n    sortedItems.forEach((item, i) => {\n      const bar = createBar(item, i);\n      viz.appendChild(bar);\n      bars.push({ bar, item, selected: false });\n    });\n\n    capacityLeft = MAX_CAPACITY;\n    capacityDisplay.textContent = capacityLeft.toString();\n    selectedIndices.clear();\n    stepBtn.disabled = false;\n  }\n\n  // Greedy step: pick largest not yet selected item that fits\n  function step() {\n    // Find first not selected item that fits\n    const nextIndex = bars.findIndex(({ item, selected }) => !selected && item.weight <= capacityLeft);\n    if (nextIndex === -1) {\n      stepBtn.disabled = true;\n      return;\n    }\n\n    const barObj = bars[nextIndex];\n\n    // Mark selected visually\n    barObj.selected = true;\n    barObj.bar.classList.add('selected');\n\n    // Reduce capacity\n    capacityLeft -= barObj.item.weight;\n    capacityDisplay.textContent = capacityLeft.toString();\n\n    // If after selection no more fits, disable step button\n    if (!bars.some(({item, selected}) => !selected && item.weight <= capacityLeft)) {\n      stepBtn.disabled = true;\n    }\n  }\n\n  // Reset to initial state\n  function reset() {\n    initViz();\n  }\n\n  // Initialize\n  initViz();\n\n  // Event listeners\n  stepBtn.addEventListener('click', step);\n  resetBtn.addEventListener('click', reset);\n})();\n</script>\n</body>\n</html>"
