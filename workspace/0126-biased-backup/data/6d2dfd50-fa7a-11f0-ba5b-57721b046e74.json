    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Radix Sort Interactive Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 1000px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .control-panel {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-bottom: 20px;\n        }\n        .control-group {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-right: 10px;\n        }\n        .array-display {\n            font-family: monospace;\n            font-size: 18px;\n            min-height: 100px;\n            border: 1px solid #000;\n            padding: 10px;\n            white-space: pre-wrap;\n        }\n        .step-info {\n            border: 1px solid #000;\n            padding: 10px;\n            min-height: 50px;\n        }\n        .buckets-display {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 10px;\n            margin-top: 20px;\n        }\n        .bucket {\n            border: 1px solid #000;\n            padding: 5px;\n            min-width: 100px;\n        }\n        .current-digit {\n            background-color: #eee;\n        }\n        .sorted {\n            font-weight: bold;\n        }\n        button {\n            padding: 5px 10px;\n            margin: 2px;\n        }\n        input[type=\"range\"] {\n            width: 200px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Radix Sort Interactive Demo</h1>\n        \n        <div class=\"control-panel\">\n            <div class=\"control-group\">\n                <h3>Array Configuration</h3>\n                <div>\n                    <label>Array Size: <span id=\"sizeValue\">10</span></label>\n                    <input type=\"range\" id=\"arraySize\" min=\"5\" max=\"30\" value=\"10\">\n                </div>\n                <div>\n                    <label>Number Range: 0 to <span id=\"rangeValue\">999</span></label>\n                    <input type=\"range\" id=\"numberRange\" min=\"100\" max=\"9999\" value=\"999\" step=\"1\">\n                </div>\n                <button id=\"randomize\">Generate Random Array</button>\n                <button id=\"manualInput\">Enter Manually</button>\n                <div id=\"manualInputArea\" style=\"display: none;\">\n                    <textarea id=\"manualArray\" rows=\"2\" cols=\"30\" placeholder=\"e.g. 123, 45, 678\"></textarea>\n                    <button id=\"submitManual\">Submit</button>\n                </div>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Sorting Controls</h3>\n                <div>\n                    Base: \n                    <select id=\"baseSelect\">\n                        <option value=\"2\">Binary (2)</option>\n                        <option value=\"8\">Octal (8)</option>\n                        <option value=\"10\" selected>Decimal (10)</option>\n                        <option value=\"16\">Hexadecimal (16)</option>\n                    </select>\n                </div>\n                <div>\n                    Direction: \n                    <select id=\"directionSelect\">\n                        <option value=\"lsd\">Least Significant Digit (LSD)</option>\n                        <option value=\"msd\">Most Significant Digit (MSD)</option>\n                    </select>\n                </div>\n                <button id=\"startSort\">Start Sorting</button>\n                <button id=\"nextStep\" disabled>Next Step</button>\n                <button id=\"autoStep\" disabled>Auto Step (0.5s)</button>\n                <button id=\"reset\">Reset</button>\n            </div>\n            \n            <div class=\"control-group\">\n                <h3>Visualization</h3>\n                <div>\n                    <label>Speed: <span id=\"speedValue\">500</span>ms</label>\n                    <input type=\"range\" id=\"speedControl\" min=\"100\" max=\"2000\" value=\"500\" step=\"100\">\n                </div>\n                <div>\n                    <input type=\"checkbox\" id=\"showBinary\" checked>\n                    <label for=\"showBinary\">Show binary representation</label>\n                </div>\n                <div>\n                    <input type=\"checkbox\" id=\"showCount\" checked>\n                    <label for=\"showCount\">Show counting phase</label>\n                </div>\n            </div>\n        </div>\n        \n        <div class=\"step-info\" id=\"stepDescription\">\n            Click \"Generate Random Array\" or \"Enter Manually\" to begin.\n        </div>\n        \n        <div class=\"array-display\" id=\"arrayDisplay\"></div>\n        \n        <div id=\"countingPhase\" style=\"display: none;\">\n            <h3>Counting Phase</h3>\n            <div id=\"countArray\"></div>\n        </div>\n        \n        <div id=\"bucketsPhase\" style=\"display: none;\">\n            <h3>Buckets (Digit <span id=\"currentDigit\">0</span>)</h3>\n            <div class=\"buckets-display\" id=\"bucketsDisplay\"></div>\n        </div>\n        \n        <div id=\"sortInfo\">\n            <h3>Sorting Information</h3>\n            <div>Max digits: <span id=\"maxDigits\">0</span></div>\n            <div>Current pass: <span id=\"currentPass\">0</span>/<span id=\"totalPasses\">0</span></div>\n            <div>Current digit position: <span id=\"digitPosition\">0</span> (from right)</div>\n        </div>\n    </div>\n\n    <script>\n        // State variables\n        let originalArray = [];\n        let workingArray = [];\n        let sortState = {\n            isSorting: false,\n            currentPass: 0,\n            currentDigit: 0,\n            maxDigits: 0,\n            base: 10,\n            direction: 'lsd',\n            autoStepInterval: null\n        };\n        \n        // DOM elements\n        const arrayDisplay = document.getElementById('arrayDisplay');\n        const stepDescription = document.getElementById('stepDescription');\n        const bucketsDisplay = document.getElementById('bucketsDisplay');\n        const countArray = document.getElementById('countArray');\n        const currentDigitSpan = document.getElementById('currentDigit');\n        const maxDigitsSpan = document.getElementById('maxDigits');\n        const currentPassSpan = document.getElementById('currentPass');\n        const totalPassesSpan = document.getElementById('totalPasses');\n        const digitPositionSpan = document.getElementById('digitPosition');\n        \n        // Initialize\n        document.addEventListener('DOMContentLoaded', () => {\n            updateArraySizeDisplay();\n            generateRandomArray();\n            \n            // Event listeners\n            document.getElementById('arraySize').addEventListener('input', updateArraySizeDisplay);\n            document.getElementById('numberRange').addEventListener('input', updateNumberRangeDisplay);\n            document.getElementById('randomize').addEventListener('click', generateRandomArray);\n            document.getElementById('manualInput').addEventListener('click', toggleManualInput);\n            document.getElementById('submitManual').addEventListener('click', submitManualArray);\n            document.getElementById('startSort').addEventListener('click', startSorting);\n            document.getElementById('nextStep').addEventListener('click', performNextStep);\n            document.getElementById('autoStep').addEventListener('click', toggleAutoStep);\n            document.getElementById('reset').addEventListener('click', resetSort);\n            document.getElementById('baseSelect').addEventListener('change', updateBase);\n            document.getElementById('directionSelect').addEventListener('change', updateDirection);\n            document.getElementById('speedControl').addEventListener('input', updateSpeed);\n        });\n        \n        function updateArraySizeDisplay() {\n            document.getElementById('sizeValue').textContent = document.getElementById('arraySize').value;\n        }\n        \n        function updateNumberRangeDisplay() {\n            document.getElementById('rangeValue').textContent = document.getElementById('numberRange').value;\n        }\n        \n        function updateSpeed() {\n            const speed = document.getElementById('speedControl').value;\n            document.getElementById('speedValue').textContent = speed;\n        }\n        \n        function updateBase() {\n            sortState.base = parseInt(document.getElementById('baseSelect').value);\n        }\n        \n        function updateDirection() {\n            sortState.direction = document.getElementById('directionSelect').value;\n        }\n        \n        function generateRandomArray() {\n            const size = parseInt(document.getElementById('arraySize').value);\n            const max = parseInt(document.getElementById('numberRange').value);\n            \n            originalArray = [];\n            for (let i = 0; i < size; i++) {\n                originalArray.push(Math.floor(Math.random() * (max + 1)));\n            }\n            \n            resetSort();\n        }\n        \n        function toggleManualInput() {\n            const manualInputArea = document.getElementById('manualInputArea');\n            manualInputArea.style.display = manualInputArea.style.display === 'none' ? 'block' : 'none';\n        }\n        \n        function submitManualArray() {\n            const input = document.getElementById('manualArray').value;\n            try {\n                originalArray = input.split(',')\n                    .map(item => parseInt(item.trim()))\n                    .filter(item => !isNaN(item));\n                \n                if (originalArray.length === 0) {\n                    throw new Error(\"No valid numbers entered\");\n                }\n                \n                document.getElementById('manualInputArea').style.display = 'none';\n                resetSort();\n            } catch (e) {\n                stepDescription.textContent = \"Invalid input. Please use comma-separated numbers.\";\n            }\n        }\n        \n        function resetSort() {\n            workingArray = [...originalArray];\n            sortState.isSorting = false;\n            sortState.currentPass = 0;\n            sortState.currentDigit = 0;\n            sortState.maxDigits = getMaxDigits();\n            \n            document.getElementById('nextStep').disabled = false;\n            document.getElementById('autoStep').disabled = false;\n            document.getElementById('startSort').disabled = false;\n            \n            if (sortState.autoStepInterval) {\n                clearInterval(sortState.autoStepInterval);\n                sortState.autoStepInterval = null;\n                document.getElementById('autoStep').textContent = 'Auto Step (0.5s)';\n            }\n            \n            updateDisplay();\n            document.getElementById('countingPhase').style.display = 'none';\n            document.getElementById('bucketsPhase').style.display = 'none';\n            \n            maxDigitsSpan.textContent = sortState.maxDigits;\n            currentPassSpan.textContent = sortState.currentPass;\n            totalPassesSpan.textContent = sortState.maxDigits;\n            digitPositionSpan.textContent = sortState.direction === 'lsd' ? '0' : (sortState.maxDigits - 1);\n            \n            stepDescription.textContent = 'Ready to sort. Click \"Start Sorting\" to begin.';\n        }\n        \n        function getMaxDigits() {\n            const base = sortState.base;\n            let max = Math.max(...originalArray);\n            let digits = 0;\n            \n            while (max > 0) {\n                digits++;\n                max = Math.floor(max / base);\n            }\n            \n            return digits || 1; // At least 1 digit\n        }\n        \n        function startSorting() {\n            sortState.isSorting = true;\n            document.getElementById('startSort').disabled = true;\n            stepDescription.textContent = 'Sorting started. Click \"Next Step\" to proceed.';\n            \n            if (sortState.direction === 'msd') {\n                sortState.currentDigit = sortState.maxDigits - 1;\n            } else {\n                sortState.currentDigit = 0;\n            }\n            \n            updateDisplay();\n        }\n        \n        function performNextStep() {\n            if (!sortState.isSorting) return;\n            \n            const base = sortState.base;\n            const digitPos = sortState.direction === 'lsd' ? \n                sortState.currentDigit : \n                (sortState.maxDigits - 1 - sortState.currentDigit);\n            \n            // Show counting phase if enabled\n            if (document.getElementById('showCount').checked) {\n                showCountingPhase(digitPos);\n                return;\n            }\n            \n            // Perform the actual sorting step\n            const buckets = Array.from({ length: base }, () => []);\n            \n            for (const num of workingArray) {\n                const digit = getDigit(num, digitPos, base);\n                buckets[digit].push(num);\n            }\n            \n            // For LSD, concatenate all buckets in order\n            if (sortState.direction === 'lsd') {\n                workingArray = buckets.flat();\n            } \n            // For MSD, we need to recursively sort each bucket\n            else {\n                workingArray = [];\n                for (let i = 0; i < buckets.length; i++) {\n                    if (buckets[i].length > 1 && sortState.currentDigit < sortState.maxDigits - 1) {\n                        // For MSD, we'd normally recursively sort here, but for simplicity we'll just concatenate\n                        // In a full implementation, we'd need to track recursion state\n                        workingArray.push(...buckets[i]);\n                    } else {\n                        workingArray.push(...buckets[i]);\n                    }\n                }\n            }\n            \n            // Update state for next step\n            sortState.currentPass++;\n            if (sortState.direction === 'lsd') {\n                sortState.currentDigit++;\n            } else {\n                sortState.currentDigit--;\n            }\n            \n            // Check if sorting is complete\n            const isComplete = sortState.direction === 'lsd' ? \n                sortState.currentDigit >= sortState.maxDigits : \n                sortState.currentDigit < 0;\n            \n            if (isComplete) {\n                sortState.isSorting = false;\n                stepDescription.textContent = 'Sorting complete!';\n                document.getElementById('nextStep').disabled = true;\n                document.getElementById('autoStep').disabled = true;\n                \n                if (sortState.autoStepInterval) {\n                    clearInterval(sortState.autoStepInterval);\n                    sortState.autoStepInterval = null;\n                    document.getElementById('autoStep').textContent = 'Auto Step (0.5s)';\n                }\n            } else {\n                stepDescription.textContent = `Processing ${sortState.direction.toUpperCase()} digit position ${digitPos}`;\n            }\n            \n            // Update display\n            currentPassSpan.textContent = sortState.currentPass;\n            digitPositionSpan.textContent = digitPos;\n            \n            updateDisplay();\n            showBuckets(buckets, digitPos);\n        }\n        \n        function showCountingPhase(digitPos) {\n            const base = sortState.base;\n            const count = Array(base).fill(0);\n            \n            for (const num of workingArray) {\n                const digit = getDigit(num, digitPos, base);\n                count[digit]++;\n            }\n            \n            // Display counting array\n            let countHTML = '<div>Counting digits at position ' + digitPos + ':</div><div>';\n            for (let i = 0; i < base; i++) {\n                countHTML += `<span style=\"margin-right: 20px;\">${i}: ${count[i]}</span>`;\n            }\n            countHTML += '</div>';\n            \n            countArray.innerHTML = countHTML;\n            document.getElementById('countingPhase').style.display = 'block';\n            \n            // After showing counting, the next step will be the actual sorting\n            document.getElementById('showCount').checked = false;\n            stepDescription.textContent = 'Counting phase complete. Next step will distribute numbers into buckets.';\n        }\n        \n        function getDigit(num, position, base) {\n            return Math.floor(num / Math.pow(base, position)) % base;\n        }\n        \n        function showBuckets(buckets, digitPos) {\n            currentDigitSpan.textContent = digitPos;\n            \n            let bucketsHTML = '';\n            for (let i = 0; i < buckets.length; i++) {\n                bucketsHTML += `<div class=\"bucket\">\n                    <div>Digit ${i}:</div>\n                    <div>${buckets[i].join(', ')}</div>\n                </div>`;\n            }\n            \n            bucketsDisplay.innerHTML = bucketsHTML;\n            document.getElementById('bucketsPhase').style.display = 'block';\n        }\n        \n        function toggleAutoStep() {\n            if (sortState.autoStepInterval) {\n                clearInterval(sortState.autoStepInterval);\n                sortState.autoStepInterval = null;\n                document.getElementById('autoStep').textContent = 'Auto Step (0.5s)';\n            } else {\n                const speed = parseInt(document.getElementById('speedControl').value);\n                sortState.autoStepInterval = setInterval(() => {\n                    if (sortState.isSorting) {\n                        performNextStep();\n                    } else {\n                        clearInterval(sortState.autoStepInterval);\n                        sortState.autoStepInterval = null;\n                        document.getElementById('autoStep').textContent = 'Auto Step (0.5s)';\n                    }\n                }, speed);\n                document.getElementById('autoStep').textContent = 'Stop Auto Step';\n            }\n        }\n        \n        function updateDisplay() {\n            const showBinary = document.getElementById('showBinary').checked;\n            let displayText = '';\n            \n            for (let i = 0; i < workingArray.length; i++) {\n                const num = workingArray[i];\n                let numStr = num.toString();\n                \n                if (showBinary) {\n                    numStr += ` (${num.toString(sortState.base)})`;\n                }\n                \n                displayText += numStr;\n                if (i < workingArray.length - 1) {\n                    displayText += ', ';\n                }\n            }\n            \n            arrayDisplay.textContent = displayText;\n        }\n    </script>\n</body>\n</html>"
  },
