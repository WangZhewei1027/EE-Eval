  "question": "K-Means Clustering",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<title>K-Means Clustering Interactive Demonstration</title>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n</head>\n<body>\n<h1>K-Means Clustering Interactive Demo</h1>\n\n<section>\n<h2>Dataset Input / Generation</h2>\n<p>You can add points manually using the controls below or generate random data. Points are displayed in coordinate space [0,100] x [0,100].</p>\n<label for=\"input-x\">X (0-100): </label>\n<input type=\"number\" id=\"input-x\" min=\"0\" max=\"100\" step=\"0.1\" value=\"50\" />\n<label for=\"input-y\">Y (0-100): </label>\n<input type=\"number\" id=\"input-y\" min=\"0\" max=\"100\" step=\"0.1\" value=\"50\" />\n<button id=\"add-point-btn\">Add Point</button>\n<button id=\"clear-points-btn\">Clear All Points</button>\n<br/>\n<label for=\"gen-count\">Generate Random Points Count: </label>\n<input type=\"number\" id=\"gen-count\" min=\"1\" max=\"500\" step=\"1\" value=\"50\" />\n<button id=\"generate-random-btn\">Generate Random Points</button>\n</section>\n\n<hr/>\n\n<section>\n<h2>Clustering Controls</h2>\n<label for=\"k-input\">Number of Clusters (k): </label>\n<input type=\"number\" id=\"k-input\" min=\"1\" max=\"20\" step=\"1\" value=\"3\" />\n<button id=\"init-centroids-btn\" disabled>Initialize Centroids (Random)</button>\n<button id=\"step-btn\" disabled>Run One K-Means Iteration Step</button>\n<button id=\"run-btn\" disabled>Run Until Convergence</button>\n<button id=\"reset-btn\" disabled>Reset Clustering</button>\n</section>\n\n<hr/>\n\n<section>\n<h2>Centroid Initialization Options</h2>\n<label><input type=\"radio\" name=\"init-method\" value=\"random\" checked> Random</label><br/>\n<label><input type=\"radio\" name=\"init-method\" value=\"kmeans++\"> K-Means++</label><br/>\n<label><input type=\"radio\" name=\"init-method\" value=\"manual\"> Manual (Place centroids)</label><br/>\n<button id=\"reset-manual-centroids\" disabled>Clear Manual Centroids</button>\n<p><em>When Manual mode is active, click on the plot area below to add centroids up to k.</em></p>\n</section>\n\n<hr/>\n\n<section>\n<h2>Algorithm Status and Info</h2>\n<p id=\"status-message\">No points in dataset.</p>\n<p>Iteration: <span id=\"iteration-count\">0</span></p>\n<p>Sum of Squared Distances (SSE): <span id=\"sse-value\">N/A</span></p>\n<p>Cluster Sizes: <span id=\"cluster-sizes\">N/A</span></p>\n</section>\n\n<hr/>\n\n<section>\n<h2>Plot and Interaction</h2>\n<p><em>Coordinate grid 0 to 100 in X and Y. Points are black dots. Centroids are labeled with cluster number.</em></p>\n<svg id=\"plot-area\" width=\"600\" height=\"600\" style=\"border:1px solid black\" tabindex=\"0\" aria-label=\"K-Means clustering plot area\"></svg>\n<br/>\n<button id=\"show-distances-btn\">Show Distances On Hover: Off</button>\n</section>\n\n<hr/>\n\n<section>\n<h2>Export / Import</h2>\n<button id=\"export-json-btn\">Export Dataset & Clustering (JSON)</button>\n<button id=\"import-json-btn\">Import Dataset & Clustering (JSON)</button>\n<input type=\"file\" id=\"import-json-file\" accept=\".json\" style=\"display:none\" />\n</section>\n\n<script>\n// Global data and state\nconst state = {\n  points: [], // {x,y,cluster}\n  centroids: [], // {x,y,clusterIndex}\n  k: 3,\n  iteration: 0,\n  assignmentsMade: false,\n  distancesVisible: false,\n  initMethod: 'random',\n  manualCentroidAddAllowed: false,\n  manualCentroidCount: 0,\n  hasConverged: false\n};\n\nconst plotSize = 600;\nconst coordMax = 100;\n\nconst plotArea = document.getElementById('plot-area');\nconst inputX = document.getElementById('input-x');\nconst inputY = document.getElementById('input-y');\nconst addPointBtn = document.getElementById('add-point-btn');\nconst clearPointsBtn = document.getElementById('clear-points-btn');\nconst genCountInput = document.getElementById('gen-count');\nconst generateRandomBtn = document.getElementById('generate-random-btn');\n\nconst kInput = document.getElementById('k-input');\nconst initCentroidsBtn = document.getElementById('init-centroids-btn');\nconst stepBtn = document.getElementById('step-btn');\nconst runBtn = document.getElementById('run-btn');\nconst resetBtn = document.getElementById('reset-btn');\n\nconst statusMessage = document.getElementById('status-message');\nconst iterationCountSpan = document.getElementById('iteration-count');\nconst sseValueSpan = document.getElementById('sse-value');\nconst clusterSizesSpan = document.getElementById('cluster-sizes');\n\nconst initMethodRadios = document.getElementsByName('init-method');\nconst resetManualCentroidsBtn = document.getElementById('reset-manual-centroids');\n\nconst showDistancesBtn = document.getElementById('show-distances-btn');\n\nconst exportJsonBtn = document.getElementById('export-json-btn');\nconst importJsonBtn = document.getElementById('import-json-btn');\nconst importJsonFileInput = document.getElementById('import-json-file');\n\n// Utility functions\n\nfunction coordToSvg(x) {\n  return (x / coordMax) * plotSize;\n}\n\nfunction svgToCoord(s) {\n  return (s / plotSize) * coordMax;\n}\n\nfunction distanceSquared(p1, p2) {\n  const dx = p1.x - p2.x;\n  const dy = p1.y - p2.y;\n  return dx*dx + dy*dy;\n}\n\nfunction updateStatus() {\n  if(state.points.length === 0){\n    statusMessage.textContent = \"No points in dataset.\";\n    iterationCountSpan.textContent = \"0\";\n    sseValueSpan.textContent = \"N/A\";\n    clusterSizesSpan.textContent = \"N/A\";\n    initCentroidsBtn.disabled = true;\n    stepBtn.disabled = true;\n    runBtn.disabled = true;\n    resetBtn.disabled = true;\n  } else {\n    statusMessage.textContent = `Dataset: ${state.points.length} points, k=${state.k}`;\n    iterationCountSpan.textContent = state.iteration;\n    let sse = calculateSSE();\n    sseValueSpan.textContent = sse.toFixed(4);\n    let sizes = clusterSizes();\n    clusterSizesSpan.textContent = sizes.length > 0 ? sizes.map((s,i)=>`#${i+1}: ${s}`).join(\", \") : \"N/A\";\n\n    initCentroidsBtn.disabled = false;\n    resetBtn.disabled = false;\n\n    if(state.centroids.length === state.k){\n      stepBtn.disabled = false;\n      runBtn.disabled = false;\n    } else {\n      stepBtn.disabled = true;\n      runBtn.disabled = true;\n    }\n  }\n  resetManualCentroidsBtn.disabled = !(state.manualCentroidAddAllowed);\n}\n\nfunction calculateSSE(){\n  if(state.points.length === 0 || state.centroids.length === 0) return 0;\n  let sse = 0;\n  for(let p of state.points){\n    if(p.cluster === null || p.cluster === undefined) continue;\n    let c = state.centroids[p.cluster];\n    sse += distanceSquared(p,c);\n  }\n  return sse;\n}\n\nfunction clusterSizes(){\n  if(state.points.length === 0 || state.centroids.length === 0) return [];\n  let sizes = Array(state.k).fill(0);\n  for(let p of state.points){\n    if(p.cluster !== null && p.cluster !== undefined) sizes[p.cluster]++;\n  }\n  return sizes;\n}\n\nfunction clearPlot(){\n  while(plotArea.firstChild) {\n    plotArea.removeChild(plotArea.firstChild);\n  }\n  // Draw axes gridlines or markers?\n  // Minimal design: could place ticks every 10 units on axes for user orientation\n  for(let i=0; i<=coordMax; i +=10){\n    let xLine = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n    xLine.setAttribute(\"x1\",coordToSvg(i));\n    xLine.setAttribute(\"y1\",0);\n    xLine.setAttribute(\"x2\",coordToSvg(i));\n    xLine.setAttribute(\"y2\",plotSize);\n    xLine.setAttribute(\"stroke\",\"gray\");\n    xLine.setAttribute(\"stroke-width\",\"0.5\");\n    plotArea.appendChild(xLine);\n\n    let yLine = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n    yLine.setAttribute(\"x1\",0);\n    yLine.setAttribute(\"y1\",coordToSvg(i));\n    yLine.setAttribute(\"x2\",plotSize);\n    yLine.setAttribute(\"y2\",coordToSvg(i));\n    yLine.setAttribute(\"stroke\",\"gray\");\n    yLine.setAttribute(\"stroke-width\",\"0.5\");\n    plotArea.appendChild(yLine);\n\n    // axis labels\n    let xLabel = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n    xLabel.setAttribute(\"x\",coordToSvg(i));\n    xLabel.setAttribute(\"y\",plotSize+12);\n    xLabel.setAttribute(\"font-size\",\"10\");\n    xLabel.textContent = i.toString();\n    plotArea.appendChild(xLabel);\n\n    let yLabel = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n    yLabel.setAttribute(\"x\",-15);\n    yLabel.setAttribute(\"y\",coordToSvg(i)+4);\n    yLabel.setAttribute(\"font-size\",\"10\");\n    yLabel.setAttribute(\"text-anchor\",\"end\");\n    yLabel.textContent = i.toString();\n    plotArea.appendChild(yLabel);\n  }\n}\n\n// Draws points and centroids, cluster numbers at centroid, and optionally distances on hover\nfunction drawPlot(mouseX=null,mouseY=null){\n  clearPlot();\n\n  // Draw points\n  for(let i=0;i<state.points.length;i++){\n    let p = state.points[i];\n    let cx = coordToSvg(p.x);\n    let cy = coordToSvg(coordMax - p.y); // Invert Y for SVG coordinates (Y grows down)\n    let circle = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n    circle.setAttribute(\"cx\",cx);\n    circle.setAttribute(\"cy\",cy);\n    circle.setAttribute(\"r\",3);\n    circle.setAttribute(\"fill\",\"black\");\n    circle.setAttribute(\"tabindex\",\"0\");\n    circle.setAttribute(\"aria-label\",`Point ${i+1}: (${p.x.toFixed(1)}, ${p.y.toFixed(1)}) Cluster: ${p.cluster !== null && p.cluster !== undefined ? p.cluster+1 : \"none\"}`);\n    plotArea.appendChild(circle);\n\n    if(state.distancesVisible && mouseX !== null && mouseY !== null && state.centroids.length === state.k){\n      // If mouse is near this point? We'll show lines and distances for the hovered point only later.\n      // TBD: We'll handle distances below for hovered.\n    }\n  }\n\n  // Draw centroids\n  for(let j=0; j<state.centroids.length; j++){\n    let c = state.centroids[j];\n    let cx = coordToSvg(c.x);\n    let cy = coordToSvg(coordMax - c.y);\n    let centroidCircle = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n    centroidCircle.setAttribute(\"cx\",cx);\n    centroidCircle.setAttribute(\"cy\",cy);\n    centroidCircle.setAttribute(\"r\",7);\n    centroidCircle.setAttribute(\"fill\",\"none\");\n    centroidCircle.setAttribute(\"stroke\",\"black\");\n    centroidCircle.setAttribute(\"stroke-width\",\"1.5\");\n    centroidCircle.setAttribute(\"aria-label\",`Centroid ${j+1}: (${c.x.toFixed(1)}, ${c.y.toFixed(1)})`);\n    centroidCircle.setAttribute(\"data-centroid-index\",j);\n    plotArea.appendChild(centroidCircle);\n\n    let text = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n    text.setAttribute(\"x\",cx);\n    text.setAttribute(\"y\",cy+4);\n    text.setAttribute(\"font-size\",\"12\");\n    text.setAttribute(\"font-weight\",\"bold\");\n    text.setAttribute(\"text-anchor\",\"middle\");\n    text.textContent = (j+1).toString();\n    plotArea.appendChild(text);\n  }\n\n  // If distancesVisible and mouseX/mouseY present, and points and centroids present, show distances for hovered point\n  if(state.distancesVisible && mouseX !== null && mouseY !== null && state.points.length>0 && state.centroids.length === state.k){\n    // Find nearest point to mouse\n    // Transform mouseX,Y in SVG coordinates to coordinates in data space\n\n    const svgRect = plotArea.getBoundingClientRect();\n    let mouseSvgX = mouseX - svgRect.left;\n    let mouseSvgY = mouseY - svgRect.top;\n    let mouseCoordX = svgToCoord(mouseSvgX);\n    let mouseCoordY = coordMax - svgToCoord(mouseSvgY);\n\n    // Find point within threshold distance (e.g. 3 units)\n    let foundPointIndex = null;\n    let minPixDist = 15;\n    for(let i=0; i<state.points.length; i++){\n      let p = state.points[i];\n      let px = coordToSvg(p.x);\n      let py = coordToSvg(coordMax - p.y);\n      let dx = px - mouseSvgX;\n      let dy = py - mouseSvgY;\n      let pixDist = Math.sqrt(dx*dx+dy*dy);\n      if(pixDist < minPixDist){\n        foundPointIndex = i;\n        minPixDist = pixDist;\n      }\n    }\n    if(foundPointIndex !== null){\n      let p = state.points[foundPointIndex];\n      let px = coordToSvg(p.x);\n      let py = coordToSvg(coordMax - p.y);\n      // Draw lines and distances to each centroid\n      for(let j=0; j<state.centroids.length; j++){\n        let c = state.centroids[j];\n        let cx = coordToSvg(c.x);\n        let cy = coordToSvg(coordMax - c.y);\n\n        let line = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n        line.setAttribute(\"x1\",px);\n        line.setAttribute(\"y1\",py);\n        line.setAttribute(\"x2\",cx);\n        line.setAttribute(\"y2\",cy);\n        line.setAttribute(\"stroke\",\"black\");\n        line.setAttribute(\"stroke-width\",\"0.8\");\n        plotArea.appendChild(line);\n\n        // Distance label (midpoint)\n        let midX = (px+cx)/2;\n        let midY = (py+cy)/2;\n        let distValue = Math.sqrt(distanceSquared(p,c));\n        let distLabel = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n        distLabel.setAttribute(\"x\",midX);\n        distLabel.setAttribute(\"y\",midY);\n        distLabel.setAttribute(\"font-size\",\"10\");\n        distLabel.setAttribute(\"text-anchor\",\"middle\");\n        distLabel.textContent = distValue.toFixed(2);\n        plotArea.appendChild(distLabel);\n      }\n    }\n  }\n}\n\n// K-Means algorithm core steps\n\nfunction assignClusters(){\n  // assign each point to nearest centroid\n  if(state.centroids.length !== state.k) return;\n  let changed = false;\n  for(let p of state.points){\n    let minDist = Infinity;\n    let minIndex = null;\n    for(let i=0; i<state.centroids.length; i++){\n      let c = state.centroids[i];\n      let d = distanceSquared(p,c);\n      if(d < minDist){\n        minDist = d;\n        minIndex = i;\n      }\n    }\n    if(p.cluster !== minIndex){\n      changed = true;\n      p.cluster = minIndex;\n    }\n  }\n  return changed;\n}\n\nfunction updateCentroids(){\n  // recompute centroid positions as mean of assigned points\n  // if any cluster has no points, centroid stays the same\n  if(state.points.length === 0) return false;\n  let moved = false;\n  let newCentroids = [];\n  for(let i=0; i<state.k; i++){\n    let assignedPoints = state.points.filter(p=>p.cluster === i);\n    if(assignedPoints.length === 0){\n      // No change\n      newCentroids.push({...state.centroids[i]});\n      continue;\n    }\n    let sumX=0, sumY=0;\n    for(let p of assignedPoints){\n      sumX += p.x;\n      sumY += p.y;\n    }\n    let meanX = sumX / assignedPoints.length;\n    let meanY = sumY / assignedPoints.length;\n    if(Math.abs(meanX - state.centroids[i].x) > 1e-6 || Math.abs(meanY - state.centroids[i].y) > 1e-6) moved = true;\n    newCentroids.push({x:meanX, y:meanY, clusterIndex:i});\n  }\n  state.centroids = newCentroids;\n  return moved;\n}\n\nfunction fullIterationStep(){\n  if(state.centroids.length !== state.k) return false;\n  let changedAssignments = assignClusters();\n  let movedCentroids = updateCentroids();\n  state.iteration++;\n  drawPlot();\n  updateStatus();\n  if(!changedAssignments && !movedCentroids){\n    state.hasConverged = true;\n    statusMessage.textContent += \" (Converged)\";\n  }\n  return state.hasConverged;\n}\n\n// Initialization methods\n\nfunction initCentroidsRandom(){\n  if(state.points.length < state.k){\n    statusMessage.textContent = \"Not enough points to initialize centroids\";\n    return false;\n  }\n  state.centroids = [];\n  // Pick k random unique points from dataset as centroids starting positions\n  let usedIndices = new Set();\n  while(state.centroids.length < state.k){\n    let idx = Math.floor(Math.random() * state.points.length);\n    if(!usedIndices.has(idx)){\n      usedIndices.add(idx);\n      let p = state.points[idx];\n      state.centroids.push({x:p.x, y:p.y, clusterIndex: state.centroids.length});\n    }\n  }\n  state.iteration = 0;\n  state.hasConverged = false;\n  assignClusters();\n  drawPlot();\n  updateStatus();\n  return true;\n}\n\n// K-Means++ initialization for centroids (more complex)\n\nfunction initCentroidsKMeansPP(){\n  if(state.points.length < state.k){\n    statusMessage.textContent = \"Not enough points to initialize centroids\";\n    return false;\n  }\n  state.centroids = [];\n  // 1. Pick first centroid randomly\n  let idx = Math.floor(Math.random() * state.points.length);\n  state.centroids.push({x:state.points[idx].x, y:state.points[idx].y, clusterIndex:0});\n  // 2. For each next centroid (2..k):\n  for(let cIdx=1; cIdx < state.k; cIdx++){\n    let distances = [];\n    // For each point, find distance to nearest already chosen centroid squared\n    for(let p of state.points){\n      let minDist = Infinity;\n      for(let c of state.centroids){\n        let d = distanceSquared(p,c);\n        if(d < minDist) minDist = d;\n      }\n      distances.push(minDist);\n    }\n    // Sum distances\n    let sumD = distances.reduce((a,b)=>a+b,0);\n    if(sumD === 0) {\n      // All points identical, pick random from points\n      let pickIdx = Math.floor(Math.random() * state.points.length);\n      state.centroids.push({x:state.points[pickIdx].x, y:state.points[pickIdx].y, clusterIndex:cIdx});\n      continue;\n    }\n    // Pick next centroid with probability proportional to distance squared\n    let r = Math.random() * sumD;\n    let runningSum = 0;\n    let nextIndex = 0;\n    for(let i=0; i<distances.length; i++){\n      runningSum += distances[i];\n      if(r <= runningSum){\n        nextIndex = i;\n        break;\n      }\n    }\n    state.centroids.push({x:state.points[nextIndex].x, y:state.points[nextIndex].y, clusterIndex:cIdx});\n  }\n  state.iteration = 0;\n  state.hasConverged = false;\n  assignClusters();\n  drawPlot();\n  updateStatus();\n  return true;\n}\n\n// Manual centroid adding mode\n\nfunction enableManualCentroidAdd(){\n  state.manualCentroidAddAllowed = true;\n  resetManualCentroidsBtn.disabled = false;\n  initCentroidsBtn.disabled = true;\n  stepBtn.disabled = true;\n  runBtn.disabled = true;\n  resetBtn.disabled = false;\n  statusMessage.textContent = \"Manual centroid placement active. Click plot to add centroids.\";\n}\n\nfunction disableManualCentroidAdd(){\n  state.manualCentroidAddAllowed = false;\n  resetManualCentroidsBtn.disabled = true;\n  initCentroidsBtn.disabled = false;\n  if(state.centroids.length === state.k){\n    stepBtn.disabled = false;\n    runBtn.disabled = false;\n  }\n  updateStatus();\n}\n\nfunction tryAddManualCentroid(svgX,svgY){\n  if(!state.manualCentroidAddAllowed) return;\n  if(state.centroids.length >= state.k) return;\n  let x = svgToCoord(svgX);\n  let y = coordMax - svgToCoord(svgY); // flip y\n  state.centroids.push({x:x,y:y, clusterIndex:state.centroids.length});\n  if(state.centroids.length === state.k){\n    // Finished manual placing\n    assignClusters();\n    state.iteration = 0;\n    state.hasConverged = false;\n    disableManualCentroidAdd();\n  }\n  drawPlot();\n  updateStatus();\n}\n\n// Event handlers\n\naddPointBtn.addEventListener('click',()=>{\n  let x = parseFloat(inputX.value);\n  let y = parseFloat(inputY.value);\n  if(isNaN(x) || x < 0 || x > coordMax || isNaN(y) || y < 0 || y > coordMax){\n    alert(\"Invalid coordinates. Values must be numbers between 0 and 100.\");\n    return;\n  }\n  state.points.push({x:x, y:y, cluster:null});\n  drawPlot();\n  updateStatus();\n});\n\nclearPointsBtn.addEventListener('click',()=>{\n  if(!confirm(\"Are you sure you want to clear all points and reset clustering?\")) return;\n  state.points = [];\n  state.centroids = [];\n  state.iteration = 0;\n  state.hasConverged = false;\n  drawPlot();\n  updateStatus();\n});\n\ngenerateRandomBtn.addEventListener('click',()=>{\n  let count = parseInt(genCountInput.value);\n  if(isNaN(count) || count < 1 || count > 500){\n    alert(\"Invalid point count. Enter a number between 1 and 500.\");\n    return;\n  }\n  // Generate random points uniformly in [0,100]\n  for(let i=0; i<count; i++){\n    state.points.push({\n      x: Math.random()*coordMax,\n      y: Math.random()*coordMax,\n      cluster: null\n    });\n  }\n  drawPlot();\n  updateStatus();\n});\n\nkInput.addEventListener('change',()=>{\n  let val = parseInt(kInput.value);\n  if(isNaN(val) || val < 1) {\n    kInput.value = state.k;\n    return;\n  }\n  if(val > 20){\n    kInput.value = 20;\n    val = 20;\n  } \n  state.k = val;\n\n  // Reset any previous centroids/clustering when k changes as points remain\n  state.centroids = [];\n  state.iteration = 0;\n  state.hasConverged = false;\n  state.points.forEach(p => p.cluster = null);\n  // If manual centroids mode enabled, reset it\n  if(state.manualCentroidAddAllowed){\n    disableManualCentroidAdd();\n  }\n  updateStatus();\n  drawPlot();\n});\n\ninitCentroidsBtn.addEventListener('click',()=>{\n  if(state.points.length < state.k){\n    alert(\"Not enough points to initialize centroids\");\n    return;\n  }\n  if(state.initMethod === 'random'){\n    initCentroidsRandom();\n  } else if(state.initMethod === 'kmeans++'){\n    initCentroidsKMeansPP();\n  } else if(state.initMethod === 'manual'){\n    if(state.manualCentroidAddAllowed){\n      alert(\"Manual centroid placement already active.\");\n      return;\n    }\n    state.centroids = [];\n    state.iteration = 0;\n    state.hasConverged = false;\n    enableManualCentroidAdd();\n    drawPlot();\n    updateStatus();\n  }\n});\n\nstepBtn.addEventListener('click',()=>{\n  if(state.hasConverged){\n    statusMessage.textContent = \"Algorithm already converged.\";\n    return;\n  }\n  fullIterationStep();\n});\n\nrunBtn.addEventListener('click',()=>{\n  if(state.hasConverged){\n    statusMessage.textContent = \"Algorithm already converged.\";\n    return;\n  }\n  // Run iterations until convergence or max iterations (100)\n  let maxIter = 100;\n  let i=0;\n  let converged = false;\n  while(i < maxIter && !converged){\n    converged = fullIterationStep();\n    i++;\n  }\n  if(!converged){\n    statusMessage.textContent += \" (Stopped after max iterations)\";\n  }\n});\n\nresetBtn.addEventListener('click',()=>{\n  state.centroids = [];\n  state.iteration = 0;\n  state.hasConverged = false;\n  state.points.forEach(p=>p.cluster=null);\n  if(state.manualCentroidAddAllowed) disableManualCentroidAdd();\n  drawPlot();\n  updateStatus();\n});\n\nfor(let radio of initMethodRadios){\n  radio.addEventListener('change',()=>{\n    if(radio.checked){\n      state.initMethod = radio.value;\n      if(state.initMethod === 'manual'){\n        initCentroidsBtn.textContent = \"Enable Manual Centroid Placement\";\n        if(state.centroids.length === state.k && !state.manualCentroidAddAllowed){\n          stepBtn.disabled = false;\n          runBtn.disabled = false;\n          resetManualCentroidsBtn.disabled = false;\n        }\n      } else {\n        initCentroidsBtn.textContent = \"Initialize Centroids (Random)\";\n        if(state.manualCentroidAddAllowed){\n          disableManualCentroidAdd();\n        }\n      }\n      updateStatus();\n    }\n  });\n}\n\nresetManualCentroidsBtn.addEventListener('click',()=>{\n  if(!state.manualCentroidAddAllowed) return;\n  state.centroids = [];\n  drawPlot();\n  updateStatus();\n});\n\nplotArea.addEventListener('click',(evt)=>{\n  if(state.manualCentroidAddAllowed){\n    let point = evt;\n    tryAddManualCentroid(point.clientX, point.clientY);\n  }\n});\n\nshowDistancesBtn.addEventListener('click',()=>{\n  state.distancesVisible = !state.distancesVisible;\n  showDistancesBtn.textContent = \"Show Distances On Hover: \" + (state.distancesVisible ? \"On\" : \"Off\");\n  drawPlot();\n});\n\n// Mouse move on plot for showing distances dynamically\nplotArea.addEventListener('mousemove',(evt)=>{\n  if(state.distancesVisible){\n    drawPlot(evt.clientX, evt.clientY);\n  }\n});\n\nplotArea.addEventListener('mouseleave',(evt)=>{\n  if(state.distancesVisible){\n    drawPlot();\n  }\n});\n\n// Export / Import functionality (JSON)\n\nfunction exportJSON(){\n  // Export points, centroids, k, iteration, cluster assignments\n  let exportData = {\n    points: state.points.map(p=>({x:p.x,y:p.y,cluster:p.cluster})),\n    centroids: state.centroids.map(c=>({x:c.x,y:c.y,clusterIndex:c.clusterIndex})),\n    k: state.k,\n    iteration: state.iteration,\n    hasConverged: state.hasConverged\n  };\n  let jsonStr = JSON.stringify(exportData, null, 2);\n  let blob = new Blob([jsonStr], {type:\"application/json\"});\n  let url = URL.createObjectURL(blob);\n  let a = document.createElement('a');\n  a.href = url;\n  a.download = 'kmeans_data_export.json';\n  a.click();\n  URL.revokeObjectURL(url);\n}\n\nfunction importJSON(file){\n  let reader = new FileReader();\n  reader.onload = function(e){\n    try{\n      let data = JSON.parse(e.target.result);\n      if(!data.points || !Array.isArray(data.points)) throw \"Invalid JSON format (points)\";\n      if(!data.centroids || !Array.isArray(data.centroids)) throw \"Invalid JSON format (centroids)\";\n      if(typeof data.k !== \"number\") throw \"Invalid JSON format (k)\";\n      if(typeof data.iteration !== \"number\") throw \"Invalid JSON format (iteration)\";\n      // Overwrite current state carefully\n      state.points = data.points.map(p=>({x:p.x,y:p.y,cluster:p.cluster}));\n      state.centroids = data.centroids.map(c=>({x:c.x,y:c.y,clusterIndex:c.clusterIndex}));\n      state.k = data.k;\n      state.iteration = data.iteration;\n      state.hasConverged = data.hasConverged || false;\n      kInput.value = state.k;\n      // disable manual centroid mode on import\n      if(state.manualCentroidAddAllowed) disableManualCentroidAdd();\n      drawPlot();\n      updateStatus();\n      statusMessage.textContent = \"Imported dataset and clustering.\";\n    }catch(err){\n      alert(\"Error parsing import JSON: \" + err);\n    }\n  };\n  reader.readAsText(file);\n}\n\nexportJsonBtn.addEventListener('click',exportJSON);\n\nimportJsonBtn.addEventListener('click',()=>{\n  importJsonFileInput.value = \"\";\n  importJsonFileInput.click();\n});\n\nimportJsonFileInput.addEventListener('change',()=>{\n  if(importJsonFileInput.files.length === 0) return;\n  let file = importJsonFileInput.files[0];\n  importJSON(file);\n});\n\n// Initial plot and status update\nupdateStatus();\ndrawPlot();\n\n</script>\n</body>\n</html>"
