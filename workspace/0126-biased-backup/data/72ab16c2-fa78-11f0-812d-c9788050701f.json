    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Big-O Notation: The Beauty of Complexity</title>\n    <style>\n        :root {\n            --primary: #2a3d66;\n            --secondary: #d6b0b1;\n            --accent: #e08e6d;\n            --light: #f9f4f5;\n            --dark: #1a1a2e;\n            --transition: all 0.8s cubic-bezier(0.645, 0.045, 0.355, 1);\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n            background-color: var(--dark);\n            color: var(--light);\n            min-height: 100vh;\n            overflow-x: hidden;\n            line-height: 1.6;\n        }\n\n        @font-face {\n            font-family: 'Inter';\n            font-style: normal;\n            font-weight: 300 700;\n            font-display: swap;\n            src: url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 4rem 2rem;\n            position: relative;\n        }\n\n        header {\n            text-align: center;\n            margin-bottom: 5rem;\n            position: relative;\n            z-index: 10;\n        }\n\n        h1 {\n            font-size: 4rem;\n            font-weight: 700;\n            margin-bottom: 1rem;\n            background: linear-gradient(to right, var(--secondary), var(--accent));\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            line-height: 1.2;\n            letter-spacing: -0.05em;\n        }\n\n        .subtitle {\n            font-size: 1.2rem;\n            max-width: 600px;\n            margin: 0 auto;\n            color: rgba(249, 244, 245, 0.7);\n        }\n\n        .visualization {\n            height: 70vh;\n            position: relative;\n            margin: 5rem 0;\n        }\n\n        .graph-container {\n            position: absolute;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            align-items: flex-end;\n            justify-content: center;\n            gap: 30px;\n            padding-bottom: 80px;\n        }\n\n        .graph {\n            position: relative;\n            width: 80px;\n            transition: var(--transition);\n        }\n\n        .graph-label {\n            position: absolute;\n            bottom: -50px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 0.9rem;\n            color: var(--secondary);\n            white-space: nowrap;\n        }\n\n        .graph-bar {\n            width: 100%;\n            background: linear-gradient(to top, var(--primary), var(--accent));\n            border-radius: 4px 4px 0 0;\n            transition: var(--transition);\n            box-shadow: 0 10px 30px rgba(42, 61, 102, 0.3);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .graph-bar::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            height: 20px;\n            background: linear-gradient(to right, \n                rgba(255,255,255,0.1), \n                rgba(255,255,255,0.3), \n                rgba(255,255,255,0.1));\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 20px;\n            margin-top: 3rem;\n        }\n\n        button {\n            background: transparent;\n            border: 2px solid var(--secondary);\n            color: var(--secondary);\n            padding: 0.8rem 2rem;\n            border-radius: 50px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: var(--transition);\n            outline: none;\n            position: relative;\n            overflow: hidden;\n        }\n\n        button:hover {\n            background: rgba(214, 176, 177, 0.1);\n            transform: translateY(-3px);\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            width: 5px;\n            height: 5px;\n            background: rgba(255, 255, 255, 0.5);\n            opacity: 0;\n            border-radius: 100%;\n            transform: scale(1, 1) translate(-50%, -50%);\n            transform-origin: 50% 50%;\n        }\n\n        button:focus:not(:active)::after {\n            animation: ripple 1s ease-out;\n        }\n\n        @keyframes ripple {\n            0% {\n                transform: scale(0, 0);\n                opacity: 0.5;\n            }\n            100% {\n                transform: scale(20, 20);\n                opacity: 0;\n            }\n        }\n\n        .info-section {\n            margin-top: 8rem;\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n            gap: 3rem;\n        }\n\n        .info-card {\n            background: rgba(26, 26, 46, 0.5);\n            border: 1px solid rgba(214, 176, 177, 0.1);\n            border-radius: 16px;\n            padding: 2rem;\n            transition: var(--transition);\n            backdrop-filter: blur(10px);\n        }\n\n        .info-card:hover {\n            transform: translateY(-10px);\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);\n            border-color: rgba(214, 176, 177, 0.3);\n        }\n\n        .info-card h3 {\n            font-size: 1.5rem;\n            margin-bottom: 1.5rem;\n            color: var(--accent);\n            position: relative;\n            display: inline-block;\n        }\n\n        .info-card h3::after {\n            content: '';\n            position: absolute;\n            bottom: -8px;\n            left: 0;\n            width: 50px;\n            height: 3px;\n            background: linear-gradient(to right, var(--accent), transparent);\n        }\n\n        .complexity {\n            margin-top: 3rem;\n            text-align: center;\n        }\n\n        .complexity h2 {\n            font-size: 2rem;\n            margin-bottom: 2rem;\n            color: var(--secondary);\n        }\n\n        .complexity-table {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n            gap: 20px;\n            margin-top: 2rem;\n        }\n\n        .complexity-item {\n            background: rgba(42, 61, 102, 0.3);\n            border-radius: 12px;\n            padding: 1.5rem;\n            transition: var(--transition);\n        }\n\n        .complexity-item:hover {\n            transform: translateY(-5px);\n            background: rgba(42, 61, 102, 0.5);\n        }\n\n        .complexity-item h4 {\n            color: var(--accent);\n            margin-bottom: 0.5rem;\n        }\n\n        .particles {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: -1;\n            opacity: 0.2;\n        }\n\n        /* Animations */\n        @keyframes float {\n            0%, 100% {\n                transform: translateY(0);\n            }\n            50% {\n                transform: translateY(-20px);\n            }\n        }\n\n        .floating {\n            animation: float 6s ease-in-out infinite;\n        }\n\n        .delay-1 {\n            animation-delay: 1s;\n        }\n\n        .delay-2 {\n            animation-delay: 2s;\n        }\n\n        .delay-3 {\n            animation-delay: 3s;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"particles\" id=\"particles-js\"></div>\n    <div class=\"container\">\n        <header>\n            <h1>Big-O Notation</h1>\n            <p class=\"subtitle\">Understanding algorithmic complexity through elegant visualization</p>\n        </header>\n\n        <div class=\"visualization\">\n            <div class=\"graph-container\">\n                <div class=\"graph floating\">\n                    <div class=\"graph-bar\" id=\"o1\" style=\"height: 30px;\"></div>\n                    <div class=\"graph-label\">O(1)</div>\n                </div>\n                <div class=\"graph floating delay-1\">\n                    <div class=\"graph-bar\" id=\"ologn\" style=\"height: 80px;\"></div>\n                    <div class=\"graph-label\">O(log n)</div>\n                </div>\n                <div class=\"graph floating delay-2\">\n                    <div class=\"graph-bar\" id=\"on\" style=\"height: 200px;\"></div>\n                    <div class=\"graph-label\">O(n)</div>\n                </div>\n                <div class=\"graph floating delay-3\">\n                    <div class=\"graph-bar\" id=\"on2\" style=\"height: 400px;\"></div>\n                    <div class=\"graph-label\">O(n²)</div>\n                </div>\n                <div class=\"graph floating delay-1\">\n                    <div class=\"graph-bar\" id=\"o2n\" style=\"height: 600px;\"></div>\n                    <div class=\"graph-label\">O(2ⁿ)</div>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"animateBtn\">Animate Growth</button>\n            <button id=\"resetBtn\">Reset</button>\n        </div>\n\n        <div class=\"complexity\">\n            <h2>Common Time Complexities</h2>\n            <div class=\"complexity-table\">\n                <div class=\"complexity-item\">\n                    <h4>O(1)</h4>\n                    <p>Constant time - operations execute in the same time regardless of input size</p>\n                </div>\n                <div class=\"complexity-item\">\n                    <h4>O(log n)</h4>\n                    <p>Logarithmic time - operations halve the problem space with each step</p>\n                </div>\n                <div class=\"complexity-item\">\n                    <h4>O(n)</h4>\n                    <p>Linear time - operations grow linearly with input size</p>\n                </div>\n                <div class=\"complexity-item\">\n                    <h4>O(n²)</h4>\n                    <p>Quadratic time - operations grow with the square of input size</p>\n                </div>\n                <div class=\"complexity-item\">\n                    <h4>O(2ⁿ)</h4>\n                    <p>Exponential time - operations double with each addition to input</p>\n                </div>\n            </div>\n        </div>\n\n        <div class=\"info-section\">\n            <div class=\"info-card\">\n                <h3>What is Big-O?</h3>\n                <p>Big-O notation describes the upper bound of an algorithm's time or space complexity in relation to its input size. It provides a theoretical measure of an algorithm's efficiency, helping developers choose the most optimal solution for their problems.</p>\n            </div>\n            <div class=\"info-card\">\n                <h3>Why it Matters</h3>\n                <p>Understanding Big-O helps predict how an algorithm will scale. An O(n²) algorithm might work fine with 10 items but become unusable with 10,000. Choosing the right complexity class can mean the difference between an instant response and a frozen application.</p>\n            </div>\n            <div class=\"info-card\">\n                <h3>Visual Interpretation</h3>\n                <p>The height of each bar represents how the time complexity grows relative to input size. Notice how O(1) remains constant while O(2ⁿ) grows exponentially - quickly becoming impractical for large inputs.</p>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // Simple particle background\n        document.addEventListener('DOMContentLoaded', () => {\n            const particlesContainer = document.getElementById('particles-js');\n            const particleCount = 50;\n            \n            for (let i = 0; i < particleCount; i++) {\n                const particle = document.createElement('div');\n                particle.style.position = 'absolute';\n                particle.style.width = Math.random() * 5 + 1 + 'px';\n                particle.style.height = particle.style.width;\n                particle.style.backgroundColor = `rgba(214, 176, 177, ${Math.random() * 0.5})`;\n                particle.style.borderRadius = '50%';\n                particle.style.top = Math.random() * 100 + '%';\n                particle.style.left = Math.random() * 100 + '%';\n                particle.style.opacity = Math.random();\n                particlesContainer.appendChild(particle);\n                \n                animateParticle(particle);\n            }\n\n            // Animate growth button\n            document.getElementById('animateBtn').addEventListener('click', () => {\n                animateGrowth();\n            });\n\n            // Reset button\n            document.getElementById('resetBtn').addEventListener('click', () => {\n                resetGrowth();\n            });\n        });\n\n        function animateParticle(particle) {\n            const duration = Math.random() * 20000 + 10000;\n            const xMovement = (Math.random() - 0.5) * 100;\n            const yMovement = (Math.random() - 0.5) * 100;\n\n            particle.animate([\n                { transform: 'translate(0, 0)' },\n                { transform: `translate(${xMovement}px, ${yMovement}px)` }\n            ], {\n                duration: duration,\n                iterations: Infinity,\n                direction: 'alternate',\n                easing: 'ease-in-out'\n            });\n        }\n\n        function animateGrowth() {\n            const durations = [1000, 1500, 2000, 2500, 3000];\n            \n            document.getElementById('o1').animate([\n                { height: '30px' },\n                { height: '30px' }\n            ], {\n                duration: 3000,\n                easing: 'cubic-bezier(0.645, 0.045, 0.355, 1)'\n            });\n\n            document.getElementById('ologn').animate([\n                { height: '80px' },\n                { height: '120px' }\n            ], {\n                duration: 3000,\n                easing: 'cubic-bezier(0.645, 0.045, 0.355, 1)'\n            });\n\n            document.getElementById('on').animate([\n                { height: '200px' },\n                { height: '400px' }\n            ], {\n                duration: 3000,\n                easing: 'cubic-bezier(0.645, 0.045, 0.355, 1)'\n            });\n\n            document.getElementById('on2').animate([\n                { height: '400px' },\n                { height: '700px' }\n            ], {\n                duration: 3000,\n                easing: 'cubic-bezier(0.645, 0.045, 0.355, 1)'\n            });\n\n            document.getElementById('o2n').animate([\n                { height: '600px' },\n                { height: '900px' }\n            ], {\n                duration: 3000,\n                easing: 'cubic-bezier(0.645, 0.045, 0.355, 1)',\n                fill: 'forwards'\n            });\n        }\n\n        function resetGrowth() {\n            document.getElementById('o1').style.height = '30px';\n            document.getElementById('ologn').style.height = '80px';\n            document.getElementById('on').style.height = '200px';\n            document.getElementById('on2').style.height = '400px';\n            document.getElementById('o2n').style.height = '600px';\n        }\n    </script>\n</body>\n</html>"
