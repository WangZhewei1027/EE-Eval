    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Routing Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 0;\n        }\n        .hidden {\n            display: none;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Routing Example</h1>\n\n<button onclick=\"navigate('home')\">Home</button>\n<button onclick=\"navigate('form')\">Form</button>\n<button onclick=\"navigate('details')\">Details</button>\n\n<div id=\"home\" class=\"page\">\n    <h2>Welcome to the Home Page</h2>\n    <p>This is an interactive routing example. You can navigate to different pages using the buttons above.</p>\n</div>\n\n<div id=\"form\" class=\"page hidden\">\n    <h2>Form Page</h2>\n    <input type=\"text\" id=\"name\" placeholder=\"Enter your name\">\n    <button onclick=\"submitForm()\">Submit</button>\n    <button onclick=\"navigate('home')\">Back to Home</button>\n</div>\n\n<div id=\"details\" class=\"page hidden\">\n    <h2>Details Page</h2>\n    <p id=\"nameDisplay\"></p>\n    <button onclick=\"navigate('form')\">Edit</button>\n    <button onclick=\"navigate('home')\">Back to Home</button>\n</div>\n\n<script>\n    let state = {};\n\n    function navigate(page) {\n        let pages = document.querySelectorAll('.page');\n        pages.forEach(p => p.classList.add('hidden')); // hide all pages\n        document.getElementById(page).classList.remove('hidden'); // show current page\n\n        if (page === 'details') {\n            document.getElementById('nameDisplay').textContent = state.name ? `Name: ${state.name}` : 'No name entered.';\n        }\n    }\n\n    function submitForm() {\n        const nameInput = document.getElementById('name').value;\n        if (nameInput) {\n            state.name = nameInput;\n            navigate('details');\n        } else {\n            alert('Please enter your name.');\n        }\n    }\n\n    navigate('home'); // start on the home page\n</script>\n\n</body>\n</html>"
