    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Floyd-Warshall Algorithm Interactive</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #ccc; padding: 15px; }\n        .matrix-container { overflow-x: auto; }\n        table { border-collapse: collapse; margin: 10px 0; }\n        th, td { border: 1px solid #000; padding: 5px 10px; text-align: center; }\n        input { width: 50px; text-align: center; }\n        button { margin: 5px; padding: 5px 10px; }\n        .highlight { background-color: #eee; }\n        .current { background-color: #ddd; }\n        .path { font-weight: bold; }\n        .controls { display: flex; flex-wrap: wrap; gap: 10px; }\n        .control-group { display: flex; flex-direction: column; margin-right: 20px; }\n        .slider-container { display: flex; align-items: center; gap: 10px; }\n        #graph-container { min-height: 300px; border: 1px solid #000; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Floyd-Warshall Algorithm Interactive</h1>\n        \n        <div class=\"panel\">\n            <h2>Graph Configuration</h2>\n            <div class=\"controls\">\n                <div class=\"control-group\">\n                    <label>Number of Nodes: <input type=\"number\" id=\"nodeCount\" min=\"2\" max=\"10\" value=\"4\"></label>\n                    <button id=\"updateSize\">Update Size</button>\n                </div>\n                <div class=\"control-group\">\n                    <label>Edge Probability: <span id=\"probValue\">50</span>% )</label>\n                    <div class=\"slider-container\">\n                        <input type=\"range\" id=\"edgeProbability\" min=\"0\" max=\"100\" value=\"50\">\n                        <button id=\"randomGraph\">Generate Random Graph</button>\n                    </div>\n                </div>\n                <div class=\"control-group\">\n                    <label>Max Edge Weight: <input type=\"number\" id=\"maxWeight\" min=\"1\" value=\"10\"></label>\n                </div>\n            </div>\n            \n            <div class=\"matrix-container\">\n                <h3>Adjacency Matrix</h3>\n                <div id=\"matrixEditor\"></div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Algorithm Execution</h2>\n            <div class=\"controls\">\n                <button id=\"runStep\">Step Forward</button>\n                <button id=\"runFull\">Run to Completion</button>\n                <button id=\"reset\">Reset</button>\n                <div class=\"slider-container\">\n                    <label>Speed: <span id=\"speedValue\">1x</span></label>\n                    <input type=\"range\" id=\"speedControl\" min=\"1\" max=\"10\" value=\"1\">\n                </div>\n            </div>\n            \n            <div>\n                <h3>Current State (k = <span id=\"currentK\">0</span>)</h3>\n                <div id=\"currentMatrix\"></div>\n            </div>\n            \n            <div>\n                <h3>Current Operation</h3>\n                <div id=\"operationInfo\">Not started</div>\n            </div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Path Finder</h2>\n            <div class=\"controls\">\n                <label>From: \n                    <select id=\"pathFrom\"></select>\n                </label>\n                <label>To: \n                    <select id=\"pathTo\"></select>\n                </label>\n                <button id=\"findPath\">Find Shortest Path</button>\n            </div>\n            <div id=\"pathResult\"></div>\n            <div id=\"pathSteps\"></div>\n        </div>\n        \n        <div class=\"panel\">\n            <h2>Graph Representation</h2>\n            <div id=\"graph-container\"></div>\n        </div>\n    </div>\n\n    <script>\n        // Global state\n        let graph = [];\n        let n = 4;\n        let currentK = 0;\n        let distanceMatrix = [];\n        let nextMatrix = [];\n        let isRunning = false;\n        let animationSpeed = 1;\n        let animationId = null;\n        let pathHighlightTimeout = null;\n        \n        // Initialize\n        document.addEventListener('DOMContentLoaded', function() {\n            initializeControls();\n            createMatrixEditor(n);\n            generateRandomGraph();\n            updateVisualization();\n            \n            // Event listeners\n            document.getElementById('updateSize').addEventListener('click', function() {\n                n = parseInt(document.getElementById('nodeCount').value);\n                createMatrixEditor(n);\n                generateRandomGraph();\n                updateVisualization();\n            });\n            \n            document.getElementById('randomGraph').addEventListener('click', function() {\n                generateRandomGraph();\n                updateVisualization();\n            });\n            \n            document.getElementById('edgeProbability').addEventListener('input', function() {\n                document.getElementById('probValue').textContent = this.value;\n            });\n            \n            document.getElementById('runStep').addEventListener('click', function() {\n                if (currentK >= n) return;\n                performStep();\n                updateVisualization();\n            });\n            \n            document.getElementById('runFull').addEventListener('click', function() {\n                if (isRunning) {\n                    cancelAnimationFrame(animationId);\n                    isRunning = false;\n                    this.textContent = 'Run to Completion';\n                } else {\n                    isRunning = true;\n                    this.textContent = 'Stop';\n                    runAlgorithm();\n                }\n            });\n            \n            document.getElementById('reset').addEventListener('click', function() {\n                resetAlgorithm();\n                updateVisualization();\n            });\n            \n            document.getElementById('speedControl').addEventListener('input', function() {\n                animationSpeed = parseInt(this.value);\n                document.getElementById('speedValue').textContent = animationSpeed + 'x';\n            });\n            \n            document.getElementById('findPath').addEventListener('click', function() {\n                findShortestPath();\n            });\n        });\n        \n        function initializeControls() {\n            // Initialize path finder dropdowns\n            updatePathSelects();\n        }\n        \n        function updatePathSelects() {\n            const fromSelect = document.getElementById('pathFrom');\n            const toSelect = document.getElementById('pathTo');\n            \n            fromSelect.innerHTML = '';\n            toSelect.innerHTML = '';\n            \n            for (let i = 0; i < n; i++) {\n                const option1 = document.createElement('option');\n                option1.value = i;\n                option1.textContent = 'Node ' + i;\n                \n                const option2 = document.createElement('option');\n                option2.value = i;\n                option2.textContent = 'Node ' + i;\n                \n                fromSelect.appendChild(option1);\n                toSelect.appendChild(option2);\n            }\n        }\n        \n        function createMatrixEditor(size) {\n            const container = document.getElementById('matrixEditor');\n            container.innerHTML = '';\n            \n            const table = document.createElement('table');\n            const thead = document.createElement('thead');\n            const tbody = document.createElement('tbody');\n            \n            // Create header row\n            const headerRow = document.createElement('tr');\n            const emptyHeader = document.createElement('th');\n            headerRow.appendChild(emptyHeader);\n            \n            for (let i = 0; i < size; i++) {\n                const th = document.createElement('th');\n                th.textContent = i;\n                headerRow.appendChild(th);\n            }\n            thead.appendChild(headerRow);\n            \n            // Create data rows\n            for (let i = 0; i < size; i++) {\n                const row = document.createElement('tr');\n                const rowHeader = document.createElement('th');\n                rowHeader.textContent = i;\n                row.appendChild(rowHeader);\n                \n                for (let j = 0; j < size; j++) {\n                    const cell = document.createElement('td');\n                    const input = document.createElement('input');\n                    input.type = 'number';\n                    input.id = `edge-${i}-${j}`;\n                    input.value = i === j ? '0' : '';\n                    input.placeholder = '∞';\n                    cell.appendChild(input);\n                    row.appendChild(cell);\n                }\n                tbody.appendChild(row);\n            }\n            \n            table.appendChild(thead);\n            table.appendChild(tbody);\n            container.appendChild(table);\n        }\n        \n        function generateRandomGraph() {\n            n = parseInt(document.getElementById('nodeCount').value);\n            const probability = parseInt(document.getElementById('edgeProbability').value) / 100;\n            const maxWeight = parseInt(document.getElementById('maxWeight').value);\n            \n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j < n; j++) {\n                    const input = document.getElementById(`edge-${i}-${j}`);\n                    if (i === j) {\n                        input.value = '0';\n                    } else {\n                        if (Math.random() < probability) {\n                            input.value = Math.floor(Math.random() * maxWeight) + 1;\n                        } else {\n                            input.value = '';\n                        }\n                    }\n                }\n            }\n            \n            updatePathSelects();\n        }\n        \n        function getGraphFromInput() {\n            const matrix = [];\n            for (let i = 0; i < n; i++) {\n                matrix[i] = [];\n                for (let j = 0; j < n; j++) {\n                    const input = document.getElementById(`edge-${i}-${j}`);\n                    matrix[i][j] = input.value === '' ? Infinity : parseInt(input.value);\n                }\n            }\n            return matrix;\n        }\n        \n        function resetAlgorithm() {\n            currentK = 0;\n            graph = getGraphFromInput();\n            distanceMatrix = JSON.parse(JSON.stringify(graph));\n            nextMatrix = Array(n).fill().map(() => Array(n).fill(null));\n            \n            // Initialize next matrix for path reconstruction\n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j < n; j++) {\n                    if (i !== j && isFinite(distanceMatrix[i][j])) {\n                        nextMatrix[i][j] = j;\n                    }\n                }\n            }\n            \n            document.getElementById('currentK').textContent = currentK;\n            document.getElementById('operationInfo').textContent = 'Algorithm reset';\n            isRunning = false;\n            document.getElementById('runFull').textContent = 'Run to Completion';\n            \n            if (animationId) {\n                cancelAnimationFrame(animationId);\n                animationId = null;\n            }\n            \n            if (pathHighlightTimeout) {\n                clearTimeout(pathHighlightTimeout);\n                pathHighlightTimeout = null;\n            }\n        }\n        \n        function performStep() {\n            if (currentK >= n) return;\n            \n            const k = currentK;\n            document.getElementById('operationInfo').textContent = `Processing intermediate node ${k}`;\n            \n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j < n; j++) {\n                    if (distanceMatrix[i][k] + distanceMatrix[k][j] < distanceMatrix[i][j]) {\n                        distanceMatrix[i][j] = distanceMatrix[i][k] + distanceMatrix[k][j];\n                        nextMatrix[i][j] = nextMatrix[i][k];\n                    }\n                }\n            }\n            \n            currentK++;\n            document.getElementById('currentK').textContent = currentK;\n            \n            if (currentK >= n) {\n                document.getElementById('operationInfo').textContent = 'Algorithm completed';\n            }\n        }\n        \n        function runAlgorithm() {\n            if (currentK >= n) return;\n            \n            performStep();\n            updateVisualization();\n            \n            if (currentK < n) {\n                animationId = setTimeout(runAlgorithm, 1000 / animationSpeed);\n            } else {\n                isRunning = false;\n                document.getElementById('runFull').textContent = 'Run to Completion';\n            }\n        }\n        \n        function updateVisualization() {\n            updateCurrentMatrix();\n            drawGraph();\n        }\n        \n        function updateCurrentMatrix() {\n            const container = document.getElementById('currentMatrix');\n            container.innerHTML = '';\n            \n            const table = document.createElement('table');\n            const thead = document.createElement('thead');\n            const tbody = document.createElement('tbody');\n            \n            // Create header row\n            const headerRow = document.createElement('tr');\n            const emptyHeader = document.createElement('th');\n            headerRow.appendChild(emptyHeader);\n            \n            for (let i = 0; i < n; i++) {\n                const th = document.createElement('th');\n                th.textContent = i;\n                headerRow.appendChild(th);\n            }\n            thead.appendChild(headerRow);\n            \n            // Create data rows\n            for (let i = 0; i < n; i++) {\n                const row = document.createElement('tr');\n                const rowHeader = document.createElement('th');\n                rowHeader.textContent = i;\n                row.appendChild(rowHeader);\n                \n                for (let j = 0; j < n; j++) {\n                    const cell = document.createElement('td');\n                    cell.textContent = distanceMatrix[i][j] === Infinity ? '∞' : distanceMatrix[i][j];\n                    \n                    // Highlight cells that might be updated in current step\n                    if (currentK > 0 && currentK <= n) {\n                        const k = currentK - 1;\n                        if (i === k || j === k) {\n                            cell.classList.add('highlight');\n                        }\n                        \n                        // Highlight cells that were updated\n                        if (i !== k && j !== k && k < currentK) {\n                            const original = graph[i][j];\n                            const throughK = graph[i][k] + graph[k][j];\n                            if (throughK < original) {\n                                cell.classList.add('current');\n                            }\n                        }\n                    }\n                    \n                    row.appendChild(cell);\n                }\n                tbody.appendChild(row);\n            }\n            \n            table.appendChild(thead);\n            table.appendChild(tbody);\n            container.appendChild(table);\n        }\n        \n        function findShortestPath() {\n            const from = parseInt(document.getElementById('pathFrom').value);\n            const to = parseInt(document.getElementById('pathTo').value);\n            \n            if (currentK < n) {\n                document.getElementById('pathResult').textContent = 'Algorithm must complete first';\n                return;\n            }\n            \n            if (!isFinite(distanceMatrix[from][to])) {\n                document.getElementById('pathResult').textContent = `No path exists from ${from} to ${to}`;\n                document.getElementById('pathSteps').innerHTML = '';\n                return;\n            }\n            \n            const path = reconstructPath(from, to);\n            document.getElementById('pathResult').textContent = `Shortest path from ${from} to ${to}: ${path.join(' → ')} (Total weight: ${distanceMatrix[from][to]})`;\n            \n            // Show path steps\n            let stepsHTML = '<h4>Path Reconstruction Steps:</h4><ol>';\n            for (let i = 0; i < path.length - 1; i++) {\n                const u = path[i];\n                const v = path[i+1];\n                stepsHTML += `<li>Direct edge from ${u} to ${v} (weight: ${graph[u][v]})</li>`;\n            }\n            stepsHTML += '</ol>';\n            document.getElementById('pathSteps').innerHTML = stepsHTML;\n            \n            // Highlight path in visualization\n            highlightPath(path);\n        }\n        \n        function reconstructPath(u, v) {\n            if (nextMatrix[u][v] === null) return [];\n            \n            const path = [u];\n            while (u !== v) {\n                u = nextMatrix[u][v];\n                path.push(u);\n            }\n            return path;\n        }\n        \n        function highlightPath(path) {\n            // Clear previous highlights\n            const cells = document.querySelectorAll('#currentMatrix td');\n            cells.forEach(cell => cell.classList.remove('path'));\n            \n            // Highlight path in distance matrix\n            for (let i = 0; i < path.length - 1; i++) {\n                const u = path[i];\n                const v = path[i+1];\n                const cell = document.querySelector(`#currentMatrix tr:nth-child(${u+2}) td:nth-child(${v+2})`);\n                if (cell) cell.classList.add('path');\n            }\n            \n            // Also highlight in graph visualization\n            drawGraph(path);\n            \n            // Remove highlights after 5 seconds\n            if (pathHighlightTimeout) {\n                clearTimeout(pathHighlightTimeout);\n            }\n            pathHighlightTimeout = setTimeout(() => {\n                cells.forEach(cell => cell.classList.remove('path'));\n                drawGraph();\n                pathHighlightTimeout = null;\n            }, 5000);\n        }\n        \n        function drawGraph(highlightPath = []) {\n            const container = document.getElementById('graph-container');\n            container.innerHTML = '';\n            \n            const canvas = document.createElement('canvas');\n            canvas.width = container.clientWidth;\n            canvas.height = container.clientHeight;\n            container.appendChild(canvas);\n            \n            const ctx = canvas.getContext('2d');\n            const centerX = canvas.width / 2;\n            const centerY = canvas.height / 2;\n            const radius = Math.min(canvas.width, canvas.height) * 0.4;\n            \n            // Draw edges first\n            ctx.strokeStyle = '#000';\n            ctx.lineWidth = 1;\n            ctx.font = '12px Arial';\n            ctx.textAlign = 'center';\n            ctx.textBaseline = 'middle';\n            \n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j < n; j++) {\n                    if (i !== j && isFinite(graph[i][j])) {\n                        const angle1 = (i / n) * Math.PI * 2;\n                        const angle2 = (j / n) * Math.PI * 2;\n                        \n                        const x1 = centerX + Math.cos(angle1) * radius;\n                        const y1 = centerY + Math.sin(angle1) * radius;\n                        const x2 = centerX + Math.cos(angle2) * radius;\n                        const y2 = centerY + Math.sin(angle2) * radius;\n                        \n                        // Check if this edge is part of the highlighted path\n                        const isPathEdge = highlightPath.length > 0 && \n                            highlightPath.includes(i) && highlightPath.includes(j) &&\n                            Math.abs(highlightPath.indexOf(i) - highlightPath.indexOf(j)) === 1;\n                        \n                        if (isPathEdge) {\n                            ctx.strokeStyle = '#f00';\n                            ctx.lineWidth = 3;\n                        } else {\n                            ctx.strokeStyle = '#000';\n                            ctx.lineWidth = 1;\n                        }\n                        \n                        // Draw arrow\n                        drawArrow(ctx, x1, y1, x2, y2);\n                        \n                        // Draw weight\n                        const midX = (x1 + x2) / 2;\n                        const midY = (y1 + y2) / 2;\n                        \n                        ctx.fillStyle = isPathEdge ? '#f00' : '#000';\n                        ctx.fillText(graph[i][j], midX, midY);\n                    }\n                }\n            }\n            \n            // Draw nodes\n            ctx.fillStyle = '#fff';\n            ctx.strokeStyle = '#000';\n            ctx.lineWidth = 2;\n            \n            for (let i = 0; i < n; i++) {\n                const angle = (i / n) * Math.PI * 2;\n                const x = centerX + Math.cos(angle) * radius;\n                const y = centerY + Math.sin(angle) * radius;\n                \n                const isPathNode = highlightPath.includes(i);\n                if (isPathNode) {\n                    ctx.fillStyle = '#f88';\n                } else {\n                    ctx.fillStyle = '#fff';\n                }\n                \n                ctx.beginPath();\n                ctx.arc(x, y, 20, 0, Math.PI * 2);\n                ctx.fill();\n                ctx.stroke();\n                \n                ctx.fillStyle = '#000';\n                ctx.fillText(i, x, y);\n            }\n        }\n        \n        function drawArrow(ctx, fromX, fromY, toX, toY) {\n            const headLength = 10;\n            const angle = Math.atan2(toY - fromY, toX - fromX);\n            \n            // Adjust start and end points to account for node radius\n            const adjustedFromX = fromX + Math.cos(angle) * 20;\n            const adjustedFromY = fromY + Math.sin(angle) * 20;\n            const adjustedToX = toX - Math.cos(angle) * 20;\n            const adjustedToY = toY - Math.sin(angle) * 20;\n            \n            // Draw line\n            ctx.beginPath();\n            ctx.moveTo(adjustedFromX, adjustedFromY);\n            ctx.lineTo(adjustedToX, adjustedToY);\n            ctx.stroke();\n            \n            // Draw arrow head\n            ctx.beginPath();\n            ctx.moveTo(adjustedToX, adjustedToY);\n            ctx.lineTo(\n                adjustedToX - headLength * Math.cos(angle - Math.PI / 6),\n                adjustedToY - headLength * Math.sin(angle - Math.PI / 6)\n            );\n            ctx.lineTo(adjustedToX, adjustedToY);\n            ctx.lineTo(\n                adjustedToX - headLength * Math.cos(angle + Math.PI / 6),\n                adjustedToY - headLength * Math.sin(angle + Math.PI / 6)\n            );\n            ctx.stroke();\n        }\n        \n        // Initialize\n        resetAlgorithm();\n    </script>\n</body>\n</html>"
