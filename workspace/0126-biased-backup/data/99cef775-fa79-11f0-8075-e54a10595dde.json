    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Depth-First Search (DFS) Visualizer</title>\n    <style>\n        #output {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Depth-First Search (DFS) Visualizer</h1>\n    <label for=\"startNode\">Start Node (0-based index):</label>\n    <input type=\"number\" id=\"startNode\" value=\"0\" min=\"0\">\n    \n    <label for=\"graph\">Graph (Comma-separated values):</label>\n    <input type=\"text\" id=\"graph\" value=\"0,1,0,0,0,2,1,3,0,4,0,0\">\n    \n    <button id=\"runDFS\">Run DFS</button>\n    <button id=\"reset\">Reset</button>\n    \n    <h2>Output:</h2>\n    <div id=\"output\"></div>\n\n    <script>\n        let adjacencyList = [];\n\n        document.getElementById(\"runDFS\").onclick = function() {\n            const startNode = parseInt(document.getElementById(\"startNode\").value);\n            const graphInput = document.getElementById(\"graph\").value.split(\",\").map(Number);\n            buildGraph(graphInput);\n            const visited = new Set();\n            const result = [];\n            dfs(startNode, visited, result);\n            document.getElementById(\"output\").innerText = \"DFS Order: \" + result.join(\", \");\n        };\n\n        document.getElementById(\"reset\").onclick = function() {\n            document.getElementById(\"startNode\").value = \"0\";\n            document.getElementById(\"graph\").value = \"0,1,0,0,0,2,1,3,0,4,0,0\";\n            document.getElementById(\"output\").innerText = \"\";\n            adjacencyList = [];\n        };\n\n        function buildGraph(graphInput) {\n            adjacencyList = [];\n            for (let i = 0; i < graphInput.length; i += 2) {\n                let node = graphInput[i];\n                adjacencyList[node] = adjacencyList[node] || [];\n                if (i + 1 < graphInput.length) {\n                    adjacencyList[node].push(graphInput[i + 1]);\n                }\n            }\n        }\n\n        function dfs(node, visited, result) {\n            visited.add(node);\n            result.push(node);\n            if (adjacencyList[node]) {\n                for (const neighbor of adjacencyList[node]) {\n                    if (!visited.has(neighbor)) {\n                        dfs(neighbor, visited, result);\n                    }\n                }\n            }\n        }\n    </script>\n</body>\n</html>"
