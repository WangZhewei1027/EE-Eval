    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Topological Sort Visualization</title>\n    <style>\n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Arial', sans-serif;\n            background-color: #1f1f1f;\n            color: #f0f0f0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n\n        #container {\n            position: relative;\n            width: 80vw;\n            height: 70vh;\n            background: linear-gradient(135deg, #143c61, #1f7a8a);\n            border-radius: 15px;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);\n            overflow: hidden;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n\n        .node {\n            background: #2b2b2b;\n            border-radius: 10px;\n            padding: 15px;\n            margin: 10px;\n            width: 60px;\n            text-align: center;\n            transition: transform 0.3s ease, box-shadow 0.3s ease;\n        }\n\n        .node:hover {\n            box-shadow: 0 0 20px rgba(255, 255, 0, 0.7);\n            transform: scale(1.1);\n        }\n\n        .arrow {\n            width: 50px;\n            height: 20px;\n            background: transparent;\n            position: absolute;\n            border-left: 4px solid #f0f0f0;\n        }\n\n        .arrow::after {\n            content: '';\n            position: absolute;\n            left: 40px;\n            top: 5px;\n            width: 0;\n            height: 0;\n            border-top: 10px solid transparent;\n            border-bottom: 10px solid transparent;\n            border-left: 10px solid #f0f0f0;\n        }\n\n        #controls {\n            position: absolute;\n            bottom: 20px;\n            display: flex;\n            gap: 20px;\n        }\n\n        button {\n            background: #f0a500;\n            color: #1f1f1f;\n            border: none;\n            padding: 10px 20px;\n            border-radius: 5px;\n            cursor: pointer;\n            font-weight: bold;\n            transition: background 0.3s ease;\n        }\n\n        button:hover {\n            background: #d88e00;\n        }\n    </style>\n</head>\n<body>\n\n<div id=\"container\">\n    <div id=\"nodes\">\n        <div class=\"node\" style=\"position: absolute; top: 30%; left: 10%;\">A</div>\n        <div class=\"node\" style=\"position: absolute; top: 40%; left: 40%;\">B</div>\n        <div class=\"node\" style=\"position: absolute; top: 70%; left: 20%;\">C</div>\n        <div class=\"node\" style=\"position: absolute; top: 80%; left: 60%;\">D</div>\n        <div class=\"node\" style=\"position: absolute; top: 50%; left: 70%;\">E</div>\n        <div class=\"node\" style=\"position: absolute; top: 20%; left: 80%;\">F</div>\n    </div>\n\n    <div class=\"arrow\" style=\"top: 35%; left: 12%;\"></div>\n    <div class=\"arrow\" style=\"top: 45%; left: 48%; transform: rotate(60deg);\"></div>\n    <div class=\"arrow\" style=\"top: 75%; left: 22%; transform: rotate(40deg);\"></div>\n    <div class=\"arrow\" style=\"top: 25%; left: 72%; transform: rotate(-30deg);\"></div>\n    \n    <div id=\"controls\">\n        <button id=\"startButton\">Start Sort</button>\n    </div>\n</div>\n\n<script>\n    const startButton = document.getElementById('startButton');\n    startButton.addEventListener('click', () => {\n        alert('Topological Sort starts here!');\n    });\n</script>\n\n</body>\n</html>"
