  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Deadlock Simulation</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; line-height: 1.6; }\n        .container { display: flex; flex-direction: column; gap: 20px; }\n        .panel { border: 1px solid #000; padding: 10px; }\n        .resource { margin: 5px 0; }\n        .process { margin: 10px 0; padding: 5px; border: 1px solid #000; }\n        .controls { display: flex; gap: 10px; margin-top: 10px; }\n        button { padding: 5px 10px; }\n        select, input { padding: 5px; }\n        .log { height: 200px; overflow-y: scroll; border: 1px solid #000; padding: 5px; }\n        .deadlock { background-color: #ffcccc; }\n    </style>\n</head>\n<body>\n    <h1>Deadlock Simulation</h1>\n    <div class=\"container\">\n        <div class=\"panel\">\n            <h2>Resources</h2>\n            <div id=\"resources\">\n                <div class=\"resource\" id=\"res1\">\n                    Resource A: <span class=\"status\">Available</span>\n                    <div class=\"controls\">\n                        <button onclick=\"acquireResource('res1')\">Acquire</button>\n                        <button onclick=\"releaseResource('res1')\">Release</button>\n                    </div>\n                </div>\n                <div class=\"resource\" id=\"res2\">\n                    Resource B: <span class=\"status\">Available</span>\n                    <div class=\"controls\">\n                        <button onclick=\"acquireResource('res2')\">Acquire</button>\n                        <button onclick=\"releaseResource('res2')\">Release</button>\n                    </div>\n                </div>\n            </div>\n            <div class=\"controls\">\n                <button onclick=\"addResource()\">Add Resource</button>\n                <button onclick=\"removeResource()\">Remove Resource</button>\n            </div>\n        </div>\n\n        <div class=\"panel\">\n            <h2>Processes</h2>\n            <div id=\"processes\">\n                <div class=\"process\" id=\"proc1\">\n                    Process 1\n                    <div>\n                        Holds: <span class=\"holds\"></span>\n                        <br>\n                        Waiting for: <span class=\"waiting\"></span>\n                    </div>\n                    <div class=\"controls\">\n                        <select id=\"proc1-action\">\n                            <option value=\"none\">Select action</option>\n                            <option value=\"acquire\">Acquire Resource</option>\n                            <option value=\"release\">Release Resource</option>\n                        </select>\n                        <select id=\"proc1-resource\">\n                            <option value=\"res1\">Resource A</option>\n                            <option value=\"res2\">Resource B</option>\n                        </select>\n                        <button onclick=\"processAction('proc1')\">Execute</button>\n                    </div>\n                </div>\n                <div class=\"process\" id=\"proc2\">\n                    Process 2\n                    <div>\n                        Holds: <span class=\"holds\"></span>\n                        <br>\n                        Waiting for: <span class=\"waiting\"></span>\n                    </div>\n                    <div class=\"controls\">\n                        <select id=\"proc2-action\">\n                            <option value=\"none\">Select action</option>\n                            <option value=\"acquire\">Acquire Resource</option>\n                            <option value=\"release\">Release Resource</option>\n                        </select>\n                        <select id=\"proc2-resource\">\n                            <option value=\"res1\">Resource A</option>\n                            <option value=\"res2\">Resource B</option>\n                        </select>\n                        <button onclick=\"processAction('proc2')\">Execute</button>\n                    </div>\n                </div>\n            </div>\n            <div class=\"controls\">\n                <button onclick=\"addProcess()\">Add Process</button>\n                <button onclick=\"removeProcess()\">Remove Process</button>\n            </div>\n        </div>\n\n        <div class=\"panel\">\n            <h2>Simulation Controls</h2>\n            <div class=\"controls\">\n                <button onclick=\"runAutoDeadlock()\">Run Deadlock Scenario</button>\n                <button onclick=\"runAutoNoDeadlock()\">Run No-Deadlock Scenario</button>\n                <button onclick=\"resetAll()\">Reset All</button>\n                <button onclick=\"checkDeadlock()\">Check for Deadlock</button>\n            </div>\n            <div>\n                <label>Process Speed (ms): <input type=\"range\" id=\"speed\" min=\"100\" max=\"2000\" value=\"1000\"></label>\n                <span id=\"speed-value\">1000</span>\n            </div>\n        </div>\n\n        <div class=\"panel\">\n            <h2>System State</h2>\n            <div class=\"log\" id=\"log\"></div>\n            <div id=\"deadlock-status\">No deadlock detected</div>\n        </div>\n    </div>\n\n    <script>\n        // Global state\n        const state = {\n            resources: {\n                res1: { heldBy: null },\n                res2: { heldBy: null }\n            },\n            processes: {\n                proc1: { holds: [], waitingFor: null },\n                proc2: { holds: [], waitingFor: null }\n            },\n            nextResourceId: 3,\n            nextProcessId: 3,\n            logEntries: [],\n            autoRunning: false\n        };\n\n        // DOM elements\n        const speedSlider = document.getElementById('speed');\n        const speedValue = document.getElementById('speed-value');\n        const logElement = document.getElementById('log');\n        const deadlockStatus = document.getElementById('deadlock-status');\n\n        // Update speed display\n        speedSlider.addEventListener('input', () => {\n            speedValue.textContent = speedSlider.value;\n        });\n\n        // Core functions\n        function acquireResource(resourceId, processId) {\n            const resource = state.resources[resourceId];\n            const process = state.processes[processId];\n            \n            if (resource.heldBy === null) {\n                resource.heldBy = processId;\n                process.holds.push(resourceId);\n                log(`Process ${processId} acquired ${resourceId}`);\n                // Remove from waiting if it was waiting for this resource\n                if (process.waitingFor === resourceId) {\n                    process.waitingFor = null;\n                }\n                updateUI();\n                return true;\n            } else {\n                process.waitingFor = resourceId;\n                log(`Process ${processId} is waiting for ${resourceId} (held by ${resource.heldBy})`);\n                updateUI();\n                checkDeadlock();\n                return false;\n            }\n        }\n\n        function releaseResource(resourceId, processId) {\n            const resource = state.resources[resourceId];\n            const process = state.processes[processId];\n            \n            if (resource.heldBy === processId) {\n                resource.heldBy = null;\n                process.holds = process.holds.filter(r => r !== resourceId);\n                log(`Process ${processId} released ${resourceId}`);\n                \n                // Check if any process is waiting for this resource\n                for (const [pid, p] of Object.entries(state.processes)) {\n                    if (p.waitingFor === resourceId) {\n                        acquireResource(resourceId, pid);\n                    }\n                }\n                \n                updateUI();\n                checkDeadlock();\n                return true;\n            } else {\n                log(`Process ${processId} cannot release ${resourceId} (not held)`);\n                return false;\n            }\n        }\n\n        function processAction(processId) {\n            if (state.autoRunning) return;\n            \n            const actionSelect = document.getElementById(`${processId}-action`);\n            const resourceSelect = document.getElementById(`${processId}-resource`);\n            \n            const action = actionSelect.value;\n            const resourceId = resourceSelect.value;\n            \n            if (action === 'none') {\n                log('Please select an action');\n                return;\n            }\n            \n            if (action === 'acquire') {\n                acquireResource(resourceId, processId);\n            } else if (action === 'release') {\n                releaseResource(resourceId, processId);\n            }\n            \n            actionSelect.value = 'none';\n        }\n\n        function checkDeadlock() {\n            // Build wait-for graph\n            const graph = {};\n            for (const pid of Object.keys(state.processes)) {\n                graph[pid] = [];\n            }\n            \n            for (const [pid, process] of Object.entries(state.processes)) {\n                if (process.waitingFor) {\n                    const holder = state.resources[process.waitingFor].heldBy;\n                    if (holder) {\n                        graph[pid].push(holder);\n                    }\n                }\n            }\n            \n            // Check for cycles in the graph (deadlock)\n            const visited = new Set();\n            let hasDeadlock = false;\n            \n            function hasCycle(node, path = new Set()) {\n                if (path.has(node)) return true;\n                if (visited.has(node)) return false;\n                \n                visited.add(node);\n                path.add(node);\n                \n                for (const neighbor of graph[node] || []) {\n                    if (hasCycle(neighbor, new Set(path))) {\n                        return true;\n                    }\n                }\n                \n                return false;\n            }\n            \n            for (const node of Object.keys(graph)) {\n                if (!visited.has(node) && hasCycle(node)) {\n                    hasDeadlock = true;\n                    break;\n                }\n            }\n            \n            if (hasDeadlock) {\n                deadlockStatus.textContent = \"DEADLOCK DETECTED!\";\n                deadlockStatus.style.fontWeight = \"bold\";\n                document.querySelectorAll('.process').forEach(el => {\n                    if (graph[el.id] && graph[el.id].length > 0) {\n                        el.classList.add('deadlock');\n                    }\n                });\n                log(\"Deadlock detected in the system!\");\n            } else {\n                deadlockStatus.textContent = \"No deadlock detected\";\n                deadlockStatus.style.fontWeight = \"normal\";\n                document.querySelectorAll('.process').forEach(el => {\n                    el.classList.remove('deadlock');\n                });\n            }\n            \n            return hasDeadlock;\n        }\n\n        // UI update functions\n        function updateUI() {\n            // Update resource status\n            for (const [id, resource] of Object.entries(state.resources)) {\n                const element = document.getElementById(id);\n                if (element) {\n                    const status = resource.heldBy ? `Held by ${resource.heldBy}` : 'Available';\n                    element.querySelector('.status').textContent = status;\n                }\n            }\n            \n            // Update process status\n            for (const [id, process] of Object.entries(state.processes)) {\n                const element = document.getElementById(id);\n                if (element) {\n                    element.querySelector('.holds').textContent = process.holds.join(', ') || 'None';\n                    element.querySelector('.waiting').textContent = process.waitingFor || 'None';\n                }\n            }\n        }\n\n        function log(message) {\n            state.logEntries.push(message);\n            if (state.logEntries.length > 50) {\n                state.logEntries.shift();\n            }\n            logElement.innerHTML = state.logEntries.join('<br>');\n            logElement.scrollTop = logElement.scrollHeight;\n        }\n\n        // Management functions\n        function addResource() {\n            if (state.autoRunning) return;\n            \n            const newId = `res${state.nextResourceId++}`;\n            state.resources[newId] = { heldBy: null };\n            \n            const newResource = document.createElement('div');\n            newResource.className = 'resource';\n            newResource.id = newId;\n            newResource.innerHTML = `\n                Resource ${String.fromCharCode(64 + state.nextResourceId - 1)}: <span class=\"status\">Available</span>\n                <div class=\"controls\">\n                    <button onclick=\"acquireResource('${newId}')\">Acquire</button>\n                    <button onclick=\"releaseResource('${newId}')\">Release</button>\n                </div>\n            `;\n            \n            document.getElementById('resources').appendChild(newResource);\n            \n            // Add to all process resource selectors\n            document.querySelectorAll('[id$=\"-resource\"]').forEach(select => {\n                const option = document.createElement('option');\n                option.value = newId;\n                option.textContent = `Resource ${String.fromCharCode(64 + state.nextResourceId - 1)}`;\n                select.appendChild(option);\n            });\n            \n            log(`Added new resource: ${newId}`);\n        }\n\n        function removeResource() {\n            if (state.autoRunning) return;\n            \n            const resourceIds = Object.keys(state.resources);\n            if (resourceIds.length <= 2) {\n                log(\"Cannot remove - minimum 2 resources required\");\n                return;\n            }\n            \n            const toRemove = resourceIds[resourceIds.length - 1];\n            \n            // Check if resource is in use\n            if (state.resources[toRemove].heldBy) {\n                log(`Cannot remove ${toRemove} - it's currently held by a process`);\n                return;\n            }\n            \n            // Check if any process is waiting for this resource\n            let waitingProcess = null;\n            for (const [pid, process] of Object.entries(state.processes)) {\n                if (process.waitingFor === toRemove) {\n                    waitingProcess = pid;\n                    break;\n                }\n            }\n            \n            if (waitingProcess) {\n                log(`Cannot remove ${toRemove} - process ${waitingProcess} is waiting for it`);\n                return;\n            }\n            \n            delete state.resources[toRemove];\n            document.getElementById(toRemove).remove();\n            \n            // Remove from all process resource selectors\n            document.querySelectorAll('[id$=\"-resource\"]').forEach(select => {\n                for (let i = 0; i < select.options.length; i++) {\n                    if (select.options[i].value === toRemove) {\n                        select.remove(i);\n                        break;\n                    }\n                }\n            });\n            \n            log(`Removed resource: ${toRemove}`);\n        }\n\n        function addProcess() {\n            if (state.autoRunning) return;\n            \n            const newId = `proc${state.nextProcessId++}`;\n            state.processes[newId] = { holds: [], waitingFor: null };\n            \n            const newProcess = document.createElement('div');\n            newProcess.className = 'process';\n            newProcess.id = newId;\n            \n            // Build resource options\n            let resourceOptions = '';\n            for (const resId of Object.keys(state.resources)) {\n                const resName = `Resource ${String.fromCharCode(64 + parseInt(resId.slice(3)))}`;\n                resourceOptions += `<option value=\"${resId}\">${resName}</option>`;\n            }\n            \n            newProcess.innerHTML = `\n                Process ${state.nextProcessId - 1}\n                <div>\n                    Holds: <span class=\"holds\"></span>\n                    <br>\n                    Waiting for: <span class=\"waiting\"></span>\n                </div>\n                <div class=\"controls\">\n                    <select id=\"${newId}-action\">\n                        <option value=\"none\">Select action</option>\n                        <option value=\"acquire\">Acquire Resource</option>\n                        <option value=\"release\">Release Resource</option>\n                    </select>\n                    <select id=\"${newId}-resource\">\n                        ${resourceOptions}\n                    </select>\n                    <button onclick=\"processAction('${newId}')\">Execute</button>\n                </div>\n            `;\n            \n            document.getElementById('processes').appendChild(newProcess);\n            log(`Added new process: ${newId}`);\n        }\n\n        function removeProcess() {\n            if (state.autoRunning) return;\n            \n            const processIds = Object.keys(state.processes);\n            if (processIds.length <= 2) {\n                log(\"Cannot remove - minimum 2 processes required\");\n                return;\n            }\n            \n            const toRemove = processIds[processIds.length - 1];\n            const process = state.processes[toRemove];\n            \n            // Check if process holds any resources\n            if (process.holds.length > 0) {\n                log(`Cannot remove ${toRemove} - it's currently holding resources`);\n                return;\n            }\n            \n            delete state.processes[toRemove];\n            document.getElementById(toRemove).remove();\n            log(`Removed process: ${toRemove}`);\n        }\n\n        // Simulation functions\n        function runAutoDeadlock() {\n            if (state.autoRunning) return;\n            \n            state.autoRunning = true;\n            log(\"Running deadlock scenario...\");\n            \n            // Process 1 acquires Resource A\n            setTimeout(() => {\n                acquireResource('res1', 'proc1');\n                \n                // Process 2 acquires Resource B\n                setTimeout(() => {\n                    acquireResource('res2', 'proc2');\n                    \n                    // Process 1 tries to acquire Resource B (will wait)\n                    setTimeout(() => {\n                        acquireResource('res2', 'proc1');\n                        \n                        // Process 2 tries to acquire Resource A (deadlock)\n                        setTimeout(() => {\n                            acquireResource('res1', 'proc2');\n                            state.autoRunning = false;\n                        }, getSpeed());\n                    }, getSpeed());\n                }, getSpeed());\n            }, getSpeed());\n        }\n\n        function runAutoNoDeadlock() {\n            if (state.autoRunning) return;\n            \n            state.autoRunning = true;\n            log(\"Running no-deadlock scenario...\");\n            \n            // Process 1 acquires Resource A\n            setTimeout(() => {\n                acquireResource('res1', 'proc1');\n                \n                // Process 1 releases Resource A\n                setTimeout(() => {\n                    releaseResource('res1', 'proc1');\n                    \n                    // Process 2 acquires Resource A\n                    setTimeout(() => {\n                        acquireResource('res1', 'proc2');\n                        \n                        // Process 2 releases Resource A\n                        setTimeout(() => {\n                            releaseResource('res1', 'proc2');\n                            state.autoRunning = false;\n                        }, getSpeed());\n                    }, getSpeed());\n                }, getSpeed());\n            }, getSpeed());\n        }\n\n        function resetAll() {\n            if (state.autoRunning) return;\n            \n            // Reset resources\n            for (const resId in state.resources) {\n                state.resources[resId].heldBy = null;\n            }\n            \n            // Reset processes\n            for (const procId in state.processes) {\n                state.processes[procId] = { holds: [], waitingFor: null };\n            }\n            \n            // Reset UI\n            updateUI();\n            log(\"System reset to initial state\");\n            deadlockStatus.textContent = \"No deadlock detected\";\n            deadlockStatus.style.fontWeight = \"normal\";\n            document.querySelectorAll('.process').forEach(el => {\n                el.classList.remove('deadlock');\n            });\n        }\n\n        function getSpeed() {\n            return parseInt(speedSlider.value);\n        }\n\n        // Initialize\n        updateUI();\n        log(\"System initialized. Ready to simulate deadlocks.\");\n    </script>\n</body>\n</html>"
  },
