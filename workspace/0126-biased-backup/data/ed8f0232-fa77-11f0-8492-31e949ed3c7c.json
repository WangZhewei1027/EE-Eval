</style>\n</head>\n<body>\n\n<div class=\"container\">\n    <h1>B-Tree Index Visualization</h1>\n    <div class=\"b-tree\">\n        <div class=\"node\">10</div>\n        <div class=\"node\">20</div>\n        <div class=\"node\">30</div>\n        <div class=\"node\">40</div>\n        <div class=\"node\">50</div>\n        <div class=\"node\">60</div>\n    </div>\n    <button class=\"button\" id=\"animateButton\">Animate</button>\n</div>\n\n<script>\n    document.getElementById('animateButton').addEventListener('click', function() {\n        const nodes = document.querySelectorAll('.node');\n        nodes.forEach((node, index) => {\n            setTimeout(() => {\n                node.style.transform = 'translateY(-20px)';\n                setTimeout(() => {\n                    node.style.transform = 'translateY(0)';\n                }, 300);\n            }, index * 500);\n        });\n    });\n</script>\n\n</body>\n</html>"
