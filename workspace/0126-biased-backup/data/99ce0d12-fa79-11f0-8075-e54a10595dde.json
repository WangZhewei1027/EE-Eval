    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Hash Table</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        .container { margin: 20px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Interactive Hash Table</h1>\n        \n        <div>\n            <h2>Controls</h2>\n            <input type=\"text\" id=\"keyInput\" placeholder=\"Enter Key\">\n            <input type=\"text\" id=\"valueInput\" placeholder=\"Enter Value\">\n            <button id=\"addBtn\">Add to Hash Table</button>\n            <button id=\"removeBtn\">Remove from Hash Table</button>\n            <button id=\"searchBtn\">Search Hash Table</button>\n        </div>\n        \n        <div>\n            <h2>Key</h2>\n            <input type=\"text\" id=\"searchKey\" placeholder=\"Enter Key to Search\">\n            <button id=\"searchKeyBtn\">Search Key</button>\n            <div id=\"searchResult\"></div>\n        </div>\n\n        <h2>Current Hash Table</h2>\n        <pre id=\"hashTableContent\"></pre>\n    </div>\n\n    <script>\n        class HashTable {\n            constructor(size) {\n                this.size = size;\n                this.table = new Array(size);\n            }\n\n            _hash(key) {\n                let hash = 0;\n                for (let char of key) {\n                    hash += char.charCodeAt(0);\n                }\n                return hash % this.size;\n            }\n\n            add(key, value) {\n                const index = this._hash(key);\n                this.table[index] = { key, value };\n            }\n\n            remove(key) {\n                const index = this._hash(key);\n                if (this.table[index] && this.table[index].key === key) {\n                    this.table[index] = undefined;\n                } else {\n                    return \"Key not found\";\n                }\n            }\n\n            search(key) {\n                const index = this._hash(key);\n                return this.table[index] && this.table[index].key === key\n                    ? this.table[index].value\n                    : \"Key not found\";\n            }\n        }\n\n        const hashTable = new HashTable(10);\n\n        document.getElementById('addBtn').onclick = function() {\n            const key = document.getElementById('keyInput').value;\n            const value = document.getElementById('valueInput').value;\n            hashTable.add(key, value);\n            updateHashTableContent();\n            clearInputs();\n        };\n\n        document.getElementById('removeBtn').onclick = function() {\n            const key = document.getElementById('keyInput').value;\n            const result = hashTable.remove(key);\n            updateHashTableContent();\n            clearInputs();\n        };\n\n        document.getElementById('searchKeyBtn').onclick = function() {\n            const key = document.getElementById('searchKey').value;\n            const result = hashTable.search(key);\n            document.getElementById('searchResult').innerText = result;\n        };\n\n        function updateHashTableContent() {\n            document.getElementById('hashTableContent').innerText = JSON.stringify(hashTable.table, null, 2);\n        }\n\n        function clearInputs() {\n            document.getElementById('keyInput').value = '';\n            document.getElementById('valueInput').value = '';\n            document.getElementById('searchKey').value = '';\n        }\n    </script>\n</body>\n</html>"
