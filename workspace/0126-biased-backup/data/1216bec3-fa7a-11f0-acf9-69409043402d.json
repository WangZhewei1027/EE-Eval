  "question": "Integration Testing",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Integration Testing Interactive Demo</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    background: white;\n    color: black;\n    margin: 1em;\n  }\n  label {\n    display: block;\n    margin-top: 1em;\n  }\n  input[type=text], input[type=number], select {\n    width: 200px;\n  }\n  button {\n    margin: 0.3em 0.3em 0.3em 0;\n  }\n  #log {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    padding: 0.5em;\n    height: 250px;\n    overflow-y: scroll;\n    margin-top: 1em;\n    background: #fff;\n  }\n  fieldset {\n    margin-top: 1em;\n    padding: 0.5em;\n  }\n</style>\n</head>\n<body>\n<h1>Integration Testing Interactive Demo</h1>\n<p>This demo simulates a complex integration testing workflow with multiple interactive controls and state transitions. Use the controls below to configure modules, define test scenarios, run stepwise integration tests, and explore branching paths.</p>\n\n<form id=\"configForm\" onsubmit=\"return false;\">\n  <fieldset>\n    <legend>1. Module Configuration</legend>\n    <label>\n      Number of Modules:\n      <input type=\"number\" id=\"numModules\" min=\"2\" max=\"8\" value=\"3\" />\n    </label>\n    <label>\n      Module Names (comma separated):\n      <input type=\"text\" id=\"moduleNames\" value=\"Auth,DB,API\" />\n    </label>\n    <label>\n      Select Module to Set Status:\n      <select id=\"moduleSelect\"></select>\n      <button id=\"toggleModuleStatus\">Toggle Status (Active/Inactive)</button>\n    </label>\n    <label>\n      Current Status:\n      <span id=\"moduleStatusDisplay\"></span>\n    </label>\n  </fieldset>\n\n  <fieldset>\n    <legend>2. Test Scenario Setup</legend>\n    <label>\n      Select Test Scenario:\n      <select id=\"testScenarioSelect\">\n        <option value=\"happyPath\">Happy Path</option>\n        <option value=\"failAuth\">Fail Auth Module</option>\n        <option value=\"dbTimeout\">DB Timeout</option>\n        <option value=\"apiError\">API Returns Error</option>\n        <option value=\"custom\">Custom</option>\n      </select>\n    </label>\n    <div id=\"customScenarioConfig\" style=\"display:none; margin-top:0.5em;\">\n      <label>\n        Set Module Failures (comma separated module names to FAIL):\n        <input type=\"text\" id=\"customFailures\" placeholder=\"e.g. Auth,API\" />\n      </label>\n      <label>\n        Set Module Delays (milliseconds, format: Module=Delay, e.g. DB=500,API=200):\n        <input type=\"text\" id=\"customDelays\" placeholder=\"e.g. DB=500,API=200\" />\n      </label>\n    </div>\n  </fieldset>\n\n  <fieldset>\n    <legend>3. Integration Test Execution</legend>\n    <button id=\"startTestRun\">Start Test Run</button>\n    <button id=\"stepTestRun\" disabled>Next Step</button>\n    <button id=\"resetTestRun\" disabled>Reset Test Run</button>\n    <label>\n      Step Delay (ms):\n      <input type=\"number\" id=\"stepDelay\" min=\"10\" max=\"5000\" value=\"500\" />\n    </label>\n    <label>\n      Auto Run:\n      <input type=\"checkbox\" id=\"autoRunToggle\" />\n    </label>\n  </fieldset>\n\n  <fieldset>\n    <legend>4. Branching Control</legend>\n    <label>\n      At Failure, Choose Next Action:\n      <select id=\"failureActionSelect\" disabled>\n        <option value=\"retry\">Retry Module</option>\n        <option value=\"skip\">Skip Module</option>\n        <option value=\"abort\">Abort Test</option>\n        <option value=\"modify\">Modify Config & Continue</option>\n      </select>\n    </label>\n    <div id=\"modifyConfigSection\" style=\"display:none; margin-top:0.5em;\">\n      <label>\n        Toggle Modules Active/Inctive (comma separated):\n        <input type=\"text\" id=\"modifyModules\" placeholder=\"e.g. API,DB\" />\n      </label>\n      <button id=\"applyModifyConfig\">Apply Modifications</button>\n    </div>\n  </fieldset>\n</form>\n\n<fieldset>\n  <legend>Test Execution Log & State</legend>\n  <div id=\"log\" tabindex=\"0\" aria-label=\"Test execution log\"></div>\n</fieldset>\n\n<script>\n(() => {\n  // State and Data Structures\n  const maxModules = 8;\n\n  // Module: {name:string, active:boolean, fail:boolean, delay:number(ms), lastResult: 'pending'|'success'|'fail'|'skipped', lastMessage:string}\n  let modules = [];\n\n  // Test scenario config\n  let testScenario = \"happyPath\";\n\n  // Step index in module execution\n  let currentStep = 0;\n\n  // Running state: 'idle'|'running'|'paused'|'finished'|'aborted'\n  let runState = 'idle';\n\n  // Timer for auto run\n  let autoRunTimer = null;\n\n  // Failure handling\n  // Options: retry, skip, abort, modify (fallback)\n  let failureAction = 'retry';\n\n  // Elements cache\n  const el = {\n    numModules: document.getElementById('numModules'),\n    moduleNames: document.getElementById('moduleNames'),\n    moduleSelect: document.getElementById('moduleSelect'),\n    moduleStatusDisplay: document.getElementById('moduleStatusDisplay'),\n    toggleModuleStatus: document.getElementById('toggleModuleStatus'),\n    testScenarioSelect: document.getElementById('testScenarioSelect'),\n    customScenarioConfig: document.getElementById('customScenarioConfig'),\n    customFailures: document.getElementById('customFailures'),\n    customDelays: document.getElementById('customDelays'),\n    startTestRun: document.getElementById('startTestRun'),\n    stepTestRun: document.getElementById('stepTestRun'),\n    resetTestRun: document.getElementById('resetTestRun'),\n    stepDelay: document.getElementById('stepDelay'),\n    autoRunToggle: document.getElementById('autoRunToggle'),\n    failureActionSelect: document.getElementById('failureActionSelect'),\n    modifyConfigSection: document.getElementById('modifyConfigSection'),\n    modifyModules: document.getElementById('modifyModules'),\n    applyModifyConfig: document.getElementById('applyModifyConfig'),\n    log: document.getElementById('log')\n  };\n\n  function log(msg){\n    const now = new Date();\n    const timestamp = now.toTimeString().slice(0,8);\n    el.log.textContent += `[${timestamp}] ${msg}\\n`;\n    el.log.scrollTop = el.log.scrollHeight;\n  }\n\n  function clearLog(){\n    el.log.textContent = \"\";\n  }\n\n  // Initialize modules from input controls\n  function initModulesFromInput(){\n    let n = parseInt(el.numModules.value, 10);\n    if(isNaN(n) || n < 2) n = 2;\n    if(n > maxModules) n = maxModules;\n    el.numModules.value = n;\n\n    let namesRaw = el.moduleNames.value.trim();\n    let names = namesRaw.length ? namesRaw.split(',').map(s=>s.trim()).filter(s=>s.length) : [];\n\n    // Pad or trim to n\n    if(names.length > n) names = names.slice(0,n);\n    else while(names.length < n) names.push(`Module${names.length+1}`);\n\n    modules = names.map(name => ({\n      name,\n      active: true,\n      fail: false,\n      delay: 0,\n      lastResult: 'pending',\n      lastMessage: ''\n    }));\n\n    el.moduleNames.value = names.join(',');\n\n    updateModuleSelectOptions();\n    displaySelectedModuleStatus();\n  }\n\n  // Update module select with current modules\n  function updateModuleSelectOptions(){\n    const sel = el.moduleSelect;\n    sel.innerHTML = \"\";\n    modules.forEach((m,i) => {\n      let option = document.createElement('option');\n      option.value = i;\n      option.textContent = m.name;\n      sel.appendChild(option);\n    });\n  }\n\n  // Display the current status of selected module\n  function displaySelectedModuleStatus(){\n    const idx = parseInt(el.moduleSelect.value,10);\n    if(isNaN(idx) || idx < 0 || idx >= modules.length){\n      el.moduleStatusDisplay.textContent = 'N/A';\n      return;\n    }\n    const m = modules[idx];\n    el.moduleStatusDisplay.textContent = `Active: ${m.active}, Fail: ${m.fail}, Delay: ${m.delay}ms, Last Result: ${m.lastResult}${m.lastMessage ? \" (\" + m.lastMessage + \")\" : \"\"}`;\n  }\n\n  // Toggle module active status\n  function toggleSelectedModuleStatus(){\n    const idx = parseInt(el.moduleSelect.value,10);\n    if(isNaN(idx) || idx < 0 || idx >= modules.length) return;\n    modules[idx].active = !modules[idx].active;\n    log(`Module \"${modules[idx].name}\" active set to ${modules[idx].active}`);\n    displaySelectedModuleStatus();\n  }\n\n  // Setup test scenario presets\n  function applyTestScenarioPreset(scenarioKey) {\n    switch(scenarioKey){\n      case 'happyPath':\n        // No failures, no delays\n        modules.forEach(m => { m.fail = false; m.delay = 0; });\n        clearLog();\n        log(\"Test scenario set to Happy Path. No failures, no delays.\");\n        break;\n      case 'failAuth':\n        // Fail Auth module ONLY if exists\n        modules.forEach(m => {\n          m.fail = false;\n          m.delay = 0;\n          if(m.name.toLowerCase().includes('auth')) m.fail = true;\n        });\n        clearLog();\n        log(\"Test scenario set to Fail Auth Module.\");\n        break;\n      case 'dbTimeout':\n        // DB module delayed and fail\n        modules.forEach(m => {\n          m.fail = false;\n          m.delay = 0;\n          if(m.name.toLowerCase().includes('db')) {\n            m.fail = true;\n            m.delay = 1000;\n          }\n        });\n        clearLog();\n        log(\"Test scenario set to DB Timeout (delay + failure).\");\n        break;\n      case 'apiError':\n        modules.forEach(m => {\n          m.fail = false;\n          m.delay = 0;\n          if(m.name.toLowerCase().includes('api')) m.fail = true;\n        });\n        clearLog();\n        log(\"Test scenario set to API Returns Error.\");\n        break;\n      case 'custom':\n        clearLog();\n        log(\"Custom test scenario - configure failures and delays manually.\");\n        break;\n      default:\n        break;\n    }\n    // Reset lastResult states\n    modules.forEach(m => {\n      m.lastResult = 'pending';\n      m.lastMessage = '';\n    });\n    displaySelectedModuleStatus();\n  }\n\n  // Apply custom test scenario config from text inputs\n  function applyCustomScenarioConfig() {\n    const failText = el.customFailures.value.trim();\n    const delayText = el.customDelays.value.trim();\n\n    // Reset all fails/delays\n    modules.forEach(m => {\n      m.fail = false;\n      m.delay = 0;\n    });\n\n    if(failText.length){\n      const fails = failText.split(',').map(s=>s.trim().toLowerCase());\n      modules.forEach(m => {\n        if(fails.includes(m.name.toLowerCase())) m.fail = true;\n      });\n    }\n    if(delayText.length){\n      // Format: Module=Delay,...\n      delayText.split(',').forEach(pair=>{\n        const [mod, val] = pair.split('=').map(s=>s.trim());\n        if(!mod || !val) return;\n        const delayVal = parseInt(val,10);\n        if(isNaN(delayVal) || delayVal < 0) return;\n        modules.forEach(m=>{\n          if(m.name.toLowerCase() === mod.toLowerCase()) m.delay = delayVal;\n        });\n      });\n    }\n    // Reset lastResult states\n    modules.forEach(m => {\n      m.lastResult = 'pending';\n      m.lastMessage = '';\n    });\n    displaySelectedModuleStatus();\n    clearLog();\n    log(\"Custom scenario applied.\");\n    log(`Failures: ${failText || '(none)'} | Delays: ${delayText || '(none)'}`);\n  }\n\n  // Execution step function: Executes current step module integration test step\n  async function executeStep(){\n    if(runState !== 'running') return;\n\n    if(currentStep >= modules.length){\n      log(\"Test run completed successfully.\");\n      runState = 'finished';\n      el.stepTestRun.disabled = true;\n      el.startTestRun.disabled = false;\n      el.resetTestRun.disabled = false;\n      el.failureActionSelect.disabled = true;\n      el.autoRunToggle.disabled = false;\n      return;\n    }\n\n    const mod = modules[currentStep];\n    if(!mod.active){\n      mod.lastResult = 'skipped';\n      mod.lastMessage = \"Module inactive, skipped\";\n      log(`Step ${currentStep+1}/${modules.length}: Module \"${mod.name}\" skipped (inactive).`);\n      currentStep++;\n      return;\n    }\n\n    log(`Step ${currentStep+1}/${modules.length}: Testing module \"${mod.name}\"...`);\n\n    // Simulate delay\n    if(mod.delay > 0) {\n      log(`Delaying ${mod.delay}ms...`);\n      await delay(mod.delay);\n    }\n\n    // Determine pass/fail\n    if(mod.fail){\n      mod.lastResult = 'fail';\n      mod.lastMessage = \"Simulated failure\";\n      log(`Module \"${mod.name}\" FAILED!`);\n\n      // Handle failure\n      await handleFailure(mod, currentStep);\n      return;\n    } else {\n      mod.lastResult = 'success';\n      mod.lastMessage = \"Passed\";\n      log(`Module \"${mod.name}\" passed.`);\n      currentStep++;\n    }\n  }\n\n  function delay(ms){return new Promise(res=>setTimeout(res, ms));}\n\n  // Handles a failure step based on the configured failureAction\n  async function handleFailure(mod, idx){\n    failureAction = el.failureActionSelect.value || 'retry';\n    log(`Failure action selected: ${failureAction}`);\n\n    switch(failureAction){\n      case 'retry':\n        log(`Retrying module \"${mod.name}\"...`);\n        // Just re-run the same step\n        // No state change, keep currentStep unchanged\n        // But to avoid infinite loops, limit retries\n        mod.retryCount = (mod.retryCount||0) + 1;\n        if(mod.retryCount > 3){\n          log(`Module \"${mod.name}\" retry limit exceeded (3). Aborting test.`);\n          abortTestRun();\n          return;\n        }\n        // Retry with delay\n        await delay(100);\n        break;\n      case 'skip':\n        log(`Skipping module \"${mod.name}\". Marking as skipped.`);\n        mod.lastResult = 'skipped';\n        mod.lastMessage = \"Skipped due to failure\";\n        mod.retryCount = 0;\n        currentStep++;\n        mod.retryCount = 0;\n        break;\n      case 'abort':\n        log(\"Aborting test run due to failure.\");\n        abortTestRun();\n        break;\n      case 'modify':\n        log(\"Pausing test run for config modification.\");\n        runState = 'paused';\n        el.failureActionSelect.disabled = false;\n        el.modifyConfigSection.style.display = 'block';\n        el.applyModifyConfig.disabled = false;\n        el.stepTestRun.disabled = true;\n        el.startTestRun.disabled = true;\n        el.resetTestRun.disabled = false;\n        return;  // Pause here to allow user modifications\n      default:\n        log(\"Unknown failure action, aborting.\");\n        abortTestRun();\n        break;\n    }\n  }\n\n  // Abort test run immediately\n  function abortTestRun(){\n    runState = 'aborted';\n    log(\"Test run aborted.\");\n    el.stepTestRun.disabled = true;\n    el.startTestRun.disabled = false;\n    el.resetTestRun.disabled = false;\n    el.failureActionSelect.disabled = true;\n    el.autoRunToggle.disabled = false;\n    clearAutoRunTimer();\n  }\n\n  // Begin test run from step 0\n  function startTestRun(){\n    if(runState === 'running') return;\n    runState = 'running';\n    currentStep = 0;\n\n    // Reset module last result states\n    modules.forEach(m=>{\n      m.lastResult = 'pending';\n      m.lastMessage = '';\n      m.retryCount = 0;\n    });\n\n    clearLog();\n    log(`Starting test run with scenario \"${testScenario}\" on ${modules.length} module(s).`);\n\n    el.stepTestRun.disabled = false;\n    el.resetTestRun.disabled = false;\n    el.startTestRun.disabled = true;\n    el.failureActionSelect.disabled = false;\n    el.autoRunToggle.disabled = false;\n\n    if(el.autoRunToggle.checked){\n      startAutoRun();\n    }\n  }\n\n  // Step one step manually\n  async function stepTestRunAction(){\n    if(runState !== 'running' && runState !== 'paused') return;\n    el.stepTestRun.disabled = true;\n    await executeStep();\n    if(runState === 'running'){\n      el.stepTestRun.disabled = false;\n    }\n  }\n\n  // Reset test run to idle state\n  function resetTestRun(){\n    runState = 'idle';\n    currentStep = 0;\n    clearAutoRunTimer();\n    modules.forEach(m=>{\n      m.lastResult = 'pending';\n      m.lastMessage = '';\n      m.retryCount = 0;\n    });\n    clearLog();\n    log(\"Test run reset to idle.\");\n    el.startTestRun.disabled = false;\n    el.stepTestRun.disabled = true;\n    el.resetTestRun.disabled = true;\n    el.failureActionSelect.disabled = true;\n    el.modifyConfigSection.style.display = 'none';\n    el.autoRunToggle.disabled = false;\n  }\n\n  // Auto run timer implementation\n  function startAutoRun(){\n    clearAutoRunTimer();\n    el.stepTestRun.disabled = true;\n    el.startTestRun.disabled = true;\n    el.resetTestRun.disabled = false;\n    el.failureActionSelect.disabled = false;\n    el.autoRunToggle.disabled = false;\n\n    const delayTime = parseInt(el.stepDelay.value,10);\n    if(isNaN(delayTime) || delayTime < 10) {\n      log(\"Invalid step delay value. Using 500ms.\");\n    }\n    const delayVal = (delayTime >= 10) ? delayTime : 500;\n\n    autoRunTimer = setInterval(async () => {\n      if(runState !== 'running') {\n        clearAutoRunTimer();\n        return;\n      }\n      await executeStep();\n      if(runState !== 'running'){\n        clearAutoRunTimer();\n      }\n    }, delayVal);\n  }\n\n  function clearAutoRunTimer(){\n    if(autoRunTimer){\n      clearInterval(autoRunTimer);\n      autoRunTimer = null;\n    }\n  }\n\n  // Handle scenario select change\n  function onScenarioChange(){\n    testScenario = el.testScenarioSelect.value;\n    if(testScenario === 'custom'){\n      el.customScenarioConfig.style.display = 'block';\n    } else {\n      el.customScenarioConfig.style.display = 'none';\n      applyTestScenarioPreset(testScenario);\n      resetTestRun();\n    }\n  }\n\n  // Apply custom scenario config button (no explicit button, use input focus lost or manual apply on scenario change/start)\n  function applyCustomScenarioIfNeeded(){\n    if(testScenario !== 'custom') return;\n    applyCustomScenarioConfig();\n    resetTestRun();\n  }\n\n  // Apply modifications after failure pause\n  function applyModifyConfig(){\n    const modText = el.modifyModules.value.trim();\n    if(modText.length){\n      const modsToToggle = modText.split(',').map(s=>s.trim().toLowerCase()).filter(s => s.length);\n      let changedMods = [];\n      modules.forEach(m => {\n        if(modsToToggle.includes(m.name.toLowerCase())){\n          m.active = !m.active;\n          changedMods.push(`${m.name} set to active=${m.active}`);\n        }\n      });\n      if(changedMods.length){\n        log(`Modified module activations after failure:\\n - ${changedMods.join('\\n - ')}`);\n      } else {\n        log(\"No matching modules found to modify.\");\n      }\n    } else {\n      log(\"No modules specified for modification.\");\n    }\n    // Hide modification section, resume run\n    el.modifyConfigSection.style.display = 'none';\n    el.failureActionSelect.disabled = false;\n    runState = 'running';\n    el.stepTestRun.disabled = false;\n    el.startTestRun.disabled = true;\n  }\n\n  // Event Listeners Initialization\n  function initEventListeners(){\n    // Module count or names change\n    el.numModules.addEventListener('change', () => {\n      if(runState !== 'idle'){\n        alert(\"Cannot change module count during a test run.\");\n        el.numModules.value = modules.length;\n        return;\n      }\n      initModulesFromInput();\n      resetTestRun();\n    });\n    el.moduleNames.addEventListener('change', () => {\n      if(runState !== 'idle'){\n        alert(\"Cannot change module names during a test run.\");\n        el.moduleNames.value = modules.map(m=>m.name).join(',');\n        return;\n      }\n      initModulesFromInput();\n      resetTestRun();\n    });\n\n    el.moduleSelect.addEventListener('change', displaySelectedModuleStatus);\n    el.toggleModuleStatus.addEventListener('click', e=>{\n      e.preventDefault();\n      toggleSelectedModuleStatus();\n    });\n\n    el.testScenarioSelect.addEventListener('change', onScenarioChange);\n    el.customFailures.addEventListener('blur', applyCustomScenarioIfNeeded);\n    el.customDelays.addEventListener('blur', applyCustomScenarioIfNeeded);\n\n    el.startTestRun.addEventListener('click', e=>{\n      e.preventDefault();\n      applyCustomScenarioIfNeeded();\n      startTestRun();\n    });\n\n    el.stepTestRun.addEventListener('click', async e=>{\n      e.preventDefault();\n      await stepTestRunAction();\n    });\n\n    el.resetTestRun.addEventListener('click', e=>{\n      e.preventDefault();\n      resetTestRun();\n    });\n\n    el.failureActionSelect.addEventListener('change', e=>{\n      failureAction = e.target.value;\n      if(runState === 'paused'){\n        // Depending on failureAction, show or hide modification section\n        if(failureAction === 'modify'){\n          el.modifyConfigSection.style.display = 'block';\n        } else {\n          el.modifyConfigSection.style.display = 'none';\n        }\n      }\n    });\n\n    el.applyModifyConfig.addEventListener('click', e=>{\n      e.preventDefault();\n      applyModifyConfig();\n    });\n\n    el.autoRunToggle.addEventListener('change', e=>{\n      if(e.target.checked){\n        if(runState === 'running'){\n          startAutoRun();\n        }\n      } else {\n        clearAutoRunTimer();\n        if(runState === 'running'){\n          el.stepTestRun.disabled = false;\n          el.startTestRun.disabled = true;\n        }\n      }\n    });\n\n    el.stepDelay.addEventListener('change', e=>{\n      if(el.autoRunToggle.checked && runState === 'running'){\n        startAutoRun();\n      }\n    });\n  }\n\n  // Initialize on load\n  function init(){\n    initModulesFromInput();\n    applyTestScenarioPreset('happyPath');\n    resetTestRun();\n    initEventListeners();\n  }\n\n  window.addEventListener('load', init);\n})();\n</script>\n\n</body>\n</html>"
  },
