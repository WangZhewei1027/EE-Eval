  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Process Exploration Interactive</title>\n<style>\n  body {\n    font-family: monospace, monospace;\n    margin: 1em;\n    background: white;\n    color: black;\n  }\n  label, button, input, select, textarea {\n    font-family: monospace, monospace;\n    margin: 0.2em 0.4em 0.6em 0;\n  }\n  button:focus, input:focus, select:focus, textarea:focus {\n    outline: 1px solid black;\n  }\n  fieldset {\n    margin-bottom: 1em;\n    padding: 0.5em 1em;\n  }\n  .hidden {\n    display: none;\n  }\n  #log {\n    width: 100%;\n    height: 12em;\n    resize: vertical;\n    font-family: monospace, monospace;\n  }\n  #stateDisplay {\n    white-space: pre-wrap;\n    border: 1px solid black;\n    padding: .5em;\n    margin-bottom: 1em;\n  }\n  .section {\n    margin-bottom: 1em;\n  }\n</style>\n</head>\n<body>\n<h1>Process Exploration Interactive</h1>\n\n<div id=\"stateDisplay\" aria-live=\"polite\"></div>\n\n<!-- Controls -->\n<fieldset>\n  <legend>Process Controls</legend>\n\n  <button id=\"startProcessBtn\" type=\"button\">Start Process</button>\n  <button id=\"pauseProcessBtn\" type=\"button\" disabled>Pause Process</button>\n  <button id=\"resumeProcessBtn\" type=\"button\" disabled>Resume Process</button>\n  <button id=\"resetProcessBtn\" type=\"button\" disabled>Reset Process</button>\n\n  <br />\n\n  <label for=\"progressSlider\">Progress:</label>\n  <input id=\"progressSlider\" type=\"range\" min=\"0\" max=\"100\" value=\"0\" disabled />\n  <span id=\"progressValue\">0%</span>\n\n  <br />\n\n  <label for=\"stepSelector\">Jump to Step:</label>\n  <select id=\"stepSelector\" disabled></select>\n  <button id=\"jumpStepBtn\" type=\"button\" disabled>Jump</button>\n\n  <br />\n\n  <label for=\"customInput\">Custom Input:</label>\n  <input id=\"customInput\" type=\"text\" disabled placeholder=\"Type here...\" />\n  <button id=\"submitInputBtn\" type=\"button\" disabled>Submit Input</button>\n</fieldset>\n\n<fieldset>\n  <legend>Process Actions</legend>\n  <button id=\"advanceStepBtn\" type=\"button\" disabled>Advance to Next Step</button>\n  <button id=\"branchStepBtn\" type=\"button\" disabled>Take Branch</button>\n  <button id=\"modifyDataBtn\" type=\"button\" disabled>Modify Process Data</button>\n</fieldset>\n\n<fieldset>\n  <legend>Process Data Control</legend>\n  <label for=\"dataKeyInput\">Key:</label>\n  <input id=\"dataKeyInput\" type=\"text\" placeholder=\"e.g. status\" />\n  <label for=\"dataValueInput\">Value:</label>\n  <input id=\"dataValueInput\" type=\"text\" placeholder=\"e.g. ready\" />\n  <button id=\"setDataBtn\" type=\"button\">Set Data</button>\n  <button id=\"deleteDataBtn\" type=\"button\">Delete Key</button>\n\n  <br />\n  <label for=\"filterDataInput\">Filter Displayed Data:</label>\n  <input id=\"filterDataInput\" type=\"text\" placeholder=\"Filter keys...\" />\n  <button id=\"clearFilterBtn\" type=\"button\">Clear Filter</button>\n</fieldset>\n\n<fieldset>\n  <legend>Process Data View</legend>\n  <textarea id=\"dataView\" rows=\"10\" readonly></textarea>\n</fieldset>\n\n<fieldset>\n  <legend>Process Log</legend>\n  <textarea id=\"log\" readonly></textarea>\n  <button id=\"clearLogBtn\" type=\"button\">Clear Log</button>\n</fieldset>\n\n<script>\n(() => {\n  // Process data and states\n\n  /*\n   Process concept:\n   - Multiple steps, each step can have multiple branches.\n   - Process data can change at each step.\n   - User can advance steps, jump between them, pause/resume/reset process.\n   - User input can affect next step or data.\n   - Progress slider controls/reflects progress (0-100).\n   - Data key-value store accessible for modification/view/filtering.\n   - Log tracks all actions.\n\n   Internal representation:\n\n   processSteps: Array of step objects with:\n    - id: unique string\n    - name: string for display\n    - description: details\n    - possibleNext: array of strings (step ids) for next steps or branches\n    - requiresInput: boolean whether step needs user input before advancing\n    - onEnter: function (data, input) => alters data or state\n  */\n\n  // Utility functions\n  function log(msg) {\n    const time = new Date().toLocaleTimeString();\n    state.log.push(`[${time}] ${msg}`);\n    renderLog();\n  }\n\n  function changeState(newState) {\n    state.status = newState;\n    renderState();\n  }\n\n  // Process definition\n  const processSteps = [\n    {\n      id: \"start\",\n      name: \"Start\",\n      description: \"The process begins. No action required, ready to advance.\",\n      possibleNext: [\"validation\"],\n      requiresInput: false,\n      onEnter: (data, input) => {\n        data.startedAt = new Date().toISOString();\n        return \"Process started.\";\n      },\n    },\n    {\n      id: \"validation\",\n      name: \"Validation Step\",\n      description:\n        \"Validate process inputs. You can enter custom input to decide next step.\",\n      possibleNext: [\"approved\", \"rejected\"],\n      requiresInput: true,\n      onEnter: (data, input) => {\n        if (!input) return \"Waiting for input to validate.\";\n        if (input.toLowerCase().includes(\"pass\")) {\n          return \"Validation passed.\";\n        } else if (input.toLowerCase().includes(\"fail\")) {\n          return \"Validation failed.\";\n        }\n        return \"Validation unknown, defaulting to rejected.\";\n      },\n    },\n    {\n      id: \"approved\",\n      name: \"Approved Branch\",\n      description: \"Process approved. Proceed to execution or review.\",\n      possibleNext: [\"execution\", \"review\"],\n      requiresInput: false,\n      onEnter: (data, input) => {\n        data.validationResult = \"approved\";\n        return \"Approved path entered.\";\n      },\n    },\n    {\n      id: \"rejected\",\n      name: \"Rejected Branch\",\n      description:\n        \"Process rejected. You may restart or modify data before restart.\",\n      possibleNext: [\"modifyData\", \"start\"],\n      requiresInput: false,\n      onEnter: (data, input) => {\n        data.validationResult = \"rejected\";\n        return \"Rejected path entered.\";\n      },\n    },\n    {\n      id: \"execution\",\n      name: \"Execution Step\",\n      description:\n        \"Process execution in progress. Use progress slider to reflect completion.\",\n      possibleNext: [\"completed\", \"failed\"],\n      requiresInput: false,\n      onEnter: (data, input) => {\n        data.executedAt = new Date().toISOString();\n        return \"Execution started.\";\n      },\n    },\n    {\n      id: \"review\",\n      name: \"Review Step\",\n      description:\n        \"Review process results. You may approve to complete or reject to modify.\",\n      possibleNext: [\"completed\", \"modifyData\"],\n      requiresInput: true,\n      onEnter: (data, input) => {\n        if (!input) return \"Waiting for review input.\";\n        if (input.toLowerCase().includes(\"approve\")) {\n          return \"Review approved.\";\n        } else if (input.toLowerCase().includes(\"reject\")) {\n          return \"Review rejected.\";\n        }\n        return \"Review undecided.\";\n      },\n    },\n    {\n      id: \"modifyData\",\n      name: \"Modify Data\",\n      description:\n        \"Modify process data directly. Use controls to change key/value pairs.\",\n      possibleNext: [\"validation\", \"start\"],\n      requiresInput: false,\n      onEnter: (data, input) => \"Modify data step.\";\n    },\n    {\n      id: \"completed\",\n      name: \"Completed\",\n      description:\n        \"Process completed successfully. You can reset to start again.\",\n      possibleNext: [],\n      requiresInput: false,\n      onEnter: (data, input) => {\n        data.completedAt = new Date().toISOString();\n        return \"Process successfully completed.\";\n      },\n    },\n    {\n      id: \"failed\",\n      name: \"Failed\",\n      description:\n        \"Process failed during execution. You may reset or modify data.\",\n      possibleNext: [\"modifyData\", \"start\"],\n      requiresInput: false,\n      onEnter: (data, input) => {\n        data.failedAt = new Date().toISOString();\n        return \"Process failed.\";\n      },\n    },\n  ];\n\n  // Indexed for quick lookup\n  const processStepById = {};\n  processSteps.forEach((step) => {\n    processStepById[step.id] = step;\n  });\n\n  // State management\n  const state = {\n    currentStepId: null,\n    status: \"idle\", // or running, paused, completed\n    data: {},\n    log: [],\n    userInput: \"\",\n    progress: 0,\n    paused: false,\n  };\n\n  // DOM elements\n  const stateDisplay = document.getElementById(\"stateDisplay\");\n  const startProcessBtn = document.getElementById(\"startProcessBtn\");\n  const pauseProcessBtn = document.getElementById(\"pauseProcessBtn\");\n  const resumeProcessBtn = document.getElementById(\"resumeProcessBtn\");\n  const resetProcessBtn = document.getElementById(\"resetProcessBtn\");\n  const progressSlider = document.getElementById(\"progressSlider\");\n  const progressValue = document.getElementById(\"progressValue\");\n  const stepSelector = document.getElementById(\"stepSelector\");\n  const jumpStepBtn = document.getElementById(\"jumpStepBtn\");\n  const customInput = document.getElementById(\"customInput\");\n  const submitInputBtn = document.getElementById(\"submitInputBtn\");\n  const advanceStepBtn = document.getElementById(\"advanceStepBtn\");\n  const branchStepBtn = document.getElementById(\"branchStepBtn\");\n  const modifyDataBtn = document.getElementById(\"modifyDataBtn\");\n  const dataKeyInput = document.getElementById(\"dataKeyInput\");\n  const dataValueInput = document.getElementById(\"dataValueInput\");\n  const setDataBtn = document.getElementById(\"setDataBtn\");\n  const deleteDataBtn = document.getElementById(\"deleteDataBtn\");\n  const filterDataInput = document.getElementById(\"filterDataInput\");\n  const clearFilterBtn = document.getElementById(\"clearFilterBtn\");\n  const dataView = document.getElementById(\"dataView\");\n  const logArea = document.getElementById(\"log\");\n  const clearLogBtn = document.getElementById(\"clearLogBtn\");\n\n  // Render functions\n  function renderState() {\n    if (!state.currentStepId) {\n      stateDisplay.textContent = \"Process not started. Press 'Start Process' to begin.\";\n      disableControls(true);\n      return;\n    }\n\n    const step = processStepById[state.currentStepId];\n    const statusLine = `Status: ${state.status.toUpperCase()}${state.paused ? \" (PAUSED)\" : \"\"}`;\n    const stepLine = `Current Step: ${step.name} [${step.id}]`;\n    const descLine = `Description:\\n${step.description}`;\n    const dataKeysCount = Object.keys(state.data).length;\n\n    const possibleNextSteps = step.possibleNext\n      .map((id) => {\n        const s = processStepById[id];\n        return s ? `${s.name} [${s.id}]` : id;\n      })\n      .join(\", \") || \"None\";\n\n    stateDisplay.textContent =\n      statusLine +\n      \"\\n\" +\n      stepLine +\n      \"\\n\" +\n      descLine +\n      \"\\nPossible Next Steps: \" +\n      possibleNextSteps +\n      `\\nData keys: ${dataKeysCount}` +\n      `\\nProgress: ${state.progress}%` +\n      `\\nUser Input: \"${state.userInput}\"`;\n  }\n\n  function renderLog() {\n    logArea.value = state.log.join(\"\\n\");\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  function renderDataView(filterText = \"\") {\n    const entries = Object.entries(state.data);\n    const filtered = entries.filter(([k]) => k.includes(filterText));\n    if (filtered.length === 0) {\n      dataView.value = \"(No data keys match filter)\";\n    } else {\n      const lines = filtered.map(([k, v]) => `${k}: ${v}`);\n      dataView.value = lines.join(\"\\n\");\n    }\n  }\n\n  // Enable/disable controls depending on state\n  function disableControls(disableAll) {\n    startProcessBtn.disabled = !disableAll ? false : false;\n    pauseProcessBtn.disabled = disableAll || state.status !== \"running\" || state.paused;\n    resumeProcessBtn.disabled = disableAll || !state.paused;\n    resetProcessBtn.disabled = disableAll || state.status === \"idle\";\n\n    progressSlider.disabled =\n      disableAll || state.status !== \"running\" || state.currentStepId !== \"execution\";\n\n    stepSelector.disabled = disableAll || state.status === \"idle\";\n    jumpStepBtn.disabled = stepSelector.disabled;\n\n    customInput.disabled = disableAll || !currentStepRequiresInput();\n    submitInputBtn.disabled = customInput.disabled;\n\n    advanceStepBtn.disabled = disableAll || state.status !== \"running\" || state.paused || currentStepRequiresInput();\n    branchStepBtn.disabled = disableAll || state.status !== \"running\" || state.paused || !hasBranchingOptions();\n    modifyDataBtn.disabled = disableAll || state.status !== \"running\" || state.paused;\n\n    dataKeyInput.disabled = disableAll;\n    dataValueInput.disabled = disableAll;\n    setDataBtn.disabled = disableAll;\n    deleteDataBtn.disabled = disableAll;\n    filterDataInput.disabled = disableAll;\n    clearFilterBtn.disabled = disableAll;\n\n  }\n\n  function populateStepSelector() {\n    stepSelector.innerHTML = \"\";\n    processSteps.forEach((step) => {\n      const option = document.createElement(\"option\");\n      option.value = step.id;\n      option.textContent = `${step.name} [${step.id}]`;\n      stepSelector.appendChild(option);\n    });\n  }\n\n  // Step helpers\n  function currentStepRequiresInput() {\n    if (!state.currentStepId) return false;\n    const step = processStepById[state.currentStepId];\n    return step.requiresInput;\n  }\n\n  function hasBranchingOptions() {\n    if (!state.currentStepId) return false;\n    const step = processStepById[state.currentStepId];\n    // Branching if multiple next steps available\n    return step.possibleNext.length > 1;\n  }\n\n  // Process control functions\n  function startProcess() {\n    if (state.status !== \"idle\") return;\n    state.currentStepId = \"start\";\n    state.data = {};\n    state.userInput = \"\";\n    state.progress = 0;\n    state.status = \"running\";\n    state.paused = false;\n    log(\"Process started.\");\n    enterStep(state.currentStepId);\n    disableControls(false);\n  }\n\n  function pauseProcess() {\n    if (state.status !== \"running\" || state.paused) return;\n    state.paused = true;\n    log(\"Process paused.\");\n    disableControls(false);\n  }\n  function resumeProcess() {\n    if (!state.paused) return;\n    state.paused = false;\n    log(\"Process resumed.\");\n    disableControls(false);\n  }\n  function resetProcess() {\n    log(\"Process reset.\");\n    state.status = \"idle\";\n    state.currentStepId = null;\n    state.userInput = \"\";\n    state.progress = 0;\n    state.paused = false;\n    disableControls(true);\n    renderState();\n    renderDataView(filterDataInput.value);\n  }\n\n  // Enter a step, call onEnter handler\n  function enterStep(stepId, input = null) {\n    state.currentStepId = stepId;\n    state.userInput = input || \"\";\n    const step = processStepById[stepId];\n    if (!step) return;\n    const outcome = step.onEnter(state.data, state.userInput);\n    log(`Entered step: ${step.name}. ${outcome || \"\"}`);\n\n    // Reset progress for execution step only\n    if (stepId === \"execution\") {\n      if (!state.data.progress) state.data.progress = 0;\n      state.progress = 0;\n      progressSlider.value = 0;\n      progressValue.textContent = \"0%\";\n    }\n    renderState();\n    renderDataView(filterDataInput.value);\n  }\n\n  // Advance to next step - if only one next step, go there;\n  // if multiple next steps, must branch instead.\n  function advanceStep() {\n    if (state.status !== \"running\" || state.paused) return;\n    const step = processStepById[state.currentStepId];\n    if (!step) return;\n    if (step.requiresInput && !state.userInput) {\n      log(\"Cannot advance: input required.\");\n      alert(\"This step requires you to submit input first.\");\n      return;\n    }\n    if (step.possibleNext.length === 1) {\n      enterStep(step.possibleNext[0]);\n    } else if (step.possibleNext.length === 0) {\n      log(\"No next steps. Process completed or stuck.\");\n      alert(\"No next steps available to advance.\");\n    } else {\n      log(\"Multiple next steps available, use 'Take Branch' button.\");\n      alert(\n        \"Multiple next steps available. Use the 'Take Branch' button to choose.\"\n      );\n    }\n  }\n\n  // Take branch: prompt user to select one of the next steps\n  function takeBranch() {\n    if (state.status !== \"running\" || state.paused) return;\n    const step = processStepById[state.currentStepId];\n    if (!step) return;\n    if (step.possibleNext.length < 2) {\n      alert(\"No branching options available in this step.\");\n      return;\n    }\n    // Prompt user with choices\n    const choices = step.possibleNext.map((id) => {\n      const s = processStepById[id];\n      return s ? `${s.name} [${s.id}]` : id;\n    });\n    let msg = `Select next step (branch):\\n`;\n    choices.forEach((c, i) => {\n      msg += `  ${i + 1}: ${c}\\n`;\n    });\n    let choiceIdx = prompt(msg + \"Enter number of choice:\");\n    if (choiceIdx === null) {\n      log(\"Branching cancelled by user.\");\n      return;\n    }\n    choiceIdx = parseInt(choiceIdx, 10);\n    if (\n      isNaN(choiceIdx) ||\n      choiceIdx < 1 ||\n      choiceIdx > step.possibleNext.length\n    ) {\n      alert(\"Invalid choice.\");\n      return;\n    }\n    const chosenStepId = step.possibleNext[choiceIdx - 1];\n    enterStep(chosenStepId);\n  }\n\n  // Submit input for current step\n  function submitInput() {\n    let input = customInput.value.trim();\n    if (!input) {\n      alert(\"Input cannot be empty.\");\n      return;\n    }\n    // For steps requiring input, set userInput and call onEnter with input\n    state.userInput = input;\n    const step = processStepById[state.currentStepId];\n    if (step && step.requiresInput) {\n      const outcome = step.onEnter(state.data, input);\n      log(`Input submitted at step ${step.name}: \"${input}\" -> ${outcome}`);\n      // For validation or review step, possibly auto branch depending on input\n      if (state.currentStepId === \"validation\") {\n        if (input.toLowerCase().includes(\"pass\")) {\n          enterStep(\"approved\");\n        } else if (input.toLowerCase().includes(\"fail\")) {\n          enterStep(\"rejected\");\n        } else {\n          enterStep(\"rejected\");\n        }\n      } else if (state.currentStepId === \"review\") {\n        if (input.toLowerCase().includes(\"approve\")) {\n          enterStep(\"completed\");\n        } else if (input.toLowerCase().includes(\"reject\")) {\n          enterStep(\"modifyData\");\n        } else {\n          log(\"Review undecided; remain in review step.\");\n        }\n      }\n    } else {\n      log(\"Current step does not accept input.\");\n    }\n    customInput.value = \"\";\n    renderState();\n    renderDataView(filterDataInput.value);\n  }\n\n  // Jump to arbitrary step\n  function jumpToStep() {\n    let stepId = stepSelector.value;\n    if (!stepId) return;\n    if (!processStepById[stepId]) {\n      alert(\"Selected step does not exist.\");\n      return;\n    }\n    enterStep(stepId);\n  }\n\n  // Progress slider control for execution step\n  function setProgress(value) {\n    if (state.currentStepId !== \"execution\") return;\n    let val = Number(value);\n    if (isNaN(val)) return;\n    val = Math.min(Math.max(val, 0), 100);\n    state.progress = val;\n    progressValue.textContent = val + \"%\";\n    // Update data too\n    state.data.progress = val;\n    log(`Execution progress set to ${val}%`);\n    renderState();\n    renderDataView(filterDataInput.value);\n  }\n\n  // Modify process data (update or delete)\n  function setDataKeyValue() {\n    const key = dataKeyInput.value.trim();\n    const val = dataValueInput.value;\n    if (!key) {\n      alert(\"Data key cannot be empty.\");\n      return;\n    }\n    state.data[key] = val;\n    log(`Data key set: ${key} = ${val}`);\n    renderDataView(filterDataInput.value);\n  }\n  function deleteDataKey() {\n    const key = dataKeyInput.value.trim();\n    if (!key) {\n      alert(\"Data key cannot be empty.\");\n      return;\n    }\n    if (key in state.data) {\n      delete state.data[key];\n      log(`Data key deleted: ${key}`);\n      renderDataView(filterDataInput.value);\n    } else {\n      alert(\"Data key not found.\");\n    }\n  }\n\n  // Filter keys in data view\n  function filterData() {\n    renderDataView(filterDataInput.value.trim());\n  }\n  function clearFilter() {\n    filterDataInput.value = \"\";\n    renderDataView(\"\");\n  }\n\n  // Modify data action button: jump to Modify Data step\n  function modifyDataStep() {\n    if (state.status !== \"running\" || state.paused) return;\n    enterStep(\"modifyData\");\n  }\n\n  // Event bindings\n  startProcessBtn.addEventListener(\"click\", () => {\n    startProcess();\n  });\n  pauseProcessBtn.addEventListener(\"click\", () => pauseProcess());\n  resumeProcessBtn.addEventListener(\"click\", () => resumeProcess());\n  resetProcessBtn.addEventListener(\"click\", () => resetProcess());\n\n  progressSlider.addEventListener(\"input\", (e) => setProgress(e.target.value));\n\n  jumpStepBtn.addEventListener(\"click\", () => jumpToStep());\n\n  submitInputBtn.addEventListener(\"click\", () => submitInput());\n\n  advanceStepBtn.addEventListener(\"click\", () => advanceStep());\n\n  branchStepBtn.addEventListener(\"click\", () => takeBranch());\n\n  setDataBtn.addEventListener(\"click\", () => setDataKeyValue());\n\n  deleteDataBtn.addEventListener(\"click\", () => deleteDataKey());\n\n  filterDataInput.addEventListener(\"input\", () => filterData());\n\n  clearFilterBtn.addEventListener(\"click\", () => clearFilter());\n\n  modifyDataBtn.addEventListener(\"click\", () => modifyDataStep());\n\n  clearLogBtn.addEventListener(\"click\", () => {\n    state.log = [];\n    renderLog();\n  });\n\n  // Initialize interface\n  disableControls(true);\n  populateStepSelector();\n  renderState();\n  renderDataView();\n\n  // Accessibility helper: focus first button\n  startProcessBtn.focus();\n})();\n</script>\n</body>\n</html>"
  },
