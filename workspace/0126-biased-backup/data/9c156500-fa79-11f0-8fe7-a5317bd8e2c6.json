  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n<meta charset=\"utf-8\">\n<title>Semaphore Simulator</title>\n<style>\n  /* Minimal, plain black on white. Basic layout only. */\n  html,body { height:100%; margin:6px; font-family:monospace; color:#000; background:#fff; }\n  #root { display:flex; gap:8px; height:calc(100% - 12px); }\n  #controls { width:420px; overflow:auto; padding:6px; border:1px solid #000; }\n  #main { flex:1; display:flex; flex-direction:column; gap:8px; overflow:auto; padding:6px; border:1px solid #000; }\n  section { margin-bottom:8px; }\n  label { display:inline-block; width:120px; }\n  input[type=\"text\"], input[type=\"number\"], select, textarea { width:260px; }\n  textarea { height:80px; }\n  button { margin:2px 0; }\n  .list { max-height:220px; overflow:auto; border:1px solid #000; padding:4px; }\n  .row { display:flex; gap:8px; align-items:center; margin:2px 0; }\n  .small { width:80px; }\n  pre { white-space:pre-wrap; word-wrap:break-word; max-height:300px; overflow:auto; border:1px solid #000; padding:6px; }\n  .muted { font-size:12px; }\n</style>\n</head>\n<body>\n<h1>Semaphore Simulator</h1>\n<div id=\"root\">\n  <div id=\"controls\">\n    <section>\n      <strong>Semaphore Controls</strong>\n      <div class=\"row\">\n        <label for=\"semName\">Name</label>\n        <input id=\"semName\" type=\"text\" value=\"S1\">\n      </div>\n      <div class=\"row\">\n        <label for=\"semInit\">Initial count</label>\n        <input id=\"semInit\" type=\"number\" min=\"0\" value=\"2\">\n      </div>\n      <div class=\"row\">\n        <button id=\"createSem\">Create semaphore</button>\n        <button id=\"resetAll\">Reset all</button>\n      </div>\n\n      <hr>\n\n      <div class=\"row\">\n        <label for=\"selSem\">Selected</label>\n        <select id=\"selSem\"></select>\n      </div>\n      <div class=\"row\">\n        <label for=\"semAdjust\">Adjust count</label>\n        <input id=\"semAdjust\" type=\"number\" value=\"1\" class=\"small\">\n        <button id=\"incSem\">Increase</button>\n        <button id=\"decSem\">Decrease</button>\n        <button id=\"forceReleaseOne\">Force release one</button>\n      </div>\n\n      <div class=\"row\">\n        <label for=\"fairPolicy\">Fairness</label>\n        <select id=\"fairPolicy\">\n          <option value=\"FIFO\">FIFO</option>\n          <option value=\"PRIORITY\">Priority</option>\n          <option value=\"LIFO\">LIFO</option>\n        </select>\n      </div>\n\n      <div class=\"row muted\">Tip: Use fairness to change how waiting requests are selected.</div>\n    </section>\n\n    <section>\n      <strong>Process / Acquire Controls</strong>\n      <div class=\"row\">\n        <label for=\"procName\">Process name</label>\n        <input id=\"procName\" type=\"text\" value=\"P1\">\n      </div>\n      <div class=\"row\">\n        <label for=\"acqUnits\">Units to acquire</label>\n        <input id=\"acqUnits\" type=\"number\" min=\"1\" value=\"1\" class=\"small\">\n      </div>\n      <div class=\"row\">\n        <label for=\"acqPriority\">Priority</label>\n        <input id=\"acqPriority\" type=\"number\" min=\"0\" value=\"1\" class=\"small\">\n      </div>\n      <div class=\"row\">\n        <label for=\"acqBlocking\">Blocking</label>\n        <input id=\"acqBlocking\" type=\"checkbox\" checked>\n        <label style=\"width:80px;\">Timeout ms</label>\n        <input id=\"acqTimeout\" type=\"number\" min=\"0\" value=\"0\" class=\"small\">\n      </div>\n      <div class=\"row\">\n        <button id=\"tryAcquire\">Try acquire (non-block)</button>\n        <button id=\"acquire\">Acquire (may block)</button>\n        <button id=\"acquireTO\">Acquire with timeout</button>\n      </div>\n\n      <hr>\n\n      <div class=\"row\">\n        <label for=\"relProc\">Release by</label>\n        <select id=\"relProc\"></select>\n      </div>\n      <div class=\"row\">\n        <label for=\"relUnits\">Units to release</label>\n        <input id=\"relUnits\" type=\"number\" min=\"1\" value=\"1\" class=\"small\">\n        <button id=\"release\">Release</button>\n        <button id=\"releaseAll\">Release all held</button>\n      </div>\n    </section>\n\n    <section>\n      <strong>Process Scripts & Automation</strong>\n      <div class=\"row\">\n        <label>Script (one action per line)</label>\n      </div>\n      <div>\n        <textarea id=\"scriptArea\"># Examples:\n# acquire <sem> <units> [block] [priority=N] [timeout=ms]\n# release <sem> <units>\n# sleep ms\n# compute ms\n# waitEvent name\n# signalEvent name\n# end\nacquire S1 1 block priority=1\nsleep 500\nrelease S1 1\nend\n</textarea>\n      </div>\n      <div class=\"row\">\n        <label for=\"autoRepeat\">Auto-repeat</label>\n        <input id=\"autoRepeat\" type=\"checkbox\">\n        <label for=\"spawnCount\" style=\"width:120px;\">Spawn copies</label>\n        <input id=\"spawnCount\" type=\"number\" min=\"1\" value=\"1\" class=\"small\">\n      </div>\n      <div class=\"row\">\n        <button id=\"spawnProcess\">Spawn process from script</button>\n        <button id=\"spawnRandom\">Spawn random script</button>\n      </div>\n\n      <div class=\"row muted\">Use scripts to create automated, multi-action processes. You can create many to stress-test.</div>\n    </section>\n\n    <section>\n      <strong>Scheduler & Navigation</strong>\n      <div class=\"row\">\n        <label for=\"autoRun\">Auto-run</label>\n        <input id=\"autoRun\" type=\"checkbox\">\n        <label for=\"tickSpeed\">Speed ms/tick</label>\n        <input id=\"tickSpeed\" type=\"number\" min=\"10\" value=\"200\" class=\"small\">\n      </div>\n      <div class=\"row\">\n        <button id=\"step\">Step</button>\n        <button id=\"stepBack\">Step back</button>\n        <button id=\"pauseAll\">Pause processes</button>\n        <button id=\"resumeAll\">Resume processes</button>\n      </div>\n      <div class=\"row\">\n        <label for=\"saveState\">Save snapshot</label>\n        <button id=\"saveState\">Save</button>\n        <button id=\"restoreState\">Restore last</button>\n      </div>\n      <div class=\"row muted\">Snapshots allow rewinding the simulation to explore alternate paths.</div>\n    </section>\n\n    <section>\n      <strong>Presets & Stress</strong>\n      <div class=\"row\">\n        <button id=\"presetSimple\">Preset: simple contended</button>\n        <button id=\"presetPriority\">Preset: priority test</button>\n      </div>\n      <div class=\"row\">\n        <button id=\"stress10\">Stress: spawn 10</button>\n        <button id=\"stress50\">Stress: spawn 50</button>\n      </div>\n      <div class=\"row\">\n        <button id=\"clearAll\">Clear everything</button>\n      </div>\n    </section>\n\n    <section>\n      <strong>Debug / Actions on Requests</strong>\n      <div class=\"row\">\n        <label for=\"inspectReq\">Inspect by sem</label>\n        <select id=\"inspectReq\"></select>\n      </div>\n      <div class=\"row\">\n        <button id=\"wakeFirst\">Wake first waiting</button>\n        <button id=\"bumpPriority\">Bump priority</button>\n        <button id=\"removeRequest\">Remove request</button>\n      </div>\n    </section>\n  </div>\n\n  <div id=\"main\">\n    <section>\n      <strong>State: Semaphores</strong>\n      <div id=\"sems\" class=\"list\"></div>\n    </section>\n\n    <section>\n      <strong>State: Processes</strong>\n      <div id=\"procs\" class=\"list\"></div>\n    </section>\n\n    <section>\n      <strong>Metrics</strong>\n      <div id=\"metrics\" class=\"list\"></div>\n    </section>\n\n    <section>\n      <strong>Event Log</strong>\n      <div style=\"display:flex;gap:6px;align-items:center;\">\n        <input id=\"logFilter\" type=\"text\" placeholder=\"filter\">\n        <button id=\"clearLog\">Clear log</button>\n      </div>\n      <pre id=\"log\"></pre>\n    </section>\n  </div>\n</div>\n\n<script>\n/*\n  Semaphore Simulator\n  - Counting semaphores\n  - Processes with scripts\n  - Blocking requests with optional timeout\n  - Fairness policies: FIFO, PRIORITY, LIFO\n  - Snapshot history for step-back\n  - Many interactive controls for deep exploration\n*/\n\n// Utility\nfunction uid(prefix='id'){ return prefix + Math.random().toString(36).slice(2,9); }\nfunction now(){ return Date.now(); }\nfunction clamp(v,min,max){ return Math.max(min,Math.min(max,v)); }\nfunction deepClone(obj){ return JSON.parse(JSON.stringify(obj)); }\n\n// Data model\nlet state = {\n  semaphores: {}, // id -> {id, name, count, waiting: [request], policy}\n  processes: {},  // id -> {id, name, state, script, ip, held:{semId:units}, priority, waitForEvent}\n  events: {},     // named events for wait/signal\n  metrics: {\n    totalAcquires:0, totalReleases:0, totalTimeouts:0, totalFailedTries:0, averageWait:0, waits:0, maxQueue:0\n  },\n  time: now()\n};\n\nlet history = []; // snapshots for step back\nlet savedSnapshots = [];\nlet config = {\n  tickSpeed: 200,\n  autoRun: false,\n  policy: 'FIFO'\n};\n\n// DOM refs\nconst selSem = document.getElementById('selSem');\nconst inspectReq = document.getElementById('inspectReq');\nconst relProc = document.getElementById('relProc');\nconst semsDiv = document.getElementById('sems');\nconst procsDiv = document.getElementById('procs');\nconst logDiv = document.getElementById('log');\nconst metricsDiv = document.getElementById('metrics');\n\n// Logging\nfunction logLine(text){\n  const t = new Date().toISOString().slice(11,23) + ' ' + text;\n  logDiv.textContent = t + '\\n' + logDiv.textContent;\n}\n\n// Create semaphore\nfunction createSemaphore(name, count){\n  const id = uid('sem_');\n  state.semaphores[id] = { id, name: name || id, count: Number(count)||0, waiting: [], policy: config.policy };\n  updateSelectors();\n  render();\n  logLine('Created semaphore \"' + name + '\" with count=' + count);\n  return id;\n}\n\n// Create process\nfunction createProcess(name, scriptLines, options={}){\n  const id = uid('proc_');\n  const script = scriptLines || [];\n  state.processes[id] = {\n    id, name: name || id, state: 'ready', script, ip:0, held:{}, priority: options.priority||1,\n    waitStart: null, waitRequestId:null, sleepingUntil:0, waitForEvent:null, autoRepeat: options.autoRepeat||false\n  };\n  updateSelectors();\n  render();\n  logLine('Spawned process \"' + name + '\"');\n  return id;\n}\n\n// Add request to semaphore waiting queue\nfunction enqueueRequest(sem, req){\n  req.timestamp = now();\n  sem.waiting.push(req);\n  // track queue max\n  state.metrics.maxQueue = Math.max(state.metrics.maxQueue, sem.waiting.length);\n}\n\n// Select next request based on policy\nfunction selectRequest(sem){\n  if(!sem.waiting.length) return null;\n  const policy = document.getElementById('fairPolicy').value || sem.policy || 'FIFO';\n  if(policy === 'FIFO') return sem.waiting[0];\n  if(policy === 'LIFO') return sem.waiting[sem.waiting.length-1];\n  if(policy === 'PRIORITY'){\n    // highest priority value wins (bigger number = higher priority)\n    let best = sem.waiting[0];\n    for(const r of sem.waiting) if((r.priority||0) > (best.priority||0)) best = r;\n    return best;\n  }\n  return sem.waiting[0];\n}\n\n// Remove request by id\nfunction removeRequestById(sem, reqId){\n  const idx = sem.waiting.findIndex(r=>r.id===reqId);\n  if(idx>=0) sem.waiting.splice(idx,1);\n}\n\n// Try to grant requests whenever possible\nfunction processSemaphoresTick(){\n  for(const semId in state.semaphores){\n    const sem = state.semaphores[semId];\n    // Attempt to satisfy waiting requests as long as count allows\n    let changed = true;\n    while(changed){\n      changed = false;\n      if(!sem.waiting.length) break;\n      // pick next request according to policy\n      const candidate = selectRequest(sem);\n      if(!candidate) break;\n      const reqUnits = candidate.units || 1;\n      if(reqUnits <= sem.count){\n        // satisfy\n        sem.count -= reqUnits;\n        const proc = state.processes[candidate.processId];\n        if(proc){\n          proc.held[semId] = (proc.held[semId]||0) + reqUnits;\n          proc.state = 'ready';\n          proc.waitRequestId = null;\n          proc.waitStart = null;\n          // advance process ip only when it was waiting for acquire step (we mark in script handling)\n          if(candidate.resumeOnGrant) candidate.resumeOnGrant();\n        }\n        // remove from queue\n        removeRequestById(sem, candidate.id);\n        state.metrics.totalAcquires++;\n        if(candidate.timestamp){\n          const w = now()-candidate.timestamp;\n          // update avg wait\n          state.metrics.averageWait = ((state.metrics.averageWait*state.metrics.waits)+w)/(state.metrics.waits+1);\n          state.metrics.waits++;\n        }\n        logLine('Granted ' + reqUnits + ' from sem \"' + sem.name + '\" to process ' + (proc?proc.name: candidate.processId));\n        changed = true;\n      } else {\n        // cannot satisfy next request\n        break;\n      }\n    }\n    // check timeouts\n    for(let i=sem.waiting.length-1;i>=0;i--){\n      const r = sem.waiting[i];\n      if(r.timeout && r.timestamp && (now() - r.timestamp >= r.timeout)){\n        // timeout\n        const proc = state.processes[r.processId];\n        if(proc){\n          proc.state = 'ready';\n          proc.waitRequestId = null;\n          proc.waitStart = null;\n          if(r.onTimeout) r.onTimeout();\n        }\n        sem.waiting.splice(i,1);\n        state.metrics.totalTimeouts++;\n        logLine('Request timed out: proc ' + (proc?proc.name:r.processId) + ' on sem ' + sem.name);\n      }\n    }\n  }\n}\n\n// Parse script lines into actions\nfunction parseScript(text){\n  const lines = text.split('\\n').map(s=>s.trim()).filter(s=>s.length && !s.startsWith('#'));\n  const actions = [];\n  for(const line of lines){\n    const parts = line.split(/\\s+/);\n    const cmd = parts[0].toLowerCase();\n    if(cmd==='acquire'){\n      // acquire <semName> <units> [block] [priority=N] [timeout=ms]\n      const semName = parts[1];\n      const units = Number(parts[2]||1);\n      const blocking = parts.includes('block');\n      let priority = 1, timeout = 0;\n      for(const p of parts.slice(3)){\n        if(p.startsWith('priority=')) priority = Number(p.split('=')[1]||1);\n        if(p.startsWith('timeout=')) timeout = Number(p.split('=')[1]||0);\n      }\n      actions.push({type:'acquire', semName, units, blocking, priority, timeout});\n    } else if(cmd==='release'){\n      const semName = parts[1];\n      const units = Number(parts[2]||1);\n      actions.push({type:'release', semName, units});\n    } else if(cmd==='sleep' || cmd==='wait'){\n      const t = Number(parts[1]||0);\n      actions.push({type:'sleep', ms:t});\n    } else if(cmd==='compute'){\n      const t = Number(parts[1]||0);\n      actions.push({type:'compute', ms:t});\n    } else if(cmd==='waitevent'){\n      actions.push({type:'waitEvent', name:parts[1]});\n    } else if(cmd==='signalevent' || cmd==='signal'){\n      actions.push({type:'signalEvent', name:parts[1]});\n    } else if(cmd==='end'){\n      actions.push({type:'end'});\n    } else {\n      // unknown treat as comment/skip\n    }\n  }\n  return actions;\n}\n\n// Find semaphore by name\nfunction findSemByName(name){\n  for(const id in state.semaphores) if(state.semaphores[id].name===name) return state.semaphores[id];\n  return null;\n}\n\n// Process one process step (per tick)\nfunction processOneProc(proc){\n  if(!proc || proc.state==='terminated') return;\n  // sleeping?\n  if(proc.sleepingUntil && now() < proc.sleepingUntil) return;\n  // waiting for event?\n  if(proc.waitForEvent){\n    // remains blocked until event sets it\n    return;\n  }\n  if(proc.state==='waiting') return;\n  // execute current instruction if any\n  const act = proc.script[proc.ip];\n  if(!act){\n    // no more actions - terminate or repeat\n    if(proc.autoRepeat){\n      proc.ip = 0;\n      return;\n    }\n    proc.state = 'terminated';\n    logLine('Process ' + proc.name + ' terminated');\n    return;\n  }\n  switch(act.type){\n    case 'acquire': {\n      const sem = findSemByName(act.semName);\n      if(!sem){\n        logLine('Acquire: semaphore \"' + act.semName + '\" not found for ' + proc.name);\n        proc.ip++;\n        break;\n      }\n      const units = act.units || 1;\n      if(units <= sem.count){\n        // immediate\n        sem.count -= units;\n        proc.held[sem.id] = (proc.held[sem.id]||0) + units;\n        proc.ip++;\n        state.metrics.totalAcquires++;\n        logLine(proc.name + ' acquired ' + units + ' from ' + sem.name);\n      } else if(!act.blocking){\n        // non-blocking try\n        proc.ip++;\n        state.metrics.totalFailedTries++;\n        logLine(proc.name + ' failed tryAcquire ' + units + ' on ' + sem.name);\n      } else {\n        // blocking: enqueue request and mark process waiting\n        const reqId = uid('req_');\n        proc.state = 'waiting';\n        proc.waitStart = now();\n        proc.waitRequestId = reqId;\n        proc.priority = act.priority || proc.priority || 1;\n        const request = {\n          id: reqId, processId: proc.id, units, priority: proc.priority,\n          timeout: act.timeout||0,\n          resumeOnGrant: function(){ proc.ip++; } ,\n          onTimeout: function(){ /* do nothing special; script already expects to continue */ }\n        };\n        enqueueRequest(sem, request);\n        logLine(proc.name + ' waiting for ' + units + ' on ' + sem.name + (act.timeout?(' timeout=' + act.timeout):''));\n      }\n      break;\n    }\n    case 'release': {\n      const sem = findSemByName(act.semName);\n      if(!sem){\n        logLine('Release: semaphore \"' + act.semName + '\" not found for ' + proc.name);\n        proc.ip++;\n        break;\n      }\n      const units = act.units || 1;\n      const held = proc.held[sem.id] || 0;\n      const toRel = Math.min(units, held);\n      if(toRel>0){\n        proc.held[sem.id] = held - toRel;\n        if(proc.held[sem.id]===0) delete proc.held[sem.id];\n        sem.count += toRel;\n        state.metrics.totalReleases++;\n        logLine(proc.name + ' released ' + toRel + ' to ' + sem.name);\n      } else {\n        logLine(proc.name + ' tried to release but holds none on ' + sem.name);\n      }\n      proc.ip++;\n      break;\n    }\n    case 'sleep': {\n      proc.sleepingUntil = now() + (act.ms||0);\n      proc.ip++;\n      break;\n    }\n    case 'compute': {\n      // simulate compute by sleeping for milliseconds but we keep state as running\n      proc.sleepingUntil = now() + (act.ms||0);\n      proc.ip++;\n      break;\n    }\n    case 'waitEvent': {\n      proc.waitForEvent = act.name;\n      proc.state = 'waiting';\n      logLine(proc.name + ' waiting for event \"' + act.name + '\"');\n      proc.ip++;\n      break;\n    }\n    case 'signalEvent': {\n      const e = act.name;\n      logLine(proc.name + ' signaled event \"' + e + '\"');\n      signalEvent(e, proc.id);\n      proc.ip++;\n      break;\n    }\n    case 'end': {\n      proc.state = 'terminated';\n      logLine(proc.name + ' reached end');\n      break;\n    }\n    default:\n      proc.ip++;\n  }\n}\n\n// Event signalling\nfunction signalEvent(name, originProcId){\n  // wake processes waiting on this event\n  for(const pid in state.processes){\n    const p = state.processes[pid];\n    if(p.waitForEvent === name){\n      p.waitForEvent = null;\n      p.state = 'ready';\n      logLine('Event \"' + name + '\" woke ' + p.name + (originProcId?(' (signaled by proc '+state.processes[originProcId].name+')'):''));\n    }\n  }\n}\n\n// Tick: one simulation step\nfunction tick(){\n  // snapshot for step back\n  saveHistorySnapshot();\n  state.time = now();\n\n  // process waiting timeouts and grants first\n  processSemaphoresTick();\n\n  // update processes: run each ready process once per tick\n  for(const pid in state.processes){\n    const p = state.processes[pid];\n    if(p.state === 'ready' || p.state === 'running'){\n      p.state = 'running';\n      processOneProc(p);\n      if(p.state === 'running') p.state = 'ready';\n    } else if(p.state === 'terminated') {\n      // nothing\n    } else if(p.state === 'waiting') {\n      // check if process has a waitRequestId and if the request was removed due to external action\n      // handled elsewhere\n    }\n  }\n\n  // After processes may have released semaphores; try granting again\n  processSemaphoresTick();\n\n  // render\n  render();\n}\n\n// Snapshot history management\nfunction saveHistorySnapshot(){\n  try {\n    const s = JSON.stringify(state);\n    history.push(s);\n    if(history.length > 200) history.shift();\n  } catch(e){}\n}\nfunction restoreLastSnapshot(){\n  if(history.length < 1) return;\n  const s = history.pop();\n  state = JSON.parse(s);\n  updateSelectors();\n  render();\n  logLine('Restored previous snapshot');\n}\n\n// Update dropdown selectors\nfunction updateSelectors(){\n  // sem selector\n  const oldSem = selSem.value;\n  selSem.innerHTML = '';\n  inspectReq.innerHTML = '';\n  for(const id in state.semaphores){\n    const opt = document.createElement('option');\n    opt.value = id; opt.textContent = state.semaphores[id].name + ' (' + state.semaphores[id].count + ')';\n    selSem.appendChild(opt);\n    const opt2 = opt.cloneNode(true);\n    inspectReq.appendChild(opt2);\n  }\n  if(oldSem) selSem.value = oldSem;\n  // processes selector for release\n  const oldProc = relProc.value;\n  relProc.innerHTML = '';\n  for(const id in state.processes){\n    const p = state.processes[id];\n    const opt = document.createElement('option');\n    opt.value = id; opt.textContent = p.name + ' ['+p.state+']';\n    relProc.appendChild(opt);\n  }\n  if(oldProc) relProc.value = oldProc;\n}\n\n// Render state panels\nfunction render(){\n  // Semaphores\n  semsDiv.innerHTML = '';\n  for(const id in state.semaphores){\n    const s = state.semaphores[id];\n    const div = document.createElement('div');\n    div.style.marginBottom = '8px';\n    let html = s.name + ' (count=' + s.count + ') ';\n    html += ' waiting=' + s.waiting.length;\n    html += ' policy=' + (document.getElementById('fairPolicy').value||s.policy);\n    html += '\\n';\n    if(s.waiting.length){\n      html += ' Queue (most recent first):\\n';\n      // show in reverse for readability (but policy explained separately)\n      const arr = s.waiting.slice().reverse();\n      for(const r of arr){\n        const p = state.processes[r.processId];\n        html += '  - ' + (p? p.name: r.processId) + ' wants ' + r.units + ' pr=' + (r.priority||0) + (r.timeout?(' timeout='+(r.timeout - (now()-r.timestamp)) + 'ms'): '') + '\\n';\n      }\n    }\n    div.textContent = html;\n    semsDiv.appendChild(div);\n  }\n\n  // Processes\n  procsDiv.innerHTML = '';\n  for(const id in state.processes){\n    const p = state.processes[id];\n    const div = document.createElement('div');\n    div.style.marginBottom = '8px';\n    let html = p.name + ' [' + p.state + '] ip=' + p.ip + ' pr=' + (p.priority||0);\n    html += '\\nHeld: ';\n    const heldEntries = Object.keys(p.held||{}).map(k=> (state.semaphores[k]?state.semaphores[k].name:k) + ':' + p.held[k]);\n    html += (heldEntries.length?heldEntries.join(', '):'none') + '\\n';\n    html += 'Script remainder: ' + (p.script.slice(p.ip).map(a=>JSON.stringify(a)).join(' | '));\n    div.textContent = html;\n    procsDiv.appendChild(div);\n  }\n\n  // Metrics\n  metricsDiv.innerHTML = '';\n  const m = state.metrics;\n  const divm = document.createElement('div');\n  divm.textContent = 'Acquires=' + m.totalAcquires + ' Releases=' + m.totalReleases + ' Timeouts=' + m.totalTimeouts + ' FailedTries=' + m.totalFailedTries + '\\nAvg wait=' + Math.round((m.averageWait||0)) + 'ms waits=' + m.waits + ' maxQueue=' + m.maxQueue;\n  metricsDiv.appendChild(divm);\n}\n\n// Actions from UI\ndocument.getElementById('createSem').addEventListener('click', ()=>{\n  const name = document.getElementById('semName').value || ('S' + (Object.keys(state.semaphores).length+1));\n  const count = Number(document.getElementById('semInit').value) || 0;\n  createSemaphore(name, count);\n});\n\ndocument.getElementById('resetAll').addEventListener('click', ()=>{\n  if(!confirm('Reset everything?')) return;\n  for(const id in state.semaphores) delete state.semaphores[id];\n  for(const id in state.processes) delete state.processes[id];\n  state.metrics = {totalAcquires:0,totalReleases:0,totalTimeouts:0,totalFailedTries:0,averageWait:0,waits:0,maxQueue:0};\n  history = [];\n  updateSelectors(); render();\n  logLine('Reset simulation');\n});\n\ndocument.getElementById('incSem').addEventListener('click', ()=>{\n  const id = selSem.value;\n  if(!id) return;\n  const inc = Number(document.getElementById('semAdjust').value) || 1;\n  state.semaphores[id].count += inc;\n  render();\n  logLine('Increased ' + state.semaphores[id].name + ' by ' + inc);\n});\n\ndocument.getElementById('decSem').addEventListener('click', ()=>{\n  const id = selSem.value;\n  if(!id) return;\n  const dec = Number(document.getElementById('semAdjust').value) || 1;\n  state.semaphores[id].count = Math.max(0, state.semaphores[id].count - dec);\n  render();\n  logLine('Decreased ' + state.semaphores[id].name + ' by ' + dec);\n});\n\ndocument.getElementById('forceReleaseOne').addEventListener('click', ()=>{\n  const id = selSem.value;\n  if(!id) return;\n  state.semaphores[id].count += 1;\n  processSemaphoresTick();\n  render();\n  logLine('Forced release of one unit to ' + state.semaphores[id].name);\n});\n\ndocument.getElementById('tryAcquire').addEventListener('click', ()=>{\n  const pname = document.getElementById('procName').value || 'proc';\n  const units = Number(document.getElementById('acqUnits').value) || 1;\n  const sem = state.semaphores[selSem.value];\n  if(!sem){ alert('Select a semaphore'); return; }\n  // create a temporary process that tries once\n  const pid = createProcess(pname + '_try', []);\n  const proc = state.processes[pid];\n  // attempt\n  if(units <= sem.count){\n    sem.count -= units;\n    proc.held[sem.id] = (proc.held[sem.id]||0) + units;\n    proc.state = 'ready'; proc.ip = 0;\n    state.metrics.totalAcquires++;\n    logLine(proc.name + ' tryAcquire succeeded on ' + sem.name);\n  } else {\n    proc.state = 'ready'; // non-blocking failure\n    state.metrics.totalFailedTries++;\n    logLine(proc.name + ' tryAcquire failed on ' + sem.name);\n  }\n  updateSelectors(); render();\n});\n\ndocument.getElementById('acquire').addEventListener('click', ()=>{\n  const pname = document.getElementById('procName').value || 'proc';\n  const units = Number(document.getElementById('acqUnits').value) || 1;\n  const pr = Number(document.getElementById('acqPriority').value) || 1;\n  const sem = state.semaphores[selSem.value];\n  if(!sem){ alert('Select a semaphore'); return; }\n  // spawn a simple process that will attempt blocking acquire then release when user asks\n  const script = [{type:'acquire', semName:sem.name, units, blocking:true, priority:pr, timeout:0}, {type:'sleep', ms:0}, {type:'end'}];\n  const pid = createProcess(pname, script, {priority:pr});\n  const proc = state.processes[pid];\n  // immediate try to allocate if possible\n  processOneProc(proc);\n  render();\n});\n\ndocument.getElementById('acquireTO').addEventListener('click', ()=>{\n  const pname = document.getElementById('procName').value || 'proc';\n  const units = Number(document.getElementById('acqUnits').value) || 1;\n  const pr = Number(document.getElementById('acqPriority').value) || 1;\n  const timeout = Number(document.getElementById('acqTimeout').value) || 0;\n  const sem = state.semaphores[selSem.value];\n  if(!sem){ alert('Select a semaphore'); return; }\n  const script = [{type:'acquire', semName:sem.name, units, blocking:true, priority:pr, timeout}, {type:'end'}];\n  const pid = createProcess(pname, script, {priority:pr});\n  processOneProc(state.processes[pid]);\n  render();\n});\n\ndocument.getElementById('release').addEventListener('click', ()=>{\n  const pid = relProc.value;\n  if(!pid) return;\n  const p = state.processes[pid];\n  const units = Number(document.getElementById('relUnits').value) || 1;\n  // choose sem from selected sem dropdown\n  const sem = state.semaphores[selSem.value];\n  if(!sem) { alert('Select a semaphore to release to'); return; }\n  const held = p.held[sem.id] || 0;\n  const toRel = Math.min(held, units);\n  sem.count += toRel;\n  if(toRel>0){ p.held[sem.id] = held - toRel; if(p.held[sem.id]===0) delete p.held[sem.id]; state.metrics.totalReleases += toRel; }\n  processSemaphoresTick();\n  render();\n  logLine(p.name + ' released ' + toRel + ' to ' + sem.name);\n});\n\ndocument.getElementById('releaseAll').addEventListener('click', ()=>{\n  const pid = relProc.value;\n  if(!pid) return;\n  const p = state.processes[pid];\n  for(const semId in p.held){\n    const units = p.held[semId];\n    state.semaphores[semId].count += units;\n    state.metrics.totalReleases += units;\n    logLine(p.name + ' released ' + units + ' from ' + state.semaphores[semId].name);\n  }\n  p.held = {};\n  processSemaphoresTick();\n  render();\n});\n\ndocument.getElementById('spawnProcess').addEventListener('click', ()=>{\n  const text = document.getElementById('scriptArea').value;\n  const scripts = parseScript(text);\n  const nameBase = document.getElementById('procName').value || 'proc';\n  const copies = Number(document.getElementById('spawnCount').value) || 1;\n  const autoRepeat = document.getElementById('autoRepeat').checked;\n  for(let i=0;i<copies;i++){\n    createProcess(nameBase + (copies>1?('_' + (i+1)) : ''), deepClone(scripts), {priority:1, autoRepeat});\n  }\n  render();\n});\n\ndocument.getElementById('spawnRandom').addEventListener('click', ()=>{\n  // create a small random script that acquires/releases random semaphores\n  const semIds = Object.keys(state.semaphores);\n  if(semIds.length===0){ alert('Create a semaphore first'); return; }\n  const randScript = [];\n  const steps = Math.floor(Math.random()*5)+3;\n  for(let i=0;i<steps;i++){\n    const sem = state.semaphores[semIds[Math.floor(Math.random()*semIds.length)]];\n    const units = Math.floor(Math.random()*2)+1;\n    randScript.push({type:'acquire', semName:sem.name, units, blocking: Math.random()>0.3, priority: Math.floor(Math.random()*5)+1, timeout: Math.random()>0.6? (Math.floor(Math.random()*2000)+200) : 0});\n    if(Math.random()>0.2) randScript.push({type:'sleep', ms: Math.floor(Math.random()*500)});\n    randScript.push({type:'release', semName:sem.name, units});\n  }\n  randScript.push({type:'end'});\n  const name = 'R' + Math.random().toString(36).slice(2,5);\n  createProcess(name, randScript);\n  render();\n});\n\ndocument.getElementById('autoRun').addEventListener('change', (e)=>{\n  config.autoRun = e.target.checked;\n  if(config.autoRun) startAutoRun();\n  else stopAutoRun();\n});\n\nlet autoTimer = null;\nfunction startAutoRun(){\n  stopAutoRun();\n  config.tickSpeed = Number(document.getElementById('tickSpeed').value) || 200;\n  autoTimer = setInterval(()=>{ tick(); }, config.tickSpeed);\n}\nfunction stopAutoRun(){ if(autoTimer) clearInterval(autoTimer); autoTimer = null; }\n\ndocument.getElementById('tickSpeed').addEventListener('change', (e)=>{\n  config.tickSpeed = Number(e.target.value) || 200;\n  if(document.getElementById('autoRun').checked) startAutoRun();\n});\n\ndocument.getElementById('step').addEventListener('click', ()=>{ tick(); });\ndocument.getElementById('stepBack').addEventListener('click', ()=>{ restoreLastSnapshot(); });\ndocument.getElementById('pauseAll').addEventListener('click', ()=>{\n  for(const pid in state.processes) state.processes[pid].state = 'ready';\n  logLine('All processes set to ready (not running)');\n  render();\n});\ndocument.getElementById('resumeAll').addEventListener('click', ()=>{\n  for(const pid in state.processes) if(state.processes[pid].state!=='terminated') state.processes[pid].state = 'ready';\n  logLine('All processes resumed');\n  render();\n});\n\ndocument.getElementById('saveState').addEventListener('click', ()=>{\n  savedSnapshots.push(JSON.stringify(state));\n  logLine('Saved snapshot #' + savedSnapshots.length);\n});\ndocument.getElementById('restoreState').addEventListener('click', ()=>{\n  if(savedSnapshots.length===0) { alert('No snapshots saved'); return; }\n  state = JSON.parse(savedSnapshots.pop());\n  updateSelectors();\n  render();\n  logLine('Restored saved snapshot');\n});\n\ndocument.getElementById('presetSimple').addEventListener('click', ()=>{\n  // clear and create simple preset\n  for(const id in state.semaphores) delete state.semaphores[id];\n  for(const id in state.processes) delete state.processes[id];\n  createSemaphore('S1', 2);\n  const sScript = `acquire S1 1 block\nsleep 2000\nrelease S1 1\nend`;\n  const scripts = parseScript(sScript);\n  createProcess('A', deepClone(scripts));\n  createProcess('B', deepClone(scripts));\n  createProcess('C', deepClone(scripts));\n  render();\n  logLine('Loaded preset: simple contended');\n});\n\ndocument.getElementById('presetPriority').addEventListener('click', ()=>{\n  for(const id in state.semaphores) delete state.semaphores[id];\n  for(const id in state.processes) delete state.processes[id];\n  createSemaphore('S1', 1);\n  // high priority short job\n  createProcess('High', parseScript('acquire S1 1 block priority=10\\nsleep 200\\nrelease S1 1\\nend'));\n  // low priority long job\n  createProcess('Low', parseScript('acquire S1 1 block priority=1\\nsleep 1000\\nrelease S1 1\\nend'));\n  render();\n  logLine('Loaded preset: priority test');\n});\n\ndocument.getElementById('stress10').addEventListener('click', ()=>{\n  if(Object.keys(state.semaphores).length===0) createSemaphore('S1', 3);\n  const semName = Object.values(state.semaphores)[0].name;\n  for(let i=0;i<10;i++){\n    const script = `acquire ${semName} 1 block priority=${Math.floor(Math.random()*3)+1}\\nsleep ${Math.floor(Math.random()*200)+50}\\nrelease ${semName} 1\\nend`;\n    createProcess('S' + i, parseScript(script));\n  }\n  render();\n});\ndocument.getElementById('stress50').addEventListener('click', ()=>{\n  if(Object.keys(state.semaphores).length===0) createSemaphore('S1', 5);\n  const semName = Object.values(state.semaphores)[0].name;\n  for(let i=0;i<50;i++){\n    const script = `acquire ${semName} 1 block priority=${Math.floor(Math.random()*5)+1}\\nsleep ${Math.floor(Math.random()*500)+50}\\nrelease ${semName} 1\\nend`;\n    createProcess('S' + i, parseScript(script));\n  }\n  render();\n});\n\ndocument.getElementById('clearAll').addEventListener('click', ()=>{\n  if(!confirm('Clear all semaphores, processes, logs?')) return;\n  for(const id in state.semaphores) delete state.semaphores[id];\n  for(const id in state.processes) delete state.processes[id];\n  logDiv.textContent = '';\n  updateSelectors(); render();\n});\n\ndocument.getElementById('inspectReq').addEventListener('change', ()=>{ /* no-op */ });\ndocument.getElementById('wakeFirst').addEventListener('click', ()=>{\n  const sem = state.semaphores[inspectReq.value];\n  if(!sem) return;\n  if(sem.waiting.length===0) { alert('No waiting requests'); return; }\n  // pick according to policy\n  const r = selectRequest(sem);\n  if(r){\n    // forcibly grant even if not enough units\n    const reqUnits = r.units || 1;\n    sem.count += reqUnits; // temporarily boost\n    processSemaphoresTick();\n    render();\n    logLine('Force-woken ' + (state.processes[r.processId]?state.processes[r.processId].name:r.processId) + ' on ' + sem.name);\n  }\n});\ndocument.getElementById('bumpPriority').addEventListener('click', ()=>{\n  const sem = state.semaphores[inspectReq.value];\n  if(!sem) return;\n  if(sem.waiting.length===0) { alert('No waiting requests'); return; }\n  // bump priority of first waiting entry\n  const r = sem.waiting[0];\n  r.priority = (r.priority||0) + 5;\n  render();\n  logLine('Bumped priority of a waiting request on ' + sem.name);\n});\ndocument.getElementById('removeRequest').addEventListener('click', ()=>{\n  const sem = state.semaphores[inspectReq.value];\n  if(!sem) return;\n  if(sem.waiting.length===0) { alert('No waiting requests'); return; }\n  const r = sem.waiting[0];\n  removeRequestById(sem, r.id);\n  if(state.processes[r.processId]){\n    state.processes[r.processId].state = 'ready';\n    state.processes[r.processId].waitRequestId = null;\n    state.processes[r.processId].waitStart = null;\n  }\n  render();\n  logLine('Removed a waiting request from ' + sem.name);\n});\n\ndocument.getElementById('clearLog').addEventListener('click', ()=>{\n  logDiv.textContent = '';\n});\n\n// Initialize with some defaults\ncreateSemaphore('S1', 2);\ncreateSemaphore('S2', 1);\ncreateProcess('P1', parseScript('acquire S1 1 block\\nsleep 300\\nrelease S1 1\\nend'));\ncreateProcess('P2', parseScript('acquire S1 2 block\\nsleep 500\\nrelease S1 2\\nend'));\nrender();\nlogLine('Initialized simulation');\n\n// Auto-run control ties\ndocument.getElementById('autoRun').checked = false;\ndocument.getElementById('tickSpeed').value = config.tickSpeed;\n\n</script>\n</body>\n</html>"
