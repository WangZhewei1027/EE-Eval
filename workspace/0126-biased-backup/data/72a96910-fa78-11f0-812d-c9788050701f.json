    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Visual Priority Queue</title>\n    <style>\n        :root {\n            --primary: #6c5ce7;\n            --secondary: #a29bfe;\n            --accent: #fd79a8;\n            --dark: #2d3436;\n            --light: #f5f6fa;\n            --success: #00b894;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n        }\n\n        body {\n            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            color: var(--dark);\n            overflow-x: hidden;\n        }\n\n        .container {\n            width: 90%;\n            max-width: 1200px;\n            margin: 2rem auto;\n            padding: 2rem;\n            background: rgba(255, 255, 255, 0.9);\n            border-radius: 20px;\n            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);\n            backdrop-filter: blur(10px);\n            position: relative;\n            overflow: hidden;\n        }\n\n        .container::before {\n            content: '';\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: radial-gradient(circle, var(--secondary) 0%, transparent 70%);\n            opacity: 0.1;\n            z-index: -1;\n            animation: float 15s infinite linear;\n        }\n\n        @keyframes float {\n            0% { transform: rotate(0deg); }\n            100% { transform: rotate(360deg); }\n        }\n\n        h1 {\n            text-align: center;\n            margin-bottom: 2rem;\n            font-weight: 700;\n            font-size: 2.5rem;\n            color: var(--primary);\n            position: relative;\n            display: inline-block;\n        }\n\n        h1::after {\n            content: '';\n            position: absolute;\n            bottom: -10px;\n            left: 50%;\n            transform: translateX(-50%);\n            width: 100px;\n            height: 4px;\n            background: var(--accent);\n            border-radius: 2px;\n        }\n\n        .description {\n            text-align: center;\n            margin-bottom: 3rem;\n            font-size: 1.1rem;\n            line-height: 1.6;\n            color: var(--dark);\n            max-width: 700px;\n            margin-left: auto;\n            margin-right: auto;\n        }\n\n        .queue-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin: 3rem 0;\n            position: relative;\n        }\n\n        .queue {\n            display: flex;\n            flex-direction: column-reverse;\n            align-items: center;\n            width: 100%;\n            min-height: 400px;\n            position: relative;\n        }\n\n        .queue-item {\n            width: 80%;\n            max-width: 500px;\n            background: white;\n            border-radius: 12px;\n            padding: 1.5rem;\n            margin: 0.5rem 0;\n            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n            transform-origin: bottom;\n            z-index: 1;\n        }\n\n        .queue-item::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 8px;\n            height: 100%;\n            background: var(--primary);\n        }\n\n        .queue-item.high-priority {\n            transform: scale(1.05);\n            box-shadow: 0 8px 25px rgba(108, 92, 231, 0.2);\n            z-index: 2;\n        }\n\n        .queue-item.high-priority::before {\n            background: var(--accent);\n            width: 10px;\n        }\n\n        .queue-item.medium-priority::before {\n            background: var(--secondary);\n        }\n\n        .queue-item.low-priority::before {\n            background: #dfe6e9;\n        }\n\n        .item-content {\n            flex: 1;\n        }\n\n        .item-title {\n            font-weight: 600;\n            font-size: 1.2rem;\n            margin-bottom: 0.5rem;\n            color: var(--dark);\n        }\n\n        .item-description {\n            color: #636e72;\n            font-size: 0.9rem;\n        }\n\n        .item-priority {\n            font-weight: 700;\n            padding: 0.5rem 1rem;\n            border-radius: 20px;\n            font-size: 0.8rem;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            margin-left: 1rem;\n        }\n\n        .high-priority .item-priority {\n            background: rgba(253, 121, 168, 0.1);\n            color: var(--accent);\n        }\n\n        .medium-priority .item-priority {\n            background: rgba(162, 155, 254, 0.1);\n            color: var(--secondary);\n        }\n\n        .low-priority .item-priority {\n            background: rgba(178, 190, 195, 0.1);\n            color: #636e72;\n        }\n\n        .controls {\n            display: flex;\n            justify-content: center;\n            gap: 1rem;\n            margin-top: 2rem;\n        }\n\n        button {\n            padding: 0.8rem 1.5rem;\n            border: none;\n            border-radius: 50px;\n            font-weight: 600;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);\n            position: relative;\n            overflow: hidden;\n        }\n\n        button::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(rgba(255, 255, 255, 0.3), transparent);\n            opacity: 0;\n            transition: opacity 0.3s;\n        }\n\n        button:hover::after {\n            opacity: 1;\n        }\n\n        .btn-process {\n            background: var(--primary);\n            color: white;\n        }\n\n        .btn-add {\n            background: var(--success);\n            color: white;\n        }\n\n        .visualization {\n            width: 100%;\n            height: 200px;\n            position: relative;\n            margin: 3rem 0;\n        }\n\n        .priority-bar {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 10px;\n            background: linear-gradient(90deg, var(--accent), var(--secondary), #dfe6e9);\n            border-radius: 5px;\n        }\n\n        .priority-marker {\n            position: absolute;\n            bottom: 20px;\n            width: 2px;\n            height: 15px;\n            background: var(--dark);\n            transform: translateX(-50%);\n        }\n\n        .priority-label {\n            position: absolute;\n            bottom: 40px;\n            transform: translateX(-50%);\n            font-size: 0.8rem;\n            font-weight: 600;\n        }\n\n        .legend {\n            display: flex;\n            justify-content: center;\n            gap: 2rem;\n            margin-top: 2rem;\n        }\n\n        .legend-item {\n            display: flex;\n            align-items: center;\n            gap: 0.5rem;\n        }\n\n        .legend-color {\n            width: 15px;\n            height: 15px;\n            border-radius: 3px;\n        }\n\n        .high-color {\n            background: var(--accent);\n        }\n\n        .medium-color {\n            background: var(--secondary);\n        }\n\n        .low-color {\n            background: #dfe6e9;\n        }\n\n        .floating-elements {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: -1;\n            overflow: hidden;\n        }\n\n        .floating-element {\n            position: absolute;\n            opacity: 0.1;\n            border-radius: 50%;\n            animation: float-up 15s infinite linear;\n        }\n\n        @keyframes float-up {\n            0% {\n                transform: translateY(100vh) rotate(0deg);\n                opacity: 0;\n            }\n            10% {\n                opacity: 0.1;\n            }\n            90% {\n                opacity: 0.1;\n            }\n            100% {\n                transform: translateY(-100px) rotate(360deg);\n                opacity: 0;\n            }\n        }\n\n        .status {\n            text-align: center;\n            margin-top: 2rem;\n            font-weight: 600;\n            color: var(--primary);\n            height: 1.5rem;\n        }\n\n        @media (max-width: 768px) {\n            .container {\n                padding: 1.5rem;\n                width: 95%;\n            }\n\n            h1 {\n                font-size: 2rem;\n            }\n\n            .queue-item {\n                width: 95%;\n                padding: 1rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"floating-elements\">\n        <!-- Floating decorative elements -->\n        <div class=\"floating-element\" style=\"width: 100px; height: 100px; background: var(--accent); left: 10%; animation-delay: 0s;\"></div>\n        <div class=\"floating-element\" style=\"width: 150px; height: 150px; background: var(--secondary); left: 30%; animation-delay: 3s;\"></div>\n        <div class=\"floating-element\" style=\"width: 80px; height: 80px; background: var(--primary); left: 70%; animation-delay: 6s;\"></div>\n        <div class=\"floating-element\" style=\"width: 120px; height: 120px; background: var(--success); left: 50%; animation-delay: 9s;\"></div>\n    </div>\n\n    <div class=\"container\">\n        <h1>Priority Queue Visualization</h1>\n        <p class=\"description\">\n            A priority queue is an abstract data type where elements are served based on priority rather than arrival time.\n            Higher priority elements are processed before lower priority ones, regardless of when they were added.\n        </p>\n\n        <div class=\"visualization\">\n            <div class=\"priority-bar\"></div>\n            <div class=\"priority-marker\" style=\"left: 10%;\"></div>\n            <div class=\"priority-marker\" style=\"left: 50%;\"></div>\n            <div class=\"priority-marker\" style=\"left: 90%;\"></div>\n            <div class=\"priority-label\" style=\"left: 10%;\">High</div>\n            <div class=\"priority-label\" style=\"left: 50%;\">Medium</div>\n            <div class=\"priority-label\" style=\"left: 90%;\">Low</div>\n        </div>\n\n        <div class=\"legend\">\n            <div class=\"legend-item\">\n                <div class=\"legend-color high-color\"></div>\n                <span>High Priority</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color medium-color\"></div>\n                <span>Medium Priority</span>\n            </div>\n            <div class=\"legend-item\">\n                <div class=\"legend-color low-color\"></div>\n                <span>Low Priority</span>\n            </div>\n        </div>\n\n        <div class=\"queue-container\">\n            <div class=\"queue\" id=\"queue\">\n                <!-- Queue items will be added here -->\n            </div>\n        </div>\n\n        <div class=\"status\" id=\"status\"></div>\n\n        <div class=\"controls\">\n            <button class=\"btn-add\" id=\"addItem\">\n                Add Random Item\n            </button>\n            <button class=\"btn-process\" id=\"processItem\">\n                Process Next Item\n            </button>\n        </div>\n    </div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const queue = document.getElementById('queue');\n            const addBtn = document.getElementById('addItem');\n            const processBtn = document.getElementById('processItem');\n            const statusEl = document.getElementById('status');\n\n            // Sample data\n            const items = [\n                { title: \"Critical System Update\", description: \"Security patch for production servers\", priority: \"high\" },\n                { title: \"Database Backup\", description: \"Nightly backup routine\", priority: \"medium\" },\n                { title: \"User Feedback Analysis\", description: \"Quarterly review of customer feedback\", priority: \"low\" },\n                { title: \"Server Maintenance\", description: \"Hardware upgrade scheduled\", priority: \"high\" },\n                { title: \"Documentation Update\", description: \"Update API documentation\", priority: \"low\" },\n                { title: \"Performance Optimization\", description: \"Query optimization for reporting module\", priority: \"medium\" }\n            ];\n\n            const priorityClasses = {\n                high: \"high-priority\",\n                medium: \"medium-priority\",\n                low: \"low-priority\"\n            };\n\n            // Initialize with some items\n            addRandomItem();\n            addRandomItem();\n            addRandomItem();\n\n            // Add random item to queue\n            addBtn.addEventListener('click', function() {\n                addRandomItem();\n                animateButton(this);\n            });\n\n            // Process next item (highest priority)\n            processBtn.addEventListener('click', function() {\n                processNextItem();\n                animateButton(this);\n            });\n\n            function addRandomItem() {\n                const randomItem = items[Math.floor(Math.random() * items.length)];\n                addItemToQueue(randomItem);\n            }\n\n            function addItemToQueue(item) {\n                const queueItem = document.createElement('div');\n                queueItem.className = `queue-item ${priorityClasses[item.priority]}`;\n                queueItem.innerHTML = `\n                    <div class=\"item-content\">\n                        <div class=\"item-title\">${item.title}</div>\n                        <div class=\"item-description\">${item.description}</div>\n                    </div>\n                    <div class=\"item-priority\">${item.priority} priority</div>\n                `;\n                \n                // Add to queue with animation\n                queueItem.style.transform = 'scale(0)';\n                queueItem.style.opacity = '0';\n                queue.appendChild(queueItem);\n                \n                setTimeout(() => {\n                    queueItem.style.transform = 'scale(1)';\n                    queueItem.style.opacity = '1';\n                }, 10);\n                \n                updateStatus(`Added: ${item.title}`);\n            }\n\n            function processNextItem() {\n                const items = document.querySelectorAll('.queue-item');\n                if (items.length === 0) {\n                    updateStatus(\"Queue is empty\");\n                    return;\n                }\n                \n                // Find highest priority item (high > medium > low)\n                let highestPriorityItem = items[0];\n                for (let i = 1; i < items.length; i++) {\n                    if (items[i].classList.contains('high-priority') && \n                        !highestPriorityItem.classList.contains('high-priority')) {\n                        highestPriorityItem = items[i];\n                    } else if (items[i].classList.contains('medium-priority') && \n                               highestPriorityItem.classList.contains('low-priority')) {\n                        highestPriorityItem = items[i];\n                    }\n                }\n                \n                // Animate removal\n                highestPriorityItem.style.transform = 'translateX(-100%) rotate(-10deg)';\n                highestPriorityItem.style.opacity = '0';\n                \n                const title = highestPriorityItem.querySelector('.item-title').textContent;\n                updateStatus(`Processing: ${title}`);\n                \n                setTimeout(() => {\n                    highestPriorityItem.remove();\n                }, 500);\n            }\n\n            function updateStatus(message) {\n                statusEl.textContent = message;\n                statusEl.style.opacity = '1';\n                setTimeout(() => {\n                    statusEl.style.opacity = '0';\n                }, 2000);\n            }\n\n            function animateButton(button) {\n                button.style.transform = 'scale(0.95)';\n                setTimeout(() => {\n                    button.style.transform = 'scale(1)';\n                }, 150);\n            }\n\n            // Add floating elements dynamically\n            for (let i = 0; i < 8; i++) {\n                const size = Math.random() * 80 + 20;\n                const delay = Math.random() * 15;\n                const duration = Math.random() * 10 + 10;\n                const left = Math.random() * 100;\n                const color = [\n                    'var(--primary)',\n                    'var(--secondary)',\n                    'var(--accent)',\n                    'var(--success)'\n                ][Math.floor(Math.random() * 4)];\n                \n                const element = document.createElement('div');\n                element.className = 'floating-element';\n                element.style.width = `${size}px`;\n                element.style.height = `${size}px`;\n                element.style.background = color;\n                element.style.left = `${left}%`;\n                element.style.animationDelay = `${delay}s`;\n                element.style.animationDuration = `${duration}s`;\n                \n                document.querySelector('.floating-elements').appendChild(element);\n            }\n        });\n    </script>\n</body>\n</html>"
