  "events": [
    {
      "id": "Enqueue",
      "event_type": "click",
      "description": "Enqueue an element to the queue.",
      "trigger_selectors": [
        "#btn-enqueue"
      ],
      "evidence": [
        "btnEnqueue.addEventListener('click', () => { const val = elEnqueue.value.trim(); if(enqueue(val)){ elEnqueue.value = ''; }});"
      ],
      "confidence": 1
    },
    {
      "id": "Dequeue",
      "event_type": "click",
      "description": "Dequeue an element from the queue.",
      "trigger_selectors": [
        "#btn-dequeue"
      ],
      "evidence": [
        "btnDequeue.addEventListener('click', () => { dequeue(); });"
      ],
      "confidence": 1
    },
    {
      "id": "Peek",
      "event_type": "click",
      "description": "Peek at the front element of the queue.",
      "trigger_selectors": [
        "#btn-peek"
      ],
      "evidence": [
        "btnPeek.addEventListener('click', () => { peek(); });"
      ],
      "confidence": 1
    },
    {
      "id": "ClearQueue",
      "event_type": "click",
      "description": "Clear all elements from the queue.",
      "trigger_selectors": [
        "#btn-clear"
      ],
      "evidence": [
        "btnClear.addEventListener('click', () => { if(confirm('Are you sure you want to clear the queue?')){ clearQueue(); }});"
      ],
      "confidence": 1
    },
    {
      "id": "BulkEnqueue",
      "event_type": "click",
      "description": "Enqueue multiple elements from input.",
      "trigger_selectors": [
        "#btn-bulk-enqueue"
      ],
      "evidence": [
        "btnBulk.addEventListener('click', () => { const text = elBulk.value; const parts = text.split(/[\\n,]+/); enqueueMultiple(parts); elBulk.value = ''; });"
      ],
      "confidence": 1
    },
    {
      "id": "EnqueueAtPosition",
      "event_type": "click",
      "description": "Enqueue an element at a specific position.",
      "trigger_selectors": [
        "#btn-enqueue-at"
      ],
      "evidence": [
        "btnEnqAt.addEventListener('click', () => { const pos = Number(elEnqPos.value); const val = elEnqPosVal.value.trim(); if(enqueueAtPosition(pos, val)){ elEnqPos.value = ''; elEnqPosVal.value = ''; }});"
      ],
      "confidence": 1
    },
    {
      "id": "RemoveAtPosition",
      "event_type": "click",
      "description": "Remove an element from a specific position.",
      "trigger_selectors": [
        "#btn-remove-at"
      ],
      "evidence": [
        "btnRemAt.addEventListener('click', () => { const pos = Number(elRemPos.value); if(removeAtPosition(pos)){ elRemPos.value = ''; }});"
      ],
      "confidence": 1
    },
    {
      "id": "Find",
      "event_type": "click",
      "description": "Find all indexes of a specific value.",
      "trigger_selectors": [
        "#btn-find"
      ],
      "evidence": [
        "btnFind.addEventListener('click', () => { const val = elFindVal.value.trim(); if(val === ''){ logEvent('Find: No value provided'); return; } findAllIndexes(val); });"
      ],
      "confidence": 1
    },
    {
      "id": "Rotate",
      "event_type": "click",
      "description": "Rotate the queue by a specified number of positions.",
      "trigger_selectors": [
        "#btn-rotate"
      ],
      "evidence": [
        "btnRotate.addEventListener('click', () => { const n = Number(elRotateCount.value); rotateQueue(n); elRotateCount.value = ''; });"
      ],
      "confidence": 1
    },
    {
      "id": "Reverse",
      "event_type": "click",
      "description": "Reverse the first N elements of the queue.",
      "trigger_selectors": [
        "#btn-reverse"
      ],
      "evidence": [
        "btnReverse.addEventListener('click', () => { let n = Number(elReverseLen.value); if(isNaN(n)) n = 0; reverseFirstN(n); elReverseLen.value = ''; });"
      ],
      "confidence": 1
    },
    {
      "id": "SetMaxSize",
      "event_type": "click",
      "description": "Set the maximum size of the queue.",
      "trigger_selectors": [
        "#btn-set-max-size"
      ],
      "evidence": [
        "btnSetMax.addEventListener('click', () => { let n = Number(elMaxSize.value); if(isNaN(n) || n < 0){ logEvent('Max Size: Invalid max size'); return; } maxSize = n; logEvent(`Max Size: Queue max size set to ${maxSize === 0 ? 'unlimited' : maxSize}`); });"
      ],
      "confidence": 1
    },
    {
      "id": "CountEqual",
      "event_type": "click",
      "description": "Count elements equal to a specific value.",
      "trigger_selectors": [
        "#btn-count-equal"
      ],
      "evidence": [
        "btnCountEqual.addEventListener('click', () => { const val = elCountEqualVal.value.trim(); if(val === ''){ logEvent('Count Equal: No value provided'); return; } countEqualTo(val); });"
      ],
      "confidence": 1
    },
    {
      "id": "Filter",
      "event_type": "click",
      "description": "Filter elements based on a JavaScript condition.",
      "trigger_selectors": [
        "#btn-filter"
      ],
      "evidence": [
        "btnFilter.addEventListener('click', () => { const cond = elFilterCond.value.trim(); filterQueue(cond); });"
      ],
      "confidence": 1
    },
    {
      "id": "ResetFilter",
      "event_type": "click",
      "description": "Reset the active filter.",
      "trigger_selectors": [
        "#btn-reset-filter"
      ],
      "evidence": [
        "btnResetFilter.addEventListener('click', () => { resetFilter(); });"
      ],
      "confidence": 1
    },
    {
      "id": "Map",
      "event_type": "click",
      "description": "Map elements based on a JavaScript expression.",
      "trigger_selectors": [
        "#btn-map"
      ],
      "evidence": [
        "btnMap.addEventListener('click', () => { const expr = elMapFunc.value.trim(); mapQueue(expr); });"
      ],
      "confidence": 1
    },
    {
      "id": "ResetMap",
      "event_type": "click",
