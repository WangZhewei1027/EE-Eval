{
  "meta": {
    "concept": "Jump Search Interactive Demo",
    "topic": "Jump Search",
    "educational_goal": "To demonstrate the Jump Search algorithm interactively.",
    "expected_interactions": [
      "Initialize Search",
      "Reset All",
      "Step Back",
      "Step Forward",
      "Auto Run",
      "Jump to Start",
      "Jump to End",
      "Go to Step",
      "Retry Search",
      "New Array",
      "Export Log"
    ]
  },
  "states": [
    {
      "id": "S0_NotInitialized",
      "label": "Not Initialized",
      "type": "initial",
      "entry_actions": [
        "clearState()"
      ],
      "exit_actions": [],
      "evidence": [
        "currentState.textContent = 'Not initialized';",
        "arrayDisplay.textContent = formatArray(array);"
      ],
      "confidence": 1
    },
    {
      "id": "S1_ReadyForSearch",
      "label": "Ready for Search",
      "type": "active",
      "entry_actions": [
        "clearLog();",
        "appendLog(`Starting Jump Search for value ${searchValue} in array of length ${array.length} with block size ${blockSize <= 0 ? 'auto (' + Math.floor(Math.sqrt(array.length)) + ')' : blockSize}.`);"
      ],
      "exit_actions": [],
      "evidence": [
        "currentState.textContent = 'Ready for new search value.';",
        "arrayDisplay.textContent = formatArray(array);"
      ],
      "confidence": 1
    },
    {
      "id": "S2_SearchInProgress",
      "label": "Search In Progress",
      "type": "active",
      "entry_actions": [],
      "exit_actions": [],
      "evidence": [
        "currentState.textContent = `Jump step ${idx}: jumped to index ${step.index}`;",
        "currentState.textContent = `Linear search step ${idx}: checking index ${step.index}`;",
        "currentState.textContent = `Result step ${idx}: search complete.`;"
      ],
      "confidence": 1
    },
    {
      "id": "S3_SearchCompleted",
      "label": "Search Completed",
      "type": "final",
      "entry_actions": [],
      "exit_actions": [],
      "evidence": [
        "currentState.textContent = `Value ${target} found at index ${foundIndex}.`;",
        "currentState.textContent = `Value ${target} not found in array.`;"
      ],
      "confidence": 1
    }
  ],
  "events": [
    {
      "id": "InitializeSearch",
      "event_type": "click",
      "description": "Starts the Jump Search process.",
      "trigger_selectors": [
        "#initSearch"
      ],
      "evidence": [
        "initSearchBtn.addEventListener('click', startSearch);"
      ],
      "confidence": 1
    },
    {
      "id": "ResetAll",
      "event_type": "click",
      "description": "Resets all inputs and states.",
      "trigger_selectors": [
        "#resetAll"
      ],
      "evidence": [
        "resetAllBtn.addEventListener('click', () => { clearState(); arrayInput.focus(); });"
      ],
      "confidence": 1
    },
    {
      "id": "StepBack",
      "event_type": "click",
      "description": "Steps back to the previous step in the search.",
      "trigger_selectors": [
        "#stepBack"
      ],
      "evidence": [
        "stepBackBtn.addEventListener('click', () => { pauseAutoRun(); if (currentStepIndex > 0) displayStep(currentStepIndex -1); });"
      ],
      "confidence": 1
    },
    {
      "id": "StepForward",
      "event_type": "click",
      "description": "Steps forward to the next step in the search.",
      "trigger_selectors": [
        "#stepForward"
      ],
      "evidence": [
        "stepForwardBtn.addEventListener('click', () => { pauseAutoRun(); if (currentStepIndex < steps.length -1) displayStep(currentStepIndex + 1); });"
      ],
      "confidence": 1
    },
    {
      "id": "AutoRun",
      "event_type": "click",
      "description": "Toggles the auto run feature.",
      "trigger_selectors": [
        "#autoRun"
      ],
      "evidence": [
        "autoRunBtn.addEventListener('click', () => { toggleAutoRun(); });"
      ],
      "confidence": 1
    },
    {
      "id": "JumpToStart",
      "event_type": "click",
      "description": "Jumps to the start of the search steps.",
      "trigger_selectors": [
        "#jumpToStart"
      ],
      "evidence": [
        "jumpToStartBtn.addEventListener('click', () => { pauseAutoRun(); displayStep(0); });"
      ],
      "confidence": 1
    },
    {
      "id": "JumpToEnd",
      "event_type": "click",
      "description": "Jumps to the end of the search steps.",
      "trigger_selectors": [
        "#jumpToEnd"
      ],
      "evidence": [
        "jumpToEndBtn.addEventListener('click', () => { pauseAutoRun(); displayStep(steps.length - 1); });"
      ],
      "confidence": 1
    },
    {
      "id": "GoToStep",
      "event_type": "click",
      "description": "Goes to a specific step in the search.",
      "trigger_selectors": [
        "#gotoStep"
      ],
      "evidence": [
        "gotoStepBtn.addEventListener('click', () => { const val = Number(selectStepInput.value); if (!Number.isInteger(val)) { alert('Step must be an integer.'); return; } if (val < 0 || val >= steps.length) { alert('Step out of range (0 to ' + (steps.length -1) + ').'); return; } pauseAutoRun(); displayStep(val); });"
      ],
      "confidence": 1
    },
    {
      "id": "RetrySearch",
      "event_type": "click",
      "description": "Retries the search with the same array but a new value.",
      "trigger_selectors": [
        "#retrySearch"
      ],
      "evidence": [
        "retrySearchBtn.addEventListener('click', retrySearch);"
      ],
      "confidence": 1
    },
    {
      "id": "NewArray",
      "event_type": "click",
      "description": "Clears the current state and allows for a new array input.",
      "trigger_selectors": [
        "#newArray"
      ],
      "evidence": [
        "newArrayBtn.addEventListener('click', () => { clearState(); arrayInput.focus(); });"
      ],
      "confidence": 1
    },
    {
      "id": "ExportLog",
      "event_type": "click",
      "description": "Exports the log as a text file.",
      "trigger_selectors": [
        "#exportLog"
      ],
      "evidence": [
        "exportLogBtn.addEventListener('click', exportLog);"
      ],
      "confidence": 1
    }
  ],
  "transitions": [
    {
      "from": "S0_NotInitialized",
