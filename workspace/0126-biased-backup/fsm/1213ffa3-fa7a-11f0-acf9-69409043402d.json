        "displayStep(currentStepIndex - 1)"
      ],
      "expected_observables": [
        "currentState.textContent = `Jump step ${idx}: jumped to index ${step.index}`;"
      ],
      "evidence": [
        "stepBackBtn.addEventListener('click', () => { pauseAutoRun(); if (currentStepIndex > 0) displayStep(currentStepIndex -1); });"
      ],
      "confidence": 1
    },
    {
      "from": "S2_SearchInProgress",
      "to": "S3_SearchCompleted",
      "event": "GoToStep",
      "actions": [
        "displayStep(val)"
      ],
      "expected_observables": [
        "currentState.textContent = `Result step ${idx}: search complete.`;"
      ],
      "evidence": [
        "gotoStepBtn.addEventListener('click', () => { const val = Number(selectStepInput.value); ... });"
      ],
      "confidence": 1
    },
    {
      "from": "S1_ReadyForSearch",
      "to": "S0_NotInitialized",
      "event": "ResetAll",
      "actions": [
        "clearState()"
      ],
      "expected_observables": [
        "currentState.textContent = 'Not initialized';"
      ],
      "evidence": [
        "resetAllBtn.addEventListener('click', () => { clearState(); arrayInput.focus(); });"
      ],
      "confidence": 1
    },
    {
      "from": "S3_SearchCompleted",
      "to": "S1_ReadyForSearch",
      "event": "RetrySearch",
      "actions": [
        "retrySearch()"
      ],
      "expected_observables": [
        "currentState.textContent = 'Ready for new search value.';"
      ],
      "evidence": [
        "retrySearchBtn.addEventListener('click', retrySearch);"
      ],
      "confidence": 1
    }
