    },
    {
      "id": "EnableMonitor",
      "event_type": "click",
      "description": "Enable the selected monitor.",
      "trigger_selectors": [
        "#enableBtn"
      ],
      "evidence": [
        "document.getElementById('enableBtn').addEventListener('click', ()=>{ if (selectedId) { monitors[selectedId].enabled = true; monitors[selectedId].state='INITIAL'; pushHistory('enable ' + selectedId); renderSelectedConfig(); } });"
