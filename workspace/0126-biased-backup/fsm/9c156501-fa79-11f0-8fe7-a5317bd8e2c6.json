      "confidence": 1
    },
    {
      "id": "DisableMonitor",
      "event_type": "click",
      "description": "Disable the selected monitor.",
      "trigger_selectors": [
        "#disableBtn"
      ],
      "evidence": [
        "document.getElementById('disableBtn').addEventListener('click', ()=>{ if (selectedId) { monitors[selectedId].enabled = false; monitors[selectedId].state='DISABLED'; stopSimulation(selectedId); pushHistory('disable ' + selectedId); renderSelectedConfig(); } });"
      ],
      "confidence": 1
    }
