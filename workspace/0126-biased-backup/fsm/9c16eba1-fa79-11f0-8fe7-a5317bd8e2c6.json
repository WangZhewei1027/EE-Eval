      "id": "GenerateData",
      "event_type": "click",
      "description": "Generate new data points based on user input.",
      "trigger_selectors": [
        "#generateBtn"
      ],
      "evidence": [
        "generateBtn.addEventListener('click', ()=>{ const n = parseInt(nPointsInput.value) || 100; const tK = parseInt(trueKInput.value) || 3; state.points = generateData(datasetType.value, n, tK); })"
      ],
      "confidence": 1
    },
    {
      "id": "AddPoint",
      "event_type": "mousedown",
      "description": "Add a point to the canvas.",
      "trigger_selectors": [
        "#plot"
      ],
      "evidence": [
        "canvas.addEventListener('mousedown',(e)=>{ if (state.mode === 'add'){ state.points.push({x:p.x,y:p.y,weight:1,assigned:-1}); drawAll(); } })"
      ],
      "confidence": 1
    },
    {
      "id": "MovePoint",
      "event_type": "mousedown",
      "description": "Start moving a point on the canvas.",
      "trigger_selectors": [
        "#plot"
      ],
      "evidence": [
        "canvas.addEventListener('mousedown',(e)=>{ if (state.mode === 'move'){ dragging = true; dragIndex = idx; } })"
      ],
      "confidence": 1
    },
    {
      "id": "DeletePoint",
      "event_type": "mousedown",
      "description": "Delete a point from the canvas.",
      "trigger_selectors": [
        "#plot"
      ],
      "evidence": [
        "canvas.addEventListener('mousedown',(e)=>{ if (state.mode === 'delete'){ state.points.splice(idx,1); drawAll(); } })"
      ],
      "confidence": 1
    },
    {
