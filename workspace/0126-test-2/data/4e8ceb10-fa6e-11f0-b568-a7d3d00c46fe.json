    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bubble Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f4f4f4;\n            padding: 20px;\n        }\n\n        #arrayContainer {\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            height: 300px;\n            margin: 20px 0;\n        }\n\n        .bar {\n            width: 30px;\n            margin: 0 2px;\n            background-color: #4CAF50;\n            display: inline-block;\n        }\n\n        .active {\n            background-color: #FF5722;\n        }\n\n        .sorted {\n            background-color: #2196F3;\n        }\n\n        button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Bubble Sort Visualization</h1>\n<div id=\"arrayContainer\"></div>\n<button id=\"startSort\">Start Bubble Sort</button>\n\n<script>\n    const arrayContainer = document.getElementById('arrayContainer');\n    const startSortButton = document.getElementById('startSort');\n    let array = [];\n\n    function generateRandomArray(size) {\n        array = [];\n        for (let i = 0; i < size; i++) {\n            array.push(Math.floor(Math.random() * 100) + 1);\n        }\n        renderArray();\n    }\n\n    function renderArray() {\n        arrayContainer.innerHTML = '';\n        array.forEach(value => {\n            const bar = document.createElement('div');\n            bar.className = 'bar';\n            bar.style.height = `${value * 3}px`;\n            bar.innerText = value;\n            arrayContainer.appendChild(bar);\n        });\n    }\n\n    async function bubbleSort() {\n        const bars = document.querySelectorAll('.bar');\n        let n = array.length;\n\n        for (let i = 0; i < n-1; i++) {\n            for (let j = 0; j < n-i-1; j++) {\n                bars[j].classList.add('active');\n                bars[j + 1].classList.add('active');\n\n                if (array[j] > array[j + 1]) {\n                    await new Promise(resolve => setTimeout(resolve, 100)); // Delay for visualization\n                    [array[j], array[j + 1]] = [array[j + 1], array[j]];\n                }\n                renderArray();\n\n                bars[j].classList.remove('active');\n                bars[j + 1].classList.remove('active');\n            }\n            bars[n-i-1].classList.add('sorted'); // Mark the last element in this pass as sorted\n        }\n        // Mark the whole array as sorted\n        renderArray();\n        for (let k = 0; k < n; k++) {\n            bars[k].classList.add('sorted');\n        }\n    }\n\n    startSortButton.addEventListener('click', async () => {\n        generateRandomArray(10); // Generate a new random array of size 10\n        await bubbleSort();\n    });\n\n    generateRandomArray(10); // Initial array generation\n</script>\n\n</body>\n</html>"
