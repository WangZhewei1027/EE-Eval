    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f9f9f9;\n        }\n        #bst-container {\n            margin-top: 20px;\n            position: relative;\n            height: 400px;\n        }\n        .node {\n            display: inline-block;\n            background-color: #4CAF50;\n            color: white;\n            border-radius: 8px;\n            padding: 10px 15px;\n            margin: 5px;\n        }\n        .level {\n            display: flex;\n            justify-content: center;\n            position: relative;\n        }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree Visualization</h1>\n    <input type=\"text\" id=\"value\" placeholder=\"Enter value\">\n    <button onclick=\"insertNode()\">Insert Node</button>\n    <div id=\"bst-container\"></div>\n\n    <script>\n        class TreeNode {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        class BinarySearchTree {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(value) {\n                const newNode = new TreeNode(value);\n                if (this.root === null) {\n                    this.root = newNode;\n                } else {\n                    this.insertNode(this.root, newNode);\n                }\n                this.render();\n            }\n\n            insertNode(node, newNode) {\n                if (newNode.value < node.value) {\n                    if (node.left === null) {\n                        node.left = newNode;\n                    } else {\n                        this.insertNode(node.left, newNode);\n                    }\n                } else {\n                    if (node.right === null) {\n                        node.right = newNode;\n                    } else {\n                        this.insertNode(node.right, newNode);\n                    }\n                }\n            }\n\n            render() {\n                const container = document.getElementById('bst-container');\n                container.innerHTML = '';\n                this.renderNode(this.root, container, 0);\n            }\n\n            renderNode(node, container, level) {\n                if (node === null) return;\n\n                const div = document.createElement('div');\n                div.className = 'node';\n                div.textContent = node.value;\n\n                const levelDiv = document.createElement('div');\n                levelDiv.className = 'level';\n                levelDiv.style.marginLeft = `${level * 50}px`;\n                levelDiv.appendChild(div);\n\n                if (level > 0) {\n                    const leftLine = document.createElement('div');\n                    leftLine.style.width = '50px';\n                    leftLine.style.borderBottom = '1px solid black';\n                    leftLine.style.position = 'absolute';\n                    leftLine.style.left = `${(level - 1) * 50 + 20}px`;\n                    leftLine.style.top = '-20px';\n                    levelDiv.appendChild(leftLine);\n\n                    const rightLine = document.createElement('div');\n                    rightLine.style.width = '50px';\n                    rightLine.style.borderBottom = '1px solid black';\n                    rightLine.style.position = 'absolute';\n                    rightLine.style.right = '0';\n                    rightLine.style.top = '-20px';\n                    levelDiv.appendChild(rightLine);\n                }\n\n                container.appendChild(levelDiv);\n                this.renderNode(node.left, container, level + 1);\n                this.renderNode(node.right, container, level + 1);\n            }\n        }\n\n        const bst = new BinarySearchTree();\n\n        function insertNode() {\n            const valueInput = document.getElementById('value');\n            const value = parseInt(valueInput.value);\n            if (!isNaN(value)) {\n                bst.insert(value);\n                valueInput.value = '';\n            } else {\n                alert('Please enter a valid number.');\n            }\n        }\n    </script>\n</body>\n</html>"
