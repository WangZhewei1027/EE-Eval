    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree Visualization</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            padding: 0;\n            background-color: #f0f4ff;\n            color: #333;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n        #container {\n            position: relative;\n            width: 80%;\n            height: 80%;\n            margin: auto;\n            border: 2px solid #0077cc;\n            border-radius: 15px;\n            background: rgba(255, 255, 255, 0.9);\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);\n            overflow: hidden;\n        }\n        .node {\n            width: 60px;\n            height: 60px;\n            background-color: #0077cc;\n            color: white;\n            text-align: center;\n            line-height: 60px;\n            border-radius: 50%;\n            position: absolute;\n            transition: transform 0.3s ease;\n        }\n        .line {\n            position: absolute;\n            width: 2px;\n            background-color: #333;\n            transition: height 0.3s ease;\n        }\n        button {\n            padding: 10px 20px;\n            margin: 10px;\n            border: none;\n            border-radius: 5px;\n            background-color: #0077cc;\n            color: white;\n            font-size: 16px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n        }\n        button:hover {\n            background-color: #005fa3;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\">\n        <div id=\"tree\"></div>\n        <button id=\"generateTree\">Generate BST</button>\n    </div>\n    <script>\n        function generateBST() {\n            const nodes = [15, 10, 20, 8, 12, 17, 25];\n            const positions = [\n                {x: 320, y: 50}, {x: 210, y: 150}, {x: 430, y: 150},\n                {x: 160, y: 250}, {x: 260, y: 250}, {x: 380, y: 250}, {x: 480, y: 250}\n            ];\n            const treeContainer = document.getElementById('tree');\n            treeContainer.innerHTML = '';\n            drawNodes(nodes, positions);\n            drawLines(positions);\n        }\n\n        function drawNodes(nodes, positions) {\n            nodes.forEach((node, index) => {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = 'node';\n                nodeElement.innerText = node;\n                nodeElement.style.transform = `translate(${positions[index].x}px, ${positions[index].y}px)`;\n                document.getElementById('tree').appendChild(nodeElement);\n            });\n        }\n\n        function drawLines(positions) {\n            const linesPositions = [\n                {start: positions[1], end: positions[0]}, // 10 -> 15\n                {start: positions[2], end: positions[0]}, // 20 -> 15\n                {start: positions[3], end: positions[1]}, // 8 -> 10\n                {start: positions[4], end: positions[1]}, // 12 -> 10\n                {start: positions[5], end: positions[2]}, // 17 -> 20\n                {start: positions[6], end: positions[2]}  // 25 -> 20\n            ];\n\n            linesPositions.forEach(linePos => {\n                const line = document.createElement('div');\n                line.className = 'line';\n                const height = Math.abs(linePos.start.y - linePos.end.y);\n                line.style.height = height + 'px';\n                line.style.transform = `translate(${linePos.start.x + 28}px, ${linePos.start.y}px) rotate(${Math.atan2(linePos.end.y - linePos.start.y, linePos.end.x - linePos.start.x) * 180 / Math.PI}deg)`;\n                document.getElementById('tree').appendChild(line);\n            });\n        }\n\n        document.getElementById(\"generateTree\").addEventListener(\"click\", generateBST);\n    </script>\n</body>\n</html>"
