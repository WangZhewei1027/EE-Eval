    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bubble Sort Visualization</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .array-display { margin-top: 20px; }\n        .element { display: inline-block; width: 30px; text-align: center; }\n    </style>\n</head>\n<body>\n\n<h1>Bubble Sort Visualization</h1>\n\n<label for=\"arraySize\">Array Size: </label>\n<input type=\"number\" id=\"arraySize\" min=\"2\" max=\"20\" value=\"5\">\n<button id=\"generateArray\">Generate Array</button>\n<button id=\"startSort\">Start Bubble Sort</button>\n<button id=\"stopSort\" disabled>Stop</button>\n\n<div class=\"array-display\" id=\"arrayDisplay\"></div>\n\n<script>\n    let array = [];\n    let intervalId;\n    let currentIndex = 0;\n    let sorted = false;\n\n    document.getElementById('generateArray').onclick = function() {\n        const size = parseInt(document.getElementById('arraySize').value);\n        array = Array.from({ length: size }, () => Math.floor(Math.random() * 100));\n        displayArray();\n        document.getElementById('startSort').disabled = false;\n        document.getElementById('stopSort').disabled = false;\n    }\n\n    function displayArray() {\n        const arrayDisplay = document.getElementById('arrayDisplay');\n        arrayDisplay.innerHTML = '';\n        array.forEach(value => {\n            const element = document.createElement('div');\n            element.className = 'element';\n            element.textContent = value;\n            arrayDisplay.appendChild(element);\n        });\n    }\n\n    document.getElementById('startSort').onclick = function() {\n        if (sorted) {\n            alert('Array is already sorted. Generate a new array to sort again.');\n            return;\n        }\n        \n        currentIndex = 0;\n        sorted = false;\n        clearInterval(intervalId);\n        \n        intervalId = setInterval(bubbleSortStep, 1000);\n    }\n\n    document.getElementById('stopSort').onclick = function() {\n        clearInterval(intervalId);\n        alert('Sorting stopped.');\n    }\n\n    function bubbleSortStep() {\n        if (currentIndex >= array.length - 1) {\n            if (sorted) {\n                clearInterval(intervalId);\n                alert('Sorting complete!');\n                return;\n            }\n            currentIndex = 0;\n            sorted = true;\n        }\n\n        const arrayDisplayElements = document.querySelectorAll('.element');\n        for (let j = 0; j < array.length - 1 - currentIndex; j++) {\n            if (array[j] > array[j + 1]) {\n                // Swap elements\n                const temp = array[j];\n                array[j] = array[j + 1];\n                array[j + 1] = temp;\n                sorted = false;\n            }\n            // Update displayed array\n            arrayDisplayElements[j].textContent = array[j];\n            arrayDisplayElements[j + 1].textContent = array[j + 1];\n        }\n\n        currentIndex++;\n    }\n</script>\n\n</body>\n</html>"
