    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin: 20px;\n        }\n        #canvas {\n            border: 1px solid black;\n            margin: 20px auto;\n            height: 400px;\n            width: 600px;\n        }\n        input {\n            width: 50px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree Visualization</h1>\n    <input type=\"number\" id=\"value\" placeholder=\"Enter value\" />\n    <button id=\"insertBtn\">Insert</button>\n    <button id=\"inorderBtn\">Inorder Traversal</button>\n    <div id=\"canvas\"></div>\n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        class BST {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(value) {\n                const newNode = new Node(value);\n                if (!this.root) {\n                    this.root = newNode;\n                } else {\n                    this.insertNode(this.root, newNode);\n                }\n            }\n\n            insertNode(node, newNode) {\n                if (newNode.value < node.value) {\n                    if (!node.left) {\n                        node.left = newNode;\n                    } else {\n                        this.insertNode(node.left, newNode);\n                    }\n                } else {\n                    if (!node.right) {\n                        node.right = newNode;\n                    } else {\n                        this.insertNode(node.right, newNode);\n                    }\n                }\n            }\n\n            inorderTraversal(node, result = []) {\n                if (node) {\n                    this.inorderTraversal(node.left, result);\n                    result.push(node.value);\n                    this.inorderTraversal(node.right, result);\n                }\n                return result;\n            }\n\n            draw(ctx, node, x, y, offset) {\n                if (node) {\n                    ctx.beginPath();\n                    ctx.arc(x, y, 20, 0, Math.PI * 2);\n                    ctx.fillStyle = \"skyblue\";\n                    ctx.fill();\n                    ctx.stroke();\n                    ctx.fillStyle = \"black\";\n                    ctx.fillText(node.value, x - 5, y + 5);\n\n                    if (node.left) {\n                        ctx.moveTo(x, y);\n                        ctx.lineTo(x - offset, y + 60);\n                        ctx.stroke();\n                        this.draw(ctx, node.left, x - offset, y + 60, offset / 2);\n                    }\n                    if (node.right) {\n                        ctx.moveTo(x, y);\n                        ctx.lineTo(x + offset, y + 60);\n                        ctx.stroke();\n                        this.draw(ctx, node.right, x + offset, y + 60, offset / 2);\n                    }\n                }\n            }\n        }\n\n        const bst = new BST();\n        const canvas = document.getElementById(\"canvas\");\n        const ctx = canvas.getContext(\"2d\");\n\n        document.getElementById(\"insertBtn\").onclick = () => {\n            const value = parseInt(document.getElementById(\"value\").value);\n            if (!isNaN(value)) {\n                bst.insert(value);\n                ctx.clearRect(0, 0, canvas.width, canvas.height);\n                bst.draw(ctx, bst.root, canvas.width / 2, 20, 200);\n                document.getElementById(\"value\").value = '';\n            }\n        };\n\n        document.getElementById(\"inorderBtn\").onclick = () => {\n            const result = bst.inorderTraversal(bst.root);\n            alert(\"Inorder Traversal: \" + result.join(', '));\n        };\n    </script>\n</body>\n</html>"
