    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin: 20px;\n        }\n        #bst {\n            margin-top: 20px;\n        }\n        .node {\n            display: inline-block;\n            width: 40px;\n            height: 40px;\n            line-height: 40px;\n            border: 2px solid #007BFF;\n            border-radius: 5px;\n            background-color: #E7F3FF;\n            position: relative;\n            font-size: 16px;\n        }\n        .branch {\n            position: absolute;\n            top: -20px;\n            left: 20px;\n            width: 1px;\n            height: 20px;\n            background: #007BFF;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Binary Search Tree (BST) Visualization</h1>\n<input type=\"number\" id=\"value-input\" placeholder=\"Enter a number\">\n<button onclick=\"insertValue()\">Insert</button>\n\n<div id=\"bst\"></div>\n\n<script>\n    class Node {\n        constructor(value) {\n            this.value = value;\n            this.left = null;\n            this.right = null;\n        }\n    }\n\n    class BST {\n        constructor() {\n            this.root = null;\n        }\n\n        insert(value) {\n            const newNode = new Node(value);\n            if (!this.root) {\n                this.root = newNode;\n                return;\n            }\n            this.insertNode(this.root, newNode);\n        }\n\n        insertNode(node, newNode) {\n            if (newNode.value < node.value) {\n                if (!node.left) {\n                    node.left = newNode;\n                } else {\n                    this.insertNode(node.left, newNode);\n                }\n            } else {\n                if (!node.right) {\n                    node.right = newNode;\n                } else {\n                    this.insertNode(node.right, newNode);\n                }\n            }\n        }\n\n        clear() {\n            this.root = null;\n        }\n\n        visualize() {\n            const bstDiv = document.getElementById('bst');\n            bstDiv.innerHTML = ''; // Clear previous visualization\n            if (!this.root) return;\n\n            this.visualizeNode(this.root, bstDiv, 0);\n        }\n\n        visualizeNode(node, parentDiv, level) {\n            if (!node) return;\n\n            const nodeDiv = document.createElement('div');\n            nodeDiv.className = 'node';\n            nodeDiv.innerText = node.value;\n            parentDiv.appendChild(nodeDiv);\n\n            const branch = document.createElement('div');\n            branch.className = 'branch';\n            nodeDiv.appendChild(branch);\n\n            const leftDiv = document.createElement('div');\n            const rightDiv = document.createElement('div');\n\n            if (node.left) {\n                this.visualizeNode(node.left, leftDiv, level + 1);\n                parentDiv.appendChild(leftDiv);\n            }\n\n            if (node.right) {\n                this.visualizeNode(node.right, rightDiv, level + 1);\n                parentDiv.appendChild(rightDiv);\n            }\n        }\n    }\n\n    const bst = new BST();\n\n    function insertValue() {\n        const valueInput = document.getElementById('value-input');\n        const value = parseInt(valueInput.value, 10);\n        if (!isNaN(value)) {\n            bst.insert(value);\n            bst.visualize();\n            valueInput.value = ''; // Clear input after insertion\n        } else {\n            alert('Please enter a valid number.');\n        }\n    }\n</script>\n\n</body>\n</html>"
