    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #tree {\n            margin: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree</h1>\n    <div id=\"tree\"></div>\n\n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        class BinarySearchTree {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(value) {\n                if (this.root === null) {\n                    this.root = new Node(value);\n                } else {\n                    this._insert(this.root, value);\n                }\n            }\n\n            _insert(node, value) {\n                if (value < node.value) {\n                    if (node.left === null) {\n                        node.left = new Node(value);\n                    } else {\n                        this._insert(node.left, value);\n                    }\n                } else {\n                    if (node.right === null) {\n                        node.right = new Node(value);\n                    } else {\n                        this._insert(node.right, value);\n                    }\n                }\n            }\n\n            inorder() {\n                if (this.root !== null) {\n                    this._inorder(this.root);\n                }\n            }\n\n            _inorder(node) {\n                if (node !== null) {\n                    this._inorder(node.left);\n                    document.getElementById(\"tree\").innerHTML += `<p>${node.value}</p>`;\n                    this._inorder(node.right);\n                }\n            }\n        }\n\n        let bst = new BinarySearchTree();\n        let values = [\"5\", \"2\", \"8\", \"3\", \"9\", \"1\", \"6\", \"7\", \"4\"];\n\n        for (let value of values) {\n            bst.insert(value);\n        }\n\n        bst.inorder();\n    </script>\n</body>\n</html>"
