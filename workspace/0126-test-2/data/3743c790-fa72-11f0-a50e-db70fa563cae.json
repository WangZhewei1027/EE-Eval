    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Color Mixer</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n            height: 100vh;\n            margin: 0;\n            background-color: #f0f0f0;\n        }\n        .container {\n            text-align: center;\n        }\n        .color-box {\n            width: 200px;\n            height: 200px;\n            margin: 20px;\n            border: 2px solid #000;\n            display: inline-block;\n        }\n        input[type=\"range\"] {\n            width: 300px;\n        }\n        input[type=\"number\"] {\n            width: 80px;\n            margin: 0 10px;\n        }\n        button {\n            margin: 5px;\n            padding: 10px 20px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"container\">\n    <h1>Interactive Color Mixer</h1>\n    <div>\n        <div class=\"color-box\" id=\"colorDisplay\" style=\"background-color: rgb(255, 255, 255);\"></div>\n    </div>\n    <div>\n        <label for=\"red\">Red:</label>\n        <input type=\"range\" id=\"red\" min=\"0\" max=\"255\" value=\"255\">\n        <input type=\"number\" id=\"redValue\" min=\"0\" max=\"255\" value=\"255\">\n\n        <label for=\"green\">Green:</label>\n        <input type=\"range\" id=\"green\" min=\"0\" max=\"255\" value=\"255\">\n        <input type=\"number\" id=\"greenValue\" min=\"0\" max=\"255\" value=\"255\">\n\n        <label for=\"blue\">Blue:</label>\n        <input type=\"range\" id=\"blue\" min=\"0\" max=\"255\" value=\"255\">\n        <input type=\"number\" id=\"blueValue\" min=\"0\" max=\"255\" value=\"255\">\n    </div>\n    <button id=\"reset\">Reset Colors</button>\n    <p></p>\n    <div>\n        <button id=\"darken\">Darken</button>\n        <button id=\"lighten\">Lighten</button>\n    </div>\n</div>\n\n<script>\n    const redSlider = document.getElementById('red');\n    const greenSlider = document.getElementById('green');\n    const blueSlider = document.getElementById('blue');\n\n    const redValue = document.getElementById('redValue');\n    const greenValue = document.getElementById('greenValue');\n    const blueValue = document.getElementById('blueValue');\n\n    const colorDisplay = document.getElementById('colorDisplay');\n    const resetButton = document.getElementById('reset');\n    const darkenButton = document.getElementById('darken');\n    const lightenButton = document.getElementById('lighten');\n\n    function updateColor() {\n        const r = redSlider.value;\n        const g = greenSlider.value;\n        const b = blueSlider.value;\n\n        colorDisplay.style.backgroundColor = `rgb(${r}, ${g}, ${b})`;\n        redValue.value = r;\n        greenValue.value = g;\n        blueValue.value = b;\n    }\n\n    redSlider.addEventListener('input', updateColor);\n    greenSlider.addEventListener('input', updateColor);\n    blueSlider.addEventListener('input', updateColor);\n\n    redValue.addEventListener('input', () => {\n        redSlider.value = redValue.value;\n        updateColor();\n    });\n    greenValue.addEventListener('input', () => {\n        greenSlider.value = greenValue.value;\n        updateColor();\n    });\n    blueValue.addEventListener('input', () => {\n        blueSlider.value = blueValue.value;\n        updateColor();\n    });\n\n    resetButton.addEventListener('click', () => {\n        redSlider.value = 255;\n        greenSlider.value = 255;\n        blueSlider.value = 255;\n        updateColor();\n    });\n\n    const adjustColor = (direction) => {\n        const r = parseInt(redSlider.value);\n        const g = parseInt(greenSlider.value);\n        const b = parseInt(blueSlider.value);\n        const adjustment = direction === 'darken' ? -30 : 30;\n\n        redSlider.value = Math.min(255, Math.max(0, r + adjustment));\n        greenSlider.value = Math.min(255, Math.max(0, g + adjustment));\n        blueSlider.value = Math.min(255, Math.max(0, b + adjustment));\n        updateColor();\n    };\n\n    darkenButton.addEventListener('click', () => adjustColor('darken'));\n    lightenButton.addEventListener('click', () => adjustColor('lighten'));\n\n    // Initial color\n    updateColor();\n</script>\n\n</body>\n</html>"
