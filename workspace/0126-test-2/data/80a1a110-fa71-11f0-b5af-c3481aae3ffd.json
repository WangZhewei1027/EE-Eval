    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree Interactive Demo</title>\n    <style>\n        body { font-family: monospace; }\n        input, button { margin: 5px; }\n        #tree { margin-top: 20px; }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree Interactive Demo</h1>\n    <div>\n        <label for=\"node-input\">Enter a value to insert:</label>\n        <input type=\"number\" id=\"node-input\" />\n        <button id=\"insert-btn\">Insert</button>\n        \n        <button id=\"min-btn\">Find Minimum</button>\n        <button id=\"max-btn\">Find Maximum</button>\n        <button id=\"inorder-btn\">In-order Traversal</button>\n        <button id=\"preorder-btn\">Pre-order Traversal</button>\n        <button id=\"postorder-btn\">Post-order Traversal</button>\n        \n        <label for=\"delete-input\">Enter a value to delete:</label>\n        <input type=\"number\" id=\"delete-input\" />\n        <button id=\"delete-btn\">Delete</button>\n\n        <label for=\"search-input\">Enter a value to search:</label>\n        <input type=\"number\" id=\"search-input\" />\n        <button id=\"search-btn\">Search</button>\n    </div>\n\n    <div id=\"tree\"></div>\n    \n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        class BinarySearchTree {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(value) {\n                const newNode = new Node(value);\n                if (!this.root) {\n                    this.root = newNode;\n                    return;\n                }\n                this._insertNode(this.root, newNode);\n            }\n\n            _insertNode(node, newNode) {\n                if (newNode.value < node.value) {\n                    if (!node.left) {\n                        node.left = newNode;\n                    } else {\n                        this._insertNode(node.left, newNode);\n                    }\n                } else {\n                    if (!node.right) {\n                        node.right = newNode;\n                    } else {\n                        this._insertNode(node.right, newNode);\n                    }\n                }\n            }\n\n            findMin(node) {\n                while (node && node.left) {\n                    node = node.left;\n                }\n                return node;\n            }\n\n            findMax(node) {\n                while (node && node.right) {\n                    node = node.right;\n                }\n                return node;\n            }\n\n            inorder(node, arr = []) {\n                if (node) {\n                    this.inorder(node.left, arr);\n                    arr.push(node.value);\n                    this.inorder(node.right, arr);\n                }\n                return arr;\n            }\n\n            preorder(node, arr = []) {\n                if (node) {\n                    arr.push(node.value);\n                    this.preorder(node.left, arr);\n                    this.preorder(node.right, arr);\n                }\n                return arr;\n            }\n\n            postorder(node, arr = []) {\n                if (node) {\n                    this.postorder(node.left, arr);\n                    this.postorder(node.right, arr);\n                    arr.push(node.value);\n                }\n                return arr;\n            }\n\n            delete(value) {\n                this.root = this._deleteNode(this.root, value);\n            }\n\n            _deleteNode(node, value) {\n                if (!node) return node;\n                if (value < node.value) {\n                    node.left = this._deleteNode(node.left, value);\n                } else if (value > node.value) {\n                    node.right = this._deleteNode(node.right, value);\n                } else {\n                    if (!node.left && !node.right) return null;\n                    if (!node.left) return node.right;\n                    if (!node.right) return node.left;\n\n                    const minNode = this.findMin(node.right);\n                    node.value = minNode.value;\n                    node.right = this._deleteNode(node.right, minNode.value);\n                }\n                return node;\n            }\n        }\n\n        const bst = new BinarySearchTree();\n\n        document.getElementById('insert-btn').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('node-input').value);\n            if (!isNaN(value)) {\n                bst.insert(value);\n                document.getElementById('node-input').value = '';\n                drawTree();\n            }\n        });\n\n        document.getElementById('min-btn').addEventListener('click', () => {\n            const minNode = bst.findMin(bst.root);\n            alert(minNode ? `Minimum value: ${minNode.value}` : 'Tree is empty');\n        });\n\n        document.getElementById('max-btn').addEventListener('click', () => {\n            const maxNode = bst.findMax(bst.root);\n            alert(maxNode ? `Maximum value: ${maxNode.value}` : 'Tree is empty');\n        });\n\n        document.getElementById('inorder-btn').addEventListener('click', () => {\n            alert(`In-order Traversal: ${bst.inorder(bst.root).join(', ')}`);\n        });\n\n        document.getElementById('preorder-btn').addEventListener('click', () => {\n            alert(`Pre-order Traversal: ${bst.preorder(bst.root).join(', ')}`);\n        });\n\n        document.getElementById('postorder-btn').addEventListener('click', () => {\n            alert(`Post-order Traversal: ${bst.postorder(bst.root).join(', ')}`);\n        });\n\n        document.getElementById('delete-btn').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('delete-input').value);\n            if (!isNaN(value)) {\n                bst.delete(value);\n                document.getElementById('delete-input').value = '';\n                drawTree();\n            }\n        });\n\n        document.getElementById('search-btn').addEventListener('click', () => {\n            const value = parseInt(document.getElementById('search-input').value);\n            if (!isNaN(value)) {\n                const found = search(bst.root, value);\n                alert(found ? `Value ${value} found` : `Value ${value} not found`);\n            }\n        });\n\n        function search(node, value) {\n            if (!node) return false;\n            if (value === node.value) return true;\n            return value < node.value ? search(node.left, value) : search(node.right, value);\n        }\n\n        function drawTree() {\n            const treeDiv = document.getElementById('tree');\n            treeDiv.innerHTML = JSON.stringify(bst.root, null, 2).replace(/\\,/g, ',<br>').replace(/\\{/g, '{<br>').replace(/\\}/g, '<br>}');\n        }\n    </script>\n</body>\n</html>"
