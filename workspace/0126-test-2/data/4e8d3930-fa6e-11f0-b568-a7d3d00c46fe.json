    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree Visualization</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #bst-container { margin: 20px; }\n        .node { display: inline-block; margin: 10px; padding: 10px; border: 1px solid #000; border-radius: 5px; }\n        .line { position: absolute; width: 2px; background: #000; }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree Visualization</h1>\n    <div id=\"bst-container\"></div>\n    <input type=\"number\" id=\"value\" placeholder=\"Enter a number\" />\n    <button onclick=\"insertNode()\">Insert Node</button>\n    <script>\n        class Node {\n            constructor(data) {\n                this.data = data;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        class BST {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(data) {\n                let newNode = new Node(data);\n                if (!this.root) {\n                    this.root = newNode;\n                } else {\n                    this.insertNode(this.root, newNode);\n                }\n                this.draw();\n            }\n\n            insertNode(node, newNode) {\n                if (newNode.data < node.data) {\n                    if (node.left === null) {\n                        node.left = newNode;\n                    } else {\n                        this.insertNode(node.left, newNode);\n                    }\n                } else {\n                    if (node.right === null) {\n                        node.right = newNode;\n                    } else {\n                        this.insertNode(node.right, newNode);\n                    }\n                }\n            }\n\n            draw() {\n                const container = document.getElementById('bst-container');\n                container.innerHTML = ''; // Clear previous drawing\n                this.drawNode(this.root, container, window.innerWidth / 2, 20, 100);\n            }\n\n            drawNode(node, container, x, y, offset) {\n                if (node) {\n                    const nodeDiv = document.createElement(\"div\");\n                    nodeDiv.className = \"node\";\n                    nodeDiv.textContent = node.data;\n                    nodeDiv.style.position = 'absolute';\n                    nodeDiv.style.left = `${x}px`;\n                    nodeDiv.style.top = `${y}px`;\n                    container.appendChild(nodeDiv);\n\n                    if (node.left) {\n                        const leftX = x - offset;\n                        const leftY = y + 50;\n                        this.drawLine(x + 15, y + 30, leftX + 15, leftY);\n                        this.drawNode(node.left, container, leftX, leftY, offset / 2);\n                    }\n\n                    if (node.right) {\n                        const rightX = x + offset;\n                        const rightY = y + 50;\n                        this.drawLine(x + 15, y + 30, rightX + 15, rightY);\n                        this.drawNode(node.right, container, rightX, rightY, offset / 2);\n                    }\n                }\n            }\n\n            drawLine(x1, y1, x2, y2) {\n                const line = document.createElement(\"div\");\n                line.className = 'line';\n                const deltaX = x2 - x1;\n                const deltaY = y2 - y1;\n                const length = Math.sqrt(deltaX * deltaX + deltaY * deltaY);\n                line.style.height = `${length}px`;\n                line.style.transformOrigin = '0 0';\n                line.style.transform = `rotate(${Math.atan2(deltaY, deltaX)}rad)`;\n                line.style.left = `${x1}px`;\n                line.style.top = `${y1}px`;\n                document.getElementById('bst-container').appendChild(line);\n            }\n        }\n\n        const bst = new BST();\n\n        function insertNode() {\n            const valueInput = document.getElementById('value');\n            const value = parseInt(valueInput.value);\n            if (!isNaN(value)) {\n                bst.insert(value);\n                valueInput.value = '';\n            }\n        }\n    </script>\n</body>\n</html>"
