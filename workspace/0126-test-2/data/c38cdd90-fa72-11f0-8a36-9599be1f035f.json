    "content": "<html>\n<head>\n    <title>Bubble Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>Bubble Sort</h1>\n    <p>Original List: <pre>{{originalList}}</pre></p>\n    <button id=\"sort-button\">Sort</button>\n    <script>\n        const originalList = ['dog', 'cat', 'apple', 'banana', 'elephant'];\n        let swapped = true;\n\n        function bubbleSort(arr) {\n            while (swapped) {\n                swapped = false;\n                for (let i = 0; i < arr.length - 1; i++) {\n                    if (arr[i] > arr[i + 1]) {\n                        [arr[i], arr[i + 1]] = [arr[i + 1], arr[i]];\n                        swapped = true;\n                    }\n                }\n            }\n        }\n\n        document.getElementById('sort-button').addEventListener('click', () => {\n            bubbleSort(originalList);\n            console.log('Sorted List:', originalList);\n        });\n    </script>\n</body>\n</html>"
