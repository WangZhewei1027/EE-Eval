    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Topological Sort Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f8f9fa;\n            margin: 0;\n            padding: 20px;\n        }\n        h1 {\n            color: #343a40;\n        }\n        #graph {\n            margin: 20px 0;\n        }\n        #result {\n            margin-top: 20px;\n            padding: 10px;\n            background-color: #e9ecef;\n            border: 1px solid #ced4da;\n        }\n    </style>\n</head>\n<body>\n    <h1>Topological Sort Demonstration</h1>\n    <p>Input the edges of the directed graph below (format: start-end, e.g., A-B). Type \"done\" when you are finished:</p>\n    <textarea id=\"edgesInput\" rows=\"5\" style=\"width: 100%;\"></textarea>\n    <button id=\"sortButton\">Perform Topological Sort</button>\n    \n    <div id=\"result\"></div>\n\n    <script>\n        document.getElementById('sortButton').addEventListener('click', function() {\n            const edgesInput = document.getElementById('edgesInput').value.trim();\n            const edges = edgesInput.split('\\n').filter(edge => edge.trim() && edge !== 'done');\n            const adjacencyList = {};\n\n            // Build the adjacency list\n            edges.forEach(edge => {\n                const [start, end] = edge.split('-').map(e => e.trim());\n                if (!adjacencyList[start]) adjacencyList[start] = [];\n                if (!adjacencyList[end]) adjacencyList[end] = [];\n                adjacencyList[start].push(end);\n            });\n\n            const visited = {};\n            const stack = [];\n\n            function topologicalSortUtil(v) {\n                visited[v] = true;\n                if (adjacencyList[v]) {\n                    adjacencyList[v].forEach(neighbor => {\n                        if (!visited[neighbor]) {\n                            topologicalSortUtil(neighbor);\n                        }\n                    });\n                }\n                stack.push(v);\n            }\n\n            // Call the topological sort function for each vertex\n            Object.keys(adjacencyList).forEach(vertex => {\n                if (!visited[vertex]) {\n                    topologicalSortUtil(vertex);\n                }\n            });\n\n            const sortedOrder = stack.reverse().join(' -> ');\n            document.getElementById('result').innerText = `Topological Sort Order: ${sortedOrder}`;\n        });\n    </script>\n</body>\n</html>"
