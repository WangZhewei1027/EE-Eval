    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>B-Tree Visualization and Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 0; padding: 0;\n      display: flex;\n      flex-direction: column;\n      height: 100vh;\n      overflow: hidden;\n    }\n    header {\n      background-color: #004080;\n      color: white;\n      padding: 1rem;\n      text-align: center;\n    }\n    #container {\n      display: flex;\n      flex-direction: row;\n      flex: 1;\n      overflow: hidden;\n    }\n    #controls {\n      width: 300px;\n      background: #f5f5f5;\n      border-right: 1px solid #ccc;\n      padding: 1rem;\n      box-sizing: border-box;\n      overflow-y: auto;\n    }\n    #output {\n      flex: 1;\n      background: white;\n      position: relative;\n    }\n    #canvas {\n      width: 100%;\n      height: 100%;\n      display: block;\n      background: #fffefa;\n    }\n    h2 {\n      margin-top: 0;\n    }\n    label {\n      display: block;\n      margin-top: 1rem;\n      font-weight: bold;\n    }\n    input[type=\"number\"], input[type=\"text\"] {\n      width: 100%;\n      box-sizing: border-box;\n      font-size: 1rem;\n      padding: 0.3rem;\n      margin-top: 0.3rem;\n    }\n    button {\n      margin-top: 1rem;\n      padding: 0.5rem 1rem;\n      font-size: 1rem;\n      background-color: #004080;\n      color: white;\n      border: none;\n      cursor: pointer;\n      border-radius: 3px;\n    }\n    button:disabled {\n      background-color: #888;\n      cursor: not-allowed;\n    }\n    #log {\n      margin-top: 1rem;\n      height: 150px;\n      overflow-y: auto;\n      background: #222;\n      color: #eee;\n      font-family: monospace;\n      font-size: 0.9rem;\n      padding: 0.5rem;\n      border-radius: 4px;\n      white-space: pre-wrap;\n    }\n\n    #help {\n      margin-top: 1rem;\n      font-size: 0.9rem;\n      color: #555;\n      line-height: 1.4;\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>B-Tree Visualization and Demo</h1>\n    <div>Demonstration of the B-Tree Data Structure (Balanced Tree for databases and filesystems)</div>\n  </header>\n  <div id=\"container\">\n    <div id=\"controls\">\n      <h2>Settings & Controls</h2>\n      <label for=\"order\">Order of B-Tree (t):</label>\n      <input type=\"number\" id=\"order\" min=\"2\" max=\"6\" value=\"3\" />\n      <small>(Minimum degree t ≥ 2, max 6 to keep visualization manageable)</small>\n\n      <label for=\"insertKey\">Insert Key:</label>\n      <input type=\"number\" id=\"insertKey\" />\n      <button id=\"btnInsert\">Insert Key</button>\n\n      <label for=\"searchKey\">Search Key:</label>\n      <input type=\"number\" id=\"searchKey\" />\n      <button id=\"btnSearch\">Search</button>\n\n      <label for=\"deleteKey\">Delete Key:</label>\n      <input type=\"number\" id=\"deleteKey\" />\n      <button id=\"btnDelete\">Delete Key</button>\n\n      <button id=\"btnReset\" style=\"margin-top:2rem; background:#a00;\">Reset Tree</button>\n\n      <div id=\"help\">\n        <strong>About B-Tree:</strong><br/>\n        A B-tree of order <em>t</em> is a self-balancing tree data structure that maintains sorted data and allows searches, sequential access, insertions, and deletions in logarithmic time.<br/><br/>\n        <strong>Nodes:</strong> Each node can have between <em>t-1</em> and <em>2t - 1</em> keys.<br/>\n        <strong>Children:</strong> Each internal node can have from <em>t</em> to <em>2t</em> children.<br/>\n        <strong>Root:</strong> The root may have fewer than <em>t-1</em> keys.<br/>\n      </div>\n\n      <div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n    </div>\n    <div id=\"output\">\n      <canvas id=\"canvas\"></canvas>\n    </div>\n  </div>\n\n  <script>\n    /*\n      B-Tree implementation in JS with visual demonstration.\n      Features:\n      - Insert key\n      - Search key (highlights node)\n      - Delete key\n      - Reset tree with chosen order (minimum degree t)\n      Visualization shows nodes with keys in rectangles connected by lines.\n    */\n\n    // BTree Node Class\n    class BTreeNode {\n      constructor(t, leaf) {\n        this.t = t;              // minimum degree\n        this.leaf = leaf;        // boolean, true if leaf node\n        this.keys = [];          // array of keys\n        this.children = [];      // array of child pointers\n      }\n\n      // Insert a key in this node - only when this node is not full\n      insertNonFull(k, logger) {\n        let i = this.keys.length - 1;\n        if (this.leaf) {\n          // Insert the new key into the correct location in this.keys\n          while (i >= 0 && this.keys[i] > k) {\n            i--;\n          }\n          this.keys.splice(i + 1, 0, k);\n          logger(`Inserted key ${k} in leaf node [${this.keys.join(', ')}]`);\n        } else {\n          // Move to the appropriate child\n          while (i >= 0 && this.keys[i] > k) {\n            i--;\n          }\n          i++;\n          logger(`Traverse child at index ${i} for key ${k}`);\n\n          if (this.children[i].keys.length === 2 * this.t - 1) {\n            logger(`Child at index ${i} is full, splitting...`);\n            this.splitChild(i, logger);\n            if (this.keys[i] < k) {\n              i++;\n            }\n          }\n          this.children[i].insertNonFull(k, logger);\n        }\n      }\n\n      // Split the child y of this node at index i\n      splitChild(i, logger) {\n        let y = this.children[i];\n        let t = this.t;\n        let z = new BTreeNode(t, y.leaf);\n        logger(`Splitting node with keys [${y.keys.join(', ')}]`);\n\n        // z takes t-1 keys from y\n        z.keys = y.keys.splice(t, t - 1);\n\n        // If y is not leaf, move half children to z\n        if (!y.leaf) {\n          z.children = y.children.splice(t, t);\n        }\n\n        // Insert new child z to this node\n        this.children.splice(i + 1, 0, z);\n\n        // Move middle key of y to this node\n        let midKey = y.keys.splice(t - 1, 1)[0];\n        this.keys.splice(i, 0, midKey);\n\n        logger(`Split done. Parent keys now: [${this.keys.join(', ')}]`);\n      }\n\n      // Search a key k in the subtree rooted with this node\n      search(k) {\n        let i = 0;\n        while (i < this.keys.length && k > this.keys[i]) {\n          i++;\n        }\n\n        if (i < this.keys.length && this.keys[i] === k) {\n          return {node: this, index: i};\n        }\n        if (this.leaf) {\n          return null;\n        } else {\n          return this.children[i].search(k);\n        }\n      }\n\n      // Remove key k from the subtree rooted with this node\n      // This method assumes the key exists in the tree rooted with this node.\n      remove(k, logger) {\n        let t = this.t;\n        let idx = this.findKey(k);\n\n        if (idx < this.keys.length && this.keys[idx] === k) {\n          // Key found in this node\n          if (this.leaf) {\n            // Case 1: node is leaf, remove key directly\n            logger(`Removing key ${k} from leaf node [${this.keys.join(', ')}]`);\n            this.keys.splice(idx, 1);\n          } else {\n            // Case 2: internal node\n            logger(`Removing key ${k} from internal node [${this.keys.join(', ')}]`);\n            this.removeFromNonLeaf(idx, logger);\n          }\n        } else {\n          // Key not found in this node\n          if (this.leaf) {\n            logger(`Key ${k} is not present in the tree.`);\n            return; // The key is not in the tree\n          }\n          // Flag to indicate if last child contains key\n          let flag = (idx === this.keys.length);\n\n          // If the child where key is supposed to exist has less than t keys, fill it\n          if (this.children[idx].keys.length < t) {\n            this.fill(idx, logger);\n          }\n\n          // After filling, descend to appropriate child to continue removing\n          if (flag && idx > this.keys.length) {\n            this.children[idx - 1].remove(k, logger);\n          } else {\n            this.children[idx].remove(k, logger);\n          }\n        }\n      }\n\n      findKey(k) {\n        let idx = 0;\n        while (idx < this.keys.length && this.keys[idx] < k) {\n          idx++;\n        }\n        return idx;\n      }\n\n      removeFromNonLeaf(idx, logger) {\n        let k = this.keys[idx];\n        let t = this.t;\n\n        // Case 2a: The child that precedes k (children[idx]) has at least t keys\n        if (this.children[idx].keys.length >= t) {\n          let pred = this.getPred(idx);\n          logger(`Replacing key ${k} with predecessor ${pred}`);\n          this.keys[idx] = pred;\n          this.children[idx].remove(pred, logger);\n        }\n        // Case 2b: The child that succeeds k (children[idx+1]) has at least t keys\n        else if (this.children[idx + 1].keys.length >= t) {\n          let succ = this.getSucc(idx);\n          logger(`Replacing key ${k} with successor ${succ}`);\n          this.keys[idx] = succ;\n          this.children[idx + 1].remove(succ, logger);\n        }\n        // Case 2c: Both children[idx] and children[idx+1] have less than t keys\n        else {\n          logger(`Merging keys and children around key ${k}`);\n          this.merge(idx, logger);\n          this.children[idx].remove(k, logger);\n        }\n      }\n\n      getPred(idx) {\n        // Keep moving to the rightmost child until we reach leaf\n        let cur = this.children[idx];\n        while (!cur.leaf) {\n          cur = cur.children[cur.keys.length];\n        }\n        return cur.keys[cur.keys.length - 1];\n      }\n\n      getSucc(idx) {\n        // Keep moving to the leftmost child until we reach leaf\n        let cur = this.children[idx + 1];\n        while (!cur.leaf) {\n          cur = cur.children[0];\n        }\n        return cur.keys[0];\n      }\n\n      fill(idx, logger) {\n        let t = this.t;\n        if (idx !== 0 && this.children[idx - 1].keys.length >= t) {\n          this.borrowFromPrev(idx, logger);\n        } else if (idx !== this.keys.length && this.children[idx + 1].keys.length >= t) {\n          this.borrowFromNext(idx, logger);\n        } else {\n          if (idx !== this.keys.length) {\n            this.merge(idx, logger);\n          } else {\n            this.merge(idx - 1, logger);\n          }\n        }\n      }\n\n      borrowFromPrev(idx, logger) {\n        let child = this.children[idx];\n        let sibling = this.children[idx - 1];\n\n        // Moving keys in child forward\n        child.keys.unshift(this.keys[idx - 1]);\n\n        if (!child.leaf) {\n          child.children.unshift(sibling.children.pop());\n        }\n\n        this.keys[idx - 1] = sibling.keys.pop();\n\n        logger(`Borrowed key from previous sibling at index ${idx - 1}`);\n      }\n\n      borrowFromNext(idx, logger) {\n        let child = this.children[idx];\n        let sibling = this.children[idx + 1];\n\n        child.keys.push(this.keys[idx]);\n\n        if (!child.leaf) {\n          child.children.push(sibling.children.shift());\n        }\n\n        this.keys[idx] = sibling.keys.shift();\n\n        logger(`Borrowed key from next sibling at index ${idx + 1}`);\n      }\n\n      merge(idx, logger) {\n        let child = this.children[idx];\n        let sibling = this.children[idx + 1];\n        let t = this.t;\n\n        // Pull key from this node down and append to child keys\n        child.keys.push(this.keys[idx]);\n\n        // Append sibling's keys and children to child\n        child.keys = child.keys.concat(sibling.keys);\n        if (!child.leaf) {\n          child.children = child.children.concat(sibling.children);\n        }\n\n        // Remove the key and the child pointer from this node\n        this.keys.splice(idx, 1);\n        this.children.splice(idx + 1, 1);\n\n        logger(`Merged nodes at index ${idx} and ${idx + 1}`);\n      }\n    }\n\n    // B Tree class\n    class BTree {\n      constructor(t, logger) {\n        this.t = t; \n        this.root = null;\n        this.logger = logger || function() {};\n      }\n\n      search(k) {\n        if (!this.root) return null;\n        return this.root.search(k);\n      }\n\n      insert(k) {\n        if (!this.root) {\n          this.root = new BTreeNode(this.t, true);\n          this.root.keys.push(k);\n          this.logger(`Created root and inserted key ${k}`);\n          return;\n        }\n\n        if (this.root.keys.length === 2 * this.t - 1) {\n          // Root full, tree grows in height\n          let s = new BTreeNode(this.t, false);\n          s.children.push(this.root);\n          this.logger(`Root full. Splitting root...`);\n          s.splitChild(0, this.logger);\n          let i = 0;\n          if (s.keys[0] < k) {\n            i++;\n          }\n          s.children[i].insertNonFull(k, this.logger);\n          this.root = s;\n          this.logger(`New root keys: [${this.root.keys.join(', ')}]`);\n        } else {\n          this.root.insertNonFull(k, this.logger);\n        }\n      }\n\n      remove(k) {\n        if (!this.root) {\n          this.logger(\"The tree is empty\");\n          return;\n        }\n        this.root.remove(k, this.logger);\n        // If root's keys count is 0, make child new root\n        if (this.root.keys.length === 0) {\n          if (this.root.leaf) {\n            this.root = null;\n          } else {\n            this.root = this.root.children[0];\n            this.logger(`Root replaced by child after removal`);\n          }\n        }\n      }\n    }\n\n    /*** Visualization and UI Logic ***/\n    (function() {\n      const canvas = document.getElementById(\"canvas\");\n      const ctx = canvas.getContext(\"2d\");\n\n      let logElem = document.getElementById(\"log\");\n      function logger(msg) {\n        const now = new Date().toLocaleTimeString();\n        logElem.textContent += `[${now}] ${msg}\\n`;\n        logElem.scrollTop = logElem.scrollHeight;\n      }\n\n      const orderInput = document.getElementById(\"order\");\n      const insertKeyInput = document.getElementById(\"insertKey\");\n      const btnInsert = document.getElementById(\"btnInsert\");\n      const searchKeyInput = document.getElementById(\"searchKey\");\n      const btnSearch = document.getElementById(\"btnSearch\");\n      const deleteKeyInput = document.getElementById(\"deleteKey\");\n      const btnDelete = document.getElementById(\"btnDelete\");\n      const btnReset = document.getElementById(\"btnReset\");\n\n      let btree = null;\n      let highlight = null; // {node, index} or null\n      let canvasWidth, canvasHeight;\n\n      // Responsive canvas size\n      function resizeCanvas() {\n        canvasWidth = canvas.clientWidth * devicePixelRatio;\n        canvasHeight = canvas.clientHeight * devicePixelRatio;\n        canvas.width = canvasWidth;\n        canvas.height = canvasHeight;\n        ctx.setTransform(1, 0, 0, 1, 0, 0); // reset transform\n        ctx.scale(devicePixelRatio, devicePixelRatio);\n        draw();\n      }\n      window.addEventListener(\"resize\", resizeCanvas);\n\n      // Draw BTree recursively\n      function drawNode(node, x, y, levelSpacing, siblingSpacing) {\n        if (!node) return;\n\n        const keyCount = node.keys.length;\n        const keyWidth = 35;\n        const keyHeight = 30;\n        const nodeWidth = keyCount * keyWidth + (keyCount - 1) * 5 + 10;\n        const nodeHeight = keyHeight + 10;\n\n        // Draw node background rect\n        ctx.fillStyle = node.leaf ? \"#d0e7ff\" : \"#bbe0ff\";\n        ctx.strokeStyle = \"black\";\n        ctx.lineWidth = 1;\n        ctx.fillRect(x, y, nodeWidth, nodeHeight);\n        ctx.strokeRect(x, y, nodeWidth, nodeHeight);\n\n        // Draw keys\n        for (let i = 0; i < keyCount; i++) {\n          let keyX = x + 5 + i * (keyWidth + 5);\n          let keyY = y + 5;\n          const isHighlighted = highlight && highlight.node === node && highlight.index === i;\n\n          ctx.fillStyle = isHighlighted ? \"#ffcc00\" : \"#f0f8ff\";\n          ctx.strokeStyle = isHighlighted ? \"#cc6600\" : \"#333\";\n          ctx.lineWidth = isHighlighted ? 2 : 1;\n          ctx.fillRect(keyX, keyY, keyWidth, keyHeight);\n          ctx.strokeRect(keyX, keyY, keyWidth, keyHeight);\n\n          ctx.fillStyle = \"black\";\n          ctx.font = \"bold 16px monospace\";\n          ctx.textAlign = \"center\";\n          ctx.textBaseline = \"middle\";\n          ctx.fillText(node.keys[i], keyX + keyWidth / 2, keyY + keyHeight / 2);\n        }\n\n        // If leaf, no children\n        if (node.leaf) {\n          return nodeWidth;\n        }\n\n        // Calculate total width of children subtree\n        let childrenWidths = node.children.map(child => measureSubtreeWidth(child, levelSpacing, siblingSpacing));\n        let totalWidth = childrenWidths.reduce((a,b)=>a+b, 0) + siblingSpacing*(childrenWidths.length - 1);\n\n        // Center child nodes horizontally under this node keys\n        let childX = x + (nodeWidth / 2) - (totalWidth / 2);\n        let childY = y + nodeHeight + levelSpacing;\n\n        // Draw lines to children\n        // Connect from bottom center of node rectangle to top center of child\n        for (let i = 0; i < node.children.length; i++) {\n          let childWidth = childrenWidths[i];\n          let parentLineX = x + nodeWidth / 2;\n          let childLineX = childX + childWidth / 2;\n          ctx.strokeStyle = \"#555\";\n          ctx.lineWidth = 1;\n          ctx.beginPath();\n          ctx.moveTo(parentLineX, y + nodeHeight);\n          ctx.lineTo(childLineX, childY);\n          ctx.stroke();\n          childX += childWidth + siblingSpacing;\n        }\n\n        // Draw children recursively\n        childX = x + (nodeWidth / 2) - (totalWidth / 2);\n        for (let i = 0; i < node.children.length; i++) {\n          let w = drawNode(node.children[i], childX, childY, levelSpacing, siblingSpacing);\n          childX += w + siblingSpacing;\n        }\n\n        return Math.max(nodeWidth, totalWidth);\n      }\n\n      function measureSubtreeWidth(node, levelSpacing, siblingSpacing) {\n        if (node.leaf) {\n          const keyCount = node.keys.length;\n          const keyWidth = 35;\n          const nodeWidth = keyCount * keyWidth + (keyCount - 1) * 5 + 10;\n          return nodeWidth;\n        }\n        let childrenWidths = node.children.map(child => measureSubtreeWidth(child, levelSpacing, siblingSpacing));\n        let totalWidth = childrenWidths.reduce((a,b)=>a+b, 0) + siblingSpacing*(childrenWidths.length - 1);\n        const keyWidth = 35;\n        const keyCount = node.keys.length;\n        const nodeWidth = keyCount * keyWidth + (keyCount - 1) * 5 + 10;\n        return Math.max(nodeWidth, totalWidth);\n      }\n\n      function draw() {\n        // Clear\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n        if (!btree || !btree.root) {\n          ctx.fillStyle = \"#888\";\n          ctx.font = \"20px Arial\";\n          ctx.textAlign = \"center\";\n          ctx.fillText(\"B-Tree is empty. Insert keys to begin.\", canvas.clientWidth/2, canvas.clientHeight/2);\n          return;\n        }\n        drawNode(btree.root, 20, 20, 60, 20);\n      }\n\n      // UI event handlers\n      btnInsert.addEventListener(\"click\", () => {\n        const k = parseInt(insertKeyInput.value);\n        if (isNaN(k)) {\n          alert(\"Please enter a valid number to insert.\");\n          return;\n        }\n        if (!btree) {\n          initTree();\n        }\n        highlight = null;\n        logger(`Inserting key ${k}...`);\n        btree.insert(k);\n        draw();\n      });\n\n      btnSearch.addEventListener(\"click\", () => {\n        const k = parseInt(searchKeyInput.value);\n        if (isNaN(k)) {\n          alert(\"Please enter a valid number to search.\");\n          return;\n        }\n        if (!btree || !btree.root) {\n          alert(\"The tree is empty.\");\n          return;\n        }\n        logger(`Searching for key ${k}...`);\n        const res = btree.search(k);\n        if (res) {\n          highlight = res;\n          logger(`Key ${k} found in node with keys [${res.node.keys.join(', ')}]`);\n        } else {\n          highlight = null;\n          logger(`Key ${k} not found in the tree.`);\n          alert(\"Key not found.\");\n        }\n        draw();\n      });\n\n      btnDelete.addEventListener(\"click\", () => {\n        const k = parseInt(deleteKeyInput.value);\n        if (isNaN(k)) {\n          alert(\"Please enter a valid number to delete.\");\n          return;\n        }\n        if (!btree || !btree.root) {\n          alert(\"The tree is empty.\");\n          return;\n        }\n        highlight = null;\n        logger(`Deleting key ${k}...`);\n        btree.remove(k);\n        draw();\n      });\n\n      btnReset.addEventListener(\"click\", () => {\n        initTree();\n      });\n\n      orderInput.addEventListener(\"change\", () => {\n        let val = parseInt(orderInput.value);\n        if (val < 2) {\n          orderInput.value = 2;\n          alert(\"Order (minimum degree) must be at least 2.\");\n        }\n      });\n\n      function initTree() {\n        logElem.textContent = \"\";\n        const order = parseInt(orderInput.value);\n        if (isNaN(order) || order < 2 || order > 6) {\n          alert(\"Order must be a number from 2 to 6.\");\n          return;\n        }\n        btree = new BTree(order, logger);\n        highlight = null;\n        logger(`Initialized empty B-Tree of order t = ${order}`);\n        draw();\n      }\n\n      // Initialize\n      resizeCanvas();\n      initTree();\n\n    })();\n  </script>\n</body>\n</html>"
