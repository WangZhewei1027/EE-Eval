    "content": "<html>\n<head>\n    <title>Linear Regression</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #graph {\n            width: 800px;\n            height: 600px;\n            border: 1px solid #ccc;\n        }\n    </style>\n</head>\n<body>\n    <h1>Linear Regression</h1>\n    <p>Linear Regression is a supervised learning algorithm used for predicting continuous output variables based on one or more predictor variables.</p>\n    <button id=\"load-data-btn\">Load Data</button>\n    <button id=\"plot-btn\">Plot Regression Line</button>\n    <div id=\"graph\"></div>\n\n    <script>\n        let xData = [];\n        let yData = [];\n        let data = [\n            {x: 1, y: 2},\n            {x: 2, y: 3},\n            {x: 3, y: 5},\n            {x: 4, y: 7},\n            {x: 5, y: 11},\n            {x: 6, y: 13}\n        ];\n\n        function loadData() {\n            let input = document.getElementById('load-data-btn');\n            let output = document.getElementById('plot-btn');\n            input.addEventListener('click', function() {\n                let x = data.map(function(d) { return d.x; });\n                let y = data.map(function(d) { return d.y; });\n                let r = x.map(function(d) { return d - d.reduce(function(a, b) { return a + b, 0}); });\n                let s = x.map(function(d) { return d - d.reduce(function(a, b) { return a + b, 0}, 0); });\n                let m = x.reduce(function(a, b) { return a + b, 0}) / x.length;\n                let b = y.reduce(function(a, b) { return a + b, 0}) / y.length - m * s.reduce(function(a, b) { return a + b, 0}) / s.length;\n                xData = x;\n                yData = y;\n                let graph = document.getElementById('graph');\n                graph.innerHTML = '';\n                for (let i = 0; i < x.length; i++) {\n                    let y = yData[i] + m * xData[i] + b;\n                    let rect = document.createElement('rect');\n                    rect.x = x[i];\n                    rect.y = y;\n                    rect.width = 1;\n                    rect.height = 20;\n                    rect.fill = 'blue';\n                    graph.appendChild(rect);\n                }\n            });\n        }\n\n        loadData();\n    </script>\n</body>\n</html>"
