    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linear Regression Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin: 20px;\n        }\n        canvas {\n            border: 1px solid #ccc;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Linear Regression Demo</h1>\n    <button onclick=\"performLinearRegression()\">Calculate Linear Regression</button>\n    <canvas id=\"regressionCanvas\" width=\"600\" height=\"400\"></canvas>\n\n    <script>\n        // Sample Data\n        const dataPoints = [\n            { x: 1, y: 2 },\n            { x: 2, y: 3 },\n            { x: 3, y: 5 },\n            { x: 4, y: 4 },\n            { x: 5, y: 6 },\n            { x: 6, y: 7 }\n        ];\n\n        function performLinearRegression() {\n            const n = dataPoints.length;\n            let sumX = 0, sumY = 0, sumXY = 0, sumXX = 0;\n\n            // Calculating sums\n            dataPoints.forEach(point => {\n                sumX += point.x;\n                sumY += point.y;\n                sumXY += point.x * point.y;\n                sumXX += point.x * point.x;\n            });\n\n            // Calculating slope (m) and intercept (b)\n            const m = (n * sumXY - sumX * sumY) / (n * sumXX - sumX * sumX);\n            const b = (sumY - m * sumX) / n;\n\n            drawChart(m, b);\n        }\n\n        function drawChart(m, b) {\n            const canvas = document.getElementById('regressionCanvas');\n            const ctx = canvas.getContext('2d');\n\n            // Clear canvas\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n            // Draw axes\n            ctx.beginPath();\n            ctx.moveTo(40, canvas.height - 40);\n            ctx.lineTo(40, 20);\n            ctx.moveTo(40, canvas.height - 40);\n            ctx.lineTo(canvas.width - 20, canvas.height - 40);\n            ctx.stroke();\n\n            // Draw data points\n            ctx.fillStyle = 'blue';\n            dataPoints.forEach(point => {\n                ctx.beginPath();\n                ctx.arc(point.x * 80 + 40, canvas.height - (point.y * 40 + 40), 5, 0, Math.PI * 2);\n                ctx.fill();\n            });\n\n            // Draw regression line\n            ctx.strokeStyle = 'red';\n            ctx.beginPath();\n            const x0 = 0;\n            const y0 = m * x0 + b;\n            const x1 = 7; // Adjust as needed\n            const y1 = m * x1 + b;\n            ctx.moveTo(x0 * 80 + 40, canvas.height - (y0 * 40 + 40));\n            ctx.lineTo(x1 * 80 + 40, canvas.height - (y1 * 40 + 40));\n            ctx.stroke();\n        }\n    </script>\n\n</body>\n</html>"
