    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Circular Linked List</title>\n    <style>\n        /* Style the list */\n        #list {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n        }\n        \n        #list li {\n            padding: 10px;\n            border-bottom: 1px solid #ccc;\n        }\n        \n        #list li:last-child {\n            border-bottom: none;\n        }\n    </style>\n</head>\n<body>\n    <h1>Circular Linked List</h1>\n    <ul id=\"list\">\n        <li>Node 1</li>\n        <li>Node 2</li>\n        <li>Node 3</li>\n        <li>Node 4</li>\n        <li>Node 5</li>\n    </ul>\n\n    <script>\n        class Node {\n            constructor(data) {\n                this.data = data;\n                this.next = null;\n            }\n        }\n\n        class CircularLinkedList {\n            constructor() {\n                this.head = null;\n            }\n\n            addNode(data) {\n                if (!this.head) {\n                    this.head = new Node(data);\n                    this.head.next = this.head;\n                } else {\n                    let newNode = new Node(data);\n                    let temp = this.head;\n                    while (temp.next !== this.head) {\n                        temp = temp.next;\n                    }\n                    temp.next = newNode;\n                    newNode.next = this.head;\n                }\n            }\n\n            printList() {\n                let temp = this.head;\n                let output = \"\";\n                while (temp !== null) {\n                    output += temp.data + \" \";\n                    temp = temp.next;\n                }\n                console.log(output);\n            }\n        }\n\n        let list = new CircularLinkedList();\n        list.addNode(\"Node 1\");\n        list.addNode(\"Node 2\");\n        list.addNode(\"Node 3\");\n        list.addNode(\"Node 4\");\n        list.addNode(\"Node 5\");\n\n        list.printList();\n    </script>\n</body>\n</html>"
