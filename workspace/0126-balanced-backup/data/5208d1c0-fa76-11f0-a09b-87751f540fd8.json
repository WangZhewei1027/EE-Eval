    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Insertion Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>Insertion Sort Example</h1>\n    <button id=\"insertion-sort-btn\">Sort by Insertion</button>\n    <div id=\"result\"></div>\n\n    <script>\n        function insertionSort(arr) {\n            for (let i = 1; i < arr.length; i++) {\n                let key = arr[i];\n                let j = i - 1;\n\n                while (j >= 0 && arr[j] > key) {\n                    arr[j + 1] = arr[j];\n                    j--;\n                }\n\n                arr[j + 1] = key;\n            }\n\n            return arr;\n        }\n\n        let arr = [64, 34, 25, 12, 22, 11, 90];\n        let result = insertionSort(arr);\n\n        console.log(\"Sorted array:\", result);\n\n        document.getElementById(\"insertion-sort-btn\").addEventListener(\"click\", function() {\n            let arr = [64, 34, 25, 12, 22, 11, 90];\n            let result = insertionSort(arr);\n\n            document.getElementById(\"result\").innerHTML = \"Sorted array: \" + result.join(\" \");\n        });\n    </script>\n</body>\n</html>"
