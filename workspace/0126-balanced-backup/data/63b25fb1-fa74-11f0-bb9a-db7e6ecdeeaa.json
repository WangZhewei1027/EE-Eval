    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Time Complexity Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  .container {\n    max-width: 900px;\n    margin: 0 auto;\n  }\n  .algo {\n    background: white;\n    border-radius: 8px;\n    padding: 1rem;\n    margin-bottom: 1.5rem;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.1);\n  }\n  .algo h2 {\n    margin-top: 0;\n  }\n  .code {\n    background: #272822;\n    color: #f8f8f2;\n    padding: 0.75rem;\n    border-radius: 6px;\n    font-family: \"Source Code Pro\", monospace, monospace;\n    font-size: 0.9rem;\n    overflow-x: auto;\n    margin-bottom: 0.75rem;\n  }\n  button {\n    background: #007acc;\n    color: white;\n    border: none;\n    padding: 0.6rem 1.2rem;\n    border-radius: 4px;\n    cursor: pointer;\n    font-weight: bold;\n    transition: background 0.3s ease;\n  }\n  button:hover:not(:disabled) {\n    background: #005fa3;\n  }\n  button:disabled {\n    background: #999;\n    cursor: not-allowed;\n  }\n  .results {\n    margin-top: 0.75rem;\n    font-weight: bold;\n    font-size: 1rem;\n  }\n  .explanation {\n    font-size: 0.9rem;\n    color: #555;\n    margin-bottom: 0.5rem;\n  }\n  .footer {\n    text-align: center;\n    margin-top: 3rem;\n    color: #666;\n    font-size: 0.8rem;\n  }\n  .loading {\n    font-style: italic;\n    color: #888;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Understanding Time Complexity</h1>\n  <p>\n    Time complexity measures how the runtime of an algorithm grows as the input size increases.\n    Here are three common examples demonstrated in JavaScript:\n  </p>\n\n  <div class=\"algo\" id=\"algo-linear\">\n    <h2>1. Linear Time Complexity - O(n)</h2>\n    <div class=\"explanation\">\n      The function loops through an array once, so time increases linearly with input size.\n    </div>\n    <pre class=\"code\">\n// Summing numbers in an array (O(n))\nfunction sumArray(arr) {\n  let sum = 0;\n  for(let i = 0; i < arr.length; i++) {\n    sum += arr[i];\n  }\n  return sum;\n}\n    </pre>\n    <button id=\"btn-linear\">Run Test with 1,000,000 entries</button>\n    <div class=\"results\" id=\"result-linear\"></div>\n  </div>\n\n  <div class=\"algo\" id=\"algo-quadratic\">\n    <h2>2. Quadratic Time Complexity - O(n²)</h2>\n    <div class=\"explanation\">\n      The function uses two nested loops which makes runtime grow quadratically.\n    </div>\n    <pre class=\"code\">\n// Counting pairs with sum zero (O(n²))\nfunction countZeroSumPairs(arr) {\n  let count = 0;\n  for(let i = 0; i < arr.length; i++) {\n    for(let j = i + 1; j < arr.length; j++) {\n      if(arr[i] + arr[j] === 0) count++;\n    }\n  }\n  return count;\n}\n    </pre>\n    <button id=\"btn-quadratic\">Run Test with 2,000 entries</button>\n    <div class=\"results\" id=\"result-quadratic\"></div>\n  </div>\n\n  <div class=\"algo\" id=\"algo-logarithmic\">\n    <h2>3. Logarithmic Time Complexity - O(log n)</h2>\n    <div class=\"explanation\">\n      Binary search halves the search space each step, making time grow logarithmically.\n    </div>\n    <pre class=\"code\">\n// Binary search (O(log n))\nfunction binarySearch(arr, target) {\n  let left = 0, right = arr.length - 1;\n  while(left <= right) {\n    let mid = Math.floor((left + right) / 2);\n    if(arr[mid] === target) return mid;\n    else if(arr[mid] < target) left = mid + 1;\n    else right = mid - 1;\n  }\n  return -1;\n}\n    </pre>\n    <button id=\"btn-logarithmic\">Run Test with 1,000,000 entries</button>\n    <div class=\"results\" id=\"result-logarithmic\"></div>\n  </div>\n\n  <div class=\"footer\">\n    &copy; 2024 Time Complexity Demo\n  </div>\n</div>\n\n<script>\n  // Linear example - sum array\n  const btnLinear = document.getElementById('btn-linear');\n  const resultLinear = document.getElementById('result-linear');\n\n  btnLinear.addEventListener('click', () => {\n    btnLinear.disabled = true;\n    resultLinear.textContent = 'Generating array...';\n    setTimeout(() => {\n      // Create large array 1,000,000 numbers\n      const arr = new Array(1_000_000).fill(1);\n\n      resultLinear.textContent = 'Running sumArray...';\n      const start = performance.now();\n      const sum = sumArray(arr);\n      const end = performance.now();\n\n      resultLinear.textContent = `Sum: ${sum} | Time taken: ${(end - start).toFixed(2)} ms`;\n      btnLinear.disabled = false;\n    }, 50);\n  });\n\n  function sumArray(arr) {\n    let sum = 0;\n    for(let i = 0; i < arr.length; i++) {\n      sum += arr[i];\n    }\n    return sum;\n  }\n\n  // Quadratic example - count pairs summing to zero\n  const btnQuadratic = document.getElementById('btn-quadratic');\n  const resultQuadratic = document.getElementById('result-quadratic');\n\n  btnQuadratic.addEventListener('click', () => {\n    btnQuadratic.disabled = true;\n    resultQuadratic.textContent = 'Generating array...';\n    setTimeout(() => {\n      // Create array with 2000 entries: half positive, half negative\n      const arr = [];\n      for(let i = 0; i < 1000; i++) {\n        arr.push(i);\n        arr.push(-i);\n      }\n\n      resultQuadratic.textContent = 'Running countZeroSumPairs...';\n      const start = performance.now();\n      const count = countZeroSumPairs(arr);\n      const end = performance.now();\n\n      resultQuadratic.textContent = `Pairs with sum zero: ${count} | Time taken: ${(end - start).toFixed(2)} ms`;\n      btnQuadratic.disabled = false;\n    }, 50);\n  });\n\n  function countZeroSumPairs(arr) {\n    let count = 0;\n    for(let i = 0; i < arr.length; i++) {\n      for(let j = i + 1; j < arr.length; j++) {\n        if(arr[i] + arr[j] === 0) count++;\n      }\n    }\n    return count;\n  }\n\n  // Logarithmic example - binary search\n  const btnLogarithmic = document.getElementById('btn-logarithmic');\n  const resultLogarithmic = document.getElementById('result-logarithmic');\n\n  btnLogarithmic.addEventListener('click', () => {\n    btnLogarithmic.disabled = true;\n    resultLogarithmic.textContent = 'Generating sorted array...';\n    setTimeout(() => {\n      // Sorted array with 1,000,000 numbers from 0 to 999,999\n      const arr = Array.from({length: 1_000_000}, (_, i) => i);\n\n      // Pick target around half\n      const target = 543210;\n\n      resultLogarithmic.textContent = `Running binarySearch for ${target}...`;\n      const start = performance.now();\n      const index = binarySearch(arr, target);\n      const end = performance.now();\n\n      resultLogarithmic.textContent = `Index found: ${index} | Time taken: ${(end - start).toFixed(4)} ms`;\n      btnLogarithmic.disabled = false;\n    }, 50);\n  });\n\n  function binarySearch(arr, target) {\n    let left = 0, right = arr.length - 1;\n    while(left <= right) {\n      let mid = Math.floor((left + right) / 2);\n      if(arr[mid] === target) return mid;\n      else if(arr[mid] < target) left = mid + 1;\n      else right = mid - 1;\n    }\n    return -1;\n  }\n</script>\n</body>\n</html>"
