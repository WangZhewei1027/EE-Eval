    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Virtual Memory</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            width: 80%;\n            margin: 40px auto;\n            text-align: center;\n        }\n        .button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Virtual Memory Example</h1>\n        <p>Imagine you have a computer with 16 GB of RAM, and you want to run 10 applications simultaneously.</p>\n        <button id=\"run-apps\">Run Apps</button>\n        <button id=\"stop-apps\">Stop Apps</button>\n        <div id=\"memory-usage\"></div>\n    </div>\n\n    <script>\n        let apps = 10;\n        let memoryUsage = 0;\n\n        const runApps = () => {\n            apps++;\n            memoryUsage += 1000; // simulate memory usage\n            document.getElementById('memory-usage').innerText = `Memory Usage: ${memoryUsage} MB`;\n            if (apps > 16) {\n                stopApps();\n            }\n        };\n\n        const stopApps = () => {\n            apps--;\n            memoryUsage -= 1000; // simulate memory usage\n            document.getElementById('memory-usage').innerText = `Memory Usage: ${memoryUsage} MB`;\n            if (apps === 0) {\n                alert('All apps stopped!');\n            }\n        };\n\n        const handleButtonClick = (buttonId) => {\n            switch (buttonId) {\n                case 'run-apps':\n                    runApps();\n                    break;\n                case 'stop-apps':\n                    stopApps();\n                    break;\n            }\n        };\n\n        document.getElementById('run-apps').addEventListener('click', handleButtonClick);\n        document.getElementById('stop-apps').addEventListener('click', handleButtonClick);\n    </script>\n</body>\n</html>"
