    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Queue Implementation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            text-align: center;\n        }\n        #queueDisplay {\n            margin: 20px auto;\n            width: 300px;\n            text-align: left;\n            border: 1px solid #ccc;\n            padding: 10px;\n            height: 150px;\n            overflow-y: auto;\n        }\n        input[type=\"text\"] {\n            padding: 5px;\n            width: 200px;\n        }\n        button {\n            padding: 5px 10px;\n            margin-left: 5px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Queue Implementation</h1>\n<div id=\"queueDisplay\"></div>\n\n<input type=\"text\" id=\"element\" placeholder=\"Enter element\">\n<button onclick=\"enqueue()\">Enqueue</button>\n<button onclick=\"dequeue()\">Dequeue</button>\n\n<script>\n    class Queue {\n        constructor() {\n            this.items = [];\n        }\n\n        enqueue(element) {\n            this.items.push(element);\n            this.displayQueue();\n        }\n\n        dequeue() {\n            if (this.isEmpty()) {\n                alert(\"Queue is empty!\");\n                return;\n            }\n            this.items.shift();\n            this.displayQueue();\n        }\n\n        isEmpty() {\n            return this.items.length === 0;\n        }\n\n        displayQueue() {\n            const queueDisplay = document.getElementById('queueDisplay');\n            queueDisplay.innerHTML = this.items.map(item => `<div>${item}</div>`).join('');\n        }\n    }\n\n    const queue = new Queue();\n\n    function enqueue() {\n        const elementInput = document.getElementById('element');\n        const element = elementInput.value;\n        if (element) {\n            queue.enqueue(element);\n            elementInput.value = '';\n        } else {\n            alert(\"Please enter an element!\");\n        }\n    }\n\n    function dequeue() {\n        queue.dequeue();\n    }\n</script>\n\n</body>\n</html>"
