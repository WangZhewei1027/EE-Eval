    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Selection Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f4f8;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    margin-bottom: 10px;\n  }\n  #array-container {\n    display: flex;\n    align-items: flex-end;\n    margin-top: 20px;\n    height: 300px;\n    width: 85vw;\n    max-width: 900px;\n    border: 2px solid #444;\n    background: #fff;\n    padding: 10px;\n    border-radius: 8px;\n  }\n  .bar {\n    margin: 0 2px;\n    background-color: #5a9bd5;\n    width: 20px;\n    border-radius: 3px 3px 0 0;\n    position: relative;\n    transition: background-color 0.3s, height 0.3s;\n  }\n  .bar span {\n    position: absolute;\n    top: -20px;\n    width: 100%;\n    text-align: center;\n    font-size: 12px;\n    color: #333;\n  }\n  .current {\n    background-color: #f39c12;\n  }\n  .min {\n    background-color: #e74c3c;\n  }\n  .sorted {\n    background-color: #2ecc71;\n  }\n  #controls {\n    margin-top: 30px;\n  }\n  button {\n    font-size: 16px;\n    padding: 8px 14px;\n    margin: 0 10px;\n    border: none;\n    border-radius: 5px;\n    background-color: #5a9bd5;\n    color: white;\n    cursor: pointer;\n    transition: background-color 0.3s;\n  }\n  button:disabled {\n    background-color: #a0c4e8;\n    cursor: not-allowed;\n  }\n  button:hover:not(:disabled) {\n    background-color: #3d7bbf;\n  }\n  #description {\n    max-width: 900px;\n    margin-top: 25px;\n    background: #fff;\n    border-radius: 8px;\n    padding: 15px 20px;\n    box-shadow: 0 2px 7px rgba(0,0,0,0.1);\n    line-height: 1.5;\n  }\n</style>\n</head>\n<body>\n<h1>Selection Sort Visualization</h1>\n<div id=\"array-container\"></div>\n<div id=\"controls\">\n  <button id=\"btn-start\">Start Sorting</button>\n  <button id=\"btn-reset\">Reset Array</button>\n</div>\n<div id=\"description\">\n  <strong>Selection Sort:</strong> This simple comparison sorting algorithm works by repeatedly finding the minimum element from the unsorted part of the array and moving it to the beginning. Here's the process:\n  <ol>\n    <li>Start at the first element (consider it minimum).</li>\n    <li>Compare it with the rest of the array to find the true minimum.</li>\n    <li>Swap the found minimum element with the element at the current position.</li>\n    <li>Move to the next element and repeat until the entire array is sorted.</li>\n  </ol>\n</div>\n\n<script>\n  const container = document.getElementById('array-container');\n  const btnStart = document.getElementById('btn-start');\n  const btnReset = document.getElementById('btn-reset');\n\n  // Configuration\n  const arraySize = 30;\n  const maxValue = 100;\n  let array = [];\n  let sorting = false;\n\n  // Create a random array\n  function generateArray() {\n    array = [];\n    for(let i = 0; i < arraySize; i++) {\n      array.push(Math.floor(Math.random() * maxValue) + 5);\n    }\n  }\n\n  // Render the bars to the container\n  function renderArray(highlight = {}) {\n    // highlight keys can be: current, min, sortedIndices (array)\n    container.innerHTML = '';\n    for(let i = 0; i < array.length; i++) {\n      const bar = document.createElement('div');\n      bar.classList.add('bar');\n      bar.style.height = `${array[i] * 2.5}px`;\n      bar.style.width = `${Math.floor(800 / arraySize)}px`; // responsive width\n\n      const label = document.createElement('span');\n      label.textContent = array[i];\n      bar.appendChild(label);\n\n      if(highlight.sortedIndices && highlight.sortedIndices.includes(i)) {\n        bar.classList.add('sorted');\n      } else if(highlight.min === i) {\n        bar.classList.add('min');\n      } else if(highlight.current === i) {\n        bar.classList.add('current');\n      }\n\n      container.appendChild(bar);\n    }\n  }\n\n  // Sleep async helper\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Selection sort animation\n  async function selectionSort() {\n    sorting = true;\n    btnStart.disabled = true;\n    btnReset.disabled = true;\n\n    let n = array.length;\n    let sortedIndices = [];\n\n    for (let i = 0; i < n - 1; i++) {\n      let min_idx = i;\n      renderArray({ current: i, min: min_idx, sortedIndices });\n      await sleep(400);\n\n      for (let j = i + 1; j < n; j++) {\n        renderArray({ current: j, min: min_idx, sortedIndices });\n        await sleep(300);\n\n        if (array[j] < array[min_idx]) {\n          min_idx = j;\n          renderArray({ current: j, min: min_idx, sortedIndices });\n          await sleep(400);\n        }\n      }\n\n      if(min_idx !== i) {\n        // Swap values\n        [array[i], array[min_idx]] = [array[min_idx], array[i]];\n        renderArray({ current: i, min: min_idx, sortedIndices });\n        await sleep(500);\n      }\n\n      sortedIndices.push(i);\n      renderArray({ sortedIndices });\n      await sleep(350);\n    }\n\n    // Add the last element to sorted\n    sortedIndices.push(n - 1);\n    renderArray({ sortedIndices });\n\n    sorting = false;\n    btnStart.disabled = false;\n    btnReset.disabled = false;\n  }\n\n  function initialize() {\n    generateArray();\n    renderArray();\n  }\n\n  btnStart.addEventListener('click', () => {\n    if(!sorting) {\n      selectionSort();\n    }\n  });\n\n  btnReset.addEventListener('click', () => {\n    if (!sorting) {\n      initialize();\n    }\n  });\n\n  // Initialize on page load\n  initialize();\n</script>\n</body>\n</html>"
