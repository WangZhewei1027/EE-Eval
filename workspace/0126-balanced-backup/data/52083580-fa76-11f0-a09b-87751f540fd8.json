    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Hash Table</title>\n    <style>\n        table {\n            border-collapse: collapse;\n        }\n        th, td {\n            border: 1px solid black;\n            padding: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Hash Table Demo</h1>\n    <table id=\"hash-table\">\n        <tr>\n            <th Key</th>\n            <th Value</th>\n        </tr>\n        <tr>\n            <td>Apple</td>\n            <td>5</td>\n        </tr>\n        <tr>\n            <td>Orange</td>\n            <td>3</td>\n        </tr>\n        <tr>\n            <td>Banana</td>\n            <td>2</td>\n        </tr>\n    </table>\n\n    <script>\n        let hashTable = {};\n\n        function add(key, value) {\n            if (key in hashTable) {\n                console.log(\"Key already exists in the Hash Table\");\n            } else {\n                hashTable[key] = value;\n                console.log(\"Key added successfully\");\n            }\n        }\n\n        function display() {\n            console.log(\"Hash Table:\");\n            for (let key in hashTable) {\n                console.log(`${key}: ${hashTable[key]}`);\n            }\n        }\n\n        function remove(key) {\n            if (key in hashTable) {\n                delete hashTable[key];\n                console.log(\"Key removed successfully\");\n            } else {\n                console.log(\"Key does not exist in the Hash Table\");\n            }\n        }\n\n        function update(key, value) {\n            if (key in hashTable) {\n                hashTable[key] = value;\n                console.log(\"Key updated successfully\");\n            } else {\n                console.log(\"Key does not exist in the Hash Table\");\n            }\n        }\n\n        function search(key) {\n            if (key in hashTable) {\n                console.log(`Key: ${key}, Value: ${hashTable[key]}`);\n            } else {\n                console.log(\"Key does not exist in the Hash Table\");\n            }\n        }\n\n        function clear() {\n            for (let key in hashTable) {\n                delete hashTable[key];\n            }\n            console.log(\"Hash Table cleared successfully\");\n        }\n\n        display();\n\n        add(\"Apple\", 5);\n        add(\"Orange\", 3);\n        add(\"Banana\", 2);\n\n        display();\n\n        remove(\"Orange\");\n\n        display();\n\n        update(\"Banana\", 4);\n\n        display();\n\n        search(\"Apple\");\n\n        display();\n\n        clear();\n\n        display();\n    </script>\n</body>\n</html>"
