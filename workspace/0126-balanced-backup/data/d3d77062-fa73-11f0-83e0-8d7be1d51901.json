  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>A* Search Visualization</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#1e1e1e;\n      --panel:#161616;\n      --card:#0f1720;\n      --accent:#4f46e5;\n      --muted:#9ca3af;\n      --light:#e6eef8;\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: linear-gradient(180deg,#071329 0%, #0b1220 100%);\n      color:var(--light);\n      display:flex;\n      align-items:stretch;\n      padding:18px;\n      box-sizing:border-box;\n    }\n    .container{\n      display:flex;\n      width:100%;\n      gap:18px;\n      align-items:flex-start;\n    }\n    .canvas-card{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:8px;\n      padding:12px;\n      box-shadow: 0 8px 30px rgba(2,6,23,0.6);\n    }\n    canvas{\n      display:block;\n      background:#0b1220;\n      border-radius:6px;\n      cursor:crosshair;\n    }\n    .controls{\n      width:360px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:14px;\n      border-radius:8px;\n      box-shadow: 0 8px 30px rgba(2,6,23,0.6);\n      display:flex;\n      flex-direction:column;\n      gap:10px;\n    }\n    .row{display:flex;gap:8px;align-items:center;}\n    label{font-size:13px;color:var(--muted);}\n    select,input[type=\"range\"],input[type=\"number\"]{background:#071024;border:1px solid rgba(255,255,255,0.04);color:var(--light);padding:6px;border-radius:6px;font-size:13px;}\n    button{background:var(--accent);border:none;color:white;padding:8px 10px;border-radius:6px;font-weight:600;cursor:pointer;}\n    button.ghost{background:transparent;border:1px solid rgba(255,255,255,0.06);}\n    .small{padding:6px 8px;font-size:13px;}\n    .muted{color:var(--muted);font-size:13px;}\n    .legend{display:flex;gap:8px;flex-wrap:wrap;}\n    .legend .box{display:flex;align-items:center;gap:6px}\n    .color-swatch{width:18px;height:18px;border-radius:4px;border:1px solid rgba(255,255,255,0.03)}\n    .stats{background:rgba(255,255,255,0.02);padding:8px;border-radius:6px;font-size:13px;}\n    .footer{margin-top:8px;font-size:12px;color:var(--muted)}\n    .title{font-size:16px;font-weight:700;margin-bottom:6px}\n    .hint{font-size:12px;color:var(--muted)}\n    input[type=\"checkbox\"]{width:16px;height:16px}\n    .controls .group{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"canvas-card\">\n      <div style=\"display:flex;align-items:center;gap:12px;margin-bottom:8px;\">\n        <div class=\"title\">A* Search - Interactive Visualization</div>\n        <div class=\"muted\" style=\"font-size:13px;\">Click to toggle walls. Shift+Click to set Start. Ctrl/Cmd+Click to set Goal.</div>\n      </div>\n      <canvas id=\"gridCanvas\" width=\"720\" height=\"480\"></canvas>\n      <div style=\"margin-top:8px;display:flex;gap:8px;align-items:center;\">\n        <div class=\"legend\">\n          <div class=\"box\"><div class=\"color-swatch\" style=\"background:#0ea5e9\"></div><div class=\"muted\">Start</div></div>\n          <div class=\"box\"><div class=\"color-swatch\" style=\"background:#7c3aed\"></div><div class=\"muted\">Goal</div></div>\n          <div class=\"box\"><div class=\"color-swatch\" style=\"background:#111827\"></div><div class=\"muted\">Wall</div></div>\n          <div class=\"box\"><div class=\"color-swatch\" style=\"background:#7dd3fc\"></div><div class=\"muted\">Path</div></div>\n          <div class=\"box\"><div class=\"color-swatch\" style=\"background:#34d399\"></div><div class=\"muted\">Open</div></div>\n          <div class=\"box\"><div class=\"color-swatch\" style=\"background:#fb7185\"></div><div class=\"muted\">Closed</div></div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"controls\">\n      <div>\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <div style=\"font-weight:700\">Controls</div>\n          <div class=\"muted\" style=\"font-size:12px\">Interactive A* demo</div>\n        </div>\n        <div class=\"hint\" style=\"margin-top:6px\">Use the buttons below to run or step through the A* algorithm on the grid.</div>\n      </div>\n\n      <div class=\"row\" style=\"gap:6px;\">\n        <button id=\"runBtn\" class=\"small\">Run</button>\n        <button id=\"stepBtn\" class=\"small ghost\">Step</button>\n        <button id=\"pauseBtn\" class=\"small ghost\">Pause</button>\n        <button id=\"resetBtn\" class=\"small ghost\">Reset</button>\n        <button id=\"clearWallsBtn\" class=\"small ghost\">Clear Walls</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Heuristic:</label>\n        <select id=\"heuristic\">\n          <option value=\"manhattan\">Manhattan</option>\n          <option value=\"euclidean\">Euclidean</option>\n          <option value=\"chebyshev\">Chebyshev</option>\n          <option value=\"octile\">Octile (good for diagonal)</option>\n        </select>\n      </div>\n\n      <div class=\"row\">\n        <label>Allow Diagonal:</label>\n        <input type=\"checkbox\" id=\"diagonal\" checked />\n        <label style=\"margin-left:8px\">Prevent corner-cutting:</label>\n        <input type=\"checkbox\" id=\"noCut\" checked />\n      </div>\n\n      <div class=\"row\">\n        <label>Weighted A* (heuristic weight):</label>\n        <input type=\"range\" id=\"weight\" min=\"0.2\" max=\"5\" step=\"0.1\" value=\"1\">\n        <div class=\"muted\" id=\"weightVal\">1.0x</div>\n      </div>\n\n      <div class=\"row\">\n        <label>Speed (ms per step):</label>\n        <input type=\"range\" id=\"speed\" min=\"0\" max=\"500\" step=\"10\" value=\"40\">\n        <div class=\"muted\" id=\"speedVal\">40 ms</div>\n      </div>\n\n      <div class=\"row\">\n        <label>Grid:</label>\n        <input id=\"cols\" type=\"number\" value=\"36\" min=\"8\" max=\"120\" style=\"width:74px\">\n        <input id=\"rows\" type=\"number\" value=\"24\" min=\"8\" max=\"80\" style=\"width:74px\">\n        <button id=\"resizeBtn\" class=\"ghost small\">Resize</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Maze / Obstacles:</label>\n        <input type=\"range\" id=\"density\" min=\"0\" max=\"0.6\" step=\"0.01\" value=\"0.18\">\n        <button id=\"randBtn\" class=\"small ghost\">Randomize</button>\n      </div>\n\n      <div class=\"row\">\n        <div style=\"flex:1\">\n          <div class=\"stats\">\n            <div>Expanded: <span id=\"expanded\">0</span></div>\n            <div>Open Size: <span id=\"openSize\">0</span></div>\n            <div>Path Length (cells): <span id=\"pathLen\">0</span></div>\n            <div>Total Cost: <span id=\"pathCost\">0</span></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"row\">\n        <div style=\"font-size:12px;color:var(--muted)\">\n          Tips: Shift+Click sets Start. Ctrl/Cmd+Click sets Goal. Click toggles walls. Use Step to walk the algorithm one expansion at a time.\n        </div>\n      </div>\n\n      <div class=\"footer\">Implementation notes: This demo uses a binary heap for the open set. The heuristic can be inflated (weighted A*). Diagonal movement and corner-cut prevention are supported.</div>\n    </div>\n  </div>\n\n<script>\n(() => {\n  // Configuration & State\n  const canvas = document.getElementById('gridCanvas');\n  const ctx = canvas.getContext('2d');\n\n  let cols = parseInt(document.getElementById('cols').value,10);\n  let rows = parseInt(document.getElementById('rows').value,10);\n  let cellSize = Math.floor(Math.min(canvas.width/cols, canvas.height/rows));\n  let offsetX = Math.floor((canvas.width - cellSize*cols)/2);\n  let offsetY = Math.floor((canvas.height - cellSize*rows)/2);\n\n  // Controls\n  const runBtn = document.getElementById('runBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const clearWallsBtn = document.getElementById('clearWallsBtn');\n  const randBtn = document.getElementById('randBtn');\n  const resizeBtn = document.getElementById('resizeBtn');\n\n  const heuristicSel = document.getElementById('heuristic');\n  const diagonalCB = document.getElementById('diagonal');\n  const noCutCB = document.getElementById('noCut');\n  const weightSlider = document.getElementById('weight');\n  const weightVal = document.getElementById('weightVal');\n  const speedSlider = document.getElementById('speed');\n  const speedVal = document.getElementById('speedVal');\n  const densitySlider = document.getElementById('density');\n\n  const expandedEl = document.getElementById('expanded');\n  const openSizeEl = document.getElementById('openSize');\n  const pathLenEl = document.getElementById('pathLen');\n  const pathCostEl = document.getElementById('pathCost');\n\n  // Grid and algorithm state\n  let grid = [];\n  let start = {x:2,y:2};\n  let goal = {x:cols-3,y:rows-3};\n  let openHeap = null;\n  let closedSet = null;\n  let running = false;\n  let intervalId = null;\n  let stepMode = false;\n  let expandedCount = 0;\n  let found = false;\n  let path = [];\n  let lastPathCost = 0;\n  let lastPathLen = 0;\n\n  // Node structure: {x,y,walkable,g,h,f,opened,closed,parent,heapIndex}\n  function makeGrid(c, r) {\n    cols = c; rows = r;\n    grid = new Array(cols);\n    for (let x=0;x<cols;x++){\n      grid[x] = new Array(rows);\n      for (let y=0;y<rows;y++){\n        grid[x][y] = {\n          x, y,\n          walkable: true,\n          g: Infinity,\n          h: 0,\n          f: Infinity,\n          opened: false,\n          closed: false,\n          parent: null,\n          heapIndex: -1\n        };\n      }\n    }\n    // set default start/goal within bounds\n    start = {x: Math.min(2, cols-1), y: Math.min(2, rows-1)};\n    goal = {x: Math.max(cols-3, 0), y: Math.max(rows-3, 0)};\n  }\n\n  makeGrid(cols, rows);\n\n  // Utility: Heuristics\n  function heuristic(a,b, type) {\n    const dx = Math.abs(a.x - b.x), dy = Math.abs(a.y - b.y);\n    switch(type) {\n      case 'manhattan': return dx + dy;\n      case 'euclidean': return Math.sqrt(dx*dx + dy*dy);\n      case 'chebyshev': return Math.max(dx,dy);\n      case 'octile':\n        // octile: for grids with diagonal movement (cost sqrt(2) diagonals)\n        const F = Math.SQRT2 - 1;\n        return (dx < dy) ? F*dx + dy : F*dy + dx;\n      default: return dx + dy;\n    }\n  }\n\n  // Binary heap (min-heap) for open set\n  class BinaryHeap {\n    constructor() {\n      this.content = [];\n    }\n    push(node) {\n      node.heapIndex = this.content.length;\n      this.content.push(node);\n      this._sinkUp(this.content.length - 1);\n    }\n    pop() {\n      const result = this.content[0];\n      const end = this.content.pop();\n      if (this.content.length > 0) {\n        this.content[0] = end;\n        this.content[0].heapIndex = 0;\n        this._sinkDown(0);\n      }\n      if (result) result.heapIndex = -1;\n      return result;\n    }\n    size() { return this.content.length; }\n    _sinkUp(n) {\n      const element = this.content[n];\n      while (n > 0) {\n        const parentN = Math.floor((n + 1)/2) - 1;\n        const parent = this.content[parentN];\n        if (this._compare(element, parent) < 0) {\n          this.content[parentN] = element;\n          this.content[n] = parent;\n          element.heapIndex = parentN;\n          parent.heapIndex = n;\n          n = parentN;\n        } else break;\n      }\n    }\n    _sinkDown(n) {\n      const length = this.content.length;\n      const element = this.content[n];\n      while(true) {\n        const child2N = (n + 1) * 2;\n        const child1N = child2N - 1;\n        let swap = null;\n        if (child1N < length) {\n          const child1 = this.content[child1N];\n          if (this._compare(child1, element) < 0) swap = child1N;\n        }\n        if (child2N < length) {\n          const child2 = this.content[child2N];\n          if (this._compare(child2, (swap === null ? element : this.content[child1N])) < 0) swap = child2N;\n        }\n        if (swap === null) break;\n        this.content[n] = this.content[swap];\n        this.content[n].heapIndex = n;\n        this.content[swap] = element;\n        element.heapIndex = swap;\n        n = swap;\n      }\n    }\n    _compare(a,b) {\n      // primary by f, tie by h (smaller), tie by g (larger) to prefer longer-so-far (break ties)\n      if (a.f !== b.f) return a.f - b.f;\n      if (a.h !== b.h) return a.h - b.h;\n      return b.g - a.g;\n    }\n    remove(node) {\n      const idx = node.heapIndex;\n      if (idx < 0 || idx >= this.content.length) return;\n      const end = this.content.pop();\n      if (idx === this.content.length) return;\n      this.content[idx] = end;\n      this.content[idx].heapIndex = idx;\n      this._sinkUp(idx);\n      this._sinkDown(idx);\n    }\n  }\n\n  // Grid drawing\n  function recalcCellSize() {\n    cellSize = Math.floor(Math.min(canvas.width/cols, canvas.height/rows));\n    offsetX = Math.floor((canvas.width - cellSize*cols)/2);\n    offsetY = Math.floor((canvas.height - cellSize*rows)/2);\n  }\n\n  function drawGrid() {\n    ctx.clearRect(0,0,canvas.width,canvas.height);\n    // background\n    ctx.fillStyle = \"#071224\";\n    ctx.fillRect(0,0,canvas.width,canvas.height);\n\n    for (let x=0;x<cols;x++){\n      for (let y=0;y<rows;y++){\n        const node = grid[x][y];\n        const px = offsetX + x*cellSize;\n        const py = offsetY + y*cellSize;\n\n        // base color\n        if (!node.walkable) {\n          ctx.fillStyle = \"#0b0b0b\";\n          ctx.fillRect(px,py,cellSize,cellSize);\n        } else if (node === getNode(start.x,start.y)) {\n          ctx.fillStyle = \"#0ea5e9\"; ctx.fillRect(px,py,cellSize,cellSize);\n        } else if (node === getNode(goal.x,goal.y)) {\n          ctx.fillStyle = \"#7c3aed\"; ctx.fillRect(px,py,cellSize,cellSize);\n        } else if (path.some(p => p.x===x && p.y===y)) {\n          ctx.fillStyle = \"#7dd3fc\"; ctx.fillRect(px,py,cellSize,cellSize);\n        } else if (node.closed) {\n          ctx.fillStyle = \"#fb7185\"; ctx.fillRect(px,py,cellSize,cellSize);\n        } else if (node.opened) {\n          ctx.fillStyle = \"#34d399\"; ctx.fillRect(px,py,cellSize,cellSize);\n        } else {\n          ctx.fillStyle = \"#071225\";\n          ctx.fillRect(px,py,cellSize,cellSize);\n        }\n\n        // grid lines\n        ctx.strokeStyle = \"rgba(255,255,255,0.03)\";\n        ctx.strokeRect(px+0.5,py+0.5,cellSize-1,cellSize-1);\n\n        // f/g values\n        if ((node.opened || node.closed) && node.g < Infinity && cellSize > 18) {\n          ctx.fillStyle = \"rgba(0,0,0,0.55)\";\n          ctx.fillRect(px + 2, py + 2, Math.min(62, cellSize-4), 14);\n          ctx.fillStyle = \"#ffffff\";\n          ctx.font = \"10px Inter, Arial\";\n          ctx.fillText(\"f:\" + formatNum(node.f), px + 4, py + 13);\n          ctx.fillStyle = \"rgba(255,255,255,0.65)\";\n          ctx.font = \"9px Inter, Arial\";\n          ctx.fillText(\"g:\" + formatNum(node.g), px + 4, py + 26 < py + cellSize ? py + 26 : py + 14);\n        }\n      }\n    }\n  }\n  function formatNum(n) {\n    if (!isFinite(n)) return \"∞\";\n    return Math.round(n*100)/100;\n  }\n\n  function getNode(x,y){\n    if (x<0||x>=cols||y<0||y>=rows) return null;\n    return grid[x][y];\n  }\n\n  // Mouse interactions\n  canvas.addEventListener('mousedown', (e) => {\n    const rect = canvas.getBoundingClientRect();\n    const mx = e.clientX - rect.left;\n    const my = e.clientY - rect.top;\n    const gx = Math.floor((mx - offsetX) / cellSize);\n    const gy = Math.floor((my - offsetY) / cellSize);\n    if (gx < 0 || gx >= cols || gy < 0 || gy >= rows) return;\n    if (e.shiftKey) {\n      start = {x:gx,y:gy};\n      resetSearchState();\n      drawGrid();\n    } else if (e.ctrlKey || e.metaKey) {\n      goal = {x:gx,y:gy};\n      resetSearchState();\n      drawGrid();\n    } else {\n      // toggle wall\n      const node = getNode(gx,gy);\n      if (node.x === start.x && node.y === start.y) return;\n      if (node.x === goal.x && node.y === goal.y) return;\n      node.walkable = !node.walkable;\n      resetSearchState();\n      drawGrid();\n    }\n  });\n\n  // Path reconstruction\n  function reconstructPath(node) {\n    const p = [];\n    let cur = node;\n    while (cur) {\n      p.push({x:cur.x,y:cur.y});\n      cur = cur.parent;\n    }\n    p.reverse();\n    return p;\n  }\n\n  function resetNodesState() {\n    for (let x=0;x<cols;x++){\n      for (let y=0;y<rows;y++){\n        const n = grid[x][y];\n        n.g = Infinity;\n        n.h = 0;\n        n.f = Infinity;\n        n.opened = false;\n        n.closed = false;\n        n.parent = null;\n        n.heapIndex = -1;\n      }\n    }\n  }\n\n  function resetSearchState() {\n    stop();\n    openHeap = null;\n    closedSet = null;\n    running = false;\n    stepMode = false;\n    expandedCount = 0;\n    found = false;\n    path = [];\n    lastPathCost = 0;\n    lastPathLen = 0;\n    resetNodesState();\n    updateStats();\n  }\n\n  // A* core: step once (expand a node)\n  function initSearch() {\n    resetSearchState();\n    openHeap = new BinaryHeap();\n    closedSet = new Set();\n\n    const s = getNode(start.x,start.y);\n    const gNode = getNode(goal.x,goal.y);\n    if (!s || !gNode) return false;\n\n    if (!s.walkable) s.walkable = true;\n    if (!gNode.walkable) gNode.walkable = true;\n\n    s.g = 0;\n    s.h = heuristic(s, gNode, heuristicSel.value) * parseFloat(weightSlider.value);\n    s.f = s.g + s.h;\n    s.opened = true;\n    openHeap.push(s);\n\n    expandedCount = 0;\n    found = false;\n    path = [];\n    updateStats();\n    return true;\n  }\n\n  function neighbors(node) {\n    const list = [];\n    const x = node.x, y = node.y;\n    const diag = diagonalCB.checked;\n    // orthogonals\n    const dirs = [\n      {dx:1,dy:0},{dx:-1,dy:0},{dx:0,dy:1},{dx:0,dy:-1}\n    ];\n    for (const d of dirs) {\n      const nx = x + d.dx, ny = y + d.dy;\n      const n = getNode(nx,ny);\n      if (n && n.walkable) list.push({node:n, cost:1});\n    }\n    if (diag) {\n      // diagonals\n      const diagDirs = [\n        {dx:1,dy:1, block1:{dx:1,dy:0}, block2:{dx:0,dy:1}},\n        {dx:1,dy:-1, block1:{dx:1,dy:0}, block2:{dx:0,dy:-1}},\n        {dx:-1,dy:1, block1:{dx:-1,dy:0}, block2:{dx:0,dy:1}},\n        {dx:-1,dy:-1, block1:{dx:-1,dy:0}, block2:{dx:0,dy:-1}},\n      ];\n      for (const d of diagDirs) {\n        const nx = x + d.dx, ny = y + d.dy;\n        const n = getNode(nx,ny);\n        if (!n || !n.walkable) continue;\n\n        if (noCutCB.checked) {\n          // ensure corner cutting is prevented: both adjacent orthogonal cells must be walkable\n          const b1 = getNode(x + d.block1.dx, y + d.block1.dy);\n          const b2 = getNode(x + d.block2.dx, y + d.block2.dy);\n          if (!b1 || !b2) continue;\n          if (!b1.walkable || !b2.walkable) continue;\n        }\n        list.push({node:n, cost: Math.SQRT2});\n      }\n    }\n    return list;\n  }\n\n  function stepSearchOnce() {\n    if (!openHeap || openHeap.size() === 0) {\n      running = false;\n      stop();\n      return;\n    }\n    const current = openHeap.pop();\n    current.opened = false;\n    current.closed = true;\n    expandedCount++;\n\n    const goalNode = getNode(goal.x, goal.y);\n    if (current === goalNode) {\n      found = true;\n      path = reconstructPath(current);\n      lastPathLen = path.length;\n      lastPathCost = current.g;\n      updateStats();\n      drawGrid();\n      stop();\n      return;\n    }\n\n    const neigh = neighbors(current);\n    for (const entry of neigh) {\n      const neighbor = entry.node;\n      if (neighbor.closed) continue;\n      const tentativeG = current.g + entry.cost;\n      if (!neighbor.opened || tentativeG < neighbor.g) {\n        neighbor.g = tentativeG;\n        neighbor.parent = current;\n        neighbor.h = heuristic(neighbor, goalNode, heuristicSel.value) * parseFloat(weightSlider.value);\n        neighbor.f = neighbor.g + neighbor.h;\n        if (!neighbor.opened) {\n          neighbor.opened = true;\n          openHeap.push(neighbor);\n        } else {\n          // decrease-key\n          openHeap._sinkUp(neighbor.heapIndex);\n        }\n      }\n    }\n\n    updateStats();\n    drawGrid();\n  }\n\n  function runAlgorithm() {\n    if (!initSearch()) return;\n    running = true;\n    stepMode = false;\n    const delay = parseInt(speedSlider.value,10);\n    if (delay <= 0) {\n      // fast synchronous run - step until done\n      while (running && openHeap.size() > 0) {\n        stepSearchOnce();\n        if (found) break;\n      }\n      return;\n    }\n    if (intervalId) clearInterval(intervalId);\n    intervalId = setInterval(() => {\n      if (!running) {\n        clearInterval(intervalId);\n        intervalId = null;\n        return;\n      }\n      stepSearchOnce();\n      if (found) {\n        clearInterval(intervalId);\n        intervalId = null;\n        running = false;\n      }\n      if (openHeap && openHeap.size() === 0) {\n        clearInterval(intervalId);\n        intervalId = null;\n        running = false;\n      }\n    }, delay);\n  }\n\n  function stepAlgorithm() {\n    if (!openHeap) {\n      if (!initSearch()) return;\n    }\n    stepMode = true;\n    running = true;\n    stepSearchOnce();\n    running = false;\n  }\n\n  function stop() {\n    running = false;\n    if (intervalId) {\n      clearInterval(intervalId);\n      intervalId = null;\n    }\n  }\n\n  // UI update helpers\n  function updateStats() {\n    expandedEl.textContent = expandedCount;\n    openSizeEl.textContent = openHeap ? openHeap.size() : 0;\n    pathLenEl.textContent = found ? lastPathLen : path.length;\n    pathCostEl.textContent = found ? formatNum(lastPathCost) : (path.length ? \"?\" : 0);\n  }\n\n  // Buttons\n  runBtn.addEventListener('click', () => {\n    stop();\n    runAlgorithm();\n  });\n  stepBtn.addEventListener('click', () => {\n    stop();\n    stepAlgorithm();\n  });\n  pauseBtn.addEventListener('click', () => {\n    stop();\n  });\n  resetBtn.addEventListener('click', () => {\n    resetSearchState();\n    drawGrid();\n  });\n  clearWallsBtn.addEventListener('click', () => {\n    for (let x=0;x<cols;x++){\n      for (let y=0;y<rows;y++){\n        grid[x][y].walkable = true;\n      }\n    }\n    resetSearchState();\n    drawGrid();\n  });\n\n  randBtn.addEventListener('click', () => {\n    const density = parseFloat(densitySlider.value);\n    for (let x=0;x<cols;x++){\n      for (let y=0;y<rows;y++){\n        grid[x][y].walkable = Math.random() > density;\n      }\n    }\n    // ensure start/goal cells are walkable\n    getNode(start.x,start.y).walkable = true;\n    getNode(goal.x,goal.y).walkable = true;\n    resetSearchState();\n    drawGrid();\n  });\n\n  resizeBtn.addEventListener('click', () => {\n    const newC = Math.max(8, Math.min(120, parseInt(document.getElementById('cols').value,10)));\n    const newR = Math.max(8, Math.min(80, parseInt(document.getElementById('rows').value,10)));\n    makeGrid(newC,newR);\n    recalcCellSize();\n    resetSearchState();\n    drawGrid();\n  });\n\n  weightSlider.addEventListener('input', () => {\n    weightVal.textContent = parseFloat(weightSlider.value).toFixed(1) + \"x\";\n  });\n\n  speedSlider.addEventListener('input', () => {\n    speedVal.textContent = speedSlider.value + \" ms\";\n    if (running && !stepMode) {\n      // restart interval with new delay\n      stop();\n      runAlgorithm();\n    }\n  });\n\n  heuristicSel.addEventListener('change', () => { resetSearchState(); drawGrid(); });\n  diagonalCB.addEventListener('change', () => { resetSearchState(); drawGrid(); });\n  noCutCB.addEventListener('change', () => { resetSearchState(); drawGrid(); });\n\n  // initialize with some random walls\n  (function seedRandomWalls() {\n    const density = parseFloat(densitySlider.value);\n    for (let x=0;x<cols;x++){\n      for (let y=0;y<rows;y++){\n        grid[x][y].walkable = Math.random() > density;\n      }\n    }\n    getNode(start.x,start.y).walkable = true;\n    getNode(goal.x,goal.y).walkable = true;\n  })();\n\n  function onWindowResize() {\n    // keep canvas size responsive if container changes\n    // we won't change canvas dims here to keep simplicity, but recalc cell size\n    recalcCellSize();\n    drawGrid();\n  }\n  window.addEventListener('resize', onWindowResize);\n\n  // initial draw\n  recalcCellSize();\n  drawGrid();\n\n  // expose a simple keyboard: R to randomize, C to clear, Space to run/pause\n  window.addEventListener('keydown', (e) => {\n    if (e.key === 'r' || e.key === 'R') { randBtn.click(); }\n    if (e.key === 'c' || e.key === 'C') { clearWallsBtn.click(); }\n    if (e.code === 'Space') {\n      e.preventDefault();\n      if (running) pauseBtn.click();\n      else runBtn.click();\n    }\n    if (e.key === 's' || e.key === 'S') stepBtn.click();\n  });\n\n  // Ensure periodic redraw stats even if nothing changes (just to keep UI reactive)\n  setInterval(() => {\n    updateStats();\n  }, 250);\n\n})();\n</script>\n</body>\n</html>"
