    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>JavaScript Thread Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            padding: 20px;\n        }\n        #output {\n            margin-top: 20px;\n            background-color: #fff;\n            padding: 10px;\n            border: 1px solid #ccc;\n        }\n    </style>\n</head>\n<body>\n    <h1>JavaScript Thread Example</h1>\n    <button id=\"startThreadButton\">Start Thread Simulation</button>\n    <div id=\"output\"></div>\n\n    <script>\n        document.getElementById(\"startThreadButton\").addEventListener(\"click\", simulateThread);\n\n        function simulateThread() {\n            const outputDiv = document.getElementById(\"output\");\n            outputDiv.innerHTML = \"\"; // Clear previous output\n            \n            outputDiv.innerHTML += \"<strong>Starting multiple tasks...</strong><br>\";\n\n            // Simulating threads using setTimeout (as JS is single-threaded)\n            const tasks = [task1, task2, task3, task4];\n\n            tasks.forEach((task, index) => {\n                // Simulating each task to run asynchronously\n                setTimeout(() => {\n                    outputDiv.innerHTML += \"Task \" + (index + 1) + \" is running...<br>\";\n                    task();\n                }, Math.random() * 2000); // Random delay to simulate concurrency\n            });\n        }\n\n        function task1() {\n            setTimeout(() => {\n                document.getElementById(\"output\").innerHTML += \"Task 1 completed!<br>\";\n            }, 1000);\n        }\n\n        function task2() {\n            setTimeout(() => {\n                document.getElementById(\"output\").innerHTML += \"Task 2 completed!<br>\";\n            }, 1500);\n        }\n\n        function task3() {\n            setTimeout(() => {\n                document.getElementById(\"output\").innerHTML += \"Task 3 completed!<br>\";\n            }, 1200);\n        }\n\n        function task4() {\n            setTimeout(() => {\n                document.getElementById(\"output\").innerHTML += \"Task 4 completed!<br>\";\n            }, 800);\n        }\n    </script>\n</body>\n</html>"
