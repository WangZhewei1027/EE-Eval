    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>HTTP Concept Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2em;\n      background: #f0f0f0;\n    }\n    h1 {\n      color: #003366;\n    }\n    #http-demo {\n      background: white;\n      padding: 1em 2em;\n      border-radius: 8px;\n      box-shadow: 0 0 5px rgba(0,0,0,0.1);\n      max-width: 700px;\n      margin-top: 1em;\n    }\n    button {\n      padding: 0.6em 1.2em;\n      font-size: 1em;\n      border: none;\n      border-radius: 4px;\n      background-color: #007BFF;\n      color: white;\n      cursor: pointer;\n      transition: background-color 0.3s ease;\n    }\n    button:hover {\n      background-color: #0056b3;\n    }\n    pre {\n      background: #272822;\n      color: #f8f8f2;\n      padding: 1em;\n      border-radius: 4px;\n      overflow-x: auto;\n      font-size: 0.9em;\n    }\n    .section {\n      margin-top: 1.5em;\n    }\n    .response {\n      white-space: pre-wrap;\n      word-wrap: break-word;\n      background-color: #eaeaea;\n      padding: 1em;\n      border-radius: 4px;\n      font-family: monospace;\n    }\n  </style>\n</head>\n<body>\n  <h1>HTTP Concept Demonstration</h1>\n\n  <div id=\"http-demo\">\n    <p>\n      HTTP (HyperText Transfer Protocol) is the protocol used by the web to transfer data between clients (browsers) and servers.\n      It consists of requests sent from client to server and responses sent back from server to client.\n    </p>\n\n    <p>\n      Click the button below to send a simple HTTP GET request to a public API and see the request & response in action:\n    </p>\n\n    <button id=\"send-request\">Send HTTP GET Request</button>\n\n    <div class=\"section\">\n      <h2>HTTP Request</h2>\n      <pre id=\"http-request\">// Request data will appear here</pre>\n    </div>\n\n    <div class=\"section\">\n      <h2>HTTP Response</h2>\n      <pre id=\"http-response\">// Response data will appear here</pre>\n    </div>\n  </div>\n\n  <script>\n    const button = document.getElementById('send-request');\n    const requestPre = document.getElementById('http-request');\n    const responsePre = document.getElementById('http-response');\n\n    button.addEventListener('click', () => {\n      // Clear previous output\n      requestPre.textContent = '// Sending request...';\n      responsePre.textContent = '// Waiting for response...';\n\n      // Define the request info\n      const url = 'https://jsonplaceholder.typicode.com/posts/1';\n      const method = 'GET';\n      const headers = {\n        'Accept': 'application/json'\n      };\n\n      // Display the HTTP request format (simplified)\n      requestPre.textContent =\n`GET ${url} HTTP/1.1\nHost: jsonplaceholder.typicode.com\nAccept: application/json\n\n`;\n\n      // Send the HTTP GET request using fetch\n      fetch(url, {\n        method,\n        headers,\n      })\n        .then(response => {\n          // Show status line and headers\n          let headersText = '';\n          response.headers.forEach((value, key) => {\n            headersText += `${key}: ${value}\\n`;\n          });\n          responsePre.textContent =\n`HTTP/${response.httpVersion || '1.1'} ${response.status} ${response.statusText}\n${headersText}\n`;\n\n          // Return parsed JSON response body\n          return response.json();\n        })\n        .then(data => {\n          // Append JSON response body to the response display\n          responsePre.textContent += JSON.stringify(data, null, 2);\n        })\n        .catch(error => {\n          responsePre.textContent = 'Error: ' + error.message;\n        });\n    });\n  </script>\n</body>\n</html>"
