    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Decision Trees</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        \n        #tree {\n            width: 50%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        #tree h2 {\n            margin-top: 0;\n        }\n        \n        #tree p {\n            margin-bottom: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Decision Trees</h1>\n    <h2>Decision Tree Example</h2>\n    <p>Decision trees are a type of machine learning model that use a tree-like structure to classify data into categories.</p>\n    <div id=\"tree\"></div>\n    <script>\n        let data = {\n            \"feature\": [\"age\", \"income\"],\n            \"target\": [\"good\", \"bad\"],\n            \"features\": {\n                \"age\": [25, 30, 35, 40, 45],\n                \"income\": [50000, 60000, 70000, 80000, 90000]\n            },\n            \"target_values\": {\n                \"good\": [1, 2, 3, 4, 5],\n                \"bad\": [0, 1, 2, 3, 4]\n            }\n        };\n        \n        function createTree(features, target, target_values) {\n            let feature = Object.keys(features)[0];\n            let value = features[feature];\n            let left = [];\n            let right = [];\n            \n            for (let i = 0; i < target.length; i++) {\n                if (value === target_values[target[i]]) {\n                    left.push({feature: feature, value: value, left: [], right: []});\n                    left[0].left.push({feature: feature, value: value, left: [], right: []});\n                    left[0].right.push({feature: feature, value: value, left: [], right: []});\n                } else {\n                    right.push({feature: feature, value: value, left: [], right: []});\n                    right[0].left.push({feature: feature, value: value, left: [], right: []});\n                    right[0].right.push({feature: feature, value: value, left: [], right: []});\n                }\n            }\n            \n            return {\n                feature: feature,\n                value: value,\n                left: left,\n                right: right\n            };\n        }\n        \n        function buildTree(features, target, target_values, current) {\n            let node = createTree(features, target, target_values);\n            let html = `\n                <div class=\"tree\">\n                    <h2>${node.feature}</h2>\n                    <p>${node.value}</p>\n                    <p>Left: ${node.left ? node.left.map(item => `<p>${item.feature}</p><p>${item.value}</p>`).join(\"\") : \"\"}</p>\n                    <p>Right: ${node.right ? node.right.map(item => `<p>${item.feature}</p><p>${item.value}</p>`).join(\"\") : \"\"}</p>\n                </div>\n            `;\n            document.getElementById(\"tree\").innerHTML = html;\n        }\n        \n        buildTree(data[\"features\"], data[\"target\"], data[\"target_values\"], data[\"feature\"]);\n    </script>\n</body>\n</html>"
