    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>A* Search Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f0f0f0;\n            padding: 20px;\n        }\n        #grid {\n            display: grid;\n            grid-template-columns: repeat(10, 40px);\n            grid-template-rows: repeat(10, 40px);\n            gap: 1px;\n            margin: auto;\n        }\n        .cell {\n            width: 40px;\n            height: 40px;\n            background-color: white;\n            border: 1px solid #ccc;\n        }\n        .start {\n            background-color: green;\n        }\n        .goal {\n            background-color: red;\n        }\n        .path {\n            background-color: blue;\n        }\n        .visited {\n            background-color: yellow;\n        }\n    </style>\n</head>\n<body>\n\n<h1>A* Search Algorithm Visualization</h1>\n<div id=\"grid\"></div>\n<button id=\"startBtn\">Start A* Search</button>\n<script>\n    const grid = document.getElementById('grid');\n    const rows = 10;\n    const cols = 10;\n    let start, goal;\n    const gridArray = [];\n\n    // Initialize the grid and the start/goal points\n    function initializeGrid() {\n        for (let i = 0; i < rows; i++) {\n            const row = [];\n            for (let j = 0; j < cols; j++) {\n                const cell = document.createElement('div');\n                cell.className = 'cell';\n                cell.dataset.row = i;\n                cell.dataset.col = j;\n                cell.onclick = () => setCellData(cell);\n                grid.appendChild(cell);\n                row.push(cell);\n            }\n            gridArray.push(row);\n        }\n        // Set start and goal positions\n        start = gridArray[0][0];\n        start.classList.add('start');\n        goal = gridArray[9][9];\n        goal.classList.add('goal');\n    }\n\n    function setCellData(cell) {\n        if (cell === start || cell === goal) return;\n        if (cell.classList.contains('wall')) {\n            cell.classList.remove('wall');\n        } else {\n            cell.classList.add('wall');\n        }\n    }\n\n    // A* Search algorithm\n    function aStarSearch() {\n        const openSet = [];\n        const closedSet = new Set();\n        const gScore = Array.from({ length: rows }, () => Array(cols).fill(Infinity));\n        const fScore = Array.from({ length: rows }, () => Array(cols).fill(Infinity));\n        \n        const startRow = parseInt(start.dataset.row);\n        const startCol = parseInt(start.dataset.col);\n        gScore[startRow][startCol] = 0;\n        fScore[startRow][startCol] = heuristic(startRow, startCol, 9, 9);\n        openSet.push({ cell: start, f: fScore[startRow][startCol] });\n\n        while (openSet.length > 0) {\n            openSet.sort((a, b) => a.f - b.f);\n            const current = openSet.shift();\n            closedSet.add(current.cell);\n\n            if (current.cell === goal) {\n                reconstructPath(current.cell);\n                return;\n            }\n\n            const neighbors = getNeighbors(current.cell);\n            for (const neighbor of neighbors) {\n                if (closedSet.has(neighbor) || neighbor.classList.contains('wall')) {\n                    continue;\n                }\n                const tentativeGScore = gScore[parseInt(current.cell.dataset.row)][parseInt(current.cell.dataset.col)] + 1;\n\n                if (!openSet.some(item => item.cell === neighbor)) {\n                    openSet.push({ cell: neighbor });\n                } else if (tentativeGScore >= gScore[parseInt(neighbor.dataset.row)][parseInt(neighbor.dataset.col)]) {\n                    continue;\n                }\n\n                gScore[parseInt(neighbor.dataset.row)][parseInt(neighbor.dataset.col)] = tentativeGScore;\n                fScore[parseInt(neighbor.dataset.row)][parseInt(neighbor.dataset.col)] = tentativeGScore + heuristic(parseInt(neighbor.dataset.row), parseInt(neighbor.dataset.col), 9, 9);\n                neighbor.classList.add('visited');\n            }\n        }\n        alert('No path found!');\n    }\n\n    function heuristic(row, col, goalRow, goalCol) {\n        return Math.abs(row - goalRow) + Math.abs(col - goalCol);\n    }\n\n    function getNeighbors(cell) {\n        const row = parseInt(cell.dataset.row);\n        const col = parseInt(cell.dataset.col);\n        const neighbors = [];\n\n        const directions = [\n            { r: -1, c: 0 }, { r: 1, c: 0 },\n            { r: 0, c: -1 }, { r: 0, c: 1 }\n        ];\n\n        directions.forEach(dir => {\n            const newRow = row + dir.r;\n            const newCol = col + dir.c;\n            if (newRow >= 0 && newRow < rows && newCol >= 0 && newCol < cols) {\n                neighbors.push(gridArray[newRow][newCol]);\n            }\n        });\n\n        return neighbors;\n    }\n\n    function reconstructPath(cell) {\n        let current = cell;\n        while (current && current !== start) {\n            if (!current.classList.contains('start') && !current.classList.contains('goal')) {\n                current.classList.add('path');\n            }\n            // Logic to track back to the previous cell can be implemented here\n            current = null;  // Placeholder, this needs to be set to the previous cell correctly\n        }\n    }\n\n    document.getElementById('startBtn').addEventListener('click', aStarSearch);\n    initializeGrid();\n</script>\n\n</body>\n</html>"
