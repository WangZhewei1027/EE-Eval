    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Encryption Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f4f6f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    color: #20435c;\n  }\n  .container {\n    max-width: 600px;\n    margin: 1rem auto;\n    background: white;\n    padding: 1.5rem 2rem;\n    border-radius: 8px;\n    box-shadow: 0 0 15px rgba(0,0,0,0.1);\n  }\n  label {\n    font-weight: bold;\n    display: block;\n    margin-top: 1rem;\n    margin-bottom: .4rem;\n  }\n  textarea, input[type=\"text\"] {\n    width: 100%;\n    box-sizing: border-box;\n    font-size: 1rem;\n    padding: .5rem;\n    border-radius: 4px;\n    border: 1px solid #ccc;\n  }\n  button {\n    margin-top: 1.2rem;\n    padding: 0.6rem 1.2rem;\n    background: #20435c;\n    color: white;\n    border: none;\n    border-radius: 4px;\n    cursor: pointer;\n    font-size: 1rem;\n  }\n  button:hover {\n    background: #1a3550;\n  }\n  .output {\n    margin-top: 1rem;\n    padding: 1rem;\n    background: #eef5f9;\n    border-radius: 4px;\n    font-family: \"Courier New\", monospace;\n    white-space: pre-wrap;\n    word-break: break-all;\n    user-select: all;\n  }\n  .note {\n    font-size: 0.9rem;\n    color: #666;\n    margin-top: 0.4rem;\n  }\n</style>\n</head>\n<body>\n\n<h1>Encryption Concept Demonstration</h1>\n\n<div class=\"container\">\n  <label for=\"plaintext\">Step 1: Enter Plaintext (Message to Encrypt)</label>\n  <textarea id=\"plaintext\" rows=\"4\" placeholder=\"Type your message here...\"></textarea>\n  \n  <label for=\"key\">Step 2: Enter Key (Secret phrase)</label>\n  <input type=\"text\" id=\"key\" placeholder=\"Enter secret key\" />\n\n  <button id=\"encryptBtn\">Encrypt Message</button>\n\n  <label for=\"ciphertext\">Encrypted Output (Ciphertext)</label>\n  <div id=\"ciphertext\" class=\"output\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n  <button id=\"decryptBtn\" style=\"display:none;\">Decrypt Message</button>\n\n  <label for=\"decrypted\" style=\"display:none;\">Decrypted Output (Original message)</label>\n  <div id=\"decrypted\" class=\"output\" style=\"display:none;\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n  <p class=\"note\">\n    This demo uses the Vigenère cipher, a classical encryption method, to illustrate how encryption and decryption work with a key.\n  </p>\n</div>\n\n<script>\n// Vigenère cipher encryption/decryption implementation\n\nfunction isLetter(char) {\n  return /[A-Z]/i.test(char);\n}\n\nfunction toCharCodeUpper(char) {\n  return char.toUpperCase().charCodeAt(0) - 65; // 0-based index A=0 ... Z=25\n}\n\nfunction fromCharCodeUpper(code) {\n  return String.fromCharCode(code + 65);\n}\n\nfunction vigenereEncrypt(plaintext, key) {\n  let result = '';\n  key = key.toUpperCase().replace(/[^A-Z]/g, '');\n  if (key.length === 0) return null;\n  let keyIndex = 0;\n\n  for (let char of plaintext) {\n    if (isLetter(char)) {\n      let p = toCharCodeUpper(char);\n      let k = toCharCodeUpper(key[keyIndex % key.length]);\n      let c = (p + k) % 26;\n      // Preserve original case\n      result += char === char.toUpperCase() ? fromCharCodeUpper(c) : fromCharCodeUpper(c).toLowerCase();\n      keyIndex++;\n    } else {\n      result += char;\n    }\n  }\n  return result;\n}\n\nfunction vigenereDecrypt(ciphertext, key) {\n  let result = '';\n  key = key.toUpperCase().replace(/[^A-Z]/g, '');\n  if (key.length === 0) return null;\n  let keyIndex = 0;\n\n  for (let char of ciphertext) {\n    if (isLetter(char)) {\n      let c = toCharCodeUpper(char);\n      let k = toCharCodeUpper(key[keyIndex % key.length]);\n      let p = (c - k + 26) % 26;\n      result += char === char.toUpperCase() ? fromCharCodeUpper(p) : fromCharCodeUpper(p).toLowerCase();\n      keyIndex++;\n    } else {\n      result += char;\n    }\n  }\n  return result;\n}\n\n// DOM elements\nconst plaintextInput = document.getElementById('plaintext');\nconst keyInput = document.getElementById('key');\nconst encryptBtn = document.getElementById('encryptBtn');\nconst ciphertextOutput = document.getElementById('ciphertext');\nconst decryptBtn = document.getElementById('decryptBtn');\nconst decryptedOutput = document.getElementById('decrypted');\nconst decryptedLabel = decryptedOutput.previousElementSibling;\n\n// Event listeners\n\nencryptBtn.addEventListener('click', () => {\n  let plaintext = plaintextInput.value.trim();\n  let key = keyInput.value.trim();\n\n  if (!plaintext) {\n    alert('Please enter a message to encrypt.');\n    return;\n  }\n  if (!key) {\n    alert('Please enter a secret key.');\n    return;\n  }\n\n  let ciphertext = vigenereEncrypt(plaintext, key);\n  if (ciphertext === null) {\n    alert('The key must contain at least one alphabetical character.');\n    return;\n  }\n\n  ciphertextOutput.textContent = ciphertext;\n  decryptBtn.style.display = 'inline-block';\n  decryptedOutput.style.display = 'none';\n  decryptedLabel.style.display = 'none';\n});\n\ndecryptBtn.addEventListener('click', () => {\n  let ciphertext = ciphertextOutput.textContent.trim();\n  let key = keyInput.value.trim();\n\n  if (!ciphertext) {\n    alert('No ciphertext to decrypt.');\n    return;\n  }\n  if (!key) {\n    alert('Please enter the secret key used for encryption.');\n    return;\n  }\n\n  let decrypted = vigenereDecrypt(ciphertext, key);\n  if (decrypted === null) {\n    alert('The key must contain at least one alphabetical character.');\n    return;\n  }\n\n  decryptedOutput.textContent = decrypted;\n  decryptedOutput.style.display = 'block';\n  decryptedLabel.style.display = 'block';\n});\n</script>\n\n</body>\n</html>"
