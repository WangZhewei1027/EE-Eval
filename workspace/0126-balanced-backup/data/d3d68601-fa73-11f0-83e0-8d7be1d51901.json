  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Bucket Sort Demonstration</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#60a5fa;\n      --muted:#94a3b8;\n      --good:#34d399;\n      --bad:#fb7185;\n      --card:#0b1220;\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: linear-gradient(180deg,#071024 0%, #071024 100%);\n      color:#e6eef8;\n    }\n    .container{\n      max-width:1100px;\n      margin:20px auto;\n      padding:18px;\n    }\n    header{\n      display:flex;\n      align-items:center;\n      gap:12px;\n      margin-bottom:14px;\n    }\n    h1{\n      font-size:20px;\n      margin:0;\n      color:var(--accent);\n    }\n    .controls{\n      display:flex;\n      gap:12px;\n      flex-wrap:wrap;\n      background:rgba(255,255,255,0.02);\n      padding:12px;\n      border-radius:8px;\n      margin-bottom:12px;\n      align-items:center;\n    }\n    .control-group{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      color:var(--muted);\n      font-size:13px;\n    }\n    input[type=range]{\n      accent-color: var(--accent);\n    }\n    button{\n      background:var(--accent);\n      color:#082034;\n      border:none;\n      padding:8px 12px;\n      border-radius:6px;\n      cursor:pointer;\n      font-weight:600;\n      box-shadow: 0 2px 8px rgba(0,0,0,0.35);\n    }\n    button.secondary{\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.06);\n      color:var(--muted);\n    }\n    .board{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:8px;\n      padding:12px;\n    }\n    .array-area{\n      height:160px;\n      border-radius:6px;\n      background:linear-gradient(180deg,rgba(255,255,255,0.01),transparent);\n      display:flex;\n      align-items:flex-end;\n      gap:4px;\n      padding:10px;\n      overflow:hidden;\n    }\n    .bar{\n      background:linear-gradient(180deg,var(--accent),#3b82f6);\n      border-radius:4px 4px 2px 2px;\n      flex:0 0 auto;\n      display:flex;\n      align-items:end;\n      justify-content:center;\n      color:rgba(255,255,255,0.9);\n      font-size:11px;\n      padding-bottom:4px;\n      box-shadow: 0 1px 4px rgba(2,6,23,0.6), inset 0 -8px 18px rgba(255,255,255,0.03);\n      transition: transform 200ms ease, background 200ms;\n    }\n    .bar.dim{\n      opacity:0.28;\n      transform: scaleY(0.98);\n    }\n    .bar.highlight{\n      background: linear-gradient(180deg,#fb923c,#f97316);\n      box-shadow: 0 6px 20px rgba(249,115,22,0.12);\n      z-index:2;\n      transform: translateY(-6px);\n    }\n    .bar.moving{\n      opacity:0.95;\n      transform: scale(1.04) translateY(-10px);\n      box-shadow: 0 20px 60px rgba(0,0,0,0.45);\n    }\n    .buckets{\n      margin-top:14px;\n      display:flex;\n      gap:8px;\n      overflow:auto;\n      padding-bottom:8px;\n    }\n    .bucket{\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n      border-radius:6px;\n      min-width:80px;\n      max-width:260px;\n      padding:8px;\n      border:1px dashed rgba(255,255,255,0.03);\n      display:flex;\n      flex-direction:column;\n      gap:8px;\n      align-items:center;\n      flex:0 0 auto;\n      color:var(--muted);\n      font-size:12px;\n    }\n    .bucket-label{\n      width:100%;\n      text-align:center;\n      font-size:12px;\n      color:var(--muted);\n      border-bottom:1px solid rgba(255,255,255,0.02);\n      padding-bottom:6px;\n    }\n    .bucket-slot{\n      display:flex;\n      gap:6px;\n      align-items:flex-end;\n      justify-content:center;\n      width:100%;\n      min-height:64px;\n      overflow:hidden;\n    }\n    .log{\n      font-size:13px;\n      color:var(--muted);\n      margin-top:10px;\n    }\n    .legend{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      margin-left:auto;\n    }\n    .chip{\n      background:#061122;\n      padding:6px 8px;\n      border-radius:6px;\n      font-size:13px;\n      color:var(--muted);\n      display:flex;\n      gap:8px;\n      align-items:center;\n    }\n    footer{\n      margin-top:10px;\n      color:var(--muted);\n      font-size:13px;\n    }\n    @media (max-width:720px){\n      .buckets{ gap:6px; }\n      .bucket{ min-width:60px; padding:6px; }\n      .array-area{ height:120px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <header>\n      <h1>Bucket Sort — Visual Demonstration</h1>\n      <div class=\"legend\" title=\"Legend\">\n        <div class=\"chip\">Orange = active / moving</div>\n        <div class=\"chip\">Blue = idle</div>\n      </div>\n    </header>\n\n    <div class=\"controls\">\n      <div class=\"control-group\">\n        <label>Array size:</label>\n        <input id=\"size\" type=\"range\" min=\"6\" max=\"80\" value=\"20\" />\n        <span id=\"sizeVal\">20</span>\n      </div>\n\n      <div class=\"control-group\">\n        <label>Buckets:</label>\n        <input id=\"bcount\" type=\"range\" min=\"1\" max=\"20\" value=\"6\" />\n        <span id=\"bcountVal\">6</span>\n      </div>\n\n      <div class=\"control-group\">\n        <label>Speed (ms):</label>\n        <input id=\"speed\" type=\"range\" min=\"10\" max=\"800\" value=\"180\" />\n        <span id=\"speedVal\">180</span>\n      </div>\n\n      <button id=\"gen\">Generate</button>\n      <button id=\"start\">Start Sort</button>\n      <button id=\"stop\" class=\"secondary\">Stop</button>\n      <button id=\"reset\" class=\"secondary\">Reset</button>\n    </div>\n\n    <div class=\"board\">\n      <div style=\"display:flex; align-items:center; gap:12px; margin-bottom:8px;\">\n        <div style=\"color:var(--muted); font-size:13px;\">Main array (unsorted → sorted)</div>\n        <div style=\"margin-left:auto; color:var(--muted); font-size:13px;\" id=\"stats\">Min: — Max: —</div>\n      </div>\n\n      <div id=\"array\" class=\"array-area\" aria-label=\"Array area\"></div>\n\n      <div id=\"buckets\" class=\"buckets\"></div>\n\n      <div class=\"log\" id=\"log\">Click \"Generate\" then \"Start Sort\". Buckets receive elements by mapping values into ranges, each bucket is sorted (insertion) and concatenated.</div>\n    </div>\n\n    <footer>Bucket Sort groups elements into buckets by range, sorts buckets individually, and concatenates them. This demo uses insertion sort inside each bucket for clarity.</footer>\n  </div>\n\n  <script>\n    // Utility sleep\n    const sleep = ms => new Promise(r => setTimeout(r, ms));\n\n    // Elements\n    const arrayEl = document.getElementById('array');\n    const bucketsEl = document.getElementById('buckets');\n    const genBtn = document.getElementById('gen');\n    const startBtn = document.getElementById('start');\n    const stopBtn = document.getElementById('stop');\n    const resetBtn = document.getElementById('reset');\n\n    const sizeInput = document.getElementById('size');\n    const bcountInput = document.getElementById('bcount');\n    const speedInput = document.getElementById('speed');\n\n    const sizeVal = document.getElementById('sizeVal');\n    const bcountVal = document.getElementById('bcountVal');\n    const speedVal = document.getElementById('speedVal');\n    const logEl = document.getElementById('log');\n    const statsEl = document.getElementById('stats');\n\n    let array = [];\n    let bars = []; // DOM nodes in main array (may be empty when moved)\n    let running = false;\n    let stopped = false;\n    let bucketCount = parseInt(bcountInput.value,10);\n    let animationDelay = parseInt(speedInput.value,10);\n\n    // Update UI labels\n    sizeInput.addEventListener('input', ()=> sizeVal.textContent = sizeInput.value);\n    bcountInput.addEventListener('input', ()=> {\n      bcountVal.textContent = bcountInput.value;\n      bucketCount = +bcountInput.value;\n    });\n    speedInput.addEventListener('input', ()=> {\n      speedVal.textContent = speedInput.value;\n      animationDelay = +speedInput.value;\n    });\n\n    // Create a random array of integers in [0,100]\n    function generateArray(n){\n      array = Array.from({length:n}, ()=> Math.floor(Math.random()*101));\n      renderMainArray();\n      clearBuckets();\n      updateStats();\n      log(\"Generated new random array.\");\n    }\n\n    function updateStats(){\n      if(array.length === 0){ statsEl.textContent = \"Min: — Max: —\"; return; }\n      const mn = Math.min(...array).toFixed(0);\n      const mx = Math.max(...array).toFixed(0);\n      statsEl.textContent = `Min: ${mn} Max: ${mx}`;\n    }\n\n    function renderMainArray(){\n      arrayEl.innerHTML = '';\n      bars = [];\n      const n = array.length;\n      const gap = 4;\n      const areaWidth = arrayEl.clientWidth || 1000;\n      // compute bar width (flex basis)\n      const barWidth = Math.max(6, Math.floor((areaWidth - gap*(n-1))/n) );\n      const maxVal = Math.max(...array,1);\n      for(let i=0;i<n;i++){\n        const v = array[i];\n        const bar = document.createElement('div');\n        bar.className = 'bar';\n        bar.style.width = barWidth + 'px';\n        bar.style.height = Math.max(6, Math.round((v / maxVal) * (arrayEl.clientHeight - 12))) + 'px';\n        bar.textContent = v;\n        bar.dataset.value = v;\n        bar.dataset.index = i;\n        arrayEl.appendChild(bar);\n        bars.push(bar);\n      }\n    }\n\n    function clearBuckets(){\n      bucketsEl.innerHTML = '';\n    }\n\n    function createBuckets(count){\n      bucketsEl.innerHTML = '';\n      for(let i=0;i<count;i++){\n        const b = document.createElement('div');\n        b.className = 'bucket';\n        b.dataset.index = i;\n        const label = document.createElement('div');\n        label.className = 'bucket-label';\n        label.textContent = `Bucket ${i}`;\n        const slot = document.createElement('div');\n        slot.className = 'bucket-slot';\n        slot.dataset.index = i;\n        b.appendChild(label);\n        b.appendChild(slot);\n        bucketsEl.appendChild(b);\n      }\n    }\n\n    function log(msg){\n      logEl.textContent = msg;\n    }\n\n    // Compute bucket index for a given value\n    function bucketIndex(val, min, max, count){\n      if(count <= 1) return 0;\n      const range = max - min;\n      if(range === 0) return 0;\n      // distribute evenly across [0, count-1]\n      let idx = Math.floor(((val - min) / (range)) * (count - 1 + 1e-9));\n      if(idx < 0) idx = 0;\n      if(idx >= count) idx = count - 1;\n      return idx;\n    }\n\n    // Highlight helper\n    function highlight(node, cls='highlight'){\n      node.classList.add(cls);\n    }\n    function unhighlight(node, cls='highlight'){\n      node.classList.remove(cls);\n    }\n\n    // The core bucket sort visualization\n    async function bucketSortVisual(){\n      if(running) return;\n      running = true;\n      stopped = false;\n      startBtn.disabled = true;\n      genBtn.disabled = true;\n      sizeInput.disabled = true;\n      bcountInput.disabled = true;\n      speedInput.disabled = true;\n      resetBtn.disabled = true;\n      stopBtn.disabled = false;\n\n      const n = array.length;\n      if(n <= 1){\n        log(\"Array too small to sort.\");\n        cleanup();\n        return;\n      }\n      const min = Math.min(...array);\n      const max = Math.max(...array);\n      updateStats();\n\n      createBuckets(bucketCount);\n      await sleep(animationDelay);\n\n      // Stage 1: Distribute\n      log(\"Distributing elements into buckets...\");\n      for(let i=0;i<n;i++){\n        if(stopped) break;\n        const val = array[i];\n        const idx = bucketIndex(val, min, max, bucketCount);\n        const bar = bars[i];\n        if(!bar) continue;\n        highlight(bar, 'moving');\n        // Append to bucket slot (visual move)\n        const slot = bucketsEl.querySelector(`.bucket-slot[data-index=\"${idx}\"]`);\n        // Clone to preserve label while we may later move original back\n        slot.appendChild(bar);\n        bar.style.transform = ''; // reset transforms\n        // After appending, change class to normal but small delay\n        await sleep(animationDelay);\n        unhighlight(bar, 'moving');\n        await sleep( Math.max(10, animationDelay/3) );\n      }\n\n      if(stopped){\n        log(\"Stopped by user during distribution.\");\n        cleanup();\n        return;\n      }\n\n      // Stage 2: Sort each bucket (we'll use insertion sort inside each bucket)\n      log(\"Sorting each bucket individually...\");\n      const bucketSlots = Array.from(bucketsEl.querySelectorAll('.bucket-slot'));\n      for(let bi=0; bi<bucketSlots.length; bi++){\n        if(stopped) break;\n        const slot = bucketSlots[bi];\n        // Get children bars as array (note: they are DOM nodes)\n        // We'll perform insertion sort by comparing numeric values and rearranging DOM nodes\n        let children = Array.from(slot.children);\n        // Visual slight dim all other buckets\n        bucketsEl.querySelectorAll('.bucket').forEach(b => b.style.opacity = '0.7');\n        slot.parentElement.style.opacity = '1';\n        for(let j=1; j<children.length; j++){\n          if(stopped) break;\n          let keyNode = children[j];\n          const keyVal = Number(keyNode.dataset.value);\n          highlight(keyNode, 'highlight');\n          await sleep(animationDelay);\n          let k = j - 1;\n          while(k >= 0 && Number(children[k].dataset.value) > keyVal){\n            // shift right\n            const from = children[k];\n            const to = children[k+1];\n            // swap in DOM by inserting 'to' before 'from' (i.e., move from to the right)\n            slot.insertBefore(from, to.nextSibling); // moves 'from' after 'to'\n            // update array\n            children[k+1] = children[k];\n            k--;\n            await sleep(Math.max(40, animationDelay/1.2));\n            if(stopped) break;\n          }\n          children[k+1] = keyNode;\n          unhighlight(keyNode, 'highlight');\n        }\n        // restore opacity\n        bucketsEl.querySelectorAll('.bucket').forEach(b => b.style.opacity = '1');\n        await sleep(animationDelay);\n      }\n\n      if(stopped){\n        log(\"Stopped by user during bucket sorting.\");\n        cleanup();\n        return;\n      }\n\n      // Stage 3: Concatenate back into main array\n      log(\"Concatenating buckets back into main array...\");\n      // Clear main array area and re-create placeholder layout for final collection\n      arrayEl.innerHTML = '';\n      // We'll take elements from buckets in order and append to main array\n      const finalBars = [];\n      for(let bi=0; bi<bucketCount; bi++){\n        if(stopped) break;\n        const slot = bucketsEl.querySelector(`.bucket-slot[data-index=\"${bi}\"]`);\n        const items = Array.from(slot.children);\n        for(let item of items){\n          highlight(item, 'moving');\n          arrayEl.appendChild(item);\n          finalBars.push(item);\n          await sleep(Math.max(20, animationDelay/1.8));\n          unhighlight(item, 'moving');\n        }\n      }\n\n      if(stopped){\n        log(\"Stopped by user during concatenation.\");\n        cleanup();\n        return;\n      }\n\n      // Update internal array and bars references\n      array = finalBars.map(b => Number(b.dataset.value));\n      bars = finalBars;\n      renderHeights();\n      log(\"Sorting finished! Array is now sorted (within bucket sort's behavior).\");\n      cleanup();\n    }\n\n    function renderHeights(){\n      const maxVal = Math.max(...array,1);\n      for(let i=0;i<bars.length;i++){\n        const b = bars[i];\n        const v = Number(b.dataset.value);\n        b.style.height = Math.max(6, Math.round((v / maxVal) * (arrayEl.clientHeight - 12))) + 'px';\n        b.textContent = v;\n      }\n      updateStats();\n    }\n\n    function cleanup(){\n      running = false;\n      startBtn.disabled = false;\n      genBtn.disabled = false;\n      sizeInput.disabled = false;\n      bcountInput.disabled = false;\n      speedInput.disabled = false;\n      resetBtn.disabled = false;\n      stopBtn.disabled = true;\n    }\n\n    // Event handlers\n    genBtn.addEventListener('click', ()=>{\n      const n = +sizeInput.value;\n      generateArray(n);\n    });\n\n    startBtn.addEventListener('click', async ()=>{\n      if(array.length === 0){\n        generateArray(+sizeInput.value);\n      }\n      bucketCount = +bcountInput.value;\n      animationDelay = +speedInput.value;\n      stopped = false;\n      await bucketSortVisual();\n    });\n\n    stopBtn.addEventListener('click', ()=>{\n      if(!running) return;\n      stopped = true;\n      log(\"Stopping... will halt at next safe point.\");\n      stopBtn.disabled = true;\n    });\n\n    resetBtn.addEventListener('click', ()=>{\n      stopped = true;\n      running = false;\n      generateArray(+sizeInput.value);\n      clearBuckets();\n      log(\"Reset to newly generated data.\");\n    });\n\n    // Initialize default array on load\n    window.addEventListener('load', ()=>{\n      sizeVal.textContent = sizeInput.value;\n      bcountVal.textContent = bcountInput.value;\n      speedVal.textContent = speedInput.value;\n      generateArray(+sizeInput.value);\n      stopBtn.disabled = true;\n    });\n\n    // Allow window resize to re-render heights to fit area\n    let resizeTimer;\n    window.addEventListener('resize', ()=>{\n      clearTimeout(resizeTimer);\n      resizeTimer = setTimeout(()=> renderHeights(), 120);\n    });\n\n    // Accessibility: space to start/stop\n    window.addEventListener('keydown', (e)=>{\n      if(e.code === 'Space'){\n        e.preventDefault();\n        if(running) stopBtn.click();\n        else startBtn.click();\n      }\n    });\n  </script>\n</body>\n</html>"
  },
