  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Prim's Algorithm Visualization</title>\n<style>\n  body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 0; display: flex; height: 100vh; }\n  #left { width: 820px; border-right: 1px solid #ddd; padding: 10px; box-sizing: border-box; background: #fafafa; }\n  #controls { margin-bottom: 10px; display:flex; gap:10px; align-items:center; flex-wrap:wrap; }\n  label { font-size: 13px; color: #333; }\n  input[type=\"range\"] { width: 140px; }\n  button { padding: 6px 10px; border-radius: 5px; border: 1px solid #bbb; background: #fff; cursor: pointer; }\n  button:active { transform: translateY(1px); }\n  #canvasWrap { width: 800px; height: 600px; background: white; border: 1px solid #ccc; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }\n  svg { width: 800px; height: 600px; display:block; user-select:none; }\n  .node { cursor: pointer; }\n  .node text { pointer-events: none; }\n  #right { flex:1; padding: 12px; box-sizing:border-box; overflow:auto; }\n  h2 { margin: 6px 0 10px 0; font-size: 16px; }\n  .panel { background: #fff; border: 1px solid #eee; padding: 10px; margin-bottom: 10px; border-radius: 6px; }\n  .edge-label { font-size: 12px; fill: #222; pointer-events:none; }\n  .status { font-size: 14px; margin-bottom: 6px; }\n  ul { padding-left: 18px; margin-top: 6px; }\n  .pq-item { font-family: monospace; font-size: 13px; }\n  .pseudocode { font-family: monospace; background:#f6f6f6; padding:8px; border-radius:6px; line-height:1.5; }\n  .pc-line { padding:2px 6px; border-radius:4px; display:block; }\n  .pc-highlight { background: #fffbdd; border-left: 3px solid #f1c40f; }\n  .muted { color:#666; font-size:13px; }\n  #legend { display:flex; gap:12px; margin-top:8px; flex-wrap:wrap; }\n  .legendItem { display:flex; gap:6px; align-items:center; font-size:13px; }\n  .swatch { width:18px; height:10px; border-radius:2px; border:1px solid #ccc; }\n  footer { font-size:12px; color:#666; margin-top:6px; }\n</style>\n</head>\n<body>\n<div id=\"left\">\n  <div id=\"controls\" class=\"panel\">\n    <div>\n      <label>Nodes: <span id=\"nodeCountLbl\">12</span></label><br>\n      <input id=\"nodeCount\" type=\"range\" min=\"5\" max=\"18\" value=\"12\">\n    </div>\n    <div>\n      <label>Density: <span id=\"densityLbl\">0.35</span></label><br>\n      <input id=\"density\" type=\"range\" min=\"0\" max=\"1\" step=\"0.05\" value=\"0.35\">\n    </div>\n    <div style=\"display:flex; flex-direction:column; gap:6px;\">\n      <button id=\"regen\">Regenerate Graph</button>\n      <button id=\"randomizePos\">Randomize Positions</button>\n    </div>\n\n    <div style=\"margin-left:auto; display:flex; gap:8px;\">\n      <button id=\"initBtn\">Init Prim</button>\n      <button id=\"stepBtn\">Step</button>\n      <button id=\"autoBtn\">Auto</button>\n      <button id=\"resetBtn\">Reset</button>\n    </div>\n  </div>\n\n  <div id=\"canvasWrap\">\n    <svg id=\"svg\"></svg>\n  </div>\n  <div style=\"margin-top:6px; display:flex; justify-content:space-between;\">\n    <div class=\"muted\">Click a node to pick start node before \"Init\". Drag nodes to reposition.</div>\n    <div class=\"muted\">Edge weight = Euclidean distance (rounded)</div>\n  </div>\n</div>\n\n<div id=\"right\">\n  <h2>Prim's Algorithm - Interactive Demo</h2>\n\n  <div class=\"panel\">\n    <div class=\"status\"><strong>Start node:</strong> <span id=\"startNode\">None</span></div>\n    <div class=\"status\"><strong>MST total weight:</strong> <span id=\"mstWeight\">0</span></div>\n    <div class=\"status\"><strong>Edges in MST:</strong> <span id=\"mstEdges\">0 / 0</span></div>\n    <div class=\"status\"><strong>Last action:</strong> <span id=\"lastAction\">—</span></div>\n    <div style=\"margin-top:8px;\">\n      <button id=\"clearSelection\">Clear Start</button>\n    </div>\n    <div id=\"legend\">\n      <div class=\"legendItem\"><div class=\"swatch\" style=\"background:#999\"></div> default edge</div>\n      <div class=\"legendItem\"><div class=\"swatch\" style=\"background:orange\"></div> candidate (in PQ)</div>\n      <div class=\"legendItem\"><div class=\"swatch\" style=\"background:seagreen\"></div> selected / in MST</div>\n      <div class=\"legendItem\"><div class=\"swatch\" style=\"background:#ff6b6b\"></div> skipped</div>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <h3 style=\"margin:0 0 8px 0;\">Priority Queue (frontier)</h3>\n    <div id=\"pqList\" style=\"max-height:180px; overflow:auto; font-family:monospace;\"></div>\n  </div>\n\n  <div class=\"panel\">\n    <h3 style=\"margin:0 0 8px 0;\">Pseudocode (highlights current step)</h3>\n    <div class=\"pseudocode\" id=\"pseudocode\">\n      <div id=\"pc1\" class=\"pc-line\">1: Select any start vertex s, mark visited(s) = true</div>\n      <div id=\"pc2\" class=\"pc-line\">2: Insert all edges (s, v) into priority queue by weight</div>\n      <div id=\"pc3\" class=\"pc-line\">3: While PQ not empty and not all vertices visited:</div>\n      <div id=\"pc4\" class=\"pc-line\" style=\"margin-left:16px;\">3.1: Extract edge (u, v) with min weight</div>\n      <div id=\"pc5\" class=\"pc-line\" style=\"margin-left:16px;\">3.2: If visited(v) continue (skip)</div>\n      <div id=\"pc6\" class=\"pc-line\" style=\"margin-left:16px;\">3.3: Add (u,v) to MST, mark visited(v) = true</div>\n      <div id=\"pc7\" class=\"pc-line\" style=\"margin-left:16px;\">3.4: Insert all edges (v, x) where visited(x)=false into PQ</div>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <h3 style=\"margin:0 0 8px 0;\">Notes</h3>\n    <ul>\n      <li>Click a node to choose the starting vertex before \"Init\".</li>\n      <li>Press \"Init Prim\" to begin. Then use \"Step\" to advance one edge selection at a time.</li>\n      <li>\"Auto\" runs steps every 700ms. \"Reset\" clears algorithm (keeps graph).</li>\n      <li>The demo ensures the graph is connected on generation.</li>\n    </ul>\n    <footer>Visualization created to demonstrate how Prim's greedy choice grows a minimum spanning tree.</footer>\n  </div>\n</div>\n\n<script>\n(() => {\n  const svg = document.getElementById('svg');\n  const width = 800, height = 600;\n  svg.setAttribute('viewBox', `0 0 ${width} ${height}`);\n\n  // UI elements\n  const nodeCountSlider = document.getElementById('nodeCount');\n  const densitySlider = document.getElementById('density');\n  const nodeCountLbl = document.getElementById('nodeCountLbl');\n  const densityLbl = document.getElementById('densityLbl');\n  const regenBtn = document.getElementById('regen');\n  const randomizePosBtn = document.getElementById('randomizePos');\n  const initBtn = document.getElementById('initBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const autoBtn = document.getElementById('autoBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const clearSelBtn = document.getElementById('clearSelection');\n\n  const startNodeLbl = document.getElementById('startNode');\n  const mstWeightLbl = document.getElementById('mstWeight');\n  const mstEdgesLbl = document.getElementById('mstEdges');\n  const lastActionLbl = document.getElementById('lastAction');\n  const pqListDiv = document.getElementById('pqList');\n\n  const pcLines = {\n    1: document.getElementById('pc1'),\n    2: document.getElementById('pc2'),\n    3: document.getElementById('pc3'),\n    4: document.getElementById('pc4'),\n    5: document.getElementById('pc5'),\n    6: document.getElementById('pc6'),\n    7: document.getElementById('pc7'),\n  };\n\n  nodeCountLbl.textContent = nodeCountSlider.value;\n  densityLbl.textContent = densitySlider.value;\n\n  nodeCountSlider.addEventListener('input', () => nodeCountLbl.textContent = nodeCountSlider.value);\n  densitySlider.addEventListener('input', () => densityLbl.textContent = densitySlider.value);\n\n  // Graph structures\n  let nodes = []; // {id,x,y,visited,group, circleElem, labelElem}\n  let edges = []; // {id,u,v,w,elemLine, elemLabel, state: 'default'|'pq'|'mst'|'skipped'}\n  let adj = [];   // adjacency lists of edges indices\n\n  // Algorithm state\n  let startNode = null;\n  let visited = new Set();\n  let pq = []; // array of {from, to, weight, edgeId}\n  let mstEdges = [];\n  let mstWeight = 0;\n  let inited = false;\n  let autoInterval = null;\n  let dragging = null;\n\n  // Utility: create SVG elements\n  function svgEl(name, attrs = {}) {\n    const e = document.createElementNS('http://www.w3.org/2000/svg', name);\n    for (const k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  // Create connected random graph\n  function generateGraph(n, density) {\n    // clear old\n    nodes = []; edges = []; adj = [];\n    while (svg.firstChild) svg.removeChild(svg.firstChild);\n\n    // random positions with padding\n    for (let i=0;i<n;i++) {\n      const x = 40 + Math.random() * (width - 80);\n      const y = 40 + Math.random() * (height - 80);\n      nodes.push({id:i, x, y, visited:false, circle:null, label:null});\n      adj.push([]);\n    }\n\n    // Ensure connectivity: create random spanning tree first\n    let edgeId = 0;\n    for (let v = 1; v < n; v++) {\n      const u = Math.floor(Math.random()*v); // connect to an earlier node\n      addEdge(u, v, edgeId++);\n    }\n\n    // Add additional edges based on density\n    for (let i=0;i<n;i++) {\n      for (let j=i+1;j<n;j++) {\n        if (edgeExistsBetween(i,j)) continue;\n        if (Math.random() < density) {\n          addEdge(i, j, edgeId++);\n        }\n      }\n    }\n\n    // draw edges and nodes\n    drawGraph();\n    resetAlgorithmState();\n  }\n\n  function edgeExistsBetween(u,v) {\n    return edges.some(e => (e.u===u && e.v===v) || (e.u===v && e.v===u));\n  }\n\n  function addEdge(u,v,id) {\n    const nu = nodes[u], nv = nodes[v];\n    const dx = nu.x - nv.x, dy = nu.y - nv.y;\n    const w = Math.max(1, Math.round(Math.hypot(dx,dy)));\n    const e = {id:id, u:u, v:v, w:w, state:'default', line:null, label:null};\n    edges.push(e);\n    adj[u].push(id);\n    adj[v].push(id);\n  }\n\n  function drawGraph() {\n    // edges first\n    for (const e of edges) {\n      const nu = nodes[e.u], nv = nodes[e.v];\n      const line = svgEl('line', {\n        x1:nu.x, y1:nu.y, x2:nv.x, y2:nv.y,\n        stroke:'#999', 'stroke-width':2, 'stroke-linecap':'round'\n      });\n      svg.appendChild(line);\n      e.line = line;\n\n      // weight label: midpoint\n      const mx = (nu.x + nv.x)/2, my = (nu.y + nv.y)/2;\n      const bg = svgEl('rect', {\n        x: mx-14, y: my-12, width: 28, height: 18, rx:4, ry:4, fill:'#fff', stroke:'#eee'\n      });\n      const t = svgEl('text', {\n        x: mx, y: my+2, 'text-anchor':'middle', 'class':'edge-label'\n      });\n      t.textContent = e.w;\n      svg.appendChild(bg);\n      svg.appendChild(t);\n      e.label = t;\n      e.labelBg = bg;\n    }\n\n    // nodes on top\n    for (const n of nodes) {\n      const g = svgEl('g', {class:'node', cursor:'pointer'});\n      const circle = svgEl('circle', {\n        cx:n.x, cy:n.y, r:14, fill:'#fff', stroke:'#2c3e50', 'stroke-width':2\n      });\n      const text = svgEl('text', {\n        x:n.x, y:n.y+4, 'text-anchor':'middle', 'font-size':12, fill:'#111'\n      });\n      text.textContent = n.id;\n      g.appendChild(circle);\n      g.appendChild(text);\n      svg.appendChild(g);\n      n.circle = circle;\n      n.label = text;\n\n      // events\n      g.addEventListener('mousedown', (ev)=> {\n        if (ev.button !== 0) return;\n        dragging = {node:n, offsetX: ev.clientX, offsetY: ev.clientY};\n        ev.preventDefault();\n      });\n\n      g.addEventListener('click', (ev)=> {\n        // choose start node if not inited\n        if (!inited) {\n          setStartNode(n.id);\n        }\n      });\n    }\n\n    // pointer capture on svg for dragging\n    window.addEventListener('mousemove', (ev)=> {\n      if (!dragging) return;\n      const p = dragging.node;\n      // compute coordinates relative to svg\n      const rect = svg.getBoundingClientRect();\n      let cx = ev.clientX - rect.left;\n      let cy = ev.clientY - rect.top;\n      cx = Math.max(20, Math.min(width-20, cx));\n      cy = Math.max(20, Math.min(height-20, cy));\n      p.x = cx; p.y = cy;\n      updatePositions();\n    });\n    window.addEventListener('mouseup', ()=> dragging = null);\n  }\n\n  function updatePositions() {\n    // update edges\n    for (const e of edges) {\n      const nu = nodes[e.u], nv = nodes[e.v];\n      e.line.setAttribute('x1', nu.x); e.line.setAttribute('y1', nu.y);\n      e.line.setAttribute('x2', nv.x); e.line.setAttribute('y2', nv.y);\n      const mx = (nu.x + nv.x)/2, my = (nu.y + nv.y)/2;\n      e.label.setAttribute('x', mx); e.label.setAttribute('y', my+2);\n      e.labelBg.setAttribute('x', mx-14); e.labelBg.setAttribute('y', my-12);\n      // recompute weight based on new position\n      const dx = nu.x - nv.x, dy = nu.y - nv.y;\n      const w = Math.max(1, Math.round(Math.hypot(dx,dy)));\n      e.w = w;\n      e.label.textContent = e.w;\n    }\n    // update nodes\n    for (const n of nodes) {\n      n.circle.setAttribute('cx', n.x);\n      n.circle.setAttribute('cy', n.y);\n      n.label.setAttribute('x', n.x);\n      n.label.setAttribute('y', n.y+4);\n    }\n    // update pq weights if any\n    refreshPQDisplay();\n    // if MST exists update weight and list\n    updateMSTStats();\n  }\n\n  // Algorithm functions\n  function resetAlgorithmState() {\n    // clear visit, pq, mst, colors\n    inited = false;\n    visited.clear();\n    pq = [];\n    mstEdges = [];\n    mstWeight = 0;\n    startNode = null;\n    startNodeLbl.textContent = 'None';\n    mstWeightLbl.textContent = '0';\n    mstEdgesLbl.textContent = `0 / ${nodes.length-1}`;\n    lastActionLbl.textContent = '—';\n    setPseudocode(null);\n    clearEdgeStyles();\n    updateNodeStyles();\n    refreshPQDisplay();\n    stopAuto();\n  }\n\n  function clearEdgeStyles() {\n    for (const e of edges) {\n      e.state = 'default';\n      e.line.setAttribute('stroke', '#999');\n      e.line.setAttribute('stroke-width', 2);\n      e.labelBg.setAttribute('fill', '#fff');\n      e.label.setAttribute('fill', '#222');\n      e.line.style.opacity = 1;\n    }\n  }\n\n  function updateNodeStyles() {\n    for (const n of nodes) {\n      if (visited.has(n.id)) {\n        n.circle.setAttribute('fill', '#f1f8f1');\n        n.circle.setAttribute('stroke', 'seagreen');\n      } else {\n        n.circle.setAttribute('fill', '#fff');\n        n.circle.setAttribute('stroke', '#2c3e50');\n      }\n    }\n  }\n\n  function setStartNode(id) {\n    startNode = id;\n    startNodeLbl.textContent = id;\n    // visually mark selection\n    nodes.forEach(n => {\n      if (n.id===id) {\n        n.circle.setAttribute('stroke', '#e67e22');\n        n.circle.setAttribute('stroke-width', 3);\n      } else {\n        n.circle.setAttribute('stroke-width', 2);\n        n.circle.setAttribute('stroke', visited.has(n.id) ? 'seagreen' : '#2c3e50');\n      }\n    });\n  }\n\n  function clearStartSelection() {\n    startNode = null;\n    startNodeLbl.textContent = 'None';\n    nodes.forEach(n => {\n      n.circle.setAttribute('stroke-width', 2);\n      n.circle.setAttribute('stroke', visited.has(n.id) ? 'seagreen' : '#2c3e50');\n    });\n  }\n\n  function initPrim() {\n    if (inited) return;\n    if (startNode === null) {\n      alert('Please click a node to select a start node before initializing.');\n      return;\n    }\n    resetVisitedMarks();\n    // mark start visited\n    visited.add(startNode);\n    nodes[startNode].circle.setAttribute('fill', '#f1f8f1');\n    nodes[startNode].circle.setAttribute('stroke', 'seagreen');\n    // insert its incident edges into pq\n    for (const edgeId of adj[startNode]) {\n      const e = edges[edgeId];\n      const other = (e.u === startNode) ? e.v : e.u;\n      if (!visited.has(other)) pushPQ({from:startNode, to:other, weight:e.w, edgeId:edgeId});\n    }\n    inited = true;\n    setPseudocode(2);\n    lastActionLbl.textContent = `Initialized at node ${startNode}. Added ${pq.length} candidate edges.`;\n    refreshPQDisplay();\n    updateNodeStyles();\n    updateEdgeStylesFromPQ();\n    updateMSTStats();\n  }\n\n  function resetVisitedMarks() {\n    visited.clear();\n    for (const n of nodes) n.visited = false;\n    for (const e of edges) {\n      e.state = 'default';\n    }\n    refreshSVGStyles();\n  }\n\n  function refreshSVGStyles() {\n    for (const e of edges) {\n      if (e.state === 'default') {\n        e.line.setAttribute('stroke', '#999'); e.line.setAttribute('stroke-width', 2);\n        e.labelBg.setAttribute('fill', '#fff');\n      } else if (e.state === 'pq') {\n        e.line.setAttribute('stroke', 'orange'); e.line.setAttribute('stroke-width', 3);\n        e.labelBg.setAttribute('fill', '#fff8ea');\n      } else if (e.state === 'mst') {\n        e.line.setAttribute('stroke', 'seagreen'); e.line.setAttribute('stroke-width', 3.5);\n        e.labelBg.setAttribute('fill', '#f0fff3');\n      } else if (e.state === 'skipped') {\n        e.line.setAttribute('stroke', '#ff6b6b'); e.line.setAttribute('stroke-width', 2);\n        e.line.style.opacity = 0.6;\n        e.labelBg.setAttribute('fill', '#fff5f5');\n      }\n    }\n  }\n\n  function pushPQ(item) {\n    // item = {from, to, weight, edgeId}\n    pq.push(item);\n    // sort ascending by weight (and small tie breaker by from,to)\n    pq.sort((a,b) => a.weight - b.weight || a.from - b.from || a.to - b.to);\n    // mark edge as candidate (if not already MST)\n    const e = edges[item.edgeId];\n    if (e.state !== 'mst') e.state = 'pq';\n    refreshSVGStyles();\n  }\n\n  function popPQ() {\n    if (pq.length === 0) return null;\n    const item = pq.shift();\n    return item;\n  }\n\n  function stepPrim() {\n    if (!inited) {\n      alert('Call \"Init Prim\" first to choose a start and populate PQ.');\n      return;\n    }\n    if (visited.size === nodes.length) {\n      lastActionLbl.textContent = 'All nodes visited. MST complete.';\n      setPseudocode(null);\n      stopAuto();\n      return;\n    }\n    if (pq.length === 0) {\n      lastActionLbl.textContent = 'PQ empty before visiting all nodes — graph may be disconnected.';\n      setPseudocode(null);\n      stopAuto();\n      return;\n    }\n\n    setPseudocode(4);\n    const item = popPQ();\n    const e = edges[item.edgeId];\n    // temporarily highlight popped edge\n    highlightEdgeTemporarily(e, '#ffd27f');\n\n    // If target already visited, skip\n    if (visited.has(item.to)) {\n      e.state = 'skipped';\n      refreshSVGStyles();\n      lastActionLbl.textContent = `Skipped edge (${item.from} — ${item.to}) weight=${item.weight} (target already visited)`;\n      setPseudocode(5);\n      refreshPQDisplay();\n      return;\n    }\n\n    // Accept edge into MST\n    e.state = 'mst';\n    visited.add(item.to);\n    nodes[item.to].circle.setAttribute('fill', '#f1f8f1');\n    nodes[item.to].circle.setAttribute('stroke', 'seagreen');\n\n    mstEdges.push({edgeId:item.edgeId, from:item.from, to:item.to, w:item.weight});\n    mstWeight += item.weight;\n    lastActionLbl.textContent = `Added edge (${item.from} — ${item.to}) weight=${item.weight} to MST.`;\n    setPseudocode(6);\n\n    // insert all edges incident to newly visited node where other not visited\n    for (const nbEdgeId of adj[item.to]) {\n      const ne = edges[nbEdgeId];\n      const other = (ne.u === item.to) ? ne.v : ne.u;\n      if (!visited.has(other)) {\n        pushPQ({from:item.to, to:other, weight:ne.w, edgeId:nbEdgeId});\n      }\n    }\n    setPseudocode(7);\n    refreshPQDisplay();\n    refreshSVGStyles();\n    updateMSTStats();\n\n    // If finished automatically stop\n    if (visited.size === nodes.length) {\n      lastActionLbl.textContent = `MST complete. Total weight ${mstWeight}`;\n      setPseudocode(null);\n      stopAuto();\n    }\n  }\n\n  function highlightEdgeTemporarily(edge, color) {\n    const original = {stroke: edge.line.getAttribute('stroke'), width: edge.line.getAttribute('stroke-width')};\n    edge.line.setAttribute('stroke', color);\n    edge.line.setAttribute('stroke-width', 4);\n    setTimeout(()=> refreshSVGStyles(), 250);\n  }\n\n  function refreshPQDisplay() {\n    pqListDiv.innerHTML = '';\n    if (pq.length === 0) {\n      pqListDiv.textContent = '(empty)';\n      return;\n    }\n    // show up to first 80 entries\n    const list = document.createElement('div');\n    for (let i=0;i<pq.length;i++) {\n      const it = pq[i];\n      const line = document.createElement('div');\n      line.className = 'pq-item';\n      line.textContent = `${i+1}. (${it.from}→${it.to}) w=${it.weight}`;\n      list.appendChild(line);\n    }\n    pqListDiv.appendChild(list);\n  }\n\n  function updateEdgeStylesFromPQ() {\n    // mark edges present in pq as 'pq' except those already in mst\n    // others default\n    const inPQ = new Set(pq.map(it => it.edgeId));\n    for (const e of edges) {\n      if (e.state === 'mst') continue;\n      if (inPQ.has(e.id)) e.state = 'pq'; else e.state = 'default';\n    }\n    refreshSVGStyles();\n  }\n\n  function updateMSTStats() {\n    mstWeightLbl.textContent = mstWeight.toString();\n    mstEdgesLbl.textContent = `${mstEdges.length} / ${nodes.length-1}`;\n  }\n\n  function setPseudocode(lineNo) {\n    for (const n in pcLines) {\n      pcLines[n].classList.toggle('pc-highlight', Number(n) === lineNo);\n    }\n  }\n\n  function resetAlgorithmKeepGraph() {\n    visited.clear();\n    pq = [];\n    mstEdges = [];\n    mstWeight = 0;\n    inited = false;\n    startNode = null;\n    startNodeLbl.textContent = 'None';\n    lastActionLbl.textContent = 'Reset (graph unchanged).';\n    for (const e of edges) e.state = 'default';\n    for (const n of nodes) {\n      n.circle.setAttribute('fill', '#fff');\n      n.circle.setAttribute('stroke', '#2c3e50');\n    }\n    refreshSVGStyles();\n    refreshPQDisplay();\n    updateMSTStats();\n    setPseudocode(null);\n    stopAuto();\n  }\n\n  function stopAuto() {\n    if (autoInterval) { clearInterval(autoInterval); autoInterval = null; autoBtn.textContent = 'Auto'; }\n  }\n\n  // Button events\n  regenBtn.addEventListener('click', ()=> {\n    const n = Number(nodeCountSlider.value);\n    const density = Number(densitySlider.value);\n    generateGraph(n, density);\n  });\n\n  randomizePosBtn.addEventListener('click', ()=> {\n    for (const n of nodes) {\n      n.x = 40 + Math.random()*(width-80);\n      n.y = 40 + Math.random()*(height-80);\n    }\n    updatePositions();\n  });\n\n  initBtn.addEventListener('click', ()=> initPrim());\n  stepBtn.addEventListener('click', ()=> stepPrim());\n  resetBtn.addEventListener('click', ()=> resetAlgorithmKeepGraph());\n  clearSelBtn.addEventListener('click', ()=> clearStartSelection());\n\n  autoBtn.addEventListener('click', ()=> {\n    if (!inited) {\n      alert('Init first.');\n      return;\n    }\n    if (autoInterval) {\n      stopAuto();\n    } else {\n      autoBtn.textContent = 'Stop';\n      autoInterval = setInterval(()=> {\n        if (!inited) { stopAuto(); return; }\n        if (visited.size === nodes.length || pq.length === 0) {\n          stopAuto();\n          return;\n        }\n        stepPrim();\n      }, 700);\n    }\n  });\n\n  // initialize\n  generateGraph(Number(nodeCountSlider.value), Number(densitySlider.value));\n\n  // small helpers for UI & consistency\n  function updateMSTStatsOnResize() { updateMSTStats(); refreshPQDisplay(); }\n  window.addEventListener('resize', updateMSTStatsOnResize);\n\n  // Make sure edges have stable id (we used array index as id)\n  // but update edges id after generation\n  edges.forEach((e,i)=> e.id = i);\n\n})();\n</script>\n</body>\n</html>"
