    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bucket Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .bucket-container {\n            display: inline-block;\n            margin: 10px;\n        }\n        .bucket {\n            width: 100px;\n            height: 50px;\n            background-color: #ccc;\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Bucket Sort</h1>\n    <div class=\"bucket-container\">\n        <div class=\"bucket\" id=\"bucket-1\">1-10</div>\n        <div class=\"bucket\" id=\"bucket-2\">11-20</div>\n        <div class=\"bucket\" id=\"bucket-3\">21-30</div>\n        <div class=\"bucket\" id=\"bucket-4\">31-40</div>\n        <div class=\"bucket\" id=\"bucket-5\">41-50</div>\n    </div>\n\n    <script>\n        let buckets = document.querySelectorAll('.bucket');\n        let numbers = Array.from({length: 51}, (_, i) => i);\n\n        numbers.forEach((number) => {\n            buckets[number].innerHTML = `Number: ${number}, Bucket: ${buckets[number].textContent}`;\n        });\n\n        let array = Array.from({length: 50}, (_, i) => i);\n        let sortedNumbers = array.sort((a, b) => a - b);\n\n        console.log('Unsorted array:', array);\n\n        sortedNumbers.forEach((number) => {\n            buckets[number].innerHTML = `Number: ${number}, Bucket: ${buckets[number].textContent}`;\n        });\n\n        console.log('Sorted array:', sortedNumbers);\n    </script>\n</body>\n</html>"
