    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>OSI Model Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#2dd4bf;\n      --muted:#9aa8b2;\n      --card:#0f1728;\n      --glass: rgba(255,255,255,0.03);\n      --success:#10b981;\n      --danger:#ef4444;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    html,body{height:100%; margin:0; background:linear-gradient(180deg,#071023 0%, #071018 60%, #051018 100%); color:#d7eef6;}\n    .wrap{display:flex; gap:18px; padding:18px; box-sizing:border-box; min-height:100vh;}\n    header{width:100%; margin-bottom:6px; display:flex; align-items:center; gap:16px;}\n    .title{\n      display:flex;flex-direction:column;\n    }\n    h1{font-size:20px;margin:0;color:var(--accent);}\n    p.lead{margin:0;color:var(--muted);font-size:13px}\n    .left, .center, .right{background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent); border-radius:12px; padding:14px; box-shadow: 0 6px 18px rgba(0,0,0,0.6); }\n    .left{width:280px; flex-shrink:0;}\n    .center{flex:1; display:flex; flex-direction:column; min-width:420px;}\n    .right{width:360px; flex-shrink:0;}\n    /* OSI stack */\n    .stack{display:flex; flex-direction:column; gap:8px}\n    .layer{\n      height:46px; border-radius:8px; display:flex; align-items:center; padding:10px; cursor:pointer; transition:transform .15s ease, box-shadow .15s ease;\n      color:#022; font-weight:700; font-size:13px;\n    }\n    .layer:hover{transform:translateY(-4px); box-shadow:0 8px 24px rgba(0,0,0,0.6)}\n    .layer .name{flex:1}\n    .layer .num{font-weight:800; opacity:.85; background:rgba(255,255,255,0.12); padding:6px 10px; border-radius:999px; color:#fff}\n    /* colors for layers */\n    .l7{background:linear-gradient(90deg,#7dd3fc, #60a5fa); color:#012037}\n    .l6{background:linear-gradient(90deg,#c7b4ff,#a78bfa); color:#0b0330}\n    .l5{background:linear-gradient(90deg,#ffd6a5,#ffb86b); color:#2b1300}\n    .l4{background:linear-gradient(90deg,#bbf7d0,#86efac); color:#05220c}\n    .l3{background:linear-gradient(90deg,#fef08a,#fde047); color:#222100}\n    .l2{background:linear-gradient(90deg,#fbcfe8,#fda4af); color:#2d0016}\n    .l1{background:linear-gradient(90deg,#cfe8ff,#9bd0ff); color:#001029}\n    /* info panel */\n    .info{margin-top:12px;padding:12px;background:var(--glass); border-radius:10px; color:var(--muted); font-size:13px}\n    .info h3{margin:0 0 8px 0; color:var(--accent); font-size:14px}\n    .badge{display:inline-block;padding:6px 8px;border-radius:999px;background:rgba(255,255,255,0.04); font-size:12px; margin-right:6px; color:var(--muted)}\n    /* center area */\n    .controls{display:flex; gap:8px; align-items:center; margin-bottom:12px}\n    .controls input[type=\"text\"]{flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.03); background:transparent;color:inherit}\n    .btn{padding:8px 12px;border-radius:8px;border:none;background:var(--accent); color:#002; font-weight:700; cursor:pointer}\n    .btn.secondary{background:transparent;border:1px solid rgba(255,255,255,0.06); color:var(--muted)}\n    .btn.danger{background:var(--danger); color:white}\n    .middle-stage{display:flex; gap:12px; align-items:center; justify-content:space-between; padding:12px; border-radius:10px; background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent)}\n    .network-path{position:relative; height:260px; background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent); border-radius:8px; padding:12px; overflow:hidden}\n    .node{position:absolute; top:28px; left:10px; display:flex; flex-direction:column; align-items:center; gap:6px}\n    .node .box{width:120px;height:56px;background:rgba(255,255,255,0.03); border-radius:8px; display:flex;align-items:center; justify-content:center; font-weight:700}\n    .path{position:absolute; left:160px; right:160px; top:40px; bottom:40px; display:flex; align-items:center; justify-content:space-between}\n    .router{width:64px;height:64px;border-radius:8px;background:linear-gradient(90deg,#ffd9a8,#ffa760); display:flex;align-items:center; justify-content:center; font-weight:800; color:#331800}\n    .link{height:6px;background:rgba(255,255,255,0.04); border-radius:6px; flex:1; margin:0 16px; position:relative; overflow:hidden}\n    .packet{\n      position:absolute; top:50%; left:8%; transform:translate(-50%,-50%); min-width:140px; padding:10px 12px; border-radius:999px; background:linear-gradient(90deg,#22c55e,#06b6d4); color:#012; font-weight:800; box-shadow:0 8px 24px rgba(0,0,0,0.5);\n      transition:left .7s linear, right .7s linear, top .5s linear;\n      z-index:40;\n      display:flex; gap:8px; align-items:center;\n    }\n    .headers-stack{position:absolute; bottom:12px; right:12px; width:240px; max-height:220px; overflow:auto; padding:8px; background:rgba(255,255,255,0.02); border-radius:10px}\n    .header-row{background:rgba(255,255,255,0.02); padding:6px 8px; margin:6px 0; border-radius:6px; display:flex; justify-content:space-between; font-size:13px}\n    .small{font-size:12px; color:var(--muted)}\n    .detail-title{font-weight:800; color:var(--accent)}\n    .protocols{display:flex; flex-wrap:wrap; gap:6px; margin-top:8px}\n    .proto{background:rgba(255,255,255,0.03); padding:6px 8px; border-radius:6px; color:var(--muted); font-size:12px}\n    /* right panel */\n    .panel-section{margin-bottom:12px}\n    .panel-section h4{margin:0 0 8px 0; color:var(--accent); font-size:13px}\n    .legend{display:flex; flex-direction:column; gap:6px}\n    .legend .item{display:flex; gap:8px; align-items:center}\n    .color-sample{width:36px;height:22px;border-radius:6px; flex-shrink:0; box-shadow:inset 0 -6px 16px rgba(0,0,0,0.3)}\n    .footer-note{font-size:12px; color:var(--muted)}\n    /* small quiz */\n    .quiz{display:flex; flex-direction:column; gap:8px}\n    .qa{background:rgba(255,255,255,0.02); padding:8px; border-radius:8px}\n    .answer{margin-top:6px; display:flex; gap:6px}\n    .chip{padding:6px 8px; border-radius:6px; background:transparent; border:1px solid rgba(255,255,255,0.03); color:var(--muted); cursor:pointer}\n    .chip.correct{background:rgba(16,185,129,0.15); border-color:rgba(16,185,129,0.7); color:var(--success)}\n    .chip.wrong{background:rgba(239,68,68,0.12); border-color:rgba(239,68,68,0.7); color:var(--danger)}\n    /* responsive */\n    @media (max-width:1000px){\n      .wrap{flex-direction:column}\n      .left,.right{width:100%}\n      .center{min-width:auto}\n      .network-path{height:360px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <div style=\"flex:1\">\n      <header>\n        <div class=\"title\">\n          <h1>Interactive OSI Model</h1>\n          <p class=\"lead\">Visualize layers, encapsulation, and packet flow — click a layer for details and animate a message through the stack.</p>\n        </div>\n      </header>\n\n      <div style=\"display:flex; gap:18px;\">\n        <div class=\"left\">\n          <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n            <div style=\"display:flex; gap:8px; align-items:center\">\n              <div style=\"width:40px;height:40px;border-radius:8px;background:linear-gradient(90deg,#2dd4bf,#60a5fa);display:flex;align-items:center;justify-content:center;font-weight:800;color:#003\">OSI</div>\n              <div>\n                <div style=\"font-weight:800;color:var(--accent)\">OSI Reference Model</div>\n                <div style=\"font-size:12px;color:var(--muted)\">Seven-layer conceptual model</div>\n              </div>\n            </div>\n            <div style=\"font-size:12px;color:var(--muted)\">Layered abstraction</div>\n          </div>\n\n          <div class=\"stack\" style=\"margin-top:12px;\" id=\"stack\">\n            <div class=\"layer l7\" data-layer=\"7\" tabindex=\"0\"><div class=\"name\">Application</div><div class=\"num\">7</div></div>\n            <div class=\"layer l6\" data-layer=\"6\" tabindex=\"0\"><div class=\"name\">Presentation</div><div class=\"num\">6</div></div>\n            <div class=\"layer l5\" data-layer=\"5\" tabindex=\"0\"><div class=\"name\">Session</div><div class=\"num\">5</div></div>\n            <div class=\"layer l4\" data-layer=\"4\" tabindex=\"0\"><div class=\"name\">Transport</div><div class=\"num\">4</div></div>\n            <div class=\"layer l3\" data-layer=\"3\" tabindex=\"0\"><div class=\"name\">Network</div><div class=\"num\">3</div></div>\n            <div class=\"layer l2\" data-layer=\"2\" tabindex=\"0\"><div class=\"name\">Data Link</div><div class=\"num\">2</div></div>\n            <div class=\"layer l1\" data-layer=\"1\" tabindex=\"0\"><div class=\"name\">Physical</div><div class=\"num\">1</div></div>\n          </div>\n\n          <div class=\"info\" id=\"info\">\n            <h3>Layer details</h3>\n            <div id=\"infoText\">Click or press Enter on any layer to see responsibilities, common protocols and examples.</div>\n          </div>\n\n          <div class=\"info\" style=\"margin-top:10px;\">\n            <div style=\"display:flex;justify-content:space-between;align-items:center\">\n              <div><strong style=\"color:var(--accent)\">Quick facts</strong></div>\n              <div class=\"small\">Conceptual model — not a strict implementation</div>\n            </div>\n            <div style=\"margin-top:8px\" class=\"small\">\n              Each layer offers services to the layer above and relies on the layer below. Encapsulation happens top → bottom on send; decapsulation bottom → top on receive.\n            </div>\n          </div>\n        </div>\n\n        <div class=\"center\">\n          <div class=\"controls\">\n            <input id=\"messageInput\" type=\"text\" value=\"Hello, OSI!\" aria-label=\"Message to send\"/>\n            <select id=\"transportSelect\" aria-label=\"Transport protocol\">\n              <option value=\"TCP\">Transport: TCP (reliable, connection)</option>\n              <option value=\"UDP\">Transport: UDP (unreliable, datagram)</option>\n            </select>\n            <button class=\"btn\" id=\"sendBtn\">Send</button>\n            <button class=\"btn secondary\" id=\"receiveBtn\">Receive</button>\n            <button class=\"btn secondary\" id=\"stepBtn\">Step</button>\n            <button class=\"btn danger\" id=\"resetBtn\" title=\"Reset animation\">Reset</button>\n          </div>\n\n          <div class=\"middle-stage\">\n            <div style=\"display:flex; gap:12px; align-items:center;\">\n              <div class=\"small\" style=\"color:var(--muted)\">Local Host</div>\n              <div style=\"width:10px;height:10px;background:var(--accent);border-radius:50%\"></div>\n            </div>\n            <div style=\"display:flex; gap:12px; align-items:center;\">\n              <div class=\"small\" style=\"color:var(--muted)\">Physical path →</div>\n              <div style=\"display:flex; gap:8px; align-items:center;\">\n                <div class=\"chip\" id=\"showHeadersToggle\">Show headers</div>\n                <div class=\"chip\" id=\"autoMode\">Auto play</div>\n              </div>\n            </div>\n            <div style=\"text-align:right\">\n              <div class=\"small\">Remote Host</div>\n              <div style=\"width:10px;height:10px;background:#ffd700;border-radius:50%; margin-left:auto\"></div>\n            </div>\n          </div>\n\n          <div class=\"network-path\" id=\"networkPath\" aria-live=\"polite\">\n            <div class=\"node\" style=\"left:10px\">\n              <div class=\"box\">Host A</div>\n              <div class=\"small\" style=\"margin-top:6px;color:var(--muted)\">Source</div>\n            </div>\n\n            <div class=\"path\">\n              <div class=\"link\" id=\"linkA\"></div>\n              <div class=\"router\" id=\"r1\">R1</div>\n              <div class=\"link\" id=\"linkB\"></div>\n              <div class=\"router\" id=\"r2\">R2</div>\n              <div class=\"link\" id=\"linkC\"></div>\n            </div>\n\n            <div class=\"node\" style=\"right:10px; top:32px; align-items:center\">\n              <div class=\"box\">Host B</div>\n              <div class=\"small\" style=\"margin-top:6px;color:var(--muted)\">Destination</div>\n            </div>\n\n            <div class=\"packet\" id=\"packet\" style=\"left:10%; display:none\" role=\"img\" aria-label=\"Packet moving\">\n              <div id=\"packetLayers\" style=\"display:flex;flex-direction:column;align-items:flex-start;\">\n                <div id=\"packetHeader\" style=\"font-size:12px;opacity:.95\"></div>\n                <div id=\"packetPayload\" style=\"font-size:13px\"></div>\n              </div>\n            </div>\n\n            <div class=\"headers-stack\" id=\"headersStack\" style=\"display:none\">\n              <div class=\"small\" style=\"margin-bottom:6px;color:var(--muted)\">Encapsulation stack (top at top)</div>\n              <div id=\"stackList\"></div>\n            </div>\n          </div>\n\n          <div style=\"margin-top:12px; display:flex; gap:12px;\">\n            <div style=\"flex:1\" class=\"info\">\n              <div class=\"detail-title\">Encapsulation snapshot</div>\n              <div class=\"small\" style=\"margin-top:8px\" id=\"snapshot\">No packet in motion.</div>\n            </div>\n            <div style=\"width:260px\" class=\"info\">\n              <div class=\"detail-title\">Current action</div>\n              <div class=\"small\" id=\"actionText\">Idle</div>\n            </div>\n          </div>\n\n        </div>\n\n        <div class=\"right\">\n          <div class=\"panel-section\">\n            <h4>Layer responsibilities & common protocols</h4>\n            <div class=\"legend\" id=\"legend\">\n              <!-- populated by JS -->\n            </div>\n          </div>\n\n          <div class=\"panel-section\">\n            <h4>Mini quiz</h4>\n            <div class=\"quiz\">\n              <div class=\"qa\" id=\"q1\">\n                <div><strong>Q:</strong> Which layer is primarily responsible for routing packets across networks?</div>\n                <div class=\"answer\">\n                  <div class=\"chip\" data-answer=\"L3\">Layer 3</div>\n                  <div class=\"chip\" data-answer=\"L4\">Layer 4</div>\n                  <div class=\"chip\" data-answer=\"L2\">Layer 2</div>\n                </div>\n              </div>\n              <div class=\"qa\" id=\"q2\">\n                <div><strong>Q:</strong> Which layer handles end-to-end reliability (e.g., retransmissions)?</div>\n                <div class=\"answer\">\n                  <div class=\"chip\" data-answer=\"L4\">Layer 4</div>\n                  <div class=\"chip\" data-answer=\"L7\">Layer 7</div>\n                  <div class=\"chip\" data-answer=\"L1\">Layer 1</div>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"panel-section\">\n            <h4>Notes</h4>\n            <div class=\"small footer-note\">\n              The OSI model is conceptual: modern stacks (TCP/IP) combine or split responsibilities. This demo emphasizes the idea of encapsulation: data gets headers added as it descends and stripped on receive.\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Data for layers\n    const layers = {\n      7: {\n        name: \"Application\",\n        desc: \"Provides network services to end-user applications. Examples: HTTP, FTP, SMTP, DNS, SSH.\",\n        examples: [\"HTTP\", \"FTP\", \"SMTP\", \"DNS\", \"SSH\"],\n        color: \"l7\"\n      },\n      6: {\n        name: \"Presentation\",\n        desc: \"Translates, encrypts, compresses data for the application layer. Examples: TLS/SSL, MIME, JPEG, MPEG.\",\n        examples: [\"TLS/SSL\", \"MIME\", \"JPEG\"],\n        color: \"l6\"\n      },\n      5: {\n        name: \"Session\",\n        desc: \"Manages sessions and dialogues between applications. Examples: NetBIOS, RPC, SIP.\",\n        examples: [\"NetBIOS\", \"RPC\", \"SIP\"],\n        color: \"l5\"\n      },\n      4: {\n        name: \"Transport\",\n        desc: \"Provides end-to-end communication, segmentation, and reliability. Examples: TCP (segments), UDP (datagrams).\",\n        examples: [\"TCP\", \"UDP\"],\n        color: \"l4\"\n      },\n      3: {\n        name: \"Network\",\n        desc: \"Handles logical addressing and routing of packets across networks. Examples: IP, ICMP, routing protocols.\",\n        examples: [\"IPv4/IPv6\", \"ICMP\", \"OSPF\", \"BGP\"],\n        color: \"l3\"\n      },\n      2: {\n        name: \"Data Link\",\n        desc: \"Frames data for the local link and controls physical addressing (MAC). Examples: Ethernet, PPP, switches.\",\n        examples: [\"Ethernet\", \"PPP\", \"ARP\"],\n        color: \"l2\"\n      },\n      1: {\n        name: \"Physical\",\n        desc: \"Transmits raw bit stream over the physical medium (cables, radio). Examples: Ethernet PHY, DSL, fiber optics, Wi‑Fi.\",\n        examples: [\"Ethernet PHY\", \"DSL\", \"Fiber\", \"Wi-Fi\"],\n        color: \"l1\"\n      }\n    };\n\n    // Populate legend with layer info\n    const legendEl = document.getElementById('legend');\n    for (let i=7;i>=1;i--){\n      const item = document.createElement('div');\n      item.className = 'item';\n      const color = document.createElement('div');\n      color.className = 'color-sample';\n      color.style.background = getComputedStyle(document.querySelector('.l'+i)).backgroundImage;\n      const text = document.createElement('div');\n      text.innerHTML = `<strong>${i} — ${layers[i].name}</strong><div class=\"small\">${layers[i].desc}</div>`;\n      item.appendChild(color);\n      item.appendChild(text);\n      legendEl.appendChild(item);\n    }\n\n    // Layer click handlers\n    document.querySelectorAll('.layer').forEach(el=>{\n      el.addEventListener('click', ()=>showLayerInfo(el.dataset.layer));\n      el.addEventListener('keydown', (e)=>{ if (e.key === 'Enter') showLayerInfo(el.dataset.layer); });\n    });\n\n    function showLayerInfo(n){\n      const d = layers[n];\n      const info = document.getElementById('infoText');\n      info.innerHTML = `<div style=\"font-weight:800;color:var(--accent)\">${d.name} — Layer ${n}</div>\n        <div style=\"margin-top:8px;color:var(--muted)\">${d.desc}</div>\n        <div style=\"margin-top:8px\"><span class=\"small\">Common protocols:</span>\n          <div class=\"protocols\">${d.examples.map(p=>`<div class=\"proto\">${p}</div>`).join('')}</div>\n        </div>`;\n    }\n\n    // Packet/encapsulation model\n    const packetEl = document.getElementById('packet');\n    const packetHeader = document.getElementById('packetHeader');\n    const packetPayload = document.getElementById('packetPayload');\n    const stackList = document.getElementById('stackList');\n    const headersStack = document.getElementById('headersStack');\n    const snapshot = document.getElementById('snapshot');\n    const actionText = document.getElementById('actionText');\n\n    let state = {\n      auto: false,\n      running: false,\n      direction: 'down', // down: send, up: receive\n      steps: [],\n      currentStep: -1,\n      headers: []\n    };\n\n    const showHeadersToggle = document.getElementById('showHeadersToggle');\n    showHeadersToggle.addEventListener('click', ()=>{\n      if (headersStack.style.display === 'none') headersStack.style.display = 'block';\n      else headersStack.style.display = 'none';\n    });\n\n    const autoMode = document.getElementById('autoMode');\n    autoMode.addEventListener('click', ()=>{\n      state.auto = !state.auto;\n      autoMode.style.background = state.auto ? 'rgba(45,212,191,0.12)' : 'transparent';\n    });\n\n    // Build encapsulation for a message based on selected transport\n    function buildEncapsulation(message, transport){\n      // Start with application payload\n      let headers = [];\n      headers.push({layer:7, label:`Application: data=\"${message}\"`});\n      // presentation - example: TLS may wrap, but we model optional\n      headers.push({layer:6, label:`Presentation: encoding=UTF-8`});\n      headers.push({layer:5, label:`Session: sessionID=0x1a2b`});\n      // transport: TCP or UDP header with ports\n      if (transport === 'TCP'){\n        headers.push({layer:4, label:`Transport(TCP): srcPort=54321 dstPort=80 seq=1001 flags=SYN`});\n      } else {\n        headers.push({layer:4, label:`Transport(UDP): srcPort=54321 dstPort=53 length=...`});\n      }\n      // network: IP header\n      headers.push({layer:3, label:`Network(IP): src=192.0.2.10 dst=198.51.100.5`});\n      // data link: MAC frame\n      headers.push({layer:2, label:`DataLink(Ethernet): src=DE:AD:BE:EF dst=BA:AD:00:01 type=0x0800`});\n      // physical: conversion to bits (represented)\n      headers.push({layer:1, label:`Physical: bits on medium (electrical/optical/radio)`});\n      return headers;\n    }\n\n    function updateStackView(){\n      stackList.innerHTML = '';\n      for (let i=0;i<state.headers.length;i++){\n        const h = state.headers[i];\n        const row = document.createElement('div');\n        row.className = 'header-row';\n        row.innerHTML = `<div style=\"font-weight:700\">${h.label.split(':')[0]}</div><div class=\"small\">${h.label.split(':').slice(1).join(':')}</div>`;\n        stackList.appendChild(row);\n      }\n    }\n\n    function animateSend(message, transport){\n      if (state.running) return;\n      state.running = true;\n      state.direction = 'down';\n      state.headers = buildEncapsulation(message, transport).reverse(); // top-of-stack first at index 0 for visual stack (top is application)\n      // NOTE: for animation we want to add headers as we go down; steps correspond to adding headers bottom->top? We'll animate logically from 7→1 adding headers to \"frame\" as it descends.\n      // But for human view we show headers stacked top-first.\n      updateStackView();\n      headersStack.style.display = headersStack.style.display === 'none' ? 'none' : headersStack.style.display; // don't change visibility\n      packetPayload.textContent = message;\n      packetHeader.textContent = ''; // will show current header summary\n      packetEl.style.display = 'flex';\n      snapshot.textContent = 'Encapsulation will be performed as the message descends the layers.';\n      state.currentStep = 7;\n      actionText.textContent = 'Starting send (application → physical)';\n      movePacketTo('left'); // start on left\n      stepDown(function finished(){\n        state.running = false;\n        actionText.textContent = 'Packet left the local host and is traversing the network.';\n        snapshot.textContent = 'Packet on the wire: ' + describeTopHeaders();\n        if (state.auto){\n          // auto receive after a short delay\n          setTimeout(()=>{ animateReceive(); }, 900);\n        }\n      });\n    }\n\n    function stepDown(onDone){\n      // sequentially process layers 7→1\n      let layer = 7;\n      const transport = document.getElementById('transportSelect').value;\n      const interval = state.auto ? 700 : 900;\n      function next(){\n        if (layer < 1){ // done\n          if (typeof onDone === 'function') onDone();\n          return;\n        }\n        // Add header for this layer (we consider that adding header packs info into packetHeader)\n        const headerInfo = getHeaderForLayer(layer, document.getElementById('messageInput').value, transport);\n        // Prepend header into visual stackList (top at top)\n        state.headers.unshift(headerInfo);\n        updateStackView();\n        packetHeader.textContent = headerPreview(state.headers);\n        snapshot.textContent = `After layer ${layer} processing: ${headerInfo.label.split(':')[0]} added/processed.`;\n        actionText.textContent = `Processing layer ${layer} (${layers[layer].name})`;\n        highlightLayer(layer);\n        // Animate a little \"nudge\" to indicate progress\n        packetEl.style.left = 10 + (7 - layer) * 8 + '%';\n        layer--;\n        setTimeout(next, interval);\n      }\n      next();\n    }\n\n    function animateReceive(){\n      if (state.running) return;\n      state.running = true;\n      state.direction = 'up';\n      actionText.textContent = 'Receiving: packet arrives at destination, decapsulation begins';\n      // Move to right side (arrival)\n      movePacketTo('right');\n      // Simulate traversal then decapsulation 1→7\n      setTimeout(()=>{ stepUp(function finished(){ state.running=false; actionText.textContent = 'Message delivered to application at destination'; snapshot.textContent = 'Decapsulation complete. Payload delivered: \"'+document.getElementById('messageInput').value+'\"'; }); }, 900);\n    }\n\n    function stepUp(onDone){\n      let layer = 1;\n      const interval = state.auto ? 600 : 900;\n      function next(){\n        if (layer > 7){\n          if (typeof onDone === 'function') onDone();\n          return;\n        }\n        // Remove header at this layer (if present)\n        const foundIdx = state.headers.findIndex(h=>h.layer === layer);\n        let removed = null;\n        if (foundIdx !== -1){\n          removed = state.headers.splice(foundIdx,1)[0];\n        } else {\n          removed = {layer:layer, label:`(no header present)`};\n        }\n        updateStackView();\n        packetHeader.textContent = headerPreview(state.headers);\n        actionText.textContent = `Decapsulating layer ${layer} (${layers[layer].name}) — removed ${removed.label.split(':')[0]}`;\n        highlightLayer(layer);\n        // nudge animation\n        packetEl.style.left = 90 - (layer-1) * 8 + '%';\n        layer++;\n        setTimeout(next, interval);\n      }\n      next();\n    }\n\n    function headerPreview(hlist){\n      if (!hlist || hlist.length===0) return 'No headers (payload only)';\n      return hlist.slice(0,3).map(h=>h.label.split(':')[0]).join(' | ');\n    }\n\n    function describeTopHeaders(){\n      if (!state.headers || state.headers.length===0) return 'payload only';\n      return state.headers.map(h=>h.label.split(':')[0]).join(' → ');\n    }\n\n    function getHeaderForLayer(layer, message, transport){\n      switch(layer){\n        case 7: return {layer:7, label:`Application: payload=\"${message}\"`};\n        case 6: return {layer:6, label:`Presentation: encoding=UTF-8`};\n        case 5: return {layer:5, label:`Session: sessionID=0x${Math.floor(Math.random()*0xffff).toString(16)}`};\n        case 4:\n          if (transport === 'TCP') return {layer:4, label:`Transport(TCP): src=54321 dst=80 seq=${1000+Math.floor(Math.random()*9000)}`};\n          else return {layer:4, label:`Transport(UDP): src=54321 dst=53 len=${message.length+8}`};\n        case 3: return {layer:3, label:`Network(IP): src=192.0.2.10 dst=198.51.100.5`};\n        case 2: return {layer:2, label:`DataLink(Eth): src=DE:AD:BE:EF dst=BA:AD:00:01 ethertype=0x0800`};\n        case 1: return {layer:1, label:`Physical: bits on medium`};\n        default: return {layer:layer, label:`Layer${layer}: info`};\n      }\n    }\n\n    function highlightLayer(n){\n      document.querySelectorAll('.layer').forEach(el=>el.style.boxShadow='none');\n      const el = document.querySelector('.layer[data-layer=\"'+n+'\"]');\n      if (el){\n        el.style.boxShadow = '0 12px 28px rgba(0,0,0,0.6), 0 0 0 4px rgba(45,212,191,0.06)';\n      }\n      // update info panel with that layer\n      showLayerInfo(n);\n    }\n\n    function movePacketTo(side){\n      if (side === 'left'){\n        packetEl.style.left = '10%';\n      } else {\n        packetEl.style.left = '90%';\n      }\n    }\n\n    // Buttons\n    document.getElementById('sendBtn').addEventListener('click', ()=>{\n      const msg = document.getElementById('messageInput').value || 'Hello';\n      const transport = document.getElementById('transportSelect').value;\n      animateSend(msg, transport);\n    });\n\n    document.getElementById('receiveBtn').addEventListener('click', ()=>{ animateReceive(); });\n\n    document.getElementById('resetBtn').addEventListener('click', ()=>{\n      state.running = false;\n      state.headers = [];\n      packetEl.style.display = 'none';\n      stackList.innerHTML = '';\n      snapshot.textContent = 'No packet in motion.';\n      actionText.textContent = 'Idle';\n      document.querySelectorAll('.layer').forEach(el=>el.style.boxShadow='none');\n    });\n\n    // Step button: perform one step in current mode or start send then step down single layer each press\n    document.getElementById('stepBtn').addEventListener('click', ()=>{\n      if (!state.running){\n        // start a controlled send process\n        state.running = true;\n        state.direction = 'down';\n        state.headers = [];\n        packetPayload.textContent = document.getElementById('messageInput').value;\n        packetEl.style.display = 'flex';\n        state.currentStep = 7;\n        actionText.textContent = 'Step send: press Step to perform next layer';\n        movePacketTo('left');\n        return;\n      }\n      if (state.running && state.direction === 'down'){\n        if (state.currentStep < 1){\n          actionText.textContent = 'Send complete (use Receive to decapsulate)';\n          state.running = false;\n          return;\n        }\n        const header = getHeaderForLayer(state.currentStep, document.getElementById('messageInput').value, document.getElementById('transportSelect').value);\n        state.headers.unshift(header);\n        updateStackView();\n        packetHeader.textContent = headerPreview(state.headers);\n        snapshot.textContent = `Step: added ${header.label.split(':')[0]} at layer ${state.currentStep}`;\n        highlightLayer(state.currentStep);\n        packetEl.style.left = (10 + (7 - state.currentStep) * 8) + '%';\n        state.currentStep--;\n        if (state.currentStep < 1){ actionText.textContent = 'Send finished; packet on wire.'; state.running = false;}\n      } else if (state.running && state.direction === 'up'){\n        // decapsulation step-by-step\n        // If no headers left, finish\n        if (state.headers.length === 0){\n          actionText.textContent = 'No headers left to remove';\n          state.running = false;\n          return;\n        }\n        // remove lowest-layer header (typically physical first), find smallest layer value in headers\n        let minLayer = Math.min(...state.headers.map(h=>h.layer));\n        const idx = state.headers.findIndex(h=>h.layer === minLayer);\n        const removed = state.headers.splice(idx,1)[0];\n        updateStackView();\n        packetHeader.textContent = headerPreview(state.headers);\n        snapshot.textContent = `Step: removed ${removed.label.split(':')[0]} (layer ${removed.layer})`;\n        highlightLayer(removed.layer);\n        packetEl.style.left = (90 - (removed.layer-1)*8) + '%';\n        if (state.headers.length===0){ actionText.textContent='Decapsulation complete.'; state.running=false; }\n      }\n    });\n\n    // Quick quiz handlers\n    document.querySelectorAll('.quiz .chip').forEach(ch=>{\n      ch.addEventListener('click', (e)=>{\n        const target = e.currentTarget;\n        const parentQ = target.closest('.qa');\n        const correct = parentQ.id === 'q1' ? 'L3' : 'L4';\n        // mark all chips disabled\n        parentQ.querySelectorAll('.chip').forEach(c=>c.style.pointerEvents='none');\n        if (target.dataset.answer === correct){\n          target.classList.add('correct');\n        } else {\n          target.classList.add('wrong');\n          // highlight correct\n          parentQ.querySelectorAll('.chip').forEach(c=>{ if (c.dataset.answer === correct) c.classList.add('correct'); });\n        }\n      });\n    });\n\n    // Small initial hints\n    document.getElementById('actionText').textContent = 'Idle — ready';\n    document.getElementById('snapshot').textContent = 'No packet in motion.';\n\n    // Small accessibility: allow space on layer to show info\n    window.addEventListener('keydown', (e)=>{\n      if (e.key === 'h'){ headersStack.style.display = headersStack.style.display === 'none' ? 'block' : 'none'; }\n    });\n  </script>\n</body>\n</html>"
