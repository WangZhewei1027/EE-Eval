    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Design Patterns Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            padding: 20px;\n        }\n        h2 {\n            color: #333;\n        }\n        .pattern {\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            padding: 10px;\n            margin-bottom: 20px;\n            background-color: #fff;\n        }\n    </style>\n</head>\n<body>\n    <h1>Design Patterns in JavaScript</h1>\n    \n    <div class=\"pattern\">\n        <h2>Singleton Pattern</h2>\n        <p>This pattern restricts the instantiation of a class to one single instance.</p>\n        <button id=\"singletonButton\">Get Singleton Instance</button>\n        <pre id=\"singletonResult\"></pre>\n    </div>\n\n    <div class=\"pattern\">\n        <h2>Factory Pattern</h2>\n        <p>This pattern creates objects without having to specify the exact class of the object being created.</p>\n        <button id=\"factoryButton\">Create Animal</button>\n        <pre id=\"factoryResult\"></pre>\n    </div>\n    \n    <script>\n        // Singleton Pattern Implementation\n        const Singleton = (function () {\n            let instance;\n\n            function createInstance() {\n                const object = new Object(\"I am the instance\");\n                return object;\n            }\n\n            return {\n                getInstance: function () {\n                    if (!instance) {\n                        instance = createInstance();\n                    }\n                    return instance;\n                }\n            };\n        })();\n\n        document.getElementById('singletonButton').addEventListener('click', function () {\n            const instance1 = Singleton.getInstance();\n            const instance2 = Singleton.getInstance();\n            \n            document.getElementById('singletonResult').textContent = \n                `Instance 1: ${instance1}\\nInstance 2: ${instance2}\\nSame instance: ${instance1 === instance2}`;\n        });\n\n        // Factory Pattern Implementation\n        class Dog {\n            speak() {\n                return \"Woof!\";\n            }\n        }\n\n        class Cat {\n            speak() {\n                return \"Meow!\";\n            }\n        }\n\n        class AnimalFactory {\n            createAnimal(type) {\n                if (type === 'dog') {\n                    return new Dog();\n                } else if (type === 'cat') {\n                    return new Cat();\n                }\n                return null;\n            }\n        }\n\n        document.getElementById('factoryButton').addEventListener('click', function () {\n            const factory = new AnimalFactory();\n            const dog = factory.createAnimal('dog');\n            const cat = factory.createAnimal('cat');\n            document.getElementById('factoryResult').textContent = \n                `Dog says: ${dog.speak()}\\nCat says: ${cat.speak()}`;\n        });\n    </script>\n</body>\n</html>"
