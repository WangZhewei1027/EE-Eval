    "content": "<html>\n<head>\n    <title>Exponential Search</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        #search-input {\n            width: 50%;\n            padding: 10px;\n            font-size: 18px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            margin: 10px;\n        }\n        #search-output {\n            font-size: 24px;\n            font-weight: bold;\n            margin: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Exponential Search</h1>\n    <input type=\"text\" id=\"search-input\" placeholder=\"Enter a number to search for\">\n    <button id=\"search-button\">Search</button>\n    <div id=\"search-output\"></div>\n\n    <script>\n        const searchInput = document.getElementById('search-input');\n        const searchButton = document.getElementById('search-button');\n        const searchOutput = document.getElementById('search-output');\n\n        searchButton.addEventListener('click', () => {\n            const input = searchInput.value.trim();\n            if (input) {\n                const numbers = input.split('').map(Number);\n                const searchResult = exponentialSearch(numbers);\n                if (searchResult) {\n                    searchOutput.textContent = `Number ${numbers.indexOf(searchResult[0]) + 1} found in the list`;\n                } else {\n                    searchOutput.textContent = 'Number not found in the list';\n                }\n            } else {\n                searchOutput.textContent = 'Please enter a number to search for';\n            }\n        });\n\n        function exponentialSearch(numbers) {\n            if (numbers.length === 0) {\n                return null;\n            }\n\n            const target = numbers[0];\n            const exponent = 2;\n\n            while (exponent <= numbers.length) {\n                const range = Math.min(numbers.length - exponent, numbers.length);\n                const mid = Math.floor(exponent / 2) + 1;\n                const midValue = numbers[mid - 1];\n\n                if (midValue === target) {\n                    return mid;\n                } else if (midValue < target) {\n                    exponent = mid;\n                } else {\n                    exponent = mid + 1;\n                }\n            }\n\n            return null;\n        }\n    </script>\n</body>\n</html>"
