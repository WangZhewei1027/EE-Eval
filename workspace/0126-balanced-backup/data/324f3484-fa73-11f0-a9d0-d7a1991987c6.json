    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Congestion Control Simulation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin-top: 50px;\n        }\n        #overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0, 0, 0, 0.5);\n            color: white;\n            display: none;\n            justify-content: center;\n            align-items: center;\n        }\n        #status {\n            margin: 20px;\n            font-size: 20px;\n        }\n        #container {\n            display: flex;\n            justify-content: center;\n            flex-direction: column;\n            align-items: center;\n            transition: all 0.3s;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Congestion Control Simulation</h1>\n<p>Click the button to simulate data packet transmission!</p>\n<button id=\"startButton\">Start Transmission</button>\n\n<div id=\"container\">\n    <div id=\"status\">Current State: Idle</div>\n    <div id=\"overlay\">Congestion Detected! Adjusting transmission rate...</div>\n    <div id=\"trafficCircle\" style=\"width: 50px; height: 50px; border-radius: 50%; background: green;\"></div>\n</div>\n\n<script>\n    let congestionThreshold = 5; // Number of successful transmissions before congestion\n    let transmissionCount = 0; // Count of successful transmissions\n    let isCongested = false;\n\n    document.getElementById('startButton').addEventListener('click', startTransmission);\n\n    function startTransmission() {\n        // Reset values\n        transmissionCount = 0;\n        isCongested = false;\n        updateStatus('Transmission started...');\n        simulateTransmission();\n    }\n\n    function simulateTransmission() {\n        if (isCongested) return;\n\n        for (let i = 0; i < 10; i++) {\n            setTimeout(() => {\n                transmissionCount++;\n                // Randomly simulate congestion\n                if (Math.random() < 0.3) { // 30% chance of inducing congestion\n                    induceCongestion();\n                } else {\n                    updateCircle('green');\n                    if (transmissionCount >= congestionThreshold) {\n                        updateStatus('Transmission successful! No congestion.');\n                    } else {\n                        updateStatus(`Current State: Transmitting... (${transmissionCount})`);\n                    }\n                }\n            }, i * 1000); // Simulating 1-second intervals of transmission\n        }\n    }\n\n    function induceCongestion() {\n        isCongested = true;\n        updateCircle('red');\n        updateStatus('Current State: Congested!');\n\n        // Show overlay for congestion detected\n        document.getElementById('overlay').style.display = 'flex';\n        \n        // Simulate congestion control: wait for a short while, then resolve\n        setTimeout(() => {\n            isCongested = false;\n            document.getElementById('overlay').style.display = 'none';\n            transmissionCount = 0; // Reset the count after congestion\n            updateCircle('yellow');\n            updateStatus('Congestion resolved, adjusting transmission rate...');\n            setTimeout(simulateTransmission, 3000); // Retry transmission after 3 seconds\n        }, 2000);\n    }\n\n    function updateCircle(color) {\n        document.getElementById('trafficCircle').style.background = color;\n    }\n\n    function updateStatus(message) {\n        document.getElementById('status').innerText = message;\n    }\n</script>\n\n</body>\n</html>"
