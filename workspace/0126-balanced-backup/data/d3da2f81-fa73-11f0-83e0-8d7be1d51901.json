  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Interactive Congestion Control Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 0; padding: 0; background: #f5f7fb; color: #111; }\n    header { background: linear-gradient(90deg,#0ea5a4,#3b82f6); color: white; padding: 14px 20px; }\n    header h1 { margin: 0; font-size: 18px; }\n    main { display: flex; gap: 16px; padding: 16px; }\n    .left, .right { background: white; border-radius: 8px; padding: 12px; box-shadow: 0 8px 20px rgba(20,30,60,0.06); }\n    .left { flex: 1 1 720px; min-width: 360px; }\n    .right { width: 360px; }\n    .panel { margin-bottom: 12px; }\n    label { display: block; font-size: 12px; color: #334155; margin-bottom: 6px; }\n    input[type=range] { width: 100%; }\n    .controls { display:flex; gap:8px; margin-top:8px; }\n    button { background:#2563eb; color:white; border: none; padding:8px 10px; border-radius:6px; cursor:pointer; }\n    button.secondary { background:#64748b; }\n    button.warn { background:#ef4444; }\n    .stats { display:flex; gap:8px; flex-wrap:wrap; }\n    .stat { flex:1 1 45%; background:#f8fafc; padding:8px; border-radius:6px; font-size:13px; }\n    canvas { width:100%; height:220px; display:block; border-radius:6px; background:linear-gradient(180deg,#ffffff,#f8fafc); }\n    .linkCanvas { height:160px; background:linear-gradient(180deg,#ffffff,#f8fafc); margin-top:8px; border-radius:6px; display:block; width:100%; }\n    footer { padding:12px 16px; font-size:13px; color:#374151; background:#fff; border-top:1px solid #e6eef8; text-align:left; }\n    .legend { display:flex; gap:8px; align-items:center; margin-top:8px; font-size:13px; color:#475569; }\n    .dot { width:12px; height:12px; border-radius:3px; display:inline-block; margin-right:6px; }\n    .muted { color:#64748b; }\n    a.inline { color:#2563eb; text-decoration:none; }\n    small.hint { color:#64748b; display:block; margin-top:6px; font-size:12px; }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Interactive Congestion Control Demonstration (TCP-like)</h1>\n  </header>\n  <main>\n    <div class=\"left\">\n      <div class=\"panel\">\n        <label>Congestion Window (cwnd) and ssthresh over time</label>\n        <canvas id=\"graph\" width=\"1200\" height=\"220\"></canvas>\n        <div class=\"legend\">\n          <div><span class=\"dot\" style=\"background:#10b981\"></span>cwnd</div>\n          <div><span class=\"dot\" style=\"background:#f97316\"></span>ssthresh</div>\n          <div><span class=\"dot\" style=\"background:#3b82f6\"></span>bandwidth (packets/s)</div>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <label>Packets on the bottleneck link (left → right)</label>\n        <canvas id=\"link\" class=\"linkCanvas\" width=\"1200\" height=\"160\"></canvas>\n        <small class=\"hint\">Green = in-flight / delivered, red = dropped, orange = retransmission</small>\n      </div>\n\n      <div class=\"panel\">\n        <div style=\"display:flex;gap:10px;align-items:center;\">\n          <button id=\"start\">Start</button>\n          <button id=\"pause\" class=\"secondary\">Pause</button>\n          <button id=\"reset\" class=\"secondary\">Reset</button>\n          <button id=\"forceLoss\" class=\"warn\">Force Drop (simulate congestion)</button>\n        </div>\n        <small class=\"hint\">Press Start to run the simulation. Force Drop instantly drops a few packets at the bottleneck.</small>\n      </div>\n    </div>\n\n    <div class=\"right\">\n      <div class=\"panel\">\n        <label>Network Parameters</label>\n        <div>\n          <label>Bandwidth (packets / sec): <span id=\"bandTxt\">20</span></label>\n          <input id=\"band\" type=\"range\" min=\"1\" max=\"120\" value=\"20\">\n        </div>\n        <div>\n          <label>Buffer size (packets): <span id=\"bufTxt\">20</span></label>\n          <input id=\"buf\" type=\"range\" min=\"0\" max=\"200\" value=\"20\">\n        </div>\n        <div>\n          <label>Round-Trip Time (ms): <span id=\"rttTxt\">200</span></label>\n          <input id=\"rtt\" type=\"range\" min=\"20\" max=\"1000\" value=\"200\">\n        </div>\n        <div>\n          <label>Random loss rate (per pkt): <span id=\"lossTxt\">0.005</span></label>\n          <input id=\"loss\" type=\"range\" min=\"0\" max=\"100\" value=\"0.5\">\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <label>Sender / ACK behavior</label>\n        <div>\n          <label>Time scale (slower → faster): <span id=\"speedTxt\">1.0x</span></label>\n          <input id=\"speed\" type=\"range\" min=\"0.25\" max=\"4\" step=\"0.25\" value=\"1\">\n        </div>\n        <div style=\"margin-top:8px;\">\n          <label><input id=\"fastRecovery\" type=\"checkbox\" checked> Enable Fast Retransmit & Fast Recovery</label>\n          <small class=\"hint\">When enabled, 3 duplicate ACKs trigger fast retransmit and recovery.</small>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <label>Live Statistics</label>\n        <div class=\"stats\">\n          <div class=\"stat\">cwnd: <b id=\"cwndVal\">1.0</b></div>\n          <div class=\"stat\">ssthresh: <b id=\"sstVal\">16</b></div>\n          <div class=\"stat\">in flight: <b id=\"flightVal\">0</b></div>\n          <div class=\"stat\">rtt: <b id=\"rttVal\">200 ms</b></div>\n          <div class=\"stat\">rto: <b id=\"rtoVal\">600 ms</b></div>\n          <div class=\"stat\">loss rate: <b id=\"lossVal\">0.5%</b></div>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <label>Explanation (brief)</label>\n        <div style=\"font-size:13px; color:#374151; line-height:1.3;\">\n          - Sender increases cwnd exponentially (Slow Start) until cwnd &gt;= ssthresh. <br>\n          - After that it increases linearly (Congestion Avoidance). <br>\n          - On packet loss: timeout reduces cwnd to 1 and ssthresh = cwnd/2 (Slow Start restart). <br>\n          - 3 duplicate ACKs can trigger Fast Retransmit/Fast Recovery to avoid slow start. <br>\n          Try changing bandwidth, buffer and loss to see how cwnd reacts.\n        </div>\n      </div>\n    </div>\n  </main>\n\n  <footer>\n    Interactive simulation — educational only. This model is simplified to illustrate the dynamics of TCP-like congestion control (Slow Start, Congestion Avoidance, Timeout, Fast Retransmit/Recovery).\n  </footer>\n\n<script>\n/*\n  Simplified TCP-like congestion control simulation.\n  - Discrete-event-ish simulation running at step dt (s).\n  - Packets are integer-sequence segments.\n  - Sender maintains cwnd (float), ssthresh (int).\n  - Link: bandwidth (pkt/s), finite buffer; packets beyond buffer are dropped.\n  - Random loss applied when entering queue.\n  - RTT modeled as propagation + queueing: packets leaving queue take rtt/2 to reach receiver; ACKs take rtt/2 back.\n  - Duplicate ACK count triggers fast retransmit (if enabled).\n  - Timeout triggers retransmit and cwnd reset.\n*/\n\n// Canvas and UI elements\nconst graph = document.getElementById('graph');\nconst gctx = graph.getContext('2d');\nconst linkCanvas = document.getElementById('link');\nconst lctx = linkCanvas.getContext('2d');\n\nconst band = document.getElementById('band');\nconst buf = document.getElementById('buf');\nconst rttInput = document.getElementById('rtt');\nconst lossInput = document.getElementById('loss');\nconst speedInput = document.getElementById('speed');\nconst fastRecovery = document.getElementById('fastRecovery');\n\nconst bandTxt = document.getElementById('bandTxt');\nconst bufTxt = document.getElementById('bufTxt');\nconst rttTxt = document.getElementById('rttTxt');\nconst lossTxt = document.getElementById('lossTxt');\nconst speedTxt = document.getElementById('speedTxt');\n\nconst startBtn = document.getElementById('start');\nconst pauseBtn = document.getElementById('pause');\nconst resetBtn = document.getElementById('reset');\nconst forceLossBtn = document.getElementById('forceLoss');\n\nconst cwndVal = document.getElementById('cwndVal');\nconst sstVal = document.getElementById('sstVal');\nconst flightVal = document.getElementById('flightVal');\nconst rttVal = document.getElementById('rttVal');\nconst rtoVal = document.getElementById('rtoVal');\nconst lossVal = document.getElementById('lossVal');\n\nlet running = false;\nlet stepInterval = null;\n\n// Simulation parameters (initial)\nlet params = {\n  bandwidth: +band.value,     // packets per second\n  bufferSize: +buf.value,     // packets\n  rtt: +rttInput.value / 1000, // seconds\n  lossProb: +lossInput.value / 10000, // normalized (input 0..100 maps to 0..0.01)\n  dt: 0.05,                   // base step (s)\n  speed: +speedInput.value,\n  fastRecovery: fastRecovery.checked\n};\n\n// Sender state\nlet state = {\n  cwnd: 1.0,        // congestion window (in segments)\n  ssthresh: 16,     // slow start threshold\n  nextSeq: 1,       // next sequence number to use\n  lastAck: 0,       // highest in-order acked seq\n  inflight: new Map(), // seq -> {sendTime, retransmitted:boolean}\n  dupAckCount: 0,\n  lastAckSeen: 0,\n  rto: null,\n  time: 0\n};\n\n// Link and buffers\nlet link = {\n  queue: [],  // packets waiting to be transmitted by link (arriving at sender side)\n  inFlightToReceiver: [], // {pkt, timeLeft}\n  inFlightToSender: [],   // ACKs: {ackNum, timeLeft}\n  bandwidth: params.bandwidth\n};\n\n// history for graph\nlet history = {\n  t: [],\n  cwnd: [],\n  ssthresh: []\n};\n\n// visual packets for rendering path\nlet visualPackets = []; // {seq, x, state: 'inflight'|'delivered'|'dropped'|'retrans', progress}\n\nfunction resetSimulation() {\n  // reset state to initial\n  params.bandwidth = +band.value;\n  params.bufferSize = +buf.value;\n  params.rtt = +rttInput.value / 1000;\n  params.lossProb = +lossInput.value / 10000;\n  params.speed = +speedInput.value;\n  params.fastRecovery = fastRecovery.checked;\n\n  state = {\n    cwnd: 1.0,\n    ssthresh: 16,\n    nextSeq: 1,\n    lastAck: 0,\n    inflight: new Map(),\n    dupAckCount: 0,\n    lastAckSeen: 0,\n    rto: params.rtt * 3,\n    time: 0\n  };\n  link = {\n    queue: [],\n    inFlightToReceiver: [],\n    inFlightToSender: [],\n    bandwidth: params.bandwidth\n  };\n  history = { t: [], cwnd: [], ssthresh: [] };\n  visualPackets = [];\n  updateUI();\n  clearCanvas();\n  drawGraph(); // blank\n  drawLink();\n}\n\n// UI update\nfunction updateUI() {\n  bandTxt.textContent = params.bandwidth;\n  bufTxt.textContent = params.bufferSize;\n  rttTxt.textContent = Math.round(params.rtt * 1000);\n  lossTxt.textContent = (params.lossProb*100).toFixed(3);\n  speedTxt.textContent = params.speed + 'x';\n\n  cwndVal.textContent = state.cwnd.toFixed(2);\n  sstVal.textContent = state.ssthresh;\n  flightVal.textContent = state.inflight.size;\n  rttVal.textContent = Math.round(params.rtt*1000) + ' ms';\n  rtoVal.textContent = Math.round((state.rto||params.rtt*3)*1000) + ' ms';\n  lossVal.textContent = (params.lossProb*100).toFixed(3) + '%';\n}\n\n// clear canvases\nfunction clearCanvas() {\n  gctx.clearRect(0,0,graph.width,graph.height);\n  lctx.clearRect(0,0,linkCanvas.width,linkCanvas.height);\n}\n\n// drawing graph of cwnd & ssthresh\nfunction drawGraph() {\n  const ctx = gctx;\n  ctx.clearRect(0,0,graph.width,graph.height);\n  // axis\n  ctx.fillStyle = '#0f172a';\n  ctx.font = '12px system-ui';\n  ctx.fillStyle = '#64748b';\n  // compute max cwnd for scaling\n  const maxCwnd = Math.max(10, ...history.cwnd, state.cwnd, state.ssthresh) * 1.2;\n  const leftPad = 40;\n  const rightPad = 10;\n  const topPad = 10;\n  const bottomPad = 26;\n  const w = graph.width - leftPad - rightPad;\n  const h = graph.height - topPad - bottomPad;\n\n  // draw grid horizontal lines\n  ctx.strokeStyle = '#eef2ff';\n  ctx.lineWidth = 1;\n  for (let i=0;i<=5;i++) {\n    const y = topPad + i*(h/5);\n    ctx.beginPath(); ctx.moveTo(leftPad,y); ctx.lineTo(leftPad+w,y); ctx.stroke();\n  }\n  // y-axis ticks\n  ctx.fillStyle = '#64748b';\n  ctx.textAlign = 'right';\n  for (let i=0;i<=5;i++) {\n    const val = Math.round(maxCwnd*(1 - i/5));\n    const y = topPad + i*(h/5) + 4;\n    ctx.fillText(val, leftPad-6, y);\n  }\n\n  // draw ssthresh (orange) and cwnd (green)\n  const tlen = Math.max(history.t.length,1);\n  const px = (i)=> leftPad + (i / (tlen-1 || 1)) * w;\n\n  // ssthresh\n  ctx.beginPath();\n  ctx.strokeStyle = '#f97316';\n  ctx.lineWidth = 2;\n  for (let i=0;i<history.ssthresh.length;i++) {\n    const v = history.ssthresh[i];\n    const x = px(i);\n    const y = topPad + (1 - (v/maxCwnd)) * h;\n    if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n  }\n  // add current ssthresh at end\n  const xcur = leftPad + w;\n  const ycur = topPad + (1 - (state.ssthresh/maxCwnd)) * h;\n  ctx.lineTo(xcur,ycur);\n  ctx.stroke();\n\n  // cwnd\n  ctx.beginPath();\n  ctx.strokeStyle = '#10b981';\n  ctx.lineWidth = 2;\n  for (let i=0;i<history.cwnd.length;i++) {\n    const v = history.cwnd[i];\n    const x = px(i);\n    const y = topPad + (1 - (v/maxCwnd)) * h;\n    if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n  }\n  const ycur2 = topPad + (1 - (state.cwnd/maxCwnd)) * h;\n  ctx.lineTo(xcur,ycur2);\n  ctx.stroke();\n\n  // small label with current values\n  ctx.fillStyle = '#0f172a';\n  ctx.textAlign = 'left';\n  ctx.fillText(`cwnd=${state.cwnd.toFixed(2)}  ssthresh=${state.ssthresh}`, leftPad+8, graph.height-6);\n  ctx.fillText(`bandwidth=${params.bandwidth} pkt/s  buffer=${params.bufferSize} pkts`, leftPad+220, graph.height-6);\n}\n\n// draw link and moving packets\nfunction drawLink() {\n  const ctx = lctx;\n  ctx.clearRect(0,0,linkCanvas.width,linkCanvas.height);\n  const W = linkCanvas.width;\n  const H = linkCanvas.height;\n  // draw link line\n  ctx.fillStyle = '#e6eef8';\n  ctx.fillRect(0, H/2 - 18, W, 36);\n  ctx.strokeStyle = '#c7d2fe';\n  ctx.strokeRect(0, H/2 - 18, W, 36);\n\n  // draw buffer occupancy indicator at link start\n  const q = link.queue.length;\n  const qcap = Math.max(1, params.bufferSize);\n  const qw = Math.min(W*0.25, (q/qcap) * (W*0.25));\n  ctx.fillStyle = '#93c5fd';\n  ctx.fillRect(6, H/2 - 14, qw, 28);\n  ctx.fillStyle = '#475569';\n  ctx.font = '12px system-ui';\n  ctx.fillText(`queue ${q}/${params.bufferSize}`, 10, H/2 - 20);\n\n  // draw packets traveling to receiver\n  for (let p of visualPackets) {\n    const x = Math.max(0, Math.min(W, p.progress * W));\n    let color = '#10b981'; // delivered/inflight\n    if (p.state === 'dropped') color = '#ef4444';\n    else if (p.state === 'retrans') color = '#f59e0b';\n    else if (p.state === 'acked') color = '#0ea5a4';\n    ctx.fillStyle = color;\n    ctx.fillRect(x-6, H/2 - 6 + (p.row*14) - 14, 12, 10);\n    // seq text small\n    ctx.fillStyle = '#ffffff';\n    ctx.font = '8px system-ui';\n    ctx.fillText(p.seq % 1000, x-6, H/2 - 2 + (p.row*14) - 14);\n  }\n}\n\n// schedule ACK arrival (put into link.inFlightToSender)\nfunction scheduleAck(ackNum, delay) {\n  link.inFlightToSender.push({ackNum, timeLeft: delay});\n}\n\n// schedule packet arrival to receiver (after delay)\nfunction scheduleToReceiver(pkt, delay) {\n  link.inFlightToReceiver.push({pkt, timeLeft: delay});\n}\n\n// attempt to send new packets according to cwnd\nfunction sendNewPackets(dt) {\n  // number we can send now\n  const allowed = Math.max(0, state.cwnd - state.inflight.size);\n  let toSend = Math.floor(allowed);\n  // send integer number of new packets\n  for (let i=0;i<toSend;i++) {\n    const seq = state.nextSeq++;\n    const pkt = { seq, sendTime: state.time, retransmitted: false };\n    // attempt to enqueue at link (enter queue)\n    enqueuePacket(pkt);\n    state.inflight.set(seq, pkt);\n    // visual\n    visualPackets.push({seq, progress: 0, state: 'inflight', row: (state.inflight.size % 8)});\n  }\n}\n\n// when a packet arrives to link's queue (from sender)\nfunction enqueuePacket(pkt) {\n  // random loss (wire loss) check\n  if (Math.random() < params.lossProb) {\n    // immediately drop\n    pkt.dropped = true;\n    visualMarkDropped(pkt.seq);\n    return;\n  }\n  // buffer overflow?\n  if (link.queue.length >= params.bufferSize) {\n    pkt.dropped = true;\n    visualMarkDropped(pkt.seq);\n    return;\n  }\n  // otherwise push into queue\n  link.queue.push(pkt);\n}\n\n// visual mark drop\nfunction visualMarkDropped(seq) {\n  for (let p of visualPackets) {\n    if (p.seq === seq) { p.state = 'dropped'; p.progress = 0.5; break; }\n  }\n}\n\n// simulate link forwarding: move up to bandwidth*dt packets from queue to inFlightToReceiver\nfunction processLink(dt) {\n  const capacity = Math.max(1, params.bandwidth * dt);\n  let sent = 0;\n  while (sent < capacity && link.queue.length > 0) {\n    const pkt = link.queue.shift();\n    // if packet was earlier marked dropped, just notify sender lost later by not scheduling ack\n    if (pkt.dropped) {\n      // mark visual drop (already done)\n      sent += 1;\n      continue;\n    }\n    // queueing/propagation delay modeled: half RTT to receiver\n    const delay = params.rtt / 2;\n    scheduleToReceiver(pkt, delay);\n    // find visual packet and set progress to start of transit\n    for (let p of visualPackets) {\n      if (p.seq === pkt.seq) { p.progress = 0.05; p.state = 'inflight'; break; }\n    }\n    sent += 1;\n  }\n\n  // advance inFlightToReceiver timers\n  for (let i = link.inFlightToReceiver.length - 1; i >= 0; i--) {\n    const obj = link.inFlightToReceiver[i];\n    obj.timeLeft -= dt;\n    const pkt = obj.pkt;\n    // update visual progress (progress along link from 0 to 0.5 -> receiver, then ack travels)\n    for (let p of visualPackets) {\n      if (p.seq === pkt.seq && p.state !== 'dropped') {\n        // progress scales with remaining time: earlier sent -> higher progress\n        const total = params.rtt / 2;\n        const elapsed = Math.max(0, total - obj.timeLeft);\n        p.progress = Math.min(1, elapsed / total * 0.5 + 0.0);\n      }\n    }\n    if (obj.timeLeft <= 0) {\n      // packet arrived at receiver => receiver immediately sends ACK back (for simplicity cumulative ACK)\n      // receiver sends ACK for pkt.seq (we model each packet triggers ack for all up to max contiguous)\n      scheduleAck(pkt.seq, params.rtt / 2); // ack returns in rtt/2\n      // mark visual as heading back (we'll set progress >0.5)\n      for (let p of visualPackets) {\n        if (p.seq === pkt.seq && !p.dropped) p.progress = 0.6;\n      }\n      // remove from inFlightToReceiver\n      link.inFlightToReceiver.splice(i, 1);\n    }\n  }\n\n  // advance inFlightToSender (ACKs)\n  for (let i = link.inFlightToSender.length - 1; i >= 0; i--) {\n    const obj = link.inFlightToSender[i];\n    obj.timeLeft -= dt;\n    if (obj.timeLeft <= 0) {\n      // ACK arrives at sender\n      handleAck(obj.ackNum);\n      link.inFlightToSender.splice(i, 1);\n    }\n  }\n\n  // update visual packets progress for ack path\n  for (let p of visualPackets) {\n    if (p.state === 'inflight') {\n      // progress increases slowly until >0.6 then ack\n      p.progress = Math.min(0.6, p.progress + dt * params.bandwidth * 0.02);\n    } else if (p.state === 'acked') {\n      p.progress = Math.min(1.0, p.progress + dt * params.bandwidth * 0.03);\n    } else if (p.state === 'retrans') {\n      p.progress = Math.min(1.0, p.progress + dt * params.bandwidth * 0.03);\n    } else if (p.state === 'dropped') {\n      // stays in place\n    }\n  }\n  // cull old visuals\n  if (visualPackets.length > 1000) visualPackets.splice(0, visualPackets.length - 1000);\n}\n\n// called when an ACK arrives at sender\nfunction handleAck(ackNum) {\n  // cumulative ack: ackNum acknowledges everything up to ackNum\n  if (ackNum > state.lastAck) {\n    // new ack\n    state.lastAck = ackNum;\n    // remove inflight entries up to ackNum\n    for (let seq of Array.from(state.inflight.keys())) {\n      if (seq <= ackNum) {\n        state.inflight.delete(seq);\n        // mark visual acked\n        for (let p of visualPackets) {\n          if (p.seq === seq) { p.state = 'acked'; break; }\n        }\n      }\n    }\n    // reset duplicate ack count\n    state.dupAckCount = 0;\n    state.lastAckSeen = ackNum;\n\n    // update cwnd depending on phase\n    if (state.cwnd < state.ssthresh) {\n      // slow start: increase by 1 segment per ACK\n      state.cwnd += 1;\n    } else {\n      // congestion avoidance: additive increase ~ +1 per RTT -> approximate +1/cwnd per ACK\n      state.cwnd += (1.0 / Math.max(1, Math.floor(state.cwnd)));\n    }\n\n  } else if (ackNum === state.lastAck) {\n    // duplicate ACK\n    state.dupAckCount += 1;\n    // if 3 duplicate acks -> fast retransmit\n    if (state.dupAckCount >= 3 && params.fastRecovery) {\n      // fast retransmit & recover\n      const oldCwnd = state.cwnd;\n      state.ssthresh = Math.max(2, Math.floor(state.cwnd / 2));\n      state.cwnd = state.ssthresh + 3;\n      // retransmit next expected packet (lastAck+1)\n      retransmitPacket(state.lastAck + 1, true);\n      // reset dup ack to avoid repeated triggering\n      state.dupAckCount = 0;\n      // mark visuals near retransmit\n      for (let p of visualPackets) {\n        if (p.seq === state.lastAck + 1) { p.state = 'retrans'; p.progress = 0; }\n      }\n    }\n  }\n\n  // update RTO estimate simple model: keep rto as 3*rtt\n  state.rto = params.rtt * 3;\n  updateUI();\n}\n\n// retransmit a packet (put into queue and mark retransmitted)\nfunction retransmitPacket(seq, isFast=false) {\n  const pkt = {seq, sendTime: state.time, retransmitted: true};\n  enqueuePacket(pkt);\n  state.inflight.set(seq, pkt);\n  // add visual packet for retransmission\n  visualPackets.push({seq, progress:0, state: 'retrans', row: (state.inflight.size % 8)});\n}\n\n// check for timeouts (packets that have been outstanding > rto)\nfunction checkTimeouts() {\n  const now = state.time;\n  for (let [seq, pkt] of state.inflight) {\n    if ((now - pkt.sendTime) > (state.rto || params.rtt*3)) {\n      // timeout triggers cwnd reduction\n      state.ssthresh = Math.max(2, Math.floor(state.cwnd / 2));\n      state.cwnd = 1.0;\n      // retransmit missing (lastAck+1)\n      retransmitPacket(state.lastAck + 1, false);\n      // clear inflight except retransmitted one to avoid double-scheduling\n      // Note: keep inflight entries (they'll be removed when acked or time out)\n      state.dupAckCount = 0;\n      break;\n    }\n  }\n}\n\n// visual removal of very old visualPackets\nfunction pruneVisuals() {\n  visualPackets = visualPackets.filter(p => !(p.state==='acked' && p.progress >= 1) && !(p.state==='dropped'));\n}\n\n// main simulation step\nfunction step(dt) {\n  state.time += dt;\n  // sender sends new packets\n  sendNewPackets(dt);\n  // link processes queue & moves packets/acks\n  processLink(dt);\n\n  // detect if some packets were dropped in queue: for any inflight seq where pkt.dropped true and pkt.sendTime older than something,\n  // we don't schedule ack so that either timeout occurs or duplicate acks not triggered. We mark drop visuals earlier.\n\n  // check for timeouts\n  checkTimeouts();\n\n  // record history\n  history.t.push(state.time);\n  history.cwnd.push(state.cwnd);\n  history.ssthresh.push(state.ssthresh);\n  if (history.t.length > 600) { history.t.shift(); history.cwnd.shift(); history.ssthresh.shift(); }\n\n  // update ui and draw\n  updateUI();\n  drawGraph();\n  drawLink();\n  pruneVisuals();\n}\n\n// event handlers and controls\nband.addEventListener('input', ()=>{\n  params.bandwidth = +band.value;\n  bandTxt.textContent = params.bandwidth;\n  updateUI();\n});\nbuf.addEventListener('input', ()=>{\n  params.bufferSize = +buf.value;\n  bufTxt.textContent = params.bufferSize;\n  updateUI();\n});\nrttInput.addEventListener('input', ()=>{\n  params.rtt = +rttInput.value / 1000;\n  rttTxt.textContent = Math.round(params.rtt*1000);\n  updateUI();\n});\nlossInput.addEventListener('input', ()=>{\n  params.lossProb = +lossInput.value / 10000;\n  lossTxt.textContent = params.lossProb.toFixed(5);\n  updateUI();\n});\nspeedInput.addEventListener('input', ()=>{\n  params.speed = +speedInput.value;\n  speedTxt.textContent = params.speed + 'x';\n});\nfastRecovery.addEventListener('change', ()=>{\n  params.fastRecovery = fastRecovery.checked;\n});\n\nstartBtn.addEventListener('click', ()=>{\n  if (running) return;\n  running = true;\n  if (!stepInterval) {\n    const baseDt = 0.05;\n    stepInterval = setInterval(()=> {\n      // each tick, run several logical steps based on speed to accelerate\n      const logicalDt = baseDt * (params.speed || 1);\n      step(logicalDt);\n    }, 50);\n  }\n});\n\npauseBtn.addEventListener('click', ()=>{\n  running = false;\n  if (stepInterval) { clearInterval(stepInterval); stepInterval = null; }\n});\n\nresetBtn.addEventListener('click', ()=>{\n  running = false;\n  if (stepInterval) { clearInterval(stepInterval); stepInterval = null; }\n  resetSimulation();\n});\n\nforceLossBtn.addEventListener('click', ()=>{\n  // drop multiple packets in the link queue to simulate a sudden congestion event\n  const dropn = Math.min(6, link.queue.length);\n  for (let i=0;i<dropn;i++) {\n    const pkt = link.queue.shift();\n    if (pkt) {\n      pkt.dropped = true;\n      visualMarkDropped(pkt.seq);\n      // remove it from inflight map (sender will eventually timeout)\n      // keep inflight so that loss detection works via ack absence\n    }\n  }\n});\n\n// initialize\nresetSimulation();\ndrawGraph();\ndrawLink();\n\n// small warm-up: draw once per second even if paused to keep visuals responsive\nsetInterval(()=>{\n  drawGraph();\n  drawLink();\n}, 1000);\n\n</script>\n</body>\n</html>"
