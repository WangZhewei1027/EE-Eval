    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Virtual Memory Simulation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #memory, #virtualMemory {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin: 10px 0;\n            height: 150px;\n            overflow: auto;\n        }\n        .memory-slot {\n            margin: 5px 0;\n            padding: 5px;\n            border: 1px solid #999;\n            background-color: #f0f0f0;\n        }\n        .active {\n            background-color: #c8e6c9;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Virtual Memory Simulation</h1>\n\n    <div>\n        <button onclick=\"loadProcess()\">Load Process</button>\n    </div>\n\n    <h2>Physical Memory (RAM)</h2>\n    <div id=\"memory\"></div>\n\n    <h2>Virtual Memory (Disk)</h2>\n    <div id=\"virtualMemory\"></div>\n\n    <script>\n        const physicalMemorySize = 4; // Simulate 4 physical memory slots\n        const virtualMemorySize = 10; // Simulate 10 virtual memory slots\n        let physicalMemory = [];\n        let virtualMemory = [];\n\n        function loadProcess() {\n            if (virtualMemory.length < virtualMemorySize) {\n                const processIndex = virtualMemory.length;\n                virtualMemory.push(`Process ${processIndex + 1}`);\n                updateVirtualMemoryDisplay();\n\n                if (physicalMemory.length < physicalMemorySize) {\n                    loadIntoPhysicalMemory(processIndex);\n                } else {\n                    console.log('Physical Memory Full! Swapping needed.');\n                    swapMemory();\n                }\n            } else {\n                console.log('Virtual Memory Full! Cannot load more processes.');\n            }\n        }\n\n        function loadIntoPhysicalMemory(index) {\n            physicalMemory.push(`Process ${index + 1}`);\n            updatePhysicalMemoryDisplay();\n        }\n\n        function updatePhysicalMemoryDisplay() {\n            const memoryDiv = document.getElementById('memory');\n            memoryDiv.innerHTML = physicalMemory.map((process, index) => \n                `<div class=\"memory-slot\">${process}</div>`\n            ).join('');\n        }\n\n        function updateVirtualMemoryDisplay() {\n            const virtualMemoryDiv = document.getElementById('virtualMemory');\n            virtualMemoryDiv.innerHTML = virtualMemory.map((process, index) => \n                `<div class=\"memory-slot\">${process}</div>`\n            ).join('');\n        }\n\n        function swapMemory() {\n            const oldestProcess = physicalMemory.shift(); // Remove from the front\n            physicalMemory.push(oldestProcess); // Add to the back (simulate using it)\n            console.log(`${oldestProcess} swapped to virtual memory.`);\n            updatePhysicalMemoryDisplay();\n        }\n    </script>\n</body>\n</html>"
