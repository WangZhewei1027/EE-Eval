    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Load Balancing Simulator</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#36c;\n      --muted:#95a0b5;\n      --good:#2dd4bf;\n      --bad:#ff6b6b;\n      --glass: rgba(255,255,255,0.03);\n      font-family: Inter, Roboto, system-ui, -apple-system, \"Segoe UI\", \"Helvetica\", Arial;\n      color: #dbe6ff;\n    }\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,#071025 0%, #071b2a 100%);font-size:14px}\n    .app{max-width:1200px;margin:18px auto;padding:18px; background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border-radius:12px; box-shadow: 0 8px 30px rgba(2,6,23,0.8);}\n    h1{margin:0 0 6px 0;font-size:20px}\n    .top {display:flex;gap:16px;align-items:center;}\n    .controls {display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin:12px 0;}\n    .control {background:var(--panel); padding:8px 10px; border-radius:8px; display:flex; gap:8px; align-items:center; color:var(--muted);}\n    .control label{font-size:12px;color:var(--muted)}\n    select, input[type=range], input[type=number]{\n      background:transparent;border:1px solid rgba(255,255,255,0.06); color:var(--muted); padding:6px 8px; border-radius:6px;\n    }\n    button{background:linear-gradient(90deg,var(--accent),#6ea4ff); color:#fff; border:none; padding:8px 12px; border-radius:8px; cursor:pointer}\n    button.secondary{background:transparent; border:1px solid rgba(255,255,255,0.06); color:var(--muted)}\n    .layout{display:flex; gap:14px; margin-top:10px;}\n    .vis {flex:1; min-width:520px; background:var(--glass); border-radius:10px; padding:12px;}\n    .sidebar {width:360px; background:var(--glass); border-radius:10px; padding:12px;}\n    .lb-row{display:flex; align-items:center; gap:8px; margin-bottom:8px}\n    .box {background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border-radius:8px; padding:8px;}\n    .lb-box{height:56px; display:flex; align-items:center; justify-content:center; width:150px; font-weight:600; letter-spacing:0.6px}\n    #canvasArea{width:100%; height:300px; background:linear-gradient(180deg, rgba(5,10,20,0.8), rgba(5,10,30,0.7)); border-radius:8px; position:relative; overflow:hidden}\n    .servers {display:flex; gap:8px; flex-wrap:wrap; margin-top:12px}\n    .server {width:120px; min-height:120px; background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border-radius:8px; padding:8px; box-sizing:border-box; display:flex; flex-direction:column; align-items:center; justify-content:flex-start; gap:8px; cursor:pointer; border:2px solid transparent}\n    .server.down{opacity:0.5; border-color:rgba(255,80,80,0.25)}\n    .server .title{font-weight:700}\n    .server .stat{font-size:12px;color:var(--muted)}\n    .bulb{width:12px;height:12px;border-radius:50%}\n    .bulb.up{background:var(--good)}\n    .bulb.down{background:var(--bad)}\n    .queue{display:flex;gap:4px;flex-wrap:wrap; justify-content:center}\n    .req-dot{width:10px;height:10px;border-radius:50%; background:#9cc4ff; box-shadow:0 1px 6px rgba(110,170,255,0.2)}\n    .charts{display:flex; gap:8px; margin-top:10px}\n    canvas{background:transparent;border-radius:6px}\n    .small{font-size:12px;color:var(--muted)}\n    .stats-grid{display:grid; grid-template-columns:repeat(2,1fr); gap:8px}\n    .stat-card{background:rgba(255,255,255,0.02); padding:8px; border-radius:8px}\n    .footer-note{font-size:12px;color:var(--muted); margin-top:10px}\n    .weight-input{width:48px}\n    .muted{color:var(--muted); font-size:12px}\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <div class=\"top\">\n      <div style=\"flex:1\">\n        <h1>Load Balancing Simulator</h1>\n        <div class=\"muted\">Interactive demo: simulate how a load balancer routes requests to backend servers using different algorithms.</div>\n      </div>\n      <div style=\"text-align:right\">\n        <div class=\"muted\">Simulation Tick: <span id=\"tickMs\">100</span> ms</div>\n      </div>\n    </div>\n\n    <div class=\"controls\">\n      <div class=\"control\">\n        <label>Algorithm</label>\n        <select id=\"algo\">\n          <option value=\"roundrobin\">Round Robin</option>\n          <option value=\"weighted\">Weighted Round Robin</option>\n          <option value=\"leastconn\">Least Connections</option>\n          <option value=\"random\">Random</option>\n        </select>\n      </div>\n\n      <div class=\"control\">\n        <label>Req/s</label>\n        <input id=\"rate\" type=\"range\" min=\"0\" max=\"50\" value=\"8\" />\n        <div style=\"width:56px;text-align:center;font-weight:700;color:var(--muted)\"><span id=\"rateVal\">8</span></div>\n      </div>\n\n      <div class=\"control\">\n        <label>Mean service (ms)</label>\n        <input id=\"serviceMean\" type=\"number\" min=\"50\" max=\"2000\" value=\"600\" />\n      </div>\n\n      <div class=\"control\">\n        <label>Variance (ms)</label>\n        <input id=\"serviceVar\" type=\"number\" min=\"0\" max=\"1500\" value=\"200\" />\n      </div>\n\n      <div class=\"control\">\n        <button id=\"startBtn\">Start</button>\n        <button id=\"resetBtn\" class=\"secondary\">Reset</button>\n      </div>\n\n      <div class=\"control\">\n        <button id=\"addServer\" class=\"secondary\">+ Server</button>\n        <button id=\"removeServer\" class=\"secondary\">- Server</button>\n      </div>\n\n    </div>\n\n    <div class=\"layout\">\n      <div class=\"vis box\">\n        <div class=\"lb-row\">\n          <div style=\"flex:1;\">\n            <div style=\"display:flex; align-items:center; gap:12px;\">\n              <div class=\"lb-box box\" style=\"width:220px; background:linear-gradient(90deg,#1b3050,#15304a); color:#cde2ff\">\n                Load Balancer\n              </div>\n              <div class=\"small muted\">Strategy: <span id=\"algoLabel\">Round Robin</span></div>\n              <div class=\"small muted\">Pointer: <span id=\"pointerLabel\">0</span></div>\n            </div>\n          </div>\n          <div style=\"text-align:right\" id=\"simControls\">\n            <div class=\"small muted\">Total generated: <b id=\"totalGen\">0</b></div>\n            <div class=\"small muted\">Dropped: <b id=\"dropped\">0</b></div>\n          </div>\n        </div>\n\n        <div id=\"canvasArea\" class=\"box\">\n          <canvas id=\"animCanvas\"></canvas>\n        </div>\n\n        <div class=\"servers\" id=\"serversContainer\" title=\"Click a server to toggle up/down\">\n          <!-- servers rendered here -->\n        </div>\n\n        <div class=\"charts\">\n          <canvas id=\"chartCanvas\" width=\"900\" height=\"120\"></canvas>\n        </div>\n\n      </div>\n\n      <div class=\"sidebar\">\n        <div style=\"display:flex; gap:8px; align-items:center; justify-content:space-between;\">\n          <div style=\"font-weight:700\">Overview</div>\n          <div class=\"small muted\">Click server box to bring it up/down</div>\n        </div>\n\n        <div style=\"margin-top:8px;\" class=\"stats-grid\">\n          <div class=\"stat-card\">\n            <div class=\"small muted\">Throughput (req/s)</div>\n            <div style=\"font-weight:800;font-size:20px\" id=\"throughput\">0</div>\n          </div>\n          <div class=\"stat-card\">\n            <div class=\"small muted\">Avg response (ms)</div>\n            <div style=\"font-weight:800;font-size:20px\" id=\"avgResp\">0</div>\n          </div>\n          <div class=\"stat-card\">\n            <div class=\"small muted\">In-flight (processing)</div>\n            <div style=\"font-weight:800;font-size:20px\" id=\"inflight\">0</div>\n          </div>\n          <div class=\"stat-card\">\n            <div class=\"small muted\">Queued total</div>\n            <div style=\"font-weight:800;font-size:20px\" id=\"queuedTotal\">0</div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:12px\">\n          <div style=\"font-weight:700\">Servers</div>\n          <div class=\"muted small\" style=\"margin-top:6px\">You can change server weights when using Weighted RR.</div>\n          <div id=\"serverWeights\" style=\"margin-top:8px\"></div>\n        </div>\n\n        <div class=\"footer-note\">\n          This is a simplified simulation: each request is routed then served by a backend with service times drawn around the configured mean. Try failing servers, changing algorithms and request rate to see different behaviors (queues, queue imbalance, and response times).\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n<script>\n/*\n  Load Balancing Simulator\n  - Single-file client-side simulation/visualization\n  - Algorithms: Round Robin, Weighted Round Robin, Least Connections, Random\n  - Interactive controls: request rate, service time mean/variance, number of servers\n  - Click a server to toggle up/down\n*/\n\n// Utility functions\nfunction randRange(a,b){ return a + Math.random()*(b-a) }\nfunction clamp(v,a,b){ return Math.max(a, Math.min(b, v)) }\nfunction now(){ return Date.now() }\n\n// Simulation parameters and state\nconst state = {\n  tickMs: 100,\n  running: false,\n  spawnRate: 8, // req/sec\n  serviceMean: 600, // ms\n  serviceVar: 200, // ms\n  servers: [],\n  nextReqId: 1,\n  totalGenerated: 0,\n  dropped: 0,\n  algo: 'roundrobin',\n  rrPointer: 0,\n  weightedRotation: [], // array of server indices for simple WRR\n  metricsWindow: 60,\n  throughputHistory: [], // per second\n  respHistory: [],\n  animObjects: [], // moving request animation objects\n  lastChartTick: now()\n}\n\n// DOM references\nconst algoSelect = document.getElementById('algo')\nconst rateInput = document.getElementById('rate')\nconst rateVal = document.getElementById('rateVal')\nconst serviceMeanInput = document.getElementById('serviceMean')\nconst serviceVarInput = document.getElementById('serviceVar')\nconst startBtn = document.getElementById('startBtn')\nconst resetBtn = document.getElementById('resetBtn')\nconst addServerBtn = document.getElementById('addServer')\nconst removeServerBtn = document.getElementById('removeServer')\nconst serversContainer = document.getElementById('serversContainer')\nconst serverWeightsDiv = document.getElementById('serverWeights')\nconst animCanvas = document.getElementById('animCanvas')\nconst chartCanvas = document.getElementById('chartCanvas')\nconst totalGenLabel = document.getElementById('totalGen')\nconst droppedLabel = document.getElementById('dropped')\nconst pointerLabel = document.getElementById('pointerLabel')\nconst algoLabel = document.getElementById('algoLabel')\nconst throughputLabel = document.getElementById('throughput')\nconst avgRespLabel = document.getElementById('avgResp')\nconst inflightLabel = document.getElementById('inflight')\nconst queuedTotalLabel = document.getElementById('queuedTotal')\nconst tickMsLabel = document.getElementById('tickMs')\n\n// Canvas setup\nconst actx = animCanvas.getContext('2d')\nconst cctx = chartCanvas.getContext('2d')\nfunction resizeCanvases(){\n  animCanvas.width = animCanvas.clientWidth\n  animCanvas.height = animCanvas.clientHeight\n  chartCanvas.width = chartCanvas.clientWidth\n  chartCanvas.height = 120\n}\nwindow.addEventListener('resize', () => {\n  resizeCanvases()\n  renderAll()\n})\nresizeCanvases()\n\n// Initialize with 3 servers\nfunction initServers(n=3){\n  state.servers = []\n  for(let i=0;i<n;i++){\n    state.servers.push(makeServer(i+1))\n  }\n  rebuildWeightedRotation()\n}\nfunction makeServer(id){\n  return {\n    id,\n    healthy: true,\n    queue: [],\n    processing: null,\n    stats: { processed: 0, cumulativeResp: 0 },\n    weight: 1\n  }\n}\n\ninitServers(3)\nrenderServers()\nrenderWeights()\n\n// UI bindings\nalgoSelect.addEventListener('change', ()=>{\n  state.algo = algoSelect.value\n  algoLabel.textContent = algoSelect.options[algoSelect.selectedIndex].text\n  renderWeights()\n})\nrateInput.addEventListener('input', ()=>{\n  state.spawnRate = parseFloat(rateInput.value)\n  rateVal.textContent = rateInput.value\n})\nserviceMeanInput.addEventListener('change', ()=>{\n  state.serviceMean = parseFloat(serviceMeanInput.value)\n})\nserviceVarInput.addEventListener('change', ()=>{\n  state.serviceVar = parseFloat(serviceVarInput.value)\n})\nstartBtn.addEventListener('click', toggleRun)\nresetBtn.addEventListener('click', resetSim)\naddServerBtn.addEventListener('click', ()=>{\n  const nextId = state.servers.length ? Math.max(...state.servers.map(s=>s.id))+1 : 1\n  state.servers.push(makeServer(nextId))\n  rebuildWeightedRotation()\n  renderServers()\n  renderWeights()\n})\nremoveServerBtn.addEventListener('click', ()=>{\n  if(state.servers.length>1){\n    state.servers.pop()\n    rebuildWeightedRotation()\n    renderServers()\n    renderWeights()\n  }\n})\n\n// Toggling server up/down by clicking in renderServers\nfunction toggleServer(index){\n  const s = state.servers[index]\n  s.healthy = !s.healthy\n  // If server becomes down, pointer may need adjustment; don't drop queued requests (they just pause)\n  rebuildWeightedRotation()\n  renderServers()\n}\n\n// Weighted rotation array\nfunction rebuildWeightedRotation(){\n  state.weightedRotation = []\n  state.servers.forEach((s,idx)=>{\n    const w = Math.max(1, Math.round(s.weight || 1))\n    for(let k=0;k<w;k++) state.weightedRotation.push(idx)\n  })\n  if(state.rrPointer >= state.weightedRotation.length) state.rrPointer = 0\n}\n\n// Routing algorithms\nfunction routeRequest(req){\n  const healthyIdxs = state.servers.map((s,i)=>s.healthy ? i : -1).filter(i=>i>=0)\n  if(healthyIdxs.length===0){\n    state.dropped++\n    return null\n  }\n  let chosen = null\n  if(state.algo === 'roundrobin'){\n    // simple round robin over healthy servers\n    let attempts = 0\n    while(attempts < state.servers.length){\n      const idx = state.rrPointer % state.servers.length\n      state.rrPointer = (state.rrPointer + 1) % state.servers.length\n      attempts++\n      if(state.servers[idx] && state.servers[idx].healthy){\n        chosen = idx; break\n      }\n    }\n  } else if(state.algo === 'weighted'){\n    // rotate through weightedRotation skipping down servers\n    if(state.weightedRotation.length === 0){\n      // fallback: choose first healthy\n      chosen = healthyIdxs[0]\n    } else {\n      let attempts = 0\n      while(attempts < state.weightedRotation.length){\n        const pos = state.rrPointer % state.weightedRotation.length\n        const idx = state.weightedRotation[pos]\n        state.rrPointer = (state.rrPointer + 1) % state.weightedRotation.length\n        attempts++\n        if(state.servers[idx] && state.servers[idx].healthy){\n          chosen = idx; break\n        }\n      }\n      if(chosen===null) chosen = healthyIdxs[0]\n    }\n  } else if(state.algo === 'leastconn'){\n    // choose server with smallest (queue length + processing? treat processing as 1)\n    let bestIdx = null; let bestVal = Infinity\n    state.servers.forEach((s,i)=>{\n      if(!s.healthy) return\n      const val = s.queue.length + (s.processing ? 1 : 0)\n      if(val < bestVal){ bestVal = val; bestIdx = i }\n    })\n    chosen = bestIdx\n  } else if(state.algo === 'random'){\n    const choice = healthyIdxs[Math.floor(Math.random()*healthyIdxs.length)]\n    chosen = choice\n  }\n  return chosen\n}\n\n// Service time generator: draw from normal around mean with sd = var, clamp > 20ms\nfunction drawService(){\n  const mean = state.serviceMean\n  const sd = state.serviceVar\n  // Box-Muller for normal\n  let u = 0, v = 0\n  while(u === 0) u = Math.random()\n  while(v === 0) v = Math.random()\n  const z = Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0*Math.PI*v)\n  const val = mean + z * sd\n  return Math.max(20, Math.round(val))\n}\n\n// Simulation loop\nlet simInterval = null\nlet animInterval = null\nlet spawnAccumulator = 0\nfunction startSim(){\n  if(state.running) return\n  state.running = true\n  startBtn.textContent = 'Stop'\n  tickMsLabel.textContent = state.tickMs\n  // spawn loop\n  simInterval = setInterval(simTick, state.tickMs)\n  // animation loop for drawing\n  animInterval = setInterval(renderAll, 30)\n  // chart ticking per second\n  state.lastChartTick = now()\n}\nfunction stopSim(){\n  if(!state.running) return\n  state.running = false\n  startBtn.textContent = 'Start'\n  clearInterval(simInterval)\n  clearInterval(animInterval)\n}\nfunction toggleRun(){\n  if(state.running) stopSim(); else startSim()\n}\n\nfunction resetSim(){\n  stopSim()\n  state.nextReqId = 1\n  state.totalGenerated = 0\n  state.dropped = 0\n  state.throughputHistory = []\n  state.respHistory = []\n  state.animObjects = []\n  state.servers.forEach(s=>{\n    s.queue = []\n    s.processing = null\n    s.stats = { processed:0, cumulativeResp:0 }\n  })\n  state.rrPointer = 0\n  spawnAccumulator = 0\n  renderAll()\n}\n\n// Sim tick does routing and processing\nfunction simTick(){\n  // spawn requests using fractional expected number\n  const expected = state.spawnRate * (state.tickMs / 1000)\n  spawnAccumulator += expected\n  const toSpawn = Math.floor(spawnAccumulator)\n  spawnAccumulator -= toSpawn\n  for(let i=0;i<toSpawn;i++){\n    spawnRequest()\n  }\n\n  // processing step: decrement processing time for each server\n  const dt = state.tickMs\n  const tNow = now()\n  let completedThisTick = 0\n  for(const s of state.servers){\n    // if not healthy, processing continues (we simulate only a server failure stops new assignments, not current processing)\n    if(s.processing){\n      s.processing.remaining -= dt\n      if(s.processing.remaining <= 0){\n        // complete\n        const resp = tNow - s.processing.createdAt\n        s.stats.processed++\n        s.stats.cumulativeResp += resp\n        completedThisTick++\n        // free processing and start next from queue if any\n        s.processing = null\n      }\n    }\n    // start next if free\n    if(!s.processing && s.queue.length>0 && s.healthy){\n      s.processing = s.queue.shift()\n      // if processing started, we add slight overhead\n    }\n  }\n\n  // chart/metrics update: per second\n  if(tNow - state.lastChartTick >= 1000){\n    const thru = completedThisTick\n    state.throughputHistory.push(thru)\n    const avgResp = computeAvgResponseMillis()\n    state.respHistory.push(avgResp)\n    if(state.throughputHistory.length > state.metricsWindow) state.throughputHistory.shift()\n    if(state.respHistory.length > state.metricsWindow) state.respHistory.shift()\n    state.lastChartTick = tNow\n  }\n\n  // update labels\n  totalGenLabel.textContent = state.totalGenerated\n  droppedLabel.textContent = state.dropped\n  pointerLabel.textContent = state.rrPointer\n}\n\n// spawn a single request and route it\nfunction spawnRequest(){\n  const id = state.nextReqId++\n  const req = { id, createdAt: now(), remaining: drawService() }\n  state.totalGenerated++\n  const chosen = routeRequest(req)\n  if(chosen === null || chosen === undefined){\n    // dropped\n    state.dropped++\n    return\n  }\n  // enqueue on chosen server\n  state.servers[chosen].queue.push(req)\n  // create animation object for request traveling from LB to server\n  createAnimObject(chosen)\n}\n\n// create animation visual object: travels from LB center to server position\nfunction createAnimObject(serverIndex){\n  // compute target coords for server box in canvas\n  const sRect = getServerRect(serverIndex)\n  if(!sRect) return\n  const canvasRect = animCanvas.getBoundingClientRect()\n  const from = { x: canvasRect.width * 0.12, y: canvasRect.height * 0.12 } // lb pos\n  const to = { x: sRect.cx - canvasRect.left, y: sRect.cy - canvasRect.top }\n  state.animObjects.push({\n    id: 'r' + Math.random().toString(36).slice(2,7),\n    start: now(),\n    duration: 420 + Math.random()*200,\n    from, to\n  })\n}\n\n// render functions\nfunction renderAll(){\n  renderServers()\n  drawAnimations()\n  drawChart()\n  updateSidebarStats()\n}\n\n// compute average response across all servers\nfunction computeAvgResponseMillis(){\n  let tot=0, cnt=0\n  for(const s of state.servers){\n    tot += s.stats.cumulativeResp\n    cnt += s.stats.processed\n  }\n  return cnt ? Math.round(tot / cnt) : 0\n}\n\nfunction updateSidebarStats(){\n  // throughput: last value\n  const lastThroughput = state.throughputHistory.length ? state.throughputHistory[state.throughputHistory.length-1] : 0\n  throughputLabel.textContent = lastThroughput\n  avgRespLabel.textContent = computeAvgResponseMillis()\n  let inflight=0, queued=0\n  for(const s of state.servers){\n    if(s.processing) inflight++\n    queued += s.queue.length\n  }\n  inflightLabel.textContent = inflight\n  queuedTotalLabel.textContent = queued\n}\n\n// Render server boxes in DOM\nfunction renderServers(){\n  serversContainer.innerHTML = ''\n  const canvasRect = animCanvas.getBoundingClientRect()\n  state.servers.forEach((s,i)=>{\n    const el = document.createElement('div')\n    el.className = 'server box' + (s.healthy ? '' : ' down')\n    el.dataset.idx = i\n    el.title = 'Click to toggle server up/down'\n    el.addEventListener('click', ()=>{ toggleServer(i) })\n    const title = document.createElement('div'); title.className = 'title'; title.textContent = 'S' + s.id\n    const bulb = document.createElement('div'); bulb.className = 'bulb ' + (s.healthy ? 'up' : 'down')\n    const topRow = document.createElement('div'); topRow.style.display='flex'; topRow.style.alignItems='center'; topRow.style.gap='8px'\n    topRow.appendChild(bulb)\n    topRow.appendChild(title)\n    const stats = document.createElement('div'); stats.className='stat'\n    stats.innerHTML = `proc: ${s.stats.processed} &nbsp; avg: ${s.stats.processed ? Math.round(s.stats.cumulativeResp/s.stats.processed) : 0} ms`\n    const qRow = document.createElement('div'); qRow.style.width='100%'; qRow.style.display='flex'; qRow.style.flexDirection='column'; qRow.style.alignItems='center'\n    const qlabel = document.createElement('div'); qlabel.className='stat'; qlabel.textContent = `queue: ${s.queue.length}`\n    const dots = document.createElement('div'); dots.className='queue'\n    // show up to 6 small dots for queue\n    for(let k=0;k<Math.min(6,s.queue.length);k++){\n      const d = document.createElement('div'); d.className='req-dot'\n      dots.appendChild(d)\n    }\n    qRow.appendChild(qlabel); qRow.appendChild(dots)\n    el.appendChild(topRow)\n    el.appendChild(stats)\n    el.appendChild(qRow)\n    serversContainer.appendChild(el)\n  })\n}\n\n// For animations, compute server element center\nfunction getServerRect(index){\n  const children = serversContainer.children\n  if(index < 0 || index >= children.length) return null\n  const el = children[index]\n  const r = el.getBoundingClientRect()\n  return { left:r.left, top:r.top, right:r.right, bottom:r.bottom, cx:(r.left+r.right)/2, cy:(r.top+r.bottom)/2 }\n}\n\nfunction drawAnimations(){\n  // clear\n  actx.clearRect(0,0,animCanvas.width,animCanvas.height)\n  // draw background LB and server targets\n  // Draw LB box\n  const width = animCanvas.width, height = animCanvas.height\n  // LB position\n  const lbX = width * 0.12, lbY = height * 0.12\n  actx.fillStyle = '#17395b'\n  actx.fillRect(lbX-48, lbY-20, 96, 40)\n  actx.fillStyle = '#cfe6ff'\n  actx.font = '12px sans-serif'\n  actx.fillText('LB', lbX-8, lbY+4)\n  // Draw server anchors\n  state.servers.forEach((s,i)=>{\n    const rect = getServerRect(i)\n    if(!rect) return\n    // transform rect to canvas coords\n    const canvasRect = animCanvas.getBoundingClientRect()\n    const cx = rect.cx - canvasRect.left\n    const cy = rect.cy - canvasRect.top\n    actx.beginPath()\n    actx.fillStyle = s.healthy ? 'rgba(45,212,191,0.06)' : 'rgba(255,107,107,0.05)'\n    actx.arc(cx, cy, 22, 0, Math.PI*2)\n    actx.fill()\n    // small outline\n    actx.strokeStyle = s.healthy ? 'rgba(45,212,191,0.4)' : 'rgba(255,107,107,0.4)'\n    actx.lineWidth = 1\n    actx.stroke()\n  })\n\n  // update and draw animObjects\n  const nowT = now()\n  for(let i=state.animObjects.length-1;i>=0;i--){\n    const obj = state.animObjects[i]\n    const t = (nowT - obj.start) / obj.duration\n    if(t >= 1){\n      state.animObjects.splice(i,1)\n      continue\n    }\n    const ease = 1 - Math.pow(1-t, 2) // ease-out\n    const x = obj.from.x + (obj.to.x - obj.from.x) * ease\n    const y = obj.from.y + (obj.to.y - obj.from.y) * ease\n    const radius = 5 + 4*(1-t)\n    const grad = actx.createRadialGradient(x,y,1,x+6,y-6,18)\n    grad.addColorStop(0, 'rgba(156,196,255,1)')\n    grad.addColorStop(1, 'rgba(60,110,200,0.06)')\n    actx.fillStyle = grad\n    actx.beginPath()\n    actx.arc(x,y,radius,0,Math.PI*2)\n    actx.fill()\n  }\n}\n\n// Chart drawing - throughput and avg response over time\nfunction drawChart(){\n  const w = chartCanvas.width, h = chartCanvas.height\n  cctx.clearRect(0,0,w,h)\n  // background\n  cctx.fillStyle = 'rgba(255,255,255,0.02)'\n  cctx.fillRect(0,0,w,h)\n  // grid lines\n  cctx.strokeStyle = 'rgba(255,255,255,0.03)'\n  cctx.lineWidth = 1\n  for(let i=0;i<5;i++){\n    const y = (i/4)*h\n    cctx.beginPath(); cctx.moveTo(0,y); cctx.lineTo(w,y); cctx.stroke()\n  }\n  // throughput (bar-like)\n  const maxLen = state.metricsWindow\n  const vals = state.throughputHistory.slice(-maxLen)\n  const maxVal = Math.max(5, ...vals)\n  const barW = w / Math.max(1, maxLen)\n  cctx.fillStyle = 'rgba(109,187,255,0.9)'\n  vals.forEach((v,i)=>{\n    const x = i * barW\n    const barH = (v / maxVal) * (h * 0.55)\n    cctx.fillRect(x, h - barH, barW*0.8, barH)\n  })\n\n  // avg response line\n  const resp = state.respHistory.slice(-maxLen)\n  const maxResp = Math.max(100, ...resp)\n  cctx.beginPath()\n  for(let i=0;i<resp.length;i++){\n    const x = i * barW + barW*0.4\n    const y = h - (resp[i] / maxResp) * (h * 0.9)\n    if(i===0) cctx.moveTo(x,y); else cctx.lineTo(x,y)\n  }\n  cctx.strokeStyle = 'rgba(45,212,191,0.95)'\n  cctx.lineWidth = 2\n  cctx.stroke()\n\n  // legend\n  cctx.fillStyle = 'rgba(255,255,255,0.8)'\n  cctx.font = '12px sans-serif'\n  cctx.fillText('Throughput (bars) & Avg resp (line)', 8, 14)\n}\n\n// Render server weights controls for weighted RR\nfunction renderWeights(){\n  serverWeightsDiv.innerHTML = ''\n  if(state.algo !== 'weighted') {\n    serverWeightsDiv.appendChild(document.createTextNode('Weights are shown only for Weighted RR.'))\n    return\n  }\n  state.servers.forEach((s,i)=>{\n    const div = document.createElement('div')\n    div.style.display='flex'; div.style.alignItems='center'; div.style.justifyContent='space-between'; div.style.padding='6px 0'\n    const label = document.createElement('div'); label.textContent = 'S' + s.id; label.style.fontWeight='700'\n    const inp = document.createElement('input'); inp.type = 'number'; inp.value = s.weight || 1; inp.min=1; inp.className='weight-input'\n    inp.addEventListener('change', ()=>{\n      s.weight = Math.max(1, Math.round(Number(inp.value) || 1))\n      rebuildWeightedRotation()\n    })\n    div.appendChild(label)\n    div.appendChild(inp)\n    serverWeightsDiv.appendChild(div)\n  })\n}\n\n// initial render\nrenderAll()\n\n// keyboard shortcuts\nwindow.addEventListener('keydown', (e)=>{\n  if(e.key === ' '){ e.preventDefault(); toggleRun() }\n  if(e.key === 'r'){ resetSim() }\n})\n\n// expose some debug functions to console for experimentation\nwindow.LBSim = {\n  state, startSim, stopSim, resetSim\n}\n\n</script>\n</body>\n</html>"
