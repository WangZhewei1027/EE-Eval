    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Array Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n        #array-output {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            min-height: 50px;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Dynamic Array Demonstration</h1>\n    <input type=\"text\" id=\"element-input\" placeholder=\"Enter a new element\" />\n    <button id=\"add-button\">Add Element</button>\n    <button id=\"remove-button\">Remove Last Element</button>\n    <div id=\"array-output\">Dynamic Array: []</div>\n\n    <script>\n        // Initialize an empty array\n        let dynamicArray = [];\n\n        // Function to update the displayed output\n        function updateOutput() {\n            document.getElementById('array-output').innerText = `Dynamic Array: [${dynamicArray.join(', ')}]`;\n        }\n\n        // Function to add an element to the dynamic array\n        document.getElementById('add-button').onclick = function() {\n            const newElement = document.getElementById('element-input').value;\n            if (newElement) {\n                dynamicArray.push(newElement);\n                document.getElementById('element-input').value = ''; // Clear input\n                updateOutput(); // Update displayed output\n            } else {\n                alert('Please enter a valid element.');\n            }\n        };\n\n        // Function to remove the last element from the dynamic array\n        document.getElementById('remove-button').onclick = function() {\n            if (dynamicArray.length > 0) {\n                dynamicArray.pop();\n                updateOutput(); // Update displayed output\n            } else {\n                alert('No elements to remove.');\n            }\n        };\n    </script>\n\n</body>\n</html>"
