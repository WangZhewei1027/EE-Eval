    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ACID Properties</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        #result {\n            font-size: 24px;\n            font-weight: bold;\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>ACID Properties</h1>\n    <p>Atomicity: A transaction is atomic if it cannot be divided into smaller parts without leaving any inconsistency.</p>\n    <div id=\"result\"></div>\n    <script>\n        let transactions = [\n            {\n                id: 1,\n                data: \"Transaction 1\"\n            },\n            {\n                id: 2,\n                data: \"Transaction 2\"\n            },\n            {\n                id: 3,\n                data: \"Transaction 3\"\n            }\n        ];\n\n        let db = {\n            transactions: transactions,\n            currentTransactionId: 1\n        };\n\n        function atomicity() {\n            let currentTransaction = db.transactions.find(transaction => transaction.id === db.currentTransactionId);\n            if (currentTransaction) {\n                let transactionsToExecute = currentTransaction.data.split(\",\");\n                let executedTransactions = transactionsToExecute.filter(transaction => transaction !== \"\");\n                if (executedTransactions.length === transactionsToExecute.length) {\n                    console.log(\"Atomicity: Success\");\n                } else {\n                    console.log(\"Atomicity: Failure\");\n                }\n            } else {\n                console.log(\"Atomicity: No transaction found\");\n            }\n        }\n\n        function consistency() {\n            let currentTransaction = db.transactions.find(transaction => transaction.id === db.currentTransactionId);\n            if (currentTransaction) {\n                let transactionsToExecute = currentTransaction.data.split(\",\");\n                let executedTransactions = transactionsToExecute.filter(transaction => transaction !== \"\");\n                if (executedTransactions.length === transactionsToExecute.length) {\n                    console.log(\"Consistency: Success\");\n                } else {\n                    console.log(\"Consistency: Failure\");\n                }\n            } else {\n                console.log(\"Consistency: No transaction found\");\n            }\n        }\n\n        function isolation() {\n            let currentTransaction = db.transactions.find(transaction => transaction.id === db.currentTransactionId);\n            if (currentTransaction) {\n                let transactionsToExecute = currentTransaction.data.split(\",\");\n                let executedTransactions = transactionsToExecute.filter(transaction => transaction !== \"\");\n                if (executedTransactions.length === transactionsToExecute.length) {\n                    console.log(\"Isolation: Success\");\n                } else {\n                    console.log(\"Isolation: Failure\");\n                }\n            } else {\n                console.log(\"Isolation: No transaction found\");\n            }\n        }\n\n        function durability() {\n            let currentTransaction = db.transactions.find(transaction => transaction.id === db.currentTransactionId);\n            if (currentTransaction) {\n                let transactionsToExecute = currentTransaction.data.split(\",\");\n                let executedTransactions = transactionsToExecute.filter(transaction => transaction !== \"\");\n                if (executedTransactions.length === transactionsToExecute.length) {\n                    console.log(\"Durability: Success\");\n                } else {\n                    console.log(\"Durability: Failure\");\n                }\n            } else {\n                console.log(\"Durability: No transaction found\");\n            }\n        }\n\n        atomicity();\n        consistency();\n        isolation();\n        durability();\n    </script>\n</body>\n</html>"
