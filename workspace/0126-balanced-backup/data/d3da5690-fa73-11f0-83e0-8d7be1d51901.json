  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Socket Programming Concepts — Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 18px; color: #111; background: #f7f8fb; }\n    header { display:flex; align-items:center; gap:14px; margin-bottom: 18px; }\n    header h1 { margin:0; font-size:20px; }\n    .grid { display: grid; grid-template-columns: 1fr; gap: 14px; }\n    .panel { background: white; border-radius: 8px; padding: 14px; box-shadow: 0 1px 3px rgba(20,20,40,0.06); }\n    .row { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }\n    label { font-weight:600; font-size:13px; margin-right:6px;}\n    input[type=\"text\"], select, textarea { padding:7px 8px; border-radius:6px; border:1px solid #d6dbe8; background: #fff; font:inherit; }\n    button { padding:8px 10px; border-radius:6px; border:1px solid #9aa7e6; background:#2f63f6; color:white; cursor:pointer; }\n    button.secondary { background:#f0f4ff; color:#20306b; border:1px solid #d1dbff; }\n    button.warn { background:#fff6ee; color:#a84b00; border:1px solid #f6d5c3; }\n    pre { background:#0b1220; color:#cfe8ff; padding:12px; border-radius:6px; overflow:auto; max-height:300px; }\n    .log { background:#0f1724; color:#e6eefc; padding:12px; border-radius:6px; height:200px; overflow:auto; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Courier New\", monospace; font-size:13px;}\n    .muted { color:#556; font-size:13px; }\n    .small { font-size:13px; color:#334; }\n    .badge { background:#eef2ff; color:#213; padding:6px 8px; border-radius:999px; font-weight:700; font-size:12px; border:1px solid #dde6ff; }\n    .col { display:flex; flex-direction:column; gap:8px; }\n    .controls { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }\n    .split { display:grid; grid-template-columns: 1fr 1fr; gap:10px; }\n    .explain { font-size:13px; color:#334; line-height:1.4; }\n    footer { margin-top:18px; font-size:12px; color:#445; }\n    .status { display:inline-block; padding:6px 8px; border-radius:6px; font-weight:600; background:#f0f6ff; border:1px solid #dbeaff; color:#1b3a8a; }\n    .metric { font-weight:700; color:#0b3; }\n    input[type=number] { width:86px; padding:6px 8px; border-radius:6px; border:1px solid #d6dbe8; }\n    .codebox { background:#fafbfd; padding:10px; border-radius:6px; border:1px solid #eef2ff; font-family: ui-monospace, Menlo, monospace; font-size:13px; color:#112; overflow:auto; }\n  </style>\n</head>\n<body>\n  <header>\n    <div class=\"badge\">Socket Programming Demo</div>\n    <h1>Socket Programming Concepts — WebSocket, WebRTC DataChannel & Virtual Sockets</h1>\n  </header>\n\n  <div class=\"grid\">\n    <!-- Explanation Panel -->\n    <section class=\"panel\">\n      <div class=\"explain\">\n        This single-page demo illustrates core socket programming concepts:\n        - how clients and servers exchange data over persistent connections,\n        - different socket types: TCP-like streams, WebSockets (browser ↔ server), and WebRTC DataChannels (peer-to-peer),\n        - message framing, fragmentation, binary vs text data, and connection lifecycle events.\n        The demos are interactive; try the WebSocket echo server (real network), and a local WebRTC DataChannel that simulates two peers inside your browser. There's also a simple virtual socket that shows fragmentation and reassembly logic you would implement in a real TCP/UDP app.\n      </div>\n    </section>\n\n    <!-- WebSocket Panel -->\n    <section class=\"panel\">\n      <h2 style=\"margin-top:0\">WebSocket (network socket-like) — Client to an Echo Server</h2>\n      <div class=\"row\">\n        <label for=\"wsUrl\">Server URL</label>\n        <input id=\"wsUrl\" type=\"text\" value=\"wss://echo.websocket.events\" style=\"flex:1\" />\n        <button id=\"wsToggle\">Connect</button>\n        <button id=\"wsClear\" class=\"secondary\">Clear Log</button>\n        <div style=\"margin-left:auto\" class=\"small\">State: <span id=\"wsState\" class=\"status\">closed</span></div>\n      </div>\n      <div style=\"margin-top:10px\" class=\"row\">\n        <input id=\"wsMessage\" type=\"text\" placeholder=\"Message to send\" style=\"flex:1\" />\n        <button id=\"wsSend\">Send</button>\n        <button id=\"wsSendBinary\" class=\"secondary\">Send Binary</button>\n      </div>\n      <div style=\"margin-top:10px\" class=\"row\">\n        <div class=\"muted\">Bytes sent: <span id=\"wsSent\">0</span></div>\n        <div class=\"muted\" style=\"margin-left:12px\">Bytes received: <span id=\"wsRecv\">0</span></div>\n        <div class=\"muted\" style=\"margin-left:12px\">Messages received: <span id=\"wsMsgs\">0</span></div>\n      </div>\n      <div style=\"margin-top:12px\" class=\"log\" id=\"wsLog\" aria-live=\"polite\"></div>\n    </section>\n\n    <!-- WebRTC DataChannel Panel -->\n    <section class=\"panel\">\n      <h2 style=\"margin-top:0\">WebRTC DataChannel (peer-to-peer) — Two Local Peers</h2>\n      <div class=\"row\">\n        <button id=\"createConn\">Create Local Peers</button>\n        <button id=\"closeConn\" class=\"secondary\">Close Peers</button>\n        <div style=\"margin-left:auto\" class=\"muted\">DataChannel is bidirectional; this page creates both peers locally so you can inspect events and exchange messages like sockets.</div>\n      </div>\n      <div style=\"margin-top:10px\" class=\"split\">\n        <div>\n          <h4 style=\"margin:6px 0\">Peer A</h4>\n          <div class=\"row\">\n            <input id=\"aMsg\" type=\"text\" placeholder=\"Message from A\" style=\"flex:1\"/>\n            <button id=\"aSend\">Send A→B</button>\n            <button id=\"aBin\" class=\"secondary\">Send Binary</button>\n          </div>\n          <div style=\"margin-top:8px\" class=\"log\" id=\"aLog\"></div>\n        </div>\n        <div>\n          <h4 style=\"margin:6px 0\">Peer B</h4>\n          <div class=\"row\">\n            <input id=\"bMsg\" type=\"text\" placeholder=\"Message from B\" style=\"flex:1\"/>\n            <button id=\"bSend\">Send B→A</button>\n            <button id=\"bBin\" class=\"secondary\">Send Binary</button>\n          </div>\n          <div style=\"margin-top:8px\" class=\"log\" id=\"bLog\"></div>\n        </div>\n      </div>\n      <div style=\"margin-top:10px\" class=\"muted\">Connection states: <span id=\"pcState\">none</span></div>\n    </section>\n\n    <!-- Virtual Socket Panel -->\n    <section class=\"panel\">\n      <h2 style=\"margin-top:0\">Virtual Socket — Simulate Fragmentation & Framing</h2>\n      <div class=\"explain\">\n        This demonstrates how a length-prefixed framing protocol reassembles fragmented TCP messages.\n        You can send a long message, configure a small MTU to force fragmentation, and see how the receiver reassembles complete logical messages.\n      </div>\n      <div style=\"margin-top:8px\" class=\"row\">\n        <label>MTU (bytes)</label>\n        <input id=\"mtu\" type=\"number\" min=\"8\" value=\"16\" />\n        <label style=\"margin-left:8px\">Fragment Delay (ms)</label>\n        <input id=\"fragDelay\" type=\"number\" min=\"0\" value=\"120\" />\n        <button id=\"vsCreate\">Create Virtual Socket</button>\n        <button id=\"vsClose\" class=\"secondary\">Close</button>\n      </div>\n      <div style=\"margin-top:8px\" class=\"row\">\n        <input id=\"vsMsg\" type=\"text\" placeholder=\"Logical message to send\" style=\"flex:1\" />\n        <button id=\"vsSend\">Send</button>\n      </div>\n      <div style=\"margin-top:10px\" class=\"split\">\n        <div>\n          <h4 style=\"margin:6px 0\">Sender (fragments shown)</h4>\n          <div class=\"log\" id=\"vsSendLog\"></div>\n        </div>\n        <div>\n          <h4 style=\"margin:6px 0\">Receiver (reassembly)</h4>\n          <div class=\"log\" id=\"vsRecvLog\"></div>\n        </div>\n      </div>\n      <div style=\"margin-top:10px\" class=\"codebox\">\n        <strong>Length-prefixed framing (concept)</strong><br>\n        Before sending: prefix each message with a fixed-size length header (e.g. 2 or 4 bytes). The receiver reads bytes until the length header is complete, then reads the declared payload size, even if it arrives in fragments.\n        This demo uses a 2-byte big-endian length prefix.\n      </div>\n    </section>\n\n    <!-- Node.js Example Panel -->\n    <section class=\"panel\">\n      <h2 style=\"margin-top:0\">Server & Client (Node.js) — Raw TCP Example</h2>\n      <div class=\"explain\">\n        The browser cannot open raw TCP sockets, but below is a small Node.js example using the net module showing how a TCP server and client work. Run on your machine to test real sockets.\n      </div>\n      <pre>\n/* TCP server (Node.js)\nconst net = require('net');\nconst server = net.createServer(socket =&gt; {\n  console.log('client connected', socket.remoteAddress);\n  socket.on('data', data =&gt; {\n    console.log('received:', data.toString());\n    // echo back\n    socket.write(Buffer.from('Echo: ' + data.toString()));\n  });\n  socket.on('close', () =&gt; console.log('client closed'));\n});\nserver.listen(9000, () =&gt; console.log('listening on 9000'));\n\n\n/* TCP client (Node.js)\nconst net = require('net');\nconst client = net.createConnection({ port: 9000 }, () =&gt; {\n  console.log('connected to server');\n  client.write('Hello server!');\n});\nclient.on('data', data =&gt; {\n  console.log('server says:', data.toString());\n  client.end();\n});\nclient.on('end', () =&gt; console.log('disconnected'));\n*/\n      </pre>\n    </section>\n\n    <footer>\n      Note: WebSocket demo uses public echo server wss://echo.websocket.events (may be rate-limited). WebRTC DataChannel here creates both peers locally (no STUN required for local loopback) and thus works entirely in your browser. The virtual socket demonstrates framing and fragmentation logic used in socket programming.\n    </footer>\n  </div>\n\n  <script>\n    // Utility: append to log\n    function appendLog(el, text, opts = {}) {\n      const d = document.createElement('div');\n      d.style.whiteSpace = 'pre-wrap';\n      d.textContent = '[' + new Date().toLocaleTimeString() + '] ' + text;\n      if (opts.color) d.style.color = opts.color;\n      el.appendChild(d);\n      el.scrollTop = el.scrollHeight;\n    }\n\n    // ---------- WebSocket Demo ----------\n    (function(){\n      const wsUrlInput = document.getElementById('wsUrl');\n      const wsToggle = document.getElementById('wsToggle');\n      const wsState = document.getElementById('wsState');\n      const wsLog = document.getElementById('wsLog');\n      const wsSend = document.getElementById('wsSend');\n      const wsSendBinary = document.getElementById('wsSendBinary');\n      const wsMessage = document.getElementById('wsMessage');\n      const wsClear = document.getElementById('wsClear');\n      const wsSent = document.getElementById('wsSent');\n      const wsRecv = document.getElementById('wsRecv');\n      const wsMsgs = document.getElementById('wsMsgs');\n\n      let socket = null;\n      let bytesSent = 0, bytesRecv = 0, msgs = 0;\n\n      function setState(s) {\n        wsState.textContent = s;\n      }\n\n      function connect() {\n        const url = wsUrlInput.value.trim();\n        if (!url) return alert('Enter WebSocket server URL');\n        appendLog(wsLog, 'Connecting to ' + url + ' ...');\n        try {\n          socket = new WebSocket(url);\n        } catch (e) {\n          appendLog(wsLog, 'Failed to construct WebSocket: ' + e, {color:'#f66'});\n          return;\n        }\n        socket.binaryType = 'arraybuffer';\n        setState('connecting');\n        wsToggle.textContent = 'Disconnect';\n\n        socket.addEventListener('open', () => {\n          appendLog(wsLog, 'OPEN');\n          setState('open');\n        });\n        socket.addEventListener('message', ev => {\n          let payload = ev.data;\n          if (payload instanceof ArrayBuffer) {\n            const view = new Uint8Array(payload);\n            bytesRecv += view.byteLength;\n            appendLog(wsLog, 'RECV (binary) ' + view.byteLength + ' bytes: ' + bytesToHex(view));\n          } else {\n            bytesRecv += new TextEncoder().encode(payload).length;\n            appendLog(wsLog, 'RECV (text): ' + payload);\n          }\n          msgs++;\n          wsRecv.textContent = bytesRecv;\n          wsMsgs.textContent = msgs;\n        });\n        socket.addEventListener('close', ev => {\n          appendLog(wsLog, 'CLOSE (' + (ev.code||'') + ')');\n          setState('closed');\n          wsToggle.textContent = 'Connect';\n        });\n        socket.addEventListener('error', ev => {\n          appendLog(wsLog, 'ERROR', {color:'#f66'});\n        });\n      }\n\n      function disconnect() {\n        if (socket) {\n          socket.close();\n          socket = null;\n          setState('closed');\n          wsToggle.textContent = 'Connect';\n        }\n      }\n\n      wsToggle.addEventListener('click', () => {\n        if (!socket || socket.readyState === WebSocket.CLOSED) connect();\n        else disconnect();\n      });\n\n      wsSend.addEventListener('click', () => {\n        if (!socket || socket.readyState !== WebSocket.OPEN) return alert('Socket not open');\n        const text = wsMessage.value;\n        socket.send(text);\n        const size = new TextEncoder().encode(text).length;\n        bytesSent += size;\n        wsSent.textContent = bytesSent;\n        appendLog(wsLog, 'SENT (text): ' + text);\n      });\n\n      wsSendBinary.addEventListener('click', () => {\n        if (!socket || socket.readyState !== WebSocket.OPEN) return alert('Socket not open');\n        // Example binary payload: current timestamp + random bytes\n        const buf = new Uint8Array(12);\n        const view = new DataView(buf.buffer);\n        view.setFloat64(0, Date.now());\n        crypto.getRandomValues(buf.subarray(8));\n        socket.send(buf.buffer);\n        bytesSent += buf.byteLength;\n        wsSent.textContent = bytesSent;\n        appendLog(wsLog, 'SENT (binary) ' + buf.byteLength + ' bytes: ' + bytesToHex(buf));\n      });\n\n      wsClear.addEventListener('click', () => {\n        wsLog.innerHTML = '';\n        bytesRecv = bytesSent = msgs = 0;\n        wsRecv.textContent = 0; wsSent.textContent = 0; wsMsgs.textContent = 0;\n      });\n\n      function bytesToHex(arr) {\n        return Array.from(new Uint8Array(arr)).map(b => b.toString(16).padStart(2,'0')).join(' ');\n      }\n    })();\n\n    // ---------- WebRTC DataChannel Demo ----------\n    (function(){\n      const createBtn = document.getElementById('createConn');\n      const closeBtn = document.getElementById('closeConn');\n      const aSendBtn = document.getElementById('aSend');\n      const bSendBtn = document.getElementById('bSend');\n      const aBinBtn = document.getElementById('aBin');\n      const bBinBtn = document.getElementById('bBin');\n      const aMsg = document.getElementById('aMsg');\n      const bMsg = document.getElementById('bMsg');\n      const aLog = document.getElementById('aLog');\n      const bLog = document.getElementById('bLog');\n      const pcState = document.getElementById('pcState');\n\n      let pc1 = null, pc2 = null;\n      let dc1 = null, dc2 = null;\n\n      function reset() {\n        if (pc1) { pc1.close(); pc1 = null; }\n        if (pc2) { pc2.close(); pc2 = null; }\n        dc1 = dc2 = null;\n        aLog.innerHTML = ''; bLog.innerHTML = '';\n        pcState.textContent = 'none';\n      }\n\n      async function createPeers() {\n        reset();\n        pcState.textContent = 'creating';\n        pc1 = new RTCPeerConnection();\n        pc2 = new RTCPeerConnection();\n\n        // local event logging\n        pc1.oniceconnectionstatechange = () => updateState();\n        pc2.oniceconnectionstatechange = () => updateState();\n\n        // Create channel on pc1 (A→B)\n        dc1 = pc1.createDataChannel('channel');\n        dc1.onopen = () => appendLog(aLog, 'DataChannel OPEN (A)');\n        dc1.onclose = () => appendLog(aLog, 'DataChannel CLOSED (A)');\n        dc1.onmessage = (ev) => {\n          const data = ev.data;\n          if (data instanceof ArrayBuffer) appendLog(aLog, 'RECV (binary) ' + (new Uint8Array(data)).length + ' bytes');\n          else appendLog(aLog, 'RECV: ' + data);\n        };\n\n        // pc2: react to incoming channel\n        pc2.ondatachannel = (e) => {\n          dc2 = e.channel;\n          dc2.onopen = () => appendLog(bLog, 'DataChannel OPEN (B)');\n          dc2.onclose = () => appendLog(bLog, 'DataChannel CLOSED (B)');\n          dc2.onmessage = ev => {\n            const data = ev.data;\n            if (data instanceof ArrayBuffer) appendLog(bLog, 'RECV (binary) ' + (new Uint8Array(data)).length + ' bytes');\n            else appendLog(bLog, 'RECV: ' + data);\n          };\n        };\n\n        // Simple ICE candidate exchange local-only:\n        pc1.onicecandidate = e => { if (e.candidate) pc2.addIceCandidate(e.candidate).catch(err => console.warn(err)); };\n        pc2.onicecandidate = e => { if (e.candidate) pc1.addIceCandidate(e.candidate).catch(err => console.warn(err)); };\n\n        // Create offer/answer\n        const offer = await pc1.createOffer();\n        await pc1.setLocalDescription(offer);\n        await pc2.setRemoteDescription(offer);\n        const answer = await pc2.createAnswer();\n        await pc2.setLocalDescription(answer);\n        await pc1.setRemoteDescription(answer);\n\n        updateState();\n      }\n\n      function updateState() {\n        const s1 = pc1 ? pc1.iceConnectionState : 'none';\n        const s2 = pc2 ? pc2.iceConnectionState : 'none';\n        pcState.textContent = 'pc1: ' + s1 + ' | pc2: ' + s2;\n      }\n\n      createBtn.addEventListener('click', createPeers);\n      closeBtn.addEventListener('click', reset);\n\n      aSendBtn.addEventListener('click', () => {\n        if (!dc1 || dc1.readyState !== 'open') return alert('DataChannel not open');\n        dc1.send(aMsg.value);\n        appendLog(aLog, 'SENT: ' + aMsg.value);\n      });\n      bSendBtn.addEventListener('click', () => {\n        if (!dc2 || dc2.readyState !== 'open') return alert('DataChannel not open');\n        dc2.send(bMsg.value);\n        appendLog(bLog, 'SENT: ' + bMsg.value);\n      });\n\n      aBinBtn.addEventListener('click', () => {\n        if (!dc1 || dc1.readyState !== 'open') return alert('DataChannel not open');\n        const arr = new Uint8Array(20);\n        crypto.getRandomValues(arr);\n        dc1.send(arr.buffer);\n        appendLog(aLog, 'SENT (binary) 20 bytes');\n      });\n      bBinBtn.addEventListener('click', () => {\n        if (!dc2 || dc2.readyState !== 'open') return alert('DataChannel not open');\n        const arr = new Uint8Array(12);\n        crypto.getRandomValues(arr);\n        dc2.send(arr.buffer);\n        appendLog(bLog, 'SENT (binary) 12 bytes');\n      });\n    })();\n\n    // ---------- Virtual Socket (length-prefixed fragmentation) ----------\n    (function(){\n      const mtuInput = document.getElementById('mtu');\n      const fragDelayInput = document.getElementById('fragDelay');\n      const vsCreate = document.getElementById('vsCreate');\n      const vsClose = document.getElementById('vsClose');\n      const vsSendBtn = document.getElementById('vsSend');\n      const vsMsgInput = document.getElementById('vsMsg');\n      const vsSendLog = document.getElementById('vsSendLog');\n      const vsRecvLog = document.getElementById('vsRecvLog');\n\n      let running = false;\n      let sender = null, receiver = null;\n\n      // VirtualSocket simulates sending bytes over a \"wire\" that fragments based on MTU and delay.\n      class VirtualSocket {\n        constructor({mtu=16, delay=80, onRecv=null}) {\n          this.mtu = mtu;\n          this.delay = delay;\n          this.onRecv = onRecv;\n          this._readBuffer = new Uint8Array(0); // bytes that have arrived but not yet processed\n        }\n        // sendLogical: will prefix message with 2-byte length, then fragment into MTU-sized chunks,\n        // and deliver fragments asynchronously to the receiver._receiveFragment\n        sendLogical(msg) {\n          // encode message\n          const payload = new TextEncoder().encode(msg);\n          const len = payload.length;\n          // 2-byte big-endian header\n          const header = new Uint8Array(2);\n          header[0] = (len >> 8) & 0xff;\n          header[1] = (len & 0xff);\n          const framed = new Uint8Array(2 + len);\n          framed.set(header, 0);\n          framed.set(payload, 2);\n\n          // fragment the framed bytes\n          const chunks = [];\n          for (let i=0;i<framed.length;i+=this.mtu) {\n            chunks.push(framed.slice(i, i+this.mtu));\n          }\n          // schedule delivery\n          chunks.forEach((chunk, idx) => {\n            const t = idx * this.delay;\n            setTimeout(() => {\n              if (this.onRecv) this.onRecv(chunk);\n            }, t);\n          });\n          return chunks;\n        }\n        // receiver side: add bytes and try to reassemble messages\n        receiveFragment(bytes) {\n          // append\n          const newBuf = new Uint8Array(this._readBuffer.length + bytes.length);\n          newBuf.set(this._readBuffer, 0);\n          newBuf.set(bytes, this._readBuffer.length);\n          this._readBuffer = newBuf;\n          const messages = [];\n          // parse as many complete length-prefixed messages as available\n          while (this._readBuffer.length >= 2) {\n            const view = new DataView(this._readBuffer.buffer, this._readBuffer.byteOffset, this._readBuffer.byteLength);\n            const len = view.getUint16(0);\n            if (this._readBuffer.length >= 2 + len) {\n              const msgBytes = this._readBuffer.slice(2, 2+len);\n              const text = new TextDecoder().decode(msgBytes);\n              messages.push(text);\n              // drop consumed bytes\n              this._readBuffer = this._readBuffer.slice(2+len);\n            } else {\n              // wait for more\n              break;\n            }\n          }\n          return messages;\n        }\n      }\n\n      function create() {\n        const mtu = Number(mtuInput.value) || 16;\n        const delay = Number(fragDelayInput.value) || 80;\n        vsSendLog.innerHTML = ''; vsRecvLog.innerHTML = '';\n        // receiver object\n        receiver = new VirtualSocket({mtu, delay, onRecv: (frag) => {\n          appendLog(vsSendLog, 'FRAG SENT ('+frag.length+' bytes): ' + bytesToHex(frag));\n          // deliver to receiver.receiveFragment after a tiny network delay\n          setTimeout(() => {\n            appendLog(vsRecvLog, 'FRAG RECV ('+frag.length+' bytes): ' + bytesToHex(frag));\n            const msgs = receiver.receiveFragment(frag);\n            msgs.forEach(m => appendLog(vsRecvLog, 'REASSEMBLED MSG: ' + m));\n          }, 10);\n        }});\n        running = true;\n        appendLog(vsSendLog, 'Virtual socket created (MTU=' + mtu + ', delay=' + delay + 'ms)');\n        appendLog(vsRecvLog, 'Receiver ready');\n      }\n\n      function close() {\n        running = false;\n        receiver = null;\n        appendLog(vsSendLog, 'Closed');\n        appendLog(vsRecvLog, 'Closed');\n      }\n\n      vsCreate.addEventListener('click', create);\n      vsClose.addEventListener('click', close);\n\n      vsSendBtn.addEventListener('click', () => {\n        if (!receiver) return alert('Create virtual socket first');\n        const text = vsMsgInput.value;\n        if (!text) return alert('Enter message');\n        const mtu = Number(mtuInput.value) || 16;\n        const delay = Number(fragDelayInput.value) || 80;\n        // Use a temporary sender just to compute chunks; we reuse receiver.onRecv to accept fragments.\n        const senderTmp = new VirtualSocket({mtu, delay, onRecv: (frag) => {\n          // when sender \"sends\" a fragment, we schedule the receiver to get it (onRecv defined in create)\n        }});\n        // But in create() we already configured receiver.onRecv to log and deliver to receiver.receiveFragment.\n        // We'll call receiver.onRecv for each chunk to simulate network send.\n        const chunks = senderTmp.sendLogical(text);\n        // Instead of relying solely on senderTmp.onRecv, call receiver.onRecv per chunk with same timing\n        chunks.forEach((chunk, idx) => {\n          setTimeout(() => {\n            // Simulate sending the fragment through the wire to receiver\n            if (receiver && receiver.onRecv) receiver.onRecv(chunk);\n          }, idx * delay);\n        });\n      });\n\n      function bytesToHex(arr) {\n        return Array.from(new Uint8Array(arr)).map(b => b.toString(16).padStart(2,'0')).join(' ');\n      }\n    })();\n\n  </script>\n</body>\n</html>"
  },
