    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Support Vector Machine</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        .container {\n            width: 50%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .container h1 {\n            margin-top: 0;\n        }\n        .container p {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Support Vector Machine</h1>\n        <p>Imagine a line in the plane that maximizes the margin between the line and the data points.</p>\n        <button id=\"generate-button\">Generate SVM</button>\n        <div id=\"svm-output\"></div>\n    </div>\n\n    <script>\n        const generateButton = document.getElementById('generate-button');\n        const svmOutputDiv = document.getElementById('svm-output');\n\n        generateButton.addEventListener('click', () => {\n            const data = {\n                features: [1, 2, 3, 4, 5],\n                labels: [0, 0, 0, 1, 1]\n            };\n\n            const svm = new SVMModel();\n            svm.train(data);\n\n            const predictions = svm.predict(data.features.map(feature => feature[0]));\n            const output = predictions.map(label => label === 1 ? 'Positive' : 'Negative');\n\n            svmOutputDiv.innerHTML = `\n                <h2>SVM Output:</h2>\n                <p>Positive: ${output.join(', ')}</p>\n            `;\n        });\n    </script>\n</body>\n</html>"
