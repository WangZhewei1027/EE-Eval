    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n            background-color: #f4f4f4;\n        }\n        #array {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 20px;\n        }\n        .element {\n            width: 30px;\n            height: 30px;\n            margin: 0 2px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            background-color: #4CAF50;\n            color: white;\n            border-radius: 5px;\n        }\n        .current {\n            background-color: #ff9800;\n        }\n        .found {\n            background-color: #2196F3;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Binary Search Visualization</h1>\n<p>Enter a sorted array and a target number to find:</p>\n<input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 1,2,3,4,5\" />\n<input type=\"number\" id=\"targetInput\" placeholder=\"Target number\" />\n<button id=\"searchButton\">Search</button>\n\n<div id=\"array\"></div>\n<p id=\"result\"></p>\n\n<script>\n    document.getElementById('searchButton').addEventListener('click', function() {\n        const arrayInput = document.getElementById('arrayInput').value;\n        const targetInput = parseInt(document.getElementById('targetInput').value);\n        const array = arrayInput.split(',').map(num => parseInt(num.trim()));\n\n        displayArray(array);\n        const result = binarySearch(array, targetInput);\n        document.getElementById('result').innerText = result !== -1 ? \n            `Target found at index: ${result}` : \n            'Target not found';\n    });\n\n    function displayArray(array) {\n        const arrayDiv = document.getElementById('array');\n        arrayDiv.innerHTML = ''; // Clear previous array\n        array.forEach((num) => {\n            const element = document.createElement('div');\n            element.className = 'element';\n            element.innerText = num;\n            arrayDiv.appendChild(element);\n        });\n    }\n\n    async function binarySearch(array, target) {\n        let left = 0;\n        let right = array.length - 1;\n\n        while (left <= right) {\n            const mid = Math.floor((left + right) / 2);\n            updateCurrentElement(mid);\n\n            if (array[mid] === target) {\n                markAsFound(mid);\n                return mid;\n            } else if (array[mid] < target) {\n                left = mid + 1;\n            } else {\n                right = mid - 1;\n            }\n\n            await sleep(1000); // Wait before next iteration for visualization\n            resetCurrentElement(mid);\n        }\n        return -1; // Not found\n    }\n\n    function updateCurrentElement(index) {\n        const elements = document.getElementsByClassName('element');\n        if (elements[index]) {\n            elements[index].classList.add('current');\n        }\n    }\n\n    function resetCurrentElement(index) {\n        const elements = document.getElementsByClassName('element');\n        if (elements[index]) {\n            elements[index].classList.remove('current');\n        }\n    }\n\n    function markAsFound(index) {\n        const elements = document.getElementsByClassName('element');\n        if (elements[index]) {\n            elements[index].classList.add('found');\n        }\n    }\n\n    function sleep(ms) {\n        return new Promise(resolve => setTimeout(resolve, ms));\n    }\n</script>\n\n</body>\n</html>"
