    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\"/>\n  <title>B-Tree Interactive Demonstration</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#2dd4bf;\n      --muted:#94a3b8;\n      --card:#071025;\n      --danger:#fb7185;\n      --white:#e6eef8;\n    }\n    html,body{height:100%;margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    body{background:linear-gradient(180deg,var(--bg),#031025);color:var(--white);display:flex;flex-direction:column;align-items:center;padding:18px 12px;box-sizing:border-box;}\n    h1{margin:6px 0 8px;font-size:20px;}\n    .container{width:1100px;max-width:98%;display:grid;grid-template-columns:360px 1fr;gap:16px;}\n    .panel{background:linear-gradient(180deg,var(--panel),#061226);border-radius:12px;padding:14px;box-shadow:0 6px 20px rgba(2,6,23,0.6);border:1px solid rgba(255,255,255,0.03);}\n    .controls h2{font-size:14px;margin:0 0 8px;color:var(--accent)}\n    label{display:block;font-size:13px;color:var(--muted);margin:8px 0 6px}\n    input[type=\"number\"], input[type=\"text\"], select{width:100%;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.06);background:transparent;color:var(--white);box-sizing:border-box}\n    .row{display:flex;gap:8px}\n    button{cursor:pointer;padding:8px 10px;border-radius:8px;border:0;background:linear-gradient(180deg,#0ea5a9,#028f82);color:#022;font-weight:700}\n    button.secondary{background:transparent;border:1px solid rgba(255,255,255,0.06);color:var(--white);font-weight:600}\n    .small{padding:6px 8px;font-size:13px;border-radius:8px}\n    .muted{color:var(--muted);font-size:13px}\n    #canvasWrap{background:linear-gradient(180deg,#021223,#04182a);min-height:520px;overflow:auto;border-radius:10px;padding:8px;}\n    #svgCanvas{width:100%;height:640px;display:block}\n    .log{max-height:160px;overflow:auto;background:linear-gradient(180deg,rgba(255,255,255,0.02),transparent);padding:8px;border-radius:8px;margin-top:8px;font-size:13px;color:var(--muted)}\n    .controls .section{margin-bottom:12px;padding-bottom:10px;border-bottom:1px dashed rgba(255,255,255,0.02)}\n    .kbd{background:#071a1c;padding:6px 8px;border-radius:6px;border:1px solid rgba(255,255,255,0.02);display:inline-block;color:var(--muted);font-size:12px}\n    .footer{color:var(--muted);font-size:12px;margin-top:10px}\n    .legend{display:flex;gap:8px;align-items:center;margin-top:8px}\n    .dot{width:10px;height:10px;border-radius:50%}\n    .dot.focus{background:var(--accent)}\n    .dot.split{background:#f59e0b}\n    .dot.warn{background:var(--danger)}\n    .titleRow{display:flex;justify-content:space-between;align-items:center}\n    .credits{font-size:12px;color:var(--muted)}\n  </style>\n</head>\n<body>\n  <div class=\"titleRow\" style=\"width:1100px;max-width:98%;\">\n    <h1>B-Tree Interactive Demonstration</h1>\n    <div class=\"credits\">Concept: B-Tree (order t). Visual, step-through insertion & search.</div>\n  </div>\n\n  <div class=\"container\">\n    <div class=\"panel controls\">\n      <h2>Controls</h2>\n\n      <div class=\"section\">\n        <label>Degree (t) — Minimum degree of the B-Tree (>=2)</label>\n        <div class=\"row\">\n          <input id=\"degree\" type=\"number\" min=\"2\" value=\"2\"/>\n          <button id=\"applyDegree\" class=\"small secondary\">Apply</button>\n        </div>\n        <div class=\"muted\" style=\"margin-top:8px\">Properties: Each node can have at most 2t−1 keys and at least t−1 keys (except root).</div>\n      </div>\n\n      <div class=\"section\">\n        <label>Insert key(s)</label>\n        <div class=\"row\">\n          <input id=\"insertKeys\" type=\"text\" placeholder=\"e.g. 10,20,15 or single value\"/>\n          <button id=\"insertBtn\" class=\"small\">Insert</button>\n        </div>\n\n        <div style=\"margin-top:8px\">\n          <button id=\"randFill\" class=\"small secondary\">Insert Random (10)</button>\n          <button id=\"clearBtn\" class=\"small secondary\">Clear</button>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <label>Playback & Step</label>\n        <div class=\"row\" style=\"align-items:center\">\n          <button id=\"playBtn\" class=\"small\">Play</button>\n          <button id=\"pauseBtn\" class=\"small secondary\">Pause</button>\n          <button id=\"prevStep\" class=\"small secondary\">Prev</button>\n          <button id=\"nextStep\" class=\"small secondary\">Next</button>\n          <div style=\"flex:1\"></div>\n        </div>\n        <label style=\"margin-top:8px\">Speed</label>\n        <input id=\"speed\" type=\"range\" min=\"100\" max=\"2000\" value=\"800\"/>\n      </div>\n\n      <div class=\"section\">\n        <label>Search key</label>\n        <div class=\"row\">\n          <input id=\"searchKey\" type=\"number\" placeholder=\"value\"/>\n          <button id=\"searchBtn\" class=\"small\">Search</button>\n        </div>\n        <div class=\"muted\" style=\"margin-top:8px\">Search highlights nodes visited during lookup.</div>\n      </div>\n\n      <div class=\"section\">\n        <label>Visualization options</label>\n        <div class=\"row\">\n          <label class=\"muted\" style=\"display:flex;align-items:center;gap:8px\">\n            <input id=\"showIds\" type=\"checkbox\"/> Show node ids\n          </label>\n          <label class=\"muted\" style=\"display:flex;align-items:center;gap:8px\">\n            <input id=\"autoCenter\" type=\"checkbox\" checked/> Auto center canvas\n          </label>\n        </div>\n      </div>\n\n      <div>\n        <div class=\"legend\">\n          <div class=\"dot focus\"></div><div class=\"muted\">current/visited</div>\n          <div class=\"dot split\" style=\"margin-left:8px\"></div><div class=\"muted\">splitting</div>\n          <div class=\"dot warn\" style=\"margin-left:8px\"></div><div class=\"muted\">new root</div>\n        </div>\n        <div class=\"log\" id=\"log\"></div>\n      </div>\n    </div>\n\n    <div class=\"panel\" style=\"display:flex;flex-direction:column;\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px\">\n        <div class=\"muted\">B-Tree Visualization (SVG)</div>\n        <div class=\"muted\">t = <span id=\"curT\">2</span> &nbsp; | &nbsp; keys max = <span id=\"maxKeys\">3</span></div>\n      </div>\n      <div id=\"canvasWrap\">\n        <svg id=\"svgCanvas\" viewBox=\"0 0 1400 700\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n      </div>\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:10px\">\n        <div class=\"muted\">Steps: <span id=\"stepCount\">0</span> &nbsp; | &nbsp; Current: <span id=\"curStep\">0</span></div>\n        <div class=\"muted\">Nodes: <span id=\"nodeCount\">0</span></div>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  B-Tree Interactive Demonstration\n  - Implements B-tree insertion (with splitting) and search.\n  - Records snapshots (states) for step-through visualization.\n  - Single-file: HTML + CSS + JS\n*/\n\n(function(){\n  // Utilities\n  function el(tag, attrs){ const e = document.createElement(tag); if(attrs) Object.assign(e,attrs); return e; }\n  function $(id){ return document.getElementById(id); }\n  function clamp(v,a,b){ return Math.max(a,Math.min(b,v)); }\n  function sleep(ms){ return new Promise(resolve => setTimeout(resolve, ms)); }\n\n  // Unique id generator for nodes\n  let NODE_UID = 1;\n  function nextNodeId(){ return NODE_UID++; }\n\n  // B-Tree Node\n  function BNode(t){\n    this.t = t;\n    this.keys = [];\n    this.children = [];\n    this.leaf = true;\n    this.id = nextNodeId();\n  }\n\n  // B-Tree\n  function BTree(t, recorder){\n    this.t = t;\n    this.root = new BNode(t);\n    this.recorder = recorder || null; // function(snapshotMessage, highlightIds, flag) => record snapshot\n  }\n\n  BTree.prototype.record = function(msg, highlights, flag){\n    if(this.recorder) this.recorder(msg || '', (highlights||[]), flag || {});\n  }\n\n  // Search returns {node, index, pathIds}\n  BTree.prototype.search = function(k){\n    const path = [];\n    function _search(node){\n      path.push(node.id);\n      let i=0;\n      while(i<node.keys.length && k>node.keys[i]) i++;\n      if(i<node.keys.length && k===node.keys[i]){\n        return {node, index:i, path};\n      }\n      if(node.leaf) return {node:null, index:-1, path};\n      return _search(node.children[i]);\n    }\n    return _search(this.root);\n  }\n\n  // Splitting child y = x.children[i]\n  BTree.prototype.splitChild = function(x, i){\n    // x: parent, i: index of child to split\n    const t = this.t;\n    const y = x.children[i];\n    const z = new BNode(t);\n    z.leaf = y.leaf;\n\n    // move t-1 largest keys from y to z\n    z.keys = y.keys.slice(t); // indices t .. end\n    const median = y.keys[t-1];\n    y.keys = y.keys.slice(0, t-1);\n\n    // move children if not leaf\n    if(!y.leaf){\n      z.children = y.children.slice(t); // t .. end\n      y.children = y.children.slice(0, t);\n    }\n\n    // insert z into parent's children\n    x.children.splice(i+1, 0, z);\n    // insert median into parent\n    x.keys.splice(i, 0, median);\n\n    // record step: splitting y into y and z, and inserting median into x\n    this.record(`Splitting node ${y.id}. Promote key ${median} to parent ${x.id}.`, [y.id, z.id, x.id], {split:true, newRoot:(x===this.root && x.keys.length===1)});\n    return;\n  };\n\n  BTree.prototype.insert = function(k){\n    // Disallow duplicates\n    const found = this.search(k);\n    for(const nid of found.path){ } // just to compute path\n    if(found.node && found.index>=0){\n      this.record(`Key ${k} already present in node ${found.node.id}.`, [found.node.id], {});\n      return;\n    }\n    let r = this.root;\n    // if root full, split and make new root\n    if(r.keys.length === 2*this.t -1){\n      const s = new BNode(this.t);\n      s.leaf = false;\n      s.children.push(r);\n      this.root = s;\n      this.record(`Root ${r.id} is full. Create new root ${s.id} and split child.`, [r.id, s.id], {newRoot:true});\n      this.splitChild(s, 0);\n      this._insertNonFull(s, k);\n    } else {\n      this._insertNonFull(r, k);\n    }\n  };\n\n  BTree.prototype._insertNonFull = function(x, k){\n    const t = this.t;\n    if(x.leaf){\n      // Insert into keys in sorted order\n      let i = x.keys.length - 1;\n      while(i>=0 && k < x.keys[i]) i--;\n      x.keys.splice(i+1, 0, k);\n      this.record(`Inserted key ${k} into leaf node ${x.id}.`, [x.id], {});\n    } else {\n      // find child index\n      let i = x.keys.length - 1;\n      while(i>=0 && k < x.keys[i]) i--;\n      i++;\n      // visit child\n      this.record(`Traverse to child ${x.children[i].id} of node ${x.id}.`, [x.id, x.children[i].id], {});\n      if(x.children[i].keys.length === 2*t-1){\n        // split before descent\n        this.record(`Child ${x.children[i].id} is full; split it.`, [x.children[i].id, x.id], {split:true});\n        this.splitChild(x, i);\n        if(k > x.keys[i]) i++;\n      }\n      this._insertNonFull(x.children[i], k);\n    }\n  };\n\n  // Recorder and snapshot management\n  function Recorder(){\n    this.snapshots = [];\n    this.index = 0; // current snapshot index to display\n  }\n  Recorder.prototype.clear = function(){ this.snapshots=[]; this.index=0; };\n  Recorder.prototype.add = function(treeRoot, message, highlights, flag){\n    // deep clone the tree structure starting from root, preserve node ids\n    const cloneMap = new Map();\n    function cloneNode(n){\n      const c = {id:n.id, keys:n.keys.slice(), leaf:n.leaf, children:[]};\n      cloneMap.set(n.id, c);\n      for(const ch of n.children){\n        c.children.push(cloneNode(ch));\n      }\n      return c;\n    }\n    const rootClone = cloneNode(treeRoot);\n    this.snapshots.push({root:rootClone, message:message, highlights: Array.from(highlights||[]), flag: flag||{}});\n  };\n  Recorder.prototype.count = function(){ return this.snapshots.length; };\n  Recorder.prototype.get = function(i){ return this.snapshots[i]; };\n\n  // Visualization: SVG renderer\n  function Renderer(svg){\n    this.svg = svg;\n    this.nodeWBase = 80;\n    this.nodeH = 34;\n    this.hGap = 18;\n    this.vGap = 56;\n    this.showIds = false;\n  }\n\n  Renderer.prototype.render = function(snapshot, options){\n    // snapshot.root is cloned tree\n    const svg = this.svg;\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n    if(!snapshot || !snapshot.root) return;\n\n    this.baseX = 20;\n    this.positions = new Map(); // nodeId -> {x,y,w}\n    this.leafOrderX = 20;\n    this.maxDepth = 0;\n\n    // compute positions\n    const compute = (node, depth) => {\n      this.maxDepth = Math.max(this.maxDepth, depth);\n      let w = Math.max(this.nodeWBase, 24 * Math.max(1, node.keys.length) + 20);\n      if(node.leaf){\n        let x = this.leafOrderX + w/2;\n        this.positions.set(node.id, {x:x, depth:depth, w:w});\n        this.leafOrderX += w + this.hGap;\n        return;\n      } else {\n        // compute children first\n        for(const ch of node.children) compute(ch, depth+1);\n        const first = this.positions.get(node.children[0].id);\n        const last = this.positions.get(node.children[node.children.length-1].id);\n        const x = (first.x + last.x)/2;\n        this.positions.set(node.id, {x:x, depth:depth, w:w});\n      }\n    };\n    compute(snapshot.root, 0);\n\n    // compute SVG width and height\n    const minX = 0;\n    const maxX = Math.max(...Array.from(this.positions.values()).map(p => p.x + p.w/2)) + 20;\n    const width = Math.max(800, maxX + 40);\n    const height = (this.maxDepth+2) * (this.nodeH + this.vGap) + 40;\n    svg.setAttribute('viewBox', `0 0 ${width} ${height}`);\n    svg.setAttribute('width', '100%');\n    svg.setAttribute('height', height);\n\n    // draw edges\n    const parentChildPairs = [];\n    function collectEdges(node){\n      if(!node) return;\n      const ppos = this.positions.get(node.id);\n      for(const ch of node.children){\n        const cpos = this.positions.get(ch.id);\n        parentChildPairs.push({px:ppos.x, py:ppos.depth, cx:cpos.x, cy:cpos.depth});\n        collectEdges.call(this, ch);\n      }\n    }\n    collectEdges.call(this, snapshot.root);\n\n    for(const e of parentChildPairs){\n      const x1 = e.px;\n      const y1 = e.py * (this.nodeH + this.vGap) + 20 + this.nodeH/2;\n      const x2 = e.cx;\n      const y2 = e.cy * (this.nodeH + this.vGap) + 20 - this.nodeH/2;\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1', x1);\n      line.setAttribute('y1', y1);\n      line.setAttribute('x2', x2);\n      line.setAttribute('y2', y2);\n      line.setAttribute('stroke', 'rgba(255,255,255,0.08)');\n      line.setAttribute('stroke-width', '2');\n      svg.appendChild(line);\n    }\n\n    // draw nodes\n    const highlights = new Set(snapshot.highlights||[]);\n    for(const [id, pos] of this.positions){\n      // find node by id in clone tree\n      const node = findNode(snapshot.root, id);\n      const x = pos.x;\n      const y = pos.depth * (this.nodeH + this.vGap) + 20;\n      const w = pos.w;\n      const h = this.nodeH;\n      // container group\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform', `translate(${x - w/2}, ${y - h/2})`);\n      // outer rect\n      const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      rect.setAttribute('x', 0);\n      rect.setAttribute('y', 0);\n      rect.setAttribute('rx', 8);\n      rect.setAttribute('ry', 8);\n      rect.setAttribute('width', w);\n      rect.setAttribute('height', h);\n      rect.setAttribute('fill', '#051423');\n      rect.setAttribute('stroke', 'rgba(255,255,255,0.06)');\n      rect.setAttribute('stroke-width', '1.2');\n      g.appendChild(rect);\n\n      // highlight backgrounds if any\n      if(highlights.has(id)){\n        const bg = document.createElementNS('http://www.w3.org/2000/svg','rect');\n        bg.setAttribute('x', 0);\n        bg.setAttribute('y', 0);\n        bg.setAttribute('width', w);\n        bg.setAttribute('height', h);\n        bg.setAttribute('rx', 8);\n        bg.setAttribute('fill', snapshot.flag && snapshot.flag.newRoot ? '#24313a' : (snapshot.flag && snapshot.flag.split ? '#2f2b10' : '#052f2a'));\n        bg.setAttribute('opacity', 0.7);\n        g.appendChild(bg);\n      }\n\n      // draw key separators and text\n      const kcount = Math.max(1, node.keys.length);\n      const slotW = w / kcount;\n      for(let i=0;i<kcount;i++){\n        const sep = document.createElementNS('http://www.w3.org/2000/svg','line');\n        sep.setAttribute('x1', slotW*i);\n        sep.setAttribute('y1', 0);\n        sep.setAttribute('x2', slotW*i);\n        sep.setAttribute('y2', h);\n        sep.setAttribute('stroke', 'rgba(255,255,255,0.03)');\n        sep.setAttribute('stroke-width', '1');\n        g.appendChild(sep);\n      }\n      // last separator at end\n      const lastSep = document.createElementNS('http://www.w3.org/2000/svg','line');\n      lastSep.setAttribute('x1', w);\n      lastSep.setAttribute('y1', 0);\n      lastSep.setAttribute('x2', w);\n      lastSep.setAttribute('y2', h);\n      lastSep.setAttribute('stroke', 'rgba(255,255,255,0.03)');\n      g.appendChild(lastSep);\n\n      // keys text\n      for(let i=0;i<node.keys.length;i++){\n        const tx = slotW*(i) + slotW/2;\n        const ty = h/2 + 5;\n        const t = document.createElementNS('http://www.w3.org/2000/svg','text');\n        t.setAttribute('x', tx);\n        t.setAttribute('y', ty);\n        t.setAttribute('text-anchor', 'middle');\n        t.setAttribute('font-family', 'Inter,Arial,Helvetica');\n        t.setAttribute('font-size', '14');\n        t.setAttribute('fill', '#ddecf3');\n        t.textContent = node.keys[i];\n        g.appendChild(t);\n      }\n      // show id if option\n      if(this.showIds){\n        const tid = document.createElementNS('http://www.w3.org/2000/svg','text');\n        tid.setAttribute('x', w - 6);\n        tid.setAttribute('y', h - 6);\n        tid.setAttribute('text-anchor', 'end');\n        tid.setAttribute('font-size', '11');\n        tid.setAttribute('fill', '#9fb6c2');\n        tid.textContent = `#${node.id}`;\n        g.appendChild(tid);\n      }\n\n      svg.appendChild(g);\n    }\n\n    // small helper to find node by id in cloned tree\n    function findNode(root, id){\n      const stack = [root];\n      while(stack.length){\n        const n = stack.shift();\n        if(n.id === id) return n;\n        for(const ch of n.children) stack.push(ch);\n      }\n      return null;\n    }\n\n    // message overlay: bottom-left\n    if(snapshot.message){\n      const msg = document.createElementNS('http://www.w3.org/2000/svg','text');\n      msg.setAttribute('x', 12);\n      msg.setAttribute('y', height - 12);\n      msg.setAttribute('font-size', 12);\n      msg.setAttribute('fill', '#9fb6c2');\n      msg.textContent = snapshot.message;\n      svg.appendChild(msg);\n    }\n  };\n\n  // Application state\n  const recorder = new Recorder();\n  let btree = null;\n  let renderer = null;\n  let playing = false;\n  let playTimer = null;\n\n  // UI elements\n  const degreeInput = $('degree');\n  const applyDegree = $('applyDegree');\n  const insertInput = $('insertKeys');\n  const insertBtn = $('insertBtn');\n  const randFill = $('randFill');\n  const clearBtn = $('clearBtn');\n  const playBtn = $('playBtn');\n  const pauseBtn = $('pauseBtn');\n  const prevStep = $('prevStep');\n  const nextStep = $('nextStep');\n  const speedEl = $('speed');\n  const searchKey = $('searchKey');\n  const searchBtn = $('searchBtn');\n  const svgCanvas = $('svgCanvas');\n  const logEl = $('log');\n  const curTEl = $('curT');\n  const maxKeysEl = $('maxKeys');\n  const stepCountEl = $('stepCount');\n  const curStepEl = $('curStep');\n  const nodeCountEl = $('nodeCount');\n  const showIdsEl = $('showIds');\n  const autoCenterEl = $('autoCenter');\n\n  // Initialization\n  function init(){\n    renderer = new Renderer(svgCanvas);\n    createTree(parseInt(degreeInput.value || \"2\"));\n    attachHandlers();\n    renderCurrentSnapshot();\n  }\n\n  function createTree(t){\n    NODE_UID = 1; // reset ids for clarity each time\n    recorder.clear();\n    btree = new BTree(t, function(message, highlights, flag){\n      // push snapshot of current simulated btree root\n      recorder.add(btree.root, message, highlights, flag);\n    });\n    curTEl.textContent = t;\n    maxKeysEl.textContent = (2*t-1);\n    log(`Created B-Tree with t=${t}.`);\n    // record initial snapshot\n    btree.record('Initial empty tree', [], {});\n    updateCounters();\n  }\n\n  function attachHandlers(){\n    applyDegree.addEventListener('click', ()=>{\n      const t = Math.max(2, parseInt(degreeInput.value)||2);\n      degreeInput.value = t;\n      createTree(t);\n      renderCurrentSnapshot();\n    });\n    insertBtn.addEventListener('click', ()=>{\n      const txt = insertInput.value.trim();\n      if(!txt) return;\n      const parts = txt.split(',').map(s=>s.trim()).filter(s=>s!=='');\n      const ints = [];\n      for(const p of parts){\n        const n = Number(p);\n        if(Number.isNaN(n)){ log(`Ignored non-number: ${p}`); continue; }\n        ints.push(n);\n      }\n      if(ints.length===0) return;\n      // For each key, perform insertion and record snapshots for playback\n      for(const k of ints){\n        btree.insert(k);\n      }\n      // push final message\n      btree.record(`Completed inserting ${ints.length} key(s).`, [], {});\n      // go to first new snapshot after last step\n      recorder.index = Math.max(0, recorder.snapshots.length - 1);\n      renderCurrentSnapshot();\n      updateCounters();\n    });\n\n    randFill.addEventListener('click', ()=>{\n      const t = btree.t;\n      const count = 10;\n      const keys = [];\n      for(let i=0;i<count;i++){\n        keys.push(Math.floor(Math.random()*90)+10);\n      }\n      insertInput.value = keys.join(',');\n    });\n\n    clearBtn.addEventListener('click', ()=>{\n      createTree(btree.t);\n      renderCurrentSnapshot();\n    });\n\n    playBtn.addEventListener('click', ()=>{ startPlay(); });\n    pauseBtn.addEventListener('click', ()=>{ stopPlay(); });\n    prevStep.addEventListener('click', ()=>{ stepBackward(); });\n    nextStep.addEventListener('click', ()=>{ stepForward(); });\n\n    searchBtn.addEventListener('click', ()=>{\n      const k = Number(searchKey.value);\n      if(Number.isNaN(k)) return;\n      // create a fresh recorder to store search traversal snapshots\n      const sr = new Recorder();\n      // Use temporary function to record current tree's traversal (no tree mutation)\n      // We'll mimic search and push snapshots showing visited nodes\n      const root = cloneForSearch(btree.root);\n      // Custom traversal that records visitation snapshots\n      function visit(node, path){\n        sr.add(root, `Visiting node ${node.id}`, [node.id], {});\n      }\n      // search algorithm on original tree but recording clone snapshots\n      const pathIds = [];\n      function _searchRecord(node){\n        visit(node);\n        let i=0;\n        while(i<node.keys.length && k>node.keys[i]) i++;\n        if(i<node.keys.length && k===node.keys[i]){\n          sr.add(root, `Found key ${k} in node ${node.id}`, [node.id], {});\n          return true;\n        }\n        if(node.leaf){\n          sr.add(root, `Key ${k} not found (reached leaf ${node.id}).`, [node.id], {});\n          return false;\n        }\n        return _searchRecord(node.children[i]);\n      }\n      _searchRecord(btree.root);\n      // display sr snapshots\n      recorder.snapshots = sr.snapshots;\n      recorder.index = 0;\n      renderCurrentSnapshot();\n      updateCounters();\n    });\n\n    showIdsEl.addEventListener('change', ()=>{\n      renderer.showIds = showIdsEl.checked;\n      renderCurrentSnapshot();\n    });\n  }\n\n  function cloneForSearch(root){\n    // clone structure for overlay so nodes have same ids for highlighting\n    function cloneNode(n){\n      const c = {id:n.id, keys:n.keys.slice(), leaf:n.leaf, children:[]};\n      for(const ch of n.children) c.children.push(cloneNode(ch));\n      return c;\n    }\n    return cloneNode(root);\n  }\n\n  function log(msg){\n    const time = new Date().toLocaleTimeString();\n    logEl.innerHTML = `<div style=\"padding:6px 0;border-bottom:1px dashed rgba(255,255,255,0.02);\"><b style=\"color:var(--accent)\">${time}</b> — ${msg}</div>` + logEl.innerHTML;\n  }\n\n  function renderCurrentSnapshot(){\n    const total = recorder.count();\n    stepCountEl.textContent = total;\n    const idx = clamp(recorder.index, 0, Math.max(0,total-1));\n    curStepEl.textContent = total===0 ? 0 : idx+1;\n    const snapshot = total===0 ? null : recorder.get(idx);\n    renderer.render(snapshot||{root:null, message:''});\n    // update node count\n    const nodeCnt = snapshot && snapshot.root ? countNodes(snapshot.root) : 0;\n    nodeCountEl.textContent = nodeCnt;\n    // auto-scroll or center\n    if(autoCenterEl.checked){\n      // try to center viewport on svgCanvas container\n      const wrap = document.getElementById('canvasWrap');\n      wrap.scrollLeft = Math.max(0, (svgCanvas.viewBox.baseVal.width - wrap.clientWidth)/2);\n    }\n    // also update log area with snapshot message\n    if(snapshot && snapshot.message){\n      log(snapshot.message);\n    }\n  }\n\n  function countNodes(root){\n    if(!root) return 0;\n    let c = 1;\n    for(const ch of root.children) c += countNodes(ch);\n    return c;\n  }\n\n  function startPlay(){\n    if(playing) return;\n    playing = true;\n    log('Playback started.');\n    const delay = () => parseInt(speedEl.value||'800');\n    playTimer = setInterval(()=>{\n      if(recorder.index < recorder.count()-1){\n        recorder.index++;\n        renderCurrentSnapshot();\n      } else {\n        stopPlay();\n      }\n    }, delay());\n  }\n\n  function stopPlay(){\n    if(!playing) return;\n    playing = false;\n    clearInterval(playTimer);\n    playTimer = null;\n    log('Playback paused.');\n  }\n\n  function stepForward(){\n    if(recorder.count()===0) return;\n    recorder.index = clamp(recorder.index+1, 0, recorder.count()-1);\n    renderCurrentSnapshot();\n  }\n\n  function stepBackward(){\n    if(recorder.count()===0) return;\n    recorder.index = clamp(recorder.index-1, 0, recorder.count()-1);\n    renderCurrentSnapshot();\n  }\n\n  // helper to update counters\n  function updateCounters(){\n    stepCountEl.textContent = recorder.count();\n    curStepEl.textContent = recorder.count() ? (recorder.index+1) : 0;\n    nodeCountEl.textContent = countNodes(recorder.count()?recorder.get(recorder.index).root: null);\n  }\n\n  // start\n  init();\n\n  // expose some helpers for debugging in console (optional)\n  window._btree_demo = {btree, recorder, renderer, renderCurrentSnapshot, log};\n\n})();\n</script>\n</body>\n</html>"
