  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>B-Tree Index Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#5eead4;\n      --muted:#94a3b8;\n      --node-bg:#071129;\n      --node-border:#1f2937;\n    }\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,var(--bg),#041226);color:#e6eef8;font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;}\n    .app{\n      display:flex;\n      gap:18px;\n      padding:18px;\n      box-sizing:border-box;\n      height:100%;\n    }\n    .panel{\n      width:360px;\n      max-width:36%;\n      min-width:260px;\n      background:linear-gradient(180deg,var(--panel),#061124);\n      border-radius:12px;\n      padding:14px;\n      box-shadow:0 6px 18px rgba(2,6,23,0.6);\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n    .panel h2{margin:0;font-size:18px;color:var(--accent)}\n    .controls{display:flex;flex-direction:column;gap:10px}\n    .row{display:flex;gap:8px;align-items:center}\n    input[type=\"number\"],input[type=\"text\"],select{\n      background:#061520;border:1px solid #123;outline:none;color:#dff7ef;padding:8px;border-radius:8px;flex:1;\n    }\n    button{\n      background:linear-gradient(180deg,#0ea5a4,#05847f);\n      color:#012020;border:none;padding:8px 10px;border-radius:8px;cursor:pointer;font-weight:600;\n      box-shadow:0 6px 12px rgba(0,0,0,0.4);\n    }\n    button.ghost{background:transparent;border:1px solid #123;color:var(--muted);box-shadow:none;}\n    .small{padding:6px 8px;font-size:13px}\n    .info{font-size:13px;color:var(--muted);line-height:1.35}\n    .log{\n      background:linear-gradient(180deg,#041726,#03121a);\n      padding:8px;border-radius:8px;min-height:120px;overflow:auto;font-family:monospace;font-size:13px;color:#cfece3;border:1px solid rgba(255,255,255,0.02);\n    }\n    .canvas-wrap{\n      flex:1;position:relative;overflow:auto;border-radius:12px;padding:18px;\n      background:linear-gradient(180deg,#071627,#02111b);border:1px solid rgba(255,255,255,0.02);\n    }\n    svg{position:absolute;left:0;top:0;pointer-events:none}\n    .node{\n      position:absolute;\n      display:flex;\n      gap:0;\n      align-items:stretch;\n      height:40px;\n      border-radius:8px;\n      background:linear-gradient(180deg,var(--node-bg),#04122a);\n      border:2px solid var(--node-border);\n      box-sizing:border-box;\n      padding:4px;\n      transition:transform 200ms, box-shadow 200ms;\n      transform-origin:center top;\n      box-shadow:0 6px 14px rgba(2,8,18,0.6);\n      font-weight:700;\n    }\n    .node.leaf{box-shadow:0 10px 28px rgba(4,12,30,0.45)}\n    .key{\n      min-width:28px;\n      height:28px;\n      line-height:28px;\n      text-align:center;\n      background:transparent;\n      color:#c7f9ec;\n      font-size:13px;\n      border-right:1px solid rgba(255,255,255,0.03);\n      padding:0 8px;\n      display:inline-flex;align-items:center;justify-content:center;border-radius:6px;\n    }\n    .key:last-child{border-right:none}\n    .key.highlight{background:linear-gradient(90deg,#63f6d0,#2dd4bf);color:#022;box-shadow:0 4px 12px rgba(45,212,191,0.14)}\n    .node.split {transform:scale(1.06);box-shadow:0 12px 30px rgba(45,212,191,0.12)}\n    .controls .hint{font-size:13px;color:var(--muted)}\n    .footer{display:flex;gap:8px;align-items:center;justify-content:space-between}\n    .kbd{background:#02121a;padding:6px 8px;border-radius:6px;border:1px solid rgba(255,255,255,0.02);font-size:13px;color:var(--muted)}\n    .legend{display:flex;gap:8px;align-items:center;padding-top:6px}\n    .dot{width:12px;height:12px;border-radius:3px}\n    .dot.a{background:#2dd4bf}\n    .dot.b{background:#60a5fa}\n    .dot.c{background:#fbbf24}\n    .controls .small-note{font-size:12px;color:var(--muted)}\n    .topbar{display:flex;gap:8px;align-items:center;justify-content:space-between}\n    .range{display:flex;align-items:center;gap:8px}\n    .range input[type=\"range\"]{width:120px}\n    @media (max-width:880px){\n      .app{flex-direction:column}\n      .panel{width:100%;max-width:none}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <div class=\"panel\">\n      <div class=\"topbar\">\n        <h2>B-Tree Index (interactive)</h2>\n        <div class=\"kbd\">B-Tree (min degree t)</div>\n      </div>\n\n      <div class=\"controls\">\n        <div class=\"row\">\n          <label style=\"min-width:80px;color:var(--muted)\">min degree (t)</label>\n          <div class=\"range\">\n            <input id=\"degree\" type=\"range\" min=\"2\" max=\"5\" value=\"2\"/>\n            <div id=\"degreeVal\" class=\"kbd\">t = 2</div>\n          </div>\n        </div>\n\n        <div class=\"row\">\n          <input id=\"keyInput\" type=\"text\" placeholder=\"Enter key(s) comma separated e.g. 10,5,20\" />\n          <button id=\"insertBtn\" class=\"small\">Insert</button>\n        </div>\n\n        <div class=\"row\">\n          <input id=\"searchInput\" type=\"number\" placeholder=\"Search key\" />\n          <button id=\"searchBtn\" class=\"small ghost\">Search</button>\n          <button id=\"randomBtn\" class=\"small\">Random</button>\n        </div>\n\n        <div class=\"row\">\n          <button id=\"clearBtn\" class=\"small ghost\">Reset</button>\n          <button id=\"autoplayBtn\" class=\"small ghost\">Autoplay demo</button>\n          <div style=\"flex:1\"></div>\n        </div>\n\n        <div class=\"info\">\n          What is demonstrated:\n          <ul style=\"margin:6px 0 0 18px;padding:0;color:var(--muted)\">\n            <li>Insert keys into a B-Tree (min-degree t)</li>\n            <li>Splitting of full nodes (visualized)</li>\n            <li>Search path highlighting</li>\n          </ul>\n        </div>\n\n        <div>\n          <strong>Log (algorithm steps)</strong>\n          <div id=\"log\" class=\"log\" aria-live=\"polite\"></div>\n        </div>\n\n        <div class=\"footer\">\n          <div class=\"small-note\">Tip: try t = 2, insert 1..15 to see many splits</div>\n          <div class=\"legend\">\n            <div style=\"color:var(--muted);font-size:13px\">Highlights:</div>\n            <div class=\"dot a\" title=\"split/active\"></div><div style=\"color:var(--muted);font-size:13px\">split</div>\n            <div class=\"dot b\" title=\"search path\" style=\"margin-left:8px\"></div><div style=\"color:var(--muted);font-size:13px\">search</div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n    <div id=\"canvas\" class=\"canvas-wrap\">\n      <svg id=\"svg\"></svg>\n      <!-- nodes will be appended here -->\n    </div>\n  </div>\n\n<script>\n/*\n  Interactive B-Tree demo\n  - Implements B-Tree insertion (CLRS style) with splitChild.\n  - Visualizes nodes and splitting with logs.\n  - Search highlights path.\n  - Min-degree t adjustable (2..5)\n*/\n\n(() => {\n  // Utility\n  const $ = id => document.getElementById(id);\n  const logEl = $('log');\n  const canvas = $('canvas');\n  const svg = $('svg');\n\n  function log(msg, kind='info'){\n    const d = document.createElement('div');\n    d.textContent = msg;\n    d.style.padding = '2px 0';\n    if(kind==='step') d.style.color = '#c7f3ea';\n    else if(kind==='warn') d.style.color = '#ffd1a3';\n    logEl.prepend(d);\n  }\n  function clearLog(){ logEl.innerHTML=''; }\n\n  // BTree Node class\n  class BNode {\n    constructor(t, leaf=true){\n      this.t = t;\n      this.keys = [];      // array of keys\n      this.children = [];  // array of BNode\n      this.leaf = leaf;\n      this.id = 'n' + Math.random().toString(36).slice(2,9);\n    }\n    isFull(){ return this.keys.length === (2*this.t - 1); }\n  }\n\n  // BTree with min degree t\n  class BTree {\n    constructor(t=2){\n      this.t = t;\n      this.root = new BNode(t,true);\n    }\n\n    search(k){\n      // returns path of nodes visited and index where found or would be inserted\n      const path = [];\n      function _search(node){\n        path.push({node, highlightIndex:null});\n        let i=0;\n        while(i < node.keys.length && k > node.keys[i]) i++;\n        if(i < node.keys.length && k === node.keys[i]){\n          path[path.length-1].highlightIndex = i;\n          return {found:true,node,idx:i,path};\n        } else if(node.leaf){\n          return {found:false,node,idx:i,path};\n        } else {\n          // highlight decision at i\n          path[path.length-1].highlightIndex = i;\n          return _search(node.children[i]);\n        }\n      }\n      return _search(this.root);\n    }\n\n    insert(k, animate=true){\n      if(typeof k !== 'number' || Number.isNaN(k)) return;\n      if(this.root.isFull()){\n        // need to split root\n        const s = new BNode(this.t,false);\n        s.children[0] = this.root;\n        this.root = s;\n        if(animate){\n          return this._splitAndInsert(s,0,k);\n        } else {\n          this._splitChild(s,0);\n          this._insertNonFull(s,k);\n          return Promise.resolve();\n        }\n      } else {\n        if(animate) return this._insertWithAnimation(this.root,k);\n        this._insertNonFull(this.root,k);\n        return Promise.resolve();\n      }\n    }\n\n    _insertNonFull(node,k){\n      let i = node.keys.length - 1;\n      if(node.leaf){\n        // insert into keys[] keeping sorted\n        while(i >= 0 && k < node.keys[i]) i--;\n        node.keys.splice(i+1,0,k);\n      } else {\n        while(i >= 0 && k < node.keys[i]) i--;\n        i++;\n        if(node.children[i].isFull()){\n          this._splitChild(node,i);\n          if(k > node.keys[i]) i++;\n        }\n        this._insertNonFull(node.children[i],k);\n      }\n    }\n\n    _splitChild(x, i){\n      // split full child y = x.children[i]\n      const t = this.t;\n      const y = x.children[i];\n      const z = new BNode(t, y.leaf);\n      // z gets y.keys[t .. 2t-2], y keeps keys[0 .. t-2], median y.keys[t-1] moves up\n      z.keys = y.keys.slice(t); // from index t to end (2t-1 - 1)\n      const median = y.keys[t-1];\n      y.keys = y.keys.slice(0, t-1);\n      if(!y.leaf){\n        z.children = y.children.slice(t);\n        y.children = y.children.slice(0,t);\n      }\n      x.children.splice(i+1,0,z);\n      x.keys.splice(i,0,median);\n    }\n\n    // Animated helpers (promise-based with timeouts)\n    _delay(ms){ return new Promise(r=>setTimeout(r, ms)); }\n\n    async _splitAndInsert(parent, childIndex, k){\n      // Visualize new root and split at childIndex then continue insertion\n      log('Root is full -> creating new root and splitting child', 'step');\n      render(); await this._delay(650);\n\n      // highlight child to split\n      highlightNode(parent.children[childIndex], 'split');\n      log(`Splitting child node (index ${childIndex})`, 'step');\n      await this._delay(600);\n\n      this._splitChild(parent, childIndex);\n      render();\n      // show split result\n      highlightNode(parent, 'split');\n      log('Promoted median to parent; child split into two nodes', 'step');\n      await this._delay(700);\n\n      // now insert non-full\n      await this._insertWithAnimation(parent, k);\n    }\n\n    async _insertWithAnimation(node,k){\n      // recursive animated insertion: emulate CLRS logic with highlighting\n      let current = node;\n      while(true){\n        render();\n        highlightNode(current, 'split'); // active node\n        log(`At node ${current.id} keys=[${current.keys.join(', ')}]`, 'step');\n        await this._delay(550);\n\n        if(current.leaf){\n          // insert into leaf\n          let i = current.keys.length -1;\n          while(i >= 0 && k < current.keys[i]) i--;\n          current.keys.splice(i+1,0,k);\n          render();\n          log(`Inserted key ${k} into leaf`, 'step');\n          highlightKey(current, k);\n          await this._delay(650);\n          clearHighlights();\n          return;\n        } else {\n          // find child index\n          let i=0;\n          while(i < current.keys.length && k > current.keys[i]) i++;\n          log(`Descending to child ${i}`, 'step');\n          // if child is full, split and decide again\n          if(current.children[i].isFull()){\n            highlightNode(current.children[i], 'split');\n            await this._delay(500);\n            log(`Child ${i} is full -> splitting`, 'step');\n            this._splitChild(current, i);\n            render();\n            highlightNode(current, 'split');\n            await this._delay(700);\n            // after split, if k greater than promoted key, go to i+1\n            if(k > current.keys[i]) i++;\n            clearHighlights();\n          }\n          current = current.children[i];\n        }\n      }\n    }\n\n    // helper to build tree from array (uses repeated insert)\n    async insertBulk(arr){\n      for(const v of arr){\n        await this.insert(v, true);\n      }\n    }\n\n  }\n\n  // ---- Visualization state and functions ----\n  let tree = new BTree(2);\n\n  // DOM helpers for rendering nodes\n  const nodeMap = new Map(); // node.id -> div\n  const highlightMap = new Map();\n\n  function clearCanvas(){\n    // remove node elements\n    const nodes = canvas.querySelectorAll('.node');\n    nodes.forEach(n=>n.remove());\n    svg.innerHTML = '';\n    nodeMap.clear();\n  }\n\n  function render(){\n    clearCanvas();\n    // build layout positions\n    const spacingX = 18;\n    const spacingY = 72;\n    const minNodeWidth = 54;\n    const keyWidth = 34;\n\n    function nodeWidth(node){\n      return Math.max(minNodeWidth, node.keys.length * keyWidth + 12);\n    }\n\n    // compute subtree widths to layout children centered\n    function computeWidth(node){\n      if(node.leaf) return nodeWidth(node);\n      let w = 0;\n      for(const c of node.children) w += computeWidth(c) + spacingX;\n      if(w>0) w -= spacingX;\n      return Math.max(w, nodeWidth(node));\n    }\n\n    function place(node, x, y){\n      // returns center x\n      const w = computeWidth(node);\n      if(node.leaf){\n        const nx = x + w/2 - nodeWidth(node)/2;\n        createNodeElement(node, nx, y);\n        return nx + nodeWidth(node)/2;\n      } else {\n        // start children at x\n        let cx = x;\n        const childCenters = [];\n        for(const c of node.children){\n          const cw = computeWidth(c);\n          const center = place(c, cx, y + spacingY);\n          childCenters.push(center);\n          cx += cw + spacingX;\n        }\n        // center this node above its children\n        const center = (childCenters[0] + childCenters[childCenters.length-1]) / 2;\n        const nx = center - nodeWidth(node)/2;\n        createNodeElement(node, nx, y);\n        // draw lines from node to children - deferred\n        for(const c of node.children){\n          drawEdge(node, c);\n        }\n        return center;\n      }\n    }\n\n    // draw tree starting x=20\n    const startX = 20;\n    const startY = 20;\n    place(tree.root, startX, startY);\n\n    // adjust svg size to fit\n    const rects = canvas.querySelectorAll('.node');\n    let maxX = 0, maxY = 0;\n    rects.forEach(el=>{\n      const r = el.getBoundingClientRect();\n      const c = canvas.getBoundingClientRect();\n      const right = el.offsetLeft + el.offsetWidth;\n      const bottom = el.offsetTop + el.offsetHeight;\n      maxX = Math.max(maxX, right);\n      maxY = Math.max(maxY, bottom);\n    });\n    svg.setAttribute('width', Math.max(maxX+40,c.offsetWidth));\n    svg.setAttribute('height', Math.max(maxY+40,c.offsetHeight));\n  }\n\n  function createNodeElement(node, left, top){\n    const div = document.createElement('div');\n    div.className = 'node' + (node.leaf? ' leaf':'');\n    div.style.left = Math.round(left) + 'px';\n    div.style.top = Math.round(top) + 'px';\n    div.dataset.id = node.id;\n    // keys\n    div.innerHTML = '';\n    node.keys.forEach((k,idx)=>{\n      const kdiv = document.createElement('div');\n      kdiv.className = 'key';\n      kdiv.textContent = k;\n      kdiv.dataset.key = k;\n      kdiv.dataset.index = idx;\n      div.appendChild(kdiv);\n    });\n    canvas.appendChild(div);\n    nodeMap.set(node.id, {el:div,node});\n  }\n\n  function drawEdge(parent, child){\n    const p = nodeMap.get(parent.id);\n    const c = nodeMap.get(child.id);\n    if(!p || !c) return;\n    const sx = p.el.offsetLeft + p.el.offsetWidth/2;\n    const sy = p.el.offsetTop + p.el.offsetHeight;\n    const tx = c.el.offsetLeft + c.el.offsetWidth/2;\n    const ty = c.el.offsetTop;\n    const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n    const dx = (tx - sx) * 0.35;\n    const d = `M ${sx} ${sy} C ${sx} ${sy+20} ${sx+dx} ${ty-10} ${tx} ${ty}`;\n    path.setAttribute('d', d);\n    path.setAttribute('stroke','#0ea5a477');\n    path.setAttribute('fill','none');\n    path.setAttribute('stroke-width','2');\n    svg.appendChild(path);\n  }\n\n  function clearHighlights(){\n    for(const {el} of nodeMap.values()){\n      el.classList.remove('split');\n      const keys = el.querySelectorAll('.key');\n      keys.forEach(k=>k.classList.remove('highlight'));\n    }\n  }\n\n  function highlightNode(node, cls){\n    clearHighlights();\n    const entry = nodeMap.get(node.id);\n    if(entry) entry.el.classList.add('split');\n  }\n  function highlightKey(node, key){\n    const entry = nodeMap.get(node.id);\n    if(!entry) return;\n    const keys = entry.el.querySelectorAll('.key');\n    keys.forEach(k=>{\n      if(Number(k.textContent) === key) k.classList.add('highlight');\n    });\n  }\n  function highlightSearchPath(path){\n    clearHighlights();\n    for(const p of path){\n      const entry = nodeMap.get(p.node.id);\n      if(entry){\n        entry.el.classList.add('split');\n        if(p.highlightIndex !== null){\n          const idx = p.highlightIndex;\n          const keyEl = entry.el.querySelector(`.key:nth-child(${idx+1})`);\n          if(keyEl) keyEl.classList.add('highlight');\n        }\n      }\n    }\n  }\n\n  // ---- UI wiring ----\n  const degree = $('degree');\n  const degreeVal = $('degreeVal');\n  degree.addEventListener('input', ()=>{\n    const t = Number(degree.value);\n    degreeVal.textContent = `t = ${t}`;\n  });\n\n  $('insertBtn').addEventListener('click', async ()=>{\n    const raw = $('keyInput').value.trim();\n    if(!raw) return;\n    const parts = raw.split(',').map(s=>s.trim()).filter(Boolean).map(Number);\n    // update degree if changed\n    const t = Number(degree.value);\n    if(t !== tree.t){\n      tree = new BTree(t);\n      clearLog();\n      log(`Reinitialized tree with t=${t}`, 'step');\n    }\n    for(const v of parts){\n      log(`Insert ${v}`);\n      await tree.insert(v, true);\n    }\n    render();\n    $('keyInput').value = '';\n  });\n\n  $('randomBtn').addEventListener('click', async ()=>{\n    const t = Number(degree.value);\n    if(t !== tree.t){\n      tree = new BTree(t);\n      clearLog();\n      log(`Reinitialized tree with t=${t}`, 'step');\n    }\n    // insert random 6 numbers\n    const arr = [];\n    for(let i=0;i<6;i++) arr.push(Math.floor(Math.random()*90)+1);\n    log('Inserting random: ' + arr.join(', '));\n    for(const v of arr){\n      await tree.insert(v, true);\n    }\n    render();\n  });\n\n  $('searchBtn').addEventListener('click', ()=>{\n    const raw = Number($('searchInput').value);\n    if(Number.isNaN(raw)) return;\n    const res = tree.search(raw);\n    log(`Search ${raw} -> ${res.found ? 'FOUND' : 'NOT FOUND'}`, 'step');\n    render();\n    highlightSearchPath(res.path);\n  });\n\n  $('clearBtn').addEventListener('click', ()=>{\n    const t = Number(degree.value);\n    tree = new BTree(t);\n    clearCanvas();\n    clearLog();\n    log(`Tree reset (t=${t})`, 'step');\n    render();\n  });\n\n  // autoplay demo: insert sequence 1..n\n  $('autoplayBtn').addEventListener('click', async ()=>{\n    const t = Number(degree.value);\n    tree = new BTree(t);\n    clearLog();\n    render();\n    log(`Autoplay demo: inserting 1..15 with t=${t}`, 'step');\n    const arr = [];\n    for(let i=1;i<=15;i++) arr.push(i);\n    for(const v of arr){\n      log(`Insert ${v}`);\n      await tree.insert(v, true);\n    }\n    render();\n  });\n\n  // initial render\n  render();\n  log('B-Tree demo ready. Set t and insert keys.', 'step');\n\n  // small accessibility: click node shows its keys in log\n  canvas.addEventListener('click', (e)=>{\n    const nodeEl = e.target.closest('.node');\n    if(!nodeEl) return;\n    const id = nodeEl.dataset.id;\n    const info = nodeMap.get(id);\n    if(info){\n      log(`Node ${id} keys=[${info.node.keys.join(', ')}]`, 'step');\n    }\n  });\n\n  // expose some functions for debugging\n  window._btree_demo = {tree, render, log};\n\n})();\n</script>\n</body>\n</html>"
  },
