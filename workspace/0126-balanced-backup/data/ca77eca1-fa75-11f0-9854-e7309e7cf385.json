    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bucket Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n\n       .bucket {\n            width: 50px;\n            height: 50px;\n            background-color: red;\n            border-radius: 50%;\n        }\n\n        button {\n            margin-top: 20px;\n            padding: 10px 30px;\n            background-color: blue;\n            color: white;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"bucket\"></div>\n\n    <button onclick=\"sortBuckets()\">Sort Buckets</button>\n\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.1/jquery.min.js\"></script>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/bucketsort/4.3.0/dist/bucketsort.min.js\"></script>\n\n    <script>\n        function sortBuckets() {\n            const bucketItems = document.querySelectorAll('.bucket');\n            let bucketIndex = 0;\n\n            while (bucketItems.length > 0) {\n                const currentBucket = bucketItems[bucketIndex];\n                let currentItem = document.querySelector('.item');\n\n                if (currentItem.style.display === 'none') {\n                    bucketItems.splice(bucketIndex, 1);\n                    bucketIndex++;\n                } else {\n                    currentItem.style.display = '';\n                }\n            }\n\n            const sortedItems = [...bucketItems];\n\n            for (let i = 0; i < sortedItems.length; i++) {\n                sortedItems[i].textContent = sortedItems[i].innerHTML;\n            }\n        }\n    </script>\n</body>\n</html>"
