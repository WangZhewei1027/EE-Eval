    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dijkstra's Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        #graph-container {\n            width: 600px;\n            height: 400px;\n            border: 1px solid #ccc;\n            margin: 20px 0;\n            position: relative;\n        }\n        .node {\n            position: absolute;\n            width: 30px;\n            height: 30px;\n            border-radius: 50%;\n            background-color: #4CAF50;\n            color: white;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            cursor: pointer;\n        }\n        .node.start {\n            background-color: #2196F3;\n        }\n        .node.end {\n            background-color: #F44336;\n        }\n        .node.visited {\n            background-color: #FFC107;\n        }\n        .node.path {\n            background-color: #9C27B0;\n        }\n        .edge {\n            position: absolute;\n            height: 2px;\n            background-color: #333;\n            transform-origin: 0 0;\n        }\n        .weight {\n            position: absolute;\n            background-color: white;\n            padding: 2px;\n            font-size: 12px;\n        }\n        .controls {\n            margin-bottom: 20px;\n        }\n        button {\n            padding: 8px 16px;\n            margin: 0 5px;\n            cursor: pointer;\n        }\n        #info-panel {\n            margin-top: 20px;\n            width: 600px;\n            border: 1px solid #ddd;\n            padding: 10px;\n        }\n        table {\n            width: 100%;\n            border-collapse: collapse;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n    </style>\n</head>\n<body>\n    <h1>Dijkstra's Algorithm Visualization</h1>\n    <div class=\"controls\">\n        <button id=\"add-node\">Add Node</button>\n        <button id=\"add-edge\">Add Edge</button>\n        <button id=\"set-start\">Set Start Node</button>\n        <button id=\"set-end\">Set End Node</button>\n        <button id=\"run-algorithm\">Run Dijkstra's</button>\n        <button id=\"reset\">Reset</button>\n    </div>\n    <div id=\"graph-container\"></div>\n    <div id=\"info-panel\">\n        <h3>Algorithm Steps:</h3>\n        <div id=\"steps\"></div>\n        <h3>Distance Table:</h3>\n        <table id=\"distance-table\">\n            <thead>\n                <tr>\n                    <th>Node</th>\n                    <th>Distance</th>\n                    <th>Previous</th>\n                    <th>Visited</th>\n                </tr>\n            </thead>\n            <tbody></tbody>\n        </table>\n    </div>\n\n    <script>\n        // Graph representation\n        const graph = {\n            nodes: [],\n            edges: [],\n            startNode: null,\n            endNode: null,\n            nextNodeId: 1\n        };\n\n        // UI elements\n        const graphContainer = document.getElementById('graph-container');\n        const stepsDiv = document.getElementById('steps');\n        const distanceTable = document.getElementById('distance-table').querySelector('tbody');\n        const addNodeBtn = document.getElementById('add-node');\n        const addEdgeBtn = document.getElementById('add-edge');\n        const setStartBtn = document.getElementById('set-start');\n        const setEndBtn = document.getElementById('set-end');\n        const runAlgorithmBtn = document.getElementById('run-algorithm');\n        const resetBtn = document.getElementById('reset');\n\n        // State variables\n        let mode = 'add-node';\n        let edgeStart = null;\n\n        // Initialize\n        function init() {\n            addNodeBtn.addEventListener('click', () => mode = 'add-node');\n            addEdgeBtn.addEventListener('click', () => mode = 'add-edge');\n            setStartBtn.addEventListener('click', () => mode = 'set-start');\n            setEndBtn.addEventListener('click', () => mode = 'set-end');\n            runAlgorithmBtn.addEventListener('click', runDijkstra);\n            resetBtn.addEventListener('click', resetGraph);\n\n            graphContainer.addEventListener('click', handleGraphClick);\n        }\n\n        // Handle graph clicks\n        function handleGraphClick(e) {\n            if (e.target === graphContainer) {\n                // Clicked on empty space\n                if (mode === 'add-node') {\n                    addNode(e.clientX - graphContainer.getBoundingClientRect().left, \n                            e.clientY - graphContainer.getBoundingClientRect().top);\n                }\n            } else if (e.target.classList.contains('node')) {\n                const nodeId = parseInt(e.target.getAttribute('data-id'));\n                \n                if (mode === 'add-edge') {\n                    if (!edgeStart) {\n                        edgeStart = nodeId;\n                        e.target.classList.add('selected');\n                    } else if (edgeStart !== nodeId) {\n                        const weight = prompt('Enter edge weight:', '1');\n                        if (weight && !isNaN(weight)) {\n                            addEdge(edgeStart, nodeId, parseInt(weight));\n                        }\n                        document.querySelector(`.node[data-id=\"${edgeStart}\"]`).classList.remove('selected');\n                        edgeStart = null;\n                    }\n                } else if (mode === 'set-start') {\n                    if (graph.startNode) {\n                        document.querySelector(`.node[data-id=\"${graph.startNode}\"]`).classList.remove('start');\n                    }\n                    graph.startNode = nodeId;\n                    e.target.classList.add('start');\n                } else if (mode === 'set-end') {\n                    if (graph.endNode) {\n                        document.querySelector(`.node[data-id=\"${graph.endNode}\"]`).classList.remove('end');\n                    }\n                    graph.endNode = nodeId;\n                    e.target.classList.add('end');\n                }\n            }\n        }\n\n        // Add a node to the graph\n        function addNode(x, y) {\n            const nodeId = graph.nextNodeId++;\n            graph.nodes.push({\n                id: nodeId,\n                x: x,\n                y: y\n            });\n\n            const nodeElement = document.createElement('div');\n            nodeElement.className = 'node';\n            nodeElement.setAttribute('data-id', nodeId);\n            nodeElement.style.left = (x - 15) + 'px';\n            nodeElement.style.top = (y - 15) + 'px';\n            nodeElement.textContent = nodeId;\n            graphContainer.appendChild(nodeElement);\n        }\n\n        // Add an edge to the graph\n        function addEdge(from, to, weight) {\n            // Check if edge already exists\n            if (const existingEdge = graph.edges.find(e => \n                (e.from === from && e.to === to) || (e.from === to && e.to === from))) {\n                return;\n            }\n\n            graph.edges.push({\n                from: from,\n                to: to,\n                weight: weight\n            });\n\n            drawEdge(from, to, weight);\n        }\n\n        // Draw an edge on the canvas\n        function drawEdge(from, to, weight) {\n            const fromNode = graph.nodes.find(n => n.id === from);\n            const toNode = graph.nodes.find(n => n.id === to);\n\n            if (!fromNode || !toNode) return;\n\n            const x1 = fromNode.x;\n            const y1 = fromNode.y;\n            const x2 = toNode.x;\n            const y2 = toNode.y;\n\n            // Calculate edge position and angle\n            const length = Math.sqrt(Math.pow(x2 - x1, 2) + Math.pow(y2 - y1, 2));\n            const angle = Math.atan2(y2 - y1, x2 - x1);\n\n            // Create edge element\n            const edgeElement = document.createElement('div');\n            edgeElement.className = 'edge';\n            edgeElement.setAttribute('data-from', from);\n            edgeElement.setAttribute('data-to', to);\n            edgeElement.style.left = x1 + 'px';\n            edgeElement.style.top = y1 + 'px';\n            edgeElement.style.width = length + 'px';\n            edgeElement.style.transform = `rotate(${angle}rad)`;\n\n            // Create weight element\n            const weightElement = document.createElement('div');\n            weightElement.className = 'weight';\n            weightElement.textContent = weight;\n            weightElement.style.left = (x1 + (x2 - x1) / 2 - 10) + 'px';\n            weightElement.style.top = (y1 + (y2 - y1) / 2 - 10) + 'px';\n\n            graphContainer.appendChild(edgeElement);\n            graphContainer.appendChild(weightElement);\n        }\n\n        // Run Dijkstra's algorithm\n        function runDijkstra() {\n            if (!graph.startNode) {\n                alert('Please set a start node');\n                return;\n            }\n\n            // Reset all nodes\n            document.querySelectorAll('.node').forEach(node => {\n                node.classList.remove('visited', 'path');\n            });\n\n            // Initialize distances\n            const distances = {};\n            const previous = {};\n            const visited = new Set();\n            const unvisited = new Set(graph.nodes.map(n => n.id));\n\n            graph.nodes.forEach(node => {\n                distances[node.id] = node.id === graph.startNode ? 0 : Infinity;\n                previous[node.id] = null;\n            });\n\n            stepsDiv.innerHTML = '';\n            updateDistanceTable(distances, previous, visited);\n\n            // Main algorithm loop\n            while (unvisited.size > 0) {\n                // Find node with smallest distance\n                let current = null;\n                let smallestDistance = Infinity;\n\n                for (const nodeId of unvisited) {\n                    if (distances[nodeId] < smallestDistance) {\n                        smallestDistance = distances[nodeId];\n                        current = nodeId;\n                    }\n                }\n\n                if (current === null || smallestDistance === Infinity) {\n                    break; // No more reachable nodes\n                }\n\n                // Mark as visited\n                unvisited.delete(current);\n                visited.add(current);\n                document.querySelector(`.node[data-id=\"${current}\"]`).classList.add('visited');\n\n                // Update neighbors\n                const neighbors = graph.edges.filter(e => e.from === current || e.to === current);\n                for (const edge of neighbors) {\n                    const neighbor = edge.from === current ? edge.to : edge.from;\n                    if (visited.has(neighbor)) continue;\n\n                    const newDistance = distances[current] + edge.weight;\n                    if (newDistance < distances[neighbor]) {\n                        distances[neighbor] = newDistance;\n                        previous[neighbor] = current;\n                    }\n                }\n\n                // Add to steps\n                const step = document.createElement('div');\n                step.textContent = `Visited node ${current}, updated distances to neighbors`;\n                stepsDiv.appendChild(step);\n\n                updateDistanceTable(distances, previous, visited);\n            }\n\n            // Highlight shortest path if end node is set\n            if (graph.endNode && previous[graph.endNode] !== null) {\n                let path = [];\n                let current = graph.endNode;\n                while (current !== null) {\n                    path.unshift(current);\n                    current = previous[current];\n                }\n\n                for (let i = 0; i < path.length; i++) {\n                    document.querySelector(`.node[data-id=\"${path[i]}\"]`).classList.add('path');\n                }\n\n                const pathStr = path.join(' → ');\n                const pathDiv = document.createElement('div');\n                pathDiv.innerHTML = `<strong>Shortest path from ${graph.startNode} to ${graph.endNode}:</strong> ${pathStr} (Distance: ${distances[graph.endNode]})`;\n                stepsDiv.appendChild(pathDiv);\n            }\n        }\n\n        // Update the distance table\n        function updateDistanceTable(distances, previous, visited) {\n            distanceTable.innerHTML = '';\n            graph.nodes.forEach(node => {\n                const row = document.createElement('tr');\n                \n                const idCell = document.createElement('td');\n                idCell.textContent = node.id;\n                row.appendChild(idCell);\n                \n                const distCell = document.createElement('td');\n                distCell.textContent = distances[node.id] === Infinity ? '∞' : distances[node.id];\n                row.appendChild(distCell);\n                \n                const prevCell = document.createElement('td');\n                prevCell.textContent = previous[node.id] || '-';\n                row.appendChild(prevCell);\n                \n                const visitedCell = document.createElement('td');\n                visitedCell.textContent = visited.has(node.id) ? 'Yes' : 'No';\n                row.appendChild(visitedCell);\n                \n                distanceTable.appendChild(row);\n            });\n        }\n\n        // Reset the graph\n        function resetGraph() {\n            graph.nodes = [];\n            graph.edges = [];\n            graph.startNode = null;\n            graph.endNode = null;\n            graph.nextNodeId = 1;\n            graphContainer.innerHTML = '';\n            stepsDiv.innerHTML = '';\n            distanceTable.innerHTML = '';\n            mode = 'add-node';\n            edgeStart = null;\n        }\n\n        // Initialize the app\n        init();\n\n        // Add some sample nodes and edges for demonstration\n        function addSampleGraph() {\n            // Add nodes\n            addNode(100, 100);\n            addNode(300, 100);\n            addNode(100, 300);\n            addNode(300, 300);\n            addNode(500, 200);\n\n            // Add edges\n            addEdge(1, 2, 4);\n            addEdge(1, 3, 2);\n            addEdge(2, 3, 1);\n            addEdge(2, 4, 5);\n            addEdge(3, 4, 8);\n            addEdge(4, 5, 3);\n\n            // Set start and end nodes\n            graph.startNode = 1;\n            graph.endNode = 5;\n            document.querySelector(`.node[data-id=\"1\"]`).classList.add('start');\n            document.querySelector(`.node[data-id=\"5\"]`).classList.add('end');\n        }\n\n        // Uncomment to add sample graph on load\n        // addSampleGraph();\n    </script>\n</body>\n</html>"
  },
