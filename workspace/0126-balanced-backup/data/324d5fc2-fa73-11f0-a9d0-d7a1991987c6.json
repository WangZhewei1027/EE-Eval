    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Counting Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin: 20px;\n        }\n        #arrayDiv {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 20px;\n        }\n        .bar {\n            width: 30px;\n            margin: 1px;\n            background-color: teal;\n            text-align: center;\n            color: white;\n            line-height: 30px;\n        }\n        #output {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Counting Sort Visualization</h1>\n<p>Enter numbers (0-9) separated by commas:</p>\n<input type=\"text\" id=\"inputArray\" value=\"4,2,2,8,3,3,1\">\n<button onclick=\"performCountingSort()\">Sort</button>\n\n<h2>Original Array</h2>\n<div id=\"arrayDiv\"></div>\n\n<h2>Sorted Array</h2>\n<div id=\"output\"></div>\n\n<script>\nfunction displayArray(array, containerId) {\n    const arrayDiv = document.getElementById(containerId);\n    arrayDiv.innerHTML = '';\n    for (let number of array) {\n        const bar = document.createElement('div');\n        bar.className = 'bar';\n        bar.style.height = `${number * 10}px`;\n        bar.textContent = number;\n        arrayDiv.appendChild(bar);\n    }\n}\n\nfunction countingSort(array) {\n    const max = Math.max(...array);\n    const count = new Array(max + 1).fill(0);\n    const output = new Array(array.length);\n\n    // Store the count of each number\n    for (let num of array) {\n        count[num]++;\n    }\n\n    // Change count[i] so that it now contains the actual\n    // position of this number in output[]\n    for (let i = 1; i <= max; i++) {\n        count[i] += count[i - 1];\n    }\n\n    // Build the output array\n    for (let i = array.length - 1; i >= 0; i--) {\n        output[count[array[i]] - 1] = array[i];\n        count[array[i]]--;\n    }\n\n    return output;\n}\n\nfunction performCountingSort() {\n    const input = document.getElementById('inputArray').value;\n    const array = input.split(',').map(Number);\n    \n    // Display original array\n    displayArray(array, 'arrayDiv');\n    \n    // Sort the array\n    const sortedArray = countingSort(array);\n    \n    // Display sorted array\n    displayArray(sortedArray, 'output');\n}\n</script>\n\n</body>\n</html>"
