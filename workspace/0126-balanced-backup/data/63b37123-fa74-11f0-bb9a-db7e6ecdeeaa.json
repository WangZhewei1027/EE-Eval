    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Load Balancing Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1em;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  .server-container {\n    display: flex;\n    justify-content: center;\n    gap: 2em;\n    margin: 1em 0;\n  }\n  .server {\n    background: #fff;\n    border: 2px solid #888;\n    padding: 1em;\n    border-radius: 8px;\n    width: 180px;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.1);\n  }\n  .server h2 {\n    margin-top: 0;\n    text-align: center;\n  }\n  .load {\n    background: #eee;\n    padding: 0.5em;\n    margin-top: 1em;\n    border-radius: 4px;\n  }\n  .requests-log {\n    max-height: 150px;\n    overflow-y: auto;\n    background: #fff;\n    border: 1px solid #ccc;\n    margin-top: 1em;\n    padding: 0.5em;\n    font-size: 0.9em;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n  button {\n    display: block;\n    margin: 1em auto;\n    font-size: 1.2em;\n    padding: 0.5em 1.2em;\n    border-radius: 6px;\n    border: none;\n    cursor: pointer;\n    background: #007bff;\n    color: white;\n    transition: background 0.3s ease;\n  }\n  button:hover:enabled {\n    background: #0056b3;\n  }\n  button:disabled {\n    background: #999;\n    cursor: not-allowed;\n  }\n  .info {\n    max-width: 600px;\n    margin: 0 auto 2em;\n    line-height: 1.5;\n    font-size: 1.1em;\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n  <h1>Load Balancing Demonstration</h1>\n  <div class=\"info\">\n    <p>\n      This demo simulates a <b>Load Balancer</b> distributing incoming requests across multiple backend servers.\n      Click \"Send Request\" multiple times to see how requests get assigned to different servers using the\n      <i>Round Robin</i> algorithm.\n    </p>\n  </div>\n\n  <div class=\"server-container\" id=\"servers\">\n    <!-- Servers will be dynamically created -->\n  </div>\n\n  <button id=\"sendRequestBtn\">Send Request</button>\n\n  <div class=\"requests-log\" id=\"requestsLog\" aria-live=\"polite\" aria-atomic=\"true\" role=\"log\">\n    <strong>Request Log:</strong>\n  </div>\n\n<script>\n(() => {\n  // Number of backend servers\n  const SERVER_COUNT = 3;\n\n  // Server representation\n  class Server {\n    constructor(id) {\n      this.id = id;\n      this.load = 0; // Number of current active requests\n      this.element = null;\n      this.requestsHandled = 0;\n    }\n\n    createElement() {\n      const container = document.createElement('div');\n      container.classList.add('server');\n\n      const title = document.createElement('h2');\n      title.textContent = `Server ${this.id + 1}`;\n      container.appendChild(title);\n\n      this.loadEl = document.createElement('div');\n      this.loadEl.classList.add('load');\n      this.updateLoadDisplay();\n      container.appendChild(this.loadEl);\n\n      this.element = container;\n      return container;\n    }\n\n    updateLoadDisplay() {\n      this.loadEl.textContent = `Active Requests: ${this.load}`;\n    }\n\n    assignRequest(requestId, onComplete) {\n      this.load++;\n      this.requestsHandled++;\n      this.updateLoadDisplay();\n\n      // Simulate request processing time between 1s and 3s\n      const processingTime = 1000 + Math.random() * 2000;\n\n      // Notify assignment\n      logMessage(`Request #${requestId} assigned to Server ${this.id + 1} (processing ~${(processingTime / 1000).toFixed(2)}s)`);\n\n      // Simulate async work\n      setTimeout(() => {\n        this.load--;\n        this.updateLoadDisplay();\n        logMessage(`Request #${requestId} completed on Server ${this.id + 1}`);\n        if (onComplete) onComplete();\n      }, processingTime);\n    }\n  }\n\n  // LoadBalancer implementing Round Robin\n  class LoadBalancer {\n    constructor(servers) {\n      this.servers = servers;\n      this.nextServerIndex = 0;\n    }\n\n    assignRequest(requestId) {\n      // Assign the request to the next server in the list and update index (Round Robin)\n      const server = this.servers[this.nextServerIndex];\n      this.nextServerIndex = (this.nextServerIndex + 1) % this.servers.length;\n      server.assignRequest(requestId);\n    }\n  }\n\n  // UI Elements\n  const serversContainer = document.getElementById('servers');\n  const sendRequestBtn = document.getElementById('sendRequestBtn');\n  const requestsLog = document.getElementById('requestsLog');\n\n  // Instantiate servers\n  const servers = [];\n  for (let i = 0; i < SERVER_COUNT; i++) {\n    const srv = new Server(i);\n    servers.push(srv);\n    serversContainer.appendChild(srv.createElement());\n  }\n\n  // Instantiate load balancer\n  const loadBalancer = new LoadBalancer(servers);\n\n  // Request counter\n  let requestCounter = 0;\n\n  // Log function\n  function logMessage(msg) {\n    const time = new Date().toLocaleTimeString();\n    requestsLog.textContent += `\\n[${time}] ${msg}`;\n    requestsLog.scrollTop = requestsLog.scrollHeight;\n  }\n\n  // Button click handler: send request\n  sendRequestBtn.addEventListener('click', () => {\n    requestCounter++;\n    loadBalancer.assignRequest(requestCounter);\n  });\n\n})();\n</script>\n</body>\n</html>"
