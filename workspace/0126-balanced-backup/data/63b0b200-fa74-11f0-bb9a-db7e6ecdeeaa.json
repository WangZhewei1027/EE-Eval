    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Min Heap Visualization and Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f5f7fa;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 5px;\n  }\n  .container {\n    max-width: 700px;\n    margin: 0 auto;\n    background: #fff;\n    border-radius: 8px;\n    box-shadow: 0 8px 20px rgb(0 0 0 / 0.1);\n    padding: 25px;\n  }\n  .heap-array {\n    margin-top: 1rem;\n    font-family: monospace;\n    font-size: 1.2rem;\n    background: #e1ecfc;\n    padding: 10px 15px;\n    border-radius: 6px;\n    user-select: none;\n  }\n  .controls {\n    display: flex;\n    gap: 15px;\n    margin-top: 15px;\n    flex-wrap: wrap;\n  }\n  .controls > div {\n    flex: 1 1 120px;\n  }\n  input[type=\"number\"] {\n    width: 100%;\n    padding: 8px 10px;\n    font-size: 1rem;\n    border: 2px solid #2980b9;\n    border-radius: 5px;\n  }\n  button {\n    width: 100%;\n    padding: 10px 0;\n    background-color: #2980b9;\n    color: white;\n    border: none;\n    border-radius: 5px;\n    font-weight: 600;\n    cursor: pointer;\n    transition: background-color 0.25s ease;\n  }\n  button:disabled {\n    background-color: #999;\n    cursor: not-allowed;\n  }\n  button:hover:not(:disabled) {\n    background-color: #1c5980;\n  }\n  #message {\n    margin-top: 1rem;\n    min-height: 1.5em;\n    font-weight: 600;\n    color: #2980b9;\n  }\n  .heap-tree {\n    margin-top: 25px;\n    text-align: center;\n  }\n  svg {\n    max-width: 100%;\n    height: 250px;\n  }\n  .node-circle {\n    fill: #2980b9;\n    stroke: #1c5980;\n    stroke-width: 2px;\n  }\n  .node-text {\n    fill: white;\n    font-weight: 600;\n    user-select: none;\n  }\n  .edge-line {\n    stroke: #7f8c8d;\n    stroke-width: 2px;\n  }\n  footer {\n    margin-top: 40px;\n    text-align: center;\n    font-size: 0.9rem;\n    color: #666;\n  }\n  @media (max-width: 480px) {\n    .controls {\n      flex-direction: column;\n    }\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Min Heap (Binary Heap) Demo</h1>\n  <p>A Min Heap maintains the smallest element at the root. Each parent node is less than or equal to its children.</p>\n\n  <div class=\"controls\">\n    <div>\n      <input type=\"number\" id=\"insertValue\" placeholder=\"Value to insert\" />\n      <button id=\"insertBtn\">Insert</button>\n    </div>\n    <div>\n      <button id=\"extractBtn\">Extract Min</button>\n    </div>\n    <div>\n      <button id=\"peekBtn\">Peek Min</button>\n    </div>\n    <div>\n      <button id=\"clearBtn\">Clear Heap</button>\n    </div>\n  </div>\n  <div id=\"message\"></div>\n\n  <h2>Heap Array Representation</h2>\n  <div class=\"heap-array\" id=\"heapArray\">[]</div>\n\n  <h2>Heap Tree Visualization</h2>\n  <div class=\"heap-tree\">\n    <svg id=\"heapSvg\" viewBox=\"0 0 600 250\" aria-label=\"Min Heap Tree\"></svg>\n  </div>\n</div>\n<footer>\n  &copy; 2024 Min Heap Demo\n</footer>\n\n<script>\n  class MinHeap {\n    constructor() {\n      this.heap = [];\n    }\n    size() {\n      return this.heap.length;\n    }\n    insert(value) {\n      this.heap.push(value);\n      this._bubbleUp(this.heap.length - 1);\n    }\n    peek() {\n      if (this.size() === 0) return null;\n      return this.heap[0];\n    }\n    extractMin() {\n      if (this.size() === 0) return null;\n      if (this.size() === 1) return this.heap.pop();\n      const min = this.heap[0];\n      this.heap[0] = this.heap.pop();\n      this._bubbleDown(0);\n      return min;\n    }\n    _bubbleUp(index) {\n      while (index > 0) {\n        const parentIndex = Math.floor((index - 1) / 2);\n        if (this.heap[index] < this.heap[parentIndex]) {\n          [this.heap[index], this.heap[parentIndex]] = [this.heap[parentIndex], this.heap[index]];\n          index = parentIndex;\n        } else {\n          break;\n        }\n      }\n    }\n    _bubbleDown(index) {\n      const size = this.size();\n      while (true) {\n        let smallest = index;\n        const left = 2 * index + 1;\n        const right = 2 * index + 2;\n\n        if (left < size && this.heap[left] < this.heap[smallest]) {\n          smallest = left;\n        }\n        if (right < size && this.heap[right] < this.heap[smallest]) {\n          smallest = right;\n        }\n        if (smallest === index) break;\n        [this.heap[index], this.heap[smallest]] = [this.heap[smallest], this.heap[index]];\n        index = smallest;\n      }\n    }\n    clear() {\n      this.heap = [];\n    }\n  }\n\n  // Visualization code\n  const svgNS = \"http://www.w3.org/2000/svg\";\n\n  function clearSvg(svg) {\n    while (svg.firstChild) {\n      svg.removeChild(svg.firstChild);\n    }\n  }\n\n  // Binary heap tree positions:\n  // We will display nodes in levels with fixed vertical spacing\n  // Horizontally, nodes equally spaced depending on how many can fit at that level\n\n  // Constants for visualization\n  const levelHeight = 70;\n  const nodeRadius = 20;\n  const svgWidth = 600;\n  const svgHeight = 250;\n\n  function drawHeapTree(svg, heap) {\n    clearSvg(svg);\n    if (heap.length === 0) {\n      // Display \"Empty Heap\" text centered\n      const emptyText = document.createElementNS(svgNS, \"text\");\n      emptyText.textContent = \"Heap is empty\";\n      emptyText.setAttribute(\"x\", svgWidth / 2);\n      emptyText.setAttribute(\"y\", svgHeight / 2);\n      emptyText.setAttribute(\"font-size\", \"18\");\n      emptyText.setAttribute(\"fill\", \"#666\");\n      emptyText.setAttribute(\"text-anchor\", \"middle\");\n      emptyText.setAttribute(\"dominant-baseline\", \"middle\");\n      svg.appendChild(emptyText);\n      return;\n    }\n\n    // Compute positions for each node based on heap index\n    // Level order: level of node i is floor(log2(i+1))\n    // Number of nodes at level L is 2^L\n\n    // Precompute positions\n    const positions = [];\n\n    const totalLevels = Math.floor(Math.log2(heap.length)) + 1;\n\n    for (let i = 0; i < heap.length; i++) {\n      const level = Math.floor(Math.log2(i + 1));\n      const indexInLevel = i - (Math.pow(2, level) - 1);\n      const nodesInLevel = Math.pow(2, level);\n\n      const horizontalGap = svgWidth / (nodesInLevel + 1);\n      const x = horizontalGap * (indexInLevel + 1);\n      const y = levelHeight * (level + 1);\n\n      positions.push({ x, y });\n    }\n\n    // Draw edges first (lines from parents to children)\n    for (let i = 0; i < heap.length; i++) {\n      const leftChild = 2 * i + 1;\n      const rightChild = 2 * i + 2;\n      const from = positions[i];\n      if (leftChild < heap.length) {\n        const to = positions[leftChild];\n        const line = document.createElementNS(svgNS, \"line\");\n        line.setAttribute(\"x1\", from.x);\n        line.setAttribute(\"y1\", from.y + nodeRadius);\n        line.setAttribute(\"x2\", to.x);\n        line.setAttribute(\"y2\", to.y - nodeRadius);\n        line.setAttribute(\"class\", \"edge-line\");\n        svg.appendChild(line);\n      }\n      if (rightChild < heap.length) {\n        const to = positions[rightChild];\n        const line = document.createElementNS(svgNS, \"line\");\n        line.setAttribute(\"x1\", from.x);\n        line.setAttribute(\"y1\", from.y + nodeRadius);\n        line.setAttribute(\"x2\", to.x);\n        line.setAttribute(\"y2\", to.y - nodeRadius);\n        line.setAttribute(\"class\", \"edge-line\");\n        svg.appendChild(line);\n      }\n    }\n\n    // Draw nodes (circles + text)\n    for (let i = 0; i < heap.length; i++) {\n      const { x, y } = positions[i];\n      \n      const circle = document.createElementNS(svgNS, \"circle\");\n      circle.setAttribute(\"cx\", x);\n      circle.setAttribute(\"cy\", y);\n      circle.setAttribute(\"r\", nodeRadius);\n      circle.setAttribute(\"class\", \"node-circle\");\n      svg.appendChild(circle);\n\n      const text = document.createElementNS(svgNS, \"text\");\n      text.setAttribute(\"x\", x);\n      text.setAttribute(\"y\", y + 5);\n      text.setAttribute(\"class\", \"node-text\");\n      text.setAttribute(\"text-anchor\", \"middle\");\n      text.textContent = heap[i];\n      svg.appendChild(text);\n    }\n  }\n\n  // DOM elements\n  const heapArrayEl = document.getElementById(\"heapArray\");\n  const insertValueInput = document.getElementById(\"insertValue\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const extractBtn = document.getElementById(\"extractBtn\");\n  const peekBtn = document.getElementById(\"peekBtn\");\n  const clearBtn = document.getElementById(\"clearBtn\");\n  const messageEl = document.getElementById(\"message\");\n  const heapSvg = document.getElementById(\"heapSvg\");\n\n  const heap = new MinHeap();\n\n  function updateDisplay() {\n    heapArrayEl.textContent = `[ ${heap.heap.join(\", \")} ]`;\n    drawHeapTree(heapSvg, heap.heap);\n  }\n\n  function showMessage(text, isError = false) {\n    messageEl.textContent = text;\n    messageEl.style.color = isError ? \"#c0392b\" : \"#2980b9\";\n  }\n\n  insertBtn.addEventListener(\"click\", () => {\n    const val = insertValueInput.value.trim();\n    if (val === \"\") {\n      showMessage(\"Please enter a number to insert\", true);\n      return;\n    }\n    const num = Number(val);\n    if (isNaN(num)) {\n      showMessage(\"Invalid input. Enter a valid number.\", true);\n      return;\n    }\n    heap.insert(num);\n    showMessage(`Inserted value ${num} into the heap.`);\n    insertValueInput.value = \"\";\n    updateDisplay();\n  });\n\n  extractBtn.addEventListener(\"click\", () => {\n    if (heap.size() === 0) {\n      showMessage(\"Heap is empty. Cannot extract min.\", true);\n      return;\n    }\n    const min = heap.extractMin();\n    showMessage(`Extracted minimum value: ${min}`);\n    updateDisplay();\n  });\n\n  peekBtn.addEventListener(\"click\", () => {\n    if (heap.size() === 0) {\n      showMessage(\"Heap is empty.\");\n      return;\n    }\n    const min = heap.peek();\n    showMessage(`Minimum value (peek): ${min}`);\n  });\n\n  clearBtn.addEventListener(\"click\", () => {\n    heap.clear();\n    showMessage(\"Heap cleared.\");\n    updateDisplay();\n  });\n\n  // Initialize display\n  updateDisplay();\n</script>\n</body>\n</html>"
  },
