    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Red-Black Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        \n        .node {\n            width: 50px;\n            height: 50px;\n            border: 1px solid black;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            font-size: 24px;\n        }\n        \n        .node.red {\n            background-color: red;\n        }\n        \n        .node.black {\n            background-color: black;\n        }\n    </style>\n</head>\n<body>\n    <h1>Red-Black Tree</h1>\n    <p id=\"tree\"></p>\n\n    <script>\n        class Node {\n            constructor(value, color = 'red') {\n                this.value = value;\n                this.color = color;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        function insert(root, value) {\n            if (root === null) {\n                return new Node(value, 'black');\n            } else if (value < root.value) {\n                root.left = insert(root.left, value);\n            } else {\n                root.right = insert(root.right, value);\n            }\n            return root;\n        }\n\n        function printTree(root, indent = 0) {\n            if (root !== null) {\n                console.log(' '.repeat(indent) + root.value);\n                printTree(root.left, indent + 2);\n                printTree(root.right, indent + 2);\n            }\n        }\n\n        function redBlackTree(root) {\n            if (root !== null) {\n                root.color = 'black';\n                if (root.left !== null) {\n                    root.left.color = 'red';\n                    redBlackTree(root.left);\n                }\n                if (root.right !== null) {\n                    root.right.color = 'red';\n                    redBlackTree(root.right);\n                }\n            }\n        }\n\n        let root = null;\n\n        // Insert values into the tree\n        root = insert(root, 10);\n        root = insert(root, 5);\n        root = insert(root, 15);\n        root = insert(root, 3);\n        root = insert(root, 7);\n        root = insert(root, 12);\n        root = insert(root, 17);\n\n        // Print the tree\n        printTree(root);\n\n        // Red-Black Tree\n        root = null;\n        root = insert(root, 10);\n        root = insert(root, 5);\n        root = insert(root, 15);\n        root = insert(root, 3);\n        root = insert(root, 7);\n        root = insert(root, 12);\n        root = insert(root, 17);\n\n        // Print the Red-Black Tree\n        printTree(root);\n    </script>\n</body>\n</html>"
