    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linked List</title>\n    <style>\n        /* Style for the list */\n        .linked-list {\n            list-style: none;\n            padding: 0;\n            margin: 0;\n            display: inline-block;\n            width: 100%;\n        }\n        \n        /* Style for each node */\n        .node {\n            padding: 10px;\n            border-bottom: 1px solid #ccc;\n        }\n        \n        /* Style for the last node */\n        .last-node {\n            padding: 10px;\n            border-bottom: 1px solid #ccc;\n            margin-right: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"linked-list\">\n        <div class=\"node\">1</div>\n        <div class=\"last-node\">2</div>\n        <div class=\"node\">3</div>\n        <div class=\"node\">4</div>\n        <div class=\"node\">5</div>\n    </div>\n\n    <script>\n        class Node {\n            constructor(data) {\n                this.data = data;\n                this.next = null;\n            }\n        }\n\n        class LinkedList {\n            constructor() {\n                this.head = null;\n            }\n\n            append(data) {\n                if (!this.head) {\n                    this.head = new Node(data);\n                } else {\n                    let current = this.head;\n                    while (current.next) {\n                        current = current.next;\n                    }\n                    current.next = new Node(data);\n                }\n            }\n\n            display() {\n                let elements = [];\n                let current = this.head;\n                while (current) {\n                    elements.push(current.data);\n                    current = current.next;\n                }\n                return elements;\n            }\n\n            remove(node) {\n                if (node === this.head) {\n                    this.head = node.next;\n                } else {\n                    let current = this.head;\n                    while (current.next) {\n                        if (current.next === node) {\n                            current.next = node.next;\n                            return;\n                        }\n                        current = current.next;\n                    }\n                }\n            }\n        }\n\n        let ll = new LinkedList();\n        ll.append(1);\n        ll.append(2);\n        ll.append(3);\n        ll.append(4);\n        ll.append(5);\n\n        console.log(ll.display()); // Output: [1, 2, 3, 4, 5]\n\n        ll.remove(ll.head.next); // Output: [1, 2, 3, 4]\n\n        console.log(ll.display()); // Output: [1, 2, 3, 4]\n    </script>\n</body>\n</html>"
