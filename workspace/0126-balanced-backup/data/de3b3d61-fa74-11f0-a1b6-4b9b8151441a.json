    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>AVL Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        .controls {\n            margin-bottom: 20px;\n            display: flex;\n            gap: 10px;\n            flex-wrap: wrap;\n            justify-content: center;\n        }\n        input {\n            padding: 8px;\n            width: 60px;\n        }\n        button {\n            padding: 8px 15px;\n            cursor: pointer;\n        }\n        .tree-container {\n            margin-top: 30px;\n        }\n        .node {\n            display: inline-block;\n            width: 40px;\n            height: 40px;\n            border: 2px solid #333;\n            border-radius: 50%;\n            text-align: center;\n            line-height: 40px;\n            margin: 0 10px;\n            background-color: #f0f0f0;\n            position: relative;\n        }\n        .node.highlight {\n            background-color: #ffcc00;\n        }\n        .level {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 30px;\n        }\n        .line {\n            position: absolute;\n            background-color: #333;\n            height: 2px;\n            transform-origin: left center;\n        }\n        .output {\n            margin-top: 20px;\n            padding: 15px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            background-color: #f9f9f9;\n            max-width: 600px;\n            width: 100%;\n        }\n        .operations {\n            margin-top: 20px;\n            display: flex;\n            flex-direction: column;\n            gap: 10px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>AVL Tree Visualization</h1>\n        \n        <div class=\"controls\">\n            <input type=\"number\" id=\"insertValue\" placeholder=\"Value\">\n            <button onclick=\"insertNode()\">Insert</button>\n            <input type=\"number\" id=\"deleteValue\" placeholder=\"Value\">\n            <button onclick=\"deleteNode()\">Delete</button>\n            <input type=\"number\" id=\"searchValue\" placeholder=\"Value\">\n            <button onclick=\"searchNode()\">Search</button>\n            <button onclick=\"clearTree()\">Clear Tree</button>\n        </div>\n        \n        <div class=\"operations\">\n            <button onclick=\"traverseInOrder()\">In-Order Traversal</button>\n            <button onclick=\"traversePreOrder()\">Pre-Order Traversal</button>\n            <button onclick=\"traversePostOrder()\">Post-Order Traversal</button>\n        </div>\n        \n        <div class=\"tree-container\" id=\"tree\"></div>\n        \n        <div class=\"output\" id=\"output\">\n            Operations will be displayed here...\n        </div>\n    </div>\n\n    <script>\n        // AVL Tree Node\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n                this.height = 1;\n            }\n        }\n\n        // AVL Tree class\n        class AVLTree {\n            constructor() {\n                this.root = null;\n            }\n            \n            // Get height of node\n            getHeight(node) {\n                if (!node) return 0;\n                return node.height;\n            }\n            \n            // Update height of node\n            updateHeight(node) {\n                if (!node) return;\n                node.height = Math.max(\n                    this.getHeight(node.left),\n                    this.getHeight(node.right)\n                ) + 1;\n            }\n            \n            // Get balance factor\n            getBalance(node) {\n                if (!node) return 0;\n                return this.getHeight(node.left) - this.getHeight(node.right);\n            }\n            \n            // Right rotation\n            rightRotate(y) {\n                const x = y.left;\n                const T2 = x.right;\n                \n                // Perform rotation\n                x.right = y;\n                y.left = T2;\n                \n                // Update heights\n                this.updateHeight(y);\n                this.updateHeight(x);\n                \n                return x;\n            }\n            \n            // Left rotation\n            leftRotate(x) {\n                const y = x.right;\n                const T2 = y.left;\n                \n                // Perform rotation\n                y.left = x;\n                x.right = T2;\n                \n                // Update heights\n                this.updateHeight(x);\n                this.updateHeight(y);\n                \n                return y;\n            }\n            \n            // Insert a value\n            insert(value) {\n                this.root = this._insert(this.root, value);\n            }\n            \n            _insert(node, value) {\n                // Standard BST insertion\n                if (!node) return new Node(value);\n                \n                if (value < node.value) {\n                    node.left = this._insert(node.left, value);\n                } else if (value > node.value) {\n                    node.right = this._insert(node.right, value);\n                } else {\n                    // Duplicate values not allowed\n                    return node;\n                }\n                \n                // Update height\n                this.updateHeight(node);\n                \n                // Get balance factor\n                const balance = this.getBalance(node);\n                \n                // Perform rotations if needed\n                \n                // Left Left Case\n                if (balance > 1 && value < node.left.value) {\n                    return this.rightRotate(node);\n                }\n                \n                // Right Right Case\n                if (balance < -1 && value > node.right.value) {\n                    return this.leftRotate(node);\n                }\n                \n                // Left Right Case\n                if (balance > 1 && value > node.left.value) {\n                    node.left = this.leftRotate(node.left);\n                    return this.rightRotate(node);\n                }\n                \n                // Right Left Case\n                if (balance < -1 && value < node.right.value) {\n                    node.right = this.rightRotate(node.right);\n                    return this.leftRotate(node);\n                }\n                \n                return node;\n            }\n            \n            // Delete a value\n            delete(value) {\n                this.root = this._delete(this.root, value);\n            }\n            \n            _delete(node, value) {\n                // Standard BST delete\n                if (!node) return node;\n                \n                if (value < node.value) {\n                    node.left = this._delete(node.left, value);\n                } else if (value > node.value) {\n                    node.right = this._delete(node.right, value);\n                } else {\n                    // Node with only one child or no child\n                    if (!node.left || !node.right) {\n                        const temp = node.left || node.right;\n                        \n                        // No child case\n                        if (!temp) {\n                            node = null;\n                        } else {\n                            // One child case\n                            node = temp;\n                        }\n                    } else {\n                        // Node with two children: Get inorder successor\n                        const temp = this.getMinNode(node.right);\n                        node.value = temp.value;\n                        node.right = this._delete(node.right, temp.value);\n                    }\n                }\n                \n                // If the tree had only one node then return\n                if (!node) return node;\n                \n                // Update height\n                this.updateHeight(node);\n                \n                // Get balance factor\n                const balance = this.getBalance(node);\n                \n                // Perform rotations if needed\n                \n                // Left Left Case\n                if (balance > 1 && this.getBalance(node.left) >= 0) {\n                    return this.rightRotate(node);\n                }\n                \n                // Left Right Case\n                if (balance > 1 && this.getBalance(node.left) < 0) {\n                    node.left = this.leftRotate(node.left);\n                    return this.rightRotate(node);\n                }\n                \n                // Right Right Case\n                if (balance < -1 && this.getBalance(node.right) <= 0) {\n                    return this.leftRotate(node);\n                }\n                \n                // Right Left Case\n                if (balance < -1 && this.getBalance(node.right) > 0) {\n                    node.right = this.rightRotate(node.right);\n                    return this.leftRotate(node);\n                }\n                \n                return node;\n            }\n            \n            // Search for a value\n            search(value) {\n                return this._search(this.root, value);\n            }\n            \n            _search(node, value) {\n                if (!node) return null;\n                if (node.value === value) return node;\n                if (value < node.value) return this._search(node.left, value);\n                return this._search(node.right, value);\n            }\n            \n            // Get node with minimum value\n            getMinNode(node) {\n                let current = node;\n                while (current.left) {\n                    current = current.left;\n                }\n                return current;\n            }\n            \n            // In-order traversal\n            inOrder() {\n                const result = [];\n                this._inOrder(this.root, result);\n                return result;\n            }\n            \n            _inOrder(node, result) {\n                if (node) {\n                    this._inOrder(node.left, result);\n                    result.push(node.value);\n                    this._inOrder(node.right, result);\n                }\n            }\n            \n            // Pre-order traversal\n            preOrder() {\n                const result = [];\n                this._preOrder(this.root, result);\n                return result;\n            }\n            \n            _preOrder(node, result) {\n                if (node) {\n                    result.push(node.value);\n                    this._preOrder(node.left, result);\n                    this._preOrder(node.right, result);\n                }\n            }\n            \n            // Post-order traversal\n            postOrder() {\n                const result = [];\n                this._postOrder(this.root, result);\n                return result;\n            }\n            \n            _postOrder(node, result) {\n                if (node) {\n                    this._postOrder(node.left, result);\n                    this._postOrder(node.right, result);\n                    result.push(node.value);\n                }\n            }\n        }\n\n        // Global AVL Tree instance\n        const avlTree = new AVLTree();\n\n        // DOM manipulation functions\n        function renderTree() {\n            const treeContainer = document.getElementById('tree');\n            treeContainer.innerHTML = '';\n            \n            if (!avlTree.root) {\n                return;\n            }\n            \n            // Calculate tree levels\n            const levels = [];\n            const queue = [{ node: avlTree.root, level: 0 }];\n            \n            while (queue.length) {\n                const { node, level } = queue.shift();\n                \n                if (!levels[level]) {\n                    levels[level] = [];\n                }\n                \n                levels[level].push(node);\n                \n                if (node.left) {\n                    queue.push({ node: node.left, level: level + 1 });\n                } else if (level < 10) { // Limit depth for visualization\n                    // Push null for empty left child\n                    levels[level + 1] = levels[level + 1] || [];\n                    levels[level + 1].push(null);\n                }\n                \n                if (node.right) {\n                    queue.push({ node: node.right, level: level + 1 });\n                } else if (level < 10) { // Limit depth for visualization\n                    // Push null for empty right child\n                    levels[level + 1] = levels[level + 1] || [];\n                    levels[level + 1].push(null);\n                }\n            }\n            \n            // Render each level\n            for (let i = 0; i < levels.length; i++) {\n                const levelDiv = document.createElement('div');\n                levelDiv.className = 'level';\n                \n                for (let j = 0; j < levels[i].length; j++) {\n                    const node = levels[i][j];\n                    \n                    if (node) {\n                        const nodeDiv = document.createElement('div');\n                        nodeDiv.className = 'node';\n                        nodeDiv.textContent = node.value;\n                        nodeDiv.dataset.value = node.value;\n                        \n                        // Add height info\n                        nodeDiv.title = `Height: ${node.height}`;\n                        \n                        levelDiv.appendChild(nodeDiv);\n                        \n                        // Add lines to children if they exist\n                        const nextLevel = levels[i + 1];\n                        if (nextLevel) {\n                            const leftChild = nextLevel[j * 2];\n                            const rightChild = nextLevel[j * 2 + 1];\n                            \n                            if (leftChild) {\n                                addLine(nodeDiv, leftChild, 'left');\n                            }\n                            \n                            if (rightChild) {\n                                addLine(nodeDiv, rightChild, 'right');\n                            }\n                        }\n                    } else {\n                        // Empty space for null nodes\n                        const emptyDiv = document.createElement('div');\n                        emptyDiv.style.width = '40px';\n                        emptyDiv.style.height = '40px';\n                        emptyDiv.style.margin = '0 10px';\n                        levelDiv.appendChild(emptyDiv);\n                    }\n                }\n                \n                treeContainer.appendChild(levelDiv);\n            }\n        }\n\n        function addLine(parentNode, childNode, direction) {\n            const line = document.createElement('div');\n            line.className = 'line';\n            \n            const parentRect = parentNode.getBoundingClientRect();\n            const parentX = parentRect.left + parentRect.width / 2;\n            const parentY = parentRect.top + parentRect.height;\n            \n            const childRect = childNode.getBoundingClientRect();\n            const childX = childRect.left + childRect.width / 2;\n            const childY = childRect.top;\n            \n            const length = Math.sqrt(Math.pow(childX - parentX, 2) + Math.pow(childY - parentY, 2));\n            const angle = Math.atan2(childY - parentY, childX - parentX) * 180 / Math.PI;\n            \n            line.style.width = `${length}px`;\n            line.style.transform = `rotate(${angle}deg)`;\n            line.style.left = `${parentRect.width / 2}px`;\n            line.style.top = `${parentRect.height}px`;\n            \n            parentNode.appendChild(line);\n            \n            // Recalculate position after DOM update\n            setTimeout(() => {\n                const parentRect = parentNode.getBoundingClientRect();\n                const parentX = parentRect.left + parentRect.width / 2;\n                const parentY = parentRect.top + parentRect.height;\n                \n                const childRect = childNode.getBoundingClientRect();\n                const childX = childRect.left + childRect.width / 2;\n                const childY = childRect.top;\n                \n                const length = Math.sqrt(Math.pow(childX - parentX, 2) + Math.pow(childY - parentY, 2));\n                const angle = Math.atan2(childY - parentY, childX - parentX) * 180 / Math.PI;\n                \n                line.style.width = `${length}px`;\n                line.style.transform = `rotate(${angle}deg)`;\n            }, 0);\n        }\n\n        function logOperation(message) {\n            const output = document.getElementById('output');\n            output.textContent = message;\n        }\n\n        // Button handlers\n        function insertNode() {\n            const value = parseInt(document.getElementById('insertValue').value);\n            if (isNaN(value)) {\n                logOperation('Please enter a valid number to insert.');\n                return;\n            }\n            \n            avlTree.insert(value);\n            renderTree();\n            logOperation(`Inserted value: ${value}`);\n            \n            document.getElementById('insertValue').value = '';\n        }\n\n        function deleteNode() {\n            const value = parseInt(document.getElementById('deleteValue').value);\n            if (isNaN(value)) {\n                logOperation('Please enter a valid number to delete.');\n                return;\n            }\n            \n            const node = avlTree.search(value);\n            if (!node) {\n                logOperation(`Value ${value} not found in the tree.`);\n                return;\n            }\n            \n            avlTree.delete(value);\n            renderTree();\n            logOperation(`Deleted value: ${value}`);\n            \n            document.getElementById('deleteValue').value = '';\n        }\n\n        function searchNode() {\n            const value = parseInt(document.getElementById('searchValue').value);\n            if (isNaN(value)) {\n                logOperation('Please enter a valid number to search.');\n                return;\n            }\n            \n            const node = avlTree.search(value);\n            if (node) {\n                // Highlight the found node\n                const nodes = document.querySelectorAll('.node');\n                nodes.forEach(n => {\n                    n.classList.remove('highlight');\n                    if (parseInt(n.dataset.value) === value) {\n                        n.classList.add('highlight');\n                    }\n                });\n                \n                logOperation(`Found value: ${value}`);\n            } else {\n                logOperation(`Value ${value} not found in the tree.`);\n            }\n            \n            document.getElementById('searchValue').value = '';\n        }\n\n        function clearTree() {\n            avlTree.root = null;\n            renderTree();\n            logOperation('Tree cleared.');\n        }\n\n        function traverseInOrder() {\n            const result = avlTree.inOrder();\n            logOperation(`In-Order Traversal: ${result.join(', ')}`);\n        }\n\n        function traversePreOrder() {\n            const result = avlTree.preOrder();\n            logOperation(`Pre-Order Traversal: ${result.join(', ')}`);\n        }\n\n        function traversePostOrder() {\n            const result = avlTree.postOrder();\n            logOperation(`Post-Order Traversal: ${result.join(', ')}`);\n        }\n\n        // Initial render\n        renderTree();\n        logOperation('AVL Tree visualization ready. Insert values to build the tree.');\n    </script>\n</body>\n</html>"
