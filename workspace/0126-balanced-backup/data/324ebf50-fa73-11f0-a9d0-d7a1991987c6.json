    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deadlock Simulation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin-top: 50px;\n        }\n        .status {\n            margin-top: 20px;\n            font-weight: bold;\n            color: red;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Deadlock Simulation</h1>\n<button id=\"start\">Start Simulation</button>\n<div class=\"status\" id=\"status\"></div>\n\n<script>\n    let resourceA = false;\n    let resourceB = false;\n\n    function process1() {\n        // Process 1 tries to acquire resource A\n        console.log('Process 1: Requesting Resource A...');\n        resourceA = true;\n        console.log('Process 1: Acquired Resource A.');\n\n        // Simulating some operation with Resource A before requesting Resource B\n        setTimeout(() => {\n            console.log('Process 1: Requesting Resource B...');\n            if (resourceB) {\n                console.log('Process 1: Waiting for Resource B...');\n                document.getElementById('status').innerText = 'Deadlock: Process 1 is waiting for Resource B.';\n            } else {\n                resourceB = true;\n                console.log('Process 1: Acquired Resource B.');\n                document.getElementById('status').innerText = 'Process 1: Acquired Resource B and completed.';\n            }\n        }, 1000);\n    }\n\n    function process2() {\n        // Process 2 tries to acquire resource B\n        console.log('Process 2: Requesting Resource B...');\n        resourceB = true;\n        console.log('Process 2: Acquired Resource B.');\n\n        // Simulating some operation with Resource B before requesting Resource A\n        setTimeout(() => {\n            console.log('Process 2: Requesting Resource A...');\n            if (resource