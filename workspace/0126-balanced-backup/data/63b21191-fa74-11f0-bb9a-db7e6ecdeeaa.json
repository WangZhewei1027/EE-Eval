    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Backtracking Demo: N-Queens Problem</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f0f0;\n  }\n  h1 {\n    text-align: center;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 20px;\n  }\n  input[type=number] {\n    width: 50px;\n    font-size: 16px;\n    text-align: center;\n  }\n  button {\n    font-size: 16px;\n    padding: 5px 12px;\n    margin-left: 10px;\n    cursor: pointer;\n  }\n  #board {\n    margin: 0 auto;\n    width: fit-content;\n    border: 2px solid #333;\n    background: #fff;\n  }\n  .row {\n    display: flex;\n  }\n  .cell {\n    width: 40px;\n    height: 40px;\n    border: 1px solid #aaa;\n    box-sizing: border-box;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 32px;\n    user-select: none;\n    font-weight: bold;\n  }\n  .cell.black {\n    background: #769656;\n  }\n  .cell.white {\n    background: #eeeed2;\n  }\n  #log {\n    max-width: 600px;\n    margin: 20px auto 0 auto;\n    background: #272822;\n    color: #f8f8f2;\n    padding: 10px;\n    font-family: monospace;\n    font-size: 14px;\n    height: 180px;\n    overflow-y: auto;\n    border-radius: 5px;\n    white-space: pre-wrap;\n  }\n  #status {\n    text-align: center;\n    margin-top: 15px;\n    font-weight: bold;\n  }\n  a {\n    color: #0066cc;\n  }\n</style>\n</head>\n<body>\n<h1>Backtracking Visualization: N-Queens Problem</h1>\n<div id=\"controls\">\n  <label for=\"nSize\">Board size (N): </label>\n  <input type=\"number\" id=\"nSize\" min=\"4\" max=\"12\" value=\"8\" />\n  <button id=\"startBtn\">Start Backtracking</button>\n  <button id=\"nextStepBtn\" disabled>Next Step</button>\n  <button id=\"autoRunBtn\" disabled>Auto Run</button>\n  <button id=\"resetBtn\">Reset</button>\n</div>\n<div id=\"board\"></div>\n<div id=\"status\"></div>\n<div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n<script>\n(() => {\n  const boardEl = document.getElementById('board');\n  const nInput = document.getElementById('nSize');\n  const startBtn = document.getElementById('startBtn');\n  const nextStepBtn = document.getElementById('nextStepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const autoRunBtn = document.getElementById('autoRunBtn');\n  const statusEl = document.getElementById('status');\n  const logEl = document.getElementById('log');\n\n  let N = 8;\n  let board = [];\n  let solutionsCount = 0;\n  let currentRow = 0;\n  let running = false;\n  let autoRunInterval = null;\n\n  // Backtracking state holding variable\n  // We'll create a generator function for backtracking, so we can \"step\" through it.\n\n  function createBoard(n) {\n    boardEl.innerHTML = '';\n    boardEl.style.gridTemplateColumns = `repeat(${n}, 40px)`;\n    boardEl.style.width = `${n * 40}px`;\n\n    for (let r = 0; r < n; r++) {\n      const row = document.createElement('div');\n      row.classList.add('row');\n      for (let c = 0; c < n; c++) {\n        const cell = document.createElement('div');\n        cell.classList.add('cell');\n        // color cells like chess board\n        if ((r + c) % 2 === 1) {\n          cell.classList.add('black');\n        } else {\n          cell.classList.add('white');\n        }\n        cell.id = `cell-${r}-${c}`;\n        row.appendChild(cell);\n      }\n      boardEl.appendChild(row);\n    }\n  }\n\n  // Update UI board from board array\n  function updateBoardUI(boardArray) {\n    const n = boardArray.length;\n    for (let r = 0; r < n; r++) {\n      for (let c = 0; c < n; c++) {\n        const cell = document.getElementById(`cell-${r}-${c}`);\n        if (boardArray[r] === c) {\n          cell.textContent = \"♛\"; // Queen Unicode symbol\n          cell.style.color = '#d22';\n        } else {\n          cell.textContent = '';\n        }\n      }\n    }\n  }\n\n  // Check if queen placement is safe\n  function isSafe(board, row, col) {\n    for (let i = 0; i < row; i++) {\n      if (\n        board[i] === col || // same column\n        board[i] - i === col - row || // same diagonal \\\n        board[i] + i === col + row // same diagonal /\n      ) {\n        return false;\n      }\n    }\n    return true;\n  }\n\n  // Generator for backtracking - yields after placing each queen and after each backtrack\n  function* solveNQueens(n) {\n    let board = new Array(n).fill(-1);\n\n    function* backtrack(row) {\n      if (row === n) {\n        // Found a solution\n        yield { type: 'solution', board: [...board] };\n        return;\n      }\n      for (let col = 0; col < n; col++) {\n        yield { type: 'try', row, col };\n        if (isSafe(board, row, col)) {\n          board[row] = col;\n          yield { type: 'place', row, col, board: [...board] };\n          yield* backtrack(row + 1);\n          board[row] = -1; // backtrack\n          yield { type: 'remove', row, col };\n        } else {\n          yield { type: 'fail', row, col };\n        }\n      }\n    }\n    yield* backtrack(0);\n  }\n\n  function logMessage(msg) {\n    logEl.textContent += msg + '\\n';\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  let solverGen = null;\n\n  function reset() {\n    N = parseInt(nInput.value, 10);\n    if (isNaN(N) || N < 4 || N > 12) {\n      alert('Please enter a number between 4 and 12');\n      N = 8;\n      nInput.value = 8;\n    }\n    board = new Array(N).fill(-1);\n    createBoard(N);\n    updateBoardUI(board);\n    solutionsCount = 0;\n    currentRow = 0;\n    running = false;\n    solverGen = null;\n    statusEl.textContent = '';\n    logEl.textContent = '';\n    nextStepBtn.disabled = true;\n    autoRunBtn.disabled = true;\n    startBtn.disabled = false;\n    if (autoRunInterval) {\n      clearInterval(autoRunInterval);\n      autoRunInterval = null;\n      autoRunBtn.textContent = 'Auto Run';\n    }\n  }\n\n  function onStep() {\n    if (!solverGen) return;\n    const res = solverGen.next();\n    if (res.done) {\n      statusEl.textContent = `All solutions found: ${solutionsCount}`;\n      nextStepBtn.disabled = true;\n      autoRunBtn.disabled = true;\n      startBtn.disabled = false;\n      running = false;\n      if (autoRunInterval) {\n        clearInterval(autoRunInterval);\n        autoRunInterval = null;\n        autoRunBtn.textContent = 'Auto Run';\n      }\n      return;\n    }\n    const val = res.value;\n    if (!val) return;\n\n    switch (val.type) {\n      case 'try':\n        statusEl.textContent = `Trying to place queen at row ${val.row + 1}, col ${val.col + 1}...`;\n        logMessage(`Trying (r${val.row + 1}, c${val.col + 1})`);\n        break;\n      case 'fail':\n        logMessage(`Conflict detected at (r${val.row + 1}, c${val.col + 1}), cannot place queen.`);\n        break;\n      case 'place':\n        board[val.row] = val.col;\n        updateBoardUI(board);\n        statusEl.textContent = `Placed queen at row ${val.row + 1}, col ${val.col + 1}.`;\n        logMessage(`Placed queen at (r${val.row + 1}, c${val.col + 1})`);\n        break;\n      case 'remove':\n        board[val.row] = -1;\n        updateBoardUI(board);\n        statusEl.textContent = `Backtracking from row ${val.row + 1}, removed queen from col ${val.col + 1}.`;\n        logMessage(`Removing queen at (r${val.row + 1}, c${val.col + 1}) - backtrack`);\n        break;\n      case 'solution':\n        solutionsCount++;\n        updateBoardUI(val.board);\n        statusEl.textContent = `Solution #${solutionsCount} found!`;\n        logMessage(`=== Solution #${solutionsCount} ===`);\n        break;\n    }\n  }\n\n  function onAutoRun() {\n    if (!solverGen) return;\n    if (autoRunInterval) {\n      clearInterval(autoRunInterval);\n      autoRunInterval = null;\n      autoRunBtn.textContent = 'Auto Run';\n      nextStepBtn.disabled = false;\n      startBtn.disabled = false;\n    } else {\n      autoRunBtn.textContent = 'Pause';\n      nextStepBtn.disabled = true;\n      startBtn.disabled = true;\n      autoRunInterval = setInterval(() => {\n        onStep();\n        if (!running) {\n          clearInterval(autoRunInterval);\n          autoRunInterval = null;\n          autoRunBtn.textContent = 'Auto Run';\n          nextStepBtn.disabled = true;\n          startBtn.disabled = false;\n        }\n      }, 150);\n    }\n  }\n\n  startBtn.addEventListener('click', () => {\n    reset();\n    running = true;\n    solverGen = solveNQueens(N);\n    logMessage(`Starting backtracking for N=${N}...`);\n    nextStepBtn.disabled = false;\n    autoRunBtn.disabled = false;\n    startBtn.disabled = true;\n    onStep(); // Start with first step immediately\n  });\n\n  nextStepBtn.addEventListener('click', () => {\n    if (!running) return;\n    onStep();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    reset();\n  });\n\n  autoRunBtn.addEventListener('click', () => {\n    if (!running) return;\n    onAutoRun();\n  });\n\n  // Initialize on load\n  reset();\n})();\n</script>\n</body>\n</html>"
  },
