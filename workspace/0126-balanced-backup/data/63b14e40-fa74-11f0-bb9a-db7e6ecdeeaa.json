    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Linear Search Demonstration</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2rem;\n      background: #f9f9f9;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n      color: #2c3e50;\n    }\n    .container {\n      max-width: 600px;\n      margin: 0 auto;\n      background: #fff;\n      padding: 1.5rem;\n      border-radius: 8px;\n      box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n    }\n    label {\n      display: block;\n      margin-bottom: 0.3rem;\n      font-weight: bold;\n    }\n    input[type=\"text\"], input[type=\"number\"] {\n      width: 100%;\n      padding: 0.4rem;\n      margin-bottom: 1rem;\n      border: 1px solid #ccc;\n      border-radius: 4px;\n      font-size: 1rem;\n    }\n    button {\n      display: block;\n      width: 100%;\n      background: #2980b9;\n      color: #fff;\n      border: none;\n      padding: 0.6rem;\n      font-size: 1.1rem;\n      border-radius: 4px;\n      cursor: pointer;\n    }\n    button:hover {\n      background: #1f6391;\n    }\n    .output {\n      margin-top: 1.5rem;\n      font-size: 1.1rem;\n      min-height: 2.5rem;\n    }\n    .array-display {\n      font-family: monospace;\n      padding: 0.5rem;\n      background: #ecf0f1;\n      border-radius: 4px;\n      margin-bottom: 1rem;\n      word-wrap: break-word;\n    }\n    .step {\n      margin-top: 0.8rem;\n      font-family: monospace;\n      background: #dff0d8;\n      border-left: 5px solid #3c763d;\n      padding: 0.4rem 0.8rem;\n      border-radius: 3px;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Linear Search Algorithm Demo</h1>\n    <label for=\"arrayInput\">Enter elements (comma separated):</label>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 4, 2, 7, 1, 3\" value=\"4, 2, 7, 1, 3, 9, 8\" />\n    <label for=\"targetInput\">Enter target value to search:</label>\n    <input type=\"number\" id=\"targetInput\" placeholder=\"e.g. 7\" />\n    <button id=\"searchBtn\">Perform Linear Search</button>\n    <div class=\"output\" id=\"output\"></div>\n  </div>\n\n  <script>\n    const arrayInput = document.getElementById('arrayInput');\n    const targetInput = document.getElementById('targetInput');\n    const searchBtn = document.getElementById('searchBtn');\n    const output = document.getElementById('output');\n\n    // Utility to clear output area\n    function clearOutput() {\n      output.innerHTML = '';\n    }\n\n    // Display the array nicely\n    function displayArray(arr) {\n      const div = document.createElement('div');\n      div.className = 'array-display';\n      div.textContent = `[ ${arr.join(', ')} ]`;\n      output.appendChild(div);\n    }\n\n    // Create a step element for each step\n    function displayStep(index, valueChecked, target) {\n      const stepDiv = document.createElement('div');\n      stepDiv.className = 'step';\n      stepDiv.textContent = `Checking index ${index}: value = ${valueChecked} ${valueChecked === target ? '✔️ (Match found!)' : '✖️'}`;\n      output.appendChild(stepDiv);\n    }\n\n    // Linear search function (with stepwise display)\n    function linearSearch(arr, target) {\n      clearOutput();\n      output.innerHTML = '<strong>Array to search:</strong>';\n      displayArray(arr);\n      output.innerHTML += `<strong>Target value:</strong> ${target}<br><br>`;\n\n      for (let i = 0; i < arr.length; i++) {\n        displayStep(i, arr[i], target);\n        if (arr[i] === target) {\n          output.innerHTML += `<br><strong>Result:</strong> Target found at index <em>${i}</em>.`;\n          return i;\n        }\n      }\n      output.innerHTML += `<br><strong>Result:</strong> Target not found in the array.`;\n      return -1;\n    }\n\n    // Event listener for button click\n    searchBtn.addEventListener('click', () => {\n      const arrStr = arrayInput.value.trim();\n      const targetStr = targetInput.value.trim();\n\n      if (!arrStr) {\n        alert('Please enter array elements.');\n        return;\n      }\n      if (targetStr === '') {\n        alert('Please enter a target value to search.');\n        return;\n      }\n\n      // Parse input array\n      let arr = arrStr.split(',').map(s => s.trim());\n\n      // Make sure all elements are numbers\n      const numericArr = [];\n      for(let i = 0; i < arr.length; i++) {\n        const n = Number(arr[i]);\n        if (isNaN(n)) {\n          alert(`Invalid number encountered in array: \"${arr[i]}\"`);\n          return;\n        }\n        numericArr.push(n);\n      }\n\n      const target = Number(targetStr);\n\n      linearSearch(numericArr, target);\n    });\n  </script>\n</body>\n</html>"
