    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>TimSort Visual Demonstration</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 0; padding: 0; background:#f7f9fc; color:#111; }\n    header { padding: 16px; background: linear-gradient(90deg,#3b82f6,#06b6d4); color: white; }\n    header h1 { margin: 0; font-size: 20px; }\n    .container { display: grid; grid-template-columns: 320px 1fr; gap: 12px; padding: 12px; height: calc(100vh - 76px); box-sizing: border-box; }\n    .controls { background: white; border-radius: 8px; padding: 12px; box-shadow: 0 2px 8px rgba(12,18,31,0.06); overflow:auto; }\n    .controls label { display:block; margin-top:10px; font-weight:600; font-size:13px; }\n    .controls input[type=range] { width: 100%; }\n    .controls button, .controls input[type=number], .controls select { margin-top:8px; padding:8px; width:100%; box-sizing:border-box; border-radius:6px; border:1px solid #d1d5db; background:white; }\n    .controls .row { display:flex; gap:8px; }\n    .controls .row button { flex:1; }\n    .stats { margin-top:12px; font-size:13px; }\n    .visual { background: white; border-radius:8px; padding:12px; box-shadow: 0 2px 8px rgba(12,18,31,0.06); display:flex; flex-direction:column; gap:8px; height:100%; }\n    #canvasContainer { flex:1; border:1px dashed #e6edf3; border-radius:6px; padding:10px; position:relative; overflow:auto; background: linear-gradient(180deg,#ffffff,#fbfdff); }\n    #bars { display:flex; align-items:flex-end; height:100%; gap:2px; transition:height 160ms; }\n    .bar { background:#60a5fa; width:12px; height:20px; border-radius:2px; transition: height 160ms, background 120ms; display:inline-block; }\n    .bar.default { background:#60a5fa; }\n    .bar.run { background:#f97316; } /* orange */\n    .bar.merge { background:#a78bfa; } /* purple */\n    .bar.compare { background:#ef4444; } /* red */\n    .bar.sorted { background:#10b981; } /* green */\n    .legend { display:flex; gap:8px; font-size:13px; align-items:center; }\n    .legend span { display:flex; gap:6px; align-items:center; }\n    .swatch { width:14px; height:14px; border-radius:3px; display:inline-block; }\n    .stackView { margin-top:8px; font-size:13px; background:#f8fafc; padding:8px; border-radius:6px; max-height:200px; overflow:auto; }\n    pre { background:#0f172a; color:#e6eef8; padding:8px; border-radius:6px; font-size:12px; overflow:auto; }\n    .footerNote { margin-top:8px; font-size:13px; color:#374151; }\n    small { color:#475569; }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>TimSort Visual Demonstration</h1>\n  </header>\n\n  <div class=\"container\">\n    <div class=\"controls\">\n      <label>Array size (20 - 200)\n        <input id=\"size\" type=\"range\" min=\"20\" max=\"200\" value=\"80\" />\n      </label>\n      <label>Randomness / Seed\n        <div class=\"row\">\n          <input id=\"seed\" type=\"number\" min=\"0\" placeholder=\"Leave blank = random\" />\n          <button id=\"randomize\">Randomize Array</button>\n        </div>\n      </label>\n\n      <label>Animation speed (ms per step)\n        <input id=\"speed\" type=\"range\" min=\"10\" max=\"800\" value=\"80\" />\n      </label>\n\n      <label>Controls</label>\n      <div class=\"row\">\n        <button id=\"stepBtn\">Step</button>\n        <button id=\"playBtn\">Play</button>\n        <button id=\"resetBtn\">Reset</button>\n      </div>\n\n      <div class=\"row\">\n        <button id=\"detectRunsBtn\">Detect Runs</button>\n        <button id=\"fullSortBtn\">Run Full TimSort</button>\n      </div>\n\n      <div class=\"stats\">\n        <div>n = <span id=\"nVal\">80</span></div>\n        <div>minrun = <strong id=\"minrunVal\">0</strong></div>\n      </div>\n\n      <div style=\"margin-top:10px;\">\n        <label>Run stack</label>\n        <div class=\"stackView\" id=\"stackView\">[]</div>\n      </div>\n\n      <div style=\"margin-top:10px;\">\n        <label>Algorithm explanation</label>\n        <div style=\"font-size:13px; line-height:1.3;\">\n          TimSort: Find \"natural\" runs, make them at least minrun via insertion sort, then merge runs using stack invariants to keep merges balanced. This demo shows detection, run extension, and merges step-by-step.\n        </div>\n      </div>\n\n      <div class=\"footerNote\">\n        <small>Tip: press \"Detect Runs\" to see natural runs, then \"Step\" to advance through TimSort. \"Play\" runs automatically.</small>\n      </div>\n    </div>\n\n    <div class=\"visual\">\n      <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n        <div class=\"legend\">\n          <span><i class=\"swatch\" style=\"background:#60a5fa\"></i> default</span>\n          <span><i class=\"swatch\" style=\"background:#f97316\"></i> run</span>\n          <span><i class=\"swatch\" style=\"background:#a78bfa\"></i> merging</span>\n          <span><i class=\"swatch\" style=\"background:#ef4444\"></i> compare</span>\n          <span><i class=\"swatch\" style=\"background:#10b981\"></i> sorted</span>\n        </div>\n        <div style=\"font-size:13px; color:#374151\">TimSort Visualization</div>\n      </div>\n\n      <div id=\"canvasContainer\">\n        <div id=\"bars\" aria-hidden=\"true\"></div>\n      </div>\n\n      <div style=\"display:flex; gap:8px; align-items:flex-start;\">\n        <div style=\"flex:1\">\n          <label>Operation log</label>\n          <pre id=\"log\" style=\"height:120px\">Ready.</pre>\n        </div>\n        <div style=\"width:260px;\">\n          <label>Snapshot / Debug</label>\n          <div style=\"background:#f8fafc;padding:8px;border-radius:6px;font-size:13px;\">\n            <div>Phase: <span id=\"phase\">idle</span></div>\n            <div>Next action count: <span id=\"actionCount\">0</span></div>\n            <div style=\"margin-top:6px;\">Current merge: <span id=\"currentMerge\">-</span></div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <script>\n    // TimSort Visualization - Single file implementation\n    // Author: Generated for demo\n    (function(){\n      // DOM\n      const barsEl = document.getElementById('bars');\n      const sizeEl = document.getElementById('size');\n      const seedEl = document.getElementById('seed');\n      const randomizeBtn = document.getElementById('randomize');\n      const stepBtn = document.getElementById('stepBtn');\n      const playBtn = document.getElementById('playBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const detectRunsBtn = document.getElementById('detectRunsBtn');\n      const fullSortBtn = document.getElementById('fullSortBtn');\n      const speedEl = document.getElementById('speed');\n      const nVal = document.getElementById('nVal');\n      const minrunVal = document.getElementById('minrunVal');\n      const stackView = document.getElementById('stackView');\n      const logEl = document.getElementById('log');\n      const phaseEl = document.getElementById('phase');\n      const actionCountEl = document.getElementById('actionCount');\n      const currentMergeEl = document.getElementById('currentMerge');\n\n      let arr = [];\n      let frames = []; // sequence of frames (snapshots) to animate/step\n      let playing = false;\n      let playTimer = null;\n      let currentFrame = 0;\n\n      function seededRandom(seed) {\n        // simple LCG\n        let s = seed >>> 0;\n        return function() {\n          s = (s * 1664525 + 1013904223) >>> 0;\n          return s / 4294967296;\n        }\n      }\n\n      function buildArray(n, seed) {\n        const rand = seed == null ? Math.random : seededRandom(seed);\n        const a = [];\n        for (let i=0;i<n;i++){\n          // create partial presortedness sometimes by creating runs\n          // generate clusters to create natural runs occasionally\n          let val = Math.floor(rand()*100) + 1;\n          a.push(val);\n        }\n        return a;\n      }\n\n      function renderArray(snapshot) {\n        const data = snapshot ? snapshot.arr : arr;\n        barsEl.innerHTML = '';\n        const maxv = Math.max(...data);\n        for (let i=0;i<data.length;i++){\n          const v = data[i];\n          const bar = document.createElement('div');\n          bar.className = 'bar default';\n          const h = Math.max(3, Math.round((v / maxv) * 260));\n          bar.style.height = h + 'px';\n          // determine color from snapshot metadata\n          if (snapshot) {\n            if (snapshot.sortedIndices && snapshot.sortedIndices.has(i)) {\n              bar.className = 'bar sorted';\n            } else if (snapshot.merge && i >= snapshot.merge.start && i < snapshot.merge.start + snapshot.merge.len) {\n              bar.className = 'bar merge';\n            } else if (snapshot.runMap && snapshot.runMap[i] !== undefined) {\n              bar.className = 'bar run';\n            } else if (snapshot.compare && snapshot.compare.has(i)) {\n              bar.className = 'bar compare';\n            } else {\n              bar.className = 'bar default';\n            }\n          }\n          bar.title = String(v);\n          barsEl.appendChild(bar);\n        }\n      }\n\n      function log(msg) {\n        const time = new Date().toLocaleTimeString();\n        logEl.textContent = `[${time}] ${msg}\\n` + logEl.textContent;\n      }\n\n      // TimSort helpers\n\n      function minRunLength(n) {\n        // Python TimSort minrun calculation\n        let r = 0;\n        while (n >= 64) {\n          r |= n & 1;\n          n >>= 1;\n        }\n        return n + r;\n      }\n\n      // We'll build frames as snapshots at key points.\n      function pushFrame(arrSnapshot, options = {}) {\n        // arrSnapshot is an array copy\n        const snapshot = {\n          arr: arrSnapshot.slice(),\n          runMap: options.runMap ? new Map(options.runMap) : null,\n          merge: options.merge ? Object.assign({}, options.merge) : null,\n          compare: options.compare ? new Set(options.compare) : null,\n          sortedIndices: options.sortedIndices ? new Set(options.sortedIndices) : null,\n          stack: options.stack ? options.stack.map(s => ({start:s.start,len:s.len})) : null,\n          phase: options.phase || null,\n          note: options.note || ''\n        };\n        frames.push(snapshot);\n      }\n\n      // Insertion sort on range [lo, hi)\n      function insertionSortRange(a, lo, hi, framesContext) {\n        for (let i = lo + 1; i < hi; i++) {\n          let key = a[i];\n          let j = i - 1;\n          while (j >= lo && a[j] > key) {\n            a[j+1] = a[j];\n            // capture frame showing the swap/shift\n            framesContext.pushFrame(a, { compare: [j, j+1], phase: 'insertion-shift' });\n            j--;\n          }\n          a[j+1] = key;\n          framesContext.pushFrame(a, { compare: [j+1], phase: 'insertion-insert' });\n        }\n      }\n\n      // Merge two adjacent runs [start, start+len1) and [start+len1, start+len1+len2)\n      function mergeAt(a, start, len1, len2, framesContext) {\n        const start2 = start + len1;\n        const left = a.slice(start, start2);\n        const right = a.slice(start2, start2 + len2);\n        let i = 0, j = 0, k = start;\n        // Mark merge area for frames\n        framesContext.pushFrame(a, { merge: {start: start, len: len1 + len2}, phase: 'merge-start', compare: [] });\n\n        while (i < left.length && j < right.length) {\n          // show comparison\n          framesContext.pushFrame(a, { merge: {start: start, len: len1 + len2}, compare: [start + i, start + len1 + j], phase: 'merge-compare' });\n          if (left[i] <= right[j]) {\n            a[k++] = left[i++];\n          } else {\n            a[k++] = right[j++];\n          }\n          // show write\n          framesContext.pushFrame(a, { merge: {start: start, len: len1 + len2}, phase: 'merge-write', compare: [] });\n        }\n        while (i < left.length) {\n          a[k++] = left[i++];\n          framesContext.pushFrame(a, { merge: {start: start, len: len1 + len2}, phase: 'merge-write' });\n        }\n        while (j < right.length) {\n          a[k++] = right[j++];\n          framesContext.pushFrame(a, { merge: {start: start, len: len1 + len2}, phase: 'merge-write' });\n        }\n        // final frame marking merged run\n        framesContext.pushFrame(a, { merge: {start: start, len: len1 + len2}, phase: 'merge-done' });\n      }\n\n      // TimSort main that generates frames but does not animate\n      function generateTimSortFrames(inputArr) {\n        const a = inputArr.slice();\n        const n = a.length;\n        const minrun = minRunLength(n);\n        const ctx = { pushFrame: pushFrame.bind(null) };\n\n        frames = []; // reset frames\n        pushFrame(a, { phase: 'start' });\n\n        // 1) Identify natural runs\n        let runs = [];\n        let i = 0;\n        while (i < n) {\n          let runStart = i;\n          i++;\n          if (i === n) {\n            // single element run\n            runs.push({ start: runStart, len: 1 });\n            break;\n          }\n          if (a[i-1] <= a[i]) {\n            // ascending\n            while (i < n && a[i-1] <= a[i]) i++;\n          } else {\n            // descending\n            while (i < n && a[i-1] > a[i]) i++;\n            // reverse the descending run to make ascending\n            a.splice(runStart, i - runStart, ...a.slice(runStart, i).reverse());\n            // capture frame for reversal\n            pushFrame(a, { phase: 'reverse-run', runMap: rangeToMap(runStart, i - runStart), note: `Reverse run [${runStart},${i})` });\n          }\n          runs.push({ start: runStart, len: i - runStart });\n        }\n        pushFrame(a, { phase: 'runs-detected', note: `Detected ${runs.length} runs`, runMap: runsToMap(runs), stack: runs });\n\n        // 2) Extend short runs to at least minrun via insertion sort\n        const runStack = [];\n        for (let r of runs) {\n          let runLen = r.len;\n          if (runLen < minrun) {\n            const extend = Math.min(minrun, n - r.start);\n            runLen = extend;\n            // insertion sort the range [r.start, r.start+runLen)\n            insertionSortRange(a, r.start, r.start + runLen, { pushFrame });\n            pushFrame(a, { phase: 'extend-run', runMap: rangeToMap(r.start, runLen), note: `Extended/insertion-sorted run at ${r.start}` });\n          }\n          runStack.push({ start: r.start, len: runLen });\n          pushFrame(a, { phase: 'push-run', stack: runStack, runMap: rangeToMap(r.start, runLen) });\n\n          // Maintain invariants and merge as needed\n          collapseRuns(a, runStack, { pushFrame });\n        }\n\n        // After all runs processed, force merges until one run remains\n        while (runStack.length > 1) {\n          collapseRuns(a, runStack, { pushFrame }, true); // force merge\n        }\n\n        pushFrame(a, { phase: 'done', sortedIndices: new Set(Array.from({length:n}, (_,i)=>i)) });\n      }\n\n      // helper: convert runs to map for coloring\n      function runsToMap(runs) {\n        const m = new Map();\n        for (const r of runs) {\n          for (let i = r.start; i < r.start + r.len; i++) m.set(i, true);\n        }\n        return m;\n      }\n\n      function rangeToMap(start, len) {\n        const m = new Map();\n        for (let i = start; i < start + len; i++) m.set(i, true);\n        return m;\n      }\n\n      // collapseRuns ensures invariants by merging appropriate runs\n      function collapseRuns(a, stack, ctx, force=false) {\n        // pushFrame to show stack\n        ctx.pushFrame(a, { phase: 'check-stack', stack: stack });\n        const pushFrameLocal = ctx.pushFrame;\n        function mergeAtIndex(i) {\n          const A = stack[i];\n          const B = stack[i+1];\n          pushFrameLocal(a, { phase: 'will-merge', note: `Merging runs at ${A.start} (len ${A.len}) and ${B.start} (len ${B.len})`, stack: stack, merge: {start:A.start, len:A.len + B.len} });\n          mergeAt(a, A.start, A.len, B.len, ctx);\n          // replace A and B with merged run\n          stack.splice(i, 2, { start: A.start, len: A.len + B.len });\n          pushFrameLocal(a, { phase: 'merged', stack: stack });\n        }\n\n        // TimSort invariants: while stack has at least 2 runs and invariants violated, merge.\n        let changed = true;\n        while (stack.length > 1 && changed) {\n          changed = false;\n          const m = stack.length;\n          if (m >= 3) {\n            const A = stack[m-3].len;\n            const B = stack[m-2].len;\n            const C = stack[m-1].len;\n            if (A <= B + C) {\n              // choose which to merge\n              if (A < C) {\n                mergeAtIndex(m-3);\n              } else {\n                mergeAtIndex(m-2);\n              }\n              changed = true;\n              continue;\n            }\n          }\n          // second invariant\n          if (stack.length >= 2) {\n            const X = stack[stack.length-2].len;\n            const Y = stack[stack.length-1].len;\n            if (X <= Y || force) {\n              mergeAtIndex(stack.length-2);\n              changed = true;\n              continue;\n            }\n          }\n        }\n      }\n\n      // Animation/Playback management\n      function updateUIStatus() {\n        nVal.textContent = arr.length;\n        minrunVal.textContent = minRunLength(arr.length);\n        actionCountEl.textContent = Math.max(0, frames.length - currentFrame);\n        phaseEl.textContent = (frames[currentFrame] && frames[currentFrame].phase) || 'idle';\n        if (frames[currentFrame] && frames[currentFrame].stack) {\n          stackView.textContent = JSON.stringify(frames[currentFrame].stack.map(s=>`{start:${s.start},len:${s.len}}`), null, 0);\n        } else {\n          stackView.textContent = '[]';\n        }\n        if (frames[currentFrame] && frames[currentFrame].merge) {\n          currentMergeEl.textContent = `${frames[currentFrame].merge.start}..${frames[currentFrame].merge.start + frames[currentFrame].merge.len}`;\n        } else currentMergeEl.textContent = '-';\n      }\n\n      function showFrame(idx) {\n        if (idx < 0) idx = 0;\n        if (idx >= frames.length) idx = frames.length -1;\n        currentFrame = idx;\n        const snapshot = frames[currentFrame];\n        renderArray(snapshot);\n        log(`[frame ${currentFrame+1}/${frames.length}] phase=${snapshot.phase} ${snapshot.note || ''}`);\n        updateUIStatus();\n      }\n\n      function stepOnce() {\n        if (frames.length === 0) {\n          log('No frames to step. Generate frames by pressing \"Detect Runs\" or \"Full TimSort\".');\n          return;\n        }\n        if (currentFrame < frames.length - 1) {\n          currentFrame++;\n          showFrame(currentFrame);\n        } else {\n          log('Reached last frame.');\n        }\n      }\n\n      function playToggle() {\n        playing = !playing;\n        playBtn.textContent = playing ? 'Pause' : 'Play';\n        if (playing) {\n          const delay = Number(speedEl.value);\n          (function runner(){\n            if (!playing) return;\n            if (currentFrame < frames.length - 1) {\n              currentFrame++;\n              showFrame(currentFrame);\n              playTimer = setTimeout(runner, delay);\n            } else {\n              playing = false;\n              playBtn.textContent = 'Play';\n              log('Playback finished.');\n            }\n          })();\n        } else {\n          clearTimeout(playTimer);\n        }\n      }\n\n      // wiring events\n      sizeEl.addEventListener('input', ()=>{\n        const n = Number(sizeEl.value);\n        nVal.textContent = n;\n      });\n\n      randomizeBtn.addEventListener('click', ()=>{\n        const n = Number(sizeEl.value);\n        const seedVal = seedEl.value === '' ? null : Number(seedEl.value);\n        arr = buildArray(n, seedVal);\n        frames = [];\n        currentFrame = 0;\n        renderArray({arr});\n        log('Array randomized.');\n        updateUIStatus();\n      });\n\n      resetBtn.addEventListener('click', ()=>{\n        // reset to initial random array at current settings\n        randomizeBtn.click();\n      });\n\n      detectRunsBtn.addEventListener('click', ()=>{\n        // build frames but stop after detection and extension\n        const input = arr.slice();\n        frames = [];\n        currentFrame = 0;\n        pushFrame(input, { phase: 'start' });\n        // detect & extend runs with slightly different flow where we don't force final merges\n        const n = input.length;\n        const minrun = minRunLength(n);\n        pushFrame(input, { phase: 'info', note: `minrun=${minrun}` });\n\n        // detect runs\n        let runs = [];\n        let i = 0;\n        while (i < n) {\n          let runStart = i;\n          i++;\n          if (i === n) {\n            runs.push({ start: runStart, len: 1 });\n            break;\n          }\n          if (input[i-1] <= input[i]) {\n            while (i < n && input[i-1] <= input[i]) i++;\n          } else {\n            while (i < n && input[i-1] > input[i]) i++;\n            input.splice(runStart, i - runStart, ...input.slice(runStart, i).reverse());\n            pushFrame(input, { phase: 'reverse-run', note: `Reversed descending run [${runStart},${i})`, runMap: rangeToMap(runStart, i-runStart) });\n          }\n          runs.push({ start: runStart, len: i - runStart });\n        }\n        pushFrame(input, { phase: 'runs-detected', note: `Detected ${runs.length} runs`, runMap: runsToMap(runs) });\n\n        // extend short runs via insertion\n        const runStack = [];\n        for (const r of runs) {\n          let runLen = r.len;\n          if (runLen < minrun) {\n            runLen = Math.min(minrun, n - r.start);\n            insertionSortRange(input, r.start, r.start + runLen, { pushFrame });\n            pushFrame(input, { phase: 'extend-run', runMap: rangeToMap(r.start, runLen), note: `Extended run at ${r.start}` });\n          }\n          runStack.push({ start: r.start, len: runLen });\n          pushFrame(input, { phase: 'push-run', stack: runStack, runMap: rangeToMap(r.start, runLen) });\n        }\n        // show final stack without doing merges\n        pushFrame(input, { phase: 'detection-done', stack: runStack, note: 'Run detection & extension complete' });\n        frames = frames; // frames already collected\n        log(`Detected and extended runs; ${frames.length} frames generated.`);\n        showFrame(0);\n      });\n\n      fullSortBtn.addEventListener('click', ()=>{\n        // generate full timsort frames\n        generateTimSortFrames(arr);\n        currentFrame = 0;\n        log(`Full TimSort frames generated: ${frames.length} frames.`);\n        showFrame(0);\n      });\n\n      stepBtn.addEventListener('click', ()=>{\n        if (playing) {\n          playToggle();\n        }\n        stepOnce();\n      });\n\n      playBtn.addEventListener('click', ()=>{\n        // if no frames, generate default full sort\n        if (frames.length === 0) {\n          generateTimSortFrames(arr);\n        }\n        playToggle();\n      });\n\n      resetBtn.addEventListener('click', ()=>{\n        // reset frames and array\n        const seedVal = seedEl.value === '' ? null : Number(seedEl.value);\n        arr = buildArray(Number(sizeEl.value), seedVal);\n        frames = [];\n        currentFrame = 0;\n        renderArray({arr});\n        log('Reset array.');\n        updateUIStatus();\n      });\n\n      // Initialization\n      (function init(){\n        const seedVal = seedEl.value === '' ? null : Number(seedEl.value);\n        arr = buildArray(Number(sizeEl.value), seedVal);\n        renderArray({arr});\n        minrunVal.textContent = minRunLength(arr.length);\n        nVal.textContent = arr.length;\n        log('Ready. Generate frames with \"Detect Runs\" or \"Full TimSort\".');\n      })();\n\n    })();\n  </script>\n</body>\n</html>"
