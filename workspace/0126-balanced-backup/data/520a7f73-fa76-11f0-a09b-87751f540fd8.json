s.root = this.root.delete(key);\n            }\n        }\n\n        let tree = new BTree();\n\n        function insert(node, key, value) {\n            if (key < node.key) {\n                if (node.left === null) {\n                    node.left = new Node(key, value);\n                } else {\n                    insert(node.left, key, value);\n                }\n            } else if (key > node.key) {\n                if (node.right === null) {\n                    node.right = new Node(key, value);\n                } else {\n                    insert(node.right, key, value);\n                }\n            }\n        }\n\n        function search(node, key) {\n            if (node === null) {\n                return null;\n            }\n            if (key < node.key) {\n                return search(node.left, key);\n            } else if (key > node.key) {\n                return search(node.right, key);\n            } else {\n                return node.value;\n            }\n        }\n\n        function deleteNode(node, key) {\n            if (node === null) {\n                return null;\n            }\n            if (key < node.key) {\n                node.left = deleteNode(node.left, key);\n            } else if (key > node.key) {\n                node.right = deleteNode(node.right, key);\n            } else {\n                if (node.left === null && node.right === null) {\n                    return null;\n                } else if (node.left === null) {\n                    return node.right;\n                } else if (node.right === null) {\n                    return node.left;\n                } else {\n                    let min = findMin(node.right);\n                    node.key = min.key;\n                    node.value = min.value;\n                    node.right = deleteNode(node.right, min.key);\n                }\n            }\n            return node;\n        }\n\n        function findMin(node) {\n            while (node.left !== null) {\n                node = node.left;\n            }\n            return node;\n        }\n\n        function printTree(node, level = 0) {\n            if (node !== null) {\n                printTree(node.right, level + 1);\n                console.log(' '.repeat(4 * level) + '| ' + ' '.repeat(4 * level - 1) + node.key + ' | ' + node.value);\n                printTree(node.left, level + 1);\n            }\n        }\n\n        tree.insert(1, 10);\n        tree.insert(2, 20);\n        tree.insert(3, 30);\n\n        console.log('Search result: ', search(tree.root, 1).key, ' | ', search(tree.root, 1).value);\n        console.log('Delete 1');\n        tree.delete(1);\n        console.log('Search result: ', search(tree.root, 1).key, ' | ', search(tree.root, 1).value);\n        printTree(tree.root);\n    </script>\n</body>\n</html>"
