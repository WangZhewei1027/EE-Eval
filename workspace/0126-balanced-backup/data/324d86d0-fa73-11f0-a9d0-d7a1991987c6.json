    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tim Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f4f4f4;\n            padding: 20px;\n        }\n        #array {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 20px;\n        }\n        .bar {\n            width: 20px;\n            margin: 0 1px;\n            background color: #3498db;\n        }\n    </style>\n</head>\n<body>\n    <h1>Tim Sort Visualization</h1>\n    <div id=\"array\"></div>\n    <button onclick=\"startTimSort()\">Sort Array</button>\n    <script>\n        const MIN_RUN = 32;\n        let array = [...Array(100).keys()].sort(() => Math.random() - 0.5);\n        \n        function displayArray(arr, highlightedIndices = []) {\n            const arrayDiv = document.getElementById('array');\n            arrayDiv.innerHTML = '';\n            arr.forEach((value, index) => {\n                const bar = document.createElement('div');\n                bar.className = 'bar';\n                bar.style.height = `${value * 2}px`;\n                bar.style.backgroundColor = highlightedIndices.includes(index) ? '#e74c3c' : '#3498db';\n                arrayDiv.appendChild(bar);\n            });\n        }\n\n        function insertionSort(arr, left, right) {\n            for (let i = left + 1; i <= right; i++) {\n                let key = arr[i];\n                let j = i - 1;\n                while (j >= left && arr[j] > key) {\n                    arr[j + 1] = arr[j];\n                    j--;\n                }\n                arr[j + 1] = key;\n            }\n        }\n\n        function merge(arr, left, mid, right) {\n            const len1 = mid - left + 1;\n            const len2 = right - mid;\n            let leftArr = new Array(len1);\n            let rightArr = new Array(len2);\n\n            for (let i = 0; i < len1; i++) {\n                leftArr[i] = arr[left + i];\n            }\n            for (let j = 0; j < len2; j++) {\n                rightArr[j] = arr[mid + 1 + j];\n            }\n\n            let i = 0, j = 0, k = left;\n            while (i < len1 && j < len2) {\n                if (leftArr[i] <= rightArr[j]) {\n                    arr[k] = leftArr[i];\n                    i++;\n                } else {\n                    arr[k] = rightArr[j];\n                    j++;\n                }\n                k++;\n            }\n            while (i < len1) {\n                arr[k] = leftArr[i];\n                i++;\n                k++;\n            }\n            while (j < len2) {\n                arr[k] = rightArr[j];\n                j++;\n                k++;\n            }\n        }\n\n        function timSort(arr) {\n            const n = arr.length;\n\n            for (let i = 0; i < n; i += MIN_RUN) {\n                const end = Math.min(i + MIN_RUN - 1, n - 1);\n                insertionSort(arr, i, end);\n            }\n\n            for (let size = MIN_RUN; size < n; size *= 2) {\n                for (let left = 0; left < n; left += 2 * size) {\n                    const mid = left + size - 1;\n                    const right = Math.min((left + 2 * size - 1), (n - 1));\n                    if (mid < right) {\n                        merge(arr, left, mid, right);\n                    }\n                }\n            }\n        }\n\n        function startTimSort() {\n            const originalArray = [...array];\n            displayArray(originalArray);\n            setTimeout(() => {\n                timSort(originalArray);\n                displayArray(originalArray);\n            }, 1000);\n        }\n\n        window.onload = () => displayArray(array);\n    </script>\n</body>\n</html>"
