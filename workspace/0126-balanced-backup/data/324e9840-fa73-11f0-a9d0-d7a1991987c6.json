    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>P vs NP Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n            background-color: #f0f0f0;\n        }\n        h1 {\n            text-align: center;\n        }\n        #container {\n            display: flex;\n            justify-content: space-between;\n        }\n        .box {\n            background-color: #fff;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            padding: 20px;\n            width: 45%;\n            box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);\n        }\n        .button {\n            margin-top: 10px;\n            padding: 10px;\n            background-color: #007bff;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #0056b3;\n        }\n    </style>\n</head>\n<body>\n    <h1>P vs NP Demonstration</h1>\n    <div id=\"container\">\n        <div class=\"box\" id=\"pBox\">\n            <h2>P Problems</h2>\n            <p>Problems that can be solved in polynomial time. Example: Sorting a list.</p>\n            <button class=\"button\" onclick=\"solveP()\">Solve a P problem</button>\n            <pre id=\"pResult\"></pre>\n        </div>\n        <div class=\"box\" id=\"npBox\">\n            <h2>NP Problems</h2>\n            <p>Problems for which a solution can be verified in polynomial time. Example: Sudoku.</p>\n            <button class=\"button\" onclick=\"solveNP()\">Solve an NP problem</button>\n            <pre id=\"npResult\"></pre>\n        </div>\n    </div>\n\n    <script>\n        function solveP() {\n            // Simulate solving a P problem\n            const startTime = performance.now();\n            const sortedArray = selfSort([5, 3, 8, 1, 2]);\n            const endTime = performance.now();\n            const timeTaken = (endTime - startTime).toFixed(2);\n            document.getElementById('pResult').innerText = `Sorted Array: ${sortedArray}\\nTime taken to sort: ${timeTaken} ms`;\n        }\n\n        function selfSort(arr) {\n            return arr.sort((a, b) => a - b);\n        }\n\n        function solveNP() {\n            const startTime = performance.now();\n            const isSolution = npSampleProblem([3, 5, 7, 25, 1, 2, 8], 10); // Check if any two numbers sum to 10\n            const endTime = performance.now();\n            const timeTaken = (endTime - startTime).toFixed(2);\n            document.getElementById('npResult').innerText = `Solution found: ${isSolution}\\nTime taken for verification: ${timeTaken} ms`;\n        }\n\n        function npSampleProblem(arr, target) {\n            const nums = new Set();\n            for (let num of arr) {\n                if (nums.has(target - num)) {\n                    return true; // A pair was found\n                }\n                nums.add(num);\n            }\n            return false; // No such pair found\n        }\n    </script>\n</body>\n</html>"
