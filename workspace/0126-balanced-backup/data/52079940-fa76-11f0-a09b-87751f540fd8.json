    "content": "<html>\n<head>\n    <title>Array Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #output {\n            font-size: 24px;\n            font-weight: bold;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Array Example</h1>\n    <p id=\"output\"></p>\n\n    <script>\n        let colors = ['red', 'green', 'blue', 'yellow', 'orange', 'purple'];\n        let fruits = ['apple', 'banana', 'cherry', 'date', 'elderberry', 'fig'];\n\n        // Create an array from two arrays\n        let fruitsArray = [...fruits, 'grape', 'strawberry'];\n        let colorsArray = [...colors, 'pink', 'brown'];\n\n        console.log('Array of fruits:', fruitsArray);\n        console.log('Array of colors:', colorsArray);\n\n        // Accessing elements by index\n        console.log('Fruit at index 2:', fruitsArray[2]);\n        console.log('Color at index 1:', colorsArray[1]);\n\n        // Modifying elements in the array\n        fruitsArray[0] = 'mango';\n        colorsArray[3] = 'black';\n        console.log('Fruits after modification:', fruitsArray);\n        console.log('Colors after modification:', colorsArray);\n\n        // Adding elements to the array\n        fruitsArray.push('kiwi');\n        colorsArray.push('pink');\n        console.log('Fruits after addition:', fruitsArray);\n        console.log('Colors after addition:', colorsArray);\n\n        // Removing elements from the array\n        fruitsArray.pop();\n        colorsArray.shift();\n        console.log('Fruits after removal:', fruitsArray);\n        console.log('Colors after removal:', colorsArray);\n\n        // Updating elements in the array\n        fruitsArray[0] = 'pineapple';\n        colorsArray[1] = 'brown';\n        console.log('Fruits after update:', fruitsArray);\n        console.log('Colors after update:', colorsArray);\n    </script>\n</body>\n</html>"
