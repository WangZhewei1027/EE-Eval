    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Compiler Concept Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2em;\n    background: #f0f0f0;\n  }\n  h1 {\n    color: #333;\n  }\n  textarea, pre, select, button {\n    font-family: monospace;\n    font-size: 1rem;\n  }\n  textarea {\n    width: 100%;\n    height: 120px;\n  }\n  pre {\n    white-space: pre-wrap;\n    background: #272822;\n    color: #f8f8f2;\n    padding: 1em;\n    border-radius: 5px;\n    min-height: 80px;\n  }\n  label {\n    font-weight: bold;\n  }\n  .section {\n    margin-bottom: 2em;\n  }\n  button {\n    padding: 0.5em 1em;\n    margin-top: 0.5em;\n    cursor: pointer;\n  }\n  .error {\n    color: #d44;\n    background: #fee;\n    padding: 0.5em;\n    border-radius: 4px;\n  }\n</style>\n</head>\n<body>\n<h1>Compiler Concept Demonstration</h1>\n\n<div class=\"section\">\n  <label for=\"sourceCode\">Source Code (simple arithmetic expressions):</label><br />\n  <textarea id=\"sourceCode\" spellcheck=\"false\">a = 3 + 5 * (2 - 1);\nb = a * 4 - 7;\nb + 10;</textarea>\n</div>\n\n<div class=\"section\">\n  <button id=\"compileBtn\">Compile</button>\n</div>\n\n<div class=\"section\">\n  <label>Tokens (Lexical Analysis):</label>\n  <pre id=\"tokensOutput\">(Press \"Compile\" to see tokens)</pre>\n</div>\n\n<div class=\"section\">\n  <label>Parse Tree (Parsing):</label>\n  <pre id=\"parseOutput\">(Press \"Compile\" to see parse tree)</pre>\n</div>\n\n<div class=\"section\">\n  <label>Generated Intermediate Code (3-Address Code):</label>\n  <pre id=\"codeOutput\">(Press \"Compile\" to see code)</pre>\n</div>\n\n<script>\n(() => {\n  /*\n    Simple compiler demonstration:\n    - Lexer: tokenize input (variables, numbers, operators, parentheses, semicolons)\n    - Parser: build an AST for assignment and expression statements\n    - Code Generator: output 3-address code (instructions)\n  */\n\n  // Token definitions\n  const TOKEN_TYPES = {\n    NUMBER: 'NUMBER',\n    IDENT: 'IDENT',\n    OP: 'OP',\n    PAREN: 'PAREN',\n    SEMICOLON: 'SEMICOLON',\n    ASSIGN: 'ASSIGN',\n    EOF: 'EOF',\n  };\n\n  function isAlpha(ch) {\n    return /^[A-Za-z_]$/.test(ch);\n  }\n  function isDigit(ch) {\n    return /^[0-9]$/.test(ch);\n  }\n  function isAlnum(ch) {\n    return isAlpha(ch) || isDigit(ch);\n  }\n\n  // Lexer\n  class Lexer {\n    constructor(input) {\n      this.input = input;\n      this.pos = 0;\n      this.currentChar = this.input[this.pos];\n    }\n\n    advance() {\n      this.pos++;\n      if (this.pos >= this.input.length) {\n        this.currentChar = null;\n      } else {\n        this.currentChar = this.input[this.pos];\n      }\n    }\n\n    skipWhitespace() {\n      while (this.currentChar && /\\s/.test(this.currentChar)) {\n        this.advance();\n      }\n    }\n\n    number() {\n      let result = '';\n      while (this.currentChar && isDigit(this.currentChar)) {\n        result += this.currentChar;\n        this.advance();\n      }\n      return { type: TOKEN_TYPES.NUMBER, value: result };\n    }\n\n    ident() {\n      let result = '';\n      while (this.currentChar && isAlnum(this.currentChar)) {\n        result += this.currentChar;\n        this.advance();\n      }\n      return { type: TOKEN_TYPES.IDENT, value: result };\n    }\n\n    getNextToken() {\n      while (this.currentChar !== null) {\n        if (/\\s/.test(this.currentChar)) {\n          this.skipWhitespace();\n          continue;\n        }\n\n        if (isAlpha(this.currentChar)) {\n          return this.ident();\n        }\n\n        if (isDigit(this.currentChar)) {\n          return this.number();\n        }\n\n        if (this.currentChar === '+') {\n          this.advance();\n          return { type: TOKEN_TYPES.OP, value: '+' };\n        }\n        if (this.currentChar === '-') {\n          this.advance();\n          return { type: TOKEN_TYPES.OP, value: '-' };\n        }\n        if (this.currentChar === '*') {\n          this.advance();\n          return { type: TOKEN_TYPES.OP, value: '*' };\n        }\n        if (this.currentChar === '/') {\n          this.advance();\n          return { type: TOKEN_TYPES.OP, value: '/' };\n        }\n        if (this.currentChar === '(') {\n          this.advance();\n          return { type: TOKEN_TYPES.PAREN, value: '(' };\n        }\n        if (this.currentChar === ')') {\n          this.advance();\n          return { type: TOKEN_TYPES.PAREN, value: ')' };\n        }\n        if (this.currentChar === '=') {\n          this.advance();\n          return { type: TOKEN_TYPES.ASSIGN, value: '=' };\n        }\n        if (this.currentChar === ';') {\n          this.advance();\n          return { type: TOKEN_TYPES.SEMICOLON, value: ';' };\n        }\n\n        throw new Error(`Lexer error: Unknown character '${this.currentChar}'`);\n      }\n\n      return { type: TOKEN_TYPES.EOF, value: null };\n    }\n  }\n\n  // Parser: recursive descent parser\n  // Grammar (simplified):\n  // program: statement*\n  // statement: assignment | expressionStatement\n  // assignment: IDENT = expression ;\n  // expressionStatement: expression ;\n  // expression: term ((+|-) term)*\n  // term: factor ((*|/) factor)*\n  // factor: NUMBER | IDENT | ( expression )\n\n  class Parser {\n    constructor(lexer) {\n      this.lexer = lexer;\n      this.currentToken = this.lexer.getNextToken();\n    }\n\n    eat(type) {\n      if (this.currentToken.type === type) {\n        this.currentToken = this.lexer.getNextToken();\n      } else {\n        throw new Error(`Parser error: expected token type ${type} but got ${this.currentToken.type}`);\n      }\n    }\n\n    parseProgram() {\n      const statements = [];\n      while (this.currentToken.type !== TOKEN_TYPES.EOF) {\n        statements.push(this.parseStatement());\n      }\n      return { type: 'Program', body: statements };\n    }\n\n    parseStatement() {\n      // lookahead for assignment: IDENT ASSIGN ...\n      if (this.currentToken.type === TOKEN_TYPES.IDENT) {\n        let lookahead = this.lexer.pos;\n        let lookToken = this.currentToken;\n        // peek next token\n        let nextToken = null;\n        if (lookahead < this.lexer.input.length) {\n          const savePos = this.lexer.pos;\n          const saveChar = this.lexer.currentChar;\n          const saveCurr = this.currentToken;\n          const tempLexer = new Lexer(this.lexer.input);\n          tempLexer.pos = this.lexer.pos;\n          tempLexer.currentChar = this.lexer.currentChar;\n          tempLexer.getNextToken();\n          nextToken = tempLexer.getNextToken();\n        }\n\n        if (nextToken && nextToken.type === TOKEN_TYPES.ASSIGN) {\n          return this.parseAssignment();\n        }\n      }\n      return this.parseExpressionStatement();\n    }\n\n    parseAssignment() {\n      const left = this.currentToken;\n      this.eat(TOKEN_TYPES.IDENT);\n      this.eat(TOKEN_TYPES.ASSIGN);\n      const right = this.parseExpression();\n      this.eat(TOKEN_TYPES.SEMICOLON);\n      return { type: 'Assignment', left: { type: 'Identifier', name: left.value }, right };\n    }\n\n    parseExpressionStatement() {\n      const expr = this.parseExpression();\n      this.eat(TOKEN_TYPES.SEMICOLON);\n      return { type: 'ExpressionStatement', expression: expr };\n    }\n\n    parseExpression() {\n      let node = this.parseTerm();\n      while (this.currentToken.type === TOKEN_TYPES.OP &&\n        (this.currentToken.value === '+' || this.currentToken.value === '-')) {\n        const token = this.currentToken;\n        this.eat(TOKEN_TYPES.OP);\n        const right = this.parseTerm();\n        node = { type: 'BinaryExpression', operator: token.value, left: node, right: right };\n      }\n      return node;\n    }\n\n    parseTerm() {\n      let node = this.parseFactor();\n      while (this.currentToken.type === TOKEN_TYPES.OP &&\n        (this.currentToken.value === '*' || this.currentToken.value === '/')) {\n        const token = this.currentToken;\n        this.eat(TOKEN_TYPES.OP);\n        const right = this.parseFactor();\n        node = { type: 'BinaryExpression', operator: token.value, left: node, right: right };\n      }\n      return node;\n    }\n\n    parseFactor() {\n      const token = this.currentToken;\n\n      if (token.type === TOKEN_TYPES.NUMBER) {\n        this.eat(TOKEN_TYPES.NUMBER);\n        return { type: 'Literal', value: Number(token.value) };\n      }\n      else if (token.type === TOKEN_TYPES.IDENT) {\n        this.eat(TOKEN_TYPES.IDENT);\n        return { type: 'Identifier', name: token.value };\n      }\n      else if (token.type === TOKEN_TYPES.PAREN && token.value === '(') {\n        this.eat(TOKEN_TYPES.PAREN);\n        const node = this.parseExpression();\n        if (this.currentToken.type === TOKEN_TYPES.PAREN && this.currentToken.value === ')') {\n          this.eat(TOKEN_TYPES.PAREN);\n        } else {\n          throw new Error(\"Parser error: expected ')'\");\n        }\n        return node;\n      }\n\n      throw new Error(`Parser error: unexpected token type ${token.type} with value ${token.value}`);\n    }\n  }\n\n  // Code Generator - generate 3-address intermediate code from AST\n  // We'll generate instructions like:\n  // t1 = 3\n  // t2 = 5\n  // t3 = 2\n  // t4 = t3 - 1\n  // t5 = t2 * t4\n  // t6 = t1 + t5\n  // a = t6\n  // ...\n  // Uses a simple temp variable counter\n\n  class CodeGenerator {\n    constructor() {\n      this.tempCount = 0;\n      this.instructions = [];\n      this.variables = new Set();\n    }\n\n    newTemp() {\n      this.tempCount++;\n      return `t${this.tempCount}`;\n    }\n\n    generate(node) {\n      if (!node) return null;\n\n      switch (node.type) {\n        case 'Program': {\n          node.body.forEach(stmt => this.generate(stmt));\n          return;\n        }\n        case 'Assignment': {\n          const r = this.generate(node.right);\n          const leftName = node.left.name;\n          this.variables.add(leftName);\n          this.instructions.push(`${leftName} = ${r}`);\n          return leftName;\n        }\n        case 'ExpressionStatement': {\n          this.generate(node.expression);\n          return;\n        }\n        case 'BinaryExpression': {\n          const left = this.generate(node.left);\n          const right = this.generate(node.right);\n          const temp = this.newTemp();\n          this.instructions.push(`${temp} = ${left} ${node.operator} ${right}`);\n          return temp;\n        }\n        case 'Literal': {\n          const temp = this.newTemp();\n          this.instructions.push(`${temp} = ${node.value}`);\n          return temp;\n        }\n        case 'Identifier': {\n          this.variables.add(node.name);\n          return node.name;\n        }\n        default:\n          throw new Error(`CodeGen error: Unknown node type ${node.type}`);\n      }\n    }\n  }\n\n  // Utility to print tokens nicely\n  function formatTokens(tokens) {\n    return tokens.map(t => `${t.type}${t.value !== null ? `(${t.value})` : ''}`).join('\\n');\n  }\n\n  // Utility to pretty-print AST\n  function prettyPrintAST(node, indent = '') {\n    if (!node) return '';\n    switch (node.type) {\n      case 'Program':\n        return node.body.map(stmt => prettyPrintAST(stmt, indent)).join('\\n');\n      case 'Assignment':\n        return `${indent}Assignment:\\n${indent}  Left: ${prettyPrintAST(node.left, indent + '    ')}\\n${indent}  Right:\\n${prettyPrintAST(node.right, indent + '    ')}`;\n      case 'ExpressionStatement':\n        return `${indent}ExpressionStatement:\\n${prettyPrintAST(node.expression, indent + '  ')}`;\n      case 'BinaryExpression':\n        return `${indent}BinaryExpression (${node.operator}):\\n${indent}  Left:\\n${prettyPrintAST(node.left, indent + '    ')}\\n${indent}  Right:\\n${prettyPrintAST(node.right, indent + '    ')}`;\n      case 'Literal':\n        return `${indent}Literal (${node.value})`;\n      case 'Identifier':\n        return `${indent}Identifier (${node.name})`;\n      default:\n        return `${indent}Unknown node type (${node.type})`;\n    }\n  }\n\n  // Main interaction\n  const sourceInput = document.getElementById('sourceCode');\n  const compileBtn = document.getElementById('compileBtn');\n  const tokensOutput = document.getElementById('tokensOutput');\n  const parseOutput = document.getElementById('parseOutput');\n  const codeOutput = document.getElementById('codeOutput');\n\n  compileBtn.addEventListener('click', () => {\n    tokensOutput.textContent = '';\n    parseOutput.textContent = '';\n    codeOutput.textContent = '';\n\n    const source = sourceInput.value;\n\n    try {\n      // Lexical analysis - get all tokens\n      const lexer = new Lexer(source);\n      const tokens = [];\n      let token;\n      do {\n        token = lexer.getNextToken();\n        tokens.push(token);\n      } while (token.type !== TOKEN_TYPES.EOF);\n      tokensOutput.textContent = formatTokens(tokens);\n\n      // Parsing\n      const parser = new Parser(new Lexer(source));\n      const ast = parser.parseProgram();\n      parseOutput.textContent = prettyPrintAST(ast);\n\n      // Code generation\n      const codeGen = new CodeGenerator();\n      codeGen.generate(ast);\n      codeOutput.textContent = codeGen.instructions.join('\\n');\n    } catch (err) {\n      tokensOutput.textContent = '';\n      parseOutput.textContent = '';\n      codeOutput.textContent = '';\n      const msg = err.message || 'Error during compilation';\n      tokensOutput.textContent = '';\n      parseOutput.textContent = '';\n      codeOutput.innerHTML = `<div class=\"error\">${msg}</div>`;\n    }\n  });\n})();\n</script>\n</body>\n</html>"
