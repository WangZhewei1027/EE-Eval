    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>AVL Tree Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    :root {\n      --bg: #0f1724;\n      --panel: #0b1220;\n      --accent: #3dd6a5;\n      --muted: #9aa6b2;\n      --danger: #ff6b6b;\n      --card: #071026;\n      --node-fill: linear-gradient(180deg,#1b2a4a,#123153);\n    }\n    html,body{height:100%;margin:0;font-family:Inter,Segoe UI,Helvetica,Arial,sans-serif;background:linear-gradient(180deg,#071426 0%, #041625 100%);color:#e6eef6}\n    .container{display:grid;grid-template-columns:360px 1fr;gap:18px;padding:18px;box-sizing:border-box;height:100%}\n    .panel{background:rgba(255,255,255,0.03);border-radius:10px;padding:14px;box-shadow:0 6px 20px rgba(0,0,0,0.6);overflow:auto}\n    h1{margin:4px 0 8px;font-size:18px}\n    .controls{display:flex;flex-direction:column;gap:10px}\n    .row{display:flex;gap:8px;align-items:center}\n    input[type=\"text\"]{flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.05);background:transparent;color:inherit}\n    button{padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,0.06);background:linear-gradient(180deg,rgba(255,255,255,0.02),transparent);color:var(--accent);cursor:pointer}\n    button.secondary{background:transparent;color:var(--muted);border:1px dashed rgba(255,255,255,0.03)}\n    .small{padding:6px 8px;font-size:13px}\n    .hint{font-size:13px;color:var(--muted)}\n    .svg-wrap{background:linear-gradient(180deg,#041427 0%, #072035 100%);border-radius:10px;padding:10px;height:calc(100vh - 64px - 36px);display:flex;flex-direction:column}\n    #svgCanvas{flex:1;width:100%;height:100%;overflow:auto;border-radius:8px;background:transparent}\n    .status{margin-top:8px;padding:8px;border-radius:8px;background:rgba(255,255,255,0.02);display:flex;justify-content:space-between;align-items:center;font-size:13px}\n    .log{margin-top:10px;height:140px;overflow:auto;padding:8px;border-radius:8px;background:rgba(0,0,0,0.25);font-size:13px;color:var(--muted)}\n    .trav{display:flex;flex-direction:column;gap:6px;margin-top:8px}\n    .trav div{font-size:13px;color:var(--muted)}\n    .controls .play-controls{display:flex;gap:8px;align-items:center}\n    .speed{display:flex;gap:6px;align-items:center}\n    .legend{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n    .chip{padding:6px 8px;border-radius:8px;background:rgba(255,255,255,0.02);font-size:13px;color:var(--muted)}\n    svg{width:100%;height:100%}\n    .node{cursor:default;transition:transform 300ms}\n    .node circle{fill:#0e63a8;stroke:#09324a;stroke-width:2}\n    .node text{fill:white;font-weight:600;font-size:13px}\n    .node .smalltext{font-size:11px;fill:#bfeaff;font-weight:600}\n    .node.highlight circle{fill:#3dd6a5;stroke:#0b4a3a;stroke-width:2}\n    .node.rotated circle{fill:#ffd86b;stroke:#7a5f1f}\n    .edge{stroke:#2a4a68;stroke-width:2}\n    .edge.highlight{stroke:#3dd6a5;stroke-width:3}\n    .infoBox{font-size:13px;color:var(--muted)}\n    .footer{font-size:12px;color:var(--muted);margin-top:8px}\n    @media (max-width:800px){.container{grid-template-columns:1fr;}}\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"panel\">\n      <h1>AVL Tree — Interactive Visualizer</h1>\n      <div class=\"hint\">Insert or delete nodes to see automatic balancing with rotations (LL, RR, LR, RL). Step through the balancing process.</div>\n\n      <div class=\"controls\" style=\"margin-top:12px\">\n        <div class=\"row\">\n          <input id=\"inputValue\" type=\"text\" placeholder=\"Enter number(s), e.g. 10 or 10,20,30\">\n          <button id=\"insertBtn\">Insert</button>\n          <button id=\"deleteBtn\" class=\"secondary\">Delete</button>\n        </div>\n\n        <div class=\"row\">\n          <button id=\"randomBtn\" class=\"small\">Random Tree</button>\n          <button id=\"clearBtn\" class=\"small secondary\">Clear</button>\n          <button id=\"bulkBtn\" class=\"small\">Bulk Insert</button>\n        </div>\n\n        <div class=\"play-controls\">\n          <button id=\"playBtn\" class=\"small\">Play</button>\n          <button id=\"pauseBtn\" class=\"small secondary\">Pause</button>\n          <button id=\"stepBtn\" class=\"small\">Step</button>\n          <div class=\"speed\">\n            <label class=\"hint\">Speed</label>\n            <input id=\"speedRange\" type=\"range\" min=\"200\" max=\"2000\" step=\"100\" value=\"800\">\n          </div>\n        </div>\n\n        <div class=\"legend\">\n          <div class=\"chip\">Nodes: circle value</div>\n          <div class=\"chip\">Small text: height | bf</div>\n          <div class=\"chip\">Green: active / selected</div>\n          <div class=\"chip\">Yellow: nodes rotated</div>\n        </div>\n\n        <div class=\"trav\">\n          <div class=\"infoBox\">Traversals:</div>\n          <div id=\"inOrder\" class=\"hint\">In-order: —</div>\n          <div id=\"preOrder\" class=\"hint\">Pre-order: —</div>\n          <div id=\"postOrder\" class=\"hint\">Post-order: —</div>\n          <div id=\"levelOrder\" class=\"hint\">Level-order: —</div>\n        </div>\n\n        <div class=\"log\" id=\"log\"></div>\n\n        <div class=\"footer\">Tip: Use \"Bulk Insert\" to insert a sequence (comma/space separated). Duplicate keys are ignored.</div>\n      </div>\n    </div>\n\n    <div class=\"svg-wrap panel\">\n      <div id=\"svgCanvas\"></div>\n      <div class=\"status\">\n        <div id=\"statusText\">Status: Ready</div>\n        <div class=\"hint\">Snapshots: <span id=\"snapCount\">0</span></div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // AVL Tree visualizer — single-file implementation\n    (function(){\n      // Basic utilities\n      let nextNodeId = 1;\n      function createNode(key){\n        return {id: nextNodeId++, key: Number(key), left: null, right: null, height: 1};\n      }\n\n      function height(n){ return n ? n.height : 0; }\n      function updateHeight(n){ if(n) n.height = 1 + Math.max(height(n.left), height(n.right)); }\n\n      function balanceFactor(n){ return n ? height(n.left) - height(n.right) : 0; }\n\n      // Deep clone tree (for snapshotting)\n      function cloneTree(node){\n        if(!node) return null;\n        return { id: node.id, key: node.key, left: cloneTree(node.left), right: cloneTree(node.right), height: node.height };\n      }\n\n      // AVL rotations (return new root)\n      function rotateRight(y){\n        const x = y.left;\n        const T2 = x.right;\n        x.right = y;\n        y.left = T2;\n        updateHeight(y); updateHeight(x);\n        return x;\n      }\n      function rotateLeft(x){\n        const y = x.right;\n        const T2 = y.left;\n        y.left = x;\n        x.right = T2;\n        updateHeight(x); updateHeight(y);\n        return y;\n      }\n\n      // We'll generate snapshots for visual playback\n      let snapshots = [];\n      function pushSnapshot(root, message, highlights){\n        snapshots.push({root: cloneTree(root), message: message||'', highlights: highlights||[]});\n      }\n\n      // AVL insert with snapshot logging\n      function avlInsert(root, key){\n        let inserted = false;\n        function _insert(node){\n          if(!node){\n            const n = createNode(key);\n            pushSnapshot(assignRootAfterDummy(n), 'Inserted '+key, [n.id]);\n            inserted = true;\n            return n;\n          }\n          pushSnapshot(assignRootAfterDummy(root), 'Visit '+node.key, [node.id]);\n          if(key === node.key){\n            pushSnapshot(assignRootAfterDummy(root), 'Key '+key+' already exists — ignore', [node.id]);\n            return node; // duplicate, ignore\n          } else if(key < node.key){\n            node.left = _insert(node.left);\n          } else {\n            node.right = _insert(node.right);\n          }\n          updateHeight(node);\n          pushSnapshot(assignRootAfterDummy(root), 'Update height of '+node.key+' -> h='+node.height+' bf='+balanceFactor(node), [node.id]);\n          const bf = balanceFactor(node);\n\n          // Left Left\n          if(bf > 1 && key < node.left.key){\n            pushSnapshot(assignRootAfterDummy(root), 'Right rotate at '+node.key+' (LL case)', [node.id, node.left.id]);\n            node = rotateRight(node);\n            pushSnapshot(assignRootAfterDummy(root), 'Performed right rotation', [node.id]);\n          }\n          // Right Right\n          else if(bf < -1 && key > node.right.key){\n            pushSnapshot(assignRootAfterDummy(root), 'Left rotate at '+node.key+' (RR case)', [node.id, node.right.id]);\n            node = rotateLeft(node);\n            pushSnapshot(assignRootAfterDummy(root), 'Performed left rotation', [node.id]);\n          }\n          // Left Right\n          else if(bf > 1 && key > node.left.key){\n            pushSnapshot(assignRootAfterDummy(root), 'Left rotate at '+node.left.key+' (part of LR)', [node.left.id]);\n            node.left = rotateLeft(node.left);\n            pushSnapshot(assignRootAfterDummy(root), 'Right rotate at '+node.key+' (LR case)', [node.id, node.left.id]);\n            node = rotateRight(node);\n            pushSnapshot(assignRootAfterDummy(root), 'Performed LR rotation', [node.id]);\n          }\n          // Right Left\n          else if(bf < -1 && key < node.right.key){\n            pushSnapshot(assignRootAfterDummy(root), 'Right rotate at '+node.right.key+' (part of RL)', [node.right.id]);\n            node.right = rotateRight(node.right);\n            pushSnapshot(assignRootAfterDummy(root), 'Left rotate at '+node.key+' (RL case)', [node.id, node.right.id]);\n            node = rotateLeft(node);\n            pushSnapshot(assignRootAfterDummy(root), 'Performed RL rotation', [node.id]);\n          }\n          return node;\n        }\n\n        // Helper so pushSnapshot can get snapshot of full tree (root may change during recursion)\n        function assignRootAfterDummy(potentialRoot){\n          // we'll set a global tempRoot to the current full tree when calling pushSnapshot\n          return currentRootForSnapshot;\n        }\n\n        // We'll perform insert while allowing snapshots to see root updates\n        // Because rotation returns new subtree root, we need to update the external root too.\n        // So implement insertion iteratively by using closure reference 'rootRef'\n        let currentRootForSnapshot = root;\n        // To ensure assignRootAfterDummy sees the latest root, we wrap updates\n        function _insertWithRoot(node){\n          if(!node){\n            const n = createNode(key);\n            currentRootForSnapshot = replaceNodeInTree(root, null, n); // placeholder to keep clone consistent\n            pushSnapshot(currentRootForSnapshot, 'Inserted '+key, [n.id]);\n            inserted = true;\n            return n;\n          }\n          pushSnapshot(currentRootForSnapshot, 'Visit '+node.key, [node.id]);\n          if(key === node.key){\n            pushSnapshot(currentRootForSnapshot, 'Key '+key+' already exists — ignore', [node.id]);\n            return node;\n          } else if(key < node.key){\n            node.left = _insertWithRoot(node.left);\n          } else {\n            node.right = _insertWithRoot(node.right);\n          }\n          updateHeight(node);\n          currentRootForSnapshot = root;\n          pushSnapshot(currentRootForSnapshot, 'Update height of '+node.key+' -> h='+node.height+' bf='+balanceFactor(node), [node.id]);\n          const bf = balanceFactor(node);\n          if(bf > 1 && key < node.left.key){\n            pushSnapshot(currentRootForSnapshot, 'Right rotate at '+node.key+' (LL case)', [node.id, node.left.id]);\n            node = rotateRight(node);\n            currentRootForSnapshot = replaceSubtree(root, node.id ? node.id : null, node); // not accurate id mapping but we'll snapshot root\n            pushSnapshot(currentRootForSnapshot, 'Performed right rotation', [node.id]);\n          } else if(bf < -1 && key > node.right.key){\n            pushSnapshot(currentRootForSnapshot, 'Left rotate at '+node.key+' (RR case)', [node.id, node.right.id]);\n            node = rotateLeft(node);\n            currentRootForSnapshot = replaceSubtree(root, node.id ? node.id : null, node);\n            pushSnapshot(currentRootForSnapshot, 'Performed left rotation', [node.id]);\n          } else if(bf > 1 && key > node.left.key){\n            pushSnapshot(currentRootForSnapshot, 'Left rotate at '+node.left.key+' (part of LR)', [node.left.id]);\n            node.left = rotateLeft(node.left);\n            pushSnapshot(currentRootForSnapshot, 'Right rotate at '+node.key+' (LR case)', [node.id, node.left.id]);\n            node = rotateRight(node);\n            currentRootForSnapshot = replaceSubtree(root, node.id ? node.id : null, node);\n            pushSnapshot(currentRootForSnapshot, 'Performed LR rotation', [node.id]);\n          } else if(bf < -1 && key < node.right.key){\n            pushSnapshot(currentRootForSnapshot, 'Right rotate at '+node.right.key+' (part of RL)', [node.right.id]);\n            node.right = rotateRight(node.right);\n            pushSnapshot(currentRootForSnapshot, 'Left rotate at '+node.key+' (RL case)', [node.id, node.right.id]);\n            node = rotateLeft(node);\n            currentRootForSnapshot = replaceSubtree(root, node.id ? node.id : null, node);\n            pushSnapshot(currentRootForSnapshot, 'Performed RL rotation', [node.id]);\n          }\n          return node;\n        }\n\n        // The above complexity with root replacement is to keep snapshots consistent.\n        // Simpler approach: perform classic recursion modifying 'root' variable as we go.\n        // We'll implement a clean insertion routine that updates the external root.\n        snapshots.push({root: cloneTree(root), message:'Starting insert '+key, highlights:[]});\n\n        function insertClean(node){\n          if(!node){\n            const n = createNode(key);\n            pushSnapshot(cloneTree(n), 'Inserted node '+key, [n.id]);\n            return n;\n          }\n          pushSnapshot(cloneTree(currentRoot), 'Visit '+node.key, [node.id]);\n          if(key === node.key){\n            pushSnapshot(cloneTree(currentRoot), 'Key '+key+' exists — ignored', [node.id]);\n            return node;\n          } else if(key < node.key){\n            node.left = insertClean(node.left);\n          } else {\n            node.right = insertClean(node.right);\n          }\n          updateHeight(node);\n          pushSnapshot(cloneTree(currentRoot), 'Updated height of '+node.key+' -> '+node.height+' (bf='+balanceFactor(node)+')', [node.id]);\n          const bf = balanceFactor(node);\n          if(bf > 1 && key < node.left.key){\n            pushSnapshot(cloneTree(currentRoot), 'Right rotation at '+node.key+' (LL)', [node.id, node.left.id]);\n            node = rotateRight(node);\n            pushSnapshot(cloneTree(currentRoot), 'Right rotation done', [node.id]);\n          } else if(bf < -1 && key > node.right.key){\n            pushSnapshot(cloneTree(currentRoot), 'Left rotation at '+node.key+' (RR)', [node.id, node.right.id]);\n            node = rotateLeft(node);\n            pushSnapshot(cloneTree(currentRoot), 'Left rotation done', [node.id]);\n          } else if(bf > 1 && key > node.left.key){\n            pushSnapshot(cloneTree(currentRoot), 'Left rotation at '+node.left.key+' then Right at '+node.key+' (LR)', [node.id, node.left.id]);\n            node.left = rotateLeft(node.left);\n            node = rotateRight(node);\n            pushSnapshot(cloneTree(currentRoot), 'LR rotation done', [node.id]);\n          } else if(bf < -1 && key < node.right.key){\n            pushSnapshot(cloneTree(currentRoot), 'Right rotation at '+node.right.key+' then Left at '+node.key+' (RL)', [node.id, node.right.id]);\n            node.right = rotateRight(node.right);\n            node = rotateLeft(node);\n            pushSnapshot(cloneTree(currentRoot), 'RL rotation done', [node.id]);\n          }\n          return node;\n        }\n\n        // We'll run insertClean with currentRoot references to keep snapshot of full tree consistent.\n        // For simplicity, we rely on currentRoot being updated at the outermost call.\n        let currentRoot = root;\n        function insertAndUpdateRoot(){\n          currentRoot = insertClean(currentRoot);\n          return currentRoot;\n        }\n        const newRoot = insertAndUpdateRoot();\n        pushSnapshot(cloneTree(newRoot), 'Insertion complete for '+key, []);\n        return newRoot;\n      }\n\n      // Simpler delete implementation with snapshots\n      function avlDelete(root, key){\n        let currentRoot = root;\n        pushSnapshot(cloneTree(currentRoot), 'Starting delete '+key, []);\n        function minValueNode(node){\n          let cur = node;\n          while(cur.left) cur = cur.left;\n          return cur;\n        }\n        function deleteNode(node, k){\n          if(!node){\n            pushSnapshot(cloneTree(currentRoot), 'Key '+k+' not found', []);\n            return node;\n          }\n          pushSnapshot(cloneTree(currentRoot), 'Visit '+node.key, [node.id]);\n          if(k < node.key){\n            node.left = deleteNode(node.left, k);\n          } else if(k > node.key){\n            node.right = deleteNode(node.right, k);\n          } else {\n            pushSnapshot(cloneTree(currentRoot), 'Found node '+k, [node.id]);\n            // node with one or no child\n            if(!node.left || !node.right){\n              const temp = node.left ? node.left : node.right;\n              if(!temp){\n                // no child\n                pushSnapshot(cloneTree(currentRoot), 'Removing leaf '+node.key, [node.id]);\n                node = null;\n              } else {\n                // one child\n                pushSnapshot(cloneTree(currentRoot), 'Replace '+node.key+' with child '+temp.key, [node.id, temp.id]);\n                node = temp;\n              }\n            } else {\n              // two children: get inorder successor\n              const temp = minValueNode(node.right);\n              pushSnapshot(cloneTree(currentRoot), 'Successor of '+node.key+' is '+temp.key, [node.id, temp.id]);\n              node.key = temp.key;\n              node.right = deleteNode(node.right, temp.key);\n            }\n          }\n          if(!node) return node;\n          updateHeight(node);\n          pushSnapshot(cloneTree(currentRoot), 'Updated height of '+node.key+' -> '+node.height+' (bf='+balanceFactor(node)+')', [node.id]);\n          const bf = balanceFactor(node);\n          // Balance\n          if(bf > 1 && balanceFactor(node.left) >= 0){\n            pushSnapshot(cloneTree(currentRoot), 'Right rotate at '+node.key+' (LL case)', [node.id, node.left.id]);\n            node = rotateRight(node);\n            pushSnapshot(cloneTree(currentRoot), 'Rotation done', [node.id]);\n          } else if(bf > 1 && balanceFactor(node.left) < 0){\n            pushSnapshot(cloneTree(currentRoot), 'Left rotate at '+node.left.key+' then Right at '+node.key+' (LR)', [node.id, node.left.id]);\n            node.left = rotateLeft(node.left);\n            node = rotateRight(node);\n            pushSnapshot(cloneTree(currentRoot), 'Rotation done', [node.id]);\n          } else if(bf < -1 && balanceFactor(node.right) <= 0){\n            pushSnapshot(cloneTree(currentRoot), 'Left rotate at '+node.key+' (RR case)', [node.id, node.right.id]);\n            node = rotateLeft(node);\n            pushSnapshot(cloneTree(currentRoot), 'Rotation done', [node.id]);\n          } else if(bf < -1 && balanceFactor(node.right) > 0){\n            pushSnapshot(cloneTree(currentRoot), 'Right rotate at '+node.right.key+' then Left at '+node.key+' (RL)', [node.id, node.right.id]);\n            node.right = rotateRight(node.right);\n            node = rotateLeft(node);\n            pushSnapshot(cloneTree(currentRoot), 'Rotation done', [node.id]);\n          }\n          return node;\n        }\n        currentRoot = deleteNode(currentRoot, key);\n        pushSnapshot(cloneTree(currentRoot), 'Delete complete for '+key, []);\n        return currentRoot;\n      }\n\n      // Helper for traversals\n      function inOrder(node, out){ if(node){ inOrder(node.left,out); out.push(node.key); inOrder(node.right,out);} }\n      function preOrder(node,out){ if(node){ out.push(node.key); preOrder(node.left,out); preOrder(node.right,out); } }\n      function postOrder(node,out){ if(node){ postOrder(node.left,out); postOrder(node.right,out); out.push(node.key); } }\n      function levelOrder(node,out){\n        if(!node) return;\n        const q=[node];\n        while(q.length){\n          let n=q.shift();\n          out.push(n.key);\n          if(n.left) q.push(n.left);\n          if(n.right) q.push(n.right);\n        }\n      }\n\n      // Rendering using SVG\n      const svgContainer = document.getElementById('svgCanvas');\n      function clearSvg(){ svgContainer.innerHTML = ''; }\n\n      function renderState(state){\n        clearSvg();\n        // Create SVG element\n        const svgNS = \"http://www.w3.org/2000/svg\";\n        const svg = document.createElementNS(svgNS, 'svg');\n        svg.setAttribute('viewBox','0 0 1200 600');\n        svg.setAttribute('preserveAspectRatio','xMidYMin meet');\n        svgContainer.appendChild(svg);\n\n        if(!state || !state.root) {\n          // empty tree message\n          const t = document.createElementNS(svgNS,'text');\n          t.setAttribute('x',600); t.setAttribute('y',300); t.setAttribute('text-anchor','middle');\n          t.setAttribute('fill','#8db3d6'); t.setAttribute('font-size','20'); t.textContent='Tree is empty';\n          svg.appendChild(t);\n          return;\n        }\n        // Compute positions using inorder layout\n        const nodes = [];\n        let xCounter = 0;\n        function assign(node, depth){\n          if(!node) return;\n          assign(node.left, depth+1);\n          const x = ++xCounter;\n          nodes.push({node: node, depth: depth, xIndex: x});\n          assign(node.right, depth+1);\n        }\n        assign(state.root, 0);\n        const maxDepth = nodes.reduce((m,n)=>Math.max(m,n.depth),0);\n        const width = Math.max(800, xCounter*80+200);\n        const height = Math.max(300, (maxDepth+2)*100);\n        svg.setAttribute('viewBox','0 0 '+width+' '+height);\n\n        // Map to positions\n        const positions = new Map();\n        nodes.forEach(n=>{\n          const x = (n.xIndex) * (width/(xCounter+1));\n          const y = 60 + n.depth*100;\n          positions.set(n.node.id,{x,y,node:n.node});\n        });\n\n        // Draw edges first\n        function drawEdges(node){\n          if(!node) return;\n          if(node.left){\n            const p1 = positions.get(node.id);\n            const p2 = positions.get(node.left.id);\n            const path = document.createElementNS(svgNS,'path');\n            const midx = p2.x;\n            const d = `M ${p1.x} ${p1.y} C ${p1.x} ${p1.y+30}, ${p2.x} ${p2.y-30}, ${p2.x} ${p2.y}`;\n            path.setAttribute('d',d);\n            path.setAttribute('fill','none');\n            path.setAttribute('class','edge');\n            svg.appendChild(path);\n            drawEdges(node.left);\n          }\n          if(node.right){\n            const p1 = positions.get(node.id);\n            const p2 = positions.get(node.right.id);\n            const path = document.createElementNS(svgNS,'path');\n            const d = `M ${p1.x} ${p1.y} C ${p1.x} ${p1.y+30}, ${p2.x} ${p2.y-30}, ${p2.x} ${p2.y}`;\n            path.setAttribute('d',d);\n            path.setAttribute('fill','none');\n            path.setAttribute('class','edge');\n            svg.appendChild(path);\n            drawEdges(node.right);\n          }\n        }\n        drawEdges(state.root);\n\n        // Draw nodes\n        const highlightSet = new Set((state.highlights||[]).map(id=>id));\n        function drawNode(node){\n          const p = positions.get(node.id);\n          const group = document.createElementNS(svgNS,'g');\n          group.setAttribute('transform',`translate(${p.x},${p.y})`);\n          group.setAttribute('class','node');\n          if(highlightSet.has(node.id)){\n            group.classList.add('highlight');\n          }\n          // If message mentions rotation, mark rotated nodes (yellow)\n          if((state.message||'').toLowerCase().includes('rotate') && highlightSet.has(node.id)){\n            group.classList.add('rotated');\n          }\n          const circle = document.createElementNS(svgNS,'circle');\n          circle.setAttribute('cx',0); circle.setAttribute('cy',0); circle.setAttribute('r',22);\n          group.appendChild(circle);\n          const txt = document.createElementNS(svgNS,'text');\n          txt.setAttribute('x',0); txt.setAttribute('y',5); txt.setAttribute('text-anchor','middle');\n          txt.textContent = node.key;\n          group.appendChild(txt);\n\n          const small = document.createElementNS(svgNS,'text');\n          small.setAttribute('x',0); small.setAttribute('y',36); small.setAttribute('text-anchor','middle');\n          small.setAttribute('class','smalltext');\n          const bf = balanceFactor(node);\n          small.textContent = 'h='+node.height+' | bf='+bf;\n          group.appendChild(small);\n\n          svg.appendChild(group);\n          if(node.left) drawNode(node.left);\n          if(node.right) drawNode(node.right);\n        }\n        drawNode(state.root);\n\n        // Message box\n        const box = document.createElementNS(svgNS,'rect');\n        box.setAttribute('x',10); box.setAttribute('y',10); box.setAttribute('width',width-20); box.setAttribute('height',38);\n        box.setAttribute('rx',8); box.setAttribute('fill','rgba(255,255,255,0.02)'); box.setAttribute('stroke','rgba(255,255,255,0.03)');\n        svg.appendChild(box);\n        const msg = document.createElementNS(svgNS,'text');\n        msg.setAttribute('x',20); msg.setAttribute('y',34); msg.setAttribute('fill','#bfeaff'); msg.setAttribute('font-size','14');\n        msg.textContent = state.message || '';\n        svg.appendChild(msg);\n      }\n\n      // Replace subtree helper (best-effort used in earlier code, but main logic uses other insertion)\n      function replaceSubtree(root, idToReplace, newSubtree){\n        // If root is null or matches id, return newSubtree\n        if(!root) return newSubtree;\n        if(root.id === idToReplace) return newSubtree;\n        function recurse(n){\n          if(!n) return null;\n          if(n.left && n.left.id === idToReplace) n.left = newSubtree;\n          else n.left = recurse(n.left) || n.left;\n          if(n.right && n.right.id === idToReplace) n.right = newSubtree;\n          else n.right = recurse(n.right) || n.right;\n          updateHeight(n);\n          return n;\n        }\n        recurse(root);\n        return root;\n      }\n\n      // Very small helper used in insertion snapshots (no-op)\n      function replaceNodeInTree(root, target, newNode){ return root || newNode; }\n\n      // UI & controller\n      let treeRoot = null;\n      const input = document.getElementById('inputValue');\n      const insertBtn = document.getElementById('insertBtn');\n      const deleteBtn = document.getElementById('deleteBtn');\n      const bulkBtn = document.getElementById('bulkBtn');\n      const randomBtn = document.getElementById('randomBtn');\n      const clearBtn = document.getElementById('clearBtn');\n      const playBtn = document.getElementById('playBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const stepBtn = document.getElementById('stepBtn');\n      const speedRange = document.getElementById('speedRange');\n      const logDiv = document.getElementById('log');\n      const statusText = document.getElementById('statusText');\n      const snapCount = document.getElementById('snapCount');\n\n      function writeLog(msg){\n        const time = new Date().toLocaleTimeString();\n        logDiv.innerHTML = `<div style=\"margin-bottom:4px\"><span style=\"color:#8abbe6\">[${time}]</span> ${msg}</div>` + logDiv.innerHTML;\n      }\n\n      // Update traversal displays\n      const inOrderDiv = document.getElementById('inOrder');\n      const preOrderDiv = document.getElementById('preOrder');\n      const postOrderDiv = document.getElementById('postOrder');\n      const levelOrderDiv = document.getElementById('levelOrder');\n      function updateTraversals(){\n        const a=[]; inOrder(treeRoot, a); inOrderDiv.textContent = 'In-order: ' + (a.length? a.join(', '): '—');\n        const b=[]; preOrder(treeRoot,b); preOrderDiv.textContent = 'Pre-order: ' + (b.length? b.join(', '): '—');\n        const c=[]; postOrder(treeRoot,c); postOrderDiv.textContent = 'Post-order: ' + (c.length? c.join(', '): '—');\n        const d=[]; levelOrder(treeRoot,d); levelOrderDiv.textContent = 'Level-order: ' + (d.length? d.join(', '): '—');\n      }\n\n      // Snapshot playback\n      let playTimer = null;\n      let currentIndex = 0;\n      function loadSnapshots(s){\n        snapshots = s || snapshots;\n        currentIndex = 0;\n        snapCount.textContent = snapshots.length;\n        statusText.textContent = 'Status: Ready ('+snapshots.length+' steps)';\n      }\n      function playSnapshots(){\n        if(snapshots.length===0) { writeLog('No snapshots to play'); return; }\n        playBtn.disabled = true;\n        pauseBtn.disabled = false;\n        const speed = Number(speedRange.value);\n        if(currentIndex >= snapshots.length) currentIndex = 0;\n        statusText.textContent = 'Status: Playing...';\n        playTimer = setInterval(()=>{\n          if(currentIndex >= snapshots.length){\n            pausePlayback();\n            statusText.textContent = 'Status: Finished';\n            return;\n          }\n          const s = snapshots[currentIndex++];\n          renderState(s);\n          document.getElementById('statusText').textContent = 'Step '+currentIndex+'/'+snapshots.length+' — '+(s.message||'');\n          snapCount.textContent = snapshots.length;\n          // log briefly\n        }, speed);\n      }\n      function pausePlayback(){\n        if(playTimer) clearInterval(playTimer);\n        playTimer = null;\n        playBtn.disabled = false;\n        pauseBtn.disabled = true;\n        statusText.textContent = 'Status: Paused';\n      }\n      function stepForward(){\n        if(currentIndex >= snapshots.length) {\n          statusText.textContent = 'Status: End of snapshots';\n          return;\n        }\n        const s = snapshots[currentIndex++];\n        renderState(s);\n        statusText.textContent = 'Step '+currentIndex+'/'+snapshots.length+' — '+(s.message||'');\n        snapCount.textContent = snapshots.length;\n      }\n\n      // Event handlers\n      insertBtn.addEventListener('click', ()=>{\n        const raw = input.value.trim();\n        if(!raw){ writeLog('Please enter a value to insert'); return; }\n        const parts = raw.split(/[, \\t]+/).map(x=>x.trim()).filter(x=>x.length);\n        for(const p of parts){\n          const v = Number(p);\n          if(isNaN(v)){ writeLog('Invalid number: '+p); continue; }\n          snapshots = []; // reset\n          const before = cloneTree(treeRoot);\n          treeRoot = avlInsert(treeRoot, v);\n          // after insertion, ensure final state snapshot is present and set treeRoot accordingly\n          // snapshots already appended inside avlInsert\n          loadSnapshots(snapshots);\n          currentIndex = 0;\n          renderState(snapshots[0]);\n          writeLog('Inserted '+v+' — playback ready ('+snapshots.length+' steps)');\n          updateTraversals();\n          break; // only do first value quickly — for more use bulk insert\n        }\n      });\n\n      deleteBtn.addEventListener('click', ()=>{\n        const raw = input.value.trim();\n        if(!raw){ writeLog('Please enter a value to delete'); return; }\n        const v = Number(raw.split(/[, \\t]+/)[0]);\n        if(isNaN(v)){ writeLog('Invalid number: '+raw); return; }\n        snapshots = [];\n        treeRoot = avlDelete(treeRoot, v);\n        loadSnapshots(snapshots);\n        currentIndex = 0;\n        if(snapshots.length) renderState(snapshots[0]);\n        writeLog('Delete '+v+' — playback ready ('+snapshots.length+' steps)');\n        updateTraversals();\n      });\n\n      bulkBtn.addEventListener('click', ()=>{\n        const raw = input.value.trim();\n        if(!raw){ writeLog('Enter numbers separated by commas/spaces'); return; }\n        const parts = raw.split(/[, \\t]+/).map(x=>x.trim()).filter(x=>x.length);\n        snapshots = [];\n        for(const p of parts){\n          const v = Number(p);\n          if(isNaN(v)){ writeLog('Invalid number in list: '+p); continue; }\n          treeRoot = avlInsert(treeRoot, v);\n        }\n        // snapshots array contains last insertion snapshots — ok to playback those\n        loadSnapshots(snapshots);\n        currentIndex = 0;\n        if(snapshots.length) renderState(snapshots[0]);\n        writeLog('Bulk inserted '+parts.length+' values — playback ready ('+snapshots.length+' steps)');\n        updateTraversals();\n      });\n\n      randomBtn.addEventListener('click', ()=>{\n        const count = Math.floor(Math.random()*6)+4;\n        const vals = [];\n        while(vals.length < count){\n          const v = Math.floor(Math.random()*90)+10;\n          if(!vals.includes(v)) vals.push(v);\n        }\n        snapshots = [];\n        for(const v of vals){\n          treeRoot = avlInsert(treeRoot, v);\n        }\n        loadSnapshots(snapshots);\n        currentIndex = 0;\n        if(snapshots.length) renderState(snapshots[0]);\n        writeLog('Generated random tree ['+vals.join(', ')+'] — playback ready ('+snapshots.length+' steps)');\n        updateTraversals();\n      });\n\n      clearBtn.addEventListener('click', ()=>{\n        treeRoot = null;\n        snapshots = [];\n        currentIndex = 0;\n        clearSvg();\n        updateTraversals();\n        statusText.textContent = 'Status: Ready';\n        snapCount.textContent = '0';\n        writeLog('Cleared tree');\n      });\n\n      playBtn.addEventListener('click', ()=>{ if(snapshots.length===0){ writeLog('Nothing to play — perform an operation first'); return;} playSnapshots(); });\n      pauseBtn.addEventListener('click', ()=>{ pausePlayback(); writeLog('Playback paused'); });\n      stepBtn.addEventListener('click', ()=>{ pausePlayback(); stepForward(); });\n\n      // Initial hint rendering\n      clearSvg();\n      const initState = {root:null, message:'Welcome — insert nodes to begin', highlights:[]};\n      renderState(initState);\n      statusText.textContent = 'Status: Ready';\n      writeLog('AVL Tree Visualizer ready. Insert a number (e.g. 30) and click Insert.');\n\n      // keyboard enter to insert\n      input.addEventListener('keydown', (e)=>{\n        if(e.key === 'Enter') insertBtn.click();\n      });\n\n      // Prevent accidental text selection in svg\n      svgContainer.addEventListener('mousedown', (e)=>{ e.preventDefault(); });\n\n      // small auto-update of traversal on snapshot end\n      // When playback completes, set treeRoot to last snapshot's root (if snapshot exists)\n      const observer = new MutationObserver(()=>{\n        // when svg changes, check if last snapshot message is \"Insertion complete\" etc and update treeRoot\n      });\n      observer.observe(svgContainer, {childList:true, subtree:true});\n    })();\n  </script>\n</body>\n</html>"
