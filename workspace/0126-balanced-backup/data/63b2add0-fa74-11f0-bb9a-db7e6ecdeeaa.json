  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>CPU Scheduling Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f4f7f8;\n  }\n  h1 {\n    text-align: center;\n    color: #333;\n  }\n  .container {\n    max-width: 900px;\n    margin: 0 auto;\n  }\n  label {\n    margin-right: 10px;\n    font-weight: bold;\n  }\n  select, button {\n    padding: 6px 12px;\n    margin-right: 20px;\n    font-size: 1rem;\n  }\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 20px;\n    background: #fff;\n    box-shadow: 0 0 5px rgba(0,0,0,0.1);\n  }\n  th, td {\n    border: 1px solid #ddd;\n    text-align: center;\n    padding: 8px;\n    font-size: 0.9rem;\n  }\n  th {\n    background: #007acc;\n    color: white;\n  }\n  #ganttChart {\n    margin-top: 30px;\n    height: 60px;\n    position: relative;\n    background: #eee;\n    border-radius: 6px;\n    overflow: hidden;\n    box-shadow: inset 0 0 5px #ccc;\n  }\n  .gantt-block {\n    height: 100%;\n    position: absolute;\n    top: 0;\n    color: white;\n    text-align: center;\n    line-height: 60px;\n    font-weight: bold;\n    font-size: 1rem;\n    border-right: 1px solid rgba(255, 255, 255, 0.7);\n  }\n  #timeline {\n    margin-top: 5px;\n    font-size: 0.85rem;\n    display: flex;\n    justify-content: space-between;\n  }\n  textarea {\n    width: 100%;\n    height: 120px;\n    font-family: monospace;\n    font-size: 0.9rem;\n    margin-top: 10px;\n  }\n  .tooltip {\n    position: relative;\n    cursor: pointer;\n  }\n  .tooltip:hover::after {\n    content: attr(data-tooltip);\n    position: absolute;\n    white-space: nowrap;\n    top: 130%;\n    left: 50%;\n    transform: translateX(-50%);\n    background: #333;\n    color: #fff;\n    padding: 4px 8px;\n    border-radius: 4px;\n    font-size: 0.75rem;\n    z-index: 10;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>CPU Scheduling Algorithms Demonstration</h1>\n\n  <p>\n    Select a CPU scheduling algorithm and enter processes with their arrival and burst times. The simulation will calculate and visualize scheduling order, waiting times, turnaround times, and a Gantt chart.\n  </p>\n\n  <label for=\"algorithm\">Choose Algorithm:</label>\n  <select id=\"algorithm\">\n    <option value=\"fcfs\">First-Come, First-Served (FCFS)</option>\n    <option value=\"sjf\">Shortest Job First (SJF) - Non-preemptive</option>\n    <option value=\"sjfp\">Shortest Job First (SJF) - Preemptive (SRTF)</option>\n    <option value=\"priority\">Priority Scheduling - Non-preemptive</option>\n    <option value=\"priorityp\">Priority Scheduling - Preemptive</option>\n    <option value=\"rr\">Round Robin (RR)</option>\n  </select>\n\n  <label for=\"quantum\" id=\"quantumLabel\" style=\"display:none;\">Time Quantum:</label>\n  <input type=\"number\" id=\"quantum\" min=\"1\" value=\"2\" style=\"width: 60px; display:none;\" />\n\n  <h3>Process Input</h3>\n  <p>Enter processes, one per line, in format: <br />\n     <code>ProcessID ArrivalTime BurstTime [Priority]</code><br />\n     Example for Priority Scheduling: <code>P1 0 5 2</code><br />\n     Priority is optional and used only in Priority scheduling.\n  </p>\n  <textarea id=\"processInput\" placeholder=\"Example:\nP1 0 5\nP2 1 3\nP3 2 8\nP4 3 6\"></textarea>\n\n  <div style=\"margin-top: 15px;\">\n    <button id=\"runBtn\">Run Simulation</button>\n    <button id=\"resetBtn\" style=\"margin-left:10px;\">Reset</button>\n  </div>\n\n  <div id=\"results\" style=\"margin-top:30px; display:none;\">\n    <h3>Scheduling Results</h3>\n    <table id=\"resultTable\">\n      <thead>\n        <tr>\n          <th>Process</th>\n          <th>Arrival Time</th>\n          <th>Burst Time</th>\n          <th class=\"priorityCol\" style=\"display:none;\">Priority</th>\n          <th>Start Time</th>\n          <th>Completion Time</th>\n          <th>Waiting Time</th>\n          <th>Turnaround Time</th>\n        </tr>\n      </thead>\n      <tbody></tbody>\n      <tfoot>\n        <tr>\n          <th colspan=\"6\" style=\"text-align:right;\">Average Waiting Time:</th>\n          <th id=\"avgWaitingTime\"></th>\n          <th></th>\n        </tr>\n        <tr>\n          <th colspan=\"6\" style=\"text-align:right;\">Average Turnaround Time:</th>\n          <th id=\"avgTurnaroundTime\"></th>\n          <th></th>\n        </tr>\n      </tfoot>\n    </table>\n\n    <div id=\"ganttChart\" aria-label=\"Gantt Chart\"></div>\n    <div id=\"timeline\"></div>\n  </div>\n</div>\n\n<script>\n(() => {\n  const algorithmSelect = document.getElementById('algorithm');\n  const quantumInput = document.getElementById('quantum');\n  const quantumLabel = document.getElementById('quantumLabel');\n  const processInput = document.getElementById('processInput');\n  const runBtn = document.getElementById('runBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const resultsDiv = document.getElementById('results');\n  const resultTableBody = document.querySelector('#resultTable tbody');\n  const avgWaitingTimeElem = document.getElementById('avgWaitingTime');\n  const avgTurnaroundTimeElem = document.getElementById('avgTurnaroundTime');\n  const ganttChart = document.getElementById('ganttChart');\n  const timelineDiv = document.getElementById('timeline');\n  const priorityCols = document.querySelectorAll('.priorityCol');\n\n  function showError(msg) {\n    alert(msg);\n  }\n\n  // Show/hide time quantum input depending on RR algorithm\n  function handleAlgorithmChange() {\n    const algo = algorithmSelect.value;\n    if(algo === 'rr'){\n      quantumInput.style.display = 'inline-block';\n      quantumLabel.style.display = 'inline-block';\n    } else {\n      quantumInput.style.display = 'none';\n      quantumLabel.style.display = 'none';\n    }\n    // Show priority column only if priority scheduling\n    if(algo === 'priority' || algo === 'priorityp'){\n      priorityCols.forEach(c => c.style.display = '');\n    } else {\n      priorityCols.forEach(c => c.style.display = 'none');\n    }\n  }\n  algorithmSelect.addEventListener('change', handleAlgorithmChange);\n  handleAlgorithmChange();\n\n  function parseProcesses(input) {\n    const lines = input.trim().split('\\n');\n    let processes = [];\n    for(let i=0; i<lines.length; i++){\n      if(!lines[i].trim()) continue;\n      const parts = lines[i].trim().split(/\\s+/);\n      // At least ProcessID, ArrivalTime, BurstTime required\n      if(parts.length < 3){\n        showError(`Line ${i+1} is invalid. Expected format: ProcessID ArrivalTime BurstTime [Priority]`);\n        return null;\n      }\n      let [pid, arrivalStr, burstStr, priorityStr] = parts;\n      const arrival = Number(arrivalStr);\n      const burst = Number(burstStr);\n      if(isNaN(arrival) || arrival < 0){\n        showError(`Invalid arrival time at line ${i+1}`);\n        return null;\n      }\n      if(isNaN(burst) || burst <= 0){\n        showError(`Invalid burst time at line ${i+1}`);\n        return null;\n      }\n      let priority = null;\n      if(priorityStr !== undefined){\n        priority = Number(priorityStr);\n        if(isNaN(priority) || priority < 0){\n          showError(`Invalid priority at line ${i+1}`);\n          return null;\n        }\n      }\n      processes.push({\n        pid,\n        arrival,\n        burst,\n        remaining: burst,\n        priority,\n        startTime: null,\n        completionTime: null,\n        waitingTime: null,\n        turnaroundTime: null,\n      });\n    }\n    // Sort by arrival for sanity\n    processes.sort((a,b) => a.arrival - b.arrival);\n    return processes;\n  }\n\n  // FCFS Scheduling - Non preemptive\n  function fcfsScheduling(processes) {\n    let currentTime = 0;\n    for(let p of processes){\n      if(currentTime < p.arrival) currentTime = p.arrival;\n      p.startTime = currentTime;\n      p.completionTime = currentTime + p.burst;\n      p.turnaroundTime = p.completionTime - p.arrival;\n      p.waitingTime = p.startTime - p.arrival;\n      currentTime = p.completionTime;\n    }\n    return processes;\n  }\n\n  // SJF Non-preemptive\n  function sjfNonPreemptive(processes) {\n    let processList = JSON.parse(JSON.stringify(processes));\n    let n = processList.length;\n    let completed = 0;\n    let currentTime = 0;\n    let isVisited = new Array(n).fill(false);\n\n    while(completed < n){\n      // Find eligible processes arrived by currentTime and not completed\n      let idx = -1;\n      let minBurst = Infinity;\n      for(let i=0; i<n; i++){\n        if(processList[i].arrival <= currentTime && !isVisited[i] && processList[i].burst < minBurst){\n          minBurst = processList[i].burst;\n          idx = i;\n        }\n      }\n      if(idx === -1){\n        // If no process arrived, move time forward\n        currentTime++;\n        continue;\n      }\n      let p = processList[idx];\n      p.startTime = currentTime;\n      p.completionTime = p.startTime + p.burst;\n      p.turnaroundTime = p.completionTime - p.arrival;\n      p.waitingTime = p.startTime - p.arrival;\n      currentTime = p.completionTime;\n      isVisited[idx] = true;\n      completed++;\n    }\n    return processList;\n  }\n\n  // Shortest Remaining Time First (SJF Preemptive)\n  function sjfPreemptive(processes) {\n    let processList = JSON.parse(JSON.stringify(processes));\n    let n = processList.length;\n    let remainingTimes = processList.map(p => p.burst);\n    let completed = 0;\n    let currentTime = 0;\n    let prevProcess = null;\n\n    let startTimes = new Array(n).fill(null);\n    let completionTimes = new Array(n).fill(null);\n\n    while(completed < n){\n      // Find process with shortest remaining time at currentTime\n      let idx = -1;\n      let minRemaining = Infinity;\n      for(let i=0; i<n; i++){\n        if(processList[i].arrival <= currentTime && remainingTimes[i] > 0 && remainingTimes[i] < minRemaining){\n          minRemaining = remainingTimes[i];\n          idx = i;\n        }\n      }\n      if(idx === -1){\n        currentTime++;\n        continue;\n      }\n      if(startTimes[idx] === null) startTimes[idx] = currentTime;\n      // Execute the process for 1 time unit\n      remainingTimes[idx]--;\n      currentTime++;\n\n      // Check completion\n      if(remainingTimes[idx] === 0){\n        completionTimes[idx] = currentTime;\n        completed++;\n      }\n    }\n    // Fill start, completion, waiting and turnaround times\n    for(let i=0; i<n; i++){\n      processList[i].startTime = startTimes[i];\n      processList[i].completionTime = completionTimes[i];\n      processList[i].turnaroundTime = completionTimes[i] - processList[i].arrival;\n      processList[i].waitingTime = processList[i].turnaroundTime - processList[i].burst;\n    }\n    return processList;\n  }\n\n  // Priority Non-preemptive\n  function priorityNonPreemptive(processes) {\n    let processList = JSON.parse(JSON.stringify(processes));\n    let n = processList.length;\n    let completed = 0;\n    let currentTime = 0;\n    let isVisited = new Array(n).fill(false);\n\n    while(completed < n){\n      let idx = -1;\n      let highestPriority = Infinity;\n      for(let i=0; i<n; i++){\n        if(processList[i].arrival <= currentTime && !isVisited[i]){\n          let p = processList[i];\n          if(p.priority === null) {\n            showError(`Priority value required for process ${p.pid}`);\n            return null;\n          }\n          if(p.priority < highestPriority){\n            highestPriority = p.priority;\n            idx = i;\n          } else if(p.priority === highestPriority){\n            // Tie-break on arrival time\n            if(processList[i].arrival < processList[idx].arrival){\n              idx = i;\n            }\n          }\n        }\n      }\n      if(idx === -1){\n        currentTime++;\n        continue;\n      }\n      let p = processList[idx];\n      p.startTime = currentTime;\n      p.completionTime = p.startTime + p.burst;\n      p.turnaroundTime = p.completionTime - p.arrival;\n      p.waitingTime = p.startTime - p.arrival;\n      currentTime = p.completionTime;\n      isVisited[idx] = true;\n      completed++;\n    }\n    return processList;\n  }\n\n  // Priority Preemptive\n  function priorityPreemptive(processes) {\n    let processList = JSON.parse(JSON.stringify(processes));\n    let n = processList.length;\n\n    let remainingTimes = processList.map(p => p.burst);\n    let completed = 0;\n    let currentTime = 0;\n\n    let startTimes = new Array(n).fill(null);\n    let completionTimes = new Array(n).fill(null);\n\n    while(completed < n){\n      // Find highest priority (lowest value) among arrived and remaining processes\n      let idx = -1;\n      let highestPriority = Infinity;\n      for(let i=0; i<n; i++){\n        if(processList[i].arrival <= currentTime && remainingTimes[i] > 0){\n          let p = processList[i];\n          if(p.priority === null){\n            showError(`Priority value required for process ${p.pid}`);\n            return null;\n          }\n          if(p.priority < highestPriority){\n            highestPriority = p.priority;\n            idx = i;\n          } else if(p.priority === highestPriority){\n            // Tie-break on arrival\n            if(processList[i].arrival < processList[idx].arrival){\n              idx = i;\n            }\n          }\n        }\n      }\n\n      if(idx === -1){\n        currentTime++;\n        continue;\n      }\n      if(startTimes[idx] === null) startTimes[idx] = currentTime;\n      remainingTimes[idx]--;\n      currentTime++;\n      if(remainingTimes[idx] === 0){\n        completionTimes[idx] = currentTime;\n        completed++;\n      }\n    }\n\n    for(let i=0; i<n; i++){\n      processList[i].startTime = startTimes[i];\n      processList[i].completionTime = completionTimes[i];\n      processList[i].turnaroundTime = completionTimes[i] - processList[i].arrival;\n      processList[i].waitingTime = processList[i].turnaroundTime - processList[i].burst;\n    }\n    return processList;\n  }\n\n  // Round Robin scheduling\n  function roundRobin(processes, quantum) {\n    const processList = JSON.parse(JSON.stringify(processes));\n    const n = processList.length;\n    const remainingTimes = processList.map(p => p.burst);\n    const arrivalTimes = processList.map(p => p.arrival);\n    const startTimes = new Array(n).fill(null);\n    const completionTimes = new Array(n).fill(null);\n    const queue = [];\n    let currentTime = 0;\n    let completed = 0;\n    let visited = new Array(n).fill(false);\n\n    // Add processes that arrive at time 0 to queue\n    for(let i=0; i<n; i++){\n      if(arrivalTimes[i] <= currentTime){\n        queue.push(i);\n        visited[i] = true;\n      }\n    }\n\n    while(completed < n){\n      if(queue.length === 0){\n        // No process in queue, advance time to next arrival\n        let minArrival = Infinity;\n        let nextIndex = -1;\n        for(let i=0; i<n; i++){\n          if(!visited[i] && arrivalTimes[i] < minArrival){\n            minArrival = arrivalTimes[i];\n            nextIndex = i;\n          }\n        }\n        currentTime = minArrival;\n        queue.push(nextIndex);\n        visited[nextIndex] = true;\n        continue;\n      }\n\n      let i = queue.shift();\n      if(startTimes[i] === null) startTimes[i] = currentTime;\n\n      if(remainingTimes[i] > quantum){\n        currentTime += quantum;\n        remainingTimes[i] -= quantum;\n      } else {\n        currentTime += remainingTimes[i];\n        remainingTimes[i] = 0;\n        completed++;\n        completionTimes[i] = currentTime;\n      }\n      \n      // Add new processes arrived during this quantum\n      for(let j=0; j<n; j++){\n        if(arrivalTimes[j] > (currentTime - quantum) && arrivalTimes[j] <= currentTime && !visited[j]){\n          queue.push(j);\n          visited[j] = true;\n        }\n      }\n      // If process not finished, enqueue again\n      if(remainingTimes[i] > 0){\n        queue.push(i);\n      }\n    }\n\n    for(let i=0; i<n; i++){\n      processList[i].startTime = startTimes[i];\n      processList[i].completionTime = completionTimes[i];\n      processList[i].turnaroundTime = completionTimes[i] - processList[i].arrival;\n      processList[i].waitingTime = processList[i].turnaroundTime - processList[i].burst;\n    }\n    return processList;\n  }\n\n  // Generate Gantt chart blocks data from scheduling results\n  function generateGanttData(processes, algorithm) {\n    // For non-preemptive algorithms, Gantt chart is straightforward:\n    // Use start and completion times in sorted order.\n\n    // For preemptive (SJF preemptive, priority preemptive, RR), we simulate timeline.\n\n    // We'll create a timeline array with entries: {pid, start, end}\n\n    if(['fcfs','sjf','priority'].includes(algorithm)){\n      // Non-preemptive simply display each process duration\n      return processes.map(p => ({pid: p.pid, start: p.startTime, end: p.completionTime}));\n    }\n    \n    // Preemptive algorithms need timeline reconstruction\n\n    // We'll reconstruct timeline by simulating the CPU timeline:\n\n    // For SJF Preemptive (SRTF), Priority Preemptive, and RR we simulate time unit by unit:\n\n    // We'll return an array of segments with pid and time ranges.\n\n    const timeline = [];\n    const burstMap = {};\n    for(const p of processes){\n      burstMap[p.pid] = p.burst;\n    }\n\n    const n = processes.length;\n    let currentTime = 0;\n    const completedCount = new Array(n).fill(false);\n\n    if(algorithm === 'sjfp' || algorithm === 'priorityp'){\n      // We have to simulate step by step:\n      // Build a copy of processes with remaining times\n      let remTimes = processes.map(p => p.burst);\n      let arrivals = processes.map(p => p.arrival);\n      let priorities = processes.map(p => p.priority);\n      let prevPid = null;\n\n      while(true){\n        let idx = -1;\n        let minVal = Infinity;\n        if(algorithm === 'sjfp'){\n          for(let i=0; i<n; i++){\n            if(arrivals[i] <= currentTime && remTimes[i] > 0 && remTimes[i] < minVal){\n              minVal = remTimes[i];\n              idx = i;\n            }\n          }\n        } else {\n          // priorityp\n          let minPriority = Infinity;\n          for(let i=0; i<n; i++){\n            if(arrivals[i] <= currentTime && remTimes[i] > 0){\n              if(priorities[i] < minPriority){\n                minPriority = priorities[i];\n                idx = i;\n              } else if(priorities[i] === minPriority){\n                if(arrivals[i] < arrivals[idx]){\n                  idx = i;\n                }\n              }\n            }\n          }\n        }\n        if(idx === -1){\n          // CPU idle segment\n          if(prevPid !== null){\n            timeline[timeline.length-1].end = currentTime;\n            prevPid = null;\n          }\n          // find next arrival\n          let nextArrival = Infinity;\n          for(let i=0; i<n; i++){\n            if(remTimes[i] > 0 && arrivals[i] > currentTime){\n              nextArrival = Math.min(nextArrival, arrivals[i]);\n            }\n          }\n          if(nextArrival === Infinity) break;\n          currentTime = nextArrival;\n          continue;\n        }\n\n        let pid = processes[idx].pid;\n        if(prevPid !== pid){\n          // start new block\n          timeline.push({pid, start: currentTime, end: currentTime+1});\n          prevPid = pid;\n        } else {\n          // extend current block\n          timeline[timeline.length-1].end++;\n        }\n        remTimes[idx]--;\n        if(remTimes[idx] === 0){\n          completedCount[idx] = true;\n        }\n        currentTime++;\n        if(completedCount.every(e => e)) break;\n      }\n      return timeline;\n    }\n\n    if(algorithm === 'rr'){\n      // Simulate RR to get segments\n      const quantum = Number(quantumInput.value);\n      let remTimes = processes.map(p => p.burst);\n      let arrivals = processes.map(p => p.arrival);\n      let visited = new Array(n).fill(false);\n      let queue = [];\n      let time = 0;\n\n      // Helper to add to gantt timeline\n      function addSegment(pid, start, end){\n        // If last segment pid same, extend, else add new\n        if(timeline.length && timeline[timeline.length-1].pid === pid && timeline[timeline.length-1].end === start){\n          timeline[timeline.length-1].end = end;\n        } else {\n          timeline.push({pid, start, end});\n        }\n      }\n\n      // Enqueue all processes that have arrived at time 0\n      for(let i=0; i<n; i++){\n        if(arrivals[i] <= time){\n          queue.push(i);\n          visited[i] = true;\n        }\n      }\n      if(queue.length === 0){\n        // If no process at 0, jump to earliest arrival\n        let earliestArr = Math.min(...arrivals);\n        time = earliestArr;\n        for(let i=0; i<n; i++){\n          if(arrivals[i] === earliestArr){\n            queue.push(i);\n            visited[i] = true;\n          }\n        }\n      }\n\n      while(queue.length){\n        let i = queue.shift();\n        let startSegment = time;\n        let slice = Math.min(quantum, remTimes[i]);\n        remTimes[i] -= slice;\n        time += slice;\n        addSegment(processes[i].pid, startSegment, time);\n\n        // Enqueue processes that arrived in meantime\n        for(let j=0; j<n; j++){\n          if(!visited[j] && arrivals[j] <= time){\n            queue.push(j);\n            visited[j] = true;\n          }\n        }\n\n        if(remTimes[i] > 0){\n          queue.push(i);\n        }\n      }\n      return timeline;\n    }\n    return [];\n  }\n\n  // Generate color for each process (simple hashing)\n  function processColor(pid) {\n    const colors = [\n      '#007acc', '#e67300', '#009933', '#cc0066',\n      '#663399', '#ff6600', '#008080', '#cc3300',\n      '#666600', '#990099', '#3366cc', '#ff3399'\n    ];\n    let index = 0;\n    for(let i=0; i<pid.length; i++){\n      index += pid.charCodeAt(i);\n    }\n    return colors[index % colors.length];\n  }\n\n  // Render table with processes info\n  function renderResultTable(processes, algorithm) {\n    resultTableBody.innerHTML = '';\n    let totalWaiting = 0;\n    let totalTurnaround = 0;\n    const showPriority = algorithm === 'priority' || algorithm === 'priorityp';\n\n    for(let p of processes){\n      const tr = document.createElement('tr');\n      tr.innerHTML = `<td>${p.pid}</td>\n        <td>${p.arrival}</td>\n        <td>${p.burst}</td>\n        <td class=\"priorityCol\" style=\"display:${showPriority ? '' : 'none'}\">${p.priority !== null && p.priority !== undefined ? p.priority : '-'}</td>\n        <td>${p.startTime}</td>\n        <td>${p.completionTime}</td>\n        <td>${p.waitingTime}</td>\n        <td>${p.turnaroundTime}</td>`;\n      resultTableBody.appendChild(tr);\n      totalWaiting += p.waitingTime;\n      totalTurnaround += p.turnaroundTime;\n    }\n    avgWaitingTimeElem.textContent = (totalWaiting / processes.length).toFixed(2);\n    avgTurnaroundTimeElem.textContent = (totalTurnaround / processes.length).toFixed(2);\n  }\n\n  // Render Gantt chart\n  function renderGanttChart(ganttData) {\n    ganttChart.innerHTML = '';\n    timelineDiv.innerHTML = '';\n    if(ganttData.length === 0) return;\n\n    // Determine total length\n    const totalStart = Math.min(...ganttData.map(d => d.start));\n    const totalEnd = Math.max(...ganttData.map(d => d.end));\n    const totalDuration = totalEnd - totalStart;\n\n    for(let segment of ganttData){\n      const segmentDiv = document.createElement('div');\n      segmentDiv.classList.add('gantt-block');\n      segmentDiv.style.left = ((segment.start - totalStart) / totalDuration * 100) + '%';\n      segmentDiv.style.width = ((segment.end - segment.start) / totalDuration * 100) + '%';\n      segmentDiv.style.backgroundColor = processColor(segment.pid);\n\n      segmentDiv.textContent = segment.pid;\n      segmentDiv.title = `${segment.pid}: ${segment.start} - ${segment.end}`;\n      ganttChart.appendChild(segmentDiv);\n    }\n    // Timeline markers\n    for(let t=totalStart; t<=totalEnd; t++){\n      let label = document.createElement('div');\n      label.style.flex = '1';\n      label.style.textAlign = 'center';\n      label.textContent = t;\n      timelineDiv.appendChild(label);\n    }\n  }\n\n  function runSimulation() {\n    const algorithm = algorithmSelect.value;\n    let quantum = Number(quantumInput.value);\n    if(algorithm === 'rr' && (!quantum || quantum <= 0)){\n      showError(\"Please enter a valid time quantum (> 0) for Round Robin scheduling.\");\n      return;\n    }\n    const processes = parseProcesses(processInput.value);\n    if(!processes) return;\n\n    let scheduledProcesses;\n\n    switch(algorithm){\n      case 'fcfs':\n        scheduledProcesses = fcfsScheduling(processes);\n        break;\n      case 'sjf':\n        scheduledProcesses = sjfNonPreemptive(processes);\n        break;\n      case 'sjfp':\n        scheduledProcesses = sjfPreemptive(processes);\n        break;\n      case 'priority':\n        scheduledProcesses = priorityNonPreemptive(processes);\n        if(scheduledProcesses === null) return;\n        break;\n      case 'priorityp':\n        scheduledProcesses = priorityPreemptive(processes);\n        if(scheduledProcesses === null) return;\n        break;\n      case 'rr':\n        scheduledProcesses = roundRobin(processes, quantum);\n        break;\n      default:\n        showError(\"Unknown algorithm selected.\");\n        return;\n    }\n    renderResultTable(scheduledProcesses, algorithm);\n\n    const ganttData = generateGanttData(scheduledProcesses, algorithm);\n    renderGanttChart(ganttData);\n    resultsDiv.style.display = 'block';\n  }\n\n  function resetAll() {\n    processInput.value = '';\n    resultsDiv.style.display = 'none';\n    resultTableBody.innerHTML = '';\n    avgWaitingTimeElem.textContent = '';\n    avgTurnaroundTimeElem.textContent = '';\n    ganttChart.innerHTML = '';\n    timelineDiv.innerHTML = '';\n  }\n\n  runBtn.addEventListener('click', runSimulation);\n  resetBtn.addEventListener('click', resetAll);\n\n})();\n</script>\n\n</body>\n</html>"
