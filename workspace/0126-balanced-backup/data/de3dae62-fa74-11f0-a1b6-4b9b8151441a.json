    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Abstract Syntax Tree Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n            padding: 10px;\n            font-family: monospace;\n        }\n        button {\n            padding: 8px 16px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            cursor: pointer;\n            font-size: 16px;\n        }\n        button:hover {\n            background-color: #45a049;\n        }\n        #astOutput {\n            border: 1px solid #ddd;\n            padding: 15px;\n            background-color: #f9f9f9;\n            white-space: pre-wrap;\n            font-family: monospace;\n            min-height: 200px;\n        }\n        .node {\n            margin-left: 20px;\n        }\n        .node-type {\n            font-weight: bold;\n            color: #0066cc;\n        }\n        .node-value {\n            color: #009933;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Abstract Syntax Tree Demo</h1>\n        <p>Enter a simple JavaScript expression below to see its AST representation:</p>\n        \n        <textarea id=\"codeInput\" placeholder=\"Enter JavaScript code (e.g., 2 + 3 * 5)\">2 + 3 * 5</textarea>\n        \n        <button id=\"parseButton\">Generate AST</button>\n        \n        <h2>AST Output:</h2>\n        <div id=\"astOutput\">Click \"Generate AST\" to see the tree structure of your code.</div>\n    </div>\n\n    <script>\n        document.getElementById('parseButton').addEventListener('click', function() {\n            const code = document.getElementById('codeInput').value.trim();\n            if (!code) {\n                alert('Please enter some JavaScript code');\n                return;\n            }\n\n            try {\n                // Simple AST parser for basic expressions\n                const ast = parseExpression(code);\n                displayAST(ast);\n            } catch (e) {\n                document.getElementById('astOutput').textContent = 'Error: ' + e.message;\n            }\n        });\n\n        // Simple tokenizer\n        function tokenize(code) {\n            const tokens = [];\n            let current = 0;\n            \n            while (current < code.length) {\n                let char = code[current];\n                \n                // Skip whitespace\n                if (/\\s/.test(char)) {\n                    current++;\n                    continue;\n                }\n                \n                // Handle numbers\n                if (/[0-9]/.test(char)) {\n                    let value = '';\n                    while (/[0-9]/.test(code[current])) {\n                        value += code[current];\n                        current++;\n                    }\n                    tokens.push({ type: 'NUMBER', value });\n                    continue;\n                }\n                \n                // Handle operators\n                if (/[\\+\\-\\*\\/]/.test(char)) {\n                    tokens.push({ type: 'OPERATOR', value: char });\n                    current++;\n                    continue;\n                }\n                \n                throw new Error(`Unknown character: ${char}`);\n            }\n            \n            return tokens;\n        }\n\n        // Simple parser for basic arithmetic expressions\n        function parseExpression(code) {\n            const tokens = tokenize(code);\n            let current = 0;\n            \n            function walk() {\n                let token = tokens[current];\n                \n                // Handle numbers\n                if (token.type === 'NUMBER') {\n                    current++;\n                    return {\n                        type: 'NumberLiteral',\n                        value: token.value\n                    };\n                }\n                \n                // Handle binary expressions\n                if (token.type === 'OPERATOR') {\n                    const operator = token.value;\n                    current++;\n                    \n                    const left = walk();\n                    const right = walk();\n                    \n                    return {\n                        type: 'BinaryExpression',\n                        operator,\n                        left,\n                        right\n                    };\n                }\n                \n                throw new Error(`Unknown token type: ${token.type}`);\n            }\n            \n            return walk();\n        }\n\n        // Display the AST in a readable format\n        function displayAST(node, indent = 0) {\n            const output = document.getElementById('astOutput');\n            let html = '';\n            \n            function traverse(node, depth) {\n                const indentStr = '&nbsp;'.repeat(depth * 4);\n                \n                if (node.type === 'NumberLiteral') {\n                    html += `${indentStr}<span class=\"node-type\">NumberLiteral</span>: <span class=\"node-value\">${node.value}</span><br>`;\n                } else if (node.type === 'BinaryExpression') {\n                    html += `${indentStr}<span class=\"node-type\">BinaryExpression</span> (${node.operator}):<br>`;\n                    html += `${indentStr}<div class=\"node\">`;\n                    traverse(node.left, depth + 1);\n                    traverse(node.right, depth + 1);\n                    html += `${indentStr}</div>`;\n                }\n            }\n            \n            traverse(node, 0);\n            output.innerHTML = html;\n        }\n    </script>\n</body>\n</html>"
