    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bucket Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin: 20px;\n        }\n        .array-container {\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            margin: 20px 0;\n        }\n        .bar {\n            width: 30px;\n            margin: 0 5px;\n            background-color: teal;\n            display: inline-block;\n            transition: height 0.2s;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Bucket Sort Visualization</h1>\n<button onclick=\"startBucketSort()\">Sort Array</button>\n<div class=\"array-container\" id=\"array-container\"></div>\n\n<script>\n    const array = [0.78, 0.17, 0.39, 0.26, 0.72, 0.94, 0.21, 0.12, 0.55, 0.89];\n\n    function renderArray(arr) {\n        const container = document.getElementById('array-container');\n        container.innerHTML = '';\n        arr.forEach(value => {\n            const bar = document.createElement('div');\n            bar.className = 'bar';\n            bar.style.height = `${value * 300}px`; // Scale the height for better visibility\n            container.appendChild(bar);\n        });\n    }\n\n    function bucketSort(arr) {\n        const buckets = Array.from({ length: 10 }, () => []);\n\n        // Distributing values into buckets\n        arr.forEach((value) => {\n            const index = Math.floor(value * 10);\n            buckets[index].push(value);\n        });\n\n        // Sorting each bucket and concatenating\n        return buckets.flatMap(bucket => bucket.sort((a, b) => a - b));\n    }\n\n    function startBucketSort() {\n        renderArray(array);\n        const sortedArray = bucketSort(array);\n        renderArray(sortedArray);\n    }\n\n    // Initial render\n    renderArray(array);\n</script>\n\n</body>\n</html>"
