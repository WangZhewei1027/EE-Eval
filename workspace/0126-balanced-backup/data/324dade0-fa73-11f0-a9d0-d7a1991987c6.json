    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interpolation Search Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        input[type=\"number\"] {\n            width: 50px;\n        }\n        table {\n            margin-top: 20px;\n            border-collapse: collapse;\n            width: 100%;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: center;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interpolation Search Demo</h1>\n    <p>Enter a sorted array and the number to search for:</p>\n    \n    <textarea id=\"arrayInput\" rows=\"4\" cols=\"50\" placeholder=\"Enter sorted numbers separated by commas\"></textarea><br><br>\n    <input type=\"number\" id=\"searchValue\" placeholder=\"Search for...\" />\n    <button onclick=\"performSearch()\">Search</button>\n\n    <h3 id=\"result\"></h3>\n\n    <h2>Steps:</h2>\n    <table id=\"stepTable\">\n        <thead>\n            <tr>\n                <th>Step</th>\n                <th>Low</th>\n                <th>High</th>\n                <th>Probe Index</th>\n                <th>Current Value</th></tr>\n        </thead>\n        <tbody></tbody>\n    </table>\n\n    <script>\n        function interpolationSearch(arr, x) {\n            let low = 0;\n            let high = arr.length - 1;\n            let steps = [];\n\n            while (low <= high && x >= arr[low] && x <= arr[high]) {\n                // Calculate probe position\n                let probeIndex = low + Math.floor(((high - low) / (arr[high] - arr[low])) * (x - arr[low]));\n\n                // Log step\n                steps.push({step: steps.length + 1, low: low, high: high, probeIndex: probeIndex, currentValue: arr[probeIndex]});\n\n                // If we found the element\n                if (arr[probeIndex] === x) {\n                    return {index: probeIndex, steps: steps};\n                }\n\n                // If x is larger, x is in upper part\n                if (arr[probeIndex] < x) {\n                    low = probeIndex + 1;\n                }\n                // If x is smaller, x is in lower part\n                else {\n                    high = probeIndex - 1;\n                }\n            }\n\n            // Element not found\n            return {index: -1, steps: steps};\n        }\n\n        function performSearch() {\n            const input = document.getElementById(\"arrayInput\").value;\n            const searchValue = parseInt(document.getElementById(\"searchValue\").value);\n            const resultElement = document.getElementById(\"result\");\n            const stepTableBody = document.getElementById(\"stepTable\").querySelector(\"tbody\");\n            stepTableBody.innerHTML = '';\n\n            const arr = input.split(',').map(Number).sort((a, b) => a - b);\n            const searchResult = interpolationSearch(arr, searchValue);\n\n            if (searchResult.index !== -1) {\n                resultElement.textContent = `Found ${searchValue} at index: ${searchResult.index}`;\n            } else {\n                resultElement.textContent = `${searchValue} not found.`;\n            }\n\n            searchResult.steps.forEach(step => {\n                let row = document.createElement(\"tr\");\n                row.innerHTML = `<td>${step.step}</td><td>${step.low}</td><td>${step.high}</td><td>${step.probeIndex}</td><td>${step.currentValue}</td>`;\n                stepTableBody.appendChild(row);\n            });\n        }\n    </script>\n</body>\n</html>"
