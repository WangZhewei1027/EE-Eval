    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>ACID Properties Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        h1, h2 {\n            color: #2c3e50;\n        }\n        .property {\n            background-color: #f8f9fa;\n            border-left: 4px solid #3498db;\n            padding: 15px;\n            margin-bottom: 20px;\n            border-radius: 0 4px 4px 0;\n        }\n        .atomicity { border-color: #e74c3c; }\n        .consistency { border-color: #2ecc71; }\n        .isolation { border-color: #f39c12; }\n        .durability { border-color: #9b59b6; }\n        button {\n            background-color: #3498db;\n            color: white;\n            border: none;\n            padding: 8px 16px;\n            border-radius: 4px;\n            cursor: pointer;\n            margin: 5px;\n        }\n        button:hover {\n            background-color: #2980b9;\n        }\n        #transactionLog {\n            border: 1px solid #ddd;\n            padding: 10px;\n            height: 150px;\n            overflow-y: scroll;\n            margin-top: 20px;\n            background-color: #f8f9fa;\n        }\n        .success { color: #2ecc71; }\n        .failure { color: #e74c3c; }\n    </style>\n</head>\n<body>\n    <h1>ACID Properties in Database Transactions</h1>\n    <p>ACID (Atomicity, Consistency, Isolation, Durability) is a set of properties that guarantee database transactions are processed reliably.</p>\n    \n    <div class=\"property atomicity\">\n        <h2>Atomicity</h2>\n        <p>Transactions are treated as a single \"unit\" which either completes fully or not at all.</p>\n        <button onclick=\"demoAtomicity(true)\">Successful Atomic Transaction</button>\n        <button onclick=\"demoAtomicity(false)\">Failed Atomic Transaction</button>\n        <div id=\"atomicityResult\"></div>\n    </div>\n    \n    <div class=\"property consistency\">\n        <h2>Consistency</h2>\n        <p>A transaction brings the database from one valid state to another, maintaining all defined rules.</p>\n        <button onclick=\"demoConsistency()\">Demonstrate Consistency</button>\n        <div id=\"consistencyResult\"></div>\n    </div>\n    \n    <div class=\"property isolation\">\n        <h2>Isolation</h2>\n        <p>Concurrent transactions execute as if they were sequential, preventing interference.</p>\n        <button onclick=\"demoIsolation()\">Demonstrate Isolation</button>\n        <div id=\"isolationResult\"></div>\n    </div>\n    \n    <div class=\"property durability\">\n        <h2>Durability</h2>\n        <p>Once a transaction is committed, it remains committed even in the event of a system failure.</p>\n        <button onclick=\"demoDurability()\">Demonstrate Durability</button>\n        <div id=\"durabilityResult\"></div>\n    </div>\n    \n    <h2>Transaction Log</h2>\n    <div id=\"transactionLog\"></div>\n    \n    <script>\n        let accountBalance = 1000;\n        let transactionId = 1;\n        const transactionLog = document.getElementById('transactionLog');\n        \n        function logTransaction(message, isSuccess) {\n            const entry = document.createElement('div');\n            entry.innerHTML = `#${transactionId++}: ${message}`;\n            entry.className = isSuccess ? 'success' : 'failure';\n            transactionLog.appendChild(entry);\n            transactionLog.scrollTop = transactionLog.scrollHeight;\n        }\n        \n        // Atomicity Demo\n        function demoAtomicity(success) {\n            const resultDiv = document.getElementById('atomicityResult');\n            resultDiv.innerHTML = '<p>Starting funds transfer transaction...</p>';\n            \n            try {\n                // Begin transaction\n                resultDiv.innerHTML += '<p>1. Withdrawing $200 from Account A</p>';\n                if (!success) throw new Error(\"Network failure during transfer\");\n                \n                resultDiv.innerHTML += '<p>2. Depositing $200 to Account B</p>';\n                \n                // Commit transaction\n                resultDiv.innerHTML += '<p class=\"success\">Transaction committed successfully!</p>';\n                logTransaction('Funds transfer completed atomically', true);\n            } catch (error) {\n                // Rollback transaction\n                resultDiv.innerHTML += `<p class=\"failure\">Error: ${error.message}</p>`;\n                resultDiv.innerHTML += '<p class=\"failure\">Rolling back transaction...</p>';\n                resultDiv.innerHTML += '<p class=\"failure\">Transaction failed - no changes applied</p>';\n                logTransaction('Funds transfer failed and was rolled back', false);\n            }\n        }\n        \n        // Consistency Demo\n        function demoConsistency() {\n            const resultDiv = document.getElementById('consistencyResult');\n            resultDiv.innerHTML = '<p>Current account balance: $' + accountBalance + '</p>';\n            \n            try {\n                const amount = 200;\n                resultDiv.innerHTML += `<p>Attempting to withdraw $${amount}...</p>`;\n                \n                if (amount > accountBalance) {\n                    throw new Error(\"Insufficient funds - violates account balance constraint\");\n                }\n                \n                accountBalance -= amount;\n                resultDiv.innerHTML += `<p class=\"success\">Withdrawal successful! New balance: $${accountBalance}</p>`;\n                logTransaction(`Withdrew $${amount} - maintained consistency`, true);\n            } catch (error) {\n                resultDiv.innerHTML += `<p class=\"failure\">${error.message}</p>`;\n                resultDiv.innerHTML += '<p class=\"failure\">Account balance remains unchanged</p>';\n                logTransaction('Withdrawal rejected to maintain consistency', false);\n            }\n        }\n        \n        // Isolation Demo\n        function demoIsolation() {\n            const resultDiv = document.getElementById('isolationResult');\n            resultDiv.innerHTML = '<p>Starting concurrent transactions...</p>';\n            \n            // Transaction 1 (reads balance)\n            resultDiv.innerHTML += '<p>Transaction 1 reads balance: $' + accountBalance + '</p>';\n            \n            // Simulate Transaction 2 updating balance concurrently\n            const originalBalance = accountBalance;\n            accountBalance += 300;\n            logTransaction('Transaction 2 deposited $300', true);\n            \n            // Transaction 1 continues with its original read value\n            resultDiv.innerHTML += '<p>Transaction 1 continues working with original value: $' + originalBalance + '</p>';\n            resultDiv.innerHTML += '<p>Transaction 1 is isolated from Transaction 2\\'s changes until commit</p>';\n        }\n        \n        // Durability Demo\n        function demoDurability() {\n            const resultDiv = document.getElementById('durabilityResult');\n            resultDiv.innerHTML = '<p>Committing transaction to database...</p>';\n            \n            setTimeout(() => {\n                resultDiv.innerHTML += '<p class=\"success\">Transaction committed to persistent storage</p>';\n                resultDiv.innerHTML += '<p>Simulating system crash...</p>';\n                \n                setTimeout(() => {\n                    resultDiv.innerHTML += '<p class=\"success\">After recovery: Transaction remains committed</p>';\n                    logTransaction('Transaction persisted despite system failure', true);\n                }, 1000);\n            }, 1000);\n        }\n    </script>\n</body>\n</html>"
  },
