  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>SVM (Support Vector Machine) Interactive Demo</title>\n  <style>\n    body { font-family: Arial, sans-serif; margin: 12px; }\n    #top { display:flex; gap:12px; align-items:flex-start; }\n    #controls { width: 340px; }\n    canvas { border:1px solid #ccc; background: #fafafa; cursor: crosshair; }\n    .btn { padding:6px 10px; margin:4px 2px; cursor:pointer; }\n    .info { font-size: 13px; color:#333; margin-top:8px; }\n    label { display:block; margin-top:8px; font-size:13px; }\n    input[type=range] { width:180px; vertical-align: middle; }\n    .small { font-size:12px; color:#555; }\n    .legend { display:flex; gap:8px; margin-top:8px; align-items:center; }\n    .swatch { width:14px; height:14px; display:inline-block; border-radius:3px; border:1px solid #999; }\n  </style>\n</head>\n<body>\n  <h2>Support Vector Machine — Interactive Demonstration (Pegasos SGD)</h2>\n  <div id=\"top\">\n    <div id=\"controls\">\n      <div>\n        <strong>How to use</strong>\n        <div class=\"small info\">\n          - Click on the canvas to add points. Use \"Class\" buttons to pick label.<br>\n          - Press \"Train\" to run the SVM learner (Pegasos). \"Epochs\" controls training iterations.<br>\n          - Toggle \"Auto-train\" to update continuously while adding points.<br>\n          - \"Random dataset\" generates sample data; \"Clear\" removes all points.<br>\n          - Support vectors are highlighted with black outlines when hinge loss is active (y*(w·x+b) ≤ 1).\n        </div>\n      </div>\n\n      <label>Class:\n        <button id=\"class-pos\" class=\"btn\" style=\"background:#ff8080;\">Positive (red)</button>\n        <button id=\"class-neg\" class=\"btn\" style=\"background:#80b3ff;\">Negative (blue)</button>\n      </label>\n\n      <label>Training controls:\n        <div style=\"margin-top:6px;\">\n          <button id=\"train\" class=\"btn\">Train</button>\n          <button id=\"auto\" class=\"btn\">Auto-train: off</button>\n          <button id=\"clear\" class=\"btn\">Clear</button>\n          <button id=\"random-sep\" class=\"btn\">Random (separable)</button>\n          <button id=\"random-mix\" class=\"btn\">Random (mixed)</button>\n        </div>\n      </label>\n\n      <label>Epochs: <span id=\"epoch-val\">200</span>\n        <input id=\"epochs\" type=\"range\" min=\"10\" max=\"2000\" step=\"10\" value=\"200\">\n      </label>\n\n      <label>Lambda (regularization): <span id=\"lambda-val\">0.02</span>\n        <input id=\"lambda\" type=\"range\" min=\"0.001\" max=\"0.2\" step=\"0.001\" value=\"0.02\">\n      </label>\n\n      <label>Mini-batch size: <span id=\"batch-val\">10</span>\n        <input id=\"batch\" type=\"range\" min=\"1\" max=\"50\" step=\"1\" value=\"10\">\n      </label>\n\n      <div class=\"legend\">\n        <div style=\"display:flex; gap:8px; align-items:center;\">\n          <div class=\"swatch\" style=\"background:#ff8080\"></div> Positive (y = +1)\n        </div>\n        <div style=\"display:flex; gap:8px; align-items:center;\">\n          <div class=\"swatch\" style=\"background:#80b3ff\"></div> Negative (y = -1)\n        </div>\n      </div>\n\n      <div class=\"info\">\n        <div id=\"stats\"></div>\n      </div>\n    </div>\n\n    <div>\n      <canvas id=\"plot\" width=\"600\" height=\"600\"></canvas>\n      <div style=\"margin-top:8px; font-size:12px; color:#444;\">\n        Click on canvas to add a point. Shift+Click toggles class for that click only.\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  SVM Interactive Demo (single-file)\n  - Uses the Pegasos algorithm (stochastic gradient) to train a linear SVM.\n  - Points are in normalized coordinates [-1, 1].\n  - Objective minimized: (lambda/2)||w||^2 + (1/n) sum_i max(0, 1 - y_i*(w·x_i + b))\n  - Support vectors (active hinge loss) are those with y*(w·x + b) <= 1 + tol.\n  - Visualization: decision boundary f(x)=w·x+b=0, margin lines f(x)=±1.\n*/\n\nconst canvas = document.getElementById('plot');\nconst ctx = canvas.getContext('2d');\nconst W = canvas.width, H = canvas.height;\nconst MARGIN = 20;\n\nlet points = []; // {x,y,label} x,y in [-1,1], label in {+1,-1}\nlet currentLabel = +1;\nlet autoTrain = false;\n\nlet params = {\n  epochs: 200,\n  lambda: 0.02,\n  batch: 10\n};\n\nlet model = { w: [0,0], b: 0 };\n\n// UI elements\nconst classPosBtn = document.getElementById('class-pos');\nconst classNegBtn = document.getElementById('class-neg');\nconst trainBtn = document.getElementById('train');\nconst autoBtn = document.getElementById('auto');\nconst clearBtn = document.getElementById('clear');\nconst randomSepBtn = document.getElementById('random-sep');\nconst randomMixBtn = document.getElementById('random-mix');\nconst epochsSlider = document.getElementById('epochs');\nconst lambdaSlider = document.getElementById('lambda');\nconst batchSlider = document.getElementById('batch');\nconst epochVal = document.getElementById('epoch-val');\nconst lambdaVal = document.getElementById('lambda-val');\nconst batchVal = document.getElementById('batch-val');\nconst statsDiv = document.getElementById('stats');\n\nfunction toCanvasX(x) { return MARGIN + (x + 1) * (W - 2*MARGIN) / 2; }\nfunction toCanvasY(y) { return MARGIN + (1 - (y + 1)/2) * (H - 2*MARGIN); }\nfunction fromCanvasX(cx) { return ((cx - MARGIN) / (W - 2*MARGIN)) * 2 - 1; }\nfunction fromCanvasY(cy) { return ((1 - (cy - MARGIN) / (H - 2*MARGIN))) * 2 - 1; }\n\nfunction draw() {\n  ctx.clearRect(0,0,W,H);\n  drawAxes();\n  drawDecisionBoundary();\n  drawPoints();\n}\n\nfunction drawAxes() {\n  ctx.save();\n  ctx.strokeStyle = '#e0e0e0';\n  ctx.lineWidth = 1;\n  ctx.beginPath();\n  // grid\n  for(let i=-8;i<=8;i++){\n    let x = toCanvasX(i/8);\n    ctx.moveTo(x,MARGIN);\n    ctx.lineTo(x,H-MARGIN);\n    let y = toCanvasY(i/8);\n    ctx.moveTo(MARGIN,y);\n    ctx.lineTo(W-MARGIN,y);\n  }\n  ctx.stroke();\n  // border\n  ctx.strokeStyle = '#ccc';\n  ctx.strokeRect(MARGIN, MARGIN, W-2*MARGIN, H-2*MARGIN);\n  ctx.restore();\n}\n\nfunction drawPoints() {\n  const w = model.w, b = model.b;\n  const norm = Math.hypot(w[0], w[1]) || 1;\n  const tol = 1e-6;\n  for (let p of points) {\n    const cx = toCanvasX(p.x), cy = toCanvasY(p.y);\n    // compute hinge condition\n    const f = p.label * (w[0]*p.x + w[1]*p.y + b);\n    const isSupport = (f <= 1 + 1e-3); // active hinge loss\n    ctx.beginPath();\n    ctx.fillStyle = p.label > 0 ? '#ff8080' : '#80b3ff';\n    ctx.strokeStyle = isSupport ? '#000' : '#666';\n    ctx.lineWidth = isSupport ? 2.5 : 1;\n    ctx.arc(cx, cy, isSupport ? 7 : 6, 0, Math.PI*2);\n    ctx.fill();\n    ctx.stroke();\n\n    // small inner dot\n    ctx.beginPath();\n    ctx.fillStyle = '#fff';\n    ctx.arc(cx, cy, 2.2, 0, Math.PI*2);\n    ctx.fill();\n  }\n}\n\nfunction drawDecisionBoundary() {\n  const w = model.w, b = model.b;\n  // if all-zero, nothing to draw\n  if (Math.abs(w[0])<1e-9 && Math.abs(w[1])<1e-9 && Math.abs(b)<1e-9) return;\n  // compute intersection with canvas square in normalized coords [-1,1]\n  const lines = [0,1,-1].map(val => ({a:w[0], b:w[1], c:b - val})); // we will draw for val = 0 (decision), ±1 (margins)\n  const colors = ['#222', '#444', '#444'];\n  const dashes = [[], [6,6], [6,6]];\n  for (let idx=0; idx<lines.length; idx++) {\n    const L = lines[idx];\n    const pts = [];\n    const eps = 1e-9;\n    // intersect line a*x + b*y + c = 0 with each of four boundaries x=-1,x=1,y=-1,y=1\n    if (Math.abs(L.b) > eps) {\n      // x = -1\n      let y = -(L.a * (-1) + L.c) / L.b;\n      if (y>=-1-1e-6 && y<=1+1e-6) pts.push({x:-1,y:y});\n      // x = 1\n      y = -(L.a * (1) + L.c) / L.b;\n      if (y>=-1-1e-6 && y<=1+1e-6) pts.push({x:1,y:y});\n    }\n    if (Math.abs(L.a) > eps) {\n      // y = -1\n      let x = -(L.b * (-1) + L.c) / L.a;\n      if (x>=-1-1e-6 && x<=1+1e-6) pts.push({x:x,y:-1});\n      // y = 1\n      x = -(L.b * (1) + L.c) / L.a;\n      if (x>=-1-1e-6 && x<=1+1e-6) pts.push({x:x,y:1});\n    }\n    if (pts.length >= 2) {\n      const p0 = pts[0], p1 = pts[1];\n      ctx.save();\n      ctx.beginPath();\n      ctx.moveTo(toCanvasX(p0.x), toCanvasY(p0.y));\n      ctx.lineTo(toCanvasX(p1.x), toCanvasY(p1.y));\n      ctx.strokeStyle = colors[idx];\n      ctx.lineWidth = idx===0 ? 2 : 1.5;\n      if (dashes[idx].length) ctx.setLineDash(dashes[idx]);\n      else ctx.setLineDash([]);\n      ctx.stroke();\n      ctx.restore();\n    }\n  }\n}\n\ncanvas.addEventListener('click', (ev) => {\n  const rect = canvas.getBoundingClientRect();\n  const cx = ev.clientX - rect.left;\n  const cy = ev.clientY - rect.top;\n  const x = fromCanvasX(cx);\n  const y = fromCanvasY(cy);\n  // If shift pressed, invert class for this click\n  const label = ev.shiftKey ? -currentLabel : currentLabel;\n  points.push({x:x, y:y, label: label});\n  if (autoTrain) trainAndDraw();\n  else draw();\n});\n\nclassPosBtn.addEventListener('click', () => { currentLabel = +1; classPosBtn.style.boxShadow='inset 0 0 0 2px #900'; classNegBtn.style.boxShadow=''; });\nclassNegBtn.addEventListener('click', () => { currentLabel = -1; classNegBtn.style.boxShadow='inset 0 0 0 2px #045'; classPosBtn.style.boxShadow=''; });\nclassPosBtn.click();\n\ntrainBtn.addEventListener('click', () => trainAndDraw());\nautoBtn.addEventListener('click', () => {\n  autoTrain = !autoTrain;\n  autoBtn.textContent = 'Auto-train: ' + (autoTrain ? 'on' : 'off');\n  if (autoTrain) trainAndDraw();\n});\n\nclearBtn.addEventListener('click', () => { points = []; model = {w:[0,0], b:0}; draw(); updateStats(); });\nrandomSepBtn.addEventListener('click', () => {\n  points = generateRandom(40, true); model = {w:[0,0], b:0}; if (autoTrain) trainAndDraw(); else draw(); updateStats();\n});\nrandomMixBtn.addEventListener('click', () => {\n  points = generateRandom(40, false); model = {w:[0,0], b:0}; if (autoTrain) trainAndDraw(); else draw(); updateStats();\n});\n\nepochsSlider.addEventListener('input', () => { params.epochs = parseInt(epochsSlider.value); epochVal.textContent = params.epochs; });\nlambdaSlider.addEventListener('input', () => { params.lambda = parseFloat(lambdaSlider.value); lambdaVal.textContent = params.lambda; });\nbatchSlider.addEventListener('input', () => { params.batch = parseInt(batchSlider.value); batchVal.textContent = params.batch; });\n\nfunction trainAndDraw() {\n  if (points.length === 0) { draw(); updateStats(); return; }\n  pegasosTrain(points, params.epochs, params.lambda, params.batch, model);\n  draw();\n  updateStats();\n}\n\nfunction updateStats() {\n  if (points.length === 0) {\n    statsDiv.innerHTML = '<em>No points</em>';\n    return;\n  }\n  const w = model.w, b = model.b;\n  let correct = 0;\n  let hinge = 0;\n  for (let p of points) {\n    const val = p.label * (w[0]*p.x + w[1]*p.y + b);\n    if (val > 0) correct++;\n    hinge += Math.max(0, 1 - val);\n  }\n  hinge /= points.length;\n  const acc = Math.round(100 * correct / points.length);\n  // margin: based on SVM primal scaling, margin lines at f(x)=±1. margin distance = min_i y*(w·x+b)/||w||\n  const norm = Math.hypot(w[0], w[1]) || 1e-9;\n  let minv = Infinity;\n  for (let p of points) {\n    minv = Math.min(minv, p.label * (w[0]*p.x + w[1]*p.y + b) / norm);\n  }\n  const marginText = (minv === Infinity ? 'N/A' : (minv < 0 ? 'No positive margin (not separable)' : minv.toFixed(3)));\n  statsDiv.innerHTML = `\n    Points: ${points.length} • Accuracy: ${acc}% • Hinge loss: ${hinge.toFixed(3)} • Margin: ${marginText}<br>\n    w = [${w[0].toFixed(3)}, ${w[1].toFixed(3)}] • b = ${b.toFixed(3)} • lambda = ${params.lambda}\n  `;\n}\n\n// Pegasos algorithm implementation (with bias)\nfunction pegasosTrain(data, epochs, lambda, batchSize, modelRef) {\n  // copy current model to start from\n  let w = [modelRef.w[0], modelRef.w[1]];\n  let b = modelRef.b;\n  const n = data.length;\n  const rand = (a,b) => a + Math.random()*(b-a);\n\n  let t = 0;\n  for (let epoch=0; epoch<epochs; epoch++) {\n    // shuffle indices\n    const indices = [];\n    for (let i=0;i<n;i++) indices.push(i);\n    for (let i=n-1;i>0;i--) {\n      const j = Math.floor(Math.random()* (i+1));\n      [indices[i], indices[j]] = [indices[j], indices[i]];\n    }\n    for (let start=0; start<n; start += batchSize) {\n      t++;\n      const eta = 1 / (lambda * t);\n      const batch = indices.slice(start, Math.min(start+batchSize, n));\n      // find set A_t of examples in batch that violate margin\n      let A = [];\n      for (let idx of batch) {\n        const p = data[idx];\n        const val = p.label * (w[0]*p.x + w[1]*p.y + b);\n        if (val < 1) A.push(idx);\n      }\n      // shrink w\n      w[0] *= (1 - eta*lambda);\n      w[1] *= (1 - eta*lambda);\n      // gradient step from violating examples\n      if (A.length > 0) {\n        let gx = 0, gy = 0, gb = 0;\n        for (let idx of A) {\n          const p = data[idx];\n          gx += p.label * p.x;\n          gy += p.label * p.y;\n          gb += p.label;\n        }\n        const coeff = eta / A.length;\n        w[0] += coeff * gx;\n        w[1] += coeff * gy;\n        b += coeff * gb;\n      }\n      // projection step for w to ensure ||w|| <= 1/sqrt(lambda)\n      const normw = Math.hypot(w[0], w[1]);\n      const maxnorm = 1 / Math.sqrt(lambda);\n      if (normw > maxnorm) {\n        const scale = maxnorm / normw;\n        w[0] *= scale; w[1] *= scale;\n      }\n    }\n  }\n  modelRef.w[0] = w[0]; modelRef.w[1] = w[1]; modelRef.b = b;\n}\n\n// generate random dataset (two Gaussian blobs). If separable = true, separate clusters well.\nfunction generateRandom(n, separable) {\n  const pts = [];\n  const cx1 = separable ? -0.6 : -0.3;\n  const cx2 = separable ? 0.6 : 0.3;\n  const cy1 = separable ? -0.2 : -0.2;\n  const cy2 = separable ? 0.2 : 0.2;\n  const s = separable ? 0.12 : 0.28;\n  for (let i=0;i<n/2;i++) {\n    pts.push({ x: cx1 + (randomNormal()*s), y: cy1 + (randomNormal()*s), label: +1 });\n  }\n  for (let i=0;i<n/2;i++) {\n    pts.push({ x: cx2 + (randomNormal()*s), y: cy2 + (randomNormal()*s), label: -1 });\n  }\n  return pts;\n}\n\n// simple normal sampler (Box-Muller)\nfunction randomNormal() {\n  let u = 0, v = 0;\n  while(u === 0) u = Math.random();\n  while(v === 0) v = Math.random();\n  return Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);\n}\n\n// initial draw and some example points\npoints = generateRandom(30, true);\ndraw();\nupdateStats();\n\n</script>\n</body>\n</html>"
