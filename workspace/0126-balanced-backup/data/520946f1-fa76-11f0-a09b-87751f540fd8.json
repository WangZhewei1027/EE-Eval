    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Dijkstra's Algorithm</title>\n    <style>\n        #graph {\n            border: 1px solid black;\n            width: 800px;\n            height: 600px;\n            margin: 50px auto;\n        }\n    </style>\n</head>\n<body>\n    <h1>Dijkstra's Algorithm</h1>\n    <canvas id=\"graph\"></canvas>\n    <script>\n        let graph = {\n            'A': {'B': 1, 'C': 4, 'D': 7},\n            'B': {'A': 1, 'C': 2, 'D': 5},\n            'C': {'A': 4, 'B': 2, 'D': 1},\n            'D': {'A': 7, 'B': 5, 'C': 1}\n        };\n\n        function dijkstra(graph, start) {\n            let distances = {};\n            let unvisited = Object.keys(graph);\n            distances[start] = 0;\n\n            while (unvisited.length > 0) {\n                let minDistance = Infinity;\n                let minNode = null;\n\n                for (let node of unvisited) {\n                    if (distances[node] < minDistance) {\n                        minDistance = distances[node];\n                        minNode = node;\n                    }\n                }\n\n                unvisited.splice(unvisited.indexOf(minNode), 1);\n\n                for (let neighbor in graph[minNode]) {\n                    let distance = graph[minNode][neighbor];\n                    let newDistance = distances[minNode] + distance;\n\n                    if (newDistance < distances[neighbor]) {\n                        distances[neighbor] = newDistance;\n                    }\n                }\n            }\n\n            return distances;\n        }\n\n        let startNode = 'A';\n        let distances = dijkstra(graph, startNode);\n\n        let node = Object.keys(distances).map(node => [node, distances[node]]).sort((a, b) => a[1] - b[1])[0][0];\n        let shortestPath = dijkstra(graph, node);\n\n        console.log(\"Shortest distances from\", startNode, \":\", distances);\n        console.log(\"Shortest path:\", shortestPath);\n    </script>\n</body>\n</html>"
