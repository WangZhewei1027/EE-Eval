    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>OSI Model Interactive Demo</title>\n<style>\n  body {\n    font-family: \"Segoe UI\", Tahoma, Geneva, Verdana, sans-serif;\n    margin: 0;\n    background: #f0f4f8;\n    color: #333;\n    display: flex;\n    flex-direction: column;\n    min-height: 100vh;\n  }\n  header {\n    background: #004d99;\n    color: white;\n    padding: 1rem 2rem;\n    text-align: center;\n  }\n  main {\n    flex: 1;\n    max-width: 900px;\n    margin: 2rem auto;\n    padding: 0 1rem;\n  }\n  h1 {\n    margin-bottom: 0.25em;\n  }\n  p.description {\n    max-width: 600px;\n    margin-bottom: 2rem;\n    font-size: 1.1rem;\n    line-height: 1.5;\n  }\n  #osi-model {\n    display: flex;\n    flex-direction: column;\n    gap: 1rem;\n    max-width: 600px;\n    margin: 0 auto 3rem auto;\n  }\n  .layer {\n    cursor: pointer;\n    padding: 1rem 1.5rem;\n    border-radius: 8px;\n    background: #e7ebf0;\n    border: 2px solid transparent;\n    box-shadow: 0 2px 6px rgb(0 0 0 / 0.1);\n    transition:\n      background-color 0.3s ease,\n      border-color 0.3s ease,\n      box-shadow 0.3s ease;\n    user-select: none;\n  }\n  .layer:hover {\n    background-color: #d0d7e8;\n  }\n  .layer.selected {\n    background-color: #004d99;\n    border-color: #003366;\n    color: white;\n    box-shadow: 0 0 10px #003366;\n  }\n  .layer-number {\n    font-weight: 700;\n    font-size: 1.25rem;\n    display: inline-block;\n    width: 28px;\n    text-align: center;\n    margin-right: 0.8rem;\n    vertical-align: middle;\n    background: #004d99;\n    color: white;\n    border-radius: 50%;\n    line-height: 28px;\n    user-select: none;\n  }\n  #layer-title {\n    font-size: 1.8rem;\n    margin-bottom: 0.5rem;\n  }\n  #layer-func {\n    font-size: 1.2rem;\n    line-height: 1.4;\n    margin-bottom: 1rem;\n  }\n  #layer-details {\n    background: #dbe9ff;\n    border-radius: 8px;\n    padding: 1rem 1.5rem;\n    max-width: 600px;\n    margin: 0 auto;\n    box-shadow: 0 2px 5px rgb(0 0 0 / 0.1);\n    font-size: 1rem;\n    line-height: 1.5;\n  }\n  footer {\n    background: #004d99;\n    color: white;\n    text-align: center;\n    padding: 1rem 0;\n    font-size: 0.9rem;\n  }\n  @media (max-width: 600px) {\n    #osi-model {\n      max-width: 100%;\n    }\n    #layer-details {\n      max-width: 100%;\n    }\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>OSI Model - Open Systems Interconnection</h1>\n</header>\n<main>\n  <p class=\"description\">\n    The OSI model is a conceptual framework used to understand and implement standard protocols in computer networking. \n    It divides network communication into seven distinct layers. Click on each layer below to learn about its function and components.\n  </p>\n  <div id=\"osi-model\" role=\"list\" aria-label=\"OSI Model Layers\">\n    <!-- Layers will be inserted here by JavaScript -->\n  </div>\n  <section id=\"layer-details\" aria-live=\"polite\" aria-atomic=\"true\" tabindex=\"0\">\n    <h2 id=\"layer-title\">Select a layer to see details</h2>\n    <p id=\"layer-func\">Click one of the OSI layers above to view its function, key protocols, and examples.</p>\n  </section>\n</main>\n<footer>\n  OSI Model Demo — Created for educational purposes\n</footer>\n\n<script>\n  const osiLayers = [\n    {\n      number: 7,\n      name: \"Application Layer\",\n      function:\n        \"Provides network services directly to end-user applications. Enables user interaction and network processes.\",\n      details: `\n      <strong>Key Responsibilities:</strong> Interacting with software applications to implement a communicating component.<br>\n      <strong>Protocols:</strong> HTTP, FTP, SMTP, DNS, Telnet, SNMP.<br>\n      <strong>Examples:</strong> Web browsers, email clients, file transfer applications.\n      `,\n    },\n    {\n      number: 6,\n      name: \"Presentation Layer\",\n      function:\n        \"Formats, encrypts, and compresses data for transmission; translates data between the application and network formats.\",\n      details: `\n      <strong>Key Responsibilities:</strong> Data translation, encryption/decryption, compression/decompression.<br>\n      <strong>Protocols:</strong> SSL/TLS, JPEG, GIF, MPEG.<br>\n      <strong>Examples:</strong> Data encryption programs, character code translation (ASCII, EBCDIC).\n      `,\n    },\n    {\n      number: 5,\n      name: \"Session Layer\",\n      function:\n        \"Manages sessions and connections between applications, establishing, maintaining, and terminating communication sessions.\",\n      details: `\n      <strong>Key Responsibilities:</strong> Session establishment, maintenance, synchronization, and termination.<br>\n      <strong>Protocols:</strong> NetBIOS, PPTP, RPC.<br>\n      <strong>Examples:</strong> Remote procedure calls, managing multiple web sessions.\n      `,\n    },\n    {\n      number: 4,\n      name: \"Transport Layer\",\n      function:\n        \"Provides reliable data transmission with flow control, error detection and correction, and segmentation.\",\n      details: `\n      <strong>Key Responsibilities:</strong> End-to-end connection establishment, reliability, flow control.<br>\n      <strong>Protocols:</strong> TCP, UDP, SCTP.<br>\n      <strong>Examples:</strong> Web traffic using TCP, streaming using UDP.\n      `,\n    },\n    {\n      number: 3,\n      name: \"Network Layer\",\n      function:\n        \"Handles routing, addressing, and forwarding of data packets through different networks.\",\n      details: `\n      <strong>Key Responsibilities:</strong> Logical addressing (IP), routing, packet forwarding.<br>\n      <strong>Protocols:</strong> IP, ICMP, IPSec, OSPF.<br>\n      <strong>Examples:</strong> Internet routers, IP addressing, packet forwarding.\n      `,\n    },\n    {\n      number: 2,\n      name: \"Data Link Layer\",\n      function:\n        \"Provides node-to-node data transfer, error detection, and correction from the physical layer.\",\n      details: `\n      <strong>Key Responsibilities:</strong> Framing, physical addressing (MAC), error detection and correction.<br>\n      <strong>Protocols:</strong> Ethernet, PPP, Switches, ARP.<br>\n      <strong>Examples:</strong> MAC addresses, network switches, Wi-Fi.\n      `,\n    },\n    {\n      number: 1,\n      name: \"Physical Layer\",\n      function:\n        \"Defines the electrical and physical specifications for devices including cables, cards, and physical aspects.\",\n      details: `\n      <strong>Key Responsibilities:</strong> Bit transmission, voltage levels, cable specifications, connectors.<br>\n      <strong>Examples:</strong> Ethernet cables, fiber optics, radio frequencies, repeaters.\n      `,\n    },\n  ];\n\n  const osiContainer = document.getElementById(\"osi-model\");\n  const layerTitle = document.getElementById(\"layer-title\");\n  const layerFunc = document.getElementById(\"layer-func\");\n  const layerDetails = document.getElementById(\"layer-details\");\n  let currentSelected = null;\n\n  // Sort layers by number descending for visual top-to-bottom\n  osiLayers.sort((a,b) => b.number - a.number);\n\n  function createLayerElement(layer) {\n    const div = document.createElement(\"div\");\n    div.className = \"layer\";\n    div.tabIndex = 0;\n    div.setAttribute(\"role\", \"listitem\");\n    div.setAttribute(\"aria-label\", `Layer ${layer.number}: ${layer.name}`);\n    div.dataset.number = layer.number;\n\n    const numberSpan = document.createElement(\"span\");\n    numberSpan.className = \"layer-number\";\n    numberSpan.textContent = layer.number;\n\n    const nameSpan = document.createElement(\"span\");\n    nameSpan.className = \"layer-name\";\n    nameSpan.textContent = layer.name;\n\n    div.appendChild(numberSpan);\n    div.appendChild(nameSpan);\n\n    // Click and keyboard accessibility\n    div.addEventListener(\"click\", () => selectLayer(layer.number));\n    div.addEventListener(\"keydown\", e => {\n      if (e.key === \"Enter\" || e.key === \" \"){\n        e.preventDefault();\n        selectLayer(layer.number);\n      }\n    });\n\n    return div;\n  }\n\n  function selectLayer(number) {\n    if (currentSelected === number) return; // no change\n\n    // Remove old selection\n    const oldSelected = osiContainer.querySelector(\".layer.selected\");\n    if (oldSelected) oldSelected.classList.remove(\"selected\");\n\n    const newSelected = osiContainer.querySelector(`.layer[data-number=\"${number}\"]`);\n    if (newSelected) newSelected.classList.add(\"selected\");\n\n    const layer = osiLayers.find(l => l.number === number);\n\n    if (layer) {\n      layerTitle.textContent = `Layer ${layer.number}: ${layer.name}`;\n      layerFunc.textContent = layer.function;\n      layerDetails.innerHTML = `<h2 id=\"layer-title\">Layer ${layer.number}: ${layer.name}</h2>\n        <p id=\"layer-func\">${layer.function}</p>\n        <div>${layer.details}</div>`;\n      layerDetails.focus();\n      currentSelected = number;\n    }\n  }\n\n  function init() {\n    osiLayers.forEach(layer => {\n      const el = createLayerElement(layer);\n      osiContainer.appendChild(el);\n    });\n  }\n\n  init();\n</script>\n</body>\n</html>"
  },
