    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Simple Compiler Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n            background-color: #f4f4f4;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n        }\n        pre {\n            background: #e7e7e7;\n            padding: 10px;\n            border: 1px solid #ccc;\n            overflow: auto;\n        }\n        button {\n            padding: 10px 15px;\n            margin-top: 10px;\n            background-color: #007BFF;\n            color: white;\n            border: none;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #0056b3;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Simple JavaScript Compiler Concept Demonstration</h1>\n<p>Type in a simple arithmetic expression (e.g., \"2 + 2 * (3 - 1)\") and click \"Compile\" to see the output of the evaluation.</p>\n\n<textarea id=\"codeInput\" placeholder=\"Enter expression here...\"></textarea>\n<button id=\"compileButton\">Compile</button>\n\n<h2>Output</h2>\n<pre id=\"output\"></pre>\n\n<script>\n    document.getElementById('compileButton').addEventListener('click', function() {\n        const input = document.getElementById('codeInput').value;\n        \n        try {\n            // Simple \"compilation\" step: directly evaluating the expression\n            const result = eval(input);\n            document.getElementById('output').textContent = `Result: ${result}`;\n        } catch (error) {\n            // Handle any errors in evaluating the expression\n            document.getElementById('output').textContent = `Error: ${error.message}`;\n        }\n    });\n</script>\n\n</body>\n</html>"
