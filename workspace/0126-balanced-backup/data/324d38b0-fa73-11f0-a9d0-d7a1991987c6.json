    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Undirected Graph Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #graph {\n            display: flex;\n            flex-direction: column;\n            align-items: flex-start;\n            margin-bottom: 20px;\n        }\n        .node {\n            display: inline-block;\n            margin: 5px;\n            padding: 10px;\n            background-color: #4CAF50;\n            color: white;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .edges {\n            display: flex;\n            flex-wrap: wrap;\n        }\n        .edge {\n            margin: 2px;\n            color: #757575;\n        }\n    </style>\n</head>\n<body>\n\n<h2>Undirected Graph Visualization</h2>\n<div id=\"graph\"></div>\n<div>\n    <input type=\"text\" id=\"nodeInput\" placeholder=\"Add Node (e.g., A)\">\n    <button onclick=\"addNode()\">Add Node</button>\n</div>\n<div>\n    <input type=\"text\" id=\"edgeInput\" placeholder=\"Add Edge (e.g., A-B)\">\n    <button onclick=\"addEdge()\">Add Edge</button>\n</div>\n\n<script>\n    const graph = {\n        nodes: new Set(),\n        edges: new Set()\n    };\n\n    function renderGraph() {\n        const graphElement = document.getElementById('graph');\n        graphElement.innerHTML = '';\n        \n        // Render Nodes\n        for (const node of graph.nodes) {\n            const nodeElement = document.createElement('div');\n            nodeElement.classList.add('node');\n            nodeElement.textContent = node;\n            graphElement.appendChild(nodeElement);\n        }\n\n        // Render Edges\n        const edgesElement = document.createElement('div');\n        edgesElement.classList.add('edges');\n        for (const edge of graph.edges) {\n            const edgeElement = document.createElement('div');\n            edgeElement.classList.add('edge');\n            edgeElement.textContent = edge;\n            edgesElement.appendChild(edgeElement);\n        }\n\n        graphElement.appendChild(edgesElement);\n    }\n\n    function addNode() {\n        const nodeInput = document.getElementById('nodeInput');\n        const nodeValue = nodeInput.value.trim();\n        \n        if (nodeValue) {\n            graph.nodes.add(nodeValue);\n            nodeInput.value = '';\n            renderGraph();\n        }\n    }\n\n    function addEdge() {\n        const edgeInput = document.getElementById('edgeInput');\n        const edgeValue = edgeInput.value.trim();\n\n        if (edgeValue && edgeValue.includes('-')) {\n            const [nodeA, nodeB] = edgeValue.split('-').map(n => n.trim());\n            if (graph.nodes.has(nodeA) && graph.nodes.has(nodeB)) {\n                graph.edges.add(`${nodeA} - ${nodeB}`);\n                graph.edges.add(`${nodeB} - ${nodeA}`); // Undirected edge\n                edgeInput.value = '';\n                renderGraph();\n            } else {\n                alert('Both nodes must exist in the graph before creating an edge.');\n            }\n        }\n    }\n</script>\n\n</body>\n</html>"
