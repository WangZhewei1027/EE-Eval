  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Trie (Prefix Tree) — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724; --card:#0b1220; --muted:#9aa7bd; --accent:#6ee7b7; --accent2:#60a5fa;\n      --danger:#fb7185;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    html,body{height:100%; margin:0; background:linear-gradient(180deg,var(--bg),#071028); color:#e6eef6;}\n    .wrap{max-width:1100px;margin:28px auto;padding:22px;background:linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01));border-radius:12px;box-shadow:0 6px 30px rgba(2,6,23,0.6);}\n    header{display:flex;gap:18px;align-items:center;margin-bottom:18px}\n    h1{font-size:20px;margin:0}\n    p.lead{margin:0;color:var(--muted);font-size:13px}\n    .controls{display:flex;gap:12px;flex-wrap:wrap;margin:18px 0}\n    .controls input[type=\"text\"], .controls textarea{\n      padding:10px 12px;border-radius:8px;border:1px solid rgba(255,255,255,0.05);background:rgba(255,255,255,0.02);color:inherit;min-width:220px;\n    }\n    .controls button{padding:10px 12px;border-radius:8px;border:0;background:var(--accent);color:#04201a;cursor:pointer}\n    .controls button.secondary{background:transparent;border:1px solid rgba(255,255,255,0.06);color:var(--muted)}\n    .controls .danger{background:var(--danger);color:#fff}\n    .grid{display:grid;grid-template-columns:1fr 420px;gap:18px}\n    .card{background:rgba(255,255,255,0.02);padding:14px;border-radius:10px;min-height:160px}\n    .panel-title{font-weight:600;margin-bottom:8px}\n    #visualization{overflow:auto;max-height:520px;padding:10px;border-radius:8px;background:linear-gradient(180deg,rgba(255,255,255,0.01),transparent)}\n    .trie-node{list-style:none;margin:6px 0;padding-left:14px;position:relative}\n    .trie-node::before{content:\"\";position:absolute;left:4px;top:12px;width:8px;height:1px;background:rgba(255,255,255,0.03)}\n    .node-label{display:inline-flex;gap:8px;align-items:center;padding:6px 8px;border-radius:6px;background:rgba(255,255,255,0.02);color:var(--muted);font-size:13px}\n    .node-char{font-weight:700;color:var(--accent2);font-size:13px}\n    .node-end{background:var(--accent);padding:3px 6px;border-radius:999px;color:#01261a;font-size:12px;margin-left:6px}\n    .node-count{font-size:11px;color:var(--muted);margin-left:6px}\n    .highlight{box-shadow:0 0 0 3px rgba(96,165,250,0.06), inset 0 0 30px rgba(96,165,250,0.02);border-radius:6px;border:1px solid rgba(96,165,250,0.12);color:#dff1ff}\n    .path-highlight{background:linear-gradient(90deg, rgba(110,231,183,0.06), rgba(96,165,250,0.04)); border-radius:6px}\n    .suggestions{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}\n    .chip{background:rgba(255,255,255,0.03);padding:6px 8px;border-radius:999px;font-size:13px;cursor:pointer;color:var(--muted)}\n    .chip:hover{background:rgba(255,255,255,0.04)}\n    .help{color:var(--muted);font-size:13px;padding-top:6px}\n    .stats{font-size:13px;color:var(--muted);margin-top:8px}\n    footer{margin-top:18px;color:var(--muted);font-size:13px}\n    .small{font-size:12px;color:var(--muted)}\n  </style>\n</head>\n<body>\n  <div class=\"wrap\" role=\"main\">\n    <header>\n      <div>\n        <h1>Trie (Prefix Tree) — Interactive Demo</h1>\n        <p class=\"lead\">Insert words, search exact matches, find prefixes and autocomplete suggestions. Visualized as nested branches.</p>\n      </div>\n    </header>\n\n    <div class=\"controls\">\n      <input id=\"wordInput\" type=\"text\" placeholder=\"Type a word to insert (e.g. hello)\" aria-label=\"Insert word\">\n      <button id=\"insertBtn\">Insert</button>\n\n      <input id=\"searchInput\" type=\"text\" placeholder=\"Search exact word or prefix...\" aria-label=\"Search\">\n      <button id=\"searchBtn\" class=\"secondary\">Search</button>\n      <button id=\"prefixBtn\" class=\"secondary\">Is Prefix?</button>\n\n      <input id=\"bulkInput\" type=\"text\" placeholder=\"Bulk insert (comma or newline separated)...\" style=\"min-width:360px\">\n      <button id=\"bulkBtn\">Bulk Insert</button>\n\n      <button id=\"clearBtn\" class=\"danger\">Clear Trie</button>\n    </div>\n\n    <div class=\"grid\">\n      <div>\n        <div class=\"card\">\n          <div class=\"panel-title\">Operations & Autocomplete</div>\n          <div style=\"display:flex;gap:12px;align-items:flex-start;flex-wrap:wrap\">\n            <div style=\"flex:1;min-width:220px\">\n              <div style=\"margin-bottom:8px\">\n                <label class=\"small\">Live prefix suggestions (type in Search input)</label>\n                <div id=\"suggestList\" class=\"suggestions\" aria-live=\"polite\"></div>\n              </div>\n\n              <div style=\"margin-top:10px\">\n                <button id=\"exampleBtn\" class=\"secondary\">Load Example Words</button>\n                <button id=\"removeBtn\" class=\"secondary\">Remove Word</button>\n              </div>\n\n              <div class=\"help\" id=\"status\">Status: idle</div>\n              <div class=\"stats\" id=\"stats\">Nodes: 0 | Words: 0</div>\n            </div>\n\n            <div style=\"width:320px\">\n              <div style=\"font-weight:600;margin-bottom:8px\">Quick tips</div>\n              <div class=\"small\">\n                - Insert words to build the trie. Each node represents a character.<br>\n                - Search returns true only for full words inserted.<br>\n                - Prefix check tells if any word starts with the prefix.<br>\n                - Autocomplete lists words that begin with a typed prefix.\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"card\" style=\"margin-top:14px\">\n          <div class=\"panel-title\">Examples & Controls</div>\n          <div style=\"display:flex;gap:8px;flex-wrap:wrap\">\n            <button class=\"chip\" data-sample=\"cat,dog,can,car,cart,carbon,card,care\">Animals & cars</button>\n            <button class=\"chip\" data-sample=\"hello,hell,he,hero,her,heron,help\">hello/hero family</button>\n            <button class=\"chip\" data-sample=\"apple,app,apply,apt,ape,april\">apple family</button>\n            <button class=\"chip\" data-sample=\"bat,batch,bath,banana,band\">b* words</button>\n          </div>\n        </div>\n\n      </div>\n\n      <aside>\n        <div class=\"card\">\n          <div class=\"panel-title\">Trie Visualization</div>\n          <div id=\"visualization\" aria-hidden=\"false\">\n            <!-- Tree renders here -->\n          </div>\n        </div>\n\n        <div class=\"card\" style=\"margin-top:12px\">\n          <div class=\"panel-title\">Last operation</div>\n          <div id=\"lastOp\" class=\"small\">None yet.</div>\n        </div>\n      </aside>\n    </div>\n\n    <footer>\n      Implementation notes: Each node stores children by character, a flag marking end-of-word and a count of how many words pass through. Removing prunes unused nodes.\n    </footer>\n  </div>\n\n  <script>\n    (function(){\n      // Trie implementation\n      class TrieNode {\n        constructor() {\n          this.children = new Map(); // char -> TrieNode\n          this.isWord = false;\n          this.passCount = 0; // how many words pass through (including this node's word)\n        }\n      }\n\n      class Trie {\n        constructor() {\n          this.root = new TrieNode();\n          this.wordCount = 0;\n        }\n\n        insert(word) {\n          if (!word || typeof word !== 'string') return;\n          word = word.trim();\n          if (word.length === 0) return;\n          let node = this.root;\n          node.passCount += 1;\n          for (let ch of word) {\n            if (!node.children.has(ch)) node.children.set(ch, new TrieNode());\n            node = node.children.get(ch);\n            node.passCount += 1;\n          }\n          if (!node.isWord) {\n            node.isWord = true;\n            this.wordCount += 1;\n          }\n        }\n\n        search(word) {\n          if (!word) return false;\n          let node = this.root;\n          for (let ch of word) {\n            if (!node.children.has(ch)) return false;\n            node = node.children.get(ch);\n          }\n          return node.isWord === true;\n        }\n\n        startsWith(prefix) {\n          if (prefix == null) return false;\n          let node = this.root;\n          for (let ch of prefix) {\n            if (!node.children.has(ch)) return false;\n            node = node.children.get(ch);\n          }\n          return true;\n        }\n\n        // return up to limit suggestions with given prefix\n        suggestions(prefix, limit = 10) {\n          let node = this.root;\n          for (let ch of prefix) {\n            if (!node.children.has(ch)) return [];\n            node = node.children.get(ch);\n          }\n          let results = [];\n          const dfs = (n, path) => {\n            if (results.length >= limit) return;\n            if (n.isWord) results.push(path);\n            for (let [ch, child] of n.children) {\n              dfs(child, path + ch);\n              if (results.length >= limit) break;\n            }\n          };\n          dfs(node, prefix);\n          return results;\n        }\n\n        // Remove a word. Returns true if removed.\n        remove(word) {\n          if (!word || !this.search(word)) return false;\n          const removeRec = (node, idx) => {\n            if (idx === word.length) {\n              if (node.isWord) {\n                node.isWord = false;\n                this.wordCount -= 1;\n                node.passCount -= 1;\n                // If node has no children, signal to parent to delete this mapping\n                return node.children.size === 0;\n              }\n              return false;\n            }\n            const ch = word[idx];\n            const child = node.children.get(ch);\n            if (!child) return false;\n            const shouldDeleteChild = removeRec(child, idx+1);\n            // Decrement passCount for this child regardless\n            child.passCount -= 1;\n            if (shouldDeleteChild) {\n              node.children.delete(ch);\n            }\n            // If current node is not end-of-word and has no children, suggest parent to delete too\n            return !node.isWord && node.children.size === 0;\n          };\n\n          // decrement root passCount\n          this.root.passCount -= 1;\n          removeRec(this.root, 0);\n          return true;\n        }\n\n        nodeCount() {\n          // count nodes by traversing\n          let cnt = 0;\n          const stack = [this.root];\n          while (stack.length) {\n            const n = stack.pop();\n            cnt++;\n            for (let child of n.children.values()) stack.push(child);\n          }\n          return cnt;\n        }\n      }\n\n      // UI wiring\n      const trie = new Trie();\n      const wordInput = document.getElementById('wordInput');\n      const insertBtn = document.getElementById('insertBtn');\n      const bulkInput = document.getElementById('bulkInput');\n      const bulkBtn = document.getElementById('bulkBtn');\n      const clearBtn = document.getElementById('clearBtn');\n      const exampleBtn = document.getElementById('exampleBtn');\n      const searchInput = document.getElementById('searchInput');\n      const searchBtn = document.getElementById('searchBtn');\n      const prefixBtn = document.getElementById('prefixBtn');\n      const suggestList = document.getElementById('suggestList');\n      const visualization = document.getElementById('visualization');\n      const status = document.getElementById('status');\n      const stats = document.getElementById('stats');\n      const lastOp = document.getElementById('lastOp');\n      const removeBtn = document.getElementById('removeBtn');\n\n      function sanitizeWords(text) {\n        if (!text) return [];\n        // split by commas or newlines and trim and filter empties\n        return text.split(/[\\n,]+/).map(s => s.trim()).filter(Boolean);\n      }\n\n      function updateStats() {\n        stats.textContent = `Nodes: ${trie.nodeCount()} | Words: ${trie.wordCount}`;\n      }\n\n      function renderTrie() {\n        // Render nested UL starting from root\n        visualization.innerHTML = '';\n        const ul = document.createElement('ul');\n        ul.style.paddingLeft = '6px';\n        ul.style.margin = '0';\n        visualization.appendChild(ul);\n\n        const renderNode = (node, parentEl, path) => {\n          // children sorted by character for stable display\n          const entries = Array.from(node.children.entries()).sort((a,b)=> a[0].localeCompare(b[0]));\n          entries.forEach(([ch, child]) => {\n            const li = document.createElement('li');\n            li.className = 'trie-node';\n            li.dataset.path = path + ch; // path from root (excluding root empty)\n            const label = document.createElement('div');\n            label.className = 'node-label';\n            const charSpan = document.createElement('span');\n            charSpan.className = 'node-char';\n            charSpan.textContent = ch;\n            label.appendChild(charSpan);\n            if (child.isWord) {\n              const endSpan = document.createElement('span');\n              endSpan.className = 'node-end';\n              endSpan.textContent = 'word';\n              label.appendChild(endSpan);\n            }\n            const countSpan = document.createElement('span');\n            countSpan.className = 'node-count';\n            countSpan.textContent = `pass:${child.passCount}`;\n            label.appendChild(countSpan);\n\n            li.appendChild(label);\n            parentEl.appendChild(li);\n\n            if (child.children.size > 0) {\n              const sub = document.createElement('ul');\n              sub.style.paddingLeft = '12px';\n              sub.style.margin = '6px 0';\n              li.appendChild(sub);\n              renderNode(child, sub, path + ch);\n            }\n          });\n        };\n\n        renderNode(trie.root, ul, '');\n      }\n\n      function setStatus(text, short=false) {\n        status.textContent = 'Status: ' + text;\n        if (!short) lastOp.textContent = text;\n      }\n\n      // Insert\n      insertBtn.addEventListener('click', () => {\n        const w = wordInput.value.trim();\n        if (!w) { setStatus('Enter a non-empty word.'); return; }\n        trie.insert(w);\n        updateStats();\n        renderTrie();\n        setStatus(`Inserted \"${w}\"`);\n        wordInput.value = '';\n      });\n\n      // Bulk insert\n      bulkBtn.addEventListener('click', () => {\n        const words = sanitizeWords(bulkInput.value);\n        if (!words.length) { setStatus('Enter at least one word to bulk insert.'); return; }\n        words.forEach(w => trie.insert(w));\n        updateStats();\n        renderTrie();\n        setStatus(`Inserted ${words.length} words`);\n        bulkInput.value = '';\n      });\n\n      // Example load\n      exampleBtn.addEventListener('click', () => {\n        const sample = ['hello','hell','he','hero','her','heritage','help','heap','helmet','heat'];\n        sample.forEach(w => trie.insert(w));\n        updateStats(); renderTrie();\n        setStatus('Loaded example words');\n      });\n\n      // Clear\n      clearBtn.addEventListener('click', () => {\n        // re-create trie\n        while (visualization.firstChild) visualization.removeChild(visualization.firstChild);\n        Object.keys(trie).forEach(k=>delete trie[k]); // remove properties\n        // replace with new instance\n        window.trie = null;\n        // create new one\n        // Note: keep variable reference used by UI functions\n        // Using global stored reference here for simplicity:\n        // reinitialize local 'trie' by mutating properties\n        // Easiest is to reload page but avoid that.\n        // We'll create a fresh Trie and copy reference\n        const newTrie = new (Trie)();\n        // copy properties back onto existing var scope reference by using closure? simpler: assign to window and to local var via eval?\n        // But since 'trie' is declared with const, we cannot reassign. Instead we rebuild by copying into current object if it were mutable.\n        // To keep simple and robust, we'll reload the page to reset state.\n        setStatus('Clearing trie — page will reload to reset state', true);\n        setTimeout(()=>location.reload(), 350);\n      });\n\n      // Search exact\n      searchBtn.addEventListener('click', () => {\n        const q = searchInput.value.trim();\n        if (!q) { setStatus('Enter a word to search'); return; }\n        const found = trie.search(q);\n        setStatus(found ? `\"${q}\" is present (exact match)` : `\"${q}\" not found`);\n        // highlight path if exists\n        highlightPath(q, found ? 'highlight' : 'path-highlight');\n      });\n\n      // Prefix check\n      prefixBtn.addEventListener('click', () => {\n        const q = searchInput.value.trim();\n        if (!q) { setStatus('Enter a prefix to check'); return; }\n        const p = trie.startsWith(q);\n        setStatus(p ? `There is at least one word starting with \"${q}\"` : `No words start with \"${q}\"`);\n        highlightPath(q, p ? 'path-highlight' : 'highlight');\n      });\n\n      // Remove word\n      removeBtn.addEventListener('click', () => {\n        const q = wordInput.value.trim() || searchInput.value.trim();\n        if (!q) { setStatus('Provide a word to remove in the Insert or Search input'); return; }\n        const removed = trie.remove(q);\n        if (removed) {\n          updateStats(); renderTrie();\n          setStatus(`Removed \"${q}\"`);\n        } else {\n          setStatus(`Could not remove \"${q}\" — not found`);\n        }\n      });\n\n      // Live suggestions as user types\n      let lastSuggest = '';\n      function updateSuggestions(prefix) {\n        suggestList.innerHTML = '';\n        if (!prefix) return;\n        const sug = trie.suggestions(prefix, 12);\n        if (sug.length === 0) {\n          const n = document.createElement('div'); n.className = 'small'; n.style.color='var(--muted)'; n.textContent = 'No suggestions';\n          suggestList.appendChild(n);\n        } else {\n          sug.forEach(s => {\n            const b = document.createElement('button');\n            b.className = 'chip';\n            b.textContent = s;\n            b.addEventListener('click', ()=> {\n              searchInput.value = s;\n              setStatus(`Autocomplete selected \"${s}\"`);\n              highlightPath(s, 'highlight');\n            });\n            suggestList.appendChild(b);\n          });\n        }\n        highlightPath(prefix, 'path-highlight');\n      }\n\n      searchInput.addEventListener('input', (e)=> {\n        const q = e.target.value.trim();\n        if (q === lastSuggest) return;\n        lastSuggest = q;\n        updateSuggestions(q);\n      });\n\n      // Click sample chips\n      document.querySelectorAll('.chip[data-sample]').forEach(btn=>{\n        btn.addEventListener('click', ()=> {\n          const s = btn.dataset.sample;\n          const words = s.split(',').map(t=>t.trim()).filter(Boolean);\n          words.forEach(w=>trie.insert(w));\n          updateStats(); renderTrie();\n          setStatus(`Inserted sample (${words.length} words)`);\n        });\n      });\n\n      // Initially render empty tree\n      updateStats();\n      renderTrie();\n\n      // Highlight path utility\n      function clearHighlights() {\n        visualization.querySelectorAll('.node-label').forEach(el=>{\n          el.classList.remove('highlight', 'path-highlight');\n        });\n      }\n\n      function highlightPath(prefix, cls) {\n        clearHighlights();\n        if (!prefix) return;\n        // highlight nodes along prefix path if they exist\n        for (let i=1;i<=prefix.length;i++) {\n          const path = prefix.slice(0,i);\n          const el = visualization.querySelector(`[data-path=\"${CSS.escape(path)}\"]`);\n          if (el) {\n            const label = el.querySelector('.node-label');\n            if (label) label.classList.add(cls);\n          } else {\n            // stop when a part of path doesn't exist\n            break;\n          }\n        }\n      }\n\n      // Utility: CSS.escape polyfill for old browsers\n      if (!window.CSS || !CSS.escape) {\n        CSS = CSS || {};\n        CSS.escape = function(value) {\n          return String(value).replace(/([^\\w-])/g, '\\\\$1');\n        };\n      }\n\n      // Helpful keyboard shortcuts\n      document.addEventListener('keydown', (e)=>{\n        if (e.ctrlKey && e.key === 'i') { e.preventDefault(); wordInput.focus(); }\n        if (e.ctrlKey && e.key === 'f') { e.preventDefault(); searchInput.focus(); }\n      });\n\n    })();\n  </script>\n</body>\n</html>"
  },
