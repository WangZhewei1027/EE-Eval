    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Max Heap Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9f9f9;\n  }\n  h1 {\n    text-align: center;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 20px;\n  }\n  input[type=\"number\"] {\n    width: 80px;\n    font-size: 1em;\n    padding: 5px;\n  }\n  button {\n    font-size: 1em;\n    padding: 6px 12px;\n    margin-left: 10px;\n    cursor: pointer;\n  }\n  #heapContainer {\n    display: flex;\n    justify-content: center;\n    margin-top: 30px;\n  }\n  svg {\n    width: 100%;\n    max-width: 700px;\n    height: 360px;\n    background: #fff;\n    border: 1px solid #ccc;\n    border-radius: 6px;\n  }\n  .node {\n    fill: #4a90e2;\n    stroke: #2c64b8;\n    stroke-width: 2px;\n    cursor: default;\n  }\n  .node-text {\n    fill: white;\n    font-weight: bold;\n    font-size: 16px;\n    pointer-events: none;\n  }\n  line {\n    stroke: #555;\n    stroke-width: 2;\n  }\n  #log {\n    max-width: 700px;\n    margin: 20px auto;\n    height: 140px;\n    background: #222;\n    color: #eee;\n    padding: 10px;\n    border-radius: 6px;\n    overflow-y: auto;\n    font-family: \"Courier New\", Courier, monospace;\n    font-size: 0.9em;\n  }\n  #log strong {\n    color: #4a90e2;\n  }\n</style>\n</head>\n<body>\n<h1>Max Heap Visualization</h1>\n<div id=\"controls\">\n  <input id=\"inputValue\" type=\"number\" placeholder=\"Enter number\" />\n  <button id=\"insertBtn\">Insert</button>\n  <button id=\"extractBtn\">Extract Max</button>\n  <button id=\"clearBtn\">Clear</button>\n</div>\n<div id=\"heapContainer\">\n  <svg id=\"heapSVG\" viewBox=\"0 0 700 360\" aria-label=\"Max heap visualization\" role=\"img\"></svg>\n</div>\n<div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<script>\n(() => {\n  // Max Heap Class\n  class MaxHeap {\n    constructor() {\n      this.data = [];\n    }\n    insert(value) {\n      this.data.push(value);\n      this._siftUp(this.data.length - 1);\n    }\n    extractMax() {\n      if (this.data.length === 0) return null;\n      if (this.data.length === 1) return this.data.pop();\n      const max = this.data[0];\n      this.data[0] = this.data.pop();\n      this._siftDown(0);\n      return max;\n    }\n    _parent(i) {\n      return Math.floor((i - 1) / 2);\n    }\n    _left(i) {\n      return 2 * i + 1;\n    }\n    _right(i) {\n      return 2 * i + 2;\n    }\n    _siftUp(i) {\n      while (i > 0) {\n        let p = this._parent(i);\n        if (this.data[p] < this.data[i]) {\n          [this.data[p], this.data[i]] = [this.data[i], this.data[p]];\n          i = p;\n        } else {\n          break;\n        }\n      }\n    }\n    _siftDown(i) {\n      while (true) {\n        let left = this._left(i);\n        let right = this._right(i);\n        let largest = i;\n        if (left < this.data.length && this.data[left] > this.data[largest]) largest = left;\n        if (right < this.data.length && this.data[right] > this.data[largest]) largest = right;\n        if (largest !== i) {\n          [this.data[i], this.data[largest]] = [this.data[largest], this.data[i]];\n          i = largest;\n        } else {\n          break;\n        }\n      }\n    }\n  }\n\n  // Visualization and UI\n  const heap = new MaxHeap();\n  const svg = document.getElementById('heapSVG');\n  const insertBtn = document.getElementById('insertBtn');\n  const extractBtn = document.getElementById('extractBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const inputValue = document.getElementById('inputValue');\n  const logEl = document.getElementById('log');\n\n  // Constants defining node placement\n  const nodeRadius = 20;\n  const maxLevels = 5;\n  const width = 700;\n  const height = 360;\n  const levelHeight = height / maxLevels;\n\n  function log(message) {\n    const p = document.createElement('div');\n    p.textContent = message;\n    logEl.appendChild(p);\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  function clearLog() {\n    logEl.textContent = '';\n  }\n\n  /**\n   * Given index in heap array, calculate the (x,y) position in SVG coordinate\n   * Uses a binary tree layout formula - nodes horizontally spaced by their index at level.\n   */\n  function calculateNodePosition(index) {\n    // level of node:\n    let level = 0;\n    let count = 1;\n    while (index >= count) {\n      index -= count;\n      count *= 2;\n      level++;\n    }\n    const nodesInLevel = 2 ** level;\n    const xGap = width / (nodesInLevel + 1);\n    const x = xGap * (index + 1);\n    const y = levelHeight * (level + 0.5);\n    return { x, y };\n  }\n\n  function clearSVG() {\n    while (svg.firstChild) {\n      svg.removeChild(svg.firstChild);\n    }\n  }\n\n  /** Draw lines between parent and children **/\n  function drawEdges(data) {\n    for (let i = 0; i < data.length; i++) {\n      const parentPos = calculateNodePosition(i);\n      const leftIndex = 2 * i + 1;\n      const rightIndex = 2 * i + 2;\n      if (leftIndex < data.length) {\n        const leftPos = calculateNodePosition(leftIndex);\n        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n        line.setAttribute('x1', parentPos.x);\n        line.setAttribute('y1', parentPos.y + nodeRadius);\n        line.setAttribute('x2', leftPos.x);\n        line.setAttribute('y2', leftPos.y - nodeRadius);\n        svg.appendChild(line);\n      }\n      if (rightIndex < data.length) {\n        const rightPos = calculateNodePosition(rightIndex);\n        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n        line.setAttribute('x1', parentPos.x);\n        line.setAttribute('y1', parentPos.y + nodeRadius);\n        line.setAttribute('x2', rightPos.x);\n        line.setAttribute('y2', rightPos.y - nodeRadius);\n        svg.appendChild(line);\n      }\n    }\n  }\n\n  /** Draw nodes with circles and text **/\n  function drawNodes(data) {\n    data.forEach((val, i) => {\n      const { x, y } = calculateNodePosition(i);\n\n      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n      circle.setAttribute('cx', x);\n      circle.setAttribute('cy', y);\n      circle.setAttribute('r', nodeRadius);\n      circle.setAttribute('class', 'node');\n      svg.appendChild(circle);\n\n      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n      text.setAttribute('x', x);\n      text.setAttribute('y', y + 6);\n      text.setAttribute('text-anchor', 'middle');\n      text.setAttribute('class', 'node-text');\n      text.textContent = val;\n      svg.appendChild(text);\n    });\n  }\n\n  function renderHeap() {\n    clearSVG();\n    const data = heap.data;\n    if (data.length === 0) return;\n    drawEdges(data);\n    drawNodes(data);\n  }\n\n  insertBtn.addEventListener('click', () => {\n    const val = Number(inputValue.value);\n    if (!Number.isFinite(val)) {\n      alert('Please enter a valid number.');\n      inputValue.value = '';\n      return;\n    }\n    heap.insert(val);\n    log(`Inserted <strong>${val}</strong> into the heap.`);\n    renderHeap();\n    inputValue.value = '';\n    inputValue.focus();\n  });\n\n  extractBtn.addEventListener('click', () => {\n    const max = heap.extractMax();\n    if (max === null) {\n      alert('Heap is empty. Nothing to extract.');\n      return;\n    }\n    log(`Extracted max <strong>${max}</strong> from the heap.`);\n    renderHeap();\n  });\n\n  clearBtn.addEventListener('click', () => {\n    heap.data = [];\n    clearSVG();\n    clearLog();\n    inputValue.value = '';\n    inputValue.focus();\n    log('Heap cleared.');\n  });\n\n  inputValue.addEventListener('keydown', e => {\n    if (e.key === 'Enter') insertBtn.click();\n  });\n\n  // Initial example heap for demo\n  (function initialDemo() {\n    const demoValues = [40, 30, 20, 15, 10, 12, 18];\n    demoValues.forEach(v => heap.insert(v));\n    log('Initial heap built with values: ' + demoValues.join(', '));\n    renderHeap();\n  })();\n})();\n</script>\n</body>\n</html>"
