  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Radix Sort Visualizer (LSD)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724; --panel:#0b1220; --accent:#06b6d4; --muted:#94a3b8;\n      --card:#0b1220; --good:#10b981; --bad:#ef4444;\n    }\n    *{box-sizing:border-box;font-family:Inter,ui-sans-serif,system-ui,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    body{margin:0;background:linear-gradient(180deg,#071021 0%, #081429 100%); color:#e6eef6; min-height:100vh;}\n    .wrap{max-width:1100px;margin:28px auto;padding:20px;}\n    header{display:flex;align-items:center;gap:18px;margin-bottom:18px}\n    header h1{font-size:20px;margin:0}\n    .controls{display:flex;flex-wrap:wrap;gap:10px;align-items:center}\n    .control{background:var(--card);padding:10px;border-radius:8px;display:flex;gap:8px;align-items:center}\n    label{font-size:13px;color:var(--muted)}\n    input[type=number], select{padding:6px;border-radius:6px;border:1px solid rgba(255,255,255,0.06);background:#061323;color:var(--muted);width:100px}\n    button{background:linear-gradient(180deg, rgba(255,255,255,0.03), transparent);color:#e6eef6;border:1px solid rgba(255,255,255,0.06);padding:8px 12px;border-radius:8px;cursor:pointer}\n    button:active{transform:translateY(1px)}\n    button.secondary{background:transparent;border:1px solid rgba(255,255,255,0.06)}\n    .main{\n      display:grid;grid-template-columns:1fr 360px;gap:18px;margin-top:18px;\n    }\n    .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent); padding:14px;border-radius:12px;border:1px solid rgba(255,255,255,0.04)}\n    .visual{min-height:320px;display:flex;flex-direction:column;gap:12px}\n    .array-row{display:flex;gap:8px;align-items:end;padding:10px;border-radius:8px;background:linear-gradient(180deg,#041027,transparent);min-height:92px}\n    .item{\n      min-width:40px;height:48px;border-radius:8px;background:linear-gradient(180deg,#083241,#042231);display:flex;align-items:center;justify-content:center;font-weight:600;color:#dff8ff;border:1px solid rgba(255,255,255,0.04);\n      position:relative;transition:transform 300ms ease,opacity 200ms ease;\n    }\n    .small{min-width:36px;height:36px;font-size:13px}\n    .label{font-size:12px;color:var(--muted);margin-bottom:6px}\n    .buckets{display:grid;grid-template-columns:repeat(auto-fill,minmax(56px,1fr));gap:10px}\n    .bucket{background:linear-gradient(180deg,#041027,transparent);padding:8px;border-radius:8px;min-height:80px;border:1px dashed rgba(255,255,255,0.03)}\n    .bucket .bucket-title{font-size:13px;color:var(--muted);margin-bottom:6px;text-align:center}\n    .bucket-list{display:flex;flex-direction:column;gap:6px;align-items:center;min-height:40px}\n    .bucket .item{min-width:44px;height:36px;font-size:13px}\n    .meta{display:flex;flex-direction:column;gap:8px}\n    .stats{display:flex;gap:8px;flex-wrap:wrap}\n    .stat{background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;font-size:13px}\n    .code{background:#071728;padding:12px;border-radius:8px;border:1px solid rgba(255,255,255,0.03);font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;font-size:13px;color:#bfeeff;white-space:pre;overflow:auto;max-height:220px}\n    .explain{font-size:13px;color:var(--muted);line-height:1.45}\n    .highlight{outline:2px solid rgba(6,182,212,0.18);box-shadow:0 6px 20px rgba(6,182,212,0.06);border-radius:8px}\n    .current-digit{background:linear-gradient(90deg,#063741,#05333a);padding:6px 8px;border-radius:8px;font-weight:700}\n    .footer{margin-top:12px;font-size:13px;color:var(--muted)}\n    .kbd{background:#05202a;padding:4px 8px;border-radius:6px;border:1px solid rgba(255,255,255,0.03)}\n    .speed{display:flex;align-items:center;gap:8px}\n    input[type=range]{width:120px}\n    .note{font-size:13px;color:var(--muted)}\n    @media (max-width:920px){\n      .main{grid-template-columns:1fr;gap:12px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <header>\n      <div>\n        <h1>Radix Sort Visualizer (Least Significant Digit - LSD)</h1>\n        <div class=\"note\">Stable integer sort using digit-by-digit distribution into buckets. Works best for non-negative integers.</div>\n      </div>\n      <div style=\"margin-left:auto\"></div>\n    </header>\n\n    <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n      <div class=\"control\">\n        <label for=\"size\">Size</label>\n        <input id=\"size\" type=\"number\" min=\"2\" max=\"40\" value=\"12\">\n      </div>\n\n      <div class=\"control\">\n        <label for=\"maxval\">Max value</label>\n        <input id=\"maxval\" type=\"number\" min=\"1\" max=\"99999\" value=\"999\">\n      </div>\n\n      <div class=\"control\">\n        <label for=\"base\">Radix (base)</label>\n        <select id=\"base\">\n          <option value=\"10\">10 (decimal)</option>\n          <option value=\"2\">2 (binary)</option>\n          <option value=\"16\">16 (hex)</option>\n        </select>\n      </div>\n\n      <div class=\"control\">\n        <label for=\"speed\">Speed</label>\n        <div class=\"speed\">\n          <input id=\"speed\" type=\"range\" min=\"100\" max=\"1500\" value=\"700\">\n          <div id=\"speedVal\" style=\"font-size:13px;color:var(--muted)\">700ms</div>\n        </div>\n      </div>\n\n      <div class=\"control\">\n        <button id=\"generate\">Generate</button>\n        <button id=\"start\">Start</button>\n        <button id=\"step\" class=\"secondary\">Step</button>\n        <button id=\"reset\" class=\"secondary\">Reset</button>\n      </div>\n    </div>\n\n    <div class=\"main\">\n      <div class=\"panel\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div>\n            <div class=\"label\">Array</div>\n            <div id=\"arrayRow\" class=\"array-row\" aria-live=\"polite\"></div>\n          </div>\n          <div style=\"min-width:240px\">\n            <div class=\"meta\">\n              <div class=\"stats\">\n                <div class=\"stat\">Pass: <span id=\"pass\">0</span>/<span id=\"totalPasses\">0</span></div>\n                <div class=\"stat\">Current digit: <span id=\"digitIndex\" class=\"current-digit\">-</span></div>\n                <div class=\"stat\">Base: <span id=\"currentBase\">10</span></div>\n                <div class=\"stat\">Stable: <span style=\"color:var(--good)\">Yes</span></div>\n              </div>\n              <div style=\"margin-top:6px\" class=\"explain\">\n                <div><strong>How it works (LSD):</strong></div>\n                - For each digit from least significant to most, place numbers into buckets according to that digit.<br>\n                - Then collect buckets in order to form the new array; repeat for next digit.<br>\n                - Complexity: O(n * d) where d is number of digits (log_base(max)).\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:14px\">\n          <div class=\"label\">Buckets</div>\n          <div id=\"buckets\" class=\"buckets\" aria-live=\"polite\"></div>\n        </div>\n\n      </div>\n\n      <div class=\"panel\">\n        <div class=\"label\">Algorithm (LSD Radix Sort)</div>\n        <div class=\"code\" id=\"pseudocode\">\n// Pseudocode (LSD Radix Sort)\nradixSort(A, base):\n  maxVal = max(A)\n  d = number of digits of maxVal in base\n  for digit = 0 to d-1:\n    // Distribute into buckets 0..base-1\n    for each x in A:\n      key = digitValue(x, digit, base)\n      buckets[key].append(x)\n    // Collect buckets in order (stable)\n    A = concatenate buckets[0], buckets[1], ..., buckets[base-1]\n    clear all buckets\n        </div>\n\n        <div style=\"margin-top:12px;display:flex;gap:8px;align-items:center\">\n          <button id=\"explainToggle\" class=\"secondary\">Toggle Explanation</button>\n        </div>\n\n        <div style=\"margin-top:12px\">\n          <div class=\"label\">Details</div>\n          <div class=\"explain\" id=\"details\">\n            - This visualizer uses LSD (least significant digit) approach and supports different bases.<br>\n            - All numbers are treated as non-negative. For negatives, you can offset values or handle signs separately.<br>\n          </div>\n        </div>\n\n        <div class=\"footer\">Tip: Use Step to move one action at a time, or Start to animate automatically.</div>\n      </div>\n    </div>\n\n  </div>\n\n  <script>\n    // Radix Sort Visualizer (LSD)\n    // Single-file, no external dependencies.\n\n    // DOM elements\n    const sizeInput = document.getElementById('size');\n    const maxvalInput = document.getElementById('maxval');\n    const baseSelect = document.getElementById('base');\n    const speedInput = document.getElementById('speed');\n    const speedVal = document.getElementById('speedVal');\n\n    const generateBtn = document.getElementById('generate');\n    const startBtn = document.getElementById('start');\n    const stepBtn = document.getElementById('step');\n    const resetBtn = document.getElementById('reset');\n\n    const arrayRow = document.getElementById('arrayRow');\n    const bucketsDiv = document.getElementById('buckets');\n\n    const passEl = document.getElementById('pass');\n    const totalPassesEl = document.getElementById('totalPasses');\n    const digitIndexEl = document.getElementById('digitIndex');\n    const currentBaseEl = document.getElementById('currentBase');\n\n    let arr = [];\n    let base = parseInt(baseSelect.value,10);\n    let maxval = parseInt(maxvalInput.value,10);\n    let size = parseInt(sizeInput.value,10);\n    let speed = parseInt(speedInput.value,10);\n\n    // Algorithm state for stepping/animation\n    let state = null;\n    let autoTimer = null;\n    let running = false;\n\n    // Utility: generate random integers\n    function randArray(n, maxv){\n      const a = [];\n      for(let i=0;i<n;i++) a.push(Math.floor(Math.random()* (maxv+1)));\n      return a;\n    }\n\n    // Render array as bars/items\n    function renderArray(list){\n      arrayRow.innerHTML = '';\n      for(let i=0;i<list.length;i++){\n        const v = list[i];\n        const div = document.createElement('div');\n        div.className = 'item';\n        div.textContent = formatValue(v);\n        div.dataset.value = String(v);\n        arrayRow.appendChild(div);\n      }\n    }\n\n    // Render buckets\n    function renderBuckets(bCount){\n      bucketsDiv.innerHTML = '';\n      for(let b=0;b<bCount;b++){\n        const bk = document.createElement('div');\n        bk.className = 'bucket';\n        bk.dataset.bucket = String(b);\n\n        const title = document.createElement('div');\n        title.className = 'bucket-title';\n        title.textContent = String(b);\n        bk.appendChild(title);\n\n        const list = document.createElement('div');\n        list.className = 'bucket-list';\n        bk.appendChild(list);\n\n        bucketsDiv.appendChild(bk);\n      }\n    }\n\n    function formatValue(v){\n      if (base === 16) return '0x' + v.toString(16).toUpperCase();\n      if (base === 2) return '0b' + v.toString(2);\n      return String(v);\n    }\n\n    // Initialize for sorting\n    function prepareState(inputArr, radix){\n      const A = inputArr.slice(); // copy\n      const maxVal = Math.max(...A, 0);\n      const digits = maxVal === 0 ? 1 : Math.floor(Math.log(maxVal) / Math.log(radix)) + 1;\n      const buckets = Array.from({length:radix}, ()=>[]);\n\n      return {\n        A,\n        radix,\n        digits,\n        currentDigit: 0, // 0..digits-1\n        phase: 'distribute', // 'distribute' or 'collect' or 'done'\n        idx: 0, // index into A during distribution\n        buckets,\n        collectBucket: 0, // bucket index during collection\n        collectIdx: 0, // index inside bucket during collection\n        passesCompleted: 0\n      };\n    }\n\n    // Digit extractor: get digit at position d (0 = least significant)\n    function digitValue(x, d, radix){\n      return Math.floor(x / Math.pow(radix, d)) % radix;\n    }\n\n    // UI updates for metadata\n    function updateMeta(){\n      currentBaseEl.textContent = String(base);\n      passEl.textContent = String(state ? state.passesCompleted : 0);\n      totalPassesEl.textContent = state ? String(state.digits) : '0';\n      digitIndexEl.textContent = state ? (state.currentDigit < state.digits ? String(state.currentDigit) : '-') : '-';\n    }\n\n    // Action: perform one small step (either move one element to bucket, or collect one element)\n    function stepOnce(){\n      if (!state || state.phase === 'done') {\n        running = false;\n        clearAuto();\n        return;\n      }\n\n      if (state.phase === 'distribute') {\n        // If finished distributing all items for this digit, switch to collect\n        if (state.idx >= state.A.length) {\n          state.phase = 'collect';\n          state.collectBucket = 0;\n          state.collectIdx = 0;\n          // Clear visuals for array and render buckets' lists\n          renderArray([]); // empty array during collection for clarity\n          renderBuckets(state.radix);\n          // populate bucket visuals\n          for(let b=0;b<state.radix;b++){\n            const listDiv = bucketsDiv.querySelector('.bucket[data-bucket=\"'+b+'\"] .bucket-list');\n            for(const v of state.buckets[b]){\n              const item = document.createElement('div');\n              item.className = 'item small';\n              item.textContent = formatValue(v);\n              listDiv.appendChild(item);\n            }\n          }\n          updateMeta();\n          return;\n        }\n\n        // Take next element from A at idx and move to bucket\n        const val = state.A[state.idx];\n        const key = digitValue(val, state.currentDigit, state.radix);\n        state.buckets[key].push(val);\n        // Visual: remove item from array view (we'll render remaining)\n        const remaining = state.A.slice(state.idx+1);\n        // To preserve visual of already-processed items, keep placeholders? Simpler: show remaining.\n        renderArray(remaining);\n        // Update bucket visuals: show appended element\n        renderBuckets(state.radix);\n        for(let b=0;b<state.radix;b++){\n          const listDiv = bucketsDiv.querySelector('.bucket[data-bucket=\"'+b+'\"] .bucket-list');\n          for(const v of state.buckets[b]){\n            const item = document.createElement('div');\n            item.className = 'item small';\n            item.textContent = formatValue(v);\n            listDiv.appendChild(item);\n          }\n        }\n\n        state.idx++;\n        updateMeta();\n        return;\n      }\n\n      if (state.phase === 'collect') {\n        // Find next non-empty bucket starting from collectBucket\n        while(state.collectBucket < state.radix && state.buckets[state.collectBucket].length === 0){\n          state.collectBucket++;\n        }\n        if (state.collectBucket >= state.radix){\n          // finished collecting for this digit\n          state.passesCompleted++;\n          // Apply collected array\n          let newA = [];\n          for(let b=0;b<state.radix;b++){\n            newA = newA.concat(state.buckets[b]);\n            state.buckets[b] = [];\n          }\n          state.A = newA;\n          state.currentDigit++;\n          state.idx = 0;\n          state.phase = (state.currentDigit < state.digits) ? 'distribute' : 'done';\n          // Render final array for this pass\n          renderArray(state.A);\n          renderBuckets(state.radix);\n          updateMeta();\n          return;\n        }\n\n        // Remove one element from current bucket front and append to collected array position\n        const v = state.buckets[state.collectBucket].shift();\n        // Visual: append this value to array view (we'll render as collected so far)\n        const collected = [];\n        // Reconstruct collected elements: concat processed buckets and the items already removed in earlier steps this pass.\n        for(let b=0;b<state.collectBucket;b++){\n          collected.push(...state._collectedFromBucket ? state._collectedFromBucket[b] || [] : []);\n        }\n        // Simpler approach: maintain a temporary collectList in state\n        if (!state.collectList) state.collectList = [];\n        state.collectList.push(v);\n\n        renderArray(state.collectList.concat( state.A.slice(state.idx) )); // show collected followed by remaining unprocessed (if any)\n        // update bucket visuals after removing\n        renderBuckets(state.radix);\n        for(let b=0;b<state.radix;b++){\n          const listDiv = bucketsDiv.querySelector('.bucket[data-bucket=\"'+b+'\"] .bucket-list');\n          for(const val of state.buckets[b]){\n            const item = document.createElement('div');\n            item.className = 'item small';\n            item.textContent = formatValue(val);\n            listDiv.appendChild(item);\n          }\n        }\n\n        // If this bucket is now empty, move to next bucket\n        if (state.buckets[state.collectBucket].length === 0){\n          state.collectBucket++;\n        }\n        updateMeta();\n        return;\n      }\n    }\n\n    // Start automatic stepping\n    function startAuto(){\n      if (!state || state.phase === 'done') return;\n      running = true;\n      clearAuto();\n      autoTimer = setInterval(()=>{\n        stepOnce();\n        if (state && state.phase === 'done') {\n          clearAuto();\n          running = false;\n          updateMeta();\n        }\n      }, speed);\n      startBtn.textContent = 'Pause';\n    }\n\n    function pauseAuto(){\n      running = false;\n      clearAuto();\n      startBtn.textContent = 'Start';\n    }\n\n    function clearAuto(){\n      if (autoTimer) {\n        clearInterval(autoTimer);\n        autoTimer = null;\n      }\n    }\n\n    // Reset to initial (keep array but reset sort)\n    function resetState(){\n      if (!arr) return;\n      state = prepareState(arr, base);\n      // initial render\n      renderArray(state.A);\n      renderBuckets(state.radix);\n      updateMeta();\n    }\n\n    // Wire up controls\n    generateBtn.addEventListener('click', ()=>{\n      size = Math.max(2, Math.min(40, parseInt(sizeInput.value || '12',10)));\n      maxval = Math.max(1, Math.min(99999, parseInt(maxvalInput.value || '999',10)));\n      base = parseInt(baseSelect.value,10);\n      arr = randArray(size, maxval);\n      // reset\n      clearAuto();\n      running = false;\n      startBtn.textContent = 'Start';\n      state = prepareState(arr, base);\n      renderArray(state.A);\n      renderBuckets(state.radix);\n      updateMeta();\n      // clear any collectList\n      delete state.collectList;\n    });\n\n    startBtn.addEventListener('click', ()=>{\n      if (!state) return;\n      if (running){\n        pauseAuto();\n      } else {\n        // If we are at 'done', reset to allow restart with same array\n        if (state.phase === 'done'){\n          // keep arr sorted -> start over using original arr? We'll re-prepare to run again starting from current array\n          state = prepareState(state.A, base);\n          renderBuckets(state.radix);\n        }\n        startAuto();\n      }\n    });\n\n    stepBtn.addEventListener('click', ()=>{\n      if (!state) return;\n      // If running, pause first\n      if (running) {\n        pauseAuto();\n      }\n      // perform one step\n      stepOnce();\n      // If pass ended we might need to clean collectList\n      if (state && state.phase !== 'collect') delete state.collectList;\n      if (state && state.phase === 'done') {\n        startBtn.textContent = 'Start';\n      }\n    });\n\n    resetBtn.addEventListener('click', ()=>{\n      clearAuto();\n      running = false;\n      startBtn.textContent = 'Start';\n      // Re-generate from current params\n      if (arr && arr.length) {\n        state = prepareState(arr, base);\n        renderArray(state.A);\n        renderBuckets(state.radix);\n        updateMeta();\n      }\n    });\n\n    speedInput.addEventListener('input', ()=>{\n      speed = parseInt(speedInput.value,10);\n      speedVal.textContent = speed + 'ms';\n      if (autoTimer){\n        // restart interval with new speed\n        startAuto();\n      }\n    });\n\n    baseSelect.addEventListener('change', ()=>{\n      base = parseInt(baseSelect.value,10);\n      currentBaseEl.textContent = String(base);\n      // If there's an existing array, reset state to use new base\n      if (arr) {\n        state = prepareState(arr, base);\n        renderArray(state.A);\n        renderBuckets(state.radix);\n        updateMeta();\n      }\n    });\n\n    // Explain toggle (shows/hides details)\n    document.getElementById('explainToggle').addEventListener('click', ()=>{\n      const d = document.getElementById('details');\n      d.style.display = d.style.display === 'none' ? 'block' : 'none';\n    });\n\n    // On load, generate initial array\n    (function init(){\n      size = parseInt(sizeInput.value,10);\n      maxval = parseInt(maxvalInput.value,10);\n      base = parseInt(baseSelect.value,10);\n      speed = parseInt(speedInput.value,10);\n      speedVal.textContent = speed + 'ms';\n      arr = randArray(size, maxval);\n      state = prepareState(arr, base);\n      renderArray(state.A);\n      renderBuckets(state.radix);\n      updateMeta();\n    })();\n\n    // Accessibility and small keyboard shortcuts\n    window.addEventListener('keydown', (e)=>{\n      if (e.key === ' '){ // space to start/pause\n        e.preventDefault();\n        startBtn.click();\n      } else if (e.key === 'ArrowRight'){ // step\n        stepBtn.click();\n      } else if (e.key === 'g' || e.key === 'G'){ // generate\n        generateBtn.click();\n      }\n    });\n\n    // Small note: this visualizer is designed to demonstrate the core idea:\n    //  - Distribute into digit buckets (we visualize by emptying original array as we distribute)\n    //  - Collect buckets in order (we accumulate into collectList, then commit)\n    // It intentionally breaks complex animations into clear, incremental steps for learning.\n\n  </script>\n</body>\n</html>"
  },
