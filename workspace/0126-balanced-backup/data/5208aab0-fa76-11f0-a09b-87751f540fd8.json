    "content": "<html>\n<head>\n    <title>Suffix Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        .header {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Suffix Tree</h1>\n        <p>Concept: A tree-like data structure used for efficient searching and retrieval of strings.</p>\n        <p>Example: <code>\n            <span class=\"header\">Word</span>\n            <span class=\"header\">Word</span>\n            <span class=\"header\">Word</span>\n            <span class=\"header\">Word</span>\n            <span class=\"header\">Word</span>\n        </code></p>\n        <button onclick=\"generateSuffixTree('word', 'word')\">Generate Suffix Tree</button>\n        <div id=\"tree\"></div>\n    </div>\n\n    <script>\n        function generateSuffixTree(word, suffix) {\n            if (word.length === 0) {\n                return '';\n            } else if (word[0] === suffix[0]) {\n                return generateSuffixTree(word.slice(1), suffix + word[0]);\n            } else {\n                let suffixTree = '';\n                for (let i = 0; i < word.length; i++) {\n                    suffixTree += '<span class=\"header\">' + word[i] + '</span>';\n                    let remainingWord = word.slice(i + 1);\n                    let remainingSuffix = suffix + word[i];\n                    let remainingSuffixTree = generateSuffixTree(remainingWord, remainingSuffix);\n                    suffixTree += '<span class=\"header\">' + remainingSuffixTree + '</span>';\n                }\n                return suffixTree;\n            }\n        }\n\n        let word = 'word';\n        let suffix = 'word';\n        let tree = generateSuffixTree(word, suffix);\n        document.getElementById('tree').innerHTML = '<div id=\"tree\"></div>';\n        document.getElementById('tree').innerHTML += tree;\n    </script>\n</body>\n</html>"
