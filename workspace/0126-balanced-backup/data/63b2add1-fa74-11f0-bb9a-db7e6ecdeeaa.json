    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Deadlock Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n  }\n  h1 {\n    text-align:center;\n  }\n  #log {\n    white-space: pre-wrap;\n    background-color: #f4f4f4;\n    border: 1px solid #ccc;\n    height: 300px;\n    overflow-y: scroll;\n    padding: 10px;\n    margin-top: 20px;\n  }\n  button {\n    display: block;\n    margin: 0 auto;\n    padding: 10px 20px;\n    font-size: 16px;\n  }\n</style>\n</head>\n<body>\n<h1>Deadlock Demonstration</h1>\n<p>This example simulates a deadlock situation between two simulated \"threads\" trying to acquire two resources in opposite order.</p>\n<button id=\"startBtn\">Start Deadlock Simulation</button>\n\n<div id=\"log\"></div>\n\n<script>\n// Simulate resources as locks\nclass Lock {\n  constructor(name) {\n    this.name = name;\n    this.isLocked = false;\n    this.queue = [];\n  }\n\n  acquire(taskName) {\n    return new Promise(resolve => {\n      const attemptLock = () => {\n        if (!this.isLocked) {\n          this.isLocked = true;\n          log(`${taskName} acquired lock on ${this.name}`);\n          resolve();\n        } else {\n          // Push attemptLock to queue to retry later\n          this.queue.push(attemptLock);\n        }\n      };\n      attemptLock();\n    });\n  }\n\n  release(taskName) {\n    this.isLocked = false;\n    log(`${taskName} released lock on ${this.name}`);\n    if (this.queue.length > 0) {\n      const nextAttempt = this.queue.shift();\n      // Schedule next attempt asynchronously to avoid call stack overflow\n      setTimeout(nextAttempt, 0);\n    }\n  }\n}\n\n// Simple log utility\nconst logDiv = document.getElementById(\"log\");\nfunction log(msg) {\n  const time = new Date().toLocaleTimeString();\n  logDiv.textContent += `[${time}] ${msg}\\n`;\n  logDiv.scrollTop = logDiv.scrollHeight;\n}\n\n// Deadlock simulation\nasync function task(name, firstLock, secondLock) {\n  log(`${name} started and tries to acquire ${firstLock.name}`);\n  await firstLock.acquire(name);\n\n  // Simulate some processing delay before trying to acquire second lock\n  await sleep(1000);\n\n  log(`${name} tries to acquire ${secondLock.name}`);\n  await secondLock.acquire(name);\n\n  // If both locks acquired, simulate some work then release both\n  log(`${name} acquired both locks. Working...`);\n  await sleep(1000);\n\n  secondLock.release(name);\n  firstLock.release(name);\n  log(`${name} finished its work and released both locks.`);\n}\n\nfunction sleep(ms) {\n  return new Promise(resolve => setTimeout(resolve, ms));\n}\n\ndocument.getElementById(\"startBtn\").addEventListener(\"click\", () => {\n  logDiv.textContent = \"\";\n  log(\"Starting deadlock simulation...\");\n\n  const resourceA = new Lock(\"Resource A\");\n  const resourceB = new Lock(\"Resource B\");\n\n  // Task1 tries to lock Resource A then Resource B\n  task(\"Task 1\", resourceA, resourceB);\n\n  // Task2 tries to lock Resource B then Resource A\n  task(\"Task 2\", resourceB, resourceA);\n\n  // Because each task holds one resource and waits for the other\n  // this creates a deadlock, resulting in neither task finishing.\n  log(\"Both tasks started. They will deadlock trying to acquire the second resource.\");\n});\n</script>\n</body>\n</html>"
