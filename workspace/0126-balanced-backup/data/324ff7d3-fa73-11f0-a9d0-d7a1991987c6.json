    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Random Forest Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n\n        #chart {\n            margin-top: 20px;\n        }\n        \n        #info {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            background-color: #f9f9f9;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Random Forest Visualization</h1>\n<p>This simple demonstration explains the concept of Random Forest by simulating a classification task.</p>\n<button id=\"run\">Run Random Forest Simulation</button>\n\n<div id=\"chart\"></div>\n\n<div id=\"info\">\n    <h3>Model Summary</h3>\n    <pre id=\"modelSummary\"></pre>\n</div>\n\n<script>\n    // Simulating a dataset with 2 classes\n    const data = [];\n    for (let i = 0; i < 100; i++) {\n        // Class 0\n        data.push({ x: Math.random(), y: Math.random(), label: 0 }); \n        // Class 1\n        data.push({ x: Math.random() + 0.5, y: Math.random() + 0.5, label: 1 });\n    }\n\n    function createRandomForest(data, nTrees) {\n        const trees = [];\n\n        for (let i = 0; i < nTrees; i++) {\n            // Bootstrap sampling\n            const sample = [];\n            const sampleIndices = new Set();\n            while (sample.length < data.length) {\n                const randomIndex = Math.floor(Math.random() * data.length);\n                if (!sampleIndices.has(randomIndex)) {\n                    sample.push(data[randomIndex]);\n                    sampleIndices.add(randomIndex);\n                }\n            }\n            trees.push(buildTree(sample));\n        }\n\n        return trees;\n    }\n\n    function buildTree(data) {\n        // This function currently only classifies based on majority vote\n        const counts = {};\n        data.forEach(d => {\n            counts[d.label] = (counts[d.label] || 0) + 1;\n        });\n        return counts[0] > counts[1] ? 0 : 1;\n    }\n\n    function classify(trees, point) {\n        const votes = {};\n        trees.forEach(tree => {\n            const prediction = tree;\n            votes[prediction] = (votes[prediction] || 0) + 1;\n        });\n        return Object.keys(votes).reduce((a, b) => votes[a] > votes[b] ? a : b);\n    }\n\n    document.getElementById('run').addEventListener('click', () => {\n        const nTrees = 10;\n        const trees = createRandomForest(data, nTrees);\n        const predictions = data.map(point => classify(trees, point));\n\n        // Display classification results\n        const modelSummary = `\n        Number of Trees: ${nTrees}\n        Predictions: [${predictions.join(', ')}]\n        `;\n        document.getElementById('modelSummary').innerText = modelSummary;\n\n        // Draw chart to visualize points and their labels\n        drawChart(data, predictions);\n    });\n\n    function drawChart(data, predictions) {\n        const canvas = document.createElement('canvas');\n        canvas.width = 400;\n        canvas.height = 400;\n        document.getElementById('chart').innerHTML = ''; // Clear previous chart\n        document.getElementById('chart').appendChild(canvas);\n        const ctx = canvas.getContext('2d');\n\n        data.forEach((point, index) => {\n            ctx.fillStyle = predictions[index] == 0 ? 'skyblue' : 'salmon';\n            ctx.beginPath();\n            ctx.arc(point.x * 400, point.y * 400, 5, 0, Math.PI * 2);\n            ctx.fill();\n        });\n    }\n</script>\n\n</body>\n</html>"
