    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Two Pointers Technique Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f0f0;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 1rem;\n  }\n  #container {\n    max-width: 700px;\n    margin: 0 auto;\n    background: white;\n    padding: 1.5rem;\n    border-radius: 8px;\n    box-shadow: 0 0 12px rgba(0,0,0,0.15);\n  }\n  label, select, button {\n    font-size: 1rem;\n  }\n  label {\n    display: block;\n    margin-bottom: 0.25rem;\n  }\n  select {\n    padding: 0.3rem;\n    margin-bottom: 1rem;\n    width: 100%;\n    box-sizing: border-box;\n  }\n  button {\n    padding: 0.5rem 1rem;\n    margin-bottom: 1rem;\n    cursor: pointer;\n    background-color: #0078d7;\n    border: none;\n    color: white;\n    border-radius: 4px;\n  }\n  button:hover {\n    background-color: #005fa3;\n  }\n  #arrayDisplay {\n    display: flex;\n    justify-content: center;\n    margin-bottom: 1rem;\n  }\n  .arrayItem {\n    min-width: 40px;\n    min-height: 40px;\n    margin: 0 4px;\n    background-color: #ddd;\n    color: #333;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    border-radius: 4px;\n    position: relative;\n    font-weight: 600;\n    transition: background-color 0.3s;\n  }\n  .pointer-left {\n    background-color: #4caf50;\n    color: white;\n  }\n  .pointer-right {\n    background-color: #f44336;\n    color: white;\n  }\n  .pointer-both {\n    background-color: #ff9800;\n    color: white;\n  }\n  #log {\n    background: #222;\n    color: #0f0;\n    font-family: monospace;\n    height: 180px;\n    overflow-y: auto;\n    padding: 0.75rem;\n    border-radius: 6px;\n    white-space: pre-wrap;\n  }\n  #explanation {\n    margin-top: 1rem;\n    background: #e1f5fe;\n    border-left: 6px solid #0277bd;\n    padding: 0.75rem 1rem;\n    border-radius: 4px;\n  }\n  a {\n    color: #0277bd;\n  }\n</style>\n</head>\n<body>\n  <div id=\"container\">\n    <h1>Two Pointers Technique Demonstration</h1>\n    <p>\n      The <strong>Two Pointers</strong> technique is a common algorithmic approach used to solve problems involving arrays or lists by using two indices that move towards each other or in the same direction, to efficiently find or check certain conditions.\n    </p>\n\n    <label for=\"demoSelect\">Choose a demonstration:</label>\n    <select id=\"demoSelect\">\n      <option value=\"pairSumSorted\">Find Pair with Given Sum (Sorted Array)</option>\n      <option value=\"removeDuplicates\">Remove Duplicates from Sorted Array</option>\n      <option value=\"palindromeCheck\">Check if String is Palindrome</option>\n    </select>\n    <button id=\"startBtn\">Start Demo</button>\n\n    <div id=\"arrayDisplay\"></div>\n\n    <div id=\"log\"></div>\n\n    <div id=\"explanation\"></div>\n  </div>\n\n<script>\n(function(){\n  const demoSelect = document.getElementById('demoSelect');\n  const startBtn = document.getElementById('startBtn');\n  const arrayDisplay = document.getElementById('arrayDisplay');\n  const log = document.getElementById('log');\n  const explanation = document.getElementById('explanation');\n\n  // Clear display areas\n  function resetDisplay() {\n    arrayDisplay.innerHTML = '';\n    log.textContent = '';\n    explanation.innerHTML = '';\n  }\n\n  // Utility to log messages with scrolling\n  function writeLog(msg) {\n    log.textContent += msg + '\\n';\n    log.scrollTop = log.scrollHeight;\n  }\n\n  // Visualize an array with pointers\n  // pointers: { left: index?, right: index? }\n  function displayArray(arr, pointers) {\n    arrayDisplay.innerHTML = '';\n    for(let i = 0; i < arr.length; i++) {\n      const div = document.createElement('div');\n      div.classList.add('arrayItem');\n      div.textContent = arr[i];\n      let leftP = pointers.left === i;\n      let rightP = pointers.right === i;\n\n      if(leftP && rightP){\n        div.classList.add('pointer-both');\n      } else if (leftP){\n        div.classList.add('pointer-left');\n      } else if (rightP){\n        div.classList.add('pointer-right');\n      }\n      arrayDisplay.appendChild(div);\n    }\n  }\n\n  // Demo 1: Find pair with given sum in sorted array using two pointers (from both ends)\n  async function demoPairSumSorted() {\n    resetDisplay();\n    explanation.innerHTML = `<strong>Problem:</strong> Given a sorted array, find if there is a pair of numbers which add up to a target sum.<br>\n    <br>\n    <strong>Approach:</strong> Use two pointers starting at the beginning and end. Move pointers depending on sum comparison.<br>\n    <br>\n    <a href=\"https://www.geeksforgeeks.org/two-pointers\" target=\"_blank\" rel=\"noopener\">Learn more about Two Pointers</a>`;\n\n    const arr = [1, 3, 4, 5, 7, 10, 12];\n    const target = 9;\n    writeLog(`Array: [${arr.join(', ')}]`);\n    writeLog(`Target Sum: ${target}`);\n    await sleep(1000);\n\n    let left = 0;\n    let right = arr.length - 1;\n    \n    while(left < right) {\n      displayArray(arr, {left, right});\n      const sum = arr[left] + arr[right];\n      writeLog(`Checking: arr[${left}] + arr[${right}] = ${arr[left]} + ${arr[right]} = ${sum}`);\n\n      if(sum === target) {\n        writeLog(`Found pair: (${arr[left]}, ${arr[right]})`);\n        displayArray(arr, {left, right});\n        return;\n      } else if(sum < target) {\n        writeLog(`Sum less than target. Moving left pointer from index ${left} to ${left + 1}`);\n        left++;\n      } else {\n        writeLog(`Sum greater than target. Moving right pointer from index ${right} to ${right - 1}`);\n        right--;\n      }\n      await sleep(1500);\n    }\n\n    writeLog('No pair found with the given sum.');\n    displayArray(arr, {});\n  }\n\n  // Demo 2: Remove duplicates from sorted array in-place using two pointers\n  // Returns length of new array (unique elements)\n  async function demoRemoveDuplicates() {\n    resetDisplay();\n    explanation.innerHTML = `<strong>Problem:</strong> Given a sorted array, remove duplicates in place such that each element appears only once.<br>\n    Return the length of the modified array.<br>\n    <br>\n    <strong>Approach:</strong> Use two pointers: one for iterating (fast), and one for position to place unique items (slow).<br>\n    <br>\n    <a href=\"https://leetcode.com/problems/remove-duplicates-from-sorted-array/\" target=\"_blank\" rel=\"noopener\">LeetCode #26</a>`;\n\n    let arr = [0,0,1,1,1,2,2,3,3,4];\n    writeLog(`Original array: [${arr.join(', ')}]`);\n    await sleep(1000);\n\n    let slow = 0;\n    displayArray(arr, {left: slow, right: null});\n    writeLog(`Starting with slow pointer at index ${slow}`);\n    await sleep(1500);\n\n    for(let fast = 1; fast < arr.length; fast++) {\n      displayArray(arr, {left: slow, right: fast});\n      writeLog(`Comparing arr[fast]: arr[${fast}] = ${arr[fast]} and arr[slow]: arr[${slow}] = ${arr[slow]}`);\n\n      if(arr[fast] !== arr[slow]){\n        slow++;\n        writeLog(`Found new unique element ${arr[fast]}. Move slow pointer to ${slow} and update arr[${slow}]`);\n        arr[slow] = arr[fast];\n        displayArray(arr, {left: slow, right: fast});\n      } else {\n        writeLog(`Duplicate found: ${arr[fast]}. Moving fast pointer ahead.`);\n      }\n      await sleep(1200);\n    }\n\n    const length = slow + 1;\n    writeLog(`\\nFinal length of unique elements: ${length}`);\n    writeLog(`Modified array (only first ${length} elements valid): [${arr.slice(0, length).join(', ')}]`);\n    displayArray(arr, {});\n  }\n\n  // Demo 3: Check if string is palindrome using two pointers\n  async function demoPalindromeCheck() {\n    resetDisplay();\n    explanation.innerHTML = `<strong>Problem:</strong> Check if a given string is a palindrome.<br>\n    <br>\n    <strong>Approach:</strong> Use two pointers, one at start and one at end, compare characters moving towards center.<br>\n    <br>\n    <a href=\"https://leetcode.com/problems/valid-palindrome/\" target=\"_blank\" rel=\"noopener\">LeetCode #125</a>`;\n\n    const s = \"racecar\";\n    writeLog(`Checking string: \"${s}\"`);\n    await sleep(1000);\n\n    let left = 0;\n    let right = s.length - 1;\n\n    while(left < right) {\n      displayString(s, left, right);\n      writeLog(`Comparing s[${left}] = '${s[left]}' and s[${right}] = '${s[right]}'`);\n      if(s[left] !== s[right]) {\n        writeLog('Characters do not match. Not a palindrome.');\n        displayString(s, left, right, false);\n        return;\n      }\n      writeLog('Characters match. Move pointers inward.');\n      left++;\n      right--;\n      await sleep(1300);\n    }\n\n    writeLog('All characters matched. It is a palindrome!');\n    displayString(s, -1, -1, true);\n  }\n\n  // Visualize string with pointers\n  function displayString(str, left, right, isPalindrome) {\n    arrayDisplay.innerHTML = '';\n    for(let i = 0; i < str.length; i++) {\n      const div = document.createElement('div');\n      div.classList.add('arrayItem');\n      div.textContent = str[i];\n      if(i === left && i === right){\n        div.classList.add('pointer-both');\n      } else if(i === left) {\n        div.classList.add('pointer-left');\n      } else if(i === right){\n        div.classList.add('pointer-right');\n      }\n      arrayDisplay.appendChild(div);\n    }\n    if(isPalindrome === false){\n      explanation.innerHTML += `<br><strong>Result:</strong> Not a palindrome.`;\n    } else if(isPalindrome === true){\n      explanation.innerHTML += `<br><strong>Result:</strong> It is a palindrome!`;\n    }\n  }\n\n  // Simple sleep promise\n  function sleep(ms){\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  async function startDemo() {\n    startBtn.disabled = true;\n    const val = demoSelect.value;\n\n    if(val === 'pairSumSorted') {\n      await demoPairSumSorted();\n    } else if(val === 'removeDuplicates') {\n      await demoRemoveDuplicates();\n    } else if(val === 'palindromeCheck') {\n      await demoPalindromeCheck();\n    }\n\n    writeLog('\\nDemo finished.');\n    startBtn.disabled = false;\n  }\n\n  startBtn.addEventListener('click', startDemo);\n})();\n</script>\n</body>\n</html>"
  },
