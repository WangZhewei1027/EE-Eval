    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Transaction Concept Demonstration</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      max-width: 700px;\n      margin: 2rem auto;\n      padding: 1rem;\n      background-color: #f5f5f5;\n    }\n    h1, h2 {\n      color: #333;\n    }\n    button {\n      padding: 0.5rem 1rem;\n      font-size: 1rem;\n      margin-top: 0.5rem;\n      cursor: pointer;\n      border: none;\n      border-radius: 4px;\n      background-color: #007bff;\n      color: white;\n    }\n    button:disabled {\n      background-color: #888;\n      cursor: not-allowed;\n    }\n    .balances {\n      display: flex;\n      justify-content: space-around;\n      margin-top: 1rem;\n      background: white;\n      padding: 1rem;\n      border-radius: 8px;\n      box-shadow: 0 0 8px rgba(0,0,0,0.1);\n    }\n    .account {\n      text-align: center;\n    }\n    .log {\n      background: #222;\n      color: #eee;\n      margin-top: 1rem;\n      padding: 1rem;\n      height: 200px;\n      overflow-y: auto;\n      border-radius: 8px;\n      font-family: monospace;\n      font-size: 0.9rem;\n      white-space: pre-wrap;\n    }\n  </style>\n</head>\n<body>\n  <h1>Transaction Concept Demonstration</h1>\n  <p>\n    This demo simulates a bank transfer transaction between two accounts. A <strong>transaction</strong> groups multiple operations in an atomic way:\n    <ul>\n      <li>Either <strong>all</strong> operations succeed (commit), or</li>\n      <li>None are applied (rollback) if any operation fails</li>\n    </ul>\n    Here, we simulate this by trying to debit Account A and credit Account B. If debit fails (e.g. insufficient funds), transaction aborts and no balance changes apply.\n  </p>\n\n  <div class=\"balances\">\n    <div class=\"account\">\n      <h2>Account A</h2>\n      <div>Balance: $<span id=\"balanceA\">1000</span></div>\n    </div>\n    <div class=\"account\">\n      <h2>Account B</h2>\n      <div>Balance: $<span id=\"balanceB\">500</span></div>\n    </div>\n  </div>\n\n  <div style=\"margin-top:1rem;\">\n    <label for=\"transferAmount\">Transfer Amount: $</label>\n    <input type=\"number\" id=\"transferAmount\" min=\"1\" max=\"10000\" value=\"100\" />\n    <button id=\"transferBtn\">Transfer from A to B</button>\n  </div>\n\n  <div class=\"log\" id=\"log\"></div>\n\n  <script>\n    /* \n      We simulate accounts and a simple transaction manager.\n      Transaction ensures both debit and credit succeed, or changes are rolled back.\n    */\n\n    // Accounts stored as objects with balance\n    const accounts = {\n      A: { balance: 1000 },\n      B: { balance: 500 }\n    };\n\n    // Elements\n    const balanceAElem = document.getElementById('balanceA');\n    const balanceBElem = document.getElementById('balanceB');\n    const transferAmountInput = document.getElementById('transferAmount');\n    const transferBtn = document.getElementById('transferBtn');\n    const logElem = document.getElementById('log');\n\n    // Update balances display\n    function updateBalances() {\n      balanceAElem.textContent = accounts.A.balance.toFixed(2);\n      balanceBElem.textContent = accounts.B.balance.toFixed(2);\n    }\n\n    // Simple function to log messages\n    function log(message) {\n      const now = new Date().toLocaleTimeString();\n      logElem.textContent += `[${now}] ${message}\\n`;\n      logElem.scrollTop = logElem.scrollHeight;\n    }\n\n    // Transaction class simulates beginning, commit, rollback\n    class Transaction {\n      constructor() {\n        this.localState = {};\n        this.hasBegun = false;\n      }\n\n      begin() {\n        // Snapshot balances\n        this.localState = {\n          A: accounts.A.balance,\n          B: accounts.B.balance\n        };\n        this.hasBegun = true;\n        log('Transaction started. Snapshot: ' + JSON.stringify(this.localState));\n      }\n\n      debit(accountKey, amount) {\n        if (!this.hasBegun) throw new Error('Transaction not started');\n        if (!(accountKey in this.localState)) throw new Error('Account not found in transaction');\n\n        if (amount <= 0) throw new Error('Debit amount must be positive');\n\n        const newBalance = this.localState[accountKey] - amount;\n        if (newBalance < 0) {\n          throw new Error(`Insufficient funds in account ${accountKey}`);\n        }\n        this.localState[accountKey] = newBalance;\n        log(`Debited $${amount.toFixed(2)} from Account ${accountKey}. Temp balance: $${newBalance.toFixed(2)}`);\n      }\n\n      credit(accountKey, amount) {\n        if (!this.hasBegun) throw new Error('Transaction not started');\n        if (!(accountKey in this.localState)) throw new Error('Account not found in transaction');\n\n        if (amount <= 0) throw new Error('Credit amount must be positive');\n\n        const newBalance = this.localState[accountKey] + amount;\n        this.localState[accountKey] = newBalance;\n        log(`Credited $${amount.toFixed(2)} to Account ${accountKey}. Temp balance: $${newBalance.toFixed(2)}`);\n      }\n\n      commit() {\n        if (!this.hasBegun) throw new Error('Transaction not started');\n\n        // Apply local state to real accounts atomically\n        accounts.A.balance = this.localState.A;\n        accounts.B.balance = this.localState.B;\n\n        this.hasBegun = false;\n        log('Transaction committed: balances updated.');\n      }\n\n      rollback() {\n        if (!this.hasBegun) throw new Error('Transaction not started');\n        this.hasBegun = false;\n        log('Transaction rolled back: no changes applied.');\n      }\n    }\n\n    // Handle transfer button click\n    transferBtn.addEventListener('click', () => {\n      let amount = parseFloat(transferAmountInput.value);\n      if (isNaN(amount) || amount <= 0) {\n        alert('Please enter a valid positive transfer amount');\n        return;\n      }\n\n      transferBtn.disabled = true;\n      log(`\\n----- Starting transfer of $${amount.toFixed(2)} from Account A to B -----`);\n\n      const tx = new Transaction();\n      try {\n        tx.begin();\n        tx.debit('A', amount);\n        tx.credit('B', amount);\n        tx.commit();\n        updateBalances();\n        log(`Transfer successful. $${amount.toFixed(2)} moved from Account A to Account B.`);\n      } catch (e) {\n        tx.rollback();\n        log(`Transfer failed: ${e.message}`);\n        alert(`Transfer failed: ${e.message}`);\n      } finally {\n        transferBtn.disabled = false;\n      }\n    });\n\n    updateBalances();\n    log(\"Demo ready. Set an amount and click 'Transfer from A to B' to start a new transaction.\");\n  </script>\n</body>\n</html>"
  },
