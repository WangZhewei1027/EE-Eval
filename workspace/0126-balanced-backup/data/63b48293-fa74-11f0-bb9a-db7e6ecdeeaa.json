    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Overfitting Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n  }\n  h1 {\n    text-align: center;\n  }\n  #canvas-container {\n    display: flex;\n    justify-content: center;\n    margin-top: 20px;\n  }\n  canvas {\n    border: 1px solid #ccc;\n    margin: 0 10px;\n  }\n  #info {\n    max-width: 600px;\n    margin: 20px auto;\n    line-height: 1.5;\n  }\n  label {\n    display: block;\n    margin-top: 10px;\n  }\n  input[type=\"range\"] {\n    width: 100%;\n  }\n  #error {\n    margin-top: 10px;\n    font-weight: bold;\n  }\n  #footer {\n    margin-top: 40px;\n    font-size: 0.9em;\n    color: #666;\n    text-align:center;\n  }\n</style>\n</head>\n<body>\n<h1>Overfitting Demonstration</h1>\n<div id=\"info\">\n  <p>\n    This demo shows a simple regression problem with noisy data points generated from a known function.\n    You can fit different polynomial curves to the data by adjusting the polynomial degree using the slider.\n    <strong>Underfitting</strong> occurs when the model degree is too low and can't capture the true pattern,\n    while <strong>overfitting</strong> happens when the degree is too high, making the model capture noise as if it were signal.\n  </p>\n  <p>\n    The plot on the left shows the original noisy data points and the true underlying function (dashed line).\n    The plot on the right shows the fitted polynomial curve for the degree you selected.\n  </p>\n  <label for=\"degreeRange\">Polynomial Degree: <span id=\"degreeValue\">1</span></label>\n  <input type=\"range\" id=\"degreeRange\" min=\"0\" max=\"15\" step=\"1\" value=\"1\"/>\n  <div id=\"error\"></div>\n</div>\n<div id=\"canvas-container\">\n  <canvas id=\"canvasData\" width=\"400\" height=\"300\" aria-label=\"Plot of data points and true function\"></canvas>\n  <canvas id=\"canvasFit\" width=\"400\" height=\"300\" aria-label=\"Plot of fitted polynomial curve\"></canvas>\n</div>\n\n<script>\n  // Generate synthetic data from a true function with noise\n  const canvasData = document.getElementById(\"canvasData\");\n  const ctxData = canvasData.getContext(\"2d\");\n  const canvasFit = document.getElementById(\"canvasFit\");\n  const ctxFit = canvasFit.getContext(\"2d\");\n  const degreeRange = document.getElementById(\"degreeRange\");\n  const degreeValue = document.getElementById(\"degreeValue\");\n  const errorDisplay = document.getElementById(\"error\");\n\n  const WIDTH = canvasData.width;\n  const HEIGHT = canvasData.height;\n\n  // True function: sin(2*pi*x)\n  function trueFunction(x) {\n    return Math.sin(2 * Math.PI * x);\n  }\n\n  // Generate noisy data points\n  const NUM_POINTS = 30;\n  const noiseSigma = 0.3;\n  let dataPoints = [];\n  for(let i=0; i < NUM_POINTS; i++){\n    let x = i/(NUM_POINTS - 1);\n    let y = trueFunction(x) + (Math.random() * 2 - 1) * noiseSigma;\n    dataPoints.push({x: x, y: y});\n  }\n\n  // Coordinate mapping helpers\n  function xToCanvas(x) {\n    return x * (WIDTH - 40) + 30;\n  }\n  function yToCanvas(y) {\n    // y range ~ [-1.5 to 1.5]\n    return HEIGHT/2 - (y * (HEIGHT/3));\n  }\n\n  // Draw axes & true function and points on left canvas\n  function drawDataCanvas() {\n    ctxData.clearRect(0, 0, WIDTH, HEIGHT);\n    ctxData.font = \"12px sans-serif\";\n    ctxData.fillStyle = \"#000\";\n\n    // Draw axes\n    ctxData.strokeStyle = \"#aaa\";\n    ctxData.lineWidth = 1;\n    // x axis\n    ctxData.beginPath();\n    ctxData.moveTo(xToCanvas(0), yToCanvas(0));\n    ctxData.lineTo(xToCanvas(1), yToCanvas(0));\n    ctxData.stroke();\n    // y axis\n    ctxData.beginPath();\n    ctxData.moveTo(xToCanvas(0), yToCanvas(1.5));\n    ctxData.lineTo(xToCanvas(0), yToCanvas(-1.5));\n    ctxData.stroke();\n\n    // Draw true function (dashed)\n    ctxData.strokeStyle = \"green\";\n    ctxData.lineWidth = 2;\n    ctxData.setLineDash([5, 5]);\n    ctxData.beginPath();\n    for (let i=0; i<=100; i++){\n      let x = i/100;\n      let y = trueFunction(x);\n      let cx = xToCanvas(x);\n      let cy = yToCanvas(y);\n      if(i===0) ctxData.moveTo(cx, cy);\n      else ctxData.lineTo(cx, cy);\n    }\n    ctxData.stroke();\n    ctxData.setLineDash([]);\n\n    // Draw data points\n    ctxData.fillStyle = \"blue\";\n    for(let pt of dataPoints){\n      ctxData.beginPath();\n      ctxData.arc(xToCanvas(pt.x), yToCanvas(pt.y), 4, 0, 2*Math.PI);\n      ctxData.fill();\n    }\n\n    // Labels\n    ctxData.fillStyle = \"black\";\n    ctxData.fillText(\"True Function (green dashed)\", 160, 20);\n    ctxData.fillText(\"Noisy Data Points (blue)\", 160, 40);\n  }\n\n  // Polynomial regression fitting using normal equations\n  // returns array of coefficients, lowest power first\n  function polyFit(data, degree) {\n    if (degree < 0) return [];\n\n    const N = data.length;\n    const X = [];\n    const Y = [];\n\n    for(let i=0; i<N; i++){\n      // design matrix row with powers of x\n      let row = [];\n      for(let d=0; d<=degree; d++){\n        row.push(Math.pow(data[i].x, d));\n      }\n      X.push(row);\n      Y.push(data[i].y);\n    }\n\n    // Compute transpose(X)*X\n    let XtX = numericDotTranspose(X, X);\n    // Compute transpose(X)*Y\n    let XtY = numericDotTransposeVector(X, Y);\n    // Solve linear system XtX * a = XtY\n    let coef = numericSolve(XtX, XtY);\n    return coef;\n  }\n\n  // Matrix multiplication: transpose(A)*B\n  function numericDotTranspose(A, B) {\n    let rowsA = A.length;\n    let colsA = A[0].length;\n    let rowsB = B.length;\n    let colsB = B[0].length;\n    if(rowsB !== rowsA)\n      throw new Error(\"Incompatible dimensions in numericDotTranspose\");\n\n    // Result dims: colsA x colsB\n    let result = [];\n    for(let i=0; i<colsA; i++){\n      result[i] = [];\n      for(let j=0; j<colsB; j++){\n        let sum = 0;\n        for(let k=0; k<rowsA; k++){\n          sum += A[k][i] * B[k][j];\n        }\n        result[i][j] = sum;\n      }\n    }\n    return result;\n  }\n\n  // transpose(A)*v where v is vector\n  function numericDotTransposeVector(A, v) {\n    let rows = A.length;\n    let cols = A[0].length;\n    if(rows !== v.length) throw new Error(\"Incompatible sizes in numericDotTransposeVector\");\n    let result = new Array(cols).fill(0);\n    for(let i=0; i<cols; i++){\n      for(let j=0; j<rows; j++){\n        result[i] += A[j][i]*v[j];\n      }\n    }\n    return result;\n  }\n\n  // Solve Ax = b using Gaussian elimination\n  // A is square matrix NxN, b is vector length N\n  // returns vector solution\n  function numericSolve(A, b) {\n    let n = A.length;\n    // Clone matrix and vector\n    let M = A.map(row => row.slice());\n    let x = b.slice();\n\n    for(let k=0; k<n; k++){\n      // Find pivot\n      let max = Math.abs(M[k][k]);\n      let maxRow = k;\n      for(let i=k+1; i<n; i++){\n        if(Math.abs(M[i][k]) > max){\n          max = Math.abs(M[i][k]);\n          maxRow = i;\n        }\n      }\n      if(max === 0) return new Array(n).fill(0); // singular\n\n      // Swap rows k and maxRow\n      [M[k], M[maxRow]] = [M[maxRow], M[k]];\n      [x[k], x[maxRow]] = [x[maxRow], x[k]];\n\n      // Elimination\n      for(let i=k+1; i<n; i++){\n        let factor = M[i][k] / M[k][k];\n        for(let j=k; j<n; j++){\n          M[i][j] = M[i][j] - factor * M[k][j];\n        }\n        x[i] = x[i] - factor * x[k];\n      }\n    }\n\n    // Back substitution\n    let result = new Array(n);\n    for(let i=n-1; i>=0; i--){\n      let sum = 0;\n      for(let j=i+1; j<n; j++){\n        sum += M[i][j] * result[j];\n      }\n      result[i] = (x[i] - sum) / M[i][i];\n    }\n    return result;\n  }\n\n  // Evaluate polynomial at x given coefficients\n  function polyEval(coef, x) {\n    let y = 0;\n    for(let i=0; i<coef.length; i++){\n      y += coef[i]*Math.pow(x, i);\n    }\n    return y;\n  }\n\n  // Draw fitted polynomial curve on right canvas\n  function drawFitCanvas(coef) {\n    ctxFit.clearRect(0,0,WIDTH,HEIGHT);\n\n    // Draw axes (same as left canvas)\n    ctxFit.strokeStyle = \"#aaa\";\n    ctxFit.lineWidth = 1;\n    ctxFit.beginPath();\n    // x axis\n    ctxFit.moveTo(xToCanvas(0), yToCanvas(0));\n    ctxFit.lineTo(xToCanvas(1), yToCanvas(0));\n    ctxFit.stroke();\n    // y axis\n    ctxFit.beginPath();\n    ctxFit.moveTo(xToCanvas(0), yToCanvas(1.5));\n    ctxFit.lineTo(xToCanvas(0), yToCanvas(-1.5));\n    ctxFit.stroke();\n\n    // Draw fitted polynomial curve\n    ctxFit.strokeStyle = \"red\";\n    ctxFit.lineWidth = 2;\n    ctxFit.beginPath();\n    for(let i=0; i<=100; i++){\n      let x = i/100;\n      let y = polyEval(coef, x);\n      let cx = xToCanvas(x);\n      let cy = yToCanvas(y);\n      if(i===0) ctxFit.moveTo(cx, cy);\n      else ctxFit.lineTo(cx, cy);\n    }\n    ctxFit.stroke();\n\n    // Draw data points for reference\n    ctxFit.fillStyle = \"rgba(0,0,255,0.3)\";\n    for(let pt of dataPoints){\n      ctxFit.beginPath();\n      ctxFit.arc(xToCanvas(pt.x), yToCanvas(pt.y), 4, 0, 2*Math.PI);\n      ctxFit.fill();\n    }\n\n    // Labels\n    ctxFit.fillStyle = \"black\";\n    ctxFit.fillText(\"Fitted Polynomial (red)\", 150, 20);\n    ctxFit.fillText(\"Degree: \" + (coef.length - 1), 150, 40);\n  }\n\n  // Calculate mean squared error on data points\n  function meanSquaredError(coef, data) {\n    if(coef.length === 0) return 0;\n    let sum = 0;\n    for(let pt of data){\n      let yPred = polyEval(coef, pt.x);\n      let diff = yPred - pt.y;\n      sum += diff*diff;\n    }\n    let mse = sum / data.length;\n    return mse;\n  }\n\n  // Update function called on slider changes\n  function update() {\n    const degree = parseInt(degreeRange.value);\n    degreeValue.textContent = degree;\n\n    // Fit polynomial\n    let coef;\n    if(degree === 0){\n      // Degree 0: model predicts mean of y values (intercept only)\n      let sumY = dataPoints.reduce((acc,p) => acc + p.y, 0);\n      coef = [sumY / dataPoints.length];\n    } else {\n      coef = polyFit(dataPoints, degree);\n    }\n\n    drawDataCanvas();\n    drawFitCanvas(coef);\n\n    // Calculate MSE and also error on true function points (to illustrate overfit)\n    // We'll compute two errors:\n    //  - Train error on noisy data\n    //  - True error on exact (noise-free) points\n\n    const trainMSE = meanSquaredError(coef, dataPoints);\n\n    // True error: sample 100 pts from true function without noise\n    let trueData = [];\n    for(let i=0; i<100; i++){\n      let x = i/99;\n      trueData.push({x:x, y:trueFunction(x)});\n    }\n    const trueMSE = meanSquaredError(coef, trueData);\n\n    // Display errors\n    errorDisplay.innerHTML = \n      `<div style=\"color:#cc0000\">Training MSE (noisy data): ${trainMSE.toFixed(4)}</div>`+\n      `<div style=\"color:#007700\">True MSE (noise-free): ${trueMSE.toFixed(4)}</div>`+\n      `<div style=\"font-style:italic; margin-top:6px;\">`+\n      `Notice how training error decreases monotonically as degree increases, but true error is lowest at moderate degree and then increases due to <strong>overfitting</strong>.`+\n      `</div>`;\n  }\n\n  // Initialize\n  drawDataCanvas();\n  update();\n\n  degreeRange.addEventListener(\"input\", update);\n</script>\n</body>\n</html>"
  },
