    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Means Clustering Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin: 20px;\n        }\n        #canvas {\n            border: 1px solid #000;\n            margin: 20px auto;\n            display: block;\n        }\n        .controls {\n            margin: 10px;\n        }\n        button {\n            padding: 8px 15px;\n            margin: 5px;\n            cursor: pointer;\n        }\n        .cluster-info {\n            margin: 20px auto;\n            max-width: 600px;\n            text-align: left;\n        }\n    </style>\n</head>\n<body>\n    <h1>K-Means Clustering Visualization</h1>\n    <div class=\"controls\">\n        <label for=\"kValue\">Number of clusters (K):</label>\n        <input type=\"number\" id=\"kValue\" min=\"1\" max=\"10\" value=\"3\">\n        <button id=\"resetBtn\">Reset Points</button>\n        <button id=\"clusterBtn\">Run Clustering</button>\n        <button id=\"stepBtn\">Step</button>\n    </div>\n    <canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n    <div class=\"cluster-info\" id=\"info\"></div>\n\n    <script>\n        const canvas = document.getElementById('canvas');\n        const ctx = canvas.getContext('2d');\n        const resetBtn = document.getElementById('resetBtn');\n        const clusterBtn = document.getElementById('clusterBtn');\n        const stepBtn = document.getElementById('stepBtn');\n        const kInput = document.getElementById('kValue');\n        const infoDiv = document.getElementById('info');\n\n        let points = [];\n        let centroids = [];\n        let clusters = [];\n        let iteration = 0;\n        let isRunning = false;\n        let animationId = null;\n\n        // Initialize the canvas with random points\n        function initPoints() {\n            points = [];\n            const pointCount = 100;\n            for (let i = 0; i < pointCount; i++) {\n                points.push({\n                    x: Math.random() * (canvas.width - 40) + 20,\n                    y: Math.random() * (canvas.height - 40) + 20,\n                    cluster: -1\n                });\n            }\n            draw();\n        }\n\n        // Initialize centroids randomly\n        function initCentroids() {\n            centroids = [];\n            const k = parseInt(kInput.value);\n            \n            // Select k distinct random points as initial centroids\n            const shuffled = [...points].sort(() => 0.5 - Math.random());\n            centroids = shuffled.slice(0, k).map(p => ({\n                x: p.x,\n                y: p.y,\n                color: getRandomColor()\n            }));\n        }\n\n        function getRandomColor() {\n            const letters = '0123456789ABCDEF';\n            let color = '#';\n            for (let i = 0; i < 6; i++) {\n                color += letters[Math.floor(Math.random() * 16)];\n            }\n            return color;\n        }\n\n        // Assign each point to the nearest centroid\n        function assignClusters() {\n            clusters = centroids.map(() => []);\n            \n            for (let point of points) {\n                let minDist = Infinity;\n                let closestCentroid = -1;\n                \n                for (let i = 0; i < centroids.length; i++) {\n                    const dx = point.x - centroids[i].x;\n                    const dy = point.y - centroids[i].y;\n                    const dist = dx * dx + dy * dy; // squared distance\n                    \n                    if (dist < minDist) {\n                        minDist = dist;\n                        closestCentroid = i;\n                    }\n                }\n                \n                point.cluster = closestCentroid;\n                clusters[closestCentroid].push(point);\n            }\n        }\n\n        // Update centroids to be the mean of their cluster\n        function updateCentroids() {\n            let converged = true;\n            \n            for (let i = 0; i < centroids.length; i++) {\n                if (clusters[i].length === 0) continue;\n                \n                const oldX = centroids[i].x;\n                const oldY = centroids[i].y;\n                \n                // Calculate mean of cluster points\n                let sumX = 0;\n                let sumY = 0;\n                for (let point of clusters[i]) {\n                    sumX += point.x;\n                    sumY += point.y;\n                }\n                \n                centroids[i].x = sumX / clusters[i].length;\n                centroids[i].y = sumY / clusters[i].length;\n                \n                // Check if centroid moved significantly\n                const dx = centroids[i].x - oldX;\n                const dy = centroids[i].y - oldY;\n                if (dx * dx + dy * dy > 1) { // threshold of 1 pixel\n                    converged = false;\n                }\n            }\n            \n            return converged;\n        }\n\n        function draw() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            \n            // Draw points\n            for (let point of points) {\n                if (point.cluster >= 0 && centroids[point.cluster]) {\n                    ctx.fillStyle = centroids[point.cluster].color;\n                } else {\n                    ctx.fillStyle = '#999999';\n                }\n                ctx.beginPath();\n                ctx.arc(point.x, point.y, 5, 0, Math.PI * 2);\n                ctx.fill();\n            }\n            \n            // Draw centroids\n            for (let centroid of centroids) {\n                ctx.fillStyle = centroid.color;\n                ctx.beginPath();\n                ctx.arc(centroid.x, centroid.y, 8, 0, Math.PI * 2);\n                ctx.fill();\n                ctx.strokeStyle = '#000';\n                ctx.lineWidth = 2;\n                ctx.stroke();\n            }\n            \n            // Display iteration info\n            infoDiv.innerHTML = `\n                <h3>Algorithm State</h3>\n                <p>Iteration: ${iteration}</p>\n                <p>Number of clusters: ${centroids.length}</p>\n                <p>Click \"Step\" to see each step or \"Run Clustering\" to animate the process.</p>\n            `;\n        }\n\n        function step() {\n            if (centroids.length === 0) {\n                initCentroids();\n            }\n            \n            assignClusters();\n            const converged = updateCentroids();\n            iteration++;\n            \n            draw();\n            \n            if (converged) {\n                infoDiv.innerHTML += `<p>Converged after ${iteration} iterations!</p>`;\n                if (isRunning) {\n                    cancelAnimationFrame(animationId);\n                    isRunning = false;\n                }\n            }\n        }\n\n        function runClustering() {\n            if (isRunning) return;\n            \n            isRunning = true;\n            iteration = 0;\n            \n            function animate() {\n                step();\n                if (isRunning) {\n                    animationId = requestAnimationFrame(animate);\n                }\n            }\n            \n            animate();\n        }\n\n        function stopClustering() {\n            isRunning = false;\n            cancelAnimationFrame(animationId);\n        }\n\n        // Event listeners\n        resetBtn.addEventListener('click', () => {\n            stopClustering();\n            initPoints();\n            centroids = [];\n            clusters = [];\n            iteration = 0;\n        });\n\n        clusterBtn.addEventListener('click', runClustering);\n        stepBtn.addEventListener('click', step);\n\n        // Initialize\n        initPoints();\n        draw();\n\n        // Allow adding new points by clicking\n        canvas.addEventListener('click', (e) => {\n            const rect = canvas.getBoundingClientRect();\n            const x = e.clientX - rect.left;\n            const y = e.clientY - rect.top;\n            \n            points.push({\n                x: x,\n                y: y,\n                cluster: -1\n            });\n            \n            draw();\n        });\n    </script>\n</body>\n</html>"
