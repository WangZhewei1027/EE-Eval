    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SQL Simulation with JavaScript</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            margin: 20px 0;\n        }\n        th, td {\n            padding: 10px;\n            border: 1px solid #ddd;\n            text-align: left;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n        input, button {\n            margin: 5px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>SQL Simulation</h1>\n<p>Use this simulation to understand SQL operations like SELECT, INSERT, and DELETE.</p>\n\n<h2>Database Table</h2>\n<table id=\"dataTable\">\n    <thead>\n        <tr>\n            <th>ID</th>\n            <th>Name</th>\n            <th>Age</th>\n        </tr>\n    </thead>\n    <tbody>\n    </tbody>\n</table>\n\n<h2>Commands</h2>\n<input type=\"text\" id=\"commandInput\" placeholder=\"Enter SQL command (e.g. INSERT, SELECT, DELETE)\" />\n<button onclick=\"executeCommand()\">Execute</button>\n\n<p id=\"output\"></p>\n\n<script>\n    const database = [];\n\n    function renderTable() {\n        const tbody = document.querySelector('#dataTable tbody');\n        tbody.innerHTML = '';\n        database.forEach((entry) => {\n            const row = document.createElement('tr');\n            row.innerHTML = `<td>${entry.id}</td><td>${entry.name}</td><td>${entry.age}</td>`;\n            tbody.appendChild(row);\n        });\n    }\n\n    function executeCommand() {\n        const command = document.getElementById('commandInput').value.trim().toUpperCase();\n        const output = document.getElementById('output');\n        output.textContent = '';\n\n        if (command.startsWith('INSERT')) {\n            const parts = command.split(' ').slice(2); // Keep only the values\n            const id = parseInt(parts[0]);\n            const name = parts[1].replace(/'/g, ''); // Remove quotes\n            const age = parseInt(parts[2]);\n            if (id && name && age) {\n                database.push({ id: id, name: name, age: age });\n                output.textContent = 'Inserted successfully';\n                renderTable();\n            } else {\n                output.textContent = 'Error: Invalid INSERT command';\n            }\n        } else if (command.startsWith('SELECT')) {\n            output.textContent = JSON.stringify(database, null, 2);\n        } else if (command.startsWith('DELETE')) {\n            const parts = command.split(' ');\n            const idToDelete = parseInt(parts[2]);\n            const index = database.findIndex(entry => entry.id === idToDelete);\n            if (index > -1) {\n                database.splice(index, 1);\n                output.textContent = 'Deleted successfully';\n                renderTable();\n            } else {\n                output.textContent = 'Error: ID not found';\n            }\n        } else {\n            output.textContent = 'Error: Unsupported command';\n        }\n\n        document.getElementById('commandInput').value = ''; // Clear input after execution\n    }\n</script>\n\n</body>\n</html>"
  },
