    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree</title>\n</head>\n<body>\n\n<h2>Binary Search Tree</h2>\n\n<div id=\"root\"></div>\n\n<script>\nfunction insertNode(data, position, key) {\n    var node = document.createElement(\"li\");\n    node.textContent = data;\n    if(position >= 0 && data < root.data) {\n        position -= 1;\n    }\n    if(position < root.length - 1) {\n        insertNode(data, position + 1, key);\n    } else {\n        insertNode(data, position, null);\n    }\n    root.appendChild(node);\n}\n\nfunction searchNode(data, position, key) {\n    for(var i = position; i < root.length; i++) {\n        if(root[i].textContent === key) return i;\n    }\n    return -1;\n}\n\nfunction getMinData(data) {\n    var minNode = null;\n    for(var i = 0; i < data.length; i++) {\n        if(data[i] < data[minNode]) minNode = i;\n    }\n    return minNode;\n}\n\nvar root = document.getElementById(\"root\");\ninsertNode(data, 0, \"Apple\");\ninsertNode(data, 5, \"Banana\");\ninsertNode(data, 7, \"Cherry\");\ninsertNode(data, 9, \"Date\");\n\nconsole.log(searchNode(data, 4, \"Apple\")); // Output: 3\nconsole.log(getMinData(data)); // Output: 3\n\ndocument.getElementById(\"root\").style.display = \"block\";\n</script>\n\n</body>\n</html>"
