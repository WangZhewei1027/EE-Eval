  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>PageRank Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        h1 {\n            color: #2c3e50;\n            text-align: center;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .graph-container {\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            padding: 15px;\n            background-color: #f9f9f9;\n        }\n        #graph {\n            width: 100%;\n            height: 400px;\n            border: 1px solid #ccc;\n            background-color: white;\n        }\n        .controls {\n            display: flex;\n            gap: 10px;\n            flex-wrap: wrap;\n        }\n        button {\n            padding: 8px 15px;\n            background-color: #3498db;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #2980b9;\n        }\n        .results {\n            margin-top: 20px;\n            padding: 15px;\n            background-color: #ecf0f1;\n            border-radius: 5px;\n        }\n        .node {\n            stroke: #fff;\n            stroke-width: 1.5px;\n        }\n        .link {\n            stroke: #999;\n            stroke-opacity: 0.6;\n        }\n        .arrow {\n            fill: #999;\n        }\n        .node-label {\n            font-size: 12px;\n            font-weight: bold;\n        }\n        .rank-label {\n            font-size: 10px;\n            fill: #777;\n        }\n        .slider-container {\n            margin: 15px 0;\n        }\n        .slider-container label {\n            display: block;\n            margin-bottom: 5px;\n        }\n        input[type=\"range\"] {\n            width: 100%;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>PageRank Algorithm Visualization</h1>\n        \n        <div class=\"graph-container\">\n            <svg id=\"graph\"></svg>\n        </div>\n        \n        <div class=\"controls\">\n            <button id=\"addNode\">Add Node</button>\n            <button id=\"addLink\">Add Link</button>\n            <button id=\"calculate\">Calculate PageRank</button>\n            <button id=\"reset\">Reset Graph</button>\n        </div>\n        \n        <div class=\"slider-container\">\n            <label for=\"damping\">Damping Factor (α): <span id=\"dampingValue\">0.85</span></label>\n            <input type=\"range\" id=\"damping\" min=\"0.1\" max=\"0.99\" step=\"0.01\" value=\"0.85\">\n        </div>\n        \n        <div class=\"slider-container\">\n            <label for=\"iterations\">Iterations: <span id=\"iterationsValue\">20</span></label>\n            <input type=\"range\" id=\"iterations\" min=\"1\" max=\"50\" step=\"1\" value=\"20\">\n        </div>\n        \n        <div class=\"results\">\n            <h3>PageRank Results:</h3>\n            <div id=\"results\"></div>\n        </div>\n        \n        <div>\n            <h3>How PageRank Works:</h3>\n            <p>PageRank is an algorithm used by Google to rank web pages in their search engine results.</p>\n            <p>Key concepts:</p>\n            <ul>\n                <li>Pages with more incoming links are generally more important</li>\n                <li>Links from important pages count more</li>\n                <li>The damping factor (α) represents the probability that a user will continue clicking links</li>\n            </ul>\n            <p>Try adding nodes and links, then click \"Calculate PageRank\" to see the results.</p>\n        </div>\n    </div>\n\n    <script src=\"https://d3js.org/d3.v7.min.js\"></script>\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            // Graph data\n            let graph = {\n                nodes: [\n                    { id: \"A\", rank: 0.25 },\n                    { id: \"B\", rank: 0.25 },\n                    { id: \"C\", rank: 0.25 },\n                    { id: \"D\", rank: 0.25 }\n                ],\n                links: [\n                    { source: \"A\", target: \"B\" },\n                    { source: \"B\", target: \"C\" },\n                    { source: \"C\", target: \"D\" },\n                    { source: \"D\", target: \"A\" },\n                    { source: \"B\", target: \"D\" }\n                ]\n            };\n            \n            // Simulation parameters\n            let dampingFactor = 0.85;\n            let iterations = 20;\n            \n            // UI elements\n            const svg = d3.select(\"#graph\");\n            const resultsDiv = document.getElementById(\"results\");\n            const dampingSlider = document.getElementById(\"damping\");\n            const dampingValue = document.getElementById(\"dampingValue\");\n            const iterationsSlider = document.getElementById(\"iterations\");\n            const iterationsValue = document.getElementById(\"iterationsValue\");\n            \n            // Event listeners\n            document.getElementById(\"addNode\").addEventListener(\"click\", addNode);\n            document.getElementById(\"addLink\").addEventListener(\"click\", addLink);\n            document.getElementById(\"calculate\").addEventListener(\"click\", calculatePageRank);\n            document.getElementById(\"reset\").addEventListener(\"click\", resetGraph);\n            dampingSlider.addEventListener(\"input\", updateDampingFactor);\n            iterationsSlider.addEventListener(\"input\", updateIterations);\n            \n            // Initialize the graph visualization\n            drawGraph();\n            \n            function drawGraph() {\n                const width = document.getElementById(\"graph\").clientWidth;\n                const height = document.getElementById(\"graph\").clientHeight;\n                \n                svg.attr(\"width\", width).attr(\"height\", height);\n                svg.selectAll(\"*\").remove();\n                \n                // Create arrow marker\n                svg.append(\"defs\").append(\"marker\")\n                    .attr(\"id\", \"arrowhead\")\n                    .attr(\"viewBox\", \"0 -5 10 10\")\n                    .attr(\"refX\", 25)\n                    .attr(\"refY\", 0)\n                    .attr(\"orient\", \"auto\")\n                    .attr(\"markerWidth\", 6)\n                    .attr(\"markerHeight\", 6)\n                    .attr(\"xoverflow\", \"visible\")\n                    .append(\"svg:path\")\n                    .attr(\"d\", \"M 0,-5 L 10,0 L 0,5\")\n                    .attr(\"class\", \"arrow\");\n                \n                // Create simulation\n                const simulation = d3.forceSimulation(graph.nodes)\n                    .force(\"link\", d3.forceLink(graph.links).id(d => d.id).distance(100))\n                    .force(\"charge\", d3.forceManyBody().strength(-300))\n                    .force(\"center\", d3.forceCenter(width / 2, height / 2))\n                    .force(\"collision\", d3.forceCollide().radius(30));\n                \n                // Draw links\n                const link = svg.append(\"g\")\n                    .selectAll(\"line\")\n                    .data(graph.links)\n                    .enter().append(\"line\")\n                    .attr(\"class\", \"link\")\n                    .attr(\"marker-end\", \"url(#arrowhead)\");\n                \n                // Draw nodes\n                const node = svg.append(\"g\")\n                    .selectAll(\"g\")\n                    .data(graph.nodes)\n                    .enter().append(\"g\")\n                    .call(d3.drag()\n                        .on(\"start\", dragstarted)\n                        .on(\"drag\", dragged)\n                        .on(\"end\", dragended));\n                \n                node.append(\"circle\")\n                    .attr(\"class\", \"node\")\n                    .attr(\"r\", d => 20 + (d.rank * 60))\n                    .attr(\"fill\", d => d3.interpolateBlues(d.rank * 0.8 + 0.2));\n                \n                node.append(\"text\")\n                    .attr(\"class\", \"node-label\")\n                    .attr(\"dy\", 4)\n                    .text(d => d.id);\n                \n                node.append(\"text\")\n                    .attr(\"class\", \"rank-label\")\n                    .attr(\"dy\", 25)\n                    .text(d => d.rank.toFixed(3));\n                \n                // Update positions on simulation tick\n                simulation.on(\"tick\", () => {\n                    link\n                        .attr(\"x1\", d => d.source.x)\n                        .attr(\"y1\", d => d.source.y)\n                        .attr(\"x2\", d => d.target.x)\n                        .attr(\"y2\", d => d.target.y);\n                    \n                    node.attr(\"transform\", d => `translate(${d.x},${d.y})`);\n                });\n                \n                function dragstarted(event, d) {\n                    if (!event.active) simulation.alphaTarget(0.3).restart();\n                    d.fx = d.x;\n                    d.fy = d.y;\n                }\n                \n                function dragged(event, d) {\n                    d.fx = event.x;\n                    d.fy = event.y;\n                }\n                \n                function dragended(event, d) {\n                    if (!event.active) simulation.alphaTarget(0);\n                    d.fx = null;\n                    d.fy = null;\n                }\n            }\n            \n            function addNode() {\n                const newNodeId = String.fromCharCode(65 + graph.nodes.length);\n                graph.nodes.push({ id: newNodeId, rank: 0.25 });\n                drawGraph();\n            }\n            \n            function addLink() {\n                if (graph.nodes.length < 2) return;\n                \n                // Get random source and target (different nodes)\n                let sourceIndex, targetIndex;\n                do {\n                    sourceIndex = Math.floor(Math.random() * graph.nodes.length);\n                    targetIndex = Math.floor(Math.random() * graph.nodes.length);\n                } while (sourceIndex === targetIndex);\n                \n                const source = graph.nodes[sourceIndex].id;\n                const target = graph.nodes[targetIndex].id;\n                \n                // Check if link already exists\n                const linkExists = graph.links.some(\n                    link => link.source === source && link.target === target\n                );\n                \n                if (!linkExists) {\n                    graph.links.push({ source, target });\n                    drawGraph();\n                }\n            }\n            \n            function calculatePageRank() {\n                const numNodes = graph.nodes.length;\n                if (numNodes === 0) return;\n                \n                // Initialize PageRank values\n                const initialRank = 1 / numNodes;\n                const ranks = {};\n                const newRanks = {};\n                \n                graph.nodes.forEach(node => {\n                    ranks[node.id] = initialRank;\n                    newRanks[node.id] = 0;\n                });\n                \n                // Calculate outgoing links count for each node\n                const outLinks = {};\n                graph.nodes.forEach(node => {\n                    outLinks[node.id] = 0;\n                });\n                \n                graph.links.forEach(link => {\n                    outLinks[link.source]++;\n                });\n                \n                // Perform iterations\n                for (let i = 0; i < iterations; i++) {\n                    // Distribute PageRank through links\n                    graph.links.forEach(link => {\n                        if (outLinks[link.source] > 0) {\n                            newRanks[link.target] += ranks[link.source] / outLinks[link.source];\n                        }\n                    });\n                    \n                    // Apply damping factor\n                    graph.nodes.forEach(node => {\n                        newRanks[node.id] = (1 - dampingFactor) / numNodes + dampingFactor * newRanks[node.id];\n                    });\n                    \n                    // Update ranks for next iteration\n                    graph.nodes.forEach(node => {\n                        ranks[node.id] = newRanks[node.id];\n                        newRanks[node.id] = 0;\n                    });\n                }\n                \n                // Normalize ranks to sum to 1\n                const totalRank = graph.nodes.reduce((sum, node) => sum + ranks[node.id], 0);\n                graph.nodes.forEach(node => {\n                    node.rank = ranks[node.id] / totalRank;\n                });\n                \n                // Update visualization\n                drawGraph();\n                \n                // Display results\n                displayResults();\n            }\n            \n            function displayResults() {\n                // Sort nodes by rank\n                const sortedNodes = [...graph.nodes].sort((a, b) => b.rank - a.rank);\n                \n                let html = \"<table><tr><th>Node</th><th>PageRank</th></tr>\";\n                sortedNodes.forEach(node => {\n                    html += `<tr><td>${node.id}</td><td>${node.rank.toFixed(4)}</td></tr>`;\n                });\n                html += \"</table>\";\n                \n                resultsDiv.innerHTML = html;\n            }\n            \n            function resetGraph() {\n                graph = {\n                    nodes: [\n                        { id: \"A\", rank: 0.25 },\n                        { id: \"B\", rank: 0.25 },\n                        { id: \"C\", rank: 0.25 },\n                        { id: \"D\", rank: 0.25 }\n                    ],\n                    links: [\n                        { source: \"A\", target: \"B\" },\n                        { source: \"B\", target: \"C\" },\n                        { source: \"C\", target: \"D\" },\n                        { source: \"D\", target: \"A\" },\n                        { source: \"B\", target: \"D\" }\n                    ]\n                };\n                \n                drawGraph();\n                resultsDiv.innerHTML = \"\";\n            }\n            \n            function updateDampingFactor() {\n                dampingFactor = parseFloat(dampingSlider.value);\n                dampingValue.textContent = dampingFactor.toFixed(2);\n            }\n            \n            function updateIterations() {\n                iterations = parseInt(iterationsSlider.value);\n                iterationsValue.textContent = iterations;\n            }\n        });\n    </script>\n</body>\n</html>"
  },
