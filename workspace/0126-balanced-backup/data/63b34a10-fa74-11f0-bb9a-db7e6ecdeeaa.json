  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>TCP/IP Concept Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f4f8;\n    color: #222;\n  }\n  h1 {\n    text-align: center;\n    color: #0b3d91;\n  }\n  #network {\n    margin: 20px auto;\n    width: 90%;\n    max-width: 900px;\n    border: 2px solid #0b3d91;\n    border-radius: 10px;\n    background: white;\n    padding: 20px;\n  }\n  .device {\n    border: 2px solid #0b3d91;\n    border-radius: 10px;\n    padding: 15px;\n    text-align: center;\n    width: 180px;\n    margin: 10px;\n    background: #e3ecf9;\n    position: relative;\n  }\n  .device h3 {\n    margin: 5px 0 10px;\n    font-weight: 700;\n  }\n  .ip {\n    font-family: monospace;\n    font-size: 0.9em;\n    background: #d0d7ea;\n    padding: 3px 6px;\n    border-radius: 5px;\n    display: inline-block;\n    margin-bottom: 10px;\n  }\n  #devicesContainer {\n    display: flex;\n    justify-content: space-around;\n    flex-wrap: wrap;\n  }\n  #eventsLog {\n    max-height: 180px;\n    overflow-y: auto;\n    background: #222;\n    color: #eee;\n    padding: 12px;\n    border-radius: 5px;\n    font-family: monospace;\n    font-size: 0.9em;\n    margin-top: 20px;\n  }\n  #sendControls {\n    margin-top: 20px;\n    text-align: center;\n  }\n  select, button {\n    font-size: 1em;\n    padding: 8px 12px;\n    margin: 0 8px 8px 8px;\n    border-radius: 6px;\n    border: 1px solid #0b3d91;\n    background: white;\n    cursor: pointer;\n  }\n  button:disabled {\n    background: #ccc;\n    cursor: not-allowed;\n  }\n  svg {\n    width: 100%;\n    height: 150px;\n    margin-top: 10px;\n  }\n  .segment, .packet {\n    cursor: pointer;\n    user-select: none;\n  }\n  #legend {\n    margin-top: 25px;\n    font-size: 0.9em;\n  }\n  .box {\n    display: inline-block;\n    width: 18px;\n    height: 18px;\n    margin-right: 6px;\n    vertical-align: middle;\n    border-radius: 3px;\n  }\n  .ipBox { background: #4178be; }\n  .tcpBox { background: #f39c12; }\n  .dataBox { background: #27ae60; }\n  .packetBox { background: #8e44ad; }\n</style>\n</head>\n<body>\n<h1>TCP/IP Concept Demonstration</h1>\n<div id=\"network\" aria-label=\"Network demonstration\">\n  <div id=\"devicesContainer\" role=\"list\">\n    <!-- Devices will be generated here -->\n  </div>\n  <div id=\"sendControls\" aria-label=\"Controls to send packet\">\n    <label for=\"sourceSelect\">Source:</label>\n    <select id=\"sourceSelect\" aria-describedby=\"descSource\">\n    </select>\n    <label for=\"destSelect\">Destination:</label>\n    <select id=\"destSelect\" aria-describedby=\"descDest\">\n    </select>\n    <button id=\"sendButton\">Send Message</button>\n    <div id=\"descSource\" style=\"display:none;\">Select source device IP address.</div>\n    <div id=\"descDest\" style=\"display:none;\">Select destination device IP address.</div>\n  </div>\n  <svg id=\"networkDiagram\" aria-hidden=\"true\"></svg>\n  <div id=\"legend\" aria-label=\"Legend\">\n    <div><span class=\"box ipBox\"></span> IP Layer</div>\n    <div><span class=\"box tcpBox\"></span> TCP Layer</div>\n    <div><span class=\"box dataBox\"></span> Data (Payload)</div>\n    <div><span class=\"box packetBox\"></span> Packet traveling</div>\n  </div>\n  <h2>Events Log</h2>\n  <div id=\"eventsLog\" aria-live=\"polite\" aria-atomic=\"false\"></div>\n</div>\n\n<script>\n(() => {\n  // Devices on the simulated network\n  const devices = [\n    { name: 'Computer A', ip: '192.168.1.2' },\n    { name: 'Computer B', ip: '192.168.1.3' },\n    { name: 'Router', ip: '192.168.1.1' },\n    { name: 'Server', ip: '10.0.0.5' }\n  ];\n\n  // DOM references\n  const devicesContainer = document.getElementById('devicesContainer');\n  const sourceSelect = document.getElementById('sourceSelect');\n  const destSelect = document.getElementById('destSelect');\n  const sendButton = document.getElementById('sendButton');\n  const eventsLog = document.getElementById('eventsLog');\n  const networkDiagram = document.getElementById('networkDiagram');\n\n  // Clear logs\n  function logEvent(text) {\n    const time = new Date().toLocaleTimeString();\n    const entry = document.createElement('div');\n    entry.textContent = `[${time}] ${text}`;\n    eventsLog.appendChild(entry);\n    eventsLog.scrollTop = eventsLog.scrollHeight;\n  }\n\n  // Create device cards in UI\n  function createDeviceCards() {\n    devices.forEach(device => {\n      const div = document.createElement('div');\n      div.className = 'device';\n      div.setAttribute('role', 'listitem');\n      div.id = `device-${device.ip.replace(/\\./g, '-')}`;\n      div.innerHTML = `\n        <h3>${device.name}</h3>\n        <div class=\"ip\">${device.ip}</div>\n        <strong>Layers:</strong>\n        <ul style=\"list-style:none; padding-left:0; text-align:left; font-size:0.9em;\">\n          <li><span class=\"ipBox box\"></span>IP Layer</li>\n          <li><span class=\"tcpBox box\"></span>TCP Layer</li>\n          <li><span class=\"dataBox box\"></span>Application/Data</li>\n        </ul>\n      `;\n      devicesContainer.appendChild(div);\n    });\n  }\n\n  // Populate source/dest selects\n  function populateSelects() {\n    devices.forEach(device => {\n      const optionSrc = document.createElement('option');\n      optionSrc.value = device.ip;\n      optionSrc.textContent = `${device.name} (${device.ip})`;\n      sourceSelect.appendChild(optionSrc);\n\n      const optionDest = document.createElement('option');\n      optionDest.value = device.ip;\n      optionDest.textContent = `${device.name} (${device.ip})`;\n      destSelect.appendChild(optionDest);\n    });\n    // Default selections\n    sourceSelect.selectedIndex = 0;\n    destSelect.selectedIndex = devices.length > 1 ? 1 : 0;\n  }\n\n  // Coordinates for devices on SVG canvas for packet animation\n  // We'll position devices horizontally spaced\n  let devicePositions = {};\n\n  function setupNetworkDiagram() {\n    const svgWidth = networkDiagram.clientWidth || 800;\n    const svgHeight = networkDiagram.clientHeight || 150;\n    networkDiagram.setAttribute('viewBox', `0 0 ${svgWidth} ${svgHeight}`);\n    networkDiagram.innerHTML = '';\n\n    const marginX = 80;\n    const marginY = svgHeight / 2;\n\n    // Position devices evenly across width\n    const stepX = (svgWidth - 2 * marginX) / (devices.length - 1);\n\n    devices.forEach((device, i) => {\n      const x = marginX + stepX * i;\n      const y = marginY;\n      devicePositions[device.ip] = { x, y };\n\n      // Draw device circle\n      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n      circle.setAttribute('cx', x);\n      circle.setAttribute('cy', y);\n      circle.setAttribute('r', 25);\n      circle.setAttribute('fill', '#4178be');\n      circle.setAttribute('stroke', '#0b3d91');\n      circle.setAttribute('stroke-width', '3');\n      circle.setAttribute('aria-label', `${device.name} at IP ${device.ip}`);\n      networkDiagram.appendChild(circle);\n\n      // Device label\n      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n      text.setAttribute('x', x);\n      text.setAttribute('y', y + 45);\n      text.setAttribute('text-anchor', 'middle');\n      text.setAttribute('font-family', 'Arial, sans-serif');\n      text.setAttribute('font-size', '13');\n      text.setAttribute('fill', '#222');\n      text.textContent = device.name;\n      networkDiagram.appendChild(text);\n\n      // IP label below name\n      const ipText = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n      ipText.setAttribute('x', x);\n      ipText.setAttribute('y', y + 62);\n      ipText.setAttribute('text-anchor', 'middle');\n      ipText.setAttribute('font-family', 'monospace');\n      ipText.setAttribute('font-size', '11');\n      ipText.setAttribute('fill', '#555');\n      ipText.textContent = device.ip;\n      networkDiagram.appendChild(ipText);\n\n      // Draw lines between devices (full mesh for demo)\n      if(i > 0) {\n        const prevDevice = devices[i - 1];\n        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n        line.setAttribute('x1', devicePositions[prevDevice.ip].x);\n        line.setAttribute('y1', marginY);\n        line.setAttribute('x2', x);\n        line.setAttribute('y2', marginY);\n        line.setAttribute('stroke', '#a0b8d5');\n        line.setAttribute('stroke-width', '2');\n        networkDiagram.insertBefore(line, circle);\n      }\n    });\n  }\n\n  // Simulate building layers and sending a packet\n  // We'll show step-by-step logs and animate the packet traveling on SVG\n\n  function createPacketSVG() {\n    // A rectangle representing a packet traveling area\n    const packet = document.createElementNS('http://www.w3.org/2000/svg', 'rect');\n    packet.setAttribute('width', 20);\n    packet.setAttribute('height', 14);\n    packet.setAttribute('fill', '#8e44ad');\n    packet.setAttribute('rx', 4);\n    packet.setAttribute('ry', 4);\n    packet.classList.add('packet');\n    networkDiagram.appendChild(packet);\n    return packet;\n  }\n\n  // Animate the packet from source to destination along line\n  function animatePacket(packet, fromPos, toPos, onComplete) {\n    // We will animate translation from fromPos to toPos with easing\n    const duration = 3500; // 3.5 seconds\n    const start = performance.now();\n\n    function step(time) {\n      const elapsed = time - start;\n      const progress = Math.min(elapsed / duration, 1);\n      // ease in-out cubic\n      const easeProgress = progress < 0.5 ?\n        4 * progress * progress * progress :\n        1 - Math.pow(-2 * progress + 2, 3) / 2;\n\n      const x = fromPos.x + (toPos.x - fromPos.x) * easeProgress - 10; // subtract half width\n      const y = fromPos.y + (toPos.y - fromPos.y) * easeProgress - 7;  // subtract half height\n\n      packet.setAttribute('x', x);\n      packet.setAttribute('y', y);\n\n      if(progress < 1) {\n        requestAnimationFrame(step);\n      } else {\n        onComplete();\n      }\n    }\n    requestAnimationFrame(step);\n  }\n\n  // Demonstrate TCP/IP layers encapsulation and transmission\n  // For simplified explanation:\n  // Application Layer: message data\n  // TCP Layer: segments message, adds TCP header info\n  // IP Layer: encapsulates TCP segment inside IP packet, adds IP header with source and destination\n  // Packet is sent over network (animation)\n  // Then reversed on recipient device (decapsulation)\n\n  function sendMessage(sourceIp, destIp, message) {\n    sendButton.disabled = true;\n\n    logEvent(`User requests sending message from ${sourceIp} to ${destIp}`);\n\n    // Step 1: Application Layer\n    logEvent(`[Application Layer] Message to send: \"${message}\"`);\n\n    // Step 2: TCP Layer - segment creation with ports\n    logEvent('[TCP Layer] Encapsulating message into TCP segment...');\n    const tcpSegment = {\n      sourcePort: 12345,  // arbitrary example ports\n      destPort: 80,\n      sequenceNumber: Math.floor(Math.random() * 10000),\n      payload: message\n    };\n    logEvent(`TCP Segment created: Seq#${tcpSegment.sequenceNumber}, SrcPort:${tcpSegment.sourcePort}, DestPort:${tcpSegment.destPort}`);\n\n    // Step 3: IP Layer - encapsulate TCP segment into IP packet\n    logEvent('[IP Layer] Encapsulating TCP segment into IP packet...');\n    const ipPacket = {\n      sourceIp,\n      destIp,\n      protocol: 'TCP',\n      tcpSegment\n    };\n    logEvent(`IP Packet created: SrcIP:${ipPacket.sourceIp}, DestIP:${ipPacket.destIp}, Protocol:${ipPacket.protocol}`);\n\n    // Step 4: Transmit packet over network - animate packet traveling\n    // Show moving rectangle from source to destination\n\n    const sourcePos = devicePositions[sourceIp];\n    const destPos = devicePositions[destIp];\n\n    if(!sourcePos || !destPos) {\n      logEvent('Error: Invalid source or destination IP address.');\n      sendButton.disabled = false;\n      return;\n    }\n\n    logEvent(`Sending packet from ${sourceIp} to ${destIp} over the network...`);\n\n    const packet = createPacketSVG();\n\n    animatePacket(packet, sourcePos, destPos, () => {\n      logEvent('Packet arrived at destination device.');\n      networkDiagram.removeChild(packet);\n\n      // Step 5: Decapsulation on destination device\n\n      logEvent('[IP Layer] Decapsulating IP packet...');\n      logEvent(`[IP Layer] Validating destination IP: ${ipPacket.destIp}`);\n\n      if (ipPacket.destIp !== destIp) {\n        logEvent('[IP Layer] Destination IP mismatch. Packet dropped.');\n        sendButton.disabled = false;\n        return;\n      }\n      logEvent('[IP Layer] IP header processed successfully.');\n\n      logEvent('[TCP Layer] Process segment...');\n      logEvent(`TCP Segment details: Seq#${tcpSegment.sequenceNumber}, SrcPort:${tcpSegment.sourcePort}, DestPort:${tcpSegment.destPort}`);\n\n      logEvent('[Application Layer] Delivering message to application...');\n      logEvent(`Message received: \"${tcpSegment.payload}\"`);\n\n      sendButton.disabled = false;\n    });\n  }\n\n  function setupEventListeners() {\n    sendButton.addEventListener('click', () => {\n      const sourceIp = sourceSelect.value;\n      const destIp = destSelect.value;\n\n      if(sourceIp === destIp) {\n        alert('Source and destination IP cannot be the same.');\n        return;\n      }\n      const message = prompt('Enter the message to send:', 'Hello TCP/IP!');\n\n      if(message === null || message.trim() === '') {\n        alert('Message cannot be empty.');\n        return;\n      }\n\n      sendMessage(sourceIp, destIp, message.trim());\n    });\n  }\n\n  // Initialize UI and SVG diagram\n  function init() {\n    createDeviceCards();\n    populateSelects();\n    setupNetworkDiagram();\n    setupEventListeners();\n    logEvent('TCP/IP Simulation Ready.');\n  }\n\n  // Responsive: redraw on window resize\n  window.addEventListener('resize', () => {\n    setupNetworkDiagram();\n  });\n\n  init();\n})();\n</script>\n</body>\n</html>"
  },
