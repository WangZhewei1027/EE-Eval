    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Tim Sort Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f4f4f4;\n  }\n  h1 {\n    text-align: center;\n  }\n  #inputArea, #outputArea {\n    margin: 15px auto;\n    max-width: 600px;\n    background: white;\n    padding: 15px;\n    border-radius: 5px;\n    box-shadow: 0 0 8px #ccc;\n  }\n  textarea {\n    width: 100%;\n    height: 100px;\n    font-family: monospace;\n    font-size: 14px;\n  }\n  button {\n    margin-top: 10px;\n    padding: 10px 15px;\n    font-size: 16px;\n    cursor: pointer;\n  }\n  #steplog {\n    height: 300px;\n    overflow-y: scroll;\n    background: #222;\n    color: #eee;\n    font-family: monospace;\n    padding: 10px;\n    border-radius: 5px;\n    white-space: pre-wrap;\n  }\n  .highlight {\n    background-color: #ffd54f;\n  }\n  .merge-step {\n    color: #81c784;\n  }\n  .run-detection-step {\n    color: #64b5f6;\n  }\n</style>\n</head>\n<body>\n<h1>Tim Sort Visualization & Explanation</h1>\n\n<div id=\"inputArea\">\n  <label for=\"arrayInput\"><strong>Enter array of numbers to sort (comma separated):</strong></label><br/>\n  <textarea id=\"arrayInput\">5, 21, 7, 23, 19, 3, 17, 11, 9, 15, 14, 8</textarea><br />\n  <button id=\"startBtn\">Start Tim Sort Demo</button>\n</div>\n\n<div id=\"outputArea\">\n  <h2>Sorting Steps Log</h2>\n  <div id=\"steplog\"></div>\n</div>\n\n<script>\n/*\n  TimSort is a hybrid stable sorting algorithm derived from merge sort and insertion sort,\n  designed to perform well on many kinds of real-world data.\n  It exploits runs of consecutive ordered elements within the data and merges them efficiently.\n*/\n\n// Constants for TimSort\nconst MIN_MERGE = 32;\n\nfunction minRunLength(n) {\n  // Returns the minimum run length for TimSort on array size n.\n  let r = 0;\n  while (n >= MIN_MERGE) {\n    r |= (n & 1);\n    n >>= 1;\n  }\n  return n + r;\n}\n\nclass TimSortDemo {\n  constructor(array, logElement) {\n    this.array = array;\n    this.minRun = minRunLength(array.length);\n    this.logElement = logElement;\n    this.runs = [];\n  }\n\n  log(message, type = '') {\n    const p = document.createElement('div');\n    if(type) p.classList.add(type);\n    p.textContent = message;\n    this.logElement.appendChild(p);\n    this.logElement.scrollTop = this.logElement.scrollHeight;\n  }\n\n  insertionSort(left, right) {\n    this.log(`Insertion sort on subarray [${left}..${right}]`, 'run-detection-step');\n    for(let i = left + 1; i <= right; i++) {\n      let key = this.array[i];\n      let j = i - 1;\n      while(j >= left && this.array[j] > key) {\n        this.array[j+1] = this.array[j];\n        j--;\n      }\n      this.array[j+1] = key;\n\n      this.log(`  Inserted ${key} into sorted part: [${this.array.slice(left, right+1).join(', ')}]`);\n    }\n  }\n\n  countRunAndMakeAscending(lo) {\n    let runHi = lo + 1;\n    if(runHi === this.array.length) return 1;\n    // Identify run direction (ascending or descending)\n    if(this.array[runHi] < this.array[lo]) {\n      // Descending run\n      while(runHi < this.array.length -1 && this.array[runHi+1] < this.array[runHi]) {\n        runHi++;\n      }\n      this.reverseRange(lo, runHi);\n      this.log(`Found descending run [${lo}..${runHi}] reversed to ascending`, 'run-detection-step');\n    } else {\n      // Ascending run\n      while(runHi < this.array.length -1 && this.array[runHi+1] >= this.array[runHi]) {\n        runHi++;\n      }\n      this.log(`Found ascending run [${lo}..${runHi}]`, 'run-detection-step');\n    }\n    return runHi - lo + 1;\n  }\n\n  reverseRange(lo, hi) {\n    while(lo < hi) {\n      [this.array[lo], this.array[hi]] = [this.array[hi], this.array[lo]];\n      lo++;\n      hi--;\n    }\n  }\n\n  pushRun(runBase, runLen) {\n    this.runs.push({runBase, runLen});\n    this.log(`Pushed run: base=${runBase}, length=${runLen} => [${this.array.slice(runBase, runBase + runLen).join(', ')}]`, 'run-detection-step');\n  }\n\n  mergeAt(i) {\n    let run1 = this.runs[i];\n    let run2 = this.runs[i+1];\n    this.log(`Merging runs at indices ${i} and ${i+1}:\n      Run1 [${run1.runBase}..${run1.runBase + run1.runLen -1}]: [${this.array.slice(run1.runBase, run1.runBase + run1.runLen).join(', ')}]\n      Run2 [${run2.runBase}..${run2.runBase + run2.runLen -1}]: [${this.array.slice(run2.runBase, run2.runBase + run2.runLen).join(', ')}]`, 'merge-step');\n\n    let base1 = run1.runBase, len1 = run1.runLen;\n    let base2 = run2.runBase, len2 = run2.runLen;\n\n    // Merge runs into temp array\n    let merged = [];\n    let i1 = base1, i2 = base2;\n\n    while(i1 < base1 + len1 && i2 < base2 + len2) {\n      if(this.array[i1] <= this.array[i2]) merged.push(this.array[i1++]);\n      else merged.push(this.array[i2++]);\n    }\n    while(i1 < base1 + len1) merged.push(this.array[i1++]);\n    while(i2 < base2 + len2) merged.push(this.array[i2++]);\n\n    // Copy merged array back\n    for(let k = 0; k < merged.length; k++) {\n      this.array[base1 + k] = merged[k];\n    }\n\n    this.runs[i] = {runBase: base1, runLen: len1 + len2};\n    this.runs.splice(i+1, 1);\n\n    this.log(`Result after merge: [${this.array.slice(base1, base1 + len1 + len2).join(', ')}]`, 'merge-step');\n  }\n\n  // Maintains the invariants:\n  //   1. len[-3] > len[-2] + len[-1]\n  //   2. len[-2] > len[-1]\n  // If invariants are not held, merge runs accordingly.\n  mergeCollapse() {\n    while(this.runs.length > 1) {\n      let n = this.runs.length;\n      if(n >= 3) {\n        let A = this.runs[n - 3].runLen;\n        let B = this.runs[n - 2].runLen;\n        let C = this.runs[n - 1].runLen;\n\n        if(A <= B + C) {\n          if(A < C) {\n            this.mergeAt(n - 3);\n          } else {\n            this.mergeAt(n - 2);\n          }\n          continue;\n        } else if(B <= C) {\n          this.mergeAt(n - 2);\n          continue;\n        }\n      }\n\n      if(this.runs.length > 1 && this.runs[this.runs.length - 2].runLen <= this.runs[this.runs.length - 1].runLen) {\n        this.mergeAt(this.runs.length - 2);\n      } else {\n        break;\n      }\n    }\n  }\n\n  mergeForceCollapse() {\n    while(this.runs.length > 1) {\n      let n = this.runs.length;\n      if(n >= 2) {\n        this.mergeAt(n - 2);\n      }\n    }\n  }\n\n  timSort() {\n    this.log(`Starting TimSort on array length ${this.array.length} with minRun=${this.minRun}\\n`);\n\n    let n = this.array.length;\n    let lo = 0;\n    while(lo < n) {\n      let runLen = this.countRunAndMakeAscending(lo);\n\n      if(runLen < this.minRun) {\n        let forceLen = Math.min(this.minRun, n - lo);\n        this.insertionSort(lo, lo + forceLen - 1);\n        runLen = forceLen;\n      }\n\n      this.pushRun(lo, runLen);\n      this.mergeCollapse();\n\n      lo += runLen;\n    }\n\n    this.mergeForceCollapse();\n\n    this.log(`\\nFinal sorted array:\\n[${this.array.join(', ')}]`);\n  }\n}\n\ndocument.getElementById('startBtn').addEventListener('click', () => {\n  let input = document.getElementById('arrayInput').value.trim();\n  if(!input) return alert('Please enter a comma separated list of numbers.');\n\n  let arr = input.split(',').map(s => Number(s.trim())).filter(n => !isNaN(n));\n  if(arr.length === 0) return alert('Please enter valid numbers.');\n\n  let logElement = document.getElementById('steplog');\n  logElement.innerHTML = ''; // Clear\n\n  let sorter = new TimSortDemo(arr, logElement);\n  sorter.timSort();\n});\n</script>\n</body>\n</html>"
