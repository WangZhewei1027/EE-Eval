    "content": "<html>\n<head>\n    <title>Kruskal's Algorithm</title>\n    <style>\n        table {\n            border-collapse: collapse;\n        }\n        th, td {\n            border: 1px solid black;\n            padding: 5px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Kruskal's Algorithm</h1>\n    <button id=\"generate-kmp-btn\">Generate Graph</button>\n    <button id=\"run-kmp-btn\">Run Kruskal's Algorithm</button>\n    <div id=\"graph\"></div>\n    <script>\n        const graph = document.getElementById('graph');\n        const generateGraphBtn = document.getElementById('generate-kmp-btn');\n        const runKMPBtn = document.getElementById('run-kmp-btn');\n\n        generateGraphBtn.addEventListener('click', generateGraph);\n        runKMPBtn.addEventListener('click', runKMP);\n\n        function generateGraph() {\n            const edges = [\n                { from: 0, to: 1, weight: 10 },\n                { from: 1, to: 2, weight: 20 },\n                { from: 2, to: 3, weight: 30 },\n                { from: 3, to: 0, weight: 40 },\n                { from: 0, to: 4, weight: 50 },\n                { from: 4, to: 5, weight: 60 },\n            ];\n\n            const graphData = [];\n            for (const edge of edges) {\n                if (graphData[edge.from].length === 0 || graphData[edge.to].length === 0) {\n                    graphData[edge.from] = [edge];\n                    graphData[edge.to] = [edge];\n                } else {\n                    const minWeight = Math.min(...graphData[edge.from].map(node => node.weight));\n                    const minIndex = graphData[edge.from].indexOf(node => node.weight === minWeight);\n                    graphData[edge.from][minIndex].push(edge);\n                    graphData[edge.to].push(edge);\n                }\n            }\n\n            const edgesList = [];\n            for (const node of graphData) {\n                edgesList.push({ from: node[0], to: node[1], weight: node[2] });\n            }\n\n            const mst = kruskalAlgorithm(edgesList);\n            const result = generateMST(mst);\n            const html = result.map(node => `<tr><td>${node.from}</td><td>${node.to}</td><td>${node.weight}</td></tr>`).join('');\n            graph.innerHTML = html;\n        }\n\n        function kruskalAlgorithm(edges) {\n            edges.sort((a, b) => a.weight - b.weight);\n            const mst = [];\n            let parent = {};\n            let rank = {};\n\n            for (const edge of edges) {\n                if (mst.length === 0 || edge.weight < mst[mst.length - 1].weight) {\n                    mst.push(edge);\n                    parent[edge.from] = edge.to;\n                    rank[edge.to] = edge.to;\n                } else if (edge.weight === mst[mst.length - 1].weight && edge.from !== mst[mst.length - 1].to) {\n                    mst[mst.length - 1].weight = edge.weight;\n                    parent[edge.from] = edge.to;\n                    rank[edge.to] = edge.to;\n                }\n            }\n\n            return mst;\n        }\n\n        function generateMST(mst) {\n            const html = [];\n            for (const edge of mst) {\n                html.push(`<tr><td>${edge.from}</td><td>${edge.to}</td><td>${edge.weight}</td></tr>`);\n            }\n            return html.join('');\n        }\n    </script>\n</body>\n</html>"
