    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Stack</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .stack {\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            width: 300px;\n            margin: 50px auto;\n            text-align: center;\n        }\n        .stack input[type=\"text\"] {\n            padding: 10px;\n            margin: 5px;\n            width: 100%;\n        }\n        .stack button {\n            padding: 10px 20px;\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .stack button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"stack\">\n        <input type=\"text\" placeholder=\"Enter a message\" />\n        <button>Insert</button>\n        <button>Remove</button>\n        <p>Messages:</p>\n        <ul id=\"messages\"></ul>\n    </div>\n\n    <script>\n        let stack = new Stack();\n        let messages = document.getElementById(\"messages\");\n        let insertButton = document.querySelector(\"button\");\n        let removeButton = document.querySelector(\"button\");\n\n        function push(message) {\n            stack.push(message);\n            insertMessage(message);\n        }\n\n        function pop() {\n            if (stack.length > 0) {\n                stack.pop();\n                removeMessage();\n            }\n        }\n\n        function insertMessage(message) {\n            let li = document.createElement(\"li\");\n            li.textContent = message;\n            messages.appendChild(li);\n        }\n\n        function removeMessage() {\n            messages.removeChild(messages.lastChild);\n        }\n\n        insertButton.addEventListener(\"click\", push);\n        removeButton.addEventListener(\"click\", pop);\n    </script>\n</body>\n</html>"
