    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Logistic Regression Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            text-align: center;\n        }\n        .scatter {\n            display: inline-block;\n            position: relative;\n            height: 400px;\n            width: 400px;\n            border: 1px solid #ccc;\n            margin-bottom: 20px;\n        }\n        .point {\n            position: absolute;\n            border-radius: 50%;\n        }\n        .line {\n            position: absolute;\n            height: 100%;\n            width: 2px;\n            background: red;\n            top: 0;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Logistic Regression Demonstration</h1>\n<div class=\"scatter\" id=\"scatterPlot\"></div>\n<button onclick=\"trainModel()\">Train Model</button>\n\n<div id=\"message\"></div>\n\n<script>\n    // Sample data: [x, y, class]\n    const data = [\n        [0.1, 0.2, 0],\n        [0.4, 0.3, 0],\n        [0.2, 0.5, 0],\n        [0.6, 0.6, 1],\n        [0.8, 0.9, 1],\n        [0.9, 0.8, 1]\n    ];\n\n    let weights = [0, 0]; // Initialize weights for the model\n\n    const scatterPlot = document.getElementById('scatterPlot');\n\n    function plotData() {\n        scatterPlot.innerHTML = '';\n        data.forEach(point => {\n            const [x, y, cls] = point;\n            const color = cls === 1 ? 'blue' : 'green';\n            const div = document.createElement('div');\n            div.classList.add('point');\n            div.style.backgroundColor = color;\n            div.style.width = '10px';\n            div.style.height = '10px';\n            div.style.left = `${x * 400}px`; // Scale to the plot\n            div.style.top = `${(1 - y) * 400}px`; // Invert y-axis\n            scatterPlot.appendChild(div);\n        });\n    }\n\n    function sigmoid(z) {\n        return 1 / (1 + Math.exp(-z));\n    }\n\n    function predict(x1, x2) {\n        return sigmoid(weights[0] + weights[1] * x1);\n    }\n\n    function trainModel() {\n        const learningRate = 0.1;\n        const epochs = 1000;\n\n        for (let i = 0; i < epochs; i++) {\n            data.forEach(point => {\n                const [x1, x2, y] = point;\n                const prediction = predict(x1, x2);\n                const error = y - prediction;\n\n                // Update weights\n                weights[0] += learningRate * error * prediction * (1 - prediction);\n                weights[1] += learningRate * error * prediction * (1 - prediction) * x1;\n                weights[1] += learningRate * error * prediction * (1 - prediction) * x2;\n            });\n        }\n\n        document.getElementById('message').innerText = 'Model trained.';\n        drawDecisionBoundary();\n    }\n\n    function drawDecisionBoundary() {\n        const line = document.createElement('div');\n        line.classList.add('line');\n        \n        const x1 = 0; // start\n        const x2 = 1; // end\n        \n        const y1 = predict(x1, 0); // intersect with y-axis\n        const y2 = predict(x2, 1); // intersect with end\n\n        const slope = (y2 - y1) / (x2 - x1);\n        \n        const angle = Math.atan(slope) * (180 / Math.PI);\n        const distance = 400 * slope;\n\n        line.style.transform = `rotate(${angle}deg)`;\n        line.style.left = `${x1 * 400}px`;\n        line.style.top = `${(1 - y1) * 400}px`;\n        line.style.height = `${distance}px`;\n        \n        scatterPlot.appendChild(line);\n    }\n    \n    plotData();\n\n</script>\n</body>\n</html>"
  },
