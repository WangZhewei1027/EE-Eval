    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Overfitting Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 20px;\n            background-color: #f4f4f4;\n        }\n        #chart {\n            width: 600px;\n            height: 400px;\n            margin: auto;\n            background-color: white;\n            border: 1px solid #ccc;\n        }\n        #controls {\n            text-align: center;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Overfitting Demonstration</h1>\n    <p>This demonstration shows the concept of overfitting in machine learning using a simple polynomial regression.</p>\n    <div id=\"chart\"></div>\n    <div id=\"controls\">\n        <button onclick=\"drawGraph(1)\">Underfitting</button>\n        <button onclick=\"drawGraph(3)\">Just Right</button>\n        <button onclick=\"drawGraph(10)\">Overfitting</button>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <script>\n        const ctx = document.getElementById('chart').getContext('2d');\n        let myChart;\n\n        function drawGraph(degree) {\n            const dataX = Array.from({length: 30}, (_, i) => i / 5);\n            const dataY = dataX.map(x => Math.sin(x) + (Math.random() * 0.2 - 0.1)); // Adding noise\n\n            const polynomialCoefficients = Array.from({length: degree + 1}, () => Math.random() * 2 - 1); // Random coefficients\n\n            const predictedY = dataX.map(x => {\n                return polynomialCoefficients.reduce((sum, coeff, index) => sum + coeff * Math.pow(x, index), 0);\n            });\n\n            if (myChart) {\n                myChart.destroy();\n            }\n\n            myChart = new Chart(ctx, {\n                type: 'scatter',\n                data: {\n                    datasets: [{\n                        label: 'Data Points',\n                        data: dataY.map((y, index) => ({ x: dataX[index], y })),\n                        backgroundColor: 'rgba(75, 192, 192, 0.6)',\n                        showLine: false,\n                        pointRadius: 3\n                    }, {\n                        label: 'Polynomial Fit',\n                        data: predictedY.map((y, index) => ({ x: dataX[index], y })),\n                        borderColor: degree > 5 ? 'rgba(255, 99, 132, 1)' : 'rgba(54, 162, 235, 1)',\n                        borderWidth: 2,\n                        fill: false,\n                        type: 'line'\n                    }]\n                },\n                options: {\n                    scales: {\n                        y: {\n                            beginAtZero: false\n                        }\n                    }\n                }\n            });\n        }\n\n        // Draw the default graph\n        drawGraph(1);\n    </script>\n</body>\n</html>"
