    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Monitor</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        \n        #monitor {\n            width: 50%;\n            margin: 40px auto;\n            border: 1px solid #ddd;\n            padding: 20px;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        #monitor h1 {\n            margin-top: 0;\n        }\n        \n        #monitor p {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"monitor\">\n        <h1>Monitor</h1>\n        <p>This is a simple monitor application.</p>\n    </div>\n\n    <script>\n        const monitor = document.getElementById('monitor');\n        const text = document.createElement('p');\n        text.textContent = 'This is a simple monitor application.';\n        monitor.appendChild(text);\n\n        const input = document.createElement('input');\n        input.type = 'text';\n        input.placeholder = 'Enter text to display on the monitor';\n        monitor.appendChild(input);\n\n        document.addEventListener('keydown', (e) => {\n            if (e.key === 'Enter') {\n                const textToDisplay = input.value.trim();\n                if (textToDisplay) {\n                    monitor.appendChild(document.createTextNode(textToDisplay));\n                    input.value = '';\n                }\n            }\n        });\n    </script>\n</body>\n</html>"
