    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>REST API Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            background-color: #f4f4f4;\n        }\n        #data {\n            margin-top: 20px;\n            padding: 10px;\n            background: white;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .user {\n            margin-bottom: 15px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        button {\n            margin-right: 10px;\n            padding: 10px 15px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .btn-fetch { background-color: #3498db; color: white; }\n        .btn-create { background-color: #2ecc71; color: white; }\n    </style>\n</head>\n<body>\n\n<h1>REST API Demo</h1>\n<button class=\"btn-fetch\" onclick=\"fetchUsers()\">Fetch Users</button>\n<button class=\"btn-create\" onclick=\"createUser()\">Create User</button>\n\n<div id=\"data\"></div>\n\n<script>\n    const apiUrl = 'https://jsonplaceholder.typicode.com/users';\n\n    async function fetchUsers() {\n        const response = await fetch(apiUrl);\n        const users = await response.json();\n        displayUsers(users);\n    }\n\n    async function createUser() {\n        const newUser = {\n            name: 'John Doe',\n            email: 'johndoe@example.com'\n        };\n\n        const response = await fetch(apiUrl, {\n            method: 'POST',\n            headers: {\n                'Content-Type': 'application/json'\n            },\n            body: JSON.stringify(newUser)\n        });\n\n        const createdUser = await response.json();\n        alert('User Created: ' + createdUser.name);\n        fetchUsers(); // Refresh the user list\n    }\n\n    function displayUsers(users) {\n        const dataDiv = document.getElementById('data');\n        dataDiv.innerHTML = '';\n        users.forEach(user => {\n            const userDiv = document.createElement('div');\n            userDiv.className = 'user';\n            userDiv.innerHTML = `<strong>${user.name}</strong><br>Email: ${user.email}`;\n            dataDiv.appendChild(userDiv);\n        });\n    }\n</script>\n\n</body>\n</html>"
