  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Context Switching Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#7dd3fc;\n      --accent2:#60a5fa;\n      --muted:#9aa7bb;\n      --good:#22c55e;\n      --bad:#fb7185;\n      --glass: rgba(255,255,255,0.03);\n    }\n    html,body{height:100%;margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,'Segoe UI',Roboto,'Helvetica Neue',Arial;}\n    body{background:linear-gradient(180deg,#071028 0%, #0f1724 60%); color:#e6eef8; padding:18px; box-sizing:border-box;}\n    header{display:flex;gap:12px;align-items:center;margin-bottom:12px;}\n    header h1{font-size:18px;margin:0;}\n    .container{display:grid;grid-template-columns:300px 1fr 320px;gap:14px;align-items:start;}\n    .panel{background:var(--panel); padding:14px;border-radius:10px; box-shadow: 0 6px 18px rgba(2,6,23,0.6); }\n    .controls h3{margin:0 0 8px 0;font-size:13px;color:var(--accent);}\n    .controls label{display:block;margin:8px 0;font-size:13px;color:var(--muted);}\n    .row{display:flex;gap:8px;align-items:center;}\n    button{background:linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.04);color:var(--accent);padding:8px 10px;border-radius:8px;cursor:pointer;}\n    button.secondary{color:var(--muted);background:transparent;border:1px dashed rgba(255,255,255,0.03);}\n    button.danger{color:var(--bad);border-color:rgba(251,113,133,0.15);}\n    input[type=range]{width:100%;}\n    .cpu-area{display:flex;flex-direction:column;gap:12px;}\n    .cpu{display:flex;gap:12px;align-items:flex-start;}\n    .cpu-visual{flex:1;background:linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01));padding:18px;border-radius:10px;min-height:240px; }\n    .status-bar{display:flex;gap:12px;align-items:center;margin-bottom:8px;}\n    .chip{background:var(--glass);padding:8px 10px;border-radius:8px;font-size:13px;color:var(--muted);display:inline-flex;align-items:center;gap:8px;}\n    .big{font-size:18px;color:var(--accent); font-weight:600;}\n    .task-list{display:flex;flex-direction:column;gap:10px;}\n    .task{display:flex;align-items:center;justify-content:space-between;padding:10px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));border:1px solid rgba(255,255,255,0.02);}\n    .task .meta{display:flex;gap:12px;align-items:center;}\n    .badge{width:28px;height:28px;border-radius:6px;display:inline-flex;align-items:center;justify-content:center;font-weight:700;color:#04263b;}\n    .task small{color:var(--muted);display:block;font-size:12px;}\n    .registers{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}\n    .reg{background:rgba(255,255,255,0.02);padding:8px;border-radius:6px;font-size:13px;min-width:72px;}\n    .timeline{height:80px;background:rgba(255,255,255,0.02);border-radius:8px;padding:8px;overflow:auto;}\n    .timeline-bar{height:28px;border-radius:6px;display:flex;align-items:center;gap:2px;padding:2px;}\n    .segment{height:24px;border-radius:4px;padding:2px 6px;color:#04263b;font-weight:700;font-size:12px;display:inline-flex;align-items:center;justify-content:center;}\n    footer{margin-top:12px;font-size:12px;color:var(--muted);}\n    .toggle{display:inline-flex;align-items:center;gap:8px;}\n    .legend{display:flex;gap:8px;align-items:center;margin-top:8px;}\n    .legend .dot{width:12px;height:12px;border-radius:3px;}\n    .note{font-size:13px;color:var(--muted);margin-top:8px;}\n    .controls .mini{font-size:13px;color:var(--muted);margin-top:6px;}\n    .task-actions button{margin-left:6px;}\n    .instructions{font-family:monospace;background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;margin-top:8px;white-space:pre-wrap;font-size:13px;color:var(--muted);}\n    .center{display:flex;align-items:center;justify-content:center;}\n    .cpu-screen{background:linear-gradient(180deg,#021025,#052033);border-radius:8px;padding:12px;color:#bfe9ff;min-height:120px;display:flex;flex-direction:column;gap:8px;}\n    .current-task{font-weight:700;color:var(--accent);}\n    .small-muted{font-size:12px;color:var(--muted);}\n    input[type=number]{width:80px;padding:6px;border-radius:6px;background:transparent;border:1px solid rgba(255,255,255,0.03);color:var(--accent);}\n    .controls-row{display:flex;gap:8px;flex-wrap:wrap;}\n    .mode{display:inline-flex;gap:6px;align-items:center;}\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Context Switching — Interactive Demonstration</h1>\n    <div style=\"margin-left:auto;\" class=\"small-muted\">Simulates tasks, CPU, and switching overhead</div>\n  </header>\n\n  <div class=\"container\">\n    <!-- Left: Controls -->\n    <div class=\"panel controls\">\n      <h3>Simulation Controls</h3>\n\n      <label>Mode</label>\n      <div class=\"row\">\n        <div class=\"mode\">\n          <label><input type=\"radio\" name=\"mode\" value=\"preemptive\" checked> Preemptive</label>\n          <label style=\"margin-left:8px;\"><input type=\"radio\" name=\"mode\" value=\"cooperative\"> Cooperative</label>\n        </div>\n      </div>\n\n      <label>Quantum (instructions per slice)</label>\n      <input id=\"quantum\" type=\"range\" min=\"1\" max=\"8\" value=\"3\">\n      <div class=\"row mini small-muted\"><div>Quantum = <span id=\"quantumVal\">3</span> instruction(s)</div></div>\n\n      <label>Context Switch Overhead (simulated instructions)</label>\n      <input id=\"overhead\" type=\"range\" min=\"0\" max=\"6\" value=\"2\">\n      <div class=\"row mini small-muted\">Overhead = <span id=\"overheadVal\">2</span> instruction(s)</div>\n\n      <div style=\"margin-top:10px;\">\n        <button id=\"runBtn\">Run</button>\n        <button id=\"stepBtn\" class=\"secondary\">Step</button>\n        <button id=\"stopBtn\" class=\"secondary\">Stop</button>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <label>Add Task</label>\n        <div class=\"row\">\n          <select id=\"preset\">\n            <option value=\"counter\">Counter (increment)</option>\n            <option value=\"sum\">Sum & yield</option>\n            <option value=\"busy\">Busy computation</option>\n            <option value=\"io\">I/O-like (frequent yield)</option>\n          </select>\n          <button id=\"addTask\">Add</button>\n        </div>\n        <div class=\"mini small-muted\">Tasks have short instruction sequences that read/update registers and yield.</div>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <label>Statistics</label>\n        <div class=\"row\">\n          <div class=\"chip\">Context switches: <span id=\"switchCount\" class=\"big\">0</span></div>\n          <div class=\"chip\">Cycles executed: <span id=\"cycleCount\" class=\"big\">0</span></div>\n        </div>\n        <div class=\"note\">Switch overhead subtracts from usable cycles and is counted in cycles executed.</div>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <label>Timeline</label>\n        <div class=\"timeline\" id=\"timeline\"></div>\n      </div>\n\n      <footer class=\"small-muted\">Use \"Step\" to observe saving/restoring of register state. Try changing quantum or overhead to see impact.</footer>\n    </div>\n\n    <!-- Middle: CPU Visual -->\n    <div class=\"panel cpu-area\">\n      <div class=\"status-bar\">\n        <div class=\"chip\">Scheduler: <span id=\"modeLabel\" style=\"color:var(--accent);font-weight:700\">Preemptive</span></div>\n        <div class=\"chip\">Active tasks: <span id=\"taskCount\">0</span></div>\n        <div class=\"chip\">Ready queue length: <span id=\"queueLen\">0</span></div>\n        <div style=\"margin-left:auto;\" class=\"chip\">Tick speed: <span id=\"tickSpeed\">Auto</span></div>\n      </div>\n\n      <div class=\"cpu\">\n        <div class=\"cpu-visual\">\n          <div class=\"cpu-screen\">\n            <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n              <div>\n                <div class=\"small-muted\">CPU</div>\n                <div style=\"font-size:16px;margin-top:6px\">Instruction execution & context switching</div>\n              </div>\n              <div style=\"text-align:right\">\n                <div class=\"small-muted\">Currently running</div>\n                <div id=\"currentTask\" class=\"current-task\">—</div>\n                <div class=\"small-muted\" style=\"margin-top:6px\">PC: <span id=\"pc\">—</span></div>\n              </div>\n            </div>\n\n            <div class=\"registers\" id=\"registersArea\">\n              <!-- register cards -->\n            </div>\n\n            <div style=\"display:flex;gap:8px;margin-top:6px;align-items:center;\">\n              <div class=\"small-muted\">Instruction:</div>\n              <div id=\"currentInstr\" style=\"font-family:monospace;color:var(--accent2)\"></div>\n              <div style=\"margin-left:auto\" class=\"small-muted\">Context save/restore highlighted during switch</div>\n            </div>\n\n            <div style=\"margin-top:8px;\">\n              <div class=\"small-muted\">Last actions</div>\n              <div id=\"log\" style=\"max-height:90px;overflow:auto;font-size:13px;color:var(--muted);\"></div>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"width:320px;\">\n          <h3 style=\"margin:0 0 8px 0;color:var(--accent);\">Ready Queue</h3>\n          <div class=\"task-list\" id=\"taskList\"></div>\n\n          <div style=\"margin-top:10px;\">\n            <div class=\"small-muted\">Selected Task Instructions</div>\n            <div id=\"instructionsView\" class=\"instructions\">No task selected</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Right: Task details & legend -->\n    <div class=\"panel\">\n      <h3>Task Inspector</h3>\n      <div id=\"inspector\">\n        <div class=\"small-muted\">Select a task from the ready queue to inspect its registers and context snapshot.</div>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <h3 style=\"margin:6px 0;color:var(--accent);\">Legend</h3>\n        <div class=\"legend\">\n          <div style=\"display:flex;flex-direction:column;\">\n            <div style=\"width:48px;height:24px;background:#8bd5ff;border-radius:6px;\" class=\"mini\"></div>\n            <small class=\"small-muted\">Task A color</small>\n          </div>\n          <div style=\"display:flex;flex-direction:column;\">\n            <div style=\"width:48px;height:24px;background:#7ee7b8;border-radius:6px;\"></div>\n            <small class=\"small-muted\">Task B color</small>\n          </div>\n          <div style=\"display:flex;flex-direction:column;\">\n            <div style=\"width:48px;height:24px;background:#ffd29e;border-radius:6px;\"></div>\n            <small class=\"small-muted\">Task C color</small>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <h3 style=\"margin:6px 0;color:var(--accent);\">How it works</h3>\n        <div class=\"small-muted\">\n          - Each task has simple instructions (INC, ADD, PRINT, YIELD, JUMP)<br>\n          - CPU executes up to \"Quantum\" instructions then performs a context switch (preemptive), or only on YIELD (cooperative)<br>\n          - Context switch saves task registers (PC, A, B) and simulates overhead cycles<br>\n          - Try different overhead and quantum to see throughput and switching frequency\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Simple interactive simulation of context switching\n    (function(){\n      // Utilities\n      const randColor = (i)=> ['#8bd5ff','#7ee7b8','#ffd29e','#f6a6ff','#cbd5ff'][i%5];\n\n      // UI elements\n      const runBtn = document.getElementById('runBtn');\n      const stepBtn = document.getElementById('stepBtn');\n      const stopBtn = document.getElementById('stopBtn');\n      const addTaskBtn = document.getElementById('addTask');\n      const preset = document.getElementById('preset');\n      const taskListEl = document.getElementById('taskList');\n      const taskCountEl = document.getElementById('taskCount');\n      const queueLenEl = document.getElementById('queueLen');\n      const currentTaskEl = document.getElementById('currentTask');\n      const pcEl = document.getElementById('pc');\n      const registersArea = document.getElementById('registersArea');\n      const currentInstrEl = document.getElementById('currentInstr');\n      const switchCountEl = document.getElementById('switchCount');\n      const cycleCountEl = document.getElementById('cycleCount');\n      const timelineEl = document.getElementById('timeline');\n      const instructionsView = document.getElementById('instructionsView');\n      const inspector = document.getElementById('inspector');\n      const quantumEl = document.getElementById('quantum');\n      const quantumVal = document.getElementById('quantumVal');\n      const overheadEl = document.getElementById('overhead');\n      const overheadVal = document.getElementById('overheadVal');\n      const modeRadios = document.getElementsByName('mode');\n      const modeLabel = document.getElementById('modeLabel');\n      const logEl = document.getElementById('log');\n\n      // Simulation state\n      let nextTaskId = 1;\n      let tasks = []; // ready queue (simple FIFO)\n      let allTasks = {}; // id->task\n      let currentTask = null;\n      let running = false;\n      let autoInterval = null;\n      let tickDelay = 300; // ms per instruction when running auto\n      let cycleCount = 0;\n      let switchCount = 0;\n\n      // Config\n      function getMode(){ return Array.from(modeRadios).find(r=>r.checked).value; }\n      function getQuantum(){ return parseInt(quantumEl.value,10); }\n      function getOverhead(){ return parseInt(overheadEl.value,10); }\n\n      // Instruction set (simple)\n      // INC reg\n      // DEC reg\n      // ADD reg value\n      // YIELD\n      // JUMP offset\n      // PRINT reg\n      // COMPUTE n  (simulate busy work, consumes n cycles)\n      // Note: We'll treat each instruction as cost 1 cycle (except COMPUTE cost)\n      function createTask(presetType){\n        const id = nextTaskId++;\n        const color = randColor(id);\n        let code = [];\n        let name = 'Task '+id;\n        if(presetType==='counter'){\n          name = 'Counter '+id;\n          code = [\n            'INC A',\n            'PRINT A',\n            'INC A',\n            'PRINT A',\n            'YIELD',\n            'INC A',\n            'PRINT A',\n            'YIELD',\n            'INC A',\n            'PRINT A',\n          ];\n        } else if(presetType==='sum'){\n          name='Summer '+id;\n          code=[\n            'INC A',\n            'ADD B 3',\n            'PRINT A',\n            'YIELD',\n            'ADD A B',\n            'PRINT A',\n            'YIELD',\n            'JUMP -3' // loop back\n          ];\n        } else if(presetType==='busy'){\n          name='Busy '+id;\n          code=[\n            'COMPUTE 4',\n            'INC A',\n            'COMPUTE 3',\n            'PRINT A',\n            'YIELD',\n            'JUMP -5'\n          ];\n        } else if(presetType==='io'){\n          name='IO-like '+id;\n          code=[\n            'INC A',\n            'PRINT A',\n            'YIELD',\n            'YIELD',\n            'INC A',\n            'PRINT A',\n            'YIELD',\n            'JUMP -5'\n          ];\n        } else {\n          code=['INC A','PRINT A','YIELD'];\n        }\n\n        const task = {\n          id, name, color, code,\n          pc:0,\n          regs: {A:0,B:0},\n          alive:true,\n          // Snapshot history (for inspector)\n          snapshots: [],\n        };\n        tasks.push(task);\n        allTasks[id]=task;\n        updateUI();\n      }\n\n      // CPU functions\n      function saveContext(task){\n        // Simulate saving registers & pc\n        task.snapshots.push({pc:task.pc, regs:{...task.regs}});\n      }\n\n      function restoreContext(task){\n        // No-op here because regs are in task, but we highlight snapshot\n      }\n\n      function stepInstruction(task){\n        if(!task || !task.alive) return {consumed:0, switched:false, log:''};\n        if(task.pc<0 || task.pc>=task.code.length){\n          // terminate\n          task.alive=false;\n          return {consumed:0, switched:true, log:`${task.name} finished`};\n        }\n        const instr = task.code[task.pc].trim();\n        let parts = instr.split(/\\s+/);\n        const op = parts[0].toUpperCase();\n        let logMsg = `${task.name}: ${instr}`;\n        let consumed = 1;\n        switch(op){\n          case 'INC':\n            task.regs[parts[1]] = (task.regs[parts[1]]||0)+1;\n            task.pc++;\n            break;\n          case 'DEC':\n            task.regs[parts[1]] = (task.regs[parts[1]]||0)-1;\n            task.pc++;\n            break;\n          case 'ADD':\n            const val = parseInt(parts[2],10)||0;\n            task.regs[parts[1]] = (task.regs[parts[1]]||0)+val;\n            task.pc++;\n            break;\n          case 'PRINT':\n            // For demo, print to log\n            log(`${task.name} -> ${parts[1]} = ${task.regs[parts[1]]||0}`);\n            task.pc++;\n            break;\n          case 'YIELD':\n            task.pc++;\n            return {consumed:1, switched:true, log:logMsg};\n          case 'JUMP':\n            const offset = parseInt(parts[1],10)||0;\n            task.pc = task.pc + offset;\n            break;\n          case 'COMPUTE':\n            consumed = Math.max(1, parseInt(parts[1],10)||1);\n            // stay at the same instruction to simulate multi-cycle compute,\n            // reduce \"remaining\" by counting cycles using a hidden field\n            if(!task._computeRemaining || task._computeRemaining<=0){\n              task._computeRemaining = consumed;\n            }\n            task._computeRemaining--;\n            if(task._computeRemaining<=0){\n              task.pc++;\n              delete task._computeRemaining;\n            }\n            break;\n          default:\n            task.pc++;\n            break;\n        }\n        return {consumed, switched:false, instr, log:logMsg};\n      }\n\n      function log(msg){\n        const el = document.createElement('div');\n        el.textContent = `[${timestamp()}] ${msg}`;\n        logEl.prepend(el);\n        if(logEl.childElementCount>80) logEl.removeChild(logEl.lastChild);\n      }\n      function timestamp(){ return new Date().toLocaleTimeString(); }\n\n      // Scheduler\n      function pickNext(){\n        // simple FIFO: rotate queue\n        if(tasks.length===0) return null;\n        // Remove completed tasks\n        tasks = tasks.filter(t=>t.alive);\n        if(tasks.length===0) return null;\n        // Next is tasks.shift()\n        const next = tasks.shift();\n        tasks.push(next); // put it at end (round-robin)\n        return next;\n      }\n\n      function performContextSwitch(oldTask, newTask){\n        // Save old, restore new; simulate overhead cycles\n        if(oldTask){\n          saveContext(oldTask);\n          highlightSave(oldTask);\n        }\n        if(newTask){\n          restoreContext(newTask);\n          highlightRestore(newTask);\n        }\n        // count overhead cycles\n        const overhead = getOverhead();\n        cycleCount += overhead;\n        switchCount++;\n        switchCountEl.textContent = switchCount;\n        cycleCountEl.textContent = cycleCount;\n        // timeline: add a special marker for context switch\n        addTimelineSegment('ctx', overhead);\n      }\n\n      function addTimelineSegment(taskName, length){\n        // length = number of cycles represented\n        const seg = document.createElement('div');\n        seg.className = 'segment';\n        seg.style.background = taskName==='ctx' ? '#394a5a' : findTaskColorByName(taskName);\n        seg.style.color = '#00171a';\n        seg.textContent = taskName==='ctx' ? 'CS' : taskName;\n        seg.title = `${taskName} (${length} cycles)`;\n        timelineEl.appendChild(seg);\n        // maintain width: size proportional to cycles\n        seg.style.flex = `0 0 ${Math.min(160,8+length*12)}px`;\n        if(timelineEl.childElementCount>40) timelineEl.removeChild(timelineEl.firstChild);\n      }\n\n      function findTaskColorByName(name){\n        for(const k in allTasks){\n          if(allTasks[k].name===name) return allTasks[k].color;\n        }\n        return '#9aa7bb';\n      }\n\n      // UI update\n      function updateUI(){\n        // Ready list\n        taskListEl.innerHTML='';\n        tasks.forEach((t,idx)=>{\n          const el = document.createElement('div');\n          el.className='task';\n          el.style.borderLeft = `4px solid ${t.color}`;\n          el.innerHTML = `<div class=\"meta\">\n            <div style=\"display:flex;flex-direction:column;\">\n              <div style=\"font-weight:700\">${t.name}</div>\n              <small>PC: ${t.pc} • A:${t.regs.A} B:${t.regs.B}</small>\n            </div>\n          </div>\n          <div class=\"task-actions\">\n            <button data-id=\"${t.id}\" class=\"inspect secondary\">Inspect</button>\n            <button data-id=\"${t.id}\" class=\"kill danger\">Kill</button>\n          </div>`;\n          taskListEl.appendChild(el);\n        });\n        taskCountEl.textContent = Object.keys(allTasks).length;\n        queueLenEl.textContent = tasks.length;\n      }\n\n      // Inspector\n      function showInspector(taskId){\n        const t = allTasks[taskId];\n        if(!t){ inspector.innerHTML = '<div class=\"small-muted\">Task not found</div>'; return; }\n        inspector.innerHTML = `\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div style=\"font-weight:700\">${t.name}</div>\n            <div style=\"background:${t.color};padding:6px 8px;border-radius:6px;color:#00171a\">ID ${t.id}</div>\n          </div>\n          <div class=\"note\" style=\"margin-top:8px\">PC: ${t.pc} &nbsp; | &nbsp; A: ${t.regs.A} &nbsp; B: ${t.regs.B}</div>\n          <div style=\"margin-top:8px\"><strong>Code:</strong></div>\n          <pre class=\"instructions\">${t.code.map((c,i)=> (i===t.pc? '→ ':'   ') + i + ': ' + c).join('\\\\n')}</pre>\n          <div style=\"margin-top:8px\"><strong>Last snapshot(s):</strong>\n            <div class=\"small-muted\">${t.snapshots.slice(-3).map(s=>`PC=${s.pc}, A=${s.regs.A}, B=${s.regs.B}`).join('<br>') || '—'}</div>\n          </div>\n        `;\n      }\n\n      // Highlight save/restore (visual cue)\n      function highlightSave(task){\n        // flash the task element border to indicate saving\n        const nodes = taskListEl.querySelectorAll('.task');\n        nodes.forEach(node=>{\n          if(node.querySelector('.task-actions .inspect') && node.querySelector('.task-actions .inspect').dataset.id==task.id){\n            node.style.boxShadow = 'inset 0 0 0 2px rgba(255,255,255,0.02)';\n            setTimeout(()=>node.style.boxShadow='', 350);\n          }\n        });\n      }\n      function highlightRestore(task){\n        const nodes = taskListEl.querySelectorAll('.task');\n        nodes.forEach(node=>{\n          if(node.querySelector('.task-actions .inspect') && node.querySelector('.task-actions .inspect').dataset.id==task.id){\n            node.style.transform = 'scale(1.01)';\n            setTimeout(()=>node.style.transform='', 280);\n          }\n        });\n      }\n\n      // Controllers: run/stop/step\n      function runAuto(){\n        if(running) return;\n        running=true;\n        runBtn.textContent='Running...';\n        autoInterval = setInterval(()=> {\n          // Execute a quantum or step-by-step with small delay\n          for(let q=0;q<getQuantum();q++){\n            executeCycle();\n          }\n        }, Math.max(80, tickDelay));\n      }\n\n      function stopAuto(){\n        running=false;\n        runBtn.textContent='Run';\n        if(autoInterval) clearInterval(autoInterval);\n        autoInterval=null;\n      }\n\n      function stepOnce(){\n        executeCycle();\n      }\n\n      function executeCycle(){\n        // If no tasks, nothing to do\n        if(tasks.length===0){\n          currentTask = null;\n          currentTaskEl.textContent = '—';\n          pcEl.textContent = '—';\n          currentInstrEl.textContent = '';\n          return;\n        }\n\n        // On first run start with currentTask = pickNext()\n        if(!currentTask || !currentTask.alive){\n          const next = pickNext();\n          const old = currentTask;\n          currentTask = next;\n          performContextSwitch(old, currentTask);\n        }\n\n        // Determine if preemptive switch should occur after quantum\n        const mode = getMode();\n        // We'll execute one instruction for the current task per call,\n        // but manage quantum via internal counter\n        if(!currentTask._sliceRemaining || currentTask._sliceRemaining<=0){\n          currentTask._sliceRemaining = getQuantum();\n        }\n\n        // Execute single instruction from currentTask\n        updateCPUView(currentTask);\n        const res = stepInstruction(currentTask);\n        cycleCount += res.consumed;\n        cycleCountEl.textContent = cycleCount;\n        pcEl.textContent = currentTask.pc;\n        currentInstrEl.textContent = res.instr || (res.log || '');\n        if(res.log && res.log.startsWith('Task')) {\n          // additional log handled by stepInstruction\n        }\n\n        // If instruction requested yielding or we ran out of quantum (preemptive), switch\n        currentTask._sliceRemaining -= 1;\n        // If the task finished, remove it\n        if(!currentTask.alive){\n          // Remove from queue and record\n          log(`${currentTask.name} terminated`);\n          delete allTasks[currentTask.id];\n          tasks = tasks.filter(t=>t.alive);\n          currentTask = null;\n          updateUI();\n          return;\n        }\n\n        let needSwitch = false;\n        if(res.switched) needSwitch = true;\n        else if(mode==='preemptive' && currentTask._sliceRemaining<=0) needSwitch = true;\n\n        if(needSwitch){\n          const old = currentTask;\n          const next = pickNext();\n          currentTask = next;\n          performContextSwitch(old, currentTask);\n          // timeline: mark the actual task that ran next\n          addTimelineSegment(old.name, 1);\n          if(currentTask) addTimelineSegment(currentTask.name, 1);\n        } else {\n          // no switch: timeline extend\n          addTimelineSegment(currentTask.name, 1);\n        }\n\n        updateUI();\n      }\n\n      // Update the CPU panel with current task status\n      function updateCPUView(task){\n        currentTaskEl.textContent = task ? task.name : '—';\n        pcEl.textContent = task ? task.pc : '—';\n        // show registers\n        registersArea.innerHTML = '';\n        if(task){\n          ['A','B'].forEach(r=>{\n            const el = document.createElement('div');\n            el.className='reg';\n            el.innerHTML = `<div style=\"font-size:12px;color:var(--muted)\">${r}</div><div style=\"font-weight:700;color:var(--accent)\">${task.regs[r]||0}</div>`;\n            registersArea.appendChild(el);\n          });\n        }\n      }\n\n      // Event listeners\n      runBtn.addEventListener('click', ()=>{\n        if(running) { stopAuto(); } else { runAuto(); }\n      });\n      stopBtn.addEventListener('click', ()=> stopAuto());\n      stepBtn.addEventListener('click', ()=> {\n        stopAuto();\n        stepOnce();\n      });\n\n      addTaskBtn.addEventListener('click', ()=>{\n        createTask(preset.value);\n      });\n\n      taskListEl.addEventListener('click', (e)=>{\n        const btn = e.target;\n        if(btn.classList.contains('inspect')){\n          const id = parseInt(btn.dataset.id,10);\n          showInspector(id);\n          const t = allTasks[id];\n          if(t) instructionsView.textContent = t.code.map((c,i)=> (i===t.pc? '→ ' : '   ')+ i + ': ' + c).join('\\\\n');\n        } else if(btn.classList.contains('kill')){\n          const id = parseInt(btn.dataset.id,10);\n          const t = allTasks[id];\n          if(t){\n            t.alive=false;\n            delete allTasks[id];\n            tasks = tasks.filter(ts=>ts.id!==id);\n            updateUI();\n          }\n        }\n      });\n\n      quantumEl.addEventListener('input', ()=>{\n        quantumVal.textContent = quantumEl.value;\n      });\n      overheadEl.addEventListener('input', ()=>{\n        overheadVal.textContent = overheadEl.value;\n      });\n      Array.from(modeRadios).forEach(r=>{\n        r.addEventListener('change', ()=>{\n          modeLabel.textContent = getMode().charAt(0).toUpperCase() + getMode().slice(1);\n        });\n      });\n\n      // Initial seeds\n      createTask('counter');\n      createTask('sum');\n      createTask('busy');\n\n      // some helper initial update\n      updateUI();\n      quantumVal.textContent = quantumEl.value;\n      overheadVal.textContent = overheadEl.value;\n      modeLabel.textContent = getMode().charAt(0).toUpperCase() + getMode().slice(1);\n\n      // Small demonstration: step every 600ms if the user hasn't pressed run (visual animation)\n      // but don't auto-run; keep interactive.\n      // Provide keyboard: Space step, R toggle run\n      document.addEventListener('keydown', (e)=>{\n        if(e.code==='Space'){ e.preventDefault(); stepOnce(); }\n        if(e.key.toLowerCase()==='r'){ if(running) stopAuto(); else runAuto(); }\n      });\n\n      // Expose for debugging in console (optional)\n      window._ctxSim = {\n        createTask, tasks, allTasks, executeCycle, runAuto, stopAuto, stepOnce\n      };\n    })();\n  </script>\n</body>\n</html>"
