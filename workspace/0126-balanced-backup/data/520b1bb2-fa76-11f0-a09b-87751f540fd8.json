    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Unit Testing</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Unit Testing Example</h1>\n    <div id=\"container\"></div>\n\n    <script>\n        // Define a function to be tested\n        function add(a, b) {\n            return a + b;\n        }\n\n        // Define a test suite\n        function testAdd() {\n            let result = add(2, 3);\n            console.log(result);  // Expected output: 5\n\n            // Test the add function with invalid inputs\n            let result2 = add(2, 0);\n            console.log(result2);  // Expected output: 2\n\n            // Test the add function with negative numbers\n            let result3 = add(-2, -3);\n            console.log(result3);  // Expected output: -5\n        }\n\n        // Run the test suite\n        testAdd();\n\n        // Define a test runner\n        function testRunner() {\n            let test = new TestRunner();\n            test.addTest(testAdd);\n            test.run();\n        }\n\n        // Create a test runner\n        let testRunner = new TestRunner();\n\n        // Run the test suite\n        testRunner.run();\n    </script>\n\n    <script>\n        class TestRunner {\n            addTest(test) {\n                test.addFunction = test;\n            }\n\n            run() {\n                // Run the test suite\n                console.log(\"Running tests...\");\n                for (let test of test.addTest()) {\n                    test();\n                }\n            }\n        }\n\n        // Add a test function to the test runner\n        testRunner.addTest(testAdd);\n    </script>\n\n    <script>\n        // Define a test function\n        function testAdd() {\n            let a = 2;\n            let b = 3;\n            console.log(a + b);\n        }\n    </script>\n\n    <script>\n        // Run the test suite\n        let test = new TestRunner();\n        test.addTest(testAdd);\n        test.run();\n    </script>\n\n    <script>\n        // Define a function with a side effect (console.log)\n        function testAddSideEffect() {\n            let a = 2;\n            let b = 3;\n            console.log(a + b);\n            console.log(\"Side effect executed\");\n        }\n\n        // Run the test suite\n        let test = new TestRunner();\n        test.addTest(testAddSideEffect);\n        test.run();\n    </script>\n</body>\n</html>"
