    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Thread Concept Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n  }\n  .container {\n    max-width: 700px;\n    margin: auto;\n  }\n  button {\n    padding: 0.5rem 1rem;\n    font-size: 1rem;\n  }\n  #log {\n    margin-top: 1rem;\n    height: 300px;\n    overflow-y: scroll;\n    border: 1px solid #ccc;\n    background: #f9f9f9;\n    padding: 0.5rem;\n    white-space: pre-line;\n    font-family: monospace;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Thread Concept Demonstration (Using Web Workers)</h1>\n  <p>\n    This demo shows how <strong>threads</strong> enable multitasking in JavaScript using <em>Web Workers</em>.\n    The main thread runs UI, while a worker thread computes a heavy task concurrently.\n  </p>\n  <button id=\"startBtn\">Start Heavy Computation</button>\n  <div id=\"log\"></div>\n</div>\n\n<script>\n  const logEl = document.getElementById('log');\n  const startBtn = document.getElementById('startBtn');\n\n  function log(message) {\n    logEl.textContent += message + '\\n';\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  // Web Worker code as a Blob URL\n  const workerCode = `\n    self.onmessage = function(e) {\n      const max = e.data;\n      let count = 0;\n\n      // Simulate heavy computation: count primes up to max\n      function isPrime(n) {\n        if (n < 2) return false;\n        for(let i = 2; i*i <= n; i++) {\n          if (n % i === 0) return false;\n        }\n        return true;\n      }\n\n      for(let i = 2; i <= max; i++) {\n        if (isPrime(i)) count++;\n\n        // Report progress every 10%\n        if (i % Math.floor(max/10) === 0) {\n          self.postMessage({ progress: Math.floor((i / max) * 100) });\n        }\n      }\n\n      self.postMessage({ done: true, primes: count });\n    };\n  `;\n\n  const blob = new Blob([workerCode], { type: 'application/javascript' });\n  const workerURL = URL.createObjectURL(blob);\n\n  startBtn.addEventListener('click', () => {\n    logEl.textContent = '';\n    log('Main thread: Starting heavy computation in worker thread...');\n    startBtn.disabled = true;\n\n    const worker = new Worker(workerURL);\n\n    // Listen for messages from the worker thread\n    worker.onmessage = function (e) {\n      const data = e.data;\n      if (data.progress !== undefined) {\n        log(`Worker thread: Progress ${data.progress}%`);\n      }\n      if (data.done) {\n        log(`Worker thread: Computation done! Number of primes found: ${data.primes}`);\n        log('Main thread: Worker thread finished computation.');\n        startBtn.disabled = false;\n        worker.terminate();\n      }\n    };\n\n    // Send a large number to worker for computation\n    const maxNumber = 1_000_000;\n    worker.postMessage(maxNumber);\n\n    // Demonstrate main thread continues working\n    let dots = 0;\n    const intervalId = setInterval(() => {\n      log(`Main thread: UI remains responsive${'.'.repeat(dots)}`);\n      dots = (dots + 1) % 5;\n      if (startBtn.disabled === false) {\n        clearInterval(intervalId);\n        log('Main thread: UI ready for next task.');\n      }\n    }, 1000);\n  });\n</script>\n</body>\n</html>"
