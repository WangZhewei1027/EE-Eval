    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Amortized Analysis Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #output { white-space: pre; }\n        button { margin: 10px 0; }\n    </style>\n</head>\n<body>\n\n    <h1>Amortized Analysis Demonstration</h1>\n    <p>This demonstration illustrates the concept of amortized analysis using a dynamic array that grows when needed.</p>\n\n    <button id=\"add\">Add Element</button>\n    <button id=\"reset\">Reset</button>\n    \n    <h2>Dynamic Array Operations</h2>\n    <div id=\"output\"></div>\n\n    <script>\n        class DynamicArray {\n            constructor() {\n                this.array = new Array(2); // Start with an initial capacity\n                this.size = 0;\n                this.operations = 0;\n            }\n\n            add(element) {\n                if (this.size >= this.array.length) {\n                    // Need to resize array\n                    this.resize();\n                }\n                this.array[this.size] = element;\n                this.size++;\n                this.operations++;\n                this.report();\n            }\n\n            resize() {\n                this.operations++; // Account for the resizing operation\n                const newArray = new Array(this.array.length * 2);\n                for (let i = 0; i < this.size; i++) {\n                    newArray[i] = this.array[i];\n                }\n                this.array = newArray;\n            }\n\n            report() {\n                const output = `Total Array Size: ${this.array.length}, Elements: ${this.size}, Operations: ${this.operations}\\n`;\n                document.getElementById('output').textContent += output;\n            }\n        }\n\n        const dynamicArray = new DynamicArray();\n\n        document.getElementById('add').addEventListener('click', () => {\n            const element = Math.floor(Math.random() * 100);\n            dynamicArray.add(element);\n        });\n\n        document.getElementById('reset').addEventListener('click', () => {\n            location.reload();\n        });\n\n    </script>\n</body>\n</html>"
