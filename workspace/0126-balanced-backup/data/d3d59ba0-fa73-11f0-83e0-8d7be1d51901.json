  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<title>B+ Tree Interactive Demo</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<style>\n  body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, Arial; margin: 12px; background: #f7f8fa; color: #112;}\n  h1 { margin: 6px 0 10px; font-size: 20px; }\n  .controls { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-bottom:12px; }\n  .controls > * { background: white; padding:8px; border-radius:8px; box-shadow: 0 1px 3px rgba(16,24,40,0.06); }\n  label { font-size:13px; color:#333; margin-right:8px; }\n  input[type=\"number\"], input[type=\"text\"] { width:120px; padding:6px 8px; border-radius:6px; border:1px solid #ddd; }\n  button { padding:8px 10px; border-radius:8px; border:1px solid #cfd8e3; background:#fff; cursor:pointer; }\n  button:hover { box-shadow: 0 2px 6px rgba(0,0,0,0.06); }\n  #canvasWrap { border-radius:10px; overflow:auto; background:linear-gradient(180deg,#fff,#fbfdff); padding:14px; box-shadow: 0 2px 8px rgba(16,24,40,0.06); min-height:200px; }\n  svg { width:100%; height:520px; display:block; }\n  .legend { margin-top:8px; font-size:13px; color:#444; }\n  .small { font-size:12px; color:#666; }\n  .keyBox { fill: #fff; stroke: #3b82f6; stroke-width:1.5; }\n  .leafBox { stroke: #10b981; }\n  .internalBox { stroke: #3b82f6; }\n  .keyText { font-size:12px; fill: #083344; text-anchor:middle; dominant-baseline:central; }\n  .nodeLabel { font-size:11px; fill:#333; }\n  .link { stroke:#9aaed5; stroke-width:1.2; fill:none; }\n  .leafLink { stroke:#10b981; stroke-width:1.6; marker-end:url(#arrow); opacity:0.9; }\n  .highlight { stroke:#ff8a00 !important; stroke-width:3 !important; filter: drop-shadow(0 3px 6px rgba(255,138,0,0.18)); }\n  .ghost { opacity:0.35; }\n  .info { margin-top:10px; padding:10px; background:white; border-radius:10px; font-size:13px; color:#222; box-shadow: 0 1px 3px rgba(16,24,40,0.04); }\n  .footer { margin-top:10px; font-size:12px; color:#5b6b7c; }\n  .smallBtn { font-size:12px; padding:6px 8px; }\n  input[type=\"range\"] { vertical-align:middle; }\n</style>\n</head>\n<body>\n<h1>B+ Tree Interactive Demo</h1>\n\n<div class=\"controls\">\n  <div>\n    <label>Order (max children per internal node):</label>\n    <input id=\"order\" type=\"range\" min=\"3\" max=\"8\" value=\"4\"/>\n    <span id=\"orderVal\" class=\"small\">4</span>\n  </div>\n\n  <div>\n    <label>Insert key:</label>\n    <input id=\"keyInput\" type=\"number\" placeholder=\"e.g. 42\"/>\n    <button id=\"insBtn\">Insert</button>\n  </div>\n\n  <div>\n    <label>Search key:</label>\n    <input id=\"searchInput\" type=\"number\" placeholder=\"e.g. 42\"/>\n    <button id=\"searchBtn\">Search</button>\n  </div>\n\n  <div>\n    <label>Delete key:</label>\n    <input id=\"delInput\" type=\"number\" placeholder=\"e.g. 42\"/>\n    <button id=\"delBtn\">Delete</button>\n  </div>\n\n  <div>\n    <button id=\"randBtn\" class=\"smallBtn\">Insert 8 random</button>\n    <button id=\"bulkBtn\" class=\"smallBtn\">Insert sequence</button>\n    <button id=\"clearBtn\" class=\"smallBtn\">Clear</button>\n  </div>\n\n  <div>\n    <label>Animate:</label>\n    <input id=\"animate\" type=\"checkbox\" checked/>\n  </div>\n</div>\n\n<div id=\"canvasWrap\">\n  <svg id=\"svg\"></svg>\n</div>\n\n<div class=\"info\" id=\"info\">\n  Click Insert to add integer keys. Search highlights path to leaf. Delete removes from leaf and rebalances.\n  Change Order to see different capacities (order = max children per internal node).\n</div>\n\n<div class=\"footer\">\n  B+ Tree simplified demonstration. Leaves store keys; internal nodes store separators. Leaf nodes are linked.\n</div>\n\n<script>\n(() => {\n  // B+ Tree implementation and visualization\n  const svg = document.getElementById('svg');\n  const orderInput = document.getElementById('order');\n  const orderVal = document.getElementById('orderVal');\n  const keyInput = document.getElementById('keyInput');\n  const insBtn = document.getElementById('insBtn');\n  const searchInput = document.getElementById('searchInput');\n  const searchBtn = document.getElementById('searchBtn');\n  const delInput = document.getElementById('delInput');\n  const delBtn = document.getElementById('delBtn');\n  const randBtn = document.getElementById('randBtn');\n  const bulkBtn = document.getElementById('bulkBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const animateCheckbox = document.getElementById('animate');\n  orderVal.textContent = orderInput.value;\n\n  // Node class\n  class Node {\n    constructor(isLeaf=false) {\n      this.isLeaf = isLeaf;\n      this.keys = [];       // for leaves: keys; for internal: separator keys\n      this.children = [];   // for internal: child pointers; for leaf: unused\n      this.parent = null;\n      this.next = null;     // for leaves: linked list next\n      this.id = Node.nextId++;\n    }\n  }\n  Node.nextId = 1;\n\n  let root = new Node(true);\n  let order = parseInt(orderInput.value); // max children per internal node\n  let leafCapacity = order - 1;\n\n  function resetTree() {\n    Node.nextId = 1;\n    root = new Node(true);\n    leafCapacity = order - 1;\n    render();\n  }\n\n  // Utility: find leaf to insert/search\n  function findLeaf(key) {\n    let node = root;\n    const path = [];\n    while (!node.isLeaf) {\n      path.push(node);\n      // choose child index\n      let i = 0;\n      while (i < node.keys.length && key >= node.keys[i]) i++;\n      node = node.children[i];\n    }\n    path.push(node);\n    return {leaf: node, path};\n  }\n\n  function insert(key) {\n    if (key === null || key === undefined || isNaN(key)) return;\n    const {leaf, path} = findLeaf(key);\n    // insert in sorted order into leaf.keys\n    let idx = 0;\n    while (idx < leaf.keys.length && leaf.keys[idx] < key) idx++;\n    leaf.keys.splice(idx, 0, key);\n    animatePath(path, 'insert').then(() => {\n      if (leaf.keys.length > leafCapacity) {\n        splitLeaf(leaf);\n      }\n      render();\n    });\n  }\n\n  function splitLeaf(leaf) {\n    const total = leaf.keys.length;\n    const split = Math.ceil(total / 2);\n    const rightKeys = leaf.keys.splice(split);\n    const newLeaf = new Node(true);\n    newLeaf.keys = rightKeys;\n    newLeaf.next = leaf.next;\n    leaf.next = newLeaf;\n    newLeaf.parent = leaf.parent;\n\n    const promoteKey = newLeaf.keys[0];\n    if (!leaf.parent) {\n      // create new root\n      const newRoot = new Node(false);\n      newRoot.keys = [promoteKey];\n      newRoot.children = [leaf, newLeaf];\n      leaf.parent = newRoot;\n      newLeaf.parent = newRoot;\n      root = newRoot;\n      return;\n    } else {\n      insertIntoParent(leaf.parent, promoteKey, newLeaf);\n    }\n  }\n\n  function insertIntoParent(parent, key, rightNode) {\n    // insert key into parent's keys and rightNode into children at appropriate position\n    let idx = 0;\n    while (idx < parent.keys.length && key >= parent.keys[idx]) idx++;\n    parent.keys.splice(idx, 0, key);\n    parent.children.splice(idx+1, 0, rightNode);\n    rightNode.parent = parent;\n\n    if (parent.children.length > order) {\n      splitInternal(parent);\n    }\n  }\n\n  function splitInternal(node) {\n    const totalChildren = node.children.length;\n    const splitIndex = Math.ceil(totalChildren / 2); // left children count\n    const rightChildren = node.children.splice(splitIndex);\n    const rightKeys = node.keys.splice(splitIndex - 1);\n    // note: node.keys now left keys\n    const promoteKey = rightKeys.shift(); // first key in rightKeys was the separator to promote\n    const rightNode = new Node(false);\n    rightNode.children = rightChildren;\n    rightNode.keys = rightKeys;\n    for (let c of rightChildren) c.parent = rightNode;\n\n    // attach rightNode to parent\n    if (!node.parent) {\n      const newRoot = new Node(false);\n      newRoot.keys = [promoteKey];\n      newRoot.children = [node, rightNode];\n      node.parent = newRoot;\n      rightNode.parent = newRoot;\n      root = newRoot;\n    } else {\n      insertIntoParent(node.parent, promoteKey, rightNode);\n    }\n  }\n\n  function search(key) {\n    if (key === null || key === undefined || isNaN(key)) return null;\n    const {leaf, path} = findLeaf(key);\n    const found = leaf.keys.includes(key);\n    animatePath(path, found ? 'found' : 'search').then(() => {\n      render(found ? key : null, path);\n    });\n    return {found, leaf, path};\n  }\n\n  function deleteKey(key) {\n    if (key === null || key === undefined || isNaN(key)) return;\n    const {leaf, path} = findLeaf(key);\n    const idx = leaf.keys.indexOf(key);\n    if (idx === -1) {\n      animatePath(path, 'notfound').then(() => render());\n      return false;\n    }\n    leaf.keys.splice(idx, 1);\n    animatePath(path, 'delete').then(() => {\n      // handle underflow\n      if (leaf === root) {\n        // special root leaf case: nothing else\n        render();\n        return;\n      }\n      const minLeafKeys = Math.ceil(leafCapacity / 2);\n      if (leaf.keys.length < minLeafKeys) {\n        rebalanceLeaf(leaf);\n      } else {\n        render();\n      }\n    });\n    return true;\n  }\n\n  function rebalanceLeaf(leaf) {\n    const parent = leaf.parent;\n    const idx = parent.children.indexOf(leaf);\n    // try borrow left\n    const leftSibling = idx > 0 ? parent.children[idx - 1] : null;\n    const rightSibling = (idx < parent.children.length - 1) ? parent.children[idx + 1] : null;\n\n    const minLeafKeys = Math.ceil(leafCapacity / 2);\n\n    if (leftSibling && leftSibling.keys.length > minLeafKeys) {\n      // move last of leftSibling to front of leaf\n      const moved = leftSibling.keys.pop();\n      leaf.keys.unshift(moved);\n      parent.keys[idx -1] = leaf.keys[0]; // update separator\n      render();\n      return;\n    }\n    if (rightSibling && rightSibling.keys.length > minLeafKeys) {\n      // move first of rightSibling to end of leaf\n      const moved = rightSibling.keys.shift();\n      leaf.keys.push(moved);\n      parent.keys[idx] = rightSibling.keys[0];\n      render();\n      return;\n    }\n    // otherwise merge\n    if (leftSibling) {\n      // merge leaf into leftSibling\n      leftSibling.keys = leftSibling.keys.concat(leaf.keys);\n      leftSibling.next = leaf.next;\n      parent.children.splice(idx,1);\n      parent.keys.splice(idx-1,1);\n      if (parent === root && parent.children.length === 1) {\n        // shrink root\n        root = parent.children[0];\n        root.parent = null;\n        render();\n        return;\n      }\n      if (parent.children.length < Math.ceil(order/2)) {\n        rebalanceInternal(parent);\n        return;\n      }\n      render();\n      return;\n    } else if (rightSibling) {\n      // merge rightSibling into leaf\n      leaf.keys = leaf.keys.concat(rightSibling.keys);\n      leaf.next = rightSibling.next;\n      parent.children.splice(idx+1,1);\n      parent.keys.splice(idx,1);\n      if (parent === root && parent.children.length === 1) {\n        root = parent.children[0];\n        root.parent = null;\n        render();\n        return;\n      }\n      if (parent.children.length < Math.ceil(order/2)) {\n        rebalanceInternal(parent);\n        return;\n      }\n      render();\n      return;\n    }\n    // fallback\n    render();\n  }\n\n  function rebalanceInternal(node) {\n    if (node === root) {\n      if (node.children.length === 1 && !node.isLeaf) {\n        root = node.children[0];\n        root.parent = null;\n      }\n      render();\n      return;\n    }\n    const parent = node.parent;\n    const idx = parent.children.indexOf(node);\n    const left = idx > 0 ? parent.children[idx - 1] : null;\n    const right = (idx < parent.children.length - 1) ? parent.children[idx + 1] : null;\n    const minChildren = Math.ceil(order/2);\n\n    if (left && left.children.length > minChildren) {\n      // borrow from left\n      const borrowedChild = left.children.pop();\n      const borrowedKey = parent.keys[idx - 1];\n      const leftKey = left.keys.pop();\n      // move separator down and adjust keys\n      node.children.unshift(borrowedChild);\n      borrowedChild.parent = node;\n      parent.keys[idx - 1] = leftKey;\n      node.keys.unshift(borrowedKey);\n      render();\n      return;\n    }\n    if (right && right.children.length > minChildren) {\n      // borrow from right\n      const borrowedChild = right.children.shift();\n      const borrowedKey = parent.keys[idx];\n      const rightKey = right.keys.shift();\n      node.children.push(borrowedChild);\n      borrowedChild.parent = node;\n      node.keys.push(borrowedKey);\n      parent.keys[idx] = rightKey;\n      render();\n      return;\n    }\n    // merge\n    if (left) {\n      // merge node into left\n      const sepKey = parent.keys[idx - 1];\n      left.keys.push(sepKey, ...node.keys);\n      left.children = left.children.concat(node.children);\n      for (let c of node.children) c.parent = left;\n      parent.children.splice(idx,1);\n      parent.keys.splice(idx - 1,1);\n      if (parent === root && parent.children.length === 1) {\n        root = parent.children[0];\n        root.parent = null;\n      } else if (parent.children.length < Math.ceil(order/2)) {\n        rebalanceInternal(parent);\n        return;\n      }\n      render();\n      return;\n    } else if (right) {\n      // merge right into node\n      const sepKey = parent.keys[idx];\n      node.keys.push(sepKey, ...right.keys);\n      node.children = node.children.concat(right.children);\n      for (let c of right.children) c.parent = node;\n      parent.children.splice(idx + 1,1);\n      parent.keys.splice(idx,1);\n      if (parent === root && parent.children.length === 1) {\n        root = parent.children[0];\n        root.parent = null;\n      } else if (parent.children.length < Math.ceil(order/2)) {\n        rebalanceInternal(parent);\n        return;\n      }\n      render();\n      return;\n    }\n  }\n\n  // Visualization\n  function render(highlightKey=null, highlightPath=null) {\n    svg.innerHTML = '';\n    const ns = \"http://www.w3.org/2000/svg\";\n    const defs = document.createElementNS(ns,'defs');\n    defs.innerHTML = `\n      <marker id=\"arrow\" markerWidth=\"10\" markerHeight=\"10\" refX=\"10\" refY=\"3\" orient=\"auto\" markerUnits=\"strokeWidth\">\n        <path d=\"M0,0 L6,3 L0,6 L2,3 z\" fill=\"#10b981\"></path>\n      </marker>\n    `;\n    svg.appendChild(defs);\n\n    // Compute layout: recursive assign x positions based on leaves\n    const leaves = [];\n    function collectLeaves(node) {\n      if (node.isLeaf) {\n        leaves.push(node);\n      } else {\n        node.children.forEach(collectLeaves);\n      }\n    }\n    collectLeaves(root);\n\n    // assign x for leaves evenly\n    const margin = 20;\n    const nodeWidthBase = 24; // per key\n    const gapX = 16;\n    const levels = [];\n    function computeDepths(node, depth=0) {\n      if (!levels[depth]) levels[depth] = [];\n      levels[depth].push(node);\n      if (!node.isLeaf) {\n        node.children.forEach(c => computeDepths(c, depth+1));\n      }\n    }\n    computeDepths(root);\n\n    // Determine x positions: each leaf has an x based on its index\n    const leafCount = leaves.length || 1;\n    const leafSpacing = 120;\n    const startX = margin;\n    const xForLeaf = new Map();\n    leaves.forEach((leaf,i) => {\n      xForLeaf.set(leaf, startX + i * leafSpacing);\n    });\n\n    // set node positions: internal nodes x is center of its children\n    const nodePos = new Map();\n    function setPos(node, depth=0) {\n      if (node.isLeaf) {\n        const x = xForLeaf.get(node);\n        const y = 40 + (levels.length - 1) * 100;\n        nodePos.set(node, {x,y});\n      } else {\n        node.children.forEach(c => setPos(c));\n        const childPositions = node.children.map(c => nodePos.get(c).x);\n        const x = childPositions.reduce((a,b)=>a+b,0) / childPositions.length;\n        const y = 40 + (getDepth(node) - 0) * 100;\n        nodePos.set(node, {x,y});\n      }\n    }\n    function getDepth(node) {\n      // depth from root (root depth 0)\n      let depth = 0;\n      let cur = node;\n      while (cur && cur.parent) {\n        depth++;\n        cur = cur.parent;\n      }\n      return depth;\n    }\n    setPos(root);\n\n    // Draw links parent->child\n    function drawLinks(node) {\n      if (!node.isLeaf) {\n        const p = nodePos.get(node);\n        node.children.forEach(child => {\n          const c = nodePos.get(child);\n          const line = document.createElementNS(ns,'path');\n          line.setAttribute('d', `M${p.x},${p.y+28} L${c.x},${c.y-28}`);\n          line.setAttribute('class','link');\n          svg.appendChild(line);\n          drawLinks(child);\n        });\n      }\n    }\n    drawLinks(root);\n\n    // Draw nodes\n    function drawNode(node) {\n      const pos = nodePos.get(node);\n      const keyCount = Math.max(node.keys.length, 1);\n      const keyWidth = nodeWidthBase;\n      const width = Math.max(40, keyCount * keyWidth + 12);\n      const height = 36;\n      const x = pos.x - width/2;\n      const y = pos.y - height/2;\n      // outer rect\n      const rect = document.createElementNS(ns,'rect');\n      rect.setAttribute('x', x);\n      rect.setAttribute('y', y);\n      rect.setAttribute('rx', 8);\n      rect.setAttribute('ry', 8);\n      rect.setAttribute('width', width);\n      rect.setAttribute('height', height);\n      rect.setAttribute('class', 'keyBox ' + (node.isLeaf ? 'leafBox' : 'internalBox'));\n      svg.appendChild(rect);\n\n      // Draw keys boxes inside\n      const cellW = width / Math.max(1,node.keys.length || 1);\n      for (let i=0;i<Math.max(1,node.keys.length);i++) {\n        const kx = x + i*cellW;\n        const ky = y;\n        const cell = document.createElementNS(ns,'rect');\n        cell.setAttribute('x', kx);\n        cell.setAttribute('y', ky);\n        cell.setAttribute('width', cellW);\n        cell.setAttribute('height', height);\n        cell.setAttribute('fill','none');\n        cell.setAttribute('stroke','none');\n        svg.appendChild(cell);\n      }\n      // text for keys\n      if (node.keys.length === 0) {\n        const t = document.createElementNS(ns,'text');\n        t.setAttribute('x', pos.x);\n        t.setAttribute('y', pos.y);\n        t.setAttribute('class','nodeLabel');\n        t.textContent = '(empty)';\n        svg.appendChild(t);\n      } else {\n        for (let i=0;i<node.keys.length;i++) {\n          const kx = pos.x - width/2 + (i + 0.5) * cellW;\n          const ky = pos.y;\n          const t = document.createElementNS(ns,'text');\n          t.setAttribute('x', kx);\n          t.setAttribute('y', ky);\n          t.setAttribute('class','keyText');\n          t.textContent = node.keys[i];\n          svg.appendChild(t);\n        }\n      }\n      // node type label\n      const lab = document.createElementNS(ns,'text');\n      lab.setAttribute('x', x + 6);\n      lab.setAttribute('y', y - 6);\n      lab.setAttribute('class','small nodeLabel');\n      lab.textContent = node.isLeaf ? `Leaf #${node.id}` : `Node #${node.id}`;\n      svg.appendChild(lab);\n\n      // leaf pointer indicator\n      if (node.isLeaf && node.next) {\n        const sx = x + width + 6;\n        const sy = pos.y;\n        const nx = nodePos.get(node.next)?.x ?? (sx + 60);\n        const ny = nodePos.get(node.next)?.y ?? sy;\n        const pl = document.createElementNS(ns,'path');\n        pl.setAttribute('d', `M${x+width},${sy} C${x+width+20},${sy} ${nx-20},${ny} ${nx},${ny}`);\n        pl.setAttribute('class','leafLink');\n        svg.appendChild(pl);\n      }\n\n      // highlight if key present matches highlightKey\n      if (highlightKey !== null && node.keys.includes(highlightKey)) {\n        rect.classList.add('highlight');\n      }\n      // path highlight: highlight node if in path\n      if (highlightPath && highlightPath.includes(node)) {\n        rect.classList.add('highlight');\n      }\n\n      // click to show node details and allow small insert from node keys\n      rect.addEventListener('click', ()=> {\n        alert(`${node.isLeaf? 'Leaf' : 'Internal'} node #${node.id}\\nKeys: [${node.keys.join(', ')}]\\n` + (node.isLeaf ? `Next leaf id: ${node.next ? node.next.id : 'none'}` : `Children: ${node.children.map(c=>c.id).join(', ')}`));\n      });\n    }\n\n    // draw all nodes by traversing levels top-down\n    // get nodes sorted by depth\n    const nodesToDraw = [];\n    function collect(node) {\n      nodesToDraw.push(node);\n      if (!node.isLeaf) node.children.forEach(collect);\n    }\n    collect(root);\n    nodesToDraw.sort((a,b) => getDepth(a) - getDepth(b));\n    nodesToDraw.forEach(drawNode);\n  }\n\n  // Animation helpers - highlight path sequentially\n  function animatePath(path, typ) {\n    return new Promise(resolve => {\n      if (!animateCheckbox.checked) { resolve(); return; }\n      // path is array of nodes from root to leaf\n      let i = 0;\n      const stepTime = 400;\n      const nodes = path;\n      const interval = setInterval(() => {\n        // re-render highlighting only current node\n        render(null, nodes.slice(0, i+1));\n        i++;\n        if (i >= nodes.length) {\n          clearInterval(interval);\n          setTimeout(()=> resolve(), 220);\n        }\n      }, stepTime);\n    });\n  }\n\n  // UI events\n  orderInput.addEventListener('input', () => {\n    order = parseInt(orderInput.value);\n    orderVal.textContent = order;\n  });\n\n  orderInput.addEventListener('change', () => {\n    if (!confirm('Changing order will reset the tree. Continue?')) {\n      orderInput.value = order;\n      orderVal.textContent = order;\n      return;\n    }\n    order = parseInt(orderInput.value);\n    orderVal.textContent = order;\n    resetTree();\n  });\n\n  insBtn.addEventListener('click', () => {\n    const v = parseInt(keyInput.value);\n    if (isNaN(v)) { alert('Enter a number to insert'); return; }\n    insert(v);\n    keyInput.value = '';\n  });\n\n  searchBtn.addEventListener('click', () => {\n    const v = parseInt(searchInput.value);\n    if (isNaN(v)) { alert('Enter a number to search'); return; }\n    search(v);\n  });\n\n  delBtn.addEventListener('click', () => {\n    const v = parseInt(delInput.value);\n    if (isNaN(v)) { alert('Enter a number to delete'); return; }\n    deleteKey(v);\n  });\n\n  randBtn.addEventListener('click', () => {\n    // insert 8 random integers\n    const rand = [];\n    for (let i=0;i<8;i++) { rand.push(Math.floor(Math.random()*100)); }\n    const doInsert = (arr, idx=0) => {\n      if (idx >= arr.length) return;\n      insert(arr[idx]);\n      setTimeout(()=> doInsert(arr, idx+1), 180);\n    };\n    doInsert(rand);\n  });\n\n  bulkBtn.addEventListener('click', () => {\n    // Insert a sequence 1..12\n    const seq = [10, 20, 5, 6, 12, 30, 7, 17, 25, 1, 2, 3];\n    const doInsert = (arr, idx=0) => {\n      if (idx >= arr.length) return;\n      insert(arr[idx]);\n      setTimeout(()=> doInsert(arr, idx+1), 160);\n    };\n    doInsert(seq);\n  });\n\n  clearBtn.addEventListener('click', () => {\n    if (!confirm('Clear the tree?')) return;\n    resetTree();\n  });\n\n  // initialize\n  resetTree();\n\n  // initial sample\n  [10, 20, 5, 6, 12].forEach((v, i) => setTimeout(()=> insert(v), i*120+50));\n})();\n</script>\n</body>\n</html>"
  },
