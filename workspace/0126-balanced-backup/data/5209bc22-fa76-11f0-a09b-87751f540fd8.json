    "content": "<html>\n<head>\n    <title>Branch and Bound</title>\n    <style>\n        #graph {\n            border: 1px solid black;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"graph\"></div>\n    <script>\n        let graph = document.getElementById('graph');\n        let nodes = [];\n        let edges = [];\n\n        function addNode(node) {\n            nodes.push(node);\n            graph.innerHTML += `<div class=\"node\">${node}</div>`;\n        }\n\n        function addEdge(edge) {\n            edges.push(edge);\n        }\n\n        function isLeaf(node) {\n            return nodes.indexOf(node) === nodes.length - 1;\n        }\n\n        function branch(node, parent) {\n            let left = nodes.filter(n => n !== parent && isLeaf(n) && n !== node);\n            let right = nodes.filter(n => n !== parent && !isLeaf(n) && n !== node);\n\n            if (left.length === 0 && right.length === 0) {\n                return null;\n            }\n\n            if (left.length > 0) {\n                let leftParent = left[0];\n                let leftResult = branch(left[0], leftParent);\n                if (leftResult !== null) {\n                    return leftResult;\n                }\n            }\n\n            if (right.length > 0) {\n                let rightParent = right[0];\n                let rightResult = branch(right[0], rightParent);\n                if (rightResult !== null) {\n                    return rightResult;\n                }\n            }\n\n            return null;\n        }\n\n        function bound(node) {\n            let parent = nodes.indexOf(node);\n            let left = nodes.filter(n => n !== parent && isLeaf(n) && n !== node);\n            let right = nodes.filter(n => n !== parent && !isLeaf(n) && n !== node);\n\n            if (left.length === 0 && right.length === 0) {\n                return null;\n            }\n\n            if (left.length > 0) {\n                let leftParent = left[0];\n                let leftResult = bound(left[0]);\n                if (leftResult !== null) {\n                    return leftResult;\n                }\n            }\n\n            if (right.length > 0) {\n                let rightParent = right[0];\n                let rightResult = bound(right[0]);\n                if (rightResult !== null) {\n                    return rightResult;\n                }\n            }\n\n            return null;\n        }\n\n        addNode('A');\n        addNode('B');\n        addNode('C');\n        addNode('D');\n        addNode('E');\n\n        addEdge('A', 'B');\n        addEdge('A', 'C');\n        addEdge('B', 'D');\n        addEdge('C', 'E');\n\n        let result = branch('A', null);\n        console.log(result);\n        console.log(bound('A'));\n    </script>\n</body>\n</html>"
