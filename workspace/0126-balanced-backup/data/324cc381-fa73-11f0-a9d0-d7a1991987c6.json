    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Multiset Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #multiset {\n            margin-top: 20px;\n        }\n        .element {\n            margin: 5px 0;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Multiset Demonstration</h1>\n<p>A multiset is a generalized concept of a set that allows for multiple occurrences of the same element.</p>\n\n<h2>Operations:</h2>\n<button onclick=\"addElement()\">Add Element</button>\n<input type=\"text\" id=\"elementInput\" placeholder=\"Enter element\" />\n<button onclick=\"removeElement()\">Remove Element</button>\n\n<div id=\"multiset\"></div>\n\n<script>\n    class Multiset {\n        constructor() {\n            this.elements = {};\n        }\n\n        add(element) {\n            if (this.elements[element]) {\n                this.elements[element]++;\n            } else {\n                this.elements[element] = 1;\n            }\n            this.display();\n        }\n\n        remove(element) {\n            if (this.elements[element]) {\n                this.elements[element]--;\n                if (this.elements[element] === 0) {\n                    delete this.elements[element];\n                }\n            }\n            this.display();\n        }\n\n        display() {\n            const multisetDiv = document.getElementById('multiset');\n            multisetDiv.innerHTML = '';\n            for (const [element, count] of Object.entries(this.elements)) {\n                const elementDiv = document.createElement('div');\n                elementDiv.className = 'element';\n                elementDiv.textContent = `${element}: ${count}`;\n                multisetDiv.appendChild(elementDiv);\n            }\n        }\n    }\n\n    const myMultiset = new Multiset();\n\n    function addElement() {\n        const input = document.getElementById('elementInput');\n        const element = input.value.trim();\n        if (element) {\n            myMultiset.add(element);\n            input.value = '';\n        }\n    }\n\n    function removeElement() {\n        const input = document.getElementById('elementInput');\n        const element = input.value.trim();\n        if (element) {\n            myMultiset.remove(element);\n            input.value = '';\n        }\n    }\n</script>\n\n</body>\n</html>"
