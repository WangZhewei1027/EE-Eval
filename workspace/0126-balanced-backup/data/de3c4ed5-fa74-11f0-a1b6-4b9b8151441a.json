    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Branch and Bound Algorithm</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        h1 {\n            color: #2c3e50;\n            text-align: center;\n        }\n        .container {\n            background-color: #f9f9f9;\n            border-radius: 5px;\n            padding: 20px;\n            margin-bottom: 20px;\n        }\n        .matrix {\n            margin: 20px 0;\n            border-collapse: collapse;\n        }\n        .matrix th, .matrix td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: center;\n        }\n        .matrix th {\n            background-color: #f2f2f2;\n        }\n        button {\n            background-color: #3498db;\n            color: white;\n            border: none;\n            padding: 10px 15px;\n            border-radius: 4px;\n            cursor: pointer;\n            font-size: 16px;\n        }\n        button:hover {\n            background-color: #2980b9;\n        }\n        .result {\n            margin-top: 20px;\n            padding: 15px;\n            background-color: #e8f4fc;\n            border-radius: 4px;\n            display: none;\n        }\n        .node {\n            margin: 10px 0;\n            padding: 10px;\n            background-color: #eaf7ea;\n            border-radius: 4px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Branch and Bound Algorithm</h1>\n    \n    <div class=\"container\">\n        <h2>Traveling Salesman Problem</h2>\n        <p>The Branch and Bound algorithm is demonstrated here by solving a Traveling Salesman Problem (TSP) instance.</p>\n        \n        <table class=\"matrix\">\n            <tr>\n                <th></th>\n                <th>A</th>\n                <th>B</th>\n                <th>C</th>\n                <th>D</th>\n            </tr>\n            <tr>\n                <th>A</th>\n                <td>0</td>\n                <td>10</td>\n                <td>15</td>\n                <td>20</td>\n            </tr>\n            <tr>\n                <th>B</th>\n                <td>10</td>\n                <td>0</td>\n                <td>35</td>\n                <td>25</td>\n            </tr>\n            <tr>\n                <th>C</th>\n                <td>15</td>\n                <td>35</td>\n                <td>0</td>\n                <td>30</td>\n            </tr>\n            <tr>\n                <th>D</th>\n                <td>20</td>\n                <td>25</td>\n                <td>30</td>\n                <td>0</td>\n            </tr>\n        </table>\n        \n        <button id=\"solveBtn\">Solve with Branch and Bound</button>\n        \n        <div id=\"result\" class=\"result\">\n            <h3>Solution:</h3>\n            <div id=\"solution\"></div>\n            <h3>Algorithm Steps:</h3>\n            <div id=\"steps\"></div>\n        </div>\n    </div>\n\n    <script>\n        document.getElementById('solveBtn').addEventListener('click', solveTSP);\n\n        function solveTSP() {\n            const adjacencyMatrix = [\n                [0, 10, 15, 20],\n                [10, 0, 35, 25],\n                [15, 35, 0, 30],\n                [20, 25, 30, 0]\n            ];\n            \n            const n = adjacencyMatrix.length;\n            const visited = new Array(n).fill(false);\n            const finalPath = [];\n            let finalRes = Infinity;\n            \n            // Start with node 0 (A)\n            visited[0] = true;\n            finalPath.push(0);\n            \n            const stepsContainer = document.getElementById('steps');\n            stepsContainer.innerHTML = '';\n            \n            // Recursive function to find the shortest path\n            function branchAndBound(currentBound, currentWeight, level, currentPath) {\n                // Base case: when we reach the last node\n                if (level === n) {\n                    // Check if there's an edge from last to first node\n                    if (adjacencyMatrix[currentPath[level-1]][currentPath[0]] !== 0) {\n                        // Total weight of solution\n                        const currRes = currentWeight + adjacencyMatrix[currentPath[level-1]][currentPath[0]];\n                        \n                        // Update final path and result if better\n                        if (currRes < finalRes) {\n                            for (let i = 0; i < currentPath.length; i++) {\n                                finalPath[i] = currentPath[i];\n                            }\n                            finalPath[n] = currentPath[0];\n                            finalRes = currRes;\n                            \n                            // Display this step\n                            const stepDiv = document.createElement('div');\n                            stepDiv.className = 'node';\n                            stepDiv.innerHTML = `\n                                <strong>New Best Path Found!</strong><br>\n                                Path: ${getPathString(finalPath)}<br>\n                                Total Cost: ${finalRes}\n                            `;\n                            stepsContainer.appendChild(stepDiv);\n                        }\n                    }\n                    return;\n                }\n                \n                // Explore all nodes not visited yet\n                for (let i = 0; i < n; i++) {\n                    if (adjacencyMatrix[currentPath[level-1]][i] !== 0 && !visited[i]) {\n                        const tempBound = currentBound;\n                        let currentWeightTemp = currentWeight + adjacencyMatrix[currentPath[level-1]][i];\n                        \n                        // Calculate lower bound for next level\n                        let currentBoundTemp = currentBound;\n                        if (level === 1) {\n                            currentBoundTemp -= ((firstMin(adjacencyMatrix, currentPath[level-1]) + firstMin(adjacencyMatrix, i)) / 2);\n                        } else {\n                            currentBoundTemp -= ((secondMin(adjacencyMatrix, currentPath[level-1]) + firstMin(adjacencyMatrix, i)) / 2);\n                        }\n                        \n                        // If current lower bound + current weight is less than final result, explore further\n                        if (currentBoundTemp + currentWeightTemp < finalRes) {\n                            currentPath[level] = i;\n                            visited[i] = true;\n                            \n                            // Display this branch\n                            const stepDiv = document.createElement('div');\n                            stepDiv.className = 'node';\n                            stepDiv.innerHTML = `\n                                <strong>Branching on Node ${String.fromCharCode(65 + i)}</strong><br>\n                                Current Path: ${getPathString(currentPath.slice(0, level+1))}<br>\n                                Current Cost: ${currentWeightTemp}<br>\n                                Lower Bound: ${currentBoundTemp + currentWeightTemp}\n                            `;\n                            stepsContainer.appendChild(stepDiv);\n                            \n                            // Recursive call\n                            branchAndBound(currentBoundTemp, currentWeightTemp, level + 1, currentPath);\n                        } else {\n                            // Display pruned branch\n                            const stepDiv = document.createElement('div');\n                            stepDiv.className = 'node';\n                            stepDiv.style.backgroundColor = '#fceaea';\n                            stepDiv.innerHTML = `\n                                <strong>Pruned Branch to Node ${String.fromCharCode(65 + i)}</strong><br>\n                                Reason: Lower bound (${currentBoundTemp + currentWeightTemp}) ≥ current best (${finalRes})\n                            `;\n                            stepsContainer.appendChild(stepDiv);\n                        }\n                        \n                        // Reset visited and currentWeight for next iteration\n                        currentWeight -= adjacencyMatrix[currentPath[level-1]][i];\n                        visited.fill(false);\n                        for (let j = 0; j < level; j++) {\n                            visited[currentPath[j]] = true;\n                        }\n                    }\n                }\n            }\n            \n            // Calculate initial bound\n            let initialBound = 0;\n            for (let i = 0; i < n; i++) {\n                initialBound += (firstMin(adjacencyMatrix, i) + secondMin(adjacencyMatrix, i));\n            }\n            initialBound = Math.ceil(initialBound / 2);\n            \n            // Display initial bound\n            const initialDiv = document.createElement('div');\n            initialDiv.className = 'node';\n            initialDiv.innerHTML = `\n                <strong>Starting Branch and Bound</strong><br>\n                Initial Lower Bound: ${initialBound}\n            `;\n            stepsContainer.appendChild(initialDiv);\n            \n            // Start the algorithm\n            branchAndBound(initialBound, 0, 1, [...finalPath]);\n            \n            // Display final result\n            document.getElementById('solution').innerHTML = `\n                <p>Optimal Path: ${getPathString(finalPath)}</p>\n                <p>Minimum Cost: ${finalRes}</p>\n            `;\n            document.getElementById('result').style.display = 'block';\n        }\n        \n        // Utility function to get first minimum edge cost\n        function firstMin(matrix, i) {\n            let min = Infinity;\n            for (let k = 0; k < matrix.length; k++) {\n                if (matrix[i][k] < min && i !== k) {\n                    min = matrix[i][k];\n                }\n            }\n            return min;\n        }\n        \n        // Utility function to get second minimum edge cost\n        function secondMin(matrix, i) {\n            let first = Infinity, second = Infinity;\n            for (let k = 0; k < matrix.length; k++) {\n                if (i === k) continue;\n                \n                if (matrix[i][k] <= first) {\n                    second = first;\n                    first = matrix[i][k];\n                } else if (matrix[i][k] <= second && matrix[i][k] !== first) {\n                    second = matrix[i][k];\n                }\n            }\n            return second;\n        }\n        \n        // Helper function to convert node indices to letters (A, B, C, D)\n        function getPathString(path) {\n            return path.map(node => String.fromCharCode(65 + node)).join(' → ');\n        }\n    </script>\n</body>\n</html>"
