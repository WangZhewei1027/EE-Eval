    "role": "assistant",
    "content": "<html>\n<head>\n  <title>Design Patterns</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n    }\n    .container {\n      width: 80%;\n      margin: 40px auto;\n      text-align: center;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Design Patterns</h1>\n    <p>Design Patterns are reusable solutions to common problems in software design.</p>\n    <h2>Creational Patterns</h2>\n    <p>1. Singleton Pattern</p>\n    <p>2. Factory Pattern</p>\n    <p>3. Abstract Factory Pattern</p>\n    <p>4. Builder Pattern</p>\n    <h2>Structural Patterns</h2>\n    <p>1. Adapter Pattern</p>\n    <p>2. Bridge Pattern</p>\n    <p>3. Composite Pattern</p>\n    <p>4. Decorator Pattern</p>\n    <p>5. Facade Pattern</p>\n    <p>6. Flyweight Pattern</p>\n    <p>7. Proxy Pattern</p>\n    <h2>Behavioral Patterns</h2>\n    <p>1. Observer Pattern</p>\n    <p>2. Strategy Pattern</p>\n    <p>3. Template Method Pattern</p>\n    <p>4. Visitor Pattern</p>\n  </div>\n\n  <script>\n    class Singleton {\n      constructor() {\n        if (Singleton.instance) {\n          return Singleton.instance;\n        }\n        let instance = new Singleton();\n        Singleton.instance = instance;\n        return instance;\n      }\n    }\n\n    class Factory {\n      constructor(type) {\n        this.type = type;\n      }\n    }\n\n    class AbstractFactory {\n      constructor() {\n        this.factories = [];\n      }\n    }\n\n    class ConcreteFactory extends AbstractFactory {\n      constructor() {\n        super();\n        this.factories = [\n          new Factory(\"1\"),\n          new Factory(\"2\")\n        ];\n      }\n    }\n\n    class Builder {\n      constructor() {\n        this.items = [];\n      }\n\n      addItem(item) {\n        this.items.push(item);\n      }\n\n      build() {\n        return this.items;\n      }\n    }\n\n    class Decorator {\n      constructor() {\n        this.decorated = false;\n      }\n\n      addDecorator(item) {\n        this.decorated = true;\n        item.decorate();\n      }\n\n      removeDecorator() {\n        this.decorated = false;\n      }\n    }\n\n    class ConcreteDecorator extends Decorator {\n      constructor() {\n        super();\n        this.item = null;\n      }\n\n      decorate(item) {\n        item.decorate();\n        this.item = item;\n      }\n    }\n\n    class Observer {\n      constructor() {\n        this.observers = [];\n      }\n\n      attach(observer) {\n        this.observers.push(observer);\n      }\n\n      detach(observer) {\n        this.observers = this.observers.filter(observer => observer !== observer);\n      }\n\n      notify(observer) {\n        for (let observer of this.observers) {\n          observer.update();\n        }\n      }\n    }\n\n    class ConcreteObserver extends Observer {\n      update() {\n        console.log(\"Updated\");\n      }\n    }\n\n    class ConcreteStrategy extends Observer {\n      update() {\n        console.log(\"Updated strategy\");\n      }\n    }\n\n    class ConcreteTemplateMethod extends Observer {\n      update() {\n        console.log(\"Updated template method\");\n      }\n    }\n\n    class ConcreteVisitor extends Observer {\n      update() {\n        console.log(\"Updated visitor\");\n      }\n    }\n\n    class ConcreteFlyweight extends Object {\n      constructor() {\n        this.friendly = true;\n      }\n    }\n\n    class ConcreteProxy extends Object {\n      constructor() {\n        this.friendly = true;\n      }\n    }\n\n    function getSingleton() {\n      return new Singleton();\n    }\n\n    function getFactory(type) {\n      return new ConcreteFactory();\n    }\n\n    function getConcreteBuilder() {\n      return new ConcreteBuilder();\n    }\n\n    function getConcreteDecorator() {\n      return new ConcreteDecorator();\n    }\n\n    function getConcreteObserver() {\n      return new ConcreteObserver();\n    }\n\n    function getConcreteStrategy() {\n      return new ConcreteStrategy();\n    }\n\n    function getConcreteTemplateMethod() {\n      return new ConcreteTemplateMethod();\n    }\n\n    function getConcreteVisitor() {\n      return new ConcreteVisitor();\n    }\n\n    function getConcreteFlyweight() {\n      return new ConcreteFlyweight();\n    }\n\n    function getConcreteProxy() {\n      return new ConcreteProxy();\n    }\n\n    function main() {\n      let singleton = getSingleton();\n      let factory = getFactory(\"1\");\n      let builder = getConcreteBuilder();\n      let decorator = getConcreteDecorator();\n      let observer = getConcreteObserver();\n      let strategy = getConcreteStrategy();\n      let templateMethod = getConcreteTemplateMethod();\n      let visitor = getConcreteVisitor();\n      let flyweight = getConcreteFlyweight();\n      let proxy = getConcreteProxy();\n\n      console.log(\"Singleton:\", singleton);\n      console.log(\"Factory:\", factory);\n      console.log(\"Builder:\", builder);\n      console.log(\"Decorator:\", decorator);\n      console.log(\"Observer:\", observer);\n      console.log(\"Strategy:\", strategy);\n      console.log(\"Template Method:\", templateMethod);\n      console.log(\"Visitor:\", visitor);\n      console.log(\"Flyweight:\", flyweight);\n      console.log(\"Proxy:\", proxy);\n    }\n\n    main();\n  </script>\n</body>\n</html>"
