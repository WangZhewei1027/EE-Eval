    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Jump Search Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f8f9fa;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 5px;\n  }\n  p {\n    text-align: center;\n    max-width: 700px;\n    margin: 0 auto 20px;\n    color: #555;\n  }\n  #array-container {\n    display: flex;\n    justify-content: center;\n    flex-wrap: wrap;\n    max-width: 720px;\n    margin: 0 auto 20px;\n  }\n  .array-element {\n    width: 40px;\n    height: 40px;\n    border: 2px solid #666;\n    margin: 3px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    font-weight: 600;\n    font-size: 16px;\n    border-radius: 6px;\n    background-color: white;\n    transition: background-color 0.4s ease, border-color 0.4s ease;\n    user-select: none;\n  }\n  .default {\n    background-color: white;\n    border-color: #666;\n    color: #333;\n  }\n  .jumped {\n    background-color: #cce5ff;\n    border-color: #339af0;\n    color: #1c7ed6;\n  }\n  .block {\n    background-color: #ffe066;\n    border-color: #fcc419;\n    color: #a67600;\n  }\n  .current {\n    background-color: #69db7c;\n    border-color: #38b000;\n    color: #1b4332;\n    font-weight: 700;\n  }\n  .found {\n    background-color: #51cf66;\n    border-color: #2f9e44;\n    color: #073b12;\n    font-weight: 700;\n  }\n  #controls {\n    max-width: 720px;\n    margin: 10px auto 20px;\n    text-align: center;\n  }\n  input[type=\"number\"] {\n    width: 80px;\n    padding: 6px 8px;\n    font-size: 16px;\n    border-radius: 4px;\n    border: 1.5px solid #aaa;\n    margin-right: 10px;\n    text-align: center;\n  }\n  button {\n    background-color: #339af0;\n    border: none;\n    color: white;\n    padding: 10px 18px;\n    font-size: 16px;\n    border-radius: 6px;\n    cursor: pointer;\n    transition: background-color 0.3s ease;\n  }\n  button:hover:not(:disabled) {\n    background-color: #1c7ed6;\n  }\n  button:disabled {\n    background-color: #a5d8ff;\n    cursor: default;\n  }\n  #log {\n    max-width: 720px;\n    margin: 0 auto;\n    background-color: #e9ecef;\n    border-radius: 6px;\n    padding: 15px;\n    min-height: 100px;\n    font-size: 14px;\n    white-space: pre-line;\n    color: #212529;\n    overflow-y: auto;\n    max-height: 250px;\n  }\n</style>\n</head>\n<body>\n<h1>Jump Search Visualization</h1>\n<p>\n  Jump Search is an efficient search algorithm for sorted arrays. It works by jumping ahead by fixed steps and then performing a linear search within the identified block.\n</p>\n\n<div id=\"array-container\"></div>\n\n<div id=\"controls\">\n  <label for=\"search-value\">Search Value:</label>\n  <input type=\"number\" id=\"search-value\" placeholder=\"Enter number\" />\n  <button id=\"start-btn\">Start Search</button>\n  <button id=\"reset-btn\" disabled>Reset</button>\n</div>\n\n<div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<script>\n(() => {\n  const arr = [];\n  const ARRAY_SIZE = 30;  \n  const maxVal = 100;\n\n  const arrayContainer = document.getElementById('array-container');\n  const searchInput = document.getElementById('search-value');\n  const startBtn = document.getElementById('start-btn');\n  const resetBtn = document.getElementById('reset-btn');\n  const logContainer = document.getElementById('log');\n\n  let blocks = [];\n  let animationSpeed = 800; // ms per step\n\n  // Initialize and generate sorted array of unique numbers\n  function generateArray() {\n    arr.length = 0;\n    let used = new Set();\n    while (arr.length < ARRAY_SIZE) {\n      let val = Math.floor(Math.random() * maxVal) + 1;\n      if (!used.has(val)) {\n        used.add(val);\n        arr.push(val);\n      }\n    }\n    arr.sort((a,b) => a - b);\n  }\n\n  // Render array elements on the page\n  function renderArray() {\n    arrayContainer.innerHTML = '';\n    for(let i=0; i<arr.length; i++) {\n      const elem = document.createElement('div');\n      elem.classList.add('array-element', 'default');\n      elem.textContent = arr[i];\n      elem.dataset.index = i;\n      arrayContainer.appendChild(elem);\n    }\n  }\n\n  // Reset styles and log\n  function reset() {\n    document.querySelectorAll('.array-element').forEach(el=>{\n      el.className = 'array-element default';\n    });\n    logContainer.textContent = '';\n    searchInput.value = '';\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Sleep Promise helper\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Get element by index\n  function getElement(i) {\n    return arrayContainer.querySelector(`.array-element[data-index=\"${i}\"]`);\n  }\n\n  // Log message with automatic scrolling\n  function log(msg) {\n    logContainer.textContent += msg + '\\n';\n    logContainer.scrollTop = logContainer.scrollHeight;\n  }\n\n  // Jump Search Algorithm with visualization and logging\n  async function jumpSearch(arr, x) {\n    const n = arr.length;\n    const step = Math.floor(Math.sqrt(n));\n\n    log(`Array length: ${n}, Optimal jump step: ${step}`);\n    log(`Searching for value: ${x}`);\n\n    // Mark the jump step blocks\n    // We'll visualize jumps and the block we search linearly.\n    // Clear previous styles\n    document.querySelectorAll('.array-element').forEach(el=>{\n      el.className = 'array-element default';\n    });\n\n    let prev = 0;\n    let current = 0;\n\n    // Jump in blocks\n    log('Starting jump phase:');\n    while(current < n && arr[current] < x) {\n      // Highlight jump step element\n      if(prev > 0) {\n        getElement(prev - 1).className = 'array-element default'; // previous block end reset\n      }\n      getElement(current).className = 'array-element jumped';\n      log(`Jump to index ${current} (value: ${arr[current]})`);\n      await sleep(animationSpeed);\n\n      if(arr[current] >= x) break;\n      prev = current;\n      current += step;\n      if(current > n - 1) current = n - 1;\n    }\n\n    // Highlight block where linear search will happen\n    if(prev > 0) {\n      // Mark block from prev to current\n      for(let i = prev; i <= Math.min(current, n-1); i++){\n        getElement(i).className = 'array-element block';\n      }\n    } else {\n      // If search value smaller or equal first element, block is first step's elements\n      for(let i=0; i <= Math.min(current, n-1); i++) {\n        getElement(i).className = 'array-element block';\n      }\n    }\n    log(`Linear search in block: index ${prev} to ${current}`);\n    await sleep(animationSpeed);\n\n    // Linear search within the block\n    const end = Math.min(current, n - 1);\n    for(let i = prev; i <= end; i++) {\n      getElement(i).className = 'array-element current';\n      log(`Checking index ${i} (value: ${arr[i]})`);\n      await sleep(animationSpeed/1.5);\n\n      if(arr[i] === x) {\n        getElement(i).className = 'array-element found';\n        log(`Value ${x} found at index ${i}! 🎉`);\n        return i;\n      }\n      // revert back to block color if not found\n      if(i !== end) getElement(i).className = 'array-element block';\n    }\n\n    log(`Value ${x} not found in array.`);\n    return -1;\n  }\n\n  // Initialize app\n  function init() {\n    generateArray();\n    renderArray();\n    reset();\n  }\n\n  startBtn.addEventListener('click', async () => {\n    const val = Number(searchInput.value);\n    if(isNaN(val)) {\n      alert('Please enter a valid number to search.');\n      return;\n    }\n    if(val < arr[0] || val > arr[arr.length-1]) {\n      alert(`Value out of array range (${arr[0]} - ${arr[arr.length-1]}).`);\n      return;\n    }\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n    searchInput.disabled = true;\n\n    await jumpSearch(arr, val);\n\n    resetBtn.disabled = false;\n    searchInput.disabled = false;\n  });\n\n  resetBtn.addEventListener('click', () => {\n    init();\n  });\n\n  init();\n\n})();\n</script>\n</body>\n</html>"
