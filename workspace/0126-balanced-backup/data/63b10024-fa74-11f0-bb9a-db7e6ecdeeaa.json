    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Heap Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1em;\n    background: #f5f5f5;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #arrayContainer {\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n    margin: 2em 0;\n    height: 200px;\n  }\n  .bar {\n    margin: 0 2px;\n    background-color: #4a90e2;\n    width: 20px;\n    transition: all 0.3s ease;\n    border-radius: 3px 3px 0 0;\n  }\n  .bar.active {\n    background-color: #e94e77;\n  }\n  .bar.sorted {\n    background-color: #28a745;\n  }\n  #controls {\n    text-align: center;\n  }\n  #controls button, #controls input {\n    font-size: 1em;\n    margin: 0 0.25em;\n    padding: 0.5em 1em;\n  }\n  #log {\n    max-height: 200px;\n    overflow-y: auto;\n    background: #eee;\n    border-radius: 5px;\n    padding: 1em;\n    font-family: monospace;\n    font-size: 0.9em;\n  }\n</style>\n</head>\n<body>\n<h1>Heap Sort Visualization</h1>\n<div id=\"arrayContainer\"></div>\n<div id=\"controls\">\n  <label for=\"arraySize\">Array Size: </label>\n  <input type=\"number\" id=\"arraySize\" min=\"5\" max=\"50\" value=\"20\" />\n  <button id=\"generateBtn\">Generate New Array</button>\n  <button id=\"startBtn\">Start Heap Sort</button>\n</div>\n<h3>Log / Steps</h3>\n<div id=\"log\"></div>\n\n<script>\n(() => {\n  const arrayContainer = document.getElementById('arrayContainer');\n  const generateBtn = document.getElementById('generateBtn');\n  const startBtn = document.getElementById('startBtn');\n  const logContainer = document.getElementById('log');\n  const arraySizeInput = document.getElementById('arraySize');\n\n  let array = [];\n  let bars = [];\n  let heapSize = 0;\n  let sorting = false;\n\n  function log(message) {\n    const el = document.createElement('div');\n    el.textContent = message;\n    logContainer.appendChild(el);\n    logContainer.scrollTop = logContainer.scrollHeight;\n  }\n\n  function generateArray(size) {\n    array = [];\n    for (let i = 0; i < size; i++) {\n      array.push(Math.floor(Math.random() * 150) + 20);\n    }\n    renderArray();\n    logContainer.innerHTML = \"\";\n    log(`Generated new array: [${array.join(', ')}]`);\n  }\n\n  function renderArray(activeIndices = [], sortedIndices = []) {\n    arrayContainer.innerHTML = '';\n    bars = [];\n    const maxVal = Math.max(...array);\n    array.forEach((value, idx) => {\n      const bar = document.createElement('div');\n      bar.classList.add('bar');\n      const heightPercent = (value / maxVal) * 100;\n      bar.style.height = heightPercent + '%';\n      if (activeIndices.includes(idx)) bar.classList.add('active');\n      if (sortedIndices.includes(idx)) bar.classList.add('sorted');\n      bar.title = value;\n      bars.push(bar);\n      arrayContainer.appendChild(bar);\n    });\n  }\n\n  // Swap elements in array and update bars\n  function swap(i, j) {\n    [array[i], array[j]] = [array[j], array[i]];\n  }\n\n  // Heapify subtree rooted with node i, size is heapSize\n  async function heapify(n, i) {\n    let largest = i;\n    let left = 2 * i + 1;\n    let right = 2 * i + 2;\n\n    renderArray([i, left, right].filter(x => x < n));\n    await pause(500);\n\n    if (left < n && array[left] > array[largest]) {\n      largest = left;\n    }\n    if (right < n && array[right] > array[largest]) {\n      largest = right;\n    }\n\n    if (largest !== i) {\n      log(`Swapping elements at indices ${i} (${array[i]}) and ${largest} (${array[largest]})`);\n      swap(i, largest);\n      renderArray([i, largest]);\n      await pause(500);\n      await heapify(n, largest);\n    }\n  }\n\n  // Pause helper\n  function pause(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Build a maxheap\n  async function buildHeap(n) {\n    log(\"Building max heap...\");\n    // Index of last non-leaf node\n    for (let i = Math.floor(n / 2) - 1; i >= 0; i--) {\n      log(`Heapifying subtree rooted at index ${i}`);\n      await heapify(n, i);\n    }\n    log(\"Max heap built.\");\n  }\n\n  async function heapSort() {\n    if (sorting) return;\n    sorting = true;\n    logContainer.innerHTML = '';\n    log(`Starting Heap Sort on array: [${array.join(', ')}]`);\n    let n = array.length;\n\n    await buildHeap(n);\n\n    for (let i = n - 1; i > 0; i--) {\n      log(`Swapping root (${array[0]}) with element at index ${i} (${array[i]})`);\n      swap(0, i);\n      renderArray([], Array.from({length: n - i}, (_, idx) => n - 1 - idx));\n      await pause(700);\n      await heapify(i, 0);\n    }\n    renderArray([], Array.from({length: n}, (_, idx) => idx));\n    log(\"Heap Sort complete. Array sorted.\");\n    sorting = false;\n  }\n\n  generateBtn.onclick = () => {\n    if (sorting) return;\n    let size = parseInt(arraySizeInput.value);\n    if (isNaN(size) || size < 5 || size > 50) {\n      alert(\"Array size must be between 5 and 50.\");\n      return;\n    }\n    generateArray(size);\n  };\n\n  startBtn.onclick = () => {\n    if (sorting) return;\n    heapSort();\n  };\n\n  // Initialize with default size\n  generateArray(parseInt(arraySizeInput.value));\n})();\n</script>\n</body>\n</html>"
