  "question": "HTTP",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>HTTP Interactive Demo</title>\n<style>\n  :root{\n    --bg:#0f1724;\n    --panel:#0b1220;\n    --muted:#9aa7bf;\n    --accent:#7dd3fc;\n    --ok:#22c55e;\n    --bad:#fb7185;\n    --glass: rgba(255,255,255,0.03);\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n  html,body{height:100%;margin:0;background:linear-gradient(180deg,#071025 0%, var(--bg) 100%);color:#e6eef8}\n  .wrap{max-width:1200px;margin:28px auto;padding:20px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);box-shadow:0 8px 30px rgba(2,6,23,0.6)}\n  header{display:flex;align-items:center;gap:18px;margin-bottom:14px}\n  header h1{font-size:20px;margin:0}\n  header p{margin:0;color:var(--muted);font-size:13px}\n  .grid{display:grid;grid-template-columns:360px 1fr 420px;gap:16px}\n  .panel{background:var(--panel);border-radius:10px;padding:12px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.02)}\n  .section-title{font-size:13px;margin-bottom:8px;color:var(--muted);display:flex;justify-content:space-between;align-items:center}\n  select,input[type=text],textarea{background:transparent;border:1px solid rgba(255,255,255,0.04);color:inherit;padding:8px;border-radius:6px;outline:none}\n  .row{display:flex;gap:8px;align-items:center}\n  .method{width:90px;padding:8px;font-weight:600}\n  .path{flex:1}\n  .small{font-size:13px;color:var(--muted)}\n  .button{background:linear-gradient(180deg,var(--accent),#45cbea);border:none;color:#06202a;padding:8px 12px;border-radius:8px;font-weight:700;cursor:pointer}\n  .btn-ghost{background:transparent;border:1px solid rgba(255,255,255,0.06);color:var(--muted);padding:7px 10px;border-radius:8px;cursor:pointer}\n  textarea{min-height:120px;resize:vertical;width:100%}\n  .headers{max-height:160px;overflow:auto;margin-bottom:8px}\n  .header-row{display:flex;gap:8px;margin-bottom:6px}\n  .header-row input{flex:1}\n  .add-btn{background:transparent;border:1px dashed rgba(255,255,255,0.04);padding:8px;border-radius:8px;color:var(--muted);cursor:pointer;width:100%}\n  .raw{background:#071428;padding:12px;border-radius:8px;font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;font-size:13px;white-space:pre-wrap;overflow:auto;max-height:360px}\n  .meta{display:flex;gap:8px;align-items:center}\n  .status{font-weight:800;padding:6px 10px;border-radius:8px}\n  .status.ok{background:linear-gradient(90deg,#062b1a,#06401b);color:var(--ok)}\n  .status.err{background:linear-gradient(90deg,#3f0a0f,#5b0d13);color:var(--bad)}\n  .timeline{height:72px;display:flex;flex-direction:column;justify-content:center;align-items:center;gap:8px}\n  .bar{height:6px;width:80%;background:linear-gradient(90deg, rgba(255,255,255,0.03), transparent);border-radius:4px;position:relative}\n  .arrow{position:absolute;top:-6px;transform:translateX(-50%);font-size:12px}\n  .log{background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);padding:10px;border-radius:8px;color:var(--muted);font-size:13px;max-height:120px;overflow:auto}\n  .kbd{background:rgba(255,255,255,0.03);padding:4px 8px;border-radius:6px;margin-left:8px;font-weight:700}\n  footer{margin-top:12px;color:var(--muted);font-size:13px}\n  .flex-col{display:flex;flex-direction:column}\n  .controls{display:flex;gap:8px;flex-wrap:wrap}\n  .badge{border-radius:6px;padding:4px 8px;background:rgba(255,255,255,0.02);font-size:12px;color:var(--muted)}\n  .muted{color:var(--muted)}\n  .right-head{display:flex;justify-content:space-between;align-items:center;gap:8px}\n  .row-wrap{display:flex;gap:8px;flex-wrap:wrap}\n  .tiny{font-size:12px;padding:6px;border-radius:6px}\n  .status-line{font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace}\n  .explain{font-size:13px;color:var(--muted);margin-top:8px}\n  .chip{background:rgba(255,255,255,0.02);padding:6px 8px;border-radius:999px;font-size:12px}\n  .link{color:var(--accent);text-decoration:underline;cursor:pointer}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <header>\n    <div>\n      <h1>HTTP Interactive Demo</h1>\n      <p>Build a request, send it to a simulated server, and inspect the request/response cycle.</p>\n    </div>\n    <div style=\"margin-left:auto\" class=\"small muted\">This is a client-side simulation — no network traffic is performed.</div>\n  </header>\n\n  <div class=\"grid\">\n    <!-- Left: Request Builder -->\n    <div class=\"panel\">\n      <div class=\"section-title\"><span>Request</span><span class=\"small muted\">Compose a raw HTTP request</span></div>\n      <div class=\"row\" style=\"margin-bottom:8px\">\n        <select id=\"method\" class=\"method\">\n          <option>GET</option>\n          <option>POST</option>\n          <option>PUT</option>\n          <option>DELETE</option>\n          <option>HEAD</option>\n          <option>OPTIONS</option>\n        </select>\n        <input id=\"path\" class=\"path\" type=\"text\" value=\"/time\" />\n        <button id=\"sendBtn\" class=\"button\">Send (simulated)</button>\n      </div>\n\n      <div style=\"display:flex;gap:8px;margin-bottom:10px;align-items:center\">\n        <div class=\"small muted\">Host</div>\n        <input id=\"host\" type=\"text\" value=\"demo.local\" style=\"width:180px\" />\n        <div class=\"small muted\">Protocol</div>\n        <select id=\"proto\">\n          <option>HTTP/1.1</option>\n          <option>HTTP/2</option>\n        </select>\n      </div>\n\n      <div class=\"section-title\"><span>Headers</span>\n        <div class=\"small muted\">Headers are case-insensitive</div>\n      </div>\n      <div class=\"headers\" id=\"headersList\">\n        <!-- header rows -->\n      </div>\n      <button id=\"addHeader\" class=\"add-btn\">+ Add header</button>\n\n      <div style=\"margin-top:10px\" class=\"section-title\"><span>Body</span><span class=\"small muted\">Used with POST/PUT</span></div>\n      <textarea id=\"body\" placeholder='{\"name\":\"Alice\"}'></textarea>\n\n      <div style=\"margin-top:12px\" class=\"row-wrap\">\n        <button id=\"sendRealBtn\" class=\"btn-ghost tiny\" title=\"This will attempt a real fetch (May be blocked by CORS)\">Send using fetch</button>\n        <label style=\"display:flex;align-items:center;gap:8px\" class=\"small muted\"><input id=\"includeCookies\" type=\"checkbox\" /> Include cookies</label>\n        <label style=\"display:flex;align-items:center;gap:8px\" class=\"small muted\"><input id=\"followRedirect\" type=\"checkbox\" checked/> Follow redirect (simulated)</label>\n      </div>\n\n      <div class=\"explain\">\n        Try endpoints: /time, /echo, /redirect, /etag, /stream. Use POST /echo to see body echoed back. The \"simulated\" server below implements common HTTP features.\n      </div>\n    </div>\n\n    <!-- Middle: Request/Response raw and timeline -->\n    <div class=\"panel\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px\">\n        <div class=\"section-title\" style=\"margin:0\"><span>Raw HTTP</span><span class=\"small muted\">Wire-format view</span></div>\n        <div class=\"meta\">\n          <div id=\"latencyLabel\" class=\"badge\">Latency: <span id=\"latencyVal\">300ms</span></div>\n          <input id=\"latency\" type=\"range\" min=\"0\" max=\"2000\" value=\"300\" style=\"width:160px\" />\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:12px\">\n        <div style=\"flex:1\">\n          <div class=\"small muted\" style=\"margin-bottom:6px\">Request (client → server)</div>\n          <div id=\"rawRequest\" class=\"raw\">— build a request on the left and press Send —</div>\n        </div>\n        <div style=\"width:340px\">\n          <div class=\"small muted\" style=\"margin-bottom:6px\">Response (server → client)</div>\n          <div id=\"rawResponse\" class=\"raw\">— response will appear here —</div>\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:12px;margin-top:12px;align-items:center\">\n        <div class=\"timeline\" style=\"flex:1\">\n          <div class=\"bar\" id=\"timeBar\">\n            <div class=\"arrow\" id=\"sendArrow\" style=\"left:8%;display:none\">⬆︎ Request</div>\n            <div class=\"arrow\" id=\"recvArrow\" style=\"left:92%;display:none\">⬇︎ Response</div>\n          </div>\n          <div class=\"small muted\" id=\"timeDetails\">Idle</div>\n        </div>\n        <div style=\"width:260px\">\n          <div class=\"right-head\">\n            <div class=\"small muted\">Status</div>\n            <div id=\"statusBox\" class=\"status status-line\">—</div>\n          </div>\n          <div style=\"margin-top:8px\" class=\"log\" id=\"eventLog\">No events yet</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Right: Parsed response and server controls -->\n    <div class=\"panel\">\n      <div class=\"section-title\"><span>Server (simulated)</span><span class=\"small muted\">Configure response behavior</span></div>\n\n      <div style=\"display:flex;gap:8px;align-items:center;margin-bottom:8px\">\n        <label class=\"small muted\">Default status</label>\n        <select id=\"serverStatus\" class=\"tiny\">\n          <option value=\"200\">200 OK</option>\n          <option value=\"201\">201 Created</option>\n          <option value=\"204\">204 No Content</option>\n          <option value=\"301\">301 Moved Permanently</option>\n          <option value=\"302\">302 Found</option>\n          <option value=\"304\">304 Not Modified</option>\n          <option value=\"400\">400 Bad Request</option>\n          <option value=\"401\">401 Unauthorized</option>\n          <option value=\"403\">403 Forbidden</option>\n          <option value=\"404\">404 Not Found</option>\n          <option value=\"500\">500 Internal Server Error</option>\n        </select>\n        <label class=\"small muted\" style=\"margin-left:auto;display:flex;gap:8px;align-items:center\">Delay(ms) <input id=\"serverDelay\" type=\"number\" value=\"0\" style=\"width:80px;background:transparent;border:1px solid rgba(255,255,255,0.04);padding:6px;border-radius:6px;color:inherit\" /></label>\n      </div>\n\n      <div style=\"display:flex;gap:8px;align-items:center;margin-bottom:8px\">\n        <label class=\"small muted\"><input id=\"enableCookie\" type=\"checkbox\" checked /> Set-Cookie</label>\n        <label class=\"small muted\"><input id=\"enableETag\" type=\"checkbox\" /> ETag/304</label>\n        <label class=\"small muted\"><input id=\"enableChunked\" type=\"checkbox\" /> Chunked streaming</label>\n      </div>\n\n      <div style=\"margin-top:8px\" class=\"section-title\"><span>Parsed Response</span><span class=\"small muted\">Human-friendly view</span></div>\n      <div style=\"display:flex;gap:8px;align-items:center;margin-bottom:8px\">\n        <div class=\"small muted\">Status:</div><div id=\"parsedStatus\" class=\"chip\">—</div>\n        <div class=\"small muted\">Content-Type:</div><div id=\"parsedType\" class=\"chip\">—</div>\n      </div>\n\n      <div style=\"margin-bottom:8px\">\n        <div class=\"small muted\" style=\"margin-bottom:6px\">Response headers</div>\n        <div id=\"parsedHeaders\" class=\"log\">—</div>\n      </div>\n\n      <div>\n        <div class=\"small muted\" style=\"margin-bottom:6px\">Body (parsed)</div>\n        <div id=\"parsedBody\" class=\"raw\">—</div>\n      </div>\n\n      <div style=\"margin-top:10px\" class=\"explain\">\n        Concepts demonstrated:\n        <ul style=\"margin-top:6px;color:var(--muted)\">\n          <li><strong>Request line:</strong> METHOD path HTTP/version</li>\n          <li><strong>Headers:</strong> key: value pairs, case-insensitive</li>\n          <li><strong>Status line:</strong> HTTP/version status reason</li>\n          <li><strong>Transfer-Encoding: chunked</strong> — streaming response</li>\n          <li><strong>Set-Cookie</strong> and subsequent Cookie header</li>\n          <li><strong>ETag</strong> and conditional GET → 304 Not Modified</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n  <footer>\n    Tip: Try POST /echo with JSON body, enable chunked streaming for /stream, or visit /redirect to see 301/302 flows.\n  </footer>\n</div>\n\n<script>\n(function(){\n  // Utilities\n  function $(id){return document.getElementById(id)}\n\n  // Initial header set\n  const headersList = $('headersList');\n  const defaultHeaders = [\n    {k:'User-Agent', v:'HTTP-Demo/1.0'},\n    {k:'Accept', v:'*/*'},\n    {k:'Accept-Encoding', v:'identity'},\n  ];\n  function createHeaderRow(k='', v=''){\n    const row = document.createElement('div');\n    row.className = 'header-row';\n    const key = document.createElement('input');\n    key.type = 'text'; key.value = k; key.placeholder = 'Header name';\n    const val = document.createElement('input');\n    val.type = 'text'; val.value = v; val.placeholder = 'Header value';\n    const del = document.createElement('button');\n    del.textContent = '✕'; del.className = 'btn-ghost tiny';\n    del.onclick = ()=>row.remove();\n    row.appendChild(key); row.appendChild(val); row.appendChild(del);\n    return row;\n  }\n  function populateHeaders(){\n    headersList.innerHTML='';\n    defaultHeaders.forEach(h=>headersList.appendChild(createHeaderRow(h.k,h.v)));\n    headersList.appendChild(createHeaderRow('Host', $('host').value));\n  }\n  populateHeaders();\n  $('addHeader').onclick = ()=>headersList.appendChild(createHeaderRow());\n\n  // Elements\n  const methodEl = $('method'), pathEl = $('path'), protoEl = $('proto');\n  const bodyEl = $('body');\n  const rawRequest = $('rawRequest'), rawResponse = $('rawResponse');\n  const statusBox = $('statusBox'), parsedStatus = $('parsedStatus'), parsedType = $('parsedType');\n  const parsedHeaders = $('parsedHeaders'), parsedBody = $('parsedBody');\n  const sendBtn = $('sendBtn'), sendRealBtn = $('sendRealBtn');\n  const eventLog = $('eventLog'), timeBar = $('timeBar'), sendArrow = $('sendArrow'), recvArrow = $('recvArrow'), timeDetails = $('timeDetails');\n  const latency = $('latency'), latencyVal = $('latencyVal'), serverDelay = $('serverDelay');\n  const serverStatus = $('serverStatus');\n  const enableCookie = $('enableCookie'), enableETag = $('enableETag'), enableChunked = $('enableChunked');\n  const includeCookies = $('includeCookies'), followRedirect = $('followRedirect');\n\n  latency.oninput = ()=>latencyVal.textContent = latency.value + 'ms';\n\n  // Event logging\n  function logEvent(msg){\n    const ts = new Date().toLocaleTimeString();\n    eventLog.textContent = `[${ts}] ${msg}\\n` + eventLog.textContent;\n  }\n\n  // Build request text\n  function buildRequestText(){\n    const m = methodEl.value;\n    const p = pathEl.value || '/';\n    const protocol = protoEl.value || 'HTTP/1.1';\n    const host = $('host').value || 'demo.local';\n    const headerRows = Array.from(headersList.querySelectorAll('.header-row'));\n    const headers = [];\n    // Ensure Host header present\n    let hasHost = false;\n    headerRows.forEach(r=>{\n      const inputs = r.querySelectorAll('input');\n      const k = inputs[0].value.trim();\n      const v = inputs[1].value.trim();\n      if(k){\n        headers.push({k,v});\n        if(k.toLowerCase()==='host') hasHost = true;\n      }\n    });\n    if(!hasHost) headers.unshift({k:'Host', v: host});\n    let text = `${m} ${p} ${protocol}\\r\\n`;\n    headers.forEach(h=>{\n      if(h.k) text += `${h.k}: ${h.v}\\r\\n`;\n    });\n    // Cookies from simulation if included\n    if(includeCookies.checked && simulatedState.cookies){\n      const cookieHeader = Object.entries(simulatedState.cookies).map(([k,v])=>k+'='+v).join('; ');\n      if(cookieHeader) text += `Cookie: ${cookieHeader}\\r\\n`;\n    }\n    text += `\\r\\n`;\n    if(['POST','PUT'].includes(m)){\n      text += bodyEl.value || '';\n    }\n    return {text, headers: headers.reduce((a,b)=>{a[b.k]=b.v;return a},{})};\n  }\n\n  // Simulated server state (keeps cookies, etag)\n  const simulatedState = {\n    cookies: {}, // name: value\n    etags: {},   // path: etag\n    requests: 0\n  };\n\n  // Helper to pretty status reason\n  const statusReasons = {\n    200:'OK',201:'Created',204:'No Content',301:'Moved Permanently',302:'Found',304:'Not Modified',\n    400:'Bad Request',401:'Unauthorized',403:'Forbidden',404:'Not Found',500:'Internal Server Error'\n  };\n\n  // Simulated server handler\n  function simulatedServerHandle(req){\n    // req: {method,path,headers,body}\n    const path = req.path;\n    const method = req.method;\n    const headers = req.headers;\n    const body = req.body;\n    simulatedState.requests++;\n    // Default response meta\n    let status = parseInt(serverStatus.value,10);\n    let headersOut = {'Server':'SimulatedHTTP/1.0','Content-Type':'text/plain; charset=utf-8'};\n    let bodyOut = '';\n    let reason = statusReasons[status] || '';\n    // Path-specific behavior\n    if(path === '/time' && method === 'GET'){\n      headersOut['Content-Type']='application/json';\n      bodyOut = JSON.stringify({now:new Date().toISOString(),requests:simulatedState.requests},null,2);\n    } else if(path === '/echo' && (method==='POST' || method==='PUT')){\n      // Echo back body\n      headersOut['Content-Type']='application/json';\n      bodyOut = body || '';\n    } else if(path === '/redirect'){\n      status = 302;\n      headersOut['Location'] = '/time';\n      bodyOut = 'Redirecting to /time';\n    } else if(path === '/etag'){\n      // ETag handling: returns 200 with ETag, or 304 if If-None-Match matches\n      const etag = simulatedState.etags[path] || ('W/\"v'+simulatedState.requests+'\"');\n      simulatedState.etags[path] = etag;\n      headersOut['ETag']=etag;\n      if(enableETag.checked && headers['If-None-Match'] && headers['If-None-Match'] === etag){\n        status = 304;\n        bodyOut = '';\n      } else {\n        status = 200;\n        headersOut['Content-Type']='application/json';\n        bodyOut = JSON.stringify({path:'etag','etag':etag,'time':new Date().toISOString()},null,2);\n      }\n    } else if(path === '/stream' && method === 'GET'){\n      // Streaming endpoint: produce chunks\n      headersOut['Content-Type']='text/plain; charset=utf-8';\n      bodyOut = {stream:true, chunks:[\n        'Hello from the server (chunk 1)\\n',\n        'Here is chunk 2\\n',\n        'Finalizing with chunk 3\\n'\n      ]};\n    } else {\n      // default: echo method and path\n      headersOut['Content-Type']='application/json';\n      bodyOut = JSON.stringify({method,path,headers,body,serverTime:new Date().toISOString()},null,2);\n    }\n\n    // Cookie set\n    if(enableCookie.checked){\n      const cname = 'demo_id';\n      const cval = 'id' + (simulatedState.requests % 1000);\n      headersOut['Set-Cookie'] = `${cname}=${cval}; HttpOnly; Path=/`;\n      simulatedState.cookies[cname] = cval;\n    }\n\n    // If server configured status overrides in some cases (except 304/stream/redirect)\n    if([302,301,304].includes(status) || path==='stream' || path==='etag' || path==='redirect'){\n      // use status from logic\n    } else {\n      status = parseInt(serverStatus.value,10) || status;\n    }\n\n    const delay = Math.max(0, parseInt(serverDelay.value || '0',10));\n    return new Promise((resolve)=>{\n      setTimeout(()=>{\n        resolve({status,reason:statusReasons[status]||'',headers:headersOut,body:bodyOut});\n      }, delay || 0);\n    });\n  }\n\n  // Simulate sending request and receiving response over \"network\"\n  async function sendSimulated(){\n    const reqBuilt = buildRequestText();\n    rawRequest.textContent = reqBuilt.text;\n    logEvent('Built request');\n    sendArrow.style.display='block';\n    recvArrow.style.display='none';\n    timeDetails.textContent = 'Sending request...';\n    statusBox.textContent = '…';\n    parsedStatus.textContent = '—';\n    parsedType.textContent = '—';\n    parsedHeaders.textContent = '—';\n    parsedBody.textContent = '—';\n    rawResponse.textContent = '';\n    // Visual: start arrow near left, animate based on latency + server delay\n    const netLatency = parseInt(latency.value||'0',10);\n    const sendPos = 8;\n    const recvPos = 92;\n    sendArrow.style.left = sendPos + '%';\n    recvArrow.style.left = recvPos + '%';\n    // Wait for \"network\" latency to reach server\n    logEvent(`Client → Server (${netLatency}ms)`);\n    timeDetails.textContent = `Client → Server (${netLatency}ms)`;\n    await new Promise(r => setTimeout(r, netLatency));\n    // Update: server handling\n    logEvent('Server processing request...');\n    timeDetails.textContent = 'Server processing...';\n    const request = parseRawRequest(reqBuilt.text);\n    // call simulated server\n    const resp = await simulatedServerHandle(request);\n    // For streaming, we emulate chunked transfer\n    if(resp.body && typeof resp.body === 'object' && resp.body.stream && enableChunked.checked){\n      // Prepare chunked headers\n      const h = Object.assign({}, resp.headers);\n      h['Transfer-Encoding'] = 'chunked';\n      // Build initial status line + headers\n      const statusLine = `${protoEl.value} ${resp.status} ${resp.reason}\\r\\n`;\n      const headerLines = Object.entries(h).map(([k,v])=>`${k}: ${v}`).join('\\r\\n') + '\\r\\n\\r\\n';\n      rawResponse.textContent = statusLine + headerLines;\n      parsedStatus.textContent = `${resp.status} ${resp.reason}`;\n      parsedType.textContent = h['Content-Type'] || '—';\n      parsedHeaders.textContent = Object.entries(h).map(([k,v])=>`${k}: ${v}`).join('\\n');\n      statusBox.textContent = `${resp.status} ${resp.reason}`;\n      statusBox.className = 'status status-line ' + (resp.status>=400 ? 'err':'ok');\n      // Simulate chunk arrival spaced out\n      for(let i=0;i<resp.body.chunks.length;i++){\n        await new Promise(r => setTimeout(r, 500 + Math.random()*400));\n        const chunk = resp.body.chunks[i];\n        // chunk format length in hex + CRLF + data + CRLF\n        const hex = chunk.length.toString(16);\n        rawResponse.textContent += `${hex}\\r\\n${chunk}\\r\\n`;\n        parsedBody.textContent = (parsedBody.textContent === '—') ? chunk : parsedBody.textContent + '\\n' + chunk;\n        logEvent(`Received chunk ${i+1}/${resp.body.chunks.length}`);\n      }\n      // final zero-length chunk\n      rawResponse.textContent += `0\\r\\n\\r\\n`;\n      recvArrow.style.display='block';\n      timeDetails.textContent = 'Response complete (chunked)';\n      logEvent('Response complete (chunked)');\n    } else {\n      // Non-streaming response\n      // Build response text\n      const statusLine = `${protoEl.value} ${resp.status} ${resp.reason}\\r\\n`;\n      const headerLines = Object.entries(resp.headers).map(([k,v])=>`${k}: ${v}`).join('\\r\\n') + '\\r\\n\\r\\n';\n      const bodyText = typeof resp.body === 'string' ? resp.body : (resp.body===null?'' : JSON.stringify(resp.body, null, 2));\n      rawResponse.textContent = statusLine + headerLines + bodyText;\n      // Fill parsed panes\n      parsedStatus.textContent = `${resp.status} ${resp.reason}`;\n      parsedType.textContent = resp.headers['Content-Type'] || '—';\n      parsedHeaders.textContent = Object.entries(resp.headers).map(([k,v])=>`${k}: ${v}`).join('\\n');\n      parsedBody.textContent = bodyText || '—';\n      statusBox.textContent = `${resp.status} ${resp.reason}`;\n      statusBox.className = 'status status-line ' + (resp.status>=400 ? 'err':'ok');\n      // Handle Set-Cookie simulation: apply to simulatedState.cookies (already set in handler)\n      if(resp.headers['Set-Cookie']){\n        logEvent(`Set-Cookie received: ${resp.headers['Set-Cookie']}`);\n      }\n      // Move arrow to response\n      await new Promise(r => setTimeout(r, netLatency));\n      recvArrow.style.display='block';\n      timeDetails.textContent = `Response ${resp.status} received`;\n      logEvent(`Server → Client (${netLatency}ms) — ${resp.status} ${resp.reason}`);\n      // Follow redirect if needed (simulated)\n      if((resp.status === 301 || resp.status === 302) && followRedirect.checked && resp.headers['Location']){\n        logEvent(`Following redirect to ${resp.headers['Location']}`);\n        // Update path and resend once automatically\n        pathEl.value = resp.headers['Location'];\n        setTimeout(()=>sendSimulated(), 200);\n      }\n    }\n  }\n\n  // Parse the raw request text back into object (simple)\n  function parseRawRequest(text){\n    const lines = text.split(/\\r?\\n/);\n    const first = lines[0]||'';\n    const [method, path, proto] = first.split(' ');\n    const headers = {};\n    let i=1;\n    for(;i<lines.length;i++){\n      const line = lines[i];\n      if(line.trim()==='') { i++; break; }\n      const idx = line.indexOf(':');\n      if(idx>0){\n        const k=line.slice(0,idx).trim();\n        const v=line.slice(idx+1).trim();\n        headers[k]=v;\n      }\n    }\n    const body = lines.slice(i).join('\\n');\n    return {method, path, proto, headers, body};\n  }\n\n  // Button wiring\n  sendBtn.onclick = async ()=>{\n    sendBtn.disabled = true;\n    sendRealBtn.disabled = true;\n    await sendSimulated();\n    sendBtn.disabled = false;\n    sendRealBtn.disabled = false;\n  };\n\n  // sendRealBtn: tries to perform a fetch to a real URL. Will be blocked by CORS in most cases.\n  sendRealBtn.onclick = async ()=>{\n    const m = methodEl.value;\n    const p = pathEl.value;\n    // If path looks like absolute URL use it, else use http://host + path\n    let url = p;\n    if(!/^https?:\\/\\//i.test(p)){\n      url = 'http://' + $('host').value + p;\n    }\n    try{\n      const init = {method:m, headers:{}};\n      // copy headers\n      const headerRows = Array.from(headersList.querySelectorAll('.header-row'));\n      headerRows.forEach(r=>{\n        const inputs = r.querySelectorAll('input');\n        const k = inputs[0].value.trim();\n        const v = inputs[1].value.trim();\n        if(k) init.headers[k]=v;\n      });\n      if(['POST','PUT'].includes(m)) init.body = bodyEl.value;\n      if(includeCookies.checked) init.credentials = 'include';\n      logEvent(`Attempting real fetch to ${url} (CORS may block)`);\n      const res = await fetch(url, init);\n      const text = await res.text();\n      // Build rawResponse\n      let head = `${res.status} ${res.statusText}\\r\\n`;\n      res.headers.forEach((v,k)=> head += `${k}: ${v}\\r\\n`);\n      rawRequest.textContent = buildRequestText().text;\n      rawResponse.textContent = head + '\\r\\n' + text;\n      parsedStatus.textContent = `${res.status} ${res.statusText}`;\n      parsedHeaders.textContent = Array.from(res.headers.entries()).map(([k,v])=>`${k}: ${v}`).join('\\n');\n      parsedBody.textContent = text.slice(0, 10000);\n      statusBox.textContent = `${res.status} ${res.statusText}`;\n      statusBox.className = 'status status-line ' + (res.status>=400 ? 'err':'ok');\n      logEvent(`Real fetch complete: ${res.status} ${res.statusText}`);\n    }catch(err){\n      logEvent('Fetch failed: ' + err.message);\n      rawResponse.textContent = 'Fetch error: ' + err.message;\n      parsedBody.textContent = 'Fetch error';\n      statusBox.textContent = 'Error';\n      statusBox.className = 'status status-line err';\n    }\n  };\n\n  // When host changes update Host header row if present\n  $('host').addEventListener('input', ()=>{\n    const rows = Array.from(headersList.querySelectorAll('.header-row'));\n    rows.forEach(r=>{\n      const key = r.querySelectorAll('input')[0];\n      const val = r.querySelectorAll('input')[1];\n      if(key.value.trim().toLowerCase()==='host'){\n        val.value = $('host').value;\n      }\n    });\n  });\n\n  // Initialize some defaults\n  function init(){\n    // Attach Host input to header list if missing\n    const hasHost = Array.from(headersList.querySelectorAll('.header-row')).some(r=> r.querySelectorAll('input')[0].value.trim().toLowerCase()==='host');\n    if(!hasHost) headersList.appendChild(createHeaderRow('Host', $('host').value));\n    rawRequest.textContent = '— build a request on the left and press Send —';\n    rawResponse.textContent = '— response will appear here —';\n    eventLog.textContent = 'Ready';\n    parsedHeaders.textContent = '—';\n    parsedBody.textContent = '—';\n    parsedStatus.textContent = '—';\n  }\n  init();\n\n  // Small demo: clicking some helpful paths auto-fills\n  pathEl.addEventListener('dblclick', ()=>{\n    alert('Double-click helpful paths: /time, /echo, /stream, /etag, /redirect (closes alert)');\n  });\n\n  // Small keyboard shortcut: Ctrl+Enter to send\n  document.addEventListener('keydown', (e)=>{\n    if((e.ctrlKey || e.metaKey) && e.key === 'Enter'){\n      sendBtn.click();\n    }\n  });\n\n  // Expose for debugging\n  window._sim = {simulatedState, sendSimulated, buildRequestText};\n\n})();\n</script>\n</body>\n</html>"
