    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Big-Omega (Ω) Notation Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    color: #005a9c;\n  }\n  section {\n    max-width: 700px;\n    margin: 1.5rem auto;\n    background: white;\n    padding: 1.5rem 2rem;\n    border-radius: 8px;\n    box-shadow: 0 0 8px #a3c4f3;\n  }\n  p {\n    line-height: 1.5;\n  }\n  .code-block {\n    background: #282c34;\n    color: #d4d4d4;\n    padding: 1rem;\n    border-radius: 6px;\n    font-family: 'Courier New', Courier, monospace;\n    overflow-x: auto;\n    margin: 1rem 0;\n  }\n  canvas {\n    display: block;\n    margin: 2rem auto;\n    background: #fff;\n    box-shadow: 0 0 10px #a3c4f3;\n    border-radius: 8px;\n  }\n  #controls {\n    max-width: 700px;\n    margin: 0 auto 2rem;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n  }\n  label {\n    font-weight: bold;\n  }\n  input[type=\"range\"] {\n    flex-grow: 1;\n    margin: 0 1rem;\n  }\n  #explanation {\n    max-width: 700px;\n    margin: 0 auto;\n    font-style: italic;\n    color: #555;\n  }\n</style>\n</head>\n<body>\n<h1>Big-Omega (Ω) Notation Demonstration</h1>\n\n<section>\n  <h2>What is Big-Omega?</h2>\n  <p>\n    Big-Omega (Ω) notation describes a <strong>lower bound</strong> on the growth rate of a function.\n    It tells us the minimum rate at which a function grows as its input size becomes large.\n    Formally, <code>f(n) ∈ Ω(g(n))</code> means constants <code>c > 0</code> and <code>n₀</code> exist such that for all <code>n ≥ n₀</code>,\n  </p>\n  <div class=\"code-block\">f(n) ≥ c × g(n)</div>\n  <p>In simpler terms, beyond some input size, f(n) is always greater than or equal to c times g(n).</p>\n</section>\n\n<section>\n  <h2>Example Functions</h2>\n  <p>Here we'll compare two functions:</p>\n  <ul>\n    <li><code>f(n) = 2n + 3</code> (linear function)</li>\n    <li><code>g(n) = n</code> (linear function)</li>\n  </ul>\n  <p>We want to show that <code>f(n) ∈ Ω(g(n))</code>, meaning <code>2n + 3</code> grows at least as fast as <code>n</code> for large <code>n</code>.</p>\n</section>\n\n<section>\n  <h2>Interactive Visualization</h2>\n  <div id=\"controls\">\n    <label for=\"inputN\">Input size, n:</label>\n    <input type=\"range\" id=\"inputN\" min=\"1\" max=\"100\" value=\"10\" step=\"1\" />\n    <span id=\"nValue\">10</span>\n  </div>\n  <canvas id=\"graph\" width=\"700\" height=\"350\" aria-label=\"Big-Omega notation functions graph\" role=\"img\"></canvas>\n  <div id=\"explanation\"></div>\n</section>\n\n<script>\n(() => {\n  const canvas = document.getElementById('graph');\n  const ctx = canvas.getContext('2d');\n  const inputN = document.getElementById('inputN');\n  const nValueDisplay = document.getElementById('nValue');\n  const explanation = document.getElementById('explanation');\n\n  // Functions to compare: f(n) = 2n + 3, g(n) = n\n  function f(n) {\n    return 2 * n + 3;\n  }\n  function g(n) {\n    return n;\n  }\n\n  // We'll plot for n=0 to maxN\n  const maxN = 100;\n  const padding = 50;\n\n  // Scale factors for plotting\n  // We'll determine max y value for scaling, based on f(maxN)\n  const maxY = f(maxN) + 10;\n\n  function clearCanvas() {\n    ctx.fillStyle = '#fff';\n    ctx.fillRect(0, 0, canvas.width, canvas.height);\n  }\n\n  function drawAxes() {\n    ctx.strokeStyle = '#555';\n    ctx.lineWidth = 1;\n    ctx.font = '12px Arial';\n    ctx.fillStyle = '#555';\n\n    // X axis\n    ctx.beginPath();\n    ctx.moveTo(padding, canvas.height - padding);\n    ctx.lineTo(canvas.width - padding, canvas.height - padding);\n    ctx.stroke();\n\n    // Y axis\n    ctx.beginPath();\n    ctx.moveTo(padding, canvas.height - padding);\n    ctx.lineTo(padding, padding);\n    ctx.stroke();\n\n    // Label axes\n    ctx.fillText('n', canvas.width - padding - 10, canvas.height - padding + 25);\n    ctx.fillText('Value', padding - 30, padding - 10);\n\n    // Draw tick marks and labels on x-axis (every 10)\n    for (let i = 0; i <= maxN; i += 10) {\n      const x = mapX(i);\n      ctx.beginPath();\n      ctx.moveTo(x, canvas.height - padding);\n      ctx.lineTo(x, canvas.height - padding + 5);\n      ctx.stroke();\n      ctx.fillText(i, x - 6, canvas.height - padding + 20);\n    }\n\n    // Draw tick marks and labels on y-axis (every ~20)\n    const yStep = 20;\n    for (let yVal = 0; yVal <= maxY; yVal += yStep) {\n      const y = mapY(yVal);\n      ctx.beginPath();\n      ctx.moveTo(padding - 5, y);\n      ctx.lineTo(padding, y);\n      ctx.stroke();\n      ctx.fillText(yVal, padding - 40, y + 4);\n    }\n  }\n\n  // Map n value to canvas x coordinate\n  function mapX(n) {\n    return padding + ((canvas.width - 2 * padding) * n) / maxN;\n  }\n\n  // Map f(n) value to canvas y coordinate\n  function mapY(val) {\n    // invert y axis for canvas\n    return canvas.height - padding - ((canvas.height - 2 * padding) * val) / maxY;\n  }\n\n  // Draw function graph given a function, color, line style \n  function drawFunction(fn, color, dash = []) {\n    ctx.strokeStyle = color;\n    ctx.lineWidth = 2;\n    ctx.setLineDash(dash);\n    ctx.beginPath();\n    for (let n = 0; n <= maxN; n++) {\n      const x = mapX(n);\n      const y = mapY(fn(n));\n      if (n === 0) ctx.moveTo(x, y);\n      else ctx.lineTo(x, y);\n    }\n    ctx.stroke();\n    ctx.setLineDash([]);\n  }\n\n  // Draw horizontal line representing c * g(n) for chosen n and c\n  function drawBoundLine(c, nStart) {\n    // For Omega, need f(n) >= c * g(n) for n >= n0\n    // We draw y = c * g(x) line starting at n0\n\n    // Draw the line y = c*g(x) for x = nStart ... maxN as a dashed line\n\n    ctx.strokeStyle = '#d14';\n    ctx.lineWidth = 2;\n    ctx.setLineDash([10, 6]);\n\n    ctx.beginPath();\n\n    // Start point at nStart\n    let x = mapX(nStart);\n    let y = mapY(c * g(nStart));\n    ctx.moveTo(x, y);\n\n    // Draw to maxN\n    for (let n = nStart + 1; n <= maxN; n++) {\n      const px = mapX(n);\n      const py = mapY(c * g(n));\n      ctx.lineTo(px, py);\n    }\n    ctx.stroke();\n    ctx.setLineDash([]);\n  }\n\n  // Draw vertical line to represent n0\n  function drawN0Line(n0) {\n    ctx.strokeStyle = '#5a5a5a';\n    ctx.lineWidth = 1;\n    ctx.setLineDash([4, 4]);\n\n    const x = mapX(n0);\n    ctx.beginPath();\n    ctx.moveTo(x, canvas.height - padding);\n    ctx.lineTo(x, padding);\n    ctx.stroke();\n\n    ctx.setLineDash([]);\n    ctx.fillStyle = '#5a5a5a';\n    ctx.font = '14px Arial';\n    ctx.fillText('n₀ = ' + n0, x + 5, padding + 15);\n  }\n\n  // Check for suitable constants c and n0 for given f and g\n  // For f(n)=2n+3, g(n)=n, one can pick c=1.5 and n0=6 (for example)\n  // We'll allow user to move n from 1 to 100 and check the inequality f(n)>= c*g(n)\n\n  // We can choose c = 1.5 (constant, for demonstration)\n  const c = 1.5;\n  // We'll find minimal n0 such that for all n >= n0: f(n) >= c*g(n)\n  function computeN0() {\n    for (let n = 1; n <= maxN; n++) {\n      if (f(n) >= c * g(n)) {\n        // check if true for all n >= this n\n        let validForAll = true;\n        for (let k = n; k <= maxN; k++) {\n          if (f(k) < c * g(k)) {\n            validForAll = false;\n            break;\n          }\n        }\n        if (validForAll) return n;\n      }\n    }\n    return null; // no suitable n0\n  }\n\n  // We'll highlight if current n (input slider) satisfies the inequality or not\n  function updateExplanation(currentN, n0, satisfies) {\n    let msg = `For c = ${c} and threshold n₀ = ${n0}, `;\n    if (currentN < n0) {\n      msg += `the input size n = ${currentN} is less than the threshold n₀. The Big-Omega inequality might not hold yet.`;\n    } else {\n      if (satisfies) {\n        msg += `f(n) = 2n + 3 ≥ c × g(n) = ${c} × n holds at n = ${currentN}.`;\n      } else {\n        msg += `f(n) < c × g(n) at n = ${currentN}, inequality does NOT hold here.`;\n      }\n    }\n    explanation.textContent = msg;\n  }\n\n  function draw() {\n    clearCanvas();\n    drawAxes();\n\n    drawFunction(f, '#007acc'); // f(n) blue solid\n    drawFunction(g, '#28a745', [5, 5]); // g(n) green dashed\n\n    // Calculate minimal n0\n    const n0 = computeN0() || 1;\n\n    // Draw bound line y = c*g(n) for n >= n0\n    drawBoundLine(c, n0);\n\n    // Draw vertical line n0\n    drawN0Line(n0);\n\n    // Show legend\n    ctx.fillStyle = '#007acc';\n    ctx.fillRect(canvas.width - 160, padding + 10, 15, 10);\n    ctx.fillStyle = '#333';\n    ctx.font = '13px Arial';\n    ctx.fillText('f(n) = 2n + 3', canvas.width - 140, padding + 20);\n\n    ctx.strokeStyle = '#28a745';\n    ctx.setLineDash([5, 5]);\n    ctx.beginPath();\n    ctx.moveTo(canvas.width - 160, padding + 35);\n    ctx.lineTo(canvas.width - 145, padding + 35);\n    ctx.stroke();\n    ctx.setLineDash([]);\n    ctx.fillStyle = '#333';\n    ctx.fillText('g(n) = n', canvas.width - 140, padding + 40);\n\n    ctx.strokeStyle = '#d14';\n    ctx.setLineDash([10, 6]);\n    ctx.beginPath();\n    ctx.moveTo(canvas.width - 160, padding + 60);\n    ctx.lineTo(canvas.width - 145, padding + 60);\n    ctx.stroke();\n    ctx.setLineDash([]);\n    ctx.fillStyle = '#333';\n    ctx.fillText(`Ω bound: y = ${c} × g(n)`, canvas.width - 140, padding + 65);\n\n    // Show current n vertical line and point on functions\n    const currN = +inputN.value;\n    const xCurr = mapX(currN);\n\n    // vertical line\n    ctx.strokeStyle = '#ffa500';\n    ctx.lineWidth = 1.5;\n    ctx.setLineDash([3, 3]);\n    ctx.beginPath();\n    ctx.moveTo(xCurr, canvas.height - padding);\n    ctx.lineTo(xCurr, padding);\n    ctx.stroke();\n    ctx.setLineDash([]);\n\n    // points on f(n), g(n), and c*g(n)\n    const yf = mapY(f(currN));\n    const yg = mapY(g(currN));\n    const ybound = mapY(c * g(currN));\n\n    // Draw points\n    // f(n): blue circle\n    ctx.fillStyle = '#007acc';\n    ctx.beginPath();\n    ctx.arc(xCurr, yf, 6, 0, Math.PI * 2);\n    ctx.fill();\n\n    // g(n): green circle\n    ctx.fillStyle = '#28a745';\n    ctx.beginPath();\n    ctx.arc(xCurr, yg, 6, 0, Math.PI * 2);\n    ctx.fill();\n\n    // bound: red square\n    ctx.fillStyle = '#d14';\n    ctx.beginPath();\n    ctx.rect(xCurr - 5, ybound - 5, 10, 10);\n    ctx.fill();\n\n    // Evaluate if inequality holds at current n: f(n) >= c * g(n)\n    const satisfies = f(currN) >= c * g(currN);\n\n    updateExplanation(currN, n0, satisfies);\n  }\n\n  inputN.addEventListener('input', () => {\n    nValueDisplay.textContent = inputN.value;\n    draw();\n  });\n\n  // Initial draw\n  draw();\n})();\n</script>\n</body>\n</html>"
  },
