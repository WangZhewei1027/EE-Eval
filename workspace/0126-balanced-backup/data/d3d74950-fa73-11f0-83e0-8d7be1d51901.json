  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Floyd–Warshall Algorithm Demonstration</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 18px; color: #222; }\n    h1 { margin: 0 0 8px 0; font-size: 22px; }\n    p { margin: 6px 0; }\n    .container { display: flex; gap: 18px; align-items: flex-start; }\n    .col { background: #fbfbfb; border: 1px solid #e6e6e6; padding: 12px; border-radius: 8px; box-shadow: 0 1px 2px rgba(0,0,0,0.03); }\n    .col.small { width: 320px; }\n    .controls { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }\n    button { cursor: pointer; padding: 6px 10px; border-radius: 5px; border: 1px solid #cfcfcf; background: #fff; }\n    button.primary { background: #2d8cf0; color: white; border-color: #1a71d1; }\n    button.negative { background: #ffd6d6; border-color: #ff9b9b; }\n    label { display: flex; gap: 8px; align-items: center; }\n    input[type=\"number\"] { width: 62px; padding: 4px; }\n    table { border-collapse: collapse; margin-top: 8px; }\n    td, th { border: 1px solid #ddd; padding: 6px 8px; text-align: center; min-width: 56px; }\n    th { background: #fafafa; font-weight: 600; }\n    td.inputcell { padding: 2px; }\n    input.cell { width: 100%; box-sizing: border-box; text-align: center; padding: 6px; border: none; background: transparent; }\n    .inf { color: #888; }\n    .highlight { background: #fffae6; }\n    .updated { background: #e6ffef; border: 2px solid #9ef0bf; }\n    .kcell { background: #eef6ff; }\n    .legend { display: flex; gap: 8px; align-items: center; margin-top: 8px; }\n    .legend .box { width: 16px; height: 16px; border-radius: 3px; display:inline-block; }\n    .box-k { background: #eef6ff; border: 1px solid #cfe6ff; }\n    .box-inv { background: #fffae6; border: 1px solid #ffe6b2; }\n    .box-upd { background: #e6ffef; border: 1px solid #bff0cf; }\n    .status { margin-top: 8px; font-weight: 600; }\n    .smalltext { font-size: 13px; color: #555; }\n    .matrix-title { margin-top: 8px; font-weight: 700; }\n    select { padding: 6px; }\n    input[type=\"checkbox\"] { transform: scale(1.1); }\n    #log { height: 120px; overflow: auto; background: #fff; border: 1px solid #eee; padding: 8px; font-family: monospace; font-size: 12px; border-radius: 6px; }\n    footer { margin-top: 14px; font-size: 13px; color: #666; }\n    .flexrow { display:flex; gap:8px; align-items:center; }\n  </style>\n</head>\n<body>\n  <h1>Floyd–Warshall Algorithm — Interactive Demonstration</h1>\n  <p class=\"smalltext\">Floyd–Warshall computes shortest paths between all pairs of nodes in a weighted graph (works with directed graphs and handles negative edges if there are no negative cycles). Use the controls to edit the adjacency, step through the algorithm, or run it automatically. The \"next\" matrix lets you reconstruct shortest paths.</p>\n\n  <div class=\"container\">\n    <div class=\"col small\">\n      <div class=\"controls\">\n        <label>Nodes:\n          <input id=\"nodeCount\" type=\"number\" min=\"2\" max=\"10\" value=\"5\">\n        </label>\n        <button id=\"applyN\">Apply</button>\n      </div>\n\n      <div class=\"controls\">\n        <button id=\"randomBtn\">Random Graph</button>\n        <button id=\"clearBtn\">Clear Graph</button>\n      </div>\n\n      <div class=\"controls\">\n        <button id=\"initBtn\" class=\"primary\">Initialize</button>\n        <button id=\"stepBtn\">Step</button>\n        <button id=\"runBtn\" class=\"primary\">Run All</button>\n        <button id=\"autoBtn\">Auto Run</button>\n        <button id=\"resetBtn\" class=\"negative\">Reset</button>\n      </div>\n\n      <div class=\"controls\">\n        <label><input type=\"checkbox\" id=\"directed\" checked> Directed</label>\n        <label>Speed:\n          <input id=\"speed\" type=\"range\" min=\"50\" max=\"1200\" value=\"400\">\n        </label>\n      </div>\n\n      <div class=\"matrix-title\">Adjacency matrix (enter INF or leave blank for no edge):</div>\n      <div id=\"adjContainer\"></div>\n\n      <div class=\"legend\">\n        <div style=\"display:flex;gap:6px;align-items:center;\">\n          <span class=\"box box-k\"></span> current k\n        </div>\n        <div style=\"display:flex;gap:6px;align-items:center;\">\n          <span class=\"box box-inv\"></span> comparison (i,j) being considered\n        </div>\n        <div style=\"display:flex;gap:6px;align-items:center;\">\n          <span class=\"box box-upd\"></span> value updated\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"col\" style=\"flex:1;\">\n      <div style=\"display:flex;gap:12px;align-items:center;flex-wrap:wrap;\">\n        <div>\n          <div class=\"matrix-title\">Distance matrix (D)</div>\n          <div id=\"distContainer\"></div>\n        </div>\n        <div>\n          <div class=\"matrix-title\">Next matrix (for path reconstruction)</div>\n          <div id=\"nextContainer\"></div>\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:12px;margin-top:12px;align-items:center;flex-wrap:wrap;\">\n        <div class=\"flexrow\">\n          <label>Source:\n            <select id=\"srcSelect\"></select>\n          </label>\n          <label>Target:\n            <select id=\"tgtSelect\"></select>\n          </label>\n          <button id=\"showPathBtn\">Show Path</button>\n        </div>\n        <div class=\"status\" id=\"status\">Status: ready</div>\n      </div>\n\n      <div style=\"margin-top:10px;\">\n        <div class=\"matrix-title\">Log</div>\n        <div id=\"log\"></div>\n      </div>\n\n      <footer>\n        Tips: Click Initialize to load the adjacency into the algorithm. Step runs one (k,i,j) comparison. Run All computes to completion. Use Auto Run to animate. Use \"Next\" matrix to reconstruct a shortest path after the algorithm finishes.\n      </footer>\n    </div>\n  </div>\n\n  <script>\n    // Floyd-Warshall interactive demo\n    (() => {\n      const maxNodes = 10;\n      let n = 5;\n      let directed = true;\n\n      // Matrices\n      let adj = [];     // adjacency original (Number or Infinity)\n      let dist = [];    // current distances\n      let nextMat = []; // next pointers for path reconstruction\n\n      // algorithm indices for step-by-step\n      let kIndex = 0, iIndex = 0, jIndex = 0;\n      let initialized = false;\n      let runningAuto = false;\n      let initialAdjSnapshot = null;\n\n      // DOM\n      const adjContainer = document.getElementById('adjContainer');\n      const distContainer = document.getElementById('distContainer');\n      const nextContainer = document.getElementById('nextContainer');\n      const nodeCountInput = document.getElementById('nodeCount');\n      const applyNBtn = document.getElementById('applyN');\n      const randomBtn = document.getElementById('randomBtn');\n      const clearBtn = document.getElementById('clearBtn');\n      const initBtn = document.getElementById('initBtn');\n      const stepBtn = document.getElementById('stepBtn');\n      const runBtn = document.getElementById('runBtn');\n      const autoBtn = document.getElementById('autoBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const directedCheckbox = document.getElementById('directed');\n      const speedSlider = document.getElementById('speed');\n      const srcSelect = document.getElementById('srcSelect');\n      const tgtSelect = document.getElementById('tgtSelect');\n      const showPathBtn = document.getElementById('showPathBtn');\n      const statusEl = document.getElementById('status');\n      const logEl = document.getElementById('log');\n\n      function log(msg) {\n        const line = document.createElement('div');\n        line.textContent = msg;\n        logEl.appendChild(line);\n        logEl.scrollTop = logEl.scrollHeight;\n      }\n\n      // Utilities\n      function INF() { return Number.POSITIVE_INFINITY; }\n      function isInf(x) { return x === Infinity || x === Number.POSITIVE_INFINITY; }\n      function formatVal(x) {\n        if (isInf(x)) return '∞';\n        return (Number.isInteger(x) ? x : Number(x).toFixed(2));\n      }\n\n      function createEmptyMatrix(size, fill = Infinity) {\n        return Array.from({length: size}, () => Array.from({length: size}, () => fill));\n      }\n\n      function buildAdjUI() {\n        adjContainer.innerHTML = '';\n        const table = document.createElement('table');\n        const thead = document.createElement('thead');\n        const headerRow = document.createElement('tr');\n        headerRow.appendChild(document.createElement('th'));\n        for (let j=0;j<n;j++){\n          const th = document.createElement('th');\n          th.textContent = 'v' + j;\n          headerRow.appendChild(th);\n        }\n        thead.appendChild(headerRow);\n        table.appendChild(thead);\n        const tbody = document.createElement('tbody');\n        for (let i=0;i<n;i++){\n          const tr = document.createElement('tr');\n          const rowHeader = document.createElement('th');\n          rowHeader.textContent = 'v' + i;\n          tr.appendChild(rowHeader);\n          for (let j=0;j<n;j++){\n            const td = document.createElement('td');\n            td.classList.add('inputcell');\n            const input = document.createElement('input');\n            input.className = 'cell';\n            input.dataset.i = i; input.dataset.j = j;\n            // default text\n            if (i === j) input.value = '0';\n            else {\n              const val = adj && adj[i] && (adj[i][j] !== undefined) ? adj[i][j] : Infinity;\n              input.value = isInf(val) ? '' : String(val);\n            }\n            td.appendChild(input);\n            tr.appendChild(td);\n          }\n          tbody.appendChild(tr);\n        }\n        table.appendChild(tbody);\n        adjContainer.appendChild(table);\n\n        // listeners: update adj on change\n        adjContainer.querySelectorAll('input.cell').forEach(inp => {\n          inp.addEventListener('change', () => {\n            readAdjFromUI();\n            initialized = false;\n            status('Adjacency edited — click Initialize to start algorithm with this graph.');\n          });\n        });\n      }\n\n      function readAdjFromUI() {\n        const inputs = adjContainer.querySelectorAll('input.cell');\n        adj = createEmptyMatrix(n, INF());\n        inputs.forEach(inp => {\n          const i = Number(inp.dataset.i);\n          const j = Number(inp.dataset.j);\n          const raw = inp.value.trim();\n          if (raw === '' || raw.toLowerCase() === 'inf' || raw === '∞') {\n            adj[i][j] = INF();\n          } else {\n            const v = Number(raw);\n            adj[i][j] = isNaN(v) ? INF() : v;\n          }\n        });\n        // enforce diagonal zero\n        for (let i=0;i<n;i++) adj[i][i]=0;\n        if (!directed) {\n          // mirror symmetric for undirected graph\n          for (let i=0;i<n;i++){\n            for (let j=0;j<n;j++){\n              if (i<j) {\n                const a = adj[i][j], b=adj[j][i];\n                if (!isInf(a)) adj[j][i]=a;\n                else if (!isInf(b)) adj[i][j]=b;\n              }\n            }\n          }\n          // update UI to reflect symmetry\n          updateAdjUIFromMatrix();\n        }\n      }\n\n      function updateAdjUIFromMatrix() {\n        adjContainer.querySelectorAll('input.cell').forEach(inp => {\n          const i = Number(inp.dataset.i), j = Number(inp.dataset.j);\n          const val = adj[i][j];\n          inp.value = isInf(val) ? '' : String(val);\n        });\n      }\n\n      function initFromAdj() {\n        readAdjFromUI();\n        // create dist and next from adjacency\n        dist = createEmptyMatrix(n, INF());\n        nextMat = createEmptyMatrix(n, null);\n        for (let i=0;i<n;i++){\n          for (let j=0;j<n;j++){\n            dist[i][j] = adj[i][j];\n            if (!isInf(adj[i][j]) && i!==j) nextMat[i][j] = j;\n          }\n          dist[i][i] = 0;\n          nextMat[i][i] = i;\n        }\n        // snapshot initial adjacency for reset\n        initialAdjSnapshot = adj.map(row => row.slice());\n        kIndex = 0; iIndex = 0; jIndex = 0;\n        initialized = true;\n        runningAuto = false;\n        renderMatrices();\n        populateNodeSelectors();\n        log('Initialized algorithm with current adjacency.');\n        status('Initialized. Ready to step or run.');\n      }\n\n      function renderMatrices(highlight = {}) {\n        // highlight: {k, i, j, updated: {i,j} }\n        renderDistMatrix(highlight);\n        renderNextMatrix(highlight);\n      }\n\n      function renderDistMatrix(highlight) {\n        distContainer.innerHTML = '';\n        const table = document.createElement('table');\n        const thead = document.createElement('thead');\n        const headerRow = document.createElement('tr');\n        headerRow.appendChild(document.createElement('th'));\n        for (let j=0;j<n;j++){\n          const th = document.createElement('th'); th.textContent = 'v' + j; headerRow.appendChild(th);\n        }\n        thead.appendChild(headerRow); table.appendChild(thead);\n\n        const tbody = document.createElement('tbody');\n        for (let i=0;i<n;i++){\n          const tr = document.createElement('tr');\n          const rowHeader = document.createElement('th'); rowHeader.textContent = 'v' + i; tr.appendChild(rowHeader);\n          for (let j=0;j<n;j++){\n            const td = document.createElement('td');\n            td.textContent = formatVal(dist[i][j]);\n            if (highlight.k === j || highlight.k === i || highlight.k === jIndex) {} // just placeholder\n            // apply highlight classes\n            if (highlight.k === undefined ? false : highlight.kCell && highlight.kCell === j) {}\n            // mark current k row/col via class on column header? We'll mark cells involving k\n            if (highlight.k !== undefined && (i === highlight.k || j === highlight.k)) {\n              td.classList.add('kcell');\n            }\n            if (highlight.i !== undefined && highlight.j !== undefined && i === highlight.i && j === highlight.j) {\n              td.classList.add('highlight');\n            }\n            if (highlight.updated && highlight.updated.i === i && highlight.updated.j === j) {\n              td.classList.add('updated');\n            }\n            tr.appendChild(td);\n          }\n          tbody.appendChild(tr);\n        }\n        table.appendChild(tbody);\n        distContainer.appendChild(table);\n      }\n\n      function renderNextMatrix(highlight) {\n        nextContainer.innerHTML = '';\n        const table = document.createElement('table');\n        const thead = document.createElement('thead');\n        const headerRow = document.createElement('tr');\n        headerRow.appendChild(document.createElement('th'));\n        for (let j=0;j<n;j++){\n          const th = document.createElement('th'); th.textContent = 'v' + j; headerRow.appendChild(th);\n        }\n        thead.appendChild(headerRow); table.appendChild(thead);\n\n        const tbody = document.createElement('tbody');\n        for (let i=0;i<n;i++){\n          const tr = document.createElement('tr');\n          const rowHeader = document.createElement('th'); rowHeader.textContent = 'v' + i; tr.appendChild(rowHeader);\n          for (let j=0;j<n;j++){\n            const td = document.createElement('td');\n            const v = nextMat[i][j];\n            td.textContent = (v===null||v===undefined) ? '-' : 'v' + v;\n            if (highlight.k !== undefined && (i === highlight.k || j === highlight.k)) {\n              td.classList.add('kcell');\n            }\n            if (highlight.i !== undefined && highlight.j !== undefined && i === highlight.i && j === highlight.j) {\n              td.classList.add('highlight');\n            }\n            if (highlight.updated && highlight.updated.i === i && highlight.updated.j === j) {\n              td.classList.add('updated');\n            }\n            tr.appendChild(td);\n          }\n          tbody.appendChild(tr);\n        }\n        table.appendChild(tbody);\n        nextContainer.appendChild(table);\n      }\n\n      function status(msg) {\n        statusEl.textContent = 'Status: ' + msg;\n      }\n\n      function populateNodeSelectors() {\n        srcSelect.innerHTML = '';\n        tgtSelect.innerHTML = '';\n        for (let i=0;i<n;i++){\n          const o1 = document.createElement('option'); o1.value = i; o1.textContent = 'v' + i;\n          const o2 = document.createElement('option'); o2.value = i; o2.textContent = 'v' + i;\n          srcSelect.appendChild(o1); tgtSelect.appendChild(o2);\n        }\n      }\n\n      // Step logic: perform one compare/update for current k,i,j\n      function stepOnce() {\n        if (!initialized) {\n          status('Initialize first.');\n          return {done:true};\n        }\n        if (kIndex >= n) {\n          status('Algorithm finished.');\n          return {done:true};\n        }\n        const k = kIndex, i = iIndex, j = jIndex;\n        const highlight = {k:k, i:i, j:j, kCell:k};\n        const before = dist[i][j];\n        // avoid numeric overflow with INF\n        const dik = dist[i][k], dkj = dist[k][j];\n        const sum = (isInf(dik) || isInf(dkj)) ? INF() : (dik + dkj);\n        let updated = null;\n        if (sum < dist[i][j]) {\n          dist[i][j] = sum;\n          nextMat[i][j] = nextMat[i][k];\n          updated = {i:i, j:j};\n          log(`k=v${k}, compare v${i}->v${j} : ${formatVal(before)} > ${formatVal(dik)} + ${formatVal(dkj)} = ${formatVal(sum)} → updated`);\n        } else {\n          log(`k=v${k}, compare v${i}->v${j} : ${formatVal(before)} <= ${formatVal(sum)} (no change)`);\n        }\n        renderMatrices({k:k, i:i, j:j, updated: updated, kCell:k});\n        // advance indices\n        jIndex++;\n        if (jIndex >= n) {\n          jIndex = 0; iIndex++;\n        }\n        if (iIndex >= n) {\n          iIndex = 0; kIndex++;\n        }\n        if (kIndex >= n) {\n          status('Algorithm finished.');\n          log('Floyd–Warshall completed.');\n          return {done:true};\n        } else {\n          status(`Next: k=v${kIndex}, i=v${iIndex}, j=v${jIndex}`);\n          return {done:false};\n        }\n      }\n\n      // Run to completion (fast)\n      function runAll() {\n        if (!initialized) { status('Initialize first.'); return; }\n        log('Running full Floyd–Warshall (fast mode)...');\n        for (let k=0;k<n;k++){\n          for (let i=0;i<n;i++){\n            for (let j=0;j<n;j++){\n              const dik = dist[i][k], dkj = dist[k][j];\n              const sum = (isInf(dik) || isInf(dkj)) ? INF() : (dik + dkj);\n              if (sum < dist[i][j]) {\n                dist[i][j] = sum;\n                nextMat[i][j] = nextMat[i][k];\n              }\n            }\n          }\n        }\n        kIndex = n; iIndex = 0; jIndex = 0;\n        renderMatrices();\n        log('Completed.');\n        status('Algorithm finished.');\n      }\n\n      async function autoRun() {\n        if (!initialized) { status('Initialize first.'); return; }\n        if (runningAuto) {\n          runningAuto = false;\n          autoBtn.textContent = 'Auto Run';\n          status('Auto run stopped.');\n          return;\n        }\n        runningAuto = true;\n        autoBtn.textContent = 'Stop';\n        status('Auto running...');\n        log('Auto run started.');\n        while (runningAuto && kIndex < n) {\n          const res = stepOnce();\n          if (res.done) break;\n          await sleep(Number(speedSlider.value));\n        }\n        runningAuto = false;\n        autoBtn.textContent = 'Auto Run';\n        if (kIndex >= n) {\n          status('Auto run finished.');\n        } else {\n          status('Auto run stopped.');\n        }\n      }\n\n      function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }\n\n      // Path reconstruction using nextMat\n      function reconstructPath(u, v) {\n        if (!initialized || kIndex < n) {\n          // allow path reconstruction only after completion ideally\n        }\n        if (nextMat[u][v] === null || nextMat[u][v] === undefined) {\n          return null;\n        }\n        const path = [u];\n        let cur = u;\n        while (cur !== v) {\n          cur = nextMat[cur][v];\n          if (cur === null || cur === undefined) return null; // no path\n          path.push(cur);\n          if (path.length > n+5) break; // safety\n        }\n        return path;\n      }\n\n      // UI actions\n      applyNBtn.addEventListener('click', () => {\n        const val = Number(nodeCountInput.value);\n        if (!val || val < 2 || val > maxNodes) {\n          alert('Choose node count between 2 and ' + maxNodes);\n          return;\n        }\n        n = val;\n        directed = directedCheckbox.checked;\n        adj = createEmptyMatrix(n, INF());\n        for (let i=0;i<n;i++) adj[i][i]=0;\n        buildAdjUI();\n        renderMatrices();\n        initialized = false;\n        status('Graph size changed. Edit adjacency and click Initialize.');\n      });\n\n      randomBtn.addEventListener('click', () => {\n        n = Number(nodeCountInput.value);\n        directed = directedCheckbox.checked;\n        adj = createEmptyMatrix(n, INF());\n        for (let i=0;i<n;i++){\n          for (let j=0;j<n;j++){\n            if (i === j) { adj[i][j]=0; continue; }\n            if (Math.random() < 0.45) {\n              const w = Math.floor(Math.random()*9)+1;\n              adj[i][j]=w;\n            } else {\n              adj[i][j]=INF();\n            }\n          }\n        }\n        if (!directed) {\n          for (let i=0;i<n;i++){\n            for (let j=i+1;j<n;j++){\n              if (!isInf(adj[i][j])) adj[j][i]=adj[i][j];\n              else if (!isInf(adj[j][i])) adj[i][j]=adj[j][i];\n            }\n          }\n        }\n        buildAdjUI();\n        updateAdjUIFromMatrix();\n        initialized = false;\n        status('Random graph generated. Click Initialize to start.');\n      });\n\n      clearBtn.addEventListener('click', () => {\n        n = Number(nodeCountInput.value);\n        adj = createEmptyMatrix(n, INF());\n        for (let i=0;i<n;i++) adj[i][i]=0;\n        buildAdjUI();\n        initialized = false;\n        status('Cleared adjacency. Edit weights and Initialize.');\n      });\n\n      initBtn.addEventListener('click', () => {\n        directed = directedCheckbox.checked;\n        initFromAdj();\n      });\n\n      stepBtn.addEventListener('click', () => {\n        if (!initialized) { status('Initialize first.'); return; }\n        if (kIndex >= n) {\n          status('Algorithm already finished.');\n          return;\n        }\n        runningAuto = false;\n        autoBtn.textContent = 'Auto Run';\n        const res = stepOnce();\n        if (res.done) status('Algorithm finished.');\n      });\n\n      runBtn.addEventListener('click', () => {\n        if (!initialized) { status('Initialize first.'); return; }\n        runningAuto = false; autoBtn.textContent = 'Auto Run';\n        runAll();\n      });\n\n      autoBtn.addEventListener('click', () => {\n        autoRun();\n      });\n\n      resetBtn.addEventListener('click', () => {\n        if (!initialAdjSnapshot) {\n          status('No initial snapshot. Initialize first to be able to reset.');\n          return;\n        }\n        adj = initialAdjSnapshot.map(r=>r.slice());\n        updateAdjUIFromMatrix();\n        initFromAdj();\n        status('Reset to initial adjacency snapshot.');\n        log('Reset to initial adjacency snapshot.');\n      });\n\n      showPathBtn.addEventListener('click', () => {\n        const u = Number(srcSelect.value), v = Number(tgtSelect.value);\n        if (isNaN(u) || isNaN(v)) return;\n        if (!initialized || kIndex < n) {\n          if (!confirm('Algorithm not finished. Proceed to attempt path reconstruction from current \"next\" matrix?')) {\n            return;\n          }\n        }\n        const path = reconstructPath(u, v);\n        if (!path) {\n          status(`No path from v${u} to v${v}`);\n          log(`Path query: v${u} -> v${v} : no path.`);\n          return;\n        }\n        const nodes = path.map(x=>'v'+x).join(' → ');\n        const total = dist[u][v];\n        status(`Path: ${nodes} (cost ${formatVal(total)})`);\n        log(`Path query: v${u} -> v${v} : ${nodes} (cost ${formatVal(total)})`);\n        // highlight path cells in matrices temporarily\n        highlightPath(path);\n      });\n\n      function highlightPath(path) {\n        // mark the sequence of (i,j) pairs in the dist/next matrix by temporarily adding \"updated\" class\n        const updatedPairs = [];\n        for (let t=0;t<path.length-1;t++) {\n          updatedPairs.push({i:path[t], j:path[t+1]});\n        }\n        renderMatrices({updated: {i:-1,j:-1}}); // base render\n        // Add overlay highlight\n        const distCells = distContainer.querySelectorAll('tbody tr');\n        updatedPairs.forEach(p => {\n          const row = distContainer.querySelector('tbody').children[p.i];\n          if (row) {\n            const cell = row.children[p.j+1]; // +1 offset for row header\n            if (cell) cell.classList.add('updated');\n          }\n        });\n        setTimeout(()=> renderMatrices(), 900);\n      }\n\n      // initialize UI at load\n      (function initUI() {\n        // default adjacency\n        adj = createEmptyMatrix(n, INF());\n        for (let i=0;i<n;i++) adj[i][i]=0;\n        // example edges for first load\n        const example = [\n          [0,3,8,INF(),-4],\n          [INF(),0,INF(),1,7],\n          [INF(),4,0,INF(),INF()],\n          [2,INF(),-5,0,INF()],\n          [INF(),INF(),INF(),6,0]\n        ];\n        if (n === 5) adj = example;\n        buildAdjUI();\n        renderMatrices();\n        populateNodeSelectors();\n        status('Edit adjacency or load random graph, then click Initialize.');\n      })();\n\n      // helper to update adjacency UI and matrices when directed toggle changes\n      directedCheckbox.addEventListener('change', () => {\n        directed = directedCheckbox.checked;\n        status('Graph direction toggled. Edit adjacency if desired and Initialize.');\n      });\n\n      // Keyboard shortcuts: Space for step, R for run all\n      document.addEventListener('keydown', (e) => {\n        if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT')) return;\n        if (e.code === 'Space') {\n          e.preventDefault();\n          stepBtn.click();\n        } else if (e.key.toLowerCase() === 'r') {\n          runBtn.click();\n        }\n      });\n\n    })();\n  </script>\n</body>\n</html>"
