    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Floyd-Warshall Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        table {\n            border-collapse: collapse;\n            margin-bottom: 20px;\n        }\n        td {\n            border: 1px solid #444;\n            padding: 10px;\n            text-align: center;\n            width: 50px;\n        }\n        input {\n            width: 55px;\n        }\n        #output {\n            margin-top: 20px;\n            font-size: 1.2em;\n        }\n    </style>\n</head>\n<body>\n    <h1>Floyd-Warshall Algorithm Visualizer</h1>\n    <table id=\"matrix\"></table>\n    <button onclick=\"runFloydWarshall()\">Run Floyd-Warshall Algorithm</button>\n    <div id=\"output\"></div>\n\n    <script>\n        const numVertices = 4;\n        const inf = Infinity;\n\n        // Build the initial adjacency matrix\n        let dist = [\n            [0, 3, inf, 7],\n            [inf, 0, 1, inf],\n            [inf, inf, 0, 2],\n            [6, inf, inf, 0]\n        ];\n\n        // Function to create and display the matrix in a table\n        function createMatrixTable() {\n            const table = document.getElementById('matrix');\n            table.innerHTML = '';\n            for (let i = 0; i < numVertices; i++) {\n                const row = document.createElement('tr');\n                for (let j = 0; j < numVertices; j++) {\n                    const cell = document.createElement('td');\n                    if (dist[i][j] === inf) {\n                        cell.innerHTML = '∞';\n                    } else {\n                        cell.innerHTML = dist[i][j];\n                    }\n                    row.appendChild(cell);\n                }\n                table.appendChild(row);\n            }\n        }\n\n        // Function to run the Floyd-Warshall algorithm\n        function runFloydWarshall() {\n            let distances = JSON.parse(JSON.stringify(dist)); // deep copy of the distance array\n            \n            for (let k = 0; k < numVertices; k++) {\n                for (let i = 0; i < numVertices; i++) {\n                    for (let j = 0; j < numVertices; j++) {\n                        if (distances[i][k] !== inf && distances[k][j] !== inf) {\n                            distances[i][j] = Math.min(distances[i][j], distances[i][k] + distances[k][j]);\n                        }\n                    }\n                }\n            }\n            displayOutput(distances);\n        }\n\n        // Function to display the final results on the page\n        function displayOutput(result) {\n            let outputDiv = document.getElementById('output');\n            outputDiv.innerHTML = '<h2>Shortest Path Distances</h2>';\n            const resultTable = document.createElement('table');\n\n            for (let i = 0; i < numVertices; i++) {\n                const row = document.createElement('tr');\n                for (let j = 0; j < numVertices; j++) {\n                    const cell = document.createElement('td');\n                    if (result[i][j] === inf) {\n                        cell.innerHTML = '∞';\n                    } else {\n                        cell.innerHTML = result[i][j];\n                    }\n                    row.appendChild(cell);\n                }\n                resultTable.appendChild(row);\n            }\n            outputDiv.appendChild(resultTable);\n        }\n\n        // Initialize the matrix display\n        createMatrixTable();\n    </script>\n</body>\n</html>"
