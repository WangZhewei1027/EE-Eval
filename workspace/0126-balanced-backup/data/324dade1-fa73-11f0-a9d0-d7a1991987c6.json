    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Exponential Search Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n            background-color: #f4f4f4;\n            border-radius: 8px;\n        }\n        input[type=\"number\"], input[type=\"text\"], button {\n            padding: 10px;\n            margin: 10px 0;\n        }\n        .output {\n            margin-top: 20px;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <h1>Exponential Search Demonstration</h1>\n    <p>Enter a sorted array and a target value to search for:</p>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"Enter sorted array (comma-separated)\">\n    <input type=\"number\" id=\"targetInput\" placeholder=\"Enter target value\">\n    <button onclick=\"performExponentialSearch()\">Search</button>\n\n    <div class=\"output\" id=\"result\"></div>\n\n    <script>\n        function exponentialSearch(arr, x) {\n            if (arr[0] === x) {\n                return 0;\n            }\n\n            let i = 1;\n            while (i < arr.length && arr[i] <= x) {\n                i *= 2;\n            }\n\n            return binarySearch(arr, Math.floor(i / 2), Math.min(i, arr.length - 1), x);\n        }\n\n        function binarySearch(arr, left, right, x) {\n            while (left <= right) {\n                let mid = Math.floor((left + right) / 2);\n                if (arr[mid] === x) {\n                    return mid;\n                }\n                if (arr[mid] < x) {\n                    left = mid + 1;\n                } else {\n                    right = mid - 1;\n                }\n            }\n            return -1;\n        }\n\n        function performExponentialSearch() {\n            const arrayInput = document.getElementById('arrayInput').value.split(',').map(num => parseInt(num.trim()));\n            const targetInput = parseInt(document.getElementById('targetInput').value);\n            const resultElement = document.getElementById('result');\n\n            if (arrayInput.length === 0 || isNaN(targetInput)) {\n                resultElement.innerHTML = \"Please enter a valid sorted array and target value.\";\n                return;\n            }\n\n            const index = exponentialSearch(arrayInput, targetInput);\n            if (index === -1) {\n                resultElement.innerHTML = \"Target value \" + targetInput + \" not found in the array.\";\n            } else {\n                resultElement.innerHTML = \"Target value \" + targetInput + \" found at index: \" + index;\n            }\n        }\n    </script>\n</body>\n</html>"
