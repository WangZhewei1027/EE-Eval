    "content": "<html>\n<head>\n  <title>TCP/IP Demonstration</title>\n  <style>\n    body {\n      font-family: monospace;\n    }\n  </style>\n</head>\n<body>\n\n<h1>TCP/IP Demonstration</h1>\n\n<div id=\"client\"></div>\n<div id=\"server\"></div>\n\n<script>\n  let clientSocket = null;\n  let serverSocket = null;\n\n  // Establish connection with server\n  function establishConnection() {\n    serverSocket = new WebSocket(\"ws://localhost:8080\");\n    console.log(\"Connected to server\");\n  }\n\n  // Receive data from server\n  function receiveData() {\n    if (clientSocket) {\n      clientSocket.send(\"Hello from client\");\n      let data = clientSocket.read().then(response => {\n        console.log(\"Received data:\", response);\n        return response;\n      });\n      return data;\n    } else {\n      console.log(\"No connection established\");\n    }\n  }\n\n  // Send data to server\n  function sendData() {\n    if (clientSocket) {\n      clientSocket.send(\"Hello from server\");\n      let data = clientSocket.read().then(response => {\n        console.log(\"Sent data:\", response);\n        return response;\n      });\n      return data;\n    } else {\n      console.log(\"No connection established\");\n    }\n  }\n\n  // Handle client connection\n  function handleClient() {\n    clientSocket.onmessage = event => {\n      console.log(\"Received message:\", event.data);\n    };\n    clientSocket.onopen = establishConnection;\n    clientSocket.onerror = event => {\n      console.log(\"Error occurred:\", event);\n    };\n    clientSocket.onclose = event => {\n      console.log(\"Connection closed\");\n    };\n  }\n\n  // Handle server connection\n  function handleServer() {\n    serverSocket.onmessage = event => {\n      console.log(\"Received message:\", event.data);\n    };\n    serverSocket.onerror = event => {\n      console.log(\"Error occurred:\", event);\n    };\n    serverSocket.onopen = establishConnection;\n    serverSocket.onclose = event => {\n      console.log(\"Connection closed\");\n    };\n  }\n\n  // Main function\n  function main() {\n    handleClient();\n    handleServer();\n  }\n\n  main();\n</script>\n\n</body>\n</html>"
