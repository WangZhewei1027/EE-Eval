    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>Quick Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            background: #f0f0f0;\n            color: #333;\n        }\n        h1 {\n            text-align: center;\n        }\n        #arrayContainer {\n            display: flex;\n            justify-content: center;\n            align-items: flex-end;\n            height: 300px;\n            margin: 20px auto;\n            width: 90%;\n            max-width: 800px;\n            background: white;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            position: relative;\n        }\n        .bar {\n            margin: 0 2px;\n            background-color: steelblue;\n            width: 20px;\n            transition: background-color 0.3s;\n            color: white;\n            font-size: 12px;\n            text-align: center;\n            user-select: none;\n            border-radius: 3px 3px 0 0;\n            position: relative;\n        }\n        .bar.pivot {\n            background-color: #d9534f;\n        }\n        .bar.compared {\n            background-color: #f0ad4e;\n        }\n        .bar.swapped {\n            background-color: #5bc0de;\n        }\n        #controls {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n        button {\n            padding: 10px 18px;\n            margin: 0 10px;\n            font-size: 16px;\n            cursor: pointer;\n            border: none;\n            border-radius: 5px;\n            background-color: steelblue;\n            color: white;\n            transition: background-color 0.3s;\n        }\n        button:hover:not(:disabled) {\n            background-color: #4682b4;\n        }\n        button:disabled {\n            background-color: #a9a9a9;\n            cursor: not-allowed;\n        }\n        #speedLabel {\n            margin-left: 10px;\n            font-size: 14px;\n        }\n        input[type=range] {\n            vertical-align: middle;\n        }\n        #explanation {\n            max-width: 800px;\n            margin: 0 auto 30px auto;\n            background: white;\n            padding: 15px 20px;\n            border-radius: 5px;\n            line-height: 1.5;\n            box-shadow: 0 0 10px #ccc;\n        }\n    </style>\n</head>\n<body>\n    <h1>Quick Sort Visualization</h1>\n    <div id=\"explanation\">\n        <strong>Quick Sort</strong> is a divide-and-conquer sorting algorithm. It works by selecting a <em>pivot</em> element from the array and partitioning the other elements into two subarrays according to whether they are less than or greater than the pivot.\n        The subarrays are then sorted recursively. This process results in a sorted array.\n    </div>\n    <div id=\"controls\">\n        <button id=\"newArrayBtn\">Generate New Array</button>\n        <button id=\"sortBtn\">Start Quick Sort</button>\n        <label for=\"speedRange\">Speed:</label>\n        <input type=\"range\" id=\"speedRange\" min=\"1\" max=\"1000\" value=\"300\" />\n        <span id=\"speedLabel\">300 ms</span>\n    </div>\n    <div id=\"arrayContainer\" aria-label=\"Array bars visualization\"></div>\n\n    <script>\n        const container = document.getElementById('arrayContainer');\n        const newArrayBtn = document.getElementById('newArrayBtn');\n        const sortBtn = document.getElementById('sortBtn');\n        const speedRange = document.getElementById('speedRange');\n        const speedLabel = document.getElementById('speedLabel');\n\n        let array = [];\n        let speed = 300; // milliseconds\n        const maxElements = 30;\n        const minVal = 5;\n        const maxVal = 100;\n\n        function sleep(ms) {\n            return new Promise(resolve => setTimeout(resolve, ms));\n        }\n\n        function generateArray() {\n            array = [];\n            for (let i = 0; i < maxElements; i++) {\n                array.push(Math.floor(Math.random() * (maxVal - minVal + 1)) + minVal);\n            }\n            renderArray();\n        }\n\n        function renderArray(highlight = {}) {\n            // highlight: {pivot: index, compared: [i,j], swapped: [i,j]}\n            container.innerHTML = '';\n            for (let i = 0; i < array.length; i++) {\n                const bar = document.createElement('div');\n                bar.classList.add('bar');\n                bar.style.height = (array[i] * 3) + 'px'; // scale height for visibility\n                bar.textContent = array[i];\n\n                if (highlight.pivot === i) {\n                    bar.classList.add('pivot');\n                    bar.title = \"Pivot\";\n                }\n                if (highlight.compared && highlight.compared.includes(i)) {\n                    bar.classList.add('compared');\n                    bar.title = \"Compared\";\n                }\n                if (highlight.swapped && highlight.swapped.includes(i)) {\n                    bar.classList.add('swapped');\n                    bar.title = \"Swapped\";\n                }\n\n                container.appendChild(bar);\n            }\n        }\n\n        async function quickSort(arr, left, right) {\n            if (left < right) {\n                let partitionIndex = await partition(arr, left, right);\n                await quickSort(arr, left, partitionIndex - 1);\n                await quickSort(arr, partitionIndex + 1, right);\n            }\n        }\n\n        async function partition(arr, left, right) {\n            let pivotValue = arr[right];\n            let i = left - 1;\n            renderArray({ pivot: right }); \n            await sleep(speed);\n\n            for (let j = left; j < right; j++) {\n                renderArray({ pivot: right, compared: [j, i] });\n                await sleep(speed);\n                if (arr[j] < pivotValue) {\n                    i++;\n                    [arr[i], arr[j]] = [arr[j], arr[i]];\n                    renderArray({ pivot: right, swapped: [i, j] });\n                    await sleep(speed);\n                }\n            }\n            [arr[i + 1], arr[right]] = [arr[right], arr[i + 1]];\n            renderArray({ pivot: i + 1, swapped: [i+1, right] });\n            await sleep(speed);\n            return i + 1;\n        }\n\n        function disableButtons(state) {\n            newArrayBtn.disabled = state;\n            sortBtn.disabled = state;\n        }\n\n        newArrayBtn.addEventListener('click', () => {\n            generateArray();\n        });\n\n        sortBtn.addEventListener('click', async () => {\n            disableButtons(true);\n            await quickSort(array, 0, array.length - 1);\n            renderArray();\n            disableButtons(false);\n        });\n\n        speedRange.addEventListener('input', () => {\n            speed = 1001 - speedRange.value; // higher range value => faster speed (lower delay)\n            speedLabel.textContent = speed + ' ms';\n        });\n\n        // Initialize\n        generateArray();\n        speedLabel.textContent = speed + ' ms';\n    </script>\n</body>\n</html>"
