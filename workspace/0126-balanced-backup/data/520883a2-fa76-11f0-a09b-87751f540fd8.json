    "content": "<html>\n<head>\n    <title>Heap (Max)</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #heap {\n            width: 300px;\n            height: 200px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            padding: 20px;\n            margin: 40px auto;\n            text-align: center;\n        }\n        #heap input[type=\"number\"] {\n            width: 100%;\n            height: 30px;\n            margin-bottom: 10px;\n            padding: 5px;\n            font-size: 18px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Heap (Max)</h1>\n    <div id=\"heap\"></div>\n    <input type=\"number\" id=\"input\" value=\"5\">\n    <button onclick=\"heapifyUp()\">Heapify Up</button>\n    <button onclick=\"heapifyDown()\">Heapify Down</button>\n\n    <script>\n        function heapifyUp() {\n            let n = parseInt(document.getElementById('input').value);\n            let temp = n;\n            while (temp > 1) {\n                let parent = Math.floor(temp / 2);\n                if (n > parent) {\n                    let tempValue = n;\n                    let temp2Value = parent;\n                    if (n > parent) {\n                        if (n > parent * 2) {\n                            tempValue = parent * 2;\n                        } else {\n                            tempValue = parent * 2 + 1;\n                        }\n                    }\n                    if (tempValue < temp2Value) {\n                        let temp3 = temp;\n                        let temp4 = temp2;\n                        if (tempValue < temp) {\n                            temp3 = temp;\n                            temp4 = temp2;\n                        }\n                        if (tempValue < temp2Value) {\n                            tempValue = temp2Value;\n                            temp2Value = temp3;\n                        }\n                        [temp, temp2] = [temp2, temp3];\n                        temp = temp2Value;\n                        temp2 = temp4;\n                    }\n                    temp = tempValue;\n                }\n                n = temp;\n            }\n        }\n\n        function heapifyDown() {\n            let n = parseInt(document.getElementById('input').value);\n            let temp = n;\n            let left = 2 * temp;\n            let right = 2 * temp + 1;\n            let smallest = temp;\n            if (left < n && parseInt(document.getElementById('heap').innerHTML) < parseInt(document.getElementById('heap').innerHTML).split(' ')[left - 1]) {\n                smallest = left;\n                if (right < n && parseInt(document.getElementById('heap').innerHTML) < parseInt(document.getElementById('heap').innerHTML).split(' ')[right - 1]) {\n                    smallest = right;\n                }\n            }\n            if (smallest < n) {\n                let tempValue = parseInt(document.getElementById('heap').innerHTML);\n                let temp2Value = parseInt(document.getElementById('heap').innerHTML).split(' ')[smallest - 1];\n                if (smallest < left) {\n                    let temp3 = parseInt(document.getElementById('heap').innerHTML);\n                    let temp4 = parseInt(document.getElementById('heap').innerHTML).split(' ')[smallest - 1];\n                    if (smallest < left) {\n                        tempValue = parseInt(document.getElementById('heap').innerHTML).split(' ')[left - 1];\n                        temp2Value = temp3;\n                        temp3 = temp4;\n                    }\n                    if (smallest < right) {\n                        tempValue = parseInt(document.getElementById('heap').innerHTML).split(' ')[right - 1];\n                        temp2Value = temp3;\n                        temp3 = temp4;\n                    }\n                    [temp, temp2] = [temp2, temp3];\n                    temp = temp2Value;\n                    temp2 = temp4;\n                }\n                temp = smallest;\n                temp2 = temp4;\n            }\n            temp = smallest;\n            temp2 = temp4;\n            if (temp < n) {\n                let temp3 = temp;\n                let temp4 = temp2;\n                if (temp < left) {\n                    temp3 = left;\n                    temp4 = left + 1;\n                }\n                if (temp < right) {\n                    temp3 = right;\n                    temp4 = right + 1;\n                }\n                [temp, temp2] = [temp2, temp3];\n                temp = temp2Value;\n                temp2 = temp4Value;\n            }\n            temp = tempValue;\n            temp2 = temp4Value;\n            document.getElementById('heap').innerHTML = temp + ' ' + temp2;\n        }\n    </script>\n</body>\n</html>"
