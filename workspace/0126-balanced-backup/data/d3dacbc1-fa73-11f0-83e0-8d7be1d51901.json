    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<title>Refactoring Demo — Interactive Single-File</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<style>\n  :root{--bg:#0f1724;--card:#0b1220;--muted:#9aa7b3;--accent:#7dd3fc;--good:#10b981;--bad:#f43f5e;--panel:#071022}\n  body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;background:linear-gradient(180deg,#071022 0%, #071a2a 100%);color:#e6eef6}\n  header{padding:18px 22px;border-bottom:1px solid rgba(255,255,255,0.03);display:flex;align-items:center;gap:14px}\n  header h1{font-size:18px;margin:0}\n  .container{display:grid;grid-template-columns:1fr 420px;gap:18px;padding:18px;align-items:start}\n  .card{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:8px;padding:12px;border:1px solid rgba(255,255,255,0.03)}\n  .editorWrap{display:flex;gap:12px}\n  textarea{width:100%;height:420px;background:transparent;color:#e6eef6;border:1px solid rgba(255,255,255,0.03);padding:12px;border-radius:6px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px;line-height:1.45;resize:vertical}\n  .controls{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0}\n  button{background:linear-gradient(180deg,#0b6b90,#075a78);color:white;border:0;padding:8px 10px;border-radius:6px;cursor:pointer;font-weight:600}\n  button.secondary{background:linear-gradient(180deg,#1f2937,#0f1724);}\n  button.ghost{background:transparent;border:1px solid rgba(255,255,255,0.04);font-weight:600}\n  .small{padding:6px 8px;font-size:13px}\n  .opts{display:flex;flex-direction:column;gap:6px;margin-top:8px}\n  label.opt{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,0.01);padding:8px;border-radius:6px}\n  .muted{color:var(--muted);font-size:13px}\n  .rightCol{position:sticky;top:18px;height:calc(100vh - 36px);overflow:auto;padding:12px}\n  h2{margin:6px 0 10px 0;font-size:15px}\n  pre{white-space:pre-wrap;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;background:rgba(255,255,255,0.02);padding:8px;border-radius:6px;color:#e6eef6}\n  .testResult{display:flex;gap:8px;align-items:center}\n  .ok{color:var(--good);font-weight:700}\n  .fail{color:var(--bad);font-weight:700}\n  .steps{margin-top:10px;display:flex;flex-direction:column;gap:6px}\n  .step{background:rgba(255,255,255,0.02);padding:8px;border-radius:6px;border-left:4px solid rgba(255,255,255,0.03);}\n  .diff{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;background:#011627;padding:10px;border-radius:6px;color:#dbe7ee;overflow:auto;max-height:180px}\n  footer{padding:12px 18px;font-size:13px;color:var(--muted);border-top:1px solid rgba(255,255,255,0.03)}\n  .legend{display:flex;gap:8px;align-items:center;font-size:13px;margin-top:6px}\n  .chip{padding:4px 8px;border-radius:999px;background:rgba(255,255,255,0.03)}\n  .badge{font-weight:700;padding:4px 8px;border-radius:6px;background:rgba(255,255,255,0.02)}\n  .flex{display:flex;gap:8px;align-items:center}\n</style>\n</head>\n<body>\n<header>\n  <div style=\"width:44px;height:44px;border-radius:8px;background:linear-gradient(180deg,#08385a,#0b2a3a);display:flex;align-items:center;justify-content:center;font-weight:800;color:#7dd3fc\">RF</div>\n  <div>\n    <h1>Refactoring — interactive demo</h1>\n    <div class=\"muted\">See how small, safe refactors improve readability and maintain behavior.</div>\n  </div>\n</header>\n\n<div class=\"container\">\n  <div class=\"card\">\n    <div style=\"display:flex;justify-content:space-between;align-items:center\">\n      <div>\n        <h2>Before ↔ After editors</h2>\n        <div class=\"muted\">Edit the example code, toggle transforms, then run refactors and tests.</div>\n      </div>\n      <div class=\"legend\">\n        <span class=\"chip\">Demo-only</span>\n        <span class=\"badge\">JS</span>\n      </div>\n    </div>\n\n    <div style=\"margin-top:10px\" class=\"editorWrap\">\n      <div style=\"flex:1;display:flex;flex-direction:column;gap:8px\">\n        <div style=\"display:flex;gap:8px;align-items:center\">\n          <strong>Original</strong>\n          <div class=\"muted\">editable source</div>\n        </div>\n        <textarea id=\"originalArea\"></textarea>\n      </div>\n\n      <div style=\"width:420px;display:flex;flex-direction:column;gap:8px\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <strong>Refactored</strong>\n          <div class=\"muted\">auto-generated</div>\n        </div>\n        <textarea id=\"refactoredArea\" readonly></textarea>\n      </div>\n    </div>\n\n    <div class=\"controls\">\n      <button id=\"applyAll\">Apply All Refactors</button>\n      <button id=\"applySelected\" class=\"secondary\">Apply Selected</button>\n      <button id=\"undo\" class=\"ghost small\">Undo</button>\n      <button id=\"runTests\" class=\"small\">Run Tests</button>\n      <button id=\"showSteps\" class=\"small ghost\">Show Steps</button>\n    </div>\n\n    <div style=\"display:flex;gap:12px;align-items:flex-start\">\n      <div style=\"flex:1\">\n        <div class=\"opts card\" style=\"padding:10px\">\n          <label class=\"opt\"><input type=\"checkbox\" id=\"t_guard\" checked /> Introduce guard clause (empty input)</label>\n          <label class=\"opt\"><input type=\"checkbox\" id=\"t_extract\" checked /> Extract computeItemTotal() function</label>\n          <label class=\"opt\"><input type=\"checkbox\" id=\"t_constants\" checked /> Replace magic numbers with constants</label>\n          <label class=\"opt\"><input type=\"checkbox\" id=\"t_varlet\" checked /> Use let/const instead of var</label>\n          <label class=\"opt\"><input type=\"checkbox\" id=\"t_format\" checked /> Basic formatting (indentation)</label>\n        </div>\n      </div>\n\n      <div style=\"width:320px\">\n        <div class=\"card\">\n          <h2>Quick tests</h2>\n          <div class=\"muted\">Runs a few cases on both original and refactored functions to confirm behavior is preserved.</div>\n          <div style=\"margin-top:8px\">\n            <button id=\"runTests2\" class=\"small\">Run Tests (also)</button>\n          </div>\n          <div id=\"testOutput\" style=\"margin-top:10px\"></div>\n        </div>\n\n        <div class=\"card\" style=\"margin-top:12px\">\n          <h2>Refactor steps</h2>\n          <div class=\"muted\">Click \"Show Steps\" to view the sequence applied when \"All\" is used.</div>\n          <div id=\"steps\" class=\"steps\" style=\"margin-top:8px;max-height:220px;overflow:auto\"></div>\n        </div>\n      </div>\n    </div>\n\n    <div style=\"margin-top:12px\">\n      <h2>About this demo</h2>\n      <div class=\"muted\">This single-file demo applies a few automated, safe refactors to a sample invoicing function. The transforms are simple, pattern-based, and meant to illustrate ideas — real-world refactors typically use AST tools (TypeScript, Babel, clang) and tests to ensure safety.</div>\n    </div>\n  </div>\n\n  <aside class=\"rightCol\">\n    <div class=\"card\">\n      <h2>What is Refactoring?</h2>\n      <div class=\"muted\">Refactoring is the disciplined technique of restructuring existing code — changing its internal structure without altering external behavior. Benefits:</div>\n      <ul style=\"margin-top:8px\">\n        <li>Improve readability and intent</li>\n        <li>Reduce duplication</li>\n        <li>Isolate responsibilities (single responsibility)</li>\n        <li>Make testing and future changes easier</li>\n        <li>Enable safer enhancements</li>\n      </ul>\n\n      <h2 style=\"margin-top:12px\">Refactor patterns shown</h2>\n      <ul>\n        <li>Introduce guard clause</li>\n        <li>Extract function</li>\n        <li>Replace magic numbers with named constants</li>\n        <li>Use let/const</li>\n        <li>Basic formatting & clearer variable names</li>\n      </ul>\n\n      <h2 style=\"margin-top:12px\">Safety tips</h2>\n      <ol>\n        <li>Have tests (unit/integration) covering behavior before refactor</li>\n        <li>Refactor in small steps and commit often</li>\n        <li>Prefer renames & extractions over rewriting logic</li>\n        <li>Run tests after each change</li>\n      </ol>\n\n      <div style=\"margin-top:12px\" class=\"muted\">This demo runs tests automatically and compares the outputs before and after refactor to demonstrate behavior preservation for these examples.</div>\n    </div>\n\n    <div class=\"card\" style=\"margin-top:12px\">\n      <h2>Diff (simple)</h2>\n      <div id=\"diffBox\" class=\"diff\">Press \"Apply All Refactors\" to see a line-by-line comparison.</div>\n    </div>\n  </aside>\n</div>\n\n<footer>\n  Built for learning: small, safe, reversible refactors. This page performs text-based transforms for demonstration; it is not a full AST refactoring tool.\n</footer>\n\n<script>\n/*\n  Interactive Refactoring Demo\n  - Provides an editable original JS snippet and an auto-generated refactored version.\n  - Applies several simple, pattern-based transformations.\n  - Runs tests to ensure behavior is preserved for sample inputs.\n  - Demo-only: transformations are intentionally simple and tailored to the example.\n*/\n\nconst originalExample = `// calculateOrderTotal: messy but working\nfunction calculateOrderTotal(items, customerType) {\n  var total = 0;\n  for (var i = 0; i < items.length; i++) {\n    var item = items[i];\n    var price = item.price;\n    if (item.discount && item.discount > 0) {\n      price = price - price * item.discount;\n    }\n    total += price * item.quantity;\n  }\n  if (customerType === 'vip') {\n    total = total * 0.9;\n  } else if (customerType === 'employee') {\n    total = total * 0.8;\n  }\n  var tax = total * 0.07;\n  total = total + tax;\n  return Math.round(total * 100) / 100;\n}`;\n\n// DOM refs\nconst originalArea = document.getElementById('originalArea');\nconst refactoredArea = document.getElementById('refactoredArea');\nconst applyAllBtn = document.getElementById('applyAll');\nconst applySelectedBtn = document.getElementById('applySelected');\nconst undoBtn = document.getElementById('undo');\nconst runTestsBtn = document.getElementById('runTests');\nconst runTestsBtn2 = document.getElementById('runTests2');\nconst showStepsBtn = document.getElementById('showSteps');\nconst stepsEl = document.getElementById('steps');\nconst testOutput = document.getElementById('testOutput');\nconst diffBox = document.getElementById('diffBox');\n\n// checkboxes\nconst t_guard = document.getElementById('t_guard');\nconst t_extract = document.getElementById('t_extract');\nconst t_constants = document.getElementById('t_constants');\nconst t_varlet = document.getElementById('t_varlet');\nconst t_format = document.getElementById('t_format');\n\nlet history = [];\nfunction pushHistory(code) { history.push(code); if (history.length > 20) history.shift(); }\n\noriginalArea.value = originalExample;\nrefactoredArea.value = originalExample;\npushHistory(originalExample);\n\n// Basic transforms (pattern-based, demonstration-only)\nfunction introduceGuardClause(code) {\n  // If the function lacks an early return for empty items, add it after function signature.\n  return code.replace(/function\\s+calculateOrderTotal\\s*\\(\\s*items\\s*,\\s*customerType\\s*\\)\\s*{/, m => m + '\\n  if (!items || items.length === 0) {\\n    return 0;\\n  }\\n');\n}\n\nfunction extractComputeItemTotal(code) {\n  // Create computeItemTotal and replace repeated logic in loop with call.\n  // This is a simple textual transform designed for this example.\n  if (code.includes('function computeItemTotal')) return code; // already extracted\n\n  // Insert helper before main function end or after start\n  let helper = `\nfunction computeItemTotal(item) {\n  let price = item.price;\n  if (item.discount && item.discount > 0) {\n    price -= price * item.discount;\n  }\n  return price * item.quantity;\n}\n`;\n\n  // Replace loop body that computed item price and total\n  let newCode = code.replace(/for\\s*\\(\\s*let\\s*i\\s*=\\s*0;|for\\s*\\(\\s*var\\s*i\\s*=\\s*0;/, m => {\n    // ensure var -> let for new for loop if needed (we may change var later)\n    return m;\n  });\n\n  // Replace the repeated logic in the loop with: total += computeItemTotal(item);\n  newCode = newCode.replace(/for\\s*\\(\\s*.*?\\)\\s*{\\s*?var\\s+item\\s*=\\s*items\\[(?:.*?)\\];\\s*var\\s+price\\s*=\\s*item\\.price;\\s*if\\s*\\(item\\.discount\\s*&\\&\\s*item\\.discount\\s*>\\s*0\\)\\s*{\\s*price\\s*=\\s*price\\s*-\\s*price\\s*\\*\\s*item\\.discount;\\s*}\\s*total\\s*\\+=\\s*price\\s*\\*\\s*item\\.quantity;\\s*}/s, match => {\n    // This regex is fragile but okay for the demo snippet\n    return match.replace(/var\\s+price\\s*=.*?total\\s*\\+=\\s*price\\s*\\*\\s*item\\.quantity;/s, 'total += computeItemTotal(item);');\n  });\n\n  // If the above replacement didn't match (slightly different spacing), fall back to simpler replacement:\n  if (newCode === code) {\n    newCode = code.replace(/total\\s*\\+=\\s*price\\s*\\*\\s*item\\.quantity\\s*;/, 'total += computeItemTotal(item);');\n  }\n\n  // Prepend helper function at top (just before the main function)\n  newCode = helper + '\\n' + newCode;\n  return newCode;\n}\n\nfunction replaceMagicNumbersWithConstants(code) {\n  // Add constants block at top if not present\n  let consts = `const TAX_RATE = 0.07;\nconst VIP_DISCOUNT = 0.10;\nconst EMPLOYEE_DISCOUNT = 0.20;\n`;\n  if (!/TAX_RATE/.test(code)) {\n    code = consts + '\\n' + code;\n  }\n  // Replace multiplications and explicit numbers with named constants (targeting our example)\n  // Replace total = total * 0.9 -> total *= (1 - VIP_DISCOUNT)\n  code = code.replace(/total\\s*=\\s*total\\s*\\*\\s*0\\.9\\b/g, 'total *= (1 - VIP_DISCOUNT)');\n  code = code.replace(/total\\s*=\\s*total\\s*\\*\\s*0\\.8\\b/g, 'total *= (1 - EMPLOYEE_DISCOUNT)');\n  // Replace var tax = total * 0.07; -> var tax = total * TAX_RATE;\n  code = code.replace(/(\\bvar|\\blet|\\bconst)\\s+tax\\s*=\\s*total\\s*\\*\\s*0\\.07\\b/g, '$1 tax = total * TAX_RATE');\n  return code;\n}\n\nfunction convertVarToLetConst(code) {\n  // Naive conversion: convert var declarations to let, but for variables that are never reassigned we could pick const.\n  // For demo we replace var with let and then convert obvious constants like function declarations untouched.\n  code = code.replace(/\\bvar\\b/g, 'let');\n  return code;\n}\n\nfunction basicFormat(code) {\n  // Very simple formatting: normalize indentation for braces and spaces.\n  // We'll do:\n  // - ensure opening brace has newline after (handled)\n  // - add two spaces indentation per block level\n  const lines = code.split('\\n');\n  let indent = 0;\n  const out = [];\n  for (let raw of lines) {\n    let line = raw.trimEnd();\n    // decrease indent on closing brace\n    if (/^\\}/.test(line)) indent = Math.max(0, indent - 1);\n    let pad = '  '.repeat(indent);\n    out.push(pad + line.trimStart());\n    if (/\\{$/.test(line)) indent++;\n  }\n  return out.join('\\n');\n}\n\n// Compose transforms\nfunction applyTransforms(code, options, recordSteps=true) {\n  const steps = [];\n  let result = code;\n  if (options.guard) {\n    result = introduceGuardClause(result);\n    if (recordSteps) steps.push('Introduce guard clause for empty items');\n  }\n  if (options.extract) {\n    result = extractComputeItemTotal(result);\n    if (recordSteps) steps.push('Extract computeItemTotal(item) to remove duplication');\n  }\n  if (options.constants) {\n    result = replaceMagicNumbersWithConstants(result);\n    if (recordSteps) steps.push('Replace magic numbers with named constants (TAX_RATE, VIP_DISCOUNT, EMPLOYEE_DISCOUNT)');\n  }\n  if (options.varlet) {\n    result = convertVarToLetConst(result);\n    if (recordSteps) steps.push('Replace var with let/const (basic)');\n  }\n  if (options.format) {\n    result = basicFormat(result);\n    if (recordSteps) steps.push('Apply basic formatting and indentation');\n  }\n  return { code: result, steps };\n}\n\n// Simple sandboxed runner: evaluate code and return calculateOrderTotal function\nfunction getFunctionFromCode(code) {\n  try {\n    // We create a new function scope so constants and helpers don't leak across runs\n    const wrapper = new Function(code + '\\nreturn typeof calculateOrderTotal === \"function\" ? calculateOrderTotal : null;');\n    const fn = wrapper();\n    if (typeof fn !== 'function') {\n      throw new Error('calculateOrderTotal not found or not a function');\n    }\n    return { fn };\n  } catch (err) {\n    return { error: err.toString() };\n  }\n}\n\n// Test harness\nconst testCases = [\n  {\n    name: 'Single item, no discount, regular customer',\n    items: [{ price: 10, quantity: 2 }],\n    customerType: 'regular',\n  },\n  {\n    name: 'Two items, with item discount, VIP customer',\n    items: [{ price: 50, quantity: 1, discount: 0.1 }, { price: 20, quantity: 3 }],\n    customerType: 'vip',\n  },\n  {\n    name: 'Employee customer, no items',\n    items: [],\n    customerType: 'employee'\n  },\n  {\n    name: 'Item with discount zero',\n    items: [{ price: 15, quantity: 1, discount: 0 }],\n    customerType: 'regular'\n  }\n];\n\nfunction runTestsOnCode(code) {\n  const mk = getFunctionFromCode(code);\n  if (mk.error) {\n    return { error: mk.error };\n  }\n  const fn = mk.fn;\n  const results = [];\n  for (const tc of testCases) {\n    try {\n      const out = fn(tc.items, tc.customerType);\n      results.push({ name: tc.name, out });\n    } catch (err) {\n      return { error: err.toString() };\n    }\n  }\n  return { results };\n}\n\nfunction compareTestResults(resA, resB) {\n  if (resA.error || resB.error) return false;\n  if (resA.results.length !== resB.results.length) return false;\n  for (let i = 0; i < resA.results.length; i++) {\n    if (String(resA.results[i].out) !== String(resB.results[i].out)) return false;\n  }\n  return true;\n}\n\nfunction showTestOutput(originalCode, refactCode) {\n  testOutput.innerHTML = '';\n  const orig = runTestsOnCode(originalCode);\n  const ref = runTestsOnCode(refactCode);\n\n  function renderResult(title, obj) {\n    const div = document.createElement('div');\n    div.className = 'card';\n    div.style.padding = '8px';\n    div.style.marginBottom = '8px';\n    const h = document.createElement('div');\n    h.style.fontWeight = '700';\n    h.style.marginBottom = '6px';\n    h.textContent = title;\n    div.appendChild(h);\n    if (obj.error) {\n      const e = document.createElement('pre');\n      e.textContent = 'Error: ' + obj.error;\n      e.style.color = 'var(--bad)';\n      div.appendChild(e);\n    } else {\n      const ul = document.createElement('div');\n      for (const r of obj.results) {\n        const row = document.createElement('div');\n        row.style.display = 'flex';\n        row.style.justifyContent = 'space-between';\n        row.style.padding = '4px 0';\n        row.innerHTML = `<div class=\"muted\" style=\"flex:1\"><strong>${r.name}</strong></div><div style=\"min-width:90px;text-align:right\">${r.out}</div>`;\n        ul.appendChild(row);\n      }\n      div.appendChild(ul);\n    }\n    return div;\n  }\n\n  testOutput.appendChild(renderResult('Original function', orig));\n  testOutput.appendChild(renderResult('Refactored function', ref));\n\n  const ok = !orig.error && !ref.error && compareTestResults(orig, ref);\n  const summary = document.createElement('div');\n  summary.style.marginTop = '8px';\n  summary.className = 'testResult';\n  summary.innerHTML = ok ? `<div class=\"ok\">PASS</div><div class=\"muted\">Behavior preserved for demo test cases.</div>` : `<div class=\"fail\">FAIL</div><div class=\"muted\">Outputs differ or error occurred. Review the code and tests.</div>`;\n  testOutput.appendChild(summary);\n}\n\n// Simple line diff for demo\nfunction simpleDiff(a, b) {\n  const aLines = a.split('\\n');\n  const bLines = b.split('\\n');\n  const max = Math.max(aLines.length, bLines.length);\n  const lines = [];\n  for (let i = 0; i < max; i++) {\n    const al = aLines[i] || '';\n    const bl = bLines[i] || '';\n    if (al === bl) {\n      lines.push('  ' + al);\n    } else {\n      if (al) lines.push('- ' + al);\n      if (bl) lines.push('+ ' + bl);\n    }\n  }\n  return lines.join('\\n');\n}\n\n// UI actions\nfunction applySelectedTransforms() {\n  const code = originalArea.value;\n  pushHistory(code);\n  const opts = {\n    guard: t_guard.checked,\n    extract: t_extract.checked,\n    constants: t_constants.checked,\n    varlet: t_varlet.checked,\n    format: t_format.checked\n  };\n  const { code: out, steps } = applyTransforms(code, opts);\n  refactoredArea.value = out;\n  stepsEl.innerHTML = '';\n  for (const s of steps) {\n    const div = document.createElement('div');\n    div.className = 'step';\n    div.textContent = s;\n    stepsEl.appendChild(div);\n  }\n  diffBox.textContent = simpleDiff(code, out);\n}\n\napplySelectedBtn.addEventListener('click', applySelectedTransforms);\n\napplyAllBtn.addEventListener('click', () => {\n  // Turn on all transforms\n  t_guard.checked = t_extract.checked = t_constants.checked = t_varlet.checked = t_format.checked = true;\n  applySelectedTransforms();\n});\n\nundoBtn.addEventListener('click', () => {\n  if (history.length > 1) {\n    history.pop(); // current\n    const prev = history.pop(); // previous\n    if (prev) {\n      originalArea.value = prev;\n      refactoredArea.value = prev;\n      pushHistory(prev);\n      stepsEl.innerHTML = '';\n      diffBox.textContent = '';\n      testOutput.innerHTML = '';\n    }\n  } else {\n    originalArea.value = originalExample;\n    refactoredArea.value = originalExample;\n    stepsEl.innerHTML = '';\n    diffBox.textContent = '';\n  }\n});\n\nrunTestsBtn.addEventListener('click', () => {\n  showTestOutput(originalArea.value, refactoredArea.value);\n});\nrunTestsBtn2.addEventListener('click', () => {\n  showTestOutput(originalArea.value, refactoredArea.value);\n});\n\nshowStepsBtn.addEventListener('click', () => {\n  stepsEl.innerHTML = '';\n  const code = originalArea.value;\n  const opts = {\n    guard: true,\n    extract: true,\n    constants: true,\n    varlet: true,\n    format: true\n  };\n  const { code: out, steps } = applyTransforms(code, opts);\n  for (const s of steps) {\n    const div = document.createElement('div');\n    div.className = 'step';\n    div.innerHTML = `<strong>${s}</strong><div class=\"muted\" style=\"margin-top:4px\">Why: ${stepRationale(s)}</div>`;\n    stepsEl.appendChild(div);\n  }\n  refactoredArea.value = out;\n  diffBox.textContent = simpleDiff(code, out);\n});\n\n// Small explanations for steps\nfunction stepRationale(step) {\n  if (step.includes('guard')) return 'Avoid deeper nesting and handle empty inputs early.';\n  if (step.includes('Extract')) return 'Give the item total calculation a single responsibility and remove duplication.';\n  if (step.includes('Replace magic')) return 'Named constants communicate intent and make future changes simpler.';\n  if (step.includes('Replace var')) return 'let/const are block-scoped and less error-prone than var.';\n  if (step.includes('format')) return 'Consistent formatting improves readability.';\n  return '';\n}\n\n// Initialize\napplySelectedTransforms();\n\n</script>\n</body>\n</html>"
  },
