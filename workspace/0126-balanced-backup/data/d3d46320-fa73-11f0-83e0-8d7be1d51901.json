    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Doubly Linked List - Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#06b6d4;\n      --muted:#94a3b8;\n      --node:#071020;\n      --node-border:#1f2937;\n      --node-bg:#0b1724;\n      --success:#10b981;\n      --danger:#ef4444;\n      font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    html,body{height:100%; margin:0; background:linear-gradient(180deg,#071025 0%, #071225 100%); color:#e6eef8;}\n    .wrap{\n      max-width:1100px;\n      margin:24px auto;\n      padding:20px;\n    }\n    header{\n      display:flex;\n      gap:16px;\n      align-items:center;\n      margin-bottom:14px;\n    }\n    header h1{\n      font-size:20px;\n      margin:0;\n      letter-spacing:0.2px;\n    }\n    header p{margin:0;color:var(--muted);font-size:13px}\n    .panel{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      padding:12px;\n      border-radius:10px;\n      box-shadow: 0 4px 18px rgba(2,6,23,0.6);\n    }\n\n    .controls{\n      display:flex;\n      gap:12px;\n      flex-wrap:wrap;\n      align-items:center;\n      margin-bottom:14px;\n    }\n    .controls .group{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      background:rgba(255,255,255,0.01);\n      padding:8px;\n      border-radius:8px;\n    }\n    input[type=\"text\"], input[type=\"number\"]{\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.04);\n      padding:8px 10px;\n      color:var(--muted);\n      border-radius:6px;\n      width:120px;\n    }\n    button{\n      background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.05);\n      color:var(--muted);\n      padding:8px 10px;\n      border-radius:8px;\n      cursor:pointer;\n      transition:all .15s ease;\n      font-weight:600;\n      font-size:13px;\n    }\n    button:hover{transform:translateY(-2px); color:#e6eef8;}\n    button.primary{\n      border-color: rgba(6,182,212,0.2);\n      box-shadow: 0 6px 18px rgba(6,182,212,0.06);\n      color:var(--accent);\n    }\n    button.warn{ color:var(--danger); }\n    button.ghost{ background:transparent; border:1px dashed rgba(255,255,255,0.03); }\n\n    .visual{\n      margin-top:18px;\n      min-height:150px;\n      display:flex;\n      flex-direction:column;\n      gap:14px;\n    }\n\n    .list-row{\n      display:flex;\n      gap:10px;\n      align-items:center;\n      flex-wrap:nowrap;\n      overflow:auto;\n      padding:12px;\n      border-radius:10px;\n      background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border:1px solid rgba(255,255,255,0.02);\n    }\n\n    .node{\n      flex:0 0 auto;\n      background:linear-gradient(180deg, var(--node-bg), rgba(255,255,255,0.01));\n      border:1px solid var(--node-border);\n      color:#dbeafe;\n      min-width:120px;\n      display:flex;\n      gap:8px;\n      padding:8px;\n      border-radius:8px;\n      align-items:center;\n      position:relative;\n      transition:transform .15s ease, box-shadow .15s ease;\n      cursor:pointer;\n    }\n    .node:hover{ transform:translateY(-6px); box-shadow: 0 10px 30px rgba(2,6,23,0.6);}\n    .node .box{\n      background:rgba(255,255,255,0.02);\n      border-radius:6px;\n      padding:6px 8px;\n      min-width:40px;\n      text-align:center;\n      font-weight:700;\n      font-size:14px;\n      color:#dbeafe;\n      border:1px solid rgba(255,255,255,0.03);\n    }\n    .node .label{ font-size:12px; color:var(--muted); }\n    .arrow{\n      font-size:18px;\n      color:var(--muted);\n      margin:0 6px;\n      user-select:none;\n    }\n\n    .node .meta{\n      display:flex;\n      flex-direction:column;\n      gap:4px;\n      align-items:flex-start;\n      margin-left:4px;\n    }\n    .node .meta small{ color:var(--muted); font-size:11px; }\n\n    .node.selected{\n      outline:3px solid rgba(6,182,212,0.15);\n      box-shadow:0 8px 30px rgba(6,182,212,0.08);\n    }\n    .node.current{\n      outline:3px solid rgba(16,185,129,0.14);\n      box-shadow:0 10px 30px rgba(16,185,129,0.06);\n    }\n\n    .info{\n      display:flex;\n      gap:12px;\n      margin-top:12px;\n      flex-wrap:wrap;\n    }\n    .box{\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border-radius:8px;\n      padding:12px;\n      border:1px solid rgba(255,255,255,0.02);\n      min-width:240px;\n      color:var(--muted);\n    }\n    pre{\n      white-space:pre-wrap;\n      word-break:break-word;\n      margin:0;\n      font-size:13px;\n      color:#cde7f3;\n    }\n\n    .log{\n      height:140px;\n      overflow:auto;\n      background:rgba(0,0,0,0.12);\n      border-radius:6px;\n      padding:8px;\n      font-family:monospace;\n      font-size:13px;\n      color:var(--muted);\n    }\n    footer{ margin-top:18px; color:var(--muted); font-size:13px; text-align:center;}\n\n    @media (max-width:700px){\n      .node{ min-width:100px; }\n      input[type=\"text\"]{ width:90px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <header>\n      <div>\n        <h1>Doubly Linked List — Interactive Demo</h1>\n        <p>Visualize and manipulate a doubly linked list (nodes have prev and next pointers). Click nodes to select for some operations.</p>\n      </div>\n    </header>\n\n    <div class=\"panel\">\n      <div class=\"controls\">\n        <div class=\"group\">\n          <input id=\"valueInput\" type=\"text\" placeholder=\"value (e.g. 10)\" />\n          <button id=\"insertHeadBtn\" class=\"primary\">Insert Head</button>\n          <button id=\"insertTailBtn\" class=\"primary\">Insert Tail</button>\n          <button id=\"insertAfterBtn\" class=\"primary\">Insert After Selected</button>\n          <button id=\"insertAfterValBtn\" class=\"primary\">Insert After Value</button>\n        </div>\n\n        <div class=\"group\">\n          <input id=\"targetValueInput\" type=\"text\" placeholder=\"target value\" />\n          <button id=\"removeValueBtn\" class=\"warn\">Remove by Value</button>\n          <input id=\"removeIndex\" type=\"number\" placeholder=\"index\" style=\"width:80px\" />\n          <button id=\"removeIndexBtn\" class=\"warn\">Remove at Index</button>\n        </div>\n\n        <div class=\"group\">\n          <button id=\"searchBtn\">Search</button>\n          <button id=\"clearBtn\">Clear</button>\n          <button id=\"randomBtn\" class=\"ghost\">Randomize</button>\n        </div>\n\n        <div class=\"group\">\n          <button id=\"traverseFwdBtn\">Traverse →</button>\n          <button id=\"traverseBwdBtn\">Traverse ←</button>\n          <button id=\"stopTraverseBtn\">Stop</button>\n        </div>\n      </div>\n\n      <div class=\"visual\">\n        <div class=\"list-row\" id=\"listRow\" title=\"Click a node to select it (for insert after).\"></div>\n\n        <div style=\"display:flex; gap:12px; align-items:flex-start; margin-top:6px;\">\n          <div class=\"box\" style=\"flex:1\">\n            <strong>List state (forward/backward)</strong>\n            <div style=\"height:8px\"></div>\n            <div style=\"display:flex; gap:8px;\">\n              <div style=\"flex:1\">\n                <div style=\"color:var(--muted);font-size:13px;margin-bottom:6px\">Forward:</div>\n                <pre id=\"forwardView\">[]</pre>\n              </div>\n              <div style=\"flex:1\">\n                <div style=\"color:var(--muted);font-size:13px;margin-bottom:6px\">Backward:</div>\n                <pre id=\"backwardView\">[]</pre>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"box\" style=\"width:360px;\">\n            <strong>Console</strong>\n            <div style=\"height:8px\"></div>\n            <div class=\"log\" id=\"logArea\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"info\">\n      <div class=\"box\" style=\"flex:1\">\n        <strong>About this demo</strong>\n        <p style=\"color:var(--muted);margin-top:8px\">\n          A doubly linked list stores nodes that know about both their previous and next neighbors. This allows forward and backward traversal in O(n) but with O(1) insertions/removals when you have a reference to the node.\n        </p>\n        <ul style=\"color:var(--muted); margin-top:6px\">\n          <li>Insert Head / Tail — add nodes at ends</li>\n          <li>Insert After Selected / Value — insert after a chosen node</li>\n          <li>Remove by Value / Index — delete nodes</li>\n          <li>Traverse → / Traverse ← — animate traversals</li>\n        </ul>\n      </div>\n\n      <div class=\"box\" style=\"width:420px;\">\n        <strong>Implementation (simplified)</strong>\n        <pre id=\"codeBlock\">\nclass Node {\n  constructor(value){ this.value=value; this.prev=null; this.next=null; }\n}\n\nclass DoublyLinkedList {\n  constructor(){\n    this.head = null;\n    this.tail = null;\n    this.length = 0;\n  }\n\n  insertHead(value){ ... }     // O(1)\n  insertTail(value){ ... }     // O(1)\n  insertAfter(targetValue, value){ ... } // O(n) to find target\n  removeByValue(value){ ... }  // O(n)\n  removeAt(index){ ... }       // O(n)\n  toArrayForward(){ ... }\n  toArrayBackward(){ ... }\n}\n        </pre>\n      </div>\n    </div>\n\n    <footer class=\"panel\" style=\"margin-top:14px;\">\n      Tip: click a node in the visualization to select it for \"Insert After Selected\". Selected nodes are outlined. Traversals highlight nodes as they are visited.\n    </footer>\n  </div>\n\n  <script>\n    // Doubly Linked List Implementation\n    class Node {\n      constructor(value){\n        this.value = value;\n        this.prev = null;\n        this.next = null;\n      }\n    }\n\n    class DoublyLinkedList {\n      constructor(){\n        this.head = null;\n        this.tail = null;\n        this.length = 0;\n      }\n\n      insertHead(value){\n        const node = new Node(value);\n        if(!this.head){ this.head = this.tail = node; }\n        else {\n          node.next = this.head;\n          this.head.prev = node;\n          this.head = node;\n        }\n        this.length++;\n        return node;\n      }\n\n      insertTail(value){\n        const node = new Node(value);\n        if(!this.tail){ this.head = this.tail = node; }\n        else {\n          node.prev = this.tail;\n          this.tail.next = node;\n          this.tail = node;\n        }\n        this.length++;\n        return node;\n      }\n\n      // insert after first node with targetValue\n      insertAfterValue(targetValue, value){\n        let cur = this.head;\n        while(cur){\n          if(cur.value === targetValue){\n            const node = new Node(value);\n            node.prev = cur;\n            node.next = cur.next;\n            if(cur.next) cur.next.prev = node;\n            cur.next = node;\n            if(this.tail === cur) this.tail = node;\n            this.length++;\n            return node;\n          }\n          cur = cur.next;\n        }\n        return null;\n      }\n\n      // remove first node with value\n      removeByValue(value){\n        let cur = this.head;\n        while(cur){\n          if(cur.value === value){\n            this._unlink(cur);\n            return cur;\n          }\n          cur = cur.next;\n        }\n        return null;\n      }\n\n      // remove node at index (0-based)\n      removeAt(index){\n        if(index < 0 || index >= this.length) return null;\n        let i = 0;\n        let cur = this.head;\n        while(cur && i < index){ cur = cur.next; i++; }\n        if(cur) this._unlink(cur);\n        return cur;\n      }\n\n      _unlink(node){\n        if(!node) return;\n        if(node.prev) node.prev.next = node.next;\n        else this.head = node.next;\n\n        if(node.next) node.next.prev = node.prev;\n        else this.tail = node.prev;\n\n        node.next = node.prev = null;\n        this.length--;\n      }\n\n      // find index of first value, or -1\n      indexOf(value){\n        let idx = 0;\n        let cur = this.head;\n        while(cur){\n          if(cur.value === value) return idx;\n          cur = cur.next; idx++;\n        }\n        return -1;\n      }\n\n      toArrayForward(){\n        const out = [];\n        let cur = this.head;\n        while(cur){ out.push(cur.value); cur = cur.next; }\n        return out;\n      }\n\n      toArrayBackward(){\n        const out = [];\n        let cur = this.tail;\n        while(cur){ out.push(cur.value); cur = cur.prev; }\n        return out;\n      }\n    }\n\n    // Demo & UI Code\n    const list = new DoublyLinkedList();\n    const listRow = document.getElementById('listRow');\n    const forwardView = document.getElementById('forwardView');\n    const backwardView = document.getElementById('backwardView');\n    const logArea = document.getElementById('logArea');\n    const valueInput = document.getElementById('valueInput');\n    const targetValueInput = document.getElementById('targetValueInput');\n    const removeIndexInput = document.getElementById('removeIndex');\n\n    let selectedNodeElement = null; // DOM element\n    let nodeElements = new Map(); // Node -> DOM element\n    let traversalTimer = null;\n\n    function log(...args){\n      const line = args.map(a => (typeof a === 'object' ? JSON.stringify(a) : String(a))).join(' ');\n      const el = document.createElement('div');\n      el.textContent = new Date().toLocaleTimeString() + ' › ' + line;\n      logArea.appendChild(el);\n      logArea.scrollTop = logArea.scrollHeight;\n    }\n\n    function render(){\n      listRow.innerHTML = '';\n      nodeElements.clear();\n      let cur = list.head;\n      let idx = 0;\n      while(cur){\n        const nodeEl = createNodeElement(cur, idx);\n        listRow.appendChild(nodeEl);\n        nodeElements.set(cur, nodeEl);\n\n        if(cur.next){\n          // arrow element\n          const arrow = document.createElement('div');\n          arrow.className = 'arrow';\n          arrow.innerHTML = '→';\n          listRow.appendChild(arrow);\n        }\n        cur = cur.next; idx++;\n      }\n\n      // update forward/backward views\n      forwardView.textContent = JSON.stringify(list.toArrayForward());\n      backwardView.textContent = JSON.stringify(list.toArrayBackward());\n    }\n\n    function createNodeElement(node, index){\n      const el = document.createElement('div');\n      el.className = 'node';\n      el.dataset.index = index;\n\n      const boxPrev = document.createElement('div');\n      boxPrev.className = 'box';\n      boxPrev.style.minWidth = '46px';\n      boxPrev.textContent = node.prev ? String(node.prev.value) : 'null';\n      boxPrev.title = 'prev';\n\n      const meta = document.createElement('div');\n      meta.className = 'meta';\n      const mainVal = document.createElement('div');\n      mainVal.style.fontWeight = '800';\n      mainVal.textContent = node.value;\n      const small = document.createElement('small');\n      small.className = 'label';\n      small.textContent = 'index ' + index;\n      meta.appendChild(mainVal);\n      meta.appendChild(small);\n\n      const boxNext = document.createElement('div');\n      boxNext.className = 'box';\n      boxNext.style.minWidth = '46px';\n      boxNext.textContent = node.next ? String(node.next.value) : 'null';\n      boxNext.title = 'next';\n\n      el.appendChild(boxPrev);\n      el.appendChild(meta);\n      el.appendChild(boxNext);\n\n      el.addEventListener('click', (e) => {\n        e.stopPropagation();\n        selectNodeElement(el, node);\n      });\n\n      return el;\n    }\n\n    function selectNodeElement(el, node){\n      if(selectedNodeElement){\n        selectedNodeElement.classList.remove('selected');\n      }\n      selectedNodeElement = el;\n      el.classList.add('selected');\n      log('Selected node with value', node.value);\n    }\n\n    document.body.addEventListener('click', (e) => {\n      // click outside clears selection\n      if(selectedNodeElement){\n        selectedNodeElement.classList.remove('selected');\n        selectedNodeElement = null;\n      }\n    });\n\n    // Buttons\n    document.getElementById('insertHeadBtn').addEventListener('click', () => {\n      const val = valueInput.value.trim();\n      if(val === '') { alert('Enter a value'); return; }\n      list.insertHead(val);\n      log('Inserted at head:', val);\n      render();\n    });\n\n    document.getElementById('insertTailBtn').addEventListener('click', () => {\n      const val = valueInput.value.trim();\n      if(val === '') { alert('Enter a value'); return; }\n      list.insertTail(val);\n      log('Inserted at tail:', val);\n      render();\n    });\n\n    document.getElementById('insertAfterBtn').addEventListener('click', () => {\n      const val = valueInput.value.trim();\n      if(val === '') { alert('Enter a value to insert'); return; }\n      if(!selectedNodeElement){ alert('Select a node to insert after (click a node)'); return; }\n      const idx = Number(selectedNodeElement.dataset.index);\n      // find node at that index\n      let cur = list.head;\n      let i = 0;\n      while(cur && i < idx){ cur = cur.next; i++; }\n      if(cur){\n        const node = list.insertAfterValue(cur.value, val);\n        if(node){\n          log('Inserted', val, 'after node with value', cur.value);\n          render();\n        }\n      } else {\n        alert('Selected node not found');\n      }\n    });\n\n    document.getElementById('insertAfterValBtn').addEventListener('click', () => {\n      const val = valueInput.value.trim();\n      const target = targetValueInput.value.trim();\n      if(val === '' || target === '') { alert('Enter both target and value'); return; }\n      const node = list.insertAfterValue(target, val);\n      if(node){\n        log('Inserted', val, 'after first node with value', target);\n        render();\n      } else {\n        alert('Target value not found');\n      }\n    });\n\n    document.getElementById('removeValueBtn').addEventListener('click', () => {\n      const target = targetValueInput.value.trim();\n      if(target === '') { alert('Enter a value to remove'); return; }\n      const removed = list.removeByValue(target);\n      if(removed){\n        log('Removed first node with value', target);\n        render();\n      } else {\n        alert('Value not found');\n      }\n    });\n\n    document.getElementById('removeIndexBtn').addEventListener('click', () => {\n      const idx = Number(removeIndexInput.value);\n      if(isNaN(idx)){ alert('Enter an index'); return; }\n      const removed = list.removeAt(idx);\n      if(removed){\n        log('Removed node at index', idx, 'value:', removed.value);\n        render();\n      } else {\n        alert('Index out of bounds');\n      }\n    });\n\n    document.getElementById('searchBtn').addEventListener('click', () => {\n      const target = targetValueInput.value.trim();\n      if(target === '') { alert('Enter a value to search'); return; }\n      const idx = list.indexOf(target);\n      if(idx >= 0){\n        log('Value', target, 'found at index', idx);\n        // highlight DOM element\n        const el = [...listRow.querySelectorAll('.node')].find(n => Number(n.dataset.index) === idx);\n        if(el){\n          if(selectedNodeElement) selectedNodeElement.classList.remove('selected');\n          selectedNodeElement = el;\n          el.classList.add('selected');\n          // small flash\n          el.classList.add('current');\n          setTimeout(()=>el.classList.remove('current'), 900);\n        }\n      } else {\n        log('Value', target, 'not found');\n        alert('Value not found');\n      }\n    });\n\n    document.getElementById('clearBtn').addEventListener('click', () => {\n      if(!confirm('Clear the entire list?')) return;\n      while(list.head){ list._unlink(list.head); } // clear\n      log('Cleared list');\n      render();\n    });\n\n    document.getElementById('randomBtn').addEventListener('click', () => {\n      // create random small list\n      while(list.head) list._unlink(list.head);\n      const count = Math.floor(Math.random() * 6) + 3;\n      for(let i=0;i<count;i++){\n        list.insertTail(Math.floor(Math.random()*90)+10);\n      }\n      log('Randomized list with', count, 'nodes');\n      render();\n    });\n\n    // Traversal with highlight\n    function animateTraversal(direction = 'forward'){\n      stopTraversal();\n      if(list.length === 0){ alert('List is empty'); return; }\n      let cur = direction === 'forward' ? list.head : list.tail;\n      let idx = direction === 'forward' ? 0 : list.length - 1;\n      traversalTimer = setInterval(() => {\n        // clear previous 'current' class\n        document.querySelectorAll('.node.current').forEach(n => n.classList.remove('current'));\n        // highlight current node DOM element\n        const el = [...listRow.querySelectorAll('.node')].find(n => Number(n.dataset.index) === idx);\n        if(el) el.classList.add('current');\n        log('Visited', cur ? cur.value : 'null', 'index', idx);\n        if(direction === 'forward'){\n          cur = cur ? cur.next : null;\n          idx++;\n          if(cur === null){ // finished one round; stop after highlighting last\n            clearInterval(traversalTimer);\n            traversalTimer = null;\n            setTimeout(()=>document.querySelectorAll('.node.current').forEach(n => n.classList.remove('current')), 600);\n          }\n        } else {\n          cur = cur ? cur.prev : null;\n          idx--;\n          if(cur === null){\n            clearInterval(traversalTimer);\n            traversalTimer = null;\n            setTimeout(()=>document.querySelectorAll('.node.current').forEach(n => n.classList.remove('current')), 600);\n          }\n        }\n      }, 700);\n    }\n\n    function stopTraversal(){\n      if(traversalTimer){ clearInterval(traversalTimer); traversalTimer = null; log('Traversal stopped'); }\n      document.querySelectorAll('.node.current').forEach(n => n.classList.remove('current'));\n    }\n\n    document.getElementById('traverseFwdBtn').addEventListener('click', ()=> animateTraversal('forward'));\n    document.getElementById('traverseBwdBtn').addEventListener('click', ()=> animateTraversal('backward'));\n    document.getElementById('stopTraverseBtn').addEventListener('click', stopTraversal);\n\n    // Initialize with a few nodes\n    (function initDemo(){\n      list.insertTail(10);\n      list.insertTail(20);\n      list.insertTail(30);\n      list.insertTail(40);\n      render();\n      log('Demo initialized with 4 nodes [10,20,30,40]');\n    }());\n  </script>\n</body>\n</html>"
  },
