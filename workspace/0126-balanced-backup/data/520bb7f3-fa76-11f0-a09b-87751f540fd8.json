    "role": "assistant",
    "content": "<html>\n<head>\n    <title>K-Nearest Neighbors</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            width: 80%;\n            margin: 40px auto;\n            text-align: center;\n        }\n        .input-field {\n            width: 50%;\n            margin: 20px auto;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        .button {\n            width: 100%;\n            padding: 10px;\n            background-color: #4CAF50;\n            color: #fff;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h2>K-Nearest Neighbors</h2>\n        <form>\n            <label for=\"features\">Features:</label>\n            <input type=\"text\" id=\"features\" required>\n            <button type=\"button\" class=\"button\" onclick=\"findKNN()\">Find KNN</button>\n        </form>\n        <div id=\"result\"></div>\n    </div>\n\n    <script>\n        function findKNN(features) {\n            // Assume we have a dataset of features and their corresponding labels\n            let dataset = [\n                { label: 'A', features: [1, 2, 3, 4, 5] },\n                { label: 'B', features: [2, 3, 4, 5, 6] },\n                { label: 'C', features: [3, 4, 5, 6, 7] },\n                { label: 'D', features: [4, 5, 6, 7, 8] },\n                { label: 'E', features: [5, 6, 7, 8, 9] }\n            ];\n\n            // Convert features to a numerical representation\n            let numericalFeatures = dataset.map(feature => {\n                let sum = 0;\n                let count = 0;\n                feature.forEach((value, index) => {\n                    sum += value;\n                    count++;\n                });\n                return sum / count;\n            });\n\n            // Calculate the Euclidean distance between each feature in the input features\n            let inputFeatures = features.map(feature => numericalFeatures[dataset.indexOf(feature)]);\n            let distances = [];\n            for (let i = 0; i < inputFeatures.length; i++) {\n                let distance = 0;\n                for (let j = 0; j < inputFeatures.length; j++) {\n                    if (i !== j) {\n                        distance += Math.pow(inputFeatures[i] - inputFeatures[j], 2);\n                    }\n                }\n                distances.push(distance);\n            }\n\n            // Get the k nearest neighbors\n            let k = parseInt(document.getElementById('features').value.split(',').length);\n            let nearestNeighbors = [];\n            for (let i = 0; i < distances.length; i++) {\n                if (distances[i] <= 10) {\n                    nearestNeighbors.push([distances[i], i]);\n                }\n            }\n            nearestNeighbors.sort((a, b) => a[0] - b[0]);\n\n            // Print the k nearest neighbors\n            for (let i = 0; i < nearestNeighbors.length; i++) {\n                let index = nearestNeighbors[i][1];\n                let label = dataset[index].label;\n                let distance = distances[index];\n                document.getElementById('result').innerHTML += `<p>The ${label} feature has a distance of ${distance} to the nearest neighbors.</p>`;\n            }\n        }\n    </script>\n</body>\n</html>"
