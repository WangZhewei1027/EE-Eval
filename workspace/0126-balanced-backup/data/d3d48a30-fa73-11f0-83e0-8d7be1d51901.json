  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Circular Linked List - Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --accent:#60a5fa;\n      --muted:#94a3b8;\n      --good:#34d399;\n      --danger:#fb7185;\n      --glass: rgba(255,255,255,0.03);\n      --panel:#071027;\n    }\n    html,body{height:100%; margin:0; font-family:Inter,ui-sans-serif,system-ui,-apple-system,'Segoe UI',Roboto,'Helvetica Neue',Arial; background:linear-gradient(180deg,var(--bg),#071029); color:#e6eef8;}\n    .container{max-width:1100px; margin:22px auto; background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border-radius:12px; padding:18px; box-shadow:0 6px 30px rgba(2,6,23,0.6);}\n    h1{margin:0 0 6px 0; font-size:20px; color:var(--accent);}\n    p.lead{margin:0 0 10px 0; color:var(--muted); font-size:13px;}\n    .layout{display:flex; gap:18px;}\n    .left{flex:1; min-width:360px; padding:12px; background:var(--panel); border-radius:10px;}\n    .right{width:360px; padding:12px; background:var(--card); border-radius:10px;}\n    .controls{display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:8px;}\n    input,select{padding:8px 10px; border-radius:8px; border:1px solid rgba(255,255,255,0.04); background:transparent; color:inherit; outline:none;}\n    button{padding:8px 10px; border-radius:8px; border:0; background:var(--accent); color:#032047; cursor:pointer; font-weight:600;}\n    button.secondary{background:transparent; border:1px solid rgba(255,255,255,0.04); color:var(--muted);}\n    .small{padding:6px;font-size:13px}\n    .row{display:flex; gap:8px; align-items:center}\n    .muted{color:var(--muted); font-size:13px}\n    .svg-wrap{height:480px; background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00)); border-radius:8px; border:1px dashed rgba(255,255,255,0.03); display:flex; align-items:center; justify-content:center; overflow:hidden; position:relative;}\n    svg{width:100%; height:100%;}\n    .info{font-size:13px; color:var(--muted); margin-top:10px;}\n    .legend{display:flex; gap:8px; margin-top:10px; flex-wrap:wrap;}\n    .chip{padding:6px 8px; border-radius:8px; background:var(--glass); font-size:13px; color:var(--muted);}\n    .list-details{margin-top:12px; color:var(--muted); font-size:13px;}\n    .footer{font-size:12px; color:var(--muted); margin-top:12px;}\n    .highlight { fill: #fee; stroke: #ffda59; stroke-width:2px; }\n    .node-label{ font-size:12px; fill: #041029; font-weight:700; }\n    .node-sub{ font-size:10px; fill: #9aaecb; }\n    .btn-row{display:flex; gap:8px; margin-top:8px; flex-wrap:wrap;}\n    .notice{padding:8px; border-radius:8px; background:rgba(255,255,255,0.02); color:var(--muted); font-size:13px;}\n    .code{font-family:ui-monospace,SFMono-Regular,Menlo,monospace; font-size:12px; color:#bfe0ff;}\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Circular Linked List — Interactive Demo</h1>\n    <p class=\"lead\">A circular linked list is like a normal linked list, but the last node's next pointer points back to the head, forming a circle. Use the controls to create, modify and step through the list.</p>\n\n    <div class=\"layout\">\n      <div class=\"left\">\n        <div class=\"svg-wrap\" id=\"canvasWrap\" title=\"Visualization of nodes and next pointers\">\n          <svg id=\"svg\" viewBox=\"0 0 900 480\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n        </div>\n\n        <div class=\"info\">\n          <div class=\"legend\">\n            <div class=\"chip\">Head ➜ marked</div>\n            <div class=\"chip\">Arrows show next pointers</div>\n            <div class=\"chip\">Single node forms a self-loop</div>\n          </div>\n          <div class=\"list-details\" id=\"listDetails\">List is empty</div>\n        </div>\n\n        <div style=\"margin-top:12px;\">\n          <div class=\"notice\">Traversal controls: \"Start / Next\" steps through nodes in order. \"Animate\" will loop through all nodes automatically once.</div>\n          <div class=\"btn-row\">\n            <button id=\"trStart\" class=\"small\">Start / Next</button>\n            <button id=\"trReset\" class=\"small secondary\">Stop / Reset</button>\n            <button id=\"trAnimate\" class=\"small\">Animate</button>\n            <select id=\"trSpeed\" class=\"small\">\n              <option value=\"800\">Slow</option>\n              <option value=\"450\" selected>Normal</option>\n              <option value=\"180\">Fast</option>\n            </select>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"right\">\n        <div style=\"margin-bottom:10px;\">\n          <div class=\"row\" style=\"margin-bottom:8px;\">\n            <input id=\"valueInput\" placeholder=\"Node value (string or number)\" />\n            <button id=\"addHead\" class=\"small\">Insert Head</button>\n            <button id=\"addTail\" class=\"small\">Insert Tail</button>\n          </div>\n\n          <div class=\"row\" style=\"margin-bottom:8px;\">\n            <input id=\"afterIndex\" placeholder=\"Index after (0-based)\" style=\"width:110px;\" />\n            <button id=\"insertAfter\" class=\"small\">Insert After</button>\n            <button id=\"deleteAt\" class=\"small secondary\">Delete at Index</button>\n          </div>\n\n          <div class=\"row\" style=\"margin-bottom:8px;\">\n            <input id=\"deleteValueInput\" placeholder=\"Delete by value\" />\n            <button id=\"deleteValBtn\" class=\"small\">Delete Value</button>\n            <button id=\"findBtn\" class=\"small secondary\">Find Value</button>\n          </div>\n\n          <div class=\"row\" style=\"margin-bottom:10px;\">\n            <input id=\"initCount\" type=\"number\" min=\"0\" max=\"12\" placeholder=\"Count (random init)\" style=\"width:120px;\" />\n            <button id=\"randBtn\" class=\"small\">Create Random</button>\n            <button id=\"clearBtn\" class=\"small secondary\">Clear</button>\n          </div>\n\n          <div style=\"margin-top:8px;\">\n            <div class=\"muted\">Notes:</div>\n            <ul style=\"margin:6px 0 0 18px; color:var(--muted); font-size:13px;\">\n              <li>Indexing for operations is 0-based (head is index 0).</li>\n              <li>When the list is empty, insertHead and insertTail create the first node.</li>\n            </ul>\n          </div>\n        </div>\n\n        <div style=\"margin-top:8px;\">\n          <div class=\"muted\">Quick reference (time complexity):</div>\n          <div style=\"display:flex; gap:8px; margin-top:8px;\">\n            <div class=\"chip\">Insert head: O(1) if tail known else O(n)</div>\n            <div class=\"chip\">Insert tail: O(1) if tail known else O(n)</div>\n            <div class=\"chip\">Search / Delete: O(n)</div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:12px;\">\n          <div class=\"muted\">Internal state (debug):</div>\n          <pre id=\"debug\" class=\"code\" style=\"background:transparent; border-radius:6px; padding:8px; max-height:140px; overflow:auto;\"></pre>\n        </div>\n\n      </div>\n    </div>\n\n    <div class=\"footer\">Implementation: nodes have unique ids and nextId pointers; visualization computes the sequence by following next pointers from head until it loops back.</div>\n  </div>\n\n  <script>\n    // Circular Linked List Interactive Implementation\n    (function(){\n      // DOM elements\n      const svg = document.getElementById('svg');\n      const listDetails = document.getElementById('listDetails');\n      const debug = document.getElementById('debug');\n      const valueInput = document.getElementById('valueInput');\n      const addHeadBtn = document.getElementById('addHead');\n      const addTailBtn = document.getElementById('addTail');\n      const randBtn = document.getElementById('randBtn');\n      const clearBtn = document.getElementById('clearBtn');\n      const initCount = document.getElementById('initCount');\n      const afterIndex = document.getElementById('afterIndex');\n      const insertAfterBtn = document.getElementById('insertAfter');\n      const deleteAtBtn = document.getElementById('deleteAt');\n      const deleteValueInput = document.getElementById('deleteValueInput');\n      const deleteValBtn = document.getElementById('deleteValBtn');\n      const findBtn = document.getElementById('findBtn');\n\n      const trStartBtn = document.getElementById('trStart');\n      const trResetBtn = document.getElementById('trReset');\n      const trAnimateBtn = document.getElementById('trAnimate');\n      const trSpeedSelect = document.getElementById('trSpeed');\n\n      // Data structures: map of nodes by id; headId references id of head node (null if empty)\n      let nodes = {};       // id -> {id, value, nextId}\n      let headId = null;\n      let _idCounter = 1;\n\n      // Traversal state\n      let traversalCurrent = null;\n      let traversalStarted = false;\n      let animateInterval = null;\n\n      // Helper: create a node object\n      function createNode(value){\n        const id = String(_idCounter++);\n        return { id, value: String(value), nextId: null };\n      }\n\n      // Convert current list to ordered sequence starting from head. If empty returns [].\n      function getSequence(){\n        const seq = [];\n        if (!headId) return seq;\n        let cur = headId;\n        const seen = new Set();\n        while(cur && !seen.has(cur)){\n          const node = nodes[cur];\n          if(!node) break;\n          seq.push(node);\n          seen.add(cur);\n          cur = node.nextId;\n        }\n        return seq;\n      }\n\n      // Find node object by index in sequence (0-based)\n      function nodeAtIndex(index){\n        const seq = getSequence();\n        return (index>=0 && index<seq.length) ? seq[index] : null;\n      }\n\n      // Find previous node of node with id targetId (returns null if list empty)\n      function findPrev(targetId){\n        if(!headId) return null;\n        let cur = headId;\n        let prev = null;\n        const seen = new Set();\n        while(cur && !seen.has(cur)){\n          const node = nodes[cur];\n          seen.add(cur);\n          if(node.nextId === targetId) return node;\n          prev = node;\n          cur = node.nextId;\n        }\n        return null;\n      }\n\n      // Insert at head\n      function insertHead(value){\n        const node = createNode(value);\n        nodes[node.id] = node;\n        if(!headId){\n          node.nextId = node.id; // self-loop\n          headId = node.id;\n        } else {\n          // node.next -> old head\n          node.nextId = headId;\n          // find last node and set its next to new head\n          const seq = getSequence();\n          const last = seq[seq.length - 1];\n          last.nextId = node.id;\n          headId = node.id;\n        }\n        render();\n      }\n\n      // Insert at tail\n      function insertTail(value){\n        const node = createNode(value);\n        nodes[node.id] = node;\n        if(!headId){\n          node.nextId = node.id;\n          headId = node.id;\n        } else {\n          const seq = getSequence();\n          const last = seq[seq.length - 1];\n          last.nextId = node.id;\n          node.nextId = headId;\n        }\n        render();\n      }\n\n      // Insert after an index (0-based)\n      function insertAfterIndex(index, value){\n        const target = nodeAtIndex(index);\n        if(!target){\n          alert('Index out of range');\n          return;\n        }\n        const node = createNode(value);\n        nodes[node.id] = node;\n        node.nextId = target.nextId;\n        target.nextId = node.id;\n        render();\n      }\n\n      // Delete at index\n      function deleteAtIndex(index){\n        if(!headId){ alert('List is empty'); return; }\n        const seq = getSequence();\n        if(index<0 || index>=seq.length){ alert('Index out of range'); return; }\n        const target = seq[index];\n        // If single node\n        if(seq.length === 1){\n          delete nodes[target.id];\n          headId = null;\n          render();\n          return;\n        }\n        const prev = findPrev(target.id);\n        if(!prev){ alert('Unexpected error finding prev'); return; }\n        prev.nextId = target.nextId;\n        if(target.id === headId){\n          headId = target.nextId;\n        }\n        delete nodes[target.id];\n        render();\n      }\n\n      // Delete by value (first occurrence)\n      function deleteByValue(value){\n        if(!headId){ alert('List empty'); return; }\n        const seq = getSequence();\n        const idx = seq.findIndex(n=>n.value === String(value));\n        if(idx === -1){ alert('Value not found'); return; }\n        deleteAtIndex(idx);\n      }\n\n      // Find first index of value\n      function findValue(value){\n        const seq = getSequence();\n        const idx = seq.findIndex(n=>n.value === String(value));\n        return idx;\n      }\n\n      // Clear list\n      function clearList(){\n        nodes = {};\n        headId = null;\n        traversalCurrent = null;\n        traversalStarted = false;\n        stopAnimation();\n        render();\n      }\n\n      // Create random list with n nodes (values 1..n)\n      function createRandom(n){\n        clearList();\n        const values = [];\n        for(let i=1;i<=n;i++) values.push(String(Math.floor(Math.random()*90)+10));\n        for(let v of values){\n          insertTail(v);\n        }\n        render();\n      }\n\n      // Rendering: draw nodes and arrows in SVG\n      function render(){\n        // Update debug panel\n        updateDebug();\n\n        // Clear svg\n        while(svg.firstChild) svg.removeChild(svg.firstChild);\n\n        const seq = getSequence();\n        const n = seq.length;\n        // If empty, show message\n        if(n === 0){\n          listDetails.textContent = 'List is empty';\n          // draw a simple message in svg\n          const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n          text.setAttribute('x',450);\n          text.setAttribute('y',240);\n          text.setAttribute('text-anchor','middle');\n          text.setAttribute('fill','#7f9fbf');\n          text.setAttribute('font-size','18');\n          text.textContent = 'Empty Circular Linked List';\n          svg.appendChild(text);\n          return;\n        } else {\n          listDetails.textContent = `Size: ${n} — Sequence: ` + seq.map(s=>s.value).join(' → ') + ' → (back to head)';\n        }\n\n        // defs for arrow marker\n        const defs = document.createElementNS('http://www.w3.org/2000/svg','defs');\n        const marker = document.createElementNS('http://www.w3.org/2000/svg','marker');\n        marker.setAttribute('id','arrow');\n        marker.setAttribute('markerWidth','8');\n        marker.setAttribute('markerHeight','8');\n        marker.setAttribute('refX','6');\n        marker.setAttribute('refY','4');\n        marker.setAttribute('orient','auto');\n        const pathm = document.createElementNS('http://www.w3.org/2000/svg','path');\n        pathm.setAttribute('d','M0,0 L8,4 L0,8 z');\n        pathm.setAttribute('fill','#b8d6ff');\n        marker.appendChild(pathm);\n        defs.appendChild(marker);\n        svg.appendChild(defs);\n\n        // layout nodes around a circle\n        const cx = 450, cy = 240;\n        const radius = Math.min(360, Math.max(110, 60 + n*18));\n        const angleStep = (2*Math.PI)/n;\n        const nodePos = {};\n        for(let i=0;i<n;i++){\n          const angle = -Math.PI/2 + i*angleStep; // start from top\n          const x = cx + Math.cos(angle)*radius;\n          const y = cy + Math.sin(angle)*radius;\n          nodePos[seq[i].id] = {x,y,angle,i};\n        }\n\n        // Draw arrows first (so circles sit on top)\n        for(let i=0;i<n;i++){\n          const node = seq[i];\n          const from = nodePos[node.id];\n          const toId = node.nextId;\n          const to = nodePos[toId];\n          if(!to){\n            // next points to unknown? handle gracefully by pointing to center\n            drawArrow(from.x, from.y, cx, cy);\n            continue;\n          }\n          if(node.id === toId){\n            // self-loop: draw loop\n            drawSelfLoop(from.x, from.y);\n          } else {\n            drawCurvedArrow(from.x, from.y, to.x, to.y, from.angle);\n          }\n        }\n\n        // Draw nodes (circles with values)\n        for(let i=0;i<n;i++){\n          const node = seq[i];\n          const pos = nodePos[node.id];\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          g.setAttribute('transform', `translate(${pos.x},${pos.y})`);\n          // circle\n          const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          circle.setAttribute('r','28');\n          circle.setAttribute('fill','#0b2b56');\n          circle.setAttribute('stroke','#2d68a8');\n          circle.setAttribute('stroke-width','2');\n          circle.setAttribute('id',`node-${node.id}`);\n          g.appendChild(circle);\n          // value text\n          const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n          text.setAttribute('class','node-label');\n          text.setAttribute('x','0');\n          text.setAttribute('y','6');\n          text.setAttribute('text-anchor','middle');\n          text.textContent = node.value;\n          g.appendChild(text);\n          // small id\n          const sub = document.createElementNS('http://www.w3.org/2000/svg','text');\n          sub.setAttribute('class','node-sub');\n          sub.setAttribute('x','0');\n          sub.setAttribute('y','22');\n          sub.setAttribute('text-anchor','middle');\n          sub.textContent = `id:${node.id}`;\n          g.appendChild(sub);\n\n          // interactive: click to highlight / delete\n          g.addEventListener('click', ()=> {\n            // on click, set as current traversal pointer and highlight\n            traversalCurrent = node.id;\n            traversalStarted = true;\n            stopAnimation();\n            highlightNode(node.id);\n          });\n\n          svg.appendChild(g);\n        }\n\n        // draw head pointer annotation (arrow from top-left)\n        const headPos = nodePos[headId];\n        if(headPos){\n          const hx = 110, hy = 40;\n          const headGroup = document.createElementNS('http://www.w3.org/2000/svg','g');\n          const headText = document.createElementNS('http://www.w3.org/2000/svg','text');\n          headText.setAttribute('x',hx);\n          headText.setAttribute('y',hy-8);\n          headText.setAttribute('fill','#bfe0ff');\n          headText.setAttribute('font-size','12');\n          headText.textContent = 'head';\n          headGroup.appendChild(headText);\n          // line to head\n          const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n          line.setAttribute('x1',hx);\n          line.setAttribute('y1',hy);\n          line.setAttribute('x2',headPos.x - 24*Math.cos(headPos.angle));\n          line.setAttribute('y2',headPos.y - 24*Math.sin(headPos.angle));\n          line.setAttribute('stroke','#8fbef9');\n          line.setAttribute('stroke-width','2');\n          line.setAttribute('marker-end','url(#arrow)');\n          headGroup.appendChild(line);\n          svg.appendChild(headGroup);\n        }\n\n        // If there is an active traversal node, highlight it\n        if(traversalStarted && traversalCurrent){\n          highlightNode(traversalCurrent);\n        }\n      }\n\n      // draw a simple straight arrow with marker\n      function drawArrow(x1,y1,x2,y2){\n        const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n        line.setAttribute('x1',x1);\n        line.setAttribute('y1',y1);\n        line.setAttribute('x2',x2);\n        line.setAttribute('y2',y2);\n        line.setAttribute('stroke','#b8d6ff');\n        line.setAttribute('stroke-width','2');\n        line.setAttribute('marker-end','url(#arrow)');\n        svg.appendChild(line);\n      }\n\n      // curved arrow for readability: use quadratic bezier control point offset based on from angle\n      function drawCurvedArrow(x1,y1,x2,y2, fromAngle=0){\n        const dx = x2-x1, dy = y2-y1;\n        const mx = (x1+x2)/2, my = (y1+y2)/2;\n        // control point offset perpendicular to chord\n        const offset = Math.max(30, Math.min(120, Math.hypot(dx,dy)/4));\n        const cx = mx + Math.cos(fromAngle - Math.PI/2)*offset;\n        const cy = my + Math.sin(fromAngle - Math.PI/2)*offset;\n        const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n        path.setAttribute('d', `M ${x1} ${y1} Q ${cx} ${cy} ${x2} ${y2}`);\n        path.setAttribute('fill','none');\n        path.setAttribute('stroke','#b8d6ff');\n        path.setAttribute('stroke-width','2');\n        path.setAttribute('marker-end','url(#arrow)');\n        svg.appendChild(path);\n      }\n\n      // self-loop around a single node\n      function drawSelfLoop(x,y){\n        const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n        // small loop at top-right of node\n        const r = 36;\n        const sx = x + 22, sy = y - 12;\n        const cx = sx + 36, cy = sy - 36;\n        path.setAttribute('d', `M ${sx} ${sy} C ${sx+20} ${sy-40}, ${cx} ${cy+36}, ${sx} ${sy-8}`);\n        path.setAttribute('fill','none');\n        path.setAttribute('stroke','#b8d6ff');\n        path.setAttribute('stroke-width','2');\n        path.setAttribute('marker-end','url(#arrow)');\n        svg.appendChild(path);\n      }\n\n      // Highlight a node by id and dim others\n      function highlightNode(id){\n        // dim all circles\n        const circles = svg.querySelectorAll('circle');\n        circles.forEach(c=>{\n          c.setAttribute('fill','#0b2b56');\n          c.setAttribute('stroke','#2d68a8');\n        });\n        const texts = svg.querySelectorAll('text');\n        texts.forEach(t=>{\n          t.setAttribute('fill', t.classList.contains('node-sub') ? '#9aaecb' : '#e6eef8');\n        });\n\n        // highlight specific node circle\n        const nodeEl = svg.getElementById(`node-${id}`);\n        if(nodeEl){\n          nodeEl.setAttribute('fill','#fffbec');\n          nodeEl.setAttribute('stroke','#ffb86b');\n        }\n\n        // change detail text\n        const seq = getSequence();\n        const idx = seq.findIndex(n=>n.id===id);\n        if(idx !== -1){\n          listDetails.textContent += `   | current -> index ${idx}, value: ${nodes[id].value}`;\n        }\n        // update debug panel too\n        updateDebug();\n      }\n\n      // Update debug area\n      function updateDebug(){\n        const seq = getSequence();\n        const obj = {\n          headId,\n          size: seq.length,\n          sequence: seq.map(n=>({id:n.id, value:n.value, nextId:n.nextId}))\n        };\n        debug.textContent = JSON.stringify(obj,null,2);\n      }\n\n      // Traversal controls\n      function traversalNext(){\n        if(!headId){\n          alert('List empty');\n          return;\n        }\n        const seq = getSequence();\n        if(!traversalStarted){\n          traversalStarted = true;\n          traversalCurrent = headId;\n        } else {\n          const curNode = nodes[traversalCurrent];\n          traversalCurrent = curNode.nextId;\n        }\n        highlightNode(traversalCurrent);\n      }\n\n      function traversalReset(){\n        traversalStarted = false;\n        traversalCurrent = null;\n        stopAnimation();\n        render();\n      }\n\n      function animateTraversal(){\n        if(!headId){ alert('List empty'); return; }\n        stopAnimation();\n        traversalStarted = true;\n        traversalCurrent = headId;\n        highlightNode(traversalCurrent);\n        const speed = Number(trSpeedValue());\n        let firstId = traversalCurrent;\n        animateInterval = setInterval(()=>{\n          const cur = nodes[traversalCurrent];\n          traversalCurrent = cur.nextId;\n          highlightNode(traversalCurrent);\n          // stop after back to head\n          if(traversalCurrent === firstId){\n            stopAnimation();\n          }\n        }, speed);\n      }\n\n      function stopAnimation(){\n        if(animateInterval) clearInterval(animateInterval);\n        animateInterval = null;\n      }\n\n      function trSpeedValue(){ return document.getElementById('trSpeed').value; }\n\n      // Event bindings\n      addHeadBtn.addEventListener('click', ()=> {\n        const v = valueInput.value.trim();\n        if(v === '') { alert('Enter a value'); return; }\n        insertHead(v);\n        valueInput.value = '';\n      });\n      addTailBtn.addEventListener('click', ()=> {\n        const v = valueInput.value.trim();\n        if(v === '') { alert('Enter a value'); return; }\n        insertTail(v);\n        valueInput.value = '';\n      });\n      randBtn.addEventListener('click', ()=> {\n        const n = parseInt(initCount.value) || 6;\n        createRandom(Math.max(0, Math.min(12,n)));\n      });\n      clearBtn.addEventListener('click', ()=> {\n        if(confirm('Clear the whole list?')) clearList();\n      });\n      insertAfterBtn.addEventListener('click', ()=> {\n        const idx = parseInt(afterIndex.value);\n        const v = valueInput.value.trim();\n        if(isNaN(idx)){ alert('Enter index'); return; }\n        if(v === ''){ alert('Enter value to insert'); return; }\n        insertAfterIndex(idx, v);\n        valueInput.value = '';\n        afterIndex.value = '';\n      });\n      deleteAtBtn.addEventListener('click', ()=> {\n        const idx = parseInt(afterIndex.value);\n        if(isNaN(idx)){ alert('Enter index to delete in the same field'); return; }\n        deleteAtIndex(idx);\n        afterIndex.value = '';\n      });\n      deleteValBtn.addEventListener('click', ()=> {\n        const v = deleteValueInput.value.trim();\n        if(v === ''){ alert('Enter value to delete'); return; }\n        deleteByValue(v);\n        deleteValueInput.value = '';\n      });\n      findBtn.addEventListener('click', ()=> {\n        const v = deleteValueInput.value.trim();\n        if(v === ''){ alert('Enter value to find'); return; }\n        const idx = findValue(v);\n        if(idx === -1){\n          alert('Value not found');\n        } else {\n          alert(`Value found at index ${idx} (head is 0)`);\n          const node = nodeAtIndex(idx);\n          traversalCurrent = node.id;\n          traversalStarted = true;\n          stopAnimation();\n          highlightNode(node.id);\n        }\n      });\n\n      trStartBtn.addEventListener('click', ()=>{\n        stopAnimation();\n        traversalNext();\n      });\n      trResetBtn.addEventListener('click', ()=>{\n        traversalReset();\n      });\n      trAnimateBtn.addEventListener('click', ()=>{\n        animateTraversal();\n      });\n\n      // initialize with sample nodes\n      createRandom(6);\n\n      // Make svg responsive on window resize (re-render)\n      window.addEventListener('resize', ()=> { render(); });\n\n      // Expose a console-friendly state for debugging (not necessary, but handy)\n      window.__circularList = {\n        insertHead: (v)=> { insertHead(v); },\n        insertTail: (v)=> { insertTail(v); },\n        deleteByValue: (v)=> { deleteByValue(v); },\n        deleteAtIndex: (i)=> { deleteAtIndex(i); },\n        getSequence,\n        rawNodes: ()=> nodes,\n      };\n    })();\n  </script>\n</body>\n</html>"
