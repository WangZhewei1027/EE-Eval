    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Ternary Search Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#60a5fa;\n      --muted:#94a3b8;\n      --success:#10b981;\n      --danger:#ef4444;\n      --yellow:#f59e0b;\n      --card:#0b1220;\n      --box:#0b1220;\n    }\n    *{box-sizing:border-box;font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;}\n    body{\n      margin:0;\n      padding:20px;\n      background:linear-gradient(180deg,#071021 0%, #081428 100%);\n      color:#e6eef8;\n      min-height:100vh;\n    }\n    .container{\n      max-width:1100px;margin:0 auto;\n    }\n    header{\n      display:flex;align-items:center;gap:20px;margin-bottom:20px;\n    }\n    header h1{font-size:20px;margin:0}\n    header p{margin:0;color:var(--muted);font-size:13px;}\n    .main{\n      display:grid;grid-template-columns:1fr 380px;gap:20px;\n    }\n    .card{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:10px;padding:16px;border:1px solid rgba(255,255,255,0.03);\n    }\n    .visual{\n      min-height:260px;display:flex;flex-direction:column;gap:12px;align-items:stretch;\n    }\n    .array-row{\n      display:flex;gap:8px;flex-wrap:wrap;\n      align-items:center;justify-content:flex-start;padding:6px;\n    }\n    .cell{\n      width:48px;height:48px;border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;\n      background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.03);color:#cbd5e1;font-weight:600;cursor:pointer;\n      transition:transform 220ms ease, box-shadow 220ms ease, background 220ms ease, border-color 220ms ease;\n      position:relative;\n    }\n    .cell .idx{font-size:10px;color:var(--muted);position:absolute;top:4px;left:6px;}\n    .cell:hover{transform:translateY(-4px);box-shadow:0 8px 20px rgba(2,6,23,0.5)}\n    .cell.default{background:rgba(255,255,255,0.02);}\n    .cell.m1{background:linear-gradient(180deg,#065f46,#047857);border-color:rgba(16,185,129,0.15);color:white;}\n    .cell.m2{background:linear-gradient(180deg,#92400e,#c2410c);border-color:rgba(245,158,11,0.18);color:white;}\n    .cell.leftptr{box-shadow:0 6px 18px rgba(59,130,246,0.12);border-color:rgba(96,165,250,0.15);background:linear-gradient(180deg,#2563eb22,#60a5fa11);}\n    .cell.rightptr{box-shadow:0 6px 18px rgba(99,102,241,0.12);border-color:rgba(99,102,241,0.15);background:linear-gradient(180deg,#7c3aed11,#7c3aed11);}\n    .cell.found{background:linear-gradient(180deg,#10b981,#059669);color:white;border-color:rgba(16,185,129,0.2);transform:scale(1.06)}\n    .cell.notfound{background:linear-gradient(180deg,#ef4444,#dc2626);color:white;border-color:rgba(239,68,68,0.15);}\n    .controls{display:grid;gap:10px;}\n    .row{display:flex;gap:8px;align-items:center;}\n    button, input[type=\"range\"], select{\n      background:transparent;border:1px solid rgba(255,255,255,0.06);padding:8px 10px;border-radius:8px;color:inherit;\n    }\n    button.primary{background:linear-gradient(90deg,#2563eb,#60a5fa);border:0;color:white;}\n    button.ghost{background:transparent;border:1px solid rgba(255,255,255,0.04);}\n    label{font-size:13px;color:var(--muted);}\n    .small{font-size:13px;color:var(--muted);}\n    .log{height:180px;overflow:auto;background:rgba(255,255,255,0.015);padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);font-family:monospace;font-size:13px;}\n    .status{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}\n    .badge{padding:6px 8px;border-radius:8px;background:rgba(255,255,255,0.02);font-size:13px;border:1px solid rgba(255,255,255,0.02);}\n    .legend{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;}\n    .legend .l{display:flex;gap:6px;align-items:center;padding:6px 8px;border-radius:8px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.02)}\n    .dot{width:14px;height:14px;border-radius:4px;}\n    .d-m1{background:linear-gradient(180deg,#065f46,#047857);}\n    .d-m2{background:linear-gradient(180deg,#92400e,#c2410c);}\n    .d-left{background:linear-gradient(180deg,#60a5fa22,#2563eb22);}\n    .d-right{background:linear-gradient(180deg,#7c3aed22,#7c3aed22);}\n    footer{margin-top:18px;color:var(--muted);font-size:13px;}\n    small.note{color:var(--muted);display:block;margin-top:8px;font-size:13px;}\n    input[type=\"number\"]{width:110px;padding:8px;border-radius:8px;}\n    .top-controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:8px;}\n    .muted{color:var(--muted);font-size:13px}\n    .centered{display:flex;align-items:center;gap:8px}\n    .flexcol{display:flex;flex-direction:column;gap:8px}\n    .explain{font-size:14px;color:var(--muted);line-height:1.4}\n    .grow{flex:1}\n    @media (max-width:980px){\n      .main{grid-template-columns:1fr; }\n      .array-row{justify-content:center}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <header>\n      <div>\n        <h1>Ternary Search — Interactive Visualizer</h1>\n        <p>See how ternary search splits a sorted array into three parts to locate a target value (iterative or recursive).</p>\n      </div>\n    </header>\n\n    <div class=\"main\">\n      <div class=\"card\">\n        <div class=\"visual\">\n          <div class=\"top-controls\">\n            <div style=\"display:flex;gap:8px;align-items:center;\">\n              <label class=\"small\">Array size</label>\n              <input id=\"sizeRange\" type=\"range\" min=\"5\" max=\"28\" value=\"13\">\n              <span id=\"sizeLabel\" class=\"small\">13</span>\n              <button id=\"genBtn\" class=\"ghost\">Generate</button>\n            </div>\n            <div style=\"margin-left:auto;display:flex;gap:8px;align-items:center;\">\n              <label class=\"small\">Mode</label>\n              <select id=\"modeSelect\" title=\"Select algorithm mode\">\n                <option value=\"iter\">Iterative</option>\n                <option value=\"rec\">Recursive (step-by-step)</option>\n              </select>\n            </div>\n          </div>\n\n          <div class=\"array-row card\" id=\"arrayRow\" title=\"Click a cell to set the target\">\n            <!-- cells injected here -->\n          </div>\n\n          <div style=\"display:flex;gap:8px;align-items:center;\">\n            <div style=\"display:flex;gap:8px;align-items:center;\">\n              <label class=\"small\">Target</label>\n              <input id=\"targetInput\" type=\"number\" placeholder=\"Click a cell or enter value\">\n              <button id=\"setTargetBtn\" class=\"ghost\">Set</button>\n            </div>\n\n            <div style=\"display:flex;gap:8px;margin-left:auto;align-items:center;\">\n              <button id=\"resetBtn\" class=\"ghost\">Reset</button>\n              <button id=\"stepBtn\" class=\"ghost\">Step</button>\n              <button id=\"playBtn\" class=\"primary\">Play</button>\n            </div>\n          </div>\n\n          <div style=\"display:flex;gap:8px;align-items:center;justify-content:space-between;\">\n            <div class=\"status\">\n              <div class=\"badge\">Comparisons: <span id=\"compCount\">0</span></div>\n              <div class=\"badge\">Iterations: <span id=\"iterCount\">0</span></div>\n              <div class=\"badge\">Result: <span id=\"resultText\">-</span></div>\n            </div>\n\n            <div style=\"display:flex;gap:8px;align-items:center;\">\n              <label class=\"small\">Speed</label>\n              <input id=\"speedRange\" type=\"range\" min=\"100\" max=\"2000\" value=\"700\">\n            </div>\n          </div>\n\n          <div class=\"legend\">\n            <div class=\"l\"><div class=\"dot d-left\"></div><div class=\"small\">Left / Right pointers</div></div>\n            <div class=\"l\"><div class=\"dot d-m1\"></div><div class=\"small\">m1</div></div>\n            <div class=\"l\"><div class=\"dot d-m2\"></div><div class=\"small\">m2</div></div>\n          </div>\n        </div>\n        <div style=\"margin-top:12px;\">\n          <div class=\"explain\">\n            <strong>How it works</strong><br>\n            Ternary search repeatedly divides the search interval into three parts using two mid indices m1 and m2:\n            m1 = l + ⌊(r-l)/3⌋ and m2 = r - ⌊(r-l)/3⌋. Compare the target with arr[m1] and arr[m2]:\n            - If equal to either, we've found the target.<br>\n            - If target < arr[m1], search left third: r = m1 - 1.<br>\n            - If arr[m1] < target < arr[m2], search middle third: l = m1 + 1, r = m2 - 1.<br>\n            - If target > arr[m2], search right third: l = m2 + 1.<br>\n            Note: Ternary search reduces the interval faster than binary search in terms of splits, but its number of comparisons per step may make it less efficient in practice for simple search (binary search is typically preferred).\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <h3 style=\"margin:0\">Execution Log</h3>\n          <div class=\"small muted\">Click cells to choose a target; use Step or Play to run.</div>\n        </div>\n        <div class=\"log\" id=\"logArea\" aria-live=\"polite\" style=\"margin-top:8px;\"></div>\n        <small class=\"note\">Algorithmic complexity: O(log3 n) iterations, but up to 2 comparisons per iteration. Binary search is O(log2 n) with 1 comparison per iteration.</small>\n      </div>\n    </div>\n\n    <footer>\n      Tip: When the visualizer shows m1 and m2, you'll see which comparisons occur and how the search interval changes.\n    </footer>\n  </div>\n\n  <script>\n    (function(){\n      // Utilities\n      const el = id => document.getElementById(id);\n      const arrayRow = el('arrayRow');\n      const genBtn = el('genBtn');\n      const sizeRange = el('sizeRange');\n      const sizeLabel = el('sizeLabel');\n      const modeSelect = el('modeSelect');\n      const targetInput = el('targetInput');\n      const setTargetBtn = el('setTargetBtn');\n      const playBtn = el('playBtn');\n      const stepBtn = el('stepBtn');\n      const resetBtn = el('resetBtn');\n      const compCount = el('compCount');\n      const iterCount = el('iterCount');\n      const resultText = el('resultText');\n      const logArea = el('logArea');\n      const speedRange = el('speedRange');\n\n      let arr = [];\n      let size = parseInt(sizeRange.value,10);\n      sizeLabel.textContent = size;\n      let target = null;\n      let genTime = 0;\n\n      // Generator and control\n      let gen = null;\n      let playing = false;\n      let timer = null;\n      let comparisons = 0;\n      let iterations = 0;\n      let lastState = null;\n\n      // initialize\n      function generateArray(n){\n        // generate sorted unique numbers\n        const base = Math.floor(Math.random()*6) + 1;\n        let a = [];\n        let cur = base;\n        for(let i=0;i<n;i++){\n          cur += Math.floor(Math.random()*9) + 1;\n          a.push(cur);\n        }\n        arr = a;\n        renderArray();\n        resetExecution();\n        log('Generated new array ('+n+' elements).');\n      }\n\n      function renderArray(){\n        arrayRow.innerHTML = '';\n        arr.forEach((v,i)=>{\n          const cell = document.createElement('div');\n          cell.className = 'cell default';\n          cell.dataset.index = i;\n          cell.innerHTML = '<div class=\"idx\">'+i+'</div><div>'+v+'</div>';\n          cell.title = 'Value: '+v + ' — Index: ' + i;\n          cell.addEventListener('click', () => {\n            setTarget(arr[i]);\n            flashLog('Target set to array['+i+'] = '+arr[i]);\n          });\n          arrayRow.appendChild(cell);\n        });\n      }\n\n      function setTarget(v){\n        v = Number(v);\n        if (isNaN(v)) return;\n        target = v;\n        targetInput.value = v;\n        resultText.textContent = '-';\n        comparisons = 0;\n        iterCount.textContent = '0';\n        compCount.textContent = '0';\n        highlightTargetInInput();\n        log('Target set to '+v);\n      }\n\n      function resetExecution(){\n        stop();\n        gen = null;\n        comparisons = 0;\n        iterations = 0;\n        compCount.textContent = '0';\n        iterCount.textContent = '0';\n        resultText.textContent = '-';\n        logArea.innerHTML = '';\n        lastState = null;\n        clearHighlights();\n      }\n\n      function clearHighlights(){\n        document.querySelectorAll('.cell').forEach(c => {\n          c.className = 'cell default';\n        });\n      }\n\n      function highlightRange(state){\n        // state: {l,r,m1,m2,stage,found,index}\n        clearHighlights();\n        if(!state) return;\n        const {l,r,m1,m2,stage,found,index} = state;\n        const cells = document.querySelectorAll('.cell');\n        // mark pointers left..right\n        for(let i=l;i<=r;i++){\n          const c = cells[i];\n          if(!c) continue;\n          // subtle pointer color for region\n          c.classList.add('leftptr');\n        }\n        // override for right pointer region visual (if desired)\n        // highlight m1/m2 specially\n        if(m1!==undefined && cells[m1]) cells[m1].className = 'cell m1';\n        if(m2!==undefined && cells[m2]) cells[m2].className = 'cell m2';\n\n        // show found / notfound\n        if(found){\n          const foundCell = cells[index];\n          if(foundCell) foundCell.className = 'cell found';\n        }\n      }\n\n      function log(msg){\n        const time = new Date().toLocaleTimeString();\n        logArea.innerHTML = '<div>['+time+'] '+escapeHtml(msg)+'</div>' + logArea.innerHTML;\n      }\n      function flashLog(msg){\n        logArea.innerHTML = '<div style=\"color:var(--accent)\">» '+escapeHtml(msg)+'</div>' + logArea.innerHTML;\n      }\n      function escapeHtml(s){\n        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n      }\n\n      // Ternary search generators (yield states for each visible step)\n      function* ternaryIterative(a, target){\n        let l = 0, r = a.length - 1;\n        let iter = 0;\n        while(l <= r){\n          iter++;\n          const m1 = l + Math.floor((r - l) / 3);\n          const m2 = r - Math.floor((r - l) / 3);\n          // show computed mids\n          yield {l,r,m1,m2,stage:'computed',iter};\n          // compare m1\n          yield {l,r,m1,m2,stage:'compare_m1',value:a[m1],iter};\n          if(a[m1] === target){\n            yield {l,r,m1,m2,stage:'found',found:true,index:m1,iter,comparisons:1};\n            return {found:true,index:m1,iterations:iter};\n          }\n          // if target < a[m1], go left\n          if(target < a[m1]){\n            yield {l,r,m1,m2,stage:'m1_gt',iter};\n            r = m1 - 1;\n            continue;\n          }\n          // else compare m2\n          yield {l,r,m1,m2,stage:'compare_m2',value:a[m2],iter};\n          if(a[m2] === target){\n            yield {l,r,m1,m2,stage:'found',found:true,index:m2,iter,comparisons:2};\n            return {found:true,index:m2,iterations:iter};\n          }\n          if(target < a[m2]){\n            yield {l,r,m1,m2,stage:'between',iter};\n            l = m1 + 1;\n            r = m2 - 1;\n          }else{\n            yield {l,r,m1,m2,stage:'m2_lt',iter};\n            l = m2 + 1;\n          }\n        }\n        yield {stage:'not_found',found:false,iter};\n        return {found:false,iterations:iter};\n      }\n\n      function* ternaryRecursive(a, target){\n        let iter = 0;\n        function* rec(l,r){\n          if(l>r){\n            yield {stage:'not_found',l,r,iter};\n            return {found:false};\n          }\n          iter++;\n          const m1 = l + Math.floor((r - l) / 3);\n          const m2 = r - Math.floor((r - l) / 3);\n          yield {l,r,m1,m2,stage:'computed',iter};\n          // compare m1\n          yield {l,r,m1,m2,stage:'compare_m1',value:a[m1],iter};\n          if(a[m1] === target){\n            yield {l,r,m1,m2,stage:'found',found:true,index:m1,iter};\n            return {found:true,index:m1};\n          }\n          if(target < a[m1]){\n            yield {l,r,m1,m2,stage:'m1_gt',iter};\n            return yield* rec(l, m1 - 1);\n          }\n          // compare m2\n          yield {l,r,m1,m2,stage:'compare_m2',value:a[m2],iter};\n          if(a[m2] === target){\n            yield {l,r,m1,m2,stage:'found',found:true,index:m2,iter};\n            return {found:true,index:m2};\n          }\n          if(target < a[m2]){\n            yield {l,r,m1,m2,stage:'between',iter};\n            return yield* rec(m1 + 1, m2 - 1);\n          }else{\n            yield {l,r,m1,m2,stage:'m2_lt',iter};\n            return yield* rec(m2 + 1, r);\n          }\n        }\n        return yield* rec(0, a.length-1);\n      }\n\n      // Controller for stepping/playing\n      function createGenerator(){\n        if(!Array.isArray(arr) || arr.length===0) return null;\n        if(target === null || target === undefined || target === '') {\n          flashLog('Please set a target value first (click a cell or enter a value).');\n          return null;\n        }\n        resetStateForRun();\n        const mode = modeSelect.value;\n        if(mode === 'iter'){\n          return ternaryIterative(arr, target);\n        }else{\n          return ternaryRecursive(arr, target);\n        }\n      }\n\n      function resetStateForRun(){\n        comparisons = 0;\n        iterations = 0;\n        compCount.textContent = '0';\n        iterCount.textContent = '0';\n        resultText.textContent = '-';\n        logArea.innerHTML = '';\n        clearHighlights();\n      }\n\n      function step(){\n        if(!gen){\n          gen = createGenerator();\n          if(!gen) return;\n        }\n        const res = gen.next();\n        if(res.done){\n          // final return value could include found info\n          const val = res.value || {};\n          if(val && val.found){\n            resultText.textContent = 'Found at index '+val.index;\n            log('Target found at index '+val.index+' after '+(val.iterations || iterations)+' iterations.');\n          }else{\n            resultText.textContent = 'Not found';\n            log('Target not found after '+(val.iterations || iterations)+' iterations.');\n          }\n          playing = false;\n          playBtn.textContent = 'Play';\n          return;\n        }\n        const state = res.value;\n        lastState = state;\n        handleState(state);\n      }\n\n      function handleState(state){\n        // update counters\n        if(state.stage === 'compare_m1' || state.stage === 'compare_m2') comparisons++;\n        if(state.iter !== undefined) iterations = state.iter;\n        compCount.textContent = comparisons;\n        iterCount.textContent = iterations;\n        // update visuals\n        highlightRange(state);\n        // log messages for visibility\n        switch(state.stage){\n          case 'computed':\n            log('Iteration '+state.iter+': m1='+state.m1+' (val='+arr[state.m1]+'), m2='+state.m2+' (val='+arr[state.m2]+'). Range ['+state.l+','+state.r+']');\n            break;\n          case 'compare_m1':\n            log('Compare m1: arr['+state.m1+'] ('+state.value+') with target '+target);\n            break;\n          case 'm1_gt':\n            log('target < arr['+state.m1+'] → search left third (set r = '+(state.m1-1)+')');\n            break;\n          case 'compare_m2':\n            log('Compare m2: arr['+state.m2+'] ('+state.value+') with target '+target);\n            break;\n          case 'between':\n            log('arr['+state.m1+'] < target < arr['+state.m2+'] → search middle third (l='+ (state.m1+1) +', r='+ (state.m2-1) +')');\n            break;\n          case 'm2_lt':\n            log('target > arr['+state.m2+'] → search right third (set l = '+(state.m2+1)+')');\n            break;\n          case 'found':\n            log('Found target at index '+state.index+'!');\n            resultText.textContent = 'Found at index '+state.index;\n            highlightRange(state);\n            break;\n          case 'not_found':\n            log('Interval empty. Target not found.');\n            resultText.textContent = 'Not found';\n            highlightRange(state);\n            break;\n          default:\n            log('Step: '+state.stage);\n        }\n      }\n\n      function play(){\n        if(playing){\n          stop();\n          return;\n        }\n        if(!gen){\n          gen = createGenerator();\n          if(!gen) return;\n        }\n        playing = true;\n        playBtn.textContent = 'Pause';\n        runLoop();\n      }\n\n      function runLoop(){\n        if(!playing) return;\n        step();\n        // if last state signaled found or not found, stop\n        if(resultText.textContent !== '-' && (resultText.textContent.includes('Found') || resultText.textContent.includes('Not found'))){\n          stop();\n          return;\n        }\n        const delay = parseInt(speedRange.value,10);\n        timer = setTimeout(runLoop, delay);\n      }\n\n      function stop(){\n        playing = false;\n        if(timer) clearTimeout(timer);\n        playBtn.textContent = 'Play';\n      }\n\n      // UI wiring\n      sizeRange.addEventListener('input',()=>{\n        size = Number(sizeRange.value);\n        sizeLabel.textContent = size;\n      });\n\n      genBtn.addEventListener('click',()=>{\n        generateArray(size);\n      });\n\n      setTargetBtn.addEventListener('click',()=>{\n        if(targetInput.value === '') { flashLog('Enter a value into the Target field or click a cell.'); return; }\n        setTarget(Number(targetInput.value));\n      });\n\n      stepBtn.addEventListener('click',()=>{\n        stop();\n        step();\n      });\n\n      playBtn.addEventListener('click',()=>{\n        play();\n      });\n\n      resetBtn.addEventListener('click',()=>{\n        generateArray(size);\n        targetInput.value = '';\n        target = null;\n        resetExecution();\n      });\n\n      // helpers\n      function highlightTargetInInput(){\n        // if target equals some array value, highlight that cell\n        document.querySelectorAll('.cell').forEach(c => {\n          c.classList.remove('found-candidate');\n        });\n        if(target === null) return;\n        const idx = arr.indexOf(Number(target));\n        if(idx !== -1){\n          const cell = document.querySelector('.cell[data-index=\"'+idx+'\"]');\n          if(cell) cell.style.outline = '2px dashed rgba(96,165,250,0.2)';\n          setTimeout(()=>{ if(cell) cell.style.outline = ''; }, 1200);\n        }\n      }\n\n      // initial generation\n      generateArray(size);\n\n      // small UX: enter key in input sets\n      targetInput.addEventListener('keydown', (e)=>{\n        if(e.key === 'Enter'){\n          setTargetBtn.click();\n        }\n      });\n\n      // mode change resets run\n      modeSelect.addEventListener('change', ()=>{\n        resetExecution();\n      });\n\n    })();\n  </script>\n</body>\n</html>"
