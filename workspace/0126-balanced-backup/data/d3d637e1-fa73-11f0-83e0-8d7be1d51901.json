    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Merge Sort Visualization</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#06b6d4;\n      --muted:#94a3b8;\n      --bar:#60a5fa;\n      --bar-compare:#f59e0b;\n      --bar-write:#10b981;\n      --bar-range:#7c3aed;\n      --panel-2:#071123;\n      --text:#e6eef8;\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: linear-gradient(180deg,var(--bg), #071224 140%);\n      color:var(--text);\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n    }\n    .wrap{\n      max-width:1100px;\n      margin:24px auto;\n      padding:20px;\n    }\n    header{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n      margin-bottom:18px;\n    }\n    h1{\n      font-size:20px;\n      margin:0;\n      letter-spacing:0.2px;\n    }\n    .controls{\n      display:flex;\n      flex-wrap:wrap;\n      gap:8px;\n    }\n    .panel{\n      background:linear-gradient(180deg,var(--panel),var(--panel-2));\n      border-radius:10px;\n      padding:12px;\n      box-shadow: 0 6px 24px rgba(2,6,23,0.6);\n    }\n    .control-row{display:flex;align-items:center;gap:10px;}\n    button{\n      background:linear-gradient(180deg,var(--accent), #0aa9c3);\n      border:none;\n      color:#022;\n      font-weight:600;\n      padding:8px 12px;\n      border-radius:8px;\n      cursor:pointer;\n      transition:transform 120ms ease;\n    }\n    button.secondary{\n      background:transparent;\n      color:var(--text);\n      border:1px solid rgba(255,255,255,0.06);\n    }\n    button:active{transform:translateY(1px)}\n    .small{\n      padding:6px 8px;\n      font-size:13px;\n    }\n    label{font-size:13px;color:var(--muted)}\n    input[type=\"range\"]{width:160px;}\n    .layout{\n      display:grid;\n      grid-template-columns: 1fr 320px;\n      gap:14px;\n    }\n    .visual.panel{\n      height:420px;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n      padding:12px;\n    }\n    .array-area{\n      flex:1;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n      border-radius:8px;\n      padding:10px;\n      display:flex;\n      align-items:flex-end;\n      gap:6px;\n      overflow:hidden;\n      position:relative;\n    }\n    .bars{display:flex;align-items:flex-end;gap:6px;width:100%;}\n    .bar{\n      background:var(--bar);\n      height:40px;\n      flex:1;\n      border-radius:4px 4px 0 0;\n      display:flex;\n      align-items:flex-end;\n      justify-content:center;\n      color:rgba(255,255,255,0.9);\n      font-size:11px;\n      user-select:none;\n      transition: height 250ms ease, background-color 160ms linear;\n      box-shadow: 0 2px 8px rgba(2,6,23,0.4), inset 0 -2px 3px rgba(255,255,255,0.02);\n    }\n    .bar .val{padding:4px;font-weight:700;}\n    .bar.compare{background:var(--bar-compare); color:#081018;}\n    .bar.write{background:var(--bar-write); color:#02120a;}\n    .bar.range{box-shadow: 0 0 0 3px rgba(124,58,237,0.08), inset 0 -2px 3px rgba(255,255,255,0.02);}\n    .pseudocode{\n      font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n      font-size:13px;\n      line-height:1.5;\n      background:rgba(255,255,255,0.02);\n      padding:12px;\n      border-radius:8px;\n      color:var(--muted);\n      max-height:380px;\n      overflow:auto;\n    }\n    .code-line{\n      padding:6px 8px;\n      border-radius:6px;\n    }\n    .code-line.active{\n      background:linear-gradient(90deg, rgba(6,182,212,0.08), rgba(124,58,237,0.06));\n      color:var(--text);\n      border-left:3px solid var(--accent);\n    }\n    .legend{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n    .legend .item{\n      display:flex;\n      align-items:center;\n      gap:8px;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .swatch{\n      width:18px;\n      height:12px;\n      border-radius:4px;\n      box-shadow: 0 2px 6px rgba(2,6,23,0.5);\n    }\n    footer{\n      margin-top:14px;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .top-controls{display:flex;gap:8px;align-items:center;}\n    .status{\n      font-size:13px;\n      color:var(--muted);\n      margin-left:8px;\n    }\n    .range-value{min-width:36px;text-align:center;}\n    @media (max-width:980px){\n      .layout{grid-template-columns:1fr; }\n      .visual.panel{height:360px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <header class=\"panel\">\n      <div style=\"display:flex;flex-direction:column;\">\n        <h1>Merge Sort — Interactive Visualization</h1>\n        <div style=\"color:var(--muted);font-size:13px;margin-top:6px;\">\n          Watch merge sort split and merge subarrays. Use controls to play, step, and adjust speed/size.\n        </div>\n      </div>\n      <div class=\"controls\">\n        <div class=\"top-controls\">\n          <button id=\"newBtn\">New Array</button>\n          <button id=\"shuffleBtn\" class=\"secondary small\">Shuffle</button>\n          <button id=\"sortBtn\" class=\"small\">Start</button>\n          <button id=\"pauseBtn\" class=\"secondary small\" disabled>Pause</button>\n          <button id=\"stepBtn\" class=\"secondary small\">Step</button>\n          <div class=\"status\" id=\"status\">Idle</div>\n        </div>\n      </div>\n    </header>\n\n    <div class=\"layout\">\n      <section class=\"visual panel\">\n        <div style=\"display:flex;align-items:center;justify-content:space-between;\">\n          <div style=\"display:flex;align-items:center;gap:10px;\">\n            <label>Size</label>\n            <input id=\"sizeRange\" type=\"range\" min=\"6\" max=\"80\" value=\"30\">\n            <div class=\"range-value\" id=\"sizeValue\">30</div>\n            <label>Speed</label>\n            <input id=\"speedRange\" type=\"range\" min=\"0\" max=\"1000\" value=\"300\">\n            <div class=\"range-value\" id=\"speedValue\">300ms</div>\n          </div>\n          <div class=\"legend\">\n            <div class=\"item\"><div class=\"swatch\" style=\"background:var(--bar-compare)\"></div> Compare</div>\n            <div class=\"item\"><div class=\"swatch\" style=\"background:var(--bar-write)\"></div> Write</div>\n            <div class=\"item\"><div class=\"swatch\" style=\"background:var(--bar-range)\"></div> Current Merge Range</div>\n          </div>\n        </div>\n\n        <div class=\"array-area panel\" id=\"arrayArea\">\n          <div class=\"bars\" id=\"bars\"></div>\n        </div>\n\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <div style=\"color:var(--muted);font-size:13px\">Array Visual</div>\n          <div style=\"color:var(--muted);font-size:13px\">Merge Sort (Top-down)</div>\n        </div>\n      </section>\n\n      <aside class=\"panel\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;\">\n          <div style=\"font-weight:700\">Pseudocode</div>\n          <div style=\"color:var(--muted);font-size:13px\">Highlighted step</div>\n        </div>\n        <div class=\"pseudocode\" id=\"pseudocode\">\n          <div class=\"code-line\" id=\"line1\">1  function mergeSort(A, l, r)</div>\n          <div class=\"code-line\" id=\"line2\">2    if l >= r: return</div>\n          <div class=\"code-line\" id=\"line3\">3    mid = (l + r) // 2</div>\n          <div class=\"code-line\" id=\"line4\">4    mergeSort(A, l, mid)</div>\n          <div class=\"code-line\" id=\"line5\">5    mergeSort(A, mid+1, r)</div>\n          <div class=\"code-line\" id=\"line6\">6    merge(A, l, mid, r)</div>\n          <hr style=\"border:none;border-top:1px solid rgba(255,255,255,0.03);margin:8px 0;\">\n          <div class=\"code-line\" id=\"line7\">7  function merge(A, l, mid, r)</div>\n          <div class=\"code-line\" id=\"line8\">8    left = A[l..mid]</div>\n          <div class=\"code-line\" id=\"line9\">9    right = A[mid+1..r]</div>\n          <div class=\"code-line\" id=\"line10\">10   i = 0; j = 0; k = l</div>\n          <div class=\"code-line\" id=\"line11\">11   while i &lt; len(left) and j &lt; len(right):</div>\n          <div class=\"code-line\" id=\"line12\">12     if left[i] &lt;= right[j]:</div>\n          <div class=\"code-line\" id=\"line13\">13       A[k] = left[i]; i += 1</div>\n          <div class=\"code-line\" id=\"line14\">14     else:</div>\n          <div class=\"code-line\" id=\"line15\">15       A[k] = right[j]; j += 1</div>\n          <div class=\"code-line\" id=\"line16\">16     k += 1</div>\n          <div class=\"code-line\" id=\"line17\">17   while i &lt; len(left):</div>\n          <div class=\"code-line\" id=\"line18\">18     A[k] = left[i]; i += 1; k += 1</div>\n          <div class=\"code-line\" id=\"line19\">19   while j &lt; len(right):</div>\n          <div class=\"code-line\" id=\"line20\">20     A[k] = right[j]; j += 1; k += 1</div>\n        </div>\n        <div style=\"margin-top:10px; display:flex;gap:8px;flex-wrap:wrap;\">\n          <button id=\"resetBtn\" class=\"secondary small\">Reset View</button>\n          <button id=\"explainBtn\" class=\"secondary small\">Show Steps</button>\n        </div>\n      </aside>\n    </div>\n\n    <footer>\n      Tips: Use \"Start\" to animate automatically, \"Step\" to move action-by-action. Adjust size & speed for detail.\n    </footer>\n  </div>\n\n  <script>\n    (function(){\n      // DOM\n      const barsContainer = document.getElementById('bars');\n      const sizeRange = document.getElementById('sizeRange');\n      const sizeValue = document.getElementById('sizeValue');\n      const speedRange = document.getElementById('speedRange');\n      const speedValue = document.getElementById('speedValue');\n      const newBtn = document.getElementById('newBtn');\n      const shuffleBtn = document.getElementById('shuffleBtn');\n      const sortBtn = document.getElementById('sortBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const stepBtn = document.getElementById('stepBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const status = document.getElementById('status');\n\n      const pseudocodeLines = {};\n      for(let i=1;i<=20;i++) pseudocodeLines[i] = document.getElementById('line'+i);\n\n      // State\n      let array = [];\n      let size = parseInt(sizeRange.value,10);\n      let maxVal = 200;\n      let actions = [];\n      let actionIndex = 0;\n      let playing = false;\n      let timer = null;\n      let delay = parseInt(speedRange.value,10);\n      let barElems = [];\n      let lastHighlighted = {indices:[],range:[]};\n\n      sizeValue.textContent = size;\n      speedValue.textContent = delay + 'ms';\n\n      // Utilities\n      function randInt(min,max){ return Math.floor(Math.random()*(max-min+1))+min; }\n\n      function createArray(n){\n        array = [];\n        maxVal = Math.max(50, n*5);\n        for(let i=0;i<n;i++){\n          array.push(randInt(8,maxVal));\n        }\n        return array;\n      }\n\n      function renderArray(){\n        barsContainer.innerHTML='';\n        barElems = [];\n        const n = array.length;\n        for(let i=0;i<n;i++){\n          const b = document.createElement('div');\n          b.className = 'bar';\n          b.style.flex = '1 1 auto';\n          // compute height relative to max\n          const hPercent = Math.max(3, Math.round((array[i]/maxVal)*100));\n          b.style.height = (hPercent*0.9) + '%';\n          b.dataset.index = i;\n          const v = document.createElement('div');\n          v.className='val';\n          v.textContent = array[i];\n          b.appendChild(v);\n          barsContainer.appendChild(b);\n          barElems.push(b);\n        }\n      }\n\n      function shuffleArray(){\n        for(let i=array.length-1;i>0;i--){\n          const j=randInt(0,i);\n          [array[i],array[j]]=[array[j],array[i]];\n        }\n        renderArray();\n      }\n\n      // Merge sort action generator: produces list of actions to replay with indices into the main array\n      function generateActions(arrIn){\n        const arr = arrIn.slice(); // work on a copy\n        const n = arr.length;\n        const acts = [];\n\n        function markSplit(l,r,mid){\n          acts.push({type:'markSplit', l, r, mid});\n        }\n        function merge(l, mid, r){\n          const left = arr.slice(l, mid+1);\n          const right = arr.slice(mid+1, r+1);\n          let i=0,j=0,k=l;\n          // highlight the current merge range\n          acts.push({type:'markRange', l, mid, r});\n          while(i<left.length && j<right.length){\n            // compare indices in the main array representation\n            acts.push({type:'compare', iIndex: l + i, jIndex: mid + 1 + j, l, mid, r});\n            if(left[i] <= right[j]){\n              acts.push({type:'overwrite', index:k, value:left[i], fromIndex: l + i, l, mid, r});\n              arr[k] = left[i];\n              i++; k++;\n            } else {\n              acts.push({type:'overwrite', index:k, value:right[j], fromIndex: mid + 1 + j, l, mid, r});\n              arr[k] = right[j];\n              j++; k++;\n            }\n          }\n          while(i<left.length){\n            acts.push({type:'overwrite', index:k, value:left[i], fromIndex: l + i, l, mid, r});\n            arr[k] = left[i];\n            i++; k++;\n          }\n          while(j<right.length){\n            acts.push({type:'overwrite', index:k, value:right[j], fromIndex: mid + 1 + j, l, mid, r});\n            arr[k] = right[j];\n            j++; k++;\n          }\n          acts.push({type:'mergeComplete', l, mid, r});\n        }\n\n        function sort(l,r){\n          if(l>=r) return;\n          const mid = Math.floor((l + r)/2);\n          markSplit(l,r,mid);\n          sort(l, mid);\n          sort(mid+1, r);\n          merge(l, mid, r);\n        }\n\n        sort(0, n-1);\n        return acts;\n      }\n\n      // Playback functions\n      function clearHighlights(){\n        // remove classes\n        barElems.forEach(b => {\n          b.classList.remove('compare','write','range');\n        });\n        for(let i=1;i<=20;i++) pseudocodeLines[i].classList.remove('active');\n      }\n\n      function highlightCode(lines){\n        for(let i=1;i<=20;i++) pseudocodeLines[i].classList.remove('active');\n        if(!lines) return;\n        if(Array.isArray(lines)){\n          lines.forEach(l => { if(pseudocodeLines[l]) pseudocodeLines[l].classList.add('active'); });\n        } else {\n          if(pseudocodeLines[lines]) pseudocodeLines[lines].classList.add('active');\n        }\n      }\n\n      function applyAction(act){\n        clearHighlights();\n        switch(act.type){\n          case 'markSplit':\n            // indicate dividing step - highlight the top lines that perform the split\n            highlightCode([1,2,3]);\n            // briefly mark the mid point bar(s)\n            highlightRange(act.l, act.r, 'range');\n            status.textContent = `Splitting [${act.l} .. ${act.r}] at ${act.mid}`;\n            break;\n          case 'markRange':\n            // highlight the subarray being merged\n            highlightCode([7,8,9,10]);\n            highlightRange(act.l, act.r, 'range');\n            status.textContent = `Merging range [${act.l} .. ${act.r}]`;\n            break;\n          case 'compare':\n            highlightCode([11,12]);\n            markBar(act.iIndex, 'compare');\n            markBar(act.jIndex, 'compare');\n            highlightRange(act.l, act.r, 'range');\n            status.textContent = `Compare A[${act.iIndex}] and A[${act.jIndex}]`;\n            break;\n          case 'overwrite':\n            // show write and update bar at index\n            highlightCode([13,15,16,18,20]); // generic highlight for write/copy lines\n            markBar(act.index, 'write');\n            // animate height and value change\n            updateBarValue(act.index, act.value);\n            highlightRange(act.l, act.r, 'range');\n            status.textContent = `Write A[${act.index}] = ${act.value}`;\n            break;\n          case 'mergeComplete':\n            highlightCode(6); // merge(A, l, mid, r) call line\n            highlightRange(act.l, act.r, 'range');\n            status.textContent = `Completed merge [${act.l} .. ${act.r}]`;\n            // after a moment leave range displayed until next action clears\n            break;\n        }\n      }\n\n      function markBar(index, cls){\n        if(index >=0 && index < barElems.length){\n          barElems[index].classList.add(cls);\n        }\n      }\n\n      function highlightRange(l, r, cls){\n        for(let i=l;i<=r;i++){\n          if(i>=0 && i<barElems.length) barElems[i].classList.add(cls);\n        }\n      }\n\n      function updateBarValue(index, value){\n        if(index < 0 || index >= barElems.length) return;\n        const b = barElems[index];\n        const v = b.querySelector('.val');\n        v.textContent = value;\n        // update height proportional to current maxVal\n        const hPercent = Math.max(3, Math.round((value/maxVal)*100));\n        b.style.height = (hPercent*0.9) + '%';\n      }\n\n      // Play control\n      function play(){\n        if(playing) return;\n        if(actions.length===0){\n          // generate actions\n          actions = generateActions(array);\n          actionIndex = 0;\n        }\n        playing = true;\n        sortBtn.disabled = true;\n        pauseBtn.disabled = false;\n        newBtn.disabled = true;\n        shuffleBtn.disabled = true;\n        sizeRange.disabled = true;\n        stepBtn.disabled = true;\n        status.textContent = 'Playing...';\n        scheduleNext();\n      }\n\n      function scheduleNext(){\n        if(!playing) return;\n        if(actionIndex >= actions.length){\n          stopPlaying(true);\n          return;\n        }\n        const act = actions[actionIndex++];\n        applyAction(act);\n        timer = setTimeout(scheduleNext, delay || 50);\n      }\n\n      function pause(){\n        if(!playing) return;\n        playing = false;\n        clearTimeout(timer);\n        sortBtn.disabled = false;\n        pauseBtn.disabled = true;\n        newBtn.disabled = false;\n        shuffleBtn.disabled = false;\n        sizeRange.disabled = false;\n        stepBtn.disabled = false;\n        status.textContent = 'Paused';\n      }\n\n      function stopPlaying(end){\n        playing = false;\n        clearTimeout(timer);\n        sortBtn.disabled = end;\n        pauseBtn.disabled = true;\n        newBtn.disabled = false;\n        shuffleBtn.disabled = false;\n        sizeRange.disabled = false;\n        stepBtn.disabled = false;\n        if(end){\n          status.textContent = 'Completed';\n          // final highlight none\n          clearHighlights();\n        } else {\n          status.textContent = 'Stopped';\n        }\n      }\n\n      function step(){\n        if(actions.length===0){\n          actions = generateActions(array);\n          actionIndex = 0;\n        }\n        if(actionIndex >= actions.length){\n          status.textContent = 'Completed';\n          return;\n        }\n        const act = actions[actionIndex++];\n        applyAction(act);\n        // if finished\n        if(actionIndex >= actions.length){\n          status.textContent = 'Completed';\n        } else {\n          status.textContent = 'Stepped';\n        }\n      }\n\n      // Reset view: re-render original array from values on bars (use current array), clear highlights and actions\n      function resetView(){\n        if(playing) pause();\n        actions = [];\n        actionIndex = 0;\n        clearHighlights();\n        renderArray();\n        status.textContent = 'Reset view';\n      }\n\n      // Initial setup\n      function init(){\n        createArray(size);\n        renderArray();\n        status.textContent = 'Idle';\n      }\n\n      // Listeners\n      sizeRange.addEventListener('input', e=>{\n        size = parseInt(e.target.value,10);\n        sizeValue.textContent = size;\n      });\n\n      sizeRange.addEventListener('change', e=>{\n        size = parseInt(e.target.value,10);\n        createArray(size);\n        renderArray();\n        // reset actions & state\n        actions = [];\n        actionIndex = 0;\n        status.textContent = 'Array size changed';\n      });\n\n      speedRange.addEventListener('input', e=>{\n        delay = parseInt(e.target.value,10);\n        speedValue.textContent = delay + 'ms';\n      });\n\n      newBtn.addEventListener('click', ()=>{\n        if(playing) return;\n        createArray(size);\n        renderArray();\n        actions = [];\n        actionIndex = 0;\n        status.textContent = 'New array created';\n      });\n\n      shuffleBtn.addEventListener('click', ()=>{\n        if(playing) return;\n        shuffleArray();\n        actions = [];\n        actionIndex = 0;\n        status.textContent = 'Shuffled';\n      });\n\n      sortBtn.addEventListener('click', ()=>{ play(); });\n\n      pauseBtn.addEventListener('click', ()=>{ pause(); });\n\n      stepBtn.addEventListener('click', ()=>{ step(); });\n\n      resetBtn.addEventListener('click', ()=>{ resetView(); });\n\n      // small helper to show all steps (list actions count)\n      document.getElementById('explainBtn').addEventListener('click', ()=>{\n        if(playing) return;\n        const acts = generateActions(array);\n        alert('This array will generate ' + acts.length + ' actions (comparisons & writes). Use Step or Start to visualize them.');\n      });\n\n      // keyboard shortcuts\n      window.addEventListener('keydown', (e)=>{\n        if(e.key === ' '){\n          e.preventDefault();\n          if(playing) pause(); else play();\n        } else if(e.key === '>'){\n          step();\n        }\n      });\n\n      // Initialize\n      init();\n\n      // Make bars responsive on window resize (re-render to adjust spacing)\n      window.addEventListener('resize', () => { /* no-op for now */ });\n\n    })();\n  </script>\n</body>\n</html>"
  },
