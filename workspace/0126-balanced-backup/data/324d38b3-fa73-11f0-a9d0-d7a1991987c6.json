    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Insertion Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f4f4f4;\n            padding: 50px;\n        }\n        #array {\n            display: flex;\n            justify-content: center;\n            margin: 20px 0;\n        }\n        .bar {\n            width: 30px;\n            margin: 0 2px;\n            background-color: teal;\n            display: inline-block;\n            transition: background-color 0.3s;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Insertion Sort Visualization</h1>\n<div id=\"array\"></div>\n<button id=\"sortButton\">Start Insertion Sort</button>\n\n<script>\n    const array = [5, 3, 8, 4, 2];\n    const arrayContainer = document.getElementById('array');\n\n    function visualizeArray(array) {\n        arrayContainer.innerHTML = '';\n        array.forEach(value => {\n            const bar = document.createElement('div');\n            bar.className = 'bar';\n            bar.style.height = `${value * 30}px`;\n            arrayContainer.appendChild(bar);\n        });\n    }\n\n    async function insertionSort(arr) {\n        for (let i = 1; i < arr.length; i++) {\n            let key = arr[i];\n            let j = i - 1;\n\n            while (j >= 0 && arr[j] > key) {\n                arr[j + 1] = arr[j];\n                visualizeArray(arr);\n                await new Promise(resolve => setTimeout(resolve, 500));\n                j--;\n            }\n            arr[j + 1] = key;\n            visualizeArray(arr);\n            await new Promise(resolve => setTimeout(resolve, 500));\n        }\n    }\n\n    document.getElementById('sortButton').addEventListener('click', () => {\n        const arrCopy = [...array];\n        visualizeArray(arrCopy);\n        insertionSort(arrCopy);\n    });\n\n    visualizeArray(array); // Initial visualization\n</script>\n</body>\n</html>"
