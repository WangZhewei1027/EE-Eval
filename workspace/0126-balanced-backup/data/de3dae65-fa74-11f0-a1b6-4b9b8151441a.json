    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Static Typing Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        .container {\n            border: 1px solid #ddd;\n            padding: 20px;\n            border-radius: 5px;\n            background-color: #f9f9f9;\n        }\n        .success { color: green; }\n        .error { color: red; }\n    </style>\n</head>\n<body>\n    <h1>Static Typing in JavaScript (using TypeScript-like demonstration)</h1>\n    \n    <div class=\"container\">\n        <h2>1. Type Annotations</h2>\n        <p id=\"type-annotation-result\" class=\"success\">Checking type annotations...</p>\n        \n        <h2>2. Type Safety</h2>\n        <p id=\"type-safety-result\">Attempting incorrect type assignment...</p>\n        \n        <h2>3. Function Parameter Types</h2>\n        <p id=\"function-params-result\">Testing function parameter types...</p>\n        \n        <h2>4. Return Type Checking</h2>\n        <p id=\"return-type-result\">Verifying function return types...</p>\n    </div>\n\n    <script>\n        // This demo simulates static typing behavior that would normally be caught\n        // by TypeScript compiler, but shows the concepts in plain JavaScript\n\n        // 1. Type Annotations (simulated)\n        function simulateStaticTyping() {\n            try {\n                // Simulate type annotation (not real JS syntax)\n                let message = \"/* string */ 'Hello World'\";\n                let count = \"/* number */ 42\";\n                let flag = \"/* boolean */ true\";\n                \n                document.getElementById('type-annotation-result').innerHTML = \n                    `Types declared successfully: <br>\n                    message: ${typeof 'Hello World'}, \n                    count: ${typeof 42}, \n                    flag: ${typeof true}`;\n                    \n                return true;\n            } catch (e) {\n                document.getElementById('type-annotation-result').className = 'error';\n                document.getElementById('type-annotation-result').textContent = \n                    'Type error: ' + e.message;\n                return false;\n            }\n        }\n\n        // 2. Type Safety\n        function testTypeSafety() {\n            try {\n                // This would cause a type error in TypeScript\n                let num = \"/* number */ 10\";\n                num = \"'string value'\"; // Wrong type!\n                \n                document.getElementById('type-safety-result').className = 'error';\n                document.getElementById('type-safety-result').innerHTML = \n                    'Expected type error did NOT occur in JavaScript (would fail in TypeScript).<br>' +\n                    'In JavaScript, num is now: ' + typeof 'string value';\n            } catch (e) {\n                document.getElementById('type-safety-result').className = 'success';\n                document.getElementById('type-safety-result').textContent = \n                    'Type safety enforced (simulated): ' + e.message;\n            }\n        }\n\n        // 3. Function Parameter Types\n        function testFunctionParams(success) {\n            try {\n                function addNumbers(/* number */ a, /* number */ b) {\n                    return a + b;\n                }\n                \n                let result = addNumbers(5, 10); // Correct types\n                let badResult = addNumbers(5, 'hello'); // Wrong type (but JS allows it)\n                \n                if (success) {\n                    document.getElementById('function-params-result').className = 'success';\n                    document.getElementById('function-params-result').textContent = \n                        'Correct params: addNumbers(5, 10) = ' + result;\n                } else {\n                    document.getElementById('function-params-result').className = 'error';\n                    document.getElementById('function-params-result').innerHTML = \n                        'In JavaScript: No error for wrong parameter type!<br>' +\n                        'addNumbers(5, \"hello\") = ' + badResult + '<br>' +\n                        '(In TypeScript this would cause a compile error)';\n                }\n            } catch (e) {\n                document.getElementById('function-params-result').className = 'error';\n                document.getElementById('function-params-result').textContent = \n                    'Parameter type enforced (simulated): ' + e.message;\n            }\n        }\n\n        // 4. Return Type Checking\n        function testReturnTypes() {\n            try {\n                function getUserAge(/* string */ name) /* : number */ {\n                    if (name === 'Alice') return 30;\n                    return 'Unknown'; // Wrong return type (but JS allows it)\n                }\n                \n                let age = getUserAge('Alice'); // Correct\n                let badAge = getUserAge('Bob'); // Returns string when number expected\n                \n                document.getElementById('return-type-result').className = 'error';\n                document.getElementById('return-type-result').innerHTML = \n                    'In JavaScript: No error for wrong return type!<br>' +\n                    'getUserAge(\"Alice\") = ${age} (type: ${typeof age})<br>' +\n                    'getUserAge(\"Bob\") = \"${badAge}\" (type: ${typeof badAge})<br>' +\n                    '(In TypeScript this would cause a compile error)';\n            } catch (e) {\n                document.getElementById('return-type-result').className = 'success';\n                document.getElementById('return-type-result').textContent = \n                    'Return type enforced (simulated): ' + e.message;\n            }\n        }\n\n        // Run all tests\n        setTimeout(() => {\n            simulateStaticTyping();\n            testTypeSafety();\n            testFunctionParams(false); // false to show the type safety issue\n            testReturnTypes();\n        }, 500);\n    </script>\n</body>\n</html>"
