  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Bubble Sort Visualizer</title>\n<style>\n  :root{\n    --bg:#0f1724;\n    --panel:#0b1220;\n    --primary:#7c3aed;\n    --muted:#94a3b8;\n    --good:#16a34a;\n    --bad:#ef4444;\n    --compare:#f59e0b;\n    --bar-bg:#111827;\n    --card:#0b1220;\n  }\n  *{box-sizing:border-box}\n  body{\n    margin:0;\n    font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    background:linear-gradient(180deg,var(--bg),#051026);\n    color:#e6eef8;\n    min-height:100vh;\n    display:flex;\n    align-items:flex-start;\n    justify-content:center;\n    padding:28px;\n  }\n  .app{\n    width:100%;\n    max-width:1100px;\n  }\n  header{\n    display:flex;\n    align-items:center;\n    gap:18px;\n    margin-bottom:16px;\n  }\n  h1{\n    margin:0;\n    font-size:20px;\n    letter-spacing:0.2px;\n  }\n  .controls{\n    background:linear-gradient(180deg,var(--card), #071024);\n    border-radius:12px;\n    padding:14px;\n    display:flex;\n    gap:12px;\n    align-items:center;\n    flex-wrap:wrap;\n    box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n  }\n  .control-group{display:flex;gap:8px;align-items:center}\n  button{\n    background:transparent;\n    border:1px solid rgba(255,255,255,0.06);\n    color:var(--muted);\n    padding:8px 12px;\n    border-radius:8px;\n    cursor:pointer;\n    font-weight:600;\n    transition:all 150ms;\n  }\n  button.primary{\n    background:linear-gradient(90deg,var(--primary),#4c1d95);\n    color:white;\n    border: none;\n    box-shadow: 0 6px 18px rgba(124,58,237,0.18);\n  }\n  button:disabled{opacity:0.45;cursor:not-allowed}\n  input[type=\"range\"]{accent-color:var(--primary)}\n  .label{font-size:13px;color:var(--muted);min-width:110px}\n  .stats{display:flex;gap:12px;align-items:center}\n  .stat{font-size:13px;color:var(--muted);background:rgba(255,255,255,0.03);padding:8px 10px;border-radius:8px}\n  main{\n    margin-top:14px;\n    display:grid;\n    grid-template-columns: 1fr 360px;\n    gap:18px;\n  }\n  .visual{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n    border-radius:12px;\n    padding:14px;\n    min-height:420px;\n    display:flex;\n    flex-direction:column;\n    gap:12px;\n  }\n  .array-area{\n    background:linear-gradient(180deg,var(--bar-bg), #071024);\n    border-radius:10px;\n    height:360px;\n    display:flex;\n    align-items:flex-end;\n    padding:10px;\n    gap:6px;\n    overflow:hidden;\n  }\n  .bar{\n    background:linear-gradient(180deg,#60a5fa,#1e40af);\n    width:18px;\n    border-radius:6px 6px 4px 4px;\n    display:flex;\n    align-items:flex-end;\n    justify-content:center;\n    color:rgba(255,255,255,0.9);\n    font-size:11px;\n    font-weight:700;\n    transition:height 240ms ease, background 180ms ease, transform 180ms ease;\n    box-shadow: 0 4px 12px rgba(2,6,23,0.6);\n    position:relative;\n  }\n  .bar::after{\n    content:\"\";\n    position:absolute;\n    left:0;right:0;top:0;height:6px;border-radius:6px 6px 0 0;\n    background:linear-gradient(180deg, rgba(255,255,255,0.06), transparent);\n  }\n  .bar.small{font-size:10px}\n  .bar.compare{background:linear-gradient(180deg,var(--compare),#d97706); transform: translateY(-6px);}\n  .bar.swap{background:linear-gradient(180deg,var(--bad),#b91c1c); transform: translateY(-6px);}\n  .bar.sorted{background:linear-gradient(180deg,var(--good),#15803d)}\n  .side{\n    background:linear-gradient(180deg,var(--card),#041025);\n    border-radius:12px;\n    padding:12px;\n    min-height:420px;\n  }\n  .section{margin-bottom:12px}\n  .section h3{margin:0 0 8px 0;font-size:14px}\n  .pseudocode{\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n    border-radius:8px;\n    padding:10px;\n    font-family:ui-monospace,SFMono-Regular,Menlo,monospace;\n    font-size:13px;\n    color:var(--muted);\n    line-height:1.6;\n  }\n  .pseudocode div{padding:6px;border-radius:6px}\n  .pseudocode .active{background:rgba(124,58,237,0.12);color:#fff}\n  .footer-note{font-size:13px;color:var(--muted)}\n  .controls-wrap{display:flex;gap:8px;flex-wrap:wrap}\n  .top-row{display:flex;justify-content:space-between;align-items:center;gap:12px}\n  @media (max-width:980px){\n    main{grid-template-columns:1fr; padding-bottom:20px}\n    .side{order:-1}\n    .array-area{height:280px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"app\">\n    <header>\n      <h1>Bubble Sort — Visual Demonstration</h1>\n    </header>\n\n    <div class=\"controls\">\n      <div class=\"control-group\">\n        <label class=\"label\">Array Size</label>\n        <input id=\"size\" type=\"range\" min=\"5\" max=\"70\" value=\"28\" />\n      </div>\n\n      <div class=\"control-group\">\n        <label class=\"label\">Speed</label>\n        <input id=\"speed\" type=\"range\" min=\"10\" max=\"1000\" value=\"200\" />\n      </div>\n\n      <div class=\"control-group controls-wrap\">\n        <button id=\"shuffleBtn\">Shuffle</button>\n        <button id=\"startBtn\" class=\"primary\">Start</button>\n        <button id=\"pauseBtn\" disabled>Pause</button>\n        <button id=\"stepBtn\">Step</button>\n        <button id=\"resetBtn\">Reset</button>\n      </div>\n\n      <div style=\"margin-left:auto\" class=\"stats\">\n        <div class=\"stat\">Comparisons: <span id=\"compCount\">0</span></div>\n        <div class=\"stat\">Swaps: <span id=\"swapCount\">0</span></div>\n      </div>\n    </div>\n\n    <main>\n      <section class=\"visual\">\n        <div class=\"top-row\">\n          <div style=\"font-size:13px;color:var(--muted)\">Bubble Sort iteratively compares adjacent items and swaps them to \"bubble\" larger values to the end.</div>\n          <div style=\"font-size:13px;color:var(--muted)\"><strong>Note:</strong> You can Step through or Play.</div>\n        </div>\n\n        <div class=\"array-area\" id=\"arrayArea\" aria-hidden=\"false\"></div>\n\n        <div class=\"footer-note\">\n          Hover bars to see values. Sorted bars are green. Current comparison is amber. Swapping bars turn red.\n        </div>\n      </section>\n\n      <aside class=\"side\">\n        <div class=\"section\">\n          <h3>Pseudocode</h3>\n          <div class=\"pseudocode\" id=\"pseudocode\">\n            <div id=\"l0\">1. for i from 0 to n-1</div>\n            <div id=\"l1\">2. &nbsp;&nbsp;for j from 0 to n-i-2</div>\n            <div id=\"l2\">3. &nbsp;&nbsp;&nbsp;&nbsp;if arr[j] &gt; arr[j+1]</div>\n            <div id=\"l3\">4. &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;swap arr[j], arr[j+1]</div>\n            <div id=\"l4\">5. &nbsp;&nbsp;&nbsp;&nbsp;end if</div>\n            <div id=\"l5\">6. &nbsp;&nbsp;end for</div>\n            <div id=\"l6\">7. end for</div>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <h3>Controls</h3>\n          <div style=\"font-size:13px;color:var(--muted);line-height:1.5\">\n            - Shuffle: generate a new random array.<br>\n            - Start: play from current state.<br>\n            - Pause: pause the animation.<br>\n            - Step: perform a single comparison/swap step.<br>\n            - Reset: revert to original unsorted array.\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <h3>Current</h3>\n          <div style=\"display:flex;gap:8px;flex-direction:column\">\n            <div class=\"stat\">Phase: <span id=\"phase\">idle</span></div>\n            <div class=\"stat\">Current i: <span id=\"curI\">-</span></div>\n            <div class=\"stat\">Current j: <span id=\"curJ\">-</span></div>\n          </div>\n        </div>\n      </aside>\n    </main>\n  </div>\n\n<script>\n(function(){\n  // DOM references\n  const arrayArea = document.getElementById('arrayArea');\n  const sizeInput = document.getElementById('size');\n  const speedInput = document.getElementById('speed');\n  const shuffleBtn = document.getElementById('shuffleBtn');\n  const startBtn = document.getElementById('startBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const compCountEl = document.getElementById('compCount');\n  const swapCountEl = document.getElementById('swapCount');\n  const phaseEl = document.getElementById('phase');\n  const curIEl = document.getElementById('curI');\n  const curJEl = document.getElementById('curJ');\n  const pseudoEls = Array.from({length:7}, (_,i)=>document.getElementById('l'+i));\n\n  // State\n  let arr = [];\n  let original = [];\n  let bars = [];\n  let comparisons = 0;\n  let swaps = 0;\n  let gen = null;\n  let running = false;\n  let paused = false;\n  let timer = null;\n\n  // Helpers\n  function randInt(min, max){ return Math.floor(Math.random()*(max-min+1))+min; }\n\n  function generateArray(n){\n    // Generate values between 5 and 100\n    const res = [];\n    for(let i=0;i<n;i++){\n      res.push(randInt(5, 100));\n    }\n    return res;\n  }\n\n  function renderArray(initial=false){\n    // initial: true when creating DOM elements\n    arrayArea.innerHTML = '';\n    bars = [];\n    const n = arr.length;\n    const maxVal = Math.max(...arr);\n    const barWidth = Math.max(6, Math.floor((arrayArea.clientWidth - (n-1)*6) / n));\n    for(let i=0;i<n;i++){\n      const v = arr[i];\n      const bar = document.createElement('div');\n      bar.className = 'bar';\n      bar.title = String(v);\n      bar.dataset.index = String(i);\n      bar.style.height = (v / maxVal * 100) + '%';\n      bar.style.width = (barWidth) + 'px';\n      bar.textContent = '';\n      bar.addEventListener('mouseenter', ()=>{ bar.textContent = String(v); });\n      bar.addEventListener('mouseleave', ()=>{ bar.textContent = ''; });\n      arrayArea.appendChild(bar);\n      bars.push(bar);\n    }\n  }\n\n  function updateBars(){\n    const maxVal = Math.max(...arr);\n    for(let i=0;i<bars.length;i++){\n      const v = arr[i];\n      const bar = bars[i];\n      bar.dataset.index = String(i);\n      bar.title = String(v);\n      bar.style.height = (v / maxVal * 100) + '%';\n      // remove highlight classes but keep sorted as needed\n      bar.classList.remove('compare','swap');\n    }\n  }\n\n  function markSorted(index){\n    if(bars[index]) {\n      bars[index].classList.remove('compare','swap');\n      bars[index].classList.add('sorted');\n    }\n  }\n\n  function clearAllMarks(){\n    bars.forEach(b=>{ b.classList.remove('compare','swap','sorted'); });\n  }\n\n  function highlightCompare(i,j){\n    clearAllMarks();\n    if(bars[i]) bars[i].classList.add('compare');\n    if(bars[j]) bars[j].classList.add('compare');\n  }\n\n  function highlightSwap(i,j){\n    if(bars[i]) bars[i].classList.remove('compare'), bars[i].classList.add('swap');\n    if(bars[j]) bars[j].classList.remove('compare'), bars[j].classList.add('swap');\n  }\n\n  function swapValues(i,j){\n    const tmp = arr[i];\n    arr[i] = arr[j];\n    arr[j] = tmp;\n    // visually update heights:\n    updateBars();\n  }\n\n  function setPhase(name){\n    phaseEl.textContent = name;\n  }\n\n  function setCurrent(i,j){\n    curIEl.textContent = (i===null || i===undefined) ? '-' : i;\n    curJEl.textContent = (j===null || j===undefined) ? '-' : j;\n  }\n\n  function updateCounts(){\n    compCountEl.textContent = comparisons;\n    swapCountEl.textContent = swaps;\n  }\n\n  // Pseudocode highlighting\n  function clearPseudo(){\n    pseudoEls.forEach(e=>e.classList.remove('active'));\n  }\n  function highlightLine(idx){\n    clearPseudo();\n    if(idx>=0 && idx < pseudoEls.length) pseudoEls[idx].classList.add('active');\n  }\n\n  // Bubble sort generator that yields steps\n  function* bubbleSortGenerator(a){\n    const n = a.length;\n    // line 0: for i from 0 to n-1\n    for(let i=0;i<n;i++){\n      // line 1: inner loop\n      for(let j=0;j<n-i-1;j++){\n        // indicate comparison\n        yield {type:'line', line:1, i:i, j:j};\n        yield {type:'compare', i:i, j:j, jpos:j};\n        // compare\n        if(a[j] > a[j+1]){\n          // line 3: swap\n          yield {type:'line', line:3, i:i, j:j};\n          yield {type:'swap', i:j, j:j+1};\n        } else {\n          // line 4/5 no swap\n          yield {type:'line', line:4, i:i, j:j};\n        }\n      }\n      // after inner loop, mark last as sorted (n-i-1)\n      yield {type:'line', line:5, i:i, j:null};\n      yield {type:'sorted', index: n - i - 1};\n    }\n    yield {type:'done'};\n  }\n\n  // Control run/step\n  function startRun(){\n    if(!gen) gen = bubbleSortGenerator(arr.slice()); // provide array copy? But we need to mutate arr so generator must operate on arr not copy. Adjust: generator should use arr reference. Let's instead recreate gen pointing to function that uses arr reference.\n  }\n\n  // Fix generator creation to use live array:\n  function createGenerator(){\n    function* g(){\n      const n = arr.length;\n      for(let i=0;i<n;i++){\n        for(let j=0;j<n-i-1;j++){\n          yield {type:'line', line:1, i:i, j:j};\n          yield {type:'compare', i:i, j:j, jpos:j};\n          if(arr[j] > arr[j+1]){\n            yield {type:'line', line:3, i:i, j:j};\n            yield {type:'swap', i:j, j:j+1};\n          } else {\n            yield {type:'line', line:4, i:i, j:j};\n          }\n        }\n        yield {type:'line', line:5, i:i, j:null};\n        yield {type:'sorted', index: n - i - 1};\n      }\n      yield {type:'done'};\n    }\n    return g();\n  }\n\n  function processYield(res){\n    if(res.done) {\n      running = false;\n      paused = false;\n      gen = null;\n      setPhase('finished');\n      highlightLine(-1);\n      startBtn.disabled = false;\n      pauseBtn.disabled = true;\n      stepBtn.disabled = true;\n      // mark all sorted just in case\n      for(let k=0;k<bars.length;k++) markSorted(k);\n      return;\n    }\n    const step = res.value;\n    switch(step.type){\n      case 'line':\n        highlightLine(step.line);\n        setPhase('sorting');\n        setCurrent(step.i, step.j===null?'-':step.j);\n        break;\n      case 'compare':\n        // increment comparisons\n        comparisons++;\n        updateCounts();\n        highlightCompare(step.j, step.j+1);\n        setPhase('comparing');\n        setCurrent(step.i, step.j);\n        break;\n      case 'swap':\n        swaps++;\n        updateCounts();\n        highlightSwap(step.i, step.j);\n        setPhase('swapping');\n        setCurrent(step.i, step.j);\n        // swap in array and update visuals\n        swapValues(step.i, step.j);\n        break;\n      case 'sorted':\n        markSorted(step.index);\n        setPhase('marked sorted');\n        setCurrent(null,null);\n        break;\n      case 'done':\n        setPhase('done');\n        break;\n      default:\n        break;\n    }\n  }\n\n  // Runner uses setTimeout based on speed\n  function runLoop(){\n    if(!gen) return;\n    if(paused){ return; }\n    const res = gen.next();\n    processYield(res);\n    if(res.done) return;\n    // schedule next\n    const delay = Math.max(10, Number(speedInput.value) || 200);\n    timer = setTimeout(runLoop, delay);\n  }\n\n  // Event bindings\n  function enableControlsForRunning(isRunning){\n    startBtn.disabled = isRunning;\n    pauseBtn.disabled = !isRunning;\n    shuffleBtn.disabled = isRunning;\n    sizeInput.disabled = isRunning;\n    resetBtn.disabled = isRunning;\n    stepBtn.disabled = isRunning;\n  }\n\n  shuffleBtn.addEventListener('click', ()=>{\n    const n = Number(sizeInput.value);\n    arr = generateArray(n);\n    original = arr.slice();\n    comparisons = 0; swaps = 0;\n    updateCounts();\n    clearPseudo(); highlightLine(-1);\n    renderArray(true);\n    setPhase('idle');\n    setCurrent(null,null);\n    gen = null;\n    running = false;\n    paused = false;\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n    resetBtn.disabled = false;\n  });\n\n  sizeInput.addEventListener('input', ()=>{\n    const n = Number(sizeInput.value);\n    arr = generateArray(n);\n    original = arr.slice();\n    comparisons = 0; swaps = 0;\n    updateCounts();\n    renderArray(true);\n    clearPseudo(); highlightLine(-1);\n    setPhase('idle');\n    gen = null;\n    running = false;\n    paused = false;\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n  });\n\n  startBtn.addEventListener('click', ()=>{\n    if(!gen){\n      gen = createGenerator();\n    }\n    running = true;\n    paused = false;\n    setPhase('running');\n    startBtn.disabled = true;\n    pauseBtn.disabled = false;\n    stepBtn.disabled = true;\n    shuffleBtn.disabled = true;\n    sizeInput.disabled = true;\n    resetBtn.disabled = true;\n    runLoop();\n  });\n\n  pauseBtn.addEventListener('click', ()=>{\n    if(!running) return;\n    paused = true;\n    running = false;\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n    shuffleBtn.disabled = false;\n    sizeInput.disabled = false;\n    resetBtn.disabled = false;\n    setPhase('paused');\n    if(timer) { clearTimeout(timer); timer = null; }\n  });\n\n  stepBtn.addEventListener('click', ()=>{\n    // If no generator, create\n    if(!gen) gen = createGenerator();\n    const res = gen.next();\n    processYield(res);\n    if(res.done){\n      gen = null;\n      startBtn.disabled = false;\n      pauseBtn.disabled = true;\n      stepBtn.disabled = true;\n    } else {\n      // keep controls available for more stepping\n      startBtn.disabled = false;\n      pauseBtn.disabled = true;\n      stepBtn.disabled = false;\n    }\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    if(original && original.length){\n      arr = original.slice();\n      comparisons = 0; swaps = 0;\n      updateCounts();\n      gen = null;\n      running = false;\n      paused = false;\n      renderArray(true);\n      clearPseudo();\n      setPhase('idle');\n      setCurrent(null,null);\n      startBtn.disabled = false;\n      pauseBtn.disabled = true;\n      stepBtn.disabled = false;\n    }\n  });\n\n  // initialize\n  (function init(){\n    const n = Number(sizeInput.value);\n    arr = generateArray(n);\n    original = arr.slice();\n    renderArray(true);\n    comparisons = 0; swaps = 0;\n    updateCounts();\n    clearPseudo();\n    setPhase('idle');\n    setCurrent(null,null);\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n  })();\n\n  // ensure responsiveness on resize: recompute bar widths\n  window.addEventListener('resize', ()=>{\n    // re-render bars keeping current values\n    if(arr && arr.length){\n      // recreate but keep highlights by removing classes\n      renderArray();\n    }\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
