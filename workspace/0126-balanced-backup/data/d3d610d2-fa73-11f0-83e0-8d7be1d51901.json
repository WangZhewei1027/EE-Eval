    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<title>Selection Sort Visualizer</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<style>\n  :root{\n    --bg:#0f1724;\n    --panel:#0b1220;\n    --muted:#9aa6b2;\n    --accent:#60a5fa;\n    --good:#10b981;\n    --danger:#fb7185;\n    --card:#0f1724;\n  }\n  html,body{height:100%;margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n  body{background:linear-gradient(180deg,#071226 0%, #07182a 100%); color:#cfe7ff; display:flex; align-items:center; justify-content:center; padding:24px; box-sizing:border-box;}\n  .app{width:100%; max-width:1100px;}\n  header{display:flex;align-items:center;gap:16px;margin-bottom:16px;}\n  h1{font-size:20px;margin:0;color:#e6f0ff;}\n  .controls{display:flex;gap:8px;align-items:center;margin-left:auto;}\n  button, input[type=range], input[type=number]{\n    background:linear-gradient(180deg,#0f1b2a,#071226);\n    border:1px solid rgba(255,255,255,0.06);\n    color:#d9eeff;\n    padding:8px 10px;\n    border-radius:8px;\n    cursor:pointer;\n    font-size:13px;\n  }\n  button:active{transform:translateY(1px)}\n  button[disabled]{opacity:0.45;cursor:not-allowed}\n  .panel{background:linear-gradient(180deg,#071227,#04101b); padding:14px;border-radius:12px; border:1px solid rgba(255,255,255,0.03); box-shadow: 0 6px 30px rgba(2,6,23,0.6);}\n  .topbar{display:flex;gap:12px;align-items:center;margin-bottom:12px;}\n  .slider-group{display:flex;gap:8px;align-items:center}\n  .label{font-size:12px;color:var(--muted)}\n  .visual{height:340px; background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent); border-radius:8px; padding:12px; display:flex; align-items:flex-end; gap:6px; overflow:hidden; position:relative;}\n  .bars{display:flex;align-items:flex-end;gap:6px;width:100%;height:100%;}\n  .bar{flex:1; min-width:6px; margin:0; background:linear-gradient(180deg,#60a5fa,#1e3a8a); border-radius:6px 6px 4px 4px; display:flex;align-items:flex-end; justify-content:center; color:#001826; font-weight:700; transition:height 300ms ease, transform 200ms ease, background 200ms ease; box-shadow: inset 0 -6px 14px rgba(0,0,0,0.25);}\n  .bar.small{font-size:11px;padding-bottom:4px}\n  .bar.large{font-size:12px;padding-bottom:6px}\n  .bar .val{transform:translateY(2px)}\n  .bar.current-i{background:linear-gradient(180deg,#fbbf24,#d97706); color:#081018}\n  .bar.current-j{background:linear-gradient(180deg,#60a5fa,#2563eb); color:#001026}\n  .bar.current-min{background:linear-gradient(180deg,#fb7185,#b91c1c); color:#fff}\n  .bar.swapping{transform:translateY(-10px) scale(1.03); box-shadow:0 10px 30px rgba(0,0,0,0.45)}\n  .stats{display:flex;gap:10px;align-items:center;margin-top:10px}\n  .stat{background:rgba(255,255,255,0.03); padding:8px 10px; border-radius:8px; font-size:13px; color:var(--muted)}\n  .right{display:flex; gap:12px; align-items:center;}\n  .pseudocode{margin-top:12px;padding:12px;border-radius:8px;background:linear-gradient(180deg,#041522,#021018); font-family:monospace; color:#bfe6ff; font-size:13px; line-height:1.6; border:1px solid rgba(255,255,255,0.03)}\n  .code-line{padding:2px 6px;border-radius:4px}\n  .code-line.active{background:linear-gradient(90deg, rgba(96,165,250,0.14), rgba(159,122,234,0.06)); color:#e6f7ff}\n  .footer{display:flex;justify-content:space-between;align-items:center;margin-top:12px;gap:12px;flex-wrap:wrap}\n  .legend{display:flex;gap:8px;align-items:center}\n  .legend .item{display:flex;gap:6px;align-items:center;font-size:13px;color:var(--muted)}\n  .swatch{width:14px;height:14px;border-radius:3px}\n  .mutedbox{font-size:13px;color:var(--muted)}\n  input[type=number]{width:70px}\n  @media (max-width:720px){ .topbar{flex-direction:column;align-items:stretch} .controls{margin-left:0;flex-wrap:wrap} .visual{height:260px} }\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <header>\n    <h1>Selection Sort Visualizer</h1>\n    <div class=\"controls\" role=\"toolbar\" aria-label=\"Controls\">\n      <div class=\"slider-group panel\" style=\"display:flex;align-items:center;gap:8px;\">\n        <label class=\"label\" for=\"size\">Size</label>\n        <input id=\"size\" type=\"range\" min=\"6\" max=\"60\" value=\"24\" />\n        <input id=\"sizeNum\" type=\"number\" min=\"6\" max=\"60\" value=\"24\" />\n      </div>\n      <div class=\"slider-group panel\" style=\"display:flex;align-items:center;gap:8px;\">\n        <label class=\"label\" for=\"speed\">Speed</label>\n        <input id=\"speed\" type=\"range\" min=\"50\" max=\"1200\" value=\"220\" />\n        <span id=\"speedLabel\" style=\"font-size:13px;color:var(--muted);min-width:56px;text-align:right\">220 ms</span>\n      </div>\n\n      <div style=\"display:flex;gap:6px;\">\n        <button id=\"startBtn\" class=\"panel\" title=\"Start\">Start</button>\n        <button id=\"pauseBtn\" class=\"panel\" title=\"Pause\" disabled>Pause</button>\n        <button id=\"stepBtn\" class=\"panel\" title=\"Step\">Step</button>\n        <button id=\"resetBtn\" class=\"panel\" title=\"Reset\">Reset</button>\n        <button id=\"shuffleBtn\" class=\"panel\" title=\"Shuffle\">Shuffle</button>\n      </div>\n    </div>\n  </header>\n\n  <div class=\"panel\">\n    <div class=\"topbar\">\n      <div style=\"flex:1;\">\n        <div class=\"visual\" aria-hidden=\"false\">\n          <div class=\"bars\" id=\"bars\" role=\"list\" aria-label=\"Array bars\"></div>\n        </div>\n        <div class=\"stats\">\n          <div class=\"stat\">Comparisons: <strong id=\"compCount\">0</strong></div>\n          <div class=\"stat\">Swaps: <strong id=\"swapCount\">0</strong></div>\n          <div class=\"stat\">Index i: <strong id=\"indexI\">—</strong></div>\n          <div class=\"stat\">Min idx: <strong id=\"indexMin\">—</strong></div>\n        </div>\n      </div>\n      <div class=\"right\" style=\"min-width:260px;\">\n        <div style=\"width:260px;\">\n          <div class=\"pseudocode\" aria-hidden=\"true\">\n            <div id=\"line1\" class=\"code-line\">for i = 0 to n - 2</div>\n            <div id=\"line2\" class=\"code-line\"> &nbsp;&nbsp;min = i</div>\n            <div id=\"line3\" class=\"code-line\"> &nbsp;&nbsp;for j = i + 1 to n - 1</div>\n            <div id=\"line4\" class=\"code-line\"> &nbsp;&nbsp;&nbsp;&nbsp;if A[j] &lt; A[min]</div>\n            <div id=\"line5\" class=\"code-line\"> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;min = j</div>\n            <div id=\"line6\" class=\"code-line\"> &nbsp;&nbsp;if min != i</div>\n            <div id=\"line7\" class=\"code-line\"> &nbsp;&nbsp;&nbsp;&nbsp;swap A[i], A[min]</div>\n          </div>\n          <div style=\"margin-top:8px;font-size:13px;color:var(--muted)\">\n            Complexity: O(n^2) time, O(1) extra space\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      <div class=\"legend\">\n        <div class=\"item\"><span class=\"swatch\" style=\"background:linear-gradient(180deg,#60a5fa,#2563eb)\"></span> Current j (scanning)</div>\n        <div class=\"item\"><span class=\"swatch\" style=\"background:linear-gradient(180deg,#fbbf24,#d97706)\"></span> Current i (position to fill)</div>\n        <div class=\"item\"><span class=\"swatch\" style=\"background:linear-gradient(180deg,#fb7185,#b91c1c)\"></span> Current min</div>\n      </div>\n      <div class=\"mutedbox\">Tip: Use Step to advance one operation at a time. Speed adjusts the delay between steps.</div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Elements\n  const barsEl = document.getElementById('bars');\n  const sizeRange = document.getElementById('size');\n  const sizeNum = document.getElementById('sizeNum');\n  const speedRange = document.getElementById('speed');\n  const speedLabel = document.getElementById('speedLabel');\n  const startBtn = document.getElementById('startBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const shuffleBtn = document.getElementById('shuffleBtn');\n  const compCountEl = document.getElementById('compCount');\n  const swapCountEl = document.getElementById('swapCount');\n  const indexIEl = document.getElementById('indexI');\n  const indexMinEl = document.getElementById('indexMin');\n  const codeLines = {\n    1: document.getElementById('line1'),\n    2: document.getElementById('line2'),\n    3: document.getElementById('line3'),\n    4: document.getElementById('line4'),\n    5: document.getElementById('line5'),\n    6: document.getElementById('line6'),\n    7: document.getElementById('line7')\n  };\n\n  // State\n  let array = [];\n  let size = parseInt(sizeRange.value,10);\n  let delay = parseInt(speedRange.value,10);\n  let generator = null;\n  let running = false;\n  let paused = false;\n  let compCount = 0;\n  let swapCount = 0;\n\n  // Helpers\n  function randInt(min,max){ return Math.floor(Math.random()*(max-min+1))+min; }\n  function createArray(n){\n    const arr=[];\n    for(let i=0;i<n;i++) arr.push(randInt(5,100));\n    return arr;\n  }\n\n  function renderBars(){\n    barsEl.innerHTML='';\n    const maxVal = Math.max(...array,100);\n    array.forEach((v,idx)=>{\n      const bar = document.createElement('div');\n      bar.className = 'bar';\n      bar.style.height = (v/maxVal*100) + '%';\n      bar.style.transitionDuration = Math.max(80, delay*0.7) + 'ms';\n      bar.style.flex = '1';\n      if (array.length <= 30) bar.classList.add('large'); else bar.classList.add('small');\n      const val = document.createElement('div');\n      val.className='val';\n      val.textContent = v;\n      bar.appendChild(val);\n      bar.dataset.index = idx;\n      barsEl.appendChild(bar);\n    });\n  }\n\n  function highlight(i,j,minIdx,swappingIdxs){\n    // Clear classes\n    barsEl.querySelectorAll('.bar').forEach(b=>{ b.classList.remove('current-i','current-j','current-min','swapping'); });\n    if (i!=null){\n      const bar = barsEl.children[i];\n      if (bar) bar.classList.add('current-i');\n      indexIEl.textContent = i;\n    } else indexIEl.textContent = '—';\n    if (j!=null){\n      const bar = barsEl.children[j];\n      if (bar) bar.classList.add('current-j');\n    }\n    if (minIdx!=null){\n      const bar = barsEl.children[minIdx];\n      if (bar) bar.classList.add('current-min');\n      indexMinEl.textContent = minIdx;\n    } else indexMinEl.textContent = '—';\n    if (swappingIdxs && swappingIdxs.length){\n      swappingIdxs.forEach(idx=>{\n        const bar = barsEl.children[idx];\n        if (bar) bar.classList.add('swapping');\n      });\n    }\n  }\n\n  function swapVisual(i,j){\n    // swap heights and text content\n    const bi = barsEl.children[i];\n    const bj = barsEl.children[j];\n    if (!bi || !bj) return;\n    const hi = bi.style.height;\n    const hj = bj.style.height;\n    const ti = bi.textContent;\n    const tj = bj.textContent;\n    bi.style.height = hj;\n    bj.style.height = hi;\n    bi.textContent = tj;\n    bj.textContent = ti;\n  }\n\n  function updateCounters(){\n    compCountEl.textContent = compCount;\n    swapCountEl.textContent = swapCount;\n  }\n\n  function clearCodeHighlights(){\n    Object.values(codeLines).forEach(el=>el.classList.remove('active'));\n  }\n\n  function highlightCode(line){\n    clearCodeHighlights();\n    if (line && codeLines[line]) codeLines[line].classList.add('active');\n  }\n\n  // Generator for selection sort steps\n  function* selectionSteps(arr){\n    const n = arr.length;\n    for (let i=0;i<n-1;i++){\n      // select i\n      yield {type:'select_i', i:i, min:i};\n      let min = i;\n      // inner loop\n      for (let j=i+1;j<n;j++){\n        yield {type:'compare', i:i, j:j, min:min};\n        if (arr[j] < arr[min]){ // new min found\n          min = j;\n          yield {type:'new_min', i:i, j:j, min:min};\n        }\n      }\n      if (min !== i){\n        // swap\n        // first yield swap-pre to animate\n        yield {type:'swap', i:i, j:min};\n        // perform actual swap in array for subsequent steps\n        const tmp = arr[i];\n        arr[i] = arr[min];\n        arr[min] = tmp;\n      }\n      // after finishing i, yield finished-i (to update code highlight)\n      yield {type:'done_i', i:i};\n    }\n    yield {type:'finished'};\n  }\n\n  // Control flow to run generator with delay\n  function runGeneratorStep(){\n    if (!generator) return;\n    const next = generator.next();\n    if (next.done) {\n      running=false;\n      paused=false;\n      startBtn.disabled=false;\n      pauseBtn.disabled=true;\n      stepBtn.disabled=true;\n      shuffleBtn.disabled=false;\n      sizeRange.disabled=false;\n      sizeNum.disabled=false;\n      highlight(null,null,null,[]);\n      highlightCode(null);\n      return;\n    }\n    const step = next.value;\n    handleStep(step);\n  }\n\n  function handleStep(step){\n    switch(step.type){\n      case 'select_i':\n        highlight(step.i,null,step.min,[]);\n        highlightCode(2);\n        break;\n      case 'compare':\n        compCount++;\n        updateCounters();\n        highlight(step.i,step.j,step.min,[]);\n        highlightCode(4);\n        break;\n      case 'new_min':\n        highlight(step.i,step.j,step.min,[]);\n        highlightCode(5);\n        break;\n      case 'swap':\n        swapCount++;\n        updateCounters();\n        // animate swap visually\n        highlight(step.i,step.j,null,[step.i, step.j]);\n        highlightCode(7);\n        // swap values in DOM immediately (visual)\n        setTimeout(()=>{ swapVisual(step.i, step.j); }, Math.min(200, delay*0.6));\n        break;\n      case 'done_i':\n        highlight(step.i,null,null,[]);\n        highlightCode(1);\n        break;\n      case 'finished':\n        highlight(null,null,null,[]);\n        highlightCode(null);\n        running=false;\n        paused=false;\n        startBtn.disabled=false;\n        pauseBtn.disabled=true;\n        stepBtn.disabled=true;\n        shuffleBtn.disabled=false;\n        sizeRange.disabled=false;\n        sizeNum.disabled=false;\n        break;\n    }\n  }\n\n  // Async runner that respects pause and speed\n  async function play(){\n    if (!generator) return;\n    running = true;\n    paused = false;\n    startBtn.disabled=true;\n    pauseBtn.disabled=false;\n    stepBtn.disabled=true;\n    shuffleBtn.disabled=true;\n    sizeRange.disabled=true;\n    sizeNum.disabled=true;\n\n    while (running && !generator.next().done) {\n      // We used generator.next() in condition, but that advanced it already.\n      // To handle properly, rework: Instead, we will not call next twice. We'll restructure.\n      break;\n    }\n    // Proper loop: step until end or paused\n    while (running && !paused){\n      const {value, done} = generator.next();\n      if (done) break;\n      handleStep(value);\n      // wait for delay, but allow immediate stepping if paused\n      await new Promise(res=>{\n        let waited=0;\n        const sleep = () => {\n          if (paused){ res(); return; }\n          waited += 20;\n          if (waited >= delay) return res();\n          setTimeout(sleep,20);\n        };\n        setTimeout(sleep,20);\n      });\n    }\n\n    if (!paused && running){\n      // finished\n      running=false;\n      startBtn.disabled=false;\n      pauseBtn.disabled=true;\n      stepBtn.disabled=true;\n      shuffleBtn.disabled=false;\n      sizeRange.disabled=false;\n      sizeNum.disabled=false;\n      highlight(null,null,null,[]);\n      highlightCode(null);\n    }\n  }\n\n  // Alternative stepRunner: single step (used by Step button)\n  function singleStep(){\n    if (!generator) return;\n    const {value, done} = generator.next();\n    if (done){\n      running=false;\n      paused=false;\n      startBtn.disabled=false;\n      pauseBtn.disabled=true;\n      stepBtn.disabled=true;\n      shuffleBtn.disabled=false;\n      sizeRange.disabled=false;\n      sizeNum.disabled=false;\n      highlight(null,null,null,[]);\n      highlightCode(null);\n      return;\n    }\n    handleStep(value);\n  }\n\n  // Initialize\n  function init(){\n    array = createArray(size);\n    compCount = 0;\n    swapCount = 0;\n    updateCounters();\n    renderBars();\n    generator = null;\n    running = false;\n    paused = false;\n    startBtn.disabled=false;\n    pauseBtn.disabled=true;\n    stepBtn.disabled=false;\n    shuffleBtn.disabled=false;\n    sizeRange.disabled=false;\n    sizeNum.disabled=false;\n    highlight(null,null,null,[]);\n    highlightCode(null);\n    indexIEl.textContent='—';\n    indexMinEl.textContent='—';\n  }\n\n  // Event listeners\n  sizeRange.addEventListener('input', e=>{\n    size = parseInt(e.target.value,10);\n    sizeNum.value = size;\n  });\n  sizeNum.addEventListener('input', e=>{\n    let v = parseInt(e.target.value,10);\n    if (isNaN(v)) v = 6;\n    v = Math.max(6, Math.min(60, v));\n    size = v;\n    sizeRange.value = v;\n    sizeNum.value = v;\n  });\n  sizeRange.addEventListener('change', ()=>{\n    init();\n  });\n  sizeNum.addEventListener('change', ()=>{\n    init();\n  });\n  speedRange.addEventListener('input', e=>{\n    delay = parseInt(e.target.value,10);\n    speedLabel.textContent = delay + ' ms';\n    // update transitions\n    barsEl.querySelectorAll('.bar').forEach(b=>{\n      b.style.transitionDuration = Math.max(80, delay*0.7) + 'ms';\n    });\n  });\n\n  startBtn.addEventListener('click', ()=>{\n    if (running && paused){\n      paused = false;\n      play();\n      return;\n    }\n    // Create new generator from current array snapshot values\n    // We must use a copy of the visible numeric array. Extract numbers from DOM to ensure swap visuals are in sync.\n    const currentValues = Array.from(barsEl.children).map(b => parseInt(b.textContent,10));\n    generator = selectionSteps(currentValues);\n    running = true;\n    paused = false;\n    play();\n  });\n\n  pauseBtn.addEventListener('click', ()=>{\n    if (!running) return;\n    paused = true;\n    pauseBtn.disabled=true;\n    startBtn.disabled=false;\n    stepBtn.disabled=false;\n  });\n\n  stepBtn.addEventListener('click', ()=>{\n    // If not running, create a generator from current visible state\n    if (!generator || (!running && !paused)){\n      const currentValues = Array.from(barsEl.children).map(b => parseInt(b.textContent,10));\n      generator = selectionSteps(currentValues);\n      running = true;\n      paused = true; // stay paused after single step\n    }\n    singleStep();\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    init();\n  });\n\n  shuffleBtn.addEventListener('click', ()=>{\n    array = createArray(size);\n    renderBars();\n    compCount = 0;\n    swapCount = 0;\n    updateCounters();\n    generator = null;\n    running = false;\n    paused = false;\n    startBtn.disabled=false;\n    pauseBtn.disabled=true;\n    stepBtn.disabled=false;\n    indexIEl.textContent='—';\n    indexMinEl.textContent='—';\n    highlight(null,null,null,[]);\n    highlightCode(null);\n  });\n\n  // Allow clicking a bar to highlight it (for curiosity)\n  barsEl.addEventListener('click', (e)=>{\n    const b = e.target.closest('.bar');\n    if (!b) return;\n    const idx = Number(b.dataset.index);\n    highlight(null, null, idx, []);\n    setTimeout(()=>{ highlight(null,null,null,[]); }, 600);\n  });\n\n  // Seed initial\n  init();\n  speedLabel.textContent = delay + ' ms';\n\n  // Ensure resizing keeps value labels readable\n  window.addEventListener('resize', ()=>{\n    barsEl.querySelectorAll('.bar').forEach(b=>{\n      if (barsEl.children.length <= 30){\n        b.classList.add('large');\n        b.classList.remove('small');\n      } else {\n        b.classList.add('small');\n        b.classList.remove('large');\n      }\n    });\n  });\n\n  // Improve play() implementation: override earlier broken loop with correct behavior using async runner that checks paused.\n  // Replace play implementation with a safer one\n  async function play(){\n    if (!generator) return;\n    running = true;\n    paused = false;\n    startBtn.disabled=true;\n    pauseBtn.disabled=false;\n    stepBtn.disabled=true;\n    shuffleBtn.disabled=true;\n    sizeRange.disabled=true;\n    sizeNum.disabled=true;\n    while (running && !paused){\n      const {value, done} = generator.next();\n      if (done) break;\n      handleStep(value);\n      // wait respecting pause\n      let waited = 0;\n      await new Promise(res=>{\n        const tick = () => {\n          if (paused) return res();\n          waited += 20;\n          if (waited >= delay) return res();\n          setTimeout(tick,20);\n        };\n        setTimeout(tick,20);\n      });\n    }\n    if (!paused){\n      running=false;\n      startBtn.disabled=false;\n      pauseBtn.disabled=true;\n      stepBtn.disabled=true;\n      shuffleBtn.disabled=false;\n      sizeRange.disabled=false;\n      sizeNum.disabled=false;\n      highlight(null,null,null,[]);\n      highlightCode(null);\n    }\n  }\n\n  // Bind improved play\n  window.play = play;\n\n})();\n</script>\n</body>\n</html>"
