  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<title>Dijkstra's Algorithm — Interactive Demo</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<style>\n  :root{\n    --bg:#f6f7fb;\n    --panel:#ffffff;\n    --muted:#6b7280;\n    --accent:#2563eb;\n    --ok:#10b981;\n    --warn:#f97316;\n    --danger:#ef4444;\n    --node:#4b5563;\n    --node-label:#ffffff;\n    --edge:#9ca3af;\n    --select:#60a5fa;\n  }\n  html,body{height:100%;margin:0;font-family:Inter, Roboto, Arial, sans-serif;background:var(--bg);color:#111827}\n  .container{display:grid;grid-template-columns:320px 1fr 320px;gap:18px;padding:18px;height:100%}\n  .card{background:var(--panel);border-radius:8px;padding:12px;box-shadow:0 1px 3px rgba(15,23,42,0.06);display:flex;flex-direction:column;overflow:auto}\n  h1{font-size:18px;margin:0 0 6px 0}\n  p.small{font-size:13px;color:var(--muted);margin:6px 0 12px 0}\n  .controls{display:flex;flex-direction:column;gap:8px;}\n  .row{display:flex;gap:8px;align-items:center}\n  button, input[type=\"number\"], select{font-size:13px;padding:8px;border-radius:6px;border:1px solid #e5e7eb;background:white}\n  button{cursor:pointer}\n  button.primary{background:var(--accent);color:white;border:none}\n  button.ghost{background:transparent;border:1px solid #e5e7eb}\n  .small-btn{padding:6px 8px;font-size:13px}\n  svg{width:100%;height:70vh;background:linear-gradient(180deg,#ffffff00,#ffffff00);border-radius:8px}\n  .legend{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}\n  .chip{font-size:12px;padding:6px 8px;border-radius:999px;background:#f3f4f6;color:#374151;display:inline-flex;align-items:center;gap:8px}\n  .status-list{font-size:13px;overflow:auto}\n  table{width:100%;border-collapse:collapse;font-size:13px}\n  th,td{padding:6px;border-bottom:1px dashed #eef2f7;text-align:left}\n  th{font-size:12px;color:var(--muted);font-weight:600}\n  .node-label{pointer-events:none;font-weight:600;font-size:12px}\n  /* node colors */\n  .node-unvisited{fill:#d1d5db;stroke:#9ca3af;stroke-width:2}\n  .node-fringe{fill:#60a5fa;stroke:#2563eb;stroke-width:2}\n  .node-current{fill:#f59e0b;stroke:#b45309;stroke-width:2}\n  .node-final{fill:#10b981;stroke:#047857;stroke-width:2}\n  .node-source{fill:#7c3aed;stroke:#5b21b6;stroke-width:2}\n  .edge-line{stroke:var(--edge);stroke-width:2;stroke-linecap:round}\n  .edge-highlight{stroke:#f59e0b;stroke-width:3}\n  .edge-final{stroke:#10b981;stroke-width:3}\n  .weight-label{font-size:12px;fill:#111827;background:white}\n  .info{font-size:13px;color:var(--muted);margin-top:6px}\n  .footer{margin-top:12px;font-size:12px;color:var(--muted)}\n  .controls .modes{display:flex;flex-wrap:wrap;gap:6px}\n  .notice{font-size:12px;color:#92400e;background:#fff7ed;padding:8px;border-radius:6px}\n  .flex-1{flex:1}\n  .center{display:flex;align-items:center;justify-content:center}\n  .small-muted{font-size:12px;color:var(--muted)}\n  .edge-weight-input{width:84px}\n  .graph-actions{display:flex;gap:6px;flex-wrap:wrap}\n  .highlight-shadow{filter:drop-shadow(0 4px 8px rgba(15,23,42,0.08));}\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <div class=\"card\">\n    <h1>Dijkstra's Algorithm — Interactive Demo</h1>\n    <p class=\"small\">Build a weighted graph, choose a source node, and step through Dijkstra's shortest-path process. Visual cues show which nodes are in the fringe, currently processed, or finalized.</p>\n\n    <div class=\"controls\">\n      <div class=\"modes\">\n        <button id=\"mode-add-node\" class=\"small-btn\">Add Node</button>\n        <button id=\"mode-add-edge\" class=\"small-btn\">Add Edge</button>\n        <button id=\"mode-set-source\" class=\"small-btn\">Set Source</button>\n        <button id=\"mode-drag\" class=\"small-btn\">Drag / Select</button>\n      </div>\n\n      <div class=\"row\">\n        <label class=\"small-muted\">Edge weight:</label>\n        <input id=\"edge-weight\" class=\"edge-weight-input\" type=\"number\" min=\"1\" value=\"1\" />\n        <button id=\"btn-make-random\" class=\"small-btn ghost\">Random Graph</button>\n        <button id=\"btn-clear\" class=\"small-btn ghost\">Clear</button>\n      </div>\n\n      <div class=\"graph-actions\">\n        <button id=\"btn-init\" class=\"small-btn primary\">Initialize Dijkstra</button>\n        <button id=\"btn-next\" class=\"small-btn\">Next Step</button>\n        <button id=\"btn-run\" class=\"small-btn\">Auto Run</button>\n        <button id=\"btn-pause\" class=\"small-btn\">Pause</button>\n        <button id=\"btn-reset\" class=\"small-btn ghost\">Reset Run</button>\n      </div>\n\n      <div class=\"notice\" id=\"notice\">Mode: Drag / Select. Click nodes to inspect. Use \"Set Source\" to pick the start node.</div>\n\n      <div class=\"legend\">\n        <div class=\"chip\"><span style=\"display:inline-block;width:12px;height:12px;background:#d1d5db;border-radius:3px\"></span> Unvisited</div>\n        <div class=\"chip\"><span style=\"display:inline-block;width:12px;height:12px;background:#60a5fa;border-radius:3px\"></span> Fringe</div>\n        <div class=\"chip\"><span style=\"display:inline-block;width:12px;height:12px;background:#f59e0b;border-radius:3px\"></span> Current</div>\n        <div class=\"chip\"><span style=\"display:inline-block;width:12px;height:12px;background:#10b981;border-radius:3px\"></span> Finalized</div>\n        <div class=\"chip\"><span style=\"display:inline-block;width:12px;height:12px;background:#7c3aed;border-radius:3px\"></span> Source</div>\n      </div>\n\n      <div class=\"info\">\n        How it works: Dijkstra repeatedly selects the closest non-final node (the fringe), relaxes its outgoing edges (updating distance estimates), and marks it finalized when done. Use Next to step one atomic action (extract or relax one neighbor).\n      </div>\n    </div>\n  </div>\n\n  <div class=\"card\" id=\"canvas-card\" style=\"position:relative;\">\n    <svg id=\"svg\" viewBox=\"0 0 1000 700\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n    <!-- Simple controls overlay for instructions -->\n    <div style=\"position:absolute;right:12px;bottom:12px;background:#ffffffaa;padding:8px;border-radius:8px;font-size:12px;color:#374151;box-shadow:0 6px 18px rgba(2,6,23,0.06);\">\n      Click canvas to add nodes (when in Add Node). For adding an edge: click a node then another (when in Add Edge). Drag nodes when in Drag mode.\n    </div>\n  </div>\n\n  <div class=\"card\">\n    <h1>Algorithm State</h1>\n    <p class=\"small\">Distances, previous pointers, and the fringe (nodes reachable but not finalized) are shown. The priority queue is represented by the fringe ordered by current distance.</p>\n\n    <div style=\"display:flex;gap:12px;margin-top:8px;\">\n      <div class=\"flex-1\">\n        <div style=\"font-size:13px;color:var(--muted);margin-bottom:6px\">Fringe (priority queue view)</div>\n        <div id=\"fringe\" class=\"status-list\"></div>\n      </div>\n      <div style=\"width:160px\">\n        <div style=\"font-size:13px;color:var(--muted);margin-bottom:6px\">Controls</div>\n        <div style=\"display:flex;flex-direction:column;gap:6px\">\n          <button id=\"btn-highlight-path\" class=\"small-btn ghost\">Show Shortest Tree</button>\n          <button id=\"btn-clear-highlights\" class=\"small-btn ghost\">Clear Highlights</button>\n        </div>\n      </div>\n    </div>\n\n    <div style=\"margin-top:12px\">\n      <div style=\"font-size:13px;color:var(--muted);margin-bottom:6px\">Distance Table</div>\n      <div style=\"max-height:320px;overflow:auto\">\n        <table id=\"dist-table\">\n          <thead>\n            <tr><th>Node</th><th>Distance</th><th>Previous</th><th>Status</th></tr>\n          </thead>\n          <tbody></tbody>\n        </table>\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      Tip: Use \"Next Step\" to observe exactly which neighbor is relaxed. \"Auto Run\" will proceed with a small delay.\n    </div>\n  </div>\n</div>\n\n<script>\n/*\n  Dijkstra Interactive Demo\n  - Nodes and edges on an SVG canvas\n  - Modes: add node, add edge, set source, drag/select\n  - Stepwise Dijkstra: each \"Next\" either extracts the next node or relaxes one neighbor\n*/\n\n(() => {\n  // Data structures\n  let nodes = []; // {id,label,x,y}\n  let edges = []; // {id,u,v,w}\n  let nextNodeId = 1;\n  let nextEdgeId = 1;\n\n  // SVG and elements\n  const svg = document.getElementById('svg');\n  const NS = \"http://www.w3.org/2000/svg\";\n\n  // Mode control\n  let mode = 'drag'; // 'add-node','add-edge','set-source','drag'\n  const notice = document.getElementById('notice');\n\n  // Graph interaction state\n  let addEdgeFirst = null;\n  let sourceNode = null;\n\n  // Dijkstra state\n  let dist = {};   // dist[nodeId] = numeric\n  let prev = {};   // prev[nodeId] = nodeId or null\n  let finalized = new Set(); // finalized nodes\n  let current = null; // node currently being processed\n  let neighborIndex = 0; // which neighbor of current is next to relax\n  let running = false;\n  let autoTimer = null;\n\n  // Utility functions\n  function byId(id){ return nodes.find(n=>n.id===id) }\n  function addNode(x,y){\n    const id = String(nextNodeId++);\n    const node = {id: id, label: id, x: x, y: y};\n    nodes.push(node);\n    draw();\n    return node;\n  }\n  function addEdge(uId,vId,w){\n    if(uId === vId) return;\n    // Ensure no duplicate edge (undirected)\n    const exists = edges.some(e => (e.u===uId && e.v===vId) || (e.u===vId && e.v===uId));\n    if(exists) return;\n    const edge = {id: String(nextEdgeId++), u: uId, v: vId, w: Number(w)};\n    edges.push(edge);\n    draw();\n    return edge;\n  }\n  function clearGraph(){\n    nodes = [];\n    edges = [];\n    nextNodeId = 1;\n    nextEdgeId = 1;\n    resetRunState();\n    draw();\n  }\n\n  // Visualization: draw nodes and edges using SVG\n  function clearSVG(){\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n  }\n\n  function draw(){\n    clearSVG();\n    // draw edges first\n    edges.forEach(e => {\n      const u = byId(e.u), v = byId(e.v);\n      if(!u || !v) return;\n      const line = document.createElementNS(NS,'line');\n      line.setAttribute('x1', u.x);\n      line.setAttribute('y1', u.y);\n      line.setAttribute('x2', v.x);\n      line.setAttribute('y2', v.y);\n      line.setAttribute('id', 'edge-'+e.id);\n      line.classList.add('edge-line');\n      // style depending on state\n      if(finalized.has(e.u) && finalized.has(e.v)){\n        line.classList.add('edge-final');\n      }\n      svg.appendChild(line);\n\n      // weight label\n      const mx = (u.x + v.x)/2;\n      const my = (u.y + v.y)/2;\n      const text = document.createElementNS(NS,'text');\n      text.setAttribute('x', mx);\n      text.setAttribute('y', my - 8);\n      text.setAttribute('text-anchor','middle');\n      text.setAttribute('class','weight-label');\n      text.textContent = e.w;\n      text.setAttribute('data-edge', e.id);\n      svg.appendChild(text);\n    });\n\n    // draw nodes\n    nodes.forEach(n => {\n      // group per node\n      const g = document.createElementNS(NS,'g');\n      g.setAttribute('transform', `translate(${n.x},${n.y})`);\n      g.classList.add('node-group');\n      g.setAttribute('data-id', n.id);\n\n      // circle\n      const c = document.createElementNS(NS,'circle');\n      c.setAttribute('r', 20);\n      c.setAttribute('cx', 0);\n      c.setAttribute('cy', 0);\n      c.setAttribute('id', 'node-'+n.id);\n      // apply classes based on state\n      if(n.id === sourceNode){\n        c.classList.add('node-source');\n      } else if(finalized.has(n.id)){\n        c.classList.add('node-final');\n      } else if(current === n.id){\n        c.classList.add('node-current');\n      } else {\n        const d = dist[n.id];\n        if(d !== undefined && d < Infinity){\n          c.classList.add('node-fringe');\n        } else {\n          c.classList.add('node-unvisited');\n        }\n      }\n      g.appendChild(c);\n\n      // label (node id)\n      const text = document.createElementNS(NS,'text');\n      text.setAttribute('text-anchor','middle');\n      text.setAttribute('y','6');\n      text.setAttribute('class','node-label');\n      text.textContent = n.label;\n      g.appendChild(text);\n\n      // interactions\n      g.addEventListener('mousedown', onNodeMouseDown);\n      g.addEventListener('click', onNodeClick);\n\n      svg.appendChild(g);\n    });\n\n    updateDistTable();\n    updateFringeView();\n    attachEdgeStyling(); // ensure highlighted classes\n  }\n\n  // After drawing, style edges for highlights (if current edge being relaxed)\n  let highlightEdgeId = null;\n  function attachEdgeStyling(){\n    edges.forEach(e => {\n      const line = document.getElementById('edge-'+e.id);\n      if(!line) return;\n      line.classList.remove('edge-highlight');\n      if(e.id === highlightEdgeId) {\n        line.classList.add('edge-highlight');\n      } else {\n        // if both endpoints finalized, mark final style (already added possibly)\n        if(finalized.has(e.u) && finalized.has(e.v)) {\n          line.classList.add('edge-final');\n        } else {\n          line.classList.remove('edge-final');\n        }\n      }\n    });\n  }\n\n  // Mouse interaction for dragging nodes\n  let dragInfo = null;\n  function onNodeMouseDown(evt){\n    if(mode !== 'drag') return;\n    // prevent svg pan selection\n    evt.stopPropagation();\n    const g = evt.currentTarget;\n    const id = g.getAttribute('data-id');\n    const pt = getSVGPoint(evt.clientX, evt.clientY);\n    dragInfo = {id:id, offsetX: pt.x - byId(id).x, offsetY: pt.y - byId(id).y};\n    window.addEventListener('mousemove', onDragMove);\n    window.addEventListener('mouseup', onDragEnd);\n  }\n  function onDragMove(evt){\n    if(!dragInfo) return;\n    const pt = getSVGPoint(evt.clientX, evt.clientY);\n    const node = byId(dragInfo.id);\n    node.x = Math.max(30, Math.min(970, pt.x - dragInfo.offsetX + dragInfo.offsetX)); // keep within bounds\n    node.y = Math.max(30, Math.min(670, pt.y - dragInfo.offsetY + dragInfo.offsetY));\n    // simpler: set to pt coords\n    node.x = Math.max(30, Math.min(970, pt.x));\n    node.y = Math.max(30, Math.min(670, pt.y));\n    draw();\n  }\n  function onDragEnd(){\n    dragInfo = null;\n    window.removeEventListener('mousemove', onDragMove);\n    window.removeEventListener('mouseup', onDragEnd);\n  }\n\n  // Click node for various modes\n  function onNodeClick(evt){\n    evt.stopPropagation();\n    const id = evt.currentTarget.getAttribute('data-id');\n    if(mode === 'add-edge'){\n      if(!addEdgeFirst){\n        addEdgeFirst = id;\n        notice.textContent = `Add Edge: selected node ${id}. Click another node to finish.`;\n      } else {\n        const weight = Number(document.getElementById('edge-weight').value) || 1;\n        addEdge(addEdgeFirst, id, weight);\n        addEdgeFirst = null;\n        notice.textContent = `Edge added. Mode: Add Edge (click nodes to create another)`;\n      }\n    } else if(mode === 'set-source'){\n      sourceNode = id;\n      notice.textContent = `Source set to node ${id}. Click \"Initialize Dijkstra\" to start.`;\n      draw();\n    } else if(mode === 'drag'){\n      // show node info briefly\n      const d = dist[id];\n      const p = prev[id] || '-';\n      alert(`Node ${id}\\nDistance: ${d === undefined ? '—' : (d===Infinity?'∞':d)}\\nPrevious: ${p}`);\n    }\n  }\n\n  // Click on empty svg to add node when in add-node mode\n  svg.addEventListener('click', (evt) => {\n    if(mode !== 'add-node') return;\n    const pt = getSVGPoint(evt.clientX, evt.clientY);\n    addNode(pt.x, pt.y);\n  });\n\n  // Convert screen coords to SVG coords\n  function getSVGPoint(clientX, clientY){\n    const pt = svg.createSVGPoint();\n    pt.x = clientX; pt.y = clientY;\n    const ctm = svg.getScreenCTM().inverse();\n    const sp = pt.matrixTransform(ctm);\n    return {x: sp.x, y: sp.y};\n  }\n\n  // UI control wiring\n  document.getElementById('mode-add-node').addEventListener('click', ()=> setMode('add-node'));\n  document.getElementById('mode-add-edge').addEventListener('click', ()=> setMode('add-edge'));\n  document.getElementById('mode-set-source').addEventListener('click', ()=> setMode('set-source'));\n  document.getElementById('mode-drag').addEventListener('click', ()=> setMode('drag'));\n  document.getElementById('btn-make-random').addEventListener('click', makeRandomGraph);\n  document.getElementById('btn-clear').addEventListener('click', ()=> { if(confirm('Clear graph?')) clearGraph(); });\n  document.getElementById('btn-init').addEventListener('click', initializeDijkstra);\n  document.getElementById('btn-next').addEventListener('click', stepOnce);\n  document.getElementById('btn-run').addEventListener('click', startAutoRun);\n  document.getElementById('btn-pause').addEventListener('click', pauseAutoRun);\n  document.getElementById('btn-reset').addEventListener('click', resetRunState);\n  document.getElementById('btn-highlight-path').addEventListener('click', highlightShortestTree);\n  document.getElementById('btn-clear-highlights').addEventListener('click', clearHighlights);\n\n  function setMode(m){\n    mode = m;\n    addEdgeFirst = null;\n    document.querySelectorAll('.modes button').forEach(b => b.classList.remove('primary'));\n    if(m === 'add-node') document.getElementById('mode-add-node').classList.add('primary');\n    if(m === 'add-edge') document.getElementById('mode-add-edge').classList.add('primary');\n    if(m === 'set-source') document.getElementById('mode-set-source').classList.add('primary');\n    if(m === 'drag') document.getElementById('mode-drag').classList.add('primary');\n    notice.textContent = `Mode: ${m.replace('-',' ')}${m==='add-edge'?' — click two nodes to create an edge':''}`;\n  }\n\n  // Dijkstra algorithm functions\n  function initializeDijkstra(){\n    if(!sourceNode){\n      alert('Please set a source node first (use \"Set Source\" mode then click a node).');\n      return;\n    }\n    // initialize arrays\n    dist = {};\n    prev = {};\n    finalized = new Set();\n    current = null;\n    neighborIndex = 0;\n    highlightEdgeId = null;\n    nodes.forEach(n => {\n      dist[n.id] = Infinity;\n      prev[n.id] = null;\n    });\n    dist[sourceNode] = 0;\n    draw();\n    notice.textContent = 'Dijkstra initialized. Use \"Next Step\" to proceed.';\n  }\n\n  function resetRunState(){\n    pauseAutoRun();\n    dist = {};\n    prev = {};\n    finalized = new Set();\n    current = null;\n    neighborIndex = 0;\n    highlightEdgeId = null;\n    running = false;\n    draw();\n    notice.textContent = 'Run state reset. Set a source and initialize to begin.';\n  }\n\n  // Return neighbors list of node id: [{edge,neighborId,weight}]\n  function neighborsOf(id){\n    const list = [];\n    edges.forEach(e => {\n      if(e.u === id) list.push({edge: e, neighbor: e.v, w: e.w});\n      else if(e.v === id) list.push({edge: e, neighbor: e.u, w: e.w});\n    });\n    return list;\n  }\n\n  // Step logic: either extract next node or relax one neighbor of current.\n  function stepOnce(){\n    if(Object.keys(dist).length === 0){\n      notice.textContent = 'Run not initialized. Set source and click \"Initialize Dijkstra\".';\n      return;\n    }\n    // If no current being processed, choose next min (non-finalized)\n    if(current === null){\n      // find unfinalized node with smallest dist\n      let minNode = null; let minVal = Infinity;\n      for(const nid of Object.keys(dist)){\n        if(finalized.has(nid)) continue;\n        const d = dist[nid];\n        if(d < minVal){\n          minVal = d;\n          minNode = nid;\n        }\n      }\n      if(minNode === null || minVal === Infinity){\n        notice.textContent = 'Algorithm finished: no more reachable nodes.';\n        running = false;\n        pauseAutoRun();\n        draw();\n        return;\n      }\n      current = minNode;\n      neighborIndex = 0;\n      notice.textContent = `Extracted node ${current} (distance ${dist[current]}). Now relaxing its neighbors.`;\n      draw();\n      return;\n    }\n\n    // Process one neighbor of current (relaxation)\n    const neigh = neighborsOf(current);\n    if(neighborIndex < neigh.length){\n      const entry = neigh[neighborIndex];\n      const v = entry.neighbor;\n      const w = entry.w;\n      highlightEdgeId = entry.edge.id;\n      // skip if neighbor already finalized\n      if(finalized.has(v)){\n        notice.textContent = `Neighbor ${v} already finalized, skipping.`;\n      } else {\n        const alt = dist[current] + w;\n        if(alt < dist[v]){\n          dist[v] = alt;\n          prev[v] = current;\n          notice.textContent = `Relaxed edge ${current}→${v}: improved dist to ${alt}.`;\n        } else {\n          notice.textContent = `Examined edge ${current}→${v}: no improvement (alt ${alt}).`;\n        }\n      }\n      neighborIndex++;\n      draw();\n      return;\n    }\n\n    // All neighbors processed -> finalize current\n    finalized.add(current);\n    highlightEdgeId = null;\n    notice.textContent = `Finished with node ${current}. Marked finalized.`;\n    current = null;\n    neighborIndex = 0;\n    draw();\n  }\n\n  // Auto-run with small delay\n  function startAutoRun(){\n    if(Object.keys(dist).length === 0){\n      notice.textContent = 'Run not initialized. Set source and click \"Initialize Dijkstra\".';\n      return;\n    }\n    if(running) return;\n    running = true;\n    autoTimer = setInterval(() => {\n      // if finished, stop\n      // if current null and no more reachable nodes, stop automatically\n      if(current === null){\n        let has = false;\n        for(const n of Object.keys(dist)){\n          if(!finalized.has(n) && dist[n] < Infinity){\n            has = true; break;\n          }\n        }\n        if(!has){\n          // nothing left to process\n          pauseAutoRun();\n          notice.textContent = 'Auto-run complete.';\n          return;\n        }\n      }\n      stepOnce();\n    }, 600);\n    notice.textContent = 'Auto-run started.';\n  }\n  function pauseAutoRun(){\n    running = false;\n    if(autoTimer) clearInterval(autoTimer);\n    autoTimer = null;\n    notice.textContent = notice.textContent.replace('Auto-run started.','Paused.');\n  }\n\n  // UI: update distance table\n  function updateDistTable(){\n    const tbody = document.querySelector('#dist-table tbody');\n    tbody.innerHTML = '';\n    nodes.forEach(n=>{\n      const tr = document.createElement('tr');\n      const status = finalized.has(n.id) ? 'final' : (n.id===current ? 'current' : (dist[n.id]!==undefined && dist[n.id]<Infinity ? 'fringe' : 'unvisited'));\n      const td1 = document.createElement('td'); td1.textContent = n.label;\n      const td2 = document.createElement('td'); td2.textContent = dist[n.id]===undefined ? '—' : (dist[n.id] === Infinity ? '∞' : dist[n.id]);\n      const td3 = document.createElement('td'); td3.textContent = prev[n.id] || '-';\n      const td4 = document.createElement('td'); td4.textContent = status;\n      tr.appendChild(td1); tr.appendChild(td2); tr.appendChild(td3); tr.appendChild(td4);\n      tbody.appendChild(tr);\n    });\n  }\n\n  // Update fringe (priority queue) view\n  function updateFringeView(){\n    const div = document.getElementById('fringe');\n    // collect nodes that are not finalized and have finite dist\n    const fringes = nodes\n      .filter(n => dist[n.id]!==undefined && dist[n.id] < Infinity && !finalized.has(n.id))\n      .sort((a,b)=>dist[a.id]-dist[b.id])\n      .map(n => ({id:n.id, d:dist[n.id]}));\n    if(fringes.length === 0){\n      div.innerHTML = '<div class=\"small-muted\">Fringe empty</div>';\n    } else {\n      div.innerHTML = fringes.map(f => `<div style=\"margin-bottom:6px\"><strong>${f.id}</strong> &nbsp; dist=${f.d}${current===f.id? ' (current)' : ''}</div>`).join('');\n    }\n  }\n\n  // Highlight shortest tree (edges from prev[])\n  let highlightedEdges = new Set();\n  function highlightShortestTree(){\n    highlightedEdges.clear();\n    for(const nid of Object.keys(prev)){\n      const p = prev[nid];\n      if(p){\n        // find edge between p and nid\n        const e = edges.find(x => (x.u===p && x.v===nid) || (x.v===p && x.u===nid));\n        if(e) highlightedEdges.add(e.id);\n      }\n    }\n    // apply highlight style by thickening weight labels & edge\n    edges.forEach(e=>{\n      const line = document.getElementById('edge-'+e.id);\n      if(!line) return;\n      if(highlightedEdges.has(e.id)){\n        line.classList.add('edge-highlight');\n        line.classList.add('highlight-shadow');\n      } else {\n        line.classList.remove('edge-highlight');\n        line.classList.remove('highlight-shadow');\n      }\n    });\n    notice.textContent = 'Shortest-tree edges highlighted (those used by prev pointers).';\n  }\n  function clearHighlights(){\n    highlightedEdges.clear();\n    edges.forEach(e=>{\n      const line = document.getElementById('edge-'+e.id);\n      if(line){\n        line.classList.remove('edge-highlight');\n        line.classList.remove('highlight-shadow');\n      }\n    });\n    draw();\n    notice.textContent = 'Highlights cleared.';\n  }\n\n  // Random graph generator\n  function makeRandomGraph(){\n    if(!confirm('Generate a random graph? This will clear the current graph.')) return;\n    clearGraph();\n    const N = Math.max(4, Math.floor(Math.random()*6)+5); // 5-10 nodes\n    for(let i=0;i<N;i++){\n      const x = 80 + Math.random()*840;\n      const y = 80 + Math.random()*540;\n      addNode(x,y);\n    }\n    // connect with random edges\n    // ensure connectivity by making a random spanning tree first\n    const ids = nodes.map(n=>n.id);\n    const shuffled = ids.slice().sort(()=>Math.random()-0.5);\n    for(let i=1;i<shuffled.length;i++){\n      const u = shuffled[i];\n      const v = shuffled[Math.floor(Math.random()*i)];\n      addEdge(u,v, Math.floor(Math.random()*9)+1);\n    }\n    // add some extra edges\n    const extra = Math.floor(N * 0.8);\n    for(let i=0;i<extra;i++){\n      const a = ids[Math.floor(Math.random()*ids.length)];\n      const b = ids[Math.floor(Math.random()*ids.length)];\n      if(a!==b){\n        addEdge(a,b, Math.floor(Math.random()*12)+1);\n      }\n    }\n    draw();\n    notice.textContent = `Random graph with ${N} nodes created. Use Set Source → Initialize to run Dijkstra.`;\n  }\n\n  // Initialize with a small sample graph for first-time users\n  function seedSample(){\n    // simple graph layout\n    addNode(180,120); //1\n    addNode(480,120); //2\n    addNode(820,120); //3\n    addNode(320,340); //4\n    addNode(620,320); //5\n    addNode(200,560); //6\n    addNode(760,560); //7\n    addEdge('1','2',7);\n    addEdge('1','4',9);\n    addEdge('1','6',14);\n    addEdge('2','3',10);\n    addEdge('2','4',15);\n    addEdge('3','5',11);\n    addEdge('4','5',2);\n    addEdge('4','6',9);\n    addEdge('5','7',6);\n    addEdge('6','7',9);\n    draw();\n  }\n\n  // initial setup\n  setMode('drag');\n  seedSample();\n\n  // ensure window resizing keeps SVG viewBox visible; no extra handling needed due to preserveAspectRatio\n\n  // expose for debugging (optional)\n  window._graph = { nodes, edges, addNode, addEdge };\n})();\n</script>\n</body>\n</html>"
