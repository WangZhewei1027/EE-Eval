    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Depth-First Search (DFS)</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #graph {\n            width: 800px;\n            height: 600px;\n            border: 1px solid black;\n        }\n    </style>\n</head>\n<body>\n    <h1>Depth-First Search (DFS)</h1>\n    <canvas id=\"graph\"></canvas>\n\n    <script>\n        let graph = {\n            'A': ['B', 'C'],\n            'B': ['A', 'D', 'E'],\n            'C': ['A', 'F'],\n            'D': ['B'],\n            'E': ['B', 'F'],\n            'F': ['C', 'E']\n        };\n\n        let visited = new Set();\n        let stack = [];\n\n        function dfs(node, parent) {\n            visited.add(node);\n            stack.push(node);\n\n            for (let child of graph[node]) {\n                if (!visited.has(child)) {\n                    dfs(child, node);\n                }\n            }\n\n            stack.pop();\n        }\n\n        function drawGraph() {\n            let ctx = document.getElementById('graph').getContext('2d');\n            let graphCanvas = document.createElement('canvas');\n            graphCanvas.width = 800;\n            graphCanvas.height = 600;\n            graphCanvas.style.position = 'absolute';\n            graphCanvas.style.top = '0px';\n            graphCanvas.style.left = '0px';\n            graphCanvas.style.width = '100%';\n            graphCanvas.style.height = '100%';\n            document.body.appendChild(graphCanvas);\n\n            ctx = graphCanvas.getContext('2d');\n            drawGraph();\n\n            for (let node in graph) {\n                for (let child of graph[node]) {\n                    if (child !== parent) {\n                        ctx.beginPath();\n                        ctx.moveTo(100, 100);\n                        ctx.lineTo(300, 100);\n                        ctx.stroke();\n                    }\n                }\n            }\n        }\n\n        function startDFS() {\n            for (let node in graph) {\n                if (!visited.has(node)) {\n                    dfs(node, null);\n                }\n            }\n        }\n\n        startDFS();\n\n        drawGraph();\n    </script>\n</body>\n</html>"
