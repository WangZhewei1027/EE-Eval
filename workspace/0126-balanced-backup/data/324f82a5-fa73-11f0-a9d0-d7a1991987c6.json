    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Refactoring Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background-color: #f0f0f0;\n        }\n        .result {\n            font-size: 20px;\n            margin: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Refactoring Example</h1>\n    <input type=\"number\" id=\"num1\" placeholder=\"Enter first number\" />\n    <input type=\"number\" id=\"num2\" placeholder=\"Enter second number\" />\n    <button onclick=\"calculateSum()\">Calculate Sum</button>\n    <div class=\"result\" id=\"result\"></div>\n\n    <script>\n        // Original function without refactoring\n        function calculateSum() {\n            var num1 = parseFloat(document.getElementById('num1').value);\n            var num2 = parseFloat(document.getElementById('num2').value);\n            var result;\n\n            if (!isNaN(num1) && !isNaN(num2)) {\n                result = num1 + num2;\n            } else {\n                result = \"Please enter valid numbers\";\n            }\n\n            document.getElementById('result').innerText = result;\n        }\n\n        // Refactored version of the original function\n        function calculateSumRefactored() {\n            const num1 = getNumberValue('num1');\n            const num2 = getNumberValue('num2');\n            const result = computeSum(num1, num2);\n\n            displayResult(result);\n        }\n\n        function getNumberValue(id) {\n            const value = parseFloat(document.getElementById(id).value);\n            return isNaN(value) ? null : value;\n        }\n\n        function computeSum(num1, num2) {\n            if (num1 !== null && num2 !== null) {\n                return num1 + num2;\n            }\n            return \"Please enter valid numbers\";\n        }\n\n        function displayResult(result) {\n            document.getElementById('result').innerText = result;\n        }\n\n        // To use the refactored function\n        document.querySelector('button').onclick = calculateSumRefactored;\n    </script>\n</body>\n</html>"
