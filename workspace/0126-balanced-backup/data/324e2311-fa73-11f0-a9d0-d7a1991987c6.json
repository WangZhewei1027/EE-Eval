    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>PageRank Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f4f4f4;\n        }\n        canvas {\n            border: 1px solid #ccc;\n            margin-top: 20px;\n        }\n        #nodes {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>PageRank Algorithm Demonstration</h1>\n    <p>Click the button to see the PageRank values of the nodes.</p>\n    <button onclick=\"calculatePageRank()\">Calculate PageRank</button>\n    <div id=\"nodes\"></div>\n    <canvas id=\"canvas\" width=\"500\" height=\"500\"></canvas>\n\n    <script>\n        const graph = {\n            A: ['B', 'C'],\n            B: ['A', 'C'],\n            C: ['A'],\n            D: ['C'],\n            E: ['B', 'D']\n        };\n\n        const d = 0.85; // Damping factor\n        const numIterations = 100; // Number of iterations\n        \n        function calculatePageRank() {\n            let ranks = {};\n            let numNodes = Object.keys(graph).length;\n\n            // Initialize ranks\n            for (const node in graph) {\n                ranks[node] = 1 / numNodes;\n            }\n\n            // Iterate to calculate PageRank\n            for (let i = 0; i < numIterations; i++) {\n                let newRanks = {};\n                for (const node in graph) {\n                    newRanks[node] = (1 - d) / numNodes;\n                    for (const neighbor in graph) {\n                        if (graph[neighbor].includes(node)) {\n                            newRanks[node] += d * (ranks[neighbor] / graph[neighbor].length);\n                        }\n                    }\n                }\n                ranks = newRanks;\n            }\n\n            displayRanks(ranks);\n            drawGraph(ranks);\n        }\n\n        function displayRanks(ranks) {\n            const nodesDiv = document.getElementById('nodes');\n            nodesDiv.innerHTML = \"<h2>PageRank Values</h2>\";\n            for (const node in ranks) {\n                nodesDiv.innerHTML += `<p>${node}: ${ranks[node].toFixed(4)}</p>`;\n            }\n        }\n\n        function drawGraph(ranks) {\n            const canvas = document.getElementById('canvas');\n            const ctx = canvas.getContext('2d');\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n            const nodePositions = {\n                A: { x: 100, y: 100 },\n                B: { x: 300, y: 80 },\n                C: { x: 250, y: 200 },\n                D: { x: 400, y: 180 },\n                E: { x: 200, y: 300 }\n            };\n\n            for (const node in nodePositions) {\n                ctx.beginPath();\n                const radius = ranks[node] * 300; // Scale size by PageRank\n                ctx.arc(nodePositions[node].x, nodePositions[node].y, radius, 0, 2 * Math.PI);\n                ctx.fillStyle = `rgba(0, 0, 255, ${ranks[node]})`;\n                ctx.fill();\n                ctx.stroke();\n                ctx.closePath();\n                ctx.fillStyle = \"#000\";\n                ctx.fillText(node, nodePositions[node].x - 5, nodePositions[node].y + 5);\n            }\n        }\n    </script>\n</body>\n</html>"
