  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Space Complexity Explorer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{--bg:#0f1724;--card:#0b1220;--muted:#9aa7b2;--accent:#7dd3fc;--accent2:#fb923c}\n    *{box-sizing:border-box;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial}\n    body{margin:0;background:linear-gradient(180deg,#071022 0%, #071b2b 100%);color:#e6eef6;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}\n    .app{width:960px;max-width:96vw;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.03);padding:18px;border-radius:12px;box-shadow:0 6px 30px rgba(2,6,23,0.6)}\n    h1{margin:0 0 8px 0;font-size:20px}\n    p.lead{margin:0 0 16px 0;color:var(--muted);font-size:13px}\n    .controls{display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:12px}\n    .control{background:rgba(255,255,255,0.02);padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);display:flex;gap:8px;align-items:center}\n    label{font-size:13px;color:var(--muted);min-width:120px}\n    select,input[type=range]{background:transparent;color:inherit;border:0;outline:0}\n    .sliderVal{font-weight:600;color:var(--accent);min-width:36px;text-align:right}\n    .toggle{display:flex;align-items:center;gap:8px}\n    .btn{background:linear-gradient(90deg,var(--accent) 0%, #50c6f7 100%);border:none;color:#032127;padding:8px 12px;border-radius:8px;cursor:pointer}\n    .grid{display:grid;grid-template-columns:1fr 320px;gap:12px;margin-top:12px}\n    .panel{background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));padding:12px;border-radius:10px;border:1px solid rgba(255,255,255,0.02)}\n    .visHeader{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}\n    .bars{height:140px;background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));border-radius:6px;padding:10px;display:flex;flex-direction:column;gap:10px}\n    .barRow{display:flex;gap:8px;align-items:center}\n    .barLabel{width:120px;color:var(--muted);font-size:13px}\n    .barTrack{height:24px;background:rgba(255,255,255,0.03);border-radius:6px;flex:1;position:relative;overflow:hidden;border:1px solid rgba(255,255,255,0.02)}\n    .barSegment{height:100%;position:absolute;left:0;top:0;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;font-weight:700}\n    .inputSeg{background:linear-gradient(90deg,#60a5fa55,#7dd3fc55);color:#013040}\n    .auxSeg{background:linear-gradient(90deg,#fb923c55,#fb923c77);color:#1a0c00;left:auto;right:0;justify-content:flex-start;padding-left:8px}\n    .nums{display:flex;gap:12px;color:var(--muted);font-size:13px;align-items:center}\n    .code{background:#001122;border-radius:8px;padding:10px;margin-top:10px;font-family:Consolas,monospace;font-size:13px;color:#cfefff;white-space:pre-wrap}\n    .explain{color:var(--muted);font-size:13px;margin-top:8px}\n    .smallGrid{margin-top:10px;display:flex;flex-wrap:wrap;gap:4px}\n    .unit{width:14px;height:14px;background:linear-gradient(180deg,#0ea5a7,#7dd3fc);border-radius:3px;border:1px solid rgba(255,255,255,0.06)}\n    .unit.aux{background:linear-gradient(180deg,#fb923c,#fb923c);border-radius:3px}\n    footer{margin-top:12px;color:var(--muted);font-size:12px;text-align:center}\n    @media (max-width:900px){.grid{grid-template-columns:1fr}}\n  </style>\n</head>\n<body>\n  <div class=\"app\" role=\"main\" aria-labelledby=\"title\">\n    <h1 id=\"title\">Space Complexity Explorer</h1>\n    <p class=\"lead\">Interactively explore how different algorithms use memory (space complexity). Move the slider to change input size (n), pick an example, and see the estimated auxiliary space and visualized allocation. Auxiliary space = extra memory used beyond the input.</p>\n\n    <div class=\"controls\">\n      <div class=\"control\">\n        <label for=\"example\">Algorithm example</label>\n        <select id=\"example\" title=\"Choose algorithm example\" aria-label=\"Algorithm example\">\n          <option value=\"const\">Constant space (O(1)) — in-place sum</option>\n          <option value=\"copy\">Linear space (O(n)) — copy array (slice)</option>\n          <option value=\"map\">Linear space (O(n)) — map to new array</option>\n          <option value=\"matrix\">Quadratic space (O(n²)) — create n×n matrix</option>\n          <option value=\"rec_fact\">Linear space (O(n)) — recursive factorial (stack)</option>\n          <option value=\"rec_bin\">Logarithmic space (O(log n)) — recursive binary search</option>\n          <option value=\"fib_naive\">Recursive Fibonacci (call stack) — O(n) depth</option>\n        </select>\n      </div>\n\n      <div class=\"control\">\n        <label for=\"nRange\">Input size n</label>\n        <input id=\"nRange\" type=\"range\" min=\"1\" max=\"200\" value=\"10\" />\n        <div class=\"sliderVal\" id=\"nVal\">10</div>\n      </div>\n\n      <div class=\"control toggle\">\n        <label for=\"includeInput\" title=\"Toggle whether to include input size in total\">Include input in total?</label>\n        <input id=\"includeInput\" type=\"checkbox\" checked />\n      </div>\n\n      <div class=\"control\">\n        <button class=\"btn\" id=\"runBtn\">Update</button>\n      </div>\n    </div>\n\n    <div class=\"grid\">\n      <div class=\"panel\">\n        <div class=\"visHeader\">\n          <strong id=\"titleExample\">Constant space (O(1)) — in-place sum</strong>\n          <div class=\"nums\"><div id=\"formula\" style=\"font-weight:700\"></div></div>\n        </div>\n\n        <div class=\"bars\" aria-hidden=\"false\">\n          <div class=\"barRow\">\n            <div class=\"barLabel\">Input (given)</div>\n            <div class=\"barTrack\" id=\"inputTrack\" aria-label=\"Input memory\">\n              <div class=\"barSegment inputSeg\" id=\"inputSeg\" style=\"width:0%\">0</div>\n            </div>\n            <div style=\"width:80px;text-align:right;color:var(--muted);\" id=\"inputCount\">0 units</div>\n          </div>\n\n          <div class=\"barRow\">\n            <div class=\"barLabel\">Auxiliary (extra)</div>\n            <div class=\"barTrack\" id=\"auxTrack\" aria-label=\"Auxiliary memory\">\n              <div class=\"barSegment auxSeg\" id=\"auxSeg\" style=\"width:0%\">0</div>\n            </div>\n            <div style=\"width:80px;text-align:right;color:var(--muted);\" id=\"auxCount\">0 units</div>\n          </div>\n\n          <div class=\"barRow\">\n            <div class=\"barLabel\">Total (if counting input)</div>\n            <div class=\"barTrack\" id=\"totalTrack\" aria-label=\"Total memory\">\n              <div class=\"barSegment inputSeg\" id=\"totalInputSeg\" style=\"width:0%\"></div>\n              <div class=\"barSegment auxSeg\" id=\"totalAuxSeg\" style=\"width:0%\"></div>\n            </div>\n            <div style=\"width:80px;text-align:right;color:var(--muted);\" id=\"totalCount\">0 units</div>\n          </div>\n        </div>\n\n        <div class=\"code\" id=\"pseudocode\">\n/* Pseudocode and explanation will appear here for the chosen example */\n        </div>\n\n        <div class=\"explain\" id=\"explainText\"></div>\n      </div>\n\n      <div class=\"panel\" style=\"min-height:320px\">\n        <strong>Small visual grid (shows the memory units)</strong>\n        <div id=\"smallGrid\" class=\"smallGrid\" aria-hidden=\"false\"></div>\n\n        <div class=\"explain\" style=\"margin-top:12px\">\n          Tips:\n          <ul style=\"margin:6px 0 0 18px;color:var(--muted);font-size:13px\">\n            <li>Auxiliary (extra) space is memory used by the algorithm besides the input.</li>\n            <li>Space complexity is expressed using Big-O to describe how auxiliary space scales with n.</li>\n            <li>Recursive algorithms use stack frames; that counts toward space complexity.</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <footer>Built for learning — estimates are illustrative (unit counts are simplified).</footer>\n  </div>\n\n  <script>\n    (function(){\n      // Elements\n      const exampleEl = document.getElementById('example');\n      const nRange = document.getElementById('nRange');\n      const nVal = document.getElementById('nVal');\n      const runBtn = document.getElementById('runBtn');\n      const includeInput = document.getElementById('includeInput');\n\n      const titleExample = document.getElementById('titleExample');\n      const formulaEl = document.getElementById('formula');\n      const inputSeg = document.getElementById('inputSeg');\n      const auxSeg = document.getElementById('auxSeg');\n      const inputCount = document.getElementById('inputCount');\n      const auxCount = document.getElementById('auxCount');\n      const totalCount = document.getElementById('totalCount');\n      const totalInputSeg = document.getElementById('totalInputSeg');\n      const totalAuxSeg = document.getElementById('totalAuxSeg');\n      const pseudocode = document.getElementById('pseudocode');\n      const explainText = document.getElementById('explainText');\n      const smallGrid = document.getElementById('smallGrid');\n\n      // Example definitions\n      const examples = {\n        const: {\n          name: \"Constant space (O(1)) — in-place sum\",\n          formula: \"Auxiliary: O(1)\",\n          code: `// Sum array in-place using a single accumulator\nfunction sum(arr) {\n  let total = 0;      // O(1) extra\n  for (let i = 0; i < arr.length; i++) {\n    total += arr[i];\n  }\n  return total;\n}`,\n          explain: \"This algorithm uses constant auxiliary space: one accumulator variable. The input array exists already, and no new arrays or deep recursion are created.\",\n          auxFn: n => 1, // 1 unit auxiliary\n          inputFn: n => n // assume input occupies n units\n        },\n        copy: {\n          name: \"Linear space (O(n)) — copy array (slice)\",\n          formula: \"Auxiliary: O(n)\",\n          code: `// Make a shallow copy of the array\nfunction copyArray(arr) {\n  // slice allocates a new array with the same elements: O(n) extra\n  return arr.slice();\n}`,\n          explain: \"Copying an array allocates a new array proportional to the input size n, so auxiliary space is O(n).\",\n          auxFn: n => n,\n          inputFn: n => n\n        },\n        map: {\n          name: \"Linear space (O(n)) — map to new array\",\n          formula: \"Auxiliary: O(n)\",\n          code: `// Transform elements into a new array\nfunction double(arr) {\n  const out = [];            // new array, grows to n elements\n  for (let x of arr) {\n    out.push(x * 2);\n  }\n  return out;\n}`,\n          explain: \"Mapping to a new array requires storing n results, so auxiliary space grows linearly with n.\",\n          auxFn: n => n,\n          inputFn: n => n\n        },\n        matrix: {\n          name: \"Quadratic space (O(n²)) — create n×n matrix\",\n          formula: \"Auxiliary: O(n²)\",\n          code: `// Build an n x n matrix\nfunction makeMatrix(n) {\n  const mat = new Array(n);\n  for (let i = 0; i < n; i++) {\n    mat[i] = new Array(n).fill(0); // each row has n elements\n  }\n  return mat; // total elements = n * n (auxiliary)\n}`,\n          explain: \"A matrix of size n by n contains n² elements, so auxiliary memory is O(n²). Be careful: n=100 would allocate 10,000 elements.\",\n          auxFn: n => n * n,\n          inputFn: n => n\n        },\n        rec_fact: {\n          name: \"Linear space (O(n)) — recursive factorial (stack)\",\n          formula: \"Auxiliary: O(n) (call stack)\",\n          code: `// Recursive factorial\nfunction fact(n) {\n  if (n <= 1) return 1;\n  return n * fact(n - 1); // each call adds a stack frame -> depth n\n}`,\n          explain: \"Recursive calls add stack frames. The depth for factorial is proportional to n, so auxiliary space (stack) is O(n).\",\n          auxFn: n => n,\n          inputFn: n => 1 // input is a single integer\n        },\n        rec_bin: {\n          name: \"Logarithmic space (O(log n)) — recursive binary search\",\n          formula: \"Auxiliary: O(log n) (call stack)\",\n          code: `// Recursive binary search on sorted array\nfunction binarySearch(arr, target, lo = 0, hi = arr.length - 1) {\n  if (lo > hi) return -1;\n  const mid = Math.floor((lo + hi) / 2);\n  if (arr[mid] === target) return mid;\n  if (arr[mid] < target) return binarySearch(arr, target, mid + 1, hi);\n  else return binarySearch(arr, target, lo, mid - 1);\n}`,\n          explain: \"Binary search halves the search interval each recursive call, so the depth (stack frames) is O(log n). Auxiliary space is therefore logarithmic.\",\n          auxFn: n => Math.max(1, Math.floor(Math.log2(n)) + 1),\n          inputFn: n => n\n        },\n        fib_naive: {\n          name: \"Recursive Fibonacci (call stack) — O(n) depth\",\n          formula: \"Auxiliary: O(n) (call stack depth)\",\n          code: `// Naive recursive Fibonacci (time exponential, space linear)\nfunction fib(n) {\n  if (n <= 1) return n;\n  return fib(n - 1) + fib(n - 2); // recursion depth is O(n)\n}`,\n          explain: \"Even though time is exponential, the deepest chain of calls grows linearly with n (O(n)), so the call stack uses O(n) space.\",\n          auxFn: n => n,\n          inputFn: n => 1\n        }\n      };\n\n      // Utility to update UI\n      function updateUI() {\n        const key = exampleEl.value;\n        const ex = examples[key];\n        const n = parseInt(nRange.value, 10);\n\n        // Compute units\n        const inputUnits = ex.inputFn(n);\n        let auxUnits = ex.auxFn(n);\n\n        // Protect from extremely large visual numbers\n        const maxVisualUnits = 2000000; // somewhat arbitrary cap\n        if (inputUnits > maxVisualUnits || auxUnits > maxVisualUnits) {\n          auxUnits = Math.min(auxUnits, maxVisualUnits);\n        }\n\n        // Titles and texts\n        titleExample.textContent = ex.name;\n        formulaEl.textContent = ex.formula;\n\n        pseudocode.textContent = ex.code;\n        explainText.textContent = ex.explain;\n\n        // Update counts\n        inputCount.textContent = inputUnits + \" units\";\n        auxCount.textContent = auxUnits + \" units\";\n\n        // Total\n        const totalUnits = (includeInput.checked ? (inputUnits + auxUnits) : auxUnits);\n        totalCount.textContent = totalUnits + \" units\";\n\n        // Percent widths for bars (avoid divide by zero)\n        const denom = Math.max(1, inputUnits + auxUnits);\n        const inputPct = Math.round((inputUnits / denom) * 100);\n        const auxPct = Math.round((auxUnits / denom) * 100);\n\n        // Update bar segments (aux segment is placed on the right)\n        inputSeg.style.width = inputPct + \"%\";\n        inputSeg.textContent = inputUnits > 0 ? inputUnits : \"\";\n        auxSeg.style.width = auxPct + \"%\";\n        auxSeg.textContent = auxUnits > 0 ? auxUnits : \"\";\n\n        // For total bar: show combined segments side by side\n        const totalDenom = Math.max(1, (includeInput.checked ? (inputUnits + auxUnits) : auxUnits));\n        const totalInputPct = includeInput.checked ? Math.round((inputUnits / totalDenom) * 100) : 0;\n        const totalAuxPct = totalDenom === 0 ? 0 : Math.round(((includeInput.checked ? auxUnits : auxUnits) / totalDenom) * 100);\n\n        totalInputSeg.style.width = totalInputPct + \"%\";\n        totalAuxSeg.style.width = totalAuxPct + \"%\";\n\n        // Small grid visualization: show up to 300 units as small boxes; otherwise show a scaled summary\n        smallGrid.innerHTML = \"\";\n        const maxBoxes = 300;\n        const showInputBoxes = Math.min(inputUnits, maxBoxes);\n        const showAuxBoxes = Math.min(auxUnits, maxBoxes - showInputBoxes);\n\n        if (inputUnits + auxUnits <= maxBoxes) {\n          // draw all boxes directly\n          for (let i=0;i<inputUnits;i++){\n            const d = document.createElement('div');\n            d.className = 'unit';\n            d.title = 'input unit';\n            smallGrid.appendChild(d);\n          }\n          for (let i=0;i<auxUnits;i++){\n            const d = document.createElement('div');\n            d.className = 'unit aux';\n            d.title = 'auxiliary unit';\n            smallGrid.appendChild(d);\n          }\n        } else {\n          // draw scaled representation\n          // show a sample of input and aux using up to maxBoxes but indicate a legend with scale\n          const sampleInput = Math.round(Math.max(1, (inputUnits/(inputUnits+auxUnits)) * maxBoxes * 0.6));\n          const sampleAux = Math.round(Math.max(1, (auxUnits/(inputUnits+auxUnits)) * maxBoxes * 0.6));\n\n          // ensure not exceed maxBoxes\n          let sI = sampleInput, sA = sampleAux;\n          if (sI + sA > maxBoxes) {\n            const scale = maxBoxes / (sI + sA);\n            sI = Math.max(1, Math.round(sI * scale));\n            sA = Math.max(1, Math.round(sA * scale));\n          }\n          for (let i=0;i<sI;i++){\n            const d = document.createElement('div');\n            d.className = 'unit';\n            d.title = 'input unit (sample)';\n            d.style.opacity = 0.9;\n            smallGrid.appendChild(d);\n          }\n          for (let i=0;i<sA;i++){\n            const d = document.createElement('div');\n            d.className = 'unit aux';\n            d.title = 'auxiliary unit (sample)';\n            d.style.opacity = 0.9;\n            smallGrid.appendChild(d);\n          }\n          const note = document.createElement('div');\n          note.style.color = 'var(--muted)';\n          note.style.fontSize = '12px';\n          note.style.marginTop = '8px';\n          note.textContent = `Visualization shows a scaled sample (${sI} input + ${sA} auxiliary boxes). Actual units: input=${inputUnits}, aux=${auxUnits}.`;\n          smallGrid.appendChild(note);\n        }\n\n        // Accessibility: update ARIA labels\n        inputSeg.setAttribute('aria-valuenow', inputUnits);\n        auxSeg.setAttribute('aria-valuenow', auxUnits);\n      }\n\n      // Event listeners\n      nRange.addEventListener('input', ()=>{ nVal.textContent = nRange.value; });\n      runBtn.addEventListener('click', updateUI);\n      exampleEl.addEventListener('change', updateUI);\n      includeInput.addEventListener('change', updateUI);\n\n      // Initialize\n      nVal.textContent = nRange.value;\n      updateUI();\n    })();\n  </script>\n</body>\n</html>"
  },
