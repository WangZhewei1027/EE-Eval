  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Deadlock Demonstration (Single File)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, Arial; margin: 16px; background:#f7f9fc; color:#111;}\n    header { margin-bottom: 12px; }\n    h1 { font-size: 20px; margin: 0 0 6px 0; }\n    p { margin: 6px 0; color:#333; }\n    .controls { display:flex; gap:8px; margin: 10px 0 18px 0; flex-wrap:wrap;}\n    button { padding:8px 12px; border-radius:6px; border:1px solid #cbd5e1; background: white; cursor:pointer; }\n    button.primary { background:#2563eb; color:white; border-color:#1d4ed8; }\n    button.warn { background:#f97316; color:white; border-color:#ea580c; }\n    button.ghost { background:transparent; border:1px dashed #cbd5e1; }\n    .board { display:flex; gap:16px; align-items:flex-start; flex-wrap:wrap; }\n    .column { background: white; border-radius:8px; padding:12px; box-shadow: 0 1px 3px rgba(16,24,40,0.06); width:270px; }\n    .title { font-weight:700; margin-bottom:8px; font-size:14px; }\n    .resource { border:1px solid #e6eef8; border-radius:8px; padding:10px; display:flex; align-items:center; gap:10px; margin-bottom:8px; }\n    .resource .dot { width:14px; height:14px; border-radius:4px; }\n    .free { background:#d1fae5; border:1px solid #86efac; }\n    .owned { background:#fde68a; border:1px solid #facc15; }\n    .waiting { background:#fbcfe8; border:1px solid #fb7185; }\n    .proc { padding:8px; border-radius:8px; margin-bottom:8px; background:#f8fafc; border:1px solid #e2e8f0; }\n    .proc.running { border-color:#34d399; box-shadow:0 0 0 4px rgba(16,185,129,0.06); }\n    .proc.waiting { border-color:#fb7185; box-shadow:0 0 0 4px rgba(239,68,68,0.06); }\n    .log { max-height:240px; overflow:auto; background:#0f172a; color:#e6eef8; padding:8px; border-radius:6px; font-family: monospace; font-size:12px; }\n    .legend { font-size:12px; margin-top:6px; color:#374151; }\n    .link { color:#2563eb; text-decoration:underline; cursor:pointer; background:transparent; border:none; padding:0; }\n    .cycle { color:#b91c1c; font-weight:700; }\n    footer { margin-top:14px; font-size:12px; color:#475569; }\n    .spacer { height:8px; }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Deadlock Demonstration</h1>\n    <p>Interactive single-file demo that simulates two processes and two shared resources. Start the sequence that leads to a deadlock, observe the wait-for graph and detection, and break or avoid the deadlock.</p>\n  </header>\n\n  <div class=\"controls\">\n    <button id=\"startDead\" class=\"primary\">Start Deadlock</button>\n    <button id=\"startOrdered\">Start Without Deadlock (Ordered Locks)</button>\n    <button id=\"detectToggle\">Auto-detect: ON</button>\n    <button id=\"breakDead\" class=\"warn\">Break Deadlock (force release)</button>\n    <button id=\"reset\" class=\"ghost\">Reset</button>\n  </div>\n\n  <div class=\"board\">\n    <div class=\"column\" style=\"min-width:340px;\">\n      <div class=\"title\">Processes</div>\n      <div id=\"procA\" class=\"proc\">\n        <div style=\"font-weight:700\">Process A</div>\n        <div id=\"procAStatus\">Idle</div>\n        <div class=\"spacer\"></div>\n        <div style=\"font-size:13px\">Holds: <span id=\"holdsA\">—</span></div>\n        <div style=\"font-size:13px\">Waiting for: <span id=\"waitA\">—</span></div>\n      </div>\n\n      <div id=\"procB\" class=\"proc\">\n        <div style=\"font-weight:700\">Process B</div>\n        <div id=\"procBStatus\">Idle</div>\n        <div class=\"spacer\"></div>\n        <div style=\"font-size:13px\">Holds: <span id=\"holdsB\">—</span></div>\n        <div style=\"font-size:13px\">Waiting for: <span id=\"waitB\">—</span></div>\n      </div>\n\n      <div class=\"spacer\"></div>\n      <div class=\"title\">Log</div>\n      <div id=\"log\" class=\"log\"></div>\n    </div>\n\n    <div class=\"column\">\n      <div class=\"title\">Resources / Locks</div>\n      <div id=\"res1\" class=\"resource\">\n        <div class=\"dot free\" id=\"dotR1\"></div>\n        <div>\n          <div style=\"font-weight:700\">Resource R1</div>\n          <div style=\"font-size:13px\">Owner: <span id=\"ownerR1\">—</span></div>\n        </div>\n      </div>\n\n      <div id=\"res2\" class=\"resource\">\n        <div class=\"dot free\" id=\"dotR2\"></div>\n        <div>\n          <div style=\"font-weight:700\">Resource R2</div>\n          <div style=\"font-size:13px\">Owner: <span id=\"ownerR2\">—</span></div>\n        </div>\n      </div>\n\n      <div class=\"spacer\"></div>\n      <div class=\"title\">Deadlock / Wait-for Graph</div>\n      <div id=\"graphDesc\">No active waits.</div>\n      <div style=\"margin-top:8px\" id=\"cycleInfo\"></div>\n      <div class=\"legend\">\n        Legend: <span style=\"display:inline-block;padding:2px 6px;border-radius:4px;background:#d1fae5;margin-right:6px\">Free</span>\n        <span style=\"display:inline-block;padding:2px 6px;border-radius:4px;background:#fde68a;margin-right:6px\">Owned</span>\n        <span style=\"display:inline-block;padding:2px 6px;border-radius:4px;background:#fbcfe8\">Waiting</span>\n      </div>\n    </div>\n  </div>\n\n  <footer>\n    Notes: This demo uses cooperative async \"locks\" to illustrate the four Coffman conditions that cause deadlock: mutual exclusion, hold and wait, no preemption, and circular wait. Press \"Break Deadlock\" to force release and let one process continue.\n  </footer>\n\n  <script>\n    // Simple Promise-based lock implementation\n    class Lock {\n      constructor(name) {\n        this.name = name;\n        this.owner = null;     // process id string or null\n        this.queue = [];       // array of {pid, resolve}\n      }\n\n      // Acquire returns a promise that resolves when owner is set to pid.\n      acquire(pid) {\n        if (this.owner === null) {\n          this.owner = pid;\n          return Promise.resolve();\n        }\n        // Put the pid into queue and return a promise that resolves when lock assigned\n        return new Promise(resolve => {\n          this.queue.push({ pid, resolve });\n        });\n      }\n\n      // Release the lock. If there's a waiting requester, assign to next in queue.\n      release(releasingPid) {\n        if (this.owner !== releasingPid && this.owner !== null) {\n          // someone else forced or bad release; still allow force release\n        }\n        this.owner = null;\n        if (this.queue.length > 0) {\n          const next = this.queue.shift();\n          this.owner = next.pid;\n          // resolve the waiting acquire\n          next.resolve();\n        }\n      }\n\n      // Force release - empty the queue and free\n      forceRelease() {\n        this.owner = null;\n        // resolve nothing automatically -- we keep queued promises but since owner is null,\n        // next caller will get it on calling acquire. Forcing will also clear queue so waiting tasks won't auto-acquire.\n        this.queue = [];\n      }\n    }\n\n    // Global simulation state\n    const R1 = new Lock('R1');\n    const R2 = new Lock('R2');\n\n    // UI elements\n    const dotR1 = document.getElementById('dotR1');\n    const dotR2 = document.getElementById('dotR2');\n    const ownerR1 = document.getElementById('ownerR1');\n    const ownerR2 = document.getElementById('ownerR2');\n    const procAStatus = document.getElementById('procAStatus');\n    const procBStatus = document.getElementById('procBStatus');\n    const holdsA = document.getElementById('holdsA');\n    const holdsB = document.getElementById('holdsB');\n    const waitA = document.getElementById('waitA');\n    const waitB = document.getElementById('waitB');\n    const logEl = document.getElementById('log');\n    const graphDesc = document.getElementById('graphDesc');\n    const cycleInfo = document.getElementById('cycleInfo');\n\n    const startDead = document.getElementById('startDead');\n    const startOrdered = document.getElementById('startOrdered');\n    const detectToggle = document.getElementById('detectToggle');\n    const breakDead = document.getElementById('breakDead');\n    const resetBtn = document.getElementById('reset');\n\n    let detectOn = true;\n    let simActive = false;\n    let mode = null; // \"deadlock\" or \"ordered\"\n    let detectInterval = null;\n\n    function log(msg) {\n      const time = new Date().toLocaleTimeString();\n      logEl.innerText = `[${time}] ${msg}\\n` + logEl.innerText;\n    }\n\n    function updateUI() {\n      ownerR1.innerText = R1.owner || '—';\n      ownerR2.innerText = R2.owner || '—';\n\n      // dot colors\n      dotR1.className = 'dot ' + (R1.owner ? 'owned' : 'free');\n      dotR2.className = 'dot ' + (R2.owner ? 'owned' : 'free');\n\n      // holds lists\n      holdsA.innerText = (R1.owner === 'A' || R2.owner === 'A') ? [R1.owner==='A'?'R1':null, R2.owner==='A'?'R2':null].filter(Boolean).join(', ') : '—';\n      holdsB.innerText = (R1.owner === 'B' || R2.owner === 'B') ? [R1.owner==='B'?'R1':null, R2.owner==='B'?'R2':null].filter(Boolean).join(', ') : '—';\n    }\n\n    // Track waiting states for UI only (not part of Lock)\n    const waitingFor = { A: null, B: null };\n\n    // Wait-for graph detection: edges process -> process if process waits for a resource owned by that other process.\n    function computeWaitForGraph() {\n      const edges = [];\n      if (waitingFor.A) {\n        const owner = (waitingFor.A === 'R1' ? R1.owner : R2.owner);\n        if (owner && owner !== 'A') edges.push(['A', owner]);\n      }\n      if (waitingFor.B) {\n        const owner = (waitingFor.B === 'R1' ? R1.owner : R2.owner);\n        if (owner && owner !== 'B') edges.push(['B', owner]);\n      }\n      return edges;\n    }\n\n    function detectCycle() {\n      const edges = computeWaitForGraph();\n      // build adjacency\n      const nodes = ['A','B'];\n      const adj = { A: [], B: [] };\n      edges.forEach(([u,v]) => adj[u].push(v));\n      // detect cycle with DFS\n      const visited = { A:false, B:false }, stack = { A:false, B:false };\n      const cycleNodes = [];\n\n      function dfs(u) {\n        visited[u]=true; stack[u]=true;\n        for (const v of adj[u]) {\n          if (!visited[v]) {\n            if (dfs(v)) { cycleNodes.push(v); return true; }\n          } else if (stack[v]) {\n            cycleNodes.push(v);\n            return true;\n          }\n        }\n        stack[u]=false;\n        return false;\n      }\n\n      let found=false;\n      for (const n of nodes) {\n        if (!visited[n]) {\n          if (dfs(n)) { cycleNodes.push(n); found=true; break; }\n        }\n      }\n      return { found, edges, cycle: found ? Array.from(new Set(cycleNodes)) : [] };\n    }\n\n    function updateGraphUI() {\n      const { found, edges, cycle } = detectCycle();\n      if (edges.length === 0) {\n        graphDesc.innerText = 'No active waits.';\n        cycleInfo.innerText = '';\n      } else {\n        graphDesc.innerText = 'Wait-for edges: ' + edges.map(e => `${e[0]} → ${e[1]}`).join(', ');\n        if (found) {\n          cycleInfo.innerHTML = '<span class=\"cycle\">Deadlock detected!</span> Cycle involves: ' + cycle.join(', ');\n        } else {\n          cycleInfo.innerText = 'No cycle detected.';\n        }\n      }\n    }\n\n    // Process code. Each process attempts to:\n    // - Acquire first resource and hold\n    // - Then attempt to acquire second resource (which may be held by the other), causing wait.\n    // For \"deadlock\" mode, A acquires R1 then tries R2; B acquires R2 then tries R1 (circular wait).\n    // For \"ordered\" mode, both acquire R1 then R2 (same global order) to avoid deadlock.\n    async function processA() { // id 'A'\n      procAStatus.innerText = 'Starting...'; procAStatus.parentElement.classList.remove('waiting'); procAStatus.parentElement.classList.add('running');\n      log('Process A: start');\n      updateUI();\n\n      if (mode === 'deadlock') {\n        // acquire R1\n        procAStatus.innerText = 'Acquiring R1...';\n        await R1.acquire('A');\n        procAStatus.innerText = 'Holding R1';\n        log('Process A acquired R1');\n        updateUI();\n\n        // hold briefly to increase chance of circular wait\n        await sleep(300);\n        // attempt to acquire R2\n        waitingFor.A = 'R2';\n        procAStatus.innerText = 'Waiting for R2';\n        procAStatus.parentElement.classList.remove('running'); procAStatus.parentElement.classList.add('waiting');\n        log('Process A attempts to acquire R2 (may block)');\n        updateGraphUI();\n        await R2.acquire('A'); // will block if B holds it\n        waitingFor.A = null;\n        procAStatus.innerText = 'Acquired R2';\n        procAStatus.parentElement.classList.remove('waiting'); procAStatus.parentElement.classList.add('running');\n        log('Process A acquired R2');\n        updateUI();\n\n        // work, then release both\n        await sleep(400);\n        R2.release('A'); log('Process A released R2');\n        R1.release('A'); log('Process A released R1');\n      } else if (mode === 'ordered') {\n        // both processes acquire in same order: R1 then R2\n        procAStatus.innerText = 'Acquiring R1...';\n        await R1.acquire('A');\n        procAStatus.innerText = 'Holding R1';\n        log('Process A acquired R1 (ordered)');\n        updateUI();\n\n        await sleep(200);\n        waitingFor.A = 'R2';\n        procAStatus.innerText = 'Waiting for R2';\n        procAStatus.parentElement.classList.remove('running'); procAStatus.parentElement.classList.add('waiting');\n        await R2.acquire('A');\n        waitingFor.A = null;\n        procAStatus.innerText = 'Acquired R2';\n        procAStatus.parentElement.classList.remove('waiting'); procAStatus.parentElement.classList.add('running');\n        log('Process A acquired R2 (ordered)');\n        updateUI();\n\n        await sleep(400);\n        R2.release('A'); log('Process A released R2 (ordered)');\n        R1.release('A'); log('Process A released R1 (ordered)');\n      }\n\n      procAStatus.innerText = 'Done';\n      procAStatus.parentElement.classList.remove('running','waiting');\n      waitingFor.A = null;\n      updateUI();\n      updateGraphUI();\n      log('Process A: finished');\n    }\n\n    async function processB() { // id 'B'\n      procBStatus.innerText = 'Starting...'; procBStatus.parentElement.classList.remove('waiting'); procBStatus.parentElement.classList.add('running');\n      log('Process B: start');\n      updateUI();\n\n      if (mode === 'deadlock') {\n        // acquire R2 first (opposite order)\n        procBStatus.innerText = 'Acquiring R2...';\n        await R2.acquire('B');\n        procBStatus.innerText = 'Holding R2';\n        log('Process B acquired R2');\n        updateUI();\n\n        await sleep(300);\n        waitingFor.B = 'R1';\n        procBStatus.innerText = 'Waiting for R1';\n        procBStatus.parentElement.classList.remove('running'); procBStatus.parentElement.classList.add('waiting');\n        log('Process B attempts to acquire R1 (may block)');\n        updateGraphUI();\n        await R1.acquire('B');\n        waitingFor.B = null;\n        procBStatus.innerText = 'Acquired R1';\n        procBStatus.parentElement.classList.remove('waiting'); procBStatus.parentElement.classList.add('running');\n        log('Process B acquired R1');\n        updateUI();\n\n        await sleep(400);\n        R1.release('B'); log('Process B released R1');\n        R2.release('B'); log('Process B released R2');\n      } else if (mode === 'ordered') {\n        // same order: R1 then R2\n        procBStatus.innerText = 'Acquiring R1...';\n        await R1.acquire('B');\n        procBStatus.innerText = 'Holding R1';\n        log('Process B acquired R1 (ordered)');\n        updateUI();\n\n        await sleep(200);\n        waitingFor.B = 'R2';\n        procBStatus.innerText = 'Waiting for R2';\n        procBStatus.parentElement.classList.remove('running'); procBStatus.parentElement.classList.add('waiting');\n        await R2.acquire('B');\n        waitingFor.B = null;\n        procBStatus.innerText = 'Acquired R2';\n        procBStatus.parentElement.classList.remove('waiting'); procBStatus.parentElement.classList.add('running');\n        log('Process B acquired R2 (ordered)');\n        updateUI();\n\n        await sleep(400);\n        R2.release('B'); log('Process B released R2 (ordered)');\n        R1.release('B'); log('Process B released R1 (ordered)');\n      }\n\n      procBStatus.innerText = 'Done';\n      procBStatus.parentElement.classList.remove('running','waiting');\n      waitingFor.B = null;\n      updateUI();\n      updateGraphUI();\n      log('Process B: finished');\n    }\n\n    // utility sleep\n    function sleep(ms) {\n      return new Promise(resolve => setTimeout(resolve, ms));\n    }\n\n    // start functions\n    startDead.addEventListener('click', async () => {\n      if (simActive) { log('Simulation already running'); return; }\n      resetLocks();\n      mode = 'deadlock';\n      simActive = true;\n      log('Starting DEADLOCK scenario (A: R1 then R2; B: R2 then R1)');\n      // start both without waiting for each other; they will interleave\n      processA();\n      processB();\n      startDetectionLoop();\n    });\n\n    startOrdered.addEventListener('click', async () => {\n      if (simActive) { log('Simulation already running'); return; }\n      resetLocks();\n      mode = 'ordered';\n      simActive = true;\n      log('Starting ORDERED scenario (both acquire R1 then R2) - should avoid deadlock');\n      processA();\n      // slight offset to simulate concurrency but maintain ordering\n      setTimeout(processB, 60);\n      startDetectionLoop();\n    });\n\n    detectToggle.addEventListener('click', () => {\n      detectOn = !detectOn;\n      detectToggle.innerText = `Auto-detect: ${detectOn ? 'ON' : 'OFF'}`;\n      if (detectOn) startDetectionLoop(); else stopDetectionLoop();\n    });\n\n    breakDead.addEventListener('click', () => {\n      // Forcefully release one resource to break potential deadlock.\n      log('Force-releasing R2 to break deadlock (simulates preemption)');\n      R2.forceRelease();\n      // also release R1 as safety\n      R1.forceRelease();\n      waitingFor.A = null; waitingFor.B = null;\n      updateUI();\n      updateGraphUI();\n    });\n\n    resetBtn.addEventListener('click', () => {\n      resetAll();\n      log('Reset simulation');\n    });\n\n    function resetLocks() {\n      R1.owner = null; R1.queue = [];\n      R2.owner = null; R2.queue = [];\n      waitingFor.A = null; waitingFor.B = null;\n      updateUI();\n      updateGraphUI();\n      procAStatus.innerText = 'Idle'; procBStatus.innerText = 'Idle';\n      procAStatus.parentElement.classList.remove('running','waiting');\n      procBStatus.parentElement.classList.remove('running','waiting');\n      logEl.innerText = '';\n    }\n\n    function resetAll() {\n      stopDetectionLoop();\n      simActive = false;\n      mode = null;\n      resetLocks();\n    }\n\n    function startDetectionLoop() {\n      if (!detectOn) return;\n      if (detectInterval) clearInterval(detectInterval);\n      detectInterval = setInterval(() => {\n        updateUI();\n        updateGraphUI();\n        const det = detectCycle();\n        if (det.found) {\n          log('Deadlock detected (cycle): ' + det.cycle.join(' -> '));\n        }\n      }, 300);\n    }\n\n    function stopDetectionLoop() {\n      if (detectInterval) { clearInterval(detectInterval); detectInterval = null; }\n    }\n\n    // initialize\n    resetAll();\n    updateUI();\n\n    // Small extra: clicking on resource will force release to show resolution\n    document.getElementById('res1').addEventListener('click', () => {\n      R1.forceRelease();\n      waitingFor.A = waitingFor.A === 'R1' ? null : waitingFor.A;\n      waitingFor.B = waitingFor.B === 'R1' ? null : waitingFor.B;\n      log('R1 force-released (manual)');\n      updateUI(); updateGraphUI();\n    });\n    document.getElementById('res2').addEventListener('click', () => {\n      R2.forceRelease();\n      waitingFor.A = waitingFor.A === 'R2' ? null : waitingFor.A;\n      waitingFor.B = waitingFor.B === 'R2' ? null : waitingFor.B;\n      log('R2 force-released (manual)');\n      updateUI(); updateGraphUI();\n    });\n\n    // Update status display frequently for visual clarity\n    setInterval(() => {\n      // show waiting text values\n      waitA.innerText = waitingFor.A || '—';\n      waitB.innerText = waitingFor.B || '—';\n      updateUI();\n    }, 150);\n\n  </script>\n</body>\n</html>"
