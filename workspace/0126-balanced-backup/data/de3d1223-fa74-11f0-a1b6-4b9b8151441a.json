    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Query Optimization Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        .container {\n            display: flex;\n            gap: 20px;\n        }\n        .column {\n            flex: 1;\n            padding: 15px;\n            background-color: #f5f5f5;\n            border-radius: 5px;\n        }\n        button {\n            padding: 8px 15px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n            margin: 10px 0;\n        }\n        button:hover {\n            background-color: #45a049;\n        }\n        pre {\n            background-color: #eee;\n            padding: 10px;\n            border-radius: 4px;\n            overflow-x: auto;\n        }\n        .time-display {\n            font-weight: bold;\n            color: #d35400;\n        }\n        .optimized {\n            border-left: 4px solid #2ecc71;\n        }\n        .unoptimized {\n            border-left: 4px solid #e74c3c;\n        }\n    </style>\n</head>\n<body>\n    <h1>Query Optimization Demonstration</h1>\n    <p>This demo shows the performance difference between unoptimized and optimized database queries in JavaScript.</p>\n    \n    <div class=\"container\">\n        <div class=\"column unoptimized\">\n            <h2>Unoptimized Query</h2>\n            <p>This approach performs a full table scan for each search, which is inefficient.</p>\n            <div>\n                <label for=\"unopt-search\">Search products:</label>\n                <input type=\"text\" id=\"unopt-search\" placeholder=\"Enter product name\">\n                <button onclick=\"runUnoptimizedQuery()\">Run Query</button>\n            </div>\n            <div>\n                <p>Execution time: <span class=\"time-display\" id=\"unopt-time\">0 ms</span></p>\n                <p>Results: <span id=\"unopt-results-count\">0</span> items</p>\n                <pre id=\"unopt-results\"></pre>\n            </div>\n        </div>\n        \n        <div class=\"column optimized\">\n            <h2>Optimized Query</h2>\n            <p>This approach uses indexing for faster lookups and avoids full table scans.</p>\n            <div>\n                <label for=\"opt-search\">Search products:</label>\n                <input type=\"text\" id=\"opt-search\" placeholder=\"Enter product name\">\n                <button onclick=\"runOptimizedQuery()\">Run Query</button>\n            </div>\n            <div>\n                <p>Execution time: <span class=\"time-display\" id=\"opt-time\">0 ms</span></p>\n                <p>Results: <span id=\"opt-results-count\">0</span> items</p>\n                <pre id=\"opt-results\"></pre>\n            </div>\n        </div>\n    </div>\n    \n    <h3>Key Optimization Techniques Demonstrated:</h3>\n    <ul>\n        <li><strong>Indexing:</strong> Creating a lookup structure for faster searches</li>\n        <li><strong>Query Planning:</strong> Analyzing the most efficient way to execute queries</li>\n        <li><strong>Early Filtering:</strong> Applying filters as early as possible</li>\n        <li><strong>Projection:</strong> Only retrieving needed fields</li>\n    </ul>\n\n    <script>\n        // Sample product database\n        const products = [];\n        const productIndex = {}; // Our optimization: an index for products\n        \n        // Generate sample data\n        function generateSampleData() {\n            const categories = ['Electronics', 'Clothing', 'Home', 'Books', 'Toys'];\n            const brands = ['Acme', 'Globex', 'Soylent', 'Initech', 'Umbrella'];\n            \n            for (let i = 0; i < 10000; i++) {\n                const product = {\n                    id: i,\n                    name: `Product ${i} ${brands[i % brands.length]}`,\n                    category: categories[i % categories.length],\n                    price: (Math.random() * 100).toFixed(2),\n                    inStock: Math.random() > 0.3,\n                    rating: Math.floor(Math.random() * 5) + 1\n                };\n                products.push(product);\n                \n                // Build our index (optimization)\n                if (!productIndex[product.category]) {\n                    productIndex[product.category] = [];\n                }\n                productIndex[product.category].push(product);\n            }\n        }\n        \n        // Unoptimized query - scans entire collection\n        function unoptimizedQuery(searchTerm, categoryFilter) {\n            const results = [];\n            const startTime = performance.now();\n            \n            for (const product of products) {\n                if ((!searchTerm || product.name.includes(searchTerm)) &&\n                    (!categoryFilter || product.category === categoryFilter)) {\n                    results.push({\n                        id: product.id,\n                        name: product.name,\n                        price: product.price\n                    });\n                }\n            }\n            \n            const endTime = performance.now();\n            return {\n                results: results,\n                time: endTime - startTime\n            };\n        }\n        \n        // Optimized query - uses indexes and early filtering\n        function optimizedQuery(searchTerm, categoryFilter) {\n            const startTime = performance.now();\n            let results = [];\n            \n            if (categoryFilter && productIndex[categoryFilter]) {\n                // Use the index for this category\n                const categoryProducts = productIndex[categoryFilter];\n                for (const product of categoryProducts) {\n                    if (!searchTerm || product.name.includes(searchTerm)) {\n                        results.push({\n                            id: product.id,\n                            name: product.name,\n                            price: product.price\n                        });\n                    }\n                }\n            } else {\n                // Fallback to filtered scan (but still better than full scan)\n                for (const product of products) {\n                    if ((!searchTerm || product.name.includes(searchTerm)) &&\n                        (!categoryFilter)) {\n                        results.push({\n                            id: product.id,\n                            name: product.name,\n                            price: product.price\n                        });\n                    }\n                }\n            }\n            \n            const endTime = performance.now();\n            return {\n                results: results,\n                time: endTime - startTime\n            };\n        }\n        \n        // Run the unoptimized query and display results\n        function runUnoptimizedQuery() {\n            const searchTerm = document.getElementById('unopt-search').value;\n            const categoryFilter = ''; // Could add UI for this\n            \n            const result = unoptimizedQuery(searchTerm, categoryFilter);\n            \n            document.getElementById('unopt-time').textContent = result.time.toFixed(2) + ' ms';\n            document.getElementById('unopt-results-count').textContent = result.results.length;\n            document.getElementById('unopt-results').textContent = \n                JSON.stringify(result.results.slice(0, 10), null, 2) + \n                (result.results.length > 10 ? '\\n... (showing first 10 of ' + result.results.length + ')' : '');\n        }\n        \n        // Run the optimized query and display results\n        function runOptimizedQuery() {\n            const searchTerm = document.getElementById('opt-search').value;\n            const categoryFilter = ''; // Could add UI for this\n            \n            const result = optimizedQuery(searchTerm, categoryFilter);\n            \n            document.getElementById('opt-time').textContent = result.time.toFixed(2) + ' ms';\n            document.getElementById('opt-results-count').textContent = result.results.length;\n            document.getElementById('opt-results').textContent = \n                JSON.stringify(result.results.slice(0, 10), null, 2) + \n                (result.results.length > 10 ? '\\n... (showing first 10 of ' + result.results.length + ')' : '');\n        }\n        \n        // Initialize the demo\n        generateSampleData();\n        console.log(\"Sample data generated with\", products.length, \"products\");\n    </script>\n</body>\n</html>"
