    "content": "<html>\n<head>\n    <title>Mutex Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>Mutex Example</h1>\n    <p>Mutex is a lock that allows only one thread to access a shared resource at a time.</p>\n    <button id=\"mutex\">Start Mutex</button>\n    <div id=\"mutex-lock\"></div>\n\n    <script>\n        let mutexLock = null;\n\n        document.getElementById('mutex').addEventListener('click', () => {\n            if (mutexLock) {\n                mutexLock = null;\n                document.getElementById('mutex-lock').innerHTML = 'Mutex unlocked';\n            } else {\n                mutexLock = new Mutex();\n                mutexLock.run(() => {\n                    document.getElementById('mutex-lock').innerHTML = 'Mutex locked';\n                });\n            }\n        });\n    </script>\n    <script>\n        class Mutex {\n            constructor() {\n                this.lock = false;\n            }\n\n            async run(callback) {\n                while (this.lock) {\n                    await new Promise(resolve => setTimeout(resolve, 10));\n                }\n                try {\n                    await callback();\n                } finally {\n                    this.lock = false;\n                }\n            }\n        }\n    </script>\n</body>\n</html>"
