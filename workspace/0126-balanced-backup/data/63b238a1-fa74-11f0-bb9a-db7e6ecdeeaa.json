    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Big-O Notation Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    max-width: 900px;\n  }\n  h1, h2 {\n    color: #004aad;\n  }\n  .code-block {\n    background: #f4f4f4;\n    border: 1px solid #ddd;\n    padding: 15px;\n    overflow-x: auto;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n  button {\n    padding: 10px 18px;\n    font-size: 16px;\n    cursor: pointer;\n    margin-top: 10px;\n  }\n  table {\n    border-collapse: collapse;\n    width: 100%;\n    margin-top:15px;\n  }\n  th, td {\n    border: 1px solid #ddd;\n    text-align: right;\n    padding: 8px;\n    font-family: monospace;\n  }\n  th {\n    background-color: #004aad;\n    color: white;\n  }\n  .plot-container {\n    margin-top: 40px;\n  }\n  canvas {\n    background-color: #fafafa;\n    border: 1px solid #ddd;\n  }\n  small {\n    color: #666;\n  }\n</style>\n</head>\n<body>\n<h1>Understanding Big-O Notation</h1>\n<p>\n  Big-O notation describes the upper bound of an algorithm's running time or space requirements in terms of the input size <code>n</code>.\n  It helps compare how well algorithms perform as inputs become large.\n</p>\n<h2>Common Big-O Complexities</h2>\n<ul>\n  <li><code>O(1)</code> — Constant time: runtime does not depend on input size.</li>\n  <li><code>O(log n)</code> — Logarithmic time: grows slowly as <code>n</code> increases.</li>\n  <li><code>O(n)</code> — Linear time: runtime increases proportionally with <code>n</code>.</li>\n  <li><code>O(n log n)</code> — Linearithmic time: typical of efficient sorting algorithms.</li>\n  <li><code>O(n²)</code> — Quadratic time: runtime grows proportionally to square of <code>n</code>.</li>\n</ul>\n\n<h2>Interactive Demo: Measuring Execution Time</h2>\n<p>Press the \"Run Tests\" button to execute algorithms of different complexities with varying input sizes and observe how their execution times grow.</p>\n\n<button id=\"runButton\">Run Tests</button>\n\n<div id=\"results\"></div>\n\n<div class=\"plot-container\">\n  <h2>Big-O Time Complexity Plot</h2>\n  <canvas id=\"plot\" width=\"800\" height=\"400\"></canvas>\n  <small>Y axis: time (ms), X axis: input size (n)</small>\n</div>\n\n<script>\n// Algorithms demonstrating different complexities\n\n// O(1) - Constant time\nfunction constantTime(n) {\n  return 42; // Always returns immediately\n}\n\n// O(log n) - Logarithmic time (binary search style)\nfunction logarithmicTime(n) {\n  let count = 0;\n  let i = n;\n  while (i > 1) {\n    i = Math.floor(i / 2);\n    count++;\n  }\n  return count;\n}\n\n// O(n) - Linear time\nfunction linearTime(n) {\n  let sum = 0;\n  for (let i = 0; i < n; i++) {\n    sum += i;\n  }\n  return sum;\n}\n\n// O(n log n) - Linearithmic time (merge sort)\nfunction mergeSort(arr) {\n  if (arr.length <= 1) return arr;\n  let mid = Math.floor(arr.length / 2);\n  let left = mergeSort(arr.slice(0, mid));\n  let right = mergeSort(arr.slice(mid));\n  return merge(left, right);\n}\nfunction merge(left, right) {\n  let result = [], li = 0, ri = 0;\n  while (li < left.length && ri < right.length) {\n    if (left[li] < right[ri]) {\n      result.push(left[li++]);\n    } else {\n      result.push(right[ri++]);\n    }\n  }\n  return result.concat(left.slice(li)).concat(right.slice(ri));\n}\nfunction linearithmicTime(n) {\n  let arr = [];\n  for (let i = 0; i < n; i++) {\n    arr.push(Math.floor(Math.random()*n));\n  }\n  return mergeSort(arr);\n}\n\n// O(n²) - Quadratic time\nfunction quadraticTime(n) {\n  let count = 0;\n  for (let i = 0; i < n; i++) {\n    for (let j = 0; j < n; j++) {\n      count++;\n    }\n  }\n  return count;\n}\n\n// Helper: measure function execution time in ms\nfunction measureTime(func, n) {\n  let start = performance.now();\n  func(n);\n  let end = performance.now();\n  return end - start;\n}\n\n// Data for testing\nconst inputSizes = [10, 100, 500, 1000, 2000, 3000];\n// For large times, prevent quadratic from running too long\nconst reduceSizesForQuadratic = [10, 50, 100, 200, 300];\n\n// Store results\nconst results = {\n  'O(1)': [],\n  'O(log n)': [],\n  'O(n)': [],\n  'O(n log n)': [],\n  'O(n²)': []\n};\n\nconst resultsDiv = document.getElementById('results');\nconst runButton = document.getElementById('runButton');\n\nfunction clearResults() {\n  resultsDiv.innerHTML = '';\n}\n\n// Creates a results table\nfunction createTable() {\n  let html = '<table><thead><tr><th>Input size (n)</th>';\n  Object.keys(results).forEach(key => {\n    html += `<th>${key}</th>`;\n  });\n  html += '</tr></thead><tbody>';\n  for(let i=0; i<inputSizes.length; i++) {\n    html += `<tr><td style=\"text-align:center\">${inputSizes[i]}</td>`;\n    Object.keys(results).forEach(key => {\n      let time = results[key][i];\n      html += `<td>${time !== undefined ? time.toFixed(3) : '-'}</td>`;\n    });\n    html += '</tr>';\n  }\n  html += '</tbody></table>';\n  resultsDiv.innerHTML = html;\n}\n\n// Plotting using 2D Canvas\nfunction plotResults() {\n  const canvas = document.getElementById('plot');\n  const ctx = canvas.getContext('2d');\n  ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n  // Setup margins\n  const margin = {top: 30, right: 80, bottom: 40, left: 70};\n  const w = canvas.width - margin.left - margin.right;\n  const h = canvas.height - margin.top - margin.bottom;\n\n  // Draw axes\n  ctx.strokeStyle = '#000';\n  ctx.fillStyle = '#000';\n  ctx.lineWidth = 1;\n\n  ctx.beginPath();\n  // Y axis\n  ctx.moveTo(margin.left, margin.top);\n  ctx.lineTo(margin.left, margin.top + h);\n  // X axis\n  ctx.lineTo(margin.left + w, margin.top + h);\n  ctx.stroke();\n\n  // Labels\n  ctx.font = \"14px Arial\";\n  ctx.fillText(\"Time (ms)\", 10, margin.top + h/2);\n  ctx.fillText(\"Input size (n)\", margin.left + w/2 - 30, margin.top + h + 30);\n\n  // Find max time to scale y axis\n  let maxTime = 0;\n  for(let key in results) {\n    results[key].forEach(t => {if(t>maxTime) maxTime = t;});\n  }\n  if(maxTime === 0) maxTime = 1;\n\n  // Y axis ticks and grid lines\n  ctx.strokeStyle = '#ddd';\n  ctx.fillStyle = '#000';\n  ctx.textAlign = \"right\";\n  let numYTicks = 5;\n  for(let i=0; i<=numYTicks; i++) {\n    let yVal = maxTime*i/numYTicks;\n    let y = margin.top + h - (h*i/numYTicks);\n    ctx.beginPath();\n    ctx.moveTo(margin.left - 5, y);\n    ctx.lineTo(margin.left + w, y);\n    ctx.stroke();\n    ctx.fillText(yVal.toFixed(1), margin.left - 10, y+5);\n  }\n\n  // X axis ticks and grid lines\n  ctx.textAlign = \"center\";\n  ctx.strokeStyle = '#ddd';\n  ctx.fillStyle = '#000';\n  inputSizes.forEach((n,i) => {\n    let x = margin.left + (w * i/(inputSizes.length - 1));\n    ctx.beginPath();\n    ctx.moveTo(x, margin.top + h);\n    ctx.lineTo(x, margin.top + h + 5);\n    ctx.stroke();\n    ctx.fillText(n, x, margin.top + h + 20);\n    // vertical grid\n    ctx.beginPath();\n    ctx.moveTo(x, margin.top);\n    ctx.lineTo(x, margin.top + h);\n    ctx.strokeStyle = '#eee';\n    ctx.stroke();\n    ctx.strokeStyle = '#000';\n  });\n\n  // Colors for lines\n  const colors = {\n    \"O(1)\": \"#e41a1c\",\n    \"O(log n)\": \"#377eb8\",\n    \"O(n)\": \"#4daf4a\",\n    \"O(n log n)\": \"#984ea3\",\n    \"O(n²)\": \"#ff7f00\"\n  };\n\n  // Plot each complexity\n  ctx.lineWidth = 2;\n  for(let key in results) {\n    ctx.strokeStyle = colors[key];\n    ctx.beginPath();\n    results[key].forEach((t,i) => {\n      if(t === undefined) return;\n      let x = margin.left + (w * i/(inputSizes.length - 1));\n      let y = margin.top + h - (t / maxTime * h);\n      if(i===0) ctx.moveTo(x,y);\n      else ctx.lineTo(x,y);\n    });\n    ctx.stroke();\n\n    // Draw legend colored square\n    let legendX = margin.left + w + 20;\n    let legendY = margin.top + 20 + Object.keys(results).indexOf(key)*25;\n    ctx.fillStyle = colors[key];\n    ctx.fillRect(legendX, legendY -12, 16, 16);\n    ctx.fillStyle = '#000';\n    ctx.textAlign = \"left\";\n    ctx.fillText(key, legendX + 22, legendY);\n  }\n}\n\nfunction runTests() {\n  clearResults();\n\n  // Clear previous results\n  for(let key in results) {\n    results[key] = [];\n  }\n\n  // Because O(n²) can be slow for large n, test it on smaller subset\n  const maxSizeForQuadratic = Math.max(...reduceSizesForQuadratic);\n\n  // Run tests with some delay to keep UI responsive\n  async function runAll() {\n    resultsDiv.innerHTML = '<p><em>Running tests... please wait.</em></p>';\n\n    for(let i=0; i<inputSizes.length; i++) {\n      let n = inputSizes[i];\n\n      // O(1)\n      results['O(1)'][i] = measureTime(constantTime, n);\n\n      // O(log n)\n      results['O(log n)'][i] = measureTime(logarithmicTime, n);\n\n      // O(n)\n      results['O(n)'][i] = measureTime(linearTime, n);\n\n      // O(n log n)\n      results['O(n log n)'][i] = measureTime(linearithmicTime, n);\n\n      // O(n²) - test only if n is in reduced set else undefined\n      if (reduceSizesForQuadratic.includes(n)) {\n        let idx = reduceSizesForQuadratic.indexOf(n);\n        results['O(n²)'][i] = measureTime(quadraticTime, n);\n      } else {\n        results['O(n²)'][i] = undefined;\n      }\n\n      // Yield control for UI update\n      await new Promise(r => setTimeout(r, 50));\n    }\n\n    createTable();\n    plotResults();\n  }\n  runAll();\n}\n\nrunButton.onclick = runTests;\n</script>\n</body>\n</html>"
  },
