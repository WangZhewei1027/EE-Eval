    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Search Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 40px;\n    background: #f9f9f9;\n  }\n  h1 {\n    text-align: center;\n  }\n  .container {\n    max-width: 600px;\n    margin: auto;\n  }\n  label, input, button {\n    font-size: 1rem;\n  }\n  input[type=\"number\"] {\n    width: 80px;\n    padding: 6px;\n    margin-right: 10px;\n  }\n  .array-container {\n    display: flex;\n    justify-content: center;\n    flex-wrap: wrap;\n    margin: 20px 0;\n    gap: 6px;\n  }\n  .element {\n    width: 40px;\n    height: 40px;\n    background: #ddd;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    border-radius: 4px;\n    user-select: none;\n    font-weight: bold;\n    transition: background-color 0.3s, transform 0.3s;\n  }\n  .element.low {\n    background: #a0c4ff;\n  }\n  .element.high {\n    background: #ffadad;\n  }\n  .element.mid {\n    background: #ffd6a5;\n    transform: scale(1.2);\n    font-weight: 900;\n  }\n  .element.found {\n    background: #9bf6ff;\n    font-weight: 900;\n    color: #005f73;\n  }\n  .status {\n    font-size: 1.1rem;\n    margin-top: 20px;\n    min-height: 1.5em;\n    text-align: center;\n  }\n  button {\n    cursor: pointer;\n    background: #0077b6;\n    color: white;\n    border: none;\n    padding: 8px 14px;\n    border-radius: 4px;\n  }\n  button:disabled {\n    background: #ccc;\n    cursor: not-allowed;\n  }\n  small {\n    display: block;\n    margin-top: 10px;\n    color: #555;\n    font-style: italic;\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Binary Search Visualization</h1>\n    <p>Array is sorted. Enter a number to search:</p>\n    <input type=\"number\" id=\"searchValue\" placeholder=\"Value\" />\n    <button id=\"startBtn\">Start Search</button>\n    <button id=\"resetBtn\" disabled>Reset</button>\n    <div class=\"array-container\" id=\"arrayContainer\"></div>\n    <div class=\"status\" id=\"status\"></div>\n    <small>Elements in blue: low index, red: high index, orange: middle, cyan: found</small>\n  </div>\n\n<script>\n(() => {\n  // Sorted array to search in\n  const array = [3, 7, 12, 19, 23, 27, 31, 38, 44, 49, 53, 59, 63, 67, 72, 78, 85, 90, 95, 99];\n\n  const arrayContainer = document.getElementById('arrayContainer');\n  const searchInput = document.getElementById('searchValue');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const statusDiv = document.getElementById('status');\n\n  let low = 0;\n  let high = array.length - 1;\n  let mid = null;\n  let searching = false;\n  let timer = null;\n\n  function renderArray(highlight = {}) {\n    // highlight: {low, mid, high, found}\n    arrayContainer.innerHTML = '';\n    for (let i = 0; i < array.length; i++) {\n      const div = document.createElement('div');\n      div.textContent = array[i];\n\n      if (i === highlight.found) {\n        div.classList.add('element', 'found');\n      } else if (i === highlight.mid) {\n        div.classList.add('element', 'mid');\n      } else if (i === highlight.low) {\n        div.classList.add('element', 'low');\n      } else if (i === highlight.high) {\n        div.classList.add('element', 'high');\n      } else {\n        div.classList.add('element');\n      }\n      arrayContainer.appendChild(div);\n    }\n  }\n\n  function binarySearchStep(target) {\n    if (low > high) {\n      // Not found\n      statusDiv.textContent = `Value ${target} not found in the array.`;\n      renderArray({});\n      searching = false;\n      startBtn.disabled = false;\n      resetBtn.disabled = false;\n      return;\n    }\n\n    mid = Math.floor((low + high) / 2);\n\n    renderArray({low, mid, high});\n\n    statusDiv.textContent = `Low index: ${low} (value: ${array[low]}), High index: ${high} (value: ${array[high]}), Mid index: ${mid} (value: ${array[mid]})`;\n\n    if (array[mid] === target) {\n      // Found target\n      renderArray({found: mid});\n      statusDiv.textContent = `Found value ${target} at index ${mid}!`;\n      searching = false;\n      startBtn.disabled = false;\n      resetBtn.disabled = false;\n      return;\n    } else if (array[mid] < target) {\n      low = mid + 1;\n    } else {\n      high = mid - 1;\n    }\n\n    // Continue steps after short delay\n    timer = setTimeout(() => binarySearchStep(target), 1000);\n  }\n\n  function startSearch() {\n    const val = parseInt(searchInput.value, 10);\n    if (isNaN(val)) {\n      alert('Please enter a valid number.');\n      return;\n    }\n    low = 0;\n    high = array.length - 1;\n    mid = null;\n    searching = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n    statusDiv.textContent = 'Starting binary search...';\n    binarySearchStep(val);\n  }\n\n  function reset() {\n    if (timer) {\n      clearTimeout(timer);\n      timer = null;\n    }\n    searching = false;\n    low = 0;\n    high = array.length - 1;\n    mid = null;\n    renderArray({});\n    statusDiv.textContent = '';\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Initial render\n  renderArray({});\n\n  startBtn.addEventListener('click', () => {\n    if (!searching) {\n      startSearch();\n    }\n  });\n\n  resetBtn.addEventListener('click', () => {\n    reset();\n  });\n\n})();\n</script>\n\n</body>\n</html>"
