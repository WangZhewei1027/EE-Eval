    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Doubly Linked List Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2rem;\n      background: #f9f9f9;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n    }\n    .container {\n      max-width: 700px;\n      margin: 0 auto;\n      background: white;\n      padding: 1.5rem;\n      border-radius: 8px;\n      box-shadow: 0 0 12px rgb(0 0 0 / 0.1);\n    }\n    .controls {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 0.5rem;\n      margin-bottom: 1rem;\n      justify-content: center;\n    }\n    input[type=\"number\"],\n    input[type=\"text\"] {\n      padding: 0.5rem;\n      font-size: 1rem;\n      width: 100px;\n      border: 1px solid #ccc;\n      border-radius: 4px;\n    }\n    button {\n      cursor: pointer;\n      padding: 0.5rem 1.2rem;\n      border: none;\n      background: #007bff;\n      color: white;\n      font-weight: bold;\n      border-radius: 4px;\n      transition: background 0.3s ease;\n    }\n    button:hover {\n      background: #0056b3;\n    }\n    .list-container {\n      margin-top: 1.5rem;\n      text-align: center;\n      min-height: 80px;\n      user-select: none;\n    }\n    .node {\n      display: inline-flex;\n      align-items: center;\n      border: 2px solid #007bff;\n      padding: 0.6rem 1rem;\n      margin: 0 0.2rem;\n      border-radius: 6px;\n      background: #e7f0ff;\n      position: relative;\n      font-weight: 600;\n      font-size: 1.1rem;\n      box-shadow: 0 2px 5px rgb(0 123 255 / 0.2);\n      min-width: 40px;\n      justify-content: center;\n    }\n    .node .arrows {\n      font-size: 1.3rem;\n      user-select: none;\n      margin: 0 0.2rem;\n      color: #666;\n    }\n    .node.current {\n      border-color: #28a745;\n      background: #d4edda;\n      box-shadow: 0 2px 10px rgb(40 167 69 / 0.6);\n      color: #155724;\n    }\n    .info {\n      margin-top: 1rem;\n      background: #eef6ff;\n      border: 1px solid #c3ddff;\n      padding: 0.8rem 1rem;\n      border-radius: 5px;\n      font-family: monospace;\n      font-size: 0.95rem;\n      max-height: 120px;\n      overflow-y: auto;\n      white-space: pre-wrap;\n      user-select: text;\n    }\n    label {\n      font-weight: 600;\n      margin-right: 0.25rem;\n    }\n    .note {\n      font-size: 0.9rem;\n      color: #555;\n      margin-top: 0.5rem;\n      text-align: center;\n      font-style: italic;\n    }\n  </style>\n</head>\n<body>\n  <h1>Doubly Linked List Demo</h1>\n  <div class=\"container\">\n    <div class=\"controls\">\n      <input type=\"text\" id=\"inputValue\" placeholder=\"Value (any)\" />\n      <button id=\"addHeadBtn\" title=\"Add node at head\">Add Head</button>\n      <button id=\"addTailBtn\" title=\"Add node at tail\">Add Tail</button>\n      <button id=\"removeHeadBtn\" title=\"Remove head node\">Remove Head</button>\n      <button id=\"removeTailBtn\" title=\"Remove tail node\">Remove Tail</button>\n      <input type=\"number\" id=\"searchValue\" placeholder=\"Search value\" />\n      <button id=\"searchBtn\" title=\"Search node by value\">Search</button>\n      <button id=\"clearSearchBtn\" title=\"Clear search highlight\">Clear Search</button>\n      <button id=\"clearListBtn\" title=\"Clear entire list\">Clear List</button>\n    </div>\n    <div class=\"list-container\" id=\"listContainer\" aria-live=\"polite\" aria-atomic=\"true\" aria-label=\"Doubly linked list visualization\">\n      <!-- Nodes will render here -->\n    </div>\n    <div class=\"info\" id=\"infoBox\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n    <div class=\"note\">\n      <strong>Note:</strong> Each node shows its <code>value</code>. Arrows (⇄) show the bidirectional links.\n    </div>\n  </div>\n\n  <script>\n    // Doubly Linked List Implementation in JS\n    class Node {\n      constructor(value) {\n        this.value = value;\n        this.next = null;\n        this.prev = null;\n      }\n    }\n\n    class DoublyLinkedList {\n      constructor() {\n        this.head = null;\n        this.tail = null;\n        this.length = 0;\n      }\n\n      addHead(value) {\n        const newNode = new Node(value);\n        if (!this.head) {\n          this.head = this.tail = newNode;\n        } else {\n          newNode.next = this.head;\n          this.head.prev = newNode;\n          this.head = newNode;\n        }\n        this.length++;\n      }\n\n      addTail(value) {\n        const newNode = new Node(value);\n        if (!this.tail) {\n          this.head = this.tail = newNode;\n        } else {\n          newNode.prev = this.tail;\n          this.tail.next = newNode;\n          this.tail = newNode;\n        }\n        this.length++;\n      }\n\n      removeHead() {\n        if (!this.head) return null;\n        const removed = this.head;\n        if (this.head === this.tail) {\n          this.head = this.tail = null;\n        } else {\n          this.head = this.head.next;\n          this.head.prev = null;\n        }\n        this.length--;\n        return removed.value;\n      }\n\n      removeTail() {\n        if (!this.tail) return null;\n        const removed = this.tail;\n        if (this.head === this.tail) {\n          this.head = this.tail = null;\n        } else {\n          this.tail = this.tail.prev;\n          this.tail.next = null;\n        }\n        this.length--;\n        return removed.value;\n      }\n\n      // Search node by value, return the first matching node\n      search(value) {\n        let current = this.head;\n        while (current) {\n          if (current.value == value) {\n            return current;\n          }\n          current = current.next;\n        }\n        return null;\n      }\n\n      toArray() {\n        // Returns an array of nodes for visualization\n        let arr = [];\n        let current = this.head;\n        while (current) {\n          arr.push(current);\n          current = current.next;\n        }\n        return arr;\n      }\n\n      clear() {\n        this.head = null;\n        this.tail = null;\n        this.length = 0;\n      }\n    }\n\n    // Visualization and interaction\n    (function () {\n      const list = new DoublyLinkedList();\n\n      const listContainer = document.getElementById('listContainer');\n      const infoBox = document.getElementById('infoBox');\n      const inputValue = document.getElementById('inputValue');\n      const searchValue = document.getElementById('searchValue');\n\n      const addHeadBtn = document.getElementById('addHeadBtn');\n      const addTailBtn = document.getElementById('addTailBtn');\n      const removeHeadBtn = document.getElementById('removeHeadBtn');\n      const removeTailBtn = document.getElementById('removeTailBtn');\n      const searchBtn = document.getElementById('searchBtn');\n      const clearSearchBtn = document.getElementById('clearSearchBtn');\n      const clearListBtn = document.getElementById('clearListBtn');\n\n      let highlightedNode = null;\n\n      function renderList() {\n        listContainer.innerHTML = '';\n        let nodes = list.toArray();\n        nodes.forEach((node, i) => {\n          const nodeEl = document.createElement('span');\n          nodeEl.classList.add('node');\n          nodeEl.textContent = node.value;\n\n          if (node === highlightedNode) {\n            nodeEl.classList.add('current');\n          }\n\n          listContainer.appendChild(nodeEl);\n          // Add arrows between nodes except after the last one\n          if (i !== nodes.length - 1) {\n            const arrow = document.createElement('span');\n            arrow.classList.add('arrows');\n            arrow.setAttribute('aria-hidden', 'true');\n            arrow.textContent = '⇄';\n            listContainer.appendChild(arrow);\n          }\n        });\n\n        if (list.length === 0) {\n          listContainer.innerHTML = '<em>The list is empty.</em>';\n        }\n      }\n\n      function updateInfo(text) {\n        infoBox.textContent = text;\n      }\n\n      function safeTrim(str){\n        // trim and convert empty strings to null\n        return str.trim() || null;\n      }\n\n      addHeadBtn.addEventListener('click', () => {\n        const val = safeTrim(inputValue.value);\n        if (val === null) {\n          alert('Please enter a value to add.');\n          return;\n        }\n        list.addHead(val);\n        inputValue.value = '';\n        highlightedNode = null;\n        renderList();\n        updateInfo(`Added \"${val}\" at head. List length: ${list.length}`);\n        inputValue.focus();\n      });\n\n      addTailBtn.addEventListener('click', () => {\n        const val = safeTrim(inputValue.value);\n        if (val === null) {\n          alert('Please enter a value to add.');\n          return;\n        }\n        list.addTail(val);\n        inputValue.value = '';\n        highlightedNode = null;\n        renderList();\n        updateInfo(`Added \"${val}\" at tail. List length: ${list.length}`);\n        inputValue.focus();\n      });\n\n      removeHeadBtn.addEventListener('click', () => {\n        if (list.length === 0) {\n          updateInfo('List is empty. Nothing to remove.');\n          return;\n        }\n        const removed = list.removeHead();\n        highlightedNode = null;\n        renderList();\n        updateInfo(`Removed head node with value \"${removed}\". List length: ${list.length}`);\n      });\n\n      removeTailBtn.addEventListener('click', () => {\n        if (list.length === 0) {\n          updateInfo('List is empty. Nothing to remove.');\n          return;\n        }\n        const removed = list.removeTail();\n        highlightedNode = null;\n        renderList();\n        updateInfo(`Removed tail node with value \"${removed}\". List length: ${list.length}`);\n      });\n\n      searchBtn.addEventListener('click', () => {\n        const val = safeTrim(searchValue.value);\n        if (val === null) {\n          alert('Please enter a value to search.');\n          return;\n        }\n        if (list.length === 0) {\n          updateInfo('List is empty. Nothing to search.');\n          highlightedNode = null;\n          renderList();\n          return;\n        }\n        const found = list.search(val);\n        if (found) {\n          highlightedNode = found;\n          renderList();\n          updateInfo(`Value \"${val}\" found in the list.`);\n        } else {\n          highlightedNode = null;\n          renderList();\n          updateInfo(`Value \"${val}\" not found in the list.`);\n        }\n      });\n\n      clearSearchBtn.addEventListener('click', () => {\n        highlightedNode = null;\n        renderList();\n        updateInfo('Search highlight cleared.');\n        searchValue.value = '';\n      });\n\n      clearListBtn.addEventListener('click', () => {\n        if (confirm('Are you sure you want to clear the entire list?')) {\n          list.clear();\n          highlightedNode = null;\n          renderList();\n          updateInfo('List cleared.');\n        }\n      });\n\n      // Initial render\n      renderList();\n      updateInfo('Doubly Linked List is empty. Add some nodes!');\n\n    })();\n  </script>\n</body>\n</html>"
  },
