    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linear Search Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            padding: 20px;\n        }\n        #result {\n            margin-top: 20px;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <h1>Linear Search Example</h1>\n    <p>Enter an array of numbers (comma-separated) and a number to search for:</p>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 1,2,3,4,5\">\n    <input type=\"text\" id=\"searchInput\" placeholder=\"Number to search\">\n    <button onclick=\"performLinearSearch()\">Search</button>\n    \n    <div id=\"result\"></div>\n\n    <script>\n        function performLinearSearch() {\n            const arrayInput = document.getElementById('arrayInput').value;\n            const searchInput = document.getElementById('searchInput').value;\n\n            // Convert the input string into an array of numbers\n            const array = arrayInput.split(',').map(num => parseInt(num.trim()));\n            const target = parseInt(searchInput.trim());\n\n            let foundIndex = -1;\n\n            // Linear Search implementation\n            for (let i = 0; i < array.length; i++) {\n                if (array[i] === target) {\n                    foundIndex = i;\n                    break;\n                }\n            }\n\n            // Display the result\n            const resultDiv = document.getElementById('result');\n            if (foundIndex !== -1) {\n                resultDiv.innerHTML = `Number ${target} found at index ${foundIndex}.`;\n            } else {\n                resultDiv.innerHTML = `Number ${target} not found in the array.`;\n            }\n        }\n    </script>\n</body>\n</html>"
