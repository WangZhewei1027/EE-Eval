    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Garbage Collection Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f8ff;\n    color: #333;\n  }\n  h1 {\n    color: #0366d6;\n  }\n  #log {\n    background: #eef6fc;\n    border: 1px solid #b6d4fa;\n    border-radius: 5px;\n    padding: 1rem;\n    max-height: 300px;\n    overflow-y: auto;\n    font-family: monospace;\n    margin-top: 1rem;\n  }\n  button {\n    background: #28a745;\n    border: none;\n    color: white;\n    padding: 0.6rem 1.2rem;\n    margin-top: 1rem;\n    font-size: 1rem;\n    cursor: pointer;\n    border-radius: 5px;\n  }\n  button:active {\n    background: #218838;\n  }\n  .warning {\n    color: #d6336c;\n  }\n</style>\n</head>\n<body>\n<h1>JavaScript Garbage Collection Demonstration</h1>\n\n<p>\n  This demo explains how JavaScript's garbage collector works by managing objects' lifetimes.\n  When objects are no longer referenced, the garbage collector frees that memory automatically.\n</p>\n\n<button id=\"createObjectsBtn\">Create Objects</button>\n<button id=\"dropReferencesBtn\" disabled>Drop References</button>\n<button id=\"forceGCBtn\" disabled title=\"Force GC only works in some browsers with flags enabled\">Request Garbage Collection (if available)</button>\n\n<div id=\"log\"></div>\n\n<script>\n(() => {\n  const logEl = document.getElementById('log');\n  const createBtn = document.getElementById('createObjectsBtn');\n  const dropBtn = document.getElementById('dropReferencesBtn');\n  const forceGCBtn = document.getElementById('forceGCBtn');\n\n  // Store objects in closures to simulate references\n  let objectsArray = null;\n\n  // Helper to log messages with timestamp\n  function log(msg, special = false) {\n    const time = new Date().toLocaleTimeString();\n    const p = document.createElement('p');\n    if (special) p.classList.add('warning');\n    p.textContent = `[${time}] ${msg}`;\n    logEl.appendChild(p);\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  // Class to monitor instances through FinalizationRegistry\n  class DemoObject {\n    constructor(id) {\n      this.id = id;\n    }\n  }\n\n  // Set up FinalizationRegistry to be notified when objects are GC'd\n  const registry = new FinalizationRegistry((id) => {\n    log(`🔄 Garbage Collector reclaimed DemoObject with id: ${id}`, true);\n  });\n\n  // Used to create objects and hold references\n  function createObjects() {\n    if(objectsArray !== null) {\n      log(\"Objects already created. Drop references first.\");\n      return;\n    }\n    objectsArray = [];\n\n    log(\"Creating 1000 DemoObject instances and registering them for finalization...\");\n\n    for(let i=0; i<1000; i++) {\n      const obj = new DemoObject(i);\n      // Register obj for finalization with its id as token\n      registry.register(obj, i);\n      objectsArray.push(obj);\n    }\n\n    log(\"1000 objects created and referenced in an array.\");\n    dropBtn.disabled = false;\n    forceGCBtn.disabled = false;\n    createBtn.disabled = true;\n  }\n\n  // Drop all references to allow GC to collect those objects\n  function dropReferences() {\n    if(objectsArray === null) {\n      log(\"No objects to drop references from.\");\n      return;\n    }\n    objectsArray = null; \n    log(\"Dropped references to all objects. Now they are eligible for garbage collection.\");\n    dropBtn.disabled = true;\n  }\n\n  // Try to force garbage collection (only works in some browsers with flags)\n  function forceGC() {\n    if (window.gc) {\n      log(\"Requesting garbage collection...\");\n      window.gc();\n      log(\"Garbage collection requested.\");\n    } else {\n      log(\"Garbage collection cannot be forced in this browser. It runs automatically.\", true);\n    }\n  }\n\n  // Add event listeners\n  createBtn.addEventListener('click', createObjects);\n  dropBtn.addEventListener('click', dropReferences);\n  forceGCBtn.addEventListener('click', forceGC);\n\n  // Initial log\n  log(\"Welcome! Click 'Create Objects' to start.\");\n})();\n</script>\n\n</body>\n</html>"
