    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Type System Demonstration</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; }\n        .container { margin-top: 20px; }\n        .output { margin-top: 10px; font-weight: bold; }\n    </style>\n</head>\n<body>\n    <h1>Type System Demonstration</h1>\n    <p>Select a type system:</p>\n    <select id=\"typeSelector\">\n        <option value=\"\">Choose a type</option>\n        <option value=\"string\">String</option>\n        <option value=\"number\">Number</option>\n        <option value=\"boolean\">Boolean</option>\n        <option value=\"object\">Object</option>\n        <option value=\"array\">Array</option>\n        <option value=\"function\">Function</option>\n    </select>\n    \n    <div class=\"container\">\n        <label for=\"inputValue\">Enter a value:</label>\n        <input type=\"text\" id=\"inputValue\" placeholder=\"Type something...\"/>\n        <button id=\"checkTypeButton\">Check Type</button>\n    </div>\n    \n    <div class=\"output\" id=\"output\"></div>\n\n    <script>\n        document.getElementById('checkTypeButton').addEventListener('click', function() {\n            const selectedType = document.getElementById('typeSelector').value;\n            const inputValue = document.getElementById('inputValue').value;\n            let isValid = false;\n\n            switch (selectedType) {\n                case 'string':\n                    isValid = typeof inputValue === 'string';\n                    break;\n                case 'number':\n                    isValid = !isNaN(inputValue) && inputValue.trim() !== '';\n                    break;\n                case 'boolean':\n                    isValid = (inputValue.toLowerCase() === 'true' || inputValue.toLowerCase() === 'false');\n                    break;\n                case 'object':\n                    try {\n                        isValid = typeof JSON.parse(inputValue) === 'object';\n                    } catch (e) {\n                        isValid = false;\n                    }\n                    break;\n                case 'array':\n                    try {\n                        isValid = Array.isArray(JSON.parse(inputValue));\n                    } catch (e) {\n                        isValid = false;\n                    }\n                    break;\n                case 'function':\n                    isValid = inputValue.includes('function');\n                    break;\n                default:\n                    alert('Please select a type to check.');\n                    return;\n            }\n\n            document.getElementById('output').innerText = isValid \n                ? `The value \"${inputValue}\" is a valid ${selectedType}.`\n                : `The value \"${inputValue}\" is NOT a valid ${selectedType}.`;\n        });\n    </script>\n</body>\n</html>"
