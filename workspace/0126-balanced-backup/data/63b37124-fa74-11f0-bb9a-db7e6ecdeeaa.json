    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Socket Programming Demo (WebSocket)</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      max-width: 600px;\n      margin: 2rem auto;\n      padding: 1rem;\n      background: #f0f0f0;\n    }\n    h1 {\n      text-align: center;\n      color: #222;\n    }\n    #status {\n      margin-bottom: 1rem;\n      padding: 0.5rem;\n      font-weight: bold;\n    }\n    #messages {\n      height: 300px;\n      border: 1px solid #ccc;\n      background: #fff;\n      overflow-y: auto;\n      padding: 0.5rem;\n      margin-bottom: 1rem;\n      white-space: pre-wrap;\n      font-family: monospace;\n    }\n    #inputSection {\n      display: flex;\n      gap: 0.5rem;\n    }\n    #messageInput {\n      flex-grow: 1;\n      padding: 0.5rem;\n      font-size: 1rem;\n    }\n    button {\n      padding: 0.5rem 1rem;\n      font-size: 1rem;\n      cursor: pointer;\n    }\n    #footer {\n      margin-top: 2rem;\n      font-size: 0.9rem;\n      color: #666;\n      text-align: center;\n    }\n    a {\n      color: #0066cc;\n      text-decoration: none;\n    }\n    a:hover {\n      text-decoration: underline;\n    }\n  </style>\n</head>\n<body>\n  <h1>Socket Programming Demo with WebSocket</h1>\n  <div id=\"status\">Connecting to WebSocket server...</div>\n  <div id=\"messages\"></div>\n  <div id=\"inputSection\">\n    <input type=\"text\" id=\"messageInput\" placeholder=\"Enter message here\" autocomplete=\"off\" />\n    <button id=\"sendBtn\" disabled>Send</button>\n  </div>\n\n  <div id=\"footer\">\n    Using public <a href=\"wss://echo.websocket.org\" target=\"_blank\" rel=\"noopener noreferrer\">Echo WebSocket Server</a> for demo.<br/>\n    This server echos back any message you send, demonstrating basic socket communication.\n  </div>\n\n  <script>\n    /*\n     * This demo uses the WebSocket API in the browser to demonstrate socket programming concepts.\n     * WebSocket is a protocol providing full-duplex communication channels over a single TCP connection.\n     * Here, the client connects to a public echo WebSocket server.\n     * When you type a message and send it, the server echoes it back.\n     */\n\n    (function() {\n      const statusEl = document.getElementById('status');\n      const messagesEl = document.getElementById('messages');\n      const inputEl = document.getElementById('messageInput');\n      const sendBtn = document.getElementById('sendBtn');\n\n      // Public echo websocket server\n      const wsUrl = 'wss://echo.websocket.org';\n\n      let socket;\n\n      // Helper to add message to messages area\n      function addMessage(prefix, message, isError = false) {\n        const time = new Date().toLocaleTimeString();\n        const line = `[${time}] ${prefix}: ${message}`;\n        const span = document.createElement('div');\n        span.textContent = line;\n        if (isError) {\n          span.style.color = 'red';\n        }\n        messagesEl.appendChild(span);\n        messagesEl.scrollTop = messagesEl.scrollHeight;\n      }\n\n      function setStatus(text, color = '#333') {\n        statusEl.textContent = text;\n        statusEl.style.color = color;\n      }\n\n      function connect() {\n        socket = new WebSocket(wsUrl);\n\n        setStatus('Connecting to WebSocket server...');\n        sendBtn.disabled = true;\n\n        socket.onopen = () => {\n          setStatus('Connected ✅', 'green');\n          addMessage('System', 'WebSocket connection established.');\n          sendBtn.disabled = false;\n          inputEl.focus();\n        };\n\n        socket.onmessage = (event) => {\n          addMessage('Server', event.data);\n        };\n\n        socket.onclose = (event) => {\n          setStatus(`Disconnected (code: ${event.code})`, 'orange');\n          addMessage('System', 'WebSocket connection closed.');\n          sendBtn.disabled = true;\n          // Try reconnecting after 3 seconds\n          setTimeout(() => {\n            addMessage('System', 'Reconnecting...');\n            connect();\n          }, 3000);\n        };\n\n        socket.onerror = (error) => {\n          setStatus('WebSocket error ❌', 'red');\n          addMessage('Error', 'WebSocket error occurred.', true);\n          sendBtn.disabled = true;\n        };\n      }\n\n      // Send message when button clicked or Enter pressed\n      function sendMessage() {\n        const msg = inputEl.value.trim();\n        if (!msg) return;\n        if (socket.readyState === WebSocket.OPEN) {\n          socket.send(msg);\n          addMessage('You', msg);\n          inputEl.value = '';\n          inputEl.focus();\n        } else {\n          addMessage('System', 'Cannot send: WebSocket is not open.', true);\n        }\n      }\n\n      sendBtn.addEventListener('click', sendMessage);\n      inputEl.addEventListener('keydown', (e) => {\n        if (e.key === 'Enter') {\n          sendMessage();\n          e.preventDefault();\n        }\n      });\n\n      connect();\n    })();\n  </script>\n</body>\n</html>"
  },
