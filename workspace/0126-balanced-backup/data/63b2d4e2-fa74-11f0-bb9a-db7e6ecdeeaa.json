    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Relational Database Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  .section {\n    margin: 1.5rem 0;\n    background: #fff;\n    padding: 1rem 1.5rem;\n    border-radius: 8px;\n    box-shadow: 0 0 8px rgb(0 0 0 / 0.05);\n  }\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 0.5rem;\n  }\n  th, td {\n    border: 1px solid #ccc;\n    padding: 0.4rem 0.8rem;\n    text-align: left;\n  }\n  th {\n    background: #eee;\n  }\n  pre {\n    background: #eef;\n    padding: 1rem;\n    border-radius: 6px;\n    overflow-x: auto;\n  }\n  .explanation {\n    font-size: 1rem;\n    margin-bottom: 1rem;\n  }\n  .relationships {\n    display: flex;\n    gap: 2rem;\n    flex-wrap: wrap;\n  }\n  .rel-box {\n    background: #e0f7fa;\n    padding: 0.8rem;\n    border-radius: 6px;\n    flex: 1 1 250px;\n  }\n  .rel-title {\n    font-weight: bold;\n    margin-bottom: 0.4rem;\n  }\n  .query-section {\n    margin-top: 1.5rem;\n  }\n  label {\n    font-weight: 600;\n  }\n  select, button {\n    margin-left: 0.5rem;\n    padding: 0.3rem 0.6rem;\n    font-size: 1rem;\n  }\n  #result {\n    margin-top: 1rem;\n    background: #fffdea;\n    padding: 1rem;\n    border-radius: 6px;\n    border: 1px solid #f1c40f;\n  }\n</style>\n</head>\n<body>\n  <h1>Relational Database Concept Demo</h1>\n\n  <div class=\"section\">\n    <div class=\"explanation\">\n      <strong>What is a Relational Database?</strong><br />\n      It stores data in tables (relations) consisting of rows and columns.\n      Each table represents an entity, and tables can be connected using keys to model relationships.\n    </div>\n    <div class=\"explanation\">\n      This demonstration shows a simple relational database with 3 tables: <code>Customers</code>, <code>Orders</code>, and <code>Products</code>.\n      We will see the data and query a result by joining tables.\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <h2>Tables</h2>\n\n    <h3>Customers</h3>\n    <table>\n      <thead>\n        <tr><th>CustomerID (PK)</th><th>Name</th><th>Email</th></tr>\n      </thead>\n      <tbody id=\"customers-table-body\"></tbody>\n    </table>\n\n    <h3>Products</h3>\n    <table>\n      <thead>\n        <tr><th>ProductID (PK)</th><th>Name</th><th>Price ($)</th></tr>\n      </thead>\n      <tbody id=\"products-table-body\"></tbody>\n    </table>\n\n    <h3>Orders</h3>\n    <table>\n      <thead>\n        <tr><th>OrderID (PK)</th><th>CustomerID (FK)</th><th>ProductID (FK)</th><th>Quantity</th></tr>\n      </thead>\n      <tbody id=\"orders-table-body\"></tbody>\n    </table>\n  </div>\n\n  <div class=\"section\">\n    <h2>Relationships</h2>\n    <div class=\"relationships\">\n      <div class=\"rel-box\">\n        <div class=\"rel-title\">Primary Key (PK)</div>\n        Uniquely identifies each row in a table.<br />\n        Examples: <code>CustomerID</code>, <code>ProductID</code>, <code>OrderID</code>\n      </div>\n      <div class=\"rel-box\">\n        <div class=\"rel-title\">Foreign Key (FK)</div>\n        Refers to a primary key in another table to establish a relationship.<br />\n        Examples: <code>Orders.CustomerID</code> → <code>Customers.CustomerID</code><br />\n        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; \n        <code>Orders.ProductID</code> → <code>Products.ProductID</code>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"section query-section\">\n    <h2>Query: List all Orders with Customer name and Product details</h2>\n\n    <label for=\"customer-select\">Filter by Customer:</label>\n    <select id=\"customer-select\">\n      <option value=\"all\">All Customers</option>\n    </select>\n    <button onclick=\"performQuery()\">Show Orders</button>\n\n    <div id=\"result\"></div>\n  </div>\n\n<script>\n  // Sample data for the relational database\n\n  const customers = [\n    { CustomerID: 1, Name: \"Alice Johnson\", Email: \"alice@example.com\" },\n    { CustomerID: 2, Name: \"Bob Smith\", Email: \"bob@example.com\" },\n    { CustomerID: 3, Name: \"Charlie Lee\", Email: \"charlie@example.com\" }\n  ];\n\n  const products = [\n    { ProductID: 101, Name: \"Laptop\", Price: 899 },\n    { ProductID: 102, Name: \"Smartphone\", Price: 499 },\n    { ProductID: 103, Name: \"Headphones\", Price: 199 }\n  ];\n\n  const orders = [\n    { OrderID: 1001, CustomerID: 1, ProductID: 101, Quantity: 1 },\n    { OrderID: 1002, CustomerID: 2, ProductID: 103, Quantity: 2 },\n    { OrderID: 1003, CustomerID: 3, ProductID: 102, Quantity: 1 },\n    { OrderID: 1004, CustomerID: 1, ProductID: 103, Quantity: 1 },\n    { OrderID: 1005, CustomerID: 2, ProductID: 101, Quantity: 3 }\n  ];\n\n  // Functions to populate tables on the page\n\n  function populateTable(tableBodyId, data, columns) {\n    const tbody = document.getElementById(tableBodyId);\n    tbody.innerHTML = \"\";\n    data.forEach(row => {\n      const tr = document.createElement(\"tr\");\n      columns.forEach(col => {\n        const td = document.createElement(\"td\");\n        td.textContent = row[col];\n        tr.appendChild(td);\n      });\n      tbody.appendChild(tr);\n    });\n  }\n\n  function populateCustomers() {\n    populateTable(\"customers-table-body\", customers, [\"CustomerID\", \"Name\", \"Email\"]);\n  }\n\n  function populateProducts() {\n    populateTable(\"products-table-body\", products, [\"ProductID\", \"Name\", \"Price\"]);\n  }\n\n  function populateOrders() {\n    populateTable(\"orders-table-body\", orders, [\"OrderID\", \"CustomerID\", \"ProductID\", \"Quantity\"]);\n  }\n\n  function populateCustomerFilter() {\n    const select = document.getElementById(\"customer-select\");\n    customers.forEach(c => {\n      const option = document.createElement(\"option\");\n      option.value = c.CustomerID;\n      option.textContent = c.Name;\n      select.appendChild(option);\n    });\n  }\n\n  // Perform a \"join\" like query in JavaScript to combine these tables:\n  // Showing each order with customer's name, product name, price, quantity, and total cost\n\n  function performQuery() {\n    const select = document.getElementById(\"customer-select\");\n    const filterCustomerID = select.value === \"all\" ? null : parseInt(select.value);\n\n    // Filter orders by customer if needed\n    const filteredOrders = filterCustomerID ? orders.filter(o => o.CustomerID === filterCustomerID) : orders;\n\n    // Join the tables: for each order find customer & product details\n    const results = filteredOrders.map(order => {\n      const customer = customers.find(c => c.CustomerID === order.CustomerID);\n      const product = products.find(p => p.ProductID === order.ProductID);\n      return {\n        OrderID: order.OrderID,\n        CustomerName: customer ? customer.Name : \"Unknown\",\n        ProductName: product ? product.Name : \"Unknown\",\n        UnitPrice: product ? product.Price : 0,\n        Quantity: order.Quantity,\n        Total: (product ? product.Price : 0) * order.Quantity\n      };\n    });\n\n    displayResults(results);\n  }\n\n  // Display the result as a table\n  function displayResults(data) {\n    const div = document.getElementById(\"result\");\n    if (data.length === 0) {\n      div.innerHTML = \"<em>No orders found.</em>\";\n      return;\n    }\n    // Create table header\n    let html = `\n      <table>\n        <thead>\n          <tr>\n            <th>OrderID</th><th>Customer Name</th><th>Product</th><th>Unit Price ($)</th><th>Quantity</th><th>Total ($)</th>\n          </tr>\n        </thead>\n        <tbody>\n    `;\n    data.forEach(row => {\n      html += `<tr>\n        <td>${row.OrderID}</td>\n        <td>${row.CustomerName}</td>\n        <td>${row.ProductName}</td>\n        <td>${row.UnitPrice.toFixed(2)}</td>\n        <td>${row.Quantity}</td>\n        <td>${row.Total.toFixed(2)}</td>\n      </tr>`;\n    });\n    html += \"</tbody></table>\";\n    div.innerHTML = html;\n  }\n\n  // Initialize on load\n  window.onload = () => {\n    populateCustomers();\n    populateProducts();\n    populateOrders();\n    populateCustomerFilter();\n    performQuery(); // Show all orders by default\n  };\n</script>\n</body>\n</html>"
  },
