    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bubble Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f4f4f4;\n            padding: 20px;\n        }\n        #array-container {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 20px;\n        }\n        .bar {\n            width: 30px;\n            margin: 0 2px;\n            background-color: teal;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Bubble Sort Visualization</h1>\n<p>Click the button to visualize the Bubble Sort algorithm.</p>\n<div id=\"array-container\"></div>\n<button id=\"sort-button\">Sort Array</button>\n\n<script>\n    const array = [5, 2, 9, 1, 5, 6, 3];\n    const arrayContainer = document.getElementById('array-container');\n    const sortButton = document.getElementById('sort-button');\n\n    function createBars(arr) {\n        arrayContainer.innerHTML = '';\n        arr.forEach(num => {\n            const bar = document.createElement('div');\n            bar.className = 'bar';\n            bar.style.height = `${num * 20}px`; // Scale for visualization\n            arrayContainer.appendChild(bar);\n        });\n    }\n\n    async function bubbleSort(arr) {\n        const bars = document.querySelectorAll('.bar');\n        for (let i = 0; i < arr.length; i++) {\n            for (let j = 0; j < arr.length - i - 1; j++) {\n                // Change color of the bars being compared\n                bars[j].style.backgroundColor = 'red';\n                bars[j + 1].style.backgroundColor = 'red';\n\n                // Compare and swap if needed\n                if (arr[j] > arr[j + 1]) {\n                    await new Promise(resolve => setTimeout(resolve, 300)); // Pause for visualization\n                    [arr[j], arr[j + 1]] = [arr[j + 1], arr[j]];\n                    createBars(arr);\n                }\n                // Reset color of the bars\n                bars[j].style.backgroundColor = 'teal';\n                bars[j + 1].style.backgroundColor = 'teal';\n            }\n            // Change color of the sorted element\n            bars[arr.length - i - 1].style.backgroundColor = 'green';\n        }\n    }\n\n    sortButton.addEventListener('click', () => {\n        createBars(array);\n        bubbleSort(array);\n    });\n\n    // Initial call to create the bars\n    createBars(array);\n</script>\n\n</body>\n</html>"
