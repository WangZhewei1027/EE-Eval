    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Sliding Window Concept</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #arrayInput {\n            margin-top: 20px;\n        }\n        .result {\n            margin-top: 20px;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Sliding Window Technique Demo</h1>\n    <p>Enter an array of numbers and a window size to calculate the sum of each window.</p>\n\n    <label for=\"array\">Array (comma-separated):</label><br>\n    <input type=\"text\" id=\"array\" placeholder=\"e.g. 1,2,3,4,5\"><br>\n\n    <label for=\"windowSize\">Window Size:</label><br>\n    <input type=\"number\" id=\"windowSize\" value=\"2\" min=\"1\"><br>\n\n    <button onclick=\"calculateSlidingWindow()\">Calculate Sliding Window Sums</button>\n\n    <div class=\"result\" id=\"result\"></div>\n\n    <script>\n        function calculateSlidingWindow() {\n            const inputArray = document.getElementById('array').value.split(',').map(Number);\n            const windowSize = parseInt(document.getElementById('windowSize').value, 10);\n            const resultElement = document.getElementById('result');\n\n            if (isNaN(windowSize) || windowSize <= 0) {\n                resultElement.innerText = \"Please enter a valid window size.\";\n                return;\n            }\n\n            if (inputArray.length < windowSize) {\n                resultElement.innerText = \"Window size cannot be larger than the array.\";\n                return;\n            }\n\n            const sums = [];\n            let currentSum = 0;\n\n            // Calculate sum for the first window\n            for (let i = 0; i < windowSize; i++) {\n                currentSum += inputArray[i];\n            }\n            sums.push(currentSum);\n\n            // Slide the window\n            for (let i = windowSize; i < inputArray.length; i++) {\n                currentSum += inputArray[i] - inputArray[i - windowSize];\n                sums.push(currentSum);\n            }\n\n            resultElement.innerText = `Sliding window sums: ${sums.join(', ')}`;\n        }\n    </script>\n\n</body>\n</html>"
