  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>K-Means Clustering — Interactive Demo</title>\n  <style>\n    body {\n      font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      margin: 0;\n      padding: 0;\n      display: flex;\n      height: 100vh;\n      background: #f5f7fb;\n      color: #111;\n    }\n    #app {\n      margin: 20px;\n      display: flex;\n      gap: 20px;\n      width: calc(100% - 40px);\n    }\n    #left {\n      flex: 1 1 700px;\n      background: white;\n      border-radius: 8px;\n      box-shadow: 0 6px 18px rgba(18,38,63,0.08);\n      padding: 14px;\n      display: flex;\n      flex-direction: column;\n    }\n    canvas {\n      border-radius: 6px;\n      background: linear-gradient(180deg, #ffffff, #fafbff);\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.6);\n      cursor: crosshair;\n      flex: 1;\n      width: 100%;\n      height: 520px;\n    }\n    #right {\n      width: 340px;\n      min-width: 260px;\n      background: white;\n      border-radius: 8px;\n      padding: 14px;\n      box-shadow: 0 6px 18px rgba(18,38,63,0.08);\n      display: flex;\n      flex-direction: column;\n      gap: 12px;\n    }\n    h1 {\n      margin: 0 0 8px 0;\n      font-size: 18px;\n    }\n    p.explain {\n      margin: 0 0 8px 0;\n      font-size: 13px;\n      color: #334;\n    }\n    .control {\n      display: flex;\n      gap: 8px;\n      align-items: center;\n      flex-wrap: wrap;\n    }\n    label {\n      font-size: 13px;\n      color: #333;\n      min-width: 60px;\n    }\n    input[type=\"range\"] { width: 160px; }\n    button {\n      background: linear-gradient(180deg, #0b74ff, #0a63d6);\n      color: white;\n      border: none;\n      padding: 8px 10px;\n      border-radius: 6px;\n      cursor: pointer;\n      font-weight: 600;\n      box-shadow: 0 4px 10px rgba(11,116,255,0.18);\n    }\n    button.ghost {\n      background: #f3f5fb;\n      color: #133;\n      box-shadow: none;\n      border: 1px solid #e3e7ef;\n      font-weight: 600;\n    }\n    .small { padding: 6px 8px; font-size: 13px; }\n    .row { display:flex; gap:8px; align-items:center; }\n    .infoBox {\n      background: #f8fbff;\n      border: 1px solid #e6efff;\n      padding: 10px;\n      border-radius: 6px;\n      font-size: 13px;\n      color: #233;\n    }\n    .legend {\n      display:flex;\n      gap:8px;\n      flex-wrap:wrap;\n    }\n    .legendItem {\n      display:flex;\n      gap:6px;\n      align-items:center;\n      font-size:13px;\n      color: #223;\n    }\n    .dot {\n      width:14px;\n      height:14px;\n      border-radius:50%;\n      border: 1px solid rgba(0,0,0,0.08);\n      box-shadow: 0 1px 2px rgba(18,38,63,0.06);\n    }\n    .footer {\n      margin-top: auto;\n      font-size: 12px;\n      color: #556;\n    }\n    .controls-grid { display:flex; gap:8px; flex-wrap:wrap; }\n    .toggle {\n      display:flex;\n      gap:8px;\n      align-items:center;\n      font-size:13px;\n    }\n    .rangeVal { min-width:28px; text-align:right; font-weight:700; }\n    a.smalllink { color:#0b63ff; text-decoration:none; font-size:12px;}\n  </style>\n</head>\n<body>\n  <div id=\"app\">\n    <div id=\"left\">\n      <h1>K-Means Clustering — Interactive Demo</h1>\n      <p class=\"explain\">Click to add points. Use controls to set K and run the algorithm. Points are colored by current cluster; centroids are squares. Try k-means++ init for smarter centroid placement.</p>\n      <canvas id=\"canvas\" width=\"900\" height=\"520\"></canvas>\n      <div style=\"display:flex; justify-content:space-between; margin-top:8px;\">\n        <div style=\"font-size:13px; color:#334;\">Click canvas to add points — hold Shift to add 10 at once</div>\n        <div style=\"font-size:13px; color:#334;\">SSE: <span id=\"sse\">0</span></div>\n      </div>\n    </div>\n\n    <div id=\"right\">\n      <div class=\"control\">\n        <label for=\"kRange\">K</label>\n        <input id=\"kRange\" type=\"range\" min=\"1\" max=\"12\" value=\"3\">\n        <div class=\"rangeVal\" id=\"kVal\">3</div>\n        <div style=\"flex:1\"></div>\n        <label for=\"pointsRange\">Points</label>\n        <input id=\"pointsRange\" type=\"range\" min=\"10\" max=\"1000\" value=\"200\">\n        <div class=\"rangeVal\" id=\"pointsVal\">200</div>\n      </div>\n\n      <div class=\"control\">\n        <button id=\"initBtn\" class=\"small\">Init centroids</button>\n        <button id=\"initPP\" class=\"ghost small\">Init k-means++</button>\n        <button id=\"randomPts\" class=\"ghost small\">Random points</button>\n        <button id=\"clearPts\" class=\"ghost small\">Clear points</button>\n      </div>\n\n      <div class=\"control\">\n        <button id=\"runBtn\">Run</button>\n        <button id=\"stepBtn\" class=\"ghost\">Step</button>\n        <button id=\"pauseBtn\" class=\"ghost\">Pause</button>\n        <button id=\"resetBtn\" class=\"ghost\">Reset</button>\n      </div>\n\n      <div class=\"control\">\n        <label for=\"speedRange\">Speed</label>\n        <input id=\"speedRange\" type=\"range\" min=\"50\" max=\"2000\" value=\"500\">\n        <div class=\"rangeVal\" id=\"speedVal\">500ms</div>\n      </div>\n\n      <div class=\"infoBox\">\n        <div style=\"display:flex; justify-content:space-between; gap:12px;\">\n          <div>Iteration: <strong id=\"iter\">0</strong></div>\n          <div>Assignments changed: <strong id=\"changed\">0</strong></div>\n        </div>\n        <div style=\"margin-top:8px;\">\n          <input type=\"checkbox\" id=\"showTrails\"><label for=\"showTrails\" style=\"margin-left:6px;\">Show centroid trails</label>\n        </div>\n      </div>\n\n      <div>\n        <div style=\"font-size:13px; margin-bottom:6px;\">Legend</div>\n        <div id=\"legend\" class=\"legend\"></div>\n      </div>\n\n      <div class=\"footer\">\n        Tips: Try different K and initialization. Empty clusters are reinitialized randomly. This demo uses Euclidean distance and standard k-means (Lloyd's algorithm).\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Canvas / drawing setup\n    const canvas = document.getElementById('canvas');\n    const ctx = canvas.getContext('2d');\n\n    const kRange = document.getElementById('kRange');\n    const kVal = document.getElementById('kVal');\n    const pointsRange = document.getElementById('pointsRange');\n    const pointsVal = document.getElementById('pointsVal');\n    const initBtn = document.getElementById('initBtn');\n    const initPPBtn = document.getElementById('initPP');\n    const randomPtsBtn = document.getElementById('randomPts');\n    const clearPtsBtn = document.getElementById('clearPts');\n    const runBtn = document.getElementById('runBtn');\n    const stepBtn = document.getElementById('stepBtn');\n    const pauseBtn = document.getElementById('pauseBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const iterLabel = document.getElementById('iter');\n    const changedLabel = document.getElementById('changed');\n    const sseLabel = document.getElementById('sse');\n    const legendDiv = document.getElementById('legend');\n    const speedRange = document.getElementById('speedRange');\n    const speedVal = document.getElementById('speedVal');\n    const showTrails = document.getElementById('showTrails');\n\n    let WIDTH = canvas.width;\n    let HEIGHT = canvas.height;\n\n    window.addEventListener('resize', () => {\n      // canvas is fixed size here; if you want responsive, adjust.\n    });\n\n    // Data model\n    let points = []; // {x, y, cluster}\n    let centroids = []; // {x, y, id, trail:[]}\n    let K = parseInt(kRange.value);\n    let running = false;\n    let iter = 0;\n    let changed = 0;\n    let intervalId = null;\n    let animationDelay = parseInt(speedRange.value);\n\n    // Color palette\n    const palette = [\n      '#FF6B6B','#4ECDC4','#5567FF','#FFD93D','#845EC2','#00C9A7','#FF9671','#C34A36',\n      '#6C5CE7','#02C39A','#FF9F1C','#00B4D8'\n    ];\n\n    // Helpers\n    function rand(min, max) { return Math.random()*(max-min)+min; }\n    function dist2(a,b){ const dx=a.x-b.x, dy=a.y-b.y; return dx*dx+dy*dy; }\n    function clamp(v,min,max){ return Math.max(min,Math.min(max,v)); }\n\n    // UI syncing\n    function updateUI() {\n      K = parseInt(kRange.value);\n      kVal.textContent = K;\n      pointsVal.textContent = pointsRange.value;\n      speedVal.textContent = animationDelay + 'ms';\n      iterLabel.textContent = iter;\n      changedLabel.textContent = changed;\n      sseLabel.textContent = computeSSE().toFixed(1);\n      updateLegend();\n    }\n\n    kRange.addEventListener('input', () => {\n      kVal.textContent = kRange.value;\n    });\n    pointsRange.addEventListener('input', () => {\n      pointsVal.textContent = pointsRange.value;\n    });\n    speedRange.addEventListener('input', () => {\n      animationDelay = parseInt(speedRange.value);\n      speedVal.textContent = animationDelay + 'ms';\n      if (running) {\n        restartInterval();\n      }\n    });\n\n    // Initialize random points\n    function generateRandomPoints(n) {\n      points = [];\n      for (let i=0;i<n;i++){\n        points.push({\n          x: rand(30, WIDTH-30),\n          y: rand(30, HEIGHT-30),\n          cluster: -1\n        });\n      }\n      iter = 0; changed = 0;\n      centroids = [];\n      updateUI();\n      draw();\n    }\n\n    // Initialize centroids uniformly at random positions\n    function initCentroidsRandom() {\n      centroids = [];\n      for (let i=0;i<K;i++){\n        centroids.push({\n          x: rand(40, WIDTH-40),\n          y: rand(40, HEIGHT-40),\n          id: i,\n          trail: []\n        });\n      }\n      iter = 0; changed = 0;\n      assignAll();\n      updateUI();\n      draw();\n    }\n\n    // k-means++ initialization using points as candidate positions; fallback to uniform if not enough points\n    function initCentroidsKMeansPP() {\n      centroids = [];\n      if (points.length === 0) {\n        initCentroidsRandom();\n        return;\n      }\n      // pick first randomly from points\n      const pts = points.slice();\n      const first = pts[Math.floor(Math.random()*pts.length)];\n      centroids.push({x:first.x, y:first.y, id:0, trail:[]});\n\n      while (centroids.length < K) {\n        // compute distance squared to nearest existing centroid\n        const dists = pts.map(p => {\n          let minD = Infinity;\n          for (const c of centroids) {\n            const dx = p.x-c.x, dy = p.y-c.y;\n            const dd = dx*dx+dy*dy;\n            if (dd < minD) minD = dd;\n          }\n          return minD;\n        });\n        // compute cumulative distribution proportional to dists\n        const sum = dists.reduce((a,b)=>a+b,0);\n        if (sum === 0) {\n          // all points coincide; place random centroid\n          centroids.push({x:rand(40, WIDTH-40), y:rand(40, HEIGHT-40), id:centroids.length, trail:[]});\n          continue;\n        }\n        let r = Math.random()*sum;\n        let idx = 0;\n        while (r > dists[idx]) {\n          r -= dists[idx];\n          idx++;\n          if (idx>=dists.length) break;\n        }\n        const p = pts[idx];\n        centroids.push({x:p.x, y:p.y, id:centroids.length, trail:[]});\n      }\n      iter = 0; changed = 0;\n      assignAll();\n      updateUI();\n      draw();\n    }\n\n    // Assignment step: assign each point to nearest centroid\n    function assignAll() {\n      if (centroids.length === 0) return;\n      let changedCount = 0;\n      for (const p of points) {\n        let best = -1;\n        let bestd = Infinity;\n        for (let i=0;i<centroids.length;i++){\n          const c = centroids[i];\n          const d = (p.x-c.x)*(p.x-c.x) + (p.y-c.y)*(p.y-c.y);\n          if (d < bestd) { bestd = d; best = i; }\n        }\n        if (p.cluster !== best) {\n          p.cluster = best;\n          changedCount++;\n        }\n      }\n      changed = changedCount;\n      return changedCount;\n    }\n\n    // Update step: recompute centroids as mean of assigned points\n    function updateCentroids() {\n      const sums = new Array(centroids.length).fill(0).map(()=>({x:0,y:0,count:0}));\n      for (const p of points) {\n        if (p.cluster >= 0 && p.cluster < centroids.length) {\n          sums[p.cluster].x += p.x;\n          sums[p.cluster].y += p.y;\n          sums[p.cluster].count += 1;\n        }\n      }\n      for (let i=0;i<centroids.length;i++){\n        const s = sums[i];\n        if (s.count > 0) {\n          const newX = s.x / s.count;\n          const newY = s.y / s.count;\n          // record trail\n          if (showTrails.checked) {\n            centroids[i].trail.push({x:centroids[i].x,y:centroids[i].y});\n            if (centroids[i].trail.length > 20) centroids[i].trail.shift();\n          } else {\n            centroids[i].trail = [];\n          }\n          centroids[i].x = newX;\n          centroids[i].y = newY;\n        } else {\n          // empty cluster — reinitialize at random location\n          centroids[i].x = rand(30, WIDTH-30);\n          centroids[i].y = rand(30, HEIGHT-30);\n          centroids[i].trail = [];\n        }\n      }\n    }\n\n    // One full iteration: assignment then update\n    function iterateOnce() {\n      if (centroids.length === 0 || points.length === 0) return;\n      const changedCount = assignAll();\n      updateCentroids();\n      iter++;\n      changed = changedCount;\n      updateUI();\n      draw();\n    }\n\n    // Run loop\n    function startRunning() {\n      if (running) return;\n      running = true;\n      runBtn.disabled = true;\n      restartInterval();\n    }\n\n    function restartInterval() {\n      if (intervalId) clearInterval(intervalId);\n      intervalId = setInterval(() => {\n        iterateOnce();\n      }, animationDelay);\n    }\n\n    function pauseRunning() {\n      running = false;\n      runBtn.disabled = false;\n      if (intervalId) {\n        clearInterval(intervalId);\n        intervalId = null;\n      }\n    }\n\n    // SSE: sum squared errors\n    function computeSSE() {\n      if (centroids.length === 0) return 0;\n      let sse = 0;\n      for (const p of points) {\n        const c = centroids[p.cluster] || {x:0,y:0};\n        sse += (p.x-c.x)*(p.x-c.x) + (p.y-c.y)*(p.y-c.y);\n      }\n      return sse;\n    }\n\n    // Draw routine\n    function draw() {\n      ctx.clearRect(0,0,WIDTH,HEIGHT);\n      // background grid\n      ctx.fillStyle = '#fff';\n      ctx.fillRect(0,0,WIDTH,HEIGHT);\n\n      // Draw trails\n      for (let i=0;i<centroids.length;i++){\n        const c = centroids[i];\n        if (c.trail && c.trail.length>0) {\n          ctx.beginPath();\n          ctx.strokeStyle = hexToRgba(palette[i%palette.length],0.35);\n          ctx.lineWidth = 2;\n          let first = true;\n          for (const t of c.trail) {\n            if (first) { ctx.moveTo(t.x,t.y); first=false; }\n            else ctx.lineTo(t.x,t.y);\n          }\n          ctx.stroke();\n        }\n      }\n\n      // Draw Voronoi-ish colored regions (very approximate by drawing points)\n      // We'll draw points colored by cluster\n      for (const p of points) {\n        const color = p.cluster >= 0 ? palette[p.cluster % palette.length] : '#999';\n        ctx.beginPath();\n        ctx.fillStyle = color;\n        ctx.globalAlpha = 0.9;\n        ctx.arc(p.x, p.y, 4, 0, Math.PI*2);\n        ctx.fill();\n        ctx.globalAlpha = 1;\n        // outline\n        ctx.strokeStyle = 'rgba(0,0,0,0.06)';\n        ctx.lineWidth = 1;\n        ctx.stroke();\n      }\n\n      // Draw centroids\n      for (let i=0;i<centroids.length;i++){\n        const c = centroids[i];\n        const color = palette[i % palette.length];\n        // shadow\n        ctx.fillStyle = hexToRgba(color, 1);\n        ctx.strokeStyle = '#111';\n        ctx.globalAlpha = 0.95;\n        ctx.fillRect(c.x-7, c.y-7, 14, 14);\n        ctx.beginPath();\n        ctx.strokeStyle = hexToRgba('#000',0.12);\n        ctx.strokeRect(c.x-7, c.y-7, 14, 14);\n        ctx.globalAlpha = 1;\n      }\n\n      // If paused: label helpful text\n      if (!running) {\n        // nothing extra\n      }\n    }\n\n    function hexToRgba(hex, a=1.0) {\n      const h = hex.replace('#','');\n      const r = parseInt(h.substring(0,2),16);\n      const g = parseInt(h.substring(2,4),16);\n      const b = parseInt(h.substring(4,6),16);\n      return `rgba(${r},${g},${b},${a})`;\n    }\n\n    // Legend\n    function updateLegend(){\n      legendDiv.innerHTML = '';\n      for (let i=0;i<K;i++){\n        const item = document.createElement('div');\n        item.className = 'legendItem';\n        const dot = document.createElement('div');\n        dot.className = 'dot';\n        dot.style.background = palette[i%palette.length];\n        item.appendChild(dot);\n        const txt = document.createElement('div');\n        txt.textContent = 'Cluster ' + (i+1);\n        item.appendChild(txt);\n        legendDiv.appendChild(item);\n      }\n    }\n\n    // Canvas interaction: add points\n    canvas.addEventListener('mousedown', (ev) => {\n      const rect = canvas.getBoundingClientRect();\n      const x = clamp(ev.clientX - rect.left, 0, WIDTH);\n      const y = clamp(ev.clientY - rect.top, 0, HEIGHT);\n      const addCount = ev.shiftKey ? 10 : 1;\n      for (let i=0;i<addCount;i++){\n        const jitterX = x + rand(-8,8);\n        const jitterY = y + rand(-8,8);\n        points.push({x:jitterX, y:jitterY, cluster:-1});\n      }\n      // keep cluster assignments when possible\n      assignAll();\n      updateUI();\n      draw();\n    });\n\n    // Buttons wiring\n    randomPtsBtn.addEventListener('click', () => {\n      const n = parseInt(pointsRange.value);\n      generateRandomPoints(n);\n    });\n\n    clearPtsBtn.addEventListener('click', () => {\n      points = [];\n      centroids = [];\n      iter = 0; changed = 0;\n      updateUI();\n      draw();\n    });\n\n    initBtn.addEventListener('click', () => {\n      initCentroidsRandom();\n    });\n\n    initPPBtn.addEventListener('click', () => {\n      initCentroidsKMeansPP();\n    });\n\n    runBtn.addEventListener('click', () => {\n      if (centroids.length === 0) initCentroidsRandom();\n      startRunning();\n    });\n\n    pauseBtn.addEventListener('click', () => {\n      pauseRunning();\n    });\n\n    stepBtn.addEventListener('click', () => {\n      if (centroids.length === 0) initCentroidsRandom();\n      iterateOnce();\n    });\n\n    resetBtn.addEventListener('click', () => {\n      pauseRunning();\n      points = [];\n      centroids = [];\n      iter = 0;\n      changed = 0;\n      updateUI();\n      draw();\n    });\n\n    // Recompute changed when showTrails toggled\n    showTrails.addEventListener('change', () => {\n      for (const c of centroids) {\n        if (!showTrails.checked) c.trail = [];\n      }\n      draw();\n    });\n\n    // Basic keyboard shortcuts\n    window.addEventListener('keydown', (ev) => {\n      if (ev.key === ' ') {\n        ev.preventDefault();\n        if (running) pauseRunning(); else startRunning();\n      } else if (ev.key === 's') {\n        iterateOnce();\n      } else if (ev.key === 'r') {\n        generateRandomPoints(parseInt(pointsRange.value));\n      }\n    });\n\n    // Initialize default random data\n    generateRandomPoints(parseInt(pointsRange.value));\n    initCentroidsRandom();\n    updateLegend();\n    updateUI();\n\n    // Keep UI updated periodically (SSE and iteration count update on changes too)\n    setInterval(updateUI, 400);\n\n    // Ensure we clear interval when window hidden to save CPU (optional)\n    document.addEventListener('visibilitychange', () => {\n      if (document.hidden && intervalId) {\n        clearInterval(intervalId);\n        intervalId = null;\n      } else if (running && !intervalId) {\n        restartInterval();\n      }\n    });\n\n    // Expose some convenience on resize (if canvas changed)\n    // No-op since canvas uses fixed pixel size.\n\n    // Safety: if K > points, still allow centroids > points; centers will be random or on single points.\n  </script>\n</body>\n</html>"
  },
