    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Selection Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-top: 50px;\n        }\n        .bar {\n            display: inline-block;\n            width: 20px;\n            margin: 0 2px;\n            background-color: teal;\n        }\n        .highlight {\n            background-color: orange;\n        }\n        #array {\n            display: flex;\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Selection Sort Visualization</h1>\n<div id=\"array\"></div>\n<button onclick=\"selectionSort()\">Sort Array</button>\n<button onclick=\"generateArray()\">Generate New Array</button>\n\n<script>\n    let array = [];\n\n    function generateArray() {\n        array = [];\n        for (let i = 0; i < 10; i++) {\n            array.push(Math.floor(Math.random() * 100) + 1);\n        }\n        displayArray();\n    }\n\n    function displayArray() {\n        const arrayDiv = document.getElementById('array');\n        arrayDiv.innerHTML = '';\n        array.forEach(value => {\n            const bar = document.createElement('div');\n            bar.classList.add('bar');\n            bar.style.height = value * 2 + 'px';\n            bar.textContent = value;\n            arrayDiv.appendChild(bar);\n        });\n    }\n\n    async function selectionSort() {\n        let length = array.length;\n        for (let i = 0; i < length - 1; i++) {\n            let minIndex = i;\n            highlightBar(i);\n            for (let j = i + 1; j < length; j++) {\n                highlightBar(j);\n                await new Promise(resolve => setTimeout(resolve, 500));\n                if (array[j] < array[minIndex]) {\n                    if (minIndex !== i) {\n                        resetHighlight(minIndex);\n                    }\n                    minIndex = j;\n                    highlightBar(minIndex);\n                } else {\n                    resetHighlight(j);\n                }\n            }\n            if (minIndex !== i) {\n                [array[i], array[minIndex]] = [array[minIndex], array[i]];\n                await new Promise(resolve => setTimeout(resolve, 500));\n                displayArray();\n            }\n            resetHighlight(i);\n        }\n        highlightSortedIndices(length - 1);\n    }\n\n    function highlightBar(index) {\n        const bars = document.querySelectorAll('.bar');\n        bars[index].classList.add('highlight');\n    }\n\n    function resetHighlight(index) {\n        const bars = document.querySelectorAll('.bar');\n        bars[index].classList.remove('highlight');\n    }\n\n    function highlightSortedIndices(index) {\n        const bars = document.querySelectorAll('.bar');\n        bars[index].style.backgroundColor = 'green';\n    }\n\n    window.onload = generateArray;\n</script>\n\n</body>\n</html>"
