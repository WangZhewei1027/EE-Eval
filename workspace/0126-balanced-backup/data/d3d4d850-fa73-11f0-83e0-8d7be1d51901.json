    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Hash Table Visualizer (Demo)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#f7f9fc;\n      --card:#ffffff;\n      --accent:#2b7cff;\n      --accent-2:#ff8a00;\n      --muted:#6b7280;\n      --success:#10b981;\n      --danger:#ef4444;\n      --glass: rgba(255,255,255,0.8);\n    }\n    html,body{height:100%;margin:0;font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;}\n    body {background: linear-gradient(180deg, #eef6ff 0%, #f7fbff 100%); padding:20px; color:#0f172a;}\n    .container {max-width:1100px;margin:0 auto;}\n    header{display:flex;align-items:flex-start;gap:18px;margin-bottom:18px;}\n    h1{font-size:20px;margin:0 0 6px 0;}\n    p.lead{margin:0;color:var(--muted);font-size:13px;}\n    .controls{display:flex;gap:12px;margin-bottom:14px;align-items:flex-start;flex-wrap:wrap;}\n    .panel{background:var(--card);border-radius:10px;padding:12px;box-shadow:0 6px 20px rgba(12,15,30,0.06);min-width:260px;}\n    .panel.small{min-width:180px;}\n    label{font-size:13px;color:#0f172a;font-weight:600;display:block;margin-bottom:8px;}\n    .row{display:flex;gap:8px;align-items:center;}\n    .row > *{flex:1;}\n    input[type=\"text\"], input[type=\"number\"], select{width:100%;padding:8px;border-radius:8px;border:1px solid #e6eef8;font-size:13px;}\n    button{padding:8px 10px;border-radius:8px;border:0;background:var(--accent);color:white;font-weight:600;cursor:pointer;}\n    button.secondary{background:#e6eef8;color:#0f172a;font-weight:600;}\n    button.ghost{background:transparent;border:1px dashed #cfe2ff;color:var(--accent);}\n    .flex{display:flex;gap:8px;align-items:center;}\n    .hashCanvas{display:flex;gap:6px;flex-wrap:wrap;padding:12px;border-radius:10px;background:linear-gradient(180deg,#ffffff,#f8fbff);min-height:120px;}\n    .bucket{width:90px;height:90px;border-radius:10px;background:linear-gradient(180deg,#fff,#fbfeff);border:1px solid #e8f1ff;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;box-shadow:0 6px 18px rgba(16,24,40,0.04);}\n    .bucket.index{width:60px;height:60px;font-size:12px;}\n    .bucket .idx{position:absolute;top:6px;left:6px;font-size:11px;color:var(--muted);}\n    .bucket .content{font-size:13px;color:#05204a;display:flex;flex-direction:column;gap:4px;align-items:center;}\n    .node{display:inline-flex;gap:6px;align-items:center;background:linear-gradient(180deg,#f8fbff,#ffffff);padding:6px;border-radius:6px;border:1px solid #e6f0ff;font-size:12px;}\n    .node .k{font-weight:700;color:#0f172a;}\n    .node .v{color:var(--muted);font-size:11px;}\n    .legend{font-size:13px;color:var(--muted);margin-top:8px;}\n    .log{background:#0b1220;color:#e6f0ff;padding:10px;border-radius:8px;font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;font-size:13px;min-height:90px;overflow:auto;}\n    .controls-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}\n    .small-text{font-size:12px;color:var(--muted);}\n    .status{font-size:12px;padding:6px 8px;border-radius:8px;}\n    .status.ok{background:var(--success);color:white;}\n    .status.bad{background:var(--danger);color:white;}\n    .muted{color:var(--muted);font-size:13px;}\n    .footer{margin-top:14px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;}\n    .codeblock{background:#0b1220;color:#e6f0ff;padding:10px;border-radius:8px;font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;font-size:12px;white-space:pre-wrap;overflow:auto;}\n    .controls .group{display:flex;gap:8px;flex-direction:column;}\n    .switch{display:flex;gap:6px;align-items:center;}\n    input[type=range]{width:140px;}\n    .highlighted{box-shadow:0 6px 24px rgba(43,124,255,0.15), inset 0 0 0 2px rgba(43,124,255,0.06);}\n    .visited{outline:3px solid rgba(255,138,0,0.12);}\n    .found{outline:3px solid rgba(16,185,129,0.14);}\n    .deleted{opacity:0.45;}\n    .tombstone{font-size:12px;color:var(--muted);}\n    .clearfix{clear:both;}\n    @media (max-width:860px){\n      .controls-grid{grid-template-columns:1fr;}\n      .controls{flex-direction:column;}\n      .bucket{width:72px;height:72px;}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <header>\n      <div style=\"flex:1\">\n        <h1>Hash Table Visualizer</h1>\n        <p class=\"lead\">Interactive demonstration of a hash table. Try inserts, searches, deletes and observe collision handling (separate chaining & open addressing).</p>\n      </div>\n      <div style=\"min-width:260px\" class=\"panel small\">\n        <div style=\"font-size:13px;font-weight:700;margin-bottom:6px\">Current State</div>\n        <div style=\"display:flex;gap:8px;align-items:center;justify-content:space-between;\">\n          <div class=\"muted\">Table size: <span id=\"sizeDisplay\">10</span></div>\n          <div class=\"muted\">Load factor: <span id=\"loadDisplay\">0.00</span></div>\n        </div>\n        <div style=\"display:flex;gap:8px;margin-top:8px;\">\n          <div class=\"status ok\" id=\"statusMsg\">Ready</div>\n        </div>\n      </div>\n    </header>\n\n    <div class=\"controls\">\n      <div class=\"panel\" style=\"flex:1;\">\n        <label>Collision Strategy</label>\n        <div class=\"row\">\n          <select id=\"strategy\">\n            <option value=\"chaining\">Separate Chaining (linked lists)</option>\n            <option value=\"open\">Open Addressing (linear probing)</option>\n          </select>\n        </div>\n\n        <div style=\"margin-top:10px;\" class=\"controls-grid\">\n          <div>\n            <label>Table size (buckets)</label>\n            <input type=\"number\" id=\"tableSize\" min=\"3\" max=\"60\" value=\"10\" />\n            <div class=\"small-text\" style=\"margin-top:6px;\">Pick between 3 and 60. Small sizes make collisions visible.</div>\n          </div>\n          <div>\n            <label>Hash function</label>\n            <select id=\"hashFn\">\n              <option value=\"sum\">Sum of char codes % size (simple)</option>\n              <option value=\"djb2\">djb2 (better distribution)</option>\n            </select>\n          </div>\n        </div>\n\n        <div style=\"margin-top:10px;\" class=\"row\">\n          <div style=\"flex:1\">\n            <label>Speed (animation)</label>\n            <div class=\"flex\">\n              <input type=\"range\" id=\"speed\" min=\"50\" max=\"1200\" value=\"300\" />\n              <div class=\"small-text\" id=\"speedValue\">300 ms</div>\n            </div>\n          </div>\n          <div style=\"width:180px\">\n            <label>Step mode</label>\n            <div class=\"switch\">\n              <input type=\"checkbox\" id=\"stepMode\" />\n              <div class=\"small-text\">Pause after each bucket visited</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"panel\" style=\"width:360px;\">\n        <label>Manual operations</label>\n        <div style=\"display:flex;gap:8px;margin-bottom:8px;\">\n          <input id=\"keyInput\" type=\"text\" placeholder=\"Key (string/number)\" />\n          <input id=\"valueInput\" type=\"text\" placeholder=\"Value (any)\" />\n        </div>\n        <div style=\"display:flex;gap:8px;\">\n          <button id=\"insertBtn\">Insert</button>\n          <button id=\"searchBtn\" class=\"secondary\">Search</button>\n          <button id=\"deleteBtn\" class=\"ghost\">Delete</button>\n        </div>\n\n        <div style=\"margin-top:10px;\">\n          <label>Quick actions</label>\n          <div style=\"display:flex;gap:8px;margin-top:6px;\">\n            <button id=\"randomFill\">Random fill</button>\n            <button id=\"clearBtn\" class=\"secondary\">Clear</button>\n          </div>\n          <div class=\"small-text\" style=\"margin-top:8px;\">Random fill adds several entries to illustrate collisions.</div>\n        </div>\n      </div>\n\n      <div class=\"panel small\">\n        <label>Legend</label>\n        <div class=\"legend\">\n          <div style=\"display:flex;gap:8px;align-items:center;margin-bottom:6px;\">\n            <div style=\"width:12px;height:12px;background:var(--accent);border-radius:3px;\"></div> Current probe / highlight\n          </div>\n          <div style=\"display:flex;gap:8px;align-items:center;margin-bottom:6px;\">\n            <div style=\"width:12px;height:12px;background:var(--accent-2);border-radius:3px;\"></div> Visited (search path)\n          </div>\n          <div style=\"display:flex;gap:8px;align-items:center;\">\n            <div style=\"width:12px;height:12px;background:var(--success);border-radius:3px;\"></div> Found\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <label>Visualization</label>\n      <div id=\"tableArea\" class=\"hashCanvas\" role=\"application\" aria-label=\"Hash table visualization\"></div>\n      <div style=\"margin-top:10px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;\">\n        <div class=\"muted\">Click a bucket to inspect / expand nodes.</div>\n      </div>\n    </div>\n\n    <div style=\"display:flex;gap:12px;margin-top:12px;flex-wrap:wrap;\">\n      <div style=\"flex:1\" class=\"panel\">\n        <label>Operations log</label>\n        <div id=\"log\" class=\"log\" aria-live=\"polite\"></div>\n      </div>\n      <div style=\"width:380px\" class=\"panel\">\n        <label>Implementation (JavaScript)</label>\n        <div class=\"codeblock\" id=\"codeBlock\"></div>\n      </div>\n    </div>\n\n    <div class=\"footer muted\">\n      <div>Tip: insert keys like \"apple\", \"banana\" or numbers. Try different strategies and hash functions to see how collisions behave.</div>\n      <div>© Hash Table Demo</div>\n    </div>\n  </div>\n\n  <script>\n    // Hash Table Visualizer - single file demo\n    (function () {\n      // Utilities\n      const $ = selector => document.querySelector(selector);\n      const $all = selector => Array.from(document.querySelectorAll(selector));\n      function el(tag, props = {}, children = []) {\n        const e = document.createElement(tag);\n        for (const k in props) e[k] = props[k];\n        children.forEach(c => e.appendChild(typeof c === 'string' ? document.createTextNode(c) : c));\n        return e;\n      }\n      const logEl = $('#log');\n      function log(msg, type = 'info') {\n        const time = new Date().toLocaleTimeString();\n        const node = document.createElement('div');\n        node.style.marginBottom = '6px';\n        node.innerHTML = `<span style=\"opacity:0.6;font-size:12px\">[${time}]</span> ${escapeHtml(msg)}`;\n        logEl.prepend(node);\n      }\n      function escapeHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\n\n      // Hash functions\n      function sumHash(key) {\n        const s = String(key);\n        let sum = 0;\n        for (let i=0;i<s.length;i++) sum = (sum + s.charCodeAt(i)) >>> 0;\n        return sum;\n      }\n      function djb2(key) {\n        const s = String(key);\n        let h = 5381;\n        for (let i=0;i<s.length;i++) h = ((h << 5) + h) + s.charCodeAt(i);\n        return h >>> 0;\n      }\n\n      // Implementation of two strategies:\n      class HashTable {\n        constructor({size = 10, strategy = 'chaining', hashFn = 'sum'}) {\n          this.size = Math.max(3, Math.min(60, Math.floor(size)));\n          this.strategy = strategy; // 'chaining' or 'open'\n          this.hashFnName = hashFn;\n          this.hashFn = (hashFn === 'djb2') ? djb2 : sumHash;\n          this.reset();\n        }\n        reset() {\n          if (this.strategy === 'chaining') {\n            this.table = Array.from({length: this.size}, () => []);\n            this.count = 0;\n          } else { // open addressing\n            this.table = Array.from({length: this.size}, () => null); // null = empty, {key,value} occupied, {tombstone:true} deleted\n            this.count = 0;\n          }\n        }\n        setHashFn(name) {\n          this.hashFnName = name;\n          this.hashFn = (name === 'djb2') ? djb2 : sumHash;\n        }\n        setStrategy(strategy) {\n          this.strategy = strategy;\n          this.reset();\n        }\n        resize(newSize) {\n          this.size = Math.max(3, Math.min(60, Math.floor(newSize)));\n          // Re-insert existing entries into new table to preserve semantics\n          const items = this.items();\n          this.reset();\n          items.forEach(({key,value}) => { this.insertSync(key,value); });\n        }\n        hashIndex(key) {\n          const h = this.hashFn(key);\n          return Math.abs(h) % this.size;\n        }\n\n        // Synchronous operations (no animation)\n        insertSync(key, value) {\n          if (this.strategy === 'chaining') {\n            const idx = this.hashIndex(key);\n            // replace if key exists\n            const bucket = this.table[idx];\n            for (const node of bucket) {\n              if (node.key === key) { node.value = value; return {index: idx, replaced: true}; }\n            }\n            bucket.push({key, value});\n            this.count++;\n            return {index: idx, replaced: false};\n          } else {\n            // open addressing - linear probing\n            let idx = this.hashIndex(key);\n            let start = idx;\n            let firstTombstone = -1;\n            for (let i=0;i<this.size;i++) {\n              const pos = (start + i) % this.size;\n              const entry = this.table[pos];\n              if (entry === null) {\n                const insertPos = firstTombstone >= 0 ? firstTombstone : pos;\n                this.table[insertPos] = {key,value};\n                this.count++;\n                return {index: insertPos, replaced: false};\n              } else if (entry && entry.tombstone) {\n                if (firstTombstone < 0) firstTombstone = pos;\n              } else if (entry.key === key) {\n                entry.value = value;\n                return {index: pos, replaced: true};\n              }\n            }\n            // if we reach here, table full but maybe tombstone found\n            if (firstTombstone >= 0) {\n              this.table[firstTombstone] = {key,value};\n              this.count++;\n              return {index: firstTombstone, replaced: false};\n            }\n            throw new Error('Hash table is full');\n          }\n        }\n\n        // Animated operations return arrays of steps describing indices visited and outcome\n        async insert(key, value, callbacks = {}) {\n          const visited = [];\n          const idx = this.hashIndex(key);\n          if (this.strategy === 'chaining') {\n            // initial bucket highlighted\n            visited.push({index: idx, reason: 'bucket'});\n            // check if key exists\n            const bucket = this.table[idx];\n            for (let i=0;i<bucket.length;i++) {\n              visited.push({index: idx, reason: 'compare', sub:i});\n              if (bucket[i].key === key) {\n                bucket[i].value = value;\n                return {visited, result: 'replaced', index: idx};\n              }\n            }\n            bucket.push({key,value});\n            this.count++;\n            return {visited, result: 'inserted', index: idx};\n          } else {\n            let start = idx;\n            let firstTombstone = -1;\n            for (let i=0;i<this.size;i++) {\n              const pos = (start + i) % this.size;\n              visited.push({index: pos, reason: 'probe', step:i});\n              const entry = this.table[pos];\n              if (entry === null) {\n                const insertPos = firstTombstone >= 0 ? firstTombstone : pos;\n                this.table[insertPos] = {key,value};\n                this.count++;\n                return {visited, result: 'inserted', index: insertPos};\n              } else if (entry && entry.tombstone) {\n                if (firstTombstone < 0) firstTombstone = pos;\n              } else if (entry.key === key) {\n                entry.value = value;\n                return {visited, result: 'replaced', index: pos};\n              }\n            }\n            if (firstTombstone >= 0) {\n              this.table[firstTombstone] = {key,value};\n              this.count++;\n              return {visited, result: 'inserted', index: firstTombstone};\n            }\n            return {visited, result: 'full', index: -1};\n          }\n        }\n\n        async search(key) {\n          const visited = [];\n          const idx = this.hashIndex(key);\n          if (this.strategy === 'chaining') {\n            visited.push({index: idx, reason: 'bucket'});\n            const bucket = this.table[idx];\n            for (let i=0;i<bucket.length;i++) {\n              visited.push({index: idx, reason: 'compare', sub:i});\n              if (bucket[i].key === key) return {visited, found:true, value: bucket[i].value, index: idx};\n            }\n            return {visited, found:false, index: idx};\n          } else {\n            let start = idx;\n            for (let i=0;i<this.size;i++) {\n              const pos = (start + i) % this.size;\n              visited.push({index: pos, reason: 'probe', step:i});\n              const entry = this.table[pos];\n              if (entry === null) {\n                return {visited, found:false, index: pos};\n              } else if (!entry.tombstone && entry.key === key) {\n                return {visited, found:true, value: entry.value, index: pos};\n              } else {\n                // continue probing\n              }\n            }\n            return {visited, found:false, index:-1};\n          }\n        }\n\n        async delete(key) {\n          const visited = [];\n          const idx = this.hashIndex(key);\n          if (this.strategy === 'chaining') {\n            visited.push({index: idx, reason: 'bucket'});\n            const bucket = this.table[idx];\n            for (let i=0;i<bucket.length;i++) {\n              visited.push({index: idx, reason: 'compare', sub:i});\n              if (bucket[i].key === key) {\n                bucket.splice(i,1);\n                this.count--;\n                return {visited, deleted:true, index: idx};\n              }\n            }\n            return {visited, deleted:false, index: idx};\n          } else {\n            let start = idx;\n            for (let i=0;i<this.size;i++) {\n              const pos = (start + i) % this.size;\n              visited.push({index: pos, reason: 'probe', step:i});\n              const entry = this.table[pos];\n              if (entry === null) {\n                return {visited, deleted:false, index: pos};\n              } else if (!entry.tombstone && entry.key === key) {\n                // mark tombstone\n                this.table[pos] = {tombstone:true};\n                this.count--;\n                return {visited, deleted:true, index: pos};\n              } else {\n                // keep probing\n              }\n            }\n            return {visited, deleted:false, index:-1};\n          }\n        }\n\n        items() {\n          const out = [];\n          if (this.strategy === 'chaining') {\n            for (let i=0;i<this.size;i++) {\n              for (const n of this.table[i]) out.push({key:n.key,value:n.value});\n            }\n          } else {\n            for (const e of this.table) {\n              if (e && !e.tombstone) out.push({key:e.key,value:e.value});\n            }\n          }\n          return out;\n        }\n      }\n\n      // ---------- UI wiring ----------\n      const tableArea = $('#tableArea');\n      const insertBtn = $('#insertBtn');\n      const searchBtn = $('#searchBtn');\n      const deleteBtn = $('#deleteBtn');\n      const clearBtn = $('#clearBtn');\n      const randomFillBtn = $('#randomFill');\n      const strategySel = $('#strategy');\n      const tableSizeInput = $('#tableSize');\n      const hashFnSel = $('#hashFn');\n      const speedInput = $('#speed');\n      const speedValue = $('#speedValue');\n      const sizeDisplay = $('#sizeDisplay');\n      const loadDisplay = $('#loadDisplay');\n      const statusMsg = $('#statusMsg');\n      const stepMode = $('#stepMode');\n      const keyInput = $('#keyInput');\n      const valueInput = $('#valueInput');\n      const codeBlock = $('#codeBlock');\n\n      let animating = false;\n      function setBusy(state, message) {\n        animating = state;\n        insertBtn.disabled = state;\n        searchBtn.disabled = state;\n        deleteBtn.disabled = state;\n        clearBtn.disabled = state;\n        randomFillBtn.disabled = state;\n        strategySel.disabled = state;\n        tableSizeInput.disabled = state;\n        hashFnSel.disabled = state;\n        speedInput.disabled = state;\n        stepMode.disabled = state;\n        statusMsg.textContent = message || (state ? 'Working...' : 'Ready');\n        statusMsg.className = state ? 'status ok' : 'status ok';\n      }\n\n      let ht = new HashTable({size: parseInt(tableSizeInput.value,10), strategy: strategySel.value, hashFn: hashFnSel.value});\n      renderCode();\n      renderTable();\n\n      // Update displays\n      function updateStats() {\n        sizeDisplay.textContent = ht.size;\n        const load = (ht.count / ht.size) || 0;\n        loadDisplay.textContent = load.toFixed(2);\n      }\n\n      function renderTable(highlights = {}) {\n        // highlights: {visited: Set, current: index, found: index, deleted:Set}\n        updateStats();\n        tableArea.innerHTML = '';\n        for (let i=0;i<ht.size;i++) {\n          const bucketEl = document.createElement('div');\n          bucketEl.className = 'bucket';\n          bucketEl.dataset.index = i;\n          if (highlights.current === i) bucketEl.classList.add('highlighted');\n          if (highlights.visited && highlights.visited.has(i)) bucketEl.classList.add('visited');\n          if (highlights.found === i) bucketEl.classList.add('found');\n          if (highlights.deleted && highlights.deleted.has(i)) bucketEl.classList.add('deleted');\n          const idx = document.createElement('div');\n          idx.className = 'idx';\n          idx.textContent = i;\n          bucketEl.appendChild(idx);\n\n          const content = document.createElement('div');\n          content.className = 'content';\n\n          if (ht.strategy === 'chaining') {\n            const bucket = ht.table[i];\n            if (bucket.length === 0) {\n              content.appendChild(document.createTextNode('- empty -'));\n              content.style.color = 'var(--muted)';\n            } else {\n              // render nodes as horizontal list (wrap)\n              const row = document.createElement('div');\n              row.style.display = 'flex';\n              row.style.flexWrap = 'wrap';\n              row.style.justifyContent = 'center';\n              row.style.gap = '6px';\n              for (let j=0;j<bucket.length;j++) {\n                const n = bucket[j];\n                const nodeEl = document.createElement('div');\n                nodeEl.className = 'node';\n                nodeEl.title = `key: ${n.key}\\nvalue: ${n.value}`;\n                nodeEl.innerHTML = `<span class=\"k\">${escapeHtml(n.key)}</span><span class=\"v\">${escapeHtml(n.value)}</span>`;\n                row.appendChild(nodeEl);\n              }\n              content.appendChild(row);\n            }\n          } else {\n            const entry = ht.table[i];\n            if (entry === null) {\n              content.appendChild(document.createTextNode('- empty -'));\n              content.style.color = 'var(--muted)';\n            } else if (entry.tombstone) {\n              content.appendChild(document.createElement('div')).textContent = 'TOMB';\n              const ts = document.createElement('div');\n              ts.className = 'tombstone';\n              ts.textContent = '(deleted)';\n              content.appendChild(ts);\n            } else {\n              const nodeEl = document.createElement('div');\n              nodeEl.className = 'node';\n              nodeEl.title = `key: ${entry.key}\\nvalue: ${entry.value}`;\n              nodeEl.innerHTML = `<span class=\"k\">${escapeHtml(entry.key)}</span><span class=\"v\">${escapeHtml(entry.value)}</span>`;\n              content.appendChild(nodeEl);\n            }\n          }\n\n          bucketEl.appendChild(content);\n          bucketEl.addEventListener('click', () => {\n            if (animating) return;\n            inspectBucket(i);\n          });\n          tableArea.appendChild(bucketEl);\n        }\n      }\n\n      function inspectBucket(i) {\n        if (ht.strategy === 'chaining') {\n          const bucket = ht.table[i];\n          if (bucket.length === 0) {\n            alert(`Bucket ${i} is empty.`);\n          } else {\n            const items = bucket.map((n, idx) => `${idx}. key=${n.key} value=${n.value}`).join('\\n');\n            alert(`Bucket ${i} contents:\\n` + items);\n          }\n        } else {\n          const entry = ht.table[i];\n          if (entry === null) alert(`Slot ${i} is empty`);\n          else if (entry.tombstone) alert(`Slot ${i} is a tombstone (deleted)`);\n          else alert(`Slot ${i}: key=${entry.key}, value=${entry.value}`);\n        }\n      }\n\n      // animation helpers\n      function sleep(ms) {\n        return new Promise(res => setTimeout(res, ms));\n      }\n      function highlightStep(visSet, current, foundIdx, deletedSet) {\n        renderTable({visited: visSet, current, found: foundIdx, deleted: deletedSet});\n      }\n\n      // Operation handlers\n      insertBtn.addEventListener('click', async () => {\n        if (animating) return;\n        const key = keyInput.value.trim();\n        const value = valueInput.value.trim();\n        if (key === '') { alert('Please enter a key to insert.'); return; }\n        setBusy(true, 'Inserting...');\n        try {\n          const animationSpeed = parseInt(speedInput.value,10);\n          const step = await ht.insert(key, value, {});\n          const visited = step.visited;\n          const visSet = new Set();\n          const deletedSet = new Set();\n          for (let i=0;i<visited.length;i++) {\n            const v = visited[i];\n            visSet.add(v.index);\n            highlightStep(visSet, v.index, -1, deletedSet);\n            if (stepMode.checked) {\n              await waitForStepOrTimeout(animationSpeed);\n            } else {\n              await sleep(animationSpeed);\n            }\n          }\n          // finalize by re-rendering final table (in case underlying structure changed)\n          renderTable();\n          if (step.result === 'inserted') {\n            log(`Inserted key=\"${key}\" value=\"${value}\" at index ${step.index}`);\n          } else if (step.result === 'replaced') {\n            log(`Replaced key=\"${key}\" with new value=\"${value}\" at index ${step.index}`);\n          } else {\n            log(`Insert result: ${step.result}`);\n          }\n        } catch (e) {\n          log(`Error during insert: ${e.message}`, 'error');\n        } finally {\n          setBusy(false, 'Ready');\n        }\n      });\n\n      searchBtn.addEventListener('click', async () => {\n        if (animating) return;\n        const key = keyInput.value.trim();\n        if (key === '') { alert('Please enter a key to search.'); return; }\n        setBusy(true, 'Searching...');\n        try {\n          const animationSpeed = parseInt(speedInput.value,10);\n          const step = await ht.search(key);\n          const visited = step.visited;\n          const visSet = new Set();\n          for (let i=0;i<visited.length;i++) {\n            const v = visited[i];\n            visSet.add(v.index);\n            highlightStep(visSet, v.index, -1, null);\n            if (stepMode.checked) {\n              await waitForStepOrTimeout(animationSpeed);\n            } else {\n              await sleep(animationSpeed);\n            }\n          }\n          if (step.found) {\n            renderTable({visited: visSet, current: -1, found: step.index});\n            log(`Found key=\"${key}\" at index ${step.index} with value=\"${step.value}\"`);\n          } else {\n            renderTable({visited: visSet});\n            log(`Key=\"${key}\" not found.`);\n          }\n        } catch (e) {\n          log(`Error during search: ${e.message}`, 'error');\n        } finally {\n          setBusy(false, 'Ready');\n        }\n      });\n\n      deleteBtn.addEventListener('click', async () => {\n        if (animating) return;\n        const key = keyInput.value.trim();\n        if (key === '') { alert('Please enter a key to delete.'); return; }\n        setBusy(true, 'Deleting...');\n        try {\n          const animationSpeed = parseInt(speedInput.value,10);\n          const step = await ht.delete(key);\n          const visited = step.visited;\n          const visSet = new Set();\n          const deletedSet = new Set();\n          for (let i=0;i<visited.length;i++) {\n            const v = visited[i];\n            visSet.add(v.index);\n            highlightStep(visSet, v.index, -1, deletedSet);\n            if (stepMode.checked) {\n              await waitForStepOrTimeout(animationSpeed);\n            } else {\n              await sleep(animationSpeed);\n            }\n          }\n          if (step.deleted) {\n            // mark the deleted index as tombstone highlight\n            deletedSet.add(step.index);\n            renderTable({visited: visSet, deleted: deletedSet});\n            log(`Deleted key=\"${key}\" at index ${step.index}`);\n          } else {\n            renderTable({visited: visSet});\n            log(`Key=\"${key}\" not found; nothing deleted.`);\n          }\n        } catch (e) {\n          log(`Error during delete: ${e.message}`, 'error');\n        } finally {\n          setBusy(false, 'Ready');\n        }\n      });\n\n      clearBtn.addEventListener('click', () => {\n        if (animating) return;\n        if (!confirm('Clear entire table?')) return;\n        ht.reset();\n        renderTable();\n        log('Cleared table.');\n      });\n\n      randomFillBtn.addEventListener('click', async () => {\n        if (animating) return;\n        setBusy(true, 'Filling randomly...');\n        try {\n          const n = Math.max(1, Math.min(ht.size * 2, Math.floor(Math.random() * ht.size) + 3));\n          const speed = parseInt(speedInput.value,10);\n          for (let i=0;i<n;i++) {\n            const key = randomKey();\n            const value = 'v' + Math.floor(Math.random()*999);\n            const step = await ht.insert(key,value);\n            // quick visual flash\n            renderTable({visited: new Set([step.index]), current: step.index});\n            await sleep(Math.max(80, speed / 3));\n          }\n          renderTable();\n          log(`Random fill: added ${n} entries.`);\n        } finally {\n          setBusy(false, 'Ready');\n        }\n      });\n\n      // helpers\n      function randomKey() {\n        const words = ['apple','banana','orange','kite','node','hash','table','alpha','beta','gamma','delta','zeta','node','foo','bar','baz','qux'];\n        return words[Math.floor(Math.random()*words.length)] + (Math.random() > 0.6 ? Math.floor(Math.random()*100) : '');\n      }\n\n      // settings change events\n      strategySel.addEventListener('change', () => {\n        if (animating) return;\n        const s = strategySel.value;\n        ht.setStrategy(s);\n        renderTable();\n        log(`Strategy changed to ${s}`);\n        renderCode();\n      });\n      tableSizeInput.addEventListener('change', () => {\n        if (animating) return;\n        const newSize = parseInt(tableSizeInput.value,10);\n        if (isNaN(newSize) || newSize < 3 || newSize > 60) { alert('Size must be between 3 and 60.'); tableSizeInput.value = ht.size; return; }\n        ht.resize(newSize);\n        renderTable();\n        log(`Table resized to ${newSize}`);\n      });\n      hashFnSel.addEventListener('change', () => {\n        if (animating) return;\n        ht.setHashFn(hashFnSel.value);\n        renderTable();\n        log(`Hash function changed to ${hashFnSel.value}`);\n        renderCode();\n      });\n\n      speedInput.addEventListener('input', () => {\n        speedValue.textContent = speedInput.value + ' ms';\n      });\n\n      // Step mode helper: if step mode checked, we wait for either a click or timeout\n      let stepResolve = null;\n      async function waitForStepOrTimeout(ms) {\n        if (!stepMode.checked) return sleep(ms);\n        return new Promise(res => {\n          stepResolve = res;\n          const timeout = setTimeout(() => {\n            stepResolve = null;\n            res();\n          }, ms);\n          // click anywhere to proceed\n          const listener = () => {\n            if (stepResolve) {\n              clearTimeout(timeout);\n              stepResolve = null;\n              res();\n            }\n            window.removeEventListener('click', listener);\n          };\n          window.addEventListener('click', listener);\n        });\n      }\n\n      // show code snippet of implementation for educational purposes\n      function renderCode() {\n        const code = `// Simplified HashTable (JS pseudo-implementation)\nclass HashTable {\n  constructor(size = ${ht.size}, strategy = '${ht.strategy}', hashFn = '${ht.hashFnName}') {\n    this.size = size;\n    this.strategy = strategy; // 'chaining' or 'open'\n    this.hashFn = (hashFn === 'djb2') ? djb2 : sumHash;\n    this.reset();\n  }\n  reset() {\n    if (this.strategy === 'chaining') {\n      this.table = Array.from({length: this.size}, () => []); // each bucket is an array (linked list)\n    } else {\n      this.table = Array.from({length: this.size}, () => null); // open addressing slots\n    }\n  }\n  hashIndex(key) {\n    const h = this.hashFn(key);\n    return Math.abs(h) % this.size;\n  }\n  insert(key, value) {\n    const idx = this.hashIndex(key);\n    if (this.strategy === 'chaining') {\n      // push into bucket, replace if key exists\n      this.table[idx].push({key,value});\n    } else {\n      // linear probing: try idx, idx+1, ...\n      let pos = idx;\n      while (this.table[pos] !== null && !(this.table[pos].tombstone)) {\n        if (this.table[pos].key === key) { /* replace */ }\n        pos = (pos + 1) % this.size;\n      }\n      this.table[pos] = {key,value};\n    }\n  }\n  search(key) {\n    const idx = this.hashIndex(key);\n    if (this.strategy === 'chaining') {\n      return this.table[idx].find(n => n.key === key);\n    } else {\n      let pos = idx;\n      while (this.table[pos] !== null) {\n        if (!this.table[pos].tombstone && this.table[pos].key === key) return this.table[pos];\n        pos = (pos + 1) % this.size;\n      }\n      return null;\n    }\n  }\n  delete(key) {\n    // chaining: remove from bucket; open addressing: mark tombstone\n  }\n}\n`;\n        codeBlock.textContent = code;\n      }\n\n      // initial population\n      log('Demo started. Choose a strategy, type a key and click Insert.');\n\n      // Ensure UI dimensions adjust on resize\n      window.addEventListener('resize', () => renderTable());\n    })();\n  </script>\n</body>\n</html>"
