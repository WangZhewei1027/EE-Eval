  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\"/>\n  <title>Random Forest Demo (Interactive)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 18px; color: #111; }\n    h1 { margin: 0 0 6px 0; font-size: 20px; }\n    #container { display: flex; gap: 18px; }\n    #controls { width: 320px; }\n    label { display:block; margin-top:10px; font-size: 13px; color:#333; }\n    input[type=\"range\"] { width:100%; }\n    .small { font-size:12px; color:#555; margin-top:3px; }\n    canvas { border: 1px solid #ddd; background: #fff; display:block; }\n    .row { display:flex; gap:8px; align-items:center; margin-top:8px; }\n    button { padding:8px 10px; font-size:13px; cursor:pointer; }\n    .stat { margin-top:8px; font-size:13px; color:#222; }\n    .note { margin-top:12px; font-size:13px; color:#444; line-height:1.4; }\n    .footer { margin-top:14px; font-size:12px; color:#666; }\n  </style>\n</head>\n<body>\n  <h1>Random Forest Interactive Demo</h1>\n  <div id=\"container\">\n    <div id=\"controls\">\n      <label>Dataset\n        <select id=\"dataset\">\n          <option value=\"blobs\">Two blobs (gaussians)</option>\n          <option value=\"xor\">XOR</option>\n          <option value=\"circles\">Concentric circles</option>\n          <option value=\"moons\">Two moons</option>\n        </select>\n      </label>\n\n      <label>Number of trees: <span id=\"nTreesLabel\">25</span>\n        <input id=\"nTrees\" type=\"range\" min=\"1\" max=\"200\" value=\"25\"/>\n      </label>\n\n      <label>Max tree depth: <span id=\"maxDepthLabel\">6</span>\n        <input id=\"maxDepth\" type=\"range\" min=\"1\" max=\"12\" value=\"6\"/>\n      </label>\n\n      <label>Min samples leaf: <span id=\"minLeafLabel\">3</span>\n        <input id=\"minLeaf\" type=\"range\" min=\"1\" max=\"20\" value=\"3\"/>\n      </label>\n\n      <label>Sample fraction (bootstrap size): <span id=\"sampleFracLabel\">0.8</span>\n        <input id=\"sampleFrac\" type=\"range\" min=\"0.3\" max=\"1\" step=\"0.05\" value=\"0.8\"/>\n      </label>\n\n      <label>Features considered per split: <span id=\"mtryLabel\">1</span>\n        <input id=\"mtry\" type=\"range\" min=\"1\" max=\"2\" value=\"1\"/>\n      </label>\n\n      <label>Grid resolution (px per cell): <span id=\"cellLabel\">3</span>\n        <input id=\"cellSize\" type=\"range\" min=\"1\" max=\"8\" value=\"3\"/>\n      </label>\n\n      <div class=\"row\">\n        <button id=\"regen\">Generate data</button>\n        <button id=\"train\">Train / Recompute</button>\n      </div>\n\n      <div class=\"row\">\n        <label style=\"margin:0;\"><input type=\"checkbox\" id=\"showInd\" /> Show individual tree votes</label>\n      </div>\n\n      <div id=\"treeSelectRow\" class=\"row\" style=\"display:none;\">\n        <label style=\"margin:0;\">Tree index: <span id=\"treeIndexLabel\">0</span>\n          <input id=\"treeIndex\" type=\"range\" min=\"0\" max=\"0\" value=\"0\" />\n        </label>\n      </div>\n\n      <div class=\"stat\" id=\"accuracy\">Accuracy (train): —</div>\n      <div class=\"stat\" id=\"treesInfo\">Trees: —</div>\n\n      <div class=\"note\">\n        How it works (brief): We build many decision trees from bootstrap samples and at each split consider only a random subset of features. Each tree votes; the forest prediction is the majority vote. Change number of trees, tree depth, or data and observe how the decision boundary and confidence change.\n      </div>\n\n      <div class=\"footer\">This is a simplified implementation for demonstration purposes.</div>\n    </div>\n\n    <div>\n      <canvas id=\"surf\" width=\"600\" height=\"420\"></canvas>\n    </div>\n  </div>\n\n<script>\n/*\n Random Forest demo (classification)\n - 2D synthetic datasets\n - Simple CART-like trees with axis-aligned splits\n - Bootstrap samples and random feature subset at each split (mtry)\n - Visualize majority vote decision map + confidence\n*/\n\n// Utilities\nfunction randn_bm() {\n  // Box-Muller\n  let u=0,v=0;\n  while(u===0) u=Math.random();\n  while(v===0) v=Math.random();\n  return Math.sqrt(-2*Math.log(u)) * Math.cos(2*Math.PI*v);\n}\n\nfunction sampleIndices(n, frac) {\n  const m = Math.max(1, Math.round(n*frac));\n  const idx = [];\n  for (let i=0;i<m;i++) idx.push(Math.floor(Math.random()*n));\n  return idx;\n}\n\nfunction majorityLabel(labels) {\n  const counts = {};\n  for (const l of labels) counts[l] = (counts[l]||0)+1;\n  let best = null, bc = -1;\n  for (const k in counts) if (counts[k] > bc) { best = k; bc = counts[k]; }\n  return [parseInt(best), bc];\n}\n\nfunction gini(labels) {\n  if (labels.length===0) return 0;\n  const counts = {};\n  for (const l of labels) counts[l] = (counts[l]||0)+1;\n  let impur = 1;\n  for (const k in counts) {\n    const p = counts[k] / labels.length;\n    impur -= p*p;\n  }\n  return impur;\n}\n\n// Tree constructor: axis-aligned splits only for speed\nfunction buildTree(X, y, maxDepth=6, minLeaf=3, mtry=1) {\n  // X: array of [x,y], y: labels array\n  function build(indices, depth) {\n    const labels = indices.map(i=>y[i]);\n    const [pred, count] = majorityLabel(labels);\n    const node = { prediction: pred, samples: indices.length };\n    if (depth>=maxDepth || indices.length<=minLeaf || gini(labels)===0) {\n      node.leaf = true;\n      return node;\n    }\n    const features = [];\n    while (features.length < mtry) {\n      const f = Math.floor(Math.random()*2);\n      if (!features.includes(f)) features.push(f);\n    }\n    let best = null;\n    let bestGain = 0;\n    const parentImp = gini(labels);\n    for (const f of features) {\n      // candidate thresholds: midpoints of sorted unique values\n      const vals = indices.map(i=>X[i][f]).sort((a,b)=>a-b);\n      const cand = [];\n      for (let i=1;i<vals.length;i++) {\n        if (vals[i] !== vals[i-1]) cand.push( (vals[i]+vals[i-1])/2 );\n      }\n      // limit number of candidates for speed\n      const step = Math.max(1, Math.floor(cand.length/15));\n      for (let ci=0; ci<cand.length; ci+=step) {\n        const thr = cand[ci];\n        const leftIdx = [];\n        const rightIdx = [];\n        for (const i of indices) {\n          if (X[i][f] <= thr) leftIdx.push(i); else rightIdx.push(i);\n        }\n        if (leftIdx.length < minLeaf || rightIdx.length < minLeaf) continue;\n        const gi = parentImp - (leftIdx.length/indices.length)*gini(leftIdx.map(i=>y[i]))\n                             - (rightIdx.length/indices.length)*gini(rightIdx.map(i=>y[i]));\n        if (gi > bestGain) {\n          bestGain = gi;\n          best = { feature: f, thr, leftIdx, rightIdx };\n        }\n      }\n    }\n    if (!best || bestGain <= 1e-9) {\n      node.leaf = true;\n      return node;\n    }\n    node.feature = best.feature;\n    node.threshold = best.thr;\n    node.left = build(best.leftIdx, depth+1);\n    node.right = build(best.rightIdx, depth+1);\n    node.leaf = false;\n    return node;\n  }\n  const allIdx = Array.from({length:X.length}, (_,i)=>i);\n  return build(allIdx, 0);\n}\n\nfunction predictTree(tree, x) {\n  let node = tree;\n  while (!node.leaf) {\n    if (x[node.feature] <= node.threshold) node = node.left;\n    else node = node.right;\n  }\n  return node.prediction;\n}\n\n// Data generators (normalized to roughly [-1,1] range)\nfunction genBlobs(n=200) {\n  const X=[], y=[];\n  for (let i=0;i<n;i++) {\n    if (i < n/2) {\n      X.push([randn_bm()*0.25 - 0.7, randn_bm()*0.25 + 0.0]);\n      y.push(0);\n    } else {\n      X.push([randn_bm()*0.25 + 0.7, randn_bm()*0.25 + 0.0]);\n      y.push(1);\n    }\n  }\n  return {X,y};\n}\n\nfunction genXOR(n=200) {\n  const X=[], y=[];\n  for (let i=0;i<n;i++) {\n    const x = (Math.random()*2 -1) * 0.9;\n    const yv = (Math.random()*2 -1) * 0.9;\n    const label = (x*yv>0) ? 0 : 1; // quadrants\n    X.push([x,yv]); y.push(label);\n  }\n  return {X,y};\n}\n\nfunction genCircles(n=200) {\n  const X=[], y=[];\n  for (let i=0;i<n;i++) {\n    if (i < n/2) {\n      const r = Math.random()*0.3 + 0.2;\n      const a = Math.random()*Math.PI*2;\n      X.push([Math.cos(a)*r, Math.sin(a)*r]); y.push(0);\n    } else {\n      const r = Math.random()*0.35 + 0.7;\n      const a = Math.random()*Math.PI*2;\n      X.push([Math.cos(a)*r, Math.sin(a)*r]); y.push(1);\n    }\n  }\n  return {X,y};\n}\n\nfunction genMoons(n=200) {\n  const X=[], y=[];\n  for (let i=0;i<n;i++) {\n    if (i < n/2) {\n      const a = Math.random()*Math.PI;\n      const r = 0.4 + (Math.random()-0.5)*0.06;\n      X.push([Math.cos(a)*r - 0.4, Math.sin(a)*r + 0.05]); y.push(0);\n    } else {\n      const a = Math.random()*Math.PI;\n      const r = 0.4 + (Math.random()-0.5)*0.06;\n      X.push([Math.cos(a)*r + 0.4, -Math.sin(a)*r - 0.05]); y.push(1);\n    }\n  }\n  return {X,y};\n}\n\n// Visualization\nconst canvas = document.getElementById('surf');\nconst ctx = canvas.getContext('2d');\n\nconst controls = {\n  dataset: document.getElementById('dataset'),\n  nTrees: document.getElementById('nTrees'),\n  maxDepth: document.getElementById('maxDepth'),\n  minLeaf: document.getElementById('minLeaf'),\n  sampleFrac: document.getElementById('sampleFrac'),\n  mtry: document.getElementById('mtry'),\n  cellSize: document.getElementById('cellSize'),\n  regen: document.getElementById('regen'),\n  train: document.getElementById('train'),\n  showInd: document.getElementById('showInd'),\n  treeIndex: document.getElementById('treeIndex'),\n  treeSelectRow: document.getElementById('treeSelectRow'),\n  nTreesLabel: document.getElementById('nTreesLabel'),\n  maxDepthLabel: document.getElementById('maxDepthLabel'),\n  minLeafLabel: document.getElementById('minLeafLabel'),\n  sampleFracLabel: document.getElementById('sampleFracLabel'),\n  mtryLabel: document.getElementById('mtryLabel'),\n  cellLabel: document.getElementById('cellLabel'),\n  treeIndexLabel: document.getElementById('treeIndexLabel'),\n  accuracy: document.getElementById('accuracy'),\n  treesInfo: document.getElementById('treesInfo')\n};\n\nlet data = genBlobs();\nlet forest = [];\nlet forestSamples = []; // indices used per tree (for potential display)\nlet gridCache = null;\n\nfunction updateLabels() {\n  controls.nTreesLabel.textContent = controls.nTrees.value;\n  controls.maxDepthLabel.textContent = controls.maxDepth.value;\n  controls.minLeafLabel.textContent = controls.minLeaf.value;\n  controls.sampleFracLabel.textContent = (+controls.sampleFrac.value).toFixed(2);\n  controls.mtryLabel.textContent = controls.mtry.value;\n  controls.cellLabel.textContent = controls.cellSize.value;\n  controls.treeIndexLabel.textContent = controls.treeIndex.value;\n}\nupdateLabels();\n\ncontrols.nTrees.addEventListener('input', ()=>{\n  updateLabels();\n  controls.treeIndex.max = Math.max(0, controls.nTrees.value-1);\n  controls.treeIndex.value = Math.min(controls.treeIndex.value, controls.nTrees.value-1);\n});\ncontrols.maxDepth.addEventListener('input', updateLabels);\ncontrols.minLeaf.addEventListener('input', updateLabels);\ncontrols.sampleFrac.addEventListener('input', updateLabels);\ncontrols.mtry.addEventListener('input', updateLabels);\ncontrols.cellSize.addEventListener('input', updateLabels);\ncontrols.treeIndex.addEventListener('input', ()=> { controls.treeIndexLabel.textContent = controls.treeIndex.value; render(); });\n\ncontrols.relay = function(){};\ncontrols.regen.addEventListener('click', ()=>{\n  const ds = controls.dataset.value;\n  if (ds==='blobs') data = genBlobs(220);\n  else if (ds==='xor') data = genXOR(220);\n  else if (ds==='circles') data = genCircles(220);\n  else if (ds==='moons') data = genMoons(220);\n  forest = [];\n  forestSamples = [];\n  gridCache = null;\n  trainForest();\n});\ncontrols.train.addEventListener('click', ()=> {\n  forest = [];\n  forestSamples = [];\n  gridCache = null;\n  trainForest();\n});\n\ncontrols.showInd.addEventListener('change', ()=>{\n  controls.treeSelectRow.style.display = controls.showInd.checked ? 'flex' : 'none';\n  render();\n});\n\ncontrols.dataset.addEventListener('change', ()=>{\n  controls.regen.click();\n});\n\nfunction trainForest() {\n  const X = data.X, y = data.y;\n  const nTrees = +controls.nTrees.value;\n  const maxDepth = +controls.maxDepth.value;\n  const minLeaf = +controls.minLeaf.value;\n  const sampleFrac = +controls.sampleFrac.value;\n  const mtry = +controls.mtry.value;\n  forest = [];\n  forestSamples = [];\n  const start = performance.now();\n  for (let t=0;t<nTrees;t++) {\n    const idx = sampleIndices(X.length, sampleFrac);\n    const Xb = idx.map(i=>X[i]);\n    const yb = idx.map(i=>y[i]);\n    const tree = buildTree(Xb, yb, maxDepth, minLeaf, mtry);\n    // Note: our tree built on resampled Xb expects indices 0..Xb.length-1.\n    // To use original coordinates we will use wrapper prediction that uses Xb.\n    // We'll store mapping.\n    forest.push({ tree, idxMap: idx });\n    forestSamples.push(idx.slice());\n  }\n  const elapsed = Math.round(performance.now()-start);\n  controls.treesInfo.textContent = `Trees: ${nTrees}  (built in ${elapsed} ms)`;\n  computeAccuracy();\n  controls.treeIndex.max = Math.max(0, nTrees-1);\n  controls.treeIndex.value = Math.min(controls.treeIndex.value, nTrees-1);\n  controls.treeIndexLabel.textContent = controls.treeIndex.value;\n  render();\n}\n\nfunction predictForest(x) {\n  // x is [x,y]\n  // Each tree was trained on a bootstrap sample mapped to Xb with indices 0..len-1.\n  // To predict: we need to call predictTree on its tree providing x in same coordinate space (works).\n  // Our tree nodes compare x coordinates; this is fine since tree thresholds are based on sampled values.\n  const votes = {};\n  for (const t of forest) {\n    const p = predictTree(t.tree, x);\n    votes[p] = (votes[p]||0) + 1;\n  }\n  let best=null, bc=-1, total=0;\n  for (const k in votes) { total += votes[k]; if (votes[k] > bc) { best=k; bc=votes[k]; } }\n  return { label: parseInt(best), votes, confidence: (bc/total) };\n}\n\nfunction predictSingleTreeIndex(x, treeIndex) {\n  const t = forest[treeIndex];\n  const p = predictTree(t.tree, x);\n  return p;\n}\n\nfunction computeAccuracy() {\n  if (forest.length===0) { controls.accuracy.textContent = 'Accuracy (train): —'; return; }\n  const X = data.X, y = data.y;\n  let correct = 0;\n  for (let i=0;i<X.length;i++) {\n    const p = predictForest(X[i]).label;\n    if (p===y[i]) correct++;\n  }\n  const acc = (100*correct/X.length).toFixed(1);\n  controls.accuracy.textContent = `Accuracy (train): ${acc}%`;\n}\n\nfunction render() {\n  const width = canvas.width, height = canvas.height;\n  ctx.clearRect(0,0,width,height);\n  // Define view to cover approx [-1.2,1.2] square with margin for data\n  const pad = 0.12;\n  const xs = data.X.map(p=>p[0]);\n  const ys = data.X.map(p=>p[1]);\n  const xmin = Math.min(...xs) - pad;\n  const xmax = Math.max(...xs) + pad;\n  const ymin = Math.min(...ys) - pad;\n  const ymax = Math.max(...ys) + pad;\n\n  const cell = +controls.cellSize.value;\n  const nx = Math.ceil(width / cell);\n  const ny = Math.ceil(height / cell);\n\n  const showInd = controls.showInd.checked;\n  const showTreeIdx = +controls.treeIndex.value;\n\n  // Precompute predictions for grid\n  const img = ctx.createImageData(width, height);\n  for (let gy=0; gy<ny; gy++) {\n    for (let gx=0; gx<nx; gx++) {\n      const px = Math.floor(gx * cell);\n      const py = Math.floor(gy * cell);\n      const cx = xmin + (gx + 0.5)/nx * (xmax-xmin);\n      const cy = ymax - (gy + 0.5)/ny * (ymax-ymin); // flip y\n      let r=255,g=255,b=255,a=255;\n      if (forest.length>0) {\n        if (showInd) {\n          const pred = predictSingleTreeIndex([cx,cy], showTreeIdx);\n          // color by that tree's class\n          if (pred===0) { r=200; g=235; b=255; } else { r=255; g=220; b=230; }\n        } else {\n          const result = predictForest([cx,cy]);\n          const cls = result.label;\n          const conf = result.confidence; // [0.5..1]\n          // color by class; stronger confidence => more saturated\n          if (cls===0) { r = Math.round(200*(1-conf)+50*conf); g = Math.round(235*(1-conf)+150*conf); b = Math.round(255*(1-conf)+60*conf); }\n          else { r = Math.round(255*(1-conf)+220*conf); g = Math.round(220*(1-conf)+80*conf); b = Math.round(230*(1-conf)+80*conf); }\n        }\n      } else {\n        r=245;g=245;b=245;\n      }\n      // Fill block\n      for (let dy=0; dy<cell; dy++) {\n        for (let dx=0; dx<cell; dx++) {\n          const x = px+dx, y = py+dy;\n          if (x>=width || y>=height) continue;\n          const idx = (y*width + x)*4;\n          img.data[idx] = r;\n          img.data[idx+1] = g;\n          img.data[idx+2] = b;\n          img.data[idx+3] = a;\n        }\n      }\n    }\n  }\n  ctx.putImageData(img, 0, 0);\n\n  // Draw training points\n  for (let i=0;i<data.X.length;i++) {\n    const x = data.X[i][0], y = data.X[i][1], label = data.y[i];\n    const px = Math.round((x - xmin)/(xmax-xmin) * width);\n    const py = Math.round((ymax - y)/(ymax-ymin) * height);\n    ctx.beginPath();\n    ctx.fillStyle = label===0 ? 'rgb(10,90,170)' : 'rgb(170,20,40)';\n    ctx.strokeStyle = 'rgba(255,255,255,0.8)';\n    ctx.lineWidth = 1;\n    ctx.arc(px, py, 4, 0, Math.PI*2);\n    ctx.fill();\n    ctx.stroke();\n  }\n\n  // Optionally overlay boundaries of individual tree (outline of partitions) for the chosen tree\n  if (showInd && forest.length>0) {\n    const t = forest[+controls.treeIndex.value].tree;\n    // We can draw the splits recursively onto the canvas by mapping node thresholds -> lines\n    function drawNode(node, xminN, xmaxN, yminN, ymaxN) {\n      if (!node || node.leaf) return;\n      if (node.feature === 0) {\n        // vertical line at threshold\n        const x = (node.threshold - xmin) / (xmax - xmin) * width;\n        ctx.beginPath();\n        ctx.moveTo(x, (1 - (ymaxN - ymin)/(ymax-ymin)) * height);\n        ctx.lineTo(x, (1 - (yminN - ymin)/(ymax-ymin)) * height);\n        ctx.strokeStyle = 'rgba(20,20,20,0.15)';\n        ctx.lineWidth = 1;\n        ctx.stroke();\n        // left and right partitions\n        drawNode(node.left, xminN, node.threshold, yminN, ymaxN);\n        drawNode(node.right, node.threshold, xmaxN, yminN, ymaxN);\n      } else {\n        // horizontal split\n        const y = (ymax - node.threshold) / (ymax - ymin) * height;\n        ctx.beginPath();\n        ctx.moveTo((node.threshold - xmin)/(xmax-xmin)*width, y); // approximate\n        // better: draw line across the current partition\n        const yPx = (ymax - node.threshold) / (ymax - ymin) * height;\n        ctx.beginPath();\n        ctx.moveTo((xminN - xmin)/(xmax-xmin)*width, yPx);\n        ctx.lineTo((xmaxN - xmin)/(xmax-xmin)*width, yPx);\n        ctx.strokeStyle = 'rgba(20,20,20,0.15)';\n        ctx.lineWidth = 1;\n        ctx.stroke();\n        drawNode(node.left, xminN, xmaxN, node.threshold, ymaxN);\n        drawNode(node.right, xminN, xmaxN, yminN, node.threshold);\n      }\n    }\n    drawNode(t, xmin, xmax, ymin, ymax);\n  }\n\n  // Legend\n  ctx.fillStyle = 'rgba(255,255,255,0.8)';\n  ctx.fillRect(8,8,150,42);\n  ctx.fillStyle = 'rgb(10,90,170)'; ctx.beginPath(); ctx.arc(18,24,6,0,Math.PI*2); ctx.fill();\n  ctx.fillStyle = 'rgb(170,20,40)'; ctx.beginPath(); ctx.arc(52,24,6,0,Math.PI*2); ctx.fill();\n  ctx.fillStyle = '#333'; ctx.font = '12px sans-serif'; ctx.fillText('Class 0', 30,28); ctx.fillText('Class 1', 64,28);\n}\n\n// Init\ncontrols.regen.click();\n\n// Small performance tweak: retrain on start; ensure canvas renders\nwindow.addEventListener('resize', ()=> render());\n\n</script>\n</body>\n</html>"
