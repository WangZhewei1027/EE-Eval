    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Max Heap Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 20px;\n        }\n        .controls {\n            margin-bottom: 20px;\n            display: flex;\n            gap: 10px;\n            flex-wrap: wrap;\n            justify-content: center;\n        }\n        button {\n            padding: 8px 16px;\n            cursor: pointer;\n        }\n        input {\n            padding: 8px;\n            width: 60px;\n        }\n        .heap-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-top: 20px;\n        }\n        .heap-level {\n            display: flex;\n            justify-content: center;\n            gap: 40px;\n            margin-bottom: 20px;\n        }\n        .heap-node {\n            width: 50px;\n            height: 50px;\n            border: 2px solid #333;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-weight: bold;\n            background-color: #f0f0f0;\n            position: relative;\n        }\n        .heap-node::before {\n            content: '';\n            position: absolute;\n            width: 2px;\n            background-color: #333;\n            display: none;\n        }\n        .heap-node.left::before {\n            display: block;\n            height: 30px;\n            transform: rotate(-30deg);\n            top: -30px;\n            left: 50%;\n        }\n        .heap-node.right::before {\n            display: block;\n            height: 30px;\n            transform: rotate(30deg);\n            top: -30px;\n            right: 50%;\n        }\n        .array-display {\n            margin-top: 30px;\n            font-size: 18px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            background-color: #f9f9f9;\n        }\n    </style>\n</head>\n<body>\n    <h1>Max Heap Visualization</h1>\n    <div class=\"controls\">\n        <input type=\"number\" id=\"insertValue\" placeholder=\"Value\">\n        <button onclick=\"insertValue()\">Insert</button>\n        <button onclick=\"extractMax()\">Extract Max</button>\n        <button onclick=\"clearHeap()\">Clear Heap</button>\n        <button onclick=\"generateRandomHeap()\">Random Heap</button>\n    </div>\n    <div class=\"heap-container\" id=\"heapContainer\"></div>\n    <div class=\"array-display\">\n        Array representation: <span id=\"arrayDisplay\">[]</span>\n    </div>\n\n    <script>\n        class MaxHeap {\n            constructor() {\n                this.heap = [];\n            }\n\n            parentIndex(index) {\n                return Math.floor((index - 1) / 2);\n            }\n\n            leftChildIndex(index) {\n                return 2 * index + 1;\n            }\n\n            rightChildIndex(index) {\n                return 2 * index + 2;\n            }\n\n            swap(index1, index2) {\n                [this.heap[index1], this.heap[index2]] = [this.heap[index2], this.heap[index1]];\n            }\n\n            insert(value) {\n                this.heap.push(value);\n                this.heapifyUp();\n            }\n\n            heapifyUp() {\n                let currentIndex = this.heap.length - 1;\n                while (currentIndex > 0 && \n                       this.heap[currentIndex] > this.heap[this.parentIndex(currentIndex)]) {\n                    this.swap(currentIndex, this.parentIndex(currentIndex));\n                    currentIndex = this.parentIndex(currentIndex);\n                }\n            }\n\n            extractMax() {\n                if (this.heap.length === 0) return null;\n                const max = this.heap[0];\n                const last = this.heap.pop();\n                if (this.heap.length > 0) {\n                    this.heap[0] = last;\n                    this.heapifyDown();\n                }\n                return max;\n            }\n\n            heapifyDown() {\n                let currentIndex = 0;\n                let nextIndex = null;\n                \n                while (this.leftChildIndex(currentIndex) < this.heap.length) {\n                    const leftIndex = this.leftChildIndex(currentIndex);\n                    const rightIndex = this.rightChildIndex(currentIndex);\n                    \n                    if (rightIndex < this.heap.length && \n                        this.heap[rightIndex] > this.heap[leftIndex]) {\n                        nextIndex = rightIndex;\n                    } else {\n                        nextIndex = leftIndex;\n                    }\n                    \n                    if (this.heap[currentIndex] >= this.heap[nextIndex]) {\n                        break;\n                    }\n                    \n                    this.swap(currentIndex, nextIndex);\n                    currentIndex = nextIndex;\n                }\n            }\n\n            clear() {\n                this.heap = [];\n            }\n\n            generateRandom(size = 10) {\n                this.clear();\n                for (let i = 0; i < size; i++) {\n                    this.insert(Math.floor(Math.random() * 100) + 1);\n                }\n            }\n        }\n\n        const maxHeap = new MaxHeap();\n        const heapContainer = document.getElementById('heapContainer');\n        const arrayDisplay = document.getElementById('arrayDisplay');\n\n        function renderHeap() {\n            heapContainer.innerHTML = '';\n            arrayDisplay.textContent = `[${maxHeap.heap.join(', ')}]`;\n\n            if (maxHeap.heap.length === 0) return;\n\n            // Calculate heap levels and nodes per level\n            let level = 0;\n            let nodesInLevel = 1;\n            let index = 0;\n\n            while (index < maxHeap.heap.length) {\n                const levelContainer = document.createElement('div');\n                levelContainer.className = 'heap-level';\n\n                for (let i = 0; i < nodesInLevel && index < maxHeap.heap.length; i++, index++) {\n                    const node = document.createElement('div');\n                    node.className = 'heap-node';\n                    node.textContent = maxHeap.heap[index];\n\n                    // Add left child connector if exists\n                    const leftChildIndex = maxHeap.leftChildIndex(index);\n                    if (leftChildIndex < maxHeap.heap.length) {\n                        node.classList.add('left');\n                    }\n\n                    // Add right child connector if exists\n                    const rightChildIndex = maxHeap.rightChildIndex(index);\n                    if (rightChildIndex < maxHeap.heap.length) {\n                        node.classList.add('right');\n                    }\n\n                    levelContainer.appendChild(node);\n                }\n\n                heapContainer.appendChild(levelContainer);\n                level++;\n                nodesInLevel *= 2;\n            }\n        }\n\n        function insertValue() {\n            const valueInput = document.getElementById('insertValue');\n            const value = parseInt(valueInput.value);\n            \n            if (!isNaN(value)) {\n                maxHeap.insert(value);\n                renderHeap();\n                valueInput.value = '';\n                valueInput.focus();\n            }\n        }\n\n        function extractMax() {\n            const max = maxHeap.extractMax();\n            if (max !== null) {\n                alert(`Extracted max value: ${max}`);\n                renderHeap();\n            } else {\n                alert('Heap is empty!');\n            }\n        }\n\n        function clearHeap() {\n            maxHeap.clear();\n            renderHeap();\n        }\n\n        function generateRandomHeap() {\n            maxHeap.generateRandom();\n            renderHeap();\n        }\n\n        // Initialize with a small example\n        maxHeap.insert(30);\n        maxHeap.insert(20);\n        maxHeap.insert(10);\n        maxHeap.insert(15);\n        maxHeap.insert(5);\n        maxHeap.insert(25);\n        renderHeap();\n    </script>\n</body>\n</html>"
