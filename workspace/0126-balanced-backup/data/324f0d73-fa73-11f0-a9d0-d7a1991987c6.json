    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>OSI Model Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n\n        h1 {\n            text-align: center;\n        }\n\n        #osiTable {\n            width: 100%;\n            border-collapse: collapse;\n        }\n\n        #osiTable th, #osiTable td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: center;\n        }\n\n        #osiTable th {\n            background-color: #4CAF50;\n            color: white;\n        }\n\n        #osiTable tr:hover {\n            background-color: #f1f1f1;\n        }\n\n        .layer-description {\n            margin: 20px 0;\n            text-align: center;\n        }\n    </style>\n</head>\n\n<body>\n    <h1>Understanding the OSI Model</h1>\n    <table id=\"osiTable\">\n        <tr>\n            <th>Layer</th>\n            <th>Name</th>\n            <th>Function</th>\n        </tr>\n        <tr onclick=\"showDescription('Physical Layer', 'The Physical Layer transmits raw bit streams over a physical medium.')\">\n            <td>1</td>\n            <td>Physical</td>\n            <td>Transmission of raw data</td>\n        </tr>\n        <tr onclick=\"showDescription('Data Link Layer', 'The Data Link Layer provides node-to-node data transfer and handles error correction from the Physical Layer.')\">\n            <td>2</td>\n            <td>Data Link</td>\n            <td>Node-to-node data transfer</td>\n        </tr>\n        <tr onclick=\"showDescription('Network Layer', 'The Network Layer determines the path for data transmission and handles routing of packets.')\">\n            <td>3</td>\n            <td>Network</td>\n            <td>Routing of data</td>\n        </tr>\n        <tr onclick=\"showDescription('Transport Layer', 'The Transport Layer ensures complete data transfer and provides error recovery and flow control.')\">\n            <td>4</td>\n            <td>Transport</td>\n            <td>End-to-end connections</td>\n        </tr>\n        <tr onclick=\"showDescription('Session Layer', 'The Session Layer manages sessions between applications, facilitating communication.')\">\n            <td>5</td>\n            <td>Session</td>\n            <td>Session management</td>\n        </tr>\n        <tr onclick=\"showDescription('Presentation Layer', 'The Presentation Layer translates data formats, encryption, and compression.')\">\n            <td>6</td>\n            <td>Presentation</td>\n            <td>Data translation</td>\n        </tr>\n        <tr onclick=\"showDescription('Application Layer', 'The Application Layer provides network services directly to the user's application.')\">\n            <td>7</td>\n            <td>Application</td>\n            <td>User interface</td>\n        </tr>\n    </table>\n\n    <div id=\"description\" class=\"layer-description\">\n        <h2>Description</h2>\n        <p>Click on a layer to see its description.</p>\n    </div>\n\n    <script>\n        function showDescription(layerName, layerFunction) {\n            document.getElementById('description').innerHTML = `\n                <h2>${layerName}</h2>\n                <p>${layerFunction}</p>\n            `;\n        }\n    </script>\n</body>\n\n</html>"
