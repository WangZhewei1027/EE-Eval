    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Suffix Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        #container {\n            max-width: 900px;\n            margin: 0 auto;\n        }\n        #inputContainer {\n            margin-bottom: 20px;\n        }\n        #inputText {\n            width: 100%;\n            padding: 8px;\n            font-size: 16px;\n        }\n        #buildButton {\n            padding: 8px 16px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            cursor: pointer;\n            font-size: 16px;\n        }\n        #buildButton:hover {\n            background-color: #45a049;\n        }\n        #treeContainer {\n            margin-top: 20px;\n            overflow-x: auto;\n        }\n        .node {\n            fill: #f5f5f5;\n            stroke: #333;\n            stroke-width: 2;\n        }\n        .node text {\n            font-size: 14px;\n            fill: #333;\n        }\n        .link {\n            fill: none;\n            stroke: #999;\n            stroke-width: 2;\n        }\n        .suffix-link {\n            fill: none;\n            stroke: #ff7f0e;\n            stroke-opacity: 0.6;\n            stroke-dasharray: 5,5;\n        }\n        .controls {\n            margin-bottom: 20px;\n        }\n        .explanation {\n            background-color: #f9f9f9;\n            padding: 15px;\n            border-radius: 5px;\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"container\">\n        <h1>Suffix Tree Visualization</h1>\n        \n        <div class=\"explanation\">\n            <h2>What is a Suffix Tree?</h2>\n            <p>A suffix tree is a compressed trie containing all the suffixes of a given text as keys and positions in the text as values. Suffix trees allow fast string operations like pattern searching, finding longest repeated substrings, and more.</p>\n            <p>This visualization shows Ukkonen's online algorithm for building a suffix tree in linear time.</p>\n        </div>\n        \n        <div class=\"controls\">\n            <div id=\"inputContainer\">\n                <label for=\"inputText\">Enter a string (recommend short strings for visualization):</label><br>\n                <input type=\"text\" id=\"inputText\" value=\"banana\" placeholder=\"Enter text to build suffix tree\">\n            </div>\n            <button id=\"buildButton\">Build Suffix Tree</button>\n        </div>\n        \n        <div id=\"treeContainer\">\n            <svg id=\"treeSvg\" width=\"800\" height=\"400\"></svg>\n        </div>\n        \n        <div id=\"infoContainer\"></div>\n    </div>\n\n    <script src=\"https://d3js.org/d3.v7.min.js\"></script>\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const buildButton = document.getElementById('buildButton');\n            const inputText = document.getElementById('inputText');\n            const treeSvg = document.getElementById('treeSvg');\n            const infoContainer = document.getElementById('infoContainer');\n            \n            buildButton.addEventListener('click', function() {\n                const text = inputText.value;\n                if (!text || text.length === 0) {\n                    alert('Please enter some text');\n                    return;\n                }\n                \n                // Add termination character\n                const str = text + '$';\n                const tree = buildSuffixTree(str);\n                visualizeTree(tree, str);\n                \n                infoContainer.innerHTML = `\n                    <h3>Suffix Tree Information</h3>\n                    <p>Text: ${text} (termination character '$' added)</p>\n                    <p>Number of nodes: ${countNodes(tree.root)}</p>\n                    <p>Suffixes in the tree:</p>\n                    <ul>${getAllSuffixes(tree.root, str).map(s => `<li>${s}</li>`).join('')}</ul>\n                `;\n            });\n            \n            // Initialize with default example\n            buildButton.click();\n        });\n        \n        // Suffix Tree implementation\n        \n        class SuffixTreeNode {\n            constructor(id) {\n                this.id = id; // Unique identifier for the node\n                this.children = {};\n                this.suffixLink = null;\n                this.start = null;\n                this.end = null;\n                this.suffixIndex = -1;\n            }\n            \n            get length() {\n                if (this.end === Infinity) {\n                    return Infinity;\n                }\n                return this.end - this.start + 1;\n            }\n        }\n        \n        class SuffixTree {\n            constructor() {\n                this.root = new SuffixTreeNode(0);\n                this.root.suffixLink = this.root; // Root links to itself\n                this.size = 1; // Counter for node IDs\n                this.activeNode = this.root;\n                this.activeEdge = -1;\n                this.activeLength = 0;\n                this.remaining = 0;\n                this.leafEnd = Infinity;\n                this.lastNewNode = null;\n            }\n            \n            newNode() {\n                return new SuffixTreeNode(this.size++);\n            }\n        }\n        \n        function buildSuffixTree(str) {\n            const tree = new SuffixTree();\n            const n = str.length;\n            \n            for (let i = 0; i < n; i++) {\n                extendSuffixTree(tree, str, i);\n            }\n            \n            setSuffixIndices(tree.root, str, 0);\n            return tree;\n        }\n        \n        function extendSuffixTree(tree, str, pos) {\n            tree.leafEnd = pos;\n            tree.remaining++;\n            tree.lastNewNode = null;\n            \n            while (tree.remaining > 0) {\n                if (tree.activeLength === 0) {\n                    tree.activeEdge = pos;\n                }\n                \n                const activeChar = str[tree.activeEdge];\n                \n                if (!tree.activeNode.children[activeChar]) {\n                    // Rule 2: Create new leaf node\n                    const newNode = tree.newNode();\n                    newNode.start = pos;\n                    newNode.end = tree.leafEnd;\n                    tree.activeNode.children[activeChar] = newNode;\n                    \n                    if (tree.lastNewNode !== null) {\n                        tree.lastNewNode.suffixLink = tree.activeNode;\n                        tree.lastNewNode = null;\n                    }\n                } else {\n                    const nextNode = tree.activeNode.children[activeChar];\n                    const edgeLength = nextNode.length;\n                    \n                    if (tree.activeLength >= edgeLength) {\n                        // Skip ahead in the tree\n                        tree.activeEdge += edgeLength;\n                        tree.activeLength -= edgeLength;\n                        tree.activeNode = nextNode;\n                        continue;\n                    }\n                    \n                    // Rule 3: current character already in tree\n                    if (str[nextNode.start + tree.activeLength] === str[pos]) {\n                        if (tree.lastNewNode !== null && tree.activeNode !== tree.root) {\n                            tree.lastNewNode.suffixLink = tree.activeNode;\n                            tree.lastNewNode = null;\n                        }\n                        \n                        tree.activeLength++;\n                        break;\n                    }\n                    \n                    // Rule 2 when mismatch occurs in middle of edge\n                    const splitNode = tree.newNode();\n                    splitNode.start = nextNode.start;\n                    splitNode.end = nextNode.start + tree.activeLength - 1;\n                    \n                    // Update the existing node\n                    nextNode.start = nextNode.start + tree.activeLength;\n                    \n                    // Add the split node between active node and next node\n                    tree.activeNode.children[activeChar] = splitNode;\n                    splitNode.children[str[nextNode.start]] = nextNode;\n                    \n                    // Create new leaf node for the current character\n                    const newLeaf = tree.newNode();\n                    newLeaf.start = pos;\n                    newLeaf.end = tree.leafEnd;\n                    splitNode.children[str[pos]] = newLeaf;\n                    \n                    if (tree.lastNewNode !== null) {\n                        tree.lastNewNode.suffixLink = splitNode;\n                    }\n                    \n                    tree.lastNewNode = splitNode;\n                }\n                \n                tree.remaining--;\n                \n                if (tree.activeNode === tree.root && tree.activeLength > 0) {\n                    tree.activeLength--;\n                    tree.activeEdge = pos - tree.remaining + 1;\n                } else if (tree.activeNode !== tree.root) {\n                    tree.activeNode = tree.activeNode.suffixLink;\n                }\n            }\n        }\n        \n        function setSuffixIndices(node, str, labelHeight) {\n            if (!node) return;\n            \n            let isLeaf = true;\n            for (const child in node.children) {\n                isLeaf = false;\n                const childNode = node.children[child];\n                setSuffixIndices(childNode, str, labelHeight + childNode.length);\n            }\n            \n            if (isLeaf) {\n                node.suffixIndex = str.length - labelHeight;\n            }\n        }\n        \n        function countNodes(node) {\n            if (!node) return 0;\n            let count = 1;\n            for (const child in node.children) {\n                count += countNodes(node.children[child]);\n            }\n            return count;\n        }\n        \n        function getAllSuffixes(node, str, currentString = \"\") {\n            if (!node) return [];\n            \n            let suffixes = [];\n            if (node.suffixIndex !== -1) {\n                suffixes.push(currentString);\n                return suffixes;\n            }\n            \n            for (const child in node.children) {\n                const childNode = node.children[child];\n                const start = childNode.start;\n                const end = Math.min(childNode.end, str.length - 1);\n                const edgeString = str.substring(start, end + 1);\n                suffixes = suffixes.concat(getAllSuffixes(childNode, str, currentString + edgeString));\n            }\n            \n            return suffixes;\n        }\n        \n        // Visualization code\n        \n        function visualizeTree(tree, str) {\n            // Clear previous tree\n            d3.select(\"#treeSvg\").selectAll(\"*\").remove();\n            const svg = d3.select(\"#treeSvg\");\n            const width = +svg.attr(\"width\");\n            const height = +svg.attr(\"height\");\n            \n            // Create a hierarchical layout\n            const rootNode = prepareHierarchicalData(tree.root, str);\n            const root = d3.hierarchy(rootNode);\n            \n            // Create a tree layout\n            const treeLayout = d3.tree().size([width - 100, height - 100]);\n            treeLayout(root);\n            \n            // Draw links\n            svg.selectAll(\".link\")\n                .data(root.links())\n                .enter().append(\"path\")\n                .attr(\"class\", \"link\")\n                .attr(\"d\", d3.linkVertical()\n                    .x(d => d.x + 50)\n                    .y(d => d.y + 50));\n            \n            // Draw suffix links\n            svg.selectAll(\".suffix-link\")\n                .data(getSuffixLinks(root, str))\n                .enter().append(\"path\")\n                .attr(\"class\", \"suffix-link\")\n                .attr(\"d\", d => {\n                    return d3.linkVertical()\n                        .x(d => d.x + 50)\n                        .y(d => d.y + 50)({\n                            source: [d.source.x, d.source.y],\n                            target: [d.target.x, d.target.y]\n                        });\n                });\n            \n            // Draw nodes\n            const nodes = svg.selectAll(\".node\")\n                .data(root.descendants())\n                .enter().append(\"g\")\n                .attr(\"class\", \"node\")\n                .attr(\"transform\", d => `translate(${d.x + 50},${d.y + 50})`);\n            \n            nodes.append(\"circle\")\n                .attr(\"r\", 15)\n                .attr(\"class\", \"node\");\n            \n            nodes.append(\"text\")\n                .attr(\"dy\", \".35em\")\n                .attr(\"text-anchor\", \"middle\")\n                .style(\"fill\", \"black\")\n                .text(d => d.data.id);\n            \n            // Add edge labels\n            svg.selectAll(\".edgelabel\")\n                .data(root.links())\n                .enter().append(\"text\")\n                .attr(\"class\", \"edgelabel\")\n                .attr(\"x\", d => (d.target.x + d.source.x) / 2 + 50)\n                .attr(\"y\", d => (d.target.y + d.source.y) / 2 + 45)\n                .attr(\"text-anchor\", \"middle\")\n                .text(d => d.target.data.edgeLabel);\n            \n            // Add tooltips\n            nodes.append(\"title\")\n                .text(d => {\n                    let info = `Node ${d.data.id}`;\n                    if (d.data.suffixIndex !== -1) {\n                        info += `\\nSuffix Index: ${d.data.suffixIndex}`;\n                    }\n                    if (d.data.suffixLink !== null) {\n                        info += `\\nSuffix Link: Node ${d.data.suffixLink.id}`;\n                    }\n                    return info;\n                });\n        }\n        \n        function prepareHierarchicalData(node, str, parentId = null) {\n            const treeNode = {\n                id: node.id,\n                edgeLabel: \"\",\n                suffixIndex: node.suffixIndex,\n                children: [],\n                suffixLink: node.suffixLink\n            };\n            \n            if (parentId !== null) {\n                const start = node.start;\n                const end = Math.min(node.end, str.length - 1);\n                treeNode.edgeLabel = str.substring(start, end + 1);\n            }\n            \n            for (const key in node.children) {\n                const child = node.children[key];\n                treeNode.children.push(prepareHierarchicalData(child, str, node.id));\n            }\n            \n            return treeNode;\n        }\n        \n        function getSuffixLinks(hierarchicalRoot, str) {\n            const links = [];\n            const nodes = hierarchicalRoot.descendants();\n            \n            nodes.forEach(node => {\n                if (node.data.suffixLink && node.data.suffixLink !== node) {\n                    const target = nodes.find(n => n.data.id === node.data.suffixLink.id);\n                    if (target) {\n                        links.push({\n                            source: node,\n                            target: target\n                        });\n                    }\n                }\n            });\n            \n            return links;\n        }\n    </script>\n</body>\n</html>"
