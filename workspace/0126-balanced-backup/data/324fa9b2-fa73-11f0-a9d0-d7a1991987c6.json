    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Abstract Syntax Tree Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        #output { margin-top: 20px; }\n        .node { margin-left: 20px; }\n        .node-label { font-weight: bold; }\n    </style>\n</head>\n<body>\n    <h1>Abstract Syntax Tree Demo</h1>\n    <p>Type an arithmetic expression below to see its Abstract Syntax Tree (AST).</p>\n    <input type=\"text\" id=\"expression\" placeholder=\"Enter expression (e.g., 3 + 5)\" />\n    <button id=\"generateAST\">Generate AST</button>\n    \n    <div id=\"output\"></div>\n\n    <script>\n        document.getElementById('generateAST').addEventListener('click', function() {\n            const expression = document.getElementById('expression').value;\n            const ast = generateAST(expression);\n            displayAST(ast);\n        });\n\n        function generateAST(expression) {\n            // Simple tokenization and AST generation for basic arithmetic expressions\n            const tokens = tokenize(expression);\n            return parse(tokens);\n        }\n\n        function tokenize(expression) {\n            const regex = /\\s*(=>|{|}|[()\\-+*\\/]|\\d+)\\s*/g;\n            let tokens = [];\n            let match;\n            while (match = regex.exec(expression)) {\n                if (match[1]) {\n                    tokens.push(match[1]);\n                }\n            }\n            return tokens;\n        }\n\n        function parse(tokens) {\n            // Simple parsing for demonstration, handle + and - operators\n            let index = 0;\n\n            function parseExpression() {\n                let left = parseTerm();\n                while (index < tokens.length && (tokens[index] === '+' || tokens[index] === '-')) {\n                    const operator = tokens[index++];\n                    const right = parseTerm();\n                    left = { type: 'BinaryExpression', operator, left, right };\n                }\n                return left;\n            }\n\n            function parseTerm() {\n                const token = tokens[index++];\n                if (!isNaN(token)) {\n                    return { type: 'Literal', value: Number(token) };\n                }\n                throw new Error('Unexpected token: ' + token);\n            }\n\n            return parseExpression();\n        }\n\n        function displayAST(ast, outputDiv = document.getElementById('output')) {\n            outputDiv.innerHTML = '';\n            const tree = createTreeElement(ast);\n            outputDiv.appendChild(tree);\n        }\n\n        function createTreeElement(node) {\n            const div = document.createElement('div');\n            div.className = 'node';\n            div.innerHTML = `<span class=\"node-label\">${node.type}</span>`;\n\n            for (const key in node) {\n                if (node.hasOwnProperty(key) && key !== 'type') {\n                    const child = createTreeElement(node[key]);\n                    div.appendChild(child);\n                }\n            }\n            return div;\n        }\n    </script>\n</body>\n</html>"
