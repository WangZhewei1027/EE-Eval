  "question": "Priority Queue",
  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Priority Queue</title>\n    <style>\n        #priority-queue {\n            border: 1px solid black;\n            padding: 10px;\n            width: 300px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Priority Queue</h1>\n    <button id=\"add-queue\">Add Element</button>\n    <button id=\"remove-queue\">Remove Element</button>\n    <button id=\"peek-queue\">Peek Element</button>\n    <button id=\"display-queue\">Display Queue</button>\n    <div id=\"priority-queue\"></div>\n\n    <script>\n        class PriorityQueue {\n            constructor() {\n                this.queue = [];\n            }\n\n            enqueue(element, priority) {\n                this.queue.push([element, priority]);\n                this.queue.sort((a, b) => a[1] - b[1]);\n            }\n\n            dequeue() {\n                return this.queue.shift();\n            }\n\n            peek() {\n                return this.queue[0][0];\n            }\n\n            display() {\n                return this.queue.map(element => `${element} (${element[1]})`).join('\\n');\n            }\n        }\n\n        let queue = new PriorityQueue();\n\n        document.getElementById('add-queue').addEventListener('click', () => {\n            let element = prompt('Enter an element:');\n            if (element) {\n                queue.enqueue(element, 1);\n                document.getElementById('priority-queue').innerHTML += `<p>${element} (Priority: 1)</p>`;\n            }\n        });\n\n        document.getElementById('remove-queue').addEventListener('click', () => {\n            let element = prompt('Enter an element:');\n            if (element) {\n                let removed = queue.dequeue();\n                document.getElementById('priority-queue').innerHTML += `<p>${removed} (${removed[1]})</p>`;\n                if (removed[0] === element) {\n                    document.getElementById('priority-queue').innerHTML += `<p>Removed: ${element}</p>`;\n                }\n            }\n        });\n\n        document.getElementById('peek-queue').addEventListener('click', () => {\n            if (queue.queue.length > 0) {\n                document.getElementById('priority-queue').innerHTML += `<p>${queue.peek()} (${queue.peek()[1]})</p>`;\n            } else {\n                document.getElementById('priority-queue').innerHTML += `<p>No elements in the queue</p>`;\n            }\n        });\n\n        document.getElementById('display-queue').addEventListener('click', () => {\n            document.getElementById('priority-queue').innerHTML = queue.display();\n        });\n    </script>\n</body>\n</html>"
  },
