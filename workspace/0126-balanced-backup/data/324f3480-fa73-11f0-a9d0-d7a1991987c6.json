    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>HTTP Demonstration</title>\n    <script>\n        function makeRequest() {\n            // Create a new XMLHttpRequest object\n            const xhr = new XMLHttpRequest();\n\n            // Configure it: GET-request for the URL\n            const url = 'https://jsonplaceholder.typicode.com/posts/1'; // Example endpoint\n            xhr.open('GET', url, true);\n\n            // Set up a function to handle the response\n            xhr.onload = function () {\n                if (xhr.status >= 200 && xhr.status < 300) {\n                    // Successfully received a response\n                    const response = JSON.parse(xhr.responseText);\n                    document.getElementById('result').innerText = \n                        `Title: ${response.title}\\nBody: ${response.body}`;\n                } else {\n                    // Handle errors\n                    document.getElementById('result').innerText = \n                        `Error: ${xhr.status} - ${xhr.statusText}`;\n                }\n            };\n\n            // Handle network errors\n            xhr.onerror = function () {\n                document.getElementById('result').innerText = \n                    'Network Error';\n            };\n\n            // Send the request\n            xhr.send();\n        }\n    </script>\n</head>\n<body>\n    <h1>HTTP Request Demonstration</h1>\n    <button onclick=\"makeRequest()\">Send HTTP GET Request</button>\n    <pre id=\"result\" style=\"margin-top: 20px; background: #f3f3f3; padding: 10px;\"></pre>\n</body>\n</html>"
