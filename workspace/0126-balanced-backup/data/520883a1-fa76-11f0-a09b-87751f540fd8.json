    "content": "<html>\n<head>\n    <title>Heap (Min)</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #heap {\n            width: 50%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #heap h1 {\n            margin-top: 0;\n        }\n        #heap p {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Heap (Min)</h1>\n    <div id=\"heap\"></div>\n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        class Heap {\n            constructor() {\n                this.root = null;\n            }\n\n            parent(i) {\n                return Math.floor((i - 1) / 2);\n            }\n\n            leftChild(i) {\n                return 2 * i + 1;\n            }\n\n            rightChild(i) {\n                return 2 * i + 2;\n            }\n\n            swap(i, j) {\n                [this[i], this[j]] = [this[j], this[i]];\n            }\n\n            insert(value) {\n                this.root = this.insertNode(this.root, value);\n            }\n\n            insertNode(node, value) {\n                if (!node) {\n                    return new Node(value);\n                }\n\n                if (value < node.value) {\n                    node.left = this.insertNode(node.left, value);\n                    this.heapifyUp(node);\n                } else {\n                    node.right = this.insertNode(node.right, value);\n                    this.heapifyUp(node);\n                }\n\n                return node;\n            }\n\n            heapifyUp(node) {\n                let parentIndex = this.parent(node.index);\n                if (node.value < this[parentIndex].value) {\n                    this.swap(node.index, parentIndex);\n                    this.heapifyUp(parentIndex);\n                }\n            }\n\n            printHeap() {\n                let output = \"\";\n                let queue = [this.root];\n                while (queue.length > 0) {\n                    let node = queue.shift();\n                    output += `${node.value} `;\n                    if (node.left) {\n                        queue.push(node.left);\n                    }\n                    if (node.right) {\n                        queue.push(node.right);\n                    }\n                }\n                return output;\n            }\n        }\n\n        let heap = new Heap();\n        heap.insert(5);\n        heap.insert(3);\n        heap.insert(8);\n        heap.insert(1);\n        heap.insert(4);\n        heap.insert(7);\n        heap.insert(2);\n        heap.insert(6);\n        heap.insert(9);\n\n        console.log(\"Heap (Min):\", heap.printHeap());\n    </script>\n</body>\n</html>"
