    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Monitor Concept Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    padding: 1rem;\n    background: #f0f0f0;\n  }\n  h1 {\n    text-align: center;\n  }\n  #log {\n    background: #222;\n    color: #0f0;\n    font-family: monospace;\n    padding: 1rem;\n    height: 300px;\n    overflow-y: auto;\n    border-radius: 5px;\n    margin-bottom: 1rem;\n  }\n  button {\n    margin: 0 0.5rem;\n    padding: 0.5rem 1rem;\n    font-size: 1rem;\n  }\n</style>\n</head>\n<body>\n<h1>Monitor Concept Demonstration</h1>\n<p>This example simulates a <strong>Monitor</strong> — a high-level synchronization construct allowing threads (or async tasks) to have mutually exclusive access to shared data and use condition variables.</p>\n<p>We use a <code>Monitor</code> class that supports <code>enter()</code> (to lock), <code>leave()</code> (to unlock), and <code>wait()</code>/<code>notify()</code> methods for condition waiting/notifications.</p>\n<div id=\"log\"></div>\n<button id=\"startBtn\">Start Threads</button>\n<button id=\"notifyBtn\" disabled>Notify One</button>\n<button id=\"notifyAllBtn\" disabled>Notify All</button>\n\n<script>\n/**\n * Monitor class simulating mutual exclusion and condition variable using async/await.\n * \n * enter(): acquire the monitor's lock.\n * leave(): release the lock.\n * wait(): release the lock and wait for a notification, then reacquire.\n * notify(): wake up one waiting task.\n * notifyAll(): wake up all waiting tasks.\n */\nclass Monitor {\n  constructor() {\n    this._locked = false;\n    this._waitingQueue = [];\n    this._conditionQueue = [];\n  }\n\n  // Acquires the monitor lock, waiting if already locked.\n  async enter() {\n    if (!this._locked) {\n      this._locked = true;\n      return;\n    }\n    // Wait in line until lock is free\n    await new Promise(resolve => this._waitingQueue.push(resolve));\n    this._locked = true;\n  }\n\n  // Releases the monitor lock and wakes one from waiting queue if any\n  leave() {\n    this._locked = false;\n    if (this._waitingQueue.length > 0) {\n      const nextResolve = this._waitingQueue.shift();\n      nextResolve();\n    }\n  }\n\n  // Wait inside the monitor on a \"condition variable\".\n  // Releases the lock and returns a Promise that resolves when notified\n  async wait() {\n    this.leave();\n\n    await new Promise(resolve => this._conditionQueue.push(resolve));\n\n    // Whenever notified, reacquire lock before continuing\n    await this.enter();\n  }\n\n  // Wakes one waiter on the condition variable\n  notify() {\n    if (this._conditionQueue.length > 0) {\n      const toNotify = this._conditionQueue.shift();\n      toNotify();\n    }\n  }\n\n  // Wakes all waiters on the condition variable\n  notifyAll() {\n    while (this._conditionQueue.length > 0) {\n      const toNotify = this._conditionQueue.shift();\n      toNotify();\n    }\n  }\n}\n\n// Utility logging with timestamp\nfunction log(msg) {\n  const logDiv = document.getElementById('log');\n  const now = new Date().toLocaleTimeString();\n  logDiv.textContent += `[${now}] ${msg}\\n`;\n  logDiv.scrollTop = logDiv.scrollHeight;\n}\n\n// Demonstration: A shared resource and \"worker threads\" that must enter Monitor to access.\n// They wait when resource is not ready and get notified when it is.\n\nconst monitor = new Monitor();\n\nlet sharedResourceReady = false;\n\nasync function worker(id) {\n  await monitor.enter();\n  log(`Worker #${id}: Entered monitor.`);\n\n  while (!sharedResourceReady) {\n    log(`Worker #${id}: Resource not ready, waiting...`);\n    await monitor.wait();\n    log(`Worker #${id}: Notified, rechecking resource.`);\n  }\n\n  log(`Worker #${id}: Resource ready! Processing...`);\n  // Simulate some work with resource\n  await new Promise(r => setTimeout(r, 1000));\n  log(`Worker #${id}: Done processing.`);\n  monitor.leave();\n}\n\nfunction resetDemo() {\n  sharedResourceReady = false;\n  document.getElementById('notifyBtn').disabled = false;\n  document.getElementById('notifyAllBtn').disabled = false;\n  document.getElementById('startBtn').disabled = false;\n  document.getElementById('log').textContent = '';\n}\n\ndocument.getElementById('startBtn').addEventListener('click', () => {\n  resetDemo();\n  log('Starting workers...');\n  // Launch 3 workers asynchronously\n  for (let i = 1; i <= 3; i++) {\n    worker(i);\n  }\n  document.getElementById('startBtn').disabled = true;\n});\n\ndocument.getElementById('notifyBtn').addEventListener('click', async () => {\n  await monitor.enter();\n  sharedResourceReady = true;\n  log('Main: Shared resource set to ready. Notifying one worker.');\n  monitor.notify();\n  monitor.leave();\n});\n\ndocument.getElementById('notifyAllBtn').addEventListener('click', async () => {\n  await monitor.enter();\n  sharedResourceReady = true;\n  log('Main: Shared resource set to ready. Notifying ALL workers.');\n  monitor.notifyAll();\n  monitor.leave();\n});\n</script>\n</body>\n</html>"
