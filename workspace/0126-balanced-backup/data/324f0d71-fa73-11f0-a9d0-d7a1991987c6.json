    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Transaction Concept Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n        .transaction-container {\n            background: white;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n            padding: 20px;\n            max-width: 400px;\n            margin: auto;\n        }\n        .transaction {\n            margin-bottom: 10px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 3px;\n        }\n        button {\n            padding: 10px;\n            background-color: #28a745;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #218838;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"transaction-container\">\n    <h2>Transaction Demonstration</h2>\n    <div id=\"transactions\"></div>\n    <button id=\"processTransaction\">Process Transaction</button>\n</div>\n\n<script>\n    const transactions = [\n        { id: 1, amount: 100, type: 'deposit' },\n        { id: 2, amount: 50, type: 'withdrawal' },\n        { id: 3, amount: 200, type: 'deposit' },\n        { id: 4, amount: 25, type: 'withdrawal' }\n    ];\n\n    function displayTransactions() {\n        const transactionsDiv = document.getElementById('transactions');\n        transactionsDiv.innerHTML = ''; // Clear current transactions\n        transactions.forEach(transaction => {\n            const transactionElement = document.createElement('div');\n            transactionElement.classList.add('transaction');\n            transactionElement.innerText = `Transaction ID: ${transaction.id}, Type: ${transaction.type}, Amount: $${transaction.amount}`;\n            transactionsDiv.appendChild(transactionElement);\n        });\n    }\n\n    function processTransaction() {\n        try {\n            if (transactions.length === 0) {\n                throw new Error(\"No transactions to process\");\n            }\n\n            // Simulating the processing of each transaction\n            transactions.forEach(transaction => {\n                if (transaction.type === 'deposit') {\n                    console.log(`Deposited $${transaction.amount}`);\n                } else if (transaction.type === 'withdrawal') {\n                    console.log(`Withdrew $${transaction.amount}`);\n                } else {\n                    throw new Error(\"Unknown transaction type\");\n                }\n            });\n\n            alert('All transactions processed successfully!');\n        } catch (error) {\n            console.error(error);\n            alert('Error processing transactions: ' + error.message);\n        }\n    }\n\n    document.getElementById('processTransaction').addEventListener('click', processTransaction);\n    displayTransactions();\n</script>\n\n</body>\n</html>"
