    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>A* Search</title>\n    <style>\n        #grid {\n            display: grid;\n            grid-template-columns: repeat(10, 1fr);\n            gap: 10px;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        \n        .cell {\n            background-color: #f0f0f0;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            cursor: pointer;\n        }\n        \n        .cell.selected {\n            background-color: #4CAF50;\n            color: #fff;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"grid\"></div>\n    <script>\n        let grid = document.getElementById('grid');\n        let cells = [];\n        let start;\n        let end;\n        let path;\n        let aStar = false;\n\n        function createGrid() {\n            cells = [];\n            for (let i = 0; i < 50; i++) {\n                let row = [];\n                for (let j = 0; j < 50; j++) {\n                    row.push('<div class=\"cell\" id=\"cell' + i + ',' + j + '\"></div>');\n                }\n                cells.push(row);\n            }\n        }\n\n        function createStartAndEnd() {\n            start = 0;\n            end = 49;\n            cells[start].classList.add('selected');\n            cells[end].classList.add('selected');\n        }\n\n        function dijkstra(start) {\n            let distances = {};\n            for (let i = 0; i < 50; i++) {\n                distances[i] = Infinity;\n            }\n            distances[start] = 0;\n            let queue = [start];\n            while (queue.length > 0) {\n                let current = queue.shift();\n                for (let i = 0; i < 50; i++) {\n                    if (distances[i] > distances[current] + 1) {\n                        distances[i] = distances[current] + 1;\n                        queue.push(i);\n                    }\n                }\n            }\n            return distances;\n        }\n\n        function aStar(start, end) {\n            let distances = dijkstra(start);\n            path = [];\n            let current = end;\n            while (current !== start) {\n                path.push(current);\n                for (let i = 49; i >= 0; i--) {\n                    if (cells[i].querySelector('.selected').classList.contains('selected')) {\n                        current = i;\n                        break;\n                    }\n                }\n            }\n            path.push(start);\n            path.reverse();\n            return path;\n        }\n\n        createGrid();\n        createStartAndEnd();\n\n        let startButton = document.createElement('button');\n        startButton.textContent = 'Start';\n        startButton.addEventListener('click', function() {\n            start = parseInt(startButton.textContent);\n            startButton.textContent = 'End';\n            end = parseInt(startButton.textContent);\n            startButton.textContent = 'Start';\n            aStar = true;\n            grid.innerHTML = '';\n            for (let i = 0; i < 50; i++) {\n                for (let j = 0; j < 50; j++) {\n                    let cell = document.createElement('div');\n                    cell.classList.add('cell');\n                    cell.id = 'cell' + i + ',' + j;\n                    grid.appendChild(cell);\n                }\n            }\n            startButton.textContent = 'Start';\n            startButton.addEventListener('click', function() {\n                if (aStar) {\n                    path = aStar(start, end);\n                    console.log(path);\n                    for (let i = 0; i < path.length - 1; i++) {\n                        let row = path[i].split(',');\n                        let cell = document.getElementById(row.join(','));\n                        cell.style.background = 'red';\n                    }\n                    let row = path[path.length - 1].split(',');\n                    let cell = document.getElementById(row.join(','));\n                    cell.style.background = 'blue';\n                }\n            });\n        });\n    </script>\n</body>\n</html>"
