    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Context Switching</title>\n    <style>\n        body {\n            font-family: monospace;\n            font-size: 12px;\n            background-color: #f0f0f0;\n        }\n        .text {\n            background-color: #c9e4ca;\n            padding: 5px 10px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            margin-bottom: 10px;\n        }\n        .text.success {\n            background-color: #c9e4ca;\n            color: #33cc33;\n        }\n        .text.error {\n            background-color: #ff9900;\n            color: #fff;\n        }\n    </style>\n</head>\n<body>\n    <h1>Context Switching</h1>\n    <button onclick=\"switchContext()\">Switch Context</button>\n    <div id=\"context1\" class=\"text success\"></div>\n    <div id=\"context2\" class=\"text error\"></div>\n    <script>\n        let currentContext = \"context1\";\n        const contextElements = document.querySelectorAll(\".text\");\n\n        function switchContext() {\n            if (currentContext === \"context1\") {\n                contextElements[0].style.backgroundColor = \"#c9e4ca\";\n                contextElements[0].classList.add(\"success\");\n                contextElements[1].style.backgroundColor = \"#ff9900\";\n                contextElements[1].classList.add(\"error\");\n                currentContext = \"context2\";\n            } else {\n                contextElements[0].style.backgroundColor = \"#ff9900\";\n                contextElements[0].classList.add(\"error\");\n                contextElements[1].style.backgroundColor = \"#c9e4ca\";\n                contextElements[1].classList.add(\"success\");\n                currentContext = \"context1\";\n            }\n        }\n    </script>\n</body>\n</html>"
