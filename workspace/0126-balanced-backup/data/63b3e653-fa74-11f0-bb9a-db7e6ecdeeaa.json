    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Abstract Syntax Tree (AST) Demonstration</title>\n<style>\n  body {\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen,\n      Ubuntu, Cantarell, \"Open Sans\", \"Helvetica Neue\", sans-serif;\n    margin: 0;\n    padding: 1rem;\n    background: #f5f5f7;\n    color: #222;\n  }\n  h1 {\n    text-align: center;\n  }\n  .container {\n    max-width: 960px;\n    margin: 0 auto;\n  }\n  label {\n    font-weight: 600;\n    display: block;\n    margin: 1rem 0 0.25rem 0;\n  }\n  textarea {\n    width: 100%;\n    height: 6em;\n    font-family: monospace;\n    font-size: 1rem;\n    padding: 0.5rem;\n    border-radius: 4px;\n    border: 1px solid #ccc;\n    resize: vertical;\n  }\n  button {\n    margin-top: 0.8rem;\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    border: none;\n    border-radius: 4px;\n    background: #007acc;\n    color: white;\n    cursor: pointer;\n  }\n  button:hover {\n    background: #005fa3;\n  }\n  pre {\n    background: #272822;\n    color: #f8f8f2;\n    overflow-x: auto;\n    padding: 1rem;\n    border-radius: 5px;\n    margin-top: 1rem;\n    font-size: 0.9rem;\n    max-height: 400px;\n  }\n  .explanation {\n    background: #e0f0ff;\n    border-left: 4px solid #007acc;\n    padding: 1rem 1.2rem;\n    margin-top: 1.5rem;\n    border-radius: 4px;\n    line-height: 1.4;\n  }\n  .ast-node {\n    font-family: monospace;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Abstract Syntax Tree (AST) Demonstration</h1>\n  <p>\n    Enter a simple JavaScript expression and see its Abstract Syntax Tree representation.\n    An Abstract Syntax Tree is a tree representation of source code structure, where each node \n    represents a construct occurring in the source code.\n  </p>\n  <label for=\"codeInput\">JavaScript Expression</label>\n  <textarea id=\"codeInput\" spellcheck=\"false\">// Example: a + b * (c - 2)\na + b * (c - 2)\n</textarea>\n  <button id=\"parseBtn\">Parse to AST</button>\n  <label for=\"astOutput\">AST Output (JSON)</label>\n  <pre id=\"astOutput\" aria-live=\"polite\" aria-atomic=\"true\"></pre>\n  <div class=\"explanation\" id=\"explanation\">\n    <strong>What is an AST?</strong><br />\n    An <em>Abstract Syntax Tree</em> (AST) is a tree that represents the syntactic structure of\n    code. It abstracts away punctuation and formatting and focuses on the logical structure.\n  </div>\n</div>\n\n<script>\n(() => {\n  'use strict';\n\n  // Simple parser for arithmetic expressions producing a basic AST.\n  // This parser handles:\n  // - variables: letters and underscores\n  // - numbers: integers only\n  // - operators: +, -, *, /\n  // - parentheses for grouping\n  //\n  // It produces an AST in a form similar to ESTree for expressions:\n  // - type: 'BinaryExpression'\n  // - type: 'Identifier'\n  // - type: 'Literal'\n  //\n  // This is a recursive descent parser.\n\n  const PRECEDENCE = {\n    '+': 1,\n    '-': 1,\n    '*': 2,\n    '/': 2,\n  };\n\n  function tokenize(input) {\n    const tokens = [];\n    const WHITESPACE = /\\s/;\n    const NUMBERS = /[0-9]/;\n    const LETTERS = /[a-zA-Z_]/;\n\n    let i = 0;\n\n    while (i < input.length) {\n      const char = input[i];\n\n      if (WHITESPACE.test(char)) {\n        i++;\n        continue;\n      }\n\n      if (char === '+' || char === '-' || char === '*' || char === '/' || char === '(' || char === ')') {\n        tokens.push({ type: 'Punctuator', value: char });\n        i++;\n        continue;\n      }\n\n      if (NUMBERS.test(char)) {\n        let numStr = char;\n        i++;\n        while (i < input.length && NUMBERS.test(input[i])) {\n          numStr += input[i];\n          i++;\n        }\n        tokens.push({ type: 'Number', value: Number(numStr) });\n        continue;\n      }\n\n      if (LETTERS.test(char)) {\n        let idStr = char;\n        i++;\n        while (i < input.length && (LETTERS.test(input[i]) || /[0-9]/.test(input[i]))) {\n          idStr += input[i];\n          i++;\n        }\n        tokens.push({ type: 'Identifier', value: idStr });\n        continue;\n      }\n\n      // Unknown character\n      throw new SyntaxError(`Unknown token: ${char}`);\n    }\n    return tokens;\n  }\n\n  function parser(tokens) {\n    let pos = 0;\n\n    function peek() {\n      return tokens[pos];\n    }\n\n    function consume(type, value) {\n      const token = tokens[pos];\n      if (!token) return false;\n      if (type && token.type !== type) return false;\n      if (value && token.value !== value) return false;\n      pos++;\n      return token;\n    }\n\n    function parseExpression(precedence = 0) {\n      let left = parsePrimary();\n\n      while (true) {\n        const next = peek();\n        if (!next || next.type !== 'Punctuator' || !(next.value in PRECEDENCE)) {\n          break;\n        }\n        const opPrecedence = PRECEDENCE[next.value];\n        if (opPrecedence < precedence) break;\n\n        // Consume operator\n        const operator = consume('Punctuator').value;\n\n        // For left-associative operators, precedence stays same, \n        // for right-associative (not here), would be opPrecedence + 1\n        const right = parseExpression(opPrecedence + 1);\n\n        left = {\n          type: 'BinaryExpression',\n          operator,\n          left,\n          right,\n        };\n      }\n      return left;\n    }\n\n    function parsePrimary() {\n      const token = peek();\n\n      if (!token) {\n        throw new SyntaxError('Unexpected end of input');\n      }\n\n      if (token.type === 'Number') {\n        consume('Number');\n        return {\n          type: 'Literal',\n          value: token.value,\n          raw: token.value.toString(),\n        };\n      }\n\n      if (token.type === 'Identifier') {\n        consume('Identifier');\n        return {\n          type: 'Identifier',\n          name: token.value,\n        };\n      }\n\n      if (token.type === 'Punctuator' && token.value === '(') {\n        consume('Punctuator', '(');\n        const expr = parseExpression();\n        if (!consume('Punctuator', ')')) {\n          throw new SyntaxError(\"Expected ')'\");\n        }\n        return expr;\n      }\n\n      throw new SyntaxError(`Unexpected token: ${token.value}`);\n    }\n\n    const ast = parseExpression();\n\n    if (pos < tokens.length) {\n      throw new SyntaxError(`Unexpected token: ${tokens[pos].value}`);\n    }\n\n    return ast;\n  }\n\n  // Utility to pretty print the AST with indentation & colors for demo\n  function syntaxHighlight(json) {\n    if (typeof json != 'string') {\n      json = JSON.stringify(json, null, 2);\n    }\n    json = json\n      .replace(/&/g, '&amp;')\n      .replace(/</g, '&lt;')\n      .replace(/>/g, '&gt;');\n    return json.replace(\n      /(\"(\\\\u[a-zA-Z0-9]{4}|\\\\[^u]|[^\\\\\"])*\"(\\s*:)?|\\b(true|false|null)\\b|-?\\d+(\\.\\d+)?([eE][+\\-]?\\d+)?)/g,\n      match => {\n        let cls = 'number';\n        if (/^\"/.test(match)) {\n          if (/:$/.test(match)) {\n            cls = 'key';\n          } else {\n            cls = 'string';\n          }\n        } else if (/true|false/.test(match)) {\n          cls = 'boolean';\n        } else if (/null/.test(match)) {\n          cls = 'null';\n        }\n        return `<span class=\"${cls}\">${match}</span>`;\n      }\n    );\n  }\n\n  // For some CSS coloring in the <pre>:\n  const style = document.createElement('style');\n  style.textContent = `\n  pre span.key { color: #c792ea; }       /* purple */\n  pre span.string { color: #ecc48d; }    /* yellow */\n  pre span.number { color: #f78c6c; }    /* orange */\n  pre span.boolean { color: #f07178; }   /* coral */\n  pre span.null { color: #d6deeb; }      /* light blue */\n  `;\n  document.head.appendChild(style);\n\n  // Elements\n  const codeInput = document.getElementById('codeInput');\n  const parseBtn = document.getElementById('parseBtn');\n  const astOutput = document.getElementById('astOutput');\n\n  function parseAndRender() {\n    const input = codeInput.value.trim();\n    try {\n      if (!input) {\n        astOutput.textContent = 'Please enter an expression.';\n        return;\n      }\n      const tokens = tokenize(input);\n      const ast = parser(tokens);\n      astOutput.innerHTML = syntaxHighlight(ast);\n    } catch (e) {\n      astOutput.textContent = `Error: ${e.message}`;\n    }\n  }\n\n  parseBtn.addEventListener('click', parseAndRender);\n\n  // Initial parse on load\n  window.addEventListener('load', () => {\n    parseAndRender();\n  });\n\n})();\n</script>\n</body>\n</html>"
