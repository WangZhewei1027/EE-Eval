    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Directed Graph Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n  }\n  #graphCanvas {\n    border: 1px solid #ccc;\n    background-color: #f9f9f9;\n  }\n  #info {\n    margin-top: 10px;\n  }\n  h1 {\n    margin-bottom: 0;\n  }\n  #legend {\n    margin-top: 15px;\n  }\n  #graphRepresentation {\n    white-space: pre;\n    background: #f0f0f0;\n    border: 1px solid #ddd;\n    padding: 10px;\n    margin-top: 10px;\n    font-family: monospace;\n  }\n  button {\n    margin-top: 10px;\n  }\n</style>\n</head>\n<body>\n<h1>Directed Graph Visualization</h1>\n<p>This example shows a <strong>directed graph</strong>. Arrows indicate the direction from one node to another.</p>\n\n<canvas id=\"graphCanvas\" width=\"700\" height=\"450\"></canvas>\n\n<div id=\"info\"></div>\n\n<div id=\"legend\">\n  <strong>Legend:</strong>\n  <ul>\n    <li><span style=\"color: #2c7be5;\">●</span> Nodes</li>\n    <li><span style=\"border: solid #444; border-width: 0 2px 2px 0; display:inline-block; padding:3px; transform:rotate(-45deg); -webkit-transform:rotate(-45deg);\"></span> Directed edges (arrows)</li>\n  </ul>\n</div>\n\n<button id=\"showAdjacency\">Show Adjacency List</button>\n<pre id=\"graphRepresentation\"></pre>\n\n<script>\n(() => {\n  const canvas = document.getElementById(\"graphCanvas\");\n  const ctx = canvas.getContext(\"2d\");\n  const width = canvas.width;\n  const height = canvas.height;\n\n  // Define nodes with positions\n  const nodes = [\n    { id: \"A\", x: 120, y: 100 },\n    { id: \"B\", x: 320, y: 80 },\n    { id: \"C\", x: 500, y: 100 },\n    { id: \"D\", x: 210, y: 300 },\n    { id: \"E\", x: 430, y: 280 },\n    { id: \"F\", x: 600, y: 350 }\n  ];\n\n  // Directed edges (from -> to)\n  const edges = [\n    { from: \"A\", to: \"B\" },\n    { from: \"A\", to: \"D\" },\n    { from: \"B\", to: \"C\" },\n    { from: \"B\", to: \"E\" },\n    { from: \"C\", to: \"F\" },\n    { from: \"D\", to: \"E\" },\n    { from: \"E\", to: \"F\" },\n    { from: \"F\", to: \"C\" } // Back edge to demonstrate direction\n  ];\n\n  // Circle radius for nodes\n  const nodeRadius = 20;\n\n  // Draw an arrow from (x1,y1) to (x2,y2)\n  // with a small margin from source and target centers (so arrow doesn't overlap nodes)\n  function drawArrow(ctx, x1, y1, x2, y2, color = \"#444\") {\n    const headLength = 10;\n    const angle = Math.atan2(y2 - y1, x2 - x1);\n\n    // Offset start and end points so arrow touches node edges, not centers\n    const startX = x1 + nodeRadius * Math.cos(angle);\n    const startY = y1 + nodeRadius * Math.sin(angle);\n    const endX = x2 - nodeRadius * Math.cos(angle);\n    const endY = y2 - nodeRadius * Math.sin(angle);\n\n    ctx.strokeStyle = color;\n    ctx.fillStyle = color;\n    ctx.lineWidth = 2;\n\n    // Draw line\n    ctx.beginPath();\n    ctx.moveTo(startX, startY);\n    ctx.lineTo(endX, endY);\n    ctx.stroke();\n\n    // Draw arrowhead\n    ctx.beginPath();\n    ctx.moveTo(endX, endY);\n    ctx.lineTo(\n      endX - headLength * Math.cos(angle - Math.PI / 6),\n      endY - headLength * Math.sin(angle - Math.PI / 6)\n    );\n    ctx.lineTo(\n      endX - headLength * Math.cos(angle + Math.PI / 6),\n      endY - headLength * Math.sin(angle + Math.PI / 6)\n    );\n    ctx.lineTo(endX, endY);\n    ctx.fill();\n  }\n\n  // Draw node circle and label\n  function drawNode(ctx, node, highlight = false) {\n    ctx.beginPath();\n    ctx.fillStyle = highlight ? \"#2c7be5\" : \"#69a3f3\";\n    ctx.strokeStyle = highlight ? \"#16478c\" : \"#1a3d7c\";\n    ctx.lineWidth = highlight ? 4 : 2;\n    ctx.shadowColor = \"rgba(0,0,0,0.15)\";\n    ctx.shadowBlur = 4;\n    ctx.shadowOffsetX = 2;\n    ctx.shadowOffsetY = 2;\n\n    ctx.arc(node.x, node.y, nodeRadius, 0, Math.PI * 2);\n    ctx.fill();\n    ctx.shadowBlur = 0;\n    ctx.shadowOffsetX = 0;\n    ctx.shadowOffsetY = 0;\n    ctx.stroke();\n\n    // Text\n    ctx.fillStyle = \"#fff\";\n    ctx.font = \"bold 16px Arial\";\n    ctx.textAlign = \"center\";\n    ctx.textBaseline = \"middle\";\n    ctx.fillText(node.id, node.x, node.y);\n  }\n\n  // Find node by id\n  function findNode(id) {\n    return nodes.find((n) => n.id === id);\n  }\n\n  // Clear canvas\n  function clear() {\n    ctx.clearRect(0, 0, width, height);\n  }\n\n  // Draw entire graph\n  function drawGraph(highlightedNodeId = null) {\n    clear();\n\n    // Draw edges first\n    for (const edge of edges) {\n      const fromNode = findNode(edge.from);\n      const toNode = findNode(edge.to);\n\n      // Highlight edges starting from highlightedNodeId\n      if (highlightedNodeId && edge.from === highlightedNodeId) {\n        drawArrow(ctx, fromNode.x, fromNode.y, toNode.x, toNode.y, \"#e63946\");\n      } else {\n        drawArrow(ctx, fromNode.x, fromNode.y, toNode.x, toNode.y);\n      }\n    }\n\n    // Draw nodes on top\n    for (const node of nodes) {\n      drawNode(ctx, node, node.id === highlightedNodeId);\n    }\n  }\n\n  // Detect if a point (px, py) is inside a node\n  function isPointInNode(px, py, node) {\n    const dx = px - node.x;\n    const dy = py - node.y;\n    return dx * dx + dy * dy <= nodeRadius * nodeRadius;\n  }\n\n  // Show adjacency list for a node\n  function adjacencyList(nodeId) {\n    return edges\n      .filter((e) => e.from === nodeId)\n      .map((e) => e.to);\n  }\n\n  // Show adjacency list of entire graph\n  function graphAdjacencyList() {\n    const adj = {};\n    nodes.forEach((n) => {\n      adj[n.id] = adjacencyList(n.id);\n    });\n    return adj;\n  }\n\n  // Update info text below canvas\n  function updateInfo(nodeId) {\n    const infoDiv = document.getElementById(\"info\");\n    if (!nodeId) {\n      infoDiv.textContent = \"Click a node to see its outgoing edges.\";\n      return;\n    }\n    const neighbors = adjacencyList(nodeId);\n    if (neighbors.length === 0) {\n      infoDiv.textContent = `Node ${nodeId} has no outgoing edges.`;\n    } else {\n      infoDiv.textContent = `Node ${nodeId} has edges to: ${neighbors.join(\", \")}.`;\n    }\n  }\n\n  // Initial draw\n  drawGraph();\n  updateInfo(null);\n\n  // Handle canvas clicks\n  canvas.addEventListener(\"click\", (e) => {\n    const rect = canvas.getBoundingClientRect();\n    const clickX = e.clientX - rect.left;\n    const clickY = e.clientY - rect.top;\n\n    // Find if clicked on a node\n    const clickedNode = nodes.find((node) => isPointInNode(clickX, clickY, node));\n\n    if (clickedNode) {\n      drawGraph(clickedNode.id);\n      updateInfo(clickedNode.id);\n    } else {\n      drawGraph(null);\n      updateInfo(null);\n    }\n  });\n\n  // Show adjacency list for whole graph when button clicked\n  document.getElementById(\"showAdjacency\").addEventListener(\"click\", () => {\n    const adj = graphAdjacencyList();\n    let text = \"Adjacency List (Directed Graph):\\n\";\n    for (const [node, neighbors] of Object.entries(adj)) {\n      text += `${node} → ${neighbors.length > 0 ? neighbors.join(\", \") : \"(no outgoing edges)\"}\\n`;\n    }\n    document.getElementById(\"graphRepresentation\").textContent = text;\n  });\n})();\n</script>\n</body>\n</html>"
