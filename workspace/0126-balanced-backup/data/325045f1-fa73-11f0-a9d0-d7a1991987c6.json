    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Asymmetric Cryptography Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n            padding: 20px;\n        }\n        #box {\n            background: white;\n            padding: 20px;\n            border-radius: 5px;\n            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);\n        }\n    </style>\n</head>\n<body>\n\n<div id=\"box\">\n    <h1>Asymmetric Cryptography Demo</h1>\n    <button id=\"generateKeys\">Generate Keys</button>\n    <button id=\"encryptMessage\" disabled>Encrypt Message</button>\n    <button id=\"decryptMessage\" disabled>Decrypt Message</button>\n\n    <h3>Public Key:</h3>\n    <pre id=\"publicKey\"></pre>\n    \n    <h3>Private Key:</h3>\n    <pre id=\"privateKey\"></pre>\n    \n    <h3>Message:</h3>\n    <textarea id=\"message\" rows=\"4\" cols=\"50\"></textarea>\n    \n    <h3>Encrypted Message:</h3>\n    <pre id=\"encryptedMessage\"></pre>\n\n    <h3>Decrypted Message:</h3>\n    <pre id=\"decryptedMessage\"></pre>\n</div>\n\n<script>\n    let publicKey, privateKey;\n\n    async function generateKeys() {\n        const { publicKey: pubKey, privateKey: privKey } = await window.crypto.subtle.generateKey(\n            {\n                name: \"RSA-OAEP\",\n                modulusLength: 2048,\n                publicExponent: new Uint8Array([1, 0, 1]),\n                hash: \"SHA-256\"\n            },\n            true,\n            [\"encrypt\", \"decrypt\"]\n        );\n\n        publicKey = pubKey;\n        privateKey = privKey;\n\n        const exportedPublicKey = await window.crypto.subtle.exportKey(\"spki\", pubKey);\n        const exportedPrivateKey = await window.crypto.subtle.exportKey(\"pkcs8\", privKey);\n\n        document.getElementById(\"publicKey\").textContent = base64ArrayBuffer(exportedPublicKey);\n        document.getElementById(\"privateKey\").textContent = base64ArrayBuffer(exportedPrivateKey);\n        \n        document.getElementById(\"encryptMessage\").disabled = false;\n        document.getElementById(\"decryptMessage\").disabled = false;\n        \n        alert(\"Keys generated successfully!\");\n    }\n\n    async function encryptMessage() {\n        const message = document.getElementById(\"message\").value;\n        const encodedMessage = new TextEncoder().encode(message);\n\n        const encryptedMessage = await window.crypto.subtle.encrypt(\n            {\n                name: \"RSA-OAEP\"\n            },\n            publicKey,\n            encodedMessage\n        );\n\n        document.getElementById(\"encryptedMessage\").textContent = base64ArrayBuffer(encryptedMessage);\n    }\n\n    async function decryptMessage() {\n        const encryptedMessage = document.getElementById(\"encryptedMessage\").textContent;\n        const decryptedData = await window.crypto.subtle.decrypt(\n            {\n                name: \"RSA-OAEP\"\n            },\n            privateKey,\n            base64ToArrayBuffer(encryptedMessage)\n        );\n\n        const decryptedMessage = new TextDecoder().decode(decryptedData);\n        document.getElementById(\"decryptedMessage\").textContent = decryptedMessage;\n    }\n\n    function base64ArrayBuffer(arrayBuffer) {\n        let bytes = new Uint8Array(arrayBuffer);\n        let binary = '';\n        let len = bytes.byteLength;\n        for (let i = 0; i < len; i++) {\n            binary += String.fromCharCode(bytes[i]);\n        }\n        return window.btoa(binary);\n    }\n\n    function base64ToArrayBuffer(base64) {\n        let binaryString = window.atob(base64);\n        let len = binaryString.length;\n        let bytes = new Uint8Array(len);\n        for (let i = 0; i < len; i++) {\n            bytes[i] = binaryString.charCodeAt(i);\n        }\n        return bytes.buffer;\n    }\n\n    document.getElementById(\"generateKeys\").addEventListener(\"click\", generateKeys);\n    document.getElementById(\"encryptMessage\").addEventListener(\"click\", encryptMessage);\n    document.getElementById(\"decryptMessage\").addEventListener(\"click\", decryptMessage);\n</script>\n\n</body>\n</html>"
