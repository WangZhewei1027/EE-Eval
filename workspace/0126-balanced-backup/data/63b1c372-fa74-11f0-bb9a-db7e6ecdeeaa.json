    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Prim's Algorithm Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 0; padding: 0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    background: #f5f8fa;\n  }\n  h1 {\n    margin: 1rem 0 0.5rem;\n    color: #333;\n  }\n  #graph-container {\n    margin-top: 10px;\n    position: relative;\n    background: #fff;\n    border: 1px solid #ccc;\n    border-radius: 6px;\n  }\n  canvas {\n    background: #ffffff;\n    display: block;\n  }\n  #controls {\n    margin: 1rem 0 2rem;\n  }\n  button {\n    font-size: 1rem;\n    padding: 0.5em 1.2em;\n    margin: 0 0.5em;\n    border: none;\n    border-radius: 4px;\n    background: #3f51b5;\n    color: white;\n    cursor: pointer;\n  }\n  button:disabled {\n    background: #999;\n    cursor: default;\n  }\n  #info {\n    max-width: 600px;\n    text-align: center;\n    color: #555;\n    margin-bottom: 2rem;\n  }\n  #legend {\n    max-width: 600px;\n    display: flex;\n    justify-content: center;\n    gap: 1.5rem;\n    margin-bottom: 2rem;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    font-size: 0.9rem;\n    color: #444;\n  }\n  .legend-color {\n    width: 20px; height: 20px;\n    border-radius: 3px;\n    border: 1px solid #aaa;\n  }\n  .color-edge { background: #bbb; }\n  .color-selected { background: #4caf50; }\n  .color-considered { background: #ff9800; }\n  .color-node { background: #2196f3; }\n  .color-mst-node { background: #4caf50; }\n</style>\n</head>\n<body>\n<h1>Prim's Algorithm Visualization</h1>\n<div id=\"info\">\n  This visualization demonstrates Prim's Algorithm to find the Minimum Spanning Tree (MST)\n  of a weighted undirected graph. Click <b>Start</b> to begin and watch the MST grow.\n</div>\n<div id=\"legend\">\n  <div class=\"legend-item\"><div class=\"legend-color color-node\"></div> Unvisited Node</div>\n  <div class=\"legend-item\"><div class=\"legend-color color-mst-node\"></div> Node in MST</div>\n  <div class=\"legend-item\"><div class=\"legend-color color-edge\"></div> Edge not considered</div>\n  <div class=\"legend-item\"><div class=\"legend-color color-considered\"></div> Edge considered</div>\n  <div class=\"legend-item\"><div class=\"legend-color color-selected\"></div> Edge selected in MST</div>\n</div>\n<div id=\"graph-container\">\n  <canvas id=\"graph\" width=\"700\" height=\"500\"></canvas>\n</div>\n<div id=\"controls\">\n  <button id=\"startBtn\">Start</button>\n  <button id=\"stepBtn\" disabled>Step</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('graph');\n  const ctx = canvas.getContext('2d');\n  const width = canvas.width;\n  const height = canvas.height;\n\n  const startBtn = document.getElementById('startBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Graph Data - undirected, weighted graph\n\n  /*\n  Graph structure: nodes with fixed positions, edges with weights.\n  We'll have 8 nodes for a clear medium example.\n\n  Nodes: id and positions\n  Edges: node1, node2, weight\n\n  We'll keep adjacency list for Prim's and to draw edges.\n\n  */\n\n  const nodes = [\n    {id: 0, x: 100, y: 100},\n    {id: 1, x: 250, y: 80},\n    {id: 2, x: 400, y: 100},\n    {id: 3, x: 100, y: 250},\n    {id: 4, x: 300, y: 250},\n    {id: 5, x: 450, y: 250},\n    {id: 6, x: 200, y: 400},\n    {id: 7, x: 400, y: 400}\n  ];\n\n  // Edges bi-directional\n  const edges = [\n    {from: 0, to: 1, weight: 4},\n    {from: 0, to: 3, weight: 8},\n    {from: 1, to: 2, weight: 8},\n    {from: 1, to: 4, weight: 11},\n    {from: 2, to: 5, weight: 7},\n    {from: 3, to: 4, weight: 2},\n    {from: 3, to: 6, weight: 7},\n    {from: 4, to: 5, weight: 4},\n    {from: 4, to: 6, weight: 1},\n    {from: 4, to: 7, weight: 6},\n    {from: 5, to: 7, weight: 14},\n    {from: 6, to: 7, weight: 9}\n  ];\n\n  // We'll create adjacency list: node id -> array of {node, weight, edgeId}\n  const adjacency = {};\n  nodes.forEach(n => adjacency[n.id] = []);\n  edges.forEach((e, i) => {\n    adjacency[e.from].push({node: e.to, weight: e.weight, edgeId: i});\n    adjacency[e.to].push({node: e.from, weight: e.weight, edgeId: i});\n  });\n\n  // Visualization colors\n  const colorNode = '#2196f3';         // blue for unvisited node\n  const colorMstNode = '#4caf50';      // green for MST nodes\n  const colorEdge = '#bbb';             // grey for normal edges\n  const colorEdgeConsidered = '#ff9800'; // orange edges being considered\n  const colorEdgeSelected = '#4caf50'; // green edge in MST\n\n  // States to maintain\n  let mstNodes = new Set();       // nodes included in MST\n  let mstEdges = new Set();       // edge indices included in MST\n  let consideredEdges = new Set();// edges currently being considered/displayed orange\n\n  // Prim's algorithm state\n  let pq = []; // priority queue for edges (min heap by weight)\n  /*\n    We'll push edges crossing the MST cut to pq:\n    store {weight, from, to, edgeId}\n  */\n\n  let currentStep = 0;\n  // Algorithm steps we'll define as generator\n  let primGenerator;\n\n  // Draw all - nodes and edges, colored by current states\n  function drawGraph() {\n    ctx.clearRect(0, 0, width, height);\n    // Draw edges first\n    edges.forEach(({from, to, weight}, i) => {\n      const n1 = nodes[from];\n      const n2 = nodes[to];\n      let strokeStyle = colorEdge;\n      let lineWidth = 2;\n      if (mstEdges.has(i)) {\n        strokeStyle = colorEdgeSelected;\n        lineWidth = 4;\n      } else if (consideredEdges.has(i)) {\n        strokeStyle = colorEdgeConsidered;\n        lineWidth = 3;\n      }\n      ctx.beginPath();\n      ctx.moveTo(n1.x, n1.y);\n      ctx.lineTo(n2.x, n2.y);\n      ctx.strokeStyle = strokeStyle;\n      ctx.lineWidth = lineWidth;\n      ctx.lineCap = \"round\";\n      ctx.stroke();\n\n      // Draw weight text\n      const midX = (n1.x + n2.x) / 2;\n      const midY = (n1.y + n2.y) / 2;\n      ctx.fillStyle = '#222';\n      ctx.font = '14px Arial';\n      ctx.fillText(weight, midX + 5, midY - 5);\n    });\n\n    // Draw nodes\n    nodes.forEach(({id, x, y}) => {\n      ctx.beginPath();\n      ctx.arc(x, y, 16, 0, 2 * Math.PI);\n      if (mstNodes.has(id)) {\n        ctx.fillStyle = colorMstNode;\n        ctx.shadowColor = '#4caf50cc';\n        ctx.shadowBlur = 12;\n      } else {\n        ctx.fillStyle = colorNode;\n        ctx.shadowBlur = 0;\n      }\n      ctx.fill();\n      ctx.shadowBlur = 0;\n\n      ctx.lineWidth = 3;\n      ctx.strokeStyle = '#fff';\n      ctx.stroke();\n\n      // Draw node id inside circle\n      ctx.fillStyle = '#fff';\n      ctx.font = 'bold 14px Arial';\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'middle';\n      ctx.fillText(id, x, y);\n    });\n  }\n\n  // Priority queue implementation using min-heap on weight\n  // Minimal for this demo, assume small data.\n  class MinHeap {\n    constructor(){\n      this.arr = [];\n    }\n    swap(i,j) {\n      [this.arr[i], this.arr[j]] = [this.arr[j], this.arr[i]];\n    }\n    push(elem) {\n      this.arr.push(elem);\n      this.bubbleUp(this.arr.length - 1);\n    }\n    bubbleUp(idx) {\n      if (idx === 0) return;\n      let p = Math.floor((idx - 1)/2);\n      if (this.arr[p].weight > this.arr[idx].weight) {\n        this.swap(p, idx);\n        this.bubbleUp(p);\n      }\n    }\n    pop() {\n      if (this.arr.length === 0) return null;\n      if (this.arr.length === 1) return this.arr.pop();\n      const res = this.arr[0];\n      this.arr[0] = this.arr.pop();\n      this.bubbleDown(0);\n      return res;\n    }\n    bubbleDown(idx) {\n      const left = 2*idx + 1;\n      const right = 2*idx + 2;\n      let smallest = idx;\n      if (left < this.arr.length && this.arr[left].weight < this.arr[smallest].weight) smallest = left;\n      if (right < this.arr.length && this.arr[right].weight < this.arr[smallest].weight) smallest = right;\n      if (smallest !== idx) {\n        this.swap(smallest, idx);\n        this.bubbleDown(smallest);\n      }\n    }\n    isEmpty() {\n      return this.arr.length === 0;\n    }\n  }\n\n  // Generator function that yields steps of Prim’s algorithm for visualization\n  function* primAlgorithm(startNode = 0) {\n    mstNodes = new Set();\n    mstEdges = new Set();\n    consideredEdges = new Set();\n    const visited = new Set();\n    const minHeap = new MinHeap();\n\n    // Include start node in MST\n    mstNodes.add(startNode);\n    visited.add(startNode);\n\n    // Add all edges from start node to heap\n    adjacency[startNode].forEach(({node, weight, edgeId}) => {\n      minHeap.push({weight, from: startNode, to: node, edgeId});\n      consideredEdges.add(edgeId);\n    });\n    yield {mstNodes: new Set(mstNodes), mstEdges: new Set(mstEdges), consideredEdges: new Set(consideredEdges), action:\"Add start node and initial edges\"};\n\n    while (!minHeap.isEmpty()) {\n      let edge = minHeap.pop();\n      // Update considered edges to remove all except current candidate\n      consideredEdges.clear();\n      consideredEdges.add(edge.edgeId);\n\n      yield {mstNodes: new Set(mstNodes), mstEdges: new Set(mstEdges), consideredEdges: new Set(consideredEdges), action: `Consider edge (${edge.from} - ${edge.to}) with weight ${edge.weight}`};\n\n      // If destination node already visited, skip\n      if (visited.has(edge.to)) {\n        consideredEdges.clear();\n        yield {mstNodes: new Set(mstNodes), mstEdges: new Set(mstEdges), consideredEdges: new Set(consideredEdges), action: `Node ${edge.to} already in MST, skip edge`};\n        continue;\n      }\n\n      // Accept this edge\n      mstEdges.add(edge.edgeId);\n      mstNodes.add(edge.to);\n      visited.add(edge.to);\n      consideredEdges.clear();\n\n      yield {mstNodes: new Set(mstNodes), mstEdges: new Set(mstEdges), consideredEdges: new Set(consideredEdges), action: `Select edge (${edge.from} - ${edge.to}) to MST`};\n\n      // Add all edges from newly included node that lead to unvisited nodes\n      adjacency[edge.to].forEach(({node, weight, edgeId}) => {\n        if (!visited.has(node)) {\n          minHeap.push({weight, from: edge.to, to: node, edgeId});\n          consideredEdges.add(edgeId);\n        }\n      });\n\n      if (consideredEdges.size > 0) {\n        yield {mstNodes: new Set(mstNodes), mstEdges: new Set(mstEdges), consideredEdges: new Set(consideredEdges), action: `Add edges from node ${edge.to} to consideration`};\n      }\n    }\n\n    consideredEdges.clear();\n    yield {mstNodes: new Set(mstNodes), mstEdges: new Set(mstEdges), consideredEdges: new Set(consideredEdges), action: \"MST Complete\"};\n  }\n\n  // State of visualization\n  let currentState = null;\n\n  // Draw according to current state\n  function renderState(state) {\n    if (!state) return;\n    mstNodes = state.mstNodes;\n    mstEdges = state.mstEdges;\n    consideredEdges = state.consideredEdges;\n    drawGraph();\n    infoText.textContent = state.action;\n  }\n\n  // Info text\n  const infoText = document.createElement('div');\n  infoText.style.maxWidth = '600px';\n  infoText.style.color = '#222';\n  infoText.style.fontSize = '1.1rem';\n  infoText.style.marginTop = '0';\n  infoText.style.marginBottom = '1rem';\n  document.body.insertBefore(infoText, document.getElementById('graph-container'));\n\n  // Reset graph and controls\n  function reset() {\n    mstNodes.clear();\n    mstEdges.clear();\n    consideredEdges.clear();\n    currentStep = 0;\n    primGenerator = null;\n    startBtn.disabled = false;\n    stepBtn.disabled = true;\n    resetBtn.disabled = true;\n    infoText.textContent = 'Click Start to run Prim\\'s Algorithm';\n    drawGraph();\n  }\n\n  // Step forward one iteration\n  function step() {\n    if (!primGenerator) return;\n    const {value, done} = primGenerator.next();\n    if (done) {\n      stepBtn.disabled = true;\n      startBtn.disabled = true;\n      resetBtn.disabled = false;\n      infoText.textContent = \"Prim's Algorithm completed! Minimum Spanning Tree found.\";\n      renderState(value);\n      return;\n    }\n    renderState(value);\n  }\n\n  // Start running steps\n  function start() {\n    startBtn.disabled = true;\n    stepBtn.disabled = false;\n    resetBtn.disabled = false;\n    primGenerator = primAlgorithm();\n    step();\n  }\n\n  // Event listeners\n  startBtn.addEventListener('click', () => {\n    start();\n  });\n\n  stepBtn.addEventListener('click', () => {\n    step();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    reset();\n  });\n\n  // Initial draw\n  reset();\n\n})();\n</script>\n</body>\n</html>"
  },
