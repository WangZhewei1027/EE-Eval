  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>K-Nearest Neighbors (KNN) Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 10px;\n    background: #f0f0f0;\n  }\n  h1 {\n    text-align: center;\n  }\n  #canvas {\n    background: white;\n    border: 1px solid #999;\n    display: block;\n    margin: 10px auto;\n  }\n  #info {\n    max-width: 600px;\n    margin: 10px auto;\n    line-height: 1.4;\n    font-size: 14px;\n  }\n  #controls {\n    max-width: 600px;\n    margin: 0 auto 15px auto;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 10px;\n  }\n  #controls label {\n    font-weight: bold;\n  }\n  button {\n    padding: 6px 12px;\n    font-size: 14px;\n    cursor: pointer;\n  }\n  input[type=number] {\n    width: 50px;\n    font-size: 14px;\n  }\n  #classes {\n    max-width: 600px;\n    margin: 10px auto;\n    display: flex;\n    justify-content: center;\n    gap: 15px;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .color-box {\n    width: 16px;\n    height: 16px;\n    border-radius: 3px;\n  }\n  #instructions {\n    max-width: 600px;\n    margin: 15px auto;\n    font-size: 13px;\n    color: #555;\n    background: #e7f3fe;\n    border: 1px solid #b3d7ff;\n    padding: 10px;\n    border-radius: 5px;\n  }\n</style>\n</head>\n<body>\n<h1>K-Nearest Neighbors (KNN) Visualization</h1>\n\n<div id=\"controls\">\n  <label for=\"kInput\">K:</label>\n  <input type=\"number\" id=\"kInput\" min=\"1\" max=\"10\" value=\"3\" />\n  <button id=\"clearBtn\" title=\"Clear all points\">Clear</button>\n  <button id=\"randomBtn\" title=\"Add random points\">Add Random Points</button>\n</div>\n\n<canvas id=\"canvas\" width=\"600\" height=\"400\" tabindex=\"0\" aria-label=\"K-Nearest Neighbors visualization\"></canvas>\n\n<div id=\"classes\">\n  <div class=\"legend-item\">\n    <div class=\"color-box\" style=\"background:#e63946\"></div> Class A\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"color-box\" style=\"background:#1d3557\"></div> Class B\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"color-box\" style=\"background:#2a9d8f\"></div> Class C\n  </div>\n</div>\n\n<div id=\"info\">\n  <b>Instructions:</b> <br />\n  - Click on the canvas to add labeled points.<br />\n  - Hold <b>Shift</b> while clicking to cycle through classes for the next point.<br />\n  - The next point to classify follows your mouse cursor.<br />\n  - Adjust <b>K</b> to change the number of nearest neighbors considered.<br />\n  - Points are colored by their class.<br />\n  - The circle around the query point shows the distance to the K-th nearest neighbor.<br />\n  - Nearest neighbors are connected with lines to the query point.<br />\n</div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n  const kInput = document.getElementById('kInput');\n  const clearBtn = document.getElementById('clearBtn');\n  const randomBtn = document.getElementById('randomBtn');\n\n  // Classes and colors\n  const classes = ['A', 'B', 'C'];\n  const classColors = {\n    'A': '#e63946',\n    'B': '#1d3557',\n    'C': '#2a9d8f'\n  };\n\n  // Stored points: {x, y, class}\n  let points = [];\n\n  // Current class to add (default A)\n  let currentClassIndex = 0;\n\n  // Position of mouse for query point (next point to classify)\n  let mousePos = {x: canvas.width / 2, y: canvas.height / 2};\n  let mouseInside = false;\n\n  // K parameter\n  let K = Number(kInput.value);\n\n  function distanceSquared(p1, p2) {\n    const dx = p1.x - p2.x;\n    const dy = p1.y - p2.y;\n    return dx*dx + dy*dy;\n  }\n\n  // Return the majority class among neighbors, with tie-breaking by class order\n  function majorityClass(neighbors) {\n    const counts = {};\n    for (const c of classes) counts[c] = 0;\n\n    neighbors.forEach(pt => counts[pt.class]++);\n    let maxCount = 0;\n    let majority = null;\n    for (const c of classes) {\n      if (counts[c] > maxCount) {\n        maxCount = counts[c];\n        majority = c;\n      }\n    }\n    // Tie-break by class order if needed\n    const tiedClasses = classes.filter(c => counts[c] === maxCount);\n    if (tiedClasses.length > 1) {\n      majority = tiedClasses[0];\n    }\n    return majority;\n  }\n\n  // Find K nearest neighbors of queryPoint among points\n  // Returns array of points sorted nearest to farthest\n  function findKNearest(queryPoint, K) {\n    const sorted = points\n      .map(pt => ({...pt, distSq: distanceSquared(queryPoint, pt)}))\n      .sort((a,b) => a.distSq - b.distSq);\n    return sorted.slice(0, Math.min(K, sorted.length));\n  }\n\n  function drawPoint(pt, radius = 6, fill = true, highlight=false) {\n    ctx.beginPath();\n    ctx.arc(pt.x, pt.y, radius, 0, Math.PI * 2);\n    ctx.fillStyle = fill ? classColors[pt.class] : 'white';\n    ctx.fill();\n    ctx.lineWidth = highlight ? 3 : 1.5;\n    ctx.strokeStyle = classColors[pt.class];\n    ctx.stroke();\n  }\n\n  function drawCircle(center, radius, color, width=1) {\n    ctx.beginPath();\n    ctx.arc(center.x, center.y, radius, 0, 2 * Math.PI);\n    ctx.strokeStyle = color;\n    ctx.lineWidth = width;\n    ctx.setLineDash([5, 5]);\n    ctx.stroke();\n    ctx.setLineDash([]);\n  }\n\n  function drawLine(p1, p2, color, width=1) {\n    ctx.beginPath();\n    ctx.moveTo(p1.x, p1.y);\n    ctx.lineTo(p2.x, p2.y);\n    ctx.strokeStyle = color;\n    ctx.lineWidth = width;\n    ctx.stroke();\n  }\n\n  function redraw() {\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n    // Draw existing points\n    points.forEach(pt => drawPoint(pt));\n\n    if (!mouseInside) return;\n\n    // Draw query point (next point to classify)\n    const queryPoint = {x: mousePos.x, y: mousePos.y};\n\n    // Find K nearest neighbors\n    const neighbors = findKNearest(queryPoint, K);\n\n    // Draw lines from query to neighbors\n    neighbors.forEach(neighbor => {\n      drawLine(queryPoint, neighbor, '#555', 1);\n      drawPoint(neighbor, 8, true, true);\n    });\n\n    // Draw circle from query to K-th neighbor distance\n    if (neighbors.length > 0) {\n      const dist = Math.sqrt(neighbors[neighbors.length - 1].distSq);\n      drawCircle(queryPoint, dist, '#666', 2);\n    }\n\n    // Determine majority class\n    if (neighbors.length > 0) {\n      const majClass = majorityClass(neighbors);\n      // Draw query point colored by majority class with a white inner circle\n      drawPoint(queryPoint, 10, true);\n      ctx.beginPath();\n      ctx.arc(queryPoint.x, queryPoint.y, 7, 0, Math.PI*2);\n      ctx.fillStyle = 'white';\n      ctx.fill();\n      ctx.strokeStyle = classColors[majClass];\n      ctx.lineWidth = 3;\n      ctx.stroke();\n\n      // Show predicted label text near query point\n      ctx.font = 'bold 14px Arial';\n      ctx.fillStyle = classColors[majClass];\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'bottom';\n      ctx.fillText(`Class ${majClass}`, queryPoint.x, queryPoint.y - 12);\n    }\n  }\n\n  // Add a new point labeled with current class at (x,y)\n  function addPoint(x, y, cls) {\n    points.push({x, y, class: cls});\n    redraw();\n  }\n\n  // Cycle to next class for labeling\n  function nextClass() {\n    currentClassIndex = (currentClassIndex + 1) % classes.length;\n  }\n\n  // Handle canvas click: add a labeled point where clicked\n  canvas.addEventListener('click', e => {\n    const rect = canvas.getBoundingClientRect();\n    const x = e.clientX - rect.left;\n    const y = e.clientY - rect.top;\n\n    // If Shift key held, cycle current class before adding\n    if (e.shiftKey) nextClass();\n\n    addPoint(x, y, classes[currentClassIndex]);\n  });\n\n  // Track mouse position inside canvas for query point\n  canvas.addEventListener('mousemove', e => {\n    const rect = canvas.getBoundingClientRect();\n    mousePos.x = e.clientX - rect.left;\n    mousePos.y = e.clientY - rect.top;\n    mouseInside = true;\n    redraw();\n  });\n\n  canvas.addEventListener('mouseleave', () => {\n    mouseInside = false;\n    redraw();\n  });\n\n  // Update K when input changes\n  kInput.addEventListener('input', e => {\n    let val = parseInt(kInput.value);\n    if (isNaN(val) || val < 1) val = 1;\n    if (val > 10) val = 10;\n    K = val;\n    kInput.value = val;\n    redraw();\n  });\n\n  clearBtn.addEventListener('click', () => {\n    points = [];\n    redraw();\n  });\n\n  randomBtn.addEventListener('click', () => {\n    // Add 15 random points, roughly balanced classes\n    const num = 15;\n    for (let i=0; i<num; i++) {\n      const x = 20 + Math.random() * (canvas.width - 40);\n      const y = 20 + Math.random() * (canvas.height - 40);\n      const cls = classes[i % classes.length];\n      points.push({x, y, class: cls});\n    }\n    redraw();\n  });\n\n  // Initial draw\n  redraw();\n\n  // Accessibility: keyboard controls to cycle current class and add point centered\n  canvas.addEventListener('keydown', e => {\n    if (e.key === 'c' || e.key === 'C') {\n      nextClass();\n      e.preventDefault();\n    } else if (e.key === 'Enter' || e.key === ' ') {\n      addPoint(mousePos.x, mousePos.y, classes[currentClassIndex]);\n      e.preventDefault();\n    }\n  });\n\n  // Show current class in document title\n  function updateTitle() {\n    document.title = `KNN Visualization - Next class: ${classes[currentClassIndex]}`;\n  }\n  updateTitle();\n\n  // Also update title when current class changes\n  const originalNextClass = nextClass;\n  nextClass = function() {\n    originalNextClass();\n    updateTitle();\n  };\n\n})();\n</script>\n</body>\n</html>"
  },
