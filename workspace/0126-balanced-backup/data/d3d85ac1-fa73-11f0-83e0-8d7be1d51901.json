    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Big-Theta (Θ) Notation — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724; --card:#0b1220; --accent:#7dd3fc; --muted:#94a3b8; --good:#10b981; --bad:#fb7185;\n      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Helvetica Neue\", monospace;\n    }\n    html,body{height:100%; margin:0; font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; background:linear-gradient(180deg,#071129 0%, #071726 100%); color:#e6eef8;}\n    .container{max-width:1100px; margin:24px auto; padding:18px; background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border-radius:12px; box-shadow:0 4px 30px rgba(2,6,23,0.6);}\n    header{display:flex; align-items:center; gap:16px;}\n    header h1{margin:0; font-size:1.4rem;}\n    .grid{display:grid; grid-template-columns:360px 1fr; gap:18px; margin-top:14px;}\n    .card{background:var(--card); padding:14px; border-radius:10px; box-shadow:inset 0 1px 0 rgba(255,255,255,0.02);}\n    label{display:block; font-size:0.85rem; color:var(--muted); margin-bottom:6px;}\n    select,input,textarea{width:100%; padding:8px 10px; background:#071423; border:1px solid rgba(255,255,255,0.03); color:var(--accent); border-radius:6px; font-family:var(--mono); font-size:0.95rem;}\n    .row{display:flex; gap:8px;}\n    .row > *{flex:1;}\n    button{background:linear-gradient(90deg,var(--accent),#60a5fa); color:#042028; border:none; padding:8px 12px; border-radius:8px; cursor:pointer; font-weight:600;}\n    button.secondary{background:#0b1220; color:var(--accent); border:1px solid rgba(255,255,255,0.03);}\n    .small{font-size:0.85rem; color:var(--muted); margin-top:6px;}\n    canvas{width:100%; height:340px; display:block; border-radius:8px; background:linear-gradient(180deg,#031321 0%, #021022 100%); border:1px solid rgba(255,255,255,0.03);}\n    .footer{margin-top:12px; display:flex; gap:12px; align-items:center; justify-content:space-between;}\n    .results{font-family:var(--mono); background:linear-gradient(90deg,#02202b, #021420); padding:10px; border-radius:8px; color:var(--muted); font-size:0.95rem;}\n    .status{padding:8px 10px; border-radius:8px; font-weight:700;}\n    .status.good{background:linear-gradient(90deg, rgba(16,185,129,0.12), rgba(16,185,129,0.06)); color:var(--good);}\n    .status.bad{background:linear-gradient(90deg, rgba(251,113,133,0.12), rgba(251,113,133,0.06)); color:var(--bad);}\n    code{background:#021a25; padding:2px 6px; border-radius:6px; color:var(--accent); font-family:var(--mono);}\n    .explain{font-size:0.95rem; color:var(--muted); line-height:1.4;}\n    .examples{display:flex; gap:8px; margin-top:8px; flex-wrap:wrap;}\n    .chip{background:#021822; padding:6px 10px; border-radius:999px; color:var(--accent); border:1px solid rgba(255,255,255,0.02); cursor:pointer; font-family:var(--mono); font-size:0.9rem;}\n    .muted-block{background:rgba(255,255,255,0.02); padding:8px; border-radius:8px; color:var(--muted); font-size:0.9rem;}\n    footer small{color:var(--muted);}\n    @media (max-width:900px){ .grid{grid-template-columns:1fr; } canvas{height:260px;} }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <header>\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 24 24\" fill=\"none\" style=\"flex:0 0 40px;\">\n        <rect width=\"24\" height=\"24\" rx=\"6\" fill=\"#071726\"/>\n        <path d=\"M4 17l4-10 4 10 4-7 4 7\" stroke=\"#7dd3fc\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n      <div>\n        <h1>Big-Theta (Θ) Notation — Interactive Demo</h1>\n        <div class=\"small\">Experiment with functions f(n) and g(n) to see whether f(n) ∈ Θ(g(n)) based on sampled values.</div>\n      </div>\n    </header>\n\n    <div class=\"grid\" style=\"margin-top:18px;\">\n      <div class=\"card\">\n        <label>Choose f(n) (numerator)</label>\n        <select id=\"fSelect\">\n          <option value=\"3*n + 5\">f(n) = 3*n + 5</option>\n          <option value=\"n\">f(n) = n</option>\n          <option value=\"2*n*n + 4*n + 1\">f(n) = 2*n^2 + 4*n + 1</option>\n          <option value=\"5*n*Math.log(n)\">f(n) = 5*n*log(n)</option>\n          <option value=\"Math.log(n)\">f(n) = log(n)</option>\n          <option value=\"1\">f(n) = 1</option>\n          <option value=\"Math.pow(1.5,n)\">f(n) = 1.5^n</option>\n          <option value=\"custom\">Custom...</option>\n        </select>\n        <div id=\"fCustomWrap\" style=\"display:none; margin-top:8px;\">\n          <label>Enter f(n) as a JavaScript expression using n (e.g. 2*n*n + 1)</label>\n          <input id=\"fCustom\" placeholder=\"2*n*n + 1\" />\n        </div>\n\n        <label style=\"margin-top:12px;\">Choose g(n) (denominator)</label>\n        <select id=\"gSelect\">\n          <option value=\"n\">g(n) = n</option>\n          <option value=\"n*n\">g(n) = n^2</option>\n          <option value=\"n*Math.log(n)\">g(n) = n*log(n)</option>\n          <option value=\"Math.log(n)\">g(n) = log(n)</option>\n          <option value=\"1\">g(n) = 1</option>\n          <option value=\"Math.pow(2,n)\">g(n) = 2^n</option>\n          <option value=\"custom\">Custom...</option>\n        </select>\n        <div id=\"gCustomWrap\" style=\"display:none; margin-top:8px;\">\n          <label>Enter g(n) as a JavaScript expression using n</label>\n          <input id=\"gCustom\" placeholder=\"n*Math.log(n)\" />\n        </div>\n\n        <div style=\"margin-top:12px;\" class=\"row\">\n          <div>\n            <label>Start n (n0)</label>\n            <input id=\"n0\" type=\"number\" value=\"1\" min=\"1\" />\n          </div>\n          <div>\n            <label>Max n</label>\n            <input id=\"Nmax\" type=\"number\" value=\"200\" min=\"2\" />\n          </div>\n        </div>\n\n        <div style=\"margin-top:10px;\" class=\"row\">\n          <div>\n            <label>Samples</label>\n            <input id=\"samples\" type=\"number\" value=\"200\" min=\"10\" max=\"2000\" />\n          </div>\n          <div>\n            <label>Spacing</label>\n            <select id=\"spacing\">\n              <option value=\"linear\">Linear (n0...N)</option>\n              <option value=\"log\">Log spacing (densely small n)</option>\n            </select>\n          </div>\n        </div>\n\n        <div style=\"margin-top:12px;\" class=\"row\">\n          <button id=\"analyze\">Analyze</button>\n          <button id=\"reset\" class=\"secondary\">Reset</button>\n        </div>\n\n        <div style=\"margin-top:12px;\" class=\"small explain\">\n          About: f(n) ∈ Θ(g(n)) means there exist positive constants c1, c2 and n0 such that for all n ≥ n0:\n          c1·g(n) ≤ f(n) ≤ c2·g(n).\n          This tool samples n values and reports the observed minimum and maximum of the ratio f(n)/g(n). It visualizes f, g and the bounding lines c1·g and c2·g. This is experimental (sampled), not a formal proof.\n        </div>\n\n        <div style=\"margin-top:12px;\" class=\"muted-block\">\n          Quick examples:\n          <div class=\"examples\" style=\"margin-top:6px;\">\n            <div class=\"chip\" data-f=\"3*n + 5\" data-g=\"n\">3n+5 vs n</div>\n            <div class=\"chip\" data-f=\"2*n*n + 4*n + 1\" data-g=\"n*n\">2n^2+4n+1 vs n^2</div>\n            <div class=\"chip\" data-f=\"5*n*Math.log(n)\" data-g=\"n*Math.log(n)\">5n log n vs n log n</div>\n            <div class=\"chip\" data-f=\"n\" data-g=\"n*n\">n vs n^2</div>\n            <div class=\"chip\" data-f=\"Math.log(n)\" data-g=\"1\">log n vs 1</div>\n            <div class=\"chip\" data-f=\"Math.pow(1.5,n)\" data-g=\"Math.pow(2,n)\">1.5^n vs 2^n</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <canvas id=\"plot\" width=\"800\" height=\"340\"></canvas>\n        <div style=\"display:flex; gap:12px; margin-top:10px; align-items:center;\">\n          <div class=\"results\" id=\"metrics\">Press Analyze to compute.</div>\n          <div id=\"conclusion\" class=\"status\" style=\"margin-left:auto;\">—</div>\n        </div>\n        <div style=\"margin-top:10px; display:flex; gap:10px; align-items:center;\">\n          <div style=\"flex:1;\" class=\"small muted-block\" id=\"notes\">Notes: No values where g(n) = 0 are accepted. If g becomes nonpositive for sampled n, the tool will warn.</div>\n        </div>\n        <div style=\"margin-top:8px;\" class=\"small explain\">\n          Interpretation: If the ratio f(n)/g(n) stays bounded between two positive constants for all large n, we say f ∈ Θ(g). The plotted horizontal lines on the ratio chart show the observed min and max ratio.\n        </div>\n      </div>\n    </div>\n\n    <div style=\"display:flex; gap:12px; margin-top:14px; align-items:center;\">\n      <div class=\"small muted-block\">This is a teaching tool. Results are based on discrete sampled points and numeric evaluation.</div>\n      <div style=\"margin-left:auto;\"><small>Implementations use JavaScript's Math functions; use <code>Math.log</code> for natural log.</small></div>\n    </div>\n    <footer style=\"margin-top:14px;\">\n      <small>Built for demonstration — interactive visualization of asymptotic relation Θ.</small>\n    </footer>\n  </div>\n\n<script>\n(function(){\n  // Utility: create function from expression string safely-ish\n  function makeFunc(expr){\n    // Allowed characters: letters, numbers, operators, Math., n, parentheses, spaces, ., _ , ^ not allowed (we use ** or Math.pow)\n    // We'll rely on Function but provide minimal validation\n    if(!expr || expr.trim() === \"\") throw new Error(\"Empty expression\");\n    // Replace '^' with ** if used (user may use ^ mistakenly)\n    expr = expr.replace(/\\\\^/g, \"**\");\n    // Basic safety: disallow suspicious token sequences (no new Function calls inside)\n    const forbidden = [/process\\\\b/, /require\\\\b/, /while\\\\(/, /for\\\\(/, /Function\\\\(/, /console\\\\./, /window\\\\./, /document\\\\./];\n    for(const r of forbidden) if(r.test(expr)) throw new Error(\"Expression contains forbidden tokens.\");\n    // Build function\n    const fn = new Function(\"n\", \"with (Math) { return (\" + expr + \"); }\");\n    // Quick test\n    const test = fn(2);\n    if(!isFinite(test) && typeof test === \"number\") {\n      // allow infinities? we'll let be handled later\n    }\n    return fn;\n  }\n\n  const fSelect = document.getElementById(\"fSelect\");\n  const gSelect = document.getElementById(\"gSelect\");\n  const fCustomWrap = document.getElementById(\"fCustomWrap\");\n  const gCustomWrap = document.getElementById(\"gCustomWrap\");\n  const fCustom = document.getElementById(\"fCustom\");\n  const gCustom = document.getElementById(\"gCustom\");\n  const n0Input = document.getElementById(\"n0\");\n  const NmaxInput = document.getElementById(\"Nmax\");\n  const samplesInput = document.getElementById(\"samples\");\n  const spacingSelect = document.getElementById(\"spacing\");\n  const analyzeBtn = document.getElementById(\"analyze\");\n  const resetBtn = document.getElementById(\"reset\");\n  const plot = document.getElementById(\"plot\");\n  const ctx = plot.getContext(\"2d\");\n  const metrics = document.getElementById(\"metrics\");\n  const conclusion = document.getElementById(\"conclusion\");\n  const notes = document.getElementById(\"notes\");\n\n  function toggleCustom(select, wrap){\n    if(select.value === \"custom\") wrap.style.display = \"\";\n    else wrap.style.display = \"none\";\n  }\n\n  fSelect.addEventListener(\"change\", ()=> toggleCustom(fSelect, fCustomWrap));\n  gSelect.addEventListener(\"change\", ()=> toggleCustom(gSelect, gCustomWrap));\n\n  // chips quick examples\n  document.querySelectorAll(\".chip\").forEach(ch => {\n    ch.addEventListener(\"click\", ()=>{\n      fSelect.value = ch.dataset.f ? \"custom\" : fSelect.value;\n      gSelect.value = ch.dataset.g ? \"custom\" : gSelect.value;\n      if(ch.dataset.f){ fSelect.value = \"custom\"; fCustomWrap.style.display = \"\"; fCustom.value = ch.dataset.f; }\n      if(ch.dataset.g){ gSelect.value = \"custom\"; gCustomWrap.style.display = \"\"; gCustom.value = ch.dataset.g; }\n      analyze();\n    });\n  });\n\n  function reset(){\n    fSelect.value = \"3*n + 5\"; fCustomWrap.style.display = \"none\"; fCustom.value = \"\";\n    gSelect.value = \"n\"; gCustomWrap.style.display = \"none\"; gCustom.value = \"\";\n    n0Input.value = 1; NmaxInput.value = 200; samplesInput.value = 200; spacingSelect.value = \"linear\";\n    metrics.textContent = \"Press Analyze to compute.\";\n    conclusion.textContent = \"—\"; conclusion.className = \"status\";\n    notes.textContent = \"Notes: No values where g(n) = 0 are accepted. If g becomes nonpositive for sampled n, the tool will warn.\";\n    clearCanvas();\n  }\n\n  resetBtn.addEventListener(\"click\", reset);\n\n  function clearCanvas(){\n    ctx.clearRect(0,0,plot.width,plot.height);\n    ctx.fillStyle = \"#021a25\";\n    ctx.fillRect(0,0,plot.width,plot.height);\n  }\n  clearCanvas();\n\n  function sampleNs(n0, Nmax, samples, spacing){\n    const arr = [];\n    if(spacing === \"linear\"){\n      for(let i=0;i<samples;i++){\n        const t = (samples===1)?0: i/(samples-1);\n        const val = n0 + t*(Nmax - n0);\n        arr.push(Math.max(1, val));\n      }\n    } else {\n      // log spacing between n0..Nmax\n      const a = Math.log(Math.max(1,n0));\n      const b = Math.log(Math.max(1,Nmax));\n      for(let i=0;i<samples;i++){\n        const t = (samples===1)?0: i/(samples-1);\n        const val = Math.exp(a + t*(b-a));\n        arr.push(Math.max(1, val));\n      }\n    }\n    return arr;\n  }\n\n  function analyze(){\n    const fExpr = (fSelect.value === \"custom\") ? fCustom.value : fSelect.value;\n    const gExpr = (gSelect.value === \"custom\") ? gCustom.value : gSelect.value;\n    let fFn, gFn;\n    try{\n      fFn = makeFunc(fExpr);\n    }catch(e){\n      metrics.innerHTML = \"<div style='color:#fb7185'>Invalid f(n): \" + (e.message||e) + \"</div>\";\n      return;\n    }\n    try{\n      gFn = makeFunc(gExpr);\n    }catch(e){\n      metrics.innerHTML = \"<div style='color:#fb7185'>Invalid g(n): \" + (e.message||e) + \"</div>\";\n      return;\n    }\n\n    const n0 = Math.max(1, Number(n0Input.value) || 1);\n    const Nmax = Math.max(n0+1, Number(NmaxInput.value) || (n0+1));\n    const samples = Math.max(10, Math.min(2000, Number(samplesInput.value) || 200));\n    const spacing = spacingSelect.value;\n\n    const ns = sampleNs(n0, Nmax, samples, spacing);\n    const fvals = [];\n    const gvals = [];\n    const ratios = [];\n    let gNonpositiveCount = 0;\n    let nanCount = 0;\n    for(let i=0;i<ns.length;i++){\n      const n = ns[i];\n      let fv, gv;\n      try{ fv = Number(fFn(n)); } catch(e){ fv = NaN; }\n      try{ gv = Number(gFn(n)); } catch(e){ gv = NaN; }\n      if(!isFinite(fv) || isNaN(fv) || !isFinite(gv) || isNaN(gv)) nanCount++;\n      if(gv <= 0) gNonpositiveCount++;\n      fvals.push(fv); gvals.push(gv);\n      ratios.push( gv === 0 ? NaN : fv / gv );\n    }\n\n    // Determine observed c1 (min ratio) and c2 (max ratio) ignoring NaNs and Infs\n    const validRatios = ratios.filter(r => isFinite(r));\n    const validF = fvals.filter(x => isFinite(x));\n    const validG = gvals.filter(x => isFinite(x));\n    if(validRatios.length === 0){\n      metrics.innerHTML = \"<div style='color:#fb7185'>No valid ratio values (g(n) probably zero or expressions invalid on sampled n).</div>\";\n      conclusion.textContent = \"Undetermined\"; conclusion.className = \"status bad\";\n      notes.textContent = \"No finite ratios found. Check expressions and ensure g(n) > 0 on sampled n.\";\n      clearCanvas();\n      return;\n    }\n    const c1 = Math.min(...validRatios);\n    const c2 = Math.max(...validRatios);\n\n    // Check condition for Theta: we require c1>0 and c2 finite and c1 & c2 not extremely wide.\n    // Because this is sampled, we only give an experimental conclusion.\n    const isPositive = c1 > 0 && isFinite(c2);\n    // A heuristic: if c2/c1 isn't astronomically large (say < 1e9), consider strong evidence\n    const ratioSpread = (c1>0) ? (Math.abs(c2/c1)) : Infinity;\n    const strongEvidence = isPositive && ratioSpread < 1e9;\n\n    // Prepare metrics text\n    let metricsHtml = '';\n    metricsHtml += '<div><strong>f(n):</strong> <code>' + escapeHtml(fExpr) + '</code></div>';\n    metricsHtml += '<div><strong>g(n):</strong> <code>' + escapeHtml(gExpr) + '</code></div>';\n    metricsHtml += '<div style=\"margin-top:6px\"><strong>Sample n from</strong> ' + n0 + ' to ' + Nmax + ' (' + samples + ' points)</div>';\n    metricsHtml += '<div style=\"margin-top:6px\"><strong>Observed min ratio</strong> c1 = ' + formatNum(c1) + '</div>';\n    metricsHtml += '<div><strong>Observed max ratio</strong> c2 = ' + formatNum(c2) + '</div>';\n    metricsHtml += '<div style=\"margin-top:6px\"><strong>Spread (c2/c1)</strong> = ' + (isFinite(ratioSpread) ? formatNum(ratioSpread) : '∞') + '</div>';\n    if(nanCount>0) metricsHtml += '<div style=\"margin-top:6px;color:#fca5a5\">Warning: ' + nanCount + ' sample(s) produced NaN or ±Infinity.</div>';\n    if(gNonpositiveCount>0) metricsHtml += '<div style=\"margin-top:6px;color:#fca5a5\">Warning: g(n) ≤ 0 for ' + gNonpositiveCount + ' sample(s). Ratios may be invalid.</div>';\n    metrics.innerHTML = metricsHtml;\n\n    // Conclusion text\n    if(isPositive){\n      if(strongEvidence){\n        conclusion.textContent = \"f(n) ∈ Θ(g(n)) (strong evidence)\";\n        conclusion.className = \"status good\";\n      } else {\n        conclusion.textContent = \"f(n) ∈ Θ(g(n)) (weak evidence — wide bounds)\";\n        conclusion.className = \"status good\";\n      }\n    } else {\n      conclusion.textContent = \"f(n) ∉ Θ(g(n)) (evidence)\";\n      conclusion.className = \"status bad\";\n    }\n\n    // Plot the functions and bounds\n    drawPlot(ns, fvals, gvals, ratios, c1, c2, {n0, Nmax});\n  }\n\n  analyzeBtn.addEventListener(\"click\", analyze);\n\n  // Helpers\n  function formatNum(x){\n    if(x === Infinity) return \"Infinity\";\n    if(x === -Infinity) return \"-Infinity\";\n    if(isNaN(x)) return \"NaN\";\n    const abs = Math.abs(x);\n    if(abs === 0) return \"0\";\n    if(abs < 1e-6 || abs > 1e9) return x.toExponential(3);\n    return (Math.round(x*1e6)/1e6).toString();\n  }\n  function escapeHtml(s){\n    return s.replace(/&/g,\"&amp;\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\");\n  }\n\n  // Drawing utility\n  function drawPlot(ns, fvals, gvals, ratios, c1, c2, opts){\n    const W = plot.width = plot.clientWidth * devicePixelRatio;\n    const H = plot.height = 340 * devicePixelRatio;\n    ctx.setTransform(1,0,0,1,0,0);\n    ctx.scale(devicePixelRatio, devicePixelRatio);\n    const w = plot.clientWidth; const h = 340;\n    // Clear\n    ctx.clearRect(0,0,w,h);\n    // Background\n    const grd = ctx.createLinearGradient(0,0,0,h);\n    grd.addColorStop(0,'#021822'); grd.addColorStop(1,'#01101a');\n    ctx.fillStyle = grd;\n    ctx.fillRect(0,0,w,h);\n\n    // Prepare scales\n    // For top plot (f and g) use log scale for y to handle big dynamic range, but keep linear if values small\n    const allY = fvals.concat(gvals).filter(v => isFinite(v) && v>0);\n    const yMin = allY.length ? Math.min(...allY) : 0;\n    const yMax = allY.length ? Math.max(...allY) : 1;\n\n    const useLog = (yMax / Math.max(yMin,1)) > 100; // if very wide, use log\n    const marginLeft = 56, marginRight=16, marginTop=14, marginBottom=110;\n    const plotW = w - marginLeft - marginRight, plotH = h - marginTop - marginBottom;\n\n    // X scale linear from ns[0] to ns[ns.length-1]\n    const nMin = ns[0], nMax = ns[ns.length-1];\n\n    function xOf(n){ return marginLeft + ((n - nMin) / (nMax - nMin || 1)) * plotW; }\n    function yOf(val){\n      if(!isFinite(val) || val <= 0) return marginTop + plotH; // bottom for invalid\n      if(useLog){\n        const ly = Math.log(val);\n        const lmin = Math.log(Math.max(1e-9, yMin));\n        const lmax = Math.log(Math.max(1e-9, yMax));\n        return marginTop + (1 - (ly - lmin)/(lmax - lmin || 1)) * plotH;\n      } else {\n        return marginTop + (1 - (val - yMin)/(yMax - yMin || 1)) * plotH;\n      }\n    }\n\n    // Draw gridlines and axes\n    ctx.strokeStyle = \"rgba(255,255,255,0.04)\";\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    // horizontal grid\n    for(let i=0;i<=4;i++){\n      const y = marginTop + (i/4)*plotH;\n      ctx.moveTo(marginLeft, y); ctx.lineTo(w - marginRight, y);\n    }\n    // vertical grid\n    for(let i=0;i<=6;i++){\n      const x = marginLeft + (i/6)*plotW;\n      ctx.moveTo(x, marginTop); ctx.lineTo(x, marginTop+plotH);\n    }\n    ctx.stroke();\n\n    // Axis labels (x)\n    ctx.fillStyle = \"#9fbccd\";\n    ctx.font = \"12px \" + getComputedStyle(document.body).fontFamily;\n    ctx.textAlign = \"center\";\n    for(let i=0;i<=6;i++){\n      const nVal = nMin + (i/6)*(nMax - nMin);\n      const x = marginLeft + (i/6)*plotW;\n      ctx.fillStyle = \"#7dd3fc\";\n      ctx.fillText((Math.round(nVal*100)/100).toString(), x, marginTop + plotH + 20);\n    }\n    // y labels\n    ctx.textAlign = \"right\";\n    for(let i=0;i<=4;i++){\n      const t = 1 - i/4;\n      let label;\n      if(useLog){\n        const lmin = Math.log(Math.max(1e-9, yMin));\n        const lmax = Math.log(Math.max(1e-9, yMax));\n        const val = Math.exp(lmin + t*(lmax - lmin));\n        label = formatNum(val);\n      } else {\n        const val = yMin + t*(yMax - yMin);\n        label = formatNum(val);\n      }\n      ctx.fillStyle = \"#94a3b8\";\n      ctx.fillText(label, marginLeft - 8, marginTop + i*(plotH/4)+4);\n    }\n\n    // Draw f(n) and g(n)\n    function drawLine(vals, color, width, dash){\n      ctx.beginPath();\n      for(let i=0;i<ns.length;i++){\n        const x = xOf(ns[i]);\n        const y = isFinite(vals[i]) && vals[i] > 0 ? yOf(vals[i]) : (marginTop + plotH);\n        if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n      }\n      ctx.strokeStyle = color; ctx.lineWidth = width;\n      if(dash){ ctx.setLineDash(dash); } else ctx.setLineDash([]);\n      ctx.stroke();\n      ctx.setLineDash([]);\n    }\n\n    drawLine(gvals, \"#60a5fa\", 2.2, [6,4]); // g dashed\n    drawLine(fvals, \"#7dd3fc\", 2.6, []); // f\n\n    // Draw c1*g and c2*g bounds (if finite)\n    if(isFinite(c1)){\n      const cg1 = gvals.map(v => isFinite(v) ? v*c1 : NaN);\n      drawLine(cg1, \"rgba(16,185,129,0.9)\", 1.8, [2,4]); // lower bound\n    }\n    if(isFinite(c2)){\n      const cg2 = gvals.map(v => isFinite(v) ? v*c2 : NaN);\n      drawLine(cg2, \"rgba(251,113,133,0.9)\", 1.8, [2,4]); // upper bound\n    }\n\n    // Legend\n    ctx.fillStyle = \"#e6eef8\"; ctx.font = \"12px \" + getComputedStyle(document.body).fontFamily; ctx.textAlign = \"left\";\n    const legendX = marginLeft, legendY = marginTop + 8;\n    drawLegendSwatch(legendX, legendY, \"#7dd3fc\", \"f(n)\");\n    drawLegendSwatch(legendX + 100, legendY, \"#60a5fa\", \"g(n)\");\n    drawLegendSwatch(legendX + 200, legendY, \"rgba(16,185,129,0.9)\", \"c1·g(n)\");\n    drawLegendSwatch(legendX + 320, legendY, \"rgba(251,113,133,0.9)\", \"c2·g(n)\");\n\n    function drawLegendSwatch(x,y,color,label){\n      ctx.fillStyle = color;\n      ctx.fillRect(x, y-10, 10, 6);\n      ctx.fillStyle = \"#cfeefd\";\n      ctx.fillText(label, x+16, y-1);\n    }\n\n    // Ratio subplot (below)\n    const ryTop = marginTop + plotH + 36;\n    const ryH = h - ryTop - 20;\n    // background\n    ctx.fillStyle = \"#021a25\";\n    ctx.fillRect(marginLeft, ryTop, plotW, ryH);\n    // axes\n    ctx.strokeStyle = \"rgba(255,255,255,0.04)\";\n    ctx.strokeRect(marginLeft, ryTop, plotW, ryH);\n\n    // Compute ratio extents\n    const validRatios = ratios.filter(r => isFinite(r));\n    const rMin = Math.min(...validRatios);\n    const rMax = Math.max(...validRatios);\n    const rPad = (rMax - rMin) * 0.12 || 1;\n    const rLo = rMin - rPad, rHi = rMax + rPad;\n\n    // ratio scales\n    function ryOf(val){\n      if(!isFinite(val)) return ryTop + ryH;\n      return ryTop + (1 - (val - rLo)/(rHi - rLo || 1)) * ryH;\n    }\n\n    // draw ratio line\n    ctx.beginPath();\n    for(let i=0;i<ns.length;i++){\n      const x = xOf(ns[i]);\n      const y = ryOf(ratios[i]);\n      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n    }\n    ctx.strokeStyle = \"#ffd166\"; ctx.lineWidth = 1.8; ctx.stroke();\n\n    // draw horizontal c1 and c2\n    if(isFinite(c1)){\n      ctx.beginPath(); ctx.moveTo(marginLeft, ryOf(c1)); ctx.lineTo(marginLeft+plotW, ryOf(c1));\n      ctx.strokeStyle = \"rgba(16,185,129,0.9)\"; ctx.setLineDash([4,3]); ctx.stroke(); ctx.setLineDash([]);\n      ctx.fillStyle = \"#10b981\"; ctx.textAlign = \"right\"; ctx.fillText(\"c1=\" + formatNum(c1), marginLeft+plotW-6, ryOf(c1)-6);\n    }\n    if(isFinite(c2)){\n      ctx.beginPath(); ctx.moveTo(marginLeft, ryOf(c2)); ctx.lineTo(marginLeft+plotW, ryOf(c2));\n      ctx.strokeStyle = \"rgba(251,113,133,0.9)\"; ctx.setLineDash([4,3]); ctx.stroke(); ctx.setLineDash([]);\n      ctx.fillStyle = \"#fb7185\"; ctx.textAlign = \"right\"; ctx.fillText(\"c2=\" + formatNum(c2), marginLeft+plotW-6, ryOf(c2)-6);\n    }\n\n    // ratio y labels\n    ctx.fillStyle = \"#94a3b8\"; ctx.textAlign = \"right\";\n    for(let i=0;i<=3;i++){\n      const t = i/3;\n      const val = rHi - t*(rHi - rLo);\n      ctx.fillText(formatNum(val), marginLeft - 8, ryTop + t*ryH + 4);\n    }\n    // x-labels\n    ctx.textAlign = \"center\";\n    for(let i=0;i<=4;i++){\n      const nVal = nMin + (i/4)*(nMax - nMin);\n      const x = marginLeft + (i/4)*plotW;\n      ctx.fillStyle = \"#7dd3fc\";\n      ctx.fillText((Math.round(nVal*100)/100).toString(), x, ryTop + ryH + 20);\n    }\n\n    // Small caption\n    ctx.fillStyle = \"#9fbccd\"; ctx.textAlign = \"left\";\n    ctx.fillText(\"Top: f(n) (solid) and g(n) (dashed) with bounds c1·g and c2·g. Bottom: ratio f(n)/g(n).\", marginLeft, ryTop - 10);\n\n    // tiny dots for the first few and last few points to show behavior\n    ctx.fillStyle = \"#fff\"; ctx.globalAlpha = 0.6;\n    for(let i=0;i<ns.length;i+=Math.max(1, Math.floor(ns.length/80))){\n      const x = xOf(ns[i]);\n      const y = yOf(fvals[i]);\n      ctx.beginPath(); ctx.arc(x, y, 2, 0, Math.PI*2); ctx.fill();\n    }\n    ctx.globalAlpha = 1;\n  }\n\n  // initial analyze on load\n  analyze();\n\n})();\n</script>\n</body>\n</html>"
