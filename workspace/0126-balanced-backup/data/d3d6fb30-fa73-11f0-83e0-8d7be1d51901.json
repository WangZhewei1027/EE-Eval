  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Exponential Search Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root {\n      --bg: #0f1724;\n      --panel: #0b1220;\n      --accent: #06b6d4;\n      --muted: #94a3b8;\n      --good: #10b981;\n      --bad: #ef4444;\n      --cell: #111827;\n      --cell-border: #1f2937;\n      --text: #e6eef6;\n    }\n    * { box-sizing: border-box; font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; }\n    body {\n      margin: 0;\n      background: linear-gradient(180deg, var(--bg) 0%, #081024 100%);\n      color: var(--text);\n      padding: 20px;\n    }\n    header {\n      display:flex;\n      gap: 16px;\n      align-items:center;\n      margin-bottom: 18px;\n    }\n    h1 { font-size: 20px; margin: 0; }\n    .container {\n      display: grid;\n      grid-template-columns: 420px 1fr;\n      gap: 18px;\n      align-items: start;\n    }\n    .panel {\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);\n      border: 1px solid rgba(255,255,255,0.04);\n      padding: 14px;\n      border-radius: 10px;\n      box-shadow: 0 6px 30px rgba(2,6,23,0.6);\n    }\n    .controls .row { display:flex; gap:8px; margin-bottom:10px; align-items:center; }\n    label { font-size: 13px; color: var(--muted); min-width: 70px; }\n    input[type=\"number\"], input[type=\"text\"], select {\n      background: var(--panel);\n      border: 1px solid var(--cell-border);\n      color: var(--text);\n      padding: 8px;\n      border-radius: 8px;\n      outline: none;\n      min-width: 0;\n    }\n    button {\n      background: var(--accent);\n      border: none;\n      color: #022;\n      padding: 8px 12px;\n      border-radius: 8px;\n      cursor: pointer;\n      font-weight: 600;\n    }\n    button.ghost {\n      background: transparent;\n      border: 1px solid rgba(255,255,255,0.06);\n      color: var(--text);\n    }\n    .array-visual {\n      display:flex;\n      gap:6px;\n      flex-wrap: wrap;\n      padding: 12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n      border-radius: 8px;\n      border: 1px dashed rgba(255,255,255,0.03);\n      min-height: 84px;\n      align-items: center;\n    }\n    .cell {\n      background: var(--cell);\n      border: 1px solid var(--cell-border);\n      width: 48px;\n      height: 48px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      border-radius: 6px;\n      color: var(--muted);\n      font-weight: 700;\n      position: relative;\n      transition: transform 200ms ease, box-shadow 200ms ease;\n    }\n    .cell.index { font-size: 11px; height: 20px; width: 48px; margin-top:4px; color: var(--muted); font-weight:600; }\n    .cell.highlight { box-shadow: 0 6px 18px rgba(6,182,212,0.12); transform: translateY(-6px); color: #012; background: linear-gradient(180deg,var(--accent),#00bcd4); }\n    .cell.exp { background: linear-gradient(180deg,#7c3aed,#b0a5f8); color: #fff; box-shadow: 0 8px 26px rgba(124,58,237,0.14); }\n    .cell.range { background: linear-gradient(180deg,#fde68a,#facc15); color: #042; }\n    .cell.mid { background: linear-gradient(180deg,#60a5fa,#3b82f6); color: #042; }\n    .cell.found { background: linear-gradient(180deg,#34d399,#10b981); color:#042; box-shadow: 0 8px 26px rgba(16,185,129,0.14); }\n    .legend { display:flex; gap:8px; margin-top:8px; flex-wrap:wrap; }\n    .legend span { display:inline-flex; gap:6px; align-items:center; font-size:13px; color:var(--muted); }\n    .dot { width:14px;height:14px;border-radius:4px;display:inline-block; }\n    .log { background: rgba(255,255,255,0.02); padding:8px; border-radius:8px; max-height:150px; overflow:auto; font-size:13px; color:var(--muted); }\n    .stats { display:flex; gap:10px; margin-top:10px; flex-wrap:wrap; }\n    .stat { background: rgba(255,255,255,0.02); padding:8px 10px; border-radius:8px; color:var(--muted); font-size:13px; }\n    .explain { margin-top:12px; font-size:13px; color:var(--muted); line-height:1.4; }\n    .complex { margin-top:12px; padding:10px; background: rgba(255,255,255,0.02); border-radius:8px; color:var(--muted); font-size:13px; }\n    footer { margin-top:18px; color:var(--muted); font-size:13px; }\n    .controls .small { font-size: 13px; color: var(--muted); }\n    .speed { width:100%; }\n    @media (max-width:900px) {\n      .container { grid-template-columns: 1fr; }\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Exponential Search — Interactive Visualizer</h1>\n    <div style=\"margin-left:auto; color:var(--muted); font-size:13px;\">Visual steps + explanations</div>\n  </header>\n\n  <div class=\"container\">\n    <div class=\"panel controls\">\n      <div class=\"row\">\n        <label>Array size</label>\n        <input id=\"size\" type=\"number\" min=\"3\" max=\"70\" value=\"20\" />\n        <label style=\"min-width:60px;\">Values</label>\n        <input id=\"minVal\" type=\"number\" value=\"1\" style=\"width:70px;\" />\n        <input id=\"maxVal\" type=\"number\" value=\"200\" style=\"width:70px;\" />\n        <button id=\"genBtn\" class=\"ghost\">Generate</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Target</label>\n        <input id=\"target\" type=\"text\" placeholder=\"Enter a number\" />\n        <button id=\"setTarget\" class=\"ghost\">Set</button>\n        <button id=\"randomTarget\" class=\"ghost\">Random</button>\n      </div>\n\n      <div class=\"row\">\n        <label>Mode</label>\n        <select id=\"mode\">\n          <option value=\"auto\">Auto animate</option>\n          <option value=\"step\">Step-by-step</option>\n        </select>\n        <label class=\"small\">Speed</label>\n        <input id=\"speed\" class=\"speed\" type=\"range\" min=\"100\" max=\"2000\" value=\"700\" />\n      </div>\n\n      <div class=\"row\">\n        <button id=\"start\">Start</button>\n        <button id=\"stepBtn\" class=\"ghost\">Step</button>\n        <button id=\"resetBtn\" class=\"ghost\">Reset</button>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <div style=\"font-size:13px; color:var(--muted); margin-bottom:6px;\">Array (sorted ascending)</div>\n        <div id=\"array\" class=\"array-visual\" aria-live=\"polite\"></div>\n\n        <div class=\"legend\">\n          <span><span class=\"dot\" style=\"background:var(--accent)\"></span> Exponential/current probe</span>\n          <span><span class=\"dot\" style=\"background:#7c3aed\"></span> Exponential index</span>\n          <span><span class=\"dot\" style=\"background:#fde68a\"></span> Search range</span>\n          <span><span class=\"dot\" style=\"background:#60a5fa\"></span> Mid (binary)</span>\n          <span><span class=\"dot\" style=\"background:#34d399\"></span> Found</span>\n        </div>\n\n        <div class=\"stats\">\n          <div class=\"stat\">Comparisons: <span id=\"comparisons\">0</span></div>\n          <div class=\"stat\">Steps: <span id=\"steps\">0</span></div>\n          <div class=\"stat\">Result: <span id=\"result\">—</span></div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <div style=\"font-weight:700; margin-bottom:8px;\">Algorithm explanation</div>\n        <div class=\"explain\">\n          Exponential Search first finds a range where the target could appear by checking indices 1, 2, 4, 8, ... (doubling each time) until a value greater than or equal to the target is found or the end of array is reached. Then it runs a binary search in the identified range. It is especially effective for unbounded or exponential-growing data.\n        </div>\n        <div class=\"complex\">\n          Time complexity: O(log i) where i is the position of the target (plus binary search within the found range). Worst-case O(log n).\n        </div>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n        <div style=\"font-weight:700;\">Execution Log</div>\n        <div style=\"color:var(--muted); font-size:13px;\">Use Step mode to step manually</div>\n      </div>\n      <div id=\"log\" class=\"log\" aria-live=\"polite\" style=\"margin-top:8px;\"></div>\n\n      <div style=\"margin-top:12px;\">\n        <div style=\"font-weight:700; margin-bottom:6px;\">Walkthrough</div>\n        <div id=\"walk\" class=\"explain\">No run yet. Generate an array and start searching to see a step-by-step walkthrough.</div>\n      </div>\n\n      <footer>\n        Tip: Try targets present and not present. The visualizer highlights probes (exponential phase) and then the binary search between the found range.\n      </footer>\n    </div>\n  </div>\n\n  <script>\n    // Utility functions\n    const el = id => document.getElementById(id);\n    const arrayEl = el('array');\n    const logEl = el('log');\n    const walkEl = el('walk');\n    const comparisonsEl = el('comparisons');\n    const stepsEl = el('steps');\n    const resultEl = el('result');\n\n    let arr = [];\n    let stateGen = null;\n    let running = false;\n    let autoTimer = null;\n    let comparisons = 0;\n    let steps = 0;\n\n    function randomInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n\n    function generateArray(size, minV, maxV) {\n      const set = [];\n      // generate sorted values (allow duplicates)\n      for (let i=0;i<size;i++){\n        // ensure increasing trend by adding random increment\n        const prev = set.length ? set[set.length-1] : minV - 1;\n        const next = Math.min(maxV, Math.max(prev + 0, randomInt(minV, maxV)));\n        set.push(next);\n      }\n      // ensure sorted ascending (non-decreasing)\n      set.sort((a,b)=>a-b);\n      // if all equal, perturb a bit\n      for (let i=1;i<set.length;i++){\n        if (set[i] <= set[i-1]) set[i] = set[i-1] + randomInt(0,2);\n      }\n      // clip to max\n      return set.map(v => Math.min(v, maxV));\n    }\n\n    function renderArray(highlights = {}) {\n      // highlights: {exp: idx, expIdxs:[], range:[l,h], mid, foundIdx}\n      arrayEl.innerHTML = '';\n      const size = arr.length;\n      for (let i=0;i<size;i++){\n        const cell = document.createElement('div');\n        cell.className = 'cell';\n        let label = document.createElement('div');\n        label.textContent = arr[i];\n        cell.appendChild(label);\n\n        // index row\n        const idx = document.createElement('div');\n        idx.className = 'cell index';\n        idx.textContent = i;\n        idx.style.position = 'absolute';\n        idx.style.bottom = '-22px';\n        idx.style.left = '6px';\n        idx.style.width = '36px';\n        cell.appendChild(idx);\n\n        if (highlights.foundIdx === i) {\n          cell.classList.add('found');\n        } else if (highlights.exp === i) {\n          cell.classList.add('highlight');\n        } else if (highlights.expIdxs && highlights.expIdxs.includes(i)) {\n          cell.classList.add('exp');\n        } else if (highlights.range && i >= highlights.range[0] && i <= highlights.range[1]) {\n          cell.classList.add('range');\n        } else if (highlights.mid === i) {\n          cell.classList.add('mid');\n        }\n\n        arrayEl.appendChild(cell);\n      }\n    }\n\n    function log(msg) {\n      const p = document.createElement('div');\n      p.textContent = msg;\n      logEl.prepend(p);\n    }\n\n    function resetLog() {\n      logEl.innerHTML = '';\n    }\n\n    function setComparisons(n){ comparisons = n; comparisonsEl.textContent = comparisons; }\n    function incComp(){ comparisons++; comparisonsEl.textContent = comparisons; }\n\n    function setSteps(n){ steps = n; stepsEl.textContent = steps; }\n    function incStep(){ steps++; stepsEl.textContent = steps; }\n\n    // Exponential search implemented as a generator to step through states\n    function* exponentialSearchGenerator(a, target) {\n      setComparisons(0);\n      setSteps(0);\n      if (a.length === 0) {\n        log('Array empty.');\n        resultEl.textContent = 'Not found';\n        yield { done: true };\n        return;\n      }\n      log(`Start search for ${target}.`);\n      yield { msg: `Start search for ${target}.`, highlights: {} };\n\n      incStep();\n      // Check first element\n      incComp();\n      log(`Compare a[0] = ${a[0]} with target ${target}`);\n      yield { msg: `Compare a[0] = ${a[0]} with target ${target}`, highlights: { exp: 0, expIdxs: [0] } };\n\n      if (a[0] === target) {\n        log(`Found at index 0.`);\n        resultEl.textContent = 'Found at 0';\n        yield { done: true, found: 0, highlights: { foundIdx: 0 } };\n        return;\n      }\n\n      // Exponential phase\n      let i = 1;\n      const expIdxs = [0];\n      while (i < a.length) {\n        incStep();\n        incComp();\n        log(`Compare a[${i}] = ${a[i]} with target ${target}`);\n        yield { msg: `Compare a[${i}] = ${a[i]} with target ${target}`, highlights: { exp: i, expIdxs: expIdxs.slice() } };\n\n        expIdxs.push(i);\n        if (a[i] >= target) {\n          log(`Found range: indices ${Math.floor(i/2)} to ${i}`);\n          yield { msg: `Range found: [${Math.floor(i/2)}, ${i}]`, highlights: { range: [Math.floor(i/2), i], expIdxs: expIdxs.slice() } };\n          break;\n        }\n        i = i * 2;\n      }\n\n      if (i >= a.length) {\n        // range is [i/2, n-1]\n        const low = Math.floor(i/2);\n        const high = a.length - 1;\n        log(`Reached or exceeded array end. Range: [${low}, ${high}]`);\n        yield { msg: `Range found: [${low}, ${high}]`, highlights: { range: [low, high], expIdxs: expIdxs.slice() } };\n\n        // proceed with binary search on low..high\n        const result = yield* binarySearchGenerator(a, target, low, high, expIdxs);\n        return result;\n      } else {\n        const low = Math.floor(i/2);\n        const high = i;\n        const result = yield* binarySearchGenerator(a, target, low, high, expIdxs);\n        return result;\n      }\n    }\n\n    function* binarySearchGenerator(a, target, low, high, expIdxs = []) {\n      let l = low;\n      let h = Math.min(high, a.length - 1);\n      while (l <= h) {\n        incStep();\n        const mid = Math.floor((l + h) / 2);\n        incComp();\n        log(`Binary search compare a[${mid}] = ${a[mid]} with target ${target} (range [${l}, ${h}])`);\n        yield { msg: `Binary compare mid=${mid}: a[${mid}]=${a[mid]}`, highlights: { range: [l, h], mid, expIdxs: expIdxs.slice() } };\n\n        if (a[mid] === target) {\n          log(`Found at index ${mid}.`);\n          resultEl.textContent = `Found at ${mid}`;\n          yield { done: true, found: mid, highlights: { foundIdx: mid } };\n          return { index: mid };\n        } else if (a[mid] < target) {\n          log(`a[${mid}] < target; move right: new range [${mid+1}, ${h}]`);\n          l = mid + 1;\n          yield { msg: `Move right to [${l}, ${h}]`, highlights: { range: [l, h], expIdxs: expIdxs.slice() } };\n        } else {\n          log(`a[${mid}] > target; move left: new range [${l}, ${mid-1}]`);\n          h = mid - 1;\n          yield { msg: `Move left to [${l}, ${h}]`, highlights: { range: [l, h], expIdxs: expIdxs.slice() } };\n        }\n      }\n      log(`Target ${target} not found in range [${low}, ${high}].`);\n      resultEl.textContent = 'Not found';\n      yield { done: true, found: -1 };\n      return { index: -1 };\n    }\n\n    // Controls wiring\n    function generateAndRender() {\n      const size = Math.max(3, Math.min(70, parseInt(el('size').value) || 20));\n      const minV = parseInt(el('minVal').value) || 1;\n      const maxV = Math.max(minV + 1, parseInt(el('maxVal').value) || 100);\n      arr = generateArray(size, minV, maxV);\n      renderArray();\n      resetLog();\n      walkEl.textContent = 'Array generated. Set a target and press Start.';\n      setComparisons(0);\n      setSteps(0);\n      resultEl.textContent = '—';\n      stateGen = null;\n      stopAuto();\n    }\n\n    el('genBtn').addEventListener('click', () => {\n      generateAndRender();\n    });\n\n    el('setTarget').addEventListener('click', () => {\n      const t = parseInt(el('target').value);\n      if (Number.isNaN(t)) { alert('Enter a valid number as target.'); return; }\n      el('target').value = t;\n      walkEl.textContent = `Target set to ${t}. Press Start.`;\n    });\n\n    el('randomTarget').addEventListener('click', () => {\n      if (!arr.length) { alert('Generate array first.'); return; }\n      const pick = arr[randomInt(0, arr.length-1)];\n      el('target').value = pick;\n      walkEl.textContent = `Target randomly set to ${pick}. Press Start.`;\n    });\n\n    el('start').addEventListener('click', () => {\n      const mode = el('mode').value;\n      const tStr = el('target').value.trim();\n      if (!tStr) { alert('Please set a target number.'); return; }\n      const t = parseInt(tStr);\n      if (Number.isNaN(t)) { alert('Invalid target number.'); return; }\n      if (!arr.length) { generateAndRender(); }\n\n      // Ensure array sorted\n      for (let i=1;i<arr.length;i++){\n        if (arr[i] < arr[i-1]) {\n          alert('Array must be sorted ascending. Please regenerate.');\n          return;\n        }\n      }\n\n      resetLog();\n      setComparisons(0);\n      setSteps(0);\n      resultEl.textContent = '—';\n      stateGen = exponentialSearchGenerator(arr, t);\n      // first next to show initial state\n      const first = stateGen.next();\n      if (first.value && first.value.highlights) renderArray(first.value.highlights);\n      if (first.value && first.value.msg) walkEl.textContent = first.value.msg;\n      if (mode === 'auto') {\n        startAuto();\n      } else {\n        walkEl.textContent = 'Step one shown. Click Step to continue.';\n      }\n    });\n\n    el('stepBtn').addEventListener('click', () => {\n      if (!stateGen) { alert('Start a search first.'); return; }\n      stepOnce();\n    });\n\n    el('resetBtn').addEventListener('click', () => {\n      stopAuto();\n      stateGen = null;\n      resetLog();\n      renderArray();\n      setComparisons(0);\n      setSteps(0);\n      resultEl.textContent = '—';\n      walkEl.textContent = 'Reset. You may start again.';\n    });\n\n    el('speed').addEventListener('input', () => {\n      if (running) {\n        stopAuto();\n        startAuto();\n      }\n    });\n\n    function stepOnce() {\n      if (!stateGen) return;\n      const n = stateGen.next();\n      if (n.done) {\n        // done or generator returned\n        running = false;\n        stopAuto();\n        if (n.value && n.value.highlights) renderArray(n.value.highlights);\n        walkEl.textContent = n.value && n.value.msg ? n.value.msg : 'Done';\n        return;\n      }\n      const v = n.value;\n      if (v.msg) walkEl.textContent = v.msg;\n      if (v.highlights) renderArray(v.highlights);\n      // if done flagged in value\n      if (v.done) {\n        running = false;\n        stopAuto();\n        if (v.highlights) renderArray(v.highlights);\n      }\n    }\n\n    function startAuto() {\n      if (!stateGen) {\n        alert('Start a search first.');\n        return;\n      }\n      const speed = parseInt(el('speed').value) || 700;\n      running = true;\n      autoTimer = setInterval(() => {\n        try {\n          const n = stateGen.next();\n          if (n.value && n.value.msg) walkEl.textContent = n.value.msg;\n          if (n.value && n.value.highlights) renderArray(n.value.highlights);\n          if (n.done || (n.value && n.value.done)) {\n            stopAuto();\n            running = false;\n            if (n.value && n.value.highlights) renderArray(n.value.highlights);\n            walkEl.textContent = n.value && n.value.msg ? n.value.msg : 'Done';\n          }\n        } catch (e) {\n          stopAuto();\n          console.error(e);\n        }\n      }, Math.max(50, speed));\n    }\n\n    function stopAuto() {\n      if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }\n    }\n\n    // Initialize\n    generateAndRender();\n\n    // Accessibility: keyboard shortcuts\n    document.addEventListener('keydown', (e) => {\n      if (e.key === ' ') { // space -> step when in step mode\n        if (el('mode').value === 'step') {\n          e.preventDefault();\n          if (!stateGen) return;\n          stepOnce();\n        }\n      }\n      if (e.key === 'r') { // r -> regenerate\n        generateAndRender();\n      }\n    });\n\n    // Expose debug on window for advanced users (optional)\n    window._expViz = {\n      getArray: () => arr,\n      setArray: (a) => { arr = a.slice(); renderArray(); resetLog(); }\n    };\n  </script>\n</body>\n</html>"
  },
