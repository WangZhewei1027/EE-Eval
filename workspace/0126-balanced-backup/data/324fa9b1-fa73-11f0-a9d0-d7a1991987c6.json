  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interpreter Pattern Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .result {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            background-color: #f9f9f9;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interpreter Pattern Demo</h1>\n    <p>Input a mathematical expression using numbers and '+' or '-' operators:</p>\n    <input type=\"text\" id=\"expression\" placeholder=\"e.g., 3 + 5 - 2\">\n    <button id=\"interpret-btn\">Interpret</button>\n    \n    <div class=\"result\" id=\"result\"></div>\n\n    <script>\n        // Abstract expression\n        class Expression {\n            interpret() {\n                throw new Error(\"This method should be implemented by the concrete class.\");\n            }\n        }\n\n        // Terminal expressions for numbers\n        class NumberExpression extends Expression {\n            constructor(value) {\n                super();\n                this.value = value;\n            }\n            \n            interpret() {\n                return this.value;\n            }\n        }\n\n        // Non-terminal expression for addition\n        class AddExpression extends Expression {\n            constructor(left, right) {\n                super();\n                this.left = left;\n                this.right = right;\n            }\n\n            interpret() {\n                return this.left.interpret() + this.right.interpret();\n            }\n        }\n\n        // Non-terminal expression for subtraction\n        class SubtractExpression extends Expression {\n            constructor(left, right) {\n                super();\n                this.left = left;\n                this.right = right;\n            }\n\n            interpret() {\n                return this.left.interpret() - this.right.interpret();\n            }\n        }\n\n        // Function to parse the expression\n        function parseExpression(expression) {\n            const tokens = expression.split(\" \");\n            const stack = [];\n\n            tokens.forEach(token => {\n                if (!isNaN(token)) {\n                    stack.push(new NumberExpression(parseInt(token)));\n                } else if (token === '+') {\n                    const right = stack.pop();\n                    const left = stack.pop();\n                    stack.push(new AddExpression(left, right));\n                } else if (token === '-') {\n                    const right = stack.pop();\n                    const left = stack.pop();\n                    stack.push(new SubtractExpression(left, right));\n                }\n            });\n\n            return stack[0];\n        }\n\n        // Handle the button click event\n        document.getElementById('interpret-btn').addEventListener('click', function() {\n            const expressionInput = document.getElementById('expression').value;\n            const expression = parseExpression(expressionInput);\n            const result = expression.interpret();\n\n            document.getElementById('result').textContent = 'Result: ' + result;\n        });\n    </script>\n</body>\n</html>"
