  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Kruskal's Algorithm - Interactive Demo</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n  body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 0; display: flex; height: 100vh; }\n  #left { width: 320px; min-width: 260px; padding: 12px; box-sizing: border-box; background: #fafafa; border-right: 1px solid #ddd; overflow-y: auto; }\n  #canvasWrap { flex: 1; display:flex; flex-direction:column; }\n  header { padding: 10px; border-bottom: 1px solid #eee; display:flex; gap:8px; align-items:center; background:#fff;}\n  header h1 { font-size: 16px; margin:0; flex:1; }\n  .controls { padding:10px; display:flex; gap:6px; flex-wrap:wrap; }\n  button { padding:6px 8px; border:1px solid #bbb; background:#fff; border-radius:4px; cursor:pointer; }\n  button.active { background:#007bff; color:#fff; border-color:#0062d6; }\n  button.warn { background:#ff704d; color:#fff; border-color:#e0552f; }\n  button.ghost { background:transparent; border-color:#aaa; }\n  #svg { flex:1; background: linear-gradient(180deg,#fff,#f7f7f7); cursor: crosshair; }\n  .panel { margin:8px 0; padding:8px; border:1px solid #eee; background:#fff; border-radius:6px; }\n  .small { font-size:13px; color:#444; }\n  label { display:block; font-size:13px; margin-bottom:4px; color:#333; }\n  input[type=\"range\"] { width:100%; }\n  .edge-list { max-height:220px; overflow:auto; font-size:13px; }\n  .edge-item { padding:6px; border-bottom:1px dashed #eee; display:flex; justify-content:space-between; gap:8px; align-items:center; }\n  .status { font-weight:600; padding:4px 6px; border-radius:6px; font-size:12px; }\n  .status.ok { background:#e7f9ef; color:#0a7a3b; border:1px solid #b9f0ce; }\n  .status.skip { background:#fff1f0; color:#a12b2b; border:1px solid #faccc9; }\n  .status.pending { background:#fff8e6; color:#8a5a00; border:1px solid #f5e0a8; }\n  .info { font-size:13px; color:#444; }\n  footer { padding:8px; border-top:1px solid #eee; background:#fff; display:flex; gap:8px; align-items:center; }\n  .hint { font-size:12px; color:#666; }\n  .btn-row { display:flex; gap:6px; flex-wrap:wrap; }\n  .node-label { pointer-events:none; font-size:12px; fill:#fff; font-weight:600; }\n  .weight-label { font-size:12px; fill:#111; background:transparent; }\n  .edge-line { stroke-width:3; stroke:#bbb; }\n  .edge-line.considered { stroke:#f0b429; stroke-width:5; }\n  .edge-line.included { stroke:#20a39e; stroke-width:5; }\n  .edge-line.skipped { stroke:#d9534f; stroke-width:4; stroke-dasharray:6 4; }\n  .node-circle { stroke:#444; stroke-width:1.5; fill:#777; cursor:pointer; }\n  .node-circle.selected { stroke:#0b5ed7; stroke-width:3px; }\n  .node-circle.color0 { fill:#20a39e; } /* reused for set colors */\n  .node-circle.color1 { fill:#ffc107; }\n  .node-circle.color2 { fill:#ff6b6b; }\n  .node-circle.color3 { fill:#6f42c1; }\n  .node-circle.color4 { fill:#0d6efd; }\n  .node-circle.color5 { fill:#6610f2; }\n  .node-circle.color6 { fill:#198754; }\n  .node-circle.color7 { fill:#fd7e14; }\n  .node-circle.color8 { fill:#20c997; }\n  .node-circle.color9 { fill:#0dcaf0; }\n  #topbar { display:flex; gap:8px; align-items:center; }\n  .small-muted { font-size:12px; color:#666; }\n  .footer-left { flex:1; }\n  .control-row { display:flex; gap:6px; align-items:center; }\n</style>\n</head>\n<body>\n  <div id=\"left\">\n    <header>\n      <h1>Kruskal's Algorithm</h1>\n      <div style=\"text-align:right\">\n        <div class=\"small-muted\">Interactive Demo</div>\n      </div>\n    </header>\n\n    <div class=\"controls\">\n      <div class=\"btn-row\">\n        <button id=\"mode-add-node\" class=\"active\">Add Node</button>\n        <button id=\"mode-add-edge\">Add Edge</button>\n        <button id=\"mode-move\">Move</button>\n        <button id=\"mode-delete\">Delete</button>\n      </div>\n      <div class=\"btn-row\" style=\"margin-top:6px;\">\n        <button id=\"btn-random\">Random Graph</button>\n        <button id=\"btn-clear\" class=\"ghost\">Clear</button>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"info\">\n        Click on the canvas to add nodes. In \"Add Edge\" mode, click two nodes to connect; you'll be prompted for a weight.\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <label>Run Controls</label>\n      <div style=\"display:flex; gap:6px; margin-bottom:8px;\">\n        <button id=\"btn-step\" class=\"active\">Step</button>\n        <button id=\"btn-run\">Auto Run</button>\n        <button id=\"btn-pause\" disabled>Pause</button>\n        <button id=\"btn-reset\">Reset Run</button>\n      </div>\n      <div style=\"display:flex; gap:8px; align-items:center;\">\n        <div class=\"small-muted\">Delay:</div>\n        <input id=\"speed\" type=\"range\" min=\"200\" max=\"2000\" step=\"100\" value=\"800\">\n        <div id=\"speedLabel\" class=\"small-muted\">800 ms</div>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <label>Edge List (sorted by weight):</label>\n      <div class=\"edge-list\" id=\"edgeList\"></div>\n    </div>\n\n    <div class=\"panel\">\n      <label>MST Info</label>\n      <div class=\"info\">Total weight: <strong id=\"mstWeight\">0</strong></div>\n      <div class=\"info\" style=\"margin-top:8px;\">MST edges:</div>\n      <div id=\"mstEdges\" class=\"info small\" style=\"margin-top:6px;\"></div>\n    </div>\n\n    <footer>\n      <div class=\"footer-left small-muted\">Click nodes/edges to edit weight or inspect.</div>\n      <div style=\"font-size:12px;color:#444;\">Disjoint Set visualization colors the components</div>\n    </footer>\n  </div>\n\n  <div id=\"canvasWrap\">\n    <div id=\"topbar\" style=\"padding:8px; border-bottom:1px solid #eee;\">\n      <div class=\"control-row\">\n        <div class=\"hint small-muted\">Mode:</div>\n        <div id=\"modeLabel\" class=\"small\" style=\"min-width:120px; font-weight:600\">Add Node</div>\n      </div>\n      <div style=\"flex:1\"></div>\n      <div class=\"small-muted\">Nodes: <span id=\"nodeCount\">0</span> • Edges: <span id=\"edgeCount\">0</span></div>\n    </div>\n    <svg id=\"svg\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1200 800\" preserveAspectRatio=\"xMidYMid slice\">\n      <defs>\n        <marker id=\"arrow\" viewBox=\"0 0 10 10\" refX=\"8\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto-start-reverse\">\n          <path d=\"M 0 0 L 10 5 L 0 10 z\" fill=\"#888\"></path>\n        </marker>\n      </defs>\n      <!-- edges and nodes will be appended here -->\n    </svg>\n  </div>\n\n<script>\n(function(){\n  // Simple interactive Kruskal demo with SVG\n  const svg = document.getElementById('svg');\n  const modeButtons = {\n    addNode: document.getElementById('mode-add-node'),\n    addEdge: document.getElementById('mode-add-edge'),\n    move: document.getElementById('mode-move'),\n    del: document.getElementById('mode-delete'),\n  };\n  const modeLabel = document.getElementById('modeLabel');\n  const btnRandom = document.getElementById('btn-random');\n  const btnClear = document.getElementById('btn-clear');\n  const btnStep = document.getElementById('btn-step');\n  const btnRun = document.getElementById('btn-run');\n  const btnPause = document.getElementById('btn-pause');\n  const btnReset = document.getElementById('btn-reset');\n  const speedInput = document.getElementById('speed');\n  const speedLabel = document.getElementById('speedLabel');\n  const edgeListDiv = document.getElementById('edgeList');\n  const mstWeightEl = document.getElementById('mstWeight');\n  const mstEdgesEl = document.getElementById('mstEdges');\n  const nodeCountEl = document.getElementById('nodeCount');\n  const edgeCountEl = document.getElementById('edgeCount');\n\n  let mode = 'addNode'; // addNode, addEdge, move, delete\n  function setMode(m){\n    mode = m;\n    Object.values(modeButtons).forEach(b => b.classList.remove('active'));\n    if(m === 'addNode') modeButtons.addNode.classList.add('active');\n    if(m === 'addEdge') modeButtons.addEdge.classList.add('active');\n    if(m === 'move') modeButtons.move.classList.add('active');\n    if(m === 'delete') modeButtons.del.classList.add('active');\n    modeLabel.textContent = ({addNode:'Add Node', addEdge:'Add Edge', move:'Move', delete:'Delete'})[m];\n    resetSelections();\n  }\n\n  modeButtons.addNode.addEventListener('click', ()=> setMode('addNode'));\n  modeButtons.addEdge.addEventListener('click', ()=> setMode('addEdge'));\n  modeButtons.move.addEventListener('click', ()=> setMode('move'));\n  modeButtons.del.addEventListener('click', ()=> setMode('delete'));\n\n  // Data\n  let nodes = []; // {id,x,y}\n  let edges = []; // {id,u,v,weight,status} status: pending/considered/included/skipped\n  let nodeId = 0, edgeId = 0;\n\n  // SVG elements map\n  const edgeGroup = document.createElementNS('http://www.w3.org/2000/svg','g');\n  const nodeGroup = document.createElementNS('http://www.w3.org/2000/svg','g');\n  svg.appendChild(edgeGroup);\n  svg.appendChild(nodeGroup);\n\n  // For creating edges: store first selected node\n  let firstNodeForEdge = null;\n  let selectedElement = null; // for moving\n  let dragOffset = {x:0,y:0};\n\n  // Kruskal state\n  let kruskalState = {\n    sortedEdges: [],\n    index: 0,\n    ds: null,\n    running: false,\n    timer: null\n  };\n\n  // Utility\n  function svgPoint(evt){\n    const pt = svg.createSVGPoint();\n    pt.x = evt.clientX;\n    pt.y = evt.clientY;\n    const ctm = svg.getScreenCTM().inverse();\n    const p = pt.matrixTransform(ctm);\n    return {x: p.x, y: p.y};\n  }\n\n  function addNodeAt(x,y){\n    const id = nodeId++;\n    nodes.push({id, x, y});\n    draw();\n    updateCounts();\n  }\n\n  function addEdge(uId, vId, weight){\n    if(uId === vId) return;\n    // avoid duplicate undirected edge\n    for(const e of edges){\n      if((e.u === uId && e.v === vId) || (e.u === vId && e.v === uId)) {\n        alert('Edge already exists between these nodes.');\n        return;\n      }\n    }\n    const id = edgeId++;\n    edges.push({id, u: uId, v: vId, weight: Number(weight), status: 'pending'});\n    draw();\n    updateCounts();\n  }\n\n  function deleteNode(id){\n    nodes = nodes.filter(n => n.id !== id);\n    edges = edges.filter(e => e.u !== id && e.v !== id);\n    draw();\n    updateCounts();\n  }\n\n  function deleteEdge(id){\n    edges = edges.filter(e => e.id !== id);\n    draw();\n    updateCounts();\n  }\n\n  function updateCounts(){\n    nodeCountEl.textContent = nodes.length;\n    edgeCountEl.textContent = edges.length;\n    refreshEdgeList();\n  }\n\n  // DSU\n  class DSU {\n    constructor(n){\n      this.parent = new Map();\n      this.rank = new Map();\n    }\n    makeSet(x){ this.parent.set(x,x); this.rank.set(x,0); }\n    find(x){\n      if(this.parent.get(x) !== x){\n        this.parent.set(x, this.find(this.parent.get(x)));\n      }\n      return this.parent.get(x);\n    }\n    union(a,b){\n      let ra = this.find(a), rb = this.find(b);\n      if(ra === rb) return false;\n      let raRank = this.rank.get(ra) || 0, rbRank = this.rank.get(rb) || 0;\n      if(raRank < rbRank) this.parent.set(ra, rb);\n      else if(raRank > rbRank) this.parent.set(rb, ra);\n      else { this.parent.set(rb, ra); this.rank.set(ra, raRank+1); }\n      return true;\n    }\n  }\n\n  function startKruskal(){\n    if(nodes.length === 0) return;\n    kruskalState.sortedEdges = edges.slice().sort((a,b) => a.weight - b.weight);\n    // reset statuses\n    for(const e of edges) e.status = 'pending';\n    kruskalState.index = 0;\n    kruskalState.ds = new DSU();\n    for(const n of nodes) kruskalState.ds.makeSet(n.id);\n    kruskalState.running = false;\n    clearInterval(kruskalState.timer);\n    refreshEdgeList();\n    recolorComponents();\n    draw();\n  }\n\n  function stepKruskal(){\n    if(!kruskalState.sortedEdges || kruskalState.index >= kruskalState.sortedEdges.length){\n      // finished\n      stopAuto();\n      return;\n    }\n    const e = kruskalState.sortedEdges[kruskalState.index];\n    // mark considered\n    const edgeObj = edges.find(x => x.id === e.id);\n    edgeObj.status = 'considered';\n    draw();\n    refreshEdgeList();\n\n    // check union\n    const u = e.u, v = e.v;\n    if(kruskalState.ds.find(u) !== kruskalState.ds.find(v)){\n      // include\n      kruskalState.ds.union(u,v);\n      edgeObj.status = 'included';\n    } else {\n      edgeObj.status = 'skipped';\n    }\n    recolorComponents();\n    kruskalState.index++;\n    draw();\n    refreshEdgeList();\n    updateMSTInfo();\n\n    if(kruskalState.index >= kruskalState.sortedEdges.length){\n      stopAuto();\n    }\n  }\n\n  function recolorComponents(){\n    // assign color indices per root\n    const mapRootToColor = new Map();\n    let colorIdx = 0;\n    for(const n of nodes){\n      const root = kruskalState.ds ? kruskalState.ds.find(n.id) : n.id;\n      if(!mapRootToColor.has(root)) mapRootToColor.set(root, (colorIdx++) % 10);\n      n.colorIdx = mapRootToColor.get(root);\n    }\n    draw();\n  }\n\n  function updateMSTInfo(){\n    const included = edges.filter(e=>e.status==='included');\n    const total = included.reduce((s,e)=>s+Number(e.weight),0);\n    mstWeightEl.textContent = total;\n    mstEdgesEl.textContent = included.map(e=>{\n      const un = nodes.find(n=>n.id===e.u); const vn = nodes.find(n=>n.id===e.v);\n      return `${un?un.id:'?'}-${vn?vn.id:'?'} (${e.weight})`;\n    }).join(', ');\n  }\n\n  function resetKruskalRun(){\n    for(const e of edges) e.status = 'pending';\n    kruskalState.sortedEdges = [];\n    kruskalState.index = 0;\n    kruskalState.ds = null;\n    kruskalState.running = false;\n    clearInterval(kruskalState.timer);\n    btnRun.disabled = false;\n    btnPause.disabled = true;\n    btnStep.disabled = false;\n    refreshEdgeList();\n    updateMSTInfo();\n    recolorComponents();\n    draw();\n  }\n\n  function autoRun(){\n    if(kruskalState.sortedEdges.length === 0) startKruskal();\n    if(kruskalState.index >= kruskalState.sortedEdges.length) return;\n    kruskalState.running = true;\n    btnRun.disabled = true; btnPause.disabled = false; btnStep.disabled = true;\n    const interval = Number(speedInput.value) || 800;\n    kruskalState.timer = setInterval(()=>{\n      stepKruskal();\n      if(kruskalState.index >= kruskalState.sortedEdges.length){\n        stopAuto();\n      }\n    }, interval);\n  }\n\n  function stopAuto(){\n    kruskalState.running = false;\n    clearInterval(kruskalState.timer);\n    btnRun.disabled = false; btnPause.disabled = true; btnStep.disabled = false;\n  }\n\n  // UI events\n  svg.addEventListener('mousedown', (evt)=>{\n    const p = svgPoint(evt);\n    if(mode === 'addNode'){\n      addNodeAt(p.x, p.y);\n    }\n  });\n\n  svg.addEventListener('click', (evt)=>{\n    // Clicks on nodes and edges handled by their own handlers (via pointer events)\n  });\n\n  // Mode-specific interactions will be added to node/edge elements when drawing\n\n  btnRandom.addEventListener('click', ()=>{\n    // generate random graph\n    nodes = []; edges = []; nodeId = 0; edgeId = 0;\n    const N = Math.floor(Math.random()*5) + 6; // 6-10 nodes\n    const width = 1100, height = 700;\n    for(let i=0;i<N;i++){\n      addNodeAt(50 + Math.random()*(width-100), 50 + Math.random()*(height-100));\n    }\n    // connect with random edges\n    const possible = [];\n    for(let i=0;i<nodes.length;i++) for(let j=i+1;j<nodes.length;j++) possible.push([nodes[i].id, nodes[j].id]);\n    // ensure connected: create a random spanning chain first\n    const nodeIds = nodes.map(n=>n.id).sort(()=>Math.random()-0.5);\n    for(let i=0;i<nodeIds.length-1;i++){\n      addEdge(nodeIds[i], nodeIds[i+1], Math.floor(Math.random()*20)+1);\n    }\n    // add some extra random edges\n    const extra = Math.floor(Math.random()*Math.min(10, possible.length));\n    for(let k=0;k<extra;k++){\n      const idx = Math.floor(Math.random()*possible.length);\n      const [u,v] = possible.splice(idx,1)[0];\n      addEdge(u,v, Math.floor(Math.random()*20)+1);\n    }\n    startKruskal();\n    draw();\n    updateCounts();\n  });\n\n  btnClear.addEventListener('click', ()=>{\n    if(!confirm('Clear all nodes and edges?')) return;\n    nodes = []; edges = []; nodeId=0; edgeId=0;\n    resetKruskalRun();\n    updateCounts();\n    draw();\n  });\n\n  btnStep.addEventListener('click', ()=>{\n    if(kruskalState.sortedEdges.length === 0) startKruskal();\n    stepKruskal();\n  });\n  btnRun.addEventListener('click', ()=> autoRun());\n  btnPause.addEventListener('click', ()=> { stopAuto(); });\n  btnReset.addEventListener('click', ()=> { resetKruskalRun(); startKruskal(); });\n\n  speedInput.addEventListener('input', (e)=> {\n    speedLabel.textContent = speedInput.value + ' ms';\n    if(kruskalState.running){\n      // restart interval with new speed\n      stopAuto();\n      autoRun();\n    }\n  });\n\n  // Drawing\n  function clearSVG(){\n    while(edgeGroup.firstChild) edgeGroup.removeChild(edgeGroup.firstChild);\n    while(nodeGroup.firstChild) nodeGroup.removeChild(nodeGroup.firstChild);\n  }\n\n  function draw(){\n    clearSVG();\n    // draw edges under nodes\n    for(const e of edges){\n      const u = nodes.find(n=>n.id===e.u);\n      const v = nodes.find(n=>n.id===e.v);\n      if(!u || !v) continue;\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('data-edge-id', e.id);\n      g.style.cursor = 'pointer';\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1', u.x);\n      line.setAttribute('y1', u.y);\n      line.setAttribute('x2', v.x);\n      line.setAttribute('y2', v.y);\n      line.classList.add('edge-line');\n      if(e.status === 'considered') line.classList.add('considered');\n      if(e.status === 'included') line.classList.add('included');\n      if(e.status === 'skipped') line.classList.add('skipped');\n      line.setAttribute('stroke-linecap','round');\n      g.appendChild(line);\n\n      // weight label\n      const mx = (u.x + v.x)/2;\n      const my = (u.y + v.y)/2;\n      const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      rect.setAttribute('x', mx - 18);\n      rect.setAttribute('y', my - 14);\n      rect.setAttribute('width', 36);\n      rect.setAttribute('height', 20);\n      rect.setAttribute('rx',8);\n      rect.setAttribute('ry',8);\n      rect.setAttribute('fill', '#fff');\n      rect.setAttribute('stroke','#ddd');\n      rect.setAttribute('pointer-events','none');\n      g.appendChild(rect);\n\n      const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('x', mx);\n      text.setAttribute('y', my);\n      text.setAttribute('text-anchor','middle');\n      text.setAttribute('dominant-baseline','middle');\n      text.classList.add('weight-label');\n      text.textContent = e.weight;\n      g.appendChild(text);\n\n      // edge click handler\n      g.addEventListener('click', (evt)=>{\n        evt.stopPropagation();\n        if(mode === 'delete'){\n          if(confirm('Delete this edge?')) deleteEdge(e.id);\n        } else {\n          // edit weight\n          const val = prompt('Edit edge weight:', String(e.weight));\n          if(val !== null){\n            const num = Number(val);\n            if(!isNaN(num)){\n              e.weight = num;\n              startKruskal();\n              draw();\n            } else alert('Invalid number');\n          }\n        }\n      });\n\n      edgeGroup.appendChild(g);\n    }\n\n    // draw nodes on top\n    for(const n of nodes){\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('data-node-id', n.id);\n      g.style.cursor = 'pointer';\n\n      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      circle.setAttribute('cx', n.x);\n      circle.setAttribute('cy', n.y);\n      circle.setAttribute('r', 18);\n      circle.classList.add('node-circle');\n      if(n.colorIdx !== undefined) circle.classList.add('color' + (n.colorIdx%10));\n      if(n === firstNodeForEdge) circle.classList.add('selected');\n      g.appendChild(circle);\n\n      const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('x', n.x);\n      text.setAttribute('y', n.y+1);\n      text.setAttribute('text-anchor','middle');\n      text.classList.add('node-label');\n      text.textContent = n.id;\n      g.appendChild(text);\n\n      // event handlers\n      g.addEventListener('mousedown', (evt)=>{\n        evt.stopPropagation();\n        if(mode === 'addEdge'){\n          if(firstNodeForEdge == null){\n            firstNodeForEdge = n;\n            draw(); // to show selection\n          } else if(firstNodeForEdge.id === n.id){\n            // clicked same node: cancel selection\n            firstNodeForEdge = null;\n            draw();\n          } else {\n            // create edge between firstNodeForEdge and n\n            const w = prompt('Edge weight:', String(Math.floor(Math.random()*10)+1));\n            if(w !== null){\n              const num = Number(w);\n              if(!isNaN(num)){\n                addEdge(firstNodeForEdge.id, n.id, num);\n                firstNodeForEdge = null;\n                startKruskal();\n              } else alert('Invalid number');\n            } else {\n              firstNodeForEdge = null;\n            }\n            draw();\n          }\n        } else if(mode === 'move'){\n          selectedElement = n;\n          const p = svgPoint(evt);\n          dragOffset.x = n.x - p.x;\n          dragOffset.y = n.y - p.y;\n        } else if(mode === 'delete'){\n          if(confirm('Delete node and its incident edges?')){\n            deleteNode(n.id);\n          }\n        } else {\n          // default: show node info / edit id (id can't be changed)\n          alert('Node ' + n.id + '\\\\nPosition: ('+Math.round(n.x)+','+Math.round(n.y)+')');\n        }\n      });\n\n      // support dragging\n      svg.addEventListener('mousemove', (evt)=>{\n        if(selectedElement && mode === 'move'){\n          const p = svgPoint(evt);\n          selectedElement.x = p.x + dragOffset.x;\n          selectedElement.y = p.y + dragOffset.y;\n          draw();\n        }\n      });\n\n      window.addEventListener('mouseup', (evt)=>{\n        if(selectedElement) selectedElement = null;\n      });\n\n      nodeGroup.appendChild(g);\n    }\n\n    refreshEdgeList();\n    updateMSTInfo();\n  }\n\n  function refreshEdgeList(){\n    // display sorted by weight\n    const list = edges.slice().sort((a,b)=>a.weight-b.weight);\n    edgeListDiv.innerHTML = '';\n    for(const e of list){\n      const item = document.createElement('div');\n      item.className = 'edge-item';\n      const left = document.createElement('div');\n      left.textContent = `${e.u} — ${e.v}`;\n      const mid = document.createElement('div');\n      mid.textContent = `w=${e.weight}`;\n      mid.style.minWidth='56px';\n      mid.style.textAlign='center';\n      const right = document.createElement('div');\n      const span = document.createElement('span');\n      span.className = 'status';\n      if(e.status === 'included') { span.classList.add('ok'); span.textContent='MST'; }\n      else if(e.status === 'skipped') { span.classList.add('skip'); span.textContent='Cycle'; }\n      else if(e.status === 'considered') { span.classList.add('pending'); span.textContent='Considered'; }\n      else { span.textContent='Pending'; span.classList.add('pending'); }\n      right.appendChild(span);\n      item.appendChild(left);\n      item.appendChild(mid);\n      item.appendChild(right);\n      // clicking selects/highlights the edge on canvas\n      item.addEventListener('click', ()=>{\n        // highlight: mark as considered briefly\n        for(const edgeEl of edgeGroup.querySelectorAll('g')) {\n          edgeEl.style.outline = '';\n        }\n        const el = edgeGroup.querySelector('g[data-edge-id=\"'+e.id+'\"]');\n        if(el) el.style.outline = '3px solid rgba(0,123,255,0.2)';\n      });\n      edgeListDiv.appendChild(item);\n    }\n  }\n\n  function resetSelections(){\n    firstNodeForEdge = null;\n    selectedElement = null;\n    draw();\n  }\n\n  // init\n  draw();\n  updateCounts();\n  startKruskal();\n\n  // keyboard shortcuts\n  window.addEventListener('keydown', (e)=>{\n    if(e.key === '1') setMode('addNode');\n    if(e.key === '2') setMode('addEdge');\n    if(e.key === '3') setMode('move');\n    if(e.key === '4') setMode('delete');\n    if(e.key === ' ') { e.preventDefault(); stepKruskal(); }\n  });\n\n  // Informational tooltip on load\n  setTimeout(()=> {\n    // small guided hint\n    if(nodes.length === 0){\n      // add a couple nodes for first-time users\n      addNodeAt(200,200);\n      addNodeAt(400,120);\n      addNodeAt(620,300);\n      addNodeAt(320,420);\n      addEdge(nodes[0].id, nodes[1].id, 5);\n      addEdge(nodes[1].id, nodes[2].id, 8);\n      addEdge(nodes[2].id, nodes[3].id, 3);\n      addEdge(nodes[3].id, nodes[0].id, 7);\n      startKruskal();\n    }\n  }, 400);\n})();\n</script>\n</body>\n</html>"
