    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Bellman-Ford Algorithm Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #fefefe;\n  }\n  h1 {\n    text-align: center;\n  }\n  #graph, #distances, #logs {\n    margin-top: 20px;\n    max-width: 800px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  #graph svg {\n    border: 1px solid #ccc;\n    background: #fafafa;\n    display: block;\n    margin: 0 auto;\n  }\n  .node circle {\n    fill: #4285F4;\n    stroke: #2a56c6;\n    stroke-width: 2;\n    cursor: pointer;\n  }\n  .node text {\n    fill: white;\n    font-weight: bold;\n    pointer-events: none;\n    user-select: none;\n  }\n  .edge path {\n    stroke: #999;\n    stroke-width: 2;\n    fill: none;\n    marker-end: url(#arrowhead);\n  }\n  .edge text {\n    font-size: 12px;\n    fill: #555;\n    user-select: none;\n  }\n  .highlight-edge path {\n    stroke: #E53935;\n    stroke-width: 3;\n  }\n  .highlight-node circle {\n    fill: #E53935;\n  }\n  #controls {\n    text-align: center;\n    margin-top: 30px;\n  }\n  select, button {\n    font-size: 16px;\n    padding: 6px 12px;\n    margin: 0 5px;\n  }\n  #distances table {\n    margin: 0 auto;\n    border-collapse: collapse;\n  }\n  #distances th, #distances td {\n    padding: 8px 12px;\n    border: 1px solid #ccc;\n  }\n  #logs {\n    max-height: 200px;\n    overflow-y: auto;\n    background: #eee;\n    border: 1px solid #ccc;\n    padding: 10px;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n</style>\n</head>\n<body>\n<h1>Bellman-Ford Algorithm Visualization</h1>\n<div id=\"controls\">\n  <label for=\"sourceNode\">Select Source Node: </label>\n  <select id=\"sourceNode\"></select>\n  <button id=\"startBtn\">Start Algorithm</button>\n  <button id=\"stepBtn\" disabled>Next Step</button>\n  <button id=\"resetBtn\">Reset</button>\n</div>\n\n<div id=\"graph\"></div>\n\n<div id=\"distances\">\n  <h3>Current Distance Estimates</h3>\n  <table>\n    <thead>\n      <tr><th>Node</th><th>Distance from Source</th></tr>\n    </thead>\n    <tbody id=\"distanceTableBody\"></tbody>\n  </table>\n</div>\n\n<div id=\"logs\">\n  <h3>Algorithm Logs</h3>\n  <div id=\"logContent\"></div>\n</div>\n\n<script>\n// Graph definition - edges as {from, to, weight}\n// We create a graph with 5 nodes (A-E) and some edges with positive and negative weights (but no negative cycle)\nconst nodes = [\n  { id: 'A', x: 150, y: 80 },\n  { id: 'B', x: 400, y: 80 },\n  { id: 'C', x: 650, y: 80 },\n  { id: 'D', x: 275, y: 250 },\n  { id: 'E', x: 525, y: 250 }\n];\nconst edges = [\n  { from: 'A', to: 'B', weight: 6 },\n  { from: 'A', to: 'D', weight: 6 },\n  { from: 'B', to: 'C', weight: 5 },\n  { from: 'B', to: 'D', weight: 2 },\n  { from: 'C', to: 'E', weight: -1 },\n  { from: 'D', to: 'B', weight: -2 },\n  { from: 'D', to: 'E', weight: 1 },\n  { from: 'E', to: 'C', weight: 3 }\n];\n\n// Variables for Bellman-Ford\nlet distances = {};\nlet predecessors = {};\nlet iteration = 0;\nlet edgeIndex = 0;\nlet sourceNode = null;\nlet relaxationOccurred = false;\nlet totalIterations = nodes.length - 1;\nlet edgesCount = edges.length;\nlet isFinished = false;\n\n// DOM references\nconst graphDiv = document.getElementById('graph');\nconst distanceTableBody = document.getElementById('distanceTableBody');\nconst logContent = document.getElementById('logContent');\nconst sourceSelect = document.getElementById('sourceNode');\nconst startBtn = document.getElementById('startBtn');\nconst stepBtn = document.getElementById('stepBtn');\nconst resetBtn = document.getElementById('resetBtn');\n\n// Initialize source select options\nfunction initSourceSelect() {\n  sourceSelect.innerHTML = '';\n  nodes.forEach(n => {\n    let opt = document.createElement('option');\n    opt.value = n.id;\n    opt.textContent = n.id;\n    sourceSelect.appendChild(opt);\n  });\n}\n\n// Draw graph using SVG\nfunction drawGraph() {\n  graphDiv.innerHTML = '';\n  const svgNS = \"http://www.w3.org/2000/svg\";\n  const width = 800;\n  const height = 350;\n  let svg = document.createElementNS(svgNS, 'svg');\n  svg.setAttribute('width', width);\n  svg.setAttribute('height', height);\n\n  // Define arrowhead marker\n  let defs = document.createElementNS(svgNS, 'defs');\n  let marker = document.createElementNS(svgNS, 'marker');\n  marker.setAttribute('id', 'arrowhead');\n  marker.setAttribute('markerWidth', '10');\n  marker.setAttribute('markerHeight', '7');\n  marker.setAttribute('refX', '10');\n  marker.setAttribute('refY', '3.5');\n  marker.setAttribute('orient', 'auto');\n  let polygon = document.createElementNS(svgNS, 'polygon');\n  polygon.setAttribute('points', '0 0, 10 3.5, 0 7');\n  polygon.setAttribute('fill', '#999');\n  marker.appendChild(polygon);\n  defs.appendChild(marker);\n  svg.appendChild(defs);\n\n  // Edges group\n  const edgesGroup = document.createElementNS(svgNS, 'g');\n  edgesGroup.setAttribute('id', 'edgesGroup');\n\n  edges.forEach((e, i) => {\n    let edgeGroup = document.createElementNS(svgNS, 'g');\n    edgeGroup.classList.add('edge');\n    edgeGroup.setAttribute('data-edge-index', i);\n\n    const fromNode = nodes.find(n => n.id === e.from);\n    const toNode = nodes.find(n => n.id === e.to);\n\n    // Calculate line with arrow from fromNode to toNode\n    // Adjust line from center of fromNode circle to center of toNode circle, offset to avoid overlapping circles\n    let dx = toNode.x - fromNode.x;\n    let dy = toNode.y - fromNode.y;\n    let angle = Math.atan2(dy, dx);\n    const radius = 20; // circle radius\n\n    let startX = fromNode.x + radius * Math.cos(angle);\n    let startY = fromNode.y + radius * Math.sin(angle);\n    let endX = toNode.x - radius * Math.cos(angle);\n    let endY = toNode.y - radius * Math.sin(angle);\n\n    let path = document.createElementNS(svgNS, 'path');\n    path.setAttribute('d', `M${startX},${startY} L${endX},${endY}`);\n    path.setAttribute('stroke', '#999');\n    path.setAttribute('stroke-width', '2');\n    path.setAttribute('fill', 'none');\n    path.setAttribute('marker-end', 'url(#arrowhead)');\n\n    // Edge weight label midpoint\n    let midX = (startX + endX) / 2 + 10 * Math.sin(angle);\n    let midY = (startY + endY) / 2 - 10 * Math.cos(angle);\n\n    let weightLabel = document.createElementNS(svgNS, 'text');\n    weightLabel.setAttribute('x', midX);\n    weightLabel.setAttribute('y', midY);\n    weightLabel.textContent = e.weight;\n    weightLabel.style.fontSize = '14px';\n    weightLabel.style.fill = '#555';\n    weightLabel.style.userSelect = 'none';\n\n    edgeGroup.appendChild(path);\n    edgeGroup.appendChild(weightLabel);\n    edgesGroup.appendChild(edgeGroup);\n  });\n\n  svg.appendChild(edgesGroup);\n\n  // Nodes group\n  const nodesGroup = document.createElementNS(svgNS, 'g');\n  nodesGroup.setAttribute('id', 'nodesGroup');\n\n  nodes.forEach(n => {\n    let nodeGroup = document.createElementNS(svgNS, 'g');\n    nodeGroup.classList.add('node');\n    nodeGroup.setAttribute('data-node-id', n.id);\n    nodeGroup.setAttribute('transform', `translate(${n.x},${n.y})`);\n\n    let circle = document.createElementNS(svgNS, 'circle');\n    circle.setAttribute('r', 20);\n    circle.style.fill = '#4285F4';\n    circle.style.stroke = '#2a56c6';\n    circle.style.strokeWidth = 2;\n    nodeGroup.appendChild(circle);\n\n    let text = document.createElementNS(svgNS, 'text');\n    text.setAttribute('x', 0);\n    text.setAttribute('y', 5);\n    text.setAttribute('text-anchor', 'middle');\n    text.style.fill = 'white';\n    text.style.fontWeight = 'bold';\n    text.textContent = n.id;\n    nodeGroup.appendChild(text);\n\n    nodesGroup.appendChild(nodeGroup);\n  });\n\n  svg.appendChild(nodesGroup);\n\n  graphDiv.appendChild(svg);\n}\n\n// Initialize distances and predecessors to infinity/-1 except source\nfunction initAlgorithm(src) {\n  distances = {};\n  predecessors = {};\n  nodes.forEach(n => {\n    distances[n.id] = Infinity;\n    predecessors[n.id] = null;\n  });\n  distances[src] = 0;\n  iteration = 0;\n  edgeIndex = 0;\n  relaxationOccurred = false;\n  isFinished = false;\n  updateDistancesTable();\n  logContent.textContent = `Algorithm initialized with source = ${src}\\n`;\n  highlightDistances();\n  updateGraphHighlights(null, null);\n}\n\n// Update distance table UI\nfunction updateDistancesTable() {\n  distanceTableBody.innerHTML = '';\n  nodes.forEach(n => {\n    let tr = document.createElement('tr');\n    let tdNode = document.createElement('td');\n    tdNode.textContent = n.id;\n    let tdDist = document.createElement('td');\n    tdDist.textContent = distances[n.id] === Infinity ? '∞' : distances[n.id];\n    tr.appendChild(tdNode);\n    tr.appendChild(tdDist);\n    distanceTableBody.appendChild(tr);\n  });\n  highlightDistances();\n}\n\n// Highlight distances in the table that changed in last relaxation\nfunction highlightDistances() {\n  // No special highlight persisted, but could be enhanced\n}\n\n// Log a line\nfunction log(msg) {\n  logContent.textContent += msg + '\\n';\n  logContent.scrollTop = logContent.scrollHeight;\n}\n\n// Perform one relaxation step over one edge, manage iterations and edgeIndex\nfunction performStep() {\n  if (isFinished) {\n    log(`Algorithm completed.`);\n    stepBtn.disabled = true;\n    return;\n  }\n\n  if (iteration >= totalIterations) {\n    // One more iteration to check for negative cycle\n    if (edgeIndex === edgesCount) {\n      // No relaxation in last pass: no negative cycle\n      if (!relaxationOccurred) {\n        log(\"No further relaxation; no negative weight cycle detected.\");\n        isFinished = true;\n        stepBtn.disabled = true;\n        return;\n      } else {\n        // Reset for next pass\n        iteration++;\n        edgeIndex = 0;\n        relaxationOccurred = false;\n        log(`Iteration ${iteration} started to check negative cycle...`);\n      }\n    }\n  }\n\n  if (edgeIndex < edgesCount) {\n    const e = edges[edgeIndex];\n    const u = e.from;\n    const v = e.to;\n    const w = e.weight;\n\n    log(`Checking edge (${u} → ${v}) with weight ${w}`);\n    let relaxed = false;\n    if (distances[u] !== Infinity && distances[u] + w < distances[v]) {\n      let oldDist = distances[v];\n      distances[v] = distances[u] + w;\n      predecessors[v] = u;\n      relaxationOccurred = true;\n      relaxed = true;\n      log(`Relaxed: distance to ${v} updated from ${oldDist} to ${distances[v]} via ${u}`);\n    } else {\n      log(`No relaxation needed for edge (${u} → ${v})`);\n    }\n\n    highlightCurrentEdge(edgeIndex, relaxed);\n    updateDistancesTable();\n\n    edgeIndex++;\n\n  } else {\n    iteration++;\n    if (iteration >= totalIterations) {\n      // check for negative cycle in one last iteration\n      if (!relaxationOccurred) {\n        log('Algorithm finished: no negative weight cycles detected.');\n        isFinished = true;\n        stepBtn.disabled = true;\n      } else {\n        log('Negative weight cycle detected! Algorithm stops.');\n        isFinished = true;\n        stepBtn.disabled = true;\n      }\n      return;\n    }\n    relaxationOccurred = false;\n    edgeIndex = 0;\n    log(`Starting iteration ${iteration + 1}...`);\n  }\n}\n\n// Highlight the current edge that is being relaxed\nfunction highlightCurrentEdge(edgeI, relaxed) {\n  const svg = graphDiv.querySelector('svg');\n  if (!svg) return;\n  // Remove all highlights\n  svg.querySelectorAll('.highlight-edge').forEach(el => {\n    el.classList.remove('highlight-edge');\n  });\n  svg.querySelectorAll('.highlight-node').forEach(el => {\n    el.classList.remove('highlight-node');\n  });\n\n  if (edgeI === null) return;\n\n  const edgeGroup = svg.querySelector(`.edge[data-edge-index='${edgeI}']`);\n  if (edgeGroup) {\n    edgeGroup.classList.add('highlight-edge');\n  }\n\n  // Also highlight the from node in red and to node in orange if relaxed; else blue.\n  if (edgeGroup) {\n    const fromId = edges[edgeI].from;\n    const toId = edges[edgeI].to;\n    const nodesGroup = svg.querySelectorAll('.node');\n    nodesGroup.forEach(nodeGrp => {\n      let id = nodeGrp.getAttribute('data-node-id');\n      if (id === fromId) {\n        if (relaxed) {\n          nodeGrp.classList.add('highlight-node');\n          nodeGrp.querySelector('circle').style.fill = '#E53935'; // Red for from node relaxation\n        } else {\n          nodeGrp.querySelector('circle').style.fill = '#3949AB'; // Darker Blue\n        }\n      }\n      if (id === toId) {\n        if (relaxed) {\n          nodeGrp.classList.add('highlight-node');\n          nodeGrp.querySelector('circle').style.fill = '#FB8C00'; // Orange for to node relaxation\n        } else {\n          nodeGrp.querySelector('circle').style.fill = '#4285F4'; // Normal blue\n        }\n      }\n      if (id !== toId && id !== fromId) {\n        nodeGrp.querySelector('circle').style.fill = '#4285F4';\n      }\n    });\n  }\n}\n\n// Reset everything\nfunction reset() {\n  sourceNode = sourceSelect.value;\n  initAlgorithm(sourceNode);\n  stepBtn.disabled = false;\n  startBtn.disabled = false;\n  logContent.textContent = '';\n  drawGraph();\n}\n\n// Start run (instant run demonstration - we do stepwise only here)\nfunction startAlgorithm() {\n  startBtn.disabled = true;\n  stepBtn.disabled = false;\n  sourceNode = sourceSelect.value;\n  initAlgorithm(sourceNode);\n  log(`Press \"Next Step\" to run the algorithm step-by-step.`);\n}\n\n// Event listeners\nstartBtn.addEventListener('click', () => {\n  startAlgorithm();\n});\nstepBtn.addEventListener('click', () => {\n  performStep();\n});\nresetBtn.addEventListener('click', () => {\n  reset();\n});\n\n// Initialize\ninitSourceSelect();\ndrawGraph();\ninitAlgorithm(nodes[0].id);\nstepBtn.disabled = true;\n</script>\n</body>\n</html>"
