    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Unit Testing Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #test-results {\n            margin-top: 20px;\n            border: 1px solid #ccc;\n            padding: 10px;\n            background-color: #f9f9f9;\n        }\n        .pass {\n            color: green;\n        }\n        .fail {\n            color: red;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Unit Testing Demo</h1>\n<p>This simple unit test framework will test a sample function.</p>\n\n<button id=\"run-tests\">Run Tests</button>\n\n<div id=\"test-results\"></div>\n\n<script>\n    // Sample function to test\n    function add(a, b) {\n        return a + b;\n    }\n\n    // Unit Test Framework\n    function unitTest(description, fn) {\n        try {\n            fn();\n            document.getElementById('test-results').innerHTML += `<div class=\"pass\">✔️ ${description} - Passed</div>`;\n        } catch (error) {\n            document.getElementById('test-results').innerHTML += `<div class=\"fail\">❌ ${description} - Failed: ${error.message}</div>`;\n        }\n    }\n\n    // Define the tests for the add function\n    function runTests() {\n        document.getElementById('test-results').innerHTML = ''; // Clear previous results\n\n        unitTest(\"add(2, 3) should return 5\", function () {\n            const result = add(2, 3);\n            if (result !== 5) throw new Error(`Expected 5 but got ${result}`);\n        });\n\n        unitTest(\"add(-1, 1) should return 0\", function () {\n            const result = add(-1, 1);\n            if (result !== 0) throw new Error(`Expected 0 but got ${result}`);\n        });\n\n        unitTest(\"add(0, 0) should return 0\", function () {\n            const result = add(0, 0);\n            if (result !== 0) throw new Error(`Expected 0 but got ${result}`);\n        });\n\n        unitTest(\"add(2, -3) should return -1\", function () {\n            const result = add(2, -3);\n            if (result !== -1) throw new Error(`Expected -1 but got ${result}`);\n        });\n    }\n\n    document.getElementById('run-tests').addEventListener('click', runTests);\n</script>\n\n</body>\n</html>"
