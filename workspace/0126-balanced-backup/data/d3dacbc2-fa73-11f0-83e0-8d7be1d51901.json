  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Tiny Compiler Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 18px; color:#111; }\n    h1 { margin: 0 0 8px 0; font-size: 20px; }\n    p.desc { margin: 6px 0 18px 0; color:#444; max-width:70ch; }\n    .wrap { display:flex; gap:12px; align-items:flex-start; }\n    textarea, pre, .box { width: 100%; min-height: 160px; box-sizing:border-box; padding:10px; border-radius:8px; border:1px solid #ccc; background:#fff; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace; font-size:13px; }\n    textarea:focus, .box:focus { outline:2px solid #7aa7ff; border-color:#7aa7ff; }\n    .col { flex: 1 1 0; display:flex; flex-direction:column; gap:8px; }\n    .controls { display:flex; gap:8px; flex-wrap:wrap; }\n    button { padding:8px 12px; border-radius:8px; border:1px solid #bbb; background:#f6f8fb; cursor:pointer; }\n    button.primary { background:linear-gradient(#3d8bff,#2176ff); color:white; border-color:#1f67d6; }\n    button.danger { background:#ffe9e9; border-color:#ffbfbf; }\n    .small { padding:6px 8px; font-size:13px; }\n    .output { min-height:100px; white-space:pre-wrap; overflow:auto; }\n    .split { display:flex; gap:12px; }\n    .panel { flex:1; display:flex; flex-direction:column; gap:8px; }\n    label { font-weight:600; font-size:13px; color:#333; }\n    .tokens { font-size:13px; background:#fbfbff; border:1px dashed #d0d7ff; padding:8px; border-radius:6px; overflow:auto; max-height:220px; }\n    .err { color:#a00; font-weight:700; }\n    .ast-tree { font-family: ui-monospace, monospace; background:#f7fff7; border:1px dashed #bfeebb; padding:8px; border-radius:6px; overflow:auto; max-height:280px; }\n    footer { margin-top:18px; color:#666; font-size:13px; }\n    .row { display:flex; gap:8px; }\n    .sample-list { display:flex; gap:6px; flex-wrap:wrap; }\n    .chip { padding:6px 10px; border-radius:999px; border:1px solid #ddd; background:#fff; cursor:pointer; }\n    .chip:hover { background:#f1f5ff; border-color:#c7d7ff; }\n    code.inline { background:#f1f1f1; padding:2px 6px; border-radius:6px; font-size:12px; }\n  </style>\n</head>\n<body>\n  <h1>Tiny Compiler — interactive demo</h1>\n  <p class=\"desc\">\n    This page demonstrates the main compiler stages on a tiny language: lexical analysis (tokenize), parsing (AST), a simple optimizer (constant folding + propagation),\n    code generation to JavaScript, and execution. Type or paste a TinyLang program on the left and click the buttons to run each stage. The language supports:\n    variable declarations (let), arithmetic, and print(). Example: <code class=\"inline\">let x = 2 + 3 * (4 - 1); print(x);</code>\n  </p>\n\n  <div class=\"wrap\">\n    <div class=\"col\" style=\"flex:0 0 48%;\">\n      <label>Source (TinyLang)</label>\n      <textarea id=\"source\" spellcheck=\"false\"></textarea>\n\n      <div class=\"controls\">\n        <button id=\"btnLex\" class=\"small\">Lex</button>\n        <button id=\"btnParse\" class=\"small\">Parse</button>\n        <button id=\"btnOptimize\" class=\"small\">Optimize</button>\n        <button id=\"btnGen\" class=\"small\">Generate JS</button>\n        <button id=\"btnRun\" class=\"primary small\">Execute</button>\n        <button id=\"btnAll\" class=\"small\">Run All →</button>\n        <button id=\"btnReset\" class=\"small\">Reset sample</button>\n      </div>\n\n      <div class=\"row\" style=\"margin-top:8px; gap:10px;\">\n        <div style=\"flex:1 1 0;\">\n          <label>Output</label>\n          <pre id=\"output\" class=\"box output\"></pre>\n        </div>\n        <div style=\"width:220px;\">\n          <label>Samples</label>\n          <div class=\"sample-list\" id=\"samples\">\n            <!-- chips inserted here -->\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"col\" style=\"flex:0 0 52%;\">\n      <div class=\"split\">\n        <div class=\"panel\" style=\"flex:1;\">\n          <label>Tokens</label>\n          <div id=\"tokens\" class=\"tokens\"></div>\n        </div>\n\n        <div class=\"panel\" style=\"flex:1;\">\n          <label>AST (parsed)</label>\n          <pre id=\"ast\" class=\"box ast-tree\"></pre>\n        </div>\n      </div>\n\n      <div style=\"display:flex; gap:12px; margin-top:12px;\">\n        <div style=\"flex:1;\">\n          <label>Optimized AST</label>\n          <pre id=\"optAst\" class=\"box ast-tree\"></pre>\n        </div>\n        <div style=\"flex:1;\">\n          <label>Generated JavaScript</label>\n          <pre id=\"js\" class=\"box\"></pre>\n        </div>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <label>Errors / Messages</label>\n        <pre id=\"messages\" class=\"box\" style=\"min-height:60px;\"></pre>\n      </div>\n    </div>\n  </div>\n\n  <footer>\n    Notes: This is a toy compiler for education. Execution is via the JS Function constructor with a provided print function which captures output.\n  </footer>\n\n  <script>\n  // ===== TinyLang Compiler Demo =====\n  // Language:\n  // program := statement*\n  // statement := \"let\" identifier \"=\" expr \";\" | \"print\" \"(\" expr \")\" \";\" | expr \";\"\n  // expr := additive\n  // additive := multiplicative ((\"+\"|\"-\") multiplicative)*\n  // multiplicative := primary ((\"*\"|\"/\") primary)*\n  // primary := NUMBER | IDENT | \"(\" expr \")\"\n  //\n  // We'll implement: Lexer -> Parser -> Optimizer (constant folding + simple propagation) -> CodeGen -> Run\n\n  // Utility: position info\n  function nicePos(pos) {\n    return 'line ' + pos.line + ', col ' + pos.col;\n  }\n\n  // ===== Lexer =====\n  function lex(input) {\n    const tokens = [];\n    let i = 0, line = 1, col = 1;\n    function cur() { return input[i]; }\n    function advance(n=1) {\n      for (let k=0;k<n;k++) {\n        if (input[i] === '\\n') { line++; col=1; }\n        else col++;\n        i++;\n      }\n    }\n    function make(type, value, startPos) {\n      tokens.push({type, value, pos: startPos});\n    }\n\n    const isDigit = ch => ch >= '0' && ch <= '9';\n    const isAlpha = ch => (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') || ch === '_';\n    const isAlnum = ch => isAlpha(ch) || isDigit(ch);\n\n    while (i < input.length) {\n      const start = {line, col};\n      const ch = cur();\n      if (ch === ' ' || ch === '\\t' || ch === '\\r' || ch === '\\n') { advance(); continue; }\n      // punctuation and operators\n      if ('()+-*/=;,'.includes(ch)) {\n        make(ch, ch, start);\n        advance();\n        continue;\n      }\n      // numbers (integers and floats)\n      if (isDigit(ch)) {\n        let num = '';\n        while (isDigit(cur())) { num += cur(); advance(); }\n        if (cur() === '.') {\n          num += '.';\n          advance();\n          while (isDigit(cur())) { num += cur(); advance(); }\n        }\n        make('NUMBER', num, start);\n        continue;\n      }\n      // identifiers / keywords\n      if (isAlpha(ch)) {\n        let id = '';\n        while (isAlnum(cur())) { id += cur(); advance(); }\n        if (id === 'let' || id === 'print') make(id.toUpperCase(), id, start);\n        else make('IDENT', id, start);\n        continue;\n      }\n      // unknown char\n      throw {type:'LexError', message: 'Unexpected character: ' + ch, pos:start};\n    }\n    make('EOF', null, {line, col});\n    return tokens;\n  }\n\n  // ===== Parser =====\n  function parse(tokens) {\n    let i = 0;\n    function peek() { return tokens[i]; }\n    function next() { return tokens[i++]; }\n\n    function expect(typeOrValue) {\n      const tk = peek();\n      if (!tk) throw {type:'ParseError', message: 'Unexpected EOF', pos: {line:0,col:0}};\n      if (typeof typeOrValue === 'string') {\n        if (tk.type === typeOrValue || tk.value === typeOrValue) return next();\n      } else {\n        throw new Error('expect needs string');\n      }\n      throw {type:'ParseError', message: `Expected ${typeOrValue}, got ${tk.type} (${tk.value})`, pos: tk.pos};\n    }\n\n    function parseProgram() {\n      const body = [];\n      while (peek().type !== 'EOF') {\n        body.push(parseStatement());\n      }\n      return {type:'Program', body};\n    }\n\n    function parseStatement() {\n      const tk = peek();\n      if (tk.type === 'LET') {\n        const startPos = tk.pos; next(); // consume let\n        const id = expect('IDENT');\n        expect('=');\n        const init = parseExpression();\n        expect(';');\n        return {type:'VariableDeclaration', id: {type:'Identifier', name:id.value, pos:id.pos}, init, pos:startPos};\n      } else if (tk.type === 'PRINT') {\n        next(); // consume print\n        expect('(');\n        const arg = parseExpression();\n        expect(')');\n        expect(';');\n        return {type:'PrintStatement', argument:arg, pos:tk.pos};\n      } else {\n        // expression statement\n        const expr = parseExpression();\n        expect(';');\n        return {type:'ExpressionStatement', expression: expr, pos: tk.pos};\n      }\n    }\n\n    function parseExpression() {\n      return parseAdditive();\n    }\n\n    function parseAdditive() {\n      let node = parseMultiplicative();\n      while (peek().value === '+' || peek().value === '-') {\n        const op = next().value;\n        const right = parseMultiplicative();\n        node = {type:'BinaryExpression', operator:op, left:node, right:right};\n      }\n      return node;\n    }\n\n    function parseMultiplicative() {\n      let node = parsePrimary();\n      while (peek().value === '*' || peek().value === '/') {\n        const op = next().value;\n        const right = parsePrimary();\n        node = {type:'BinaryExpression', operator:op, left:node, right:right};\n      }\n      return node;\n    }\n\n    function parsePrimary() {\n      const tk = peek();\n      if (tk.type === 'NUMBER') {\n        next();\n        return {type:'Literal', value: Number(tk.value), raw:tk.value, pos:tk.pos};\n      }\n      if (tk.type === 'IDENT') {\n        next();\n        return {type:'Identifier', name: tk.value, pos: tk.pos};\n      }\n      if (tk.value === '(') {\n        next();\n        const inner = parseExpression();\n        expect(')');\n        return inner;\n      }\n      throw {type:'ParseError', message: 'Unexpected token in expression: ' + tk.type + ' ' + tk.value, pos: tk.pos};\n    }\n\n    const ast = parseProgram();\n    return ast;\n  }\n\n  // ===== Optimizer: constant folding + simple propagation =====\n  function optimize(ast) {\n    // Environment mapping constant variable names to literal values\n    const env = Object.create(null);\n\n    function isLiteral(node) { return node && node.type === 'Literal'; }\n\n    function fold(node) {\n      if (!node || typeof node !== 'object') return node;\n      switch (node.type) {\n        case 'Program':\n          return {type:'Program', body: node.body.map(stmt => fold(stmt))};\n        case 'VariableDeclaration':\n          const foldedInit = fold(node.init);\n          // if init is literal, record it\n          if (isLiteral(foldedInit)) env[node.id.name] = foldedInit.value;\n          return {type:'VariableDeclaration', id: node.id, init: foldedInit};\n        case 'PrintStatement':\n          return {type:'PrintStatement', argument: fold(node.argument)};\n        case 'ExpressionStatement':\n          return {type:'ExpressionStatement', expression: fold(node.expression)};\n        case 'BinaryExpression':\n          const L = fold(node.left);\n          const R = fold(node.right);\n          if (isLiteral(L) && isLiteral(R)) {\n            let v;\n            switch (node.operator) {\n              case '+': v = L.value + R.value; break;\n              case '-': v = L.value - R.value; break;\n              case '*': v = L.value * R.value; break;\n              case '/': v = L.value / R.value; break;\n              default: return {type:'BinaryExpression', operator:node.operator, left:L, right:R};\n            }\n            return {type:'Literal', value: v, raw: String(v)};\n          } else {\n            return {type:'BinaryExpression', operator:node.operator, left:L, right:R};\n          }\n        case 'Identifier':\n          if (Object.prototype.hasOwnProperty.call(env, node.name)) {\n            return {type:'Literal', value: env[node.name], raw:String(env[node.name])};\n          }\n          return node;\n        case 'Literal':\n          return node;\n        default:\n          return node;\n      }\n    }\n\n    return fold(ast);\n  }\n\n  // ===== Code Generator to JavaScript =====\n  function generateJS(ast) {\n    // We'll produce JS managing prints via __print function.\n    function gen(node) {\n      switch (node.type) {\n        case 'Program':\n          return node.body.map(gen).join('\\n');\n        case 'VariableDeclaration':\n          // Use let to mirror language\n          return `let ${node.id.name} = ${gen(node.init)};`;\n        case 'PrintStatement':\n          return `__print(${gen(node.argument)});`;\n        case 'ExpressionStatement':\n          return gen(node.expression) + ';';\n        case 'BinaryExpression':\n          return '(' + gen(node.left) + ' ' + node.operator + ' ' + gen(node.right) + ')';\n        case 'Identifier':\n          return node.name;\n        case 'Literal':\n          return typeof node.value === 'number' ? node.value.toString() : JSON.stringify(node.value);\n        default:\n          throw new Error('CodeGen: Unsupported node type ' + node.type);\n      }\n    }\n    return gen(ast);\n  }\n\n  // ===== Runner (safe-ish) =====\n  function runGenerated(jsCode) {\n    const out = [];\n    const print = (...args) => {\n      out.push(args.map(x => (typeof x === 'object' ? JSON.stringify(x) : String(x))).join(' '));\n    };\n    // Wrap in IIFE to avoid leaking variables, provide __print\n    try {\n      const fn = new Function('__print', jsCode);\n      fn(print);\n      return {success:true, output: out.join('\\n')};\n    } catch (e) {\n      return {success:false, error:e.toString()};\n    }\n  }\n\n  // ===== UI wiring =====\n  const sourceEl = document.getElementById('source');\n  const tokensEl = document.getElementById('tokens');\n  const astEl = document.getElementById('ast');\n  const optAstEl = document.getElementById('optAst');\n  const jsEl = document.getElementById('js');\n  const outputEl = document.getElementById('output');\n  const messagesEl = document.getElementById('messages');\n\n  const btnLex = document.getElementById('btnLex');\n  const btnParse = document.getElementById('btnParse');\n  const btnOptimize = document.getElementById('btnOptimize');\n  const btnGen = document.getElementById('btnGen');\n  const btnRun = document.getElementById('btnRun');\n  const btnAll = document.getElementById('btnAll');\n  const btnReset = document.getElementById('btnReset');\n\n  // Sample programs\n  const samplePrograms = [\n    {\n      name: 'Basic arithmetic',\n      code: `let x = 2 + 3 * (4 - 1);\nlet y = x * 10;\nprint(y + 5);\nprint(x + y);`\n    },\n    {\n      name: 'Constant folding',\n      code: `let a = 2 + 3;\nlet b = a * 4 + (6 - 2);\nprint(b);\nprint(a);`\n    },\n    {\n      name: 'Expressions only',\n      code: `print(1 + 2 * 3);\nprint((10 - 1) / 3);`\n    },\n    {\n      name: 'Errors: parse',\n      code: `let x = 2 + ;\nprint(x);`\n    }\n  ];\n\n  const samplesDiv = document.getElementById('samples');\n  samplePrograms.forEach(s => {\n    const b = document.createElement('div');\n    b.className = 'chip';\n    b.textContent = s.name;\n    b.title = s.code;\n    b.onclick = () => { sourceEl.value = s.code; clearAll(); };\n    samplesDiv.appendChild(b);\n  });\n\n  function clearAll() {\n    tokensEl.textContent = '';\n    astEl.textContent = '';\n    optAstEl.textContent = '';\n    jsEl.textContent = '';\n    outputEl.textContent = '';\n    messagesEl.textContent = '';\n  }\n\n  function showTokens(toks) {\n    tokensEl.textContent = toks.map(t => {\n      const v = t.type === 'NUMBER' || t.type === 'IDENT' ? t.value : (t.value === null ? 'EOF' : t.value);\n      return `${t.type.padEnd(8)}  ${String(v).padEnd(12)}  @ ${nicePos(t.pos)}`;\n    }).join('\\n');\n  }\n\n  function showAST(ast, el) {\n    const json = JSON.stringify(ast, null, 2);\n    el.textContent = json;\n  }\n\n  // Button behavior\n  btnLex.onclick = () => {\n    clearMessages();\n    try {\n      const toks = lex(sourceEl.value);\n      showTokens(toks);\n      logMessage('Lexing succeeded. ' + (toks.length-1) + ' tokens (excluding EOF).');\n    } catch (e) {\n      tokensEl.textContent = '';\n      logError(e);\n    }\n  };\n\n  btnParse.onclick = () => {\n    clearMessages();\n    try {\n      const toks = lex(sourceEl.value);\n      showTokens(toks);\n      const ast = parse(toks);\n      showAST(ast, astEl);\n      logMessage('Parsing succeeded.');\n    } catch (e) {\n      astEl.textContent = '';\n      logError(e);\n    }\n  };\n\n  btnOptimize.onclick = () => {\n    clearMessages();\n    try {\n      const toks = lex(sourceEl.value);\n      const ast = parse(toks);\n      showAST(ast, astEl);\n      const opt = optimize(ast);\n      showAST(opt, optAstEl);\n      logMessage('Optimization applied (constant folding & propagation).');\n    } catch (e) {\n      optAstEl.textContent = '';\n      logError(e);\n    }\n  };\n\n  btnGen.onclick = () => {\n    clearMessages();\n    try {\n      const toks = lex(sourceEl.value);\n      const ast = parse(toks);\n      showAST(ast, astEl);\n      const opt = optimize(ast);\n      showAST(opt, optAstEl);\n      const js = generateJS(opt);\n      jsEl.textContent = js;\n      logMessage('Code generation completed.');\n    } catch (e) {\n      jsEl.textContent = '';\n      logError(e);\n    }\n  };\n\n  btnRun.onclick = () => {\n    clearMessages();\n    try {\n      const toks = lex(sourceEl.value);\n      const ast = parse(toks);\n      const opt = optimize(ast);\n      const js = generateJS(opt);\n      jsEl.textContent = js;\n      const result = runGenerated(js);\n      if (result.success) {\n        outputEl.textContent = result.output;\n        logMessage('Program executed successfully.');\n      } else {\n        outputEl.textContent = '';\n        logError({type:'RuntimeError', message: result.error});\n      }\n    } catch (e) {\n      logError(e);\n    }\n  };\n\n  btnAll.onclick = () => {\n    clearMessages();\n    try {\n      // lex\n      const toks = lex(sourceEl.value);\n      showTokens(toks);\n      logMessage('Lexing OK.');\n      // parse\n      const ast = parse(toks);\n      showAST(ast, astEl);\n      logMessage('Parsing OK.');\n      // optimize\n      const opt = optimize(ast);\n      showAST(opt, optAstEl);\n      logMessage('Optimization OK.');\n      // gen\n      const js = generateJS(opt);\n      jsEl.textContent = js;\n      logMessage('Code generation OK.');\n      // run\n      const result = runGenerated(js);\n      if (result.success) {\n        outputEl.textContent = result.output;\n        logMessage('Execution OK.');\n      } else {\n        outputEl.textContent = '';\n        logError({type:'RuntimeError', message: result.error});\n      }\n    } catch (e) {\n      logError(e);\n    }\n  };\n\n  btnReset.onclick = () => {\n    sourceEl.value = samplePrograms[0].code;\n    clearAll();\n  };\n\n  function logMessage(msg) {\n    messagesEl.textContent += '[Info] ' + msg + '\\n';\n  }\n  function logError(e) {\n    const pos = e.pos ? (' @ ' + nicePos(e.pos)) : '';\n    messagesEl.textContent += '[Error] ' + (e.type || '') + ': ' + (e.message || String(e)) + pos + '\\n';\n  }\n  function clearMessages() {\n    messagesEl.textContent = '';\n    outputEl.textContent = '';\n  }\n\n  // Initialize with sample\n  sourceEl.value = samplePrograms[0].code;\n  clearAll();\n\n  // Optional: auto-run lex on resize? Not necessary.\n  </script>\n</body>\n</html>"
  },
