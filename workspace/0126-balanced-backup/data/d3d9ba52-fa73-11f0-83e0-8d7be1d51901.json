  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<title>Query Optimization Explorer — Interactive Demo</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<style>\n  body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 16px; color:#111; background: #f7f9fc; }\n  header { display:flex; align-items:center; gap:12px; }\n  h1 { margin:0; font-size:1.25rem; }\n  .wrap { display:flex; gap:18px; margin-top:16px; }\n  .panel { background:#fff; border:1px solid #e3e8ef; border-radius:8px; padding:12px; box-shadow: 0 1px 2px rgba(11,22,39,0.04); flex:1; min-width:300px; }\n  label { display:block; margin-top:8px; font-size:0.9rem; color:#333; }\n  input[type=\"range\"] { width:100%; }\n  .row { display:flex; gap:8px; align-items:center; margin-top:8px; }\n  .row > * { margin:0; }\n  button { background:#0366d6; color:white; border:0; padding:8px 12px; border-radius:6px; cursor:pointer; }\n  button:disabled { background:#9bb9e9; cursor:not-allowed; }\n  select, input[type=\"number\"], input[type=\"checkbox\"] { margin-left:6px; }\n  .small { font-size:0.85rem; color:#555; }\n  pre { background:#0f1724; color:#dbeafe; padding:12px; border-radius:6px; overflow:auto; max-height:260px; }\n  .bars { display:flex; gap:8px; margin-top:12px; align-items:end; }\n  .bar { flex:1; height:80px; background:linear-gradient(180deg,#dbeafe,#93c5fd); border-radius:6px; display:flex; align-items:flex-end; justify-content:center; color:#03396c; font-weight:600; padding:4px; }\n  .explain { font-family:monospace; background:#fff; border-radius:6px; padding:8px; border:1px dashed #e2e8f0; }\n  .footer { font-size:0.85rem; color:#444; margin-top:12px; }\n  .muted { color:#666; font-size:0.9rem; }\n  .big { font-weight:700; font-size:1.1rem; }\n  .grid { display:grid; grid-template-columns: 1fr 1fr; gap:12px; }\n  .note { font-size:0.85rem; color:#5b6b80; margin-top:8px; }\n  .explain-step { margin:6px 0; padding:8px; background:#f1f5f9; border-radius:6px; border:1px solid #e6eef8; font-family:monospace; }\n  .legend { display:flex; gap:8px; align-items:center; margin-top:8px; }\n  .dot { width:12px; height:12px; border-radius:50%; }\n  .dot.scan { background:#ffd166; }\n  .dot.index { background:#06d6a0; }\n  .dot.hash { background:#118ab2; }\n  footer { margin-top:14px; color:#6b7280; font-size:0.9rem; }\n  @media (max-width:880px){ .wrap { flex-direction:column; } .grid{ grid-template-columns:1fr; } }\n</style>\n</head>\n<body>\n<header>\n  <h1>Query Optimization Explorer</h1>\n  <div class=\"small muted\">Interactive demo: compare query strategies (scans, indexes, joins, predicate pushdown)</div>\n</header>\n\n<div class=\"wrap\">\n  <div class=\"panel\" style=\"max-width:420px\">\n    <strong>Data & Query</strong>\n    <div class=\"note\">Two tables: Customers and Orders. Query: join them and apply an Orders filter (amount &gt; threshold). Try different join algorithms, enable/disable an index, and toggle predicate pushdown.</div>\n\n    <label>Customers (rows)\n      <input id=\"customersCount\" type=\"range\" min=\"100\" max=\"20000\" step=\"100\" value=\"5000\"/>\n      <div class=\"row\"><output id=\"customersCountOut\">5000</output></div>\n    </label>\n\n    <label>Orders (rows)\n      <input id=\"ordersCount\" type=\"range\" min=\"500\" max=\"100000\" step=\"500\" value=\"20000\"/>\n      <div class=\"row\"><output id=\"ordersCountOut\">20000</output></div>\n    </label>\n\n    <label>Orders filter: % of Orders that pass (selectivity)\n      <input id=\"selectivity\" type=\"range\" min=\"1\" max=\"100\" step=\"1\" value=\"20\"/>\n      <div class=\"row\"><output id=\"selectivityOut\">20%</output></div>\n    </label>\n\n    <label>Join key\n      <select id=\"joinKey\">\n        <option value=\"customerId\">orders.customerId = customers.id</option>\n      </select>\n    </label>\n\n    <label class=\"row\"><input id=\"indexOnOrders\" type=\"checkbox\" checked/> Index on orders.customerId (simulates lookup map)</label>\n    <label class=\"row\"><input id=\"predicatePushdown\" type=\"checkbox\" checked/> Predicate pushdown (apply filter to Orders before join)</label>\n\n    <label>Join algorithm\n      <select id=\"algorithm\">\n        <option value=\"nested\">Nested Loop Join</option>\n        <option value=\"indexed\">Indexed Nested Loop (uses index)</option>\n        <option value=\"hash\">Hash Join (build hash on smaller side)</option>\n      </select>\n    </label>\n\n    <div style=\"margin-top:12px\">\n      <button id=\"runBtn\">Run Query</button>\n      <button id=\"explainBtn\" style=\"margin-left:8px\">Show Explain</button>\n    </div>\n\n    <div class=\"legend\">\n      <div style=\"display:flex;gap:8px;align-items:center\">\n        <span class=\"dot scan\"></span><span class=\"small\">Scan cost</span>\n      </div>\n      <div style=\"display:flex;gap:8px;align-items:center\">\n        <span class=\"dot index\"></span><span class=\"small\">Index lookup</span>\n      </div>\n      <div style=\"display:flex;gap:8px;align-items:center\">\n        <span class=\"dot hash\"></span><span class=\"small\">Hash build/probe</span>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <strong>Plan & Results</strong>\n    <div class=\"grid\" style=\"margin-top:8px\">\n      <div>\n        <div class=\"small muted\">Explain Plan</div>\n        <div id=\"explain\" class=\"explain\" style=\"min-height:110px\">Press \"Show Explain\" to see the planner decision and cost estimates.</div>\n      </div>\n      <div>\n        <div class=\"small muted\">Execution Output</div>\n        <pre id=\"output\" aria-live=\"polite\">Ready — configure the query and click \"Run Query\".</pre>\n      </div>\n    </div>\n\n    <div style=\"margin-top:10px\">\n      <div class=\"small muted\">Estimated vs Actual (time & rows read)</div>\n      <div class=\"bars\" style=\"margin-top:8px\">\n        <div style=\"flex:1\">\n          <div class=\"small\">Estimated \"work\" (relative)</div>\n          <div id=\"estBar\" class=\"bar\" style=\"height:40px\">—</div>\n        </div>\n        <div style=\"flex:1\">\n          <div class=\"small\">Measured time (ms)</div>\n          <div id=\"actBar\" class=\"bar\" style=\"height:40px;background:linear-gradient(180deg,#fde68a,#fca311);\">—</div>\n        </div>\n      </div>\n    </div>\n\n    <div id=\"metrics\" style=\"margin-top:10px\" class=\"muted\">Metrics will appear here after running.</div>\n\n  </div>\n</div>\n\n<footer class=\"panel\">\n  <strong>Key concepts demonstrated</strong>\n  <ul>\n    <li>Full table scan — examining every row costs O(N).</li>\n    <li>Indexes — lookup maps reduce cost to O(1) per probe (amortized), avoiding scanning the whole table.</li>\n    <li>Nested loop join — simple, but O(N*M) when naive.</li>\n    <li>Hash join — builds a hash table on the smaller input, yielding roughly O(N+M) work.</li>\n    <li>Predicate pushdown — filtering as early as possible reduces the amount of data operated on downstream.</li>\n  </ul>\n  <div class=\"muted\">This is a simulation to illustrate how planners choose algorithms and how choices affect cost and runtime.</div>\n</footer>\n\n<script>\n(function(){\n  // Utility: seeded RNG for reproducible demo runs\n  function createRNG(seed = 123456) {\n    let s = seed >>> 0;\n    return function() {\n      // xorshift32\n      s ^= s << 13;\n      s ^= s >>> 17;\n      s ^= s << 5;\n      return ((s >>> 0) / 4294967295);\n    };\n  }\n\n  // Elements\n  const customersCount = document.getElementById('customersCount');\n  const customersCountOut = document.getElementById('customersCountOut');\n  const ordersCount = document.getElementById('ordersCount');\n  const ordersCountOut = document.getElementById('ordersCountOut');\n  const selectivity = document.getElementById('selectivity');\n  const selectivityOut = document.getElementById('selectivityOut');\n  const indexOnOrders = document.getElementById('indexOnOrders');\n  const predicatePushdown = document.getElementById('predicatePushdown');\n  const algorithm = document.getElementById('algorithm');\n  const runBtn = document.getElementById('runBtn');\n  const explainBtn = document.getElementById('explainBtn');\n  const explainDiv = document.getElementById('explain');\n  const output = document.getElementById('output');\n  const estBar = document.getElementById('estBar');\n  const actBar = document.getElementById('actBar');\n  const metrics = document.getElementById('metrics');\n\n  // Sync outputs\n  function sync() {\n    customersCountOut.value = customersCount.value;\n    ordersCountOut.value = ordersCount.value;\n    selectivityOut.value = selectivity.value + '%';\n  }\n  customersCount.addEventListener('input', sync);\n  ordersCount.addEventListener('input', sync);\n  selectivity.addEventListener('input', sync);\n  sync();\n\n  // Data generator: customers and orders\n  function generateData(Ncust, Nord, selectPct, seedBase=Date.now()) {\n    const rng = createRNG(seedBase);\n    const customers = new Array(Ncust);\n    for (let i=0;i<Ncust;i++){\n      customers[i] = { id: i+1, name: 'C'+(i+1), region: (i % 5 === 0) ? 'North' : 'South' };\n    }\n    const orders = new Array(Nord);\n    // To control selectivity, we'll set amount > threshold for exact percentage\n    // We'll set amount randomly 1..100, and threshold such that roughly selectPct pass.\n    const threshold = Math.ceil(100 * (1 - selectPct/100));\n    for (let j=0;j<Nord;j++){\n      // Assign customerId in uniform distribution 1..Ncust\n      const cid = Math.floor(rng() * Ncust) + 1;\n      // Create amount with rng - uniform 1..100\n      const amount = Math.floor(rng() * 100) + 1;\n      orders[j] = { id: j+1, customerId: cid, amount: amount };\n    }\n    // Note: true selectivity may deviate a bit due to randomness; we will filter accordingly.\n    return { customers, orders, threshold };\n  }\n\n  // Cost model helpers\n  function estimateCost(params) {\n    // Rough, relative units:\n    // scan cost unit per row scanned = 1\n    // index lookup cost per probe = 0.1\n    // hash build cost ~ 1 per row\n    // hash probe cost per probe ~ 0.1\n    const scanUnit = 1;\n    const lookupUnit = 0.15;\n    const hashBuildUnit = 1;\n    const hashProbeUnit = 0.15;\n\n    const N = params.customers;\n    const M = params.orders;\n    const selectivity = params.selectivity; // fraction 0..1\n    const filteredOrders = params.pushdown ? M * selectivity : M;\n    let cost = 0;\n    let planDesc = [];\n\n    if (params.algorithm === 'nested') {\n      // nested loops: customer outer, orders inner\n      cost = N * filteredOrders * scanUnit;\n      planDesc.push(`Nested Loop: N_customers (${N}) × orders_scanned (${Math.round(filteredOrders)})`);\n      if (!params.pushdown) planDesc.push('No predicate pushdown ⇒ filter applied after join');\n    } else if (params.algorithm === 'indexed') {\n      // indexed nested loop: for each customer, use index lookup: cost = N * (lookup + matchedRows*scanUnit)\n      const avgMatchesPerCustomer = (M / N) * (params.selectivity);\n      cost = N * (lookupUnit + Math.max(1, avgMatchesPerCustomer) * scanUnit);\n      planDesc.push(`Indexed Lookup: N_customers (${N}) × (index_lookup + #matches)`);\n      if (!params.index) {\n        planDesc.push('NOTE: index disabled — planner may fall back to scan (higher cost)');\n        // fallback to nested loop estimate\n        cost = N * filteredOrders * scanUnit;\n      }\n    } else if (params.algorithm === 'hash') {\n      // build hash on smaller side\n      if (M <= N) {\n        // build on orders (maybe after pushdown)\n        const buildRows = filteredOrders;\n        cost = buildRows * hashBuildUnit + N * hashProbeUnit;\n        planDesc.push(`Hash Join: build hash on Orders (${Math.round(buildRows)}) + probe Customers (${N})`);\n      } else {\n        const buildRows = N;\n        cost = buildRows * hashBuildUnit + M * hashProbeUnit;\n        planDesc.push(`Hash Join: build hash on Customers (${buildRows}) + probe Orders (${M})`);\n      }\n      if (params.pushdown) planDesc.push('Predicate pushdown applied before building hash');\n    }\n    return { cost: cost || 1, planDesc };\n  }\n\n  // Execution primitives with measurement\n  function buildIndex(table, key) {\n    const map = new Map();\n    for (let r of table) {\n      const k = r[key];\n      let arr = map.get(k);\n      if (!arr) { arr = []; map.set(k, arr); }\n      arr.push(r);\n    }\n    return map;\n  }\n\n  // Join implementations return matched row pairs\n  function nestedLoopJoin(customers, orders, predicateFn, pushdown) {\n    const start = performance.now();\n    let ordersToScan = orders;\n    if (pushdown) ordersToScan = orders.filter(predicateFn); // reduces inner loops\n    let countScannedOrders = 0;\n    const matches = [];\n    for (let c of customers) {\n      for (let o of ordersToScan) {\n        countScannedOrders++;\n        if (o.customerId === c.id) {\n          // If predicate wasn't pushed, ensure we apply it now\n          if (!pushdown && !predicateFn(o)) continue;\n          matches.push([c,o]);\n        }\n      }\n    }\n    const time = performance.now() - start;\n    return { matches, time, scannedOrders: countScannedOrders, scannedCustomers: customers.length };\n  }\n\n  function indexedNestedLoopJoin(customers, orders, predicateFn, index, pushdown) {\n    const start = performance.now();\n    let scannedOrders = 0;\n    const matches = [];\n    for (let c of customers) {\n      const list = index.get(c.id);\n      if (!list) continue;\n      // If pushdown: pre-filter the indexed list\n      for (let o of list) {\n        scannedOrders++;\n        if (pushdown && !predicateFn(o)) continue;\n        if (!pushdown && !predicateFn(o)) continue; // still need predicate\n        matches.push([c,o]);\n      }\n    }\n    const time = performance.now() - start;\n    return { matches, time, scannedOrders, scannedCustomers: customers.length };\n  }\n\n  function hashJoin(customers, orders, predicateFn, pushdown) {\n    const start = performance.now();\n    let left = customers, right = orders;\n    // We'll build hash on smaller side (after applying pushdown if it targets right)\n    // In our demo, predicate targets orders, so pushdown reduces right before build.\n    let rightSide = right;\n    if (pushdown) rightSide = right.filter(predicateFn);\n    let leftSide = left;\n    let scannedRowsBuild = 0, scannedRowsProbe = 0;\n    const matches = [];\n\n    // Decide which side to build based on sizes\n    if (rightSide.length <= leftSide.length) {\n      // build on rightSide keyed by customerId\n      const map = new Map();\n      for (let r of rightSide) {\n        scannedRowsBuild++;\n        const key = r.customerId;\n        const arr = map.get(key) || [];\n        arr.push(r);\n        map.set(key, arr);\n      }\n      for (let l of leftSide) {\n        scannedRowsProbe++;\n        const arr = map.get(l.id);\n        if (arr) {\n          for (let r of arr) {\n            matches.push([l,r]);\n          }\n        }\n      }\n    } else {\n      // build on leftSide keyed by id\n      const map = new Map();\n      for (let l of leftSide) {\n        scannedRowsBuild++;\n        map.set(l.id, l);\n      }\n      for (let r of rightSide) {\n        scannedRowsProbe++;\n        const l = map.get(r.customerId);\n        if (l) matches.push([l,r]);\n      }\n    }\n    const time = performance.now() - start;\n    return { matches, time, scannedOrders: scannedRowsBuild + scannedRowsProbe, scannedCustomers: leftSide.length };\n  }\n\n  // Planner / Explain generation — chooses plan description & estimate\n  function generateExplain(params) {\n    const est = estimateCost(params);\n    const rows = {\n      customers: params.customers,\n      orders: params.orders,\n      selectivityPct: Math.round(params.selectivity*100),\n      filteredOrders: Math.round(params.orders * (params.pushdown ? params.selectivity : 1))\n    };\n    // Build textual explanation\n    let lines = [];\n    lines.push(`Query: SELECT * FROM Customers JOIN Orders ON orders.customerId = customers.id`);\n    lines.push(`Filter: orders.amount > threshold (selectivity ≈ ${Math.round(params.selectivity*100)}%)`);\n    lines.push('');\n    lines.push('Planner choices:');\n    if (params.algorithm === 'nested') {\n      lines.push('- Join algorithm: Nested Loop Join (no index probe)');\n    } else if (params.algorithm === 'indexed') {\n      if (params.index) lines.push('- Join algorithm: Indexed Nested Loop (use index on orders.customerId)');\n      else lines.push('- Join algorithm: Indexed Nested Loop requested, but index is DISABLED. Planner will fall back to nested loop scan.');\n    } else if (params.algorithm === 'hash') {\n      lines.push('- Join algorithm: Hash Join (build hash on smaller input)');\n    }\n    lines.push(params.pushdown ? '- Predicate pushdown: ENABLED (apply orders filter early)' : '- Predicate pushdown: DISABLED (filter after join)');\n    lines.push('');\n    lines.push('Cost estimate (relative units):');\n    lines.push(`- Estimated work: ${Math.round(est.cost).toLocaleString()}`);\n    lines.push('');\n    lines.push('Estimator detail:');\n    est.planDesc.forEach(x => lines.push('- '+x));\n    lines.push('');\n    lines.push('Row counts:');\n    lines.push(`- Customers: ${rows.customers}`);\n    lines.push(`- Orders: ${rows.orders}`);\n    if (params.pushdown) lines.push(`- Orders after filter: ${rows.filteredOrders}`);\n    return lines.join('\\n');\n  }\n\n  // Run query (generate data each run for fairness)\n  async function runQuery() {\n    // read config\n    const Nc = parseInt(customersCount.value,10);\n    const No = parseInt(ordersCount.value,10);\n    const selPct = parseInt(selectivity.value,10)/100;\n    const alg = algorithm.value;\n    const idx = indexOnOrders.checked;\n    const pushdown = predicatePushdown.checked;\n\n    // disable UI while running\n    runBtn.disabled = true;\n    explainBtn.disabled = true;\n    output.textContent = 'Generating data...';\n    estBar.textContent = '—';\n    actBar.textContent = '—';\n    metrics.textContent = '';\n\n    // generate data with deterministic seed for reproducibility\n    const data = generateData(Nc, No, selectivity.value, 98765);\n\n    // create predicate function\n    const threshold = data.threshold;\n    const predicateFn = (o) => o.amount > threshold;\n\n    // Build index if requested and available\n    let index = null;\n    if (idx) {\n      output.textContent = 'Building index on orders.customerId...';\n      // build index on orders (full)\n      index = buildIndex(data.orders, 'customerId');\n    }\n\n    // Show estimated plan quickly\n    const params = { customers: Nc, orders: No, selectivity: selPct, algorithm: alg, index: idx, pushdown: pushdown };\n    explainDiv.textContent = generateExplain(params);\n\n    // Execute selected algorithm and measure time & scanned rows\n    output.textContent = 'Executing query... (measuring performance)';\n    await new Promise(r => setTimeout(r,50)); // let UI update\n\n    let result, scannedOrders=0, scannedCustomers=0, execTime=0;\n    try {\n      if (alg === 'nested') {\n        result = nestedLoopJoin(data.customers, data.orders, predicateFn, pushdown);\n        scannedOrders = result.scannedOrders;\n        scannedCustomers = result.scannedCustomers;\n        execTime = result.time;\n      } else if (alg === 'indexed') {\n        if (!idx) {\n          // no index present — fallback to nested loop with scan\n          result = nestedLoopJoin(data.customers, data.orders, predicateFn, pushdown);\n        } else {\n          result = indexedNestedLoopJoin(data.customers, data.orders, predicateFn, index, pushdown);\n        }\n        scannedOrders = result.scannedOrders;\n        scannedCustomers = result.scannedCustomers;\n        execTime = result.time;\n      } else if (alg === 'hash') {\n        result = hashJoin(data.customers, data.orders, predicateFn, pushdown);\n        scannedOrders = result.scannedOrders;\n        scannedCustomers = result.scannedCustomers;\n        execTime = result.time;\n      }\n    } catch (e) {\n      output.textContent = 'Error during execution: ' + e.message;\n      runBtn.disabled = false;\n      explainBtn.disabled = false;\n      return;\n    }\n\n    // collect metrics\n    const matchedRows = result.matches.length;\n    const est = estimateCost(params);\n    // Update UI: textual output\n    const outLines = [];\n    outLines.push(`Execution finished.`);\n    outLines.push(`- Algorithm: ${alg}`);\n    outLines.push(`- Index on orders.customerId: ${idx ? 'YES' : 'NO'}`);\n    outLines.push(`- Predicate pushdown: ${pushdown ? 'YES' : 'NO'}`);\n    outLines.push('');\n    outLines.push(`Rows matched (join result): ${matchedRows}`);\n    outLines.push(`Rows scanned (orders): ${scannedOrders}`);\n    outLines.push(`Rows scanned (customers): ${scannedCustomers}`);\n    outLines.push(`Execution time (measured): ${execTime.toFixed(3)} ms`);\n    outLines.push('');\n    outLines.push('Sample of result rows (up to 8):');\n    for (let i=0;i<Math.min(8, result.matches.length); i++){\n      const [c,o] = result.matches[i];\n      outLines.push(`- Customer ${c.id} / Order ${o.id} (amount=${o.amount})`);\n    }\n    if (result.matches.length === 0) outLines.push('- (no matching rows)');\n    output.textContent = outLines.join('\\n');\n\n    // Update bars (visualization): scale relative to estimate and time\n    const estVal = Math.max(1, Math.round(est.cost));\n    const actVal = Math.max(0.01, execTime);\n    // For presentation, normalize heights between 30 and 180 px\n    const estMax = 2000000; // large sentinel for heavy synthetic cost\n    const estH = 40 + Math.min(140, Math.round((estVal / (estVal + 10000)) * 140));\n    const actH = 40 + Math.min(140, Math.round((Math.log(1+actVal) / Math.log(1+1000)) * 140));\n    estBar.style.height = estH + 'px';\n    actBar.style.height = actH + 'px';\n    estBar.textContent = estVal.toLocaleString();\n    actBar.textContent = execTime.toFixed(3) + 'ms';\n\n    metrics.innerHTML = `Estimated work: <strong>${Math.round(estVal).toLocaleString()}</strong> units — actual measured time: <strong>${execTime.toFixed(3)} ms</strong>.`;\n\n    // Re-enable UI\n    runBtn.disabled = false;\n    explainBtn.disabled = false;\n  }\n\n  // Wire buttons\n  runBtn.addEventListener('click', () => {\n    runQuery();\n  });\n\n  explainBtn.addEventListener('click', () => {\n    const Nc = parseInt(customersCount.value,10);\n    const No = parseInt(ordersCount.value,10);\n    const selPct = parseInt(selectivity.value,10)/100;\n    const alg = algorithm.value;\n    const idx = indexOnOrders.checked;\n    const pushdown = predicatePushdown.checked;\n    const params = { customers: Nc, orders: No, selectivity: selPct, algorithm: alg, index: idx, pushdown: pushdown };\n    explainDiv.textContent = generateExplain(params);\n  });\n\n  // Initial explain\n  explainBtn.click();\n\n  // A short tip log in console (for curiosity)\n  console.log('Query Optimization Explorer loaded. Use the controls to compare nested-loop, indexed and hash joins, and predicate pushdown.');\n})();\n</script>\n</body>\n</html>"
  },
