    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Mutex Demonstration</title>\n<style>\n  body {\n    font-family: sans-serif;\n    margin: 1em;\n  }\n  #log {\n    background: #f0f0f0;\n    border: 1px solid #ccc;\n    height: 250px;\n    overflow-y: scroll;\n    padding: 0.5em;\n    white-space: pre-wrap;\n    font-family: monospace;\n  }\n  button {\n    margin: 0.5em 0.2em;\n    padding: 0.5em 1em;\n    font-size: 1rem;\n  }\n</style>\n</head>\n<body>\n\n<h1>Mutex Demo in JavaScript</h1>\n<p>This demo simulates multiple async \"tasks\" trying to access a shared resource controlled by a mutex to ensure mutual exclusion.</p>\n\n<button id=\"start\">Start Tasks</button>\n<button id=\"clear\">Clear Log</button>\n\n<div id=\"log\"></div>\n\n<script>\n  // Simple async Mutex implementation\n  class Mutex {\n    constructor() {\n      this._queue = [];\n      this._locked = false;\n    }\n    \n    lock() {\n      // Returns a Promise that resolves when the lock is acquired\n      const unlockNext = () => {\n        if (this._queue.length > 0) {\n          // Dequeue a resolver and call it\n          const nextResolve = this._queue.shift();\n          nextResolve(unlockNext);\n        } else {\n          this._locked = false;\n        }\n      };\n\n      if (this._locked) {\n        return new Promise(resolve => {\n          this._queue.push(resolve);\n        });\n      } else {\n        this._locked = true;\n        return new Promise(resolve => {\n          resolve(unlockNext);\n        });\n      }\n    }\n  }\n\n  // Helper to log with timestamp\n  function log(msg) {\n    const logEl = document.getElementById('log');\n    const timestamp = new Date().toLocaleTimeString();\n    logEl.textContent += `[${timestamp}] ${msg}\\n`;\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  // Simulate a shared resource\n  let sharedCounter = 0;\n\n  // Task function simulating work requiring mutex\n  async function task(mutex, id, duration) {\n    log(`Task ${id}: Waiting to acquire mutex...`);\n    const unlock = await mutex.lock();\n\n    try {\n      log(`Task ${id}: Mutex acquired, entering critical section.`);\n      // Critical section start\n      const before = sharedCounter;\n      // Simulate some asynchronous work\n      await new Promise(r => setTimeout(r, duration));\n      sharedCounter = before + 1;\n      log(`Task ${id}: Updated sharedCounter from ${before} to ${sharedCounter}.`);\n      // Critical section end\n      log(`Task ${id}: Leaving critical section.`);\n    } finally {\n      unlock();\n      log(`Task ${id}: Mutex released.`);\n    }\n  }\n\n  document.getElementById('start').addEventListener('click', () => {\n    sharedCounter = 0;\n    log('Starting tasks...\\n');\n\n    const mutex = new Mutex();\n\n    // Launch multiple tasks with varying durations\n    task(mutex, 1, 1500);\n    task(mutex, 2, 800);\n    task(mutex, 3, 1200);\n    task(mutex, 4, 1000);\n    task(mutex, 5, 500);\n  });\n\n  document.getElementById('clear').addEventListener('click', () => {\n    document.getElementById('log').textContent = '';\n  });\n</script>\n\n</body>\n</html>"
