    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>PageRank Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f4f8;\n    color: #222;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 5px;\n  }\n  #container {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 30px;\n    justify-content: center;\n  }\n  #graph, #pagerank {\n    background: white;\n    border-radius: 8px;\n    padding: 20px;\n    box-shadow: 0 0 12px #ccc;\n  }\n  #graph {\n    flex: 1 1 520px;\n    max-width: 600px;\n  }\n  #pagerank {\n    flex: 1 1 280px;\n    max-width: 350px;\n  }\n  #iterations {\n    margin-top: 15px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 10px;\n  }\n  button {\n    border: none;\n    background-color: #007acc;\n    color: white;\n    padding: 8px 14px;\n    border-radius: 5px;\n    cursor: pointer;\n    font-weight: bold;\n    font-size: 1rem;\n  }\n  button:disabled {\n    background-color: #aaa;\n    cursor: default;\n  }\n  svg {\n    background: #e9eff5;\n    border-radius: 8px;\n  }\n  .node circle {\n    fill: #4285f4;\n    stroke: #1a73e8;\n    stroke-width: 2px;\n  }\n  .node text {\n    font-weight: bold;\n    fill: white;\n    user-select:none;\n    pointer-events:none;\n  }\n  .edge path {\n    stroke: #555;\n    stroke-width: 2px;\n    fill: none;\n    marker-end: url(#arrowhead);\n  }\n  .edge text {\n    font-size: 12px;\n    fill: #333;\n    pointer-events:none;\n  }\n  #explanation {\n    max-width: 900px;\n    margin: 20px auto 40px auto;\n    line-height: 1.4;\n  }\n  #dampingControl {\n    margin-bottom: 15px;\n    text-align: center;\n  }\n  label {\n    font-weight: bold;\n  }\n  #iterationsCount {\n    font-weight: bold;\n    min-width: 30px;\n    text-align: center;\n  }\n  @media (max-width: 900px) {\n    #container {\n      flex-direction: column;\n      align-items: center;\n    }\n    #graph, #pagerank {\n      max-width: 100%;\n      flex: none;\n    }\n  }\n</style>\n</head>\n<body>\n<h1>PageRank Algorithm Demo</h1>\n\n<div id=\"explanation\">\n  <p>\n    PageRank is an algorithm used by search engines to rank web pages in their search results.\n    It works by counting the number and quality of links to a page to estimate how important\n    the page is. The underlying assumption is that more important pages are likely to receive \n    more links from other pages.\n  </p>\n  <p>\n    This demo shows a simplified network of 5 pages (A, B, C, D, E). Each page links to some others,\n    and we iteratively calculate PageRank values for each page using the formula:\n  </p>\n  <pre>\n    PR(A) = (1 - d)/N + d * ∑ [ PR(page_i) / L(page_i) ]\n  </pre>\n  <p>\n    where:\n    <ul>\n      <li><code>d</code> is the damping factor (usually ≈ 0.85)</li>\n      <li><code>N</code> is total number of pages</li>\n      <li><code>L(page_i)</code> is number of outbound links from <code>page_i</code></li>\n      <li>The sum is over all pages linking to A</li>\n    </ul>\n  </p>\n  <p>\n    Use the buttons below to run iterations and watch how PageRank values stabilize.\n  </p>\n  <div id=\"dampingControl\">\n    <label for=\"damping\">Damping factor (d): </label>\n    <input type=\"range\" id=\"damping\" min=\"0.5\" max=\"0.95\" step=\"0.01\" value=\"0.85\" />\n    <span id=\"dampingValue\">0.85</span>\n  </div>\n</div>\n\n<div id=\"container\">\n  <div id=\"graph\">\n    <svg id=\"svgGraph\" width=\"580\" height=\"420\" aria-label=\"Graph showing pages and links\" role=\"img\" >\n      <defs>\n        <marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\"\n          refX=\"10\" refY=\"3.5\" orient=\"auto\" fill=\"#555\">\n          <polygon points=\"0 0, 10 3.5, 0 7\" />\n        </marker>\n      </defs>\n    </svg>\n  </div>\n  <div id=\"pagerank\">\n    <h2>PageRank Values</h2>\n    <table id=\"rankTable\" border=\"1\" cellpadding=\"8\" cellspacing=\"0\" style=\"border-collapse: collapse; width:100%;\">\n      <thead style=\"background:#007acc; color: white;\">\n        <tr>\n          <th>Page</th>\n          <th>Rank</th>\n        </tr>\n      </thead>\n      <tbody>\n        <!-- dynamically filled -->\n      </tbody>\n    </table>\n    <div id=\"iterations\">\n      <button id=\"stepBtn\" title=\"Do one iteration\">Iterate ▶️</button>\n      <button id=\"autoBtn\" title=\"Start/stop auto iterations\">Auto ►</button>\n      <button id=\"resetBtn\" title=\"Reset ranks\">Reset ⟲</button>\n      <span style=\"margin-left:1em;\">Iteration: <span id=\"iterationsCount\">0</span></span>\n    </div>\n  </div>\n</div>\n\n<script>\n(() => {\n  \"use strict\";\n\n  // Graph definition: pages and their outbound links\n  // Represented as adjacency list where key is page, value is array of pages it links to\n  const graph = {\n    A: [\"B\", \"C\"],\n    B: [\"C\", \"D\"],\n    C: [\"A\", \"D\", \"E\"],\n    D: [\"E\"],\n    E: [\"A\"],\n  };\n\n  const pages = Object.keys(graph);\n  const N = pages.length;\n\n  // Positions of nodes for visualization (x,y in SVG coords)\n  const nodePositions = {\n    A: { x: 130, y: 60 },\n    B: { x: 450, y: 60 },\n    C: { x: 290, y: 180 },\n    D: { x: 450, y: 320 },\n    E: { x: 130, y: 320 },\n  };\n\n  // Initialize page ranks equally\n  let ranks = {};\n  let iteration = 0;\n  let damping = 0.85;\n\n  // Elements\n  const svg = document.getElementById(\"svgGraph\");\n  const tbody = document.querySelector(\"#rankTable tbody\");\n  const stepBtn = document.getElementById(\"stepBtn\");\n  const autoBtn = document.getElementById(\"autoBtn\");\n  const resetBtn = document.getElementById(\"resetBtn\");\n  const iterCountSpan = document.getElementById(\"iterationsCount\");\n  const dampingSlider = document.getElementById(\"damping\");\n  const dampingValueSpan = document.getElementById(\"dampingValue\");\n\n  // For auto iteration\n  let autoInterval = null;\n  const AUTO_INTERVAL_MS = 1500;\n\n  // Helper: create SVG element with attrs\n  function SVG(tag, attrs = {}) {\n    const el = document.createElementNS(\"http://www.w3.org/2000/svg\", tag);\n    Object.entries(attrs).forEach(([k, v]) => el.setAttribute(k, v));\n    return el;\n  }\n\n  // Compute inbound links map (which pages link to each page)\n  // Example: inboundLinks[\"A\"] = [ \"C\", ... ]\n  const inboundLinks = {};\n  for (let p of pages) inboundLinks[p] = [];\n  for (let from of pages) {\n    for (let to of graph[from]) {\n      inboundLinks[to].push(from);\n    }\n  }\n\n  // Draw the graph with nodes and edges\n  function drawGraph() {\n    // Clear previous\n    while (svg.firstChild) svg.removeChild(svg.firstChild);\n\n    // Re-add defs (arrow heads)\n    const defs = SVG(\"defs\");\n    defs.innerHTML = `\n    <marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\"\n      refX=\"10\" refY=\"3.5\" orient=\"auto\" fill=\"#555\">\n      <polygon points=\"0 0, 10 3.5, 0 7\" />\n    </marker>`;\n    svg.appendChild(defs);\n\n    // Draw edges\n    for (let from of pages) {\n      for (let to of graph[from]) {\n        drawEdge(from, to);\n      }\n    }\n\n    // Draw nodes on top\n    for (let p of pages) {\n      drawNode(p);\n    }\n  }\n\n  // Draw a curved edge with arrow from 'from' to 'to'\n  function drawEdge(from, to) {\n    const posFrom = nodePositions[from];\n    const posTo = nodePositions[to];\n\n    // Calculate a simple quadratic curve path\n    // If from === to, draw a loop\n    let path;\n    if (from === to) {\n      // Self loop as a small circle to the right\n      const r = 20;\n      const x = posFrom.x;\n      const y = posFrom.y;\n      path = `M${x} ${y} \n              q${r} -${r} ${r * 2} 0\n              q-${r * 2} ${r} -${r * 2} 0`;\n    } else {\n      // Offset control point for curve\n      const dx = posTo.x - posFrom.x;\n      const dy = posTo.y - posFrom.y;\n      const mx = (posFrom.x + posTo.x) / 2;\n      const my = (posFrom.y + posTo.y) / 2;\n      const norm = Math.sqrt(dx * dx + dy * dy);\n      const offset = 40;\n      // Perpendicular vector for control point\n      const nx = -dy / norm;\n      const ny = dx / norm;\n\n      const cx = mx + nx * offset;\n      const cy = my + ny * offset;\n\n      path = `M${posFrom.x} ${posFrom.y} Q${cx} ${cy} ${posTo.x} ${posTo.y}`;\n    }\n\n    const edgePath = SVG(\"path\", {\n      d: path,\n      class: \"edge\",\n      \"marker-end\": \"url(#arrowhead)\",\n      \"stroke-linejoin\": \"round\",\n    });\n    edgePath.classList.add(\"edge\");\n    svg.appendChild(edgePath);\n  }\n\n  // Draw a node circle with text inside\n  function drawNode(p) {\n    const pos = nodePositions[p];\n    const g = SVG(\"g\", { class: \"node\", tabindex: \"0\", role: \"button\", \"aria-label\": `Page ${p}` });\n\n    const circle = SVG(\"circle\", { cx: pos.x, cy: pos.y, r: 30, \"aria-hidden\": \"true\" });\n    g.appendChild(circle);\n\n    const text = SVG(\"text\", {\n      x: pos.x,\n      y: pos.y + 6,\n      \"text-anchor\": \"middle\",\n      \"font-size\": \"20\",\n      \"pointer-events\": \"none\",\n      \"user-select\": \"none\",\n      fill: \"white\",\n      \"aria-hidden\": \"true\",\n    });\n    text.textContent = p;\n    g.appendChild(text);\n\n    svg.appendChild(g);\n  }\n\n  // Update the rank table with current ranks\n  function updateRankTable() {\n    tbody.innerHTML = \"\";\n    // Sort by descending rank\n    const sorted = pages.slice().sort((a, b) => ranks[b] - ranks[a]);\n    for (let p of sorted) {\n      const tr = document.createElement(\"tr\");\n      const tdName = document.createElement(\"td\");\n      tdName.textContent = p;\n      const tdRank = document.createElement(\"td\");\n      tdRank.textContent = ranks[p].toFixed(4);\n      tr.appendChild(tdName);\n      tr.appendChild(tdRank);\n      tbody.appendChild(tr);\n    }\n  }\n\n  // Run one PageRank iteration calculation\n  function iterateRank() {\n    const newRanks = {};\n    for (let p of pages) {\n      let inboundSum = 0;\n      for (let q of inboundLinks[p]) {\n        const Lq = graph[q].length || N; // if no outbound links, treat as linking to all (dead end)\n        inboundSum += ranks[q] / Lq;\n      }\n      // Take care of dangling nodes (pages with no outbound links)\n      // Pages with no outbound links contribute rank equally to all nodes\n      let danglingSum = 0;\n      for (let q of pages) {\n        if (graph[q].length === 0) {\n          danglingSum += ranks[q] / N;\n        }\n      }\n      inboundSum += danglingSum;\n\n      newRanks[p] = (1 - damping) / N + damping * inboundSum;\n    }\n\n    ranks = newRanks;\n    iteration++;\n    iterCountSpan.textContent = iteration;\n    updateRankTable();\n  }\n\n  // Reset ranks and iteration count\n  function resetRanks() {\n    iteration = 0;\n    ranks = {};\n    for (let p of pages) {\n      ranks[p] = 1 / N;\n    }\n    iterCountSpan.textContent = iteration;\n    updateRankTable();\n  }\n\n  // Initialize damping slider\n  function initDampingControl() {\n    dampingSlider.addEventListener(\"input\", () => {\n      damping = parseFloat(dampingSlider.value);\n      dampingValueSpan.textContent = damping.toFixed(2);\n      resetRanks();\n    });\n  }\n\n  // Setup buttons behavior\n  function setupButtons() {\n    stepBtn.addEventListener(\"click\", () => {\n      iterateRank();\n    });\n\n    autoBtn.addEventListener(\"click\", () => {\n      if (autoInterval) {\n        // Stop\n        clearInterval(autoInterval);\n        autoInterval = null;\n        autoBtn.textContent = \"Auto ►\";\n        stepBtn.disabled = false;\n      } else {\n        // Start\n        autoInterval = setInterval(iterateRank, AUTO_INTERVAL_MS);\n        autoBtn.textContent = \"Stop ■\";\n        stepBtn.disabled = true;\n      }\n    });\n\n    resetBtn.addEventListener(\"click\", () => {\n      if (autoInterval) {\n        clearInterval(autoInterval);\n        autoInterval = null;\n        autoBtn.textContent = \"Auto ►\";\n        stepBtn.disabled = false;\n      }\n      resetRanks();\n    });\n  }\n\n  // Initialization\n  function init() {\n    drawGraph();\n    initDampingControl();\n    setupButtons();\n    dampingValueSpan.textContent = damping.toFixed(2);\n    resetRanks();\n  }\n\n  init();\n})();\n</script>\n</body>\n</html>"
  },
