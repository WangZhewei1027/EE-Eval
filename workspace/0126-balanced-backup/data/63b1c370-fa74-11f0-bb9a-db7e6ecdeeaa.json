    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Floyd-Warshall Algorithm Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f0f0;\n  }\n  h1 {\n    text-align: center;\n  }\n  #graphInput {\n    margin-bottom: 20px;\n  }\n  label {\n    font-weight: bold;\n  }\n  textarea {\n    width: 100%;\n    font-family: monospace;\n    font-size: 14px;\n    height: 120px;\n  }\n  button {\n    margin-top: 10px;\n    padding: 10px 15px;\n    font-size: 16px;\n    cursor: pointer;\n  }\n  #output {\n    margin-top: 20px;\n    overflow-x:auto;\n  }\n  table {\n    border-collapse: collapse;\n    margin: 10px 0;\n    width: 100%;\n    max-width: 600px;\n  }\n  th, td {\n    border: 1px solid #999;\n    padding: 6px 10px;\n    text-align: center;\n  }\n  th {\n    background: #555;\n    color: white;\n  }\n  td.infinity {\n    color: #d00;\n    font-weight: bold;\n  }\n  #step-description {\n    white-space: pre-wrap;\n    background: #fff;\n    border: 1px solid #ccc;\n    padding: 10px;\n    max-width: 600px;\n    margin-bottom: 10px;\n    height: 100px;\n    overflow-y: auto;\n  }\n  #controls {\n    margin-top: 15px;\n  }\n  button:disabled {\n    opacity: 0.5;\n    cursor: default;\n  }\n  #legend {\n    margin-top: 30px;\n    max-width: 600px;\n  }\n  #legend div {\n    display: inline-block;\n    margin-right: 15px;\n    font-size: 14px;\n  }\n  #legend .infinity {\n    color: #d00;\n    font-weight: bold;\n  }\n</style>\n</head>\n<body>\n\n<h1>Floyd-Warshall Algorithm Demonstration</h1>\n\n<div id=\"graphInput\">\n  <label for=\"matrixInput\">Enter adjacency matrix (use \"INF\" or a large number for no direct edge):</label><br/>\n  <textarea id=\"matrixInput\" spellcheck=\"false\">0 3 INF 5\n2 0 INF 4\nINF 1 0 INF\nINF INF 2 0</textarea><br/>\n  <small>Example for graph with 4 vertices:</small>\n  <pre>\n0 3 INF 5\n2 0 INF 4\nINF 1 0 INF\nINF INF 2 0\n  </pre>\n  <button id=\"startBtn\">Start Algorithm</button>\n</div>\n\n<div id=\"output\" style=\"display:none;\">\n  <h2>Step <span id=\"stepNumber\">0</span> / <span id=\"maxSteps\">0</span></h2>\n  <div id=\"step-description\"></div>\n  <div id=\"matrixContainer\"></div>\n  <div id=\"controls\">\n    <button id=\"prevStep\" disabled>&lt; Previous Step</button>\n    <button id=\"nextStep\" disabled>Next Step &gt;</button>\n  </div>\n</div>\n\n<div id=\"legend\">\n  <strong>Legend:</strong>\n  <div><span style=\"color:#0a0; font-weight:bold\">Green</span> = Updated shortest distance</div>\n  <div><span class=\"infinity\">INF</span> = No path / Infinity</div>\n</div>\n\n<script>\n(() => {\n  const INF = Infinity;\n\n  // Parse input matrix text area and return adjacency matrix (2D array)\n  function parseMatrix(text) {\n    const rows = text.trim().split('\\n');\n    const matrix = [];\n    for (const rowText of rows) {\n      const values = rowText.trim().split(/\\s+/).map(v => {\n        if (v.toUpperCase() === 'INF' || v === '∞') return INF;\n        const num = Number(v);\n        return isNaN(num) ? INF : num;\n      });\n      matrix.push(values);\n    }\n    // Validate matrix shape: must be square\n    const n = matrix.length;\n    if (matrix.some(row => row.length !== n)) {\n      return null;\n    }\n    return matrix;\n  }\n\n  // Render matrix as HTML table highlighting updated cells\n  function renderMatrix(matrix, updateCoords = [], vertices) {\n    // updateCoords: array of [i,j] pairs to highlight\n    let html = '<table><thead><tr><th></th>';\n    for(let c = 0; c < matrix.length; c++) {\n      html += `<th>v${c}</th>`;\n    }\n    html += '</tr></thead><tbody>';\n    for(let r = 0; r < matrix.length; r++) {\n      html += `<tr><th>v${r}</th>`;\n      for(let c = 0; c < matrix.length; c++) {\n        let val = matrix[r][c];\n        let display = val === INF ? 'INF' : val;\n        let cls = '';\n        // Highlight if in updateCoords\n        if(updateCoords.some(([rr,cc]) => rr === r && cc === c)) {\n          cls = 'style=\"background: #ccffcc; font-weight: bold;\"'; // green highlight\n        }\n        // color INF in red\n        if(val === INF) cls = (cls ? cls.replace('\"', ' color:#d00;\"') : 'class=\"infinity\"');\n        html += `<td ${cls}>${display}</td>`;\n      }\n      html += '</tr>';\n    }\n    html += '</tbody></table>';\n    return html;\n  }\n\n  // Implementation of Floyd-Warshall algorithm with step recording for visualization\n  function floydWarshall(matrix) {\n    const n = matrix.length;\n    // Distance matrix copy\n    const dist = [];\n    for(let i = 0; i < n; i++) {\n      dist[i] = [];\n      for(let j = 0; j < n; j++) {\n        dist[i][j] = matrix[i][j];\n      }\n    }\n\n    // Steps: each element is an object:\n    // {k, i, j, updated: boolean, distSnapshot: [][]\n    //  desc: string description\n    //  updatedCell: [i,j] or null }\n    const steps = [];\n\n    // Initial state (k=-1 means before any iteration)\n    steps.push({\n      k: -1,\n      i: -1,\n      j: -1,\n      updated: false,\n      distSnapshot: JSON.parse(JSON.stringify(dist)),\n      desc: 'Initial distance matrix before running algorithm.',\n      updatedCell: null,\n    });\n\n    for(let k = 0; k < n; k++) {\n      for(let i = 0; i < n; i++) {\n        for(let j = 0; j < n; j++) {\n          let newDistance;\n          if (dist[i][k] === INF || dist[k][j] === INF) {\n            newDistance = INF;\n          } else {\n            newDistance = dist[i][k] + dist[k][j];\n          }\n          if(newDistance < dist[i][j]) {\n            const old = dist[i][j];\n            dist[i][j] = newDistance;\n            steps.push({\n              k, i, j,\n              updated: true,\n              distSnapshot: JSON.parse(JSON.stringify(dist)),\n              desc: `Considering vertex v${k} as an intermediate, we update distance d[v${i}][v${j}] from ${old === INF ? 'INF' : old} to ${newDistance}.`,\n              updatedCell: [i, j],\n            });\n          } else {\n            steps.push({\n              k, i, j,\n              updated: false,\n              distSnapshot: JSON.parse(JSON.stringify(dist)),\n              desc: `Considering vertex v${k} as an intermediate, distance d[v${i}][v${j}] remains ${dist[i][j] === INF ? 'INF' : dist[i][j]} (no update).`,\n              updatedCell: null,\n            });\n          }\n        }\n      }\n    }\n\n    return steps;\n  }\n\n  // Elements\n  const matrixInput = document.getElementById('matrixInput');\n  const startBtn = document.getElementById('startBtn');\n  const output = document.getElementById('output');\n  const stepNumberSpan = document.getElementById('stepNumber');\n  const maxStepsSpan = document.getElementById('maxSteps');\n  const stepDescDiv = document.getElementById('step-description');\n  const matrixContainer = document.getElementById('matrixContainer');\n  const prevStepBtn = document.getElementById('prevStep');\n  const nextStepBtn = document.getElementById('nextStep');\n\n  let steps = [];\n  let currentStep = 0;\n\n  function updateStepDisplay() {\n    const step = steps[currentStep];\n    stepNumberSpan.textContent = currentStep;\n    maxStepsSpan.textContent = steps.length - 1;\n    stepDescDiv.textContent = step.desc;\n    const highlight = step.updatedCell ? [step.updatedCell] : [];\n    matrixContainer.innerHTML = renderMatrix(step.distSnapshot, highlight);\n\n    prevStepBtn.disabled = currentStep <= 0;\n    nextStepBtn.disabled = currentStep >= steps.length - 1;\n  }\n\n  startBtn.addEventListener('click', () => {\n    const matrix = parseMatrix(matrixInput.value);\n    if (!matrix) {\n      alert('Invalid matrix: Ensure it is square and uses numbers/INF.');\n      return;\n    }\n    steps = floydWarshall(matrix);\n    currentStep = 0;\n\n    output.style.display = 'block';\n    startBtn.disabled = true;\n    matrixInput.disabled = true;\n\n    updateStepDisplay();\n  });\n\n  prevStepBtn.addEventListener('click', () => {\n    if(currentStep > 0) {\n      currentStep--;\n      updateStepDisplay();\n    }\n  });\n\n  nextStepBtn.addEventListener('click', () => {\n    if(currentStep < steps.length - 1) {\n      currentStep++;\n      updateStepDisplay();\n    }\n  });\n})();\n</script>\n\n</body>\n</html>"
  },
