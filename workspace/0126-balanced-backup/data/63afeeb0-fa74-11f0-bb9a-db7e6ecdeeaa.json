    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Circular Linked List Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f5f5f5;\n  }\n  h1 {\n    color: #333;\n  }\n  #list-visual {\n    margin: 20px 0;\n    padding: 10px;\n    background: white;\n    border-radius: 8px;\n    min-height: 80px;\n    font-size: 18px;\n    display: flex;\n    align-items: center;\n  }\n  .node {\n    background: #4a90e2;\n    color: white;\n    border-radius: 50%;\n    width: 50px;\n    height: 50px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    position: relative;\n    margin-right: 30px;\n    font-weight: bold;\n    user-select: none;\n  }\n  .node::after {\n    content: '→';\n    position: absolute;\n    right: -25px;\n    top: 50%;\n    transform: translateY(-50%);\n    font-size: 24px;\n    color: #4a90e2;\n  }\n  .node:last-child::after {\n    content: '↺'; /* indicating circular link back to head */\n    right: -30px;\n    font-size: 28px;\n    color: #e27d60;\n  }\n  button {\n    margin: 5px 5px 15px 0;\n    padding: 8px 15px;\n    font-size: 16px;\n    border-radius: 5px;\n    border: none;\n    cursor: pointer;\n  }\n  button:disabled {\n    background: #ccc;\n    cursor: not-allowed;\n  }\n  #output {\n    margin-top: 30px;\n    background: white;\n    padding: 15px;\n    border-radius: 8px;\n    white-space: pre-wrap;\n    max-height: 200px;\n    overflow-y: auto;\n    font-family: monospace;\n    border: 1px solid #ccc;\n  }\n  label {\n    font-weight: 600;\n  }\n  input[type=\"number\"] {\n    width: 80px;\n    padding: 5px;\n    font-size: 16px;\n    margin-right: 15px;\n  }\n</style>\n</head>\n<body>\n  <h1>Circular Linked List Demo</h1>\n  <p>\n    A Circular Linked List is a linked list where all nodes are connected in a circle; the last node points back to the head.\n  </p>\n  <div>\n    <label for=\"inputValue\">Node Value:</label>\n    <input type=\"number\" id=\"inputValue\" placeholder=\"Enter value\" />\n    <button id=\"appendBtn\">Append Node</button>\n    <button id=\"prependBtn\">Prepend Node</button>\n    <button id=\"removeBtn\">Remove Node (by value)</button>\n  </div>\n  <div id=\"list-visual\" aria-label=\"Circular Linked List Visualization\" role=\"img\">\n    <!-- Nodes visualized here -->\n  </div>\n  <button id=\"traverseBtn\">Traverse List</button>\n  <button id=\"clearBtn\">Clear List</button>\n\n  <div id=\"output\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n  <script>\n    class CircularLinkedListNode {\n      constructor(value) {\n        this.value = value;\n        this.next = null;\n      }\n    }\n\n    class CircularLinkedList {\n      constructor() {\n        this.head = null;\n      }\n\n      isEmpty() {\n        return this.head === null;\n      }\n\n      append(value) {\n        const newNode = new CircularLinkedListNode(value);\n        if (this.isEmpty()) {\n          newNode.next = newNode;\n          this.head = newNode;\n          return;\n        }\n        // otherwise, find last node and insert newNode after it\n        let current = this.head;\n        while (current.next !== this.head) {\n          current = current.next;\n        }\n        current.next = newNode;\n        newNode.next = this.head;\n      }\n\n      prepend(value) {\n        const newNode = new CircularLinkedListNode(value);\n        if (this.isEmpty()) {\n          newNode.next = newNode;\n          this.head = newNode;\n          return;\n        }\n        // Find last node\n        let last = this.head;\n        while (last.next !== this.head) {\n          last = last.next;\n        }\n        newNode.next = this.head;\n        this.head = newNode;\n        last.next = this.head;\n      }\n\n      remove(value) {\n        if (this.isEmpty()) return false;\n\n        // Special case: head needs to be removed\n        let current = this.head, prev = null;\n\n        // Check if head is the only node and matches value\n        if (current.value === value && current.next === this.head) {\n          this.head = null;\n          return true;\n        }\n\n        // General case: iterate till node with value is found\n        do {\n          if (current.value === value) {\n            if (prev) {\n              prev.next = current.next;\n              // If removing head, update head pointer\n              if (current === this.head) {\n                this.head = current.next;\n              }\n            } else {\n              // Removing head, but more nodes exist\n              let last = this.head;\n              while (last.next !== this.head) {\n                last = last.next;\n              }\n              this.head = current.next;\n              last.next = this.head;\n            }\n            return true;\n          }\n          prev = current;\n          current = current.next;\n        } while (current !== this.head);\n\n        // Node not found\n        return false;\n      }\n\n      traverse() {\n        let values = [];\n        if (this.isEmpty()) return values;\n        let current = this.head;\n        do {\n          values.push(current.value);\n          current = current.next;\n        } while (current !== this.head);\n        return values;\n      }\n\n      clear() {\n        this.head = null;\n      }\n    }\n\n    // ------- DOM and interaction logic -------\n\n    const listVisual = document.getElementById('list-visual');\n    const output = document.getElementById('output');\n    const inputValue = document.getElementById('inputValue');\n    const appendBtn = document.getElementById('appendBtn');\n    const prependBtn = document.getElementById('prependBtn');\n    const removeBtn = document.getElementById('removeBtn');\n    const traverseBtn = document.getElementById('traverseBtn');\n    const clearBtn = document.getElementById('clearBtn');\n\n    const cll = new CircularLinkedList();\n\n    function renderList() {\n      listVisual.innerHTML = '';\n      const nodes = cll.traverse();\n      if (nodes.length === 0) {\n        listVisual.textContent = 'List is empty.';\n        return;\n      }\n      nodes.forEach((val, i) => {\n        const nodeEl = document.createElement('div');\n        nodeEl.classList.add('node');\n        nodeEl.textContent = val;\n        listVisual.appendChild(nodeEl);\n      });\n    }\n\n    function printOutput(message) {\n      output.textContent = message;\n    }\n\n    appendBtn.onclick = () => {\n      const v = inputValue.value.trim();\n      if (v === '') {\n        alert('Please enter a node value.');\n        return;\n      }\n      cll.append(v);\n      printOutput(`Appended node with value: ${v}`);\n      renderList();\n      inputValue.value = '';\n    };\n\n    prependBtn.onclick = () => {\n      const v = inputValue.value.trim();\n      if (v === '') {\n        alert('Please enter a node value.');\n        return;\n      }\n      cll.prepend(v);\n      printOutput(`Prepended node with value: ${v}`);\n      renderList();\n      inputValue.value = '';\n    };\n\n    removeBtn.onclick = () => {\n      const v = inputValue.value.trim();\n      if (v === '') {\n        alert('Please enter a node value to remove.');\n        return;\n      }\n      const removed = cll.remove(v);\n      if (removed) {\n        printOutput(`Removed node with value: ${v}`);\n      } else {\n        printOutput(`Node with value ${v} not found.`);\n      }\n      renderList();\n      inputValue.value = '';\n    };\n\n    traverseBtn.onclick = () => {\n      const nodes = cll.traverse();\n      if (nodes.length === 0) {\n        printOutput('The list is empty.');\n      } else {\n        let outputStr = 'Circular Linked List traversal:\\n';\n        outputStr += nodes.join(' → ') + ' → (back to head)';\n        printOutput(outputStr);\n      }\n    };\n\n    clearBtn.onclick = () => {\n      cll.clear();\n      printOutput('List cleared.');\n      renderList();\n    };\n\n    // Initial render\n    renderList();\n  </script>\n</body>\n</html>"
