    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Interpolation Search — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --muted:#9aa7bd;\n      --accent:#60a5fa;\n      --good:#34d399;\n      --bad:#fb7185;\n      --panel:#071026;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color-scheme: dark;\n    }\n    html,body{height:100%; margin:0; background:linear-gradient(180deg,#071428 0%, #041125 100%); color:#e6eef8}\n    .app {\n      max-width:1100px;\n      margin:28px auto;\n      padding:18px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: 0 6px 18px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n    h1 { margin:0 0 6px 0; font-size:20px;}\n    p.lead { margin:6px 0 18px 0; color:var(--muted); font-size:13px;}\n    .controls {\n      display:flex;\n      gap:10px;\n      flex-wrap:wrap;\n      align-items:center;\n      margin-bottom:14px;\n    }\n    label {font-size:13px; color:var(--muted)}\n    .control {\n      display:flex;\n      gap:8px;\n      align-items:center;\n      background:rgba(255,255,255,0.02);\n      padding:8px;\n      border-radius:8px;\n      border:1px solid rgba(255,255,255,0.02);\n      min-height:44px;\n    }\n    input[type=number], select, input[type=text] {\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.04);\n      padding:6px 8px;\n      color:inherit;\n      border-radius:6px;\n      width:120px;\n    }\n    button {\n      background:linear-gradient(180deg,var(--accent), #2b7ecc);\n      color:white;\n      border:0;\n      padding:8px 12px;\n      border-radius:8px;\n      cursor:pointer;\n      font-weight:600;\n    }\n    button.ghost {\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.06);\n      color:var(--muted);\n    }\n    .small { padding:6px 8px; font-size:13px; }\n    .row {\n      display:flex;\n      gap:12px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n    .array-wrap {\n      overflow:auto;\n      padding:12px;\n      border-radius:10px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .array {\n      display:flex;\n      gap:6px;\n      padding:6px;\n      align-items:flex-end;\n      min-height:120px;\n      height:120px;\n    }\n    .cell {\n      width:36px;\n      height:36px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-size:12px;\n      color:#e6eef8;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:8px;\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow:0 1px 0 rgba(255,255,255,0.02) inset;\n      transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;\n      user-select:none;\n      position:relative;\n    }\n    .cell.small { width:28px; height:28px; font-size:11px; }\n    .cell.low { background:linear-gradient(180deg,#2647a6,#1b3586); box-shadow:0 6px 20px rgba(38,71,166,0.14); transform:translateY(-6px); }\n    .cell.high { background:linear-gradient(180deg,#9b4dbe,#7a2f99); box-shadow:0 6px 20px rgba(155,77,190,0.12); transform:translateY(-6px); }\n    .cell.pos { background:linear-gradient(180deg,#ef4444,#cc1f1f); box-shadow:0 6px 26px rgba(239,68,68,0.12); transform:translateY(-8px); }\n    .cell.visited { opacity:0.65; transform:translateY(-2px); }\n    .cell.found { background:linear-gradient(180deg,#34d399,#10b981); box-shadow:0 6px 26px rgba(46,163,112,0.14); transform:translateY(-10px); }\n    .legend { display:flex; gap:8px; align-items:center; color:var(--muted); font-size:13px; margin-top:10px; }\n    .legend .dot { width:12px; height:12px; border-radius:3px; }\n    .panel {\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      padding:12px;\n      border-radius:10px;\n      border:1px solid rgba(255,255,255,0.02);\n      margin-top:12px;\n      display:flex;\n      gap:12px;\n      flex-wrap:wrap;\n      align-items:flex-start;\n    }\n    .info {\n      min-width:260px;\n      max-width:340px;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .stats { display:flex; gap:12px; flex-wrap:wrap; }\n    .stat {\n      background:rgba(255,255,255,0.02);\n      padding:8px;\n      border-radius:8px;\n      min-width:110px;\n      text-align:center;\n    }\n    .stat b{display:block; font-size:16px; color:#e6eef8;}\n    .log {\n      max-height:220px;\n      overflow:auto;\n      background:rgba(0,0,0,0.15);\n      padding:8px;\n      border-radius:8px;\n      font-family:monospace;\n      font-size:12px;\n      color:#dbeafe;\n    }\n    .formula {\n      background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      padding:8px;\n      border-radius:8px;\n      font-family:monospace;\n      color:#f0f9ff;\n      font-size:13px;\n    }\n    footer { margin-top:14px; color:var(--muted); font-size:13px;}\n    @media (max-width:720px){\n      .array { gap:4px; }\n      .cell { width:30px; height:30px; font-size:11px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"app\" role=\"main\" aria-label=\"Interpolation Search demo\">\n    <h1>Interpolation Search — Interactive Demo</h1>\n    <p class=\"lead\">Interpolation search estimates the likely position of the target using a linear interpolation formula. It can be faster than binary search on uniformly distributed, sorted data.</p>\n\n    <div class=\"controls\" aria-hidden=\"false\">\n      <div class=\"control\">\n        <label for=\"size\">Array size</label>\n        <input id=\"size\" type=\"number\" min=\"5\" max=\"201\" value=\"41\" />\n      </div>\n\n      <div class=\"control\">\n        <label for=\"dist\">Distribution</label>\n        <select id=\"dist\">\n          <option value=\"uniform\">Uniform (linear)</option>\n          <option value=\"random\">Random sorted</option>\n          <option value=\"clustered\">Clustered</option>\n          <option value=\"exponential\">Exponential growth</option>\n          <option value=\"duplicates\">Lots of duplicates</option>\n        </select>\n      </div>\n\n      <div class=\"control\">\n        <button id=\"generate\" class=\"small\">Generate array</button>\n        <button id=\"shuffle\" class=\"small ghost\">Regenerate values</button>\n      </div>\n\n      <div class=\"control\">\n        <label for=\"target\">Target</label>\n        <input id=\"target\" type=\"number\" value=\"0\" />\n        <button id=\"randomTarget\" class=\"small ghost\">Random</button>\n      </div>\n\n      <div class=\"control\">\n        <button id=\"start\" class=\"small\">Start Search</button>\n        <button id=\"step\" class=\"small ghost\">Step</button>\n        <button id=\"reset\" class=\"small ghost\">Reset</button>\n      </div>\n\n      <div class=\"control\">\n        <label for=\"speed\">Speed</label>\n        <input id=\"speed\" type=\"range\" min=\"50\" max=\"1500\" step=\"50\" value=\"450\" />\n      </div>\n    </div>\n\n    <div class=\"array-wrap\" aria-live=\"polite\">\n      <div id=\"array\" class=\"array\" role=\"list\" aria-label=\"Array visualization\"></div>\n      <div class=\"legend\">\n        <span class=\"dot\" style=\"background:#2647a6\"></span><span>low</span>\n        <span class=\"dot\" style=\"background:#9b4dbe\"></span><span>high</span>\n        <span class=\"dot\" style=\"background:#ef4444\"></span><span>pos (probe)</span>\n        <span class=\"dot\" style=\"background:#34d399\"></span><span>found</span>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"info\">\n        <div class=\"formula\" id=\"formula\">\n          pos = low + ((target - A[low]) * (high - low)) / (A[high] - A[low])\n        </div>\n\n        <div style=\"margin-top:8px; color:var(--muted); font-size:13px;\">\n          Steps: Use Step to manually advance or Start to run automatically. The demo shows each probe (pos) and updates low/high accordingly. If A[high] == A[low], interpolation falls back to direct check.\n        </div>\n      </div>\n\n      <div style=\"flex:1\">\n        <div class=\"stats\" aria-hidden=\"false\">\n          <div class=\"stat\"><span style=\"color:var(--muted)\">Probes</span><b id=\"probes\">0</b></div>\n          <div class=\"stat\"><span style=\"color:var(--muted)\">Comparisons</span><b id=\"comps\">0</b></div>\n          <div class=\"stat\"><span style=\"color:var(--muted)\">Found index</span><b id=\"found\">-</b></div>\n          <div class=\"stat\"><span style=\"color:var(--muted)\">Iterations</span><b id=\"iters\">0</b></div>\n        </div>\n\n        <div style=\"margin-top:10px;\">\n          <label style=\"font-size:13px; color:var(--muted)\">Compare with Binary Search</label>\n          <div style=\"display:flex; gap:8px; margin-top:6px;\">\n            <button id=\"runBoth\" class=\"small\">Run both</button>\n            <button id=\"runBinary\" class=\"small ghost\">Run binary only</button>\n          </div>\n        </div>\n      </div>\n\n      <div style=\"min-width:320px;\">\n        <div style=\"font-size:13px; color:var(--muted); margin-bottom:6px;\">Log</div>\n        <div id=\"log\" class=\"log\" role=\"log\" aria-live=\"polite\"></div>\n      </div>\n    </div>\n\n    <footer>\n      Notes: Interpolation search is O(log log n) on uniformly distributed data but can degrade to O(n) in worst-case distributions. This demo is educational — values are integers and positions are floored.\n    </footer>\n  </div>\n\n<script>\n(function(){\n  // Utilities\n  const $ = sel => document.querySelector(sel);\n  const arrayEl = $('#array');\n  const sizeInput = $('#size');\n  const distSelect = $('#dist');\n  const generateBtn = $('#generate');\n  const shuffleBtn = $('#shuffle');\n  const targetInput = $('#target');\n  const randomTargetBtn = $('#randomTarget');\n  const startBtn = $('#start');\n  const stepBtn = $('#step');\n  const resetBtn = $('#reset');\n  const speedInput = $('#speed');\n  const probesEl = $('#probes');\n  const compsEl = $('#comps');\n  const foundEl = $('#found');\n  const itersEl = $('#iters');\n  const logEl = $('#log');\n  const formulaEl = $('#formula');\n  const runBothBtn = $('#runBoth');\n  const runBinaryBtn = $('#runBinary');\n\n  let array = [];\n  let currentGenerator = null;\n  let autoTimer = null;\n  let state = { probes:0, comps:0, iters:0, found:-1 };\n  let visited = new Set();\n\n  function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n\n  function makeArray(n, dist){\n    if(dist === 'uniform'){\n      // linear spaced values 1..n\n      const step = Math.max(1, Math.floor(100 / n));\n      let res = [];\n      for(let i=0;i<n;i++) res.push( i*step + 1 );\n      return res;\n    }\n    if(dist === 'random'){\n      let res = [];\n      for(let i=0;i<n;i++) res.push(randInt(1, n*4));\n      res.sort((a,b)=>a-b);\n      return res;\n    }\n    if(dist === 'clustered'){\n      // create clusters\n      let res = [];\n      let clusters = Math.max(3, Math.floor(n/8));\n      let base = 1;\n      for(let c=0;c<clusters;c++){\n        let clusterSize = Math.max(1, Math.floor(n/clusters));\n        for(let i=0;i<clusterSize && res.length<n;i++){\n          res.push(base + randInt(0, Math.max(1,Math.floor(n/6))));\n        }\n        base += randInt(1, Math.max(1,Math.floor(n/3)));\n      }\n      res = res.slice(0,n).sort((a,b)=>a-b);\n      return res;\n    }\n    if(dist === 'exponential'){\n      let res = [];\n      for(let i=0;i<n;i++){\n        res.push(Math.floor(Math.pow(1.12, i) * 2));\n      }\n      for(let i=0;i<n;i++) res[i] += i; // ensure uniqueness increases\n      return res;\n    }\n    if(dist === 'duplicates'){\n      let res = [];\n      for(let i=0;i<n;i++){\n        res.push( Math.floor(i/3) + randInt(0,1) );\n      }\n      return res.sort((a,b)=>a-b);\n    }\n    return [];\n  }\n\n  function renderArray(arr){\n    arrayEl.innerHTML = '';\n    visited = new Set();\n    arr.forEach((v,i)=>{\n      const cell = document.createElement('div');\n      cell.className = 'cell';\n      cell.dataset.index = i;\n      cell.dataset.value = v;\n      cell.title = `index ${i}: ${v}`;\n      cell.textContent = v;\n      arrayEl.appendChild(cell);\n    });\n  }\n\n  function highlight(indices){\n    // indices: {low, high, pos, found, visited:Set}\n    Array.from(arrayEl.children).forEach(cell=>{\n      const idx = +cell.dataset.index;\n      cell.className = 'cell';\n      if(indices.visited && indices.visited.has(idx)) cell.classList.add('visited');\n      if(indices.low === idx) cell.classList.add('low');\n      if(indices.high === idx) cell.classList.add('high');\n      if(indices.pos === idx) cell.classList.add('pos');\n      if(indices.found === idx) cell.classList.add('found');\n    });\n    // try to scroll pos into view\n    const posEl = arrayEl.querySelector('.cell.pos') || arrayEl.querySelector('.cell.found');\n    if(posEl) posEl.scrollIntoView({behavior:'smooth', inline:'center', block:'nearest'});\n  }\n\n  function log(msg){\n    const now = new Date().toLocaleTimeString();\n    logEl.textContent = `[${now}] ${msg}\\n` + logEl.textContent;\n  }\n\n  function resetStats(){\n    state = { probes:0, comps:0, iters:0, found:-1 };\n    updateStats();\n    logEl.textContent = '';\n  }\n\n  function updateStats(){\n    probesEl.textContent = state.probes;\n    compsEl.textContent = state.comps;\n    itersEl.textContent = state.iters;\n    foundEl.textContent = state.found === -1 ? '-' : state.found;\n  }\n\n  // Generator for step-by-step interpolation search\n  function* interpolationSearchGen(A, target){\n    let low = 0, high = A.length - 1;\n    const visitedIdx = new Set();\n\n    // initial state\n    yield {low, high, pos:null, visited: new Set(visitedIdx), info: 'start'};\n\n    while(low <= high && target >= A[low] && target <= A[high]){\n      // avoid division by zero\n      if(A[high] === A[low]){\n        // all values between low..high identical\n        if(A[low] === target){\n          // choose low as found (first)\n          yield {low, high, pos:low, visited: new Set(visitedIdx), info:'all-equal-found'};\n          return {index: low, probes: visitedIdx.size + 1, comps: visitedIdx.size + 1, iters:visitedIdx.size+1};\n        } else {\n          yield {low, high, pos:null, visited: new Set(visitedIdx), info:'all-equal-notfound'};\n          return {index:-1, probes: visitedIdx.size, comps: visitedIdx.size, iters:visitedIdx.size};\n        }\n      }\n\n      // interpolation formula (floating)\n      let posFloat = low + ((target - A[low]) * (high - low)) / (A[high] - A[low]);\n      let pos = Math.floor(posFloat);\n      // clamp to [low,high]\n      if(pos < low) pos = low;\n      if(pos > high) pos = high;\n\n      // probe pos\n      visitedIdx.add(pos);\n      yield {low, high, pos, visited: new Set(visitedIdx), info:`probe pos=${pos} (≈${posFloat.toFixed(2)})`};\n\n      // comparisons\n      if(A[pos] === target){\n        yield {low, high, pos, visited: new Set(visitedIdx), found: pos, info:'found'};\n        return {index: pos, probes: visitedIdx.size, comps: visitedIdx.size, iters:visitedIdx.size};\n      }\n      if(A[pos] < target){\n        yield {low, high, pos, visited: new Set(visitedIdx), info:`A[pos]=${A[pos]} < target`};\n        low = pos + 1;\n      } else {\n        yield {low, high, pos, visited: new Set(visitedIdx), info:`A[pos]=${A[pos]} > target`};\n        high = pos - 1;\n      }\n      // next iteration\n    }\n\n    // not found\n    yield {low, high, pos:null, visited: new Set(visitedIdx), info:'not found'};\n    return {index:-1, probes: visitedIdx.size, comps: visitedIdx.size, iters:visitedIdx.size};\n  }\n\n  // Binary search generator for comparison\n  function* binarySearchGen(A, target){\n    let low=0, high=A.length-1; const visitedIdx = new Set();\n    yield {low, high, pos:null, visited:new Set(visitedIdx), info:'start'};\n    while(low<=high){\n      let mid = Math.floor((low+high)/2);\n      visitedIdx.add(mid);\n      yield {low, high, pos:mid, visited:new Set(visitedIdx), info:`probe mid=${mid}`};\n      if(A[mid]===target){\n        yield {low, high, pos:mid, visited:new Set(visitedIdx), found:mid, info:'found'};\n        return {index:mid, probes:visitedIdx.size, comps:visitedIdx.size, iters:visitedIdx.size};\n      } else if(A[mid] < target){\n        yield {low, high, pos:mid, visited:new Set(visitedIdx), info:`A[mid]=${A[mid]} < target`};\n        low = mid+1;\n      } else {\n        yield {low, high, pos:mid, visited:new Set(visitedIdx), info:`A[mid]=${A[mid]} > target`};\n        high = mid-1;\n      }\n    }\n    yield {low, high, pos:null, visited:new Set(visitedIdx), info:'not found'};\n    return {index:-1, probes: visitedIdx.size, comps:visitedIdx.size, iters:visitedIdx.size};\n  }\n\n  // UI controls\n  function generateAndRender(){\n    const n = Math.max(5, Math.min(201, parseInt(sizeInput.value) || 41));\n    sizeInput.value = n;\n    array = makeArray(n, distSelect.value);\n    renderArray(array);\n    // default target: middle value\n    targetInput.value = array[Math.floor(array.length/2)];\n    resetStats();\n    log(`Generated ${n} values (${distSelect.value}).`);\n    updateFormulaDisplay();\n  }\n\n  function updateFormulaDisplay(curState){\n    if(!curState){\n      formulaEl.textContent = 'pos = low + ((target - A[low]) * (high - low)) / (A[high] - A[low])';\n      return;\n    }\n    const A = array;\n    const low = curState.low, high = curState.high;\n    const target = +targetInput.value;\n    if(high < low || low<0 || high>=A.length){\n      formulaEl.textContent = 'search bounds invalid';\n      return;\n    }\n    if(A[high] === A[low]){\n      formulaEl.textContent = `A[high] == A[low] == ${A[low]} → fallback check: target==${A[low]}?`;\n      return;\n    }\n    const numerator = (target - A[low]) * (high - low);\n    const denom = (A[high] - A[low]);\n    const posFloat = low + numerator/denom;\n    formulaEl.textContent = `pos = ${low} + ((${target} - ${A[low]}) * (${high} - ${low})) / (${A[high]} - ${A[low]}) = ${posFloat.toFixed(3)}`;\n  }\n\n  function startAutoPlay(gen){\n    stopAutoPlay();\n    const speed = Math.max(50, parseInt(speedInput.value) || 450);\n    autoTimer = setInterval(()=>{\n      stepOnce(gen);\n    }, speed);\n  }\n\n  function stopAutoPlay(){\n    if(autoTimer){ clearInterval(autoTimer); autoTimer = null; }\n  }\n\n  function stepOnce(gen){\n    try {\n      const next = gen.next();\n      if(next.done){\n        finalizeSearchResult(next.value);\n        stopAutoPlay();\n        currentGenerator = null;\n        return;\n      } else {\n        const s = next.value;\n        state.iters++;\n        // if pos exists, increment probes/comps appropriately when we actually compare\n        if(s.pos !== null){\n          state.probes = state.probes + 1;\n          state.comps = state.comps + 1;\n        }\n        updateStats();\n        highlight(s);\n        updateFormulaDisplay(s);\n        if(s.info) log(s.info);\n        if(s.found !== undefined){\n          state.found = s.found;\n          updateStats();\n        }\n      }\n    } catch(e){\n      console.error(e);\n      stopAutoPlay();\n      currentGenerator = null;\n    }\n  }\n\n  function finalizeSearchResult(result){\n    if(!result) return;\n    state.probes = result.probes || state.probes;\n    state.comps = result.comps || state.comps;\n    state.iters = result.iters || state.iters;\n    state.found = result.index;\n    updateStats();\n    if(result.index === -1){\n      log('Result: not found');\n    } else {\n      log(`Result: found at index ${result.index}`);\n      highlight({low:0, high:array.length-1, pos: result.index, found: result.index, visited: new Set()});\n    }\n  }\n\n  // Event handlers\n  generateBtn.addEventListener('click', ()=> generateAndRender());\n  shuffleBtn.addEventListener('click', ()=> {\n    // regenerate values with same distribution and size\n    array = makeArray(array.length, distSelect.value);\n    renderArray(array);\n    resetStats();\n    log('Regenerated values');\n  });\n\n  randomTargetBtn.addEventListener('click', ()=>{\n    if(array.length===0) return;\n    const i = randInt(0, array.length-1);\n    targetInput.value = array[i];\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    stopAutoPlay();\n    currentGenerator = null;\n    generateAndRender();\n    log('Reset demo.');\n  });\n\n  stepBtn.addEventListener('click', ()=>{\n    if(!currentGenerator){\n      // start new generator with interpolation\n      const t = parseInt(targetInput.value);\n      currentGenerator = interpolationSearchGen(array, t);\n      resetStats();\n      log(`Starting interpolation search for ${t}`);\n    }\n    // step once\n    stepOnce(currentGenerator);\n  });\n\n  startBtn.addEventListener('click', ()=>{\n    if(!currentGenerator){\n      const t = parseInt(targetInput.value);\n      currentGenerator = interpolationSearchGen(array, t);\n      resetStats();\n      log(`Starting interpolation search for ${t}`);\n    }\n    startAutoPlay(currentGenerator);\n    log('Auto-play started.');\n  });\n\n  runBothBtn.addEventListener('click', ()=>{\n    stopAutoPlay();\n    resetStats();\n    const t = parseInt(targetInput.value);\n    // run interpolation fully (no animation) but log probes\n    const interp = interpolationSearchGen(array, t);\n    let resI;\n    while(true){\n      const n = interp.next();\n      if(n.done){ resI = n.value; break; }\n    }\n    log(`Interpolation: probes=${resI.probes} index=${resI.index}`);\n\n    // run binary\n    const bin = binarySearchGen(array, t);\n    let resB;\n    while(true){\n      const n = bin.next();\n      if(n.done){ resB = n.value; break; }\n    }\n    log(`Binary: probes=${resB.probes} index=${resB.index}`);\n    // show final highlight (show interpolation result)\n    state.probes = resI.probes; state.comps = resI.comps; state.iters = resI.iters; state.found = resI.index;\n    updateStats();\n    if(resI.index !== -1) highlight({low:0, high:array.length-1, pos:resI.index, found:resI.index, visited:new Set()});\n  });\n\n  runBinaryBtn.addEventListener('click', ()=>{\n    stopAutoPlay();\n    resetStats();\n    const t = parseInt(targetInput.value);\n    const gen = binarySearchGen(array, t);\n    // animate binary search\n    currentGenerator = gen;\n    log(`Starting binary search for ${t}`);\n    startAutoPlay(gen);\n  });\n\n  // If user edits target, clear generator\n  targetInput.addEventListener('input', ()=>{ currentGenerator = null; stopAutoPlay(); });\n\n  // size/distribution changes\n  sizeInput.addEventListener('change', ()=> generateAndRender());\n  distSelect.addEventListener('change', ()=> generateAndRender());\n\n  // keyboard: space to step\n  window.addEventListener('keydown', (e)=>{\n    if(e.code === 'Space'){\n      e.preventDefault();\n      stepBtn.click();\n    }\n  });\n\n  // initial\n  generateAndRender();\n\n})();\n</script>\n</body>\n</html>"
  },
