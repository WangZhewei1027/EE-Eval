    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Git Concept Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    line-height: 1.5;\n    margin: 20px;\n    background: #f4f4f4;\n  }\n  h1 {\n    text-align: center;\n    color: #333;\n  }\n  #repo {\n    background: #fff;\n    border: 1px solid #ccc;\n    padding: 15px;\n    max-width: 750px;\n    margin: 20px auto;\n    border-radius: 5px;\n  }\n  #log {\n    background: #222;\n    color: #0f0;\n    font-family: monospace;\n    padding: 10px;\n    height: 120px;\n    overflow-y: auto;\n    border-radius: 5px;\n    margin-bottom: 15px;\n  }\n  #status {\n    background: #eee;\n    padding: 10px;\n    border-radius: 5px;\n    margin-bottom: 15px;\n    min-height: 70px;\n  }\n  button {\n    margin: 3px;\n    padding: 8px 12px;\n    border: none;\n    background: #007bff;\n    color: white;\n    border-radius: 3px;\n    cursor: pointer;\n    font-size: 14px;\n  }\n  button:disabled {\n    background: #aaa;\n    cursor: not-allowed;\n  }\n  .file-list {\n    margin-top: 10px;\n    margin-bottom: 10px;\n  }\n  label {\n    margin-right: 10px;\n  }\n  input[type=text] {\n    padding: 5px;\n    font-size: 14px;\n    width: 200px;\n  }\n  .branch-badge {\n    background: #007bff;\n    color: white;\n    padding: 2px 6px;\n    font-size: 12px;\n    border-radius: 3px;\n    margin-left: 5px;\n  }\n  .commit-hash {\n    font-family: monospace;\n    color: #555;\n  }\n</style>\n</head>\n<body>\n<h1>Git Concept Demonstration</h1>\n<div id=\"repo\">\n  <div>\n    <strong>Current branch:</strong> <span id=\"current-branch\"></span>\n    <button id=\"btn-create-branch\" title=\"Create a new branch\">New Branch</button>\n  </div>\n  <div class=\"file-list\">\n    <strong>Repository Files:</strong>\n    <ul id=\"files-list\"></ul>\n  </div>\n  <div>\n    <input type=\"text\" id=\"file-name\" placeholder=\"Filename (e.g. index.html)\" />\n    <button id=\"btn-add-file\">Add / Modify File</button>\n  </div>\n  <div>\n    <textarea id=\"file-content\" rows=\"4\" cols=\"60\" placeholder=\"File content...\"></textarea>\n  </div>\n  <div style=\"margin-top:10px;\">\n    <button id=\"btn-stage\">Stage File</button>\n    <button id=\"btn-commit\">Commit</button>\n    <input type=\"text\" id=\"commit-msg\" placeholder=\"Commit message\" size=\"30\" />\n    <button id=\"btn-log\">Show Log</button>\n  </div>\n  <div id=\"status\"><em>Status will appear here</em></div>\n  <div id=\"log\"></div>\n</div>\n\n<script>\n// Simulate a simple Git repository model\n\nclass Commit {\n  constructor(hash, message, filesSnapshot, parent=null) {\n    this.hash = hash;\n    this.message = message;\n    this.files = JSON.parse(JSON.stringify(filesSnapshot)); // deep copy files state\n    this.parent = parent; // parent commit hash or null\n  }\n}\n\nclass Repository {\n  constructor() {\n    this.branches = {\n      master: null // master branch points to latest commit (commit hash)\n    };\n    this.currentBranch = 'master';\n    this.commits = {}; // hash -> Commit\n    this.workingFiles = {}; // filename -> content (working directory files)\n    this.stagingArea = {}; // staged files (filename -> content)\n    this.commitCount = 0;\n  }\n  getHeadCommit() {\n    const headHash = this.branches[this.currentBranch];\n    return headHash ? this.commits[headHash] : null;\n  }\n  addOrModifyFile(filename, content) {\n    this.workingFiles[filename] = content;\n  }\n  stageFile(filename) {\n    if (!(filename in this.workingFiles)) {\n      throw new Error(`File \"${filename}\" does not exist in working directory.`);\n    }\n    this.stagingArea[filename] = this.workingFiles[filename];\n  }\n  commit(message) {\n    if (Object.keys(this.stagingArea).length === 0) {\n      throw new Error('Nothing to commit. Staging area is empty.');\n    }\n    const parentCommit = this.getHeadCommit();\n    // Start from parent commit's files snapshot or empty if no parent\n    const parentFiles = parentCommit ? parentCommit.files : {};\n    // Create new files snapshot by applying staged changes\n    const newFilesSnapshot = {...parentFiles};\n    for (let file in this.stagingArea) {\n      newFilesSnapshot[file] = this.stagingArea[file];\n    }\n    // Generate a new commit hash (simple increment + timestamp)\n    const newHash = `C${++this.commitCount}-${Date.now().toString(36)}`;\n    const commit = new Commit(newHash, message, newFilesSnapshot, parentCommit ? parentCommit.hash : null);\n    this.commits[newHash] = commit;\n    this.branches[this.currentBranch] = newHash;\n    this.stagingArea = {};\n  }\n  getStatus() {\n    let statusText = '';\n    // List files changed compared to last commit\n    const head = this.getHeadCommit();\n    const lastCommitFiles = head ? head.files : {};\n    const changes = [];\n    const added = [];\n    const modified = [];\n    const deleted = [];\n\n    // In working directory:\n    // - if file not in lastCommitFiles => added\n    // - if file in lastCommitFiles but content differs => modified\n    // - if file removed from workingFiles but in lastCommitFiles => deleted\n\n    // Check added and modified\n    for (let file in this.workingFiles) {\n      if (!(file in lastCommitFiles)) {\n        added.push(file);\n      } else if (this.workingFiles[file] !== lastCommitFiles[file]) {\n        modified.push(file);\n      }\n    }\n    // Check deleted\n    for (let file in lastCommitFiles) {\n      if (!(file in this.workingFiles)) {\n        deleted.push(file);\n      }\n    }\n\n    if (added.length + modified.length + deleted.length === 0) {\n      statusText = 'Working directory clean. No changes.';\n    } else {\n      if (added.length > 0) statusText += `Added files: ${added.join(', ')}\\n`;\n      if (modified.length > 0) statusText += `Modified files: ${modified.join(', ')}\\n`;\n      if (deleted.length > 0) statusText += `Deleted files: ${deleted.join(', ')}\\n`;\n    }\n\n    // Show staged files\n    const stagedFiles = Object.keys(this.stagingArea);\n    if (stagedFiles.length > 0) {\n      statusText += `\\nStaged files: ${stagedFiles.join(', ')}`;\n    } else {\n      statusText += `\\nNo files staged.`;\n    }\n    return statusText.trim();\n  }\n  createBranch(name) {\n    if (this.branches[name]) {\n      throw new Error(`Branch \"${name}\" already exists.`);\n    }\n    // New branch points to current commit\n    this.branches[name] = this.branches[this.currentBranch];\n  }\n  checkoutBranch(name) {\n    if (!this.branches[name]) {\n      throw new Error(`Branch \"${name}\" does not exist.`);\n    }\n    if (this.currentBranch === name) {\n      // Already on branch\n      return;\n    }\n    this.currentBranch = name;\n    // Update workingFiles to last commit of that branch or empty\n    const commit = this.getHeadCommit();\n    this.workingFiles = commit ? JSON.parse(JSON.stringify(commit.files)) : {};\n    this.stagingArea = {};\n  }\n  getLog() {\n    let logs = [];\n    let commit = this.getHeadCommit();\n    while (commit) {\n      logs.push(`commit ${commit.hash}\\n    ${commit.message}`);\n      commit = commit.parent ? this.commits[commit.parent] : null;\n    }\n    return logs.length > 0 ? logs.join('\\n\\n') : 'No commits yet.';\n  }\n  listFiles() {\n    // Return list of files currently in working directory\n    return Object.keys(this.workingFiles).sort();\n  }\n}\n\nconst repo = new Repository();\n\n// UI Elements\nconst currentBranchSpan = document.getElementById('current-branch');\nconst filesListUl = document.getElementById('files-list');\nconst statusDiv = document.getElementById('status');\nconst logDiv = document.getElementById('log');\n\nconst fileNameInput = document.getElementById('file-name');\nconst fileContentTextarea = document.getElementById('file-content');\nconst commitMsgInput = document.getElementById('commit-msg');\n\nconst btnAddFile = document.getElementById('btn-add-file');\nconst btnStage = document.getElementById('btn-stage');\nconst btnCommit = document.getElementById('btn-commit');\nconst btnLog = document.getElementById('btn-log');\nconst btnCreateBranch = document.getElementById('btn-create-branch');\n\nconst renderStatus = () => {\n  statusDiv.textContent = repo.getStatus();\n};\n\nconst renderCurrentBranch = () => {\n  currentBranchSpan.textContent = repo.currentBranch;\n};\n\nconst renderFiles = () => {\n  const files = repo.listFiles();\n  filesListUl.innerHTML = '';\n  if (files.length === 0) {\n    filesListUl.innerHTML = '<em>No files in working directory.</em>';\n    return;\n  }\n  files.forEach(f => {\n    const li = document.createElement('li');\n    li.textContent = f;\n    filesListUl.appendChild(li);\n  });\n};\n\nconst showAlert = (msg) => {\n  alert(msg);\n};\n\nbtnAddFile.addEventListener('click', () => {\n  const name = fileNameInput.value.trim();\n  const content = fileContentTextarea.value;\n  if (!name) {\n    showAlert('Please enter a filename.');\n    return;\n  }\n  repo.addOrModifyFile(name, content);\n  renderFiles();\n  renderStatus();\n  showAlert(`File \"${name}\" added/modified in working directory.`);\n});\n\nbtnStage.addEventListener('click', () => {\n  const name = fileNameInput.value.trim();\n  if (!name) {\n    showAlert('Please enter a filename to stage.');\n    return;\n  }\n  try {\n    repo.stageFile(name);\n  } catch(e) {\n    showAlert(e.message);\n    return;\n  }\n  renderStatus();\n  showAlert(`File \"${name}\" staged.`);\n});\n\nbtnCommit.addEventListener('click', () => {\n  const msg = commitMsgInput.value.trim();\n  if (!msg) {\n    showAlert('Please enter a commit message.');\n    return;\n  }\n  try {\n    repo.commit(msg);\n  } catch(e) {\n    showAlert(e.message);\n    return;\n  }\n  commitMsgInput.value = '';\n  renderStatus();\n  renderFiles();\n  showAlert(`Commit successful on branch \"${repo.currentBranch}\".`);\n});\n\nbtnLog.addEventListener('click', () => {\n  logDiv.textContent = repo.getLog();\n});\n\nbtnCreateBranch.addEventListener('click', () => {\n  const branch = prompt('Enter new branch name:');\n  if (branch) {\n    try {\n      repo.createBranch(branch.trim());\n      showAlert(`Branch \"${branch.trim()}\" created.`);\n      // After branch creation, optionally checkout it\n      const checkoutNow = confirm(`Checkout branch \"${branch.trim()}\" now?`);\n      if (checkoutNow) {\n        repo.checkoutBranch(branch.trim());\n        renderCurrentBranch();\n        renderFiles();\n        renderStatus();\n      }\n    } catch(e) {\n      showAlert(e.message);\n    }\n  }\n});\n\ncurrentBranchSpan.addEventListener('click', () => {\n  const branches = Object.keys(repo.branches);\n  let promptMsg = 'Available branches:\\n';\n  branches.forEach(b => {\n    promptMsg += b + (b===repo.currentBranch ? ' (current)' : '') + '\\n';\n  });\n  promptMsg += '\\nEnter branch name to checkout:';\n  const choice = prompt(promptMsg);\n  if (choice && choice.trim() !== '' && repo.branches[choice.trim()]) {\n    repo.checkoutBranch(choice.trim());\n    renderCurrentBranch();\n    renderFiles();\n    renderStatus();\n    showAlert(`Checked out branch \"${choice.trim()}\".`);\n  } else if(choice !== null) {\n    showAlert('Branch does not exist.');\n  }\n});\n\n// Initial render\nrenderCurrentBranch();\nrenderFiles();\nrenderStatus();\n</script>\n</body>\n</html>"
  },
