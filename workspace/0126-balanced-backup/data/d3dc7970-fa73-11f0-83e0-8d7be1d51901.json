  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<title>Authentication Demo (Single File)</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<style>\n  body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 0; padding: 16px; background:#f7f9fc; color:#0b2545; }\n  header { text-align:center; margin-bottom:12px; }\n  h1 { margin: 6px 0 2px; font-size:20px; }\n  p.lead { margin:0; color:#4b5563; font-size:13px; }\n  .grid { display:flex; gap:12px; flex-wrap:wrap; }\n  .card { background:white; border-radius:8px; padding:12px; box-shadow:0 1px 4px rgba(11,37,69,0.06); flex:1 1 320px; min-width:280px; }\n  label { display:block; font-size:13px; margin-top:8px; }\n  input[type=\"text\"], input[type=\"password\"], input[type=\"number\"] { width:100%; padding:8px; margin-top:6px; box-sizing:border-box; border:1px solid #e6edf5; border-radius:6px; background:#fbfdff; }\n  button { margin-top:10px; padding:8px 12px; border-radius:6px; border:0; background:#0b5cff; color:white; cursor:pointer; }\n  button.secondary { background:#6b7280; }\n  .small { font-size:12px; color:#6b7280; }\n  pre { background:#0f1724; color:#e6eef8; padding:10px; border-radius:6px; overflow:auto; max-height:240px; }\n  .muted { color:#6b7280; font-size:12px; }\n  .ok { color: #0b8a3e; font-weight:600; }\n  .err { color: #b91c1c; font-weight:600; }\n  .row { display:flex; gap:8px; align-items:center; margin-top:8px; }\n  .badge { display:inline-block; padding:4px 8px; background:#eef2ff; color:#3730a3; border-radius:999px; font-size:12px; }\n  .section-title { margin:6px 0 10px; font-size:14px; color:#0b2545; }\n  .tiny { font-size:11px; color:#6b7280; }\n</style>\n</head>\n<body>\n<header>\n  <h1>Authentication — Interactive Demo</h1>\n  <p class=\"lead\">Register, Login, view hashed & salted passwords, tokens, and a simulated 2‑factor flow — all client-side for learning</p>\n</header>\n\n<div class=\"grid\">\n  <div class=\"card\" id=\"registerCard\">\n    <div class=\"section-title\">Register (simulated server-side)</div>\n    <label>Username\n      <input id=\"regUser\" type=\"text\" placeholder=\"alice\" />\n    </label>\n    <label>Password\n      <input id=\"regPass\" type=\"password\" placeholder=\"Enter a password\" />\n    </label>\n    <label style=\"display:flex; gap:8px; align-items:center; margin-top:10px;\">\n      <input id=\"reg2fa\" type=\"checkbox\" />\n      <span class=\"tiny\">Enable simulated 2‑Factor Authentication (OTP)</span>\n    </label>\n    <div class=\"row\">\n      <button id=\"btnRegister\">Register</button>\n      <button id=\"btnClearUsers\" class=\"secondary\">Clear Users</button>\n    </div>\n    <div style=\"margin-top:10px;\">\n      <div class=\"muted\">Notes:</div>\n      <ul class=\"tiny\">\n        <li>Passwords are <strong>not</strong> stored in plaintext here — we derive a salted PBKDF2 hash (simulating server behavior).</li>\n        <li>Data is stored in localStorage for this demo only. In real deployments, user credentials remain on the server.</li>\n      </ul>\n    </div>\n  </div>\n\n  <div class=\"card\" id=\"loginCard\">\n    <div class=\"section-title\">Login</div>\n    <label>Username\n      <input id=\"loginUser\" type=\"text\" placeholder=\"alice\" />\n    </label>\n    <label>Password\n      <input id=\"loginPass\" type=\"password\" placeholder=\"Enter your password\" />\n    </label>\n    <label style=\"display:flex; gap:8px; align-items:center; margin-top:8px;\">\n      <input id=\"remember\" type=\"checkbox\" />\n      <span class=\"tiny\">Remember (store token in localStorage)</span>\n    </label>\n    <div class=\"row\">\n      <button id=\"btnLogin\">Login</button>\n      <button id=\"btnLogout\" class=\"secondary\">Logout</button>\n    </div>\n\n    <div id=\"otpSection\" style=\"display:none; margin-top:10px;\">\n      <div class=\"muted tiny\">Two‑factor is enabled for this account. Enter the one‑time code below (demo sends it to the UI).</div>\n      <label>One‑Time Code\n        <input id=\"otpInput\" type=\"text\" placeholder=\"123456\" />\n      </label>\n      <div class=\"row\">\n        <button id=\"btnVerifyOtp\">Verify OTP</button>\n        <button id=\"btnResendOtp\" class=\"secondary\">Resend (show) OTP</button>\n      </div>\n      <div id=\"otpSent\" class=\"tiny muted\" style=\"margin-top:8px;\"></div>\n    </div>\n\n    <div style=\"margin-top:12px;\">\n      <div class=\"muted tiny\">Login result:</div>\n      <div id=\"loginResult\" class=\"tiny\"></div>\n    </div>\n  </div>\n\n  <div class=\"card\" id=\"tokenCard\">\n    <div class=\"section-title\">Token & Dashboard</div>\n    <div class=\"row\" style=\"align-items:flex-start;\">\n      <div style=\"flex:1;\">\n        <div class=\"muted tiny\">Current token (simulated JWT-like)</div>\n        <pre id=\"tokenView\">No token</pre>\n        <div style=\"margin-top:8px;\">\n          <button id=\"btnInspect\" class=\"secondary\">Inspect / Verify Token</button>\n          <button id=\"btnClearToken\" class=\"secondary\">Clear Token</button>\n        </div>\n      </div>\n    </div>\n\n    <div style=\"margin-top:10px;\">\n      <div class=\"muted tiny\">Decoded payload</div>\n      <pre id=\"tokenPayload\">—</pre>\n    </div>\n  </div>\n</div>\n\n<div class=\"grid\" style=\"margin-top:12px;\">\n  <div class=\"card\">\n    <div class=\"section-title\">Educational comparison: Plaintext vs Salted Hash</div>\n    <div class=\"muted tiny\">Try the same password below to see the effect of using salt + PBKDF2.</div>\n    <label>Password to test\n      <input id=\"demoPass\" type=\"text\" placeholder=\"password123\" />\n    </label>\n    <div class=\"row\">\n      <button id=\"btnHashDemo\">Show Hashes</button>\n    </div>\n    <div style=\"margin-top:10px;\">\n      <div class=\"tiny\"><strong>Plaintext:</strong></div>\n      <pre id=\"plainView\">—</pre>\n      <div class=\"tiny\"><strong>PBKDF2 + salt (hex):</strong></div>\n      <pre id=\"saltedView\">—</pre>\n    </div>\n    <div style=\"margin-top:8px;\" class=\"muted tiny\">Even with same password, different salt → different hashes. PBKDF2 is intentionally slow to resist brute‑force attempts.</div>\n  </div>\n\n  <div class=\"card\">\n    <div class=\"section-title\">Stored Users (demo only)</div>\n    <div class=\"muted tiny\">This shows what the \"server\" has stored for each user (localStorage). Do not expose this on real servers.</div>\n    <pre id=\"usersView\">No users yet</pre>\n  </div>\n</div>\n\n<script>\n/*\n  Authentication Demo (client-side)\n  - Uses Web Crypto for PBKDF2 (password hashing) and HMAC-SHA256 (token signing)\n  - Data stored in localStorage \"auth_demo_users\" and token in \"auth_demo_token\" if remembered\n  - This is an educational simulation. Real systems must do this server-side and protect secrets.\n*/\n\nconst ITERATIONS = 100000; // PBKDF2 iterations (adjust for demo responsiveness)\nconst KEY_LEN = 32; // bytes\n// Simulated server secret (in a real app this lives only on the server)\nconst SERVER_SECRET = 'demo-server-secret-please-change'; \n\n// Helpers: encoders and base64url\nconst enc = new TextEncoder();\nconst dec = new TextDecoder();\n\nfunction toHex(bytes) {\n  return Array.from(new Uint8Array(bytes)).map(b => b.toString(16).padStart(2,'0')).join('');\n}\nfunction arrayBufferToBase64Url(buffer) {\n  let binary = '';\n  const bytes = new Uint8Array(buffer);\n  for (let i = 0; i < bytes.byteLength; i++) binary += String.fromCharCode(bytes[i]);\n  let b64 = btoa(binary);\n  return b64.replace(/\\+/g,'-').replace(/\\//g,'_').replace(/=+$/,'');\n}\nfunction base64UrlToArrayBuffer(b64u) {\n  // convert base64url to base64\n  let b64 = b64u.replace(/-/g,'+').replace(/_/g,'/');\n  while (b64.length % 4) b64 += '=';\n  const binary = atob(b64);\n  const len = binary.length;\n  const bytes = new Uint8Array(len);\n  for (let i = 0; i < len; i++) bytes[i] = binary.charCodeAt(i);\n  return bytes.buffer;\n}\nfunction base64UrlToString(b64u) {\n  const buf = base64UrlToArrayBuffer(b64u);\n  return dec.decode(buf);\n}\n\n// Storage helpers\nfunction loadUsers() {\n  try {\n    const raw = localStorage.getItem('auth_demo_users');\n    return raw ? JSON.parse(raw) : {};\n  } catch(e) { return {}; }\n}\nfunction saveUsers(users) {\n  localStorage.setItem('auth_demo_users', JSON.stringify(users));\n  renderUsers();\n}\n\nfunction saveToken(token, remember=false) {\n  if (remember) localStorage.setItem('auth_demo_token', token);\n  sessionToken = token;\n  renderToken();\n}\nfunction clearTokenStorage() {\n  localStorage.removeItem('auth_demo_token');\n  sessionToken = null;\n  renderToken();\n}\n\n// Crypto operations\nasync function generateSalt(length=16) {\n  const s = new Uint8Array(length);\n  crypto.getRandomValues(s);\n  return s.buffer;\n}\n\nasync function deriveKeyFromPassword(password, salt, iterations=ITERATIONS, keyLen=KEY_LEN) {\n  // PBKDF2 derive raw bytes\n  const keyMaterial = await crypto.subtle.importKey('raw', enc.encode(password), {name:'PBKDF2'}, false, ['deriveBits']);\n  const derivedBits = await crypto.subtle.deriveBits({name:'PBKDF2', salt, iterations, hash:'SHA-256'}, keyMaterial, keyLen * 8);\n  return new Uint8Array(derivedBits);\n}\n\nasync function importServerHmacKey(secret) {\n  return crypto.subtle.importKey('raw', enc.encode(secret), {name:'HMAC', hash:'SHA-256'}, false, ['sign','verify']);\n}\n\nasync function signTokenRaw(dataBytes) {\n  const key = await importServerHmacKey(SERVER_SECRET);\n  const sig = await crypto.subtle.sign('HMAC', key, dataBytes);\n  return new Uint8Array(sig);\n}\n\nasync function verifyTokenRaw(dataBytes, signature) {\n  const key = await importServerHmacKey(SERVER_SECRET);\n  return crypto.subtle.verify('HMAC', key, signature, dataBytes);\n}\n\n// Simple JWT-like generation (header.payload.signature) using HMAC-SHA256\nasync function createToken(payloadObj) {\n  const header = { alg: 'HS256', typ: 'JWT' };\n  const headerB64 = arrayBufferToBase64Url(enc.encode(JSON.stringify(header)));\n  const payloadB64 = arrayBufferToBase64Url(enc.encode(JSON.stringify(payloadObj)));\n  const signingInput = enc.encode(`${headerB64}.${payloadB64}`);\n  const sig = await signTokenRaw(signingInput);\n  const sigB64 = arrayBufferToBase64Url(sig.buffer);\n  return `${headerB64}.${payloadB64}.${sigB64}`;\n}\n\nasync function verifyToken(token) {\n  try {\n    const parts = token.split('.');\n    if (parts.length !== 3) return { ok:false, reason:'Malformed token' };\n    const [h, p, s] = parts;\n    const input = enc.encode(`${h}.${p}`);\n    const sigBuf = base64UrlToArrayBuffer(s);\n    const ok = await verifyTokenRaw(input, sigBuf);\n    const payload = JSON.parse(base64UrlToString(p));\n    return { ok, payload };\n  } catch(e) { return { ok:false, reason: String(e) }; }\n}\n\n// UI wiring and flows\nlet sessionToken = localStorage.getItem('auth_demo_token') || null;\n\nconst el = {\n  regUser: document.getElementById('regUser'),\n  regPass: document.getElementById('regPass'),\n  reg2fa: document.getElementById('reg2fa'),\n  btnRegister: document.getElementById('btnRegister'),\n  btnClearUsers: document.getElementById('btnClearUsers'),\n\n  loginUser: document.getElementById('loginUser'),\n  loginPass: document.getElementById('loginPass'),\n  remember: document.getElementById('remember'),\n  btnLogin: document.getElementById('btnLogin'),\n  btnLogout: document.getElementById('btnLogout'),\n  loginResult: document.getElementById('loginResult'),\n\n  otpSection: document.getElementById('otpSection'),\n  otpInput: document.getElementById('otpInput'),\n  btnVerifyOtp: document.getElementById('btnVerifyOtp'),\n  btnResendOtp: document.getElementById('btnResendOtp'),\n  otpSent: document.getElementById('otpSent'),\n\n  tokenView: document.getElementById('tokenView'),\n  tokenPayload: document.getElementById('tokenPayload'),\n  btnInspect: document.getElementById('btnInspect'),\n  btnClearToken: document.getElementById('btnClearToken'),\n\n  demoPass: document.getElementById('demoPass'),\n  btnHashDemo: document.getElementById('btnHashDemo'),\n  plainView: document.getElementById('plainView'),\n  saltedView: document.getElementById('saltedView'),\n\n  usersView: document.getElementById('usersView')\n};\n\nfunction renderUsers() {\n  const users = loadUsers();\n  el.usersView.textContent = JSON.stringify(users, null, 2) || 'No users';\n}\nfunction renderToken() {\n  el.tokenView.textContent = sessionToken || 'No token';\n  if (!sessionToken) el.tokenPayload.textContent = '—';\n}\n\nrenderUsers();\nrenderToken();\n\n// Registration flow\nel.btnRegister.addEventListener('click', async () => {\n  const username = el.regUser.value.trim();\n  const password = el.regPass.value;\n  const enable2fa = el.reg2fa.checked;\n  if (!username || !password) { alert('Provide username and password'); return; }\n\n  el.btnRegister.disabled = true;\n  el.btnRegister.textContent = 'Registering...';\n\n  try {\n    const users = loadUsers();\n    if (users[username]) { alert('User exists (demo). Choose a different username.'); return; }\n\n    const salt = await generateSalt(16);\n    const derived = await deriveKeyFromPassword(password, salt, ITERATIONS, KEY_LEN);\n\n    // For 2FA simulation create an otp seed (random) and mark as enabled\n    let otpSecret = null;\n    if (enable2fa) {\n      otpSecret = arrayBufferToBase64Url(await generateSalt(10)); // small random secret for OTP generation\n    }\n\n    users[username] = {\n      salt: arrayBufferToBase64Url(salt),\n      hash: arrayBufferToBase64Url(derived.buffer),\n      iterations: ITERATIONS,\n      keyLen: KEY_LEN,\n      twoFactorEnabled: !!enable2fa,\n      otpSecret, // only for demo\n    };\n    saveUsers(users);\n    alert('Registered (demo). You can now login.');\n    el.regUser.value = '';\n    el.regPass.value = '';\n    el.reg2fa.checked = false;\n  } catch(e) {\n    console.error(e);\n    alert('Registration failed: ' + e);\n  } finally {\n    el.btnRegister.disabled = false;\n    el.btnRegister.textContent = 'Register';\n  }\n});\n\nel.btnClearUsers.addEventListener('click', () => {\n  if (!confirm('Clear all demo users in localStorage?')) return;\n  localStorage.removeItem('auth_demo_users');\n  renderUsers();\n});\n\n// OTP generation (demo): generate numeric code and keep in-memory store\nconst otpStore = {}; // username -> { code, expiresAt }\nfunction generateOtpForUser(username) {\n  const code = Math.floor(100000 + Math.random() * 900000).toString();\n  const expiresAt = Date.now() + (2 * 60 * 1000); // 2 minutes\n  otpStore[username] = { code, expiresAt };\n  return code;\n}\nfunction getOtpForUser(username) {\n  const obj = otpStore[username];\n  if (!obj) return null;\n  if (Date.now() > obj.expiresAt) { delete otpStore[username]; return null; }\n  return obj.code;\n}\n\n// Login flow\nlet pendingLogin = null; // store pending login info waiting for 2FA\n\nel.btnLogin.addEventListener('click', async () => {\n  const username = el.loginUser.value.trim();\n  const password = el.loginPass.value;\n  if (!username || !password) { alert('Enter username and password'); return; }\n\n  el.btnLogin.disabled = true;\n  el.btnLogin.textContent = 'Checking...';\n  el.loginResult.textContent = '';\n\n  try {\n    const users = loadUsers();\n    const user = users[username];\n    if (!user) {\n      el.loginResult.innerHTML = '<span class=\"err\">No such user (demo).</span>';\n      return;\n    }\n    const saltBuf = base64UrlToArrayBuffer(user.salt);\n    const derived = await deriveKeyFromPassword(password, saltBuf, user.iterations || ITERATIONS, user.keyLen || KEY_LEN);\n    const derivedB64 = arrayBufferToBase64Url(derived.buffer);\n    if (derivedB64 !== user.hash) {\n      el.loginResult.innerHTML = '<span class=\"err\">Invalid credentials.</span>';\n      return;\n    }\n\n    // Password correct. Check 2FA\n    if (user.twoFactorEnabled) {\n      // generate OTP and show UI (in real life would be sent via SMS/email)\n      const code = generateOtpForUser(username);\n      pendingLogin = { username, remember: el.remember.checked };\n      el.otpSent.textContent = `Demo OTP code (simulated send): ${code} — expires in 2 min`;\n      el.otpSection.style.display = 'block';\n      el.loginResult.innerHTML = '<span class=\"muted\">Enter OTP to complete login.</span>';\n      return;\n    } else {\n      // Create token and finish login\n      const token = await createToken({sub: username, iat: Math.floor(Date.now()/1000), exp: Math.floor(Date.now()/1000) + 3600});\n      saveToken(token, el.remember.checked);\n      el.loginResult.innerHTML = '<span class=\"ok\">Login successful.</span>';\n      el.otpSection.style.display = 'none';\n      pendingLogin = null;\n      renderToken();\n    }\n  } catch(e) {\n    console.error(e);\n    el.loginResult.innerHTML = '<span class=\"err\">Login error: '+ e +'</span>';\n  } finally {\n    el.btnLogin.disabled = false;\n    el.btnLogin.textContent = 'Login';\n  }\n});\n\nel.btnVerifyOtp.addEventListener('click', async () => {\n  const code = el.otpInput.value.trim();\n  if (!pendingLogin) { alert('No pending login.'); return; }\n  const username = pendingLogin.username;\n  const expected = getOtpForUser(username);\n  if (!expected) {\n    alert('OTP expired. Request a new one.');\n    return;\n  }\n  if (code !== expected) {\n    el.loginResult.innerHTML = '<span class=\"err\">Wrong OTP.</span>';\n    return;\n  }\n  // OTP correct -> issue token\n  const token = await createToken({sub: username, iat: Math.floor(Date.now()/1000), exp: Math.floor(Date.now()/1000) + 3600});\n  saveToken(token, pendingLogin.remember);\n  el.loginResult.innerHTML = '<span class=\"ok\">2FA success. Logged in.</span>';\n  el.otpSection.style.display = 'none';\n  el.otpInput.value = '';\n  delete otpStore[username];\n  pendingLogin = null;\n  renderToken();\n});\n\nel.btnResendOtp.addEventListener('click', () => {\n  if (!pendingLogin) { alert('No pending 2FA request.'); return; }\n  const code = generateOtpForUser(pendingLogin.username);\n  el.otpSent.textContent = `Demo OTP code (simulated send): ${code} — expires in 2 min`;\n});\n\n// Logout\nel.btnLogout.addEventListener('click', () => {\n  clearTokenStorage();\n  el.loginResult.innerHTML = '<span class=\"muted\">Logged out.</span>';\n});\n\n// Token inspection and verification\nel.btnInspect.addEventListener('click', async () => {\n  const token = sessionToken || localStorage.getItem('auth_demo_token');\n  if (!token) { alert('No token to inspect'); return; }\n  el.tokenView.textContent = token;\n  const parts = token.split('.');\n  if (parts.length !== 3) { el.tokenPayload.textContent = 'Malformed token'; return; }\n  try {\n    const header = JSON.parse(base64UrlToString(parts[0]));\n    const payload = JSON.parse(base64UrlToString(parts[1]));\n    const verification = await verifyToken(token);\n    el.tokenPayload.textContent = 'Header:\\n' + JSON.stringify(header, null, 2) + '\\n\\nPayload:\\n' + JSON.stringify(payload, null, 2) + '\\n\\nVerified: ' + verification.ok;\n    if (!verification.ok && verification.reason) el.tokenPayload.textContent += '\\n\\nReason: ' + verification.reason;\n  } catch(e) {\n    el.tokenPayload.textContent = 'Error decoding token: ' + e;\n  }\n});\n\nel.btnClearToken.addEventListener('click', () => {\n  clearTokenStorage();\n  alert('Token cleared.');\n});\n\n// Demo: Hash comparison\nel.btnHashDemo.addEventListener('click', async () => {\n  const pwd = el.demoPass.value;\n  if (!pwd) { alert('Enter a password to test'); return; }\n  el.plainView.textContent = pwd;\n  // produce two salted hashes to show difference\n  const salt1 = await generateSalt(12);\n  const salt2 = await generateSalt(12);\n  const d1 = await deriveKeyFromPassword(pwd, salt1, 50000, KEY_LEN); // fewer iterations for speed\n  const d2 = await deriveKeyFromPassword(pwd, salt2, 50000, KEY_LEN);\n  el.saltedView.textContent = `salt1=${toHex(salt1)}\\nhash1=${toHex(d1)}\\n\\nsalt2=${toHex(salt2)}\\nhash2=${toHex(d2)}\\n\\nNote: Different salt -> different hash`;\n});\n\n// On load, render stored users and token\nrenderUsers();\nrenderToken();\n\n// Small safety: show if token persisted across reload\nif (localStorage.getItem('auth_demo_token')) {\n  el.loginResult.innerHTML = '<span class=\"muted\">A token was restored from localStorage (Remember me).</span>';\n}\n</script>\n</body>\n</html>"
  },
