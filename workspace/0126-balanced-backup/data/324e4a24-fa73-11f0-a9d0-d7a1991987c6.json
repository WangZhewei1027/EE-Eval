    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Two Pointers Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin-top: 50px;\n        }\n        input {\n            padding: 10px;\n            font-size: 16px;\n        }\n        button {\n            padding: 10px 15px;\n            font-size: 16px;\n            margin-left: 10px;\n        }\n        #result {\n            margin-top: 20px;\n            font-size: 18px;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Two Pointers Demonstration</h1>\n    <p>Enter a sorted array of numbers (comma-separated):</p>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g., -4,-1,0,3,5,9\">\n    <button id=\"runButton\">Run Example</button>\n\n    <div id=\"result\"></div>\n\n    <script>\n        document.getElementById('runButton').addEventListener('click', function() {\n            const input = document.getElementById('arrayInput').value;\n            const nums = input.split(',').map(Number);\n            const result = removeDuplicates(nums);\n            document.getElementById('result').innerText = `Unique elements: [${result.join(', ')}]`;\n        });\n\n        function removeDuplicates(arr) {\n            if (arr.length === 0) return [];\n\n            let left = 0;  // First pointer\n            for (let right = 1; right < arr.length; right++) {  // Second pointer\n                if (arr[left] !== arr[right]) {\n                    left++;\n                    arr[left] = arr[right];  // Move unique element to the left pointer\n                }\n            }\n            return arr.slice(0, left + 1);\n        }\n    </script>\n\n</body>\n</html>"
