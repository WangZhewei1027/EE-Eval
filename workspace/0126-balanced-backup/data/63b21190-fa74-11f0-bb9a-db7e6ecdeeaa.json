    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Greedy Algorithms Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f3f5;\n    color: #222;\n  }\n  h1 {\n    text-align: center;\n    color: #007acc;\n  }\n  .container {\n    max-width: 600px;\n    margin: 1rem auto;\n    background: white;\n    padding: 1.5rem;\n    border-radius: 8px;\n    box-shadow: 0 2px 8px rgb(0 0 0 / 0.1);\n  }\n  label {\n    display: block;\n    margin-bottom: 0.3rem;\n    font-weight: bold;\n  }\n  textarea {\n    width: 100%;\n    height: 4rem;\n    font-family: monospace;\n    font-size: 1rem;\n    margin-bottom: 1rem;\n    padding: 0.5rem;\n  }\n  input[type=\"text\"], input[type=number] {\n    padding: 0.4rem 0.6rem;\n    font-size: 1rem;\n    width: 100%;\n    margin-bottom: 1rem;\n    box-sizing: border-box;\n  }\n  button {\n    background: #007acc;\n    border: none;\n    color: white;\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    border-radius: 4px;\n    cursor: pointer;\n  }\n  button:hover {\n    background: #005f99;\n  }\n  pre {\n    background: #eaeff4;\n    padding: 1rem;\n    border-radius: 6px;\n    overflow-x: auto;\n  }\n  .example {\n    margin-top: 2rem;\n  }\n  .explanation {\n    background: #d9f0ff;\n    border-left: 5px solid #007acc;\n    padding: 1rem;\n    margin: 1rem 0;\n    border-radius: 4px;\n  }\n</style>\n</head>\n<body>\n<h1>Greedy Algorithm Demonstration</h1>\n<div class=\"container\">\n  <p>\n    Greedy algorithms build up a solution piece by piece, choosing the next piece that offers the most immediate benefit. \n    This does not always guarantee an optimal solution but works well for many problems.\n  </p>\n\n  <h2>Example: Coin Change Problem</h2>\n  <p>\n    Given coins of certain denominations and a target amount, \n    the goal is to make the amount using the fewest number of coins possible.\n  </p>\n\n  <label for=\"coinsInput\">Enter coin denominations (comma separated, in any order):</label>\n  <input type=\"text\" id=\"coinsInput\" value=\"25,10,5,1\" />\n\n  <label for=\"amountInput\">Enter amount to make:</label>\n  <input type=\"number\" id=\"amountInput\" value=\"87\" min=\"1\" max=\"10000\" />\n\n  <button id=\"runGreedyBtn\">Run Greedy Algorithm</button>\n\n  <div class=\"example\">\n    <h3>Result:</h3>\n    <pre id=\"result\"></pre>\n  </div>\n\n  <div class=\"explanation\" id=\"explanation\">\n    <!-- Explanation text will appear here -->\n  </div>\n</div>\n\n<script>\n  /*\n   * Implements a greedy algorithm for the classic coin change problem.\n   * It assumes coin denominations are such that the greedy approach yields an optimal solution.\n   */\n  function greedyCoinChange(coins, amount) {\n    // Sort coins descending\n    coins.sort((a, b) => b - a);\n\n    let remaining = amount;\n    const usedCoins = {};\n\n    for (const coin of coins) {\n      if (coin <= 0) continue;\n      const count = Math.floor(remaining / coin);\n      if (count > 0) {\n        usedCoins[coin] = count;\n        remaining -= count * coin;\n      }\n      if (remaining === 0) break;\n    }\n    return remaining === 0 ? usedCoins : null;\n  }\n\n  function formatResult(usedCoins) {\n    if (usedCoins === null) {\n      return \"No solution possible using this greedy approach.\";\n    }\n    let totalCoins = 0;\n    let lines = [];\n    for (const coin of Object.keys(usedCoins).sort((a,b) => b - a)) {\n      const count = usedCoins[coin];\n      totalCoins += count;\n      lines.push(`Coin ${coin}¢ : ${count} coin${count>1 ? 's' : ''}`);\n    }\n    lines.push(`\\nTotal coins used: ${totalCoins}`);\n    return lines.join('\\n');\n  }\n\n  function explanationText(coins, amount, usedCoins) {\n    if (usedCoins === null) {\n      return `The greedy algorithm tried to use the largest coins first to make ${amount}¢, \nbut was unable to make exact change with the given denominations. \nThis shows that greedy algorithms do not always guarantee a solution or optimality in all coin systems.`;\n    }\n    return `Steps taken for amount ${amount}¢:\n- Using coins sorted in descending order: ${coins.join(', ')}.\n- For each coin, take as many as possible without exceeding the remaining amount.\n- Subtract the accumulated value from the remaining amount.\n- Continue until the amount is zero.\n  \nThis greedy approach works optimally for canonical coin systems (like US coins: 25,10,5,1¢).\nIf the coin denominations are different, greedy might fail or be non-optimal.`;\n  }\n\n  document.getElementById('runGreedyBtn').addEventListener('click', () => {\n    const coinsRaw = document.getElementById('coinsInput').value;\n    const amountRaw = document.getElementById('amountInput').value;\n\n    // Parse coins\n    let coins = coinsRaw.split(',').map(c => parseInt(c.trim(), 10)).filter(n => !isNaN(n) && n > 0);\n    let amount = parseInt(amountRaw, 10);\n    const resultEl = document.getElementById('result');\n    const explanationEl = document.getElementById('explanation');\n\n    if (coins.length === 0 || isNaN(amount) || amount <= 0) {\n      resultEl.textContent = \"Please enter valid positive coin denominations and amount.\";\n      explanationEl.textContent = \"\";\n      return;\n    }\n\n    const usedCoins = greedyCoinChange(coins, amount);\n    resultEl.textContent = formatResult(usedCoins);\n    explanationEl.textContent = explanationText(coins, amount, usedCoins);\n  });\n</script>\n</body>\n</html>"
