{
  "id": "d3d5e9c1-fa73-11f0-83e0-8d7be1d51901",
  "timestamp": "2026-01-26T05:03:13.858Z",
  "model": "gpt-5-mini",
  "status": "success",
  "question": "Graph (Directed)",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Directed Graph - Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    body { margin:0; font-family: Arial, sans-serif; display:flex; height:100vh; }\n    #sidebar { width:320px; background:#f4f6f8; padding:12px; box-sizing:border-box; border-right:1px solid #ddd; overflow:auto; }\n    #canvasWrap { flex:1; position:relative; }\n    svg { width:100%; height:100%; background: linear-gradient(#fff,#fbfdff); cursor:crosshair; display:block; }\n    h2 { margin:6px 0 10px; font-size:16px; }\n    .btn { display:inline-block; margin:6px 6px 6px 0; padding:6px 10px; border-radius:4px; background:#1976d2; color:white; cursor:pointer; user-select:none; font-size:13px; }\n    .btn.secondary { background:#e0e0e0; color:#222; }\n    .btn.warn { background:#c62828; }\n    .row { margin-bottom:8px; }\n    label { font-size:13px; display:block; margin-bottom:4px; color:#333; }\n    #adjList { white-space:pre-wrap; background:white; padding:8px; border-radius:4px; border:1px solid #ddd; max-height:160px; overflow:auto; font-family:monospace; font-size:13px; }\n    .info { font-size:13px; color:#444; margin-top:10px; }\n    .controls { display:flex; flex-wrap:wrap; gap:6px; }\n    .small { padding:4px 8px; font-size:13px; }\n    #speed { width:120px; }\n    .hint { font-size:12px; color:#666; margin-top:8px; }\n    #message { margin-top:8px; font-size:13px; color:#1b5e20; }\n    #legend { font-size:13px; margin-top:8px; }\n    .dot { display:inline-block; width:12px; height:12px; border-radius:50%; margin-right:6px; vertical-align:middle; }\n  </style>\n</head>\n<body>\n  <div id=\"sidebar\">\n    <h2>Directed Graph — Interactive Demo</h2>\n    <div class=\"row controls\">\n      <div class=\"btn\" id=\"btnAddNode\">Add Node (Click canvas)</div>\n      <div class=\"btn secondary\" id=\"btnAddEdge\">Add Edge</div>\n      <div class=\"btn secondary\" id=\"btnDelete\">Delete Selected</div>\n      <div class=\"btn\" id=\"btnClear\">Clear Graph</div>\n    </div>\n\n    <div class=\"row\">\n      <label>Traversal / Algorithms</label>\n      <div class=\"controls\">\n        <div class=\"btn small secondary\" id=\"btnBFS\">BFS</div>\n        <div class=\"btn small secondary\" id=\"btnDFS\">DFS</div>\n        <div class=\"btn small secondary\" id=\"btnTopSort\">Topological Sort</div>\n        <div class=\"btn small secondary\" id=\"btnCycle\">Detect Cycle</div>\n      </div>\n      <div class=\"controls\" style=\"margin-top:6px\">\n        <div class=\"btn small secondary\" id=\"btnShortest\">Shortest Path (unweighted)</div>\n      </div>\n      <div class=\"hint\">Click the button, then click node(s) as prompted.</div>\n      <label style=\"margin-top:8px\">Animation speed</label>\n      <input id=\"speed\" type=\"range\" min=\"100\" max=\"1200\" value=\"450\">\n    </div>\n\n    <div class=\"row\">\n      <label>Adjacency List</label>\n      <div id=\"adjList\">(empty)</div>\n      <div class=\"hint\">Edges are directed: from -> to</div>\n    </div>\n\n    <div class=\"row\">\n      <label>Export / Import</label>\n      <div class=\"controls\">\n        <div class=\"btn small\" id=\"btnExport\">Export JSON</div>\n        <div class=\"btn small secondary\" id=\"btnImport\">Import JSON</div>\n      </div>\n      <textarea id=\"jsonArea\" placeholder='Paste exported JSON here to import' style=\"width:100%;height:80px;margin-top:8px;font-family:monospace;\"></textarea>\n    </div>\n\n    <div id=\"legend\">\n      <div><span class=\"dot\" style=\"background:#e3f2fd;border:1px solid #90caf9\"></span> Node</div>\n      <div style=\"margin-top:6px\"><span class=\"dot\" style=\"background:#ffeb3b\"></span> Frontier</div>\n      <div style=\"margin-top:6px\"><span class=\"dot\" style=\"background:#66bb6a\"></span> Visited</div>\n      <div class=\"info\" id=\"message\"></div>\n    </div>\n    <div class=\"hint\">Controls: click empty canvas to add a node (or press Add Node then click). Drag a node to move it. Use \"Add Edge\" then click source then destination to add a directed edge. Select a node by clicking it.</div>\n  </div>\n\n  <div id=\"canvasWrap\">\n    <svg id=\"svg\"></svg>\n  </div>\n\n<script>\n/* Directed Graph Interactive Demo - single-file\n   Features:\n   - Create nodes by clicking canvas (incremental IDs)\n   - Drag nodes to reposition\n   - Add directed edges using \"Add Edge\" (click source then dest)\n   - Select nodes, delete selected\n   - Run BFS, DFS (animated), Topological Sort, Cycle detect\n   - Shortest path (unweighted) between two clicked nodes\n   - Export / import as JSON\n*/\n\n(function(){\n  const svg = document.getElementById('svg');\n  const btnAddEdge = document.getElementById('btnAddEdge');\n  const btnAddNode = document.getElementById('btnAddNode');\n  const btnDelete = document.getElementById('btnDelete');\n  const btnClear = document.getElementById('btnClear');\n  const adjListEl = document.getElementById('adjList');\n  const messageEl = document.getElementById('message');\n  const btnBFS = document.getElementById('btnBFS');\n  const btnDFS = document.getElementById('btnDFS');\n  const btnTopSort = document.getElementById('btnTopSort');\n  const btnCycle = document.getElementById('btnCycle');\n  const btnShortest = document.getElementById('btnShortest');\n  const btnExport = document.getElementById('btnExport');\n  const btnImport = document.getElementById('btnImport');\n  const jsonArea = document.getElementById('jsonArea');\n  const speedInput = document.getElementById('speed');\n\n  let nodes = []; // {id, x, y}\n  let edges = []; // {from: id, to: id}\n  let nextNodeId = 1;\n\n  let state = {\n    mode: 'normal', // 'addingEdge', 'choosingBFS', 'choosingDFS', 'choosingSPStart', 'choosingSPEnd'\n    tempEdgeSource: null,\n    selectedNodeId: null,\n    dragging: null,\n    dragOffset: null,\n    animating: false\n  };\n\n  // SVG setup: defs for arrowhead\n  const defs = svgns('defs');\n  const marker = svgns('marker');\n  marker.setAttribute('id','arrowhead');\n  marker.setAttribute('markerWidth','10');\n  marker.setAttribute('markerHeight','7');\n  marker.setAttribute('refX','10');\n  marker.setAttribute('refY','3.5');\n  marker.setAttribute('orient','auto');\n  marker.setAttribute('markerUnits','strokeWidth');\n  const path = svgns('path');\n  path.setAttribute('d','M0,0 L10,3.5 L0,7 Z');\n  path.setAttribute('fill','#555');\n  marker.appendChild(path);\n  defs.appendChild(marker);\n  svg.appendChild(defs);\n\n  // Layer groups\n  const edgesGroup = svgns('g'); svg.appendChild(edgesGroup);\n  const edgeLabelsGroup = svgns('g'); svg.appendChild(edgeLabelsGroup);\n  const nodesGroup = svgns('g'); svg.appendChild(nodesGroup);\n\n  // Add event listeners\n  svg.addEventListener('click', svgClick);\n  svg.addEventListener('mousedown', svgMouseDown);\n  svg.addEventListener('mousemove', svgMouseMove);\n  svg.addEventListener('mouseup', svgMouseUp);\n  window.addEventListener('resize', render);\n\n  document.getElementById('btnAddNode').addEventListener('click', ()=> {\n    notify('Click on canvas to add a node.');\n    state.mode='addingNode';\n  });\n  btnAddEdge.addEventListener('click', ()=> {\n    if (state.mode==='addingEdge') {\n      cancelEdgeMode();\n    } else {\n      state.mode='addingEdge';\n      state.tempEdgeSource = null;\n      notify('Add Edge: click source node, then destination node.');\n      btnAddEdge.classList.add('active');\n    }\n  });\n  btnDelete.addEventListener('click', deleteSelected);\n  btnClear.addEventListener('click', ()=> {\n    if (!confirm('Clear entire graph?')) return;\n    nodes=[]; edges=[]; nextNodeId=1; state.selectedNodeId=null; update();\n  });\n\n  btnBFS.addEventListener('click', ()=> {\n    state.mode='choosingBFS';\n    notify('BFS: click start node.');\n  });\n  btnDFS.addEventListener('click', ()=> {\n    state.mode='choosingDFS';\n    notify('DFS: click start node.');\n  });\n  btnTopSort.addEventListener('click', ()=> {\n    runTopologicalSort();\n  });\n  btnCycle.addEventListener('click', ()=> {\n    const cycle = detectCycle();\n    if (cycle.found) notify('Cycle detected! Example cycle: ' + cycle.cycle.join(' -> '));\n    else notify('No cycle detected (DAG).');\n  });\n  btnShortest.addEventListener('click', ()=> {\n    state.mode='choosingSPStart';\n    notify('Shortest Path: click start node.');\n  });\n\n  btnExport.addEventListener('click', ()=> {\n    const data = { nodes, edges };\n    const json = JSON.stringify(data, null, 2);\n    jsonArea.value = json;\n    notify('Exported JSON to text area.');\n  });\n  btnImport.addEventListener('click', ()=> {\n    try {\n      const data = JSON.parse(jsonArea.value);\n      if (!Array.isArray(data.nodes) || !Array.isArray(data.edges)) throw 'Invalid format';\n      nodes = data.nodes.map(n=>({id:n.id,x: n.x, y: n.y}));\n      edges = data.edges.map(e=>({from:e.from, to:e.to}));\n      nextNodeId = nodes.reduce((m,n)=>Math.max(m,n.id),0)+1;\n      state.selectedNodeId=null;\n      update();\n      notify('Imported graph.');\n    } catch(err) {\n      alert('Import error: ' + err);\n    }\n  });\n\n  // Utilities\n  function svgns(tag){ return document.createElementNS('http://www.w3.org/2000/svg', tag); }\n\n  function notify(msg, color='#165c2d'){\n    messageEl.style.color = color;\n    messageEl.textContent = msg;\n  }\n\n  function cancelEdgeMode(){\n    state.mode='normal';\n    state.tempEdgeSource=null;\n    btnAddEdge.classList.remove('active');\n    notify('Edge creation cancelled.', '#666');\n  }\n\n  // SVG interactions\n  function svgClick(e){\n    // only respond to primary button\n    if (e.button !== 0) return;\n    const pt = getSvgPoint(e);\n    if (state.mode==='addingNode'){\n      addNode(pt.x, pt.y);\n      state.mode='normal';\n      notify('Node added.');\n      return;\n    }\n    // hit test on node\n    const targetId = hitTestNode(e);\n    if (state.mode==='addingEdge'){\n      if (targetId==null) { notify('Click a node to add an edge.'); return; }\n      if (state.tempEdgeSource==null){\n        state.tempEdgeSource = targetId;\n        notify('Source node selected (ID '+targetId+'). Now click destination node.');\n      } else {\n        const src = state.tempEdgeSource, dst = targetId;\n        if (src===dst) { notify('Cannot add self-loop in this demo.'); state.tempEdgeSource=null; return; }\n        addEdge(src,dst);\n        state.tempEdgeSource=null;\n        notify('Edge added ' + src + ' -> ' + dst);\n      }\n      return;\n    }\n\n    if (state.mode==='choosingBFS'){\n      if (targetId==null) { notify('Click a node to start BFS.'); return; }\n      runBFS(targetId);\n      state.mode='normal';\n      return;\n    }\n    if (state.mode==='choosingDFS'){\n      if (targetId==null) { notify('Click a node to start DFS.'); return; }\n      runDFS(targetId);\n      state.mode='normal';\n      return;\n    }\n    if (state.mode==='choosingSPStart'){\n      if (targetId==null) { notify('Click start node.'); return; }\n      state.spStart = targetId;\n      state.mode='choosingSPEnd';\n      notify('Start selected: ' + targetId + '. Now click destination node.');\n      return;\n    }\n    if (state.mode==='choosingSPEnd'){\n      if (targetId==null) { notify('Click destination node.'); return; }\n      const start = state.spStart, end = targetId;\n      state.mode='normal';\n      runShortestPath(start,end);\n      return;\n    }\n\n    // Normal click -> select node if clicked, or deselect\n    if (targetId!=null){\n      state.selectedNodeId = targetId;\n      notify('Selected node ' + targetId, '#0b5394');\n      update();\n    } else {\n      state.selectedNodeId = null;\n      update();\n    }\n  }\n\n  function svgMouseDown(e){\n    if (e.button !== 0) return;\n    const nid = hitTestNode(e);\n    if (nid!=null){\n      // prepare dragging\n      const pt = getSvgPoint(e);\n      const n = nodes.find(x=>x.id===nid);\n      state.dragging = nid;\n      state.dragOffset = { dx: pt.x - n.x, dy: pt.y - n.y };\n    }\n  }\n  function svgMouseMove(e){\n    if (state.dragging!=null){\n      const pt = getSvgPoint(e);\n      const n = nodes.find(x=>x.id===state.dragging);\n      n.x = pt.x - state.dragOffset.dx;\n      n.y = pt.y - state.dragOffset.dy;\n      update();\n    }\n  }\n  function svgMouseUp(e){\n    if (state.dragging!=null){\n      state.dragging = null;\n      state.dragOffset = null;\n    }\n  }\n\n  function getSvgPoint(e){\n    const rect = svg.getBoundingClientRect();\n    const x = e.clientX - rect.left;\n    const y = e.clientY - rect.top;\n    return { x, y };\n  }\n\n  function hitTestNode(e){\n    // check if clicking on a node circle element\n    // we'll use elementFromPoint\n    const el = document.elementFromPoint(e.clientX, e.clientY);\n    if (!el) return null;\n    if (el.classList.contains('nodeCircle') || el.classList.contains('nodeLabel')){\n      const nid = parseInt(el.getAttribute('data-id'));\n      return nid;\n    }\n    return null;\n  }\n\n  // Graph manipulation\n  function addNode(x,y){\n    const id = nextNodeId++;\n    nodes.push({ id, x, y });\n    update();\n  }\n  function addEdge(from,to){\n    // avoid duplicates\n    if (edges.some(e=>e.from===from && e.to===to)) return;\n    edges.push({from,to});\n    update();\n  }\n  function deleteSelected(){\n    if (!state.selectedNodeId) { notify('No node selected to delete.'); return; }\n    const id = state.selectedNodeId;\n    nodes = nodes.filter(n=>n.id!==id);\n    edges = edges.filter(e=>e.from!==id && e.to!==id);\n    state.selectedNodeId=null;\n    update();\n    notify('Deleted node ' + id);\n  }\n\n  // Rendering\n  function update(){\n    renderEdges();\n    renderNodes();\n    renderAdjList();\n    // update button states\n    if (state.mode!=='addingEdge') btnAddEdge.classList.remove('active');\n  }\n\n  function render(){\n    update();\n  }\n\n  function renderNodes(){\n    // clear\n    while (nodesGroup.firstChild) nodesGroup.removeChild(nodesGroup.firstChild);\n    for (const n of nodes){\n      const g = svgns('g');\n      const circle = svgns('circle');\n      circle.setAttribute('cx',n.x);\n      circle.setAttribute('cy',n.y);\n      circle.setAttribute('r',20);\n      circle.setAttribute('fill', '#e3f2fd');\n      circle.setAttribute('stroke', '#1976d2');\n      circle.setAttribute('stroke-width', '1.6');\n      circle.classList.add('nodeCircle');\n      circle.setAttribute('data-id', n.id);\n      if (state.selectedNodeId === n.id){\n        circle.setAttribute('stroke-width', '3');\n        circle.setAttribute('stroke', '#0b5394');\n      }\n      g.appendChild(circle);\n      const label = svgns('text');\n      label.setAttribute('x', n.x);\n      label.setAttribute('y', n.y+5);\n      label.setAttribute('text-anchor','middle');\n      label.setAttribute('font-size','13px');\n      label.setAttribute('fill','#0b3a66');\n      label.classList.add('nodeLabel');\n      label.setAttribute('data-id', n.id);\n      label.textContent = n.id;\n      g.appendChild(label);\n      nodesGroup.appendChild(g);\n    }\n  }\n\n  function renderEdges(highlightedPath){\n    while (edgesGroup.firstChild) edgesGroup.removeChild(edgesGroup.firstChild);\n    while (edgeLabelsGroup.firstChild) edgeLabelsGroup.removeChild(edgeLabelsGroup.firstChild);\n    for (const e of edges){\n      const from = nodes.find(n=>n.id===e.from);\n      const to = nodes.find(n=>n.id===e.to);\n      if (!from || !to) continue;\n      // compute direction line endpoints with circle radius offset\n      const dx = to.x - from.x;\n      const dy = to.y - from.y;\n      const dist = Math.hypot(dx,dy);\n      const r = 20;\n      const ex = (dx/dist) * r;\n      const ey = (dy/dist) * r;\n      const sx = from.x + ex;\n      const sy = from.y + ey;\n      const tx = to.x - ex;\n      const ty = to.y - ey;\n\n      // For visual variety, compute a small perpendicular offset if bidirectional or multiple edges could overlap.\n      // For simplicity we won't compute unique offsets; a small fixed offset for now:\n      const ux = -dy/dist;\n      const uy = dx/dist;\n      // if there's also opposite edge, offset a bit\n      const opposite = edges.some(o=>o.from===e.to && o.to===e.from);\n      const offset = opposite ? 8 : 0;\n      const sx2 = sx + ux*offset;\n      const sy2 = sy + uy*offset;\n      const tx2 = tx + ux*offset;\n      const ty2 = ty + uy*offset;\n\n      const line = svgns('line');\n      line.setAttribute('x1', sx2);\n      line.setAttribute('y1', sy2);\n      line.setAttribute('x2', tx2);\n      line.setAttribute('y2', ty2);\n      line.setAttribute('stroke','#555');\n      line.setAttribute('stroke-width', '2');\n      line.setAttribute('marker-end','url(#arrowhead)');\n      edgesGroup.appendChild(line);\n\n      // if edge is part of a highlighted path, color it\n      if (highlightedPath && highlightedPath.some(p => p.from===e.from && p.to===e.to)){\n        line.setAttribute('stroke', '#f57c00');\n        line.setAttribute('stroke-width','3.2');\n      }\n\n      // optional label at midpoint\n      // const midx=(sx2+tx2)/2, midy=(sy2+ty2)/2;\n      // const t = svgns('text'); t.setAttribute('x',midx); t.setAttribute('y', midy-6); t.setAttribute('text-anchor','middle'); t.setAttribute('font-size','11'); t.setAttribute('fill','#333'); t.textContent=''; edgeLabelsGroup.appendChild(t);\n    }\n  }\n\n  function renderAdjList(){\n    if (nodes.length===0){\n      adjListEl.textContent='(empty)';\n      return;\n    }\n    const map = new Map();\n    for (const n of nodes) map.set(n.id, []);\n    for (const e of edges) {\n      if (map.has(e.from)) map.get(e.from).push(e.to);\n    }\n    let s='';\n    for (const n of nodes){\n      const arr = map.get(n.id) || [];\n      s += n.id + ' -> [' + arr.join(', ') + ']\\n';\n    }\n    adjListEl.textContent = s.trim();\n  }\n\n  // Traversals / Algorithms\n\n  function runBFS(startId){\n    if (state.animating) { notify('Animation in progress.'); return; }\n    const neighbors = buildAdj();\n    const visited = new Set();\n    const q = [];\n    q.push(startId);\n    visited.add(startId);\n    const order = [];\n    while(q.length){\n      const v = q.shift();\n      order.push(v);\n      const nbrs = neighbors.get(v) || [];\n      for (const w of nbrs){\n        if (!visited.has(w)){\n          visited.add(w);\n          q.push(w);\n        }\n      }\n    }\n    if (order.length===0) { notify('Empty graph'); return; }\n    animateVisit(order, 'BFS order: ' + order.join(' -> '));\n  }\n\n  function runDFS(startId){\n    if (state.animating) { notify('Animation in progress.'); return; }\n    const neighbors = buildAdj();\n    const visited = new Set();\n    const order = [];\n    function dfs(v){\n      visited.add(v);\n      order.push(v);\n      const nbrs = neighbors.get(v) || [];\n      for (const w of nbrs){\n        if (!visited.has(w)) dfs(w);\n      }\n    }\n    dfs(startId);\n    animateVisit(order, 'DFS order: ' + order.join(' -> '));\n  }\n\n  function buildAdj(){\n    const m = new Map();\n    for (const n of nodes) m.set(n.id, []);\n    for (const e of edges){\n      if (!m.has(e.from)) m.set(e.from, []);\n      m.get(e.from).push(e.to);\n    }\n    return m;\n  }\n\n  function animateVisit(order, finalMsg){\n    state.animating = true;\n    const speed = parseInt(speedInput.value,10);\n    // color sequence: frontier -> visited\n    const nodeElements = {}; // id -> circle element\n    // find circle nodes in SVG\n    nodesGroup.querySelectorAll('circle.nodeCircle').forEach(c=>{\n      nodeElements[c.getAttribute('data-id')] = c;\n      c.setAttribute('fill','#e3f2fd');\n      c.setAttribute('stroke','#1976d2');\n      c.setAttribute('stroke-width','1.6');\n    });\n    let i = 0;\n    notify('Animating...');\n    const interval = setInterval(()=>{\n      if (i>0){\n        const idVisited = order[i-1];\n        const cPrev = nodeElements[idVisited];\n        if (cPrev) cPrev.setAttribute('fill','#66bb6a'); // visited green\n      }\n      if (i<order.length){\n        const id = order[i];\n        const c = nodeElements[id];\n        if (c) c.setAttribute('fill','#ffeb3b'); // frontier yellow\n      } else {\n        clearInterval(interval);\n        state.animating=false;\n        notify(finalMsg);\n        return;\n      }\n      i++;\n    }, Math.max(80, speed/4));\n  }\n\n  function runTopologicalSort(){\n    const nmap = new Map(); // indegree and neighbors\n    for (const n of nodes) nmap.set(n.id, { indeg:0, nbrs:[] });\n    for (const e of edges){\n      if (!nmap.has(e.from) || !nmap.has(e.to)) continue;\n      nmap.get(e.from).nbrs.push(e.to);\n      nmap.get(e.to).indeg++;\n    }\n    const q = [];\n    for (const [id, obj] of nmap.entries()){\n      if (obj.indeg===0) q.push(id);\n    }\n    const order = [];\n    while(q.length){\n      const v = q.shift();\n      order.push(v);\n      for (const w of nmap.get(v).nbrs){\n        nmap.get(w).indeg--;\n        if (nmap.get(w).indeg===0) q.push(w);\n      }\n    }\n    if (order.length !== nodes.length){\n      notify('Graph has a cycle; topological sort not possible.');\n    } else {\n      notify('Topological order: ' + order.join(' -> '));\n      // highlight path edges between successive in order as demonstration\n      const pathEdges = [];\n      for (let i=0;i<order.length-1;i++){\n        pathEdges.push({ from: order[i], to: order[i+1] });\n      }\n      renderEdges(pathEdges);\n      setTimeout(update, 2000);\n    }\n  }\n\n  function detectCycle(){\n    const adj = buildAdj();\n    const temp = new Set();\n    const perm = new Set();\n    let found = false;\n    let cyclePath = [];\n\n    function dfs(v, stack){\n      if (found) return;\n      if (temp.has(v)){\n        // found cycle - slice stack\n        const idx = stack.indexOf(v);\n        cyclePath = stack.slice(idx).concat(v);\n        found = true; return;\n      }\n      if (perm.has(v)) return;\n      temp.add(v);\n      stack.push(v);\n      const nbrs = adj.get(v) || [];\n      for (const w of nbrs){\n        dfs(w, stack);\n        if (found) return;\n      }\n      stack.pop();\n      temp.delete(v);\n      perm.add(v);\n    }\n    for (const n of nodes){\n      if (!perm.has(n.id)) dfs(n.id, []);\n      if (found) break;\n    }\n    return { found, cycle: cyclePath };\n  }\n\n  function runShortestPath(start, end){\n    if (state.animating) { notify('Animation in progress.'); return; }\n    const adj = buildAdj();\n    const q = [start];\n    const prev = new Map();\n    prev.set(start, null);\n    let found=false;\n    while(q.length){\n      const v = q.shift();\n      if (v===end){ found=true; break; }\n      const nbrs = adj.get(v) || [];\n      for (const w of nbrs){\n        if (!prev.has(w)){\n          prev.set(w, v);\n          q.push(w);\n        }\n      }\n    }\n    if (!found){\n      notify('No path from '+ start + ' to ' + end);\n      return;\n    }\n    const path = [];\n    let cur = end;\n    while(cur!=null){\n      path.push(cur);\n      cur = prev.get(cur);\n    }\n    path.reverse();\n    notify('Shortest path: ' + path.join(' -> '));\n    // highlight edges along path\n    const pathEdges = [];\n    for (let i=0;i<path.length-1;i++) pathEdges.push({ from: path[i], to: path[i+1] });\n    renderEdges(pathEdges);\n    // also animate nodes visited order (BFS discovered order)\n    animateVisit(path, 'Reached: ' + path.join(' -> '));\n  }\n\n  // Initialize with a sample graph for quick demo\n  function initDemo(){\n    nodes = [\n      {id:1,x:120,y:80},\n      {id:2,x:300,y:60},\n      {id:3,x:480,y:100},\n      {id:4,x:200,y:220},\n      {id:5,x:380,y:240}\n    ];\n    edges = [\n      {from:1,to:2},{from:2,to:3},{from:1,to:4},{from:4,to:2},{from:2,to:5},{from:5,to:3}\n    ];\n    nextNodeId = 6;\n    update();\n    notify('Sample graph loaded. Try BFS/DFS or Add Edge.');\n  }\n\n  // start\n  initDemo();\n\n})();\n</script>\n</body>\n</html>"
  },
