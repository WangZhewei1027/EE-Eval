    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>K-Means Clustering Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #canvas {\n    border: 1px solid #ccc;\n    background: #fff;\n    display: block;\n    margin: 0 auto 20px auto;\n  }\n  #controls {\n    max-width: 600px;\n    margin: 0 auto 10px;\n    display: flex;\n    gap: 10px;\n    flex-wrap: wrap;\n  }\n  label {\n    font-weight: bold;\n    margin-right: 4px;\n  }\n  input[type=number] {\n    width: 60px;\n  }\n  button {\n    cursor: pointer;\n    background: #007bff;\n    border: none;\n    color: white;\n    padding: 6px 12px;\n    font-size: 14px;\n    border-radius: 4px;\n    transition: background-color 0.3s ease;\n  }\n  button:hover:not(:disabled) {\n    background: #0056b3;\n  }\n  button:disabled {\n    background: #999;\n    cursor: not-allowed;\n  }\n  #info {\n    max-width: 600px;\n    margin: 0 auto;\n    font-size: 14px;\n    line-height: 1.4;\n    background: #eee;\n    padding: 10px;\n    border-radius: 4px;\n  }\n  #legend {\n    max-width: 600px;\n    margin: 10px auto;\n    display: flex;\n    justify-content: center;\n    flex-wrap: wrap;\n    gap: 12px;\n    font-size: 14px;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  .color-box {\n    width: 16px;\n    height: 16px;\n    border-radius: 3px;\n  }\n</style>\n</head>\n<body>\n<h1>K-Means Clustering Visualization</h1>\n\n<canvas id=\"canvas\" width=\"600\" height=\"450\"></canvas>\n\n<div id=\"controls\">\n  <label for=\"clusters\">Clusters (k):</label>\n  <input type=\"number\" id=\"clusters\" min=\"1\" max=\"10\" value=\"3\" />\n  <label for=\"points\">Points:</label>\n  <input type=\"number\" id=\"points\" min=\"10\" max=\"1000\" value=\"150\" />\n  <button id=\"generateBtn\">Generate Points</button>\n  <button id=\"stepBtn\" disabled>Next Step</button>\n  <button id=\"runBtn\" disabled>Run to End</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n\n<div id=\"info\">\n  <strong>Instructions:</strong> <br/>\n  - Set the number of clusters (k) and points, then \"Generate Points\".<br/>\n  - Click \"Next Step\" to perform one iteration of the k-means algorithm:<br/>\n    &nbsp;&nbsp;1. Assign points to nearest cluster.<br/>\n    &nbsp;&nbsp;2. Update cluster centroids.<br/>\n  - \"Run to End\" finishes clustering automatically.<br/>\n  - \"Reset\" to clear and start over.\n</div>\n\n<div id=\"legend\"></div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n  const width = canvas.width;\n  const height = canvas.height;\n\n  const clustersInput = document.getElementById('clusters');\n  const pointsInput = document.getElementById('points');\n  const generateBtn = document.getElementById('generateBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const runBtn = document.getElementById('runBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const legend = document.getElementById('legend');\n\n  let k = 3;            // Number of clusters\n  let numPoints = 150;  // Number of points\n  let points = [];      // Array of {x, y, cluster}\n  let centroids = [];   // Array of {x, y}\n  let finished = false;\n\n  // Colors for clusters - cycle if more than colors.length clusters\n  const colors = [\n    '#e6194b','#3cb44b','#ffe119','#4363d8','#f58231','#911eb4','#46f0f0','#f032e6','#bcf60c','#fabebe'\n  ];\n\n  // Utility: distance squared between two points\n  function distSq(a, b) {\n    const dx = a.x - b.x;\n    const dy = a.y - b.y;\n    return dx * dx + dy * dy;\n  }\n\n  // Initialize points randomly inside canvas\n  function generatePoints() {\n    points = [];\n    for (let i = 0; i < numPoints; i++) {\n      points.push({\n        x: Math.random() * width * 0.9 + width * 0.05,\n        y: Math.random() * height * 0.9 + height * 0.05,\n        cluster: -1\n      });\n    }\n  }\n\n  // Initialize centroids by picking k random points\n  function initializeCentroids() {\n    centroids = [];\n    // To ensure distinct centroids, shuffle points and pick the first k\n    let shuffled = points.slice();\n    for (let i = shuffled.length - 1; i > 0; i--) {\n      let j = Math.floor(Math.random() * (i + 1));\n      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];\n    }\n    for (let i = 0; i < k; i++) {\n      let p = shuffled[i];\n      centroids.push({x: p.x, y: p.y});\n    }\n  }\n\n  // Assign points to nearest cluster\n  // Returns true if any point changed cluster, else false\n  function assignPoints() {\n    let changed = false;\n    for (let p of points) {\n      let minDist = Infinity;\n      let bestCluster = -1;\n      for (let c = 0; c < k; c++) {\n        let d = distSq(p, centroids[c]);\n        if (d < minDist) {\n          minDist = d;\n          bestCluster = c;\n        }\n      }\n      if (p.cluster !== bestCluster) {\n        changed = true;\n        p.cluster = bestCluster;\n      }\n    }\n    return changed;\n  }\n\n  // Update centroids as mean of assigned points\n  // Returns true if any centroid moved significantly (threshold), else false\n  function updateCentroids() {\n    const newCentroids = new Array(k).fill(0).map(() => ({x:0, y:0, count:0}));\n    for (let p of points) {\n      if (p.cluster === -1) continue;\n      newCentroids[p.cluster].x += p.x;\n      newCentroids[p.cluster].y += p.y;\n      newCentroids[p.cluster].count++;\n    }\n    let moved = false;\n    for (let c = 0; c < k; c++) {\n      if (newCentroids[c].count === 0) {\n        // No points assigned to cluster, keep centroid in place\n        continue;\n      }\n      const newX = newCentroids[c].x / newCentroids[c].count;\n      const newY = newCentroids[c].y / newCentroids[c].count;\n      if (Math.abs(centroids[c].x - newX) > 1e-3 || Math.abs(centroids[c].y - newY) > 1e-3) {\n        moved = true;\n      }\n      centroids[c].x = newX;\n      centroids[c].y = newY;\n    }\n    return moved;\n  }\n\n  // Run one iteration: assign points then update centroids\n  // Return true if changed, else false means converged\n  function step() {\n    const assignmentsChanged = assignPoints();\n    const centroidsMoved = updateCentroids();\n    draw();\n    return assignmentsChanged || centroidsMoved;\n  }\n\n  // Draw points and centroids\n  function draw() {\n    ctx.clearRect(0, 0, width, height);\n\n    // Draw points\n    for (let p of points) {\n      if (p.cluster === -1) {\n        // Unassigned points: draw as gray small circles\n        ctx.fillStyle = '#bbb';\n      } else {\n        ctx.fillStyle = colors[p.cluster % colors.length];\n      }\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);\n      ctx.fill();\n      ctx.strokeStyle = '#333';\n      ctx.lineWidth = 0.5;\n      ctx.stroke();\n    }\n\n    // Draw centroids\n    for (let c = 0; c < centroids.length; c++) {\n      const cent = centroids[c];\n      ctx.fillStyle = colors[c % colors.length];\n      ctx.strokeStyle = '#222';\n      ctx.lineWidth = 2;\n      ctx.beginPath();\n      ctx.arc(cent.x, cent.y, 10, 0, Math.PI * 2);\n      ctx.fill();\n      ctx.stroke();\n\n      // Draw centroid marker (cross)\n      ctx.strokeStyle = '#fff';\n      ctx.lineWidth = 2;\n      ctx.beginPath();\n      ctx.moveTo(cent.x - 6, cent.y);\n      ctx.lineTo(cent.x + 6, cent.y);\n      ctx.moveTo(cent.x, cent.y - 6);\n      ctx.lineTo(cent.x, cent.y + 6);\n      ctx.stroke();\n    }\n  }\n\n  // Create legend below canvas\n  function updateLegend() {\n    legend.innerHTML = '';\n    for(let i = 0; i < k; i++) {\n      const item = document.createElement('div');\n      item.className = 'legend-item';\n      const box = document.createElement('div');\n      box.className = 'color-box';\n      box.style.backgroundColor = colors[i % colors.length];\n      item.appendChild(box);\n      item.appendChild(document.createTextNode(`Cluster ${i + 1}`));\n      legend.appendChild(item);\n    }\n  }\n\n  // Button event handlers\n  generateBtn.addEventListener('click', () => {\n    k = parseInt(clustersInput.value);\n    numPoints = parseInt(pointsInput.value);\n    if (isNaN(k) || k < 1 || k > 10) {\n      alert('Clusters (k) must be a number between 1 and 10.');\n      return;\n    }\n    if (isNaN(numPoints) || numPoints < 10 || numPoints > 1000) {\n      alert('Points must be a number between 10 and 1000.');\n      return;\n    }\n\n    generatePoints();\n    initializeCentroids();\n    // Initially assign points to cluster -1 (unassigned)\n    for(let p of points) {\n      p.cluster = -1;\n    }\n    finished = false;\n    stepBtn.disabled = false;\n    runBtn.disabled = false;\n    resetBtn.disabled = false;\n    draw();\n    updateLegend();\n  });\n\n  stepBtn.addEventListener('click', () => {\n    if (finished) return;\n    const changed = step();\n    if (!changed) {\n      finished = true;\n      stepBtn.disabled = true;\n      runBtn.disabled = true;\n      alert('Clustering converged!');\n    }\n  });\n\n  runBtn.addEventListener('click', () => {\n    if (finished) return;\n    let changed = true;\n    while (changed) {\n      changed = step();\n    }\n    finished = true;\n    stepBtn.disabled = true;\n    runBtn.disabled = true;\n    alert('Clustering converged!');\n  });\n\n  resetBtn.addEventListener('click', () => {\n    points = [];\n    centroids = [];\n    finished = false;\n    stepBtn.disabled = true;\n    runBtn.disabled = true;\n    resetBtn.disabled = true;\n    ctx.clearRect(0, 0, width, height);\n    legend.innerHTML = '';\n  });\n\n  // Draw axes and border to guide perspective (optional)\n  function drawAxes() {\n    ctx.save();\n    ctx.strokeStyle = '#eee';\n    ctx.lineWidth = 1;\n    // Vertical grid lines\n    for(let x = 50; x < width; x += 50) {\n      ctx.beginPath();\n      ctx.moveTo(x, 0);\n      ctx.lineTo(x, height);\n      ctx.stroke();\n    }\n    // Horizontal grid lines\n    for(let y = 50; y < height; y += 50) {\n      ctx.beginPath();\n      ctx.moveTo(0, y);\n      ctx.lineTo(width, y);\n      ctx.stroke();\n    }\n    ctx.restore();\n  }\n\n  // Override draw to include background grid\n  const originalDraw = draw;\n  draw = () => {\n    ctx.clearRect(0, 0, width, height);\n    drawAxes();\n    originalDraw();\n  };\n\n  // Initial canvas state\n  ctx.font = \"16px 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif\";\n  ctx.fillStyle = '#666';\n  ctx.textAlign = 'center';\n  ctx.fillText('Set parameters and click \"Generate Points\" to start', width/2, height/2);\n})();\n</script>\n\n</body>\n</html>"
  },
