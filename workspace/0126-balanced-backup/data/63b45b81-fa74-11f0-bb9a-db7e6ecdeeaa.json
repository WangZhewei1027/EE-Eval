  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Random Forest Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n  }\n  #canvas {\n    border: 1px solid #ccc;\n    margin-top: 20px;\n    display: block;\n  }\n  #controls {\n    margin-bottom: 10px;\n  }\n  input[type=number] {\n    width: 60px;\n  }\n  #description {\n    max-width: 800px;\n    margin-bottom: 20px;\n  }\n  #legend {\n    margin-top: 10px;\n  }\n  .tree-point {\n    stroke: black;\n    stroke-width: 1px;\n  }\n</style>\n</head>\n<body>\n<h1>Random Forest Concept Demonstration</h1>\n<div id=\"description\">\n  <p>\n    This visualization demonstrates the concept of <strong>Random Forest</strong>, an ensemble learning method \n    used for classification. A Random Forest builds multiple decision trees using random subsets of data \n    and features, and combines their results to improve prediction accuracy and control overfitting.\n  </p>\n  <p>\n    You can generate a random dataset of points belonging to two classes, train multiple decision trees on random \n    bootstrap samples with randomized feature splits, and see how each tree (colored decision regions) votes to classify \n    points in the 2D feature space.\n  </p>\n</div>\n\n<div id=\"controls\">\n  <label>Number of points per class: <input id=\"pointsPerClass\" type=\"number\" min=\"10\" max=\"200\" value=\"50\" /></label>\n  <label>Number of trees: <input id=\"numTrees\" type=\"number\" min=\"1\" max=\"25\" value=\"5\" /></label>\n  <label>Max tree depth: <input id=\"maxDepth\" type=\"number\" min=\"1\" max=\"10\" value=\"4\" /></label>\n  <button id=\"generateBtn\">Generate & Train</button>\n</div>\n\n<canvas id=\"canvas\" width=\"600\" height=\"600\"></canvas>\n<div id=\"legend\">\n  <strong>Legend:</strong>\n  <span style=\"background:#e06666;color:#fff;padding:2px 6px;border-radius:3px;\">Class A</span> \n  <span style=\"background:#6fa8dc;color:#fff;padding:2px 6px;border-radius:3px;margin-left:12px;\">Class B</span>\n</div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n  const width = canvas.width;\n  const height = canvas.height;\n\n  // Colors for classes\n  const classColors = {\n    A: '#e06666',\n    B: '#6fa8dc'\n  };\n\n  // Background colors for vote scoring weighted regions\n  const regionColors = {\n    A: 'rgba(224, 102, 102, 0.2)',\n    B: 'rgba(111, 168, 220, 0.2)'\n  };\n\n  // Generate synthetic 2D data with two classes\n  function generateData(pointsPerClass) {\n    const data = [];\n    // Class A centered near (150, 400)\n    for (let i = 0; i < pointsPerClass; i++) {\n      const x = 100 + 100 * Math.random();\n      const y = 350 + 100 * Math.random() + 20 * Math.sin(x / 20);\n      data.push({ x, y, label: 'A' });\n    }\n    // Class B centered near (400, 150)\n    for (let i = 0; i < pointsPerClass; i++) {\n      const x = 350 + 100 * Math.random();\n      const y = 100 + 100 * Math.random() + 20 * Math.cos(x / 20);\n      data.push({ x, y, label: 'B' });\n    }\n    return data;\n  }\n\n  // Utilities for splitting data\n\n  // Gini impurity for binary classes A/B\n  function giniImpurity(subset) {\n    if (subset.length === 0) return 0;\n    const countA = subset.filter(p => p.label === 'A').length;\n    const countB = subset.length - countA;\n    const pA = countA / subset.length;\n    const pB = countB / subset.length;\n    return 1 - (pA * pA + pB * pB);\n  }\n\n  // Find best split on a single feature for a set of points\n  // Features are x or y coordinate.\n  // Random Forest selects random subset of features — here 1 out of 2 features.\n  function findBestSplit(points, featureIndices) {\n    // featureIndices: array like [0] or [1], corresponding to x or y\n    let bestFeature = null;\n    let bestThreshold = null;\n    let bestImpurity = Infinity;\n    let bestLeft = null;\n    let bestRight = null;\n\n    for (const f of featureIndices) {\n      // Extract feature values and sort points by that\n      const sorted = points.slice().sort((a, b) => (f === 0 ? a.x - b.x : a.y - b.y));\n      const featureVals = sorted.map(p => (f === 0 ? p.x : p.y));\n\n      // Try splitting points between adjacent different feature values\n      for (let i = 1; i < sorted.length; i++) {\n        if (featureVals[i] === featureVals[i - 1]) continue;\n        const threshold = (featureVals[i] + featureVals[i - 1]) / 2;\n        const left = sorted.filter(p => (f === 0 ? p.x <= threshold : p.y <= threshold));\n        const right = sorted.filter(p => (f === 0 ? p.x > threshold : p.y > threshold));\n        // calculate weighted gini\n        const impurity = (left.length * giniImpurity(left) + right.length * giniImpurity(right)) / points.length;\n        if (impurity < bestImpurity) {\n          bestImpurity = impurity;\n          bestFeature = f;\n          bestThreshold = threshold;\n          bestLeft = left;\n          bestRight = right;\n        }\n      }\n    }\n    return {\n      feature: bestFeature,\n      threshold: bestThreshold,\n      left: bestLeft,\n      right: bestRight,\n      impurity: bestImpurity,\n    };\n  }\n\n  // Decision tree node\n  class TreeNode {\n    constructor(points, depth, maxDepth) {\n      this.points = points;\n      this.depth = depth;\n      this.maxDepth = maxDepth;\n      this.isLeaf = false;\n      this.left = null;\n      this.right = null;\n      this.feature = null;\n      this.threshold = null;\n      this.prediction = null;\n    }\n\n    // For random forest:\n    // Randomly select sqrt(total features) features to consider for splitting.\n    // Here total features = 2 (x, y), sqrt=1.4 ~1, so we'll just pick randomly 1 feature (x or y).\n    build() {\n      const countA = this.points.filter(p => p.label === 'A').length;\n      const countB = this.points.length - countA;\n\n      // If all points same class or max depth reached, make leaf node\n      if (countA === 0 || countB === 0 || this.depth >= this.maxDepth) {\n        this.isLeaf = true;\n        this.prediction = countA >= countB ? 'A' : 'B';\n        return;\n      }\n\n      // Randomly pick subset of features (1 feature, x or y)\n      const features = [0, 1];\n      const randomFeature = features[Math.floor(Math.random() * features.length)];\n      const split = findBestSplit(this.points, [randomFeature]);\n\n      // If no valid split found, leaf\n      if (!split || split.impurity === 0 || !split.left.length || !split.right.length) {\n        this.isLeaf = true;\n        this.prediction = countA >= countB ? 'A' : 'B';\n        return;\n      }\n\n      this.feature = split.feature;\n      this.threshold = split.threshold;\n\n      // Build child nodes recursively\n      this.left = new TreeNode(split.left, this.depth + 1, this.maxDepth);\n      this.right = new TreeNode(split.right, this.depth + 1, this.maxDepth);\n      this.isLeaf = false;\n\n      this.left.build();\n      this.right.build();\n    }\n\n    // Predict class label for a point {x,y}\n    predict(point) {\n      if (this.isLeaf) return this.prediction;\n      if (this.feature === 0) {\n        if (point.x <= this.threshold) return this.left.predict(point);\n        else return this.right.predict(point);\n      } else {\n        if (point.y <= this.threshold) return this.left.predict(point);\n        else return this.right.predict(point);\n      }\n    }\n  }\n\n  // Random Forest Classifier\n  class RandomForest {\n    constructor(numTrees, maxDepth) {\n      this.numTrees = numTrees;\n      this.maxDepth = maxDepth;\n      this.trees = [];\n    }\n\n    // Bootstrap sample with replacement from data\n    bootstrapSample(data) {\n      const n = data.length;\n      const sample = [];\n      for (let i = 0; i < n; i++) {\n        const idx = Math.floor(Math.random() * n);\n        sample.push(data[idx]);\n      }\n      return sample;\n    }\n\n    train(data) {\n      this.trees = [];\n      for (let t = 0; t < this.numTrees; t++) {\n        const sample = this.bootstrapSample(data);\n        const tree = new TreeNode(sample, 0, this.maxDepth);\n        tree.build();\n        this.trees.push(tree);\n      }\n    }\n\n    // Predict majority vote of all trees\n    predict(point) {\n      const votes = { A: 0, B: 0 };\n      for (const tree of this.trees) {\n        const p = tree.predict(point);\n        votes[p]++;\n      }\n      return votes.A >= votes.B ? 'A' : 'B';\n    }\n\n    // Get votes count for both classes (useful for coloring)\n    predictVotes(point) {\n      const votes = { A: 0, B: 0 };\n      for (const tree of this.trees) {\n        const p = tree.predict(point);\n        votes[p]++;\n      }\n      return votes;\n    }\n  }\n\n  // Draw the dataset points on canvas\n  function drawPoints(data) {\n    for (const p of data) {\n      ctx.beginPath();\n      ctx.fillStyle = classColors[p.label];\n      ctx.strokeStyle = '#333';\n      ctx.lineWidth = 0.8;\n      ctx.ellipse(p.x, p.y, 5, 5, 0, 0, 2 * Math.PI);\n      ctx.fill();\n      ctx.stroke();\n    }\n  }\n\n  // Visualize decision boundaries by coloring pixels by Random Forest vote\n  // For performance, we sample every few pixels (pixelStep)\n  function drawDecisionBoundaries(rf, pixelStep = 8) {\n    const imgData = ctx.createImageData(width, height);\n    const data = imgData.data;\n\n    // Go through pixels on a grid and fill color depending on forest vote\n    for (let y = 0; y < height; y += pixelStep) {\n      for (let x = 0; x < width; x += pixelStep) {\n        const votes = rf.predictVotes({ x, y });\n        const totalVotes = rf.numTrees;\n\n        // Calculate weighted color between classes based on vote ratio\n        const ratioA = votes.A / totalVotes;\n        const ratioB = votes.B / totalVotes;\n\n        // Blend color with white background for subtlety\n        const r = Math.round(\n          (classColors.A.substring(1, 3) * 1 * ratioA) + \n          (classColors.B.substring(1, 3) * 1 * ratioB) + \n          255 * (1 - ratioA - ratioB)\n        );\n\n        // Calculate final blended color more precisely\n        // We'll blend the fixed class colors with white by ratio\n        const blendColor = (c, ratio) => {\n          const val = parseInt(c.substring(1, 3), 16);\n          return val * ratio + 255 * (1 - ratio);\n        };\n        const blendColorG = (c, ratio) => {\n          const val = parseInt(c.substring(3, 5), 16);\n          return val * ratio + 255 * (1 - ratio);\n        };\n        const blendColorB = (c, ratio) => {\n          const val = parseInt(c.substring(5, 7), 16);\n          return val * ratio + 255 * (1 - ratio);\n        };\n\n        const rF = blendColor(classColors.A, ratioA) + blendColor(classColors.B, ratioB);\n        const gF = blendColorG(classColors.A, ratioA) + blendColorG(classColors.B, ratioB);\n        const bF = blendColorB(classColors.A, ratioA) + blendColorB(classColors.B, ratioB);\n\n        let finalR = blendColor(classColors.A, ratioA) * ratioA + blendColor(classColors.B, ratioB) * ratioB + 255 * (1 - (ratioA + ratioB));\n        let finalG = blendColorG(classColors.A, ratioA) * ratioA + blendColorG(classColors.B, ratioB) * ratioB + 255 * (1 - (ratioA + ratioB));\n        let finalB = blendColorB(classColors.A, ratioA) * ratioA + blendColorB(classColors.B, ratioB) * ratioB + 255 * (1 - (ratioA + ratioB));\n\n        // To simplify, calculate weighted average:\n\n        const weightedColor = (colorA, colorB, wA, wB) => {\n          let rA = parseInt(colorA.substring(1, 3), 16);\n          let gA = parseInt(colorA.substring(3, 5), 16);\n          let bA = parseInt(colorA.substring(5, 7), 16);\n\n          let rB = parseInt(colorB.substring(1, 3), 16);\n          let gB = parseInt(colorB.substring(3, 5), 16);\n          let bB = parseInt(colorB.substring(5, 7), 16);\n\n          let r = Math.round(rA * wA + rB * wB + 255 * (1 - wA - wB));\n          let g = Math.round(gA * wA + gB * wB + 255 * (1 - wA - wB));\n          let b = Math.round(bA * wA + bB * wB + 255 * (1 - wA - wB));\n\n          return [r, g, b];\n        };\n\n        const [rC, gC, bC] = weightedColor(classColors.A, classColors.B, ratioA, ratioB);\n\n        // fill pixelStep x pixelStep pixels\n        for (let dy = 0; dy < pixelStep; dy++) {\n          for (let dx = 0; dx < pixelStep; dx++) {\n            const px = x + dx;\n            const py = y + dy;\n            if (px >= width || py >= height) continue;\n            const idx = (py * width + px) * 4;\n            data[idx] = rC; // R\n            data[idx + 1] = gC; // G\n            data[idx + 2] = bC; // B\n            data[idx + 3] = 255; // alpha\n          }\n        }\n      }\n    }\n    ctx.putImageData(imgData, 0, 0);\n  }\n\n  // Clear canvas\n  function clearCanvas() {\n    ctx.clearRect(0, 0, width, height);\n  }\n\n  // Main interaction\n  const generateBtn = document.getElementById('generateBtn');\n  const pointsPerClassInput = document.getElementById('pointsPerClass');\n  const numTreesInput = document.getElementById('numTrees');\n  const maxDepthInput = document.getElementById('maxDepth');\n\n  let data = [];\n  let rf = null;\n\n  // Draw all: boundaries + points\n  function drawAll() {\n    clearCanvas();\n    // Draw background decision boundary\n    drawDecisionBoundaries(rf);\n    // Draw data points on top\n    drawPoints(data);\n  }\n\n  generateBtn.addEventListener('click', () => {\n    const pointsPerClass = Math.max(10, Math.min(200, +pointsPerClassInput.value));\n    const numTrees = Math.max(1, Math.min(25, +numTreesInput.value));\n    const maxDepth = Math.max(1, Math.min(10, +maxDepthInput.value));\n\n    data = generateData(pointsPerClass);\n    rf = new RandomForest(numTrees, maxDepth);\n    rf.train(data);\n    drawAll();\n  });\n\n  // Initial load\n  generateBtn.click();\n})();\n</script>\n</body>\n</html>"
