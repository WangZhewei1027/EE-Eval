    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Trie Data Structure Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1rem;\n    background: #f9f9f9;\n    color: #222;\n  }\n  h1 {\n    text-align: center;\n  }\n  .container {\n    max-width: 600px;\n    margin: auto;\n    background: white;\n    padding: 1rem 2rem 2rem 2rem;\n    border-radius: 8px;\n    box-shadow: 0 0 15px #ddd;\n  }\n  label {\n    display: block;\n    margin-top: 1rem;\n    font-weight: bold;\n  }\n  input[type=\"text\"] {\n    width: 100%;\n    padding: 0.5rem;\n    margin-top: 0.3rem;\n    font-size: 1rem;\n    box-sizing: border-box;\n  }\n  button {\n    margin-top: 1rem;\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    cursor: pointer;\n    border:none;\n    background-color:#007bff;\n    color:white;\n    border-radius: 4px;\n    transition: background-color 0.3s ease;\n  }\n  button:hover {\n    background-color:#0056b3;\n  }\n  .output {\n    margin-top: 1rem;\n    background: #eee;\n    padding: 0.8rem;\n    border-radius: 6px;\n    white-space: pre-wrap;\n    max-height: 300px;\n    overflow-y: auto;\n  }\n  .inline-block {\n    display: inline-block;\n  }\n  .result {\n    margin-top: 0.5rem;\n    font-weight: bold;\n  }\n  footer {\n    margin-top: 2rem;\n    font-size: 0.8rem;\n    color:#555;\n    text-align: center;\n  }\n  .trie-visual {\n    margin-top: 2rem;\n  }\n  .node {\n    display: inline-block;\n    margin: 0 6px;\n    text-align: center;\n  }\n  .node-circle {\n    width: 30px;\n    height: 30px;\n    border: 2px solid #007bff;\n    border-radius: 50%;\n    line-height: 28px;\n    font-weight: bold;\n    color: #007bff;\n    margin-bottom: 3px;\n    position: relative;\n  }\n  .node-circle.end {\n    background-color: #007bff;\n    color: white;\n  }\n  .branches {\n    display: flex;\n    justify-content: center;\n    margin-top: 0;\n  }\n  .branch-line {\n    width: 2px;\n    background-color: #007bff;\n    margin: 0 auto;\n  }\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Trie Data Structure Demo</h1>\n    <p>A <strong>Trie</strong> (prefix tree) is a tree data structure used primarily for storing strings in a way that facilitates efficient prefix queries. This interactive demo shows how you can <em>insert</em>, <em>search</em>, and <em>check prefixes</em> with a Trie.</p>\n    \n    <label for=\"insertWord\">Insert word into Trie:</label>\n    <input type=\"text\" id=\"insertWord\" placeholder=\"Enter a word to insert\" />\n    <button id=\"insertBtn\">Insert</button>\n    \n    <label for=\"searchWord\">Search word in Trie:</label>\n    <input type=\"text\" id=\"searchWord\" placeholder=\"Enter a word to search\" />\n    <button id=\"searchBtn\">Search</button>\n    <div id=\"searchResult\" class=\"result\"></div>\n    \n    <label for=\"prefixWord\">Check if prefix exists:</label>\n    <input type=\"text\" id=\"prefixWord\" placeholder=\"Enter a prefix to check\" />\n    <button id=\"prefixBtn\">Check Prefix</button>\n    <div id=\"prefixResult\" class=\"result\"></div>\n    \n    <h2>Current Trie Structure</h2>\n    <div id=\"trieOutput\" class=\"output\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n    <h2>Trie Visualization (letters & branches)</h2>\n    <div id=\"trieVisual\" class=\"trie-visual\" aria-label=\"Trie visual representation\"></div>\n  </div>\n\n<script>\n  // Trie Node class\n  class TrieNode {\n    constructor() {\n      this.children = new Map();\n      this.isEndOfWord = false;\n    }\n  }\n  \n  // Trie class\n  class Trie {\n    constructor() {\n      this.root = new TrieNode();\n    }\n    \n    insert(word) {\n      let node = this.root;\n      for (let char of word) {\n        if (!node.children.has(char)) {\n          node.children.set(char, new TrieNode());\n        }\n        node = node.children.get(char);\n      }\n      node.isEndOfWord = true;\n    }\n    \n    search(word) {\n      let node = this.root;\n      for (let char of word) {\n        if (!node.children.has(char)) {\n          return false;\n        }\n        node = node.children.get(char);\n      }\n      return node.isEndOfWord;\n    }\n\n    startsWith(prefix) {\n      let node = this.root;\n      for (let char of prefix) {\n        if (!node.children.has(char)) {\n          return false;\n        }\n        node = node.children.get(char);\n      }\n      return true;\n    }\n\n    // Helper method to pretty print the trie in a nested manner\n    toObject(node = this.root) {\n      let obj = {};\n      for (let [char, child] of node.children.entries()) {\n        obj[char] = this.toObject(child);\n        if (child.isEndOfWord) {\n          obj[char].isEndOfWord = true;\n        }\n      }\n      if (node.isEndOfWord && Object.keys(obj).length === 0) {\n        // Leaf node and end of word\n        return { isEndOfWord: true };\n      }\n      // If no children and not end of word, show empty\n      return obj;\n    }\n  }\n\n  // Instantiate the trie\n  const trie = new Trie();\n\n  // Utility: Display trie as indented JSON-like string\n  function formatTrie(obj, indent = 0) {\n    let spacing = '  '.repeat(indent);\n    if (typeof obj !== 'object' || obj === null) {\n      return '';\n    }\n    let lines = [];\n    for (let key in obj) {\n      if (key === 'isEndOfWord') continue;\n      let suffix = obj[key].isEndOfWord ? ' *' : '';\n      if (Object.keys(obj[key]).length === (obj[key].isEndOfWord ? 1 : 0)) {\n        // No children except possibly isEndOfWord\n        lines.push(`${spacing}${key}${suffix}`);\n      } else {\n        lines.push(`${spacing}${key}${suffix}`);\n        lines.push(formatTrie(obj[key], indent + 1));\n      }\n    }\n    return lines.join('\\n');\n  }\n\n  // Visualize the trie as nested circles with branches\n  function visualizeTrie(node, depth = 0) {\n    if (!node) return null;\n\n    // Create container for this level\n    const container = document.createElement('div');\n    container.style.display = 'flex';\n    container.style.justifyContent = depth === 0 ? 'center' : 'flex-start';\n    container.style.marginTop = depth === 0 ? '0' : '20px';\n\n    // For root, we will just show a hollow circle\n    if (depth === 0) {\n      const rootNode = document.createElement('div');\n      rootNode.classList.add('node');\n      const rootCircle = document.createElement('div');\n      rootCircle.classList.add('node-circle');\n      rootCircle.title = \"Root\";\n      rootNode.appendChild(rootCircle);\n      container.appendChild(rootNode);\n\n      // Recursive subtree\n      const branches = visualizeTrieSubNodes(node.children);\n      if (branches) {\n        container.appendChild(branches);\n      }\n      return container;\n    } else {\n      return visualizeTrieSubNodes(node.children);\n    }\n  }\n\n  function visualizeTrieSubNodes(childrenMap) {\n    if (childrenMap.size === 0) return null;\n    // Container for nodes\n    const container = document.createElement('div');\n    container.style.display = 'flex';\n    container.style.justifyContent = 'center';\n    container.style.gap = '20px';\n    container.style.marginTop = '10px';\n\n    for (let [char, node] of childrenMap.entries()) {\n      const nodeDiv = document.createElement('div');\n      nodeDiv.classList.add('node');\n\n      const circleDiv = document.createElement('div');\n      circleDiv.classList.add('node-circle');\n      if (node.isEndOfWord) circleDiv.classList.add('end');\n      circleDiv.textContent = char;\n      circleDiv.title = node.isEndOfWord \n        ? `Character: '${char}', End of word` \n        : `Character: '${char}'`;\n      nodeDiv.appendChild(circleDiv);\n\n      // Recursively append children\n      const subBranches = visualizeTrieSubNodes(node.children);\n      if (subBranches) {\n        nodeDiv.appendChild(subBranches);\n      }\n\n      container.appendChild(nodeDiv);\n    }\n    return container;\n  }\n\n  // DOM references\n  const insertWordInput = document.getElementById('insertWord');\n  const insertBtn = document.getElementById('insertBtn');\n  const searchWordInput = document.getElementById('searchWord');\n  const searchBtn = document.getElementById('searchBtn');\n  const searchResult = document.getElementById('searchResult');\n  const prefixWordInput = document.getElementById('prefixWord');\n  const prefixBtn = document.getElementById('prefixBtn');\n  const prefixResult = document.getElementById('prefixResult');\n  const trieOutput = document.getElementById('trieOutput');\n  const trieVisual = document.getElementById('trieVisual');\n\n  // Function to update the textual and visual displays of the trie\n  function updateTrieDisplay() {\n    const obj = trie.toObject();\n    if (Object.keys(obj).length === 0) {\n      trieOutput.textContent = \"(empty trie)\";\n      trieVisual.innerHTML = '';\n    } else {\n      trieOutput.textContent = formatTrie(obj) || \"(empty)\";\n      trieVisual.innerHTML = '';\n      const visualTree = visualizeTrie(trie.root);\n      if (visualTree) {\n        trieVisual.appendChild(visualTree);\n      }\n    }\n  }\n\n  // Insert button handler\n  insertBtn.addEventListener('click', () => {\n    const word = insertWordInput.value.trim().toLowerCase();\n    if (!word.match(/^[a-z]+$/)) {\n      alert(\"Please enter a non-empty word with only letters a-z.\");\n      return;\n    }\n    trie.insert(word);\n    insertWordInput.value = '';\n    insertWordInput.focus();\n    updateTrieDisplay();\n  });\n\n  // Search button handler\n  searchBtn.addEventListener('click', () => {\n    const word = searchWordInput.value.trim().toLowerCase();\n    if (!word.match(/^[a-z]+$/)) {\n      searchResult.textContent = \"Please enter a non-empty word with only letters a-z.\";\n      return;\n    }\n    const found = trie.search(word);\n    searchResult.textContent = found ? `'${word}' is in the Trie.` : `'${word}' NOT found in the Trie.`;\n  });\n\n  // Prefix button handler\n  prefixBtn.addEventListener('click', () => {\n    const prefix = prefixWordInput.value.trim().toLowerCase();\n    if (!prefix.match(/^[a-z]+$/)) {\n      prefixResult.textContent = \"Please enter a non-empty prefix with only letters a-z.\";\n      return;\n    }\n    const hasPrefix = trie.startsWith(prefix);\n    prefixResult.textContent = hasPrefix ? `There is at least one word starting with '${prefix}'.` : `No words start with '${prefix}'.`;\n  });\n\n  // Initial display\n  updateTrieDisplay();\n\n</script>\n</body>\n</html>"
