    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Sliding Window Visualization</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 20px;\n      background: #f0f2f5;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n    }\n    .container {\n      max-width: 800px;\n      margin: 0 auto;\n    }\n    .array-container {\n      display: flex;\n      justify-content: center;\n      margin: 20px 0;\n      flex-wrap: wrap;\n    }\n    .array-element {\n      width: 40px;\n      height: 40px;\n      line-height: 40px;\n      margin: 3px;\n      background: #ddd;\n      text-align: center;\n      border-radius: 5px;\n      font-weight: bold;\n      position: relative;\n      user-select: none;\n    }\n    .array-element.window {\n      background: #4a90e2;\n      color: white;\n      font-weight: bold;\n      box-shadow: 0 0 10px #4a90e2;\n    }\n    .controls {\n      text-align: center;\n      margin: 20px 0;\n    }\n    input[type=\"number\"] {\n      width: 60px;\n      font-size: 16px;\n      padding: 5px;\n      margin-left: 10px;\n    }\n    button {\n      font-size: 16px;\n      padding: 8px 16px;\n      margin-left: 10px;\n      cursor: pointer;\n      border: none;\n      border-radius: 5px;\n      background: #4a90e2;\n      color: white;\n      transition: background 0.3s ease;\n    }\n    button:disabled {\n      background: #9bbce5;\n      cursor: not-allowed;\n    }\n    button:hover:not(:disabled) {\n      background: #357ABD;\n    }\n    .output {\n      text-align: center;\n      font-size: 18px;\n      margin-top: 15px;\n    }\n    .explanation {\n      background: white;\n      padding: 15px 25px;\n      border-radius: 8px;\n      box-shadow: 0 4px 10px rgb(0 0 0 / 0.1);\n      margin-bottom: 30px;\n    }\n    code {\n      background: #eee;\n      padding: 2px 5px;\n      border-radius: 3px;\n      font-family: Consolas, monospace;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Sliding Window Technique Visualization</h1>\n    <div class=\"explanation\">\n      <p>\n        The <strong>Sliding Window</strong> technique is a method for efficiently solving problems that involve arrays or sequences.\n        It involves creating a \"window\" (a subset of elements) which slides over the data structure to examine a range of elements\n        without having to repeatedly recalculate everything.\n      </p>\n      <p>\n        Here we demonstrate finding the <strong>maximum sum of any contiguous subarray of size <code>k</code></strong> using a sliding window.\n      </p>\n      <p>\n        Enter the window size <code>k</code> and press \"Next Step\" to move the window forward one position.\n      </p>\n    </div>\n\n    <div class=\"array-container\" id=\"arrayContainer\"></div>\n\n    <div class=\"controls\">\n      <label for=\"windowSize\">Window size (k):</label>\n      <input type=\"number\" id=\"windowSize\" min=\"1\" max=\"10\" value=\"3\" />\n      <button id=\"startBtn\">Start</button>\n      <button id=\"nextStepBtn\" disabled>Next Step</button>\n      <button id=\"resetBtn\" disabled>Reset</button>\n    </div>\n\n    <div class=\"output\" id=\"outputArea\"></div>\n  </div>\n\n  <script>\n    // Sample data array\n    const data = [2, 1, 5, 1, 3, 2, 8, 1, 2, 6];\n\n    const arrayContainer = document.getElementById('arrayContainer');\n    const windowSizeInput = document.getElementById('windowSize');\n    const startBtn = document.getElementById('startBtn');\n    const nextStepBtn = document.getElementById('nextStepBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const outputArea = document.getElementById('outputArea');\n\n    let k = 3;              // window size\n    let start = 0;          // start index of window\n    let end = 0;            // end index of window\n    let maxSum = -Infinity; // max sum found so far\n    let currSum = 0;\n    let sliding = false;\n\n    function renderArray() {\n      arrayContainer.innerHTML = '';\n      data.forEach((value, idx) => {\n        const el = document.createElement('div');\n        el.classList.add('array-element');\n        el.textContent = value;\n        if (sliding && idx >= start && idx < end) {\n          el.classList.add('window');\n        }\n        if (sliding && idx === end - 1) {\n          const pointer = document.createElement('div');\n          pointer.style.position = 'absolute';\n          pointer.style.bottom = '-18px';\n          pointer.style.left = '50%';\n          pointer.style.transform = 'translateX(-50%)';\n          pointer.style.fontSize = '16px';\n          pointer.style.fontWeight = 'bold';\n          pointer.style.color = '#4a90e2';\n          pointer.textContent = '↑';\n          el.appendChild(pointer);\n        }\n        arrayContainer.appendChild(el);\n      });\n    }\n\n    function reset() {\n      k = parseInt(windowSizeInput.value);\n      if (isNaN(k) || k < 1 || k > data.length) {\n        alert(`Please enter a valid window size between 1 and ${data.length}`);\n        return false;\n      }\n      start = 0;\n      end = k;\n      maxSum = -Infinity;\n      currSum = 0;\n      sliding = true;\n      outputArea.textContent = '';\n      startBtn.disabled = true;\n      nextStepBtn.disabled = false;\n      resetBtn.disabled = false;\n\n      // Compute initial window sum\n      currSum = 0;\n      for(let i = start; i < end; i++) {\n        currSum += data[i];\n      }\n      if(currSum > maxSum) maxSum = currSum;\n      outputArea.textContent = `Initial window [${start}..${end-1}] sum = ${currSum}. Max sum so far = ${maxSum}.`;\n      renderArray();\n      return true;\n    }\n\n    function nextStep() {\n      if (end >= data.length) {\n        outputArea.textContent += `\\nReached end of array. Maximum sum of subarray of size ${k} is ${maxSum}.`;\n        nextStepBtn.disabled = true;\n        return;\n      }\n      // Slide window by one position: remove data[start], add data[end]\n      currSum = currSum - data[start] + data[end];\n      start++;\n      end++;\n\n      if(currSum > maxSum){\n        maxSum = currSum;\n      }\n\n      outputArea.textContent = `Window [${start}..${end-1}] sum = ${currSum}. Max sum so far = ${maxSum}.`;\n      renderArray();\n\n      if (end === data.length) {\n        outputArea.textContent += `\\nReached end of array. Maximum sum of subarray of size ${k} is ${maxSum}.`;\n        nextStepBtn.disabled = true;\n      }\n    }\n\n    startBtn.addEventListener('click', () => {\n      if(reset()) {\n        nextStepBtn.disabled = false;\n        resetBtn.disabled = false;\n        startBtn.disabled = true;\n        windowSizeInput.disabled = true;\n      }\n    });\n\n    nextStepBtn.addEventListener('click', () => {\n      nextStep();\n    });\n\n    resetBtn.addEventListener('click', () => {\n      // Reset state and UI\n      sliding = false;\n      start = 0;\n      end = 0;\n      maxSum = -Infinity;\n      currSum = 0;\n      outputArea.textContent = '';\n      startBtn.disabled = false;\n      nextStepBtn.disabled = true;\n      resetBtn.disabled = true;\n      windowSizeInput.disabled = false;\n      renderArray();\n    });\n\n    // Initialize\n    renderArray();\n  </script>\n</body>\n</html>"
