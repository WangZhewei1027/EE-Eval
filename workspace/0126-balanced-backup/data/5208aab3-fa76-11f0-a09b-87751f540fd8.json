    "content": "<html>\n<head>\n    <title>Bubble Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #bubble-sort {\n            width: 50%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n    </style>\n</head>\n<body>\n    <div id=\"bubble-sort\">\n        <h2>Bubble Sort</h2>\n        <p>Original List: <pre><code class=\"list\">[8, 3, 4, 2, 1, 6, 5, 7, 9]</code></pre></p>\n        <button onclick=\"bubbleSort(8, 3, 4, 2, 1, 6, 5, 7, 9)\">Sort</button>\n        <p>Sorted List: <pre><code class=\"list\">[1, 2, 3, 4, 5, 6, 7, 8, 9]</code></pre></p>\n    </div>\n\n    <script>\n        function bubbleSort(arr) {\n            let n = arr.length;\n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j < n - i - 1; j++) {\n                    if (arr[j] > arr[j + 1]) {\n                        // Swap arr[j] and arr[j+1]\n                        [arr[j], arr[j + 1]] = [arr[j + 1], arr[j]];\n                        console.log(`Swapped ${arr[j]} and ${arr[j + 1]}`);\n                    }\n                }\n            }\n            return arr;\n        }\n\n        let arr = [8, 3, 4, 2, 1, 6, 5, 7, 9];\n        console.log(\"Original List:\", arr);\n        bubbleSort(arr);\n        console.log(\"Sorted List:\", arr);\n    </script>\n</body>\n</html>"
