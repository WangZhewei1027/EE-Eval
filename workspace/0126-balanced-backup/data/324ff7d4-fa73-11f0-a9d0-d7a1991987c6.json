    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Support Vector Machine Demo</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <style>\n        canvas {\n            max-width: 600px;\n            margin: 20px auto;\n        }\n        .controls {\n            text-align: center;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Support Vector Machine Demo</h1>\n    <canvas id=\"scatterChart\"></canvas>\n    <div class=\"controls\">\n        <button onclick=\"generateData()\">Generate Data</button>\n    </div>\n\n    <script>\n        let dataPoints = [];\n        const chartCtx = document.getElementById('scatterChart').getContext('2d');\n        let scatterChart;\n\n        function generateData() {\n            dataPoints = [];\n            for (let i = 0; i < 50; i++) {\n                dataPoints.push({\n                    x: Math.random() * 10,\n                    y: Math.random() * 10,\n                    label: 0 // Class 0\n                });\n                dataPoints.push({\n                    x: Math.random() * 10 + 5,\n                    y: Math.random() * 10 + 5,\n                    label: 1 // Class 1\n                });\n            }\n            drawChart();\n        }\n\n        function drawChart() {\n            const labels = dataPoints.map(p => `(${p.x.toFixed(2)}, ${p.y.toFixed(2)})`);\n            const datasets = [\n                {\n                    label: 'Class 0',\n                    data: dataPoints.filter(dp => dp.label === 0).map(dp => ({ x: dp.x, y: dp.y })),\n                    backgroundColor: 'rgba(75, 192, 192, 0.6)',\n                    borderColor: 'rgba(75, 192, 192, 1)',\n                    pointRadius: 5,\n                },\n                {\n                    label: 'Class 1',\n                    data: dataPoints.filter(dp => dp.label === 1).map(dp => ({ x: dp.x, y: dp.y })),\n                    backgroundColor: 'rgba(255, 99, 132, 0.6)',\n                    borderColor: 'rgba(255, 99, 132, 1)',\n                    pointRadius: 5,\n                }\n            ];\n\n            if (scatterChart) {\n                scatterChart.destroy();\n            }\n          \n            scatterChart = new Chart(chartCtx, {\n                type: 'scatter',\n                data: {\n                    datasets: datasets,\n                },\n                options: {\n                    responsive: true,\n                    scales: {\n                        x: {\n                            title: {\n                                display: true,\n                                text: 'Feature 1'\n                            },\n                        },\n                        y: {\n                            title: {\n                                display: true,\n                                text: 'Feature 2'\n                            },\n                        }\n                    },\n                    plugins: {\n                        legend: {\n                            display: true,\n                            position: 'top',\n                        }\n                    }\n                },\n            });\n        }\n\n        // Initial data generation\n        generateData();\n    </script>\n</body>\n</html>"
