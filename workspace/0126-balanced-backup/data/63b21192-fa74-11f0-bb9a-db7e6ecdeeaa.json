    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Branch and Bound Demonstration - Knapsack Problem</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f2f5;\n  }\n  h1 {\n    text-align: center;\n  }\n  #knapsack-table {\n    border-collapse: collapse;\n    margin: 1rem 0;\n    width: 100%;\n    max-width: 600px;\n  }\n  #knapsack-table th, #knapsack-table td {\n    border: 1px solid #bbb;\n    padding: 0.5rem 0.75rem;\n    text-align: center;\n  }\n  #output {\n    margin-top: 1rem;\n    white-space: pre-wrap;\n    background: #fff;\n    padding: 1rem;\n    border-radius: 5px;\n    max-height: 400px;\n    overflow-y: scroll;\n    font-family: monospace;\n  }\n  button {\n    background-color: #007bff; \n    color: white;\n    border: none;\n    padding: 0.6rem 1rem;\n    border-radius: 4px;\n    cursor: pointer;\n    font-size: 1rem;\n    margin-top: 1rem;\n  }\n  button:disabled {\n    background-color: #999;\n    cursor: default;\n  }\n  #controls {\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n\n<h1>Branch and Bound Demo: 0/1 Knapsack Problem</h1>\n\n<p>This demo illustrates the Branch and Bound technique on a classic 0/1 knapsack problem.</p>\n\n<table id=\"knapsack-table\" aria-label=\"Items for knapsack problem\">\n  <thead>\n    <tr>\n      <th>Item #</th>\n      <th>Weight</th>\n      <th>Value</th>\n      <th>Value / Weight</th>\n    </tr>\n  </thead>\n  <tbody id=\"items-body\"></tbody>\n</table>\n\n<div id=\"controls\">\n  <button id=\"start-btn\">Start Branch and Bound</button>\n</div>\n\n<pre id=\"output\" aria-live=\"polite\" aria-label=\"Branch and Bound step by step output\"></pre>\n\n<script>\n  (function(){\n    // Items for the knapsack problem (weight,value)\n    const items = [\n      {weight: 2, value: 40},\n      {weight: 3.14, value: 50},\n      {weight: 1.98, value: 100},\n      {weight: 5, value: 95},\n      {weight: 3, value: 30}\n    ];\n\n    // Maximum weight capacity\n    const maxWeight = 10;\n\n    const itemsBody = document.getElementById('items-body');\n    const output = document.getElementById('output');\n    const startBtn = document.getElementById('start-btn');\n\n    // Add items to table sorted by value/weight ratio descending\n    const itemsWithRatio = items.map((it, idx) => ({\n      ...it,\n      index: idx,\n      ratio: it.value / it.weight\n    })).sort((a,b) => b.ratio - a.ratio);\n\n    function renderItems() {\n      itemsBody.innerHTML = '';\n      itemsWithRatio.forEach(({index, weight, value, ratio}) => {\n        const row = document.createElement('tr');\n        row.innerHTML = `\n          <td>${index + 1}</td>\n          <td>${weight.toFixed(2)}</td>\n          <td>${value}</td>\n          <td>${ratio.toFixed(2)}</td>\n        `;\n        itemsBody.appendChild(row);\n      });\n    }\n\n    // Node class for Branch and Bound tree\n    class Node {\n      constructor(level = -1, profit = 0, weight = 0, bound = 0, contains = []) {\n        this.level = level;       // index of last item considered\n        this.profit = profit;     // total value so far\n        this.weight = weight;     // total weight so far\n        this.bound = bound;       // upper bound of total profit in subtree\n        this.contains = contains; // array of booleans if item included\n      }\n    }\n\n    // Compute upper bound on profit in subtree rooted at node\n    // Using fractional knapsack approach\n    function bound(node) {\n      if (node.weight >= maxWeight) return 0; // infeasible\n\n      let profitBound = node.profit;\n      let j = node.level + 1;\n      let totweight = node.weight;\n\n      // add items fractionally starting from j\n      while (j < itemsWithRatio.length && totweight + itemsWithRatio[j].weight <= maxWeight) {\n        totweight += itemsWithRatio[j].weight;\n        profitBound += itemsWithRatio[j].value;\n        j++;\n      }\n\n      // if j is not out of range, add fraction of next item\n      if (j < itemsWithRatio.length) {\n        const remain = maxWeight - totweight;\n        profitBound += itemsWithRatio[j].ratio * remain;\n      }\n\n      return profitBound;\n    }\n\n    // Branch and Bound algorithm for Knapsack\n    // Will step through the algorithm showing nodes explored\n    async function branchAndBound() {\n      output.textContent = '';\n      startBtn.disabled = true;\n      // Priority queue for live nodes - sorted by bound descending (max heap)\n      let Q = [];\n\n      let u = new Node();\n      let v = new Node();\n\n      let maxProfit = 0;\n      let bestItems = [];\n\n      u.bound = bound(u);\n\n      function printNode(n, msg) {\n        const level = n.level >= 0 ? n.level + 1 : \"start\";\n        output.textContent += `[Level: ${level}] Profit: ${n.profit}, Weight: ${n.weight.toFixed(2)}, Bound: ${n.bound.toFixed(2)}\\n`;\n        if(msg) output.textContent += `  ${msg}\\n`;\n      }\n\n      // Initialize queue\n      Q.push(u);\n\n      while(Q.length > 0) {\n        // Sort Q by decreasing bound to behave like a max priority queue\n        Q.sort((a,b) => b.bound - a.bound);\n        u = Q.shift(); // node with best bound\n\n        printNode(u, \"Popped node from queue.\");\n\n        if(u.bound > maxProfit && u.level < itemsWithRatio.length - 1) {\n          // Next item index\n          const idx = u.level + 1;\n\n          // Check taking the next item\n          v.level = idx;\n          v.weight = u.weight + itemsWithRatio[idx].weight;\n          v.profit = u.profit + itemsWithRatio[idx].value;\n          v.contains = u.contains.slice();\n          v.contains[idx] = true;\n\n          if(v.weight <= maxWeight && v.profit > maxProfit) {\n            maxProfit = v.profit;\n            bestItems = v.contains.slice();\n            printNode(v, `Found new max profit with item #${itemsWithRatio[idx].index+1} included.`);\n          }\n\n          v.bound = bound(v);\n          if(v.bound > maxProfit) {\n            Q.push(new Node(v.level, v.profit, v.weight, v.bound, v.contains));\n            printNode(v, \"Adding node with item included to queue.\");\n          } else {\n            printNode(v, \"Pruned node with item included (bound <= maxProfit).\");\n          }\n\n          // Check NOT taking the next item\n          v.weight = u.weight;\n          v.profit = u.profit;\n          v.contains = u.contains.slice();\n          v.contains[idx] = false;\n          v.bound = bound(v);\n\n          if(v.bound > maxProfit) {\n            Q.push(new Node(v.level, v.profit, v.weight, v.bound, v.contains));\n            printNode(v, \"Adding node without item to queue.\");\n          } else {\n            printNode(v, \"Pruned node without item (bound <= maxProfit).\");\n          }\n        } else {\n          if(u.bound <= maxProfit) {\n            printNode(u, \"Pruned node (bound <= maxProfit).\");\n          }\n        }\n        output.scrollTop = output.scrollHeight;\n        await new Promise(r => setTimeout(r, 700)); // pause for visualization\n      }\n\n      // Show final solution items in original order\n      const solution = Array(items.length).fill(false);\n      bestItems.forEach((included, idx) => {\n        if(included) {\n          // item index from sorted list to original index\n          solution[itemsWithRatio[idx].index] = true;\n        }\n      });\n\n      output.textContent += '\\n=== Optimal Solution ===\\n';\n      let totalWeight = 0;\n      let totalValue = 0;\n      solution.forEach((inc, i) => {\n        if(inc) {\n          output.textContent += `Item #${i+1} INCLUDED (Weight: ${items[i].weight}, Value: ${items[i].value})\\n`;\n          totalWeight += items[i].weight;\n          totalValue += items[i].value;\n        } else {\n          output.textContent += `Item #${i+1} excluded\\n`;\n        }\n      });\n      output.textContent += `\\nTotal Weight: ${totalWeight.toFixed(2)} / Capacity: ${maxWeight}\\n`;\n      output.textContent += `Total Value: ${totalValue}\\n`;\n\n      startBtn.disabled = false;\n    }\n\n    renderItems();\n\n    startBtn.addEventListener('click', branchAndBound);\n  })();\n</script>\n\n</body>\n</html>"
  },
