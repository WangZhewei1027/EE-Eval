  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<title>Branch and Bound Demo — 0/1 Knapsack</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<style>\n  :root{\n    --bg:#f6f8fa;\n    --panel:#ffffff;\n    --muted:#667085;\n    --accent:#0b69ff;\n    --good:#1b9a59;\n    --bad:#e0423b;\n    --pruned:#db3f5b;\n    --node-size:52px;\n  }\n  html,body{height:100%;margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n  body{background:var(--bg);color:#0f1724;display:flex;flex-direction:column;align-items:stretch;}\n  header{padding:16px 20px;border-bottom:1px solid rgba(15,23,36,0.06);background:white;display:flex;align-items:center;gap:16px;}\n  header h1{font-size:18px;margin:0;}\n  main{display:flex;gap:16px;padding:16px;flex:1;overflow:hidden;}\n  .left,.right{background:var(--panel);border-radius:10px;padding:12px;box-shadow:0 1px 2px rgba(16,24,40,0.03);overflow:auto;}\n  .left{flex:2;min-width:520px;display:flex;flex-direction:column;gap:10px;}\n  .right{flex:1;min-width:320px;}\n  .controls{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}\n  button{padding:8px 10px;border-radius:8px;border:1px solid rgba(15,23,36,0.08);background:white;cursor:pointer;}\n  button.primary{background:var(--accent);color:white;border:none;}\n  button.warn{background:var(--pruned);color:white;border:none;}\n  input[type=\"number\"]{width:72px;padding:6px;border-radius:8px;border:1px solid rgba(15,23,36,0.08);}\n  label{font-size:13px;color:var(--muted);}\n  .settings{display:flex;gap:12px;align-items:center;flex-wrap:wrap;}\n  .items-list{display:flex;flex-direction:column;gap:6px;padding:6px;border-radius:8px;background:#fbfdff;border:1px solid rgba(11,105,255,0.06);}\n  .items-list .row{display:flex;gap:8px;align-items:center;}\n  .items-list .badge{font-weight:600;background:#eef6ff;padding:6px 8px;border-radius:8px;border:1px solid rgba(11,105,255,0.06);}\n  .panel-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}\n  .svg-wrap{flex:1;border-radius:10px;background:white;padding:8px;display:flex;flex-direction:column;}\n  .canvas{flex:1;border:1px dashed rgba(2,6,23,0.06);border-radius:8px;background:linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);overflow:auto;position:relative;}\n  svg{width:100%;height:620px;display:block;}\n  .legend{display:flex;gap:8px;align-items:center;flex-wrap:wrap;font-size:13px;margin-top:6px;}\n  .legend .dot{width:12px;height:12px;border-radius:3px;display:inline-block;margin-right:6px;}\n  .status-box{padding:8px;border-radius:8px;background:#fbfbff;border:1px solid rgba(2,6,23,0.04);font-size:13px;}\n  .log{height:180px;overflow:auto;border-radius:8px;padding:8px;background:#0f172422;font-family:monospace;color:#0b1221;}\n  .pq-list{max-height:200px;overflow:auto;}\n  .small{font-size:12px;color:var(--muted);}\n  .node-label{font-size:11px;pointer-events:none;}\n  .controls-row{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}\n  .slider{width:180px;}\n  .sol-items{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;}\n  .pill{padding:6px 8px;border-radius:999px;background:#fff;border:1px solid rgba(11,105,255,0.06);font-weight:600;}\n  footer{padding:10px 16px;font-size:12px;color:var(--muted);text-align:center;}\n  /* Node tooltip */\n  .tooltip{position:absolute;padding:8px;background:white;border-radius:8px;border:1px solid rgba(2,6,23,0.08);font-size:13px;pointer-events:none;box-shadow:0 6px 18px rgba(2,6,23,0.08);display:none;z-index:1000;}\n</style>\n</head>\n<body>\n<header>\n  <h1>Branch and Bound — 0/1 Knapsack (Interactive Demo)</h1>\n  <div class=\"small\" style=\"margin-left:auto;\">Concept: construct search tree, compute optimistic bound (fractional knapsack), use bound to prune branches.</div>\n</header>\n\n<main>\n  <div class=\"left\">\n    <div class=\"panel-title\">\n      <strong>Search Visualization</strong>\n      <div class=\"controls\">\n        <div class=\"settings\">\n          <label class=\"small\">Items:\n            <input id=\"numItems\" type=\"number\" min=\"3\" max=\"10\" value=\"6\" />\n          </label>\n          <label class=\"small\">Capacity:\n            <input id=\"capacityInput\" type=\"number\" min=\"1\" value=\"15\" />\n          </label>\n          <button id=\"randomBtn\">Randomize</button>\n        </div>\n        <button id=\"resetBtn\">Reset</button>\n        <button id=\"stepBtn\">Step</button>\n        <button id=\"playBtn\" class=\"primary\">Auto Play</button>\n        <button id=\"pauseBtn\" style=\"display:none;\">Pause</button>\n        <button id=\"runBtn\" class=\"primary\">Run to End</button>\n        <button id=\"solveBtn\">Solve (fast)</button>\n      </div>\n    </div>\n\n    <div class=\"svg-wrap\">\n      <div class=\"canvas\" id=\"canvasWrap\">\n        <svg id=\"svgCanvas\" viewBox=\"0 0 1200 620\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n        <div id=\"tooltip\" class=\"tooltip\"></div>\n      </div>\n\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:8px;\">\n        <div class=\"legend\">\n          <div><span class=\"dot\" style=\"background:#bfe1ff;\"></span>Open (in PQ)</div>\n          <div><span class=\"dot\" style=\"background:#57b894;\"></span>Expanded</div>\n          <div><span class=\"dot\" style=\"background:#ffb86b;\"></span>Popped (processing)</div>\n          <div><span class=\"dot\" style=\"background:#e06b78;\"></span>Pruned</div>\n          <div><span class=\"dot\" style=\"background:#ffd166;\"></span>Best solution leaf</div>\n        </div>\n        <div class=\"small\">Tip: hover nodes for details. Nodes show profit/weight/bound.</div>\n      </div>\n    </div>\n\n    <div style=\"display:flex;gap:12px;margin-top:10px;\">\n      <div style=\"flex:1;\">\n        <div class=\"panel-title\"><strong>Priority Queue (Open Nodes)</strong><span class=\"small\">Sorted by bound (desc)</span></div>\n        <div class=\"pq-list status-box\" id=\"pqBox\"></div>\n      </div>\n      <div style=\"width:280px;\">\n        <div class=\"panel-title\"><strong>Status</strong></div>\n        <div class=\"status-box\">\n          <div><strong>Best Profit:</strong> <span id=\"bestProfit\">0</span></div>\n          <div><strong>Best Solution:</strong></div>\n          <div class=\"sol-items\" id=\"bestSol\"></div>\n          <div style=\"margin-top:8px;\"><strong>Current Node:</strong> <span id=\"currentNode\">-</span></div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"right\">\n    <div class=\"panel-title\"><strong>Problem & Bounds</strong>\n      <div class=\"small\">Items sorted by value/weight ratio (used for bound)</div>\n    </div>\n\n    <div class=\"items-list\" id=\"itemsList\"></div>\n\n    <div style=\"margin-top:12px;\">\n      <div class=\"panel-title\"><strong>Logs</strong></div>\n      <div class=\"log\" id=\"log\"></div>\n    </div>\n\n    <div style=\"margin-top:12px;\">\n      <div class=\"panel-title\"><strong>Controls</strong></div>\n      <div class=\"controls-row\">\n        <label class=\"small\">Speed:\n          <input id=\"speed\" class=\"slider\" type=\"range\" min=\"100\" max=\"2000\" value=\"600\" />\n        </label>\n        <button id=\"explainBtn\">Explain Step</button>\n      </div>\n    </div>\n\n  </div>\n</main>\n\n<footer>\n  This interactive demo implements Branch and Bound for the 0/1 knapsack: nodes are states (level, profit, weight) and we compute an optimistic bound using the fractional knapsack. Nodes with bound <= current best are pruned.\n</footer>\n\n<script>\n(() => {\n  // Utility functions\n  function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n  function formatPath(path){\n    return path.map(x=> x===1 ? \"1\" : x===0 ? \"0\" : \"-\").join(\"\");\n  }\n\n  // DOM elements\n  const svg = document.getElementById('svgCanvas');\n  const pqBox = document.getElementById('pqBox');\n  const itemsList = document.getElementById('itemsList');\n  const logDiv = document.getElementById('log');\n  const bestProfitSpan = document.getElementById('bestProfit');\n  const bestSolDiv = document.getElementById('bestSol');\n  const currentNodeSpan = document.getElementById('currentNode');\n  const tooltip = document.getElementById('tooltip');\n\n  const numItemsInput = document.getElementById('numItems');\n  const capacityInput = document.getElementById('capacityInput');\n  const randomBtn = document.getElementById('randomBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const playBtn = document.getElementById('playBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const runBtn = document.getElementById('runBtn');\n  const solveBtn = document.getElementById('solveBtn');\n  const speedSlider = document.getElementById('speed');\n  const explainBtn = document.getElementById('explainBtn');\n\n  // State\n  let items = [];\n  let n = 6;\n  let capacity = 15;\n  let nodeIdCounter = 0;\n  let nodes = []; // flat list for visualization\n  let pq = []; // priority queue (array sorted by bound desc)\n  let bestProfit = 0;\n  let bestNode = null;\n  let runningInterval = null;\n  let playMode = false;\n  let countsAtLevel = [];\n  let maxLevels = 0;\n  let viewBoxW = 1200, viewBoxH = 620;\n\n  // Colors for statuses\n  const colors = {\n    open: \"#bfe1ff\",\n    expanded: \"#57b894\",\n    popped: \"#ffb86b\",\n    pruned: \"#e06b78\",\n    best: \"#ffd166\",\n    defaultText: \"#05204a\"\n  };\n\n  function log(...args){\n    const t = new Date().toLocaleTimeString();\n    logDiv.innerHTML = `<div>[${t}] ${args.join(\" \")}</div>` + logDiv.innerHTML;\n  }\n\n  // Create random items\n  function genItems(m, maxW=10, maxV=20){\n    const arr = [];\n    for(let i=0;i<m;i++){\n      const w = randInt(1, maxW);\n      const v = randInt(1, maxV);\n      arr.push({id:i+1, weight:w, value:v, ratio: v/w});\n    }\n    // Sort by ratio descending for bound computation and branching order\n    arr.sort((a,b)=> b.ratio - a.ratio || b.value - a.value);\n    return arr;\n  }\n\n  // Bound calculation using fractional knapsack on sorted remaining items\n  function boundFrom(node){\n    // node.level is index of next item to consider\n    if(node.weight > capacity) return 0;\n    let profitBound = node.profit;\n    let j = node.level;\n    let totWeight = node.weight;\n    while(j < n && totWeight < capacity){\n      const it = items[j];\n      if(totWeight + it.weight <= capacity){\n        totWeight += it.weight;\n        profitBound += it.value;\n      } else {\n        // fractional\n        const remain = capacity - totWeight;\n        profitBound += it.ratio * remain;\n        totWeight = capacity;\n        break;\n      }\n      j++;\n    }\n    return profitBound;\n  }\n\n  // Node factory\n  function createNode(parentId, level, profit, weight, path){\n    const id = ++nodeIdCounter;\n    const node = {\n      id, parentId, level, profit, weight, path: path.slice(), // copy\n      bound: 0, status: 'open', x:0, y:0\n    };\n    node.bound = boundFrom(node);\n    return node;\n  }\n\n  // Initialize a fresh problem\n  function initProblem(m, cap){\n    n = m;\n    capacity = cap;\n    items = genItems(n);\n    maxLevels = n + 1;\n    nodeIdCounter = 0;\n    nodes = [];\n    pq = [];\n    bestProfit = 0;\n    bestNode = null;\n    countsAtLevel = Array(maxLevels+2).fill(0);\n    // Root node: level 0, no profit, no weight, empty path (-1 undefined)\n    const root = createNode(null, 0, 0, 0, Array(n).fill(-1));\n    root.x = viewBoxW/2;\n    root.y = 40;\n    nodes.push(root);\n    pushPQ(root);\n    updateUI();\n    log(`Problem initialized with ${n} items, capacity ${capacity}.`);\n  }\n\n  // Priority queue functions (simple array)\n  function pushPQ(node){\n    // Only push if bound > bestProfit (otherwise prune immediately)\n    if(node.bound <= bestProfit){\n      node.status = 'pruned';\n      nodes.push(node); // still show it in visualization\n      log(`Node ${node.id} pruned at creation (bound <= bestProfit). bound=${node.bound.toFixed(2)}, best=${bestProfit}`);\n      return;\n    }\n    node.status = 'open';\n    pq.push(node);\n    // Keep PQ sorted by bound desc\n    pq.sort((a,b)=> b.bound - a.bound || b.profit - a.profit);\n  }\n  function popPQ(){\n    return pq.shift();\n  }\n\n  // Visualization: compute node positions based on counts at level when node created.\n  function layoutNode(node){\n    const levelIndex = node.level; // 0..n\n    const yBase = 40 + levelIndex * 80;\n    // increase count for that level and compute x spacing\n    const col = ++countsAtLevel[levelIndex];\n    const totalAtLevel = Math.max(8, Math.min(16, countsAtLevel[levelIndex])); // approximate\n    // spacing formula to spread nodes horizontally across viewBoxW\n    const spacing = Math.max(80, viewBoxW / (Math.max(6, col)+1));\n    const x = 80 + (col - 1) * spacing - (countsAtLevel[levelIndex] > 7 ? (countsAtLevel[levelIndex]-7)*10 : 0);\n    node.x = Math.max(40, Math.min(viewBoxW-40, x));\n    node.y = yBase;\n  }\n\n  // For newly created node, compute layout and add to nodes list\n  function addNodeToGraph(node){\n    layoutNode(node);\n    nodes.push(node);\n  }\n\n  // Drawing functions\n  function clearSvg(){\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n  }\n\n  function draw(){\n    clearSvg();\n    // Draw edges first\n    nodes.forEach(nod=>{\n      if(nod.parentId != null){\n        const parent = nodes.find(p=>p.id === nod.parentId);\n        if(parent){\n          const line = document.createElementNS(\"http://www.w3.org/2000/svg\",'line');\n          line.setAttribute('x1', parent.x);\n          line.setAttribute('y1', parent.y + 20);\n          line.setAttribute('x2', nod.x);\n          line.setAttribute('y2', nod.y - 20);\n          line.setAttribute('stroke', 'rgba(15,23,36,0.06)');\n          line.setAttribute('stroke-width','2');\n          svg.appendChild(line);\n        }\n      }\n    });\n\n    // Draw nodes\n    nodes.forEach(node=>{\n      const g = document.createElementNS(\"http://www.w3.org/2000/svg\",'g');\n      g.setAttribute('transform', `translate(${node.x},${node.y})`);\n      g.setAttribute('data-id', node.id);\n\n      // Circle background\n      const circle = document.createElementNS(\"http://www.w3.org/2000/svg\",'rect');\n      circle.setAttribute('x', -26);\n      circle.setAttribute('y', -26);\n      circle.setAttribute('rx', 10);\n      circle.setAttribute('ry', 10);\n      circle.setAttribute('width', 52);\n      circle.setAttribute('height', 52);\n      circle.setAttribute('fill', () => {\n        if(node.status === 'open') return colors.open;\n        if(node.status === 'expanded') return colors.expanded;\n        if(node.status === 'popped') return colors.popped;\n        if(node.status === 'pruned') return colors.pruned;\n        if(node.status === 'best') return colors.best;\n        return '#fff';\n      }());\n      circle.setAttribute('stroke','rgba(2,6,23,0.06)');\n      circle.setAttribute('stroke-width','1');\n\n      // Text lines: profit/weight\n      const text1 = document.createElementNS(\"http://www.w3.org/2000/svg\",'text');\n      text1.setAttribute('x', 0);\n      text1.setAttribute('y', -4);\n      text1.setAttribute('text-anchor','middle');\n      text1.setAttribute('class','node-label');\n      text1.setAttribute('fill', colors.defaultText);\n      text1.textContent = `p=${node.profit}, w=${node.weight}`;\n\n      const text2 = document.createElementNS(\"http://www.w3.org/2000/svg\",'text');\n      text2.setAttribute('x', 0);\n      text2.setAttribute('y', 12);\n      text2.setAttribute('text-anchor','middle');\n      text2.setAttribute('class','node-label');\n      text2.setAttribute('fill', 'rgba(2,6,23,0.6)');\n      text2.textContent = `b=${node.bound.toFixed(1)}`;\n\n      g.appendChild(circle);\n      g.appendChild(text1);\n      g.appendChild(text2);\n\n      // Interactivity: pointer events for tooltip\n      g.addEventListener('mouseenter', (ev)=>{\n        showTooltipFor(node, ev);\n      });\n      g.addEventListener('mousemove', (ev)=>{\n        positionTooltip(ev);\n      });\n      g.addEventListener('mouseleave', ()=>{ hideTooltip(); });\n\n      svg.appendChild(g);\n    });\n\n    updatePQBox();\n  }\n\n  function showTooltipFor(node, ev){\n    const html = `\n      <div><strong>Node ${node.id}</strong> (level ${node.level})</div>\n      <div>Profit: ${node.profit}</div>\n      <div>Weight: ${node.weight}</div>\n      <div>Bound: ${node.bound.toFixed(2)}</div>\n      <div>Path: ${formatPath(node.path)}</div>\n      <div>Status: ${node.status}</div>\n    `;\n    tooltip.innerHTML = html;\n    tooltip.style.display = 'block';\n    positionTooltip(ev);\n  }\n  function positionTooltip(ev){\n    const rect = document.getElementById('canvasWrap').getBoundingClientRect();\n    tooltip.style.left = (ev.clientX - rect.left + 14) + 'px';\n    tooltip.style.top = (ev.clientY - rect.top + 10) + 'px';\n  }\n  function hideTooltip(){\n    tooltip.style.display = 'none';\n  }\n\n  function updatePQBox(){\n    pqBox.innerHTML = '';\n    pq.forEach(node=>{\n      const el = document.createElement('div');\n      el.style.padding = '6px';\n      el.style.borderBottom = '1px dashed rgba(2,6,23,0.04)';\n      el.innerHTML = `<strong>Node ${node.id}</strong> &nbsp; <span style=\"color:rgba(2,6,23,0.6)\">l${node.level}</span>\n        <div class=\"small\">p=${node.profit}, w=${node.weight}, b=${node.bound.toFixed(2)}, path=${formatPath(node.path)}</div>`;\n      pqBox.appendChild(el);\n    });\n    if(pq.length === 0){\n      pqBox.innerHTML = '<div class=\"small\">Priority queue empty.</div>';\n    }\n  }\n\n  function updateItemsList(){\n    itemsList.innerHTML = '';\n    items.forEach((it, idx)=>{\n      const row = document.createElement('div');\n      row.className = 'row';\n      row.innerHTML = `<div class=\"badge\">#${it.id}</div>\n        <div style=\"flex:1\">\n          <div><strong>v=${it.value}</strong> &nbsp; w=${it.weight} &nbsp; <span class=\"small\">ratio=${it.ratio.toFixed(2)}</span></div>\n          <div class=\"small\">order=${idx}</div>\n        </div>`;\n      itemsList.appendChild(row);\n    });\n  }\n\n  function updateBestUI(){\n    bestProfitSpan.textContent = bestProfit;\n    bestSolDiv.innerHTML = '';\n    if(bestNode){\n      const picks = bestNode.path.map((d,i) => d===1 ? `#${items[i].id}` : null).filter(Boolean);\n      if(picks.length===0) bestSolDiv.innerHTML = '<div class=\"small\">none</div>';\n      else picks.forEach(p=>{\n        const pill = document.createElement('div');\n        pill.className = 'pill';\n        pill.textContent = p;\n        bestSolDiv.appendChild(pill);\n      });\n    } else {\n      bestSolDiv.innerHTML = '<div class=\"small\">none</div>';\n    }\n  }\n\n  function updateUI(){\n    updateItemsList();\n    updateBestUI();\n    draw();\n    currentNodeSpan.textContent = pq.length ? `top Node ${pq[0].id} (bound ${pq[0].bound.toFixed(2)})` : '-';\n  }\n\n  // Branch and Bound step: one pop/expand/prune cycle\n  function step(){\n    if(pq.length === 0){\n      log('PQ empty — done.');\n      playMode = false;\n      stopAuto();\n      return;\n    }\n    // Pop node with highest bound\n    const node = popPQ();\n    node.status = 'popped';\n    log(`Popped Node ${node.id} (level ${node.level}) with bound=${node.bound.toFixed(2)}, profit=${node.profit}`);\n    // mark in nodes array\n    const existing = nodes.find(n=>n.id===node.id);\n    if(existing) existing.status = 'popped';\n\n    // If bound <= bestProfit -> prune\n    if(node.bound <= bestProfit){\n      node.status = 'pruned';\n      log(`Pruned Node ${node.id} because bound <= bestProfit (${node.bound.toFixed(2)} <= ${bestProfit})`);\n      updateUI();\n      return;\n    }\n\n    // If it's at last level (leaf) or considered all items => evaluate leaf\n    if(node.level === n){\n      // leaf node\n      if(node.weight <= capacity && node.profit > bestProfit){\n        bestProfit = node.profit;\n        bestNode = node;\n        node.status = 'best';\n        log(`New best solution found at Node ${node.id}: profit=${node.profit}`);\n      } else {\n        node.status = 'expanded';\n      }\n      updateUI();\n      return;\n    }\n\n    // Expand node: create include child and exclude child\n    // Include child: take item at index node.level\n    const item = items[node.level];\n    // Include\n    const incPath = node.path.slice();\n    incPath[node.level] = 1;\n    const includeChild = createNode(node.id, node.level+1, node.profit + item.value, node.weight + item.weight, incPath);\n    // Exclude\n    const excPath = node.path.slice();\n    excPath[node.level] = 0;\n    const excludeChild = createNode(node.id, node.level+1, node.profit, node.weight, excPath);\n\n    // Add to visualization and PQ if not pruned\n    addNodeToGraph(includeChild);\n    addNodeToGraph(excludeChild);\n\n    // Evaluate includeChild: if weight within capacity, check for bestProfit\n    if(includeChild.weight <= capacity){\n      if(includeChild.profit > bestProfit){\n        bestProfit = includeChild.profit;\n        bestNode = includeChild;\n        includeChild.status = 'best';\n        log(`Found better feasible solution by including item ${item.id} (Node ${includeChild.id}): profit=${includeChild.profit}`);\n      }\n    } else {\n      includeChild.status = 'pruned';\n      log(`Pruned include-child Node ${includeChild.id} (over capacity: w=${includeChild.weight})`);\n    }\n\n    // Add to PQ if bound > bestProfit and within something\n    if(includeChild.status !== 'pruned'){\n      if(includeChild.bound > bestProfit){\n        pushPQ(includeChild);\n        log(`Pushed include-child Node ${includeChild.id} (bound=${includeChild.bound.toFixed(2)})`);\n      } else {\n        includeChild.status = 'pruned';\n        log(`Pruned include-child Node ${includeChild.id} at creation (bound <= bestProfit)`);\n      }\n    }\n\n    // Exclude child\n    if(excludeChild.bound > bestProfit){\n      pushPQ(excludeChild);\n      log(`Pushed exclude-child Node ${excludeChild.id} (bound=${excludeChild.bound.toFixed(2)})`);\n    } else {\n      excludeChild.status = 'pruned';\n      addNodeToGraph(excludeChild);\n      log(`Pruned exclude-child Node ${excludeChild.id} at creation (bound <= bestProfit)`);\n    }\n\n    // Mark node expanded\n    const existingNode = nodes.find(n=>n.id===node.id);\n    if(existingNode) existingNode.status = 'expanded';\n    updateUI();\n  }\n\n  // Run until PQ empty (fast, no animation)\n  function solveFast(){\n    while(pq.length){\n      const node = popPQ();\n      if(node.bound <= bestProfit) continue;\n      if(node.level === n){\n        if(node.weight <= capacity && node.profit > bestProfit){\n          bestProfit = node.profit;\n          bestNode = node;\n        }\n        continue;\n      }\n      const item = items[node.level];\n      // include\n      const incPath = node.path.slice(); incPath[node.level]=1;\n      const includeChild = createNode(node.id, node.level+1, node.profit + item.value, node.weight + item.weight, incPath);\n      if(includeChild.weight <= capacity){\n        if(includeChild.profit > bestProfit){\n          bestProfit = includeChild.profit;\n          bestNode = includeChild;\n        }\n      }\n      if(includeChild.bound > bestProfit && includeChild.weight <= capacity){\n        pushPQ(includeChild);\n      }\n      // exclude\n      const excPath = node.path.slice(); excPath[node.level]=0;\n      const excludeChild = createNode(node.id, node.level+1, node.profit, node.weight, excPath);\n      if(excludeChild.bound > bestProfit){\n        pushPQ(excludeChild);\n      }\n      // To keep visualization small, store only some nodes\n      nodes.push(includeChild);\n      nodes.push(excludeChild);\n    }\n    // mark best node\n    if(bestNode) bestNode.status = 'best';\n    updateUI();\n    log('Solved (fast).');\n  }\n\n  // Auto-play controls\n  function startAuto(){\n    if(playMode) return;\n    playMode = true;\n    playBtn.style.display = 'none';\n    pauseBtn.style.display = 'inline-block';\n    const interval = Math.max(80, Number(speedSlider.value) || 600);\n    runningInterval = setInterval(()=>{\n      if(!playMode) return;\n      if(pq.length === 0){\n        stopAuto();\n        log('Auto-play finished (PQ empty).');\n        return;\n      }\n      step();\n    }, interval);\n  }\n  function stopAuto(){\n    playMode = false;\n    playBtn.style.display = 'inline-block';\n    pauseBtn.style.display = 'none';\n    if(runningInterval) { clearInterval(runningInterval); runningInterval = null; }\n  }\n\n  // Reset / Randomize handlers\n  function resetHandler(){\n    n = Number(numItemsInput.value) || 6;\n    capacity = Number(capacityInput.value) || 15;\n    initProblem(n, capacity);\n  }\n\n  function randomizeHandler(){\n    n = Number(numItemsInput.value) || 6;\n    // pick a capacity about 1/3 to 1/2 of total weight\n    const itemsTemp = genItems(n, 10, 20);\n    const sumW = itemsTemp.reduce((s,it)=>s+it.weight,0);\n    const cap = Math.max(3, Math.floor(sumW * (Math.random()*0.45 + 0.25)));\n    capacityInput.value = cap;\n    items = itemsTemp;\n    // re-init with these items exactly\n    maxLevels = n+1;\n    nodeIdCounter = 0;\n    nodes = [];\n    pq = [];\n    bestProfit = 0;\n    bestNode = null;\n    countsAtLevel = Array(maxLevels+2).fill(0);\n    // root\n    const root = createNode(null, 0, 0, 0, Array(n).fill(-1));\n    layoutNode(root);\n    nodes.push(root);\n    pushPQ(root);\n    updateUI();\n    log(`Randomized problem: ${n} items, cap ${cap}`);\n  }\n\n  // Explanations per step: show a short textual explanation for next step\n  function explainStep(){\n    if(pq.length === 0){\n      alert('Nothing left in PQ. Algorithm finished.');\n      return;\n    }\n    const top = pq[0];\n    const explanation = `We pick the node with highest bound (Node ${top.id}). This bound is optimistic (we allow fractional items) and equals ${top.bound.toFixed(2)}. \nIf the bound <= current best (${bestProfit}), we can safely prune every descendant of this node because even in the best (fractional) case they cannot beat the best known solution. Otherwise we expand this node into two children: include or exclude the next item (index ${top.level}, item id ${items[top.level].id}).`;\n    alert(explanation);\n  }\n\n  // Button bindings\n  randomBtn.addEventListener('click', ()=>{ randomizeHandler(); });\n  resetBtn.addEventListener('click', ()=>{ resetHandler(); });\n  stepBtn.addEventListener('click', ()=>{ step(); });\n  playBtn.addEventListener('click', ()=>{ startAuto(); });\n  pauseBtn.addEventListener('click', ()=>{ stopAuto(); });\n  runBtn.addEventListener('click', ()=>{ \n    // run with small animation: step until done quickly\n    const runInterval = setInterval(()=>{\n      if(pq.length === 0) { clearInterval(runInterval); log('Run to end finished.'); return; }\n      step();\n    }, 10);\n  });\n  solveBtn.addEventListener('click', ()=>{ solveFast(); });\n  explainBtn.addEventListener('click', ()=>{ explainStep(); });\n\n  // Recompute speed\n  speedSlider.addEventListener('input', ()=>{\n    if(playMode){\n      stopAuto();\n      startAuto();\n    }\n  });\n\n  // Initialize default\n  function start(){\n    // initial items and capacity\n    n = Number(numItemsInput.value) || 6;\n    capacity = Number(capacityInput.value) || 15;\n    initProblem(n, capacity);\n  }\n\n  start();\n\n})();\n</script>\n</body>\n</html>"
