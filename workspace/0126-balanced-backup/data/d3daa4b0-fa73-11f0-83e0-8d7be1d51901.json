  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Agile Methodology Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    :root{\n      --bg:#f5f7fb; --panel:#ffffff; --accent:#2b9cff; --muted:#6b7280;\n      --ok:#16a34a; --danger:#ef4444;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    *{box-sizing:border-box}\n    body{margin:0;background:linear-gradient(180deg,#eef6ff 0%, var(--bg) 40%); min-height:100vh; }\n    header{padding:18px 24px; display:flex; align-items:center; gap:16px; background:transparent}\n    h1{margin:0;font-size:20px;color:#07304f}\n    .container{display:flex; gap:16px; padding:12px; margin:12px;}\n    .column{background:var(--panel); padding:12px; border-radius:10px; box-shadow:0 2px 6px rgba(11,20,40,0.06); flex:1; min-width:240px; max-height:80vh; overflow:auto}\n    .wide{flex:2; display:flex; flex-direction:column}\n    .section-title{display:flex; justify-content:space-between; align-items:center; margin-bottom:8px}\n    .muted{color:var(--muted); font-size:13px}\n    .backlog-list, .board{display:flex; flex-direction:column; gap:8px}\n    .card{background:linear-gradient(180deg,#fff,#fbfdff); padding:10px; border-radius:8px; box-shadow:0 1px 3px rgba(11,20,40,0.06); cursor:grab}\n    .card.dragging{opacity:0.6; transform:scale(0.98)}\n    .card-title{font-weight:600; color:#07304f}\n    .card-meta{font-size:12px; color:var(--muted); margin-top:6px; display:flex; justify-content:space-between; align-items:center}\n    .points{background:#eef6ff; color:var(--accent); padding:4px 8px; border-radius:20px; font-weight:700}\n    .controls{display:flex; gap:8px; margin-top:8px; align-items:center; flex-wrap:wrap}\n    button, input, select, textarea{font:inherit}\n    button{background:var(--accent); color:white; padding:8px 12px; border-radius:8px; border:0; cursor:pointer}\n    button.secondary{background:#f3f4f6; color:#111827}\n    button.ghost{background:transparent; color:var(--accent); border:1px solid #cfe8ff}\n    .small{padding:6px 8px; font-size:13px}\n    .board-columns{display:flex; gap:8px}\n    .column-drop{min-height:120px; padding:8px; border-radius:8px; background:linear-gradient(180deg,#f8fafc,transparent); border:2px dashed transparent}\n    .column-drop.over{border-color:#cfe8ff}\n    .status-header{display:flex; justify-content:space-between; align-items:center; margin-bottom:8px}\n    .info-box{padding:8px; background:#f8fafc; border-radius:8px; color:#0b2f4a; font-size:13px}\n    .form-row{display:flex; gap:8px; margin-bottom:8px}\n    input[type=\"text\"], input[type=\"number\"], textarea, select{padding:8px; border-radius:8px; border:1px solid #e6eef8; width:100%; background:white}\n    textarea{min-height:60px; resize:vertical}\n    .chart-wrap{padding:12px}\n    canvas{background:linear-gradient(180deg,#ffffff,#fbfdff); border-radius:8px; width:100%; height:200px; display:block}\n    .stats{display:flex; gap:8px; margin-top:8px; flex-wrap:wrap}\n    .stat{background:#fff; padding:8px; border-radius:10px; box-shadow:0 1px 3px rgba(11,20,40,0.04); min-width:120px}\n    .legend{display:flex; gap:8px; align-items:center; margin-top:8px}\n    .dot{width:12px;height:12px;border-radius:3px}\n    footer{padding:12px 24px; color:var(--muted); font-size:13px}\n    @media (max-width:1000px){ .container{flex-direction:column} .wide{order:2}}\n  </style>\n</head>\n<body>\n  <header>\n    <img src=\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32'><rect width='32' height='32' rx='6' fill='%232b9cff'/><text x='50%' y='58%' font-size='18' text-anchor='middle' fill='white' font-family='Arial' font-weight='700'>A</text></svg>\" alt=\"logo\" style=\"width:40px;height:40px;border-radius:8px\">\n    <div>\n      <h1>Agile Methodology — Interactive Demo</h1>\n      <div class=\"muted\">Learn key Agile concepts: iterative development, sprints, backlog, standups, and retrospectives.</div>\n    </div>\n  </header>\n\n  <div class=\"container\">\n    <!-- Backlog Column -->\n    <div class=\"column\" style=\"max-width:360px\">\n      <div class=\"section-title\">\n        <strong>Product Backlog</strong>\n        <div class=\"muted\">Prioritized list of user stories</div>\n      </div>\n\n      <div class=\"info-box\" style=\"margin-bottom:10px;\">\n        Drag stories into the Sprint board to include in a sprint. Each story has story points (effort).\n      </div>\n\n      <div style=\"margin-bottom:10px;\">\n        <form id=\"storyForm\">\n          <div class=\"form-row\">\n            <input id=\"title\" type=\"text\" placeholder=\"User story title (As a ...)\" required>\n            <input id=\"points\" type=\"number\" placeholder=\"Pts\" min=\"1\" value=\"3\" style=\"width:72px\">\n          </div>\n          <textarea id=\"desc\" placeholder=\"Acceptance criteria / description (optional)\"></textarea>\n          <div class=\"controls\" style=\"margin-top:8px\">\n            <button type=\"submit\">Add Story</button>\n            <button id=\"seedBtn\" type=\"button\" class=\"secondary small\">Seed Examples</button>\n            <button id=\"clearBacklog\" type=\"button\" class=\"secondary small\">Clear Backlog</button>\n          </div>\n        </form>\n      </div>\n\n      <div class=\"backlog-list\" id=\"backlog\"></div>\n    </div>\n\n    <!-- Main board & controls -->\n    <div class=\"wide\">\n      <div style=\"display:flex; gap:12px; align-items:center; justify-content:space-between; margin-bottom:8px;\">\n        <div style=\"display:flex; gap:8px; align-items:center\">\n          <div>\n            <label class=\"muted\">Sprint Length (days)</label><br>\n            <select id=\"sprintLength\" style=\"width:120px\">\n              <option value=\"7\">1 week (7)</option>\n              <option value=\"14\">2 weeks (14)</option>\n              <option value=\"5\">1 work-week (5)</option>\n            </select>\n          </div>\n          <div>\n            <label class=\"muted\">Team Capacity (pts/day)</label><br>\n            <input id=\"capacity\" type=\"number\" min=\"1\" value=\"8\" style=\"width:120px\">\n          </div>\n        </div>\n        <div style=\"display:flex; gap:8px; align-items:center\">\n          <button id=\"startSprint\">Start Sprint</button>\n          <button id=\"simulateDay\" class=\"secondary\">Simulate Day</button>\n          <button id=\"autoSim\" class=\"ghost\">Auto-Simulate</button>\n          <button id=\"endSprint\" class=\"secondary\">End Sprint</button>\n        </div>\n      </div>\n\n      <div class=\"board-columns\" style=\"gap:12px; margin-bottom:10px;\">\n        <div class=\"column\" style=\"min-width:260px; flex:1\">\n          <div class=\"status-header\">\n            <strong>To Do</strong>\n            <div class=\"muted\">Planned for sprint</div>\n          </div>\n          <div class=\"column-drop\" id=\"todo\" data-status=\"todo\"></div>\n        </div>\n        <div class=\"column\" style=\"min-width:260px; flex:1\">\n          <div class=\"status-header\">\n            <strong>In Progress</strong>\n            <div class=\"muted\">Work currently being done</div>\n          </div>\n          <div class=\"column-drop\" id=\"inprogress\" data-status=\"inprogress\"></div>\n        </div>\n        <div class=\"column\" style=\"min-width:260px; flex:1\">\n          <div class=\"status-header\">\n            <strong>Done</strong>\n            <div class=\"muted\">Completed stories</div>\n          </div>\n          <div class=\"column-drop\" id=\"done\" data-status=\"done\"></div>\n        </div>\n      </div>\n\n      <div style=\"display:flex; gap:12px; align-items:flex-start\">\n        <div style=\"flex:1\">\n          <div class=\"chart-wrap column\">\n            <div class=\"section-title\">\n              <strong>Sprint Burndown</strong>\n              <div class=\"muted\" id=\"sprintInfo\">No active sprint</div>\n            </div>\n            <canvas id=\"burndown\"></canvas>\n            <div class=\"legend\">\n              <div style=\"display:flex;gap:6px;align-items:center\"><div class=\"dot\" style=\"background:#ff7b00\"></div><div class=\"muted\">Actual</div></div>\n              <div style=\"display:flex;gap:6px;align-items:center\"><div class=\"dot\" style=\"background:#0ea5e9\"></div><div class=\"muted\">Ideal</div></div>\n            </div>\n          </div>\n          <div style=\"display:flex; gap:8px; margin-top:8px; flex-wrap:wrap\">\n            <div class=\"stat\">\n              <div class=\"muted\">Total Sprint Points</div>\n              <div id=\"totalPts\" style=\"font-weight:700; font-size:18px\">0</div>\n            </div>\n            <div class=\"stat\">\n              <div class=\"muted\">Remaining Points</div>\n              <div id=\"remainingPts\" style=\"font-weight:700; font-size:18px\">0</div>\n            </div>\n            <div class=\"stat\">\n              <div class=\"muted\">Day</div>\n              <div id=\"currentDay\" style=\"font-weight:700; font-size:18px\">0 / 0</div>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"width:320px\">\n          <div class=\"column\">\n            <strong>Team Board</strong>\n            <div class=\"muted\" style=\"margin-bottom:8px\">Standup notes & retrospectives</div>\n\n            <div style=\"margin-bottom:8px\">\n              <label class=\"muted\">Daily Stand-up (quick notes)</label>\n              <textarea id=\"standup\" placeholder=\"What did you do yesterday? What will you do today? Any blockers?\"></textarea>\n              <div style=\"display:flex; gap:8px; margin-top:8px\">\n                <button id=\"saveStandup\" class=\"small\">Save Note</button>\n                <button id=\"clearStandup\" class=\"small secondary\">Clear</button>\n              </div>\n            </div>\n\n            <div style=\"margin-top:8px\">\n              <label class=\"muted\">Retrospective</label>\n              <textarea id=\"retro\" placeholder=\"Sprints lessons learned\"></textarea>\n              <div style=\"display:flex; gap:8px; margin-top:8px\">\n                <button id=\"saveRetro\" class=\"small\">Save Retrospective</button>\n                <button id=\"closeSprintBtn\" class=\"small secondary\">Close Sprint (Record Velocity)</button>\n              </div>\n            </div>\n\n            <div style=\"margin-top:12px\">\n              <strong>Velocity (last sprints)</strong>\n              <div id=\"velocityList\" class=\"muted\" style=\"margin-top:8px\">No sprints completed yet.</div>\n            </div>\n\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <footer>\n    This demo simulates Agile practices: create user stories, assign them to a sprint, move them through To Do → In Progress → Done, simulate daily progress and view a burndown chart. Use retrospectives to capture lessons and track velocity.\n  </footer>\n\n<script>\n/*\n  Agile Methodology Interactive Demo\n  - Backlog: add and seed user stories with story points\n  - Drag from backlog into To Do to include in sprint\n  - Board columns: To Do, In Progress, Done (HTML5 drag & drop)\n  - Start Sprint: sets sprint length, day 0 initial burndown values\n  - Simulate Day: records remaining points each day; auto consumption using capacity applied to In Progress -> Done\n  - Burndown chart drawn on canvas: ideal and actual\n  - End/Close Sprint: records velocity and resets/returns incomplete stories to backlog\n*/\n\nconst backlogEl = document.getElementById('backlog');\nconst todoEl = document.getElementById('todo');\nconst inprogressEl = document.getElementById('inprogress');\nconst doneEl = document.getElementById('done');\nconst storyForm = document.getElementById('storyForm');\nconst titleInput = document.getElementById('title');\nconst pointsInput = document.getElementById('points');\nconst descInput = document.getElementById('desc');\nconst seedBtn = document.getElementById('seedBtn');\nconst clearBacklogBtn = document.getElementById('clearBacklog');\n\nconst startSprintBtn = document.getElementById('startSprint');\nconst simulateDayBtn = document.getElementById('simulateDay');\nconst autoSimBtn = document.getElementById('autoSim');\nconst endSprintBtn = document.getElementById('endSprint');\n\nconst sprintLengthSelect = document.getElementById('sprintLength');\nconst capacityInput = document.getElementById('capacity');\n\nconst sprintInfo = document.getElementById('sprintInfo');\nconst totalPtsEl = document.getElementById('totalPts');\nconst remainingPtsEl = document.getElementById('remainingPts');\nconst currentDayEl = document.getElementById('currentDay');\n\nconst burndownCanvas = document.getElementById('burndown');\nconst ctx = burndownCanvas.getContext('2d');\n\nconst standupInput = document.getElementById('standup');\nconst saveStandupBtn = document.getElementById('saveStandup');\nconst clearStandupBtn = document.getElementById('clearStandup');\nconst retroInput = document.getElementById('retro');\nconst saveRetroBtn = document.getElementById('saveRetro');\nconst closeSprintBtn = document.getElementById('closeSprintBtn');\n\nconst velocityListEl = document.getElementById('velocityList');\n\nlet stories = []; // all stories in backlog or sprint (status indicates where)\nlet idCounter = 1;\n\n// Sprint state\nlet sprint = {\n  active: false,\n  length: 7,\n  day: 0,\n  totalPoints: 0,\n  history: [], // remaining points each day (day0, day1 ...)\n  ideal: [],\n  autoSimHandle: null\n};\n\nlet velocities = []; // store completed points per closed sprint (max 6 shown)\n\n// Utility: render a story card\nfunction createCardElement(story){\n  const el = document.createElement('div');\n  el.className = 'card';\n  el.draggable = true;\n  el.dataset.id = story.id;\n\n  el.innerHTML = `\n    <div class=\"card-title\">${escapeHtml(story.title)}</div>\n    <div class=\"card-meta\">\n      <div class=\"muted\">${escapeHtml(story.desc || '')}</div>\n      <div class=\"points\">${story.points}</div>\n    </div>\n  `;\n  // show acceptance criteria on click (simple toggle)\n  el.addEventListener('dblclick', () => {\n    alert(\"Acceptance Criteria:\\n\\n\" + (story.desc || 'No acceptance criteria provided.'));\n  });\n\n  el.addEventListener('dragstart', (e) => {\n    e.dataTransfer.setData('text/plain', story.id);\n    el.classList.add('dragging');\n  });\n  el.addEventListener('dragend', () => el.classList.remove('dragging'));\n  return el;\n}\n\n// Escape helper\nfunction escapeHtml(s){ return (s||'').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;'); }\n\n// Render backlog list\nfunction renderBacklog(){\n  backlogEl.innerHTML = '';\n  const list = stories.filter(s => s.status === 'backlog');\n  if(list.length === 0){\n    backlogEl.innerHTML = '<div class=\"muted\">Backlog is empty. Add stories or use \"Seed Examples\".</div>';\n    return;\n  }\n  list.forEach(s => backlogEl.appendChild(createCardElement(s)));\n}\n\n// Render board columns\nfunction renderBoard(){\n  [todoEl, inprogressEl, doneEl].forEach(col => col.innerHTML = '');\n  const cols = {\n    todo: stories.filter(s => s.status === 'todo'),\n    inprogress: stories.filter(s => s.status === 'inprogress'),\n    done: stories.filter(s => s.status === 'done')\n  };\n  cols.todo.forEach(s => todoEl.appendChild(createCardElement(s)));\n  cols.inprogress.forEach(s => inprogressEl.appendChild(createCardElement(s)));\n  cols.done.forEach(s => doneEl.appendChild(createCardElement(s)));\n  updateStats();\n}\n\n// Update stats and burndown info\nfunction updateStats(){\n  const total = stories.filter(s => s.status === 'todo' || s.status === 'inprogress' || s.status === 'done').reduce((a,b)=>a+b.points,0);\n  const remaining = stories.filter(s => s.status !== 'done').reduce((a,b)=>a+b.points,0);\n  totalPtsEl.textContent = total;\n  remainingPtsEl.textContent = remaining;\n  currentDayEl.textContent = sprint.active ? (sprint.day + \" / \" + sprint.length) : \"0 / \" + sprint.length;\n  // update sprint info\n  if(sprint.active){\n    sprintInfo.textContent = `Sprint active — Day ${sprint.day}/${sprint.length} — Team capacity ${capacityInput.value} pts/day`;\n  } else {\n    sprintInfo.textContent = 'No active sprint';\n  }\n  drawBurndown();\n}\n\n// Draw burndown chart\nfunction drawBurndown(){\n  const w = burndownCanvas.clientWidth;\n  const h = burndownCanvas.clientHeight;\n  burndownCanvas.width = Math.max(300, Math.floor(w * devicePixelRatio));\n  burndownCanvas.height = Math.max(180, Math.floor(h * devicePixelRatio));\n  ctx.scale(devicePixelRatio, devicePixelRatio);\n\n  // clear\n  ctx.clearRect(0,0,w,h);\n\n  // if no sprint active and no history, show message\n  if(!sprint.active && sprint.history.length === 0){\n    ctx.fillStyle = '#0b2f4a';\n    ctx.font = '14px sans-serif';\n    ctx.fillText('Start a sprint to see a burndown chart', 12, 24);\n    return;\n  }\n\n  const padding = 36;\n  const chartW = w - padding*2;\n  const chartH = h - padding*2;\n\n  // compute points series: sprint.history has remaining points starting at day0\n  const days = sprint.length;\n  const actual = sprint.history.slice(0, days+1);\n  // if no entries yet, create from current remaining\n  if(actual.length === 0){\n    const remaining = stories.filter(s => s.status !== 'done').reduce((a,b)=>a+b.points,0);\n    actual.push(remaining);\n  }\n  // ensure length days+1\n  while(actual.length < days+1) actual.push(actual[actual.length-1]);\n\n  // ideal line: linear from total -> 0\n  const total = sprint.totalPoints || 0;\n  const ideal = [];\n  for(let d=0; d<=days; d++){\n    ideal.push(Math.max(0, total * (1 - d / days)));\n  }\n\n  // scale Y\n  const maxY = Math.max(total, ...actual);\n  const yScale = maxY === 0 ? 1 : (chartH / maxY);\n\n  // axes\n  ctx.strokeStyle = '#e6eef8';\n  ctx.lineWidth = 1;\n  ctx.beginPath();\n  // horizontal grid lines\n  for(let i=0;i<=5;i++){\n    const y = padding + (chartH * i/5);\n    ctx.moveTo(padding, y);\n    ctx.lineTo(padding + chartW, y);\n  }\n  ctx.stroke();\n\n  // labels Y\n  ctx.fillStyle = '#475569';\n  ctx.font = '12px sans-serif';\n  ctx.textAlign = 'right';\n  for(let i=0;i<=5;i++){\n    const val = Math.round(maxY * (1 - i/5));\n    const y = padding + (chartH * i/5) + 4;\n    ctx.fillText(val, padding - 6, y);\n  }\n\n  // X labels (days)\n  ctx.textAlign = 'center';\n  for(let d=0; d<=days; d++){\n    const x = padding + (chartW * d / days);\n    ctx.fillText(d.toString(), x, padding + chartH + 18);\n  }\n\n  // draw ideal line\n  ctx.beginPath();\n  ctx.strokeStyle = '#0ea5e9';\n  ctx.lineWidth = 2;\n  for(let d=0; d<=days; d++){\n    const x = padding + (chartW * d / days);\n    const y = padding + chartH - (ideal[d] * yScale);\n    if(d===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n  }\n  ctx.stroke();\n\n  // draw actual polyline\n  ctx.beginPath();\n  ctx.strokeStyle = '#ff7b00';\n  ctx.lineWidth = 2.5;\n  for(let d=0; d<actual.length; d++){\n    const x = padding + (chartW * d / days);\n    const y = padding + chartH - (actual[d] * yScale);\n    if(d===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n  }\n  ctx.stroke();\n\n  // points on actual\n  for(let d=0; d<actual.length; d++){\n    const x = padding + (chartW * d / days);\n    const y = padding + chartH - (actual[d] * yScale);\n    ctx.beginPath();\n    ctx.fillStyle = '#ff7b00';\n    ctx.rect(x-3, y-3, 6, 6);\n    ctx.fill();\n  }\n}\n\n// Drag and drop handlers for columns\nfunction makeDropHandling(el){\n  el.addEventListener('dragover', (e) => {\n    e.preventDefault();\n    el.classList.add('over');\n  });\n  el.addEventListener('dragleave', () => el.classList.remove('over'));\n  el.addEventListener('drop', (e) => {\n    e.preventDefault();\n    el.classList.remove('over');\n    const id = parseInt(e.dataTransfer.getData('text/plain'));\n    const story = stories.find(s => s.id === id);\n    if(!story) return;\n    const targetStatus = el.dataset.status;\n    // rules: if sprint not active, only allow backlog->todo (adding to sprint) or reorder inside backlog\n    if(!sprint.active){\n      // if dropped into todo/inprogress/done, we can allow adding to sprint even if sprint not active\n      // But we will mark status accordingly (so they are considered in sprint when started)\n    }\n    // Update status\n    // If moving from backlog to todo - include in sprint list\n    if(story.status === 'backlog' && targetStatus === 'todo'){\n      story.status = 'todo';\n      // ensure sprint total recalculation when sprint started\n    } else {\n      // Generic move between columns or back to backlog\n      if(targetStatus === 'todo' || targetStatus === 'inprogress' || targetStatus === 'done'){\n        story.status = targetStatus;\n      } else {\n        story.status = 'backlog';\n      }\n    }\n    renderBacklog();\n    renderBoard();\n  });\n}\n\n[todoEl, inprogressEl, doneEl, backlogEl].forEach(el => makeDropHandling(el));\n\n// Form submission to add story\nstoryForm.addEventListener('submit', (e) => {\n  e.preventDefault();\n  const t = titleInput.value.trim();\n  const p = Math.max(1, parseInt(pointsInput.value) || 1);\n  const d = descInput.value.trim();\n  if(!t) return;\n  stories.push({id: idCounter++, title: t, points: p, desc: d, status: 'backlog'});\n  titleInput.value = '';\n  pointsInput.value = '3';\n  descInput.value = '';\n  renderBacklog();\n});\n\n// Seed examples\nseedBtn.addEventListener('click', () => {\n  const examples = [\n    {title: \"As a user, I can sign up with email\", points:3, desc:\"User can create account and receive confirmation email.\"},\n    {title: \"As a user, I can reset my password\", points:2, desc:\"Password reset flow with email link.\"},\n    {title: \"As a user, I can view my profile\", points:2, desc:\"Profile shows name, email, and settings.\"},\n    {title: \"As a user, I can upload a profile picture\", points:5, desc:\"Accepts JPEG/PNG up to 2MB. Cropping applied.\"},\n    {title: \"As an admin, I can suspend accounts\", points:8, desc:\"Admin panel to suspend and reinstate accounts.\"},\n  ];\n  examples.forEach(e => stories.push({id:idCounter++, title:e.title, points:e.points, desc:e.desc, status:'backlog'}));\n  renderBacklog();\n});\n\n// Clear backlog\nclearBacklogBtn.addEventListener('click', () => {\n  if(!confirm('Clear all backlog stories?')) return;\n  stories = stories.filter(s => s.status !== 'backlog');\n  renderBacklog();\n  renderBoard();\n});\n\n// Start sprint\nstartSprintBtn.addEventListener('click', () => {\n  if(sprint.active){\n    alert('A sprint is already active. End it before starting a new one.');\n    return;\n  }\n  const len = parseInt(sprintLengthSelect.value);\n  sprint = {\n    active: true,\n    length: len,\n    day: 0,\n    totalPoints: 0,\n    history: [],\n    ideal: []\n  };\n  // compute sprint total points: sum of stories with status todo/inprogress/done\n  const sprintStories = stories.filter(s => s.status === 'todo' || s.status === 'inprogress' || s.status === 'done');\n  sprint.totalPoints = sprintStories.reduce((a,b)=>a+b.points,0);\n  // initialize history day0 with remaining points\n  const remaining = stories.filter(s => s.status !== 'done' && (s.status === 'todo' || s.status === 'inprogress' || s.status === 'done')).reduce((a,b)=>a+b.points,0);\n  sprint.history.push(remaining);\n  // ideal line\n  sprint.ideal = [];\n  for(let d=0; d<=len; d++) sprint.ideal.push(Math.max(0, sprint.totalPoints * (1 - d/len)));\n  updateStats();\n  alert(`Sprint started for ${len} days. Total planned points: ${sprint.totalPoints}.`);\n});\n\n// Simulate Day\nsimulateDayBtn.addEventListener('click', () => {\n  if(!sprint.active){ alert('No active sprint. Start a sprint first.'); return; }\n  if(sprint.day >= sprint.length){ alert('Sprint already completed its planned days. Consider closing the sprint.'); return; }\n\n  // Simple simulation: team capacity reduces remaining points by moving some tasks to Done.\n  // Strategy: finish whole stories (prefer lower points first for realism), limited by capacity per day.\n  let capacity = parseInt(capacityInput.value) || 8;\n  // make a list of in-progress first, then todo (to simulate pull from To Do)\n  const workPool = stories.filter(s => s.status === 'inprogress' || s.status === 'todo').sort((a,b)=>a.points - b.points);\n  for(const s of workPool){\n    if(capacity <= 0) break;\n    if(s.points <= capacity){\n      // finish this story\n      s.status = 'done';\n      capacity -= s.points;\n    }\n  }\n  // If capacity remains, consider partially completing a larger item (not tracked as partial points per story in this simple demo).\n  // For realism, if some inprogress larger than capacity, we will mark partial progress by subtracting from points as tempRemaining (not altering story.points).\n  // But to keep things simple, we won't split stories. Instead remaining capacity is unused.\n\n  // advance day\n  sprint.day += 1;\n  // record remaining points\n  const remaining = stories.filter(s => s.status !== 'done' && (s.status === 'todo' || s.status === 'inprogress' || s.status === 'done')).reduce((a,b)=>a+b.points,0);\n  sprint.history.push(remaining);\n  updateStats();\n\n  if(sprint.day >= sprint.length){\n    alert('Sprint has reached its planned length. Consider closing the sprint to record velocity and run retrospectives.');\n  }\n});\n\n// Auto-simulate: run simulateDay repeatedly until sprint end\nautoSimBtn.addEventListener('click', () => {\n  if(!sprint.active){ alert('No active sprint. Start a sprint first.'); return; }\n  if(autoSimBtn.dataset.running === '1'){\n    // stop\n    clearInterval(sprint.autoSimHandle);\n    autoSimBtn.dataset.running = '0';\n    autoSimBtn.textContent = 'Auto-Simulate';\n    return;\n  }\n  autoSimBtn.dataset.running = '1';\n  autoSimBtn.textContent = 'Stop Auto';\n  sprint.autoSimHandle = setInterval(() => {\n    if(!sprint.active || sprint.day >= sprint.length) {\n      clearInterval(sprint.autoSimHandle);\n      autoSimBtn.dataset.running = '0';\n      autoSimBtn.textContent = 'Auto-Simulate';\n      return;\n    }\n    simulateDayBtn.click();\n  }, 800);\n});\n\n// End sprint (close and record velocity)\nendSprintBtn.addEventListener('click', () => {\n  if(!sprint.active){ alert('No active sprint.'); return; }\n  const completedPts = stories.filter(s => s.status === 'done').reduce((a,b)=>a+b.points,0);\n  // incomplete stories go back to backlog\n  stories.forEach(s => {\n    if(s.status === 'todo' || s.status === 'inprogress') s.status = 'backlog';\n  });\n  sprint.active = false;\n  sprint.day = 0;\n  // record velocity\n  velocities.unshift({pts: completedPts, date: new Date().toLocaleDateString()});\n  if(velocities.length > 8) velocities.pop();\n  updateVelocityDisplay();\n  renderBacklog();\n  renderBoard();\n  alert(`Sprint ended. Velocity recorded: ${completedPts} pts completed.`);\n});\n\n// Close sprint (explicit from retrospective panel)\ncloseSprintBtn.addEventListener('click', () => {\n  endSprintBtn.click();\n  if(retroInput.value.trim()) {\n    alert('Retrospective saved. Thank you for reflecting on what went well and improvements.');\n    retroInput.value = '';\n  }\n});\n\n// Standup save/clear\nsaveStandupBtn.addEventListener('click', () => {\n  if(!standupInput.value.trim()){ alert('Enter something for standup.'); return; }\n  alert('Standup note saved:\\n\\n' + standupInput.value);\n  standupInput.value = '';\n});\nclearStandupBtn.addEventListener('click', () => standupInput.value = '');\n\n// Retrospective save\nsaveRetroBtn.addEventListener('click', () => {\n  if(!retroInput.value.trim()){ alert('Enter retrospective notes to save.'); return; }\n  alert('Retrospective saved:\\n\\n' + retroInput.value);\n  retroInput.value = '';\n});\n\n// Velocity display\nfunction updateVelocityDisplay(){\n  if(velocities.length === 0){\n    velocityListEl.textContent = 'No sprints completed yet.';\n    return;\n  }\n  velocityListEl.innerHTML = '';\n  velocities.forEach(v => {\n    const div = document.createElement('div');\n    div.style.marginBottom = '6px';\n    div.innerHTML = `<strong style=\"margin-right:6px\">${v.pts} pts</strong><span class=\"muted\">(${v.date})</span>`;\n    velocityListEl.appendChild(div);\n  });\n}\n\n// Initialize drag behavior for backlog as source to allow dragging back to backlog (we'll support dropping there)\nbacklogEl.addEventListener('dragover', (e) => { e.preventDefault(); });\nbacklogEl.addEventListener('drop', (e) => {\n  e.preventDefault();\n  const id = parseInt(e.dataTransfer.getData('text/plain'));\n  const story = stories.find(s => s.id === id);\n  if(story){\n    story.status = 'backlog';\n    renderBacklog();\n    renderBoard();\n  }\n});\n\n// Basic demo stories\n(function initDemo(){\n  const demo = [\n    {title:\"As a visitor, I can browse products\", points:3, desc:\"View product list and details.\"},\n    {title:\"As a user, I can add items to cart\", points:5, desc:\"Add/remove items, update quantities.\"},\n    {title:\"As a user, I can checkout securely\", points:8, desc:\"Payment flow with validation and confirmation.\"}\n  ];\n  demo.forEach(d => stories.push({id:idCounter++, title:d.title, points:d.points, desc:d.desc, status:'backlog'}));\n  renderBacklog();\n  renderBoard();\n  updateVelocityDisplay();\n})();\n\n// Allow clicking on a card to view details (also on backlog)\ndocument.body.addEventListener('click', (e) => {\n  const card = e.target.closest('.card');\n  if(!card) return;\n  const id = parseInt(card.dataset.id);\n  const s = stories.find(x => x.id === id);\n  if(!s) return;\n  // Show quick details\n  const details = `Title: ${s.title}\\nPoints: ${s.points}\\nStatus: ${s.status}\\n\\nAcceptance:\\n${s.desc || 'N/A'}`;\n  // Simple prompt options\n  if(confirm(details + '\\n\\nPress OK to move this card to Backlog, Cancel to dismiss.')){\n    s.status = 'backlog';\n    renderBacklog();\n    renderBoard();\n  }\n});\n\n// Keyboard shortcuts: N for new story focus\nwindow.addEventListener('keydown', (e) => {\n  if(e.key === 'n' || e.key === 'N'){\n    titleInput.focus();\n  }\n});\n\n// Keep UI responsive: redraw on resize\nwindow.addEventListener('resize', () => {\n  // reset canvas scale\n  ctx.setTransform(1,0,0,1,0,0);\n  drawBurndown();\n});\n\n// initial draw\ndrawBurndown();\nupdateStats();\n\n</script>\n</body>\n</html>"
