    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Monitor (Concurrency) Demo — Producer/Consumer with a Monitor</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 18px; color: #111; }\n    h1 { margin: 0 0 8px 0; }\n    p.lead { margin-top: 6px; color: #333; max-width: 860px; }\n    .controls { margin-top: 14px; display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }\n    label { font-size: 13px; color: #222; }\n    input[type=\"number\"] { width: 70px; padding: 6px; }\n    button { padding: 8px 12px; border-radius: 6px; border: 1px solid #cfcfcf; background: #fafafa; cursor: pointer; }\n    button.primary { background: #0b84ff; color: white; border-color: #0b84ff; }\n    .layout { display: flex; gap: 18px; margin-top: 18px; align-items: flex-start; }\n    .panel { background: #fff; border: 1px solid #e5e7eb; padding: 12px; border-radius: 8px; box-shadow: 0 1px 2px rgba(0,0,0,0.03); }\n    .left { width: 520px; }\n    .buffer { display: flex; gap: 6px; margin-top: 12px; align-items: center; }\n    .slot { width: 44px; height: 44px; border-radius: 6px; background: #f3f4f6; border: 1px dashed #d1d5db; display: flex; align-items: center; justify-content: center; font-weight: 600; color: #6b7280; }\n    .filled { background: linear-gradient(180deg,#34d399,#10b981); color: white; border: 1px solid rgba(0,0,0,0.06); }\n    .workers { margin-top: 12px; display: grid; gap: 8px; }\n    .worker { display:flex; gap:8px; align-items:center; border-radius:6px; padding:8px; background:#fbfbfd; border:1px solid #eef2ff; }\n    .badge { font-size:12px; padding:6px 8px; background:#111827; color:white; border-radius:6px; }\n    .logs { max-height: 420px; overflow:auto; margin-top: 12px; background:#0f172a; color:#e6eef8; padding:10px; border-radius:6px; font-family: monospace; font-size:13px; }\n    .small { font-size:13px; color:#445; }\n    .stat { display:inline-block; margin-right:10px; font-weight:600; }\n    .worker button { margin-left:auto; }\n    .footer { margin-top:10px; font-size:13px; color:#444; max-width: 860px; }\n    a { color: #0b84ff; text-decoration: none; }\n  </style>\n</head>\n<body>\n  <h1>Monitor (Concurrency) — Bounded Buffer Demo</h1>\n  <p class=\"lead\">\n    This page demonstrates the \"Monitor\" concurrency abstraction: a mutual exclusion lock combined with condition variables (wait/notify).\n    The demo runs multiple producers and consumers operating on a bounded buffer protected by a Monitor implementation.\n    The Monitor ensures only one thread/method executes its critical section at a time and enables threads to wait for conditions (e.g. \"notFull\"/\"notEmpty\").\n  </p>\n\n  <div class=\"controls\">\n    <label>Buffer capacity:\n      <input id=\"capacityInput\" type=\"number\" min=\"1\" value=\"5\" />\n    </label>\n    <button id=\"applyCapacityBtn\">Apply</button>\n    <button id=\"addProducerBtn\" class=\"primary\">Add Producer</button>\n    <button id=\"addConsumerBtn\" class=\"primary\">Add Consumer</button>\n    <button id=\"stopAllBtn\">Stop All</button>\n    <span class=\"small\" style=\"margin-left: auto;\">Producers: <span id=\"prodCount\">0</span> | Consumers: <span id=\"consCount\">0</span></span>\n  </div>\n\n  <div class=\"layout\">\n    <div class=\"panel left\">\n      <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n        <div>\n          <div class=\"stat\">Buffer size: <span id=\"bufferSize\">0</span></div>\n          <div class=\"stat\">Capacity: <span id=\"bufferCap\">5</span></div>\n        </div>\n        <div style=\"text-align:right;\">\n          <div class=\"small\">Produced total: <span id=\"producedTotal\">0</span></div>\n          <div class=\"small\">Consumed total: <span id=\"consumedTotal\">0</span></div>\n        </div>\n      </div>\n\n      <div class=\"buffer\" id=\"bufferSlots\" aria-live=\"polite\" style=\"margin-top:12px;\"></div>\n\n      <div class=\"workers\" id=\"workersArea\">\n        <!-- Worker controls appear here -->\n      </div>\n    </div>\n\n    <div class=\"panel\" style=\"flex:1; min-width:300px;\">\n      <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n        <div>\n          <strong>Logs (most recent first)</strong>\n        </div>\n        <div class=\"small\">Monitor: mutual exclusion + condition variables</div>\n      </div>\n      <div class=\"logs\" id=\"logs\" aria-live=\"polite\"></div>\n      <div style=\"margin-top:10px;\">\n        <button id=\"clearLogsBtn\">Clear Logs</button>\n      </div>\n      <div class=\"footer\">\n        Notes:\n        <ul>\n          <li>This implementation models a \"Mesa-style\" monitor: notify wakes a waiting thread but does not transfer the lock directly. A notified thread re-enters the entry queue and must re-acquire the lock.</li>\n          <li>The Monitor class implemented here offers simple enter/exit (mutex) and wait/notify(condition) primitives built on Promises.</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n  <script>\n  // ---------- Monitor implementation ----------\n  // Provides enter() / exit() (mutex) and wait(cond) / notify(cond) / notifyAll(cond).\n  class Monitor {\n    constructor() {\n      this.locked = false;            // is someone inside?\n      this.entryQueue = [];          // queue of functions to call to grant lock\n      this.conds = new Map();        // condName -> array of resume functions for waiters\n    }\n\n    // Acquire the monitor (mutex). Returns a promise that resolves when acquired.\n    enter() {\n      if (!this.locked) {\n        this.locked = true;\n        return Promise.resolve();\n      }\n      return new Promise(resolve => {\n        // push a function that sets locked and resolves the waiting enter promise\n        this.entryQueue.push(() => { this.locked = true; resolve(); });\n      });\n    }\n\n    // Release the monitor; if someone is waiting to enter, pass the lock to them.\n    exit() {\n      if (this.entryQueue.length > 0) {\n        const grantFn = this.entryQueue.shift();\n        // pass the lock to the next waiter\n        grantFn();\n      } else {\n        this.locked = false;\n      }\n    }\n\n    // Wait on a named condition variable: atomically release the monitor and suspend.\n    async wait(condName = '') {\n      if (!this.conds.has(condName)) this.conds.set(condName, []);\n      let resume;\n      const p = new Promise(resolve => resume = resolve);\n      this.conds.get(condName).push(resume);\n      // Release the monitor and suspend until signaled\n      this.exit();\n      await p;\n      // When resumed, re-acquire the monitor before returning\n      await this.enter();\n    }\n\n    // Wake one waiter waiting on condName (if any).\n    notify(condName = '') {\n      const q = this.conds.get(condName);\n      if (q && q.length > 0) {\n        const resume = q.shift();\n        resume();\n      }\n    }\n\n    // Wake all waiters on condName.\n    notifyAll(condName = '') {\n      const q = this.conds.get(condName);\n      if (q) {\n        while (q.length) {\n          const r = q.shift();\n          r();\n        }\n      }\n    }\n  }\n\n  // ---------- Bounded buffer protected by a Monitor ----------\n  class BoundedBuffer {\n    constructor(capacity) {\n      this.capacity = capacity;\n      this.buffer = [];\n      this.mon = new Monitor();\n    }\n\n    async put(item) {\n      await this.mon.enter();\n      try {\n        while (this.buffer.length >= this.capacity) {\n          // wait until there's space\n          await this.mon.wait('notFull');\n        }\n        this.buffer.push(item);\n        // signal that buffer is not empty\n        this.mon.notify('notEmpty');\n      } finally {\n        this.mon.exit();\n      }\n    }\n\n    async get() {\n      await this.mon.enter();\n      try {\n        while (this.buffer.length === 0) {\n          // wait until an item is available\n          await this.mon.wait('notEmpty');\n        }\n        const item = this.buffer.shift();\n        // signal that there's space\n        this.mon.notify('notFull');\n        return item;\n      } finally {\n        this.mon.exit();\n      }\n    }\n\n    size() { return this.buffer.length; }\n    setCapacity(n) { this.capacity = n; }\n    snapshot() { return this.buffer.slice(); }\n  }\n\n  // ---------- Demo orchestration ----------\n  const bufferSlots = document.getElementById('bufferSlots');\n  const bufferSizeEl = document.getElementById('bufferSize');\n  const bufferCapEl = document.getElementById('bufferCap');\n  const capacityInput = document.getElementById('capacityInput');\n  const applyCapacityBtn = document.getElementById('applyCapacityBtn');\n  const addProducerBtn = document.getElementById('addProducerBtn');\n  const addConsumerBtn = document.getElementById('addConsumerBtn');\n  const stopAllBtn = document.getElementById('stopAllBtn');\n  const workersArea = document.getElementById('workersArea');\n  const logsEl = document.getElementById('logs');\n  const producedTotalEl = document.getElementById('producedTotal');\n  const consumedTotalEl = document.getElementById('consumedTotal');\n  const prodCountEl = document.getElementById('prodCount');\n  const consCountEl = document.getElementById('consCount');\n  const clearLogsBtn = document.getElementById('clearLogsBtn');\n\n  let producedTotal = 0, consumedTotal = 0;\n  let nextItemId = 1;\n  let workerIdCounter = 1;\n\n  // create buffer\n  let buf = new BoundedBuffer(parseInt(capacityInput.value, 10) || 5);\n  bufferCapEl.textContent = buf.capacity;\n  renderBuffer();\n\n  function log(msg) {\n    const ts = new Date().toLocaleTimeString();\n    const line = `[${ts}] ${msg}`;\n    const div = document.createElement('div');\n    div.textContent = line;\n    logsEl.prepend(div);\n    // limit logs\n    while (logsEl.childNodes.length > 400) logsEl.removeChild(logsEl.lastChild);\n  }\n\n  function renderBuffer() {\n    bufferSlots.innerHTML = '';\n    const cap = buf.capacity;\n    const snapshot = buf.snapshot();\n    for (let i = 0; i < cap; i++) {\n      const slot = document.createElement('div');\n      slot.className = 'slot';\n      if (i < snapshot.length) {\n        slot.classList.add('filled');\n        slot.textContent = snapshot[i].toString();\n      } else {\n        slot.textContent = '';\n      }\n      bufferSlots.appendChild(slot);\n    }\n    bufferSizeEl.textContent = buf.size();\n    bufferCapEl.textContent = buf.capacity;\n  }\n\n  // simple sleep\n  function sleep(ms) { return new Promise(resolve => setTimeout(resolve, ms)); }\n\n  // Worker management\n  const workers = new Map(); // id -> {id,type, running, speedMs, element}\n\n  function updateCounts() {\n    const prod = Array.from(workers.values()).filter(w => w.type === 'producer').length;\n    const cons = Array.from(workers.values()).filter(w => w.type === 'consumer').length;\n    prodCountEl.textContent = prod;\n    consCountEl.textContent = cons;\n    producedTotalEl.textContent = producedTotal;\n    consumedTotalEl.textContent = consumedTotal;\n  }\n\n  // Create and start a producer worker\n  function addProducer(speed = 800) {\n    const id = workerIdCounter++;\n    const el = createWorkerElement(id, 'producer', speed);\n    workersArea.appendChild(el);\n    const worker = { id, type: 'producer', running: true, speedMs: speed, element: el };\n    workers.set(id, worker);\n    updateCounts();\n    producerLoop(worker).catch(e => log('Producer error: ' + e));\n  }\n\n  // Create and start a consumer worker\n  function addConsumer(speed = 1000) {\n    const id = workerIdCounter++;\n    const el = createWorkerElement(id, 'consumer', speed);\n    workersArea.appendChild(el);\n    const worker = { id, type: 'consumer', running: true, speedMs: speed, element: el };\n    workers.set(id, worker);\n    updateCounts();\n    consumerLoop(worker).catch(e => log('Consumer error: ' + e));\n  }\n\n  // Stop all workers\n  function stopAll() {\n    for (const w of workers.values()) { w.running = false; }\n    workers.clear();\n    workersArea.innerHTML = '';\n    updateCounts();\n    log('All workers stopped.');\n  }\n\n  // Create worker DOM\n  function createWorkerElement(id, type, speedMs) {\n    const container = document.createElement('div');\n    container.className = 'worker';\n    const badge = document.createElement('div');\n    badge.className = 'badge';\n    badge.textContent = `${type.toUpperCase()} #${id}`;\n    const speedLabel = document.createElement('div');\n    speedLabel.textContent = `delay: ${speedMs}ms`;\n    speedLabel.style.minWidth = '84px';\n    const slider = document.createElement('input');\n    slider.type = 'range';\n    slider.min = '100'; slider.max = '2000'; slider.value = String(speedMs);\n    slider.style.width = '190px';\n    slider.addEventListener('input', () => {\n      speedLabel.textContent = `delay: ${slider.value}ms`;\n      const w = workers.get(id);\n      if (w) w.speedMs = parseInt(slider.value, 10);\n    });\n    const removeBtn = document.createElement('button');\n    removeBtn.textContent = 'Remove';\n    removeBtn.addEventListener('click', () => {\n      const w = workers.get(id);\n      if (w) {\n        w.running = false;\n        workers.delete(id);\n        workersArea.removeChild(container);\n        log(`${type} #${id} removed`);\n        updateCounts();\n      }\n    });\n\n    container.appendChild(badge);\n    container.appendChild(speedLabel);\n    container.appendChild(slider);\n    container.appendChild(removeBtn);\n    return container;\n  }\n\n  // Producer loop: keeps producing items and calling put(item)\n  async function producerLoop(worker) {\n    log(`Producer #${worker.id} started`);\n    while (worker.running) {\n      const itemId = nextItemId++;\n      try {\n        await buf.put(itemId);\n        producedTotal++;\n        log(`Producer #${worker.id} PUT item ${itemId} (buffer=${buf.size()}/${buf.capacity})`);\n        renderBuffer();\n      } catch (err) {\n        log(`Producer #${worker.id} error: ${err}`);\n      }\n      updateCounts();\n      await sleep(worker.speedMs);\n    }\n    log(`Producer #${worker.id} stopped`);\n  }\n\n  // Consumer loop: keeps calling get() to retrieve items\n  async function consumerLoop(worker) {\n    log(`Consumer #${worker.id} started`);\n    while (worker.running) {\n      try {\n        const item = await buf.get();\n        consumedTotal++;\n        log(`Consumer #${worker.id} GOT item ${item} (buffer=${buf.size()}/${buf.capacity})`);\n        renderBuffer();\n      } catch (err) {\n        log(`Consumer #${worker.id} error: ${err}`);\n      }\n      updateCounts();\n      await sleep(worker.speedMs);\n    }\n    log(`Consumer #${worker.id} stopped`);\n  }\n\n  // Buttons\n  addProducerBtn.addEventListener('click', () => addProducer(800));\n  addConsumerBtn.addEventListener('click', () => addConsumer(1000));\n  stopAllBtn.addEventListener('click', stopAll);\n  clearLogsBtn.addEventListener('click', () => { logsEl.innerHTML = ''; });\n\n  applyCapacityBtn.addEventListener('click', () => {\n    const v = parseInt(capacityInput.value, 10);\n    if (!isNaN(v) && v >= 1) {\n      // Changing capacity on the fly\n      buf.setCapacity(v);\n      // If capacity decreased and buffer currently larger, items remain but UI shows only capacity slots.\n      renderBuffer();\n      log(`Buffer capacity set to ${v}`);\n    }\n  });\n\n  // Initialize demo with a couple of workers\n  addProducer(600);\n  addProducer(900);\n  addConsumer(1100);\n  addConsumer(700);\n\n  // Make sure UI shows initial state\n  updateCounts();\n  renderBuffer();\n  log('Demo started: Monitor-protected bounded buffer with producers & consumers.');\n\n  // Expose for debugging (not necessary)\n  window._demo = { buf, addProducer, addConsumer, stopAll, workers, Monitor, BoundedBuffer };\n\n  </script>\n</body>\n</html>"
  },
