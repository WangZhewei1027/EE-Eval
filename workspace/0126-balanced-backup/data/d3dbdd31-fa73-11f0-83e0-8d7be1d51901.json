  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>K-Nearest Neighbors (KNN) Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 16px; color: #111; }\n    h1 { margin: 0 0 8px 0; font-size: 20px; }\n    .container { display: flex; gap: 16px; flex-wrap: wrap; }\n    .panel { padding: 12px; border: 1px solid #ddd; border-radius: 8px; background: #fafafa; box-shadow: 0 1px 2px rgba(0,0,0,0.03); }\n    .controls { min-width: 280px; max-width: 340px; }\n    .canvasWrap { position: relative; }\n    canvas { border-radius: 6px; background: #fff; display: block; }\n    .row { display:flex; gap:8px; align-items:center; margin:8px 0; flex-wrap:wrap; }\n    label { font-size: 13px; }\n    input[type=\"range\"] { width: 160px; }\n    button { padding:6px 10px; border-radius:6px; border:1px solid #bbb; background:#f5f5f5; cursor:pointer; }\n    button:hover { background:#eee; }\n    .small { font-size:12px; color:#444; }\n    .legend { display:flex; gap:8px; align-items:center; margin-top:6px; }\n    .dot { width:14px; height:14px; border-radius:50%; display:inline-block; }\n    .info { margin-top:8px; font-size:13px; }\n    .muted { color:#666; font-size:12px; }\n    .footer { margin-top:12px; font-size:12px; color:#555; }\n  </style>\n</head>\n<body>\n  <h1>K-Nearest Neighbors (KNN) — Interactive Demo</h1>\n  <div class=\"container\">\n    <div class=\"panel controls\">\n      <div class=\"row\"><label class=\"small\">Mode:</label>\n        <select id=\"mode\">\n          <option value=\"add\">Add training point</option>\n          <option value=\"query\">Place query point</option>\n          <option value=\"erase\">Erase nearest point</option>\n        </select>\n        <span class=\"muted\" title=\"When adding points select class below\">● Select class</span>\n      </div>\n\n      <div class=\"row\">\n        <label class=\"small\">Class:</label>\n        <select id=\"classSelect\">\n          <option value=\"0\">Class A (red)</option>\n          <option value=\"1\">Class B (blue)</option>\n          <option value=\"2\">Class C (green)</option>\n        </select>\n        <button id=\"clearBtn\" title=\"Remove all training points & query\">Clear</button>\n      </div>\n\n      <div class=\"row\">\n        <label for=\"kRange\">k = <span id=\"kVal\">5</span></label>\n        <input id=\"kRange\" type=\"range\" min=\"1\" max=\"25\" step=\"1\" value=\"5\">\n      </div>\n\n      <div class=\"row\">\n        <label class=\"small\">Distance:</label>\n        <select id=\"distMetric\">\n          <option value=\"euclidean\">Euclidean (L2)</option>\n          <option value=\"manhattan\">Manhattan (L1)</option>\n          <option value=\"chebyshev\">Chebyshev (L∞)</option>\n        </select>\n      </div>\n\n      <div class=\"row\">\n        <label class=\"small\">Weighting:</label>\n        <select id=\"weighting\">\n          <option value=\"uniform\">Uniform (majority vote)</option>\n          <option value=\"distance\">Distance-weighted (1/d)</option>\n        </select>\n      </div>\n\n      <div class=\"row\">\n        <button id=\"randomBtn\" title=\"Generate two or three clusters\">Random clusters</button>\n        <button id=\"boundaryBtn\" title=\"Toggle decision region shading\">Toggle decision regions</button>\n      </div>\n\n      <div class=\"row\">\n        <button id=\"autoClassifyBtn\">Auto-classify nearest (place query)</button>\n        <button id=\"explainBtn\">Explain classification</button>\n      </div>\n\n      <div class=\"legend\">\n        <div><span class=\"dot\" style=\"background:#ff4d4d\"></span> Class A</div>\n        <div><span class=\"dot\" style=\"background:#4d79ff\"></span> Class B</div>\n        <div><span class=\"dot\" style=\"background:#54c16d\"></span> Class C</div>\n        <div style=\"margin-left:8px\"><span class=\"dot\" style=\"background:#fff;border:2px solid #333\"></span> Query</div>\n      </div>\n\n      <div class=\"info\">\n        <div id=\"result\" class=\"small\">Query result: <em>none</em></div>\n        <div id=\"neighbors\" class=\"small muted\">Nearest neighbors: none</div>\n      </div>\n\n      <div class=\"footer\">\n        Instructions: Select \"Add training point\" and a class, then click on the canvas to add samples. Switch to \"Place query point\" and click to classify. Use k, distance metric and weighting to see how classification changes. Right-click is disabled on the canvas to allow different mouse interactions.\n      </div>\n    </div>\n\n    <div class=\"panel canvasWrap\">\n      <canvas id=\"canvas\" width=\"700\" height=\"500\"></canvas>\n    </div>\n  </div>\n\n  <script>\n  // K-Nearest Neighbors interactive demo\n  (function(){\n    const canvas = document.getElementById('canvas');\n    const ctx = canvas.getContext('2d');\n\n    // Controls\n    const modeSel = document.getElementById('mode');\n    const classSel = document.getElementById('classSelect');\n    const kRange = document.getElementById('kRange');\n    const kVal = document.getElementById('kVal');\n    const distMetric = document.getElementById('distMetric');\n    const weighting = document.getElementById('weighting');\n    const randomBtn = document.getElementById('randomBtn');\n    const clearBtn = document.getElementById('clearBtn');\n    const boundaryBtn = document.getElementById('boundaryBtn');\n    const autoClassifyBtn = document.getElementById('autoClassifyBtn');\n    const explainBtn = document.getElementById('explainBtn');\n    const resultDiv = document.getElementById('result');\n    const neighborsDiv = document.getElementById('neighbors');\n\n    // Colors for classes\n    const CLASS_COLORS = ['#ff4d4d', '#4d79ff', '#54c16d'];\n    const CLASS_LABELS = ['A', 'B', 'C'];\n\n    // Data: training points {x,y,label}\n    let points = [];\n    // Query point\n    let query = null;\n    // Cached neighbors for last classification\n    let lastNeighbors = [];\n    // Decision region toggle\n    let showRegions = false;\n\n    // Canvas coordinate helpers\n    function getMousePos(evt) {\n      const rect = canvas.getBoundingClientRect();\n      const dpr = window.devicePixelRatio || 1;\n      // account for canvas scaling if any\n      const x = (evt.clientX - rect.left) * (canvas.width / rect.width);\n      const y = (evt.clientY - rect.top) * (canvas.height / rect.height);\n      return { x, y };\n    }\n\n    // Distance metrics\n    function dist(a, b, metric='euclidean') {\n      const dx = Math.abs(a.x - b.x);\n      const dy = Math.abs(a.y - b.y);\n      if (metric === 'euclidean') return Math.hypot(dx, dy);\n      if (metric === 'manhattan') return dx + dy;\n      if (metric === 'chebyshev') return Math.max(dx, dy);\n      return Math.hypot(dx, dy);\n    }\n\n    // KNN core: returns classification result and neighbors info\n    function classify(queryPt, k, metric='euclidean', weightingMode='uniform') {\n      if (!queryPt || points.length === 0) return { label: null, probs: null, neighbors: [] };\n      // compute distances\n      const dists = points.map((p, i) => ({ index: i, label: p.label, dist: dist(p, queryPt, metric) }));\n      dists.sort((a,b) => a.dist - b.dist);\n      const klist = dists.slice(0, Math.min(k, dists.length));\n      // handle zero distance (query exactly on a sample)\n      // If a neighbor has zero distance, that point fully determines classification.\n      const zeroNeighbor = klist.find(n => n.dist === 0);\n      const classCount = {};\n      const classWeight = {};\n      for (let i=0;i<CLASS_COLORS.length;i++){ classCount[i]=0; classWeight[i]=0; }\n      if (zeroNeighbor) {\n        // assign entirely to that class\n        classWeight[zeroNeighbor.label] = 1;\n        classCount[zeroNeighbor.label] = 1;\n      } else {\n        for (const n of klist) {\n          if (weightingMode === 'uniform') {\n            classCount[n.label] = (classCount[n.label] || 0) + 1;\n          } else if (weightingMode === 'distance') {\n            const w = 1 / (n.dist + 1e-6); // small epsilon\n            classWeight[n.label] = (classWeight[n.label] || 0) + w;\n          }\n        }\n      }\n      // compute final scores\n      const scores = {};\n      for (let i=0;i<CLASS_COLORS.length;i++){\n        scores[i] = (weightingMode === 'uniform') ? (classCount[i] || 0) : (classWeight[i] || 0);\n      }\n      // pick max\n      let bestLabel = null;\n      let bestScore = -Infinity;\n      for (const label in scores) {\n        const s = scores[label];\n        if (s > bestScore) { bestScore = s; bestLabel = parseInt(label); }\n      }\n      // tie-breaking: if multiple labels have equal bestScore, pick the one among the nearest neighbors (closest).\n      const tied = Object.keys(scores).filter(l => Math.abs(scores[l]-bestScore) < 1e-12);\n      if (tied.length > 1) {\n        // find nearest neighbor among klist that belongs to any tied class\n        for (const n of klist) {\n          if (tied.includes(String(n.label))) { bestLabel = n.label; break; }\n        }\n      }\n\n      // make probability-like output\n      const total = Object.values(scores).reduce((a,b)=>a+b,0) || 1;\n      const probs = {};\n      for (const label in scores) probs[label] = scores[label] / total;\n\n      return { label: bestLabel, probs, neighbors: klist };\n    }\n\n    // Rendering\n    function draw() {\n      // clear\n      ctx.clearRect(0,0,canvas.width,canvas.height);\n\n      // optionally draw decision regions\n      if (showRegions) drawDecisionRegions();\n\n      // draw training points\n      for (let i=0;i<points.length;i++) {\n        const p = points[i];\n        ctx.beginPath();\n        ctx.fillStyle = CLASS_COLORS[p.label] || '#999';\n        ctx.strokeStyle = '#333';\n        ctx.lineWidth = 1;\n        ctx.arc(p.x, p.y, 6, 0, Math.PI*2);\n        ctx.fill();\n        ctx.stroke();\n      }\n\n      // draw nearest neighbor connections if query present\n      if (query) {\n        // draw neighbors lines\n        lastNeighbors.forEach((n, idx) => {\n          const p = points[n.index];\n          ctx.beginPath();\n          ctx.moveTo(query.x, query.y);\n          ctx.lineTo(p.x, p.y);\n          ctx.strokeStyle = 'rgba(0,0,0,0.2)';\n          ctx.lineWidth = 1 + 2*(1 - idx/ (lastNeighbors.length+0.1));\n          ctx.setLineDash([4,3]);\n          ctx.stroke();\n          ctx.setLineDash([]);\n          // highlight neighbor\n          ctx.beginPath();\n          ctx.fillStyle = CLASS_COLORS[p.label];\n          ctx.globalAlpha = 0.9;\n          ctx.arc(p.x, p.y, 9, 0, Math.PI*2);\n          ctx.fill();\n          ctx.globalAlpha = 1;\n          ctx.strokeStyle = '#222';\n          ctx.lineWidth = 1;\n          ctx.stroke();\n        });\n\n        // draw query\n        ctx.beginPath();\n        ctx.fillStyle = '#fff';\n        ctx.strokeStyle = '#222';\n        ctx.lineWidth = 2;\n        ctx.arc(query.x, query.y, 9, 0, Math.PI*2);\n        ctx.fill();\n        ctx.stroke();\n\n        // colored inner dot to indicate predicted class\n        if (lastNeighbors && lastNeighbors.length > 0) {\n          const outcome = classify(query, parseInt(kRange.value), distMetric.value, weighting.value);\n          if (outcome.label !== null) {\n            ctx.beginPath();\n            ctx.fillStyle = CLASS_COLORS[outcome.label];\n            ctx.arc(query.x, query.y, 5, 0, Math.PI*2);\n            ctx.fill();\n          }\n        }\n      }\n\n      // small axis ticks\n      ctx.fillStyle = '#888';\n      ctx.font = '11px system-ui';\n      ctx.fillText('Click: add point / place query / erase nearest (depending on mode)', 8, canvas.height - 8);\n    }\n\n    // Draw decision regions by sampling grid\n    function drawDecisionRegions() {\n      // resolution determines speed; increase for better quality\n      const step = 8; // px grid\n      const k = parseInt(kRange.value);\n      const metric = distMetric.value;\n      const weight = weighting.value;\n      const w = canvas.width;\n      const h = canvas.height;\n\n      // create an offscreen image data for pixel painting\n      const image = ctx.createImageData(w, h);\n      // We'll color per sample cell center to approximate boundaries (faster: color rectangles)\n      for (let y=0; y<h; y+=step) {\n        for (let x=0; x<w; x+=step) {\n          const q = {x: x + step/2, y: y + step/2};\n          const out = classify(q, k, metric, weight);\n          const label = out.label;\n          let r=255,g=255,b=255, a=255;\n          if (label === null) {\n            r=g=b=255;\n          } else {\n            // small translucent background color\n            const hex = CLASS_COLORS[label];\n            const col = hexToRgb(hex);\n            r = col.r; g = col.g; b = col.b;\n            a = 60; // alpha\n          }\n          // fill rectangle (x,y) sized step x step in image data\n          for (let yy = y; yy < Math.min(y+step,h); yy++) {\n            for (let xx = x; xx < Math.min(x+step,w); xx++) {\n              const idx = (yy * w + xx) * 4;\n              image.data[idx] = r;\n              image.data[idx+1] = g;\n              image.data[idx+2] = b;\n              image.data[idx+3] = a;\n            }\n          }\n        }\n      }\n      // put onto canvas\n      ctx.putImageData(image, 0, 0);\n    }\n\n    function hexToRgb(hex) {\n      const c = hex.replace('#','');\n      return { r: parseInt(c.substring(0,2),16), g: parseInt(c.substring(2,4),16), b: parseInt(c.substring(4,6),16) };\n    }\n\n    // UI updates after classification\n    function updateClassificationDisplay() {\n      if (!query || points.length === 0) {\n        resultDiv.innerHTML = 'Query result: <em>none</em>';\n        neighborsDiv.textContent = 'Nearest neighbors: none';\n        lastNeighbors = [];\n        draw();\n        return;\n      }\n      const k = parseInt(kRange.value);\n      const metric = distMetric.value;\n      const weight = weighting.value;\n      const out = classify(query, k, metric, weight);\n      lastNeighbors = out.neighbors;\n      const label = out.label;\n      if (label === null) {\n        resultDiv.innerHTML = 'Query result: <em>none</em>';\n      } else {\n        const probs = out.probs;\n        const probStr = Object.keys(probs).map(l => `${CLASS_LABELS[l]}: ${(probs[l]*100).toFixed(1)}%`).join(' · ');\n        resultDiv.innerHTML = `Query result: <strong style=\"color:${CLASS_COLORS[label]}\">${CLASS_LABELS[label]}</strong> (${probStr})`;\n      }\n      if (out.neighbors.length === 0) {\n        neighborsDiv.textContent = 'Nearest neighbors: none';\n      } else {\n        neighborsDiv.textContent = 'Nearest neighbors: ' + out.neighbors.map(n => `${CLASS_LABELS[n.label]} (${n.dist.toFixed(1)})`).join(', ');\n      }\n      draw();\n    }\n\n    // Event handlers\n    canvas.addEventListener('pointerdown', evt => {\n      evt.preventDefault();\n      const pos = getMousePos(evt);\n      const m = modeSel.value;\n      if (m === 'add') {\n        const label = parseInt(classSel.value);\n        points.push({ x: pos.x, y: pos.y, label });\n        updateClassificationDisplay();\n      } else if (m === 'query') {\n        query = { x: pos.x, y: pos.y };\n        updateClassificationDisplay();\n      } else if (m === 'erase') {\n        // find nearest training point and remove it\n        if (points.length === 0) return;\n        let bestIdx = -1, bestDist = Infinity;\n        for (let i=0;i<points.length;i++){\n          const d = Math.hypot(points[i].x - pos.x, points[i].y - pos.y);\n          if (d < bestDist) { bestDist = d; bestIdx = i; }\n        }\n        if (bestIdx >= 0 && bestDist < 20) {\n          points.splice(bestIdx,1);\n          updateClassificationDisplay();\n        }\n      }\n    });\n\n    // disable context menu on canvas so right-click doesn't interfere\n    canvas.addEventListener('contextmenu', evt => evt.preventDefault());\n\n    // UI listeners\n    kRange.addEventListener('input', () => {\n      kVal.textContent = kRange.value;\n      updateClassificationDisplay();\n    });\n    distMetric.addEventListener('change', updateClassificationDisplay);\n    weighting.addEventListener('change', updateClassificationDisplay);\n    classSel.addEventListener('change', ()=>{}); // no-op but keeps control responsive\n\n    clearBtn.addEventListener('click', () => {\n      points = [];\n      query = null;\n      lastNeighbors = [];\n      updateClassificationDisplay();\n    });\n\n    randomBtn.addEventListener('click', () => {\n      generateRandomClusters();\n      updateClassificationDisplay();\n    });\n\n    boundaryBtn.addEventListener('click', () => {\n      showRegions = !showRegions;\n      updateClassificationDisplay();\n    });\n\n    autoClassifyBtn.addEventListener('click', () => {\n      // place query at mouse center (or random) and classify\n      // We'll place it at center for demo and show classification\n      query = { x: canvas.width/2 + (Math.random()-0.5)*120, y: canvas.height/2 + (Math.random()-0.5)*120 };\n      updateClassificationDisplay();\n    });\n\n    explainBtn.addEventListener('click', () => {\n      if (!query) {\n        alert('Place a query point first (switch to \"Place query point\" and click on the canvas).');\n        return;\n      }\n      const k = parseInt(kRange.value);\n      const out = classify(query, k, distMetric.value, weighting.value);\n      if (!out || out.neighbors.length === 0) {\n        alert('No neighbors or no training points exist.');\n        return;\n      }\n      let msg = `Classification explanation (k=${k}, metric=${distMetric.value}, weighting=${weighting.value}):\\n\\n`;\n      msg += `Nearest neighbors (closest first):\\n`;\n      out.neighbors.forEach((n,i) => {\n        msg += `${i+1}. Class ${CLASS_LABELS[n.label]} — distance ${n.dist.toFixed(2)} px\\n`;\n      });\n      msg += `\\nPredicted class: ${CLASS_LABELS[out.label]}\\nProbabilities:\\n`;\n      for (const l in out.probs) {\n        msg += `  ${CLASS_LABELS[l]}: ${(out.probs[l]*100).toFixed(1)}%\\n`;\n      }\n      alert(msg);\n    });\n\n    // helper to generate synthetic clusters for demo\n    function generateRandomClusters() {\n      points = [];\n      const w = canvas.width, h = canvas.height;\n      // create up to 3 clusters depending on selected classes\n      const classesToGenerate = parseInt(classSel.options.length);\n      // but we will always generate for the three known classes\n      const centers = [\n        {x: w*0.3 + (Math.random()-0.5)*40, y: h*0.4 + (Math.random()-0.5)*40},\n        {x: w*0.7 + (Math.random()-0.5)*60, y: h*0.6 + (Math.random()-0.5)*30},\n        {x: w*0.5 + (Math.random()-0.5)*140, y: h*0.25 + (Math.random()-0.5)*40}\n      ];\n      const perClass = 25;\n      for (let cls=0; cls<3; cls++){\n        for (let i=0;i<perClass;i++){\n          const cx = centers[cls].x + randNormal()*40;\n          const cy = centers[cls].y + randNormal()*40;\n          if (cx < 8 || cx > w-8 || cy < 8 || cy > h-8) continue;\n          points.push({x: cx, y: cy, label: cls});\n        }\n      }\n      // add some random noise points\n      for (let i=0;i<12;i++){\n        points.push({ x: Math.random()*w, y: Math.random()*h, label: Math.floor(Math.random()*3) });\n      }\n      query = null;\n      lastNeighbors = [];\n      draw();\n    }\n\n    // small normal distribution generator (Box-Muller)\n    function randNormal() {\n      let u = 0, v = 0;\n      while (u === 0) u = Math.random();\n      while (v === 0) v = Math.random();\n      return Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);\n    }\n\n    // initialize with random clusters\n    generateRandomClusters();\n\n    // expose resize handling (if canvas displayed larger than actual size, scale)\n    function fitCanvasToDisplay() {\n      // keep logical size as defined in attributes; if you want retina scaling you can multiply\n      // For simplicity we keep as is.\n      draw();\n    }\n    window.addEventListener('resize', fitCanvasToDisplay);\n\n    // initial draw\n    updateClassificationDisplay();\n\n    // small demo: clicking while holding Shift toggles query without changing mode (convenience)\n    window.addEventListener('keydown', (e) => {\n      if (e.key === 'r') generateRandomClusters();\n    });\n\n    // allow removal of last point via keyboard 'Backspace' when in add mode\n    window.addEventListener('keydown', (e) => {\n      if (e.key === 'Backspace' && modeSel.value === 'add') {\n        points.pop();\n        updateClassificationDisplay();\n      }\n    });\n\n    // make canvas respond to pointer move for interactive preview (optional)\n    canvas.addEventListener('pointermove', (evt) => {\n      // optional: show a ghost query for preview in query mode\n      if (modeSel.value === 'query') {\n        const pos = getMousePos(evt);\n        // preview without committing to query\n        draw();\n        // draw ghost query\n        ctx.beginPath();\n        ctx.fillStyle = 'rgba(0,0,0,0.08)';\n        ctx.arc(pos.x, pos.y, 9, 0, Math.PI*2);\n        ctx.fill();\n        ctx.strokeStyle = '#222';\n        ctx.lineWidth = 1;\n        ctx.stroke();\n      }\n    });\n\n    // Make sure UI updates when class color selection changes (not necessary but helpful)\n    classSel.addEventListener('change', () => { /* no op for now */ });\n\n    // Provide graceful fallback if no points\n    updateClassificationDisplay();\n\n  })();\n  </script>\n</body>\n</html>"
  },
