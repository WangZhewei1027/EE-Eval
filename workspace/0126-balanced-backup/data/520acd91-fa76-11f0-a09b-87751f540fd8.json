    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>DNS Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        #dns {\n            width: 50%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #dns h2 {\n            margin-top: 0;\n        }\n    </style>\n</head>\n<body>\n    <h1>DNS Example</h1>\n    <div id=\"dns\"></div>\n    <script>\n        const dns = {\n            'www.example.com': '192.0.2.1',\n            'www.google.com': '216.58.194.174',\n            'www.example.com.': '192.0.2.1'\n        };\n\n        function getDomainName(domain) {\n            const parts = domain.split('.');\n            let name = parts[parts.length - 2] + '.' + parts[parts.length - 1];\n            return name;\n        }\n\n        function dnsQuery(domain) {\n            if (dns[domain]) {\n                return dns[domain];\n            } else {\n                return 'No DNS entry found for ' + domain;\n            }\n        }\n\n        const dnsInput = document.getElementById('dns');\n        dnsInput.value = dnsQuery('www.example.com');\n\n        dnsInput.addEventListener('input', function() {\n            dnsInput.value = dnsQuery(dnsInput.value);\n        });\n    </script>\n</body>\n</html>"
