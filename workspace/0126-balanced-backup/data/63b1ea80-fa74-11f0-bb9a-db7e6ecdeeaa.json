    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>A* Search Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    margin-bottom: 5px;\n  }\n  #grid {\n    display: grid;\n    grid-template-columns: repeat(25, 22px);\n    grid-template-rows: repeat(25, 22px);\n    gap: 2px;\n    user-select: none;\n    margin-bottom: 15px;\n  }\n  .cell {\n    width: 22px;\n    height: 22px;\n    border: 1px solid #ddd;\n    background-color: white;\n    box-sizing: border-box;\n    cursor: pointer;\n  }\n  .cell.wall {\n    background-color: #333;\n    cursor: not-allowed;\n  }\n  .cell.start {\n    background-color: #3aeb87;\n  }\n  .cell.end {\n    background-color: #eb3a3a;\n  }\n  .cell.open {\n    background-color: #8abeeb;\n  }\n  .cell.closed {\n    background-color: #1a60a3;\n  }\n  .cell.path {\n    background-color: #f1c40f;\n  }\n  #controls {\n    display: flex;\n    gap: 10px;\n    margin-bottom: 20px;\n  }\n  button {\n    font-size: 14px;\n    padding: 6px 12px;\n    cursor: pointer;\n  }\n  button:disabled {\n    cursor: default;\n    opacity: 0.5;\n  }\n  #info {\n    max-width: 550px;\n    text-align: center;\n  }\n  #legend {\n    display: flex;\n    gap: 10px;\n    margin-top: 10px;\n    flex-wrap: wrap;\n    justify-content: center;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    font-size: 14px;\n  }\n  .legend-color {\n    width: 18px;\n    height: 18px;\n    border: 1px solid #bbb;\n  }\n  .legend-wall { background: #333; }\n  .legend-start { background: #3aeb87; }\n  .legend-end { background: #eb3a3a; }\n  .legend-open { background: #8abeeb; }\n  .legend-closed { background: #1a60a3; }\n  .legend-path { background: #f1c40f; }\n</style>\n</head>\n<body>\n<h1>A* Search Visualization</h1>\n<div id=\"grid\" aria-label=\"Grid for A* pathfinding visualization\" role=\"grid\"></div>\n<div id=\"controls\">\n  <button id=\"setStartBtn\" aria-pressed=\"false\">Set Start</button>\n  <button id=\"setEndBtn\" aria-pressed=\"false\">Set End</button>\n  <button id=\"addWallsBtn\" aria-pressed=\"true\">Add/Remove Walls</button>\n  <button id=\"runBtn\">Run A* Search</button>\n  <button id=\"clearBtn\">Clear Board</button>\n</div>\n<div id=\"info\" aria-live=\"polite\"></div>\n<div id=\"legend\" aria-label=\"Legend for cell colors\">\n  <div class=\"legend-item\"><div class=\"legend-color legend-wall\"></div> Wall</div>\n  <div class=\"legend-item\"><div class=\"legend-color legend-start\"></div> Start</div>\n  <div class=\"legend-item\"><div class=\"legend-color legend-end\"></div> End</div>\n  <div class=\"legend-item\"><div class=\"legend-color legend-open\"></div> Open set</div>\n  <div class=\"legend-item\"><div class=\"legend-color legend-closed\"></div> Closed set</div>\n  <div class=\"legend-item\"><div class=\"legend-color legend-path\"></div> Final Path</div>\n</div>\n\n<script>\n(() => {\n  const ROWS = 25;\n  const COLS = 25;\n\n  // States for user interaction mode\n  const MODE = {\n    ADD_WALLS: 'add_walls',\n    SET_START: 'set_start',\n    SET_END: 'set_end',\n  };\n  let currentMode = MODE.ADD_WALLS;\n\n  const gridElement = document.getElementById('grid');\n  const infoElement = document.getElementById('info');\n  const setStartBtn = document.getElementById('setStartBtn');\n  const setEndBtn = document.getElementById('setEndBtn');\n  const addWallsBtn = document.getElementById('addWallsBtn');\n  const runBtn = document.getElementById('runBtn');\n  const clearBtn = document.getElementById('clearBtn');\n\n  // Data structures for cells\n  class Cell {\n    constructor(row, col) {\n      this.row = row;\n      this.col = col;\n      this.isWall = false;\n      this.isStart = false;\n      this.isEnd = false;\n\n      // A* parameters\n      this.g = Infinity; // cost from start node\n      this.h = Infinity; // heuristic cost to end node\n      this.f = Infinity; // g + h\n      this.parent = null;\n\n      this.status = 'unvisited'; // unvisited, open, closed, path\n\n      // DOM element for this cell\n      this.element = document.createElement('div');\n      this.element.classList.add('cell');\n      this.element.setAttribute('role', 'gridcell');\n      this.element.setAttribute('aria-label', `Cell r${row} c${col}`);\n      this.element.dataset.row = row;\n      this.element.dataset.col = col;\n\n      this.element.tabIndex = 0; // make focusable for accessibility\n\n      // Event listeners will be added after creating cell\n    }\n\n    reset() {\n      this.isWall = false;\n      this.isStart = false;\n      this.isEnd = false;\n      this.g = Infinity;\n      this.h = Infinity;\n      this.f = Infinity;\n      this.parent = null;\n      this.status = 'unvisited';\n      this.updateVisual();\n    }\n\n    updateVisual() {\n      this.element.className = 'cell'; // reset classes\n      if (this.isWall) this.element.classList.add('wall');\n      else if (this.isStart) this.element.classList.add('start');\n      else if (this.isEnd) this.element.classList.add('end');\n      else if (this.status === 'open') this.element.classList.add('open');\n      else if (this.status === 'closed') this.element.classList.add('closed');\n      else if (this.status === 'path') this.element.classList.add('path');\n      // otherwise plain cell\n    }\n  }\n\n  // Initialize grid data\n  const grid = [];\n  for (let r = 0; r < ROWS; r++) {\n    const row = [];\n    for (let c = 0; c < COLS; c++) {\n      const cell = new Cell(r, c);\n      row.push(cell);\n      gridElement.appendChild(cell.element);\n    }\n    grid.push(row);\n  }\n\n  // Start and end cells default\n  let startCell = grid[0][0];\n  startCell.isStart = true;\n  startCell.updateVisual();\n  let endCell = grid[ROWS - 1][COLS - 1];\n  endCell.isEnd = true;\n  endCell.updateVisual();\n\n  function setMode(newMode) {\n    currentMode = newMode;\n    setStartBtn.setAttribute('aria-pressed', newMode === MODE.SET_START);\n    setEndBtn.setAttribute('aria-pressed', newMode === MODE.SET_END);\n    addWallsBtn.setAttribute('aria-pressed', newMode === MODE.ADD_WALLS);\n\n    infoElement.textContent = (() => {\n      switch(newMode) {\n        case MODE.ADD_WALLS: return 'Click on cells to add/remove walls.';\n        case MODE.SET_START: return 'Click on a cell to set the start position.';\n        case MODE.SET_END: return 'Click on a cell to set the end position.';\n      }\n    })();\n  }\n  setMode(MODE.ADD_WALLS);\n\n  // User clicks on cells in the grid\n  function onCellClick(e) {\n    const r = +e.target.dataset.row;\n    const c = +e.target.dataset.col;\n    const cell = grid[r][c];\n\n    if (runInProgress) return; // disable interaction while running\n\n    if (currentMode === MODE.ADD_WALLS) {\n      if (cell.isStart || cell.isEnd) return;\n      cell.isWall = !cell.isWall;\n      cell.updateVisual();\n    } else if (currentMode === MODE.SET_START) {\n      if (cell.isWall || cell.isEnd) return;\n      startCell.isStart = false;\n      startCell.updateVisual();\n      cell.isStart = true;\n      startCell = cell;\n      cell.updateVisual();\n      // Reset pathfinding results\n      resetPathfindingVisuals();\n    } else if (currentMode === MODE.SET_END) {\n      if (cell.isWall || cell.isStart) return;\n      endCell.isEnd = false;\n      endCell.updateVisual();\n      cell.isEnd = true;\n      endCell = cell;\n      cell.updateVisual();\n      // Reset pathfinding results\n      resetPathfindingVisuals();\n    }\n  }\n\n  gridElement.addEventListener('click', onCellClick);\n\n  // Keydown to toggle walls with space for accessibility\n  gridElement.addEventListener('keydown', e => {\n    if (e.key === ' ' || e.key === 'Enter') {\n      e.preventDefault();\n      e.target.click();\n    }\n  });\n\n  // Button event handlers\n  setStartBtn.onclick = () => setMode(MODE.SET_START);\n  setEndBtn.onclick = () => setMode(MODE.SET_END);\n  addWallsBtn.onclick = () => setMode(MODE.ADD_WALLS);\n  clearBtn.onclick = () => {\n    if (runInProgress) return;\n    for (const row of grid) {\n      for (const cell of row) {\n        cell.isWall = false;\n        cell.status = 'unvisited';\n        cell.g = Infinity;\n        cell.h = Infinity;\n        cell.f = Infinity;\n        cell.parent = null;\n        cell.updateVisual();\n      }\n    }\n    // Restore start/end cells in case they were cleared visually by reset\n    startCell.isStart = true;\n    startCell.updateVisual();\n    endCell.isEnd = true;\n    endCell.updateVisual();\n    infoElement.textContent = 'Board cleared. You can add walls, set start/end, and run A*.';\n  };\n\n  // Reset cells with open/closed/path states before a new run\n  function resetPathfindingVisuals() {\n    for (const row of grid) {\n      for (const cell of row) {\n        cell.status = 'unvisited';\n        cell.g = Infinity;\n        cell.h = Infinity;\n        cell.f = Infinity;\n        cell.parent = null;\n        // Keep wall/start/end states but reset styling for states\n        if (!cell.isWall && !cell.isStart && !cell.isEnd) {\n          cell.updateVisual();\n        }\n      }\n    }\n  }\n\n  // Manhattan distance heuristic\n  function heuristic(a, b) {\n    return Math.abs(a.row - b.row) + Math.abs(a.col - b.col);\n  }\n\n  // A* Search algorithm (async for visualization)\n  let runInProgress = false;\n\n  async function runAStar() {\n    if (runInProgress) return;\n    resetPathfindingVisuals();\n    infoElement.textContent = 'Running A* Search...';\n    runInProgress = true;\n    disableControls(true);\n\n    // Initialize start node\n    startCell.g = 0;\n    startCell.h = heuristic(startCell, endCell);\n    startCell.f = startCell.h;\n\n    // Priority queue implementation: simple array with sorting (for clarity)\n    // For performance, a real priority queue would be better\n    let openSet = [startCell];\n    startCell.status = 'open';\n    startCell.updateVisual();\n\n    while (openSet.length > 0) {\n      // Sort openSet by f value (lowest f first)\n      openSet.sort((a, b) => a.f - b.f);\n      const current = openSet.shift();\n      current.status = 'closed';\n      current.updateVisual();\n\n      if (current === endCell) {\n        infoElement.textContent = 'Path found!';\n        // Reconstruct path\n        let pathNode = current;\n        const pathCells = [];\n        while (pathNode) {\n          pathCells.push(pathNode);\n          pathNode = pathNode.parent;\n        }\n        // Draw path from start to end\n        for (const node of pathCells) {\n          if (node !== startCell && node !== endCell) {\n            node.status = 'path';\n            node.updateVisual();\n            await sleep(20);\n          }\n        }\n        runInProgress = false;\n        disableControls(false);\n        return;\n      }\n\n      // Check neighbors (up, right, down, left)\n      const neighbors = [];\n      const directions = [\n        [-1, 0],\n        [0, 1],\n        [1, 0],\n        [0, -1],\n      ];\n      for (const [dr, dc] of directions) {\n        const nr = current.row + dr;\n        const nc = current.col + dc;\n        if (nr >= 0 && nr < ROWS && nc >= 0 && nc < COLS) {\n          neighbors.push(grid[nr][nc]);\n        }\n      }\n\n      for (const neighbor of neighbors) {\n        if (neighbor.isWall || neighbor.status === 'closed') continue;\n\n        const tentativeG = current.g + 1;\n\n        if (tentativeG < neighbor.g) {\n          neighbor.parent = current;\n          neighbor.g = tentativeG;\n          neighbor.h = heuristic(neighbor, endCell);\n          neighbor.f = neighbor.g + neighbor.h;\n\n          if (neighbor.status !== 'open') {\n            openSet.push(neighbor);\n            neighbor.status = 'open';\n            neighbor.updateVisual();\n          }\n        }\n      }\n\n      // Visualization speed\n      await sleep(15);\n    }\n\n    infoElement.textContent = 'No path found.';\n    runInProgress = false;\n    disableControls(false);\n  }\n\n  // Utility sleep function for async visual delays\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  function disableControls(disable) {\n    setStartBtn.disabled = disable;\n    setEndBtn.disabled = disable;\n    addWallsBtn.disabled = disable;\n    clearBtn.disabled = disable;\n    runBtn.disabled = disable;\n  }\n\n  runBtn.onclick = runAStar;\n\n  // Initial help text\n  infoElement.textContent = 'Use the buttons to set start/end points or add/remove walls, then run A* Search.';\n})();\n</script>\n</body>\n</html>"
