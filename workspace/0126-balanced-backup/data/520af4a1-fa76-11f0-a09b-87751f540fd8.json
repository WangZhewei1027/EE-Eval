    "content": "<html>\n<head>\n    <title>REST API Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #f9f9f9;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        .header {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n        .button {\n            background-color: #4CAF50;\n            color: #fff;\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h2>REST API Demo</h2>\n            <p>This is a REST API demo that uses Node.js and Express.js.</p>\n        </div>\n        <button class=\"button\" onclick=\"getUsers()\">Get Users</button>\n        <div id=\"users\"></div>\n    </div>\n\n    <script>\n        const express = require('express');\n        const app = express();\n        const port = 3000;\n\n        // In-memory data store\n        const users = [\n            { id: 1, name: 'John Doe', email: 'john@example.com' },\n            { id: 2, name: 'Jane Doe', email: 'jane@example.com' },\n            { id: 3, name: 'Bob Smith', email: 'bob@example.com' }\n        ];\n\n        // GET /users\n        app.get('/users', (req, res) => {\n            res.json(users);\n        });\n\n        // POST /users\n        app.post('/users', (req, res) => {\n            const { name, email } = req.body;\n            users.push({ id: users.length + 1, name, email });\n            res.json(users);\n        });\n\n        // PUT /users/:id\n        app.put('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            const { name, email } = req.body;\n            users[id - 1] = { id, name, email };\n            res.json(users);\n        });\n\n        // DELETE /users/:id\n        app.delete('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            users = users.filter((user) => user.id !== id);\n            res.json(users);\n        });\n\n        // GET /users/:id\n        app.get('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            const user = users.find((user) => user.id === id);\n            if (user) {\n                res.json(user);\n            } else {\n                res.status(404).json({ message: 'User not found' });\n            }\n        });\n\n        // POST /users\n        app.post('/users', (req, res) => {\n            const { name, email } = req.body;\n            users.push({ id: users.length + 1, name, email });\n            res.json(users);\n        });\n\n        // PUT /users/:id\n        app.put('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            const { name, email } = req.body;\n            users[id - 1] = { id, name, email };\n            res.json(users);\n        });\n\n        // DELETE /users/:id\n        app.delete('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            users = users.filter((user) => user.id !== id);\n            res.json(users);\n        });\n\n        // GET /users\n        app.get('/users', (req, res) => {\n            res.json(users);\n        });\n\n        // POST /users\n        app.post('/users', (req, res) => {\n            const { name, email } = req.body;\n            users.push({ id: users.length + 1, name, email });\n            res.json(users);\n        });\n\n        // PUT /users/:id\n        app.put('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            const { name, email } = req.body;\n            users[id - 1] = { id, name, email };\n            res.json(users);\n        });\n\n        // DELETE /users/:id\n        app.delete('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            users = users.filter((user) => user.id !== id);\n            res.json(users);\n        });\n\n        // GET /users/:id\n        app.get('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            const user = users.find((user) => user.id === id);\n            if (user) {\n                res.json(user);\n            } else {\n                res.status(404).json({ message: 'User not found' });\n            }\n        });\n\n        // POST /users\n        app.post('/users', (req, res) => {\n            const { name, email } = req.body;\n            users.push({ id: users.length + 1, name, email });\n            res.json(users);\n        });\n\n        // PUT /users/:id\n        app.put('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            const { name, email } = req.body;\n            users[id - 1] = { id, name, email };\n            res.json(users);\n        });\n\n        // DELETE /users/:id\n        app.delete('/users/:id', (req, res) => {\n            const id = parseInt(req.params.id);\n            users = users.filter((user) => user.id !== id);\n            res.json(users);\n        });\n\n        app.listen(port, () => {\n            console.log(`Server listening on port ${port}`);\n        });\n    </script>\n</body>\n</html>"
