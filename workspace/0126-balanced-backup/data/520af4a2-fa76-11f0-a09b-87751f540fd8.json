    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Version Control</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #versionControl {\n            width: 500px;\n            margin: 20px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        #versionControl h1 {\n            text-align: center;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"versionControl\">\n        <h1>Version Control</h1>\n        <p>This is a simple version control system. We will be using Git to track changes.</p>\n        <button id=\"addFile\">Add File</button>\n        <button id=\"commitChanges\">Commit Changes</button>\n        <button id=\"pullChanges\">Pull Changes</button>\n        <button id=\"listChanges\">List Changes</button>\n    </div>\n\n    <script>\n        const addFileButton = document.getElementById('addFile');\n        const commitChangesButton = document.getElementById('commitChanges');\n        const pullChangesButton = document.getElementById('pullChanges');\n        const listChangesButton = document.getElementById('listChanges');\n        const versionControlElement = document.getElementById('versionControl');\n\n        addFileButton.addEventListener('click', () => {\n            const file = prompt('Enter the name of the file you want to add:');\n            if (file) {\n                const fileContent = prompt('Enter the content of the file:');\n                if (fileContent) {\n                    const newFile = document.createElement('div');\n                    newFile.textContent = fileContent;\n                    newFile.style.width = '100%';\n                    newFile.style.height = '100px';\n                    newFile.style.padding = '10px';\n                    newFile.style.border = '1px solid #ccc';\n                    newFile.style.boxShadow = '0 0 10px rgba(0, 0, 0, 0.1)';\n                    newFile.style.background = 'lightgray';\n                    versionControlElement.appendChild(newFile);\n                }\n            }\n        });\n\n        commitChangesButton.addEventListener('click', () => {\n            const fileContent = document.getElementById('fileContent').value;\n            if (fileContent) {\n                const newFile = document.createElement('div');\n                newFile.textContent = fileContent;\n                newFile.style.width = '100%';\n                newFile.style.height = '100px';\n                newFile.style.padding = '10px';\n                newFile.style.border = '1px solid #ccc';\n                newFile.style.boxShadow = '0 0 10px rgba(0, 0, 0, 0.1)';\n                newFile.style.background = 'lightgray';\n                versionControlElement.appendChild(newFile);\n                document.getElementById('fileContent').value = '';\n            }\n        });\n\n        pullChangesButton.addEventListener('click', () => {\n            const fileContent = document.getElementById('fileContent').value;\n            if (fileContent) {\n                const newFile = document.createElement('div');\n                newFile.textContent = fileContent;\n                newFile.style.width = '100%';\n                newFile.style.height = '100px';\n                newFile.style.padding = '10px';\n                newFile.style.border = '1px solid #ccc';\n                newFile.style.boxShadow = '0 0 10px rgba(0, 0, 0, 0.1)';\n                newFile.style.background = 'lightgray';\n                versionControlElement.appendChild(newFile);\n                document.getElementById('fileContent').value = '';\n            }\n        });\n\n        listChangesButton.addEventListener('click', () => {\n            const fileContent = document.getElementById('fileContent').value;\n            if (fileContent) {\n                const newFile = document.createElement('div');\n                newFile.textContent = fileContent;\n                newFile.style.width = '100%';\n                newFile.style.height = '100px';\n                newFile.style.padding = '10px';\n                newFile.style.border = '1px solid #ccc';\n                newFile.style.boxShadow = '0 0 10px rgba(0, 0, 0, 0.1)';\n                newFile.style.background = 'lightgray';\n                versionControlElement.appendChild(newFile);\n            }\n        });\n\n        const fileContent = document.getElementById('fileContent').value;\n        if (fileContent) {\n            const newFile = document.createElement('div');\n            newFile.textContent = fileContent;\n            newFile.style.width = '100%';\n            newFile.style.height = '100px';\n            newFile.style.padding = '10px';\n            newFile.style.border = '1px solid #ccc';\n            newFile.style.boxShadow = '0 0 10px rgba(0, 0, 0, 0.1)';\n            newFile.style.background = 'lightgray';\n            versionControlElement.appendChild(newFile);\n            document.getElementById('fileContent').value = '';\n        }\n    </script>\n</body>\n</html>"
