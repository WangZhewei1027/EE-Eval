    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Multiset Demonstration</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      max-width: 700px;\n      margin: 2rem auto;\n      padding: 0 1rem;\n      background: #f9f9f9;\n      color: #333;\n    }\n    h1, h2 {\n      color: #2c3e50;\n    }\n    input, button {\n      font-size: 1rem;\n      padding: 0.5rem;\n      margin-right: 0.5rem;\n    }\n    button {\n      cursor: pointer;\n      background-color: #2980b9;\n      border: none;\n      color: white;\n      border-radius: 4px;\n      transition: background-color 0.3s ease;\n    }\n    button:hover {\n      background-color: #3498db;\n    }\n    #elements-list {\n      margin-top: 1rem;\n      padding: 1rem;\n      background: white;\n      border: 1px solid #ddd;\n      border-radius: 5px;\n      min-height: 50px;\n      font-family: monospace;\n      white-space: pre-wrap;\n    }\n    small {\n      color: #777;\n    }\n    .section {\n      margin-bottom: 2rem;\n    }\n    label {\n      display: block;\n      margin-bottom: 0.3rem;\n      font-weight: bold;\n    }\n  </style>\n</head>\n<body>\n  <h1>Multiset (Bag) Demonstration</h1>\n  <p>\n    A <strong>Multiset</strong> is like a set but allows multiple occurrences of the same element.\n    This example implements a simple multiset class in JavaScript and lets you add, remove, and query elements with multiplicities.\n  </p>\n\n  <div class=\"section\">\n    <h2>Multiset Class Implementation</h2>\n    <pre><code class=\"js\">\n// Multiset class stores elements with counts\nclass Multiset {\n  constructor() {\n    this.map = new Map(); // element -> count\n  }\n\n  add(element, count = 1) {\n    if(count <= 0) return;\n    this.map.set(element, (this.map.get(element) || 0) + count);\n  }\n\n  remove(element, count = 1) {\n    if(!this.map.has(element)) return;\n    const currentCount = this.map.get(element);\n    if(count >= currentCount) {\n      this.map.delete(element);\n    } else {\n      this.map.set(element, currentCount - count);\n    }\n  }\n\n  count(element) {\n    return this.map.get(element) || 0;\n  }\n\n  has(element) {\n    return this.map.has(element);\n  }\n\n  // Total number of elements including duplicates\n  size() {\n    let total = 0;\n    for(const count of this.map.values()) {\n      total += count;\n    }\n    return total;\n  }\n\n  // Number of distinct elements\n  distinctSize() {\n    return this.map.size;\n  }\n\n  // Returns an array of [element, count]\n  entries() {\n    return Array.from(this.map.entries());\n  }\n\n  clear() {\n    this.map.clear();\n  }\n\n  // Convert to string format like: a:3, b:1, c:5\n  toString() {\n    if(this.map.size === 0) return \"(empty)\";\n    return Array.from(this.map.entries())\n      .map(([el, count]) => `${el}: ${count}`)\n      .join(\", \");\n  }\n}\n    </code></pre>\n  </div>\n\n  <div class=\"section\">\n    <h2>Interact with the Multiset</h2>\n\n    <label for=\"elementInput\">Element (string or number):</label>\n    <input type=\"text\" id=\"elementInput\" placeholder=\"Enter element\" />\n\n    <label for=\"countInput\">Count (default 1):</label>\n    <input type=\"number\" id=\"countInput\" placeholder=\"1\" min=\"1\" />\n\n    <div style=\"margin-top:0.5rem;\">\n      <button id=\"addBtn\">Add</button>\n      <button id=\"removeBtn\">Remove</button>\n    </div>\n\n    <div style=\"margin-top:1rem;\">\n      <button id=\"clearBtn\" style=\"background:#c0392b;\">Clear Multiset</button>\n    </div>\n\n    <div class=\"section\" style=\"margin-top: 2rem;\">\n      <h3>Multiset Contents</h3>\n      <div id=\"elements-list\">(empty)</div>\n      <small>Shows elements with their multiplicities.</small>\n    </div>\n\n    <div class=\"section\">\n      <h3>Multiset Stats</h3>\n      <p><strong>Total elements (including duplicates):</strong> <span id=\"totalSize\">0</span></p>\n      <p><strong>Distinct elements count:</strong> <span id=\"distinctSize\">0</span></p>\n    </div>\n  </div>\n\n  <script>\n    // The Multiset class from above\n    class Multiset {\n      constructor() {\n        this.map = new Map();\n      }\n      add(element, count = 1) {\n        if(count <= 0) return;\n        this.map.set(element, (this.map.get(element) || 0) + count);\n      }\n      remove(element, count = 1) {\n        if(!this.map.has(element)) return;\n        const currentCount = this.map.get(element);\n        if(count >= currentCount) {\n          this.map.delete(element);\n        } else {\n          this.map.set(element, currentCount - count);\n        }\n      }\n      count(element) {\n        return this.map.get(element) || 0;\n      }\n      has(element) {\n        return this.map.has(element);\n      }\n      size() {\n        let total = 0;\n        for(const count of this.map.values()) {\n          total += count;\n        }\n        return total;\n      }\n      distinctSize() {\n        return this.map.size;\n      }\n      entries() {\n        return Array.from(this.map.entries());\n      }\n      clear() {\n        this.map.clear();\n      }\n      toString() {\n        if(this.map.size === 0) return \"(empty)\";\n        return Array.from(this.map.entries())\n          .map(([el, count]) => `${el}: ${count}`)\n          .join(\", \");\n      }\n    }\n\n    // App code\n    const multiset = new Multiset();\n\n    const elementInput = document.getElementById('elementInput');\n    const countInput = document.getElementById('countInput');\n    const addBtn = document.getElementById('addBtn');\n    const removeBtn = document.getElementById('removeBtn');\n    const clearBtn = document.getElementById('clearBtn');\n\n    const elementsList = document.getElementById('elements-list');\n    const totalSizeSpan = document.getElementById('totalSize');\n    const distinctSizeSpan = document.getElementById('distinctSize');\n\n    function updateDisplay() {\n      elementsList.textContent = multiset.toString();\n      totalSizeSpan.textContent = multiset.size();\n      distinctSizeSpan.textContent = multiset.distinctSize();\n    }\n\n    function parseCount(value) {\n      const count = parseInt(value, 10);\n      if(isNaN(count) || count < 1) return 1;\n      return count;\n    }\n\n    addBtn.addEventListener('click', () => {\n      const el = elementInput.value.trim();\n      if(el === '') {\n        alert('Please enter an element to add.');\n        return;\n      }\n      const count = parseCount(countInput.value);\n      multiset.add(el, count);\n      updateDisplay();\n    });\n\n    removeBtn.addEventListener('click', () => {\n      const el = elementInput.value.trim();\n      if(el === '') {\n        alert('Please enter an element to remove.');\n        return;\n      }\n      const count = parseCount(countInput.value);\n      multiset.remove(el, count);\n      updateDisplay();\n    });\n\n    clearBtn.addEventListener('click', () => {\n      if(confirm('Are you sure you want to clear the multiset?')) {\n        multiset.clear();\n        updateDisplay();\n      }\n    });\n\n    // Initialize display\n    updateDisplay();\n  </script>\n</body>\n</html>"
