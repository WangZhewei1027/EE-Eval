    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Linear Regression Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    text-align: center;\n    background: #f7f9fc;\n  }\n  canvas {\n    border: 1px solid #ccc;\n    background: white;\n    margin-top: 20px;\n  }\n  #info {\n    max-width: 600px;\n    margin: 10px auto 0 auto;\n    font-size: 14px;\n    color: #333;\n  }\n  #controls {\n    margin-top: 15px;\n  }\n  button {\n    background: #4a90e2;\n    border: none;\n    color: white;\n    padding: 10px 16px;\n    margin: 0 5px;\n    font-size: 14px;\n    border-radius: 4px;\n    cursor: pointer;\n  }\n  button:disabled {\n    background: #a0c3f7;\n    cursor: default;\n  }\n</style>\n</head>\n<body>\n\n<h1>Linear Regression Demonstration</h1>\n<p>Click on the canvas to add data points. The blue line shows the best fit linear regression line updated in real-time.</p>\n\n<canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n\n<div id=\"info\">\n  <strong>Equation:</strong> y = <span id=\"slope\">0</span> × x + <span id=\"intercept\">0</span><br/>\n  <strong>R² (coefficient of determination):</strong> <span id=\"r2\">0</span>\n</div>\n\n<div id=\"controls\">\n  <button id=\"resetBtn\">Reset Points</button>\n  <button id=\"randomBtn\">Generate Random Points</button>\n</div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n  const slopeSpan = document.getElementById('slope');\n  const interceptSpan = document.getElementById('intercept');\n  const r2Span = document.getElementById('r2');\n  const resetBtn = document.getElementById('resetBtn');\n  const randomBtn = document.getElementById('randomBtn');\n\n  // Canvas drawing bounds\n  const width = canvas.width;\n  const height = canvas.height;\n\n  // Store points as {x, y} in data space\n  let points = [];\n\n  // Data coordinate system: map pixel to data (x,y)\n  // We'll use a fixed data range to nicely fit points\n  // For simplicity, data x,y range: x from 0 to 10, y from 0 to 10\n  // Data domain\n  const xMin = 0;\n  const xMax = 10;\n  const yMin = 0;\n  const yMax = 10;\n\n  // Convert data x to canvas pixel x\n  function dataXToPixel(x) {\n    return ((x - xMin) / (xMax - xMin)) * width;\n  }\n\n  // Convert data y to canvas pixel y (inverted canvas y axis)\n  function dataYToPixel(y) {\n    return height - ((y - yMin) / (yMax - yMin)) * height;\n  }\n\n  // Convert canvas pixel x to data x\n  function pixelToDataX(px) {\n    return xMin + (px / width) * (xMax - xMin);\n  }\n\n  // Convert canvas pixel y to data y\n  function pixelToDataY(py) {\n    return yMin + ((height - py) / height) * (yMax - yMin);\n  }\n\n  // Draw axes\n  function drawAxes() {\n    ctx.lineWidth = 1;\n    ctx.strokeStyle = '#888';\n    ctx.fillStyle = '#444';\n    ctx.font = '12px Arial';\n\n    // Clear background\n    ctx.fillStyle = '#fff';\n    ctx.fillRect(0, 0, width, height);\n\n    // Draw X axis\n    const zeroY = dataYToPixel(0);\n    ctx.strokeStyle = '#aaa';\n    ctx.beginPath();\n    ctx.moveTo(0, zeroY);\n    ctx.lineTo(width, zeroY);\n    ctx.stroke();\n\n    // Draw Y axis\n    const zeroX = dataXToPixel(0);\n    ctx.beginPath();\n    ctx.moveTo(zeroX, 0);\n    ctx.lineTo(zeroX, height);\n    ctx.stroke();\n\n    // Draw ticks and labels x axis\n    ctx.fillStyle = '#444';\n    for(let i = 0; i <= 10; i++) {\n      const x = dataXToPixel(i);\n      ctx.beginPath();\n      ctx.moveTo(x, zeroY - 5);\n      ctx.lineTo(x, zeroY + 5);\n      ctx.stroke();\n      ctx.fillText(i.toString(), x - 3, zeroY + 20);\n    }\n\n    // Draw ticks and labels y axis\n    for(let i = 0; i <= 10; i++) {\n      const y = dataYToPixel(i);\n      ctx.beginPath();\n      ctx.moveTo(zeroX - 5, y);\n      ctx.lineTo(zeroX + 5, y);\n      ctx.stroke();\n      if(i !== 0) { // Avoid overlapping label at (0,0)\n        ctx.fillText(i.toString(), zeroX - 25, y + 4);\n      }\n    }\n  }\n\n  // Draw all points\n  function drawPoints() {\n    ctx.fillStyle = '#e74c3c';\n    points.forEach(p => {\n      const px = dataXToPixel(p.x);\n      const py = dataYToPixel(p.y);\n      ctx.beginPath();\n      ctx.arc(px, py, 5, 0, Math.PI * 2);\n      ctx.fill();\n    });\n  }\n\n  // Compute linear regression parameters: slope (m) and intercept (b)\n  // Using least squares formula:\n  // m = covariance(x,y) / variance(x)\n  // b = mean(y) - m * mean(x)\n  function linearRegression(points) {\n    const n = points.length;\n    if (n < 2) {\n      return null;\n    }\n\n    let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;\n    points.forEach(p => {\n      sumX += p.x;\n      sumY += p.y;\n      sumXY += p.x * p.y;\n      sumX2 += p.x * p.x;\n    });\n    const meanX = sumX / n;\n    const meanY = sumY / n;\n\n    const numerator = sumXY - n * meanX * meanY;\n    const denominator = sumX2 - n * meanX * meanX;\n    if (denominator === 0) {\n      // Vertical line or identical x points\n      return null;\n    }\n    const m = numerator / denominator;\n    const b = meanY - m * meanX;\n\n    // Calculate R^2\n    let ssTot = 0;\n    let ssRes = 0;\n    points.forEach(p => {\n      const yPred = m * p.x + b;\n      ssTot += (p.y - meanY) * (p.y - meanY);\n      ssRes += (p.y - yPred) * (p.y - yPred);\n    });\n    const r2 = ssTot === 0 ? 1 : 1 - (ssRes / ssTot);\n\n    return { m, b, r2 };\n  }\n\n  // Draw regression line\n  function drawRegressionLine(reg) {\n    if (!reg) return;\n    ctx.strokeStyle = '#3498db';\n    ctx.lineWidth = 2;\n\n    // We draw line from xMin to xMax\n    const x1 = xMin;\n    const y1 = reg.m * x1 + reg.b;\n    const x2 = xMax;\n    const y2 = reg.m * x2 + reg.b;\n\n    // Clamp y values to canvas y range\n    let p1y = dataYToPixel(y1);\n    let p2y = dataYToPixel(y2);\n\n    ctx.beginPath();\n    ctx.moveTo(dataXToPixel(x1), p1y);\n    ctx.lineTo(dataXToPixel(x2), p2y);\n    ctx.stroke();\n  }\n\n  function redraw() {\n    drawAxes();\n    drawPoints();\n    const reg = linearRegression(points);\n    drawRegressionLine(reg);\n    if (reg) {\n      slopeSpan.textContent = reg.m.toFixed(3);\n      interceptSpan.textContent = reg.b.toFixed(3);\n      r2Span.textContent = reg.r2.toFixed(3);\n    } else {\n      slopeSpan.textContent = '0';\n      interceptSpan.textContent = '0';\n      r2Span.textContent = '0';\n    }\n  }\n\n  // Event: Add a point on click\n  canvas.addEventListener('click', e => {\n    const rect = canvas.getBoundingClientRect();\n    const px = e.clientX - rect.left;\n    const py = e.clientY - rect.top;\n    const x = pixelToDataX(px);\n    const y = pixelToDataY(py);\n    // Clamp points inside data range\n    if (x < xMin || x > xMax || y < yMin || y > yMax) return;\n    points.push({ x, y });\n    redraw();\n  });\n\n  // Reset button\n  resetBtn.addEventListener('click', () => {\n    points = [];\n    redraw();\n  });\n\n  // Generate random points along roughly a line with noise\n  randomBtn.addEventListener('click', () => {\n    // Clear points\n    points = [];\n    // Random slope and intercept for demonstration\n    const m = (Math.random() * 2) - 1; // -1 to 1\n    const b = (Math.random() * 6) + 2; // 2 to 8\n\n    for(let i = 0; i < 20; i++) {\n      const x = Math.random() * (xMax - xMin) + xMin;\n      // y = m*x + b + noise\n      const noise = (Math.random() - 0.5) * 2; // -1 to 1 noise\n      let y = m*x + b + noise;\n      // Clamp y to data range\n      y = Math.min(Math.max(y, yMin), yMax);\n      points.push({ x, y });\n    }\n    redraw();\n  });\n\n  // Initial drawing\n  redraw();\n\n})();\n</script>\n\n</body>\n</html>"
  },
