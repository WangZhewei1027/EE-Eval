    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Integration Testing Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n            color: #333;\n        }\n        h1 {\n            color: #2c3e50;\n            border-bottom: 2px solid #3498db;\n            padding-bottom: 10px;\n        }\n        .test-case {\n            background-color: #f9f9f9;\n            border-left: 4px solid #3498db;\n            padding: 15px;\n            margin: 20px 0;\n            border-radius: 0 4px 4px 0;\n        }\n        .pass {\n            color: #27ae60;\n        }\n        .fail {\n            color: #e74c3c;\n        }\n        button {\n            background-color: #3498db;\n            color: white;\n            border: none;\n            padding: 10px 15px;\n            border-radius: 4px;\n            cursor: pointer;\n            margin: 10px 0;\n        }\n        button:hover {\n            background-color: #2980b9;\n        }\n        #results {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Integration Testing Demonstration</h1>\n    <p>This demo shows how integration testing works by testing the interaction between multiple components.</p>\n    \n    <div class=\"test-case\">\n        <h3>User Authentication System Test</h3>\n        <p>This test verifies that the user authentication flow works properly when components are integrated:</p>\n        <ol>\n            <li>User validation component</li>\n            <li>Database access component</li>\n            <li>Session management component</li>\n        </ol>\n        <button id=\"runAuthTest\">Run Authentication Test</button>\n        <div id=\"authResult\"></div>\n    </div>\n    \n    <div class=\"test-case\">\n        <h3>E-commerce Checkout System Test</h3>\n        <p>This test verifies the shopping cart and payment processing integration:</p>\n        <ol>\n            <li>Cart management component</li>\n            <li>Discount calculation component</li>\n            <li>Payment processing component</li>\n            <li>Order fulfillment component</li>\n        </ol>\n        <button id=\"runCheckoutTest\">Run Checkout Test</button>\n        <div id=\"checkoutResult\"></div>\n    </div>\n    \n    <div id=\"results\"></div>\n\n    <script>\n        // Mock components for our integration tests\n        \n        // User Authentication System Components\n        const userValidation = {\n            validate: (email, password) => {\n                // Simple validation\n                if (!email.includes('@')) return { valid: false, error: 'Invalid email' };\n                if (password.length < 6) return { valid: false, error: 'Password too short' };\n                return { valid: true };\n            }\n        };\n        \n        const userDatabase = {\n            users: [\n                { email: 'test@example.com', password: 'password123', name: 'Test User' },\n                { email: 'admin@example.com', password: 'admin123', name: 'Admin User' }\n            ],\n            findUser: function(email) {\n                return this.users.find(user => user.email === email);\n            },\n            verifyPassword: function(email, password) {\n                const user = this.findUser(email);\n                if (!user) return false;\n                return user.password === password;\n            }\n        };\n        \n        const sessionManager = {\n            currentSession: null,\n            createSession: function(user) {\n                this.currentSession = {\n                    user: user.email,\n                    name: user.name,\n                    token: 'session-' + Math.random().toString(36).substr(2, 9),\n                    createdAt: new Date()\n                };\n                return this.currentSession;\n            },\n            destroySession: function() {\n                this.currentSession = null;\n            }\n        };\n        \n        // E-commerce System Components\n        const cartManager = {\n            cart: [],\n            addItem: function(item) {\n                this.cart.push(item);\n                return this.cart;\n            },\n            getTotal: function() {\n                return this.cart.reduce((total, item) => total + item.price, 0);\n            },\n            clearCart: function() {\n                this.cart = [];\n            }\n        };\n        \n        const discountCalculator = {\n            applyDiscount: function(total, coupon) {\n                if (coupon === 'SAVE10') return total * 0.9;\n                if (coupon === 'SAVE20') return total * 0.8;\n                return total;\n            }\n        };\n        \n        const paymentProcessor = {\n            processPayment: function(amount, card) {\n                // Simple mock payment processing\n                if (card.number.length !== 16) return { success: false, error: 'Invalid card' };\n                if (card.expiry < new Date().getFullYear()) return { success: false, error: 'Card expired' };\n                return { success: true, transactionId: 'txn-' + Math.random().toString(36).substr(2, 12) };\n            }\n        };\n        \n        const orderFulfillment = {\n            createOrder: function(items, paymentInfo) {\n                return {\n                    orderId: 'ord-' + Math.random().toString(36).substr(2, 8),\n                    items: items,\n                    paymentInfo: paymentInfo,\n                    status: 'processing',\n                    date: new Date()\n                };\n            }\n        };\n        \n        // Test Utilities\n        function assert(condition, message) {\n            if (!condition) {\n                throw new Error(message || \"Assertion failed\");\n            }\n        }\n        \n        function runTest(name, testFunc) {\n            try {\n                testFunc();\n                document.getElementById('results').innerHTML += \n                    `<div class=\"test-result pass\">✓ PASS: ${name}</div>`;\n                return true;\n            } catch (error) {\n                document.getElementById('results').innerHTML += \n                    `<div class=\"test-result fail\">✗ FAIL: ${name} - ${error.message}</div>`;\n                return false;\n            }\n        }\n        \n        // Integration Tests\n        function testUserAuthentication() {\n            // Test valid login\n            const validation = userValidation.validate('test@example.com', 'password123');\n            assert(validation.valid, \"User validation should pass\");\n            \n            const user = userDatabase.findUser('test@example.com');\n            assert(user, \"User should exist in database\");\n            \n            const passwordValid = userDatabase.verifyPassword('test@example.com', 'password123');\n            assert(passwordValid, \"Password should match\");\n            \n            const session = sessionManager.createSession(user);\n            assert(session, \"Session should be created\");\n            assert(session.user === 'test@example.com', \"Session should have correct user\");\n            \n            // Clean up\n            sessionManager.destroySession();\n        }\n        \n        function testCheckoutProcess() {\n            // Add items to cart\n            cartManager.addItem({ id: 1, name: 'Product A', price: 100 });\n            cartManager.addItem({ id: 2, name: 'Product B', price: 50 });\n            \n            const total = cartManager.getTotal();\n            assert(total === 150, \"Cart total should be correct\");\n            \n            const discountedTotal = discountCalculator.applyDiscount(total, 'SAVE20');\n            assert(discountedTotal === 120, \"Discount should be applied correctly\");\n            \n            const paymentResult = paymentProcessor.processPayment(discountedTotal, {\n                number: '4111111111111111',\n                expiry: 2025,\n                cvv: '123'\n            });\n            assert(paymentResult.success, \"Payment should process successfully\");\n            \n            const order = orderFulfillment.createOrder(cartManager.cart, paymentResult);\n            assert(order, \"Order should be created\");\n            assert(order.items.length === 2, \"Order should contain correct items\");\n            \n            // Clean up\n            cartManager.clearCart();\n        }\n        \n        // UI Event Handlers\n        document.getElementById('runAuthTest').addEventListener('click', function() {\n            document.getElementById('authResult').innerHTML = '<p>Running tests...</p>';\n            setTimeout(() => {\n                const passed = runTest('User Authentication Integration', testUserAuthentication);\n                const resultDiv = document.getElementById('authResult');\n                if (passed) {\n                    resultDiv.innerHTML = '<p class=\"pass\">✓ Authentication test passed! All components work together correctly.</p>';\n                } else {\n                    resultDiv.innerHTML = '<p class=\"fail\">✗ Authentication test failed. Check console for details.</p>';\n                }\n            }, 500);\n        });\n        \n        document.getElementById('runCheckoutTest').addEventListener('click', function() {\n            document.getElementById('checkoutResult').innerHTML = '<p>Running tests...</p>';\n            setTimeout(() => {\n                const passed = runTest('Checkout Process Integration', testCheckoutProcess);\n                const resultDiv = document.getElementById('checkoutResult');\n                if (passed) {\n                    resultDiv.innerHTML = '<p class=\"pass\">✓ Checkout test passed! All components work together correctly.</p>';\n                } else {\n                    resultDiv.innerHTML = '<p class=\"fail\">✗ Checkout test failed. Check console for details.</p>';\n                }\n            }, 500);\n        });\n    </script>\n</body>\n</html>"
  },
