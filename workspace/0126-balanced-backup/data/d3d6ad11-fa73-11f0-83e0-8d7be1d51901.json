  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Linear Search - Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724; --card:#0b1220; --accent:#06b6d4; --muted:#94a3b8;\n      --good:#10b981; --bad:#ef4444; --highlight:#fbbf24;\n    }\n    *{box-sizing:border-box}\n    body{\n      margin:0;\n      font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: linear-gradient(180deg,#071022 0%, #071728 60%);\n      color:#e6eef6;\n      padding:24px;\n      -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;\n      min-height:100vh;\n    }\n    .container{\n      max-width:1100px;\n      margin:0 auto;\n      display:grid;\n      grid-template-columns: 1fr 360px;\n      gap:20px;\n      align-items:start;\n    }\n    header{\n      grid-column: 1 / -1;\n      margin-bottom:6px;\n    }\n    h1{\n      margin:0 0 6px 0;\n      font-size:22px;\n      letter-spacing:0.2px;\n    }\n    p.lead{margin:0;color:var(--muted);font-size:13px}\n    .card{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);\n      padding:16px;\n      border-radius:10px;\n      box-shadow: 0 6px 24px rgba(2,6,23,0.6);\n    }\n    .controls{display:flex;gap:10px;flex-wrap:wrap;align-items:center}\n    .controls > *{min-width:0}\n    label{font-size:13px;color:var(--muted);display:block;margin-bottom:6px}\n    input[type=\"number\"], input[type=\"text\"], select{\n      padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,0.06);\n      background:transparent;color:inherit;font-size:14px;outline:none;\n    }\n    button{\n      background:var(--accent); color:#04202a; border:0; padding:8px 12px;border-radius:8px;cursor:pointer;font-weight:600;\n      box-shadow: 0 6px 14px rgba(6,182,212,0.14);\n    }\n    button.secondary{\n      background:transparent;color:var(--accent);border:1px solid rgba(6,182,212,0.12);\n      box-shadow:none;font-weight:600;\n    }\n    .row{display:flex;gap:12px;align-items:center}\n    .col{display:flex;flex-direction:column}\n    .array-visual{\n      display:flex;gap:8px;flex-wrap:wrap;padding:12px;border-radius:10px;margin-top:12px;\n      min-height:88px;background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n      align-items:center;\n    }\n    .cell{\n      min-width:48px;height:56px;border-radius:8px;background:rgba(255,255,255,0.03);\n      display:flex;align-items:center;justify-content:center;flex-direction:column;\n      font-weight:700;font-size:16px;border:1px solid rgba(255,255,255,0.03);position:relative;\n      transition:transform .18s, background .18s, border-color .18s;\n      cursor:pointer;\n    }\n    .cell .idx{position:absolute;bottom:4px;right:6px;font-size:11px;color:var(--muted);font-weight:600}\n    .cell.highlight{background:linear-gradient(180deg, rgba(251,191,36,0.15), rgba(255,255,255,0.02)); transform:scale(1.05); border-color:rgba(251,191,36,0.25)}\n    .cell.match{background:linear-gradient(180deg, rgba(16,185,129,0.12), rgba(255,255,255,0.01)); border-color:rgba(16,185,129,0.25)}\n    .cell.nomatch{background:linear-gradient(180deg, rgba(239,68,68,0.08), rgba(255,255,255,0.01)); border-color:rgba(239,68,68,0.12)}\n    .legend{display:flex;gap:12px;align-items:center;margin-top:12px}\n    .dot{width:12px;height:12px;border-radius:50%}\n    .info{font-size:14px;color:var(--muted)}\n    pre.code{\n      background:rgba(255,255,255,0.02);padding:12px;border-radius:8px;overflow:auto;font-size:13px;\n      border:1px solid rgba(255,255,255,0.02); line-height:1.45;\n    }\n    .stats{display:flex;gap:12px;flex-wrap:wrap;margin-top:12px}\n    .stat{background:rgba(255,255,255,0.02);padding:8px 10px;border-radius:8px;font-size:13px;border:1px solid rgba(255,255,255,0.02)}\n    footer{grid-column:1/-1;margin-top:8px;color:var(--muted);font-size:13px;text-align:center}\n    .small{font-size:13px;color:var(--muted)}\n    input[type=\"range\"]{width:120px}\n    .controls .spaced{margin-left:auto}\n    .help{font-size:13px;color:var(--muted);margin-top:10px}\n    @media (max-width:960px){\n      .container{grid-template-columns:1fr; padding-bottom:24px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\" role=\"main\">\n    <header>\n      <h1>Linear Search — Interactive Visualization</h1>\n      <p class=\"lead\">Step through the Linear Search algorithm. Click any cell to edit its value, set a target, and watch how the algorithm checks each element in order until it finds the target or finishes the array.</p>\n    </header>\n\n    <section class=\"card\" aria-labelledby=\"visual-title\">\n      <div id=\"visual-title\" style=\"display:flex;justify-content:space-between;align-items:center\">\n        <div>\n          <strong style=\"font-size:15px\">Array</strong>\n          <div class=\"small\" style=\"margin-top:6px\">Click a cell to edit the number. Use controls below to run the search.</div>\n        </div>\n        <div class=\"row\" style=\"gap:8px\">\n          <label style=\"margin:0\">\n            <div class=\"small\">Array size</div>\n            <input id=\"size\" type=\"range\" min=\"1\" max=\"20\" value=\"10\" aria-label=\"Array size\">\n          </label>\n          <button id=\"gen\" title=\"Generate random array\">Generate</button>\n        </div>\n      </div>\n\n      <div id=\"array\" class=\"array-visual\" aria-live=\"polite\" style=\"margin-top:14px\"></div>\n\n      <div class=\"legend\">\n        <div style=\"display:flex;gap:6px;align-items:center\"><span class=\"dot\" style=\"background:var(--highlight)\"></span><div class=\"small\">Current check</div></div>\n        <div style=\"display:flex;gap:6px;align-items:center\"><span class=\"dot\" style=\"background:var(--good)\"></span><div class=\"small\">Found</div></div>\n        <div style=\"display:flex;gap:6px;align-items:center\"><span class=\"dot\" style=\"background:var(--bad)\"></span><div class=\"small\">Not matched</div></div>\n      </div>\n\n      <div style=\"display:flex;flex-wrap:wrap;gap:12px;margin-top:12px;align-items:center\">\n        <div class=\"col\" style=\"min-width:220px\">\n          <label for=\"target\">Target value</label>\n          <input id=\"target\" type=\"text\" placeholder=\"Enter number or text\" aria-label=\"Target value\">\n        </div>\n\n        <div class=\"col\">\n          <label>Controls</label>\n          <div style=\"display:flex;gap:8px\">\n            <button id=\"start\">Start</button>\n            <button id=\"step\" class=\"secondary\">Step</button>\n            <button id=\"play\" class=\"secondary\">Play</button>\n            <button id=\"reset\" class=\"secondary\">Reset</button>\n          </div>\n        </div>\n\n        <div class=\"col\" style=\"min-width:200px\">\n          <label>Speed</label>\n          <div style=\"display:flex;align-items:center;gap:8px\">\n            <input id=\"speed\" type=\"range\" min=\"50\" max=\"1500\" value=\"350\" />\n            <div class=\"small\" id=\"speedLabel\">350ms</div>\n          </div>\n        </div>\n\n        <div class=\"col spaced\" style=\"min-width:240px\">\n          <label>Search mode</label>\n          <select id=\"mode\" aria-label=\"Search mode\">\n            <option value=\"first\">Find first match (standard)</option>\n            <option value=\"all\">Find all matches</option>\n          </select>\n        </div>\n\n      </div>\n\n      <div class=\"stats\" aria-hidden=\"false\">\n        <div class=\"stat\">Comparisons: <strong id=\"comparisons\">0</strong></div>\n        <div class=\"stat\">Index checked: <strong id=\"indexChecked\">—</strong></div>\n        <div class=\"stat\">Result: <strong id=\"result\">—</strong></div>\n        <div class=\"stat\">Array length: <strong id=\"alen\">0</strong></div>\n      </div>\n\n      <div class=\"help\">\n        Try different targets and array sizes. Linear search inspects elements one by one from left to right. In worst case it checks every element (O(n) time).\n      </div>\n    </section>\n\n    <aside class=\"card\" aria-labelledby=\"info-title\">\n      <h3 id=\"info-title\" style=\"margin-top:0\">Algorithm & Explanation</h3>\n\n      <div style=\"margin-top:8px\">\n        <strong>Pseudocode (linear search)</strong>\n        <pre class=\"code\" aria-hidden=\"false\">\nfunction linearSearch(array, target):\n  for i from 0 to array.length - 1:\n    if array[i] == target:\n      return i   // index where target found\n  return -1      // not found\n        </pre>\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <strong>Time Complexity</strong>\n        <div class=\"small\" style=\"margin-top:6px\">\n          Best case: O(1) — target at first element.<br>\n          Average case: O(n) — target somewhere in the array or not present.<br>\n          Worst case: O(n) — target at end or not present.<br>\n          Space complexity: O(1) — constant extra space.\n        </div>\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <strong>Notes</strong>\n        <ul class=\"small\" style=\"margin:8px 0 0 18px\">\n          <li>Linear search works on unsorted arrays.</li>\n          <li>For sorted arrays, binary search is faster (O(log n)).</li>\n          <li>This demo supports finding the first match or all matches.</li>\n        </ul>\n      </div>\n\n      <div style=\"margin-top:14px\">\n        <strong>Example uses</strong>\n        <ul class=\"small\" style=\"margin:8px 0 0 18px\">\n          <li>Small arrays where overhead of sorting/searching algorithms isn't worth it.</li>\n          <li>When data isn't ordered or there's no quick index lookup.</li>\n        </ul>\n      </div>\n\n    </aside>\n\n    <footer>\n      Tip: Click any array cell to edit its value. Press Start to run continuously, Step to step manually, Play to auto-step, and Reset to stop and clear highlights.\n    </footer>\n  </div>\n\n  <script>\n    (function(){\n      // Utility\n      function $(sel){return document.querySelector(sel)}\n      function $all(sel){return Array.from(document.querySelectorAll(sel))}\n      const arrayEl = $('#array');\n      const sizeRange = $('#size');\n      const genBtn = $('#gen');\n      const targetInput = $('#target');\n      const startBtn = $('#start');\n      const stepBtn = $('#step');\n      const playBtn = $('#play');\n      const resetBtn = $('#reset');\n      const speedRange = $('#speed');\n      const speedLabel = $('#speedLabel');\n      const comparisonsEl = $('#comparisons');\n      const indexCheckedEl = $('#indexChecked');\n      const resultEl = $('#result');\n      const alenEl = $('#alen');\n      const modeSel = $('#mode');\n\n      let arr = [];\n      let cells = [];\n      let idx = -1; // current index being checked\n      let comparisons = 0;\n      let running = false;\n      let playing = false;\n      let timer = null;\n      let target = null;\n      let foundIndices = [];\n\n      function randInt(min,max){ return Math.floor(Math.random()*(max-min+1))+min }\n\n      function createArray(n){\n        arr = [];\n        for(let i=0;i<n;i++) arr.push(randInt(0,99));\n        renderArray();\n        resetState();\n      }\n\n      function renderArray(){\n        arrayEl.innerHTML = '';\n        cells = [];\n        arr.forEach((v,i)=>{\n          const div = document.createElement('div');\n          div.className = 'cell';\n          div.tabIndex = 0;\n          div.setAttribute('role','button');\n          div.setAttribute('data-idx', i);\n          div.innerHTML = `<div class=\"val\">${escapeHtml(String(v))}</div><div class=\"idx\">${i}</div>`;\n          // click to edit\n          div.addEventListener('click', ()=> editCell(i));\n          div.addEventListener('keydown', (e)=>{\n            if(e.key === 'Enter') editCell(i);\n          });\n          arrayEl.appendChild(div);\n          cells.push(div);\n        });\n        alenEl.textContent = arr.length;\n      }\n\n      function escapeHtml(s){\n        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n      }\n\n      function editCell(i){\n        const old = String(arr[i]);\n        const val = prompt(`Edit value at index ${i}:`, old);\n        if(val === null) return;\n        // Try to parse as number if numeric\n        const num = Number(val);\n        arr[i] = (val.trim() !== '' && !isNaN(num)) ? num : val;\n        renderArray();\n      }\n\n      function resetState(){\n        stopPlaying();\n        idx = -1;\n        comparisons = 0;\n        foundIndices = [];\n        updateStats();\n        clearHighlights();\n        resultEl.textContent = '—';\n        indexCheckedEl.textContent = '—';\n      }\n\n      function clearHighlights(){\n        cells.forEach(c=>{\n          c.classList.remove('highlight','match','nomatch');\n        });\n      }\n\n      function updateStats(){\n        comparisonsEl.textContent = comparisons;\n        indexCheckedEl.textContent = (idx>=0 && idx < arr.length) ? idx : '—';\n        alenEl.textContent = arr.length;\n        if(foundIndices.length === 0){\n          resultEl.textContent = '—';\n        } else {\n          resultEl.textContent = foundIndices.join(', ');\n        }\n      }\n\n      function startSearch(){\n        if(running) return;\n        target = parseTarget(targetInput.value);\n        if(target === null){\n          alert('Please enter a valid target (number or text).');\n          return;\n        }\n        running = true;\n        playing = false;\n        idx = 0;\n        comparisons = 0;\n        foundIndices = [];\n        clearHighlights();\n        updateStats();\n        // run fully until find or end\n        runLoop();\n      }\n\n      function stepSearch(){\n        if(!running){\n          // initialize\n          target = parseTarget(targetInput.value);\n          if(target === null){\n            alert('Please enter a valid target (number or text).');\n            return;\n          }\n          running = true;\n          idx = 0;\n          comparisons = 0;\n          foundIndices = [];\n          clearHighlights();\n        }\n        // single step\n        if(idx >= arr.length){\n          // finished\n          finalizeSearch();\n          return;\n        }\n        checkIndex(idx);\n        idx++;\n        updateStats();\n        if(modeSel.value === 'first' && foundIndices.length>0){\n          finalizeSearch();\n        } else if(idx >= arr.length){\n          finalizeSearch();\n        }\n      }\n\n      function playSearch(){\n        if(playing){\n          stopPlaying();\n          return;\n        }\n        // start playing\n        target = parseTarget(targetInput.value);\n        if(target === null){\n          alert('Please enter a valid target (number or text).');\n          return;\n        }\n        if(!running){\n          running = true;\n          idx = 0;\n          comparisons = 0;\n          foundIndices = [];\n          clearHighlights();\n          updateStats();\n        }\n        playing = true;\n        playBtn.textContent = 'Pause';\n        scheduleNext();\n      }\n\n      function stopPlaying(){\n        playing = false;\n        playBtn.textContent = 'Play';\n        if(timer) { clearTimeout(timer); timer = null; }\n      }\n\n      function scheduleNext(){\n        if(!playing) return;\n        const delay = Number(speedRange.value);\n        timer = setTimeout(()=>{\n          if(idx >= arr.length){\n            finalizeSearch();\n            return;\n          }\n          checkIndex(idx);\n          idx++;\n          updateStats();\n          if(modeSel.value === 'first' && foundIndices.length>0){\n            finalizeSearch();\n            return;\n          }\n          if(idx >= arr.length){\n            finalizeSearch();\n            return;\n          }\n          scheduleNext();\n        }, delay);\n      }\n\n      function stopAll(){\n        running = false;\n        stopPlaying();\n      }\n\n      function finalizeSearch(){\n        stopAll();\n        // color remaining non-checked cells as nomatch for clarity\n        for(let i=0;i<cells.length;i++){\n          if(!cells[i].classList.contains('match') && !cells[i].classList.contains('nomatch')){\n            cells[i].classList.add('nomatch');\n          }\n        }\n        if(foundIndices.length===0){\n          resultEl.textContent = 'Not found';\n        } else {\n          resultEl.textContent = foundIndices.join(', ');\n        }\n        updateStats();\n      }\n\n      function checkIndex(i){\n        clearHighlights();\n        const c = cells[i];\n        c.classList.add('highlight');\n        comparisons++;\n        indexCheckedEl.textContent = i;\n        // equality check between target and arr[i] (loose comparison by type freedom? We'll do strict for numbers and strings)\n        const a = arr[i];\n        if(equals(a, target)){\n          c.classList.remove('highlight');\n          c.classList.add('match');\n          foundIndices.push(i);\n        } else {\n          c.classList.remove('highlight');\n          c.classList.add('nomatch');\n        }\n      }\n\n      function equals(a,b){\n        // If both are numbers, compare numerically\n        if(typeof a === 'number' && typeof b === 'number') return a === b;\n        // Otherwise compare string representations trimmed\n        return String(a).trim() === String(b).trim();\n      }\n\n      function parseTarget(s){\n        if(s === undefined || s === null) return null;\n        const t = String(s).trim();\n        if(t === '') return null;\n        // Check if numeric\n        const num = Number(t);\n        if(!isNaN(num)) return num;\n        return t;\n      }\n\n      // Event listeners\n      genBtn.addEventListener('click', ()=> createArray(Number(sizeRange.value)));\n      sizeRange.addEventListener('input', ()=> {\n        const val = Number(sizeRange.value);\n        sizeRange.title = val;\n      });\n\n      startBtn.addEventListener('click', ()=>{\n        stopPlaying();\n        startSearch();\n      });\n\n      stepBtn.addEventListener('click', ()=>{\n        stopPlaying();\n        stepSearch();\n      });\n\n      playBtn.addEventListener('click', ()=>{\n        if(playing) stopPlaying();\n        else playSearch();\n      });\n\n      resetBtn.addEventListener('click', ()=>{\n        stopAll();\n        resetState();\n      });\n\n      speedRange.addEventListener('input', ()=>{\n        speedLabel.textContent = speedRange.value + 'ms';\n      });\n\n      // Initialize\n      createArray(Number(sizeRange.value));\n\n      // Additional: allow Start to function as \"Run to completion\" with animations if user wants\n      function runLoop(){\n        // Animated run using scheduleNext\n        playing = true;\n        playBtn.textContent = 'Pause';\n        scheduleNext();\n      }\n\n      // Keyboard shortcuts\n      document.addEventListener('keydown', (e)=>{\n        if(e.key === ' ' && document.activeElement.tagName !== 'INPUT'){\n          e.preventDefault();\n          if(playing) stopPlaying(); else playSearch();\n        } else if(e.key === 's' && document.activeElement.tagName !== 'INPUT'){\n          stepSearch();\n        } else if(e.key === 'r' && document.activeElement.tagName !== 'INPUT'){\n          createArray(Number(sizeRange.value));\n        }\n      });\n\n      // Small accessibility: focus indicator style (not too intrusive)\n      const style = document.createElement('style');\n      style.textContent = '.cell:focus{outline:2px dashed rgba(255,255,255,0.08);outline-offset:4px}';\n      document.head.appendChild(style);\n\n      // Make sure clicking Generate stops current runs\n      genBtn.addEventListener('click', ()=> {\n        stopAll();\n      });\n\n      // Provide an initial explanation in console (for curious users)\n      console.info(\"Linear Search Demo initialized. Use Start, Step, or Play to inspect elements one-by-one.\");\n    })();\n  </script>\n</body>\n</html>"
  },
