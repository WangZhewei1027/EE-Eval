    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<title>Greedy Algorithms — Interactive Demo</title>\n<style>\n  body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 0; background: #f6f8fa; color: #111; }\n  header { background: linear-gradient(90deg,#2b8ef7,#7b61ff); color: white; padding: 18px 20px; }\n  header h1 { margin: 0; font-size: 20px; }\n  .container { display: flex; gap: 20px; padding: 18px; }\n  nav { width: 240px; background: white; border-radius: 8px; padding: 12px; box-shadow: 0 6px 18px rgba(20,30,60,0.08); height: fit-content; }\n  nav button { width: 100%; display: block; text-align: left; padding: 10px 12px; margin: 6px 0; border-radius: 6px; border: 1px solid transparent; background: #f1f5f9; cursor: pointer; }\n  nav button.active { background: linear-gradient(90deg,#eef6ff,#f5f0ff); border-color: #e2e8f0; font-weight: 600; }\n  main { flex: 1; }\n  .card { background: white; border-radius: 10px; padding: 14px; margin-bottom: 14px; box-shadow: 0 8px 20px rgba(18,22,36,0.06); }\n  h2 { margin: 6px 0 10px; font-size: 18px; }\n  .controls { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }\n  select,input[type=\"number\"],button { padding: 8px 10px; border-radius: 6px; border: 1px solid #dbe6f0; background: #fff; }\n  button.primary { background: #2b8ef7; color: white; border: none; }\n  button.warn { background: #ffb020; color: white; border: none; }\n  .output { padding: 10px; background: #f8fafc; border-radius: 8px; border: 1px dashed #e6eefc; margin-top: 12px; min-height: 56px; }\n  .list { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px; }\n  .chip { padding: 8px 10px; border-radius: 6px; background: #fff; border: 1px solid #e6edf7; box-shadow: 0 2px 6px rgba(30,40,60,0.03); }\n  .chip.highlight { background: linear-gradient(90deg,#fff7e6,#fffde6); border-color: #ffd87a; }\n  .chip.selected { background: linear-gradient(90deg,#e8f8ff,#f0fbff); border-color: #bde8ff; box-shadow: 0 6px 16px rgba(45,140,255,0.08); }\n  .explain { margin-top: 12px; padding: 10px; background: #fff; border-radius: 8px; border: 1px solid #eef2ff; }\n  .row { display:flex; gap:10px; align-items:center; margin-top:8px; flex-wrap:wrap; }\n  .interval { padding: 6px 8px; border-radius: 6px; background: #fff; border: 1px solid #e6edf7; display:inline-block; min-width:42px; text-align:center; }\n  .interval.selected { background:#cfefff; border-color:#7fd0ff; box-shadow:0 6px 14px rgba(45,140,255,0.07); }\n  .interval.conflict { opacity:0.45; }\n  .bar { height:18px; background:#e6f3ff; border-radius:6px; position:relative; }\n  .bar .seg { position:absolute; height:18px; border-radius:6px; top:0; }\n  .seg.chosen { background: linear-gradient(90deg,#ffd87a,#ffb020); box-shadow:0 6px 12px rgba(255,160,36,0.12); }\n  .seg.grey { background:#cfd8e3; opacity:0.9; }\n  .legend { font-size:13px; margin-top:8px; }\n  pre.code { background:#0b1220; color:#e6f3ff; padding:10px; border-radius:8px; overflow:auto; max-height:220px; }\n  footer { padding:12px 18px; color:#556; font-size:13px; }\n  @media (max-width:900px){ .container{ flex-direction:column; } nav{ width:100%; } }\n</style>\n</head>\n<body>\n<header>\n  <h1>Greedy Algorithms — Interactive Demonstration</h1>\n</header>\n\n<div class=\"container\">\n  <nav>\n    <button id=\"tab-coin\" class=\"active\">Coin Change (Greedy vs Optimal)</button>\n    <button id=\"tab-activity\">Activity Selection (Interval Scheduling)</button>\n    <button id=\"tab-knap\">Fractional Knapsack</button>\n    <div style=\"margin-top:10px; font-size:13px; color:#445;\">Tip: pick a demo, then use Next / Auto to step through the greedy choice process.</div>\n  </nav>\n\n  <main>\n    <!-- Coin change -->\n    <section id=\"panel-coin\" class=\"card\">\n      <h2>Coin Change — Greedy Choice</h2>\n      <div class=\"controls\">\n        <label>Coin set:\n          <select id=\"coin-set\">\n            <option value=\"us\">US coins: 1,5,10,25</option>\n            <option value=\"canonical\">Canonical: 1,5,10,20,50</option>\n            <option value=\"noncanon\">Non-canonical: 1,3,4</option>\n            <option value=\"custom\">Custom (comma-separated)</option>\n          </select>\n        </label>\n        <label id=\"custom-coins-wrapper\" style=\"display:none;\">Custom:\n          <input id=\"custom-coins\" placeholder=\"e.g. 1,7,10\" />\n        </label>\n        <label>Amount:\n          <input id=\"amount\" type=\"number\" min=\"1\" value=\"63\"/>\n        </label>\n        <button id=\"coin-reset\" class=\"primary\">Reset</button>\n        <button id=\"coin-next\">Next Step</button>\n        <button id=\"coin-auto\" class=\"warn\">Auto Play</button>\n        <button id=\"coin-show-opt\">Show Optimal (DP)</button>\n      </div>\n\n      <div class=\"output\" id=\"coin-output\">\n        <div><strong>Coins:</strong> <span id=\"coins-list\"></span></div>\n        <div class=\"row\">\n          <div><strong>Remaining:</strong> <span id=\"coin-remaining\">-</span></div>\n          <div><strong>Picked:</strong> <span id=\"coin-picked\">-</span></div>\n          <div><strong>Steps:</strong> <span id=\"coin-steps\">0</span></div>\n        </div>\n\n        <div class=\"list\" id=\"coins-chips\" style=\"margin-top:10px;\"></div>\n\n        <div class=\"explain\" id=\"coin-explain\">\n          Explanation: Greedy picks the largest coin <= remaining amount each step.\n        </div>\n\n        <div style=\"margin-top:12px;\">\n          <strong>Compare:</strong>\n          <div id=\"coin-compare\" style=\"margin-top:8px;\"></div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Activity selection -->\n    <section id=\"panel-activity\" class=\"card\" style=\"display:none;\">\n      <h2>Activity Selection — Interval Scheduling</h2>\n      <div class=\"controls\">\n        <label>Preset:\n          <select id=\"activity-preset\">\n            <option value=\"example1\">Example 1</option>\n            <option value=\"example2\">Random 8 intervals</option>\n          </select>\n        </label>\n        <button id=\"act-reset\" class=\"primary\">Reset</button>\n        <button id=\"act-next\">Next Step</button>\n        <button id=\"act-auto\" class=\"warn\">Auto Play</button>\n      </div>\n\n      <div class=\"output\">\n        <div id=\"activity-bar\" style=\"width:100%; margin-top:8px;\"></div>\n        <div style=\"margin-top:8px;\">\n          <strong>Intervals (sorted by finish time):</strong>\n          <div id=\"interval-list\" class=\"row\"></div>\n        </div>\n\n        <div class=\"explain\" id=\"activity-explain\">\n          Explanation: Greedy picks the activity with the earliest finish time, removes conflicting ones, repeat.\n        </div>\n\n        <div style=\"margin-top:10px;\">\n          <strong>Chosen set:</strong>\n          <div id=\"activity-chosen\" class=\"row\"></div>\n        </div>\n      </div>\n    </section>\n\n    <!-- Fractional knapsack -->\n    <section id=\"panel-knap\" class=\"card\" style=\"display:none;\">\n      <h2>Fractional Knapsack</h2>\n      <div class=\"controls\">\n        <label>Preset:\n          <select id=\"knap-preset\">\n            <option value=\"example\">Example items</option>\n            <option value=\"random\">Random 6 items</option>\n          </select>\n        </label>\n        <label>Capacity:\n          <input id=\"knap-cap\" type=\"number\" min=\"1\" value=\"50\" />\n        </label>\n        <button id=\"knap-reset\" class=\"primary\">Reset</button>\n        <button id=\"knap-next\">Next Step</button>\n        <button id=\"knap-auto\" class=\"warn\">Auto Play</button>\n      </div>\n\n      <div class=\"output\">\n        <div><strong>Items (value, weight) and value/weight ratio:</strong></div>\n        <div id=\"knap-items\" class=\"list\" style=\"margin-top:8px;\"></div>\n\n        <div style=\"margin-top:8px;\">\n          <strong>Remaining capacity:</strong> <span id=\"knap-rem\">-</span>\n        </div>\n\n        <div class=\"explain\" id=\"knap-explain\">\n          Explanation: Greedy takes items in decreasing order of value/weight; can take fraction of an item.\n        </div>\n\n        <div style=\"margin-top:10px;\">\n          <strong>Taken:</strong>\n          <div id=\"knap-taken\" class=\"list\"></div>\n          <div style=\"margin-top:8px;\"><strong>Total value:</strong> <span id=\"knap-value\">0</span></div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"card\">\n      <h2>When does Greedy work? When can it fail?</h2>\n      <div class=\"explain\">\n        - Greedy algorithms build a solution by repeatedly making a local optimum choice. When the local choice leads to a globally optimal solution, the algorithm is correct.<br>\n        - They are usually fast (often O(n log n) due to sorting) and simple.<br>\n        - They can fail if the problem doesn't have the \"greedy-choice property\" or \"optimal substructure\" aligned with the chosen rule — see the coin change counterexample in the demo (coins 1,3,4).\n      </div>\n      <div style=\"margin-top:8px\">\n        <strong>Complexities (typical):</strong>\n        <ul>\n          <li>Coin greedy: O(k + n) per run if coins sorted (k coins), optimal DP: O(amount * k).</li>\n          <li>Activity selection: O(n log n) dominated by sorting by finish times, greedy picks in O(n).</li>\n          <li>Fractional knapsack: O(n log n) for sorting by ratio, then O(n) to fill.</li>\n        </ul>\n      </div>\n    </section>\n\n  </main>\n</div>\n\n<footer>\n  Built-in interactive demos of greedy choices — step through to see how the algorithm makes local decisions and compare with optimal where feasible.\n</footer>\n\n<script>\n(function(){\n  // Utilities\n  function el(id){ return document.getElementById(id); }\n  function createChip(text, cls){ const d = document.createElement('div'); d.className = 'chip' + (cls? ' '+cls:''); d.textContent = text; return d; }\n\n  // Tabs\n  const tabs = { coin: el('tab-coin'), activity: el('tab-activity'), knap: el('tab-knap') };\n  const panels = { coin: el('panel-coin'), activity: el('panel-activity'), knap: el('panel-knap') };\n  function activate(name){\n    Object.values(tabs).forEach(b=>b.classList.remove('active'));\n    tabs[name].classList.add('active');\n    Object.values(panels).forEach(p=>p.style.display='none');\n    panels[name].style.display='block';\n  }\n  tabs.coin.onclick = ()=>activate('coin');\n  tabs.activity.onclick = ()=>activate('activity');\n  tabs.knap.onclick = ()=>activate('knap');\n\n  // ---- COIN CHANGE DEMO ----\n  let coinState = { coins: [25,10,5,1], amount: 63, remaining:0, picked:[], step:0, autoId:null };\n  const coinSet = el('coin-set'), customWrapper = el('custom-coins-wrapper'), customCoins = el('custom-coins');\n  coinSet.onchange = ()=>{\n    customWrapper.style.display = coinSet.value === 'custom' ? 'inline-block' : 'none';\n  };\n  function parseCoins(value){\n    if(!value) return [];\n    return value.split(',').map(s=>parseInt(s.trim())).filter(n=>Number.isFinite(n) && n>0).sort((a,b)=>b-a);\n  }\n  function setCoinsPreset(key){\n    let arr;\n    if(key==='us') arr=[25,10,5,1];\n    else if(key==='canonical') arr=[50,20,10,5,1];\n    else if(key==='noncanon') arr=[4,3,1];\n    else arr=parseCoins(customCoins.value);\n    if(arr.length===0) arr=[1];\n    coinState.coins = arr;\n  }\n  function coinReset(){\n    setCoinsPreset(coinSet.value);\n    coinState.amount = Math.max(1, parseInt(el('amount').value) || 1);\n    coinState.remaining = coinState.amount;\n    coinState.picked = [];\n    coinState.step = 0;\n    stopCoinAuto();\n    renderCoin();\n    el('coin-compare').innerHTML = '';\n  }\n  function renderCoin(){\n    el('coins-list').textContent = coinState.coins.join(', ');\n    el('coin-remaining').textContent = coinState.remaining;\n    el('coin-picked').textContent = coinState.picked.map(c=>c).join(', ') || '-';\n    el('coin-steps').textContent = coinState.step;\n    const chips = el('coins-chips'); chips.innerHTML='';\n    coinState.coins.forEach(c=>{\n      const chip = createChip(c + '¢', (c <= coinState.remaining && coinState.remaining>0) ? '' : ''); // style could be updated\n      if(c === (coinState.picked[coinState.picked.length-1])) chip.classList.add('selected');\n      chips.appendChild(chip);\n    });\n  }\n  function coinNextStep(){\n    if(coinState.remaining <= 0) return;\n    // Greedy: pick largest coin <= remaining\n    const choice = coinState.coins.find(c => c <= coinState.remaining);\n    if(!choice) {\n      // cannot make exact change\n      coinState.step++;\n      renderCoin();\n      return;\n    }\n    coinState.picked.push(choice);\n    coinState.remaining -= choice;\n    coinState.step++;\n    renderCoin();\n    if(coinState.remaining === 0) showCoinCompare();\n  }\n  function coinAuto(){\n    if(coinState.autoId) { stopCoinAuto(); return; }\n    el('coin-auto').textContent = 'Stop';\n    coinState.autoId = setInterval(()=>{\n      if(coinState.remaining <= 0) { stopCoinAuto(); return; }\n      coinNextStep();\n    }, 600);\n  }\n  function stopCoinAuto(){\n    if(coinState.autoId) clearInterval(coinState.autoId);\n    coinState.autoId = null;\n    el('coin-auto').textContent = 'Auto Play';\n  }\n  function showCoinCompare(){\n    const out = el('coin-compare');\n    // Compute greedy count\n    const greedyCount = coinState.picked.length;\n    // Compute optimal via DP (unbounded coins)\n    const amount = coinState.amount;\n    const INF = 1e9;\n    const dp = new Array(amount+1).fill(INF);\n    const choice = new Array(amount+1).fill(-1);\n    dp[0]=0;\n    for(let a=1;a<=amount;a++){\n      for(const c of coinState.coins){\n        if(c<=a && dp[a-c]+1 < dp[a]){\n          dp[a] = dp[a-c]+1;\n          choice[a]=c;\n        }\n      }\n    }\n    if(dp[amount] >= INF){\n      out.innerHTML = '<em>Cannot make exact change for this amount with given coins.</em>';\n      return;\n    }\n    // reconstruct optimal\n    let a = amount, optPicked = [];\n    while(a>0 && choice[a]>0){\n      optPicked.push(choice[a]); a -= choice[a];\n    }\n    out.innerHTML = `\n      Greedy used ${greedyCount} coin(s): ${coinState.picked.join(', ') || '-'}<br/>\n      Optimal uses ${dp[amount]} coin(s): ${optPicked.join(', ')}\n    `;\n    // Show counterexample note if greedy > optimal\n    if(greedyCount > dp[amount]){\n      out.innerHTML += '<div style=\"margin-top:8px;color:#8b0000\"><strong>Counterexample:</strong> greedy is not optimal for this coin system.</div>';\n    } else {\n      out.innerHTML += '<div style=\"margin-top:8px;color:#0b6623\"><strong>Good:</strong> greedy produced an optimal solution for this amount and coin set.</div>';\n    }\n  }\n\n  // Attach coin handlers\n  el('coin-reset').onclick = coinReset;\n  el('coin-next').onclick = coinNextStep;\n  el('coin-auto').onclick = coinAuto;\n  el('coin-show-opt').onclick = showCoinCompare;\n  // When amount or coin selection changes, reset\n  el('amount').onchange = coinReset;\n  customCoins.onchange = coinReset;\n  coinSet.onchange = coinReset;\n\n  // initialize coin demo\n  coinReset();\n\n  // ---- ACTIVITY SELECTION DEMO ----\n  let actState = { intervals: [], sorted: [], chosen: [], index:0, autoId:null };\n  function genExample1(){\n    // example intervals (start,end)\n    return [ [1,4],[3,5],[0,6],[5,7],[3,9],[5,9],[6,10],[8,11],[8,12],[2,14],[12,16] ];\n  }\n  function genRandom(n=8){\n    const arr=[];\n    for(let i=0;i<n;i++){\n      const s = Math.floor(Math.random()*12);\n      const e = s + 1 + Math.floor(Math.random()*6);\n      arr.push([s,e]);\n    }\n    return arr;\n  }\n  function actReset(){\n    const preset = el('activity-preset').value;\n    actState.intervals = preset === 'example1' ? genExample1() : genRandom(8);\n    // assign ids for display\n    actState.intervals = actState.intervals.map((iv,i)=>({id:i+1, s:iv[0], e:iv[1]}));\n    // sort by finish time e then by start\n    actState.sorted = actState.intervals.slice().sort((a,b)=>a.e - b.e || a.s - b.s);\n    actState.chosen = [];\n    actState.index = 0;\n    stopActAuto();\n    renderActivity();\n  }\n  function renderActivity(){\n    const list = el('interval-list'); list.innerHTML='';\n    actState.sorted.forEach(iv=>{\n      const d = document.createElement('div');\n      d.className = 'interval';\n      d.id = 'iv-'+iv.id;\n      d.textContent = `${iv.id}: [${iv.s},${iv.e})`;\n      list.appendChild(d);\n    });\n    // Render timeline bars\n    const bar = el('activity-bar'); bar.innerHTML='';\n    // Compute global min/max for scaling\n    let min = Math.min(...actState.sorted.map(x=>x.s));\n    let max = Math.max(...actState.sorted.map(x=>x.e));\n    if(!isFinite(min) || !isFinite(max)){ bar.textContent='No intervals.'; return; }\n    const width = bar.clientWidth || 600;\n    const total = Math.max(1, max - min);\n    const container = document.createElement('div');\n    container.style.position = 'relative';\n    container.style.height = '46px';\n    container.style.background = '#fff';\n    container.style.border = '1px solid #eef4ff';\n    container.style.borderRadius = '6px';\n    container.style.padding = '8px';\n    actState.sorted.forEach(iv=>{\n      const seg = document.createElement('div');\n      seg.className = 'seg grey';\n      const leftPct = (iv.s - min)/total * 100;\n      const wPct = (iv.e - iv.s)/total * 100;\n      seg.style.left = leftPct + '%';\n      seg.style.width = wPct + '%';\n      seg.style.position = 'absolute';\n      seg.style.height = '30px';\n      seg.style.top = '8px';\n      seg.style.borderRadius = '6px';\n      seg.style.textAlign = 'center';\n      seg.style.lineHeight = '30px';\n      seg.style.fontSize = '12px';\n      seg.style.color = '#123';\n      seg.textContent = iv.id;\n      seg.id = 'bar-' + iv.id;\n      container.appendChild(seg);\n    });\n    bar.appendChild(container);\n\n    // update chosen highlights\n    actState.chosen.forEach(iv=> {\n      const eliv = document.getElementById('iv-'+iv.id);\n      if(eliv) eliv.classList.add('selected');\n      const barseg = document.getElementById('bar-'+iv.id);\n      if(barseg) barseg.classList.add('chosen');\n    });\n    // mark removed/conflicting as faded\n    for(let i=actState.index;i<actState.sorted.length;i++){\n      const iv = actState.sorted[i];\n      const eliv = document.getElementById('iv-'+iv.id);\n      if(eliv && !actState.chosen.find(c=>c.id===iv.id)) eliv.classList.remove('selected');\n    }\n    // show chosen list\n    const chosenBox = el('activity-chosen'); chosenBox.innerHTML='';\n    actState.chosen.forEach(iv=> chosenBox.appendChild(createChip(iv.id + ':['+iv.s+','+iv.e+')','selected')));\n  }\n\n  function actNext(){\n    if(actState.index >= actState.sorted.length) return;\n    // pick next interval with earliest finish time that doesn't conflict\n    // Greedy algorithm: iterate sorted list, pick if start >= last_finish\n    if(actState.chosen.length===0){\n      const pick = actState.sorted[actState.index];\n      actState.chosen.push(pick);\n      // mark index forward to first that finishes after pick? We'll increment index until first start >= pick.e\n      actState.index++;\n      while(actState.index < actState.sorted.length && actState.sorted[actState.index].s < pick.e) actState.index++;\n    } else {\n      // If last pick exists, find next non-conflicting\n      const lastFinish = actState.chosen[actState.chosen.length-1].e;\n      // find the next interval with s >= lastFinish starting from current index\n      while(actState.index < actState.sorted.length && actState.sorted[actState.index].s < lastFinish) actState.index++;\n      if(actState.index < actState.sorted.length){\n        const pick = actState.sorted[actState.index];\n        actState.chosen.push(pick);\n        actState.index++;\n        while(actState.index < actState.sorted.length && actState.sorted[actState.index].s < pick.e) actState.index++;\n      }\n    }\n    renderActivity();\n  }\n  function actAuto(){\n    if(actState.autoId){ stopActAuto(); return; }\n    el('act-auto').textContent = 'Stop';\n    actState.autoId = setInterval(()=>{\n      if(actState.index >= actState.sorted.length) { stopActAuto(); return; }\n      actNext();\n    }, 700);\n  }\n  function stopActAuto(){ if(actState.autoId) clearInterval(actState.autoId); actState.autoId=null; el('act-auto').textContent='Auto Play'; }\n\n  el('act-reset').onclick = actReset;\n  el('act-next').onclick = actNext;\n  el('act-auto').onclick = actAuto;\n  el('activity-preset').onchange = actReset;\n  actReset();\n\n  // ---- FRACTIONAL KNAPSACK DEMO ----\n  let knapState = { items: [], sorted: [], capacity: 50, rem:0, taken: [], idx:0, totalValue:0, autoId:null };\n  function knapExample(){\n    // items as {id, value, weight}\n    return [\n      {id:1, v:60, w:10},\n      {id:2, v:100, w:20},\n      {id:3, v:120, w:30},\n    ];\n  }\n  function genKnapRandom(n=6){\n    const arr=[];\n    for(let i=0;i<n;i++){\n      const w = 5 + Math.floor(Math.random()*25);\n      const v = 10 + Math.floor(Math.random()*150);\n      arr.push({id:i+1, v:v, w:w});\n    }\n    return arr;\n  }\n  function knapReset(){\n    const preset = el('knap-preset').value;\n    knapState.items = preset === 'example' ? knapExample() : genKnapRandom(6);\n    knapState.capacity = Math.max(1, parseInt(el('knap-cap').value) || 1);\n    knapState.rem = knapState.capacity;\n    // sort by ratio desc\n    knapState.sorted = knapState.items.slice().map(it=>({...it, ratio: it.v/it.w})).sort((a,b)=>b.ratio - a.ratio);\n    knapState.taken = [];\n    knapState.idx = 0;\n    knapState.totalValue = 0;\n    stopKnapAuto();\n    renderKnap();\n  }\n  function renderKnap(){\n    const area = el('knap-items'); area.innerHTML='';\n    knapState.sorted.forEach(it=>{\n      const d = document.createElement('div');\n      d.className = 'chip';\n      d.id = 'knap-'+it.id;\n      d.innerHTML = `<div><strong>Item ${it.id}</strong></div>\n                     <div style=\"font-size:12px\">${it.v}v, ${it.w}w, r=${it.ratio.toFixed(2)}</div>`;\n      if(knapState.taken.find(x=>x.id===it.id)) d.classList.add('selected');\n      area.appendChild(d);\n    });\n    el('knap-rem').textContent = knapState.rem;\n    el('knap-taken').innerHTML = '';\n    knapState.taken.forEach(x=>{\n      el('knap-taken').appendChild(createChip(`Item ${x.id}: ${x.frac*100}% (${(x.frac*x.v).toFixed(2)}v)`,'selected'));\n    });\n    el('knap-value').textContent = knapState.totalValue.toFixed(2);\n  }\n  function knapNext(){\n    if(knapState.idx >= knapState.sorted.length || knapState.rem<=0) return;\n    const it = knapState.sorted[knapState.idx];\n    if(it.w <= knapState.rem){\n      // take whole\n      knapState.taken.push({id:it.id, frac:1, v:it.v, w:it.w});\n      knapState.rem -= it.w;\n      knapState.totalValue += it.v;\n    } else {\n      // take fraction\n      const frac = knapState.rem / it.w;\n      knapState.taken.push({id:it.id, frac: frac, v:it.v, w:it.w});\n      knapState.totalValue += it.v*frac;\n      knapState.rem = 0;\n    }\n    knapState.idx++;\n    renderKnap();\n  }\n  function knapAuto(){\n    if(knapState.autoId){ stopKnapAuto(); return; }\n    el('knap-auto').textContent = 'Stop';\n    knapState.autoId = setInterval(()=>{\n      if(knapState.idx >= knapState.sorted.length || knapState.rem<=0) { stopKnapAuto(); return; }\n      knapNext();\n    }, 700);\n  }\n  function stopKnapAuto(){ if(knapState.autoId) clearInterval(knapState.autoId); knapState.autoId=null; el('knap-auto').textContent='Auto Play'; }\n\n  el('knap-reset').onclick = knapReset;\n  el('knap-next').onclick = knapNext;\n  el('knap-auto').onclick = knapAuto;\n  el('knap-preset').onchange = knapReset;\n  el('knap-cap').onchange = knapReset;\n  knapReset();\n\n  // Ensure stopping all autos on tab change to avoid multiple timers\n  document.addEventListener('visibilitychange', ()=>{ if(document.hidden){ stopCoinAuto(); stopActAuto(); stopKnapAuto(); } });\n  // Also stop when navigating between tabs\n  Object.keys(tabs).forEach(k=>{\n    tabs[k].addEventListener('click', ()=>{ stopCoinAuto(); stopActAuto(); stopKnapAuto(); });\n  });\n\n  // Initialize: make sure panels display correctly\n  activate('coin');\n\n  // Small keyboard support: N for next, A for auto toggle, R for reset\n  document.addEventListener('keydown', (e)=>{\n    if(e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') return;\n    const panel = document.querySelector('nav button.active').id;\n    if(e.key.toLowerCase() === 'n'){\n      if(panel==='tab-coin') coinNextStep();\n      if(panel==='tab-activity') actNext();\n      if(panel==='tab-knap') knapNext();\n    } else if(e.key.toLowerCase() === 'a'){\n      if(panel==='tab-coin') coinAuto();\n      if(panel==='tab-activity') actAuto();\n      if(panel==='tab-knap') knapAuto();\n    } else if(e.key.toLowerCase() === 'r'){\n      if(panel==='tab-coin') coinReset();\n      if(panel==='tab-activity') actReset();\n      if(panel==='tab-knap') knapReset();\n    }\n  });\n\n  // Small accessibility: clicking a chip toggles highlighting info (for coin chips show how many available? not needed)\n})();\n</script>\n</body>\n</html>"
