import { test, expect } from '@playwright/test';

// Test suite for: d3d637e0-fa73-11f0-83e0-8d7be1d51901
// This suite validates the Insertion Sort — Interactive Demo against the FSM:
// States: Idle, Playing, Paused, Finished
// Events: Randomize, Load, ShuffleLoad, Play, Step, Reset, FastForward, ChangeOrder, ChangeSpeed
// It also observes console and page errors, and validates UI/DOM feedback for each interaction.

const APP_URL = 'http://127.0.0.1:5500/workspace/0126-balanced/html/d3d637e0-fa73-11f0-83e0-8d7be1d51901.html';

// Page Object to encapsulate common selectors and interactions
class InsertionSortPage {
  constructor(page) {
    this.page = page;
    // Controls
    this.size = page.locator('#size');
    this.minVal = page.locator('#minVal');
    this.maxVal = page.locator('#maxVal');
    this.rand = page.locator('#rand');
    this.custom = page.locator('#custom');
    this.load = page.locator('#load');
    this.shuffleLoad = page.locator('#shuffleLoad');
    this.play = page.locator('#play');
    this.step = page.locator('#step');
    this.reset = page.locator('#reset');
    this.fastForward = page.locator('#fastForward');
    this.order = page.locator('#order');
    this.speed = page.locator('#speed');

    // Status / counters
    this.statusText = page.locator('#statusText');
    this.stepCount = page.locator('#stepCount');
    this.compCount = page.locator('#compCount');
    this.assignCount = page.locator('#assignCount');
    this.keyVal = page.locator('#keyVal');
    this.iIndex = page.locator('#iIndex');
    this.jIndex = page.locator('#jIndex');
    this.actionText = page.locator('#actionText');

    // Visualization bars
    this.bars = page.locator('#bars');
    this.barItems = () => page.locator('#bars .bar');
  }

  // Read the visible array values from bars
  async readBarsValues() {
    const bars = await this.barItems().elementHandles();
    const vals = [];
    for (const b of bars) {
      const txt = await b.evaluate((el) => el.textContent);
      vals.push(txt ? txt.trim() : '');
    }
    return vals;
  }

  // Read bar classes for index
  async barClassList(index) {
    const bar = this.barItems().nth(index);
    return (await bar.getAttribute('class')) || '';
  }
}

test.describe('Insertion Sort Interactive Demo - FSM validation', () => {
  // capture console and page errors for each test
  let consoleErrors;
  let pageErrors;

  test.beforeEach(async ({ page }) => {
    consoleErrors = [];
    pageErrors = [];

    page.on('console', (msg) => {
      // capture console error messages
      if (msg.type() === 'error') {
        consoleErrors.push({ text: msg.text(), location: msg.location() });
      }
    });

    page.on('pageerror', (err) => {
      // capture uncaught exceptions: ReferenceError, TypeError, etc.
      pageErrors.push(err);
    });

    await page.goto(APP_URL);
    // ensure app had some time to initialize
    await page.waitForSelector('#bars');
  });

  test.afterEach(async () => {
    // Assert that there were no uncaught page errors
    expect(pageErrors, 'No uncaught page errors (ReferenceError/TypeError/etc)').toHaveLength(0);
    // Assert that page console did not log errors
    expect(consoleErrors, 'No console.error logs were emitted').toHaveLength(0);
  });

  test('Initial state is Idle and UI reflects start state', async ({ page }) => {
    // Validate S0_Idle initial state
    const app = new InsertionSortPage(page);

    // Status should indicate idle
    await expect(app.statusText).toHaveText('Status: idle');

    // Counters are zero
    await expect(app.stepCount).toHaveText('Step: 0');
    await expect(app.compCount).toHaveText('Comparisons: 0');
    await expect(app.assignCount).toHaveText('Assignments: 0');

    // Key value placeholder present
    await expect(app.keyVal).toHaveText('—');

    // Bars exist and show numeric labels
    const vals1 = await app.readBarsValues();
    expect(vals.length).toBeGreaterThanOrEqual(4); // default size 18 but minimally ensure >4
    // At least one bar should have a numeric text
    const someNumeric = vals.some(v => /^\d+$/.test(v));
    expect(someNumeric).toBeTruthy();
  });

  test('Randomize button resets array and returns to Idle', async ({ page }) => {
    // Validate Randomize event and reset behavior