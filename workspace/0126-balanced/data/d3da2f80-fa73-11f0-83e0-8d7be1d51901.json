    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Routing Demo (Hash-based SPA Router)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color: #222; }\n    body { margin: 0; padding: 0; display: flex; min-height: 100vh; }\n    nav { width: 220px; background:#0f1724; color:#fff; padding:18px; box-sizing:border-box; }\n    main { flex:1; padding: 20px; }\n    h1 { margin-top: 0; }\n    a.link { display:block; padding:8px 10px; color: #9fb6ff; text-decoration:none; border-radius:6px; margin-bottom:6px; }\n    a.link:hover { background: rgba(255,255,255,0.03); }\n    a.link.active { background: #1f6feb; color:white; box-shadow:0 2px 6px rgba(31,111,235,0.18); }\n    .meta { font-size: 13px; color:#9aa9c7; margin-bottom:12px; }\n    .card { background:#fff; border-radius:8px; padding:12px; box-shadow: 0 2px 6px rgba(16,24,40,0.06); }\n    .controls { margin:12px 0; }\n    button { cursor:pointer; padding:8px 12px; border-radius:6px; border:1px solid #d1d5db; background:#f8fafc; }\n    .loading { color:#7c3aed; font-weight:600; }\n    .muted { color:#6b7280; font-size: 14px; }\n    footer { margin-top:18px; font-size:13px; color:#6b7280; }\n    .kbd { background:#f1f5f9; padding:2px 6px; border-radius:4px; font-weight:600; margin-left:6px; }\n    pre { background:#0b1220; color:#dbeafe; padding:10px; border-radius:6px; overflow:auto; font-size:13px; }\n  </style>\n</head>\n<body>\n  <nav>\n    <h2>Routing Demo</h2>\n    <div class=\"meta\">Hash-based SPA router • client-side routes</div>\n\n    <!-- Navigation uses hash URLs (#/path). That's easiest for static files without a server. -->\n    <a class=\"link\" href=\"#/\">Home</a>\n    <a class=\"link\" href=\"#/about\">About</a>\n    <a class=\"link\" href=\"#/users\">Users</a>\n    <a class=\"link\" href=\"#/users/1\">User 1</a>\n    <a class=\"link\" href=\"#/users/2?tab=posts\">User 2 (posts)</a>\n    <a class=\"link\" href=\"#/nope\">404 Example</a>\n\n    <footer>\n      Tip: use browser back/forward to see routing history in action.<br>\n      URL examples: <span class=\"kbd\">#/users/123</span> <span class=\"kbd\">#/users/2?tab=posts</span>\n    </footer>\n  </nav>\n\n  <main>\n    <div id=\"app\" class=\"card\">\n      <!-- Content will be rendered here by the router -->\n    </div>\n\n    <section style=\"margin-top:18px;\">\n      <h3>Router Implementation (concept)</h3>\n      <p class=\"muted\">This demo shows a tiny hash-based router with:\n      route parameters (e.g. /users/:id), query parsing, nested routes, and a 404 fallback.</p>\n\n      <pre>\n/**\n * Routes are defined as: { path: '/users/:id', render: (params, query) => '...' }\n * The router converts path patterns into RegExp to extract params.\n * It listens to \"hashchange\" and renders the matching route.\n */\n      </pre>\n    </section>\n  </main>\n\n  <script>\n    (function(){\n      // Simple utilities\n      const qsToObj = (qs) => {\n        const obj = {};\n        if (!qs) return obj;\n        // remove leading ?\n        qs = qs.replace(/^\\?/, '');\n        qs.split('&').forEach(pair => {\n          if (!pair) return;\n          const [k, v=''] = pair.split('=').map(decodeURIComponent);\n          obj[k] = v;\n        });\n        return obj;\n      };\n\n      // Convert path pattern like \"/users/:id/posts/:pid\" into a RegExp and capture param names\n      function pathToRegex(path) {\n        const keys = [];\n        const pattern = path\n          .replace(/\\/+$/, '') // remove trailing slash\n          .replace(/([.*+?^=!:${}()|[\\]\\/\\\\])/g, '\\\\$1') // escape regex special\n          .replace(/\\\\:([a-zA-Z0-9_]+)/g, (_, key) => {\n            keys.push(key);\n            return '([^/]+)'; // capture group for param\n          })\n          .replace(/\\\\\\*/g, '.*'); // wildcard *\n        const regex = new RegExp('^' + pattern + '/?$');\n        return { regex, keys };\n      }\n\n      // Router class\n      class Router {\n        constructor(rootEl) {\n          this.rootEl = rootEl;\n          this.routes = []; // { path, render, regex, keys }\n          // Bind events\n          window.addEventListener('hashchange', () => this._onRouteChange());\n          // Initial render\n          this._onRouteChange();\n        }\n\n        add(path, renderFn) {\n          const info = pathToRegex(path);\n          this.routes.push({ path, render: renderFn, regex: info.regex, keys: info.keys });\n          return this;\n        }\n\n        // Get the current path fragment after the '#'\n        _getFragment() {\n          const hash = location.hash || '#/';\n          // remove leading '#'\n          const frag = hash.slice(1);\n          // split path and query\n          const [pathPart, queryPart] = frag.split('?');\n          return { path: pathPart || '/', query: qsToObj(queryPart || '') };\n        }\n\n        _onRouteChange() {\n          const { path, query } = this._getFragment();\n          // find first matching route\n          for (const r of this.routes) {\n            const match = path.match(r.regex);\n            if (match) {\n              // extract params based on keys\n              const params = {};\n              r.keys.forEach((k, i) => { params[k] = decodeURIComponent(match[i+1]); });\n              // call render function (it can be sync or return a Promise)\n              const result = r.render(params, query, this.navigate.bind(this));\n              // If the render returns a Promise, show loading state\n              if (result instanceof Promise) {\n                this._setLoading();\n                result.then(html => this._setContent(html)).catch(err => this._setContent(`<pre style=\"color:tomato;\">${escapeHtml(err && err.stack || String(err))}</pre>`));\n              } else {\n                this._setContent(result);\n              }\n              this._updateActiveLinks(path);\n              return;\n            }\n          }\n          // No route matched -> 404\n          this._setContent(this._render404(path));\n          this._updateActiveLinks(null);\n        }\n\n        // Programmatic navigation\n        navigate(pathWithQuery) {\n          location.hash = pathWithQuery;\n        }\n\n        _setLoading() {\n          this.rootEl.innerHTML = '<div class=\"loading\">Loading…</div>';\n        }\n\n        _setContent(html) {\n          this.rootEl.innerHTML = html;\n        }\n\n        _render404(path) {\n          return `\n            <h1>404 — Not Found</h1>\n            <p class=\"muted\">No route matches <strong>${escapeHtml(path)}</strong>.</p>\n            <div class=\"controls\">\n              <button onclick=\"location.hash='#/'\">Go Home</button>\n              <button onclick=\"history.back()\">Go Back</button>\n            </div>\n          `;\n        }\n\n        _updateActiveLinks(currentPath) {\n          // highlight nav links that match the current hash (simple startsWith)\n          document.querySelectorAll('a.link').forEach(a => {\n            const target = (a.getAttribute('href') || '').replace(/^#/, '') || '/';\n            if (currentPath && (target === currentPath || currentPath.startsWith(target) && target !== '/')) {\n              a.classList.add('active');\n            } else if (target === '/' && currentPath === '/') {\n              a.classList.add('active');\n            } else {\n              a.classList.remove('active');\n            }\n          });\n        }\n      }\n\n      // Escape HTML for safe insertion into templates\n      function escapeHtml(str) {\n        return String(str)\n          .replace(/&/g, '&amp;')\n          .replace(/</g, '&lt;')\n          .replace(/>/g, '&gt;')\n          .replace(/\"/g, '&quot;')\n          .replace(/'/g, '&#39;');\n      }\n\n      // Instantiate router\n      const appEl = document.getElementById('app');\n      const router = new Router(appEl);\n\n      // Demo data to show \"lazy loading\"\n      const fakeUserData = {\n        1: { id: 1, name: 'Alice', bio: 'Frontend engineer and tea enthusiast.' },\n        2: { id: 2, name: 'Bob', bio: 'Backend dev, loves Go and databases.' },\n        3: { id: 3, name: 'Carol', bio: 'Designer and illustrator.' }\n      };\n\n      // Routes\n      router\n        .add('/', () => {\n          return `\n            <h1>Home</h1>\n            <p class=\"muted\">A tiny client-side router demonstration using the URL hash.</p>\n            <div class=\"controls\">\n              <button onclick=\"location.hash='#/about'\">Go to About</button>\n              <button onclick=\"location.hash='#/users'\">See Users</button>\n            </div>\n            <hr/>\n            <h3>Why routing?</h3>\n            <p class=\"muted\">Routing lets a single-page app present different \"pages\" to the user while staying on one HTML document.</p>\n          `;\n        })\n\n        .add('/about', () => {\n          return `\n            <h1>About</h1>\n            <p class=\"muted\">This shows client-side routing — no full page reload when navigating links inside the app.</p>\n            <p>Router features in this demo:</p>\n            <ul>\n              <li>Static routes: <span class=\"kbd\">#/about</span></li>\n              <li>Parameterized routes: <span class=\"kbd\">#/users/:id</span></li>\n              <li>Query parameters: <span class=\"kbd\">#/users/2?tab=posts</span></li>\n              <li>404/fallback route</li>\n            </ul>\n          `;\n        })\n\n        .add('/users', () => {\n          // Simulate async loading of users\n          return new Promise(resolve => {\n            setTimeout(() => {\n              const list = Object.values(fakeUserData).map(u => `\n                <li>\n                  <strong>${escapeHtml(u.name)}</strong> —\n                  <a href=\"#/users/${u.id}\">Profile</a> •\n                  <a href=\"#/users/${u.id}?tab=posts\">Posts</a>\n                </li>\n              `).join('');\n              resolve(`\n                <h1>Users</h1>\n                <p class=\"muted\">List of sample users (simulated network request).</p>\n                <ul>${list}</ul>\n              `);\n            }, 600); // simulate network latency\n          });\n        })\n\n        // Parameterized route: /users/:id\n        .add('/users/:id', (params, query, navigate) => {\n          const id = params.id;\n          // simulate fetching the user\n          return new Promise((resolve, reject) => {\n            setTimeout(() => {\n              const user = fakeUserData[id];\n              if (!user) {\n                // reject to demonstrate error handling\n                resolve(`<h1>User not found</h1><p class=\"muted\">No user with id ${escapeHtml(id)}.</p><div class=\"controls\"><button onclick=\"location.hash='#/users'\">Back to users</button></div>`);\n                return;\n              }\n              // Render user info and optionally nested view\n              const tab = query.tab || 'profile';\n              const nested = (tab === 'posts') ? renderUserPosts(id) : renderUserProfile(user);\n              const html = `\n                <h1>${escapeHtml(user.name)}</h1>\n                <p class=\"muted\">${escapeHtml(user.bio)}</p>\n\n                <div class=\"controls\">\n                  <button onclick=\"location.hash='#/users/${id}'\">Profile</button>\n                  <button onclick=\"location.hash='#/users/${id}?tab=posts'\">Posts</button>\n                  <button onclick=\"history.back()\">Back</button>\n                </div>\n\n                <section style=\"margin-top:12px;\">${nested}</section>\n              `;\n              resolve(html);\n            }, 450);\n          });\n\n          // nested view functions\n          function renderUserProfile(user) {\n            return `\n              <div>\n                <h3>Profile</h3>\n                <p><strong>ID:</strong> ${escapeHtml(user.id)}</p>\n                <p>${escapeHtml(user.bio)}</p>\n                <p class=\"muted\">This section demonstrates nested content inside a route.</p>\n              </div>\n            `;\n          }\n          function renderUserPosts(id) {\n            // pretend this needs another async call\n            const posts = [\n              { id: 'a', title: `Post A by ${id}` },\n              { id: 'b', title: `Post B by ${id}` }\n            ];\n            return `\n              <div>\n                <h3>Posts</h3>\n                <ul>${posts.map(p => `<li>${escapeHtml(p.title)}</li>`).join('')}</ul>\n                <p class=\"muted\">Posts loaded for user ${escapeHtml(id)}.</p>\n              </div>\n            `;\n          }\n        });\n\n      // On initial load, ensure we have a hash (default to #/)\n      if (!location.hash) {\n        location.hash = '/';\n      }\n    })();\n  </script>\n</body>\n</html>"
  },
