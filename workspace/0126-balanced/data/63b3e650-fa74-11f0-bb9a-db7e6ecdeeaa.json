    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Refactoring Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    max-width: 700px;\n    line-height: 1.5;\n  }\n  h1 {\n    color: #2c3e50;\n  }\n  .code-block {\n    background: #f5f5f5;\n    border: 1px solid #ddd;\n    padding: 1rem;\n    margin: 1rem 0;\n    font-family: \"Courier New\", Courier, monospace;\n    white-space: pre-wrap;\n  }\n  button {\n    margin-top: 1rem;\n    padding: 0.5rem 1rem;\n    font-size: 1rem;\n    cursor: pointer;\n  }\n  .result {\n    background: #e8f5e9;\n    border: 1px solid #a5d6a7;\n    padding: 1rem;\n    margin-top: 1rem;\n    font-family: monospace;\n  }\n</style>\n</head>\n<body>\n\n<h1>Refactoring Demonstration</h1>\n<p>\n  <strong>Refactoring</strong> means changing a code's structure without changing its behavior,\n  with the goal of improving readability, maintainability, or performance.\n</p>\n\n<h2>Before Refactoring</h2>\n<p>This function calculates the total price including tax and a discount, all done in one place:</p>\n<div class=\"code-block\" id=\"code-before\">\n// Calculate total price with tax and discount\nfunction calculateTotalPrice(price, taxRate, discount) {\n  const taxAmount = price * taxRate;\n  const priceWithTax = price + taxAmount;\n  const discountAmount = priceWithTax * discount;\n  const finalPrice = priceWithTax - discountAmount;\n  return finalPrice.toFixed(2);\n}\n</div>\n\n<h2>After Refactoring</h2>\n<p>\n  We can improve the code by splitting each step into descriptive functions. This makes the code easier to understand and maintain.\n</p>\n<div class=\"code-block\" id=\"code-after\">\n// Calculate tax amount\nfunction calculateTax(price, taxRate) {\n  return price * taxRate;\n}\n\n// Calculate discount amount\nfunction calculateDiscount(price, discount) {\n  return price * discount;\n}\n\n// Calculate final price with tax and discount\nfunction calculateTotalPrice(price, taxRate, discount) {\n  const taxAmount = calculateTax(price, taxRate);\n  const priceWithTax = price + taxAmount;\n  const discountAmount = calculateDiscount(priceWithTax, discount);\n  const finalPrice = priceWithTax - discountAmount;\n  return finalPrice.toFixed(2);\n}\n</div>\n\n<h2>Try it yourself</h2>\n<p>Enter values to calculate total price:</p>\n<label>\n  Price ($):\n  <input type=\"number\" id=\"input-price\" value=\"100\" min=\"0\" step=\"0.01\" />\n</label>\n<br /><br />\n<label>\n  Tax rate (%):\n  <input type=\"number\" id=\"input-tax\" value=\"8.5\" min=\"0\" max=\"100\" step=\"0.01\" />\n</label>\n<br /><br />\n<label>\n  Discount (%):\n  <input type=\"number\" id=\"input-discount\" value=\"10\" min=\"0\" max=\"100\" step=\"0.01\" />\n</label>\n<br /><br />\n<button id=\"btn-calc\">Calculate Final Price</button>\n\n<div class=\"result\" id=\"result\"></div>\n\n<script>\n  // Refactored functions\n  function calculateTax(price, taxRate) {\n    return price * (taxRate / 100);\n  }\n\n  function calculateDiscount(price, discount) {\n    return price * (discount / 100);\n  }\n\n  function calculateTotalPrice(price, taxRate, discount) {\n    const taxAmount = calculateTax(price, taxRate);\n    const priceWithTax = price + taxAmount;\n    const discountAmount = calculateDiscount(priceWithTax, discount);\n    const finalPrice = priceWithTax - discountAmount;\n    return finalPrice.toFixed(2);\n  }\n\n  document.getElementById('btn-calc').addEventListener('click', () => {\n    const price = parseFloat(document.getElementById('input-price').value);\n    const taxRate = parseFloat(document.getElementById('input-tax').value);\n    const discount = parseFloat(document.getElementById('input-discount').value);\n\n    if (isNaN(price) || price < 0) {\n      alert('Please enter a valid price >= 0');\n      return;\n    }\n    if (isNaN(taxRate) || taxRate < 0 || taxRate > 100) {\n      alert('Please enter a valid tax rate between 0 and 100');\n      return;\n    }\n    if (isNaN(discount) || discount < 0 || discount > 100) {\n      alert('Please enter a valid discount between 0 and 100');\n      return;\n    }\n\n    const final = calculateTotalPrice(price, taxRate, discount);\n    document.getElementById('result').textContent = `Final price: $${final}`;\n  });\n</script>\n\n</body>\n</html>"
