  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Binary Search Tree (BST) - Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#fafafa;\n      --panel:#fff;\n      --accent:#1565c0;\n      --muted:#666;\n      --success:#2e7d32;\n      --danger:#c62828;\n      --node:#fff;\n      --node-border:#1e88e5;\n    }\n    html,body{height:100%;margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial}\n    body{background:linear-gradient(180deg,#f7fbff 0%,var(--bg) 100%);padding:18px;box-sizing:border-box;color:#111}\n    h1{margin:0 0 8px;font-size:20px}\n    .wrap{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:360px 1fr;gap:16px;align-items:start}\n    .panel{background:var(--panel);border-radius:10px;padding:14px;box-shadow:0 6px 18px rgba(17,24,32,0.06);border:1px solid rgba(16,24,40,0.04)}\n    .controls label{display:block;font-size:13px;color:var(--muted);margin-bottom:8px}\n    .controls input[type=\"text\"]{width:100%;padding:8px;border-radius:6px;border:1px solid #dfe7ef;font-size:14px}\n    .btn-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}\n    button{background:var(--accent);color:#fff;border:0;padding:8px 10px;border-radius:8px;cursor:pointer;font-weight:600}\n    button.secondary{background:#e9f0ff;color:var(--accent);border:1px solid #cfe0ff}\n    button.warn{background:var(--danger);}\n    button.small{padding:6px 8px;font-size:13px}\n    .log{height:140px;overflow:auto;border-radius:8px;margin-top:10px;padding:8px;background:#fbfbfb;border:1px dashed #eef5ff;font-size:13px;color:#222}\n    .legend{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;font-size:13px}\n    .legend .item{display:flex;gap:8px;align-items:center}\n    .legend .sw{width:16px;height:16px;border-radius:4px;border:1px solid #ddd}\n    .sw.search{background:#ffd54f}\n    .sw.insert{background:#81c784}\n    .sw.delete{background:#ef9a9a}\n    .svg-wrap{width:100%;height:620px;background:linear-gradient(180deg,#fff 0%, #fbfdff 100%);display:flex;align-items:flex-start;justify-content:flex-start;padding:10px;border-radius:10px;overflow:auto}\n    svg{width:100%;height:600px;overflow:visible}\n    .node{cursor:pointer;transition:transform 180ms ease}\n    .node circle{fill:var(--node);stroke:var(--node-border);stroke-width:2}\n    .node text{font-weight:700;fill:#111;font-size:13px;text-anchor:middle;dominant-baseline:central}\n    .edge{stroke:#9fbfe6;stroke-width:2;opacity:0.9}\n    .highlight{filter:drop-shadow(0 4px 8px rgba(30,136,229,0.15))}\n    .visited{stroke:#ffb300 !important;stroke-width:3 !important}\n    .found{stroke:#2e7d32 !important;stroke-width:3 !important;fill:#e8f5e9 !important}\n    .fade{opacity:0.35}\n    .trace{font-size:13px;color:var(--muted);margin-top:8px}\n    footer{margin-top:12px;font-size:13px;color:var(--muted)}\n    .traversal-buttons{display:flex;gap:8px;margin-top:8px}\n    pre{background:#0f1724;color:#dbeafe;padding:10px;border-radius:8px;overflow:auto;font-size:12px}\n    .small-muted{font-size:13px;color:var(--muted)}\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <div class=\"panel controls\">\n      <h1>Binary Search Tree (BST)</h1>\n      <div class=\"small-muted\">Insert, search, delete values and watch the tree update. Click nodes to highlight or remove.</div>\n\n      <label for=\"valueInput\">Value(s) - single or comma separated integers</label>\n      <input id=\"valueInput\" type=\"text\" placeholder=\"e.g. 12, 5, 18, 7\" />\n\n      <div class=\"btn-row\">\n        <button id=\"insertBtn\">Insert</button>\n        <button id=\"searchBtn\" class=\"secondary\">Search</button>\n        <button id=\"deleteBtn\" class=\"warn\">Delete</button>\n        <button id=\"randomBtn\" class=\"secondary\">Random Tree</button>\n        <button id=\"clearBtn\" class=\"secondary small\">Clear</button>\n      </div>\n\n      <div class=\"traversal-buttons\">\n        <button id=\"inorderBtn\" class=\"secondary small\">In-order</button>\n        <button id=\"preorderBtn\" class=\"secondary small\">Pre-order</button>\n        <button id=\"postorderBtn\" class=\"secondary small\">Post-order</button>\n        <button id=\"levelBtn\" class=\"secondary small\">Level-order</button>\n      </div>\n\n      <div class=\"legend\">\n        <div class=\"item\"><div class=\"sw search\"></div>Visiting</div>\n        <div class=\"item\"><div class=\"sw insert\"></div>Inserted / Successor</div>\n        <div class=\"item\"><div class=\"sw delete\"></div>Deleted</div>\n      </div>\n\n      <div class=\"log\" id=\"log\"></div>\n      <div class=\"trace\" id=\"trace\">Trace: </div>\n\n      <footer>\n        Tip: You can click a node in the visualization to delete it. Hover nodes to see value.\n      </footer>\n    </div>\n\n    <div class=\"panel svg-wrap\" id=\"canvasWrap\">\n      <svg id=\"svg\"></svg>\n    </div>\n  </div>\n\n  <script>\n    // Binary Search Tree Visualization Demo\n    (function(){\n      // Utilities\n      const svg = document.getElementById('svg');\n      const logBox = document.getElementById('log');\n      const traceEl = document.getElementById('trace');\n      const input = document.getElementById('valueInput');\n      const insertBtn = document.getElementById('insertBtn');\n      const searchBtn = document.getElementById('searchBtn');\n      const deleteBtn = document.getElementById('deleteBtn');\n      const randomBtn = document.getElementById('randomBtn');\n      const clearBtn = document.getElementById('clearBtn');\n      const inorderBtn = document.getElementById('inorderBtn');\n      const preorderBtn = document.getElementById('preorderBtn');\n      const postorderBtn = document.getElementById('postorderBtn');\n      const levelBtn = document.getElementById('levelBtn');\n\n      let ANIMATION_DELAY = 450; // ms per step\n\n      function log(...args){\n        const line = args.join(' ');\n        const p = document.createElement('div');\n        p.textContent = line;\n        logBox.appendChild(p);\n        logBox.scrollTop = logBox.scrollHeight;\n      }\n      function setTrace(s){\n        traceEl.textContent = 'Trace: ' + s;\n      }\n\n      // BST Data Structure\n      class Node {\n        constructor(value){\n          this.value = value;\n          this.left = null;\n          this.right = null;\n          // visualization\n          this.x = 0;\n          this.y = 0;\n          this.id = Node._nextId++;\n        }\n      }\n      Node._nextId = 1;\n\n      class BST {\n        constructor(){\n          this.root = null;\n        }\n        insert(value){\n          const steps = [];\n          if(this.root === null){\n            this.root = new Node(value);\n            steps.push({type:'insertRoot', node:this.root});\n            return {steps, node: this.root};\n          }\n          let cur = this.root;\n          while(true){\n            steps.push({type:'visit', node:cur});\n            if(value === cur.value){\n              steps.push({type:'exists', node:cur});\n              break;\n            } else if(value < cur.value){\n              if(cur.left === null){\n                cur.left = new Node(value);\n                steps.push({type:'insert', parent:cur, node:cur.left, side:'left'});\n                break;\n              } else {\n                cur = cur.left;\n              }\n            } else {\n              if(cur.right === null){\n                cur.right = new Node(value);\n                steps.push({type:'insert', parent:cur, node:cur.right, side:'right'});\n                break;\n              } else {\n                cur = cur.right;\n              }\n            }\n          }\n          return {steps, node: null};\n        }\n        search(value){\n          const steps = [];\n          let cur = this.root;\n          while(cur !== null){\n            steps.push({type:'visit', node:cur});\n            if(value === cur.value){\n              steps.push({type:'found', node:cur});\n              return {found:true, steps, node:cur};\n            } else if(value < cur.value){\n              cur = cur.left;\n            } else {\n              cur = cur.right;\n            }\n          }\n          steps.push({type:'notfound'});\n          return {found:false, steps};\n        }\n        delete(value){\n          const steps = [];\n          const {root, removed} = (function removeNode(node, value){\n            if(node === null){\n              steps.push({type:'notfound'});\n              return {root:null, removed:false, node:null};\n            }\n            steps.push({type:'visit', node});\n            if(value < node.value){\n              const res = removeNode(node.left, value);\n              node.left = res.root;\n              return {root:node, removed:res.removed, node:node};\n            } else if(value > node.value){\n              const res = removeNode(node.right, value);\n              node.right = res.root;\n              return {root:node, removed:res.removed, node:node};\n            } else {\n              // node to delete\n              steps.push({type:'target', node});\n              if(node.left === null && node.right === null){\n                steps.push({type:'deleteLeaf', node});\n                return {root:null, removed:true, node:node};\n              } else if(node.left === null){\n                steps.push({type:'deleteSingle', node, child:node.right});\n                return {root:node.right, removed:true, node:node};\n              } else if(node.right === null){\n                steps.push({type:'deleteSingle', node, child:node.left});\n                return {root:node.left, removed:true, node:node};\n              } else {\n                // two children: find inorder successor (smallest in right subtree)\n                let succParent = node;\n                let succ = node.right;\n                while(succ.left){\n                  steps.push({type:'visit', node:succ});\n                  succParent = succ;\n                  succ = succ.left;\n                }\n                steps.push({type:'successor', succ, succParent});\n                // replace value\n                const oldVal = node.value;\n                node.value = succ.value;\n                steps.push({type:'replace', node, oldVal, newVal:node.value, succ});\n                // delete successor node from right subtree\n                const res = removeNode(node.right, succ.value);\n                node.right = res.root;\n                return {root:node, removed:true, node:node};\n              }\n            }\n          })(this.root, value);\n          this.root = root;\n          return {steps, removed: removed};\n        }\n        inorder(){\n          const res=[]; (function r(n){if(!n) return; r(n.left); res.push(n.value); r(n.right);})(this.root); return res;\n        }\n        preorder(){\n          const res=[]; (function r(n){if(!n) return; res.push(n.value); r(n.left); r(n.right)})(this.root); return res;\n        }\n        postorder(){\n          const res=[]; (function r(n){if(!n) return; r(n.left); r(n.right); res.push(n.value)})(this.root); return res;\n        }\n        levelorder(){\n          const res=[]; if(!this.root) return res; const q=[this.root]; while(q.length){const n=q.shift();res.push(n.value); if(n.left) q.push(n.left); if(n.right) q.push(n.right);} return res;\n        }\n      }\n\n      // Visualization helpers\n      function clearSVG(){ while(svg.firstChild) svg.removeChild(svg.firstChild); }\n\n      function layoutTree(root){\n        // assign x positions based on inorder index\n        let xCounter = 0;\n        const levelHeight = 90;\n        function dfs(node, depth){\n          if(!node) return;\n          dfs(node.left, depth+1);\n          node.x = ++xCounter;\n          node.y = depth;\n          dfs(node.right, depth+1);\n        }\n        dfs(root, 0);\n        // convert to pixel positions:\n        const HSPACING = 60;\n        const VSPACING = levelHeight;\n        function setPixels(node){\n          if(!node) return;\n          node.px = node.x * HSPACING;\n          node.py = node.y * VSPACING + 30;\n          setPixels(node.left); setPixels(node.right);\n        }\n        setPixels(root);\n        return {width: (xCounter+2)*HSPACING, height: ( (root?getDepth(root):0)+2)*VSPACING };\n      }\n      function getDepth(node){\n        if(!node) return 0;\n        return 1 + Math.max(getDepth(node.left), getDepth(node.right));\n      }\n\n      function drawTree(tree){\n        clearSVG();\n        if(!tree.root) return;\n        const dims = layoutTree(tree.root);\n        svg.setAttribute('viewBox', `0 0 ${Math.max(dims.width,600)} ${Math.max(dims.height,240)}`);\n        // draw edges first\n        (function drawEdges(n){\n          if(!n) return;\n          if(n.left){\n            const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n            line.setAttribute('x1', n.px);\n            line.setAttribute('y1', n.py);\n            line.setAttribute('x2', n.left.px);\n            line.setAttribute('y2', n.left.py);\n            line.classList.add('edge');\n            line.dataset.from = n.id;\n            line.dataset.to = n.left.id;\n            svg.appendChild(line);\n          }\n          if(n.right){\n            const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n            line.setAttribute('x1', n.px);\n            line.setAttribute('y1', n.py);\n            line.setAttribute('x2', n.right.px);\n            line.setAttribute('y2', n.right.py);\n            line.classList.add('edge');\n            line.dataset.from = n.id;\n            line.dataset.to = n.right.id;\n            svg.appendChild(line);\n          }\n          drawEdges(n.left); drawEdges(n.right);\n        })(tree.root);\n\n        // draw nodes\n        (function drawNodes(n){\n          if(!n) return;\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          g.setAttribute('transform', `translate(${n.px},${n.py})`);\n          g.classList.add('node');\n          g.dataset.id = n.id;\n          g.dataset.value = n.value;\n          const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          circle.setAttribute('r', 18);\n          circle.setAttribute('cx', 0);\n          circle.setAttribute('cy', 0);\n          const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n          text.textContent = n.value;\n          g.appendChild(circle);\n          g.appendChild(text);\n          // interaction\n          g.addEventListener('mouseenter', ()=> g.classList.add('highlight'));\n          g.addEventListener('mouseleave', ()=> g.classList.remove('highlight'));\n          g.addEventListener('click', (e)=>{\n            e.stopPropagation();\n            // click = delete node shortcut\n            if(confirm('Delete node with value ' + n.value + '?')) {\n              performDelete(n.value);\n            }\n          });\n          svg.appendChild(g);\n          drawNodes(n.left); drawNodes(n.right);\n        })(tree.root);\n      }\n\n      // Visual action runner\n      function runSteps(tree, steps, opts={}){\n        // opts: mode: 'insert'|'search'|'delete', onComplete\n        const mode = opts.mode || 'search';\n        let i = 0;\n        const visitedElems = [];\n        setTrace('');\n        function step(){\n          if(i >= steps.length){\n            if(opts.onComplete) opts.onComplete();\n            return;\n          }\n          const s = steps[i++];\n          handleStep(s);\n          setTimeout(step, ANIMATION_DELAY);\n        }\n        function findNodeElement(node){\n          if(!node) return null;\n          return svg.querySelector(`g.node[data-id=\"${node.id}\"]`);\n        }\n        function handleStep(s){\n          if(s.type === 'visit'){\n            const el = findNodeElement(s.node);\n            if(el){\n              // highlight visited\n              const circ = el.querySelector('circle');\n              circ.classList.add('visited');\n              visitedElems.push(circ);\n              setTrace(prev => ('Visiting ' + s.node.value));\n              log('Visit', s.node.value);\n              // pulse\n              el.animate([{transform:'scale(1)'},{transform:'scale(1.05)'},{transform:'scale(1)'}],{duration:ANIMATION_DELAY,iterations:1});\n            }\n          } else if(s.type === 'found'){\n            const el = findNodeElement(s.node);\n            if(el){\n              const circ = el.querySelector('circle');\n              circ.classList.add('found');\n              setTrace('Found ' + s.node.value);\n              log('Found', s.node.value);\n            }\n          } else if(s.type === 'insertRoot'){\n            // re-draw tree to include new node, then highlight\n            drawTree(tree);\n            const el = findNodeElement(s.node);\n            if(el){\n              el.querySelector('circle').classList.add('found');\n              setTrace('Inserted root ' + s.node.value);\n              log('Insert root', s.node.value);\n            }\n          } else if(s.type === 'insert'){\n            // redraw to place node\n            drawTree(tree);\n            const el = findNodeElement(s.node);\n            if(el){\n              el.querySelector('circle').classList.add('found');\n              setTrace('Inserted ' + s.node.value + ' as ' + s.side + ' child of ' + s.parent.value);\n              log('Insert', s.node.value, 'as', s.side, 'of', s.parent.value);\n              // small pop animation\n              el.animate([{transform:'scale(0.6)'},{transform:'scale(1.06)'},{transform:'scale(1)'}],{duration:ANIMATION_DELAY,iterations:1});\n            }\n          } else if(s.type === 'exists'){\n            setTrace('Value already exists: ' + s.node.value);\n            log('Value already exists:', s.node.value);\n          } else if(s.type === 'notfound'){\n            setTrace('Value not found');\n            log('Value not found');\n          } else if(s.type === 'target'){\n            const el = findNodeElement(s.node);\n            if(el){\n              el.querySelector('circle').classList.add('visited');\n              setTrace('Target ' + s.node.value);\n              log('Target for deletion', s.node.value);\n            }\n          } else if(s.type === 'deleteLeaf'){\n            // animate removal: fade node then redraw without it\n            const el = findNodeElement(s.node);\n            if(el){\n              const circ = el.querySelector('circle');\n              circ.classList.add('delete');\n              el.animate([{opacity:1},{opacity:0}],{duration:ANIMATION_DELAY,fill:'forwards'});\n            }\n            // redraw after a short timeout\n            setTimeout(()=>{ drawTree(tree); }, ANIMATION_DELAY/1.5);\n            setTrace('Deleted leaf ' + s.node.value);\n            log('Deleted leaf', s.node.value);\n          } else if(s.type === 'deleteSingle'){\n            const el = findNodeElement(s.node);\n            if(el) el.animate([{opacity:1},{opacity:0}],{duration:ANIMATION_DELAY,fill:'forwards'});\n            setTimeout(()=>{ drawTree(tree); }, ANIMATION_DELAY/1.5);\n            setTrace('Deleted node ' + s.node.value + ', replaced by child ' + (s.child? s.child.value : ''));\n            log('Deleted (one child) ', s.node.value, 'child', s.child? s.child.value:'-');\n          } else if(s.type === 'successor'){\n            // highlight successor and its parent\n            const succEl = findNodeElement(s.succ);\n            const pEl = findNodeElement(s.succParent);\n            if(succEl) succEl.querySelector('circle').classList.add('found');\n            if(pEl) pEl.querySelector('circle').classList.add('visited');\n            setTrace('Successor is ' + s.succ.value);\n            log('Successor', s.succ.value);\n          } else if(s.type === 'replace'){\n            // value replacement already done in data; redraw to reflect\n            drawTree(tree);\n            setTrace('Replaced value ' + s.oldVal + ' with ' + s.newVal);\n            log('Replaced', s.oldVal, 'with', s.newVal);\n          }\n        }\n        // start sequence\n        step();\n      }\n\n      // Controller wiring\n      const tree = new BST();\n\n      function performInsert(values){\n        const arr = parseValues(values);\n        if(arr.length === 0) { alert('Enter at least one integer.'); return; }\n        // insert sequentially; chain animations\n        (function insertNext(index){\n          if(index >= arr.length) return;\n          const val = arr[index];\n          const result = tree.insert(val);\n          runSteps(tree, result.steps, {mode:'insert', onComplete: ()=> {\n            drawTree(tree);\n            insertNext(index+1);\n          }});\n        })(0);\n      }\n      function performSearch(value){\n        const val = parseInt(value);\n        if(Number.isNaN(val)){ alert('Enter an integer to search'); return;}\n        const result = tree.search(val);\n        runSteps(tree, result.steps, {mode:'search', onComplete:()=> {\n          if(result.found) log('Search complete:', val, 'found'); else log('Search complete:', val, 'not found');\n        }});\n      }\n      function performDelete(value){\n        const val = parseInt(value);\n        if(Number.isNaN(val)){ alert('Enter an integer to delete'); return;}\n        const result = tree.delete(val);\n        runSteps(tree, result.steps, {mode:'delete', onComplete: ()=> {\n          drawTree(tree);\n          if(result.removed) log('Deleted', val); else log('Value not found for deletion:', val);\n        }});\n      }\n\n      function parseValues(s){\n        if(!s) return [];\n        return s.split(',').map(t=>t.trim()).filter(t=>t!=='').map(t=>parseInt(t)).filter(n=>!Number.isNaN(n));\n      }\n\n      insertBtn.addEventListener('click', ()=> {\n        performInsert(input.value);\n      });\n      searchBtn.addEventListener('click', ()=> {\n        performSearch(input.value);\n      });\n      deleteBtn.addEventListener('click', ()=> {\n        performDelete(input.value);\n      });\n      randomBtn.addEventListener('click', ()=>{\n        clearAll();\n        const count = Math.floor(Math.random()*7)+5;\n        const values = [];\n        while(values.length < count){\n          const v = Math.floor(Math.random()*90)+1;\n          if(!values.includes(v)) values.push(v);\n        }\n        input.value = values.join(', ');\n        performInsert(input.value);\n      });\n      clearBtn.addEventListener('click', ()=> clearAll());\n\n      inorderBtn.addEventListener('click', ()=>{\n        const arr = tree.inorder();\n        if(arr.length === 0) { alert('Tree is empty'); return;}\n        log('In-order: ' + arr.join(', '));\n        alert('In-order traversal: ' + arr.join(', '));\n      });\n      preorderBtn.addEventListener('click', ()=>{\n        const arr = tree.preorder();\n        if(arr.length === 0) { alert('Tree is empty'); return;}\n        log('Pre-order: ' + arr.join(', '));\n        alert('Pre-order traversal: ' + arr.join(', '));\n      });\n      postorderBtn.addEventListener('click', ()=>{\n        const arr = tree.postorder();\n        if(arr.length === 0) { alert('Tree is empty'); return;}\n        log('Post-order: ' + arr.join(', '));\n        alert('Post-order traversal: ' + arr.join(', '));\n      });\n      levelBtn.addEventListener('click', ()=>{\n        const arr = tree.levelorder();\n        if(arr.length === 0) { alert('Tree is empty'); return;}\n        log('Level-order: ' + arr.join(', '));\n        alert('Level-order traversal: ' + arr.join(', '));\n      });\n\n      function clearAll(){\n        tree.root = null;\n        Node._nextId = 1;\n        clearSVG();\n        logBox.innerHTML = '';\n        setTrace('');\n        input.value = '';\n      }\n\n      // initialize with a small example\n      (function initExample(){\n        const seed = [50,30,70,20,40,60,80];\n        input.value = seed.join(', ');\n        performInsert(input.value);\n      })();\n\n      // click on empty canvas to clear highlights\n      svg.addEventListener('click', ()=> {\n        // redraw clears highlight state (we don't persist classes)\n        drawTree(tree);\n      });\n\n      // expose for debugging\n      window.__BST__ = {tree, drawTree, runSteps};\n\n    })();\n  </script>\n</body>\n</html>"
  },
