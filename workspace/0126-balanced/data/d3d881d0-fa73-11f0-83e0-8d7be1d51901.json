    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Time Complexity Interactive Demo</title>\n<style>\n  :root{\n    --bg:#0f1724;\n    --panel:#0b1220;\n    --accent:#7dd3fc;\n    --muted:#94a3b8;\n    --card:#0b1220;\n    --good:#10b981;\n    --danger:#f97316;\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    color-scheme: dark;\n  }\n  html,body{height:100%;margin:0;background:linear-gradient(180deg,#071227 0%, #071827 100%); color: #e6eef6;}\n  .wrap{max-width:1200px;margin:24px auto;padding:18px;display:grid;grid-template-columns:360px 1fr;gap:18px;}\n  .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:12px;padding:16px;box-shadow:0 6px 22px rgba(2,6,23,0.6);border:1px solid rgba(255,255,255,0.03);}\n  h1{font-size:20px;margin:0 0 8px 0;color:#cde9ff;}\n  p.lead{margin:6px 0 12px 0;color:var(--muted);font-size:13px;}\n  label{display:block;font-size:12px;color:var(--muted);margin-top:10px;margin-bottom:6px;}\n  select, input[type=range], input[type=number], button {width:100%;padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,0.06);background:transparent;color:inherit;font-size:14px;}\n  .row{display:flex;gap:8px;}\n  .small{font-size:13px;color:var(--muted);}\n  .code{background:#071827;border:1px solid rgba(255,255,255,0.03);padding:10px;border-radius:8px;font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;font-size:12px;overflow:auto;max-height:180px;color:#dbeafe;}\n  .controls{display:flex;flex-direction:column;gap:8px;}\n  button.primary{background:linear-gradient(90deg,var(--accent), #60a5fa);color:#042b41;border:none;cursor:pointer;padding:10px;border-radius:10px;font-weight:600;}\n  button.ghost{background:transparent;border:1px solid rgba(255,255,255,0.05);color:var(--muted);cursor:pointer;padding:8px;border-radius:8px;}\n  .plot-card{display:flex;flex-direction:column;height:100%;}\n  .plot-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}\n  .stats{display:flex;gap:12px;align-items:center;}\n  .stat{background:rgba(255,255,255,0.02);padding:8px 10px;border-radius:8px;font-size:13px;color:var(--muted);}\n  svg{width:100%;height:360px;background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);border-radius:8px;border:1px solid rgba(255,255,255,0.03);display:block;}\n  .legend{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;}\n  .legend .item{display:flex;gap:6px;align-items:center;font-size:13px;color:var(--muted);}\n  .dot{width:12px;height:12px;border-radius:3px;}\n  .explain{margin-top:12px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));padding:12px;border-radius:10px;border:1px solid rgba(255,255,255,0.02);font-size:13px;color:var(--muted);}\n  footer{font-size:12px;color:var(--muted);margin-top:12px;text-align:center;}\n  .small-muted{font-size:12px;color:var(--muted);}\n  .row-wrap{display:flex;gap:8px;flex-wrap:wrap;}\n  .sample-controls{display:grid;grid-template-columns:1fr 1fr;gap:8px;}\n  @media (max-width:920px){\n    .wrap{grid-template-columns:1fr; padding:12px;}\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"panel\">\n    <h1>Time Complexity — Interactive Demo</h1>\n    <p class=\"lead\">Explore how different algorithms scale as input size grows. The demo counts \"elementary operations\" (a rough proxy for work) and optionally measures elapsed time. Use controls to change algorithm and range, then plot or run single tests.</p>\n\n    <div class=\"controls\">\n      <label for=\"algo\">Choose algorithm</label>\n      <select id=\"algo\" title=\"algorithm\">\n        <option value=\"constant\">O(1) — Constant</option>\n        <option value=\"log\">O(log n) — Binary Search</option>\n        <option value=\"linear\" selected>O(n) — Linear Scan</option>\n        <option value=\"nlogn\">O(n log n) — Merge Sort (counts comparisons/merges)</option>\n        <option value=\"quadratic\">O(n^2) — Nested Loops</option>\n        <option value=\"exponential\">O(2^n) — Naive Fibonacci (small n)</option>\n      </select>\n\n      <label for=\"maxN\">Max input size (n) <span id=\"nnote\" class=\"small-muted\"></span></label>\n      <input id=\"maxN\" type=\"range\" min=\"1\" max=\"2000\" value=\"200\" />\n      <div class=\"row-wrap\">\n        <input id=\"maxNnum\" type=\"number\" min=\"1\" max=\"100000\" value=\"200\" />\n        <input id=\"points\" type=\"number\" min=\"4\" max=\"200\" value=\"25\" title=\"Number of plotted sample points\" />\n      </div>\n\n      <label for=\"scale\">Plot scale</label>\n      <select id=\"scale\">\n        <option value=\"linear\">Linear</option>\n        <option value=\"log\">Logarithmic (y-axis)</option>\n      </select>\n\n      <div class=\"row\">\n        <button id=\"plotBtn\" class=\"primary\">Plot complexity</button>\n        <button id=\"runBtn\" class=\"ghost\">Run for single n</button>\n      </div>\n\n      <label>Single-run input n (for running & timing)</label>\n      <div class=\"row\">\n        <input id=\"singleN\" type=\"number\" min=\"1\" max=\"100000\" value=\"100\" />\n        <button id=\"runOnce\" class=\"primary\" style=\"width:120px;\">Run & Measure</button>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <div class=\"small-muted\">Operation counters are an illustrative approximation of \"work\" and are counted inside each algorithm's key steps (comparisons, assignments, loop iterations). Timing results depend on your browser and machine.</div>\n      </div>\n\n      <label style=\"margin-top:8px;\">Source / Pseudocode (click to copy)</label>\n      <pre id=\"code\" class=\"code\" title=\"Click to copy code snippet\"></pre>\n\n      <div style=\"display:flex;gap:8px;margin-top:8px;\">\n        <button id=\"copyBtn\" class=\"ghost\">Copy snippet</button>\n        <button id=\"resetBtn\" class=\"ghost\">Reset</button>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"panel plot-card\">\n    <div class=\"plot-top\">\n      <div>\n        <h1 style=\"font-size:16px;margin:0;color:#dff5ff\">Plot of measured operations</h1>\n        <div class=\"small-muted\">Measured operation counts for sample n values (and theoretical curve overlay)</div>\n      </div>\n      <div class=\"stats\">\n        <div class=\"stat\">Algorithm: <span id=\"statAlgo\" style=\"color:#cde9ff;margin-left:6px\">Linear</span></div>\n        <div class=\"stat\">Last run ops: <span id=\"statOps\" style=\"color:#cde9ff;margin-left:6px\">—</span></div>\n        <div class=\"stat\">Elapsed: <span id=\"statTime\" style=\"color:#cde9ff;margin-left:6px\">—</span></div>\n      </div>\n    </div>\n\n    <svg id=\"plot\" viewBox=\"0 0 800 360\" preserveAspectRatio=\"none\" aria-label=\"Plot showing operations vs n\"></svg>\n\n    <div class=\"legend\" id=\"legend\">\n      <div class=\"item\"><div class=\"dot\" style=\"background:#60a5fa\"></div><div class=\"small-muted\">Measured operations</div></div>\n      <div class=\"item\"><div class=\"dot\" style=\"background:#7dd3fc\"></div><div class=\"small-muted\">Theoretical curve (normalized)</div></div>\n    </div>\n\n    <div class=\"explain\" id=\"explain\">\n      <strong>What this shows</strong>\n      <div style=\"margin-top:6px;\" class=\"small-muted\">\n        - The y-axis is the number of basic operations (not wall-clock time). This helps see growth rates. <br>\n        - Theoretical curves are normalized so you can visually compare shapes with measured counts. <br>\n        - Use small n for exponential algorithms — they grow extremely quickly. <br>\n      </div>\n    </div>\n\n    <footer>Interactive Time Complexity visualization — operations are approximate. Try different algorithms and n ranges.</footer>\n  </div>\n</div>\n\n<script>\n/*\n  Time Complexity Interactive Demo\n  - Single-file HTML + JS\n  - Counts elementary operations for several algorithmic patterns\n*/\n\n(function(){\n  // DOM elements\n  const algoSel = document.getElementById('algo');\n  const maxNRange = document.getElementById('maxN');\n  const maxNnum = document.getElementById('maxNnum');\n  const pointsInput = document.getElementById('points');\n  const plotBtn = document.getElementById('plotBtn');\n  const runBtn = document.getElementById('runBtn');\n  const singleN = document.getElementById('singleN');\n  const runOnce = document.getElementById('runOnce');\n  const plotSVG = document.getElementById('plot');\n  const statAlgo = document.getElementById('statAlgo');\n  const statOps = document.getElementById('statOps');\n  const statTime = document.getElementById('statTime');\n  const codeBox = document.getElementById('code');\n  const copyBtn = document.getElementById('copyBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const scaleSel = document.getElementById('scale');\n  const nnote = document.getElementById('nnote');\n\n  // initial UI setup\n  function setMaxNNote(){\n    const algo = algoSel.value;\n    let note = '';\n    if(algo === 'exponential'){\n      maxNRange.max = 30;\n      maxNRange.value = Math.min(maxNRange.value, 30);\n      maxNnum.max = 50;\n      note = '(recommended ≤ 30 for plotting)';\n    } else if(algo === 'quadratic'){\n      maxNRange.max = 2000;\n      maxNnum.max = 10000;\n      note = '(be careful: n^2 grows fast)';\n    } else if(algo === 'nlogn'){\n      maxNRange.max = 2000;\n      maxNnum.max = 100000;\n      note = '';\n    } else {\n      maxNRange.max = 2000;\n      maxNnum.max = 100000;\n      note = '';\n    }\n    nnote.textContent = note;\n    maxNnum.value = Math.min(Number(maxNnum.value)||200, Number(maxNRange.max));\n  }\n  setMaxNNote();\n\n  maxNRange.addEventListener('input', ()=>{ maxNnum.value = maxNRange.value; });\n  maxNnum.addEventListener('change', ()=>{ let v = Number(maxNnum.value)||1; v = Math.max(1, Math.min(v, Number(maxNRange.max))); maxNnum.value=v; maxNRange.value=v; });\n\n  algoSel.addEventListener('change', ()=>{\n    setMaxNNote();\n    updateCodeSnippet();\n    statAlgo.textContent = algoSel.options[algoSel.selectedIndex].text;\n  });\n\n  // Basic operation counter container to avoid global counts mixing\n  function makeCounter(){\n    let ops = 0;\n    return {\n      inc(n=1){ ops += n; },\n      value(){ return ops; },\n      reset(){ ops = 0; }\n    };\n  }\n\n  // Algorithms returning the counted operations (not including JS call overhead)\n  // Each algorithm receives (n, counter) and returns result where applicable.\n  function alg_constant(n, counter){\n    // Example: fixed small loop of 10 steps -> constant time\n    for(let i=0;i<10;i++) counter.inc(); // 10 ops regardless of n\n    return null;\n  }\n\n  function alg_log(n, counter){\n    // Simulate binary search on a sorted array of size n\n    // Guaranteed >=1\n    if(n <= 0) return null;\n    let lo = 0, hi = n - 1;\n    // target not in array mostly; count comparisons and mid calculations\n    while(lo <= hi){\n      counter.inc(); // comparison mid\n      let mid = Math.floor((lo + hi)/2);\n      counter.inc(); // comparison with target\n      // assume always not found and shrink search\n      if (mid < 0) { lo = mid + 1; } // never true: just to vary\n      hi = mid - 1;\n      counter.inc(); // assignment\n    }\n    return null;\n  }\n\n  function alg_linear(n, counter){\n    // Single loop from 0..n-1\n    for(let i=0;i<n;i++){\n      counter.inc(); // body operation\n    }\n    return null;\n  }\n\n  function alg_nlogn(n, counter){\n    // Merge sort implementation counting comparisons and assignments roughly.\n    // For speed, operate on an array of length n filled with random numbers.\n    const arr = new Array(n).fill(0).map(()=>Math.random());\n    // We'll implement merge sort iteratively/recursively with counters\n    function mergeSort(a){\n      if(a.length <= 1){ counter.inc(); return a; }\n      const mid = Math.floor(a.length/2);\n      counter.inc(); // split\n      const left = mergeSort(a.slice(0, mid));\n      const right = mergeSort(a.slice(mid));\n      // merge step\n      const merged = [];\n      let i = 0, j = 0;\n      while(i < left.length && j < right.length){\n        counter.inc(); // comparison\n        if (left[i] <= right[j]){\n          merged.push(left[i++]);\n          counter.inc(); // push/assignment\n        } else {\n          merged.push(right[j++]);\n          counter.inc();\n        }\n      }\n      // remaining elements\n      while(i < left.length){ merged.push(left[i++]); counter.inc(); }\n      while(j < right.length){ merged.push(right[j++]); counter.inc(); }\n      return merged;\n    }\n    mergeSort(arr);\n    return null;\n  }\n\n  function alg_quadratic(n, counter){\n    // double nested loop\n    for(let i=0;i<n;i++){\n      counter.inc(); // outer iteration\n      for(let j=0;j<n;j++){\n        counter.inc(); // inner iteration\n      }\n    }\n    return null;\n  }\n\n  function alg_exponential(n, counter){\n    // naive fibonacci with call counting. Keep n small.\n    let calls = 0;\n    function fib(k){\n      calls++;\n      counter.inc(); // count the function call as 1 op\n      if(k <= 1) return k;\n      return fib(k-1) + fib(k-2);\n    }\n    fib(n);\n    // we'll not return value; operations counted in counter.\n    return null;\n  }\n\n  // Map of algorithms\n  const algorithms = {\n    'constant': {fn: alg_constant, theory: n=>1, name:'O(1) — Constant'},\n    'log': {fn: alg_log, theory: n=> Math.max(1, Math.log2(Math.max(1,n))), name:'O(log n) — Binary Search'},\n    'linear': {fn: alg_linear, theory: n=> n, name:'O(n) — Linear Scan'},\n    'nlogn': {fn: alg_nlogn, theory: n=> n * (Math.log2(Math.max(2,n))), name:'O(n log n) — Merge Sort'},\n    'quadratic': {fn: alg_quadratic, theory: n=> n*n, name:'O(n^2) — Nested Loops'},\n    'exponential': {fn: alg_exponential, theory: n=> Math.pow(2, n), name:'O(2^n) — Naive Fibonacci'}\n  };\n\n  // Create code snippet text (pseudocode) for selected algorithm\n  function updateCodeSnippet(){\n    const a = algoSel.value;\n    let snippet = '';\n    if(a === 'constant'){\n      snippet = `// O(1) constant\\nfunction constant(n){\\n  // fixed small number of steps\\n  for(i=0; i<10; i++) count++;\\n}`;\n    } else if(a === 'log'){\n      snippet = `// O(log n) binary search\\nfunction binarySearch(sorted, target){\\n  lo = 0; hi = sorted.length-1;\\n  while(lo <= hi){\\n    mid = (lo+hi)/2;\\n    if(sorted[mid] == target) return mid;\\n    if(sorted[mid] < target) lo = mid+1; else hi = mid-1;\\n    // each iteration reduces interval by ~2\\n  }\\n}`;\n    } else if(a === 'linear'){\n      snippet = `// O(n) linear scan\\nfunction scan(arr){\\n  sum = 0;\\n  for(i=0; i<arr.length; i++){\\n    sum += arr[i]; // single operation per element\\n  }\\n  return sum;\\n}`;\n    } else if(a === 'nlogn'){\n      snippet = `// O(n log n) merge sort\\nfunction mergeSort(a){\\n  if(a.length <= 1) return a;\\n  mid = a.length/2;\\n  left = mergeSort(a.slice(0,mid));\\n  right = mergeSort(a.slice(mid));\\n  return merge(left, right);\\n}\\n// merge stitches two sorted arrays in linear time`;\n    } else if(a === 'quadratic'){\n      snippet = `// O(n^2) nested loops\\nfor(i=0;i<n;i++){\\n  for(j=0;j<n;j++){\\n    // constant work inside inner loop\\n  }\\n}`;\n    } else if(a === 'exponential'){\n      snippet = `// O(2^n) naive Fibonacci\\nfunction fib(n){\\n  if(n <= 1) return n;\\n  return fib(n-1) + fib(n-2);\\n}\\n// recursively expands into ~2^n calls`;\n    }\n    codeBox.textContent = snippet;\n  }\n  updateCodeSnippet();\n\n  // click to copy snippet\n  copyBtn.addEventListener('click', ()=> {\n    navigator.clipboard && navigator.clipboard.writeText(codeBox.textContent).then(()=>{\n      copyBtn.textContent = 'Copied!';\n      setTimeout(()=>copyBtn.textContent = 'Copy snippet',1000);\n    }, ()=>{ copyBtn.textContent = 'Failed'; setTimeout(()=>copyBtn.textContent = 'Copy snippet',1000); });\n  });\n\n  codeBox.addEventListener('click', ()=> copyBtn.click());\n\n  resetBtn.addEventListener('click', ()=>{\n    maxNRange.value = 200; maxNnum.value = 200; pointsInput.value = 25; singleN.value = 100; scaleSel.value = 'linear';\n    algoSel.value = 'linear';\n    setMaxNNote();\n    updateCodeSnippet();\n    statAlgo.textContent = algoSel.options[algoSel.selectedIndex].text;\n    statOps.textContent = '—';\n    statTime.textContent = '—';\n    clearPlot();\n  });\n\n  // Clear plot drawing\n  function clearPlot(){\n    while(plotSVG.firstChild) plotSVG.removeChild(plotSVG.firstChild);\n  }\n\n  // Plot utilities\n  function drawAxes(svg, w, h, padding){\n    const ns = [];\n    // axes lines\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('stroke','rgba(255,255,255,0.06)');\n    g.setAttribute('fill','none');\n    // x-axis\n    const x = document.createElementNS('http://www.w3.org/2000/svg','line');\n    x.setAttribute('x1',padding.left); x.setAttribute('y1',h-padding.bottom);\n    x.setAttribute('x2',w-padding.right); x.setAttribute('y2',h-padding.bottom);\n    g.appendChild(x);\n    // y-axis\n    const y = document.createElementNS('http://www.w3.org/2000/svg','line');\n    y.setAttribute('x1',padding.left); y.setAttribute('y1',padding.top);\n    y.setAttribute('x2',padding.left); y.setAttribute('y2',h-padding.bottom);\n    g.appendChild(y);\n    svg.appendChild(g);\n  }\n\n  function plotData(xs, measured, theoretical, options){\n    // xs: array of n values\n    // measured: array same length with op counts (numbers)\n    // theoretical: array same length with theoretical values\n    // options: {scale:'linear'|'log'}\n    const w = 800, h = 360;\n    const padding = {left:60, right:18, top:18, bottom:34};\n    const plotW = w - padding.left - padding.right;\n    const plotH = h - padding.top - padding.bottom;\n    clearPlot();\n    plotSVG.setAttribute('viewBox', `0 0 ${w} ${h}`);\n\n    // compute max for scale (use positive numbers)\n    const combined = measured.concat(theoretical).map(v => (isFinite(v) && v>=0)?v:0);\n    let maxVal = Math.max(1, ...combined);\n    // for log scale, use log10\n    const useLog = options.scale === 'log';\n\n    // draw axes\n    drawAxes(plotSVG, w, h, padding);\n\n    // draw y-grid and labels\n    const gridG = document.createElementNS('http://www.w3.org/2000/svg','g');\n    gridG.setAttribute('fill','none');\n    gridG.setAttribute('stroke','rgba(255,255,255,0.03)');\n    const ticks = useLog ? 6 : 6;\n    for(let i=0;i<=ticks;i++){\n      const t = i / ticks;\n      const y = padding.top + (1 - t) * plotH;\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1',padding.left); line.setAttribute('x2',w-padding.right); line.setAttribute('y1',y); line.setAttribute('y2',y);\n      line.setAttribute('stroke-width', '1');\n      gridG.appendChild(line);\n\n      const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n      label.setAttribute('x', padding.left - 8);\n      label.setAttribute('y', y + 4);\n      label.setAttribute('text-anchor','end');\n      label.setAttribute('font-size','11');\n      label.setAttribute('fill','rgba(255,255,255,0.6)');\n      let val;\n      if(useLog){\n        const logMax = Math.log10(maxVal);\n        const lv = t * logMax;\n        val = Math.pow(10, lv);\n        label.textContent = formatNumber(Math.round(val));\n      } else {\n        val = t * maxVal;\n        label.textContent = formatNumber(Math.round(val));\n      }\n      gridG.appendChild(label);\n    }\n    plotSVG.appendChild(gridG);\n\n    // draw x labels\n    const xG = document.createElementNS('http://www.w3.org/2000/svg','g');\n    for(let i=0;i<xs.length;i++){\n      const x = padding.left + (i/(xs.length-1)) * plotW;\n      const tx = document.createElementNS('http://www.w3.org/2000/svg','text');\n      tx.setAttribute('x', x);\n      tx.setAttribute('y', h - 8);\n      tx.setAttribute('text-anchor','middle');\n      tx.setAttribute('font-size','10');\n      tx.setAttribute('fill','rgba(255,255,255,0.5)');\n      tx.textContent = xs[i];\n      xG.appendChild(tx);\n    }\n    plotSVG.appendChild(xG);\n\n    // normalization function to map value -> y coordinate\n    function yForValue(v){\n      if(useLog){\n        const safe = Math.max(1e-9, v);\n        const logV = Math.log10(safe);\n        const maxLog = Math.log10(maxVal);\n        const t = (maxLog===0) ? 0 : (logV / maxLog);\n        return padding.top + (1 - t) * plotH;\n      } else {\n        const t = maxVal===0 ? 0 : (v / maxVal);\n        return padding.top + (1 - t) * plotH;\n      }\n    }\n\n    // draw theoretical curve (normalized)\n    const theorPath = document.createElementNS('http://www.w3.org/2000/svg','path');\n    let dT = '';\n    for(let i=0;i<theoretical.length;i++){\n      const x = padding.left + (i/(xs.length-1)) * plotW;\n      const y = yForValue(theoretical[i]);\n      dT += (i===0?'M':'L') + x + ' ' + y + ' ';\n    }\n    theorPath.setAttribute('d', dT);\n    theorPath.setAttribute('stroke', '#7dd3fc');\n    theorPath.setAttribute('fill', 'none');\n    theorPath.setAttribute('stroke-width', '2');\n    theorPath.setAttribute('opacity','0.9');\n    plotSVG.appendChild(theorPath);\n\n    // draw measured curve\n    const measPath = document.createElementNS('http://www.w3.org/2000/svg','path');\n    let dM = '';\n    for(let i=0;i<measured.length;i++){\n      const x = padding.left + (i/(xs.length-1)) * plotW;\n      const y = yForValue(measured[i]);\n      dM += (i===0?'M':'L') + x + ' ' + y + ' ';\n    }\n    measPath.setAttribute('d', dM);\n    measPath.setAttribute('stroke', '#60a5fa');\n    measPath.setAttribute('fill', 'none');\n    measPath.setAttribute('stroke-width', '2.5');\n    plotSVG.appendChild(measPath);\n\n    // draw points and tooltips\n    const ptsG = document.createElementNS('http://www.w3.org/2000/svg','g');\n    for(let i=0;i<measured.length;i++){\n      const x = padding.left + (i/(xs.length-1)) * plotW;\n      const yM = yForValue(measured[i]);\n      const yT = yForValue(theoretical[i]);\n\n      // measured point\n      const c = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      c.setAttribute('x', x-4);\n      c.setAttribute('y', yM-4);\n      c.setAttribute('width', 8);\n      c.setAttribute('height', 8);\n      c.setAttribute('rx', 2);\n      c.setAttribute('fill','#60a5fa');\n      c.setAttribute('opacity','0.95');\n      c.style.cursor = 'pointer';\n      c.addEventListener('mouseenter', ()=> showTooltip(x, yM-10, xs[i], measured[i], theoretical[i]));\n      c.addEventListener('mouseleave', hideTooltip);\n      ptsG.appendChild(c);\n\n      // theoretical small dot\n      const tdot = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      tdot.setAttribute('x', x-3);\n      tdot.setAttribute('y', yT-3);\n      tdot.setAttribute('width', 6);\n      tdot.setAttribute('height', 6);\n      tdot.setAttribute('rx', 2);\n      tdot.setAttribute('fill','#7dd3fc');\n      tdot.setAttribute('opacity','0.9');\n      tdot.addEventListener('mouseenter', ()=> showTooltip(x, yT-10, xs[i], measured[i], theoretical[i]));\n      tdot.addEventListener('mouseleave', hideTooltip);\n      ptsG.appendChild(tdot);\n    }\n    plotSVG.appendChild(ptsG);\n\n    // tooltip elements\n    let tooltip = document.getElementById('plotTooltip');\n    if(tooltip) tooltip.remove();\n    tooltip = document.createElementNS('http://www.w3.org/2000/svg','g');\n    tooltip.setAttribute('id','plotTooltip');\n    plotSVG.appendChild(tooltip);\n\n    function showTooltip(x,y,nVal,meas,th){\n      tooltip.innerHTML = '';\n      const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n      rect.setAttribute('x', x + 8);\n      rect.setAttribute('y', Math.max(8, y-26));\n      rect.setAttribute('width', 200);\n      rect.setAttribute('height', 48);\n      rect.setAttribute('rx',8);\n      rect.setAttribute('fill', 'rgba(2,6,23,0.9)');\n      rect.setAttribute('stroke', 'rgba(255,255,255,0.04)');\n      rect.setAttribute('opacity','0.98');\n      tooltip.appendChild(rect);\n\n      const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('x', x + 16);\n      text.setAttribute('y', Math.max(8, y-26) + 18);\n      text.setAttribute('font-size','12');\n      text.setAttribute('fill','#cfeeff');\n      text.textContent = `n = ${nVal}  •  ops = ${formatNumber(Math.round(meas))}`;\n      tooltip.appendChild(text);\n\n      const text2 = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text2.setAttribute('x', x + 16);\n      text2.setAttribute('y', Math.max(8, y-26) + 36);\n      text2.setAttribute('font-size','11');\n      text2.setAttribute('fill','rgba(255,255,255,0.7)');\n      text2.textContent = `theory (scaled) ≈ ${formatNumber(Math.round(th))}`;\n      tooltip.appendChild(text2);\n    }\n    function hideTooltip(){ const t = document.getElementById('plotTooltip'); if(t) t.innerHTML = ''; }\n  }\n\n  function formatNumber(n){\n    if(n >= 1e9) return (n/1e9).toFixed(2)+'B';\n    if(n >= 1e6) return (n/1e6).toFixed(2)+'M';\n    if(n >= 1e3) return (n/1e3).toFixed(2)+'k';\n    return String(n);\n  }\n\n  // Function to sample n values (spread from 1..maxN)\n  function sampleNs(maxN, points, algoKey){\n    const nvals = [];\n    if(algoKey === 'exponential'){\n      // for exponential prefer linear sampling starting at 1 up to maxN small\n      for(let i=1;i<=Math.min(maxN, Math.max(1,points)); i++){\n        nvals.push(i);\n        if(nvals.length >= points) break;\n      }\n      return nvals;\n    }\n    // general: more dense at smaller n to show curve\n    for(let i=0;i<points;i++){\n      const t = i/(points-1 || 1);\n      // use non-linear spacing: quadratic for denser small values\n      const v = Math.round(1 + Math.pow(t, 1.4) * (maxN-1));\n      nvals.push(Math.max(1, v));\n    }\n    // ensure unique and sorted\n    return Array.from(new Set(nvals)).sort((a,b)=>a-b);\n  }\n\n  // measure operations for sample ns\n  function measureSamples(algoKey, ns){\n    const measured = [];\n    const theoretical = [];\n    const algo = algorithms[algoKey];\n    for(let i=0;i<ns.length;i++){\n      const n = ns[i];\n      const counter = makeCounter();\n      // run algorithm (but don't measure time here)\n      try{\n        algo.fn(n, counter);\n      } catch(e){\n        // in case of resource exhaustion e.g. huge n for exponential\n        console.error('algorithm error', e);\n      }\n      measured.push(counter.value());\n      // theoretical raw value\n      let th = algo.theory(n);\n      // avoid 0 or negative\n      if(!isFinite(th) || th <= 0) th = 1;\n      theoretical.push(th);\n    }\n    // To overlay shapes we may want to normalize theoretical to measured scale by scaling factor:\n    // compute a multiplier so that max(theoretical)*mult = max(measured)\n    const maxMeasured = Math.max(1, ...measured);\n    const maxTheor = Math.max(1, ...theoretical);\n    const multiplier = maxMeasured / maxTheor;\n    const scaledTheor = theoretical.map(v=>v*multiplier);\n    return {measured, theoretical: scaledTheor};\n  }\n\n  // Event: plot button\n  plotBtn.addEventListener('click', ()=>{\n    const algoKey = algoSel.value;\n    const maxN = Number(maxNnum.value) || Number(maxNRange.value) || 200;\n    const points = Math.max(4, Math.min(200, Number(pointsInput.value) || 25));\n    statAlgo.textContent = algorithms[algoKey].name;\n    updateCodeSnippet();\n    // sample n values\n    const ns = sampleNs(maxN, points, algoKey);\n    // measure\n    statOps.textContent = 'calculating...';\n    statTime.textContent = '—';\n    // Allow UI to update before heavy work\n    setTimeout(()=>{\n      const {measured, theoretical} = measureSamples(algoKey, ns);\n      // We will optionally show log scale mapping\n      const scale = scaleSel.value;\n      plotData(ns, measured, theoretical, {scale});\n      statOps.textContent = formatNumber(Math.round(measured[measured.length-1])) + ' (last sample)';\n      statTime.textContent = '—';\n    }, 10);\n  });\n\n  // Event: run button (runs for several increasing n and logs results)\n  runBtn.addEventListener('click', async ()=>{\n    const algoKey = algoSel.value;\n    const maxN = Number(maxNnum.value) || 200;\n    const points = 6;\n    const ns = sampleNs(maxN, points, algoKey);\n    statAlgo.textContent = algorithms[algoKey].name;\n    statOps.textContent = 'running...';\n    statTime.textContent = 'running...';\n    const results = [];\n    const t0 = performance.now();\n    for(let i=0;i<ns.length;i++){\n      const n = ns[i];\n      const counter = makeCounter();\n      const tStart = performance.now();\n      try{\n        algorithms[algoKey].fn(n, counter);\n      } catch(e){\n        console.error('error running', e);\n      }\n      const tEnd = performance.now();\n      results.push({n, ops: counter.value(), ms: tEnd - tStart});\n      // small yield\n      await new Promise(r => setTimeout(r, 8));\n    }\n    const t1 = performance.now();\n    // display last\n    const last = results[results.length -1];\n    statOps.textContent = `${formatNumber(last.ops)} ops`;\n    statTime.textContent = `${last.ms.toFixed(3)} ms (last run)`;\n    // Also plot these results against theory\n    const theoreticalRaw = ns.map(n => {\n      let th = algorithms[algoKey].theory(n);\n      if(!isFinite(th) || th<=0) th = 1;\n      return th;\n    });\n    // scale theoretical to measured\n    const maxMeasured = Math.max(1, ...results.map(r=>r.ops));\n    const maxTheo = Math.max(1, ...theoreticalRaw);\n    const mult = maxMeasured / maxTheo;\n    const scaledTheo = theoreticalRaw.map(v=>v*mult);\n    plotData(ns, results.map(r=>r.ops), scaledTheo, {scale: scaleSel.value});\n  });\n\n  // Event: runOnce single measurement with time\n  runOnce.addEventListener('click', ()=>{\n    const algoKey = algoSel.value;\n    let n = Number(singleN.value) || 1;\n    // clamp safety\n    if(algoKey === 'exponential') n = Math.min(n, 40);\n    if(algoKey === 'quadratic') n = Math.min(n, 2000);\n    singleN.value = n;\n    statAlgo.textContent = algorithms[algoKey].name;\n    statOps.textContent = 'running...';\n    statTime.textContent = 'running...';\n    // run in setTimeout to allow UI update\n    setTimeout(()=>{\n      const counter = makeCounter();\n      const t0 = performance.now();\n      try{\n        algorithms[algoKey].fn(n, counter);\n      } catch(e){\n        console.error('error on runOnce', e);\n      }\n      const t1 = performance.now();\n      const ops = counter.value();\n      statOps.textContent = formatNumber(ops) + ' ops';\n      statTime.textContent = (t1 - t0).toFixed(3) + ' ms';\n      // plot a single point as trivial small plot for reference\n      plotData([n], [ops], [algorithms[algoKey].theory(n) || 1], {scale: scaleSel.value});\n    }, 10);\n  });\n\n  // initialize UI values\n  statAlgo.textContent = algorithms[algoSel.value].name;\n  statOps.textContent = '—';\n  statTime.textContent = '—';\n\n  // initial plot (simple linear)\n  plotBtn.click();\n\n})();\n</script>\n</body>\n</html>"
