    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Kruskal's Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f4f4f4;\n        }\n        #canvas {\n            border: 1px solid #000;\n            margin: 20px auto;\n            display: block;\n            background: #fff;\n        }\n        button {\n            padding: 10px 20px;\n            font-size: 16px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Kruskal's Algorithm Visualization</h1>\n<canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas><br>\n<button onclick=\"runKruskal()\">Run Kruskal's Algorithm</button>\n\n<script>\n    const canvas = document.getElementById('canvas');\n    const ctx = canvas.getContext('2d');\n\n    class DisjointSet {\n        constructor(size) {\n            this.parent = Array.from({length: size}, (_, i) => i);\n            this.rank = Array(size).fill(0);\n        }\n\n        find(v) {\n            if (this.parent[v] !== v) {\n                this.parent[v] = this.find(this.parent[v]);\n            }\n            return this.parent[v];\n        }\n\n        union(v1, v2) {\n            const root1 = this.find(v1);\n            const root2 = this.find(v2);\n            if (root1 !== root2) {\n                if (this.rank[root1] > this.rank[root2]) {\n                    this.parent[root2] = root1;\n                } else if (this.rank[root1] < this.rank[root2]) {\n                    this.parent[root1] = root2;\n                } else {\n                    this.parent[root2] = root1;\n                    this.rank[root1]++;\n                }\n            }\n        }\n    }\n\n    const edges = [\n        {from: 0, to: 1, weight: 10},\n        {from: 0, to: 2, weight: 6},\n        {from: 0, to: 3, weight: 5},\n        {from: 1, to: 3, weight: 15},\n        {from: 2, to: 3, weight: 4}\n    ];\n\n    function drawGraph(selectedEdges) {\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n        const vertices = {0: {x: 100, y: 100}, 1: {x: 300, y: 100}, 2: {x: 200, y: 200}, 3: {x: 100, y: 300}};\n        \n        // Draw vertices\n        for (let v in vertices) {\n            ctx.beginPath();\n            ctx.arc(vertices[v].x, vertices[v].y, 20, 0, Math.PI * 2);\n            ctx.fillStyle = \"#00f\";\n            ctx.fill();\n            ctx.stroke();\n            ctx.fillStyle = \"#fff\";\n            ctx.fillText(v, vertices[v].x - 5, vertices[v].y + 5);\n        }\n\n        // Draw edges\n        for (let edge of edges) {\n            const start = vertices[edge.from];\n            const end = vertices[edge.to];\n            ctx.beginPath();\n            ctx.moveTo(start.x, start.y);\n            ctx.lineTo(end.x, end.y);\n            ctx.strokeStyle = selectedEdges.includes(edge) ? 'green' : 'black';\n            ctx.lineWidth = selectedEdges.includes(edge) ? 3 : 1;\n            ctx.stroke();\n            ctx.fillText(edge.weight, (start.x + end.x) / 2, (start.y + end.y) / 2 - 10);\n        }\n    }\n\n    function runKruskal() {\n        edges.sort((a, b) => a.weight - b.weight);\n        const disjointSet = new DisjointSet(4);\n        const mst = [];\n        let selectedEdges = [];\n\n        for (let edge of edges) {\n            if (disjointSet.find(edge.from) !== disjointSet.find(edge.to)) {\n                disjointSet.union(edge.from, edge.to);\n                mst.push(edge);\n                selectedEdges.push(edge);\n                drawGraph(selectedEdges);\n            }\n        }\n        console.log('Minimum Spanning Tree:', mst);\n    }\n\n</script>\n</body>\n</html>"
