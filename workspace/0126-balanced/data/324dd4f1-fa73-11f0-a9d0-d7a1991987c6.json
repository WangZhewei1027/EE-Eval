    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bellman-Ford Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 20px;\n            background-color: #f4f4f4;\n        }\n        h2 {\n            color: #333;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n            margin-bottom: 20px;\n        }\n        table, th, td {\n            border: 1px solid #333;\n        }\n        th, td {\n            padding: 8px;\n            text-align: center;\n        }\n        th {\n            background-color: #4CAF50;\n            color: white;\n        }\n        .button {\n            padding: 10px 20px;\n            font-size: 16px;\n            margin: 10px 0;\n            cursor: pointer;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            transition: background-color 0.3s;\n        }\n        .button:hover {\n            background-color: #45a049;\n        }\n        pre {\n            background-color: #f8f8f8;\n            padding: 15px;\n            border: 1px solid #CCC;\n            overflow-x: auto;\n        }\n    </style>\n</head>\n<body>\n    <h2>Bellman-Ford Algorithm Visualization</h2>\n    <p>This example demonstrates the Bellman-Ford algorithm to find the shortest paths from a single source vertex to all other vertices in a weighted graph.</p>\n    <button class=\"button\" onclick=\"runBellmanFord()\">Run Bellman-Ford Algorithm</button>\n    \n    <h3>Graph Representation (Edges)</h3>\n    <pre id=\"graphEdges\"></pre>\n    \n    <h3>Resulting Shortest Path</h3>\n    <table id=\"result\" style=\"display: none;\">\n        <thead>\n            <tr>\n                <th>Vertex</th>\n                <th>Distance from Source</th>\n            </tr>\n        </thead>\n        <tbody id=\"resultBody\"></tbody>\n    </table>\n\n    <script>\n        const graph = [\n            { u: 0, v: 1, weight: -1 },\n            { u: 0, v: 2, weight: 4 },\n            { u: 1, v: 2, weight: 3 },\n            { u: 1, v: 3, weight: 2 },\n            { u: 1, v: 4, weight: 2 },\n            { u: 3, v: 2, weight: 5 },\n            { u: 3, v: 1, weight: 1 },\n            { u: 4, v: 3, weight: -3 }\n        ];\n        \n        const V = 5; // Number of vertices\n        const edgesText = graph.map(e => `(${e.u} -> ${e.v}, weight: ${e.weight})`).join(\", \");\n        document.getElementById('graphEdges').innerText = edgesText;\n        \n        function runBellmanFord() {\n            const source = 0; // Starting vertex\n            let distances = Array(V).fill(Infinity);\n            distances[source] = 0;\n\n            // Relax edges |V| - 1 times\n            for (let i = 0; i < V - 1; i++) {\n                for (const edge of graph) {\n                    if (distances[edge.u] !== Infinity && distances[edge.u] + edge.weight < distances[edge.v]) {\n                        distances[edge.v] = distances[edge.u] + edge.weight;\n                    }\n                }\n            }\n\n            // Check for negative-weight cycles\n            for (const edge of graph) {\n                if (distances[edge.u] !== Infinity && distances[edge.u] + edge.weight < distances[edge.v]) {\n                    console.warn(\"Graph contains a negative-weight cycle\");\n                    return;\n                }\n            }\n\n            displayResults(distances);\n        }\n\n        function displayResults(distances) {\n            const resultBody = document.getElementById('resultBody');\n            resultBody.innerHTML = '';\n            distances.forEach((distance, vertex) => {\n                const row = document.createElement('tr');\n                row.innerHTML = `<td>${vertex}</td><td>${distance}</td>`;\n                resultBody.appendChild(row);\n            });\n            document.getElementById('result').style.display = 'table';\n        }\n    </script>\n</body>\n</html>"
