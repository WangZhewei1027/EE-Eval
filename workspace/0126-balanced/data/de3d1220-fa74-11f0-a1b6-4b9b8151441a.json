  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree Index Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        h1 {\n            color: #2c3e50;\n            text-align: center;\n        }\n        .controls {\n            background: #f8f9fa;\n            padding: 15px;\n            border-radius: 5px;\n            margin-bottom: 20px;\n        }\n        .tree-container {\n            overflow: auto;\n            border: 1px solid #ddd;\n            padding: 20px;\n            border-radius: 5px;\n            background: #f8f9fa;\n            min-height: 300px;\n        }\n        .node {\n            display: inline-block;\n            border: 1px solid #3498db;\n            border-radius: 3px;\n            padding: 5px;\n            margin: 5px;\n            background: white;\n        }\n        .keys {\n            display: flex;\n        }\n        .key {\n            padding: 5px;\n            margin: 0 2px;\n            background: #e8f4fc;\n            border-radius: 2px;\n            min-width: 20px;\n            text-align: center;\n        }\n        .key.highlight {\n            background: #f39c12;\n            color: white;\n        }\n        .children {\n            display: flex;\n            justify-content: center;\n        }\n        .child {\n            margin: 5px;\n        }\n        button, input {\n            padding: 8px;\n            margin: 5px;\n        }\n        .explanation {\n            background: #e8f4fc;\n            padding: 15px;\n            border-radius: 5px;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>B-Tree Index Visualization</h1>\n    \n    <div class=\"controls\">\n        <input type=\"number\" id=\"keyInput\" placeholder=\"Enter a key\" min=\"1\">\n        <button onclick=\"insertKey()\">Insert Key</button>\n        <button onclick=\"findKey()\">Find Key</button>\n        <button onclick=\"randomTree()\">Random Tree</button>\n        <button onclick=\"resetTree()\">Reset Tree</button>\n        <div>\n            <label>\n                Order (min keys per node):\n                <input type=\"number\" id=\"orderInput\" min=\"2\" value=\"2\" style=\"width: 50px;\">\n            </label>\n        </div>\n    </div>\n    \n    <div class=\"tree-container\" id=\"treeContainer\"></div>\n    \n    <div class=\"explanation\">\n        <h3>What is a B-Tree?</h3>\n        <p>A B-Tree is a self-balancing tree data structure that maintains sorted data and allows searches, sequential access, insertions, and deletions in logarithmic time. The B-tree is a generalization of a binary search tree in that a node can have more than two children.</p>\n        <p>Key properties:</p>\n        <ul>\n            <li>All leaves are at the same level</li>\n            <li>Each node (except root) must contain at least t-1 keys (where t is the minimum degree)</li>\n            <li>Each node can contain at most 2t-1 keys</li>\n            <li>Keys in nodes are stored in sorted order</li>\n            <li>For any node, all keys in its left subtree are less than the first key, all keys in right subtrees are greater</li>\n        </ul>\n        <p>B-Trees are commonly used in databases and file systems for indexing because they minimize disk I/O operations.</p>\n    </div>\n\n    <script>\n        class BTreeNode {\n            constructor(order) {\n                this.order = order;\n                this.keys = [];\n                this.children = [];\n                this.isLeaf = true;\n            }\n\n            // Insert a key into a non-full node\n            insertNonFull(key) {\n                let i = this.keys.length - 1;\n                \n                if (this.isLeaf) {\n                    // Find the correct position and insert\n                    while (i >= 0 && key < this.keys[i]) {\n                        i--;\n                    }\n                    this.keys.splice(i + 1, 0, key);\n                } else {\n                    // Find the child where the key should be inserted\n                    while (i >= 0 && key < this.keys[i]) {\n                        i--;\n                    }\n                    i++;\n                    \n                    if (this.children[i].keys.length === (2 * this.order) - 1) {\n                        this.splitChild(i);\n                        if (key > this.keys[i]) {\n                            i++;\n                        }\n                    }\n                    this.children[i].insertNonFull(key);\n                }\n            }\n\n            // Split a full child node\n            splitChild(childIndex) {\n                const order = this.order;\n                const child = this.children[childIndex];\n                const newNode = new BTreeNode(order);\n                \n                newNode.isLeaf = child.isLeaf;\n                \n                // Move keys to the new node\n                newNode.keys = child.keys.splice(order, order - 1);\n                \n                // Move children if not leaf\n                if (!child.isLeaf) {\n                    newNode.children = child.children.splice(order, order);\n                }\n                \n                // Move median key up to parent\n                this.keys.splice(childIndex, 0, child.keys.pop());\n                \n                // Add new node as a child\n                this.children.splice(childIndex + 1, 0, newNode);\n                this.isLeaf = false;\n            }\n\n            // Search for a key in the subtree\n            search(key) {\n                let i = 0;\n                while (i < this.keys.length && key > this.keys[i]) {\n                    i++;\n                }\n                \n                if (i < this.keys.length && key === this.keys[i]) {\n                    return { node: this, index: i };\n                }\n                \n                if (this.isLeaf) {\n                    return null;\n                }\n                \n                return this.children[i].search(key);\n            }\n        }\n\n        class BTree {\n            constructor(order = 2) {\n                this.order = order;\n                this.root = null;\n                this.highlightedKey = null;\n            }\n\n            insert(key) {\n                if (this.root === null) {\n                    this.root = new BTreeNode(this.order);\n                    this.root.keys.push(key);\n                } else {\n                    if (this.root.keys.length === (2 * this.order) - 1) {\n                        const newRoot = new BTreeNode(this.order);\n                        newRoot.children.push(this.root);\n                        newRoot.isLeaf = false;\n                        newRoot.splitChild(0);\n                        this.root = newRoot;\n                    }\n                    this.root.insertNonFull(key);\n                }\n                this.render();\n            }\n\n            search(key) {\n                this.clearHighlight();\n                if (this.root === null) {\n                    return null;\n                }\n                \n                const result = this.root.search(key);\n                if (result) {\n                    this.highlightedKey = { node: result.node, index: result.index };\n                    this.render();\n                    return result;\n                }\n                return null;\n            }\n\n            clearHighlight() {\n                this.highlightedKey = null;\n            }\n\n            generateRandomTree(count = 15) {\n                this.root = null;\n                const values = [];\n                for (let i = 1; i <= count; i++) {\n                    values.push(i);\n                }\n                \n                // Shuffle the array\n                for (let i = values.length - 1; i > 0; i--) {\n                    const j = Math.floor(Math.random() * (i + 1));\n                    [values[i], values[j]] = [values[j], values[i]];\n                }\n                \n                values.forEach(val => this.insert(val));\n                this.render();\n            }\n\n            render() {\n                const container = document.getElementById('treeContainer');\n                container.innerHTML = '';\n                \n                if (this.root === null) {\n                    container.textContent = 'Tree is empty';\n                    return;\n                }\n                \n                this.renderNode(this.root, container);\n            }\n\n            renderNode(node, parentElement, level = 0) {\n                const nodeElement = document.createElement('div');\n                nodeElement.className = 'node';\n                \n                const keysElement = document.createElement('div');\n                keysElement.className = 'keys';\n                \n                node.keys.forEach((key, index) => {\n                    const keyElement = document.createElement('div');\n                    keyElement.className = 'key';\n                    keyElement.textContent = key;\n                    \n                    if (this.highlightedKey && this.highlightedKey.node === node && this.highlightedKey.index === index) {\n                        keyElement.classList.add('highlight');\n                    }\n                    \n                    keysElement.appendChild(keyElement);\n                });\n                \n                nodeElement.appendChild(keysElement);\n                \n                if (!node.isLeaf && node.children.length > 0) {\n                    const childrenElement = document.createElement('div');\n                    childrenElement.className = 'children';\n                    \n                    node.children.forEach(child => {\n                        const childElement = document.createElement('div');\n                        childElement.className = 'child';\n                        this.renderNode(child, childElement, level + 1);\n                        childrenElement.appendChild(childElement);\n                    });\n                    \n                    nodeElement.appendChild(childrenElement);\n                }\n                \n                parentElement.appendChild(nodeElement);\n            }\n        }\n\n        const bTree = new BTree(2);\n\n        function insertKey() {\n            const keyInput = document.getElementById('keyInput');\n            const key = parseInt(keyInput.value);\n            \n            if (!isNaN(key)) {\n                bTree.insert(key);\n                keyInput.value = '';\n            } else {\n                alert('Please enter a valid number');\n            }\n        }\n\n        function findKey() {\n            const keyInput = document.getElementById('keyInput');\n            const key = parseInt(keyInput.value);\n            \n            if (!isNaN(key)) {\n                const result = bTree.search(key);\n                if (result) {\n                    alert(`Found key ${key} in the tree`);\n                } else {\n                    alert(`Key ${key} not found in the tree`);\n                }\n            } else {\n                alert('Please enter a valid number');\n            }\n        }\n\n        function randomTree() {\n            const orderInput = document.getElementById('orderInput');\n            const order = parseInt(orderInput.value);\n            \n            if (order >= 2) {\n                bTree.order = order;\n                bTree.generateRandomTree();\n            } else {\n                alert('Order must be at least 2');\n            }\n        }\n\n        function resetTree() {\n            const orderInput = document.getElementById('orderInput');\n            const order = parseInt(orderInput.value);\n            \n            if (order >= 2) {\n                bTree.order = order;\n                bTree.root = null;\n                bTree.render();\n            } else {\n                alert('Order must be at least 2');\n            }\n        }\n\n        // Initialize with a small tree\n        bTree.insert(10);\n        bTree.insert(20);\n        bTree.insert(5);\n        bTree.insert(6);\n        bTree.insert(12);\n        bTree.insert(30);\n        bTree.insert(7);\n        bTree.insert(17);\n        bTree.render();\n    </script>\n</body>\n</html>"
  },
