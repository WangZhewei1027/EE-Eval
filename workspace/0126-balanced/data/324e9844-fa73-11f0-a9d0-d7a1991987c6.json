    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Context Switching Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n            border: 1px solid #ccc;\n        }\n        #process-container {\n            margin-top: 20px;\n            border: 1px solid #333;\n            padding: 10px;\n            background-color: #f9f9f9;\n        }\n        .process {\n            margin: 5px 0;\n            padding: 5px;\n            border: 1px solid #007bff;\n            background-color: #e7f1ff;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Context Switching Demo</h1>\n<p>Click the \"Switch Context\" button to simulate context switching between multiple processes.</p>\n\n<button id=\"switch-button\">Switch Context</button>\n\n<div id=\"process-container\"></div>\n\n<script>\n    // Simulated processes\n    const processes = [\n        { id: 1, name: 'Process 1', state: 'Running' },\n        { id: 2, name: 'Process 2', state: 'Waiting' },\n        { id: 3, name: 'Process 3', state: 'Running' },\n        { id: 4, name: 'Process 4', state: 'Waiting' }\n    ];\n\n    let currentProcessIndex = 0;\n\n    function renderProcesses() {\n        const container = document.getElementById('process-container');\n        container.innerHTML = ''; // Clear previous processes\n        processes.forEach(process => {\n            const processDiv = document.createElement('div');\n            processDiv.className = 'process';\n            processDiv.innerText = `${process.name} - State: ${process.state}`;\n            if (process.id === processes[currentProcessIndex].id) {\n                processDiv.style.fontWeight = 'bold'; // Highlight the current process\n            }\n            container.appendChild(processDiv);\n        });\n    }\n\n    function switchContext() {\n        // Change the state of the current process\n        processes[currentProcessIndex].state = 'Waiting';\n        // Move to the next process\n        currentProcessIndex = (currentProcessIndex + 1) % processes.length;\n        // Set the new current process to running\n        processes[currentProcessIndex].state = 'Running';\n        // Rerender the processes\n        renderProcesses();\n    }\n\n    // Event handler\n    document.getElementById('switch-button').addEventListener('click', switchContext);\n\n    // Initial render\n    renderProcesses();\n</script>\n\n</body>\n</html>"
