  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Encryption Concepts — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 0; padding: 0; background: #f6f8fa; color: #0b1220; }\n    header { background: linear-gradient(90deg,#0b63ff, #00b4ff); color: white; padding: 18px 24px; }\n    header h1 { margin: 0; font-size: 20px; }\n    .container { display: grid; grid-template-columns: 360px 1fr; gap: 16px; padding: 20px; max-width: 1200px; margin: 0 auto; }\n    .panel { background: white; border-radius: 10px; padding: 16px; box-shadow: 0 6px 18px rgba(16,24,40,0.08); }\n    .panel h2 { font-size: 16px; margin: 0 0 8px; }\n    .small { font-size: 13px; color: #334155; }\n    .section { margin-bottom: 14px; }\n    label { display: block; font-size: 13px; margin-bottom: 6px; color: #0f172a; }\n    input[type=\"text\"], textarea, select { width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid #e6edf3; font-size: 14px; box-sizing: border-box; background: #fbfdff; }\n    textarea { min-height: 80px; resize: vertical; }\n    button { background: #0b63ff; color: white; border: none; padding: 8px 12px; border-radius: 8px; cursor: pointer; font-weight: 600; }\n    button.secondary { background: #64748b; }\n    button.ghost { background: transparent; border: 1px solid #cbd5e1; color: #0b1220; }\n    .row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }\n    .muted { color: #475569; font-size: 13px; }\n    pre { background: #0f172a; color: #e6eefc; padding: 10px; border-radius: 8px; overflow: auto; max-height: 200px; }\n    .kbd { background:#eef2ff; padding: 2px 7px; border-radius:6px; font-weight:700; color:#0b1220; font-size:12px; }\n    .split { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }\n    .log { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace; font-size: 13px; background: #f8fafc; padding: 8px; border-radius: 8px; min-height: 80px; overflow:auto; }\n    footer { max-width: 1200px; margin: 20px auto; color: #475569; font-size: 13px; text-align: center; }\n    .pill { display:inline-block; background:#eef2ff; color:#0b63ff; padding:4px 8px; border-radius: 999px; font-size:12px; margin-right:6px; }\n    .flex-vertical { display:flex; gap:8px; flex-direction:column; }\n    .controls { display:flex; gap:8px; margin-top:6px; }\n    .note { font-size:12px; color:#64748b; }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Encryption Concepts — Interactive Demo</h1>\n    <div class=\"small\">Try simple ciphers and real Web Crypto (AES-GCM, RSA-OAEP). Learn symmetric vs asymmetric and see how hybrid encryption works.</div>\n  </header>\n\n  <main class=\"container\">\n    <aside class=\"panel\">\n      <h2>Why encryption?</h2>\n      <p class=\"small\">Encryption transforms readable information (plaintext) into an unreadable format (ciphertext) so only authorized parties can reverse it (decrypt).</p>\n\n      <div class=\"section\">\n        <div class=\"pill\">Symmetric</div>\n        <div class=\"muted\">Same secret key encrypts and decrypts. Fast for large data (e.g., AES).</div>\n      </div>\n      <div class=\"section\">\n        <div class=\"pill\">Asymmetric</div>\n        <div class=\"muted\">Public/private key pair. Public key encrypts, private key decrypts (e.g., RSA). Useful for key exchange and signatures.</div>\n      </div>\n\n      <div class=\"section\">\n        <h2>How this demo is organized</h2>\n        <ul class=\"small\">\n          <li>Simple ciphers: Caesar and Vigenère (educational).</li>\n          <li>Symmetric: AES-GCM using Web Crypto API — generate key, encrypt/decrypt, show IV and ciphertext.</li>\n          <li>Asymmetric: RSA-OAEP key pair, encrypt with public key, decrypt with private key.</li>\n          <li>Hybrid: encrypt AES key with RSA public key — common real-world pattern.</li>\n        </ul>\n      </div>\n\n      <div class=\"section\">\n        <h2>Notes</h2>\n        <p class=\"note\">This page uses the browser's Web Crypto API (crypto.subtle). Keys marked \"extractable\" are exportable for demo — in production private keys should be kept non-extractable and protected.</p>\n      </div>\n\n    </aside>\n\n    <section class=\"panel\">\n      <h2>1) Simple ciphers (educational)</h2>\n      <div class=\"split\">\n        <div>\n          <label>Plaintext</label>\n          <textarea id=\"simple-plaintext\">Hello World! Encryption demo 123</textarea>\n        </div>\n        <div>\n          <label>Output</label>\n          <textarea id=\"simple-output\" readonly></textarea>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <div style=\"display:flex; gap:8px; align-items:center;\">\n          <label style=\"margin-bottom:0;\">Algorithm</label>\n          <select id=\"simple-algo\">\n            <option value=\"caesar\">Caesar Cipher (shift)</option>\n            <option value=\"vigenere\">Vigenère Cipher (repeating key)</option>\n          </select>\n          <div id=\"caesar-controls\" style=\"display:inline-block;\">\n            <label style=\"margin:0 8px 0 8px;\">Shift: <span id=\"shift-val\">3</span></label>\n            <input type=\"range\" id=\"shift\" min=\"-25\" max=\"25\" value=\"3\" />\n          </div>\n          <div id=\"vigenere-controls\" style=\"display:none; width:240px;\">\n            <label style=\"margin:0 8px 0 8px;\">Key:</label>\n            <input type=\"text\" id=\"vigenere-key\" placeholder=\"e.g., KEY\" value=\"SECRET\" />\n          </div>\n        </div>\n\n        <div class=\"controls\" style=\"margin-top:8px;\">\n          <button id=\"simple-encrypt\">Encrypt</button>\n          <button id=\"simple-decrypt\" class=\"secondary\">Decrypt</button>\n          <button id=\"simple-clear\" class=\"ghost\">Clear</button>\n        </div>\n        <div style=\"margin-top:8px;\" class=\"muted\">Simple ciphers operate on letters and are not secure for real use. They are here to illustrate the idea of reversible transformations.</div>\n      </div>\n\n      <hr />\n\n      <h2>2) Symmetric encryption (AES-GCM) — Web Crypto</h2>\n      <div class=\"section\">\n        <label>Plaintext</label>\n        <textarea id=\"aes-plaintext\">Sensitive message to encrypt with AES-GCM</textarea>\n\n        <div style=\"display:flex; gap:8px; margin-top:8px;\">\n          <button id=\"aes-gen\" >Generate AES Key</button>\n          <button id=\"aes-encrypt\" class=\"secondary\">Encrypt</button>\n          <button id=\"aes-decrypt\" class=\"secondary\">Decrypt</button>\n          <button id=\"aes-export\" class=\"ghost\">Export Key (base64)</button>\n        </div>\n\n        <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:8px;\">\n          <div>\n            <label>IV (base64)</label>\n            <input type=\"text\" id=\"aes-iv\" readonly />\n            <label style=\"margin-top:8px;\">Ciphertext (base64)</label>\n            <textarea id=\"aes-cipher\" readonly></textarea>\n          </div>\n          <div>\n            <label>Key (base64)</label>\n            <textarea id=\"aes-key\" readonly></textarea>\n            <label style=\"margin-top:8px;\">Decrypted plaintext</label>\n            <textarea id=\"aes-decrypted\" readonly></textarea>\n          </div>\n        </div>\n      </div>\n\n      <hr />\n\n      <h2>3) Asymmetric encryption (RSA-OAEP)</h2>\n      <div class=\"section\">\n        <div class=\"row\" style=\"align-items:center;\">\n          <button id=\"rsa-gen\">Generate RSA Key Pair</button>\n          <button id=\"rsa-encrypt\" class=\"secondary\">Encrypt with public key</button>\n          <button id=\"rsa-decrypt\" class=\"secondary\">Decrypt with private key</button>\n          <button id=\"rsa-export\" class=\"ghost\">Export Public PEM</button>\n        </div>\n\n        <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:8px;\">\n          <div>\n            <label>Plaintext (short)</label>\n            <textarea id=\"rsa-plaintext\">Short text (fits RSA-OAEP limits)</textarea>\n            <label style=\"margin-top:8px;\">Ciphertext (base64)</label>\n            <textarea id=\"rsa-cipher\" readonly></textarea>\n          </div>\n          <div>\n            <label>Public key (PEM)</label>\n            <textarea id=\"rsa-public\" readonly></textarea>\n            <label style=\"margin-top:8px;\">Decrypted plaintext</label>\n            <textarea id=\"rsa-decrypted\" readonly></textarea>\n          </div>\n        </div>\n\n        <div style=\"margin-top:8px;\" class=\"note\">RSA-OAEP encrypts small messages. In practice it's used to encrypt a symmetric key (hybrid encryption).</div>\n\n      </div>\n\n      <hr />\n      <h2>4) Hybrid example (AES key encrypted with RSA)</h2>\n      <div class=\"section\">\n        <div class=\"row\">\n          <button id=\"hybrid-run\">Run Hybrid Flow</button>\n        </div>\n        <div style=\"display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:8px;\">\n          <div>\n            <label>AES Key encrypted with RSA (base64)</label>\n            <textarea id=\"hybrid-encrypted-key\" readonly></textarea>\n            <label style=\"margin-top:8px;\">Ciphertext produced by AES (base64)</label>\n            <textarea id=\"hybrid-aes-cipher\" readonly></textarea>\n          </div>\n          <div>\n            <label>Original plaintext</label>\n            <textarea id=\"hybrid-plaintext\">Hybrid: this message is encrypted using an AES key, which is itself encrypted with RSA.</textarea>\n            <label style=\"margin-top:8px;\">Decrypted plaintext after hybrid flow</label>\n            <textarea id=\"hybrid-decrypted\" readonly></textarea>\n          </div>\n        </div>\n      </div>\n\n      <hr />\n\n      <div class=\"section\">\n        <h2>Console / Logs</h2>\n        <div id=\"log\" class=\"log\"></div>\n      </div>\n\n    </section>\n  </main>\n\n  <footer>\n    Tip: Open DevTools console to see raw ArrayBuffer outputs. This demo uses base64 and hex for human-readable display.\n  </footer>\n\n  <script>\n    // Helpers\n    function log(msg) {\n      const el = document.getElementById('log');\n      el.textContent += msg + '\\\\n';\n      el.scrollTop = el.scrollHeight;\n      console.debug(msg);\n    }\n    function toBase64(buf) {\n      if (buf instanceof ArrayBuffer) buf = new Uint8Array(buf);\n      let binary = '';\n      const bytes = new Uint8Array(buf);\n      const len = bytes.byteLength;\n      for (let i = 0; i < len; i++) binary += String.fromCharCode(bytes[i]);\n      return btoa(binary);\n    }\n    function fromBase64(b64) {\n      const binary = atob(b64);\n      const len = binary.length;\n      const bytes = new Uint8Array(len);\n      for (let i=0;i<len;i++) bytes[i] = binary.charCodeAt(i);\n      return bytes.buffer;\n    }\n    function bufToHex(buffer) {\n      const bytes = new Uint8Array(buffer);\n      return Array.from(bytes).map(b=>b.toString(16).padStart(2,'0')).join('');\n    }\n    async function pemExport(key, type) {\n      // type: 'spki' for public, 'pkcs8' for private\n      const exported = await crypto.subtle.exportKey(type, key);\n      const b64 = toBase64(exported);\n      const wrap = type === 'spki' ? 'PUBLIC KEY' : 'PRIVATE KEY';\n      const pem = `-----BEGIN ${wrap}-----\\\\n${b64.match(/.{1,64}/g).join('\\\\n')}\\\\n-----END ${wrap}-----\\\\n`;\n      return pem;\n    }\n\n    // Simple ciphers\n    const simplePlain = document.getElementById('simple-plaintext');\n    const simpleOut = document.getElementById('simple-output');\n    const algoSelect = document.getElementById('simple-algo');\n    const shiftRange = document.getElementById('shift');\n    const shiftVal = document.getElementById('shift-val');\n    const vigenereKeyInput = document.getElementById('vigenere-key');\n\n    algoSelect.addEventListener('change', ()=> {\n      const a = algoSelect.value;\n      document.getElementById('caesar-controls').style.display = a === 'caesar' ? 'inline-block' : 'none';\n      document.getElementById('vigenere-controls').style.display = a === 'vigenere' ? 'inline-block' : 'none';\n    });\n    shiftRange.addEventListener('input', ()=> shiftVal.textContent = shiftRange.value);\n\n    function caesarEncrypt(s, shift) {\n      return s.split('').map(ch=>{\n        if (ch >= 'a' && ch <= 'z') {\n          const code = (ch.charCodeAt(0)-97 + shift + 26) % 26 + 97;\n          return String.fromCharCode(code);\n        } else if (ch >= 'A' && ch <= 'Z') {\n          const code = (ch.charCodeAt(0)-65 + shift + 26) % 26 + 65;\n          return String.fromCharCode(code);\n        }\n        return ch;\n      }).join('');\n    }\n\n    function vigenereProcess(s, key, encrypt=true) {\n      const aKey = key.toUpperCase().replace(/[^A-Z]/g,'');\n      if (!aKey) return s;\n      let ki = 0;\n      return s.split('').map(ch=>{\n        let base=null;\n        if (ch >= 'a' && ch <= 'z') base=97;\n        else if (ch >= 'A' && ch <= 'Z') base=65;\n        else return ch;\n        const k = aKey[ki % aKey.length].charCodeAt(0) - 65;\n        const shift = encrypt ? k : (26 - k);\n        ki++;\n        const code = (ch.charCodeAt(0)-base + shift) % 26 + base;\n        return String.fromCharCode(code);\n      }).join('');\n    }\n\n    document.getElementById('simple-encrypt').addEventListener('click', ()=>{\n      const alg = algoSelect.value;\n      const text = simplePlain.value;\n      if (alg === 'caesar') {\n        const s = parseInt(shiftRange.value,10);\n        simpleOut.value = caesarEncrypt(text, s);\n        log('[Caesar] Encrypted with shift ' + s);\n      } else {\n        const key = vigenereKeyInput.value || '';\n        simpleOut.value = vigenereProcess(text, key, true);\n        log('[Vigenère] Encrypted with key \"'+key+'\"');\n      }\n    });\n\n    document.getElementById('simple-decrypt').addEventListener('click', ()=>{\n      const alg = algoSelect.value;\n      const text = simplePlain.value;\n      if (alg === 'caesar') {\n        const s = parseInt(shiftRange.value,10);\n        simpleOut.value = caesarEncrypt(text, -s);\n        log('[Caesar] Decrypted with shift ' + s);\n      } else {\n        const key = vigenereKeyInput.value || '';\n        simpleOut.value = vigenereProcess(text, key, false);\n        log('[Vigenère] Decrypted with key \"'+key+'\"');\n      }\n    });\n\n    document.getElementById('simple-clear').addEventListener('click', ()=>{\n      simplePlain.value = '';\n      simpleOut.value = '';\n    });\n\n    // AES-GCM\n    let aesKey = null;\n    document.getElementById('aes-gen').addEventListener('click', async ()=>{\n      aesKey = await crypto.subtle.generateKey({ name: 'AES-GCM', length: 256 }, true, ['encrypt','decrypt']);\n      document.getElementById('aes-key').value = '(key generated)';\n      log('[AES] Generated AES-GCM 256-bit key (extractable true for demo)');\n      // optionally export and show base64\n      const raw = await crypto.subtle.exportKey('raw', aesKey);\n      document.getElementById('aes-key').value = toBase64(raw);\n    });\n\n    document.getElementById('aes-encrypt').addEventListener('click', async ()=>{\n      if (!aesKey) { alert('Generate AES key first'); return; }\n      const pt = document.getElementById('aes-plaintext').value;\n      const enc = new TextEncoder().encode(pt);\n      const iv = crypto.getRandomValues(new Uint8Array(12)); // 96-bit recommended\n      try {\n        const ct = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, aesKey, enc);\n        document.getElementById('aes-iv').value = toBase64(iv);\n        document.getElementById('aes-cipher').value = toBase64(ct);\n        document.getElementById('aes-decrypted').value = '';\n        log('[AES] Encryption successful — produced ' + (ct.byteLength) + ' bytes ciphertext');\n      } catch (e) {\n        log('[AES] Encryption error: ' + e);\n        alert('Encryption failed: ' + e);\n      }\n    });\n\n    document.getElementById('aes-decrypt').addEventListener('click', async ()=>{\n      if (!aesKey) { alert('Generate AES key first'); return; }\n      const b64iv = document.getElementById('aes-iv').value;\n      const b64ct = document.getElementById('aes-cipher').value;\n      if (!b64iv || !b64ct) { alert('Missing IV or ciphertext'); return; }\n      try {\n        const iv = new Uint8Array(fromBase64(b64iv));\n        const ct = fromBase64(b64ct);\n        const ptBuf = await crypto.subtle.decrypt({ name: 'AES-GCM', iv }, aesKey, ct);\n        const text = new TextDecoder().decode(ptBuf);\n        document.getElementById('aes-decrypted').value = text;\n        log('[AES] Decryption successful — plaintext length ' + text.length);\n      } catch (e) {\n        log('[AES] Decryption error: ' + e);\n        alert('Decryption failed: ' + e);\n      }\n    });\n\n    document.getElementById('aes-export').addEventListener('click', async ()=>{\n      if (!aesKey) { alert('Generate AES key first'); return; }\n      const raw = await crypto.subtle.exportKey('raw', aesKey);\n      const b64 = toBase64(raw);\n      document.getElementById('aes-key').value = b64;\n      log('[AES] Exported key as base64');\n    });\n\n    // RSA-OAEP\n    let rsaKeyPair = null;\n    document.getElementById('rsa-gen').addEventListener('click', async ()=>{\n      rsaKeyPair = await crypto.subtle.generateKey({\n        name: 'RSA-OAEP',\n        modulusLength: 2048,\n        publicExponent: new Uint8Array([0x01,0x00,0x01]),\n        hash: 'SHA-256'\n      }, true, ['encrypt','decrypt']);\n      log('[RSA] Generated 2048-bit RSA-OAEP key pair (extractable for demo)');\n      // Export public key (PEM)\n      const pem = await pemExport(rsaKeyPair.publicKey, 'spki');\n      document.getElementById('rsa-public').value = pem;\n    });\n\n    async function importRsaPublicFromPem(pem) {\n      const b64 = pem.replace(/-----(BEGIN|END) PUBLIC KEY-----/g,'').replace(/\\\\s+/g,'');\n      const buf = fromBase64(b64);\n      return crypto.subtle.importKey('spki', buf, { name: 'RSA-OAEP', hash: 'SHA-256' }, true, ['encrypt']);\n    }\n\n    document.getElementById('rsa-encrypt').addEventListener('click', async ()=>{\n      if (!rsaKeyPair) { alert('Generate RSA keys first'); return; }\n      const pt = document.getElementById('rsa-plaintext').value;\n      const enc = new TextEncoder().encode(pt);\n      try {\n        const ct = await crypto.subtle.encrypt({ name: 'RSA-OAEP' }, rsaKeyPair.publicKey, enc);\n        document.getElementById('rsa-cipher').value = toBase64(ct);\n        log('[RSA] Encrypted ' + enc.byteLength + ' bytes plaintext with RSA-OAEP -> ' + ct.byteLength + ' bytes ciphertext');\n      } catch (e) {\n        log('[RSA] RSA encrypt error: ' + e);\n        alert('RSA encrypt failed: ' + e);\n      }\n    });\n\n    document.getElementById('rsa-decrypt').addEventListener('click', async ()=>{\n      if (!rsaKeyPair) { alert('Generate RSA keys first'); return; }\n      const b64 = document.getElementById('rsa-cipher').value;\n      if (!b64) { alert('No ciphertext present'); return; }\n      try {\n        const ct = fromBase64(b64);\n        const ptBuf = await crypto.subtle.decrypt({ name: 'RSA-OAEP' }, rsaKeyPair.privateKey, ct);\n        const text = new TextDecoder().decode(ptBuf);\n        document.getElementById('rsa-decrypted').value = text;\n        log('[RSA] Decryption successful, recovered ' + text.length + ' characters');\n      } catch (e) {\n        log('[RSA] RSA decrypt error: ' + e);\n        alert('RSA decrypt failed: ' + e);\n      }\n    });\n\n    document.getElementById('rsa-export').addEventListener('click', async ()=>{\n      if (!rsaKeyPair) { alert('Generate RSA keys first'); return; }\n      const pem = await pemExport(rsaKeyPair.publicKey, 'spki');\n      document.getElementById('rsa-public').value = pem;\n      log('[RSA] Exported public key as PEM');\n    });\n\n    // Hybrid: encrypt AES key with RSA public key, use AES to encrypt message\n    document.getElementById('hybrid-run').addEventListener('click', async ()=>{\n      try {\n        log('[Hybrid] Starting hybrid flow...');\n        // Ensure RSA exists or create it\n        if (!rsaKeyPair) {\n          log('[Hybrid] No RSA keys found — generating RSA key pair...');\n          rsaKeyPair = await crypto.subtle.generateKey({\n            name: 'RSA-OAEP',\n            modulusLength: 2048,\n            publicExponent: new Uint8Array([1,0,1]),\n            hash: 'SHA-256'\n          }, true, ['encrypt','decrypt']);\n          document.getElementById('rsa-public').value = await pemExport(rsaKeyPair.publicKey, 'spki');\n        }\n\n        // Generate AES key (extractable so we can export raw key)\n        const tempAes = await crypto.subtle.generateKey({ name: 'AES-GCM', length: 256 }, true, ['encrypt','decrypt']);\n        const rawAes = await crypto.subtle.exportKey('raw', tempAes);\n        const rawAesB64 = toBase64(rawAes);\n\n        // Encrypt AES key with RSA public key\n        const encryptedKey = await crypto.subtle.encrypt({ name: 'RSA-OAEP' }, rsaKeyPair.publicKey, rawAes);\n        document.getElementById('hybrid-encrypted-key').value = toBase64(encryptedKey);\n        log('[Hybrid] AES key encrypted with RSA public key -> ' + encryptedKey.byteLength + ' bytes');\n\n        // Use AES to encrypt the message\n        const pt = document.getElementById('hybrid-plaintext').value;\n        const enc = new TextEncoder().encode(pt);\n        const iv = crypto.getRandomValues(new Uint8Array(12));\n        const aesCipher = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, tempAes, enc);\n        // Store iv+cipher (we'll join iv + cipher for transport)\n        const combined = new Uint8Array(iv.byteLength + aesCipher.byteLength);\n        combined.set(iv, 0);\n        combined.set(new Uint8Array(aesCipher), iv.byteLength);\n        document.getElementById('hybrid-aes-cipher').value = toBase64(combined.buffer);\n        log('[Hybrid] Message encrypted with AES-GCM (iv + ciphertext length: ' + combined.byteLength + ' bytes)');\n\n        // Simulate receiver: decrypt AES key with RSA private key, then decrypt AES ciphertext\n        const decryptedRawAes = await crypto.subtle.decrypt({ name: 'RSA-OAEP' }, rsaKeyPair.privateKey, encryptedKey);\n        // Import AES key back\n        const importedAes = await crypto.subtle.importKey('raw', decryptedRawAes, { name: 'AES-GCM' }, false, ['decrypt']);\n        // Split iv and ciphertext\n        const combBuf = fromBase64(document.getElementById('hybrid-aes-cipher').value);\n        const combArr = new Uint8Array(combBuf);\n        const iv2 = combArr.slice(0,12);\n        const ct2 = combArr.slice(12).buffer;\n        const decryptedBuf = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: iv2 }, importedAes, ct2);\n        const decText = new TextDecoder().decode(decryptedBuf);\n        document.getElementById('hybrid-decrypted').value = decText;\n        log('[Hybrid] Receiver decrypted AES key with RSA private key and recovered message: \"' + decText + '\"');\n      } catch (e) {\n        log('[Hybrid] Error: ' + e);\n        alert('Hybrid flow error: ' + e);\n      }\n    });\n\n    // Init log\n    log('Demo ready. Use the controls to experiment with encryption.');\n  </script>\n</body>\n</html>"
  },
