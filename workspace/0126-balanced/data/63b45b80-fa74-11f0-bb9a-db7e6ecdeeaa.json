    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Decision Trees Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #fafafa;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #tree-container {\n    display: flex;\n    justify-content: center;\n    margin: 20px 0 40px;\n  }\n  svg {\n    border: 1px solid #ccc;\n    background: #fff;\n    border-radius: 6px;\n  }\n  .node rect {\n    fill: #e0f7fa;\n    stroke: #0097a7;\n    stroke-width: 2px;\n    rx: 8;\n    ry: 8;\n  }\n  .node text {\n    font-size: 14px;\n    pointer-events: none;\n    user-select: none;\n  }\n  .link {\n    fill: none;\n    stroke: #00796b;\n    stroke-width: 2px;\n  }\n  .label {\n    font-weight: bold;\n    fill: #004d40;\n  }\n  #input-section {\n    max-width: 400px;\n    margin: 0 auto 40px;\n    padding: 20px;\n    border: 1px solid #ddd;\n    background: white;\n    border-radius: 10px;\n  }\n  #input-section h2 {\n    text-align: center;\n  }\n  label {\n    display: block;\n    margin-top: 12px;\n  }\n  select, input[type=\"number\"], button {\n    width: 100%;\n    padding: 8px 10px;\n    margin-top: 6px;\n    font-size: 16px;\n    border-radius: 6px;\n    border: 1px solid #ccc;\n    box-sizing: border-box;\n  }\n  button {\n    margin-top: 20px;\n    background: #0097a7;\n    color: white;\n    border: none;\n    cursor: pointer;\n    font-weight: bold;\n  }\n  button:hover {\n    background: #00796b;\n  }\n  #prediction-result {\n    text-align: center;\n    font-size: 20px;\n    font-weight: bold;\n    margin-top: 15px;\n    color: #00796b;\n  }\n  footer {\n    margin-top: 60px;\n    text-align: center;\n    font-size: 0.9em;\n    color: #666;\n  }\n</style>\n</head>\n<body>\n<h1>Decision Tree Classifier Demonstration</h1>\n<p style=\"text-align:center; max-width:650px; margin: 0 auto;\">\n  This interactive example illustrates how a <strong>Decision Tree</strong> works for classification.\n  Adjust the inputs and see how the decision tree evaluates them to produce a prediction.\n</p>\n\n<div id=\"tree-container\">\n<svg width=\"700\" height=\"360\" viewBox=\"0 0 700 360\" aria-label=\"Visual representation of a decision tree\" role=\"img\"></svg>\n</div>\n\n<section id=\"input-section\" aria-labelledby=\"input-section-heading\">\n  <h2 id=\"input-section-heading\">Input Features</h2>\n  <form id=\"feature-form\" aria-describedby=\"feature-description\">\n    <p id=\"feature-description\">\n      Provide values for the features below. The tree will classify the input into one of two classes: <em>Class A</em> or <em>Class B</em>.\n    </p>\n\n    <label for=\"feature1\">Feature 1 (Numeric):</label>\n    <input type=\"number\" id=\"feature1\" name=\"feature1\" min=\"0\" max=\"50\" step=\"0.1\" value=\"8\" required aria-required=\"true\" />\n\n    <label for=\"feature2\">Feature 2 (Categorical):</label>\n    <select id=\"feature2\" name=\"feature2\" required aria-required=\"true\">\n      <option value=\"\">Select</option>\n      <option value=\"Red\">Red</option>\n      <option value=\"Green\">Green</option>\n      <option value=\"Blue\">Blue</option>\n    </select>\n\n    <button type=\"submit\">Classify</button>\n  </form>\n\n  <div id=\"prediction-result\" role=\"status\" aria-live=\"polite\"></div>\n</section>\n\n<script>\n// Decision Tree Structure:\n// Example tree for classification between Class A and Class B\n// For simplicity, features: feature1 (numeric), feature2 (categorical)\n\n// Tree nodes format:\n// {\n//   id: string,\n//   type: \"internal\" | \"leaf\",\n//   feature?: string,\n//   threshold?: number (for numeric features),\n//   categories?: array (for categorical features),\n//   branches?: object mapping (for categorical splits) or two branches for numeric,\n//   value?: classification label for leaf nodes,\n// }\n\n// We'll implement a small tree like this:\n//\n// Root: feature1 <= 10?\n//    yes -> check feature2 == 'Red' or 'Green'? (Red or Green => Class A, Blue => Class B)\n//    no -> Class B\n//\n// Tree diagram with node IDs for clarity:\n//    (n0) feature1 <= 10?\n//     /            \\\n// (n1)            (n2)\n// feature2?        Leaf: Class B\n// /    \\\n//Red/Green  Blue\n// |         |\n//Class A    Class B\n\nconst treeData = {\n  id: \"n0\",\n  type: \"internal\",\n  feature: \"feature1\",\n  threshold: 10,\n  branches: {\n    lessEqual: {\n      id: \"n1\",\n      type: \"internal\",\n      feature: \"feature2\",\n      categories: {\n        \"Red\": { id: \"n3\", type: \"leaf\", value: \"Class A\" },\n        \"Green\": { id: \"n4\", type: \"leaf\", value: \"Class A\" },\n        \"Blue\": { id: \"n5\", type: \"leaf\", value: \"Class B\" },\n      },\n    },\n    greater: {\n      id: \"n2\",\n      type: \"leaf\",\n      value: \"Class B\",\n    },\n  },\n};\n\n// Draw a simple tree diagram in SVG\nconst svg = document.querySelector(\"svg\");\n\nconst NODE_WIDTH = 140;\nconst NODE_HEIGHT = 50;\nconst H_SPACING = 160;\nconst V_SPACING = 100;\n\n// Coordinates by node id — we'll assign manually for this small tree\nconst nodePositions = {\n  \"n0\": { x: 280, y: 30 },\n  \"n1\": { x: 100, y: 150 },\n  \"n2\": { x: 460, y: 150 },\n  \"n3\": { x: 20, y: 270 },\n  \"n4\": { x: 180, y: 270 },\n  \"n5\": { x: 100, y: 270 },\n};\n\nfunction createNodeGroup(node, pos) {\n  const g = document.createElementNS(\"http://www.w3.org/2000/svg\", \"g\");\n  g.setAttribute(\"class\", \"node\");\n  g.setAttribute(\"tabindex\", \"0\");\n  g.setAttribute(\"role\", \"group\");\n  g.setAttribute(\"aria-label\", node.type === \"leaf\"\n    ? `Leaf node: predicts ${node.value}`\n    : `Decision node: splits on ${node.feature}${node.threshold !== undefined ? ` ≤ ${node.threshold}` : \"\"}`\n  );\n  g.setAttribute(\"transform\", `translate(${pos.x},${pos.y})`);\n\n  const rect = document.createElementNS(\"http://www.w3.org/2000/svg\", \"rect\");\n  rect.setAttribute(\"width\", NODE_WIDTH);\n  rect.setAttribute(\"height\", NODE_HEIGHT);\n  rect.setAttribute(\"x\", 0);\n  rect.setAttribute(\"y\", 0);\n\n  const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n  text.setAttribute(\"x\", NODE_WIDTH / 2);\n  text.setAttribute(\"y\", NODE_HEIGHT / 2 + 6);\n  text.setAttribute(\"text-anchor\", \"middle\");\n  text.setAttribute(\"dominant-baseline\", \"middle\");\n  text.setAttribute(\"pointer-events\", \"none\");\n\n  if (node.type === \"leaf\") {\n    text.textContent = node.value;\n    text.setAttribute(\"fill\", \"#004d40\");\n    text.style.fontWeight = \"bold\";\n  } else {\n    if (node.feature === \"feature1\") {\n      text.textContent = `feature1 ≤ ${node.threshold}`;\n    } else if (node.feature === \"feature2\") {\n      text.textContent = `feature2?`;\n    } else {\n      text.textContent = node.feature || \"Decision\";\n    }\n  }\n\n  g.appendChild(rect);\n  g.appendChild(text);\n\n  return g;\n}\n\nfunction createLink(x1, y1, x2, y2, label) {\n  const g = document.createElementNS(\"http://www.w3.org/2000/svg\", \"g\");\n  const path = document.createElementNS(\"http://www.w3.org/2000/svg\", \"path\");\n  path.setAttribute(\n    \"d\",\n    `M${x1} ${y1} L${x2} ${y2}`\n  );\n  path.setAttribute(\"class\", \"link\");\n  g.appendChild(path);\n\n  if (label) {\n    const midX = (x1 + x2) / 2;\n    const midY = (y1 + y2) / 2;\n\n    const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n    text.setAttribute(\"x\", midX);\n    text.setAttribute(\"y\", midY - 6);\n    text.setAttribute(\"text-anchor\", \"middle\");\n    text.setAttribute(\"class\", \"label\");\n    text.textContent = label;\n    g.appendChild(text);\n  }\n  return g;\n}\n\n// Clear and draw full tree\nfunction drawTree() {\n  svg.innerHTML = \"\";\n\n  // Nodes\n  for (const id in nodePositions) {\n    // Find node by id recursively\n    const node = findNodeById(treeData, id);\n    if (!node) continue;\n    const pos = nodePositions[id];\n    const nodeGroup = createNodeGroup(node, pos);\n    svg.appendChild(nodeGroup);\n  }\n  // Links:\n  // n0 -> n1 and n2\n  const pos0 = nodePositions[\"n0\"];\n  const pos1 = nodePositions[\"n1\"];\n  const pos2 = nodePositions[\"n2\"];\n\n  svg.appendChild(createLink(pos0.x + NODE_WIDTH/2, pos0.y + NODE_HEIGHT, pos1.x + NODE_WIDTH/2, pos1.y, \"Yes\"));\n  svg.appendChild(createLink(pos0.x + NODE_WIDTH/2, pos0.y + NODE_HEIGHT, pos2.x + NODE_WIDTH/2, pos2.y, \"No\"));\n\n  // n1 -> n3, n4, n5 (categorical branches)\n  // Red -> n3, Green -> n4, Blue -> n5\n  const pos3 = nodePositions[\"n3\"];\n  const pos4 = nodePositions[\"n4\"];\n  const pos5 = nodePositions[\"n5\"];\n\n  // For better clarity: 3 branches from n1\n  // We'll draw links with labels: Red, Green, Blue\n  svg.appendChild(createLink(pos1.x + NODE_WIDTH/2, pos1.y + NODE_HEIGHT, pos3.x + NODE_WIDTH/2, pos3.y, \"Red\"));\n  svg.appendChild(createLink(pos1.x + NODE_WIDTH/2, pos1.y + NODE_HEIGHT, pos4.x + NODE_WIDTH/2, pos4.y, \"Green\"));\n  svg.appendChild(createLink(pos1.x + NODE_WIDTH/2, pos1.y + NODE_HEIGHT, pos5.x + NODE_WIDTH/2, pos5.y, \"Blue\"));\n}\n\nfunction findNodeById(node, id) {\n  if (!node) return null;\n  if (node.id === id) return node;\n  // Check numeric branches\n  if (node.type === \"internal\") {\n    if (node.branches) {\n      if (node.branches.lessEqual) {\n        const res = findNodeById(node.branches.lessEqual, id);\n        if (res) return res;\n      }\n      if (node.branches.greater) {\n        const res = findNodeById(node.branches.greater, id);\n        if (res) return res;\n      }\n      // Categorical branches:\n      for (const cat in node.branches) {\n        if (cat !== \"lessEqual\" && cat !== \"greater\") {\n          const res = findNodeById(node.branches[cat], id);\n          if (res) return res;\n        }\n      }\n    }\n  }\n  return null;\n}\n\n// Function to classify input using tree\n// Input example: { feature1: number, feature2: string }\nfunction classifyInput(input, tree = treeData) {\n  if (tree.type === \"leaf\") {\n    return tree.value;\n  }\n  if (tree.feature === \"feature1\") {\n    const val = Number(input[\"feature1\"]);\n    if (isNaN(val)) return \"Invalid input\";\n    if (val <= tree.threshold) {\n      return classifyInput(input, tree.branches.lessEqual);\n    } else {\n      return classifyInput(input, tree.branches.greater);\n    }\n  } else if (tree.feature === \"feature2\") {\n    const val = input[\"feature2\"];\n    if (!val || !tree.branches[val]) {\n      return \"Unknown category\";\n    }\n    return classifyInput(input, tree.branches[val]);\n  }\n  return \"Unknown\";\n}\n\n// Highlight path through tree nodes\nfunction highlightPath(input, tree = treeData) {\n  // Clear all highlights first\n  svg.querySelectorAll(\".node rect\").forEach(r => r.style.fill = \"#e0f7fa\");\n\n  // Recursive highlight\n  function recurse(node, input) {\n    if (!node) return;\n    const nodeGroup = svg.querySelector(`g.node[aria-label*=\"${node.type === \"leaf\" ? node.value : node.feature}\"]`);\n    if (!nodeGroup) return;\n    const rect = nodeGroup.querySelector(\"rect\");\n    rect.style.fill = \"#80deea\"; // Highlight color\n\n    if (node.type === \"leaf\") return;\n\n    if (node.feature === \"feature1\") {\n      if (input.feature1 <= node.threshold) {\n        recurse(node.branches.lessEqual, input);\n      } else {\n        recurse(node.branches.greater, input);\n      }\n    } else if (node.feature === \"feature2\") {\n      if (node.branches[input.feature2]) {\n        recurse(node.branches[input.feature2], input);\n      }\n    }\n  }\n  recurse(tree, input);\n}\n\n// Initialization & Event Handling\nconst form = document.getElementById(\"feature-form\");\nconst predictionDisplay = document.getElementById(\"prediction-result\");\nconst inputFeature2 = document.getElementById(\"feature2\");\n\n// Focus feature2 for accessibility - preselect option so we avoid unknown category\ninputFeature2.value = \"Red\";\n\ndrawTree();\n\nform.addEventListener(\"submit\", e => {\n  e.preventDefault();\n  const f1 = parseFloat(form.feature1.value);\n  const f2 = form.feature2.value;\n\n  if (isNaN(f1)) {\n    predictionDisplay.textContent = \"Please provide a valid number for Feature 1.\";\n    return;\n  }\n  if (!f2) {\n    predictionDisplay.textContent = \"Please select a value for Feature 2.\";\n    return;\n  }\n\n  const input = { feature1: f1, feature2: f2 };\n  const prediction = classifyInput(input);\n\n  highlightPath(input);\n\n  if (prediction === \"Unknown category\") {\n    predictionDisplay.textContent = \"Input category for Feature 2 not recognized by the tree.\";\n  } else if (prediction === \"Invalid input\") {\n    predictionDisplay.textContent = \"Invalid input values.\";\n  } else {\n    predictionDisplay.textContent = `Prediction: ${prediction}`;\n  }\n});\n\n// Run classification with initial values for demonstration\nform.dispatchEvent(new Event(\"submit\"));\n</script>\n</body>\n</html>"
  },
