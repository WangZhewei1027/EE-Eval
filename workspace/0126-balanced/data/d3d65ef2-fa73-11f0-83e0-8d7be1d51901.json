    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Counting Sort Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --accent:#4f46e5;\n      --muted:#94a3b8;\n      --good:#10b981;\n      --danger:#ef4444;\n      --panel:#071025;\n      --glass: rgba(255,255,255,0.03);\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: linear-gradient(180deg,#071025 0%, #041127 100%);\n      color:#e6eef8;\n      -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;\n    }\n    .wrap{\n      max-width:1100px;\n      margin:28px auto;\n      padding:18px;\n    }\n    header{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-bottom:18px;\n    }\n    h1{\n      font-size:20px;\n      margin:0;\n      letter-spacing:0.2px;\n    }\n    p.lead{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.015) 100%);\n      border:1px solid rgba(255,255,255,0.03);\n      padding:14px;\n      border-radius:10px;\n      box-shadow:0 6px 18px rgba(2,6,23,0.6);\n      margin-bottom:14px;\n    }\n    .controls{\n      display:flex;\n      gap:10px;\n      flex-wrap:wrap;\n      align-items:center;\n    }\n    input[type=\"text\"]{\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.04);\n      color:var(--muted);\n      padding:8px 10px;\n      border-radius:6px;\n      min-width:240px;\n    }\n    label{ font-size:13px; color:var(--muted); display:flex; gap:8px; align-items:center; }\n    .btn{\n      background:var(--accent);\n      color:white;\n      padding:8px 12px;\n      border-radius:8px;\n      border: none;\n      cursor:pointer;\n      font-weight:600;\n      box-shadow: 0 6px 16px rgba(79,70,229,0.18);\n    }\n    .btn.secondary{\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.05);\n      color:var(--muted);\n      box-shadow:none;\n    }\n    .btn.danger{\n      background:var(--danger);\n      box-shadow:0 6px 18px rgba(239,68,68,0.16);\n    }\n    .row{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-top:12px;\n      flex-wrap:wrap;\n    }\n    .visual{\n      display:flex;\n      gap:8px;\n      align-items:end;\n      min-height:160px;\n      padding:12px;\n      border-radius:8px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n    }\n    .bar{\n      width:30px;\n      background:linear-gradient(180deg, rgba(79,70,229,0.9), rgba(99,102,241,0.9));\n      border-radius:6px 6px 4px 4px;\n      display:flex;\n      align-items:flex-end;\n      justify-content:center;\n      color:white;\n      font-size:12px;\n      position:relative;\n      transition: all 180ms ease;\n      box-shadow: 0 6px 14px rgba(9,10,20,0.45);\n    }\n    .bar.muted{ background:linear-gradient(180deg,#0b1220,#071025); color:var(--muted); box-shadow:none; border:1px solid rgba(255,255,255,0.02); }\n    .bar.count{ background:linear-gradient(180deg,#0a9396,#0ea5a9); font-weight:700; }\n    .bar.output{ background:linear-gradient(180deg,#16a34a,#4ade80); font-weight:700; }\n    .bar.highlight{ outline:3px solid rgba(99,102,241,0.18); transform:translateY(-6px); box-shadow:0 12px 26px rgba(79,70,229,0.12); }\n    .bar.index{\n      position:absolute;\n      top:-18px;\n      left:50%;\n      transform:translateX(-50%);\n      font-size:11px;\n      color:var(--muted);\n    }\n    .legend{ font-size:13px; color:var(--muted); display:flex; gap:12px; align-items:center; margin-top:8px;}\n    .chip{ display:inline-flex; gap:8px; align-items:center; padding:6px 10px; border-radius:999px; background:var(--glass); color:var(--muted); font-size:12px;}\n    pre.pseudo{\n      background:transparent; border:1px dashed rgba(255,255,255,0.03); padding:12px; border-radius:8px; color:var(--muted); font-size:13px; overflow:auto;\n    }\n    footer{ color:var(--muted); font-size:13px; margin-top:8px; }\n    .small{ font-size:12px; color:var(--muted); }\n    .inline{ display:inline-flex; gap:8px; align-items:center; }\n    input[type=\"range\"]{ width:160px; }\n    .arrays{\n      display:flex;\n      gap:12px;\n      align-items:flex-end;\n      overflow-x:auto;\n      padding:8px;\n    }\n    .panel{\n      padding:12px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border-radius:8px;\n    }\n    @media (max-width:700px){\n      .bar{ width:24px; font-size:11px; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <header>\n      <div>\n        <h1>Counting Sort — Visual Demonstration</h1>\n        <p class=\"lead\">Stable integer sorting by counting occurrences. Works best for small integer ranges.</p>\n      </div>\n    </header>\n\n    <div class=\"card\">\n      <div style=\"display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;\">\n        <div style=\"min-width:260px;flex:1\">\n          <label class=\"small\">Array (comma separated):</label><br/>\n          <input id=\"arrayInput\" type=\"text\" value=\"4,2,2,8,3,3,1\" />\n          <div style=\"margin-top:8px;\" class=\"controls\">\n            <button class=\"btn\" id=\"btnRandom\">Generate Random</button>\n            <button class=\"btn secondary\" id=\"btnFromInput\">Load Array</button>\n            <button class=\"btn secondary\" id=\"btnReset\">Reset</button>\n          </div>\n          <div class=\"row\" style=\"margin-top:8px;\">\n            <label class=\"small inline\">Size:\n              <input id=\"sizeRange\" type=\"range\" min=\"3\" max=\"30\" value=\"7\" />\n            </label>\n            <label class=\"small inline\">Min:\n              <input id=\"minRange\" type=\"range\" min=\"-20\" max=\"20\" value=\"1\" />\n            </label>\n            <label class=\"small inline\">Max:\n              <input id=\"maxRange\" type=\"range\" min=\"-20\" max=\"50\" value=\"8\" />\n            </label>\n          </div>\n        </div>\n\n        <div style=\"min-width:260px;\">\n          <div style=\"display:flex;gap:8px;align-items:center;\">\n            <button class=\"btn\" id=\"btnStart\">Start</button>\n            <button class=\"btn\" id=\"btnPause\">Pause</button>\n            <button class=\"btn secondary\" id=\"btnStep\">Step</button>\n            <button class=\"btn danger\" id=\"btnFastForward\">Run Fast</button>\n            <label class=\"small inline\">Speed:\n              <input id=\"speed\" type=\"range\" min=\"50\" max=\"1500\" step=\"10\" value=\"500\" />\n            </label>\n          </div>\n          <div style=\"margin-top:8px;\" class=\"small\">Steps highlight elements as they are counted and placed (stable algorithm uses right-to-left placement).</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <div style=\"display:flex;gap:12px;flex-direction:column;\">\n        <div style=\"display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;\">\n          <div class=\"panel\" style=\"flex:1;min-width:320px;\">\n            <div class=\"small\" style=\"margin-bottom:8px\">Input Array</div>\n            <div id=\"inputVisual\" class=\"visual arrays\"></div>\n          </div>\n\n          <div class=\"panel\" style=\"min-width:320px;\">\n            <div class=\"small\" style=\"margin-bottom:8px\">Counts (index = value - offset)</div>\n            <div id=\"countVisual\" class=\"visual arrays\"></div>\n          </div>\n\n          <div class=\"panel\" style=\"min-width:320px;\">\n            <div class=\"small\" style=\"margin-bottom:8px\">Output (building stable result)</div>\n            <div id=\"outputVisual\" class=\"visual arrays\"></div>\n          </div>\n        </div>\n\n        <div style=\"display:flex;gap:16px;align-items:center;flex-wrap:wrap;\">\n          <div class=\"chip\">Offset: <span id=\"offsetDisplay\" style=\"margin-left:6px;font-weight:700\">0</span></div>\n          <div class=\"chip\">Phase: <span id=\"phaseDisplay\" style=\"margin-left:6px;font-weight:700\">Idle</span></div>\n          <div class=\"chip\">Step: <span id=\"stepDisplay\" style=\"margin-left:6px;font-weight:700\">0</span></div>\n          <div class=\"chip\">Range size: <span id=\"rangeSize\" style=\"margin-left:6px;font-weight:700\">0</span></div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <div style=\"display:flex;gap:16px;flex-direction:row;flex-wrap:wrap;\">\n        <div style=\"flex:1;min-width:320px;\">\n          <div class=\"small\" style=\"margin-bottom:8px\">Pseudocode (stable Counting Sort)</div>\n          <pre class=\"pseudo\">\nCountingSort(A):\n  let min = min(A), max = max(A)\n  let offset = min\n  let range = max - min + 1\n  create count[0..range-1] = {0}\n  for i = 0 to A.length-1:\n    count[A[i] - offset] += 1\n  // cumulative counts\n  for j = 1 to range-1:\n    count[j] += count[j-1]\n  // build output (stable): iterate A from right to left\n  create output[A.length]\n  for i = A.length-1 down to 0:\n    idx = A[i] - offset\n    position = count[idx] - 1\n    output[position] = A[i]\n    count[idx] -= 1\n  return output\n          </pre>\n        </div>\n        <div style=\"width:360px;min-width:260px;\">\n          <div class=\"small\" style=\"margin-bottom:8px\">Notes</div>\n          <div class=\"small\" style=\"color:var(--muted)\">\n            - Counting Sort runs in O(n + k) time where k is the range size (max-min+1).\n            <br/>- It is stable when we place elements into output from right to left using cumulative counts.\n            <br/>- For very large ranges relative to n, Counting Sort can be memory-inefficient.\n            <br/>- This demo supports negative values by applying an offset.\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <footer style=\"text-align:center;\">Built for learning — interactive step visualization of Counting Sort.</footer>\n  </div>\n\n  <script>\n    // Counting Sort Visualizer\n    // Elements\n    const arrayInput = document.getElementById('arrayInput');\n    const btnRandom = document.getElementById('btnRandom');\n    const btnFromInput = document.getElementById('btnFromInput');\n    const btnStart = document.getElementById('btnStart');\n    const btnPause = document.getElementById('btnPause');\n    const btnStep = document.getElementById('btnStep');\n    const btnReset = document.getElementById('btnReset');\n    const btnFastForward = document.getElementById('btnFastForward');\n    const sizeRange = document.getElementById('sizeRange');\n    const minRange = document.getElementById('minRange');\n    const maxRange = document.getElementById('maxRange');\n    const speedRange = document.getElementById('speed');\n\n    const inputVisual = document.getElementById('inputVisual');\n    const countVisual = document.getElementById('countVisual');\n    const outputVisual = document.getElementById('outputVisual');\n\n    const offsetDisplay = document.getElementById('offsetDisplay');\n    const phaseDisplay = document.getElementById('phaseDisplay');\n    const stepDisplay = document.getElementById('stepDisplay');\n    const rangeSizeEl = document.getElementById('rangeSize');\n\n    // State\n    let A = [];\n    let originalA = [];\n    let counts = [];\n    let output = [];\n    let offset = 0;\n    let timer = null;\n    let gen = null; // generator for algorithm steps\n    let stepCount = 0;\n    let running = false;\n\n    // Utility helpers\n    function clamp(v, a, b){ return Math.max(a, Math.min(b, v)); }\n    function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n\n    function parseArrayFromInput(){\n      const text = arrayInput.value.trim();\n      if(!text) return [];\n      const parts = text.split(',').map(s=>s.trim()).filter(s=>s.length);\n      const nums = [];\n      for(const p of parts){\n        const n = Number(p);\n        if(Number.isFinite(n) && Number.isInteger(n)) nums.push(n);\n      }\n      return nums;\n    }\n\n    function setArray(arr){\n      A = arr.slice();\n      originalA = arr.slice();\n      renderAll();\n    }\n\n    function generateRandom(){\n      const size = Number(sizeRange.value);\n      let min = Number(minRange.value);\n      let max = Number(maxRange.value);\n      if(max < min){ const t=min; min=max; max=t; }\n      // prevent insane ranges for visualization\n      const range = max - min + 1;\n      if(range > 200){\n        // clamp around min..max but keep workable\n        max = min + 199;\n        maxRange.value = max;\n      }\n      const res = [];\n      for(let i=0;i<size;i++) res.push(randInt(min,max));\n      arrayInput.value = res.join(', ');\n      setArray(res);\n    }\n\n    // Rendering functions\n    function clearChildren(el){ while(el.firstChild) el.removeChild(el.firstChild); }\n\n    function renderAll(highlight = {}) {\n      // highlight: {phase:'counting'|'prefix'|'placing'|'copy', i, j, idx, pos}\n      renderInput(highlight);\n      renderCounts(highlight);\n      renderOutput(highlight);\n      offsetDisplay.textContent = offset;\n      rangeSizeEl.textContent = counts.length || 0;\n      stepDisplay.textContent = stepCount;\n    }\n\n    function barElement(value, options = {}) {\n      const b = document.createElement('div');\n      b.className = 'bar';\n      if(options.type) b.classList.add(options.type); // count | output\n      if(options.muted) b.classList.add('muted');\n      if(options.highlight) b.classList.add('highlight');\n      b.style.height = (options.h || 60) + 'px';\n      b.title = String(value);\n      const label = document.createElement('div');\n      label.style.padding = '6px 4px';\n      label.textContent = String(value);\n      b.appendChild(label);\n      if(typeof options.index !== 'undefined'){\n        const idx = document.createElement('div');\n        idx.className = 'bar index';\n        idx.textContent = options.index;\n        b.appendChild(idx);\n      }\n      return b;\n    }\n\n    function computeHeightForValue(v, minV, maxV, maxPx=120){\n      // Map value in [minV,maxV] to height px\n      if(minV === maxV) return maxPx;\n      const t = (v - minV) / (maxV - minV);\n      return Math.max(24, Math.round(24 + t * (maxPx - 24)));\n    }\n\n    function renderInput(highlight){\n      clearChildren(inputVisual);\n      if(!A || A.length === 0) return;\n      const minV = Math.min(...A);\n      const maxV = Math.max(...A);\n      for(let i=0;i<A.length;i++){\n        const v = A[i];\n        const h = computeHeightForValue(v, minV, maxV, 120);\n        const isHighlight = highlight.phase === 'counting' && highlight.i === i\n                         || highlight.phase === 'placing' && highlight.i === i\n                         || highlight.phase === 'copy' && highlight.i === i;\n        const b = barElement(v, {h, highlight:isHighlight});\n        b.style.width = (100 / Math.max(6, A.length)) + '%';\n        inputVisual.appendChild(b);\n      }\n    }\n\n    function renderCounts(highlight){\n      clearChildren(countVisual);\n      if(!counts || counts.length === 0) return;\n      const maxCount = Math.max(...counts, 1);\n      for(let j=0;j<counts.length;j++){\n        const val = counts[j];\n        const h = Math.round(28 + (val / maxCount) * 90);\n        const isHighlight = highlight.phase === 'counting' && highlight.idx === j\n                         || highlight.phase === 'prefix' && (highlight.j === j || highlight.jPrev === j)\n                         || highlight.phase === 'placing' && highlight.idx === j;\n        const b = barElement(val, {type:'count', h, highlight:isHighlight, index: j});\n        countVisual.appendChild(b);\n      }\n    }\n\n    function renderOutput(highlight){\n      clearChildren(outputVisual);\n      if(!output || output.length === 0) return;\n      const valsExisting = output.filter(v=>v!==null && v!==undefined);\n      const minV = valsExisting.length ? Math.min(...valsExisting) : 0;\n      const maxV = valsExisting.length ? Math.max(...valsExisting) : Math.max(...A);\n      for(let p=0;p<output.length;p++){\n        const v = (output[p] === null || output[p] === undefined) ? '' : output[p];\n        const h = (v === '') ? 30 : computeHeightForValue(v, minV, maxV, 120);\n        const isHighlight = highlight.phase === 'placing' && highlight.pos === p\n                         || highlight.phase === 'copy' && highlight.i === p;\n        const b = barElement(v === '' ? '-' : v, {type:'output', h, highlight:isHighlight, muted: v === ''});\n        outputVisual.appendChild(b);\n      }\n    }\n\n    // Generator for counting sort steps\n    function* countingSortGenerator(array){\n      stepCount = 0;\n      // initial\n      const n = array.length;\n      if(n === 0){\n        phaseDisplay.textContent = 'Idle';\n        return;\n      }\n      const minA = Math.min(...array);\n      const maxA = Math.max(...array);\n      offset = minA;\n      const range = maxA - minA + 1;\n      if(range > 300){\n        // Too large to visualize / memory heavy\n        alert('Range is too large for visualization. Please pick a smaller range (max-min+1 <= 300).');\n        phaseDisplay.textContent = 'Idle';\n        return;\n      }\n      counts = new Array(range).fill(0);\n      output = new Array(n).fill(null);\n\n      // Phase 1: counting occurrences\n      phaseDisplay.textContent = 'Counting occurrences';\n      for(let i=0;i<n;i++){\n        // highlight element i\n        const idx = array[i] - offset;\n        counts[idx] += 1;\n        stepCount++;\n        yield {phase:'counting', i, idx, counts: counts.slice(), array: array.slice(), output: output.slice()};\n      }\n\n      // Phase 2: prefix sums\n      phaseDisplay.textContent = 'Cumulative counts (prefix sums)';\n      for(let j=1;j<counts.length;j++){\n        const prev = counts[j-1];\n        counts[j] += prev;\n        stepCount++;\n        yield {phase:'prefix', j, jPrev: j-1, counts: counts.slice(), array: array.slice(), output: output.slice()};\n      }\n\n      // Phase 3: Build output stable (right-to-left)\n      phaseDisplay.textContent = 'Building output (stable placement)';\n      for(let i=n-1;i>=0;i--){\n        const val = array[i];\n        const idx = val - offset;\n        const pos = counts[idx] - 1;\n        output[pos] = val;\n        counts[idx] -= 1;\n        stepCount++;\n        yield {phase:'placing', i, idx, pos, counts: counts.slice(), array: array.slice(), output: output.slice()};\n      }\n\n      // Phase 4: copy output back to array\n      phaseDisplay.textContent = 'Copying output -> array (final sorted array)';\n      for(let i=0;i<n;i++){\n        array[i] = output[i];\n        stepCount++;\n        yield {phase:'copy', i, counts: counts.slice(), array: array.slice(), output: output.slice()};\n      }\n\n      phaseDisplay.textContent = 'Done — Sorted';\n      yield {phase:'done', counts: counts.slice(), array: array.slice(), output: output.slice()};\n    }\n\n    // Control functions\n    function startAuto(speedMs = null){\n      if(running) return;\n      running = true;\n      btnStart.disabled = true;\n      btnPause.disabled = false;\n      btnStep.disabled = true;\n      btnFastForward.disabled = true;\n      const ms = speedMs !== null ? speedMs : Number(speedRange.value);\n      if(!gen) gen = countingSortGenerator(A.slice());\n      function step(){\n        const res = gen.next();\n        if(res.done){\n          running=false;\n          gen = null;\n          btnStart.disabled = false;\n          btnPause.disabled = true;\n          btnStep.disabled = false;\n          btnFastForward.disabled = false;\n          renderAll();\n          return;\n        } else {\n          const state = res.value;\n          // update UI according to generator yielded state\n          applyStateAndRender(state);\n        }\n      }\n      // run one immediately then schedule\n      step();\n      timer = setInterval(()=>{\n        const res = gen.next();\n        if(res.done){\n          clearInterval(timer); timer = null; running=false; gen=null;\n          btnStart.disabled = false; btnPause.disabled = true; btnStep.disabled = false; btnFastForward.disabled = false;\n          renderAll();\n          return;\n        } else {\n          applyStateAndRender(res.value);\n        }\n      }, ms);\n    }\n\n    function pauseAuto(){\n      running = false;\n      btnStart.disabled = false;\n      btnPause.disabled = true;\n      btnStep.disabled = false;\n      btnFastForward.disabled = false;\n      if(timer){ clearInterval(timer); timer = null; }\n    }\n\n    function stepOnce(){\n      if(!gen) gen = countingSortGenerator(A.slice());\n      const res = gen.next();\n      if(res.done){\n        gen = null;\n        running = false;\n        btnStart.disabled = false;\n        btnPause.disabled = true;\n        btnStep.disabled = false;\n        btnFastForward.disabled = false;\n        renderAll();\n        return;\n      }\n      applyStateAndRender(res.value);\n    }\n\n    function applyStateAndRender(state){\n      // update internal arrays to reflect counts/output/array for rendering\n      if('array' in state) A = state.array.slice();\n      if('counts' in state) counts = state.counts.slice();\n      if('output' in state) output = state.output.slice();\n      // Highlight object assembled for renderAll\n      const highlight = { phase: state.phase };\n      if(state.phase === 'counting'){ highlight.i = state.i; highlight.idx = state.idx; }\n      if(state.phase === 'prefix'){ highlight.j = state.j; highlight.jPrev = state.jPrev; }\n      if(state.phase === 'placing'){ highlight.i = state.i; highlight.idx = state.idx; highlight.pos = state.pos; }\n      if(state.phase === 'copy'){ highlight.i = state.i; highlight.pos = state.i; }\n      renderAll(highlight);\n    }\n\n    function resetToOriginal(){\n      pauseAuto();\n      if(originalA && originalA.length) A = originalA.slice();\n      counts = [];\n      output = [];\n      offset = 0;\n      stepCount = 0;\n      gen = null;\n      renderAll();\n      phaseDisplay.textContent = 'Idle';\n    }\n\n    // Event listeners\n    btnRandom.addEventListener('click', ()=> generateRandom());\n    btnFromInput.addEventListener('click', ()=>{\n      const arr = parseArrayFromInput();\n      if(arr.length === 0){\n        alert('Please enter a valid comma-separated list of integers.');\n        return;\n      }\n      setArray(arr);\n    });\n    btnReset.addEventListener('click', ()=> resetToOriginal());\n    btnStart.addEventListener('click', ()=>{\n      startAuto();\n    });\n    btnPause.addEventListener('click', ()=> pauseAuto());\n    btnStep.addEventListener('click', ()=> stepOnce());\n    btnFastForward.addEventListener('click', ()=> {\n      // run faster until done\n      startAuto(40);\n    });\n\n    sizeRange.addEventListener('input', (e)=>{\n      const s = Number(e.target.value);\n      sizeRange.title = s;\n    });\n    minRange.addEventListener('input', (e)=>{\n      const minv = Number(e.target.value);\n      if(Number(maxRange.value) < minv) maxRange.value = minv;\n    });\n    maxRange.addEventListener('input', (e)=>{\n      const maxv = Number(e.target.value);\n      if(Number(minRange.value) > maxv) minRange.value = maxv;\n    });\n\n    // Initialization\n    (function init(){\n      // default array from input\n      const arr = parseArrayFromInput();\n      if(arr.length) setArray(arr);\n      else generateRandom();\n      btnPause.disabled = true;\n    })();\n  </script>\n</body>\n</html>"
  },
