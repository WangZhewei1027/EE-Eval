<td>Button</td>\n            <td><button type=\"button\">Print Distance</button></td>\n        </tr>\n    </table>\n    \n    <script>\n        function printDistance() {\n            var distances = [];\n            var node = document.getElementById(\"input_node\");\n            for (var i = 0; i < distances.length; i++) {\n                if (!distances[i]) {\n                    distances[i] = [node距离];\n                }\n            }\n            \n            var minDistance = Infinity;\n            \n            for (var i = 0; i < distances.length; i++) {\n                var minDistance = Math.min(distances[i]);\n                \n                if (minDistance < distances[i][0]) {\n                    minDistance = distances[i][0];\n                }\n            }\n            \n            document.getElementById(\"output_node\").innerHTML = \"The minimum distance from Node A to Node B is \" + minDistance;\n        }\n    </script>\n</body>\n</html>"
