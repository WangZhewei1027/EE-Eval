  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Topological Sort Visualizer (Kahn & DFS)</title>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <style>\n    :root {\n      --bg: #0f1724;\n      --panel: #0b1220;\n      --accent: #60a5fa;\n      --muted: #94a3b8;\n      --good: #22c55e;\n      --bad: #ef4444;\n      --node: #1e293b;\n      --node-outline: #334155;\n      --text: #e6eef8;\n      --glass: rgba(255,255,255,0.03);\n    }\n    html,body { height:100%; margin:0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; background: linear-gradient(180deg,#071020 0%, #06121a 100%); color:var(--text); }\n    .container { display:flex; height:100vh; gap:12px; padding:12px; box-sizing:border-box; }\n    .left { flex:1; display:flex; flex-direction:column; gap:12px; }\n    .canvas-wrap { flex:1; background:var(--panel); border-radius:10px; padding:10px; box-shadow: 0 6px 20px rgba(2,6,23,0.6); position:relative; overflow:hidden; }\n    svg { width:100%; height:100%; touch-action: none; }\n    .controls { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:6px; align-items:center; }\n    button, select, input[type=range] { background:var(--glass); border:1px solid rgba(255,255,255,0.04); color:var(--text); padding:8px 10px; border-radius:8px; cursor:pointer; }\n    button.primary { background:linear-gradient(90deg,var(--accent),#3b82f6); color:#031025; font-weight:600; border:none; }\n    button.danger { background:linear-gradient(90deg,var(--bad),#ef4444); color:white; border:none; }\n    .panel { width:380px; background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border-radius:12px; padding:14px; box-sizing:border-box; border:1px solid rgba(255,255,255,0.03); display:flex; flex-direction:column; gap:12px; }\n    h2 { margin:0 0 6px 0; font-size:16px; color:var(--accent); }\n    .small { font-size:13px; color:var(--muted); margin-top: -6px; }\n    .info { font-size:13px; color:var(--muted); }\n    .log { background:#02102544; padding:8px; border-radius:8px; height:160px; overflow:auto; font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, monospace; font-size:13px; border:1px solid rgba(255,255,255,0.02); }\n    .adj { font-family:ui-monospace, Menlo, monospace; font-size:13px; color:var(--muted); background:linear-gradient(180deg,#071423, #05121a); padding:8px; border-radius:8px; border:1px solid rgba(255,255,255,0.02); max-height:160px; overflow:auto; }\n    .row { display:flex; gap:8px; align-items:center; }\n    .hint { font-size:12px; color:var(--muted); }\n    .status { padding:8px; border-radius:8px; font-weight:600; font-size:14px; }\n    .status.ok { background:linear-gradient(90deg,#052515,#07331b); color:var(--good); }\n    .status.cycle { background:linear-gradient(90deg,#2a0515,#3b071f); color:var(--bad); }\n    input[type=number] { width:80px; padding:6px 8px; border-radius:8px; border:1px solid rgba(255,255,255,0.03); background:var(--glass); color:var(--text); }\n    .btn-row { display:flex; gap:6px; flex-wrap:wrap; }\n    .small-btn { padding:6px 8px; font-size:13px; border-radius:8px; }\n    .legend { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }\n    .legend-item { display:flex; gap:6px; align-items:center; font-size:13px; color:var(--muted); }\n    .dot { width:12px; height:12px; border-radius:50%; display:inline-block; }\n    .node-label { pointer-events:none; font-size:12px; fill:var(--text); font-weight:600; text-anchor:middle; alignment-baseline:middle; }\n    .edge { stroke:rgba(255,255,255,0.06); stroke-width:2; marker-end:url(#arrow); }\n    .edge.active { stroke: #60a5fa; stroke-width:3; opacity:1; }\n    .edge.warn { stroke: var(--bad); stroke-width:3; opacity:1; }\n    .node { cursor:pointer; }\n    .node circle { fill:var(--node); stroke:var(--node-outline); stroke-width:2; }\n    .node.selected circle { stroke: #f59e0b; stroke-width:3; }\n    .node.running circle { fill: #063b56; stroke: #60a5fa; stroke-width:3; }\n    .node.removed circle { fill: #2b1220; stroke: #ef4444; }\n    .node.done circle { fill: #05261a; stroke: #22c55e; stroke-width:3; }\n    footer { position:absolute; left:12px; bottom:10px; font-size:12px; color:var(--muted); }\n    @media (max-width:980px) {\n      .container { flex-direction:column; padding:8px; }\n      .panel { width:100%; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"left\">\n      <div class=\"controls\">\n        <button id=\"mode-add-node\" class=\"small-btn primary\">Add Node (click canvas)</button>\n        <button id=\"mode-add-edge\" class=\"small-btn\">Add Edge (click src → dst)</button>\n        <button id=\"mode-delete\" class=\"small-btn\">Delete Mode</button>\n        <button id=\"clear\" class=\"small-btn\">Clear</button>\n        <button id=\"random\" class=\"small-btn\">Random DAG</button>\n        <select id=\"algo-select\">\n          <option value=\"kahn\">Kahn's Algorithm</option>\n          <option value=\"dfs\">DFS (finish-time)</option>\n        </select>\n        <label class=\"hint\">Speed</label>\n        <input id=\"speed\" type=\"range\" min=\"200\" max=\"2000\" step=\"100\" value=\"700\" />\n      </div>\n\n      <div class=\"canvas-wrap\">\n        <div class=\"controls\" style=\"position:absolute; top:10px; left:12px; z-index:10;\">\n          <button id=\"run-step\" class=\"small-btn primary\">Step</button>\n          <button id=\"run-auto\" class=\"small-btn\">Auto</button>\n          <button id=\"reset-highlights\" class=\"small-btn\">Reset</button>\n        </div>\n\n        <svg id=\"svg\" xmlns=\"http://www.w3.org/2000/svg\">\n          <defs>\n            <marker id=\"arrow\" markerWidth=\"10\" markerHeight=\"8\" refX=\"18\" refY=\"4\" orient=\"auto\" markerUnits=\"strokeWidth\">\n              <path d=\"M0,0 L10,4 L0,8 z\" fill=\"#cbd5e1\" />\n            </marker>\n            <marker id=\"arrow-blue\" markerWidth=\"10\" markerHeight=\"8\" refX=\"18\" refY=\"4\" orient=\"auto\" markerUnits=\"strokeWidth\">\n              <path d=\"M0,0 L10,4 L0,8 z\" fill=\"#60a5fa\" />\n            </marker>\n            <marker id=\"arrow-red\" markerWidth=\"10\" markerHeight=\"8\" refX=\"18\" refY=\"4\" orient=\"auto\" markerUnits=\"strokeWidth\">\n              <path d=\"M0,0 L10,4 L0,8 z\" fill=\"#ef4444\" />\n            </marker>\n          </defs>\n        </svg>\n\n        <footer>\n          Click canvas to create nodes. Drag nodes to move. Use \"Add Edge\" then click source then destination.\n        </footer>\n      </div>\n\n      <div style=\"display:flex; gap:10px;\">\n        <div style=\"flex:1;\">\n          <div class=\"panel\">\n            <h2>Algorithm Steps</h2>\n            <div class=\"row\" style=\"gap:10px;\">\n              <div>Selected: <span id=\"selected-info\" class=\"hint\">none</span></div>\n              <div style=\"margin-left:auto;\">Algorithm: <span id=\"algo-name\" class=\"hint\">Kahn</span></div>\n            </div>\n            <div class=\"log\" id=\"log\"></div>\n            <div class=\"row\">\n              <div class=\"btn-row\">\n                <button id=\"show-adj\" class=\"small-btn\">Show Adjacency</button>\n                <button id=\"show-indeg\" class=\"small-btn\">Show Indegrees</button>\n              </div>\n              <div style=\"margin-left:auto;\">\n                <button id=\"export\" class=\"small-btn\">Export JSON</button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div style=\"width:380px;\">\n          <div class=\"panel\">\n            <h2>State & Controls</h2>\n            <div class=\"row\">\n              <div style=\"flex:1;\">\n                <div class=\"status ok\" id=\"status\">Graph OK (no cycles detected)</div>\n              </div>\n            </div>\n\n            <div style=\"display:flex; gap:8px; align-items:center;\">\n              <div class=\"legend\">\n                <div class=\"legend-item\"><span class=\"dot\" style=\"background:#60a5fa\"></span> Running</div>\n                <div class=\"legend-item\"><span class=\"dot\" style=\"background:#22c55e\"></span> Done</div>\n                <div class=\"legend-item\"><span class=\"dot\" style=\"background:#ef4444\"></span> Problem / Cycle</div>\n              </div>\n            </div>\n\n            <div style=\"display:flex; gap:8px; align-items:center;\">\n              <label>Nodes:</label>\n              <div id=\"node-count\" class=\"hint\">0</div>\n              <label style=\"margin-left:10px;\">Edges:</label>\n              <div id=\"edge-count\" class=\"hint\">0</div>\n            </div>\n\n            <div style=\"display:flex; gap:8px; align-items:center; margin-top:8px;\">\n              <label>Auto run:</label>\n              <button id=\"stop-auto\" class=\"small-btn\">Stop</button>\n              <button id=\"fast-forward\" class=\"small-btn\">Finish</button>\n            </div>\n\n            <div style=\"margin-top:6px;\">\n              <div class=\"hint\">Tips: Generate a random DAG for quick demos. The visualizer runs Kahn's algorithm or DFS with animations and step-by-step logging.</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"panel\" style=\"min-width:360px; max-width:420px;\">\n      <h2>Adjacency & Indegrees</h2>\n      <div class=\"adj\" id=\"adj-view\">Graph is empty.</div>\n\n      <h2 style=\"margin-top:8px\">Topological Order</h2>\n      <div class=\"adj\" id=\"order-view\">No order yet.</div>\n\n      <h2 style=\"margin-top:8px\">Controls Help</h2>\n      <div class=\"info\">\n        - Add Node: click the canvas area.<br/>\n        - Add Edge: click \"Add Edge\", then click source node, then destination node.<br/>\n        - Delete Mode: click node or edge to remove.<br/>\n        - Kahn: repeatedly remove nodes with indegree 0 (BFS-like).<br/>\n        - DFS: perform depth-first search, recording finish times then reverse.<br/>\n        - Cycle detection: if no node has indegree 0 at some point (Kahn) or back-edge found (DFS), a cycle exists.\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Topological Sort Visualizer\n    (function(){\n      const svg = document.getElementById('svg');\n      const NS = \"http://www.w3.org/2000/svg\";\n      let nodes = []; // {id, x, y, elGroup}\n      let edges = []; // {id, from, to, elLine}\n      let nodeIdCounter = 0;\n      let edgeIdCounter = 0;\n\n      // Modes: 'add-node', 'add-edge', 'delete', 'idle'\n      let mode = 'add-node';\n      let pendingEdgeFrom = null;\n      let selectedNode = null;\n      let dragging = null;\n      let dragOffset = {x:0,y:0};\n      let autoTimer = null;\n      let algo = 'kahn';\n      let runningState = { running: false, stepMode: false, algo: null, queue: [], indeg: {}, order: [], visited: {}, stack: [], dfsStack: [], dfsState: {} };\n      const logEl = document.getElementById('log');\n      const adjView = document.getElementById('adj-view');\n      const orderView = document.getElementById('order-view');\n      const statusEl = document.getElementById('status');\n      const nodeCountEl = document.getElementById('node-count');\n      const edgeCountEl = document.getElementById('edge-count');\n      const selectedInfoEl = document.getElementById('selected-info');\n      const algoNameEl = document.getElementById('algo-name');\n\n      function log(...args){\n        const s = args.map(a => (typeof a === 'object'? JSON.stringify(a): String(a))).join(' ');\n        const div = document.createElement('div');\n        div.textContent = s;\n        logEl.appendChild(div);\n        logEl.scrollTop = logEl.scrollHeight;\n      }\n\n      function clearLog(){ logEl.innerHTML = ''; }\n\n      function updateCounts(){\n        nodeCountEl.textContent = nodes.length;\n        edgeCountEl.textContent = edges.length;\n      }\n\n      function createNode(x,y,label){\n        const id = 'n'+(++nodeIdCounter);\n        const g = document.createElementNS(NS,'g');\n        g.classList.add('node');\n        g.dataset.id = id;\n        const circle = document.createElementNS(NS,'circle');\n        circle.setAttribute('r',24);\n        circle.setAttribute('cx',x);\n        circle.setAttribute('cy',y);\n        const text = document.createElementNS(NS,'text');\n        text.setAttribute('x',x);\n        text.setAttribute('y',y+1);\n        text.setAttribute('class','node-label');\n        text.textContent = label || id;\n        g.appendChild(circle);\n        g.appendChild(text);\n        svg.appendChild(g);\n\n        nodes.push({id, x, y, el:g, label: text.textContent});\n        attachNodeEvents(g);\n        updateCounts();\n        renderAdj();\n        return id;\n      }\n\n      function attachNodeEvents(g){\n        g.addEventListener('pointerdown', (e)=>{\n          e.stopPropagation();\n          const id = g.dataset.id;\n          if(mode === 'add-node'){\n            // select for possible drag\n            dragging = id;\n            const node = findNode(id);\n            dragOffset.x = e.clientX - node.x;\n            dragOffset.y = e.clientY - node.y;\n            g.setPointerCapture(e.pointerId);\n          } else if(mode === 'add-edge'){\n            if(!pendingEdgeFrom){\n              pendingEdgeFrom = id;\n              highlightNode(id, 'selected');\n              selectedInfoEl.textContent = 'edge from ' + id;\n            } else {\n              if(pendingEdgeFrom === id){\n                // no self-loops allowed for clarity\n                log('Self-loops are not allowed in this demo.');\n                clearPendingEdge();\n                return;\n              }\n              addEdge(pendingEdgeFrom, id);\n              clearPendingEdge();\n            }\n          } else if(mode === 'delete'){\n            removeNode(id);\n            renderAdj();\n          } else {\n            // default: select node\n            selectNode(id);\n          }\n        });\n\n        g.addEventListener('pointerup', (e)=>{\n          if(dragging){\n            dragging = null;\n          }\n        });\n\n        g.addEventListener('pointermove', (e)=>{\n          if(dragging === g.dataset.id){\n            const node = findNode(g.dataset.id);\n            node.x = e.clientX - dragOffset.x;\n            node.y = e.clientY - dragOffset.y;\n            updateNodePosition(node);\n            updateEdges();\n          }\n        });\n\n        g.addEventListener('click', (e)=>{\n          e.stopPropagation();\n          if(mode === 'idle'){\n            selectNode(g.dataset.id);\n          }\n        });\n      }\n\n      function clearPendingEdge(){\n        if(pendingEdgeFrom){\n          const n = findNode(pendingEdgeFrom);\n          if(n) n.el.classList.remove('selected');\n        }\n        pendingEdgeFrom = null;\n        selectedInfoEl.textContent = 'none';\n      }\n\n      function highlightNode(id, cls){\n        const n = findNode(id);\n        if(n) n.el.classList.add(cls);\n      }\n      function unhighlightNode(id, cls){\n        const n = findNode(id);\n        if(n) n.el.classList.remove(cls);\n      }\n\n      function selectNode(id){\n        if(selectedNode){\n          const prev = findNode(selectedNode);\n          if(prev) prev.el.classList.remove('selected');\n        }\n        selectedNode = id;\n        const n = findNode(id);\n        if(n) n.el.classList.add('selected');\n        selectedInfoEl.textContent = id;\n      }\n\n      function findNode(id){ return nodes.find(n=>n.id===id); }\n      function findEdge(id){ return edges.find(e=>e.id===id); }\n\n      function addEdge(from, to){\n        // disallow duplicate edges\n        if(edges.some(e=>e.from===from && e.to===to)){\n          log('Edge already exists: ' + from + ' → ' + to);\n          return;\n        }\n        const id = 'e'+(++edgeIdCounter);\n        const line = document.createElementNS(NS,'g');\n        line.dataset.id = id;\n        line.classList.add('edge-wrap');\n\n        const path = document.createElementNS(NS,'path');\n        path.classList.add('edge');\n        path.dataset.id = id;\n        path.setAttribute('fill','none');\n        path.setAttribute('marker-end','url(#arrow)');\n\n        line.appendChild(path);\n        svg.insertBefore(line, svg.firstChild); // edges below nodes\n        edges.push({id, from, to, el: line, pathEl: path});\n        updateEdges();\n\n        // attach delete on click if in delete mode\n        line.addEventListener('click', (e)=>{\n          e.stopPropagation();\n          if(mode === 'delete'){\n            removeEdge(id);\n            renderAdj();\n          } else {\n            // highlight path\n            edges.forEach(ed=>ed.el.classList.remove('selected'));\n            line.classList.add('selected');\n            selectedInfoEl.textContent = id;\n          }\n        });\n\n        updateCounts();\n        renderAdj();\n      }\n\n      function removeEdge(id){\n        const idx = edges.findIndex(e=>e.id===id);\n        if(idx>=0){\n          const ed = edges[idx];\n          if(ed.el && ed.el.parentNode) ed.el.parentNode.removeChild(ed.el);\n          edges.splice(idx,1);\n        }\n        updateCounts();\n      }\n\n      function removeNode(id){\n        // remove node UI\n        const idx = nodes.findIndex(n=>n.id===id);\n        if(idx>=0){\n          const n = nodes[idx];\n          if(n.el && n.el.parentNode) n.el.parentNode.removeChild(n.el);\n          nodes.splice(idx,1);\n        }\n        // remove incident edges\n        for(let i=edges.length-1;i>=0;i--){\n          if(edges[i].from===id || edges[i].to===id){\n            if(edges[i].el && edges[i].el.parentNode) edges[i].el.parentNode.removeChild(edges[i].el);\n            edges.splice(i,1);\n          }\n        }\n        if(selectedNode === id) selectedNode = null;\n        updateCounts();\n      }\n\n      function clearAll(){\n        nodes.forEach(n=>{ if(n.el && n.el.parentNode) n.el.parentNode.removeChild(n.el); });\n        edges.forEach(e=>{ if(e.el && e.el.parentNode) e.el.parentNode.removeChild(e.el); });\n        nodes = []; edges = []; nodeIdCounter = 0; edgeIdCounter = 0; pendingEdgeFrom = null; selectedNode = null;\n        clearPendingEdge();\n        updateCounts();\n        renderAdj();\n        resetAlgorithm();\n        clearLog();\n        orderView.textContent = 'No order yet.';\n        statusOk();\n      }\n\n      function updateNodePosition(n){\n        if(!n) return;\n        const circle = n.el.querySelector('circle');\n        const text = n.el.querySelector('text');\n        circle.setAttribute('cx', n.x);\n        circle.setAttribute('cy', n.y);\n        text.setAttribute('x', n.x);\n        text.setAttribute('y', n.y+1);\n      }\n\n      function updateEdges(){\n        for(const e of edges){\n          const from = findNode(e.from);\n          const to = findNode(e.to);\n          if(!from || !to) continue;\n          const x1 = from.x, y1 = from.y;\n          const x2 = to.x, y2 = to.y;\n          // simple bezier for nicer layout\n          const dx = x2-x1, dy = y2-y1;\n          const mx = (x1+x2)/2 + dy*0.12;\n          const my = (y1+y2)/2 - dx*0.12;\n          const path = `M ${x1} ${y1} Q ${mx} ${my} ${x2} ${y2}`;\n          e.pathEl.setAttribute('d', path);\n        }\n      }\n\n      function renderAdj(){\n        const adj = {};\n        nodes.forEach(n=>adj[n.id]=[]);\n        edges.forEach(e=>{ if(adj[e.from]) adj[e.from].push(e.to); else adj[e.from]=[e.to]; });\n        let s = '';\n        for(const nid of Object.keys(adj)){\n          s += nid + ': [' + adj[nid].join(', ') + ']\\n';\n        }\n        adjView.textContent = s || 'Graph is empty.';\n        updateCounts();\n      }\n\n      // UI controls\n      document.getElementById('mode-add-node').addEventListener('click', ()=>{\n        mode = 'add-node';\n        setModeButtons();\n      });\n      document.getElementById('mode-add-edge').addEventListener('click', ()=>{\n        mode = 'add-edge';\n        setModeButtons();\n      });\n      document.getElementById('mode-delete').addEventListener('click', ()=>{\n        mode = 'delete';\n        setModeButtons();\n      });\n      document.getElementById('clear').addEventListener('click', ()=>{ clearAll(); });\n      document.getElementById('random').addEventListener('click', ()=>{ generateRandomDAG(); });\n      document.getElementById('run-step').addEventListener('click', ()=>{ stepAlgorithm(); });\n      document.getElementById('run-auto').addEventListener('click', ()=>{ toggleAuto(); });\n      document.getElementById('stop-auto').addEventListener('click', ()=>{ stopAuto(); });\n      document.getElementById('reset-highlights').addEventListener('click', ()=>{ resetNodeStyles(); resetEdgeStyles(); });\n      document.getElementById('show-adj').addEventListener('click', ()=>{ renderAdj(); });\n      document.getElementById('show-indeg').addEventListener('click', ()=>{ showIndegrees(); });\n      document.getElementById('algo-select').addEventListener('change', (e)=>{ algo = e.target.value; algoNameEl.textContent = (algo==='kahn'?'Kahn':'DFS'); resetAlgorithm(); });\n      document.getElementById('export').addEventListener('click', ()=>{ exportJSON(); });\n      document.getElementById('fast-forward').addEventListener('click', ()=>{ finishAlgorithm(); });\n\n      svg.addEventListener('pointerdown', (e)=>{\n        // add node at pointer if in add-node mode and not hitting existing element\n        if(mode === 'add-node'){\n          // ensure clicked on empty area (target is svg)\n          if(e.target === svg || e.target.tagName === 'defs' || e.target.tagName === 'path'){\n            const rect = svg.getBoundingClientRect();\n            const x = e.clientX - rect.left;\n            const y = e.clientY - rect.top;\n            createNode(x,y);\n          }\n        } else {\n          // clicking background clears selection/pending\n          clearPendingEdge();\n          if(selectedNode){\n            const prev = findNode(selectedNode);\n            if(prev) prev.el.classList.remove('selected');\n            selectedNode = null;\n            selectedInfoEl.textContent = 'none';\n          }\n        }\n      });\n\n      // initial mode style\n      function setModeButtons(){\n        document.getElementById('mode-add-node').classList.toggle('primary', mode==='add-node');\n        document.getElementById('mode-add-edge').classList.toggle('primary', mode==='add-edge');\n        document.getElementById('mode-delete').classList.toggle('primary', mode==='delete');\n      }\n      setModeButtons();\n\n      function statusOk(){ statusEl.className = 'status ok'; statusEl.textContent = 'Graph OK (no cycles detected)'; }\n      function statusCycle(){ statusEl.className = 'status cycle'; statusEl.textContent = 'Cycle detected! Topological order impossible'; }\n\n      // Utilities to compute adjacency maps & indegrees\n      function buildAdjIndeg(){\n        const adj = {};\n        const indeg = {};\n        nodes.forEach(n=>{ adj[n.id]=[]; indeg[n.id]=0; });\n        edges.forEach(e=>{\n          if(adj[e.from]) adj[e.from].push(e.to);\n          if(indeg[e.to] !== undefined) indeg[e.to]++;\n        });\n        return {adj, indeg};\n      }\n\n      // Kahn's algorithm step implementation\n      function initKahn(){\n        const {adj, indeg} = buildAdjIndeg();\n        runningState.algo = 'kahn';\n        runningState.queue = Object.keys(indeg).filter(k=>indeg[k]===0);\n        runningState.indeg = indeg;\n        runningState.adj = adj;\n        runningState.order = [];\n        runningState.running = true;\n        runningState.stepMode = true;\n        clearLog();\n        log(\"Kahn initialized. Zero-indegree queue:\", runningState.queue.join(', ') || '(none)');\n        updateOrderView();\n        resetNodeStyles();\n        resetEdgeStyles();\n        statusOk();\n      }\n\n      function stepKahn(){\n        if(!runningState.running || runningState.algo!=='kahn') initKahn();\n        const q = runningState.queue;\n        const indeg = runningState.indeg;\n        const adj = runningState.adj;\n        if(q.length === 0){\n          // if all nodes processed -> done else cycle\n          if(runningState.order.length === nodes.length){\n            log('Kahn complete. Order: ' + runningState.order.join(', '));\n            markDoneOrder(runningState.order);\n            runningState.running = false;\n            updateOrderView();\n            return;\n          } else {\n            log('Cycle detected: queue empty but nodes remain.');\n            statusCycle();\n            // highlight all remaining nodes as problem\n            for(const nid in indeg){\n              if(!runningState.order.includes(nid)){\n                const n = findNode(nid);\n                if(n) n.el.classList.add('removed');\n              }\n            }\n            runningState.running = false;\n            return;\n          }\n        }\n        const u = q.shift();\n        log('Pop:', u);\n        const node = findNode(u);\n        if(node){\n          node.el.classList.add('running');\n        }\n        runningState.order.push(u);\n        // decrement neighbors\n        const neigh = adj[u] || [];\n        for(const v of neigh){\n          const prev = indeg[v];\n          indeg[v] = Math.max(0, prev-1);\n          log('Decrement indeg of', v, 'from', prev, 'to', indeg[v]);\n          // highlight edge\n          const ed = edges.find(e=>e.from===u && e.to===v);\n          if(ed) { ed.pathEl.classList.add('active'); setTimeout(()=>ed.pathEl.classList.remove('active'), 600); }\n          if(indeg[v] === 0){\n            q.push(v);\n            log('Push to queue:', v);\n          }\n        }\n        // mark u as done\n        if(node){\n          node.el.classList.remove('running');\n          node.el.classList.add('done');\n        }\n        updateOrderView();\n        renderAdj();\n      }\n\n      // DFS-based topological sort step-by-step (we simulate recursion with stack)\n      function initDFS(){\n        const {adj} = buildAdjIndeg();\n        runningState.algo = 'dfs';\n        runningState.adj = adj;\n        runningState.visited = {};\n        runningState.order = [];\n        runningState.dfsStack = []; // stack frames: {node, iterIndex, neighbors}\n        runningState.running = true;\n        runningState.stepMode = true;\n        clearLog();\n        log('DFS initialized.');\n        resetNodeStyles();\n        resetEdgeStyles();\n        statusOk();\n      }\n\n      function stepDFS(){\n        if(!runningState.running || runningState.algo!=='dfs') initDFS();\n        // find next unvisited node if stack empty\n        if(runningState.dfsStack.length === 0){\n          const unvisited = Object.keys(runningState.adj).find(n=>!runningState.visited[n]);\n          if(!unvisited){\n            log('DFS complete. Order:', runningState.order.slice().reverse().join(', '));\n            markDoneOrder(runningState.order.slice().reverse());\n            runningState.running = false;\n            updateOrderView();\n            return;\n          } else {\n            // push initial frame\n            runningState.dfsStack.push({node: unvisited, idx:0, neighbors: runningState.adj[unvisited] || []});\n            log('Start DFS at', unvisited);\n            runningState.visited[unvisited] = 'visiting';\n            const n = findNode(unvisited); if(n) n.el.classList.add('running');\n            return;\n          }\n        }\n\n        // inspect top frame\n        const frame = runningState.dfsStack[runningState.dfsStack.length-1];\n        const u = frame.node;\n        const neigh = frame.neighbors;\n        if(frame.idx < neigh.length){\n          const v = neigh[frame.idx++];\n          log('Explore edge', u, '→', v);\n          const ed = edges.find(e=>e.from===u && e.to===v);\n          if(ed) ed.pathEl.classList.add('active');\n          setTimeout(()=>{ if(ed) ed.pathEl.classList.remove('active'); }, 400);\n          if(runningState.visited[v] === undefined){\n            // tree edge\n            runningState.visited[v] = 'visiting';\n            runningState.dfsStack.push({node:v, idx:0, neighbors: runningState.adj[v] || []});\n            const n = findNode(v); if(n) n.el.classList.add('running');\n            log('Go deeper to', v);\n            return;\n          } else if(runningState.visited[v] === 'visiting'){\n            // back edge => cycle\n            log('Back edge found:', u, '→', v, ' => cycle detected');\n            statusCycle();\n            // highlight cycle edge\n            if(ed) ed.pathEl.classList.add('warn');\n            runningState.running = false;\n            return;\n          } else {\n            // visited finished; ignore\n            log('Edge to finished node', v, '- ignore');\n            return;\n          }\n        } else {\n          // finish node u\n          runningState.dfsStack.pop();\n          runningState.visited[u] = 'done';\n          runningState.order.push(u);\n          log('Finished', u, 'push to order stack');\n          const n = findNode(u); if(n) { n.el.classList.remove('running'); n.el.classList.add('done'); }\n          updateOrderView();\n          return;\n        }\n      }\n\n      // Step wrapper\n      function stepAlgorithm(){\n        if(algo === 'kahn') {\n          if(!runningState.running || runningState.algo !== 'kahn') initKahn();\n          stepKahn();\n        } else {\n          if(!runningState.running || runningState.algo !== 'dfs') initDFS();\n          stepDFS();\n        }\n      }\n\n      // Auto-run\n      function toggleAuto(){\n        if(autoTimer){ stopAuto(); return; }\n        const speed = +document.getElementById('speed').value;\n        autoTimer = setInterval(()=>{ stepAlgorithm(); autoTickCleanup(); }, speed);\n        document.getElementById('run-auto').textContent = 'Running...';\n      }\n      function stopAuto(){\n        if(autoTimer){ clearInterval(autoTimer); autoTimer = null; document.getElementById('run-auto').textContent = 'Auto'; }\n      }\n      function autoTickCleanup(){\n        if(!runningState.running){ stopAuto(); document.getElementById('run-auto').textContent = 'Auto'; }\n      }\n\n      function resetNodeStyles(){\n        nodes.forEach(n=>{\n          n.el.classList.remove('running','done','selected','removed');\n        });\n      }\n      function resetEdgeStyles(){\n        edges.forEach(e=>{\n          e.pathEl.classList.remove('active','warn');\n        });\n      }\n      function resetAlgorithm(){\n        runningState = { running: false, stepMode: false, algo: null, queue: [], indeg: {}, order: [], visited: {}, dfsStack: [], adj: {} };\n        clearLog();\n      }\n\n      function updateOrderView(){\n        orderView.textContent = runningState.order.join(' → ') || 'No order yet.';\n      }\n\n      function markDoneOrder(ord){\n        // ord is final order from Kahn (or reversed DFS)\n        for(const id of ord){\n          const n = findNode(id);\n          if(n){ n.el.classList.add('done'); n.el.classList.remove('running'); }\n        }\n        orderView.textContent = ord.join(' → ');\n      }\n\n      function showIndegrees(){\n        const {indeg} = buildAdjIndeg();\n        let s = 'Indegrees:\\n';\n        for(const k of Object.keys(indeg)) s += k + ': ' + indeg[k] + '\\n';\n        alert(s);\n      }\n\n      function exportJSON(){\n        const g = { nodes: nodes.map(n=>({id:n.id,x:n.x,y:n.y,label:n.label})), edges: edges.map(e=>({id:e.id,from:e.from,to:e.to})) };\n        const data = JSON.stringify(g, null, 2);\n        const w = window.open('', '_blank');\n        w.document.write('<pre>'+data.replace(/</g,'&lt;')+'</pre>');\n      }\n\n      function finishAlgorithm(){\n        // run until completion or cycle found (safeguard iterations)\n        let iter = 0;\n        const maxIter = 10000;\n        while(runningState.running || iter===0){\n          stepAlgorithm();\n          iter++;\n          if(iter>maxIter){ log('Reached iteration limit. Aborting.'); break; }\n          if(!runningState.running) break;\n        }\n      }\n\n      // Random DAG generator\n      function generateRandomDAG(){\n        clearAll();\n        const N = Math.floor(Math.random()*6) + 5; // 5-10 nodes\n        const rect = svg.getBoundingClientRect();\n        const padding = 60;\n        // pick a random topological order\n        const order = [];\n        for(let i=0;i<N;i++) order.push('n'+(i+1));\n        // create nodes\n        for(let i=0;i<N;i++){\n          const x = padding + Math.random()*(rect.width - 2*padding);\n          const y = padding + Math.random()*(rect.height - 2*padding);\n          createNode(x,y,'n'+(i+1));\n        }\n        // connect edges respecting the order (acyclic)\n        const p = 0.28; // probability of edge\n        for(let i=0;i<N;i++){\n          for(let j=i+1;j<N;j++){\n            if(Math.random() < p){\n              const from = nodes[i].id;\n              const to = nodes[j].id;\n              addEdge(from,to);\n            }\n          }\n        }\n        // reposition some for aesthetics\n        updateEdges();\n        renderAdj();\n        log('Random DAG generated with', nodes.length, 'nodes and', edges.length, 'edges.');\n        statusOk();\n      }\n\n      // initial example\n      (function seedExample(){\n        // small preset demo\n        const rect = svg.getBoundingClientRect();\n        const w = Math.max(600, rect.width);\n        const h = Math.max(300, rect.height);\n        createNode(120,90,'A');\n        createNode(280,60,'B');\n        createNode(280,150,'C');\n        createNode(440,90,'D');\n        addEdge(nodes[0].id, nodes[1].id); // A→B\n        addEdge(nodes[0].id, nodes[2].id); // A→C\n        addEdge(nodes[1].id, nodes[3].id); // B→D\n        addEdge(nodes[2].id, nodes[3].id); // C→D\n        updateEdges();\n        renderAdj();\n      })();\n\n      // handle window resize to update edges positions\n      window.addEventListener('resize', ()=>{ updateEdges(); });\n\n      // expose small helpers for debugging in console\n      window._topo = { nodes, edges, createNode, addEdge, clearAll, stepAlgorithm, initKahn, initDFS };\n\n    })();\n  </script>\n</body>\n</html>"
