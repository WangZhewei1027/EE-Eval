    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Depth-First Search (DFS) Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        #graph {\n            margin: 20px;\n        }\n        .node {\n            display: inline-block;\n            border: 1px solid #000;\n            padding: 10px;\n            border-radius: 5px;\n            margin: 10px;\n            position: relative;\n        }\n        .edge {\n            height: 20px;\n            position: absolute;\n            background-color: #000;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Depth-First Search (DFS) Visualization</h1>\n<div id=\"graph\"></div>\n<button onclick=\"startDFS()\">Start DFS</button>\n\n<script>\n    // Representation of the graph using an adjacency list\n    const graph = {\n        A: ['B', 'C'],\n        B: ['D', 'E'],\n        C: ['F'],\n        D: [],\n        E: ['F'],\n        F: []\n    };\n\n    let visited = new Set();\n\n    function createGraphVisual() {\n        const graphContainer = document.getElementById('graph');\n        graphContainer.innerHTML = ''; // Clear previous graph\n\n        // Create nodes\n        Object.keys(graph).forEach(node => {\n            const nodeDiv = document.createElement('div');\n            nodeDiv.className = 'node';\n            nodeDiv.innerText = node;\n            nodeDiv.id = node;\n            graphContainer.appendChild(nodeDiv);\n        });\n\n        // Create edges\n        for (let node in graph) {\n            graph[node].forEach(neighbour => {\n                const edge = document.createElement('div');\n                edge.className = 'edge';\n                const nodeDiv = document.getElementById(node);\n                const neighbourDiv = document.getElementById(neighbour);\n                edge.style.width = Math.abs(nodeDiv.offsetLeft - neighbourDiv.offsetLeft) + 'px';\n                edge.style.top = nodeDiv.offsetTop + nodeDiv.offsetHeight / 2 + 'px';\n                edge.style.left = Math.min(nodeDiv.offsetLeft, neighbourDiv.offsetLeft) + nodeDiv.offsetWidth + 'px';\n                graphContainer.appendChild(edge);\n            });\n        }\n    }\n\n    function dfs(node) {\n        if (!node || visited.has(node)) return;\n        console.log(node);  // Visit the node\n        visited.add(node);\n\n        const nodeElement = document.getElementById(node);\n        nodeElement.style.backgroundColor = 'lightgreen'; // Highlight the node\n\n        // Recursive DFS for adjacent nodes\n        for (const neighbor of graph[node]) {\n            dfs(neighbor);\n        }\n    }\n\n    function startDFS() {\n        visited.clear(); // Reset visited set\n        createGraphVisual();\n        setTimeout(() => { dfs('A'); }, 1000); // Start DFS after a brief pause\n    }\n\n    // Initialize graph visual on load\n    window.onload = createGraphVisual;\n</script>\n\n</body>\n</html>"
