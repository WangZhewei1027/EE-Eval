    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree</title>\n    <style>\n        #bst {\n            display: flex;\n            justify-content: center;\n            margin-top: 20px;\n            position: relative;\n        }\n        .node {\n            border: 1px solid #000;\n            border-radius: 5px;\n            padding: 10px;\n            text-align: center;\n            position: absolute;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Binary Search Tree Visualization</h1>\n<input type=\"number\" id=\"value\" placeholder=\"Enter a number\">\n<button id=\"insertBtn\">Insert</button>\n<button id=\"clearBtn\">Clear</button>\n<div id=\"bst\"></div>\n\n<script>\n    class TreeNode {\n        constructor(value) {\n            this.value = value;\n            this.left = null;\n            this.right = null;\n        }\n    }\n\n    class BinarySearchTree {\n        constructor() {\n            this.root = null;\n        }\n\n        insert(value) {\n            const newNode = new TreeNode(value);\n            if (!this.root) {\n                this.root = newNode;\n            } else {\n                this.insertNode(this.root, newNode);\n            }\n        }\n\n        insertNode(node, newNode) {\n            if (newNode.value < node.value) {\n                if (!node.left) {\n                    node.left = newNode;\n                } else {\n                    this.insertNode(node.left, newNode);\n                }\n            } else {\n                if (!node.right) {\n                    node.right = newNode;\n                } else {\n                    this.insertNode(node.right, newNode);\n                }\n            }\n        }\n\n        draw(node, x, y, offsetX, offsetY) {\n            if (!node) return;\n\n            const nodeElement = document.createElement('div');\n            nodeElement.className = 'node';\n            nodeElement.innerHTML = node.value;\n\n            nodeElement.style.left = `${x}px`;\n            nodeElement.style.top = `${y}px`;\n\n            document.getElementById('bst').appendChild(nodeElement);\n\n            const newY = y + offsetY;\n\n            if (node.left) {\n                const newX = x - offsetX;\n                this.draw(node.left, newX, newY, offsetX / 2, offsetY);\n            }\n            \n            if (node.right) {\n                const newX = x + offsetX;\n                this.draw(node.right, newX, newY, offsetX / 2, offsetY);\n            }\n        }\n\n        render() {\n            const bstContainer = document.getElementById('bst');\n            bstContainer.innerHTML = '';\n            this.draw(this.root, bstContainer.clientWidth / 2, 20, 200, 60);\n        }\n    }\n\n    const bst = new BinarySearchTree();\n\n    document.getElementById('insertBtn').addEventListener('click', () => {\n        const value = parseInt(document.getElementById('value').value);\n        if (!isNaN(value)) {\n            bst.insert(value);\n            bst.render();\n            document.getElementById('value').value = '';\n        }\n    });\n\n    document.getElementById('clearBtn').addEventListener('click', () => {\n        bst.root = null;\n        bst.render();\n    });\n</script>\n\n</body>\n</html>"
