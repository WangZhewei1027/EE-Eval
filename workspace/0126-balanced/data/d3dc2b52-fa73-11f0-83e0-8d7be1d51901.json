  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Symmetric Cryptography Demo (AES‑GCM)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    html,body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; background: #f7fafc; color: #1a202c; margin: 0; padding: 24px; }\n    .container { max-width: 980px; margin: 0 auto; background: #fff; padding: 20px; border-radius: 10px; box-shadow: 0 6px 24px rgba(16,24,40,0.08); }\n    h1 { margin: 0 0 6px 0; font-size: 20px; }\n    p.lead { margin: 6px 0 18px 0; color: #475569; }\n    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }\n    .full { grid-column: 1 / -1; }\n    label { display:block; font-weight: 600; margin-bottom:6px; color: #0f172a; }\n    textarea, input[type=\"text\"], input[type=\"password\"], select { width: 100%; padding:10px 12px; border-radius:8px; border:1px solid #e2e8f0; box-sizing: border-box; font-family: inherit; font-size: 14px; }\n    textarea { min-height: 100px; resize: vertical; }\n    .row { display:flex; gap:8px; align-items:center; margin-top:8px; }\n    button { padding:10px 12px; border-radius:8px; border:1px solid transparent; background:#0ea5a4; color:white; cursor:pointer; font-weight:600; }\n    button.secondary { background:#64748b; }\n    button.ghost { background: transparent; color:#0f172a; border:1px solid #e2e8f0; }\n    .small { font-size:13px; color:#475569; margin-top:6px; }\n    pre.output { background:#0f172a; color:#e6edf3; padding:12px; border-radius:8px; overflow:auto; max-height:280px; }\n    .meta { margin-top:10px; font-size:13px; color:#475569; }\n    .kbd { background:#e6eef0; padding:4px 8px; border-radius:6px; font-weight:700; display:inline-block; }\n    .explain { font-size:14px; color:#334155; line-height:1.45; }\n    footer { margin-top:18px; font-size:13px; color:#64748b; text-align:center; }\n    @media (max-width:820px) { .grid { grid-template-columns: 1fr; } }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Symmetric Cryptography — Interactive Demo</h1>\n    <p class=\"lead\">This page demonstrates symmetric encryption using the Web Crypto API (AES‑GCM). Symmetric cryptography uses the same key for encryption and decryption. You can generate a key, derive one from a passphrase, encrypt text, and decrypt it back.</p>\n\n    <div class=\"grid\">\n      <div>\n        <label for=\"plaintext\">Plaintext (message to encrypt)</label>\n        <textarea id=\"plaintext\">Hello! This is a short demo of AES‑GCM symmetric encryption.</textarea>\n        <div class=\"row\">\n          <button id=\"encryptBtn\">Encrypt →</button>\n          <button id=\"clearCipher\" class=\"ghost\">Clear Ciphertext</button>\n          <div style=\"flex:1\"></div>\n        </div>\n      </div>\n\n      <div>\n        <label for=\"ciphertext\">Ciphertext (Base64)</label>\n        <textarea id=\"ciphertext\" placeholder=\"Encrypted data will appear here\" readonly></textarea>\n        <div class=\"row\">\n          <button id=\"decryptBtn\" class=\"secondary\">← Decrypt</button>\n          <button id=\"copyCipher\" class=\"ghost\">Copy</button>\n          <div style=\"flex:1\"></div>\n        </div>\n      </div>\n\n      <div class=\"full\">\n        <label for=\"keyInput\">Key / Passphrase</label>\n        <input id=\"keyInput\" type=\"text\" placeholder=\"Paste a base64 key, or type a passphrase (choose mode below)\">\n        <div class=\"row\" style=\"margin-top:8px;\">\n          <select id=\"keyMode\">\n            <option value=\"raw\">Raw key (base64)</option>\n            <option value=\"passphrase\" selected>Derive from passphrase (PBKDF2)</option>\n          </select>\n          <button id=\"genKey\" class=\"ghost\">Generate Random AES‑GCM Key</button>\n          <button id=\"deriveKey\" class=\"ghost\">Derive from passphrase</button>\n          <button id=\"importKey\" class=\"ghost\">Import Raw Base64 Key</button>\n        </div>\n        <div class=\"meta\">\n          <span class=\"kbd\">Algorithm:</span> AES‑GCM, 256‑bit key. If deriving from a passphrase we use PBKDF2 + SHA‑256. IV is randomly generated per encryption (12 bytes) and prefixed to ciphertext.\n        </div>\n        <div style=\"margin-top:10px;\" id=\"deriveInfo\"></div>\n      </div>\n\n      <div>\n        <label>Key (Base64)</label>\n        <input id=\"exportedKey\" readonly placeholder=\"No key yet\">\n        <div class=\"small\">You can copy this base64 key and reuse it. If you derived a key from a passphrase, a salt is shown below — you must keep the salt to derive the same key again.</div>\n      </div>\n\n      <div>\n        <label>PBKDF2 Salt (Base64)</label>\n        <input id=\"saltOut\" readonly placeholder=\"(not used unless deriving)\">\n      </div>\n\n      <div class=\"full\">\n        <label>Explanation & Notes</label>\n        <div class=\"explain\">\n          - Symmetric keys must be kept secret and shared securely between sender and receiver.<br>\n          - AES‑GCM provides confidentiality and authenticity (an authentication tag). Tampering the ciphertext will cause decryption to fail.<br>\n          - This demo prefixes the IV (initialization vector) to the ciphertext so the recipient can extract it to decrypt. The IV must be unique for each encryption with the same key.<br>\n          - Deriving keys from passphrases requires a salt (random value) and many iterations to slow attackers performing guesses. Keep salt and parameters with the ciphertext or send them alongside via a secure channel.<br>\n        </div>\n      </div>\n\n      <div class=\"full\">\n        <label>Low-level Output / Debug</label>\n        <pre class=\"output\" id=\"debug\"></pre>\n      </div>\n    </div>\n\n    <footer>Built with Web Crypto API — AES‑GCM demo. Not intended for production use without architectural review.</footer>\n  </div>\n\n  <script>\n    // Small utility functions\n    const encode = s => new TextEncoder().encode(s);\n    const decode = buf => new TextDecoder().decode(buf);\n\n    function arrayBufferToBase64(buffer) {\n      const bytes = new Uint8Array(buffer);\n      let binary = '';\n      const chunk = 0x8000;\n      for (let i = 0; i < bytes.length; i += chunk) {\n        binary += String.fromCharCode.apply(null, bytes.subarray(i, i + chunk));\n      }\n      return btoa(binary);\n    }\n    function base64ToArrayBuffer(base64) {\n      const binary = atob(base64);\n      const len = binary.length;\n      const bytes = new Uint8Array(len);\n      for (let i = 0; i < len; i++) {\n        bytes[i] = binary.charCodeAt(i);\n      }\n      return bytes.buffer;\n    }\n    function randomBytes(length) {\n      const b = new Uint8Array(length);\n      crypto.getRandomValues(b);\n      return b;\n    }\n    function logDebug(...args) {\n      const el = document.getElementById('debug');\n      el.textContent = (el.textContent ? el.textContent + '\\n' : '') + args.join(' ');\n      el.scrollTop = el.scrollHeight;\n    }\n    function clearDebug() { document.getElementById('debug').textContent = ''; }\n\n    // State\n    let currentCryptoKey = null; // CryptoKey used for encrypt/decrypt\n    let exportedKeyBase64 = '';\n    let currentSaltBase64 = '';\n    const ivLength = 12; // 96-bit recommended for AES-GCM\n\n    // Elements\n    const plaintextEl = document.getElementById('plaintext');\n    const ciphertextEl = document.getElementById('ciphertext');\n    const encryptBtn = document.getElementById('encryptBtn');\n    const decryptBtn = document.getElementById('decryptBtn');\n    const genKeyBtn = document.getElementById('genKey');\n    const deriveKeyBtn = document.getElementById('deriveKey');\n    const importKeyBtn = document.getElementById('importKey');\n    const keyInputEl = document.getElementById('keyInput');\n    const exportedKeyEl = document.getElementById('exportedKey');\n    const saltOutEl = document.getElementById('saltOut');\n    const keyModeEl = document.getElementById('keyMode');\n    const deriveInfoEl = document.getElementById('deriveInfo');\n    const copyCipherBtn = document.getElementById('copyCipher');\n    const clearCipherBtn = document.getElementById('clearCipher');\n\n    // Core crypto functions\n    async function generateAesKey() {\n      // Generate 256-bit AES-GCM key\n      const key = await crypto.subtle.generateKey(\n        { name: 'AES-GCM', length: 256 },\n        true,\n        ['encrypt', 'decrypt']\n      );\n      // export raw base64\n      const raw = await crypto.subtle.exportKey('raw', key);\n      exportedKeyBase64 = arrayBufferToBase64(raw);\n      currentCryptoKey = key;\n      currentSaltBase64 = '';\n      updateUIKey();\n      logDebug('Generated random AES‑GCM key (base64 length:', exportedKeyBase64.length, ')');\n      return key;\n    }\n\n    async function importRawKeyFromBase64(b64) {\n      try {\n        const raw = base64ToArrayBuffer(b64.trim());\n        const key = await crypto.subtle.importKey('raw', raw, 'AES-GCM', true, ['encrypt', 'decrypt']);\n        currentCryptoKey = key;\n        exportedKeyBase64 = b64.trim();\n        currentSaltBase64 = '';\n        updateUIKey();\n        logDebug('Imported raw key from base64.');\n      } catch (e) {\n        alert('Failed to import key: ensure it is a correct base64-encoded raw key (32 bytes for AES-256).');\n        throw e;\n      }\n    }\n\n    async function deriveKeyFromPassphrase(passphrase, saltBase64=null, iterations=150000) {\n      // If saltBase64 is null, generate a new random salt (16 bytes)\n      let salt;\n      if (!saltBase64) {\n        salt = randomBytes(16);\n        currentSaltBase64 = arrayBufferToBase64(salt);\n      } else {\n        salt = new Uint8Array(base64ToArrayBuffer(saltBase64));\n        currentSaltBase64 = saltBase64;\n      }\n      // Import passphrase as key material\n      const keyMaterial = await crypto.subtle.importKey(\n        'raw',\n        encode(passphrase),\n        { name: 'PBKDF2' },\n        false,\n        ['deriveKey']\n      );\n      // Derive AES‑GCM 256-bit key\n      const derivedKey = await crypto.subtle.deriveKey(\n        {\n          name: 'PBKDF2',\n          salt: salt,\n          iterations: iterations,\n          hash: 'SHA-256'\n        },\n        keyMaterial,\n        { name: 'AES-GCM', length: 256 },\n        true,\n        ['encrypt', 'decrypt']\n      );\n      const raw = await crypto.subtle.exportKey('raw', derivedKey);\n      exportedKeyBase64 = arrayBufferToBase64(raw);\n      currentCryptoKey = derivedKey;\n      updateUIKey();\n      deriveInfoEl.innerHTML = `Derived with PBKDF2 (iterations: ${iterations}). Keep the salt (below) to derive the same key again.`;\n      logDebug('Derived key from passphrase. Iterations:', iterations, 'Salt (b64):', currentSaltBase64);\n      return derivedKey;\n    }\n\n    async function encryptWithCurrentKey(plainText) {\n      if (!currentCryptoKey) {\n        alert('No key selected. Generate or import/derive a key first.');\n        return null;\n      }\n      try {\n        const iv = randomBytes(ivLength);\n        const ciphertext = await crypto.subtle.encrypt(\n          { name: 'AES-GCM', iv: iv },\n          currentCryptoKey,\n          encode(plainText)\n        );\n        // Prefix IV to ciphertext so recipient can extract it\n        const ivAndCipher = new Uint8Array(iv.byteLength + ciphertext.byteLength);\n        ivAndCipher.set(iv, 0);\n        ivAndCipher.set(new Uint8Array(ciphertext), iv.byteLength);\n        const b64 = arrayBufferToBase64(ivAndCipher.buffer);\n        logDebug('Encrypted data (iv len ' + ivLength + ' bytes). Ciphertext b64 length:', b64.length);\n        return b64;\n      } catch (e) {\n        console.error(e);\n        alert('Encryption failed: ' + (e && e.message ? e.message : e));\n        return null;\n      }\n    }\n\n    async function decryptWithCurrentKey(b64Cipher) {\n      if (!currentCryptoKey) {\n        alert('No key selected. Generate or import/derive a key first.');\n        return null;\n      }\n      try {\n        const ivAndCipher = new Uint8Array(base64ToArrayBuffer(b64Cipher.trim()));\n        const iv = ivAndCipher.slice(0, ivLength);\n        const ciphertext = ivAndCipher.slice(ivLength);\n        const plainBuf = await crypto.subtle.decrypt(\n          { name: 'AES-GCM', iv: iv },\n          currentCryptoKey,\n          ciphertext\n        );\n        const plain = decode(plainBuf);\n        logDebug('Decryption successful. Recovered plaintext length:', plain.length);\n        return plain;\n      } catch (e) {\n        console.error(e);\n        alert('Decryption failed. (Possible causes: wrong key, altered ciphertext, incorrect IV or tag mismatch.)');\n        logDebug('Decryption error:', e && e.message ? e.message : e);\n        return null;\n      }\n    }\n\n    // UI helpers\n    function updateUIKey() {\n      exportedKeyEl.value = exportedKeyBase64 || '';\n      saltOutEl.value = currentSaltBase64 || '';\n    }\n\n    async function onGenerateKeyClicked() {\n      clearDebug();\n      await generateAesKey();\n      deriveInfoEl.textContent = 'Random key generated.';\n    }\n    async function onDeriveKeyClicked() {\n      clearDebug();\n      const input = keyInputEl.value;\n      if (!input) { alert('Type a passphrase in the Key/Passphrase field then click \"Derive from passphrase\".'); return; }\n      // Use default iterations\n      await deriveKeyFromPassphrase(input, null, 150000);\n    }\n    async function onImportKeyClicked() {\n      clearDebug();\n      const input = keyInputEl.value.trim();\n      if (!input) { alert('Paste base64-encoded raw key into the Key field then click Import.'); return; }\n      await importRawKeyFromBase64(input);\n      deriveInfoEl.textContent = 'Imported raw key (base64).';\n    }\n\n    encryptBtn.addEventListener('click', async () => {\n      clearDebug();\n      const pt = plaintextEl.value;\n      const start = performance.now();\n      const b64 = await encryptWithCurrentKey(pt);\n      const duration = (performance.now() - start).toFixed(2);\n      if (b64) {\n        ciphertextEl.value = b64;\n        logDebug('Encryption time (ms):', duration);\n      }\n    });\n\n    decryptBtn.addEventListener('click', async () => {\n      clearDebug();\n      const b64 = ciphertextEl.value.trim();\n      if (!b64) { alert('Paste ciphertext (base64) into the Ciphertext area to decrypt.'); return; }\n      const start = performance.now();\n      const pt = await decryptWithCurrentKey(b64);\n      const duration = (performance.now() - start).toFixed(2);\n      if (pt !== null) {\n        // Place plaintext into the plaintext box\n        plaintextEl.value = pt;\n        logDebug('Decryption time (ms):', duration);\n      }\n    });\n\n    genKeyBtn.addEventListener('click', onGenerateKeyClicked);\n    deriveKeyBtn.addEventListener('click', onDeriveKeyClicked);\n    importKeyBtn.addEventListener('click', onImportKeyClicked);\n\n    copyCipherBtn.addEventListener('click', async () => {\n      const text = ciphertextEl.value;\n      if (!text) return;\n      try {\n        await navigator.clipboard.writeText(text);\n        alert('Ciphertext copied to clipboard.');\n      } catch (e) {\n        alert('Copy failed: ' + e);\n      }\n    });\n\n    clearCipherBtn.addEventListener('click', () => { ciphertextEl.value = ''; });\n\n    // Initialize demo with a generated key\n    (async function init() {\n      clearDebug();\n      logDebug('Initializing Web Crypto AES‑GCM demo...');\n      try {\n        await generateAesKey();\n        deriveInfoEl.textContent = 'A random key has been generated for you. You can also derive from a passphrase or import a base64 key.';\n      } catch (e) {\n        logDebug('Initialization failed:', e && e.message ? e.message : e);\n      }\n    })();\n\n    // Helper: if user switches keyMode, update placeholder\n    keyModeEl.addEventListener('change', () => {\n      if (keyModeEl.value === 'raw') {\n        keyInputEl.type = 'text';\n        keyInputEl.placeholder = 'Paste a base64 key (raw 32 bytes => base64)';\n      } else {\n        keyInputEl.type = 'password';\n        keyInputEl.placeholder = 'Type a passphrase to derive a key (PBKDF2)';\n      }\n    });\n  </script>\n</body>\n</html>"
  },
