    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Paging Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 40px;\n    background: #f9f9f9;\n  }\n\n  h1 {\n    text-align: center;\n    color: #333;\n  }\n\n  #content {\n    max-width: 600px;\n    margin: 20px auto;\n    background: white;\n    border-radius: 8px;\n    padding: 20px;\n    box-shadow: 0 0 10px rgba(0,0,0,0.1);\n  }\n\n  #items {\n    list-style: none;\n    padding: 0;\n    margin: 0 0 20px 0;\n  }\n\n  #items li {\n    padding: 10px 15px;\n    border-bottom: 1px solid #eee;\n    font-size: 1.1em;\n    color: #444;\n  }\n\n  #items li:last-child {\n    border-bottom: none;\n  }\n\n  #paging-controls {\n    text-align: center;\n  }\n\n  #paging-controls button {\n    background: #007bff;\n    color: white;\n    border: none;\n    margin: 0 5px;\n    padding: 8px 14px;\n    font-size: 1em;\n    border-radius: 4px;\n    cursor: pointer;\n    transition: background-color 0.2s ease;\n  }\n\n  #paging-controls button:disabled {\n    background: #bbb;\n    cursor: default;\n  }\n\n  #paging-info {\n    margin-top: 10px;\n    font-size: 0.9em;\n    color: #666;\n  }\n</style>\n</head>\n<body>\n\n<h1>Paging Demonstration</h1>\n<div id=\"content\">\n  <ul id=\"items\"></ul>\n  <div id=\"paging-controls\">\n    <button id=\"firstBtn\">« First</button>\n    <button id=\"prevBtn\">‹ Prev</button>\n    <button id=\"nextBtn\">Next ›</button>\n    <button id=\"lastBtn\">Last »</button>\n    <div id=\"paging-info\"></div>\n  </div>\n</div>\n\n<script>\n  (function() {\n    // Simulate a large data set\n    const data = [];\n    for(let i = 1; i <= 123; i++) {\n      data.push(`Item ${i}`);\n    }\n\n    const pageSize = 10;            // Items per page\n    const totalItems = data.length;\n    const totalPages = Math.ceil(totalItems / pageSize);\n    let currentPage = 1;\n\n    // DOM references\n    const itemsContainer = document.getElementById('items');\n    const firstBtn = document.getElementById('firstBtn');\n    const prevBtn = document.getElementById('prevBtn');\n    const nextBtn = document.getElementById('nextBtn');\n    const lastBtn = document.getElementById('lastBtn');\n    const pagingInfo = document.getElementById('paging-info');\n\n    // Render the current page's items\n    function renderPage(page) {\n      currentPage = page;\n\n      // Calculate slice boundaries\n      const start = (page - 1) * pageSize;\n      const end = Math.min(start + pageSize, totalItems);\n\n      // Clear previous items\n      itemsContainer.innerHTML = '';\n\n      // Add new items\n      for(let i = start; i < end; i++) {\n        const li = document.createElement('li');\n        li.textContent = data[i];\n        itemsContainer.appendChild(li);\n      }\n\n      // Update buttons\n      firstBtn.disabled = page === 1;\n      prevBtn.disabled = page === 1;\n      nextBtn.disabled = page === totalPages;\n      lastBtn.disabled = page === totalPages;\n\n      // Update paging info\n      pagingInfo.textContent = `Showing items ${start + 1} to ${end} of ${totalItems} (Page ${page} of ${totalPages})`;\n    }\n\n    // Event handlers for buttons\n    firstBtn.addEventListener('click', () => renderPage(1));\n    prevBtn.addEventListener('click', () => {\n      if(currentPage > 1) renderPage(currentPage - 1);\n    });\n    nextBtn.addEventListener('click', () => {\n      if(currentPage < totalPages) renderPage(currentPage + 1);\n    });\n    lastBtn.addEventListener('click', () => renderPage(totalPages));\n\n    // Initial render\n    renderPage(1);\n  })();\n</script>\n\n</body>\n</html>"
