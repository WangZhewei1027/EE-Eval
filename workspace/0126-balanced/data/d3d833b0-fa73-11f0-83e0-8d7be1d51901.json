    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Sliding Window Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --accent:#06b6d4;\n      --muted:#94a3b8;\n      --glass: rgba(255,255,255,0.03);\n      --good:#10b981;\n      --danger:#ef4444;\n      --panel:#0b1220;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      color-scheme: dark;\n    }\n    html,body{\n      height:100%;\n      margin:0;\n      background: linear-gradient(180deg,#031122 0%, #071226 60%);\n      color:#e6eef6;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n    }\n    .wrap{\n      max-width:1100px;\n      margin:24px auto;\n      padding:18px;\n      border-radius:12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      box-shadow: 0 6px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n    header{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-bottom:14px;\n    }\n    header h1{\n      margin:0;\n      font-size:20px;\n      letter-spacing:0.2px;\n    }\n    header p{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .top{\n      display:flex;\n      gap:18px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n    .tabs{ display:flex; gap:8px; }\n    .tab{\n      padding:8px 12px;\n      border-radius:8px;\n      background:transparent;\n      color:var(--muted);\n      cursor:pointer;\n      border:1px solid transparent;\n      font-size:13px;\n    }\n    .tab.active{\n      background:linear-gradient(90deg, rgba(6,182,212,0.12), rgba(16,185,129,0.02));\n      color:var(--accent);\n      border-color: rgba(6,182,212,0.12);\n      box-shadow:0 4px 18px rgba(6,182,212,0.08);\n    }\n    .columns{\n      display:grid;\n      grid-template-columns: 1fr 360px;\n      gap:18px;\n      margin-top:16px;\n    }\n    .panel{\n      background:var(--panel);\n      padding:14px;\n      border-radius:10px;\n      border:1px solid rgba(255,255,255,0.03);\n    }\n    .controls{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; }\n    label{ font-size:13px; color:var(--muted); }\n    input[type=\"text\"], textarea {\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.04);\n      padding:8px 10px;\n      border-radius:8px;\n      color: #e6eef6;\n      outline:none;\n      width:100%;\n      font-size:14px;\n    }\n    input[type=\"range\"]{\n      width:140px;\n    }\n    .btn{\n      padding:8px 12px;\n      border-radius:8px;\n      background:linear-gradient(90deg,#0b2540,#072138);\n      border:1px solid rgba(255,255,255,0.03);\n      color:#cfeff6;\n      cursor:pointer;\n      font-size:13px;\n    }\n    .btn.secondary{\n      background:transparent;\n      border:1px dashed rgba(255,255,255,0.03);\n      color:var(--muted);\n    }\n    .row{ display:flex; gap:10px; align-items:center; }\n    .array-visual{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      overflow:auto;\n      padding:12px 8px;\n      border-radius:8px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .cell{\n      min-width:48px;\n      height:48px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      border-radius:8px;\n      background:linear-gradient(180deg,#081827,#06202c);\n      box-shadow: 0 2px 8px rgba(2,6,23,0.6);\n      border:1px solid rgba(255,255,255,0.03);\n      font-weight:600;\n      letter-spacing:0.6px;\n    }\n    .cell.window{\n      background: linear-gradient(90deg, rgba(6,182,212,0.14), rgba(16,185,129,0.06));\n      border-color: rgba(6,182,212,0.18);\n      box-shadow:0 8px 26px rgba(6,182,212,0.06);\n      transform: translateY(-6px);\n    }\n    .cell.left{\n      outline: 3px solid rgba(16, 185, 129, 0.16);\n      box-shadow: 0 10px 28px rgba(16,185,129,0.06);\n    }\n    .cell.right{\n      outline: 3px solid rgba(6,182,212,0.14);\n      box-shadow: 0 10px 28px rgba(6,182,212,0.06);\n    }\n    .legend{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      margin-top:10px;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .chip{ display:flex; gap:6px; align-items:center; font-size:13px; color:var(--muted); }\n    .chip .dot{ width:12px;height:12px;border-radius:3px;background:var(--accent);opacity:0.18;border:1px solid rgba(255,255,255,0.02) }\n    .status{\n      margin-top:12px;\n      display:flex;\n      gap:10px;\n      flex-wrap:wrap;\n    }\n    .status .stat{\n      background:rgba(255,255,255,0.02);\n      padding:8px 10px;\n      border-radius:8px;\n      font-size:13px;\n      color:var(--muted);\n    }\n    pre.code{\n      margin:0;\n      background:transparent;\n      border-radius:8px;\n      padding:10px;\n      font-size:13px;\n      color:#dff6fb;\n      overflow:auto;\n      border:1px solid rgba(255,255,255,0.02);\n      line-height:1.45;\n      max-height:260px;\n    }\n    .highlight{\n      display:block;\n      background: linear-gradient(90deg, rgba(6,182,212,0.08), rgba(16,185,129,0.03));\n      border-left: 4px solid rgba(6,182,212,0.12);\n      padding-left:8px;\n      margin: 6px 0;\n    }\n    footer.note{\n      margin-top:16px;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .small{ font-size:12px; color:var(--muted); }\n    .controls-bottom{ display:flex; gap:8px; align-items:center; margin-top:12px; flex-wrap:wrap; }\n    .speed{ width:100px; }\n    .generate{ display:flex; gap:6px; align-items:center; }\n    .badge{ padding:6px 8px; border-radius:8px; background:rgba(255,255,255,0.02); color:var(--muted); font-size:13px; }\n    .result{\n      margin-top:10px;\n      padding:10px;\n      border-radius:8px;\n      background: linear-gradient(90deg, rgba(16,185,129,0.04), rgba(6,182,212,0.02));\n      color:#c7fff6;\n      font-weight:600;\n    }\n    .flex-col{ display:flex; flex-direction:column; gap:8px; }\n    @media (max-width:980px){\n      .columns{ grid-template-columns: 1fr; }\n      .array-visual{ overflow-x:auto; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\" role=\"main\">\n    <header>\n      <div>\n        <h1>Sliding Window Visualizer</h1>\n        <p>Interactive demonstrations: fixed-size window (max sum subarray of size k) and variable-size window (longest substring without repeating characters).</p>\n      </div>\n    </header>\n\n    <div class=\"top\">\n      <div class=\"tabs\" role=\"tablist\" aria-label=\"Demos\">\n        <button class=\"tab active\" data-mode=\"fixed\">Fixed-size (Max Sum of k)</button>\n        <button class=\"tab\" data-mode=\"variable\">Variable-size (Longest Unique Substring)</button>\n      </div>\n      <div class=\"badge\">Concept: Sliding Window</div>\n    </div>\n\n    <div class=\"columns\" style=\"margin-top:12px;\">\n      <div class=\"panel\" id=\"leftPanel\">\n        <!-- Controls & visualization here -->\n        <div id=\"fixedControls\" class=\"flex-col\">\n          <div class=\"row\">\n            <label style=\"min-width:90px\">Array (comma-separated)</label>\n            <input type=\"text\" id=\"arrayInput\" value=\"2,1,5,1,3,2\" aria-label=\"Array input\"/>\n            <div class=\"generate\">\n              <button class=\"btn secondary\" id=\"randArr\">Random</button>\n              <button class=\"btn\" id=\"applyArr\">Apply</button>\n            </div>\n          </div>\n          <div class=\"row\">\n            <label style=\"min-width:90px\">Window size k</label>\n            <input type=\"range\" id=\"kRange\" min=\"1\" max=\"10\" value=\"3\"/>\n            <div class=\"small\" id=\"kVal\">3</div>\n            <div style=\"flex:1\"></div>\n            <div class=\"small\">n = <span id=\"nVal\">6</span></div>\n          </div>\n\n          <div class=\"row\">\n            <label style=\"min-width:90px\">Controls</label>\n            <div style=\"display:flex; gap:8px; flex-wrap:wrap;\">\n              <button class=\"btn\" id=\"stepBtn\">Step</button>\n              <button class=\"btn\" id=\"playBtn\">Play</button>\n              <button class=\"btn secondary\" id=\"resetBtn\">Reset</button>\n              <button class=\"btn secondary\" id=\"fastForwardBtn\">Fast-forward</button>\n            </div>\n            <div style=\"flex:1\"></div>\n            <div class=\"small\">\n              Speed:\n              <input type=\"range\" id=\"speedRange\" min=\"100\" max=\"1500\" step=\"50\" value=\"700\" class=\"speed\"/>\n            </div>\n          </div>\n\n          <div class=\"row\">\n            <label style=\"min-width:90px\">Array Visual</label>\n            <div class=\"array-visual\" id=\"arrayViz\" aria-live=\"polite\"></div>\n          </div>\n\n          <div class=\"legend\">\n            <div class=\"chip\"><div class=\"dot\" style=\"background:linear-gradient(90deg,#06b6d4,#10b981);opacity:0.18\"></div> Highlighted window</div>\n            <div class=\"chip\"><div class=\"dot\" style=\"background:rgba(16,185,129,0.9)\"></div> left pointer</div>\n            <div class=\"chip\"><div class=\"dot\" style=\"background:rgba(6,182,212,0.9)\"></div> right pointer</div>\n          </div>\n\n          <div class=\"status\" id=\"statusArea\">\n            <div class=\"stat\">Current window sum: <span id=\"curSum\">-</span></div>\n            <div class=\"stat\">Best (max) sum: <span id=\"maxSum\">-</span></div>\n            <div class=\"stat\">Best indices: <span id=\"maxIdx\">-</span></div>\n          </div>\n\n          <div style=\"margin-top:10px;\">\n            <label>Algorithm (Fixed-size)</label>\n            <pre class=\"code\" id=\"codeFixed\">\n// Sliding window (fixed-size)\nlet windowSum = sum(arr[0..k-1]);\nlet maxSum = windowSum;\nfor (let i = k; i &lt; arr.length; i++) {\n  windowSum += arr[i] - arr[i-k]; // slide right by 1\n  if (windowSum > maxSum) update max;\n}\n            </pre>\n          </div>\n\n          <div id=\"fixedResult\" class=\"result\" style=\"display:none;\"></div>\n        </div>\n\n        <div id=\"variableControls\" class=\"flex-col\" style=\"display:none;\">\n          <div class=\"row\">\n            <label style=\"min-width:90px\">String</label>\n            <input type=\"text\" id=\"strInput\" value=\"abcabcbb\" />\n            <div class=\"generate\">\n              <button class=\"btn secondary\" id=\"randStr\">Random</button>\n              <button class=\"btn\" id=\"applyStr\">Apply</button>\n            </div>\n          </div>\n          <div class=\"row\">\n            <label style=\"min-width:90px\">Controls</label>\n            <div style=\"display:flex; gap:8px;\">\n              <button class=\"btn\" id=\"stepBtnVar\">Step</button>\n              <button class=\"btn\" id=\"playBtnVar\">Play</button>\n              <button class=\"btn secondary\" id=\"resetBtnVar\">Reset</button>\n              <button class=\"btn secondary\" id=\"fastForwardBtnVar\">Fast-forward</button>\n            </div>\n            <div style=\"flex:1\"></div>\n            <div class=\"small\">\n              Speed:\n              <input type=\"range\" id=\"speedRangeVar\" min=\"100\" max=\"1500\" step=\"50\" value=\"700\" class=\"speed\"/>\n            </div>\n          </div>\n\n          <div class=\"row\">\n            <label style=\"min-width:90px\">String Visual</label>\n            <div class=\"array-visual\" id=\"strViz\"></div>\n          </div>\n\n          <div class=\"status\" id=\"statusAreaVar\">\n            <div class=\"stat\">Window: <span id=\"curSub\">-</span></div>\n            <div class=\"stat\">Best length: <span id=\"bestLen\">-</span></div>\n            <div class=\"stat\">Best substring: <span id=\"bestSub\">-</span></div>\n          </div>\n\n          <div style=\"margin-top:10px;\">\n            <label>Algorithm (Variable-size)</label>\n            <pre class=\"code\" id=\"codeVar\">\n// Longest substring without repeating characters\nlet map = {};\nlet left = 0, maxLen = 0;\nfor (let right=0; right<s.length; right++) {\n  if (map[s[right]] >= left) left = map[s[right]] + 1;\n  map[s[right]] = right;\n  maxLen = max(maxLen, right-left+1);\n}\n            </pre>\n          </div>\n\n          <div id=\"varResult\" class=\"result\" style=\"display:none;\"></div>\n        </div>\n\n      </div>\n\n      <div class=\"panel\" id=\"rightPanel\">\n        <label>Step inspector & explanation</label>\n        <div style=\"margin-top:8px;\">\n          <pre class=\"code\" id=\"stepInfo\">Select a demo and step through the algorithm. The inspector shows the current action and variables.</pre>\n        </div>\n        <div style=\"margin-top:12px;\">\n          <label>Explanation</label>\n          <div style=\"margin-top:8px; color:var(--muted); font-size:13px;\">\n            The sliding window technique maintains a subset (window) of contiguous elements and moves it (slides) over the input to compute values incrementally:\n            - Fixed-size: maintain sum of exactly k elements — update by adding entering element and subtracting leaving element.\n            - Variable-size: expand right pointer, shrink left pointer when constraint violated (e.g., duplicates or sum constraint).\n          </div>\n        </div>\n\n        <div style=\"margin-top:14px;\">\n          <label>Quick Examples</label>\n          <div style=\"margin-top:8px; color:var(--muted); font-size:13px;\">\n            - Max sum of k: [2,1,5,1,3,2], k=3 -> best sum 9 for window [5,1,3].<br/>\n            - Longest unique substring: \"abcabcbb\" -> \"abc\" length 3.\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <footer class=\"note\">\n      Tip: Try customizing inputs and use Step/Play to watch how left and right pointers move. This interactive helps internalize the constant-time update idea that makes sliding window O(n).\n    </footer>\n  </div>\n\n  <script>\n    // Utility\n    function $(id){ return document.getElementById(id); }\n    function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }\n\n    // STATE\n    let mode = 'fixed'; // 'fixed' or 'variable'\n    const tabs = document.querySelectorAll('.tab');\n    tabs.forEach(t=>{\n      t.addEventListener('click', ()=>{\n        tabs.forEach(x=>x.classList.remove('active'));\n        t.classList.add('active');\n        mode = t.dataset.mode;\n        updateModeUI();\n      });\n    });\n\n    function updateModeUI(){\n      $('fixedControls').style.display = (mode==='fixed')? 'flex' : 'none';\n      $('variableControls').style.display = (mode==='variable')? 'flex' : 'none';\n      if(mode==='fixed') { stopVarPlay(); resetFixed(); }\n      else { stopFixedPlay(); resetVar(); }\n      $('stepInfo').textContent = (mode==='fixed')? 'Fixed-size max-sum-of-k demo. Step to move the window right one position at a time.' :\n        'Variable-size longest-unique-substring demo. Step to process each character and adjust left pointer when needed.';\n    }\n\n    // --------------------------\n    // FIXED-SIZE DEMO: MAX SUM of size k\n    // --------------------------\n    const arrayInput = $('arrayInput');\n    const kRange = $('kRange');\n    const kVal = $('kVal');\n    const nVal = $('nVal');\n    const arrayViz = $('arrayViz');\n    const curSum = $('curSum');\n    const maxSum = $('maxSum');\n    const maxIdx = $('maxIdx');\n    const codeFixed = $('codeFixed');\n    const fixedResult = $('fixedResult');\n\n    let arr = [2,1,5,1,3,2];\n    let k = 3;\n    let stepsFixed = [];\n    let fixedStepIndex = 0;\n    let fixedTimer = null;\n\n    function parseArrayInput(){\n      const text = arrayInput.value.trim();\n      if(!text) return [];\n      const parts = text.split(',').map(s=>s.trim()).filter(s=>s.length);\n      const nums = parts.map(p=>{\n        const v = Number(p);\n        return Number.isFinite(v) ? v : NaN;\n      });\n      // If any NaN, preserve as string? For this demo we require numbers\n      if(nums.some(isNaN)) {\n        alert('Array must contain numbers separated by commas. Example: 2,1,5,1,3,2');\n        return arr;\n      }\n      return nums;\n    }\n\n    function generateRandomArray(len=8, max=10){\n      const a=[];\n      for(let i=0;i<len;i++) a.push(Math.floor(Math.random()*max)+1);\n      return a;\n    }\n\n    function buildFixedSteps(){\n      stepsFixed = [];\n      const n = arr.length;\n      k = clamp(k,1,n);\n      if(n===0){\n        stepsFixed.push({type:'empty'});\n        return;\n      }\n      // initial sum of first k\n      let windowSum = 0;\n      for(let i=0;i<k && i<n;i++) windowSum += arr[i];\n      let maxS = windowSum;\n      let maxLeft = 0, maxRight = k-1;\n      // record initial\n      stepsFixed.push({\n        type:'init',\n        left:0, right:Math.min(k-1,n-1),\n        windowSum, maxSum:maxS, maxLeft, maxRight,\n        info: `Initialize window with first ${k} elements.`\n      });\n      // slide window by 1 for each next index i (right)\n      for(let i=k;i<n;i++){\n        const leaving = arr[i-k];\n        const entering = arr[i];\n        windowSum += entering - leaving;\n        const left = i-k+1;\n        const right = i;\n        let updated = false;\n        if(windowSum > maxS){\n          maxS = windowSum;\n          maxLeft = left;\n          maxRight = right;\n          updated = true;\n        }\n        stepsFixed.push({\n          type:'move',\n          left, right, windowSum, leaving, entering,\n          maxSum:maxS, maxLeft, maxRight,\n          info: `Slide window right: subtract ${leaving}, add ${entering}. ${updated? 'New max!':''}`\n        });\n      }\n      // show final\n      stepsFixed.push({\n        type:'done',\n        left: Math.max(0, n-k),\n        right: Math.min(n-1, n-1),\n        windowSum, maxSum:maxS, maxLeft, maxRight,\n        info:'Finished scanning.'\n      });\n    }\n\n    function renderArrayVizFixed(stateIndex=0){\n      arrayViz.innerHTML='';\n      const n = arr.length;\n      const s = stepsFixed[stateIndex] || {};\n      const left = (s.left !== undefined) ? s.left : -1;\n      const right = (s.right !== undefined) ? s.right : -1;\n      const maxL = s.maxLeft, maxR = s.maxRight;\n      for(let i=0;i<n;i++){\n        const div = document.createElement('div');\n        div.className='cell';\n        if(i>=left && i<=right) div.classList.add('window');\n        if(i===left) div.classList.add('left');\n        if(i===right) div.classList.add('right');\n        if(maxL !== undefined && i>=maxL && i<=maxR){\n          // slightly mark best window\n          div.style.boxShadow = (i>=left && i<=right) ? div.style.boxShadow : '0 6px 16px rgba(16,185,129,0.06)';\n        }\n        div.textContent = arr[i];\n        arrayViz.appendChild(div);\n      }\n      // update status\n      if(s.type==='empty'){\n        $('curSum').textContent = '-';\n        $('maxSum').textContent = '-';\n        $('maxIdx').textContent = '-';\n        $('fixedResult').style.display='none';\n        $('nVal').textContent = n;\n        return;\n      }\n      $('nVal').textContent = n;\n      $('curSum').textContent = (s.windowSum===undefined)? '-' : s.windowSum;\n      $('maxSum').textContent = (s.maxSum===undefined)? '-' : s.maxSum;\n      if(s.maxLeft !== undefined){\n        $('maxIdx').textContent = `[${s.maxLeft},${s.maxRight}]`;\n      } else $('maxIdx').textContent='-';\n      // step info\n      $('stepInfo').textContent = s.info || '';\n      // final result\n      if(s.type==='done'){\n        $('fixedResult').style.display='block';\n        $('fixedResult').textContent = `Best sum = ${s.maxSum}, window = [${s.maxLeft}..${s.maxRight}] -> [${arr.slice(s.maxLeft,s.maxRight+1).join(',')}]`;\n      } else $('fixedResult').style.display='none';\n      // highlight code lines roughly by replacing innerHTML\n      const lines = codeFixed.textContent.split('\\n').map(l=>l.replace(/</g,'&lt;'));\n      let highlight = '';\n      if(s.type==='init') highlight = 1; // line index arbitrary\n      else if(s.type==='move') highlight = 2;\n      else if(s.type==='done') highlight = 3;\n      codeFixed.innerHTML = lines.map((l,i)=> (i===highlight? `<span class=\"highlight\">${l}</span>` : l)).join('\\n');\n    }\n\n    // Controls\n    $('applyArr').addEventListener('click', ()=>{\n      const parsed = parseArrayInput();\n      if(parsed.length>=0){\n        arr = parsed;\n        kRange.max = Math.max(1, arr.length);\n        k = clamp(Number(kRange.value),1,arr.length||1);\n        kRange.value = k;\n        kVal.textContent = k;\n        buildFixedSteps();\n        fixedStepIndex = 0;\n        renderArrayVizFixed(0);\n      }\n    });\n\n    $('randArr').addEventListener('click', ()=>{\n      const random = generateRandomArray(8, 12);\n      arr = random;\n      arrayInput.value = arr.join(',');\n      kRange.max = Math.max(1, arr.length);\n      k = clamp(k,1,arr.length);\n      kRange.value = k;\n      kVal.textContent = k;\n      buildFixedSteps();\n      fixedStepIndex = 0;\n      renderArrayVizFixed(0);\n    });\n\n    kRange.addEventListener('input', ()=>{\n      k = Number(kRange.value);\n      kVal.textContent = k;\n      kRange.max = Math.max(1, arr.length);\n      buildFixedSteps();\n      fixedStepIndex = 0;\n      renderArrayVizFixed(0);\n    });\n\n    // Step controls\n    $('stepBtn').addEventListener('click', ()=>{\n      stopFixedPlay();\n      fixedStepIndex = clamp(fixedStepIndex+1, 0, stepsFixed.length-1);\n      renderArrayVizFixed(fixedStepIndex);\n    });\n    $('resetBtn').addEventListener('click', ()=>{\n      stopFixedPlay();\n      fixedStepIndex = 0;\n      renderArrayVizFixed(fixedStepIndex);\n    });\n    $('fastForwardBtn').addEventListener('click', ()=>{\n      stopFixedPlay();\n      fixedStepIndex = stepsFixed.length-1;\n      renderArrayVizFixed(fixedStepIndex);\n    });\n\n    $('playBtn').addEventListener('click', ()=>{\n      if(fixedTimer) {\n        stopFixedPlay();\n      } else {\n        startFixedPlay();\n      }\n    });\n\n    function startFixedPlay(){\n      $('playBtn').textContent = 'Pause';\n      const speed = Number($('speedRange').value);\n      fixedTimer = setInterval(()=>{\n        fixedStepIndex++;\n        if(fixedStepIndex >= stepsFixed.length){\n          stopFixedPlay();\n          fixedStepIndex = stepsFixed.length-1;\n          renderArrayVizFixed(fixedStepIndex);\n          return;\n        }\n        renderArrayVizFixed(fixedStepIndex);\n      }, speed);\n    }\n    function stopFixedPlay(){\n      if(fixedTimer) clearInterval(fixedTimer);\n      fixedTimer = null;\n      $('playBtn').textContent = 'Play';\n    }\n    $('speedRange').addEventListener('input', ()=>{\n      if(fixedTimer){\n        stopFixedPlay();\n        startFixedPlay();\n      }\n    });\n    function resetFixed(){\n      // read inputs and rebuild\n      const parsed = parseArrayInput();\n      if(parsed) arr = parsed;\n      k = clamp(Number(kRange.value),1,arr.length||1);\n      kRange.max = Math.max(1, arr.length||1);\n      kRange.value = k;\n      kVal.textContent = k;\n      buildFixedSteps();\n      fixedStepIndex = 0;\n      renderArrayVizFixed(0);\n    }\n\n    // Initialize fixed demo\n    resetFixed();\n\n    // --------------------------\n    // VARIABLE-SIZE DEMO: LONGEST UNIQUE SUBSTRING\n    // --------------------------\n    const strInput = $('strInput');\n    const strViz = $('strViz');\n    const curSub = $('curSub');\n    const bestLen = $('bestLen');\n    const bestSub = $('bestSub');\n    const codeVar = $('codeVar');\n    const varResult = $('varResult');\n\n    let s = \"abcabcbb\";\n    let stepsVar = [];\n    let varStepIndex = 0;\n    let varTimer = null;\n\n    function randomString(len=8){\n      const chars = 'abcdefghijklmnopqrstuvwxyz';\n      let out='';\n      for(let i=0;i<len;i++) out += chars[Math.floor(Math.random()*chars.length)];\n      return out;\n    }\n\n    function buildVarSteps(){\n      stepsVar = [];\n      s = strInput.value || '';\n      if(s.length===0){ stepsVar.push({type:'empty'}); return; }\n      const map = {};\n      let left = 0;\n      let maxLen = 0, maxLeft = 0, maxRight = -1;\n      for(let right=0; right<s.length; right++){\n        const ch = s[right];\n        // inspect char\n        stepsVar.push({\n          type:'inspect',\n          left, right, ch,\n          map: Object.assign({}, map),\n          info:`Inspect '${ch}' at index ${right}.`\n        });\n        if(map[ch] !== undefined && map[ch] >= left){\n          // to show sliding, we will record the jump of left to map[ch] + 1\n          const oldLeft = left;\n          left = map[ch] + 1;\n          stepsVar.push({\n            type:'shrink',\n            left, right, ch,\n            oldLeft, newLeft:left,\n            map: Object.assign({}, map),\n            info: `Found duplicate '${ch}'. Move left from ${oldLeft} to ${left}.`\n          });\n        }\n        map[ch] = right;\n        const curLen = right - left + 1;\n        if(curLen > maxLen){\n          maxLen = curLen;\n          maxLeft = left; maxRight = right;\n          stepsVar.push({\n            type:'updateMax',\n            left, right, ch,\n            maxLen, maxLeft, maxRight,\n            map: Object.assign({}, map),\n            info: `New best substring: '${s.slice(maxLeft, maxRight+1)}' (length ${maxLen}).`\n          });\n        } else {\n          stepsVar.push({\n            type:'ok',\n            left, right, ch,\n            maxLen, maxLeft, maxRight,\n            map: Object.assign({}, map),\n            info: `Window valid. Current substring '${s.slice(left,right+1)}' (length ${curLen}).`\n          });\n        }\n      }\n      stepsVar.push({ type:'done', left, right:s.length-1, maxLen, maxLeft, maxRight, info:'Finished scanning.'});\n    }\n\n    function renderStrViz(idx=0){\n      strViz.innerHTML='';\n      const state = stepsVar[idx] || {};\n      const left = (state.left !== undefined)? state.left : -1;\n      const right = (state.right !== undefined)? state.right : -1;\n      const map = state.map || {};\n      for(let i=0;i<s.length;i++){\n        const div = document.createElement('div');\n        div.className='cell';\n        if(i>=left && i<=right) div.classList.add('window');\n        if(i===left) div.classList.add('left');\n        if(i===right) div.classList.add('right');\n        div.textContent = s[i];\n        // show index small\n        const idxEl = document.createElement('div');\n        idxEl.style.position='absolute';\n        strViz.style.position = 'relative';\n        strViz.appendChild(div);\n      }\n      // status\n      if(state.type==='empty'){\n        curSub.textContent = '-';\n        bestLen.textContent = '-';\n        bestSub.textContent = '-';\n        $('stepInfo').textContent = 'Empty string.';\n        varResult.style.display='none';\n        return;\n      }\n      const curWindow = (left<=right && left>=0)? s.slice(left, right+1) : '';\n      curSub.textContent = curWindow || '-';\n      bestLen.textContent = (state.maxLen===undefined)? '-' : state.maxLen;\n      bestSub.textContent = (state.maxLeft!==undefined)? s.slice(state.maxLeft, (state.maxRight||state.maxLeft)+1) : '-';\n      $('stepInfo').textContent = state.info || '';\n      // map display as small\n      // code highlight\n      const lines = codeVar.textContent.split('\\n').map(l=>l.replace(/</g,'&lt;'));\n      let highlightLine = -1;\n      if(state.type==='inspect') highlightLine=1;\n      else if(state.type==='shrink') highlightLine=2;\n      else if(state.type==='updateMax') highlightLine=3;\n      codeVar.innerHTML = lines.map((l,i)=> (i===highlightLine? `<span class=\"highlight\">${l}</span>` : l)).join('\\n');\n\n      if(state.type==='done'){\n        varResult.style.display='block';\n        varResult.textContent = `Best length = ${state.maxLen}, substring = '${s.slice(state.maxLeft, state.maxRight+1)}' (indices ${state.maxLeft}..${state.maxRight})`;\n      } else varResult.style.display='none';\n    }\n\n    // Variable controls\n    $('applyStr').addEventListener('click', ()=>{\n      s = strInput.value || '';\n      buildVarSteps();\n      varStepIndex = 0;\n      renderStrViz(0);\n    });\n    $('randStr').addEventListener('click', ()=>{\n      const r = randomString(10);\n      s = r;\n      strInput.value = s;\n      buildVarSteps();\n      varStepIndex = 0;\n      renderStrViz(0);\n    });\n\n    $('stepBtnVar').addEventListener('click', ()=>{\n      stopVarPlay();\n      varStepIndex = clamp(varStepIndex+1, 0, stepsVar.length-1);\n      renderStrViz(varStepIndex);\n    });\n    $('resetBtnVar').addEventListener('click', ()=>{\n      stopVarPlay();\n      varStepIndex = 0;\n      renderStrViz(varStepIndex);\n    });\n    $('fastForwardBtnVar').addEventListener('click', ()=>{\n      stopVarPlay();\n      varStepIndex = stepsVar.length-1;\n      renderStrViz(varStepIndex);\n    });\n    $('playBtnVar').addEventListener('click', ()=>{\n      if(varTimer) stopVarPlay(); else startVarPlay();\n    });\n    function startVarPlay(){\n      $('playBtnVar').textContent = 'Pause';\n      const speed = Number($('speedRangeVar').value);\n      varTimer = setInterval(()=>{\n        varStepIndex++;\n        if(varStepIndex >= stepsVar.length){\n          stopVarPlay();\n          varStepIndex = stepsVar.length-1;\n          renderStrViz(varStepIndex);\n          return;\n        }\n        renderStrViz(varStepIndex);\n      }, speed);\n    }\n    function stopVarPlay(){\n      if(varTimer) clearInterval(varTimer);\n      varTimer = null;\n      $('playBtnVar').textContent = 'Play';\n    }\n    $('speedRangeVar').addEventListener('input', ()=>{\n      if(varTimer){\n        stopVarPlay();\n        startVarPlay();\n      }\n    });\n    function resetVar(){\n      s = strInput.value || '';\n      buildVarSteps();\n      varStepIndex = 0;\n      renderStrViz(0);\n    }\n\n    // init variable demo\n    resetVar();\n\n    // Ensure switching mode updates UI\n    updateModeUI();\n\n    // Make Enter in inputs apply easily\n    arrayInput.addEventListener('keydown', (e)=>{\n      if(e.key==='Enter') $('applyArr').click();\n    });\n    strInput.addEventListener('keydown', (e)=>{\n      if(e.key==='Enter') $('applyStr').click();\n    });\n\n    // Accessibility: announce steps (light)\n    function announce(msg){\n      // update a hidden aria live if needed - currently we update stepInfo textContent which is polite\n      $('stepInfo').textContent = msg;\n    }\n\n    // initial render after load\n    buildFixedSteps();\n    renderArrayVizFixed(0);\n\n  </script>\n</body>\n</html>"
