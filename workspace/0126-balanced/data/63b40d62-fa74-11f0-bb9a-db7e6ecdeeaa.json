    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Dynamic Typing in JavaScript</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2em;\n      background: #f0f4f8;\n      color: #333;\n    }\n    h1 {\n      color: #007acc;\n    }\n    pre {\n      background: #e8eefd;\n      padding: 1em;\n      border-radius: 5px;\n      overflow-x: auto;\n    }\n    .output {\n      background: #d1e7dd;\n      border: 1px solid #badbcc;\n      padding: 1em;\n      margin-top: 1em;\n      border-radius: 5px;\n      font-family: Consolas, monospace;\n      white-space: pre-wrap;\n    }\n    button {\n      background: #007acc;\n      color: white;\n      border: none;\n      padding: 0.5em 1em;\n      font-size: 1em;\n      border-radius: 4px;\n      cursor: pointer;\n      margin-top: 1em;\n    }\n    button:hover {\n      background: #005fa3;\n    }\n  </style>\n</head>\n<body>\n  <h1>JavaScript Dynamic Typing Demonstration</h1>\n  <p>\n    JavaScript is a <strong>dynamically typed</strong> language, which means a variable can hold values of any type, and that type can change at runtime.\n  </p>\n  <pre>\n// Declare a variable with a number\nlet dynamicVar = 42;\nconsole.log(typeof dynamicVar, dynamicVar); // number 42\n\n// Assign a string to the same variable\ndynamicVar = \"Now I'm a string!\";\nconsole.log(typeof dynamicVar, dynamicVar); // string \"Now I'm a string!\"\n\n// Assign a boolean to the same variable\ndynamicVar = true;\nconsole.log(typeof dynamicVar, dynamicVar); // boolean true\n\n// Assign an object to the same variable\ndynamicVar = { message: \"I'm an object now\" };\nconsole.log(typeof dynamicVar, dynamicVar); // object { message: \"I'm an object now\" }\n  </pre>\n  <button id=\"runBtn\">Run Demo</button>\n  <div class=\"output\" id=\"output\"></div>\n\n  <script>\n    const outputEl = document.getElementById(\"output\");\n    const runBtn = document.getElementById(\"runBtn\");\n\n    function runDemo() {\n      outputEl.textContent = \"\"; // clear previous output\n      let dynamicVar;\n\n      function log(type, value) {\n        outputEl.textContent += `${type} ${typeof value} : ${valueToString(value)}\\n`;\n      }\n      function valueToString(val) {\n        if (typeof val === \"object\" && val !== null) {\n          return JSON.stringify(val);\n        }\n        return String(val);\n      }\n\n      dynamicVar = 42;\n      log(\"Initial:\", dynamicVar);\n\n      dynamicVar = \"Now I'm a string!\";\n      log(\"Assigned string:\", dynamicVar);\n\n      dynamicVar = true;\n      log(\"Assigned boolean:\", dynamicVar);\n\n      dynamicVar = { message: \"I'm an object now\" };\n      log(\"Assigned object:\", dynamicVar);\n    }\n\n    runBtn.addEventListener(\"click\", runDemo);\n  </script>\n</body>\n</html>"
