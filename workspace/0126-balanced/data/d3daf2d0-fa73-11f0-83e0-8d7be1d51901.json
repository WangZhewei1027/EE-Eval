  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\"/>\n  <title>Interpreter Pattern — Demo (Boolean Expression Language)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n  <style>\n    :root{font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color:#111}\n    body{margin:0; padding:20px; background:#f7f9fb; color:#111}\n    header{display:flex; gap:12px; align-items:center; margin-bottom:18px}\n    header h1{font-size:18px; margin:0}\n    .container{display:grid; grid-template-columns: 360px 1fr; gap:16px;}\n    .panel{background:#fff; border:1px solid #e2e8f0; padding:14px; border-radius:8px; box-shadow:0 1px 2px rgba(16,24,40,0.03)}\n    label{display:block; font-size:13px; margin:8px 0 6px}\n    textarea, input[type=\"text\"]{width:100%; box-sizing:border-box; font-family:monospace; font-size:13px; padding:8px; border:1px solid #d1d5db; border-radius:6px; background:#fbfdff}\n    button{padding:8px 12px; border-radius:8px; border:1px solid #3b82f6; background:linear-gradient(#3b82f6,#2563eb); color:white; cursor:pointer}\n    .controls{display:flex; gap:8px; align-items:center; margin-top:8px}\n    .small{font-size:13px; color:#475569}\n    pre.code{background:#0f172a; color:#e6edf3; padding:12px; border-radius:6px; overflow:auto; max-height:280px}\n    .row{display:flex; gap:12px}\n    .output-grid{display:grid; grid-template-columns: 1fr 1fr; gap:12px}\n    .tree{font-family:monospace; font-size:13px; line-height:1.5}\n    .node{padding:6px 8px; border-radius:6px; border:1px dashed transparent; display:inline-block; cursor:pointer}\n    .node:hover{border-color:#c7d2fe; background:#f8fafc}\n    .trace{font-family:monospace; font-size:13px; white-space:pre-wrap; max-height:340px; overflow:auto}\n    footer{margin-top:18px; font-size:13px; color:#475569}\n    .result-badge{display:inline-block; padding:6px 10px; border-radius:999px; font-weight:600}\n    .result-true{background:#dcfce7; color:#166534; border:1px solid #bbf7d0}\n    .result-false{background:#fee2e2; color:#7f1d1d; border:1px solid #fecaca}\n    .error{color:#7f1d1d; background:#fff1f2; border:1px solid #fecaca; padding:8px; border-radius:6px}\n    .hint{font-size:13px; color:#475569}\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Interpreter Pattern — Interactive Demo</h1>\n    <div class=\"small\">A tiny boolean expression language: supports variables, AND, OR, NOT, parentheses.</div>\n  </header>\n\n  <div class=\"container\">\n    <div class=\"panel\">\n      <label for=\"vars\">Variables (one per line: name = true|false)</label>\n      <textarea id=\"vars\" rows=\"6\">A = true\nB = false\nC = true</textarea>\n\n      <label for=\"expr\">Expression</label>\n      <input id=\"expr\" type=\"text\" value=\"A AND B OR NOT C\" />\n\n      <div class=\"controls\">\n        <button id=\"evalBtn\">Evaluate</button>\n        <button id=\"exampleBtn\">Load Examples</button>\n        <div style=\"margin-left:auto\" class=\"hint\">Tokens: AND OR NOT ( ) TRUE FALSE variableNames</div>\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <div class=\"small\">Result</div>\n        <div id=\"resultArea\" style=\"margin-top:8px\"></div>\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <div class=\"small\">Messages</div>\n        <div id=\"message\" style=\"margin-top:8px\"></div>\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <div class=\"small\">Quick explanation</div>\n        <div class=\"small\" style=\"margin-top:6px\">\n          This demo implements the Interpreter pattern:\n          <ul style=\"margin:6px 0 0 18px; padding:0\">\n            <li>Context holds variable values.</li>\n            <li>Expression objects (Terminal & Non-Terminal) implement interpret(context).</li>\n            <li>Parser builds an AST from text, then the root.interpret(context) evaluates it.</li>\n          </ul>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <div style=\"display:flex; gap:12px; align-items:center; margin-bottom:10px\">\n        <div style=\"font-weight:700\">AST (click nodes to see sub-evaluation)</div>\n        <div class=\"small\" style=\"color:#475569\">and Trace</div>\n      </div>\n\n      <div class=\"output-grid\">\n        <div style=\"min-height:160px\">\n          <div class=\"small\">Abstract Syntax Tree</div>\n          <div id=\"ast\" class=\"tree\" style=\"margin-top:8px; padding:8px; border-radius:6px; border:1px dashed #e6eef8; min-height:140px\"></div>\n        </div>\n\n        <div>\n          <div class=\"small\">Interpretation Trace (top-down)</div>\n          <div id=\"trace\" class=\"trace\" style=\"margin-top:8px; padding:8px; border-radius:6px; border:1px dashed #e6eef8\">No evaluation yet.</div>\n        </div>\n      </div>\n\n      <hr style=\"margin:12px 0\"/>\n\n      <div>\n        <div class=\"small\">Implementation (key parts)</div>\n        <pre class=\"code\" id=\"sourceCode\">\n/* Expression base */\nclass Expression {\n  interpret(context){ throw 'abstract'; }\n}\n\n/* Terminal expressions */\nclass VariableExpression extends Expression {\n  constructor(name){super(); this.name=name;}\n  interpret(ctx){ return ctx.get(this.name); }\n}\nclass ConstantExpression extends Expression {\n  constructor(value){super(); this.value=value;}\n  interpret(ctx){ return this.value; }\n}\n\n/* Non-terminals */\nclass AndExpression extends Expression {\n  constructor(a,b){super(); this.a=a; this.b=b; }\n  interpret(ctx){ return this.a.interpret(ctx) && this.b.interpret(ctx); }\n}\nclass OrExpression extends Expression {\n  constructor(a,b){super(); this.a=a; this.b=b; }\n  interpret(ctx){ return this.a.interpret(ctx) || this.b.interpret(ctx); }\n}\nclass NotExpression extends Expression {\n  constructor(expr){super(); this.expr=expr; }\n  interpret(ctx){ return !this.expr.interpret(ctx); }\n}\n\n/* Context: variable storage */\nclass Context {\n  constructor(vars){ this.vars = vars; }\n  get(name){ if(!(name in this.vars)) throw 'Unknown variable '+name; return !!this.vars[name]; }\n}\n        </pre>\n      </div>\n    </div>\n  </div>\n\n  <footer>\n    Implementation note: this demo uses a simple tokenizer + recursive-descent parser to build the AST; each Expression implements interpret(context) — the heart of the Interpreter pattern.\n  </footer>\n\n<script>\n/*\n  Interpreter pattern demo implementation in JavaScript.\n  Language: boolean expressions with AND, OR, NOT, parentheses, TRUE, FALSE, variables.\n*/\n\n/* === Tokenizer === */\nfunction tokenize(input){\n  const tokens = [];\n  const re = /\\s*([A-Za-z_][A-Za-z0-9_]*|\\(|\\))/g;\n  let m;\n  let idx = 0;\n  while(idx < input.length){\n    // skip whitespace\n    if(/\\s/.test(input[idx])) { idx++; continue; }\n    // parentheses\n    const ch = input[idx];\n    if(ch === '(' || ch === ')'){\n      tokens.push({type: ch, value: ch}); idx++; continue;\n    }\n    // identifiers/keywords\n    const idMatch = /^[A-Za-z_][A-Za-z0-9_]*/.exec(input.slice(idx));\n    if(idMatch){\n      const raw = idMatch[0];\n      tokens.push({type: 'IDENT', value: raw});\n      idx += raw.length;\n      continue;\n    }\n    // unrecognized char\n    throw new Error(\"Unexpected character: \" + input[idx]);\n  }\n  // Normalize keywords\n  return tokens.map(t=>{\n    if(t.type === 'IDENT'){\n      const u = t.value.toUpperCase();\n      if(u === 'AND' || u === 'OR' || u === 'NOT' || u === 'TRUE' || u === 'FALSE'){\n        return {type: u, value: t.value};\n      }\n      return {type: 'VAR', value: t.value};\n    }\n    return t;\n  });\n}\n\n/* === Parser (recursive descent) ===\n   Grammar:\n   Expression := Term ( OR Term )*\n   Term       := Factor ( AND Factor )*\n   Factor     := NOT Factor | '(' Expression ')' | TRUE | FALSE | VAR\n*/\nfunction parse(tokens){\n  let i = 0;\n  function peek(){ return tokens[i] || null; }\n  function consume(expected){\n    const t = tokens[i];\n    if(!t) throw new Error(\"Unexpected end, expected \" + expected);\n    if(expected && t.type !== expected) throw new Error(\"Expected \" + expected + \" but got \" + t.type);\n    i++;\n    return t;\n  }\n\n  function parseExpression(){\n    let node = parseTerm();\n    while(peek() && peek().type === 'OR'){\n      consume('OR');\n      const right = parseTerm();\n      node = new OrExpression(node, right);\n    }\n    return node;\n  }\n\n  function parseTerm(){\n    let node = parseFactor();\n    while(peek() && peek().type === 'AND'){\n      consume('AND');\n      const right = parseFactor();\n      node = new AndExpression(node, right);\n    }\n    return node;\n  }\n\n  function parseFactor(){\n    const t = peek();\n    if(!t) throw new Error(\"Unexpected end in factor\");\n    if(t.type === 'NOT'){\n      consume('NOT');\n      const inner = parseFactor();\n      return new NotExpression(inner);\n    }\n    if(t.type === '('){\n      consume('(');\n      const inner = parseExpression();\n      consume(')');\n      return inner;\n    }\n    if(t.type === 'TRUE'){\n      consume('TRUE'); return new ConstantExpression(true);\n    }\n    if(t.type === 'FALSE'){\n      consume('FALSE'); return new ConstantExpression(false);\n    }\n    if(t.type === 'VAR'){\n      consume('VAR'); return new VariableExpression(t.value);\n    }\n    throw new Error(\"Unexpected token in factor: \" + t.type);\n  }\n\n  const root = parseExpression();\n  if(i < tokens.length) throw new Error(\"Extra tokens after parse\");\n  return root;\n}\n\n/* === Interpreter classes === */\nclass Expression {\n  interpret(ctx, trace){ throw new Error('abstract'); }\n}\nclass VariableExpression extends Expression {\n  constructor(name){ super(); this.name = name; }\n  interpret(ctx, trace){\n    const val = ctx.get(this.name);\n    trace.push(`VariableExpression(${this.name}) => ${val}`);\n    return val;\n  }\n  toString(){ return this.name; }\n}\nclass ConstantExpression extends Expression {\n  constructor(value){ super(); this.value = !!value; }\n  interpret(ctx, trace){\n    trace.push(`ConstantExpression(${this.value}) => ${this.value}`);\n    return this.value;\n  }\n  toString(){ return this.value ? 'TRUE' : 'FALSE'; }\n}\nclass AndExpression extends Expression {\n  constructor(a,b){ super(); this.a = a; this.b = b; }\n  interpret(ctx, trace){\n    trace.push(`AndExpression: evaluating left of (${this.toString()})`);\n    const av = this.a.interpret(ctx, trace);\n    trace.push(`AndExpression: left => ${av}`);\n    if(!av){\n      trace.push(`AndExpression: short-circuit, result => false`);\n      return false;\n    }\n    trace.push(`AndExpression: evaluating right of (${this.toString()})`);\n    const bv = this.b.interpret(ctx, trace);\n    trace.push(`AndExpression: right => ${bv}`);\n    const res = av && bv;\n    trace.push(`AndExpression(${this.toString()}) => ${res}`);\n    return res;\n  }\n  toString(){ return `(${this.a.toString()} AND ${this.b.toString()})`; }\n}\nclass OrExpression extends Expression {\n  constructor(a,b){ super(); this.a = a; this.b = b; }\n  interpret(ctx, trace){\n    trace.push(`OrExpression: evaluating left of (${this.toString()})`);\n    const av = this.a.interpret(ctx, trace);\n    trace.push(`OrExpression: left => ${av}`);\n    if(av){\n      trace.push(`OrExpression: short-circuit, result => true`);\n      return true;\n    }\n    trace.push(`OrExpression: evaluating right of (${this.toString()})`);\n    const bv = this.b.interpret(ctx, trace);\n    trace.push(`OrExpression: right => ${bv}`);\n    const res = av || bv;\n    trace.push(`OrExpression(${this.toString()}) => ${res}`);\n    return res;\n  }\n  toString(){ return `(${this.a.toString()} OR ${this.b.toString()})`; }\n}\nclass NotExpression extends Expression {\n  constructor(expr){ super(); this.expr = expr; }\n  interpret(ctx, trace){\n    trace.push(`NotExpression: evaluating inner of (${this.toString()})`);\n    const v = this.expr.interpret(ctx, trace);\n    const res = !v;\n    trace.push(`NotExpression(${this.toString()}) => ${res}`);\n    return res;\n  }\n  toString(){ return `(NOT ${this.expr.toString()})`; }\n}\n\n/* Context holds variable values */\nclass Context {\n  constructor(map){ this.map = map || {}; }\n  get(name){\n    if(!(name in this.map)) throw new Error(\"Unknown variable: \" + name);\n    // ensure boolean\n    return !!this.map[name];\n  }\n}\n\n/* === UI wiring === */\nconst varsEl = document.getElementById('vars');\nconst exprEl = document.getElementById('expr');\nconst evalBtn = document.getElementById('evalBtn');\nconst exampleBtn = document.getElementById('exampleBtn');\nconst astEl = document.getElementById('ast');\nconst traceEl = document.getElementById('trace');\nconst resultArea = document.getElementById('resultArea');\nconst messageEl = document.getElementById('message');\n\nfunction parseVars(text){\n  const lines = text.split(/\\r?\\n/).map(s=>s.trim()).filter(s=>s.length);\n  const map = {};\n  for(const line of lines){\n    const m = line.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(true|false)$/i);\n    if(!m) throw new Error(\"Invalid variable line: \" + line);\n    map[m[1]] = m[2].toLowerCase() === 'true';\n  }\n  return map;\n}\n\nfunction clearOutputs(){\n  astEl.innerHTML = '';\n  traceEl.textContent = 'No evaluation yet.';\n  resultArea.innerHTML = '';\n  messageEl.innerHTML = '';\n}\n\nfunction buildTreeDom(expr){\n  // Represent AST as nested spans; clickable to show eval of subnode\n  function nodeFor(e){\n    const span = document.createElement('span');\n    span.className = 'node';\n    span.textContent = (e.toString ? e.toString() : String(e));\n    span.title = e.constructor.name;\n    span.addEventListener('click', (ev)=>{\n      ev.stopPropagation();\n      // Evaluate only that node with same context but fresh trace\n      try {\n        const vars = parseVars(varsEl.value);\n        const ctx = new Context(vars);\n        const traceLines = [];\n        const val = e.interpret(ctx, traceLines);\n        traceEl.textContent = traceLines.join('\\n');\n        const badge = document.createElement('span');\n        badge.className = 'result-badge ' + (val ? 'result-true' : 'result-false');\n        badge.textContent = String(val);\n        resultArea.innerHTML = '';\n        resultArea.appendChild(badge);\n        messageEl.innerHTML = `<div class=\"small\">Evaluated node: <strong>${span.textContent}</strong></div>`;\n      } catch(err){\n        traceEl.textContent = '';\n        resultArea.innerHTML = '';\n        messageEl.innerHTML = `<div class=\"error\">${err.message}</div>`;\n      }\n    });\n    // If non-terminal, recursively add children below\n    const wrapper = document.createElement('div');\n    wrapper.style.margin = '6px 0';\n    wrapper.appendChild(span);\n    // simple inspect\n    if(e instanceof AndExpression || e instanceof OrExpression){\n      const sub = document.createElement('div');\n      sub.style.marginLeft = '14px';\n      sub.appendChild(nodeFor(e.a));\n      sub.appendChild(document.createTextNode(' '));\n      sub.appendChild(nodeFor(e.b));\n      wrapper.appendChild(sub);\n    } else if(e instanceof NotExpression){\n      const sub = document.createElement('div');\n      sub.style.marginLeft = '14px';\n      sub.appendChild(nodeFor(e.expr));\n      wrapper.appendChild(sub);\n    }\n    return wrapper;\n  }\n  return nodeFor(expr);\n}\n\nevalBtn.addEventListener('click', ()=>{\n  clearOutputs();\n  const exprText = exprEl.value.trim();\n  if(!exprText){ messageEl.innerHTML = `<div class=\"error\">Expression is empty.</div>`; return; }\n  let tokens;\n  try {\n    tokens = tokenize(exprText);\n  } catch(err){\n    messageEl.innerHTML = `<div class=\"error\">Tokenize error: ${err.message}</div>`;\n    return;\n  }\n  let ast;\n  try {\n    ast = parse(tokens);\n  } catch(err){\n    messageEl.innerHTML = `<div class=\"error\">Parse error: ${err.message}</div>`;\n    return;\n  }\n  // show AST\n  astEl.appendChild(buildTreeDom(ast));\n\n  // Evaluate root\n  let vars;\n  try{\n    vars = parseVars(varsEl.value);\n  } catch(err){\n    messageEl.innerHTML = `<div class=\"error\">${err.message}</div>`;\n    return;\n  }\n  const ctx = new Context(vars);\n  const trace = [];\n  try{\n    const val = ast.interpret(ctx, trace);\n    traceEl.textContent = trace.join('\\n');\n    const badge = document.createElement('span');\n    badge.className = 'result-badge ' + (val ? 'result-true' : 'result-false');\n    badge.textContent = String(val);\n    resultArea.innerHTML = '';\n    resultArea.appendChild(badge);\n    messageEl.innerHTML = `<div class=\"small\">Root expression evaluated. Click any AST node for focused evaluation.</div>`;\n  } catch(err){\n    messageEl.innerHTML = `<div class=\"error\">${err.message}</div>`;\n    traceEl.textContent = trace.join('\\n');\n  }\n});\n\n// fill examples\nexampleBtn.addEventListener('click', ()=>{\n  const examples = [\n    {vars: \"A = true\\nB = false\\nC = true\", expr: \"A AND B OR NOT C\"},\n    {vars: \"X = false\\nY = false\\nZ = true\", expr: \"NOT (X OR Y) AND Z\"},\n    {vars: \"P = true\\nQ = true\", expr: \"P AND (Q OR NOT P)\"},\n    {vars: \"T = true\\nF = false\", expr: \"NOT NOT T OR F\"}\n  ];\n  const ex = examples[Math.floor(Math.random()*examples.length)];\n  varsEl.value = ex.vars;\n  exprEl.value = ex.expr;\n  clearOutputs();\n});\n\n// initial evaluation on load for demo\nsetTimeout(()=>{ evalBtn.click(); }, 200);\n</script>\n</body>\n</html>"
  },
