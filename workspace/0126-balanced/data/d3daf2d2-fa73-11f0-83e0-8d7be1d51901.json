    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Garbage Collection Demo (Mark-and-Sweep)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{ --bg:#0f1724; --panel:#0b1220; --muted:#9aa7b8; --accent:#6ee7b7; --accent2:#60a5fa; --danger:#fb7185; }\n    html,body{ height:100%; margin:0; font-family:Inter,Roboto,Segoe UI,Helvetica,Arial; background:linear-gradient(180deg,#071021 0%, #07131b 100%); color:#dbeafe; }\n    .app{ display:flex; gap:12px; padding:14px; box-sizing:border-box; height:100%; }\n    .side { width:320px; background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent); border:1px solid rgba(255,255,255,0.03); padding:12px; border-radius:8px; box-shadow:0 6px 18px rgba(2,6,23,0.6); overflow:auto; }\n    .main { flex:1; display:flex; flex-direction:column; gap:12px; }\n    h2{ margin:6px 0 10px 0; font-size:16px; color:#e6eef8; }\n    .controls button, .controls select, .controls input { background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.04); color:var(--muted); padding:8px 10px; border-radius:6px; margin:6px 4px 6px 0; cursor:pointer; }\n    .controls button:hover{ border-color:rgba(255,255,255,0.08); color:#fff; }\n    .row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }\n    .status { display:flex; gap:8px; align-items:center; margin-bottom:8px; }\n    .stat { background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); padding:8px 10px; border-radius:8px; border:1px solid rgba(255,255,255,0.02); min-width:60px; text-align:center; }\n    .stat .label{ font-size:11px; color:var(--muted); } .stat .value{ font-weight:700; font-size:14px; color:#e6fdf2; }\n    #viewport { background:linear-gradient(160deg,#061224 0%, #07111a 100%); border-radius:10px; border:1px solid rgba(255,255,255,0.03); flex:1; position:relative; overflow:hidden; }\n    svg{ width:100%; height:100%; display:block; }\n    .legend { font-size:12px; color:var(--muted); margin-top:8px; }\n    .log { background:rgba(255,255,255,0.01); border-radius:8px; padding:8px; font-family:monospace; font-size:12px; color:var(--muted); max-height:160px; overflow:auto; }\n    .small{ font-size:12px; color:var(--muted); }\n    .btn-danger{ background:linear-gradient(90deg,#b91c1c,#ef4444); color:white; border:none; }\n    .controls .select-obj { width:160px; }\n    .controls label{ font-size:12px; color:var(--muted); margin-right:6px; }\n    .node-label { pointer-events:none; font-size:11px; fill:#e6eef8; text-anchor:middle; dominant-baseline:middle; }\n    .edge { stroke:rgba(255,255,255,0.08); stroke-width:2; marker-end:url(#arrow); }\n    .node { stroke:rgba(255,255,255,0.06); stroke-width:1.5; cursor:pointer; }\n    .node.reachable { fill:linear-gradient(90deg,#65f6c8,#60a5fa); }\n    .node.reachable circle{ stroke:#6ee7b7; }\n    .node.garbage circle{ fill:rgba(255,255,255,0.02); stroke:#566;\n    }\n    .node.marking circle{ stroke:#ffd166; stroke-width:3; }\n    .root-pill { display:inline-block; padding:6px 8px; border-radius:999px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.03); color:var(--muted); margin-right:6px; font-size:12px; }\n    .example-btn{ background:linear-gradient(90deg,#0ea5e9,#6366f1); color:white; border:none; padding:8px 10px; border-radius:6px; margin:6px 4px 6px 0; cursor:pointer; }\n    .footer-note{ font-size:12px; color:var(--muted); margin-top:8px; }\n    a.inline{ color:var(--accent2); text-decoration:none; }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <div class=\"side\">\n      <h2>Controls</h2>\n      <div class=\"controls\">\n        <div class=\"row\">\n          <label>Create object:</label>\n          <input id=\"objName\" placeholder=\"name (optional)\" />\n          <select id=\"objSize\">\n            <option value=\"1\">1 KB</option>\n            <option value=\"4\" selected>4 KB</option>\n            <option value=\"16\">16 KB</option>\n            <option value=\"64\">64 KB</option>\n          </select>\n          <button id=\"allocBtn\">Allocate</button>\n        </div>\n\n        <div class=\"row\" style=\"margin-top:6px;\">\n          <label>Make reference:</label>\n          <select id=\"fromSel\" class=\"select-obj\"></select>\n          <select id=\"toSel\" class=\"select-obj\"></select>\n          <button id=\"linkBtn\">→ Add ref</button>\n          <button id=\"unlinkBtn\">× Remove ref</button>\n        </div>\n\n        <div class=\"row\" style=\"margin-top:6px;\">\n          <label>Roots:</label>\n          <button id=\"rootGlobal\" class=\"root-pill\">Global</button>\n          <button id=\"rootDOM\" class=\"root-pill\">DOM</button>\n          <button id=\"rootStack\" class=\"root-pill\">Stack</button>\n        </div>\n\n        <div class=\"row\" style=\"margin-top:6px;\">\n          <button id=\"simulateBtn\" style=\"background:linear-gradient(90deg,#22c55e,#06b6d4); color:white; border:none;\">Simulate GC (Mark)</button>\n          <button id=\"sweepBtn\" style=\"background:linear-gradient(90deg,#ef4444,#fb7185); color:white; border:none;\">Sweep (free unreachable)</button>\n          <button id=\"resetBtn\" class=\"btn-danger\">Reset</button>\n        </div>\n\n        <h2 style=\"margin-top:12px;\">Memory</h2>\n        <div class=\"status\">\n          <div class=\"stat\"><div class=\"label\">Objects</div><div id=\"stat-objects\" class=\"value\">0</div></div>\n          <div class=\"stat\"><div class=\"label\">Total KB</div><div id=\"stat-total\" class=\"value\">0</div></div>\n          <div class=\"stat\"><div class=\"label\">Reachable KB</div><div id=\"stat-reachable\" class=\"value\">0</div></div>\n          <div class=\"stat\"><div class=\"label\">Garbage KB</div><div id=\"stat-garbage\" class=\"value\">0</div></div>\n        </div>\n\n        <h2>Examples</h2>\n        <div class=\"row\">\n          <button id=\"ex-closure\" class=\"example-btn\">Closure capture (retain)</button>\n          <button id=\"ex-dom-leak\" class=\"example-btn\">DOM leak (detached)</button>\n          <button id=\"ex-timer\" class=\"example-btn\">Timer leak (setInterval)</button>\n        </div>\n\n        <h2>Log</h2>\n        <div id=\"log\" class=\"log\"></div>\n\n        <div class=\"footer-note\">\n          This is a simulation of mark-and-sweep GC. Real JS engines use generational and incremental collectors and you can't reliably force GC from web pages. Use browser devtools to inspect memory.\n        </div>\n      </div>\n    </div>\n\n    <div class=\"main\">\n      <div id=\"viewport\">\n        <svg id=\"svg\"></svg>\n      </div>\n\n      <div class=\"side\" style=\"margin-top:12px; max-height:240px;\">\n        <h2>How it works (brief)</h2>\n        <div class=\"small\">\n          - Roots (Global, DOM, Stack) are starting points the collector uses. Any object reachable from roots is \"live\".<br/>\n          - Mark phase: traverse references from roots and mark reachable objects.<br/>\n          - Sweep phase: unmarked objects are considered garbage and can be reclaimed.<br/>\n          - Common causes of leaks: closures that keep references, timers/event listeners not cleared, global references or DOM nodes still referenced in JS.\n        </div>\n\n        <h2 style=\"margin-top:10px;\">Interaction tips</h2>\n        <div class=\"small\">\n          - Allocate objects, create references between them, then click \"Simulate GC\" to mark reachable objects. Unmarked ones appear dimmed.<br/>\n          - Click \"Sweep\" to free garbage (removes them from the heap).<br/>\n          - Use examples to quickly create typical leak scenarios.\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Simple garbage collector simulation (Mark-and-Sweep).\n    (function(){\n      // Model\n      let nextId = 1;\n      const heap = new Map(); // id -> node\n      const roots = {\n        Global: new Set(), // persistent root\n        DOM: new Set(),\n        Stack: new Set()\n      };\n\n      // DOM\n      const svg = document.getElementById('svg');\n      const allocBtn = document.getElementById('allocBtn');\n      const objSize = document.getElementById('objSize');\n      const objName = document.getElementById('objName');\n      const fromSel = document.getElementById('fromSel');\n      const toSel = document.getElementById('toSel');\n      const linkBtn = document.getElementById('linkBtn');\n      const unlinkBtn = document.getElementById('unlinkBtn');\n      const simulateBtn = document.getElementById('simulateBtn');\n      const sweepBtn = document.getElementById('sweepBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const statObjects = document.getElementById('stat-objects');\n      const statTotal = document.getElementById('stat-total');\n      const statReach = document.getElementById('stat-reachable');\n      const statGarbage = document.getElementById('stat-garbage');\n      const logEl = document.getElementById('log');\n      const rootGlobal = document.getElementById('rootGlobal');\n      const rootDOM = document.getElementById('rootDOM');\n      const rootStack = document.getElementById('rootStack');\n      const exClosure = document.getElementById('ex-closure');\n      const exDomLeak = document.getElementById('ex-dom-leak');\n      const exTimer = document.getElementById('ex-timer');\n\n      // Visual layout\n      const WIDTH = 1200, HEIGHT = 560;\n      svg.setAttribute('viewBox', `0 0 ${WIDTH} ${HEIGHT}`);\n\n      // Arrow marker\n      svg.innerHTML = `\n        <defs>\n          <marker id=\"arrow\" viewBox=\"0 0 10 10\" refX=\"10\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto\">\n            <path d=\"M 0 0 L 10 5 L 0 10 z\" fill=\"rgba(255,255,255,0.08)\"></path>\n          </marker>\n        </defs>\n      `;\n\n      function log(msg){\n        const time = new Date().toLocaleTimeString();\n        logEl.innerHTML = '['+time+'] ' + msg + '\\n' + logEl.innerHTML;\n      }\n\n      function createObject(name = '', sizeKB = 4, type='Object'){\n        const id = nextId++;\n        const node = {\n          id, name: name || `obj${id}`,\n          sizeKB: +sizeKB,\n          edges: new Set(), // references to other ids\n          x: 80 + Math.random()*(WIDTH-160),\n          y: 40 + Math.random()*(HEIGHT-80),\n          marked: false,\n          type\n        };\n        heap.set(id, node);\n        updateSelectors();\n        draw();\n        log(`Allocated ${node.name} (${node.sizeKB} KB)`);\n        return node;\n      }\n\n      function deleteObject(id){\n        if(!heap.has(id)) return;\n        // Remove all incoming references\n        for(const n of heap.values()){\n          if(n.edges.has(id)) n.edges.delete(id);\n        }\n        // Remove from roots\n        for(const r of Object.keys(roots)){ roots[r].delete(id); }\n        heap.delete(id);\n      }\n\n      function updateSelectors(){\n        const items = [...heap.values()];\n        function build(sel){\n          sel.innerHTML = '';\n          const placeholder = document.createElement('option');\n          placeholder.value = '';\n          placeholder.text = '-- none --';\n          sel.appendChild(placeholder);\n          for(const n of items){\n            const opt = document.createElement('option');\n            opt.value = n.id;\n            opt.text = `${n.name} (id:${n.id}, ${n.sizeKB}KB)`;\n            sel.appendChild(opt);\n          }\n        }\n        build(fromSel); build(toSel);\n        updateStats();\n      }\n\n      function updateStats(){\n        let total = 0, reachable = 0;\n        for(const n of heap.values()){\n          total += n.sizeKB;\n          if(n.marked) reachable += n.sizeKB;\n        }\n        const garbage = total - reachable;\n        statObjects.textContent = heap.size;\n        statTotal.textContent = total;\n        statReach.textContent = reachable;\n        statGarbage.textContent = garbage;\n      }\n\n      function addReference(fromId, toId){\n        const from = heap.get(+fromId);\n        const to = heap.get(+toId);\n        if(!from || !to) return;\n        from.edges.add(to.id);\n        draw();\n        log(`Reference added: ${from.name} → ${to.name}`);\n      }\n\n      function removeReference(fromId, toId){\n        const from = heap.get(+fromId);\n        const to = heap.get(+toId);\n        if(!from || !to) return;\n        from.edges.delete(to.id);\n        draw();\n        log(`Reference removed: ${from.name} -X→ ${to.name}`);\n      }\n\n      // Draw\n      function draw(){\n        // Clear except defs\n        const defs = svg.querySelector('defs');\n        svg.innerHTML = '';\n        svg.appendChild(defs);\n\n        // draw edges first\n        for(const n of heap.values()){\n          for(const toId of n.edges){\n            const to = heap.get(toId);\n            if(!to) continue;\n            const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n            line.setAttribute('x1', n.x);\n            line.setAttribute('y1', n.y);\n            line.setAttribute('x2', to.x);\n            line.setAttribute('y2', to.y);\n            line.setAttribute('class', 'edge');\n            svg.appendChild(line);\n          }\n        }\n\n        // draw nodes\n        for(const n of heap.values()){\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          g.setAttribute('transform', `translate(${n.x},${n.y})`);\n          g.setAttribute('data-id', n.id);\n          g.classList.add('node');\n          if(n.marked) g.classList.add('reachable');\n          else g.classList.add('garbage');\n\n          const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n          circle.setAttribute('r', 24);\n          circle.setAttribute('fill', n.marked ? 'url(#grad)' : 'rgba(255,255,255,0.02)');\n          circle.setAttribute('stroke', n.marked ? '#6ee7b7' : '#3b5366');\n          circle.setAttribute('stroke-width', n.marked ? '2.5' : '1.2');\n\n          const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n          text.setAttribute('class','node-label');\n          text.textContent = `${n.name}\\n${n.sizeKB}KB`;\n          // SVG text doesn't support newline easily, so do two lines\n          const t1 = document.createElementNS('http://www.w3.org/2000/svg','text');\n          t1.setAttribute('class','node-label');\n          t1.setAttribute('y', -6);\n          t1.textContent = `${n.name}`;\n          const t2 = document.createElementNS('http://www.w3.org/2000/svg','text');\n          t2.setAttribute('class','node-label');\n          t2.setAttribute('y', 10);\n          t2.setAttribute('font-size','10');\n          t2.textContent = `${n.sizeKB}KB`;\n\n          g.appendChild(circle);\n          g.appendChild(t1);\n          g.appendChild(t2);\n\n          // clickable to toggle root membership (Stack)\n          g.addEventListener('click', ()=> {\n            // toggle stack root membership for selected node\n            if(roots.Stack.has(n.id)){\n              roots.Stack.delete(n.id);\n              log(`Removed ${n.name} from Stack root`);\n            } else {\n              roots.Stack.add(n.id);\n              log(`Added ${n.name} to Stack root`);\n            }\n            // visual marker: small ring\n            draw();\n            drawRoots();\n          });\n\n          svg.appendChild(g);\n        }\n\n        drawRoots();\n        updateStats();\n      }\n\n      function drawRoots(){\n        // small labels for roots and arrows to objects they point to\n        // remove previous root labels\n        // draw root labels on top-left area\n        const rootAreaX = 12, rootAreaY = 12;\n        let idx = 0;\n        for(const key of Object.keys(roots)){\n          const set = roots[key];\n          const rx = rootAreaX + idx*120;\n          const ry = rootAreaY;\n          // root label\n          const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n          g.setAttribute('transform', `translate(${rx},${ry})`);\n          const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n          rect.setAttribute('width', 100); rect.setAttribute('height', 26);\n          rect.setAttribute('rx', 6); rect.setAttribute('ry', 6);\n          rect.setAttribute('fill','rgba(255,255,255,0.02)');\n          rect.setAttribute('stroke','rgba(255,255,255,0.03)');\n          const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n          label.setAttribute('x', 50);\n          label.setAttribute('y', 17);\n          label.setAttribute('text-anchor','middle');\n          label.setAttribute('fill','#9aa7b8');\n          label.setAttribute('font-size','12');\n          label.textContent = key;\n          g.appendChild(rect);\n          g.appendChild(label);\n          svg.appendChild(g);\n\n          // draw small arrows to objects\n          let j = 0;\n          for(const id of set){\n            const target = heap.get(id);\n            if(!target) continue;\n            const x1 = rx+50;\n            const y1 = ry+26;\n            const x2 = target.x;\n            const y2 = target.y - 24;\n            const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n            line.setAttribute('x1', x1); line.setAttribute('y1', y1); line.setAttribute('x2', x2); line.setAttribute('y2', y2);\n            line.setAttribute('stroke','rgba(255,255,255,0.08)');\n            line.setAttribute('stroke-width','2');\n            line.setAttribute('marker-end','url(#arrow)');\n            svg.appendChild(line);\n            j++;\n          }\n\n          idx++;\n        }\n      }\n\n      // MARK phase (animated)\n      let marking = false;\n      async function simulateMark(){\n        // clear previous marks\n        for(const n of heap.values()) n.marked = false;\n        draw(); log('Starting mark phase...');\n        marking = true;\n\n        const queue = [];\n        for(const r of Object.keys(roots)){\n          for(const id of roots[r]) {\n            const node = heap.get(id);\n            if(node && !node.marked){\n              node.marked = true;\n              queue.push(node);\n            }\n          }\n        }\n\n        // animate marking BFS\n        while(queue.length && marking){\n          const cur = queue.shift();\n          // highlight node temporarily\n          highlightNode(cur.id, 'marking');\n          log(`Marked ${cur.name}`);\n          await sleep(300);\n          // traverse edges\n          for(const toId of cur.edges){\n            const to = heap.get(toId);\n            if(to && !to.marked){\n              to.marked = true;\n              queue.push(to);\n            }\n          }\n          draw(); // refresh to show reachable styling\n          await sleep(120);\n        }\n        marking = false;\n        log('Mark phase complete. Reachable objects are highlighted.');\n        updateStats();\n      }\n\n      function highlightNode(id, cls){\n        const g = svg.querySelector(`g[data-id='${id}']`);\n        if(!g) return;\n        g.classList.add(cls);\n        setTimeout(()=> g.classList.remove(cls), 800);\n      }\n\n      function sweep(){\n        const toDelete = [];\n        for(const [id,n] of heap.entries()){\n          if(!n.marked) toDelete.push(id);\n        }\n        if(toDelete.length === 0){\n          log('Sweep: nothing to free.');\n          return;\n        }\n        for(const id of toDelete){\n          const n = heap.get(id);\n          deleteObject(id);\n          log(`Freed ${n.name} (${n.sizeKB} KB)`);\n        }\n        draw();\n      }\n\n      function sleep(ms){ return new Promise(r=>setTimeout(r, ms)); }\n\n      // Event listeners\n      allocBtn.addEventListener('click', ()=>{\n        const n = createObject(objName.value.trim(), objSize.value);\n        objName.value = '';\n      });\n\n      linkBtn.addEventListener('click', ()=>{\n        const from = fromSel.value;\n        const to = toSel.value;\n        if(!from || !to){ alert('Select both from/to'); return; }\n        addReference(from,to);\n      });\n\n      unlinkBtn.addEventListener('click', ()=>{\n        const from = fromSel.value;\n        const to = toSel.value;\n        if(!from || !to){ alert('Select both from/to'); return; }\n        removeReference(from,to);\n      });\n\n      simulateBtn.addEventListener('click', ()=>{\n        simulateMark();\n      });\n\n      sweepBtn.addEventListener('click', ()=>{\n        sweep();\n      });\n\n      resetBtn.addEventListener('click', ()=>{\n        if(!confirm('Reset heap?')) return;\n        heap.clear();\n        nextId = 1;\n        roots.Global.clear(); roots.DOM.clear(); roots.Stack.clear();\n        log('Heap reset.');\n        updateSelectors();\n        draw();\n      });\n\n      rootGlobal.addEventListener('click', ()=>{\n        // toggles the Global root membership of the selected object in fromSel\n        const sel = fromSel.value;\n        if(!sel){ alert('Select an object (use the left dropdown)'); return; }\n        const id = +sel;\n        if(roots.Global.has(id)){ roots.Global.delete(id); log(`Removed ${heap.get(id).name} from Global root`); }\n        else { roots.Global.add(id); log(`Added ${heap.get(id).name} to Global root`); }\n        drawRoots(); draw();\n      });\n\n      rootDOM.addEventListener('click', ()=>{\n        const sel = fromSel.value;\n        if(!sel){ alert('Select an object (use the left dropdown)'); return; }\n        const id = +sel;\n        if(roots.DOM.has(id)){ roots.DOM.delete(id); log(`Removed ${heap.get(id).name} from DOM root`); }\n        else { roots.DOM.add(id); log(`Added ${heap.get(id).name} to DOM root`); }\n        drawRoots(); draw();\n      });\n\n      rootStack.addEventListener('click', ()=>{\n        const sel = fromSel.value;\n        if(!sel){ alert('Select an object (use the left dropdown)'); return; }\n        const id = +sel;\n        if(roots.Stack.has(id)){ roots.Stack.delete(id); log(`Removed ${heap.get(id).name} from Stack root`); }\n        else { roots.Stack.add(id); log(`Added ${heap.get(id).name} to Stack root`); }\n        drawRoots(); draw();\n      });\n\n      // Examples\n      exClosure.addEventListener('click', ()=>{\n        // Simulate: function (closure) captures a large variable object so it stays reachable even if function goes out of scope\n        const big = createObject('largeArray', 64, 'Array');\n        const fn = createObject('closureFn', 1, 'Function');\n        // fn -> big (closure captures)\n        fn.edges.add(big.id);\n        // place fn in Global root (e.g. assigned to window.someFn)\n        roots.Global.add(fn.id);\n        draw(); log('Created closureFn that captures largeArray and added to Global. Even after \"stack\" loses it, the closure retains largeArray.');\n      });\n\n      exDomLeak.addEventListener('click', ()=>{\n        // Simulate DOM node that gets removed from DOM root but JS still holds a reference (leak).\n        const domNode = createObject('divNode', 4, 'DOMNode');\n        roots.DOM.add(domNode.id); // mounted in DOM\n        // create a handler object that references domNode\n        const handler = createObject('handler', 1, 'Function');\n        handler.edges.add(domNode.id);\n        // remove domNode from DOM root (simulate detach)\n        roots.DOM.delete(domNode.id);\n        // but keep handler in Global, so domNode is still reachable via handler -> leak.\n        roots.Global.add(handler.id);\n        draw();\n        log('Simulated DOM leak: divNode detached from DOM but still referenced by handler (in Global).');\n      });\n\n      exTimer.addEventListener('click', ()=>{\n        // Simulate setInterval which keeps a reference to a callback and captured objects\n        const captured = createObject('capturedData', 32, 'Object');\n        const timerFn = createObject('intervalCb', 1, 'Function');\n        timerFn.edges.add(captured.id); // callback closes over capturedData\n        // Simulate setInterval stored internally in engine as root (we'll model by adding to Global)\n        roots.Global.add(timerFn.id);\n        draw();\n        log('Simulated timer leak: interval callback (in Global) holds capturedData.');\n      });\n\n      // initialize with some objects\n      (function seed(){\n        createObject('config', 4);\n        createObject('cache', 16);\n        createObject('temp', 4);\n        // put config in Global, cache in DOM (example)\n        roots.Global.add(1);\n        roots.DOM.add(2);\n        draw();\n        log('Initial objects created. Click objects in the diagram to toggle Stack root membership.');\n      })();\n\n    })();\n  </script>\n</body>\n</html>"
  },
