    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SQL Concepts Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        .demo-area {\n            background-color: #f5f5f5;\n            padding: 15px;\n            border-radius: 5px;\n            margin: 15px 0;\n        }\n        button {\n            padding: 8px 15px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #45a049;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n            margin: 15px 0;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n        pre {\n            background-color: #eee;\n            padding: 10px;\n            border-radius: 3px;\n            overflow-x: auto;\n        }\n    </style>\n</head>\n<body>\n    <h1>SQL Concepts Demonstration</h1>\n    \n    <div class=\"demo-area\">\n        <h2>1. Creating a Table</h2>\n        <pre id=\"createTableCode\">CREATE TABLE users (\n    id INTEGER PRIMARY KEY,\n    name TEXT NOT NULL,\n    email TEXT UNIQUE,\n    age INTEGER\n);</pre>\n        <button onclick=\"createTable()\">Execute CREATE TABLE</button>\n        <p id=\"createTableResult\"></p>\n    </div>\n    \n    <div class=\"demo-area\">\n        <h2>2. Inserting Data</h2>\n        <pre id=\"insertDataCode\">INSERT INTO users (name, email, age)\nVALUES \n    ('Alice Johnson', 'alice@example.com', 28),\n    ('Bob Smith', 'bob@example.com', 32),\n    ('Charlie Brown', 'charlie@example.com', 25),\n    ('Diana Prince', 'diana@example.com', 30);</pre>\n        <button onclick=\"insertData()\">Execute INSERT</button>\n        <p id=\"insertDataResult\"></p>\n    </div>\n    \n    <div class=\"demo-area\">\n        <h2>3. Querying Data (SELECT)</h2>\n        <pre id=\"selectDataCode\">SELECT * FROM users;</pre>\n        <button onclick=\"selectData()\">Execute SELECT</button>\n        <div id=\"selectDataResult\"></div>\n    </div>\n    \n    <div class=\"demo-area\">\n        <h2>4. Filtering Data (WHERE)</h2>\n        <pre id=\"whereDataCode\">SELECT name, age FROM users WHERE age > 28;</pre>\n        <button onclick=\"whereData()\">Execute WHERE</button>\n        <div id=\"whereDataResult\"></div>\n    </div>\n    \n    <div class=\"demo-area\">\n        <h2>5. Updating Data</h2>\n        <pre id=\"updateDataCode\">UPDATE users SET age = 33 WHERE name = 'Bob Smith';</pre>\n        <button onclick=\"updateData()\">Execute UPDATE</button>\n        <p id=\"updateDataResult\"></p>\n    </div>\n    \n    <div class=\"demo-area\">\n        <h2>6. Deleting Data</h2>\n        <pre id=\"deleteDataCode\">DELETE FROM users WHERE name = 'Charlie Brown';</pre>\n        <button onclick=\"deleteData()\">Execute DELETE</button>\n        <p id=\"deleteDataResult\"></p>\n    </div>\n    \n    <div class=\"demo-area\">\n        <h2>7. Final Database State</h2>\n        <button onclick=\"showFinalData()\">Show Final Data</button>\n        <div id=\"finalDataResult\"></div>\n    </div>\n\n    <script>\n        // In-memory database simulation\n        let database = {\n            tables: {},\n            execute: function(sql) {\n                try {\n                    if (sql.startsWith(\"CREATE TABLE\")) {\n                        return this.createTable(sql);\n                    } else if (sql.startsWith(\"INSERT INTO\")) {\n                        return this.insertData(sql);\n                    } else if (sql.startsWith(\"SELECT\")) {\n                        return this.selectData(sql);\n                    } else if (sql.startsWith(\"UPDATE\")) {\n                        return this.updateData(sql);\n                    } else if (sql.startsWith(\"DELETE\")) {\n                        return this.deleteData(sql);\n                    }\n                } catch (e) {\n                    return { error: e.message };\n                }\n            },\n            \n            createTable: function(sql) {\n                const tableName = sql.match(/CREATE TABLE (\\w+)/)[1];\n                const columnsText = sql.match(/\\(([^)]+)\\)/)[1];\n                const columns = columnsText.split(',').map(col => col.trim());\n                \n                this.tables[tableName] = {\n                    columns: columns.map(col => {\n                        const parts = col.split(/\\s+/);\n                        return {\n                            name: parts[0],\n                            type: parts[1],\n                            constraints: parts.slice(2)\n                        };\n                    }),\n                    data: []\n                };\n                \n                return { message: `Table ${tableName} created successfully` };\n            },\n            \n            insertData: function(sql) {\n                const tableName = sql.match(/INSERT INTO (\\w+)/)[1];\n                const columnsMatch = sql.match(/\\(([^)]+)\\)/);\n                const columns = columnsMatch ? \n                    columnsMatch[1].split(',').map(c => c.trim()) : \n                    this.tables[tableName].columns.map(c => c.name);\n                \n                const valuesMatch = sql.match(/VALUES\\s*(\\([^)]+\\))/g);\n                const values = valuesMatch.map(v => \n                    v.match(/\\(([^)]+)\\)/)[1].split(',').map(val => \n                        val.trim().replace(/^['\"]|['\"]$/g, '')\n                    )\n                );\n                \n                const table = this.tables[tableName];\n                for (let valueSet of values) {\n                    if (valueSet.length !== columns.length) {\n                        throw new Error(\"Column count doesn't match value count\");\n                    }\n                    \n                    const row = {};\n                    columns.forEach((col, i) => {\n                        row[col] = valueSet[i];\n                    });\n                    table.data.push(row);\n                }\n                \n                return { message: `${values.length} row(s) inserted into ${tableName}` };\n            },\n            \n            selectData: function(sql) {\n                const tableName = sql.match(/FROM (\\w+)/)[1];\n                const table = this.tables[tableName];\n                \n                let columns = [];\n                if (sql.includes(\"*\")) {\n                    columns = table.columns.map(c => c.name);\n                } else {\n                    const colsMatch = sql.match(/SELECT ([^ ]+) FROM/)[1];\n                    columns = colsMatch.split(',').map(c => c.trim());\n                }\n                \n                let whereClause = \"\";\n                if (sql.includes(\"WHERE\")) {\n                    whereClause = sql.split(\"WHERE\")[1].trim();\n                }\n                \n                let filteredData = table.data;\n                if (whereClause) {\n                    const [column, operator, value] = whereClause.split(/\\s+/);\n                    filteredData = table.data.filter(row => {\n                        const rowValue = row[column];\n                        const compareValue = isNaN(value) ? value : Number(value);\n                        \n                        switch (operator) {\n                            case \">\": return Number(rowValue) > compareValue;\n                            case \"<\": return Number(rowValue) < compareValue;\n                            case \"=\": \n                            case \"==\": return rowValue == compareValue;\n                            default: return true;\n                        }\n                    });\n                }\n                \n                return { \n                    columns, \n                    data: filteredData,\n                    message: `Returned ${filteredData.length} row(s) from ${tableName}`\n                };\n            },\n            \n            updateData: function(sql) {\n                const tableName = sql.match(/UPDATE (\\w+)/)[1];\n                const setClause = sql.match(/SET ([^ ]+)/)[1];\n                const whereClause = sql.includes(\"WHERE\") ? \n                    sql.split(\"WHERE\")[1].trim() : \"\";\n                \n                const [setColumn, setValue] = setClause.split(\"=\").map(p => p.trim());\n                const cleanSetValue = setValue.replace(/^['\"]|['\"]$/g, '');\n                \n                const table = this.tables[tableName];\n                let updatedCount = 0;\n                \n                for (let row of table.data) {\n                    let shouldUpdate = true;\n                    \n                    if (whereClause) {\n                        const [whereColumn, operator, whereValue] = whereClause.split(/\\s+/);\n                        const cleanWhereValue = whereValue.replace(/^['\"]|['\"]$/g, '');\n                        \n                        switch (operator) {\n                            case \"=\": \n                                shouldUpdate = row[whereColumn] == cleanWhereValue;\n                                break;\n                            default:\n                                shouldUpdate = true;\n                        }\n                    }\n                    \n                    if (shouldUpdate) {\n                        row[setColumn] = cleanSetValue;\n                        updatedCount++;\n                    }\n                }\n                \n                return { message: `Updated ${updatedCount} row(s) in ${tableName}` };\n            },\n            \n            deleteData: function(sql) {\n                const tableName = sql.match(/DELETE FROM (\\w+)/)[1];\n                const whereClause = sql.includes(\"WHERE\") ? \n                    sql.split(\"WHERE\")[1].trim() : \"\";\n                \n                const table = this.tables[tableName];\n                let initialCount = table.data.length;\n                \n                if (whereClause) {\n                    const [column, operator, value] = whereClause.split(/\\s+/);\n                    const cleanValue = value.replace(/^['\"]|['\"]$/g, '');\n                    \n                    table.data = table.data.filter(row => {\n                        switch (operator) {\n                            case \"=\": return row[column] != cleanValue;\n                            default: return true;\n                        }\n                    });\n                } else {\n                    table.data = [];\n                }\n                \n                const deletedCount = initialCount - table.data.length;\n                return { message: `Deleted ${deletedCount} row(s) from ${tableName}` };\n            }\n        };\n        \n        // UI functions\n        function createTable() {\n            const sql = document.getElementById('createTableCode').textContent;\n            const result = database.execute(sql);\n            document.getElementById('createTableResult').textContent = result.message;\n        }\n        \n        function insertData() {\n            const sql = document.getElementById('insertDataCode').textContent;\n            const result = database.execute(sql);\n            document.getElementById('insertDataResult').textContent = result.message;\n        }\n        \n        function selectData() {\n            const sql = document.getElementById('selectDataCode').textContent;\n            const result = database.execute(sql);\n            \n            let html = `<p>${result.message}</p>`;\n            if (result.data.length > 0) {\n                html += '<table><tr>';\n                result.columns.forEach(col => {\n                    html += `<th>${col}</th>`;\n                });\n                html += '</tr>';\n                \n                result.data.forEach(row => {\n                    html += '<tr>';\n                    result.columns.forEach(col => {\n                        html += `<td>${row[col]}</td>`;\n                    });\n                    html += '</tr>';\n                });\n                html += '</table>';\n            }\n            \n            document.getElementById('selectDataResult').innerHTML = html;\n        }\n        \n        function whereData() {\n            const sql = document.getElementById('whereDataCode').textContent;\n            const result = database.execute(sql);\n            \n            let html = `<p>${result.message}</p>`;\n            if (result.data.length > 0) {\n                html += '<table><tr>';\n                result.columns.forEach(col => {\n                    html += `<th>${col}</th>`;\n                });\n                html += '</tr>';\n                \n                result.data.forEach(row => {\n                    html += '<tr>';\n                    result.columns.forEach(col => {\n                        html += `<td>${row[col]}</td>`;\n                    });\n                    html += '</tr>';\n                });\n                html += '</table>';\n            }\n            \n            document.getElementById('whereDataResult').innerHTML = html;\n        }\n        \n        function updateData() {\n            const sql = document.getElementById('updateDataCode').textContent;\n            const result = database.execute(sql);\n            document.getElementById('updateDataResult').textContent = result.message;\n        }\n        \n        function deleteData() {\n            const sql = document.getElementById('deleteDataCode').textContent;\n            const result = database.execute(sql);\n            document.getElementById('deleteDataResult').textContent = result.message;\n        }\n        \n        function showFinalData() {\n            const result = database.execute(\"SELECT * FROM users\");\n            \n            let html = `<p>${result.message}</p>`;\n            if (result.data.length > 0) {\n                html += '<table><tr>';\n                result.columns.forEach(col => {\n                    html += `<th>${col}</th>`;\n                });\n                html += '</tr>';\n                \n                result.data.forEach(row => {\n                    html += '<tr>';\n                    result.columns.forEach(col => {\n                        html += `<td>${row[col]}</td>`;\n                    });\n                    html += '</tr>';\n                });\n                html += '</table>';\n            } else {\n                html += '<p>No data in the table</p>';\n            }\n            \n            document.getElementById('finalDataResult').innerHTML = html;\n        }\n    </script>\n</body>\n</html>"
  },
