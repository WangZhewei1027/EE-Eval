    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Queue Demonstration</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2rem;\n      background: #f0f4f8;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n      color: #2c3e50;\n    }\n    .container {\n      max-width: 600px;\n      margin: 1rem auto;\n      background: #fff;\n      border-radius: 8px;\n      padding: 1.5rem;\n      box-shadow: 0 4px 10px rgb(0 0 0 / 0.1);\n    }\n    label {\n      display: block;\n      margin-bottom: 0.25rem;\n      font-weight: 600;\n    }\n    input[type=\"text\"] {\n      width: calc(100% - 110px);\n      padding: 0.5rem;\n      font-size: 1rem;\n      margin-right: 0.5rem;\n    }\n    button {\n      padding: 0.5rem 1rem;\n      font-size: 1rem;\n      margin-top: 0.5rem;\n      cursor: pointer;\n      border: none;\n      border-radius: 4px;\n      transition: background-color 0.3s ease;\n    }\n    button.enqueue {\n      background-color: #27ae60;\n      color: white;\n    }\n    button.enqueue:hover {\n      background-color: #219150;\n    }\n    button.dequeue {\n      background-color: #e74c3c;\n      color: white;\n    }\n    button.dequeue:hover {\n      background-color: #c0392b;\n    }\n    button.clear {\n      background-color: #95a5a6;\n      color: white;\n    }\n    button.clear:hover {\n      background-color: #7f8c8d;\n    }\n    .queue-display {\n      margin-top: 1rem;\n      padding: 1rem;\n      background: #ecf0f1;\n      min-height: 60px;\n      border-radius: 6px;\n      display: flex;\n      flex-wrap: nowrap;\n      align-items: center;\n      overflow-x: auto;\n    }\n    .queue-item {\n      background-color: #3498db;\n      color: white;\n      padding: 0.5rem 1rem;\n      margin-right: 0.5rem;\n      border-radius: 4px;\n      font-weight: bold;\n      white-space: nowrap;\n      user-select: none;\n      position: relative;\n    }\n    .queue-item::after {\n      content: \"→\";\n      position: absolute;\n      right: -12px;\n      top: 50%;\n      transform: translateY(-50%);\n      color: #2980b9;\n      font-weight: bold;\n    }\n    .queue-item:last-child::after {\n      content: \"\";\n    }\n    .info {\n      margin-top: 1rem;\n      font-style: italic;\n      color: #555;\n    }\n    @media(max-width: 400px) {\n      input[type=\"text\"] {\n        width: 100%;\n        margin-bottom: 0.5rem;\n      }\n      button.enqueue {\n        width: 100%;\n      }\n    }\n  </style>\n</head>\n<body>\n  <h1>Queue Concept Demonstration</h1>\n  <div class=\"container\">\n    <label for=\"enqueueValue\">Enter value to enqueue:</label>\n    <input type=\"text\" id=\"enqueueValue\" placeholder=\"e.g. 5 or Apple\" />\n    <button class=\"enqueue\" id=\"enqueueBtn\">Enqueue</button>\n\n    <div>\n      <button class=\"dequeue\" id=\"dequeueBtn\">Dequeue</button>\n      <button class=\"clear\" id=\"clearBtn\">Clear Queue</button>\n    </div>\n\n    <div class=\"queue-display\" id=\"queueDisplay\" aria-live=\"polite\" aria-label=\"Queue contents\">\n      <!-- Queue items will appear here -->\n    </div>\n\n    <div class=\"info\" id=\"info\">\n      The queue is empty.\n    </div>\n  </div>\n\n  <script>\n    // Basic queue class\n    class Queue {\n      constructor() {\n        this.items = [];\n      }\n      enqueue(element) {\n        this.items.push(element);\n      }\n      dequeue() {\n        if (this.isEmpty()) return null;\n        return this.items.shift();\n      }\n      front() {\n        if (this.isEmpty()) return null;\n        return this.items[0];\n      }\n      isEmpty() {\n        return this.items.length === 0;\n      }\n      size() {\n        return this.items.length;\n      }\n      clear() {\n        this.items = [];\n      }\n      toArray() {\n        return this.items.slice();\n      }\n    }\n\n    const queue = new Queue();\n\n    const enqueueBtn = document.getElementById(\"enqueueBtn\");\n    const dequeueBtn = document.getElementById(\"dequeueBtn\");\n    const clearBtn = document.getElementById(\"clearBtn\");\n    const enqueueInput = document.getElementById(\"enqueueValue\");\n    const queueDisplay = document.getElementById(\"queueDisplay\");\n    const info = document.getElementById(\"info\");\n\n    function updateDisplay() {\n      queueDisplay.innerHTML = \"\";\n      const arr = queue.toArray();\n      if (arr.length === 0) {\n        info.textContent = \"The queue is empty.\";\n        return;\n      }\n      info.textContent = `Queue size: ${queue.size()}. Front: ${queue.front()}`;\n\n      arr.forEach((item, index) => {\n        const div = document.createElement(\"div\");\n        div.className = \"queue-item\";\n        div.textContent = item;\n        if(index === 0) {\n          div.title = \"Front of the queue\";\n        } else if (index === arr.length - 1) {\n          div.title = \"Rear of the queue\";\n        }\n        queueDisplay.appendChild(div);\n      });\n    }\n\n    enqueueBtn.addEventListener(\"click\", () => {\n      const value = enqueueInput.value.trim();\n      if (value === \"\") {\n        alert(\"Please enter a value to enqueue.\");\n        enqueueInput.focus();\n        return;\n      }\n      queue.enqueue(value);\n      enqueueInput.value = \"\";\n      enqueueInput.focus();\n      updateDisplay();\n    });\n\n    dequeueBtn.addEventListener(\"click\", () => {\n      if (queue.isEmpty()) {\n        alert(\"Queue is empty. Nothing to dequeue.\");\n        return;\n      }\n      const dequeued = queue.dequeue();\n      alert(\"Dequeued: \" + dequeued);\n      updateDisplay();\n    });\n\n    clearBtn.addEventListener(\"click\", () => {\n      if (confirm(\"Are you sure you want to clear the queue?\")) {\n        queue.clear();\n        updateDisplay();\n      }\n    });\n\n    // Allow hitting Enter key to enqueue\n    enqueueInput.addEventListener(\"keydown\", e => {\n      if(e.key === \"Enter\") {\n        enqueueBtn.click();\n      }\n    });\n\n    // Initialize display\n    updateDisplay();\n  </script>\n</body>\n</html>"
