    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Logistic Regression Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f5f7fa;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #canvasContainer {\n    text-align: center;\n    margin-top: 20px;\n  }\n  canvas {\n    border: 1px solid #ccc;\n    background: white;\n    cursor: crosshair;\n  }\n  #info {\n    max-width: 600px;\n    margin: 15px auto;\n    line-height: 1.5;\n  }\n  #resetBtn {\n    display: block;\n    margin: 20px auto;\n    padding: 8px 15px;\n    font-size: 16px;\n    cursor: pointer;\n    border: none;\n    background: #007bff;\n    color: white;\n    border-radius: 4px;\n  }\n  #resetBtn:hover {\n    background: #0056b3;\n  }\n  #legend {\n    max-width: 600px;\n    margin: 10px auto;\n    display: flex;\n    justify-content: center;\n    gap: 20px;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n  }\n  .color-box {\n    width: 18px;\n    height: 18px;\n    border-radius: 3px;\n  }\n  .color-positive {\n    background: #d33;\n  }\n  .color-negative {\n    background: #3399d3;\n  }\n  #learnInfo {\n    max-width: 600px;\n    margin: 20px auto;\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n<h1>Logistic Regression Interactive Demo</h1>\n<p id=\"info\">\n  Click inside the plot area to add points. There are two classes for points:<br />\n  <span style=\"color:#d33;\"><strong>Class 1 (Red points)</strong></span> and <span style=\"color:#3399d3;\"><strong>Class 0 (Blue points)</strong></span>.<br />\n  By default, points you add are <strong>Class 0 (Blue)</strong>. Press the <em>spacebar</em> to toggle the class of the next point you add.<br />\n  Once you have some points, the model will train continuously and updates the decision boundary in real time.<br />\n  Logistic Regression tries to find a line that best separates the two classes by estimating probabilities using the logistic sigmoid function.<br />\n</p>\n\n<div id=\"legend\">\n  <div class=\"legend-item\"><div class=\"color-box color-negative\"></div> Class 0 (Blue)</div>\n  <div class=\"legend-item\"><div class=\"color-box color-positive\"></div> Class 1 (Red)</div>\n  <div class=\"legend-item\" style=\"margin-left:20px;\">Decision boundary: black line</div>\n</div>\n\n<div id=\"canvasContainer\">\n  <canvas id=\"plot\" width=\"600\" height=\"400\" aria-label=\"Logistic Regression plot area\" role=\"img\"></canvas>\n</div>\n\n<button id=\"resetBtn\" aria-label=\"Reset all points and model\">Reset</button>\n\n<div id=\"learnInfo\"></div>\n\n<script>\n// Logistic Regression demo with live visualization\n// Data format: points = [{x, y, label=0|1}, ...]\n// Model parameters: weights (w0 bias, w1 x, w2 y)\n\n(function () {\n  const canvas = document.getElementById(\"plot\");\n  const ctx = canvas.getContext(\"2d\");\n  const width = canvas.width;\n  const height = canvas.height;\n\n  // Coordinate system: map canvas pixels [0,width],[0,height] to [-1,1],[-1,1]\n  // For learning and decision boundary plotting\n  \n  // Map canvas coordinate to feature coordinate:\n  function canvasToFeature(x, y) {\n    return {\n      x: (x / width) * 2 - 1,\n      y: 1 - (y / height) * 2,\n    };\n  }\n  // Map feature coordinate [-1,1] to canvas pixel coordinate\n  function featureToCanvas(x, y) {\n    return {\n      x: ((x + 1) / 2) * width,\n      y: ((1 - y) / 2) * height,\n    };\n  }\n\n  let points = [];\n  // Current class toggle state (0 or 1)\n  let currentClass = 0;\n\n  // Logistic Regression model parameters: weights [bias, w1, w2]\n  // Initialized to zeros\n  let weights = [0, 0, 0];\n\n  // Learning rate\n  const learningRate = 0.1;\n\n  // Sigmoid function\n  function sigmoid(z) {\n    // Prevent overflow:\n    if (z < -20) return 0;\n    if (z > 20) return 1;\n    return 1 / (1 + Math.exp(-z));\n  }\n\n  // Predict probability for one point (feature x,y)\n  function predict(x, y) {\n    const z = weights[0] + weights[1] * x + weights[2] * y;\n    return sigmoid(z);\n  }\n\n  // Loss function: Logistic loss (cross entropy)\n  // L = - [y log(p) + (1-y) log(1-p)]\n  // For reporting only\n\n  function loss() {\n    if (points.length === 0) return 0;\n    let sumLoss = 0;\n    for (const p of points) {\n      let pHat = predict(p.x, p.y);\n      pHat = Math.min(Math.max(pHat, 1e-10), 1 - 1e-10);\n      sumLoss += - (p.label * Math.log(pHat) + (1 - p.label) * Math.log(1 - pHat));\n    }\n    return sumLoss / points.length;\n  }\n\n  // Gradient descent step: update weights\n  function trainOneStep() {\n    if (points.length === 0) return;\n    // gradients for weights: dL/dw_j\n    let grad = [0, 0, 0];\n\n    for (const p of points) {\n      const xVec = [1, p.x, p.y];\n      let pHat = predict(p.x, p.y);\n      for (let j = 0; j < 3; j++) {\n        grad[j] += (pHat - p.label) * xVec[j];\n      }\n    }\n    // Average gradients\n    for (let j = 0; j < 3; j++) {\n      grad[j] /= points.length;\n      weights[j] -= learningRate * grad[j];\n    }\n  }\n\n  // Draw points and decision boundary\n  function draw() {\n    // Clear\n    ctx.clearRect(0, 0, width, height);\n    \n    // Draw grid lines\n    ctx.strokeStyle = \"#eee\";\n    ctx.lineWidth = 1;\n    for (let i = -1; i <= 1; i += 0.5) {\n      // Vertical lines\n      let cx = featureToCanvas(i, 0).x;\n      ctx.beginPath();\n      ctx.moveTo(cx, 0);\n      ctx.lineTo(cx, height);\n      ctx.stroke();\n      // Horizontal lines\n      let cy = featureToCanvas(0, i).y;\n      ctx.beginPath();\n      ctx.moveTo(0, cy);\n      ctx.lineTo(width, cy);\n      ctx.stroke();\n    }\n\n    // Draw points\n    for (const p of points) {\n      const c = featureToCanvas(p.x, p.y);\n      ctx.beginPath();\n      ctx.arc(c.x, c.y, 7, 0, Math.PI * 2);\n      ctx.fillStyle = p.label === 1 ? \"#d33\" : \"#3399d3\";\n      ctx.fill();\n      ctx.lineWidth = 2;\n      ctx.strokeStyle = \"white\";\n      ctx.stroke();\n    }\n\n    // Draw decision boundary line\n    // The decision boundary is at p = 0.5, or z = 0:\n    // w0 + w1 * x + w2 * y = 0 => y = (-w0 - w1 * x) / w2  if w2 != 0\n    if (Math.abs(weights[2]) > 1e-5) {\n      // Compute two points on boundary in feature space x in [-1,1]\n      const x1 = -1;\n      const y1 = (-weights[0] - weights[1] * x1) / weights[2];\n      const x2 = 1;\n      const y2 = (-weights[0] - weights[1] * x2) / weights[2];\n\n      // Clamp y1,y2 to visible range [-1,1] for drawing\n      function clampY(x, y) {\n        if (y < -1) {\n          // Solve for x when y = -1 : y = (-w0 - w1 * x)/w2 => x = (-w0 - w2 * y)/w1\n          if (weights[1] !== 0) {\n            return (-weights[0] - weights[2] * (-1)) / weights[1];\n          }\n          return x;\n        }\n        if (y > 1) {\n          if (weights[1] !== 0) {\n            return (-weights[0] - weights[2] * 1) / weights[1];\n          }\n          return x;\n        }\n        return x;\n      }\n\n      let pointsToDraw = [];\n\n      // We'll find intersections with box [-1,1]x[-1,1]\n      // Find candidate intersections with vertical edges x=-1 and x=1\n      // and horizontal edges y=-1 and y=1\n      // and keep those inside the box\n\n      let candidates = [];\n\n      // Vertical edges: x = -1, x = 1\n      for (const xE of [-1, 1]) {\n        const yE = (-weights[0] - weights[1] * xE) / weights[2];\n        if (yE >= -1 && yE <= 1) candidates.push({x: xE, y: yE});\n      }\n      // Horizontal edges: y = -1, y=1\n      for (const yE of [-1, 1]) {\n        // x = (-w0 - w2 * y) / w1 if w1 != 0\n        if (weights[1] !== 0) {\n          const xE = (-weights[0] - weights[2] * yE) / weights[1];\n          if (xE >= -1 && xE <= 1) candidates.push({x: xE, y: yE});\n        }\n      }\n\n      if (candidates.length >= 2) {\n        pointsToDraw = [candidates[0], candidates[1]];\n      } else {\n        // Not enough points to draw line\n        pointsToDraw = null;\n      }\n\n      if (pointsToDraw) {\n        const p1 = featureToCanvas(pointsToDraw[0].x, pointsToDraw[0].y);\n        const p2 = featureToCanvas(pointsToDraw[1].x, pointsToDraw[1].y);\n        ctx.beginPath();\n        ctx.moveTo(p1.x, p1.y);\n        ctx.lineTo(p2.x, p2.y);\n        ctx.strokeStyle = \"black\";\n        ctx.lineWidth = 2;\n        ctx.setLineDash([8, 6]);\n        ctx.stroke();\n        ctx.setLineDash([]);\n      }\n    } else {\n      // When w2 ≈ 0, handle vertical line case:\n      // w0 + w1 * x = 0 => x = -w0 / w1\n      if (Math.abs(weights[1]) > 1e-5) {\n        const x = -weights[0] / weights[1];\n        if (x >= -1 && x <= 1) {\n          const c1 = featureToCanvas(x, -1);\n          const c2 = featureToCanvas(x, 1);\n          ctx.beginPath();\n          ctx.moveTo(c1.x, c1.y);\n          ctx.lineTo(c2.x, c2.y);\n          ctx.strokeStyle = \"black\";\n          ctx.lineWidth = 2;\n          ctx.setLineDash([8, 6]);\n          ctx.stroke();\n          ctx.setLineDash([]);\n        }\n      }\n    }\n  }\n\n  // Global variable to control animation loop\n  let running = true;\n\n  // Animate training loop\n  function trainingLoop() {\n    if (running) {\n      trainOneStep();\n      draw();\n      updateLearnInfo();\n      window.requestAnimationFrame(trainingLoop);\n    }\n  }\n\n  function updateLearnInfo() {\n    const info = document.getElementById(\"learnInfo\");\n    const n = points.length;\n    if (n === 0) {\n      info.textContent = \"Add points by clicking on the plot area to start.\";\n      return;\n    }\n    // Show current weights and loss\n    const w0 = weights[0].toFixed(3);\n    const w1 = weights[1].toFixed(3);\n    const w2 = weights[2].toFixed(3);\n    const l = loss().toFixed(4);\n\n    info.textContent = `Samples: ${n} | Weights: bias=${w0}, w₁=${w1}, w₂=${w2} | Logistic Loss: ${l}`;\n  }\n\n  // Handle user clicks to add points\n  canvas.addEventListener(\"click\", (e) => {\n    const rect = canvas.getBoundingClientRect();\n    const cx = e.clientX - rect.left;\n    const cy = e.clientY - rect.top;\n    const f = canvasToFeature(cx, cy);\n    // Add point with current class\n    points.push({x: f.x, y: f.y, label: currentClass});\n    updateLearnInfo();\n  });\n\n  // Handle spacebar to toggle class of next point to be added\n  window.addEventListener(\"keydown\", (e) => {\n    if (e.code === \"Space\") {\n      currentClass = 1 - currentClass; // Toggle 0 <-> 1\n      e.preventDefault();\n      const info = document.getElementById(\"info\");\n      info.innerHTML = `<strong>Current point class to add: <span style=\"color:${\n        currentClass === 1 ? \"#d33\" : \"#3399d3\"\n      };\">${currentClass}</span></strong><br>` + info.innerHTML;\n      // Remove old toggling indicators after 4 seconds to keep clean:\n      setTimeout(() => {\n        const html = info.innerHTML;\n        const idx = html.indexOf(\"<strong>Current point class to add:\");\n        if (idx !== -1) {\n          info.innerHTML = html.slice(idx + (\"<strong>Current point class to add:\".length));\n        }\n        // Redraw info without the toggle message after timeout\n        info.innerHTML = info.innerHTML.replace(/((.|\\n)*)?<br>/, \"\");\n      }, 4000);\n    }\n  });\n\n  // Reset button clears all points and weights\n  document.getElementById(\"resetBtn\").addEventListener(\"click\", () => {\n    points = [];\n    weights = [0, 0, 0];\n    currentClass = 0;\n    updateLearnInfo();\n    draw();\n  });\n\n  // Initial draw\n  draw();\n  updateLearnInfo();\n  trainingLoop();\n})();\n</script>\n</body>\n</html>"
