  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Dynamic Array — Interactive Demonstration</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1320;\n      --muted:#98a0b3;\n      --accent:#7dd3fc;\n      --accent2:#60a5fa;\n      --ok:#34d399;\n      --danger:#fb7185;\n      --glass: rgba(255,255,255,0.03);\n    }\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,#071425 0%, #061226 100%);font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;}\n    .wrap{max-width:1100px;margin:28px auto;padding:20px;color:#e6eef8;}\n    header{display:flex;align-items:center;gap:18px;margin-bottom:18px}\n    h1{margin:0;font-size:20px;letter-spacing:-0.2px}\n    p.desc{margin:6px 0 14px;color:var(--muted);max-width:920px}\n    .layout{display:grid;grid-template-columns: 1fr 360px;gap:18px}\n    .card{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:10px;padding:14px;box-shadow:0 6px 18px rgba(2,6,23,0.6);border:1px solid rgba(255,255,255,0.03)}\n    .controls{display:flex;flex-direction:column;gap:8px}\n    .row{display:flex;gap:8px;align-items:center}\n    .row .stretch{flex:1}\n    input[type=\"number\"], input[type=\"text\"], select{\n      width:100%;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:inherit;outline:none;\n    }\n    button{padding:8px 10px;border-radius:8px;border:none;background:linear-gradient(180deg,var(--accent),var(--accent2));color:#022;cursor:pointer;font-weight:600}\n    button.ghost{background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted)}\n    .status{display:flex;gap:12px;align-items:center;margin-bottom:10px}\n    .stat{background:var(--glass);padding:6px 10px;border-radius:8px;color:var(--muted);font-size:13px}\n    .vis-area{min-height:220px;display:flex;flex-direction:column;gap:12px;align-items:center;justify-content:flex-start;padding:10px}\n    .memory{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;padding:10px}\n    .cell{width:60px;height:48px;border-radius:8px;background:rgba(255,255,255,0.02);display:flex;flex-direction:column;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,0.03);position:relative;transition:transform .18s, box-shadow .18s}\n    .cell.index{height:20px;width:60px;background:transparent;border:none;color:var(--muted);font-size:12px}\n    .cell .value{font-weight:700;color:#eaf6ff}\n    .cell.empty .value{color:var(--muted);font-weight:500}\n    .cell.highlight{box-shadow:0 6px 18px rgba(96,165,250,0.12);transform:translateY(-6px);border-color:rgba(96,165,250,0.4)}\n    .cell.copying{box-shadow:0 8px 30px rgba(125,211,252,0.14);transform:scale(1.06);border-color:rgba(125,211,252,0.5)}\n    .annotation{font-size:13px;color:var(--muted)}\n    .log{background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;height:160px;overflow:auto;border:1px solid rgba(255,255,255,0.02);font-family:monospace;font-size:13px;color:var(--muted)}\n    .pseudo{background:#071428;padding:12px;border-radius:8px;font-family:monospace;font-size:13px;color:#cfeffd;white-space:pre;overflow:auto;border:1px solid rgba(255,255,255,0.03)}\n    .small{font-size:13px;color:var(--muted)}\n    footer{margin-top:14px;color:var(--muted);font-size:13px}\n    .badge{padding:6px 8px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));font-weight:600;color:var(--muted)}\n    .controls .inline{display:flex;gap:8px}\n    .muted{color:var(--muted);font-size:13px}\n    .danger{color:var(--danger)}\n    .ok{color:var(--ok)}\n    input[type=\"range\"]{width:100%}\n    @media(max-width:980px){\n      .layout{grid-template-columns:1fr; padding-bottom:40px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <header>\n      <div>\n        <h1>Dynamic Array — Interactive Demonstration</h1>\n        <div class=\"small muted\">See how an array resizes automatically as you append, insert, and remove elements. Watch capacity doubling and copying.</div>\n      </div>\n    </header>\n\n    <p class=\"desc\">\n      A dynamic array provides array-like indexing with automatic resizing. Internally it keeps a capacity and a size. When you append beyond capacity the array allocates a larger block (commonly double) and copies existing elements into it. This demo simulates that process so you can observe the cost and the amortized performance.\n    </p>\n\n    <div class=\"layout\">\n      <div class=\"card\">\n        <div class=\"status\">\n          <div class=\"stat\">size: <strong id=\"size\">0</strong></div>\n          <div class=\"stat\">capacity: <strong id=\"capacity\">0</strong></div>\n          <div class=\"stat\">elements copied (last resize): <strong id=\"copied\">0</strong></div>\n          <div class=\"stat badge\" title=\"Amortized cost of append\">amortized append: O(1)</div>\n        </div>\n\n        <div class=\"vis-area\">\n          <div class=\"annotation\">Underlying memory (indices shown below). Empty slots are unused capacity.</div>\n\n          <div id=\"memory\" class=\"memory\" aria-live=\"polite\"></div>\n          <div class=\"annotation\" id=\"hint\" style=\"color:var(--muted)\"></div>\n\n          <div style=\"width:100%;display:flex;gap:12px;\">\n            <div style=\"flex:1\">\n              <div class=\"small muted\">Operation log</div>\n              <div id=\"log\" class=\"log\"></div>\n            </div>\n            <div style=\"width:320px\">\n              <div class=\"small muted\">Pseudocode (simple)</div>\n              <div class=\"pseudo\">\nfunction append(A, value):\n    if A.size == A.capacity:\n        newCap = max(1, A.capacity * 2)\n        B = allocate(newCap)\n        for i in 0 .. A.size-1:\n            B[i] = A[i]          # copy element\n        A.data = B\n        A.capacity = newCap\n    A.data[A.size] = value\n    A.size += 1\n              </div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div class=\"controls\">\n          <div class=\"row\">\n            <div style=\"flex:1\">\n              <label class=\"small muted\">Initial capacity</label>\n              <input id=\"initCap\" type=\"number\" min=\"1\" value=\"4\" />\n            </div>\n            <button id=\"resetBtn\">Create / Reset</button>\n          </div>\n\n          <div class=\"row\">\n            <div class=\"stretch\">\n              <label class=\"small muted\">Append value</label>\n              <input id=\"appendVal\" type=\"text\" placeholder=\"e.g. 42 or hello\" />\n            </div>\n            <button id=\"appendBtn\">Append</button>\n          </div>\n\n          <div class=\"row\">\n            <div style=\"flex:1\">\n              <label class=\"small muted\">Insert at index</label>\n              <div class=\"inline\">\n                <input id=\"insertIdx\" type=\"number\" min=\"0\" placeholder=\"index\" />\n                <input id=\"insertVal\" type=\"text\" placeholder=\"value\" />\n              </div>\n            </div>\n            <button id=\"insertBtn\">Insert</button>\n          </div>\n\n          <div class=\"row\">\n            <div style=\"flex:1\">\n              <label class=\"small muted\">Set index</label>\n              <div class=\"inline\">\n                <input id=\"setIdx\" type=\"number\" min=\"0\" placeholder=\"index\" />\n                <input id=\"setVal\" type=\"text\" placeholder=\"value\" />\n              </div>\n            </div>\n            <button id=\"setBtn\" class=\"ghost\">Set</button>\n          </div>\n\n          <div class=\"row\">\n            <div class=\"stretch\">\n              <label class=\"small muted\">Get value at index</label>\n              <input id=\"getIdx\" type=\"number\" min=\"0\" placeholder=\"index\" />\n            </div>\n            <button id=\"getBtn\" class=\"ghost\">Get</button>\n          </div>\n\n          <div class=\"row\">\n            <div class=\"stretch\">\n              <label class=\"small muted\">Remove index</label>\n              <input id=\"removeIdx\" type=\"number\" min=\"0\" placeholder=\"index\" />\n            </div>\n            <button id=\"removeBtn\" class=\"ghost danger\">Remove</button>\n          </div>\n\n          <div class=\"row\">\n            <div class=\"stretch\">\n              <label class=\"small muted\">Pop (remove last)</label>\n            </div>\n            <button id=\"popBtn\" class=\"ghost danger\">Pop</button>\n          </div>\n\n          <div style=\"display:flex;gap:8px;align-items:center\">\n            <div style=\"flex:1\">\n              <label class=\"small muted\">Append many (n)</label>\n              <input id=\"manyN\" type=\"number\" min=\"1\" value=\"10\" />\n            </div>\n            <button id=\"manyBtn\">Append N</button>\n          </div>\n\n          <div class=\"row\">\n            <div style=\"flex:1\">\n              <label class=\"small muted\">Animation speed (ms per copy)</label>\n              <input id=\"speed\" type=\"range\" min=\"5\" max=\"500\" value=\"70\" />\n            </div>\n            <div style=\"width:70px;text-align:right;color:var(--muted)\" id=\"speedVal\">70ms</div>\n          </div>\n\n          <div class=\"row\">\n            <label style=\"flex:1\" class=\"small muted\"><input id=\"autoShrink\" type=\"checkbox\" /> Auto-shrink when sparse (size <= capacity/4)</label>\n          </div>\n\n        </div>\n\n        <footer>\n          Tip: Append repeatedly to trigger resizing. Watch how many elements are copied during each resize — resizing is O(n), but amortized cost per append is O(1).\n        </footer>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Dynamic Array Simulation with animation\n    (function(){\n      // Utilities\n      function $(id){return document.getElementById(id);}\n      function sleep(ms){return new Promise(r=>setTimeout(r, ms));}\n      function log(msg){ const el=$('log'); el.innerText = msg + \"\\\\n\" + el.innerText; }\n\n      // Simulation class\n      class DynamicArraySim {\n        constructor(initialCapacity=4, onUpdate=null){\n          this.capacity = Math.max(1, Math.floor(initialCapacity));\n          this.size = 0;\n          this.data = new Array(this.capacity).fill(null);\n          this.onUpdate = onUpdate;\n          this.lastCopied = 0;\n        }\n\n        setUpdate(cb){ this.onUpdate = cb; this._update(); }\n\n        _update(){\n          if(this.onUpdate) this.onUpdate({\n            capacity:this.capacity, size:this.size, data:this.data.slice(), copied:this.lastCopied\n          });\n        }\n\n        // allocate a new raw storage (simulate)\n        async _resize(newCap, animate=true, speed=60){\n          const old = this.data;\n          const oldCap = this.capacity;\n          const oldSize = this.size;\n          log(`Resizing: ${oldCap} -> ${newCap}. Copying ${oldSize} elements.`);\n          this.lastCopied = oldSize;\n          const newArr = new Array(newCap).fill(null);\n\n          if(!animate){\n            for(let i=0;i<oldSize;i++) newArr[i]=old[i];\n            this.data = newArr; this.capacity = newCap;\n            this._update();\n            return;\n          }\n\n          // animated copy: highlight cell-by-cell\n          for(let i=0;i<oldSize;i++){\n            // copy element\n            newArr[i] = old[i];\n            // reflect partial copy by temporarily showing new data as well\n            this.data = old.slice();\n            // mark copying by storing a special __copyIndex (used by renderer)\n            this._copyIndex = i;\n            this._tempNew = newArr.slice(); // partial new\n            this.capacity = newCap; // show new capacity box count during copy\n            this._update();\n            await sleep(speed);\n          }\n          // finalise\n          delete this._copyIndex;\n          delete this._tempNew;\n          this.data = newArr;\n          this.capacity = newCap;\n          this._update();\n        }\n\n        // append value\n        async append(value, animate=true, speed=60){\n          if(this.size === this.capacity){\n            let newCap = Math.max(1, this.capacity*2);\n            await this._resize(newCap, animate, speed);\n          }\n          this.data[this.size] = value;\n          this.size += 1;\n          this._update();\n          log(`Appended \"${value}\" (size=${this.size}, capacity=${this.capacity})`);\n        }\n\n        // insert at index (0..size)\n        async insert(index, value, animate=true, speed=60){\n          if(index < 0 || index > this.size) {\n            log(`Insert index ${index} out of bounds`);\n            return;\n          }\n          if(this.size === this.capacity){\n            let newCap = Math.max(1, this.capacity*2);\n            await this._resize(newCap, animate, speed);\n          }\n          // shift right\n          for(let i=this.size;i>index;i--){\n            this.data[i] = this.data[i-1];\n            // animate shift by temporarily highlighting\n            this._shiftIndex = i;\n            this._update();\n            if(animate) await sleep(Math.max(15, speed/2));\n          }\n          delete this._shiftIndex;\n          this.data[index] = value;\n          this.size += 1;\n          this._update();\n          log(`Inserted \"${value}\" at index ${index}`);\n        }\n\n        // set value at index\n        set(index, value){\n          if(index < 0 || index >= this.size){ log(`Set index ${index} out of bounds`); return; }\n          this.data[index] = value;\n          this._update();\n          log(`Set index ${index} = \"${value}\"`);\n        }\n\n        // get value\n        get(index){\n          if(index < 0 || index >= this.size){ log(`Get index ${index} out of bounds`); return undefined; }\n          log(`Get index ${index} -> ${this.data[index]}`);\n          return this.data[index];\n        }\n\n        // remove at index\n        remove(index, animate=true, speed=60){\n          if(index < 0 || index >= this.size){ log(`Remove index ${index} out of bounds`); return; }\n          const removed = this.data[index];\n          // shift left\n          for(let i=index;i<this.size-1;i++){\n            this.data[i] = this.data[i+1];\n            this._shiftIndex = i;\n            this._update();\n          }\n          delete this._shiftIndex;\n          this.size -= 1;\n          this.data[this.size] = null;\n          this._update();\n          log(`Removed index ${index} (value=\"${removed}\")`);\n        }\n\n        // pop last\n        pop(){\n          if(this.size===0){ log(\"Pop from empty array\"); return undefined; }\n          const val = this.data[this.size-1];\n          this.data[this.size-1] = null;\n          this.size -= 1;\n          this._update();\n          log(`Popped \"${val}\"`);\n          return val;\n        }\n\n        // maybe shrink capacity when sparse\n        async maybeShrink(autoShrink, animate=true, speed=60){\n          if(!autoShrink) return;\n          while(this.capacity > 1 && this.size <= Math.floor(this.capacity/4)){\n            const newCap = Math.max(1, Math.floor(this.capacity/2));\n            await this._resize(newCap, animate, speed);\n          }\n        }\n      }\n\n      // Renderer\n      const memoryEl = $('memory');\n      const sizeEl = $('size');\n      const capEl = $('capacity');\n      const copiedEl = $('copied');\n      const hintEl = $('hint');\n\n      let running = false;\n      function render(state){\n        // state: capacity, size, data[], copied\n        memoryEl.innerHTML = '';\n        const cap = state.capacity;\n        const size = state.size;\n        const data = state.data;\n        const copyIndex = dyn._copyIndex;\n        const tempNew = dyn._tempNew;\n        const shiftIndex = dyn._shiftIndex;\n\n        // top row: value cells\n        for(let i=0;i<cap;i++){\n          const c = document.createElement('div');\n          c.className = 'cell';\n          // determine value to display:\n          let display = null;\n          let isEmpty = true;\n          if(tempNew && i < tempNew.length && tempNew[i] !== null && tempNew[i] !== undefined){\n            display = tempNew[i];\n            isEmpty = false;\n          } else if(i < data.length && data[i] !== null && data[i] !== undefined){\n            display = data[i];\n            isEmpty = false;\n          }\n\n          if(i >= size) c.classList.add('empty');\n          if(i === copyIndex) c.classList.add('copying');\n          if(i === shiftIndex || i === shiftIndex+1) c.classList.add('highlight');\n\n          const v = document.createElement('div'); v.className='value';\n          v.innerText = (display === null || display === undefined) ? '' : String(display);\n          c.appendChild(v);\n          memoryEl.appendChild(c);\n        }\n\n        // index row\n        for(let i=0;i<cap;i++){\n          const idx = document.createElement('div');\n          idx.className='cell index';\n          idx.innerText = i;\n          memoryEl.appendChild(idx);\n        }\n\n        // status\n        sizeEl.innerText = size;\n        capEl.innerText = cap;\n        copiedEl.innerText = state.copied || 0;\n\n        // hint text\n        hintEl.innerText = `Used slots: ${size} / ${cap}. When size == capacity an append triggers allocation of a larger block and copying.`;\n      }\n\n      // Instantiate\n      let dyn = new DynamicArraySim(4, render);\n      dyn.setUpdate(render);\n\n      // Hook up UI\n      $('resetBtn').addEventListener('click', ()=>{\n        if(running) return;\n        const c = parseInt($('initCap').value,10) || 1;\n        dyn = new DynamicArraySim(Math.max(1,c), render);\n        dyn.setUpdate(render);\n        log(`Created new dynamic array with initial capacity ${dyn.capacity}`);\n        render({capacity:dyn.capacity,size:dyn.size,data:dyn.data,copied:dyn.lastCopied});\n      });\n\n      $('appendBtn').addEventListener('click', async ()=>{\n        if(running) return;\n        const val = $('appendVal').value || '(empty)';\n        running = true;\n        await dyn.append(val, true, Number($('speed').value));\n        await dyn.maybeShrink($('autoShrink').checked, true, Number($('speed').value));\n        running = false;\n      });\n\n      $('insertBtn').addEventListener('click', async ()=>{\n        if(running) return;\n        const idx = Number($('insertIdx').value);\n        const val = $('insertVal').value || '(empty)';\n        if(Number.isNaN(idx)){ log('Insert: invalid index'); return; }\n        running = true;\n        await dyn.insert(idx, val, true, Number($('speed').value));\n        await dyn.maybeShrink($('autoShrink').checked, true, Number($('speed').value));\n        running = false;\n      });\n\n      $('setBtn').addEventListener('click', ()=>{\n        const idx = Number($('setIdx').value);\n        const val = $('setVal').value || '(empty)';\n        if(Number.isNaN(idx)){ log('Set: invalid index'); return; }\n        dyn.set(idx, val);\n      });\n\n      $('getBtn').addEventListener('click', ()=>{\n        const idx = Number($('getIdx').value);\n        if(Number.isNaN(idx)){ log('Get: invalid index'); return; }\n        dyn.get(idx);\n      });\n\n      $('removeBtn').addEventListener('click', async ()=>{\n        if(running) return;\n        const idx = Number($('removeIdx').value);\n        if(Number.isNaN(idx)){ log('Remove: invalid index'); return; }\n        running = true;\n        dyn.remove(idx, true, Number($('speed').value));\n        await dyn.maybeShrink($('autoShrink').checked, true, Number($('speed').value));\n        running = false;\n      });\n\n      $('popBtn').addEventListener('click', async ()=>{\n        if(running) return;\n        running = true;\n        dyn.pop();\n        await dyn.maybeShrink($('autoShrink').checked, true, Number($('speed').value));\n        running = false;\n      });\n\n      $('manyBtn').addEventListener('click', async ()=>{\n        if(running) return;\n        const n = Math.max(1, Number($('manyN').value) || 10);\n        running = true;\n        for(let i=0;i<n;i++){\n          await dyn.append(`x${dyn.size}`, true, Number($('speed').value));\n        }\n        await dyn.maybeShrink($('autoShrink').checked, true, Number($('speed').value));\n        running = false;\n      });\n\n      $('speed').addEventListener('input', ()=>{\n        $('speedVal').innerText = $('speed').value + 'ms';\n      });\n\n      // initial render\n      render({capacity:dyn.capacity, size:dyn.size, data:dyn.data, copied:0});\n      log(\"Interactive dynamic array ready. Use the controls to modify the array.\");\n\n      // Accessibility: keyboard shortcuts (basic)\n      window.addEventListener('keydown', (e)=>{\n        if(e.key === 'a' && document.activeElement.tagName !== 'INPUT'){ e.preventDefault(); $('appendBtn').click(); }\n      });\n    })();\n  </script>\n</body>\n</html>"
  },
