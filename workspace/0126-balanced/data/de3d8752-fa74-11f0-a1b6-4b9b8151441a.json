    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Unit Testing Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 800px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        .test-section {\n            margin: 20px 0;\n            padding: 15px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n        }\n        .pass {\n            color: green;\n        }\n        .fail {\n            color: red;\n        }\n        button {\n            padding: 8px 16px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n    <h1>Unit Testing Demonstration</h1>\n    <p>This page demonstrates basic unit testing concepts with JavaScript.</p>\n\n    <div class=\"test-section\">\n        <h2>Test 1: Simple Calculator Functions</h2>\n        <div id=\"test1-results\"></div>\n        <button onclick=\"runCalculatorTests()\">Run Calculator Tests</button>\n    </div>\n\n    <div class=\"test-section\">\n        <h2>Test 2: String Utilities</h2>\n        <div id=\"test2-results\"></div>\n        <button onclick=\"runStringTests()\">Run String Tests</button>\n    </div>\n\n    <div class=\"test-section\">\n        <h2>Test 3: Asynchronous Testing</h2>\n        <div id=\"test3-results\"></div>\n        <button onclick=\"runAsyncTests()\">Run Async Tests</button>\n    </div>\n\n    <script>\n        // Simple test framework\n        const test = {\n            assertEquals: function(actual, expected, testName) {\n                const resultElement = document.createElement('div');\n                if (actual === expected) {\n                    resultElement.className = 'pass';\n                    resultElement.textContent = `✓ ${testName}: Passed`;\n                } else {\n                    resultElement.className = 'fail';\n                    resultElement.textContent = `✗ ${testName}: Failed (Expected ${expected}, got ${actual})`;\n                }\n                return resultElement;\n            },\n            assertTrue: function(condition, testName) {\n                return this.assertEquals(condition, true, testName);\n            },\n            assertFalse: function(condition, testName) {\n                return this.assertEquals(condition, false, testName);\n            }\n        };\n\n        // Function to test: Calculator\n        const calculator = {\n            add: (a, b) => a + b,\n            subtract: (a, b) => a - b,\n            multiply: (a, b) => a * b,\n            divide: (a, b) => b === 0 ? 'Error' : a / b\n        };\n\n        // Function to test: String utilities\n        const stringUtils = {\n            reverse: str => str.split('').reverse().join(''),\n            isPalindrome: str => {\n                const cleaned = str.toLowerCase().replace(/[^a-z0-9]/g, '');\n                return cleaned === cleaned.split('').reverse().join('');\n            }\n        };\n\n        // Function to test: Async function\n        const asyncFunctions = {\n            fetchData: () => {\n                return new Promise(resolve => {\n                    setTimeout(() => {\n                        resolve({ id: 1, name: 'Test Data' });\n                    }, 500);\n                });\n            }\n        };\n\n        // Test cases for calculator\n        function runCalculatorTests() {\n            const resultsContainer = document.getElementById('test1-results');\n            resultsContainer.innerHTML = '<h3>Running Calculator Tests...</h3>';\n            \n            setTimeout(() => {\n                resultsContainer.innerHTML = '';\n                \n                // Test add function\n                resultsContainer.appendChild(\n                    test.assertEquals(calculator.add(2, 3), 5, 'Add 2 and 3')\n                );\n                \n                // Test subtract function\n                resultsContainer.appendChild(\n                    test.assertEquals(calculator.subtract(5, 3), 2, 'Subtract 3 from 5')\n                );\n                \n                // Test multiply function\n                resultsContainer.appendChild(\n                    test.assertEquals(calculator.multiply(2, 4), 8, 'Multiply 2 and 4')\n                );\n                \n                // Test divide function\n                resultsContainer.appendChild(\n                    test.assertEquals(calculator.divide(10, 2), 5, 'Divide 10 by 2')\n                );\n                \n                // Test divide by zero\n                resultsContainer.appendChild(\n                    test.assertEquals(calculator.divide(10, 0), 'Error', 'Divide by zero')\n                );\n            }, 500);\n        }\n\n        // Test cases for string utilities\n        function runStringTests() {\n            const resultsContainer = document.getElementById('test2-results');\n            resultsContainer.innerHTML = '<h3>Running String Tests...</h3>';\n            \n            setTimeout(() => {\n                resultsContainer.innerHTML = '';\n                \n                // Test reverse string\n                resultsContainer.appendChild(\n                    test.assertEquals(stringUtils.reverse('hello'), 'olleh', 'Reverse \"hello\"')\n                );\n                \n                // Test palindrome detection\n                resultsContainer.appendChild(\n                    test.assertTrue(stringUtils.isPalindrome('racecar'), 'Check \"racecar\" is palindrome')\n                );\n                \n                resultsContainer.appendChild(\n                    test.assertFalse(stringUtils.isPalindrome('hello'), 'Check \"hello\" is not palindrome')\n                );\n                \n                resultsContainer.appendChild(\n                    test.assertTrue(stringUtils.isPalindrome('A man, a plan, a canal, Panama!'), 'Check complex palindrome')\n                );\n            }, 500);\n        }\n\n        // Test cases for async functions\n        function runAsyncTests() {\n            const resultsContainer = document.getElementById('test3-results');\n            resultsContainer.innerHTML = '<h3>Running Async Tests...</h3>';\n            \n            asyncFunctions.fetchData()\n                .then(data => {\n                    resultsContainer.innerHTML = '';\n                    \n                    resultsContainer.appendChild(\n                        test.assertEquals(data.id, 1, 'Check returned data id')\n                    );\n                    \n                    resultsContainer.appendChild(\n                        test.assertEquals(data.name, 'Test Data', 'Check returned data name')\n                    );\n                })\n                .catch(error => {\n                    resultsContainer.innerHTML = '';\n                    const errorElement = document.createElement('div');\n                    errorElement.className = 'fail';\n                    errorElement.textContent = `Error: ${error.message}`;\n                    resultsContainer.appendChild(errorElement);\n                });\n        }\n    </script>\n</body>\n</html>"
