    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Suffix Tree Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1em;\n    background: #f8f9fa;\n  }\n  h1 {\n    text-align: center;\n  }\n  #inputSection {\n    max-width: 600px;\n    margin: 0 auto 1em auto;\n    text-align: center;\n  }\n  input[type=text] {\n    font-size: 1.2em;\n    padding: 0.3em;\n    width: 80%;\n    max-width: 400px;\n  }\n  button {\n    font-size: 1.1em;\n    padding: 0.5em 1em;\n    margin-left: 1em;\n    cursor: pointer;\n  }\n  #tree {\n    max-width: 90vw;\n    margin: 0 auto;\n    border: 1px solid #ddd;\n    background: white;\n    overflow: auto;\n    padding: 1em;\n    border-radius: 6px;\n    box-shadow: 0 0 10px #bbb;\n  }\n  svg {\n    width: 100%;\n    height: 600px;\n  }\n  .node circle {\n    fill: #007bff;\n    stroke: #004080;\n    stroke-width: 2px;\n  }\n  .leaf circle {\n    fill: #28a745;\n    stroke: #19692c;\n  }\n  .edge {\n    fill: none;\n    stroke: #555;\n    stroke-width: 2px;\n    marker-end: url(#arrowhead);\n  }\n  text.edgeLabel {\n    font-size: 0.9em;\n    fill: #222;\n    user-select: none;\n  }\n  text.nodeLabel {\n    font-size: 1em;\n    fill: #fff;\n    pointer-events: none;\n    user-select: none;\n    font-weight: bold;\n  }\n  #info {\n    max-width: 600px;\n    margin: 1em auto;\n    background: #e9ecef;\n    padding: 1em;\n    border-radius: 6px;\n    font-size: 1em;\n  }\n  a {\n    color: #007bff;\n  }\n</style>\n</head>\n<body>\n<h1>Suffix Tree Visualization</h1>\n<div id=\"inputSection\">\n  <label for=\"inputStr\">Enter a string (only lowercase letters): </label><br />\n  <input type=\"text\" id=\"inputStr\" value=\"banana$\" maxlength=\"30\" />\n  <button id=\"buildBtn\">Build Suffix Tree</button>\n</div>\n\n<div id=\"tree\">\n  <!-- SVG visualization -->\n</div>\n\n<div id=\"info\">\n  <h2>About Suffix Trees</h2>\n  <p>\n    A <strong>Suffix Tree</strong> is a compressed trie containing all the suffixes of a given text as their keys.\n    It allows many useful string operations to be done quickly, such as substring search, pattern matching, and repeated substring detection.\n  </p>\n  <p>\n    The tree displayed shows nodes (blue circles for internal nodes, green for leaves). Edges are labeled with substrings of the input.\n    Each leaf represents a suffix position — the number in a leaf node is the start index of that suffix.\n  </p>\n  <p>\n    The input string is automatically appended with a unique terminal character <code>$</code> to ensure all suffixes end uniquely.\n  </p>\n  <p>\n    For more info, see <a href=\"https://en.wikipedia.org/wiki/Suffix_tree\" target=\"_blank\" rel=\"noopener\">Wikipedia - Suffix Tree</a>.\n  </p>\n</div>\n\n<script>\n// We'll build a simple suffix tree for demonstration using a naive O(n^2) approach\n// (Because Ukkonen's online algorithm is complex for a short demo.)\n// This creates a compressed trie by inserting all suffixes one by one, compressing edges.\n\n// The suffix tree nodes have structure:\n// {\n//   edges: Map<labelFirstChar, { label: string, node: nodeObject }>,\n//   suffixIndex: null or integer for leaves\n// }\n\nclass SuffixTree {\n  constructor(text) {\n    this.text = text;\n    this.root = this._createNode();\n    this._build();\n  }\n  _createNode() {\n    return { edges: new Map(), suffixIndex: null };\n  }\n  _build() {\n    const n = this.text.length;\n    for (let i = 0; i < n; i++) {\n      this._insertSuffix(i);\n    }\n  }\n  // Insert a suffix starting at index pos into the tree\n  _insertSuffix(pos) {\n    let node = this.root;\n    let suffix = this.text.substring(pos);\n    let currentIndex = 0;\n    while (currentIndex < suffix.length) {\n      let firstChar = suffix[currentIndex];\n      if (!node.edges.has(firstChar)) {\n        // No edge starting with this char, add leaf edge:\n        let leafNode = this._createNode();\n        leafNode.suffixIndex = pos;\n        node.edges.set(firstChar, { label: suffix.substring(currentIndex), node: leafNode });\n        return;\n      }\n      // Edge exists, try to match\n      let edge = node.edges.get(firstChar);\n      let label = edge.label;\n      let k = 0;\n      // Walk along the edge label while matching characters from suffix\n      while (k < label.length && currentIndex + k < suffix.length &&\n             label[k] === suffix[currentIndex + k]) {\n        k++;\n      }\n      if (k === label.length) {\n        // Fully matched edge label, go deeper\n        node = edge.node;\n        currentIndex += k;\n      } else {\n        // Split edge at k: create new internal node, split existing edge\n        let existingChild = edge.node;\n        let newInternal = this._createNode();\n        // old edge label tail:\n        let oldLabelTail = label.substring(k);\n        // new edge label tail:\n        let newLabelTail = suffix.substring(currentIndex + k);\n\n        // Replace edge label with prefix part\n        node.edges.set(firstChar, { label: label.substring(0, k), node: newInternal });\n\n        // old edge becomes child of new internal node\n        newInternal.edges.set(oldLabelTail[0], { label: oldLabelTail, node: existingChild });\n\n        // new edge to leaf node\n        let leafNode = this._createNode();\n        leafNode.suffixIndex = pos;\n        newInternal.edges.set(newLabelTail[0], { label: newLabelTail, node: leafNode });\n        return;\n      }\n    }\n    // If we finish matching suffix fully in an internal node, mark suffixIndex here\n    if (node.suffixIndex === null) {\n      node.suffixIndex = pos;\n    }\n  }\n}\n\n// Visualization with SVG\n\nclass TreeVisualizer {\n  constructor(container, tree, text) {\n    this.container = container;\n    this.tree = tree;\n    this.text = text;\n    this.svgNS = \"http://www.w3.org/2000/svg\";\n\n    this.nodeRadius = 18;\n    this.levelHeight = 90;\n    this.horizontalSpacing = 20;\n\n    // Positions for drawing\n    this.positions = new Map(); // node -> {x, y}\n\n    // We'll do a simplified layout: \n    // Each node placed vertically by level,\n    // Horizontally spaced by subtree width.\n\n    this.gEdges = null;\n    this.gNodes = null;\n\n    this.buildSVG();\n  }\n\n  buildSVG() {\n    this.svg = document.createElementNS(this.svgNS, \"svg\");\n    this.container.innerHTML = \"\";\n    this.container.appendChild(this.svg);\n\n    this.svg.setAttribute(\"width\", \"100%\");\n    this.svg.setAttribute(\"height\", \"600\");\n    this.svg.setAttribute(\"viewBox\", \"0 0 1000 600\");\n    this.svg.style.maxWidth = \"100%\";\n    this.svg.style.height = \"auto\";\n\n    // Arrowhead marker\n    const defs = document.createElementNS(this.svgNS, \"defs\");\n    const marker = document.createElementNS(this.svgNS, \"marker\");\n    marker.setAttribute(\"id\", \"arrowhead\");\n    marker.setAttribute(\"markerWidth\", \"10\");\n    marker.setAttribute(\"markerHeight\", \"7\");\n    marker.setAttribute(\"refX\", \"10\");\n    marker.setAttribute(\"refY\", \"3.5\");\n    marker.setAttribute(\"orient\", \"auto\");\n    marker.style.fill = \"#555\";\n    const path = document.createElementNS(this.svgNS, \"path\");\n    path.setAttribute(\"d\", \"M0,0 L10,3.5 L0,7 Z\");\n    marker.appendChild(path);\n    defs.appendChild(marker);\n    this.svg.appendChild(defs);\n\n    this.gEdges = document.createElementNS(this.svgNS, \"g\");\n    this.gNodes = document.createElementNS(this.svgNS, \"g\");\n    this.svg.appendChild(this.gEdges);\n    this.svg.appendChild(this.gNodes);\n\n    this.draw();\n  }\n\n  // Compute subtree widths bottom-up to layout tree nodes horizontally without overlap\n  computeSubtreeWidths(node) {\n    // Return the width required by this subtree\n    if (!node) return 0;\n    if (node.edges.size === 0) {\n      // leaf node width reserved as nodeDiameter\n      return this.nodeRadius * 2 + this.horizontalSpacing;\n    }\n    let width = 0;\n    for (let [, edge] of node.edges) {\n      width += this.computeSubtreeWidths(edge.node);\n    }\n    // Ensure minimum spacing if no edges (should not happen)\n    return Math.max(width, this.nodeRadius * 2 + this.horizontalSpacing);\n  }\n\n  layoutPositions() {\n    // We fix Y by level (depth) and X by accumulated subtree widths\n\n    const positions = this.positions;\n    const self = this;\n\n    function dfs(node, depth, xLeft) {\n      const y = depth * self.levelHeight + self.nodeRadius + 20;\n      if (node.edges.size === 0) {\n        // leaf node - assign center and return width\n        const width = self.nodeRadius * 2 + self.horizontalSpacing;\n        const x = xLeft + width / 2;\n        positions.set(node, { x, y });\n        return width;\n      }\n      // Internal node - assign center of children span\n      let curX = xLeft;\n      let childrenWidths = [];\n      for (let [, edge] of node.edges) {\n        let w = dfs(edge.node, depth + 1, curX);\n        childrenWidths.push(w);\n        curX += w;\n      }\n      let totalWidth = childrenWidths.reduce((a, b) => a + b, 0);\n      let x = xLeft + totalWidth / 2;\n      positions.set(node, { x, y });\n      return totalWidth;\n    }\n    dfs(this.tree.root, 0, 10);\n  }\n\n  drawEdge(x1, y1, x2, y2, label) {\n    const line = document.createElementNS(this.svgNS, \"path\");\n\n    // Draw a simple straight line for edges\n    // Optionally, later can do curved edges\n    const delta = 0;\n    const pathString = `M${x1},${y1} L${x2},${y2}`;\n    line.setAttribute(\"d\", pathString);\n    line.classList.add(\"edge\");\n    this.gEdges.appendChild(line);\n\n    // Text label positioned at 60% of the way from parent to child, slightly above the edge line\n    const text = document.createElementNS(this.svgNS, \"text\");\n    text.classList.add(\"edgeLabel\");\n    const textX = x1 + (x2 - x1) * 0.6;\n    const textY = y1 + (y2 - y1) * 0.6 - 5;\n    text.setAttribute(\"x\", textX);\n    text.setAttribute(\"y\", textY);\n    text.textContent = label;\n    this.gEdges.appendChild(text);\n  }\n\n  drawNode(x, y, label, isLeaf) {\n    const group = document.createElementNS(this.svgNS, \"g\");\n    group.classList.add(\"node\");\n    if (isLeaf) group.classList.add(\"leaf\");\n    group.setAttribute(\"transform\", `translate(${x},${y})`);\n\n    const circle = document.createElementNS(this.svgNS, \"circle\");\n    circle.setAttribute(\"r\", this.nodeRadius);\n    group.appendChild(circle);\n\n    const text = document.createElementNS(this.svgNS, \"text\");\n    text.classList.add(\"nodeLabel\");\n    text.setAttribute(\"text-anchor\", \"middle\");\n    text.setAttribute(\"dominant-baseline\", \"middle\");\n    text.textContent = label;\n    group.appendChild(text);\n\n    this.gNodes.appendChild(group);\n  }\n\n  draw() {\n    this.gEdges.innerHTML = \"\";\n    this.gNodes.innerHTML = \"\";\n\n    this.layoutPositions();\n\n    // Draw edges and nodes with DFS\n\n    const self = this;\n    const positions = this.positions;\n\n    // count nodes to label internal nodes after leaves (for internal node numbering)\n    let internalNodeCount = 0;\n\n    function dfs(node) {\n      const pos = positions.get(node);\n      const isLeaf = node.edges.size === 0;\n      let label = \"\";\n      if (isLeaf) {\n        // Leaf label = suffixIndex\n        label = node.suffixIndex.toString();\n      } else {\n        label = \"N\" + (++internalNodeCount);\n      }\n      self.drawNode(pos.x, pos.y, label, isLeaf);\n\n      for (let [ch, edge] of node.edges) {\n        const childPos = positions.get(edge.node);\n        self.drawEdge(pos.x, pos.y + self.nodeRadius, childPos.x, childPos.y - self.nodeRadius, edge.label);\n        dfs(edge.node);\n      }\n    }\n\n    dfs(this.tree.root);\n  }\n}\n\nfunction sanitizeInput(str) {\n  // only allow lowercase a-z, and append $ if not present at end\n  let s = str.toLowerCase().replace(/[^a-z]/g, \"\");\n  if (!s.endsWith(\"$\")) s += \"$\";\n  return s;\n}\n\ndocument.getElementById(\"buildBtn\").addEventListener(\"click\", () => {\n  let inputStr = document.getElementById(\"inputStr\").value;\n  if (!inputStr.length) {\n    alert(\"Please enter a non-empty string.\");\n    return;\n  }\n  let text = sanitizeInput(inputStr);\n  // Inform user if we modified string\n  if (inputStr !== text) {\n    alert(`Input sanitized to '${text}'. Only lowercase letters a-z allowed, appended '$' terminal symbol.`);\n    document.getElementById(\"inputStr\").value = text;\n  }\n  // Build suffix tree\n  try {\n    const st = new SuffixTree(text);\n    const container = document.getElementById(\"tree\");\n    new TreeVisualizer(container, st, text);\n  } catch (e) {\n    alert(\"Error building suffix tree: \" + e.message);\n    console.error(e);\n  }\n});\n\n// Initial build\ndocument.getElementById(\"buildBtn\").click();\n</script>\n</body>\n</html>"
  },
