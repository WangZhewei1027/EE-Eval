    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #tree {\n            width: 800px;\n            margin: 40px auto;\n            text-align: center;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tree\"></div>\n\n    <script>\n        class Node {\n            constructor(key) {\n                this.key = key;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        function insert(root, key) {\n            if (root === null) {\n                return new Node(key);\n            } else {\n                if (key < root.key) {\n                    root.left = insert(root.left, key);\n                } else {\n                    root.right = insert(root.right, key);\n                }\n            }\n            return root;\n        }\n\n        function inorder(root) {\n            if (root !== null) {\n                inorder(root.left);\n                document.getElementById(\"tree\").innerHTML += \"<br>Key: \" + root.key + \" - Left: \" + root.left.key + \" - Right: \" + root.right.key + \"<br>\";\n                inorder(root.right);\n            }\n        }\n\n        function search(root, key) {\n            if (root === null || root.key === key) {\n                return root;\n            } else if (key < root.key) {\n                return search(root.left, key);\n            } else {\n                return search(root.right, key);\n            }\n        }\n\n        function deleteNode(root, key) {\n            if (root === null) {\n                return root;\n            } else if (key < root.key) {\n                root.left = deleteNode(root.left, key);\n            } else if (key > root.key) {\n                root.right = deleteNode(root.right, key);\n            } else {\n                if (root.left === null && root.right === null) {\n                    return null;\n                } else if (root.left === null) {\n                    return root.right;\n                } else if (root.right === null) {\n                    return root.left;\n                } else {\n                    let minVal = root.left.key;\n                    let minIndex = 0;\n                    for (let i = 0; i < root.right.length; i++) {\n                        if (root.right[i].key < minVal) {\n                            minVal = root.right[i].key;\n                            minIndex = i;\n                        }\n                    }\n                    root.key = minVal;\n                    root.right = deleteNode(root.right, minVal);\n                }\n            }\n            return root;\n        }\n\n        let root = null;\n\n        // Insert keys into the BST\n        for (let i = 0; i < 10; i++) {\n            root = insert(root, i);\n        }\n\n        // Display keys in the BST using inorder traversal\n        inorder(root);\n\n        // Search for a key in the BST\n        let found = search(root, 5);\n        if (found !== null) {\n            document.getElementById(\"tree\").innerHTML += \"<br>Key: \" + found.key + \" - Left: \" + found.left.key + \" - Right: \" + found.right.key + \"<br>\";\n        } else {\n            document.getElementById(\"tree\").innerHTML += \"<br>Key not found in the BST\";\n        }\n\n        // Delete a key from the BST\n        root = deleteNode(root, 5);\n        inorder(root);\n    </script>\n</body>\n</html>"
