    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>JavaScript Array Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        button {\n            margin-top: 10px;\n            padding: 10px 15px;\n            font-size: 16px;\n        }\n        pre {\n            background-color: #f4f4f4;\n            padding: 10px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>JavaScript Array Demonstration</h1>\n\n<p>Click the button below to see the array operations in action!</p>\n<button id=\"run-array-demo\">Run Array Demo</button>\n\n<h2>Output:</h2>\n<pre id=\"output\"></pre>\n\n<script>\n    document.getElementById('run-array-demo').addEventListener('click', function() {\n        // Initialize an array\n        let fruits = ['Apple', 'Banana', 'Cherry'];\n\n        // Display original array\n        let output = 'Original array: ' + JSON.stringify(fruits) + '\\n\\n';\n\n        // Add an element\n        fruits.push('Mango');\n        output += 'After adding Mango: ' + JSON.stringify(fruits) + '\\n';\n\n        // Remove an element\n        fruits.pop();\n        output += 'After removing last element: ' + JSON.stringify(fruits) + '\\n';\n\n        // Access an element by index\n        output += 'First fruit: ' + fruits[0] + '\\n';\n\n        // Loop through the array\n        output += 'All fruits:\\n';\n        for (let i = 0; i < fruits.length; i++) {\n            output += (i + 1) + ': ' + fruits[i] + '\\n';\n        }\n\n        // Array length\n        output += 'Total number of fruits: ' + fruits.length;\n\n        // Display the output\n        document.getElementById('output').innerText = output;\n    });\n</script>\n\n</body>\n</html>"
