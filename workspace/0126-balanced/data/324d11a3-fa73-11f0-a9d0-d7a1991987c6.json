    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Suffix Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #tree {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-top: 20px;\n            max-height: 400px;\n            overflow-y: auto;\n            white-space: nowrap;\n        }\n        .node {\n            margin-left: 20px;\n            display: inline-block;\n        }\n    </style>\n</head>\n<body>\n    <h1>Suffix Tree Visualization</h1>\n    <label for=\"inputString\">Enter a string:</label>\n    <input type=\"text\" id=\"inputString\" value=\"ban\">\n    <button onclick=\"buildSuffixTree()\">Build Suffix Tree</button>\n\n    <div id=\"tree\"></div>\n\n    <script>\n        class SuffixTreeNode {\n            constructor() {\n                this.children = {};\n            }\n        }\n\n        class SuffixTree {\n            constructor(text) {\n                this.text = text;\n                this.root = new SuffixTreeNode();\n                this.buildTree();\n            }\n\n            buildTree() {\n                const n = this.text.length;\n                for (let i = 0; i < n; i++) {\n                    this.addSuffix(i);\n                }\n            }\n\n            addSuffix(index) {\n                let currentNode = this.root;\n                for (let i = index; i < this.text.length; i++) {\n                    const char = this.text[i];\n                    if (!currentNode.children[char]) {\n                        currentNode.children[char] = new SuffixTreeNode();\n                    }\n                    currentNode = currentNode.children[char];\n                }\n            }\n\n            visualize() {\n                const container = document.getElementById('tree');\n                container.innerHTML = '';\n                this.recursiveVisualize(container, this.root, '');\n            }\n\n            recursiveVisualize(container, node, path) {\n                for (const char in node.children) {\n                    const newPath = path + char;\n                    const newNode = document.createElement('div');\n                    newNode.className = 'node';\n                    newNode.textContent = newPath;\n                    container.appendChild(newNode);\n                    this.recursiveVisualize(container, node.children[char], newPath);\n                }\n            }\n        }\n\n        function buildSuffixTree() {\n            const inputString = document.getElementById('inputString').value;\n            const suffixTree = new SuffixTree(inputString);\n            suffixTree.visualize();\n        }\n    </script>\n</body>\n</html>"
