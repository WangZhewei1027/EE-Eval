    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>NoSQL Concept Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            background-color: #f9f9f9;\n        }\n        .container {\n            max-width: 600px;\n            margin: auto;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 5px;\n            background: white;\n        }\n        h2 {\n            text-align: center;\n        }\n        input, button {\n            width: 100%;\n            padding: 10px;\n            margin: 5px 0;\n        }\n        #output {\n            margin-top: 20px;\n            border: 1px solid #ddd;\n            padding: 10px;\n            background: #f0f0f0;\n            white-space: pre-wrap;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"container\">\n    <h2>NoSQL Database Simulation</h2>\n    <input type=\"text\" id=\"name\" placeholder=\"Enter Name\">\n    <input type=\"text\" id=\"email\" placeholder=\"Enter Email\">\n    <button id=\"addDataBtn\">Add Data</button>\n    <button id=\"showDataBtn\">Show Data</button>\n\n    <div id=\"output\"></div>\n</div>\n\n<script>\n    // Simulated NoSQL Database using a simple JavaScript object\n    let noSqlDatabase = {\n        users: []\n    };\n\n    // Function to add user data\n    function addUser() {\n        const name = document.getElementById('name').value;\n        const email = document.getElementById('email').value;\n\n        if (name && email) {\n            noSqlDatabase.users.push({ name, email });\n            document.getElementById('name').value = '';\n            document.getElementById('email').value = '';\n            alert('User added.');\n        } else {\n            alert('Please fill in both fields.');\n        }\n    }\n\n    // Function to show stored user data\n    function showData() {\n        const output = document.getElementById('output');\n        output.innerHTML = JSON.stringify(noSqlDatabase, null, 2);\n    }\n\n    // Event listeners\n    document.getElementById('addDataBtn').addEventListener('click', addUser);\n    document.getElementById('showDataBtn').addEventListener('click', showData);\n</script>\n\n</body>\n</html>"
