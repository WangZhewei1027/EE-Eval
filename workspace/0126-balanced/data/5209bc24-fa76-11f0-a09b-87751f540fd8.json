    "content": "<html>\n<head>\n    <title>Two Pointers</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>Two Pointers Example</h1>\n    <p>Two Pointers</p>\n    <button id=\"two-pointers-example\">Two Pointers Example</button>\n    <script>\n        function twoPointers() {\n            let arr = [1, 2, 3, 4, 5];\n            let sum1 = 0;\n            let sum2 = 0;\n\n            // Initialize two pointers at the beginning of the array\n            let left = 0;\n            let right = arr.length - 1;\n\n            // Traverse the array using two pointers\n            while (left <= right) {\n                sum1 += arr[left];\n                sum2 += arr[right];\n\n                // Move the pointers based on the sum of elements at the pointers\n                if (sum1 > sum2) {\n                    left++;\n                } else {\n                    right--;\n                }\n            }\n\n            // Print the result\n            console.log(\"Sum of elements at the two pointers:\", sum1);\n            console.log(\"Sum of elements at the other two pointers:\", sum2);\n        }\n\n        // Add a button to trigger the two pointers example\n        document.getElementById(\"two-pointers-example\").addEventListener(\"click\", twoPointers);\n    </script>\n</body>\n</html>"
