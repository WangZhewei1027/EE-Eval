    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Hash Table Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f7f9fc;\n    color: #333;\n  }\n  h1 {\n    color: #2a659e;\n  }\n  .container {\n    max-width: 600px;\n    margin: auto;\n  }\n  label {\n    font-weight: bold;\n  }\n  input[type=text] {\n    padding: 0.5rem;\n    font-size: 1rem;\n    width: 100%;\n    margin-top: 0.3rem;\n    margin-bottom: 1rem;\n    box-sizing: border-box;\n  }\n  button {\n    padding: 0.6rem 1.2rem;\n    background-color: #2a659e;\n    border: none;\n    color: white;\n    font-size: 1rem;\n    margin-right: 1rem;\n    cursor: pointer;\n    border-radius: 3px;\n  }\n  button:hover {\n    background-color: #1e496d;\n  }\n  .output {\n    background: white;\n    border: 1px solid #ddd;\n    padding: 1rem;\n    margin-top: 1rem;\n    min-height: 120px;\n    white-space: pre-wrap;\n    font-family: 'Courier New', Courier, monospace;\n  }\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 1rem;\n    font-size: 0.9rem;\n  }\n  th, td {\n    border: 1px solid #bbb;\n    padding: 0.4rem 0.7rem;\n    text-align: left;\n  }\n  th {\n    background-color: #e3eaf4;\n  }\n  .key-cell {\n    width: 30%;\n  }\n  .value-cell {\n    width: 60%;\n  }\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Hash Table Demonstration</h1>\n    <p>\n      This page demonstrates a simple hash table implementation in JavaScript.\n      A hash table stores key-value pairs and uses a hash function to compute the index for each key.\n    </p>\n    <label for=\"keyInput\">Key:</label>\n    <input type=\"text\" id=\"keyInput\" placeholder=\"Enter key...\" />\n\n    <label for=\"valueInput\">Value:</label>\n    <input type=\"text\" id=\"valueInput\" placeholder=\"Enter value for the key...\" />\n\n    <div>\n      <button id=\"insertBtn\">Insert / Update</button>\n      <button id=\"searchBtn\">Search</button>\n      <button id=\"deleteBtn\">Delete</button>\n      <button id=\"clearBtn\" style=\"background-color:#a33;\">Clear Table</button>\n    </div>\n\n    <div class=\"output\" id=\"outputArea\" aria-live=\"polite\" role=\"region\" aria-label=\"Output messages\">\n      Insert some key-value pairs and try searching or deleting keys.\n    </div>\n\n    <h2>Hash Table Buckets (with chaining)</h2>\n    <table aria-label=\"Hash Table contents\">\n      <thead>\n        <tr>\n          <th>Bucket Index</th>\n          <th>Key</th>\n          <th>Value</th>\n        </tr>\n      </thead>\n      <tbody id=\"tableBody\">\n        <!-- Contents dynamically inserted here -->\n      </tbody>\n    </table>\n  </div>\n\n<script>\n  // Simple hash table with separate chaining\n  class HashTable {\n    constructor(size = 16) {\n      this.buckets = new Array(size);\n      for (let i = 0; i < this.buckets.length; i++) {\n        this.buckets[i] = [];\n      }\n      this.size = size;\n    }\n\n    // Simple hash function for string keys\n    hash(key) {\n      let hash = 0;\n      for (let i = 0; i < key.length; i++) {\n        hash = (hash << 5) - hash + key.charCodeAt(i);\n        hash |= 0; // Convert to 32bit integer\n      }\n      // Ensure positive and in bucket range\n      return Math.abs(hash) % this.size;\n    }\n\n    // Insert or update key-value pair\n    insert(key, value) {\n      const index = this.hash(key);\n      const bucket = this.buckets[index];\n\n      for (let pair of bucket) {\n        if (pair.key === key) {\n          pair.value = value; // Update existing key\n          return 'Updated existing key';\n        }\n      }\n      bucket.push({ key, value }); // Insert new key\n      return 'Inserted new key';\n    }\n\n    // Search for a key; return value or null\n    search(key) {\n      const index = this.hash(key);\n      const bucket = this.buckets[index];\n      for (let pair of bucket) {\n        if (pair.key === key) {\n          return pair.value;\n        }\n      }\n      return null;\n    }\n\n    // Delete a key; returns true if deleted, false if not found\n    delete(key) {\n      const index = this.hash(key);\n      const bucket = this.buckets[index];\n      for (let i = 0; i < bucket.length; i++) {\n        if (bucket[i].key === key) {\n          bucket.splice(i, 1);\n          return true;\n        }\n      }\n      return false;\n    }\n\n    // Clear all entries\n    clear() {\n      this.buckets = new Array(this.size);\n      for (let i = 0; i < this.buckets.length; i++) {\n        this.buckets[i] = [];\n      }\n    }\n\n    // Return array of {index, key, value} for display\n    entries() {\n      const all = [];\n      for (let i = 0; i < this.buckets.length; i++) {\n        for (let pair of this.buckets[i]) {\n          all.push({ index: i, key: pair.key, value: pair.value });\n        }\n      }\n      return all;\n    }\n  }\n\n  // Instantiate the hash table\n  const ht = new HashTable(16);\n\n  // DOM elements\n  const keyInput = document.getElementById('keyInput');\n  const valueInput = document.getElementById('valueInput');\n  const outputArea = document.getElementById('outputArea');\n  const insertBtn = document.getElementById('insertBtn');\n  const searchBtn = document.getElementById('searchBtn');\n  const deleteBtn = document.getElementById('deleteBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const tableBody = document.getElementById('tableBody');\n\n  function updateTable() {\n    const entries = ht.entries();\n    tableBody.innerHTML = '';\n    if (entries.length === 0) {\n      const tr = document.createElement('tr');\n      const td = document.createElement('td');\n      td.colSpan = 3;\n      td.style.textAlign = 'center';\n      td.textContent = 'Hash table is empty';\n      tr.appendChild(td);\n      tableBody.appendChild(tr);\n      return;\n    }\n    for (const entry of entries) {\n      const tr = document.createElement('tr');\n      const tdIndex = document.createElement('td');\n      tdIndex.textContent = entry.index;\n\n      const tdKey = document.createElement('td');\n      tdKey.className = 'key-cell';\n      tdKey.textContent = entry.key;\n\n      const tdValue = document.createElement('td');\n      tdValue.className = 'value-cell';\n      tdValue.textContent = entry.value;\n\n      tr.appendChild(tdIndex);\n      tr.appendChild(tdKey);\n      tr.appendChild(tdValue);\n      tableBody.appendChild(tr);\n    }\n  }\n\n  function showMessage(msg, isError = false) {\n    outputArea.textContent = msg;\n    outputArea.style.color = isError ? 'crimson' : 'green';\n  }\n\n  insertBtn.addEventListener('click', () => {\n    const key = keyInput.value.trim();\n    const value = valueInput.value.trim();\n\n    if (key === '') {\n      showMessage('Please enter a key to insert/update.', true);\n      return;\n    }\n    if (value === '') {\n      showMessage('Please enter a value to insert/update.', true);\n      return;\n    }\n\n    const result = ht.insert(key, value);\n    showMessage(`${result}: \"${key}\" -> \"${value}\"`);\n    updateTable();\n  });\n\n  searchBtn.addEventListener('click', () => {\n    const key = keyInput.value.trim();\n    if (key === '') {\n      showMessage('Please enter a key to search.', true);\n      return;\n    }\n    const value = ht.search(key);\n    if (value === null) {\n      showMessage(`Key \"${key}\" not found in hash table.`, true);\n    } else {\n      showMessage(`Found: \"${key}\" -> \"${value}\"`);\n    }\n  });\n\n  deleteBtn.addEventListener('click', () => {\n    const key = keyInput.value.trim();\n    if (key === '') {\n      showMessage('Please enter a key to delete.', true);\n      return;\n    }\n    const deleted = ht.delete(key);\n    if (deleted) {\n      showMessage(`Deleted key \"${key}\" from hash table.`);\n      updateTable();\n    } else {\n      showMessage(`Key \"${key}\" not found in hash table.`, true);\n    }\n  });\n\n  clearBtn.addEventListener('click', () => {\n    ht.clear();\n    showMessage('Cleared the entire hash table.');\n    updateTable();\n  });\n\n  // Initialize\n  updateTable();\n</script>\n</body>\n</html>"
