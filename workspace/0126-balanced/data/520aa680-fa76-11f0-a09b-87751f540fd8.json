    "content": "<html>\n<head>\n    <title>Transaction Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        \n        .container {\n            max-width: 800px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #f9f9f9;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        \n        .transaction {\n            background-color: #fff;\n            padding: 20px;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n            margin-bottom: 20px;\n        }\n        \n        .transaction-title {\n            font-weight: bold;\n            font-size: 18px;\n            margin-bottom: 10px;\n        }\n        \n        .transaction-content {\n            padding: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h2>Transaction Example</h2>\n        <div class=\"transaction\">\n            <h2>Transaction Details</h2>\n            <p>Transaction ID: 12345</p>\n            <p>Transaction Date: 2022-01-01</p>\n            <p>Transaction Time: 12:00 AM</p>\n            <p>Transaction Amount: $100.00</p>\n            <p>Transaction Currency: USD</p>\n        </div>\n        <div class=\"transaction\">\n            <h2>Transaction History</h2>\n            <ul>\n                <li>Transaction 1: 2022-01-01, 12:00 AM, $100.00, USD</li>\n                <li>Transaction 2: 2022-01-02, 12:00 AM, $200.00, USD</li>\n                <li>Transaction 3: 2022-01-03, 12:00 AM, $300.00, USD</li>\n            </ul>\n        </div>\n    </div>\n\n    <script>\n        // Example transaction object\n        const transaction = {\n            id: 12345,\n            date: new Date('2022-01-01T12:00:00.000Z'),\n            time: '12:00 AM',\n            amount: 100.00,\n            currency: 'USD'\n        };\n\n        // Example transaction history\n        const transactionHistory = [\n            { id: 1, date: '2022-01-01T12:00:00.000Z', time: '12:00 AM', amount: 100.00, currency: 'USD' },\n            { id: 2, date: '2022-01-02T12:00:00.000Z', time: '12:00 AM', amount: 200.00, currency: 'USD' },\n            { id: 3, date: '2022-01-03T12:00:00.000Z', time: '12:00 AM', amount: 300.00, currency: 'USD' }\n        ];\n\n        // Function to display transaction details\n        function displayTransactionDetails() {\n            const transactionElement = document.querySelector('.transaction');\n            transactionElement.innerHTML = `\n                <h2>Transaction Details</h2>\n                <p>Transaction ID: ${transaction.id}</p>\n                <p>Transaction Date: ${transaction.date.toLocaleDateString()}</p>\n                <p>Transaction Time: ${transaction.time}</p>\n                <p>Transaction Amount: $${transaction.amount.toFixed(2)}</p>\n                <p>Transaction Currency: ${transaction.currency}</p>\n            `;\n        }\n\n        // Function to display transaction history\n        function displayTransactionHistory() {\n            const transactionHistoryElement = document.querySelector('.transaction');\n            transactionHistoryElement.innerHTML = `\n                <h2>Transaction History</h2>\n                <ul>\n                    ${transactionHistory.map((transaction) => `\n                        <li>Transaction ${transaction.id}: ${transaction.date.toLocaleDateString()}, ${transaction.time}, $${transaction.amount.toFixed(2)}, ${transaction.currency}</li>\n                    `).join('')}\n                </ul>\n            `;\n        }\n\n        // Display transaction details\n        displayTransactionDetails();\n\n        // Display transaction history\n        displayTransactionHistory();\n    </script>\n</body>\n</html>"
