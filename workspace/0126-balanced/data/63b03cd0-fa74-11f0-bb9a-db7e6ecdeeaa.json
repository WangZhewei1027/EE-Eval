    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Hash Map Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      max-width: 700px;\n      margin: 2rem auto;\n      padding: 0 1rem;\n      background: #f9f9f9;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n      color: #2c3e50;\n    }\n    .container {\n      background: white;\n      border-radius: 8px;\n      box-shadow: 0 2px 8px rgb(0 0 0 / 0.1);\n      padding: 1.5rem;\n      margin-top: 1rem;\n    }\n    input, select, button {\n      font-size: 1rem;\n      padding: 0.4rem 0.6rem;\n      margin-right: 0.5rem;\n      border: 1px solid #ddd;\n      border-radius: 4px;\n    }\n    button {\n      background-color: #3498db;\n      color: white;\n      border: none;\n      cursor: pointer;\n      transition: background-color 0.2s;\n    }\n    button:hover {\n      background-color: #2980b9;\n    }\n    table {\n      width: 100%;\n      border-collapse: collapse;\n      margin-top: 1rem;\n    }\n    th, td {\n      border: 1px solid #ddd;\n      padding: 0.6rem;\n      text-align: left;\n    }\n    th {\n      background-color: #2c3e50;\n      color: white;\n    }\n    .log {\n      margin-top: 1rem;\n      background: #eef6fc;\n      border: 1px solid #b3d4fc;\n      padding: 0.8rem;\n      border-radius: 4px;\n      height: 100px;\n      overflow-y: auto;\n      font-family: monospace;\n      font-size: 0.9rem;\n      white-space: pre-wrap;\n    }\n  </style>\n</head>\n<body>\n  <h1>Hash Map Concept Demo in JavaScript</h1>\n  <div class=\"container\" aria-label=\"HashMap operations\">\n    <p>This demo implements a simple <strong>Hash Map</strong> that stores key-value pairs using a hash function and handles collisions by chaining.</p>\n\n    <div>\n      <label for=\"keyInput\">Key:</label>\n      <input type=\"text\" id=\"keyInput\" placeholder=\"Enter key\" />\n      <label for=\"valueInput\">Value:</label>\n      <input type=\"text\" id=\"valueInput\" placeholder=\"Enter value\" />\n      <button id=\"putBtn\">Put</button>\n      <button id=\"getBtn\">Get</button>\n      <button id=\"removeBtn\">Remove</button>\n      <button id=\"clearBtn\" style=\"background-color:#c0392b;\">Clear</button>\n    </div>\n\n    <h2>Current Hash Map State</h2>\n    <table aria-label=\"Hash map table\">\n      <thead>\n        <tr>\n          <th>Bucket Index</th>\n          <th>Key-Value Pairs (Chain)</th>\n        </tr>\n      </thead>\n      <tbody id=\"hashmapBody\">\n        <!-- Filled by JS -->\n      </tbody>\n    </table>\n\n    <h2>Logs</h2>\n    <div class=\"log\" id=\"logArea\" aria-live=\"polite\"></div>\n  </div>\n\n  <script>\n    class HashMap {\n      constructor(size = 10) {\n        this.size = size;\n        this.buckets = new Array(size).fill(null).map(() => []);\n      }\n\n      // Simple hash function to convert string key to a bucket index\n      hash(key) {\n        let hashValue = 0;\n        for (let char of key) {\n          hashValue = (hashValue + char.charCodeAt(0) * 23) % this.size;\n        }\n        return hashValue;\n      }\n\n      // Insert or update key-value\n      put(key, value) {\n        const index = this.hash(key);\n        const bucket = this.buckets[index];\n        for (let entry of bucket) {\n          if (entry.key === key) {\n            entry.value = value;\n            return `Updated key \"${key}\" with new value \"${value}\" in bucket ${index}.`;\n          }\n        }\n        bucket.push({ key, value });\n        return `Inserted key \"${key}\" with value \"${value}\" in bucket ${index}.`;\n      }\n\n      // Retrieve value by key\n      get(key) {\n        const index = this.hash(key);\n        const bucket = this.buckets[index];\n        for (let entry of bucket) {\n          if (entry.key === key) {\n            return `Value for key \"${key}\" found: \"${entry.value}\" (bucket ${index})`;\n          }\n        }\n        return `Key \"${key}\" not found in bucket ${index}.`;\n      }\n\n      // Remove key-value pair\n      remove(key) {\n        const index = this.hash(key);\n        const bucket = this.buckets[index];\n        for (let i = 0; i < bucket.length; i++) {\n          if (bucket[i].key === key) {\n            bucket.splice(i, 1);\n            return `Key \"${key}\" removed from bucket ${index}.`;\n          }\n        }\n        return `Cannot remove: key \"${key}\" not found in bucket ${index}.`;\n      }\n\n      // Clear all entries\n      clear() {\n        this.buckets = new Array(this.size).fill(null).map(() => []);\n        return \"Hash map cleared.\";\n      }\n\n      // Return the entire map for display\n      entries() {\n        return this.buckets.map((bucket, index) => ({\n          index,\n          pairs: bucket.map(e => `${e.key}: ${e.value}`)\n        }));\n      }\n    }\n\n    // UI Elements\n    const keyInput = document.getElementById('keyInput');\n    const valueInput = document.getElementById('valueInput');\n    const putBtn = document.getElementById('putBtn');\n    const getBtn = document.getElementById('getBtn');\n    const removeBtn = document.getElementById('removeBtn');\n    const clearBtn = document.getElementById('clearBtn');\n    const hashmapBody = document.getElementById('hashmapBody');\n    const logArea = document.getElementById('logArea');\n\n    // Initialize HashMap\n    const map = new HashMap(10);\n\n    function renderHashMap() {\n      hashmapBody.innerHTML = '';\n      const entries = map.entries();\n      for (const { index, pairs } of entries) {\n        const row = document.createElement('tr');\n        const indexCell = document.createElement('td');\n        indexCell.textContent = index;\n        const pairsCell = document.createElement('td');\n        pairsCell.textContent = pairs.length ? pairs.join(' → ') : '(empty)';\n        row.appendChild(indexCell);\n        row.appendChild(pairsCell);\n        hashmapBody.appendChild(row);\n      }\n    }\n\n    function log(message) {\n      const time = new Date().toLocaleTimeString();\n      logArea.textContent += `[${time}] ${message}\\n`;\n      logArea.scrollTop = logArea.scrollHeight;\n    }\n\n    putBtn.onclick = () => {\n      const key = keyInput.value.trim();\n      const value = valueInput.value.trim();\n      if (!key) {\n        alert('Please enter a key.');\n        return;\n      }\n      if (!value) {\n        alert('Please enter a value.');\n        return;\n      }\n      const msg = map.put(key, value);\n      log(msg);\n      renderHashMap();\n    };\n\n    getBtn.onclick = () => {\n      const key = keyInput.value.trim();\n      if (!key) {\n        alert('Please enter a key.');\n        return;\n      }\n      const msg = map.get(key);\n      log(msg);\n    };\n\n    removeBtn.onclick = () => {\n      const key = keyInput.value.trim();\n      if (!key) {\n        alert('Please enter a key.');\n        return;\n      }\n      const msg = map.remove(key);\n      log(msg);\n      renderHashMap();\n    };\n\n    clearBtn.onclick = () => {\n      if (confirm('Are you sure you want to clear the entire hash map?')) {\n        const msg = map.clear();\n        log(msg);\n        renderHashMap();\n      }\n    };\n\n    // Initial render\n    renderHashMap();\n  </script>\n</body>\n</html>"
  },
