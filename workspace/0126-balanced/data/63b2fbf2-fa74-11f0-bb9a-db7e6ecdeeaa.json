    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>B-Tree Index Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    padding: 20px;\n    background: #f7f9fc;\n  }\n  h1 {\n    text-align: center;\n  }\n  #btree {\n    margin: 20px auto;\n    text-align: center;\n    user-select: none;\n  }\n  .node {\n    display: inline-block;\n    border: 2px solid #2c3e50;\n    background: #ecf0f1;\n    padding: 8px 12px;\n    border-radius: 8px;\n    margin: 8px;\n    min-width: 60px;\n  }\n  .keys {\n    display: flex;\n    justify-content: space-evenly;\n    font-weight: 600;\n    font-size: 1.2em;\n  }\n  .key {\n    padding: 0 6px;\n    cursor: pointer;\n    user-select: none;\n    border-radius: 4px;\n    transition: background-color 0.3s;\n  }\n  .key.highlight {\n    background-color: #3498db;\n    color: white;\n  }\n  .children {\n    margin-top: 12px;\n    display: flex;\n    justify-content: center;\n  }\n  svg {\n    overflow: visible;\n    margin: auto;\n    display: block;\n  }\n  #controls {\n    text-align: center;\n    margin: 20px 0;\n  }\n  button {\n    margin: 0 6px;\n    font-size: 1em;\n    padding: 8px 14px;\n    border: none;\n    border-radius: 4px;\n    background-color: #2980b9;\n    color: white;\n    cursor: pointer;\n    transition: background-color 0.25s ease;\n  }\n  button:disabled {\n    background-color: #95a5a6;\n    cursor: default;\n  }\n  input[type=\"number\"] {\n    padding: 6px;\n    font-size: 1em;\n    width: 80px;\n    border-radius: 4px;\n    border: 1.5px solid #bdc3c7;\n    text-align: center;\n    margin-right: 10px;\n  }\n  #explanation {\n    max-width: 700px;\n    margin: 30px auto;\n    background: #dff9fb;\n    border: 2px solid #22a6b3;\n    border-radius: 8px;\n    padding: 20px;\n    font-size: 1em;\n    color: #130f40;\n  }\n  #explanation h2 {\n    margin-top: 0;\n  }\n</style>\n</head>\n<body>\n<h1>B-Tree Index Visualization</h1>\n\n<div id=\"controls\">\n  <input type=\"number\" id=\"inputKey\" placeholder=\"Key to insert\" min=\"1\" max=\"99\" />\n  <button id=\"insertBtn\">Insert Key</button>\n  <button id=\"resetBtn\">Reset Tree</button>\n</div>\n\n<div id=\"btree\"></div>\n<div id=\"explanation\">\n  <h2>What is a B-Tree Index?</h2>\n  <p>\n    A <strong>B-Tree</strong> index is a balanced tree data structure that maintains sorted data and allows searches, sequential access, insertions, and deletions in logarithmic time.\n  </p>\n  <p>\n    It is widely used in databases and file systems to efficiently store and retrieve data. In a B-Tree:\n  </p>\n  <ul>\n    <li>Each node can contain multiple keys (between a minimum and maximum degree).</li>\n    <li>Nodes have children pointers defining subtrees between keys.</li>\n    <li>The tree remains balanced by splitting and merging nodes during insertions and deletions.</li>\n  </ul>\n  <p>\n    This visualization demonstrates inserting keys, how the B-Tree nodes split when they overflow, keeping the tree balanced and indexed.\n  </p>\n</div>\n\n<script>\n// B-Tree order (minimum degree t)\n// Each node except root must have at least t-1 keys,\n// At most 2t-1 keys.\nconst t = 3; // You can change the order here\n\n// Node structure\nclass BTreeNode {\n  constructor(leaf = true) {\n    this.leaf = leaf;\n    this.keys = [];\n    this.children = [];\n  }\n\n  // Find index of the first key >= k\n  findKey(k) {\n    let idx = 0;\n    while (idx < this.keys.length && this.keys[idx] < k) {\n      idx++;\n    }\n    return idx;\n  }\n}\n\nclass BTree {\n  constructor(t) {\n    this.t = t;\n    this.root = new BTreeNode(true);\n  }\n\n  // Insert a key in the B-Tree\n  insert(k) {\n    const r = this.root;\n    if (r.keys.length === 2*this.t - 1) {\n      // root is full, need to split\n      const s = new BTreeNode(false);\n      this.root = s;\n      s.children.push(r);\n      this.splitChild(s, 0);\n      this.insertNonFull(s, k);\n    } else {\n      this.insertNonFull(r, k);\n    }\n  }\n\n  // Insert k into a node that is guaranteed not full\n  insertNonFull(x, k) {\n    let i = x.keys.length - 1;\n    if (x.leaf) {\n      // Insert key in leaf by shifting larger keys right and inserting k\n      while (i >= 0 && k < x.keys[i]) {\n        i--;\n      }\n      if (x.keys[i+1] === k) return; // no duplicates - safety\n      x.keys.splice(i + 1, 0, k);\n    } else {\n      // Internal node\n      // Find the child we should insert key into\n      while (i >= 0 && k < x.keys[i]) {\n        i--;\n      }\n      i++;\n      if (i < x.children.length) {\n        if (x.children[i].keys.length === 2*this.t - 1) {\n          this.splitChild(x, i);\n          if (k > x.keys[i]) i++;\n        }\n        this.insertNonFull(x.children[i], k);\n      }\n    }\n  }\n\n  // Split the full child y of node x at index i\n  splitChild(x, i) {\n    const t = this.t;\n    const y = x.children[i];\n    const z = new BTreeNode(y.leaf);\n    // z will have t-1 keys from y\n    for (let j = 0; j < t - 1; j++) {\n      z.keys.push(y.keys[j+t]);\n    }\n    if (!y.leaf) {\n      for (let j = 0; j < t; j++) {\n        z.children.push(y.children[j+t]);\n      }\n      y.children.splice(t, t);\n    }\n    y.keys.splice(t - 1, t);\n    x.keys.splice(i, 0, y.keys[t-1]);\n    y.keys.splice(t - 1, 1);\n    x.children.splice(i + 1, 0, z);\n  }\n}\n\n/////////////////////////////\n// Visualization Code Below\n/////////////////////////////\n\nconst container = document.getElementById(\"btree\");\nconst inputKey = document.getElementById(\"inputKey\");\nconst insertBtn = document.getElementById(\"insertBtn\");\nconst resetBtn = document.getElementById(\"resetBtn\");\n\n// Create a BTree instance\nlet btree = new BTree(t);\nrenderTree(btree.root);\n\n// Insert button listener\ninsertBtn.onclick = () => {\n  const val = parseInt(inputKey.value, 10);\n  if (isNaN(val) || val < 1 || val > 99) {\n    alert(\"Please enter a valid integer key between 1 and 99\");\n    return;\n  }\n  // Prevent duplicates by checking if key already exists\n  if (keyExists(btree.root, val)) {\n    alert(\"Key \"+val+\" already exists in the tree.\");\n    return;\n  }\n  btree.insert(val);\n  inputKey.value = \"\";\n  renderTree(btree.root);\n};\n\n// Reset button listener\nresetBtn.onclick = () => {\n  btree = new BTree(t);\n  renderTree(btree.root);\n};\n\nfunction keyExists(node, k) {\n  let i = 0;\n  while (i < node.keys.length && k > node.keys[i]) {\n    i++;\n  }\n  if (i < node.keys.length && node.keys[i] === k) return true;\n  if (node.leaf) return false;\n  return keyExists(node.children[i], k);\n}\n\n// To visualize, for each node we display keys horizontally and children below them.\n// We'll use recursion to place nodes and then draw connecting lines with SVG.\n\nfunction renderTree(root) {\n  container.innerHTML = \"\";\n  // Create SVG for connectors\n  const svg = document.createElementNS(\"http://www.w3.org/2000/svg\", \"svg\");\n  svg.style.position = \"absolute\";\n  svg.style.top = \"0\";\n  svg.style.left = \"0\";\n  svg.style.width = \"100%\";\n  svg.style.height = \"600px\";\n  svg.style.pointerEvents = \"none\";\n  container.style.position = \"relative\";\n  container.appendChild(svg);\n\n  // Recursively create node DOM elements\n  const treeRootDiv = createNodeDiv(root);\n  treeRootDiv.style.margin = \"auto\";\n  container.appendChild(treeRootDiv);\n\n  // After DOM elements are added, compute lines for children connectors\n  drawConnections(treeRootDiv, svg);\n}\n\nfunction createNodeDiv(node) {\n  const nodeDiv = document.createElement(\"div\");\n  nodeDiv.classList.add(\"node\");\n  nodeDiv.style.display = \"inline-block\";\n  nodeDiv.style.verticalAlign = \"top\";\n\n  // Keys container\n  const keysDiv = document.createElement(\"div\");\n  keysDiv.classList.add(\"keys\");\n\n  node.keys.forEach(key => {\n    const keyDiv = document.createElement(\"div\");\n    keyDiv.classList.add(\"key\");\n    keyDiv.textContent = key;\n    keysDiv.appendChild(keyDiv);\n  });\n  nodeDiv.appendChild(keysDiv);\n\n  if (!node.leaf) {\n    const childrenDiv = document.createElement(\"div\");\n    childrenDiv.classList.add(\"children\");\n\n    node.children.forEach(childNode => {\n      const childDiv = createNodeDiv(childNode);\n      childrenDiv.appendChild(childDiv);\n    });\n    nodeDiv.appendChild(childrenDiv);\n  }\n\n  return nodeDiv;\n}\n\n// Draw connecting lines from parent node to children nodes\nfunction drawConnections(nodeDiv, svg) {\n  // For each node div that has children, draw lines from keys box to children nodes\n  const childrenDiv = nodeDiv.querySelector(\":scope > .children\");\n  if (!childrenDiv) return;\n\n  const keysDiv = nodeDiv.querySelector(\":scope > .keys\");\n  if (!keysDiv) return;\n\n  // Get parent keysDiv bounding rect\n  const parentRect = keysDiv.getBoundingClientRect();\n\n  // container bounding rect to calculate relative positions\n  const containerRect = container.getBoundingClientRect();\n\n  // Horizontal spacing of keys inside the keysDiv\n  const keyDivs = keysDiv.querySelectorAll(\":scope > .key\");\n  // Compute centers of each key's bounding box relative to container\n  const keyCenters = Array.from(keyDivs).map(keyDiv => {\n    const r = keyDiv.getBoundingClientRect();\n    return {\n      x: r.left + r.width/2 - containerRect.left,\n      y: r.bottom - containerRect.top\n    };\n  });\n\n  // Now for childrenDiv: children are nodes corresponding roughly to intervals between keys\n  const childNodes = Array.from(childrenDiv.children);\n\n  // Compute centers of each child top\n  const childCenters = childNodes.map(child => {\n    const r = child.querySelector(\":scope > .keys\").getBoundingClientRect();\n    return {\n      x: r.left + r.width/2 - containerRect.left,\n      y: r.top - containerRect.top\n    };\n  });\n\n  // We draw lines from key centers and also from between keys to children:\n\n  // For a B-tree node with n keys and n+1 children:\n  // child i corresponds to keys intervals:\n  // child0: < key0\n  // child1: between key0 and key1\n  // ...\n  // child n: > key n-1\n\n  // We'll draw lines from a midpoint of keys or from key edges to children to make visually clear\n\n  // For simplicity draw line from middle between keys to children:\n\n  // Define parent points to connect for each child\n  let parentPoints = [];\n  if (keyCenters.length === 0) {\n    // No keys - edge case, just connect center of keysDiv bottom to children top\n    const centerX = parentRect.left + parentRect.width/2 - containerRect.left;\n    parentPoints = Array(childCenters.length).fill({x:centerX, y: parentRect.bottom - containerRect.top});\n  } else {\n    // parentPoints length = childCenters length = keys.length + 1\n    // For each child i:\n    // if i == 0: point midway left of first key\n    // if 0 < i < keys.length: midpoint between keys[i-1] and keys[i]\n    // if i == keys.length: midway right of last key\n    const firstKey = keyCenters[0];\n    const lastKey = keyCenters[keyCenters.length-1];\n    parentPoints.push({\n      x: firstKey.x - (firstKey.x - parentRect.left + 8), // a bit to left to visually separate\n      y: parentRect.bottom - containerRect.top\n    });\n    for (let i = 1; i < keyCenters.length; i++) {\n      parentPoints.push({\n        x: (keyCenters[i-1].x + keyCenters[i].x) / 2,\n        y: parentRect.bottom - containerRect.top\n      });\n    }\n    parentPoints.push({\n      x: lastKey.x + (parentRect.right - lastKey.x - containerRect.left + 8), // a bit to right\n      y: parentRect.bottom - containerRect.top\n    });\n  }\n\n  // Draw lines with SVG\n  for (let i = 0; i < childCenters.length; i++) {\n    const p = parentPoints[i];\n    const c = childCenters[i];\n    const line = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n    line.setAttribute(\"x1\", p.x);\n    line.setAttribute(\"y1\", p.y);\n    line.setAttribute(\"x2\", c.x);\n    line.setAttribute(\"y2\", c.y);\n    line.setAttribute(\"stroke\", \"#34495e\");\n    line.setAttribute(\"stroke-width\", \"2\");\n    svg.appendChild(line);\n  }\n\n  // Recurse on children\n  childNodes.forEach(child => {\n    drawConnections(child, svg);\n  });\n}\n\n// Initial seed keys:\nconst initialKeys = [10, 20, 5, 6, 12, 30, 7, 17];\ninitialKeys.forEach(k => btree.insert(k));\nrenderTree(btree.root);\n\n</script>\n</body>\n</html>"
  },
