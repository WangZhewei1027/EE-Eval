    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Asymmetric Cryptography Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    color: #007acc;\n  }\n  label {\n    display: block;\n    margin-top: 1rem;\n    font-weight: bold;\n  }\n  textarea, input[type=\"text\"] {\n    width: 100%;\n    font-family: monospace;\n    font-size: 1rem;\n    padding: 0.4rem;\n    margin-top: 0.3rem;\n    box-sizing: border-box;\n  }\n  button {\n    margin-top: 1rem;\n    padding: 0.6rem 1rem;\n    font-size: 1rem;\n    background-color: #007acc;\n    border: none;\n    color: white;\n    border-radius: 4px;\n    cursor: pointer;\n  }\n  button:disabled {\n    background-color: #999;\n    cursor: not-allowed;\n  }\n  .output {\n    background: #eaeaea;\n    padding: 1rem;\n    margin-top: 0.5rem;\n    white-space: pre-wrap;\n    word-wrap: break-word;\n    border-radius: 4px;\n  }\n  .section {\n    margin-bottom: 2rem;\n  }\n  .key-info {\n    font-size: 0.9rem;\n    color: #555;\n    margin-top: 0.25rem;\n  }\n</style>\n</head>\n<body>\n<h1>Asymmetric Cryptography Demo (RSA with Web Crypto API)</h1>\n<p>This demo uses your browser's <strong>Web Crypto API</strong> to generate an RSA key pair and demonstrate asymmetric encryption and decryption. The private key is never shared and is used to decrypt; the public key is used to encrypt.</p>\n\n<div class=\"section\">\n  <button id=\"generate-keys-btn\">Generate RSA Key Pair</button>\n  <div id=\"keys-info\" class=\"key-info\"></div>\n  <label for=\"publicKeyPem\">Public Key (PEM encoded):</label>\n  <textarea id=\"publicKeyPem\" readonly rows=\"8\" placeholder=\"Public key will appear here...\"></textarea>\n\n  <label for=\"privateKeyPem\">Private Key (PEM encoded):</label>\n  <textarea id=\"privateKeyPem\" readonly rows=\"10\" placeholder=\"Private key will appear here...\"></textarea>\n</div>\n\n<div class=\"section\">\n  <label for=\"plaintext\">Plaintext to Encrypt:</label>\n  <textarea id=\"plaintext\" rows=\"4\" placeholder=\"Type message here...\"></textarea>\n  <button id=\"encrypt-btn\" disabled>Encrypt with Public Key</button>\n\n  <label for=\"ciphertextBase64\">Ciphertext (Base64):</label>\n  <textarea id=\"ciphertextBase64\" readonly rows=\"4\" placeholder=\"Encrypted message appears here...\"></textarea>\n\n  <button id=\"decrypt-btn\" disabled>Decrypt with Private Key</button>\n  <label for=\"decryptedText\">Decrypted Text:</label>\n  <textarea id=\"decryptedText\" readonly rows=\"4\" placeholder=\"Decrypted message appears here...\"></textarea>\n</div>\n\n<script>\n(async function() {\n  // Elements\n  const generateBtn = document.getElementById('generate-keys-btn');\n  const keysInfo = document.getElementById('keys-info');\n  const publicKeyPemEl = document.getElementById('publicKeyPem');\n  const privateKeyPemEl = document.getElementById('privateKeyPem');\n  const plaintextEl = document.getElementById('plaintext');\n  const encryptBtn = document.getElementById('encrypt-btn');\n  const ciphertextEl = document.getElementById('ciphertextBase64');\n  const decryptBtn = document.getElementById('decrypt-btn');\n  const decryptedTextEl = document.getElementById('decryptedText');\n\n  let publicKey, privateKey;\n\n  function bufToBase64(buffer) {\n    return btoa(String.fromCharCode(...new Uint8Array(buffer)));\n  }\n\n  function base64ToBuf(base64) {\n    const binary = atob(base64);\n    const len = binary.length;\n    const bytes = new Uint8Array(len);\n    for(let i=0; i<len; i++) {\n      bytes[i] = binary.charCodeAt(i);\n    }\n    return bytes.buffer;\n  }\n\n  // Convert CryptoKey to PEM format\n  async function exportKey(key) {\n    let exported = await window.crypto.subtle.exportKey(\n      key.type === 'public' ? 'spki' : 'pkcs8',\n      key\n    );\n    const exportedAsBase64 = bufToBase64(exported);\n    const exportedAsPem = pemFormat(exportedAsBase64, key.type === 'public' ? 'PUBLIC KEY' : 'PRIVATE KEY');\n    return exportedAsPem;\n  }\n\n  function pemFormat(base64String, label) {\n    const lineLength = 64;\n    const lines = [];\n    for (let i=0; i < base64String.length; i += lineLength) {\n      lines.push(base64String.slice(i, i + lineLength));\n    }\n    return `-----BEGIN ${label}-----\\n${lines.join('\\n')}\\n-----END ${label}-----`;\n  }\n\n  // Import PEM key string back to CryptoKey\n  async function importPublicKey(pem) {\n    // Remove PEM header/footer and line breaks\n    const b64 = pem.replace(/-----BEGIN PUBLIC KEY-----/, '')\n                   .replace(/-----END PUBLIC KEY-----/, '')\n                   .replace(/\\s/g, '');\n    const binaryDer = base64ToBuf(b64);\n    return await window.crypto.subtle.importKey(\n      'spki',\n      binaryDer,\n      {\n        name: 'RSA-OAEP',\n        hash: 'SHA-256',\n      },\n      true,\n      ['encrypt']\n    );\n  }\n\n  async function importPrivateKey(pem) {\n    const b64 = pem.replace(/-----BEGIN PRIVATE KEY-----/, '')\n                   .replace(/-----END PRIVATE KEY-----/, '')\n                   .replace(/\\s/g, '');\n    const binaryDer = base64ToBuf(b64);\n    return await window.crypto.subtle.importKey(\n      'pkcs8',\n      binaryDer,\n      {\n        name: 'RSA-OAEP',\n        hash: 'SHA-256',\n      },\n      true,\n      ['decrypt']\n    );\n  }\n\n  // Generate RSA key pair\n  async function generateKeyPair() {\n    keysInfo.textContent = \"Generating keys, please wait...\";\n    try {\n      const keypair = await window.crypto.subtle.generateKey(\n        {\n          name: 'RSA-OAEP',\n          modulusLength: 2048,\n          publicExponent: new Uint8Array([0x01, 0x00, 0x01]),\n          hash: 'SHA-256',\n        },\n        true,\n        ['encrypt', 'decrypt']\n      );\n      publicKey = keypair.publicKey;\n      privateKey = keypair.privateKey;\n\n      const pubPem = await exportKey(publicKey);\n      const privPem = await exportKey(privateKey);\n\n      publicKeyPemEl.value = pubPem;\n      privateKeyPemEl.value = privPem;\n\n      keysInfo.textContent = \"RSA 2048-bit key pair generated successfully.\";\n      encryptBtn.disabled = false;\n      decryptBtn.disabled = true;\n      ciphertextEl.value = \"\";\n      decryptedTextEl.value = \"\";\n    } catch (e) {\n      keysInfo.textContent = \"Error generating keys: \" + e.message;\n    }\n  }\n\n  // Encrypt plaintext with public key\n  async function encryptText() {\n    if (!publicKey) return;\n    const encoder = new TextEncoder();\n    const data = encoder.encode(plaintextEl.value);\n    try {\n      const encrypted = await window.crypto.subtle.encrypt(\n        {\n          name: \"RSA-OAEP\"\n        },\n        publicKey,\n        data\n      );\n      const base64Cipher = bufToBase64(encrypted);\n      ciphertextEl.value = base64Cipher;\n      decryptBtn.disabled = false;\n      decryptedTextEl.value = \"\";\n    } catch(e) {\n      alert('Encryption failed: ' + e.message);\n    }\n  }\n\n  // Decrypt ciphertext with private key\n  async function decryptText() {\n    if (!privateKey) return;\n    try {\n      const cipherBuffer = base64ToBuf(ciphertextEl.value.trim());\n      const decrypted = await window.crypto.subtle.decrypt(\n        {\n          name: \"RSA-OAEP\"\n        },\n        privateKey,\n        cipherBuffer\n      );\n      const decoder = new TextDecoder();\n      decryptedTextEl.value = decoder.decode(decrypted);\n    } catch(e) {\n      alert('Decryption failed: ' + e.message);\n    }\n  }\n\n  generateBtn.addEventListener('click', generateKeyPair);\n  encryptBtn.addEventListener('click', encryptText);\n  decryptBtn.addEventListener('click', decryptText);\n\n})();\n</script>\n</body>\n</html>"
