    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Jump Search Algorithm</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n        .container {\n            max-width: 600px;\n            margin: auto;\n            background: #fff;\n            padding: 20px;\n            border-radius: 8px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        h1 {\n            text-align: center;\n        }\n        input[type=\"text\"], button {\n            width: 100%;\n            padding: 10px;\n            margin: 10px 0;\n            border: 1px solid #ccc;\n            border-radius: 4px;\n        }\n        button {\n            background-color: #28a745;\n            color: white;\n            border: none;\n        }\n        button:hover {\n            background-color: #218838;\n        }\n        .result {\n            margin-top: 20px;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n\n<div class=\"container\">\n    <h1>Jump Search Algorithm</h1>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"Enter sorted numbers (comma separated)\" />\n    <input type=\"text\" id=\"targetInput\" placeholder=\"Enter number to find\" />\n    <button onclick=\"performJumpSearch()\">Search</button>\n    <div class=\"result\" id=\"resultOutput\"></div>\n</div>\n\n<script>\n    function jumpSearch(arr, target) {\n        let n = arr.length;\n        let step = Math.floor(Math.sqrt(n)); // Finding the optimal jump size\n        let prev = 0;\n\n        // Jump forward until the next block has a value greater than target\n        while (arr[Math.min(step, n) - 1] < target) {\n            prev = step;\n            step += Math.floor(Math.sqrt(n));\n            if (prev >= n) return -1; // Target is not in the array\n        }\n\n        // Perform linear search in the identified block\n        while (arr[prev] < target) {\n            prev++;\n            if (prev === Math.min(step, n)) return -1; // Target is not found\n        }\n\n        // If we found our target\n        if (arr[prev] === target) {\n            return prev; // Return the index\n        }\n\n        return -1; // Target is not in the array\n    }\n\n    function performJumpSearch() {\n        const arrayInput = document.getElementById('arrayInput').value;\n        const targetInput = document.getElementById('targetInput').value;\n\n        const arr = arrayInput.split(',').map(num => parseInt(num.trim())).filter(num => !isNaN(num));\n        const target = parseInt(targetInput);\n\n        if (!Array.isArray(arr) || arr.length === 0 || isNaN(target)) {\n            document.getElementById('resultOutput').innerText = \"Please enter a valid sorted array and a target number.\";\n            return;\n        }\n\n        const resultIndex = jumpSearch(arr, target);\n\n        if (resultIndex !== -1) {\n            document.getElementById('resultOutput').innerText = `Element ${target} found at index ${resultIndex}.`;\n        } else {\n            document.getElementById('resultOutput').innerText = `Element ${target} not found in the array.`;\n        }\n    }\n</script>\n\n</body>\n</html>"
