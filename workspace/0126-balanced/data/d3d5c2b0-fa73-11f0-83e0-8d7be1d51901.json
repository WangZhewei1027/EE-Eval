    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Max Heap (Binary Heap) Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#3b82f6;\n      --muted:#94a3b8;\n      --good:#16a34a;\n      --bad:#ef4444;\n      --card:#0b1220;\n      --glass: rgba(255,255,255,0.02);\n      --node-bg:#0b1220;\n    }\n    *{box-sizing:border-box;font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;}\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,#071023,#051027);color:#dbeafe}\n    header{padding:20px 28px;border-bottom:1px solid rgba(255,255,255,0.03);display:flex;align-items:center;gap:18px}\n    header h1{font-size:20px;margin:0}\n    main{padding:18px;display:grid;grid-template-columns:360px 1fr;gap:18px;height:calc(100vh - 74px)}\n    .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:12px;padding:14px;box-shadow: 0 4px 30px rgba(2,6,23,0.6);border:1px solid rgba(255,255,255,0.03)}\n    .controls{display:flex;flex-direction:column;gap:12px}\n    label{font-size:13px;color:var(--muted);margin-bottom:6px;display:block}\n    .row{display:flex;gap:8px;align-items:center}\n    input[type=\"number\"], input[type=\"text\"]{\n      flex:1;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:#e6eef8;\n    }\n    button{\n      background:linear-gradient(180deg,var(--accent),#2563eb);\n      border:none;color:white;padding:10px 12px;border-radius:8px;cursor:pointer;font-weight:600;\n      box-shadow: 0 6px 18px rgba(37,99,235,0.14);\n    }\n    button.secondary{\n      background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted);box-shadow:none;font-weight:500;\n    }\n    button.danger{\n      background:linear-gradient(180deg,#ef4444,#dc2626);\n    }\n    .small{padding:8px 10px;font-size:13px;border-radius:8px}\n    .array-view{display:flex;gap:8px;flex-wrap:wrap;padding:10px;border-radius:8px;background:var(--glass);border:1px dashed rgba(255,255,255,0.02)}\n    .cell{min-width:48px;height:60px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));display:flex;flex-direction:column;align-items:center;justify-content:center;color:#e6eef8;box-shadow: 0 6px 14px rgba(2,6,23,0.5);position:relative;transition:transform .25s ease, background .25s ease, box-shadow .25s ease;}\n    .cell .index{position:absolute;top:6px;left:8px;font-size:11px;color:var(--muted)}\n    .cell.highlight-compare{background:linear-gradient(180deg,#0d3b66,#083256);box-shadow:0 12px 30px rgba(13,59,102,0.2);transform:scale(1.05)}\n    .cell.highlight-swap{background:linear-gradient(180deg,#f97316,#ea580c);box-shadow:0 12px 30px rgba(249,115,22,0.16);transform:scale(1.07)}\n    .cell.peek{background:linear-gradient(180deg,#065f46,#064e3b);box-shadow:0 12px 26px rgba(6,95,70,0.12)}\n    .value{font-size:18px;font-weight:700}\n    .tree-canvas{position:relative;height:360px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));overflow:hidden}\n    svg.lines{position:absolute;inset:0;pointer-events:none}\n    .node{position:absolute;display:flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:50%;background:var(--node-bg);border:1px solid rgba(255,255,255,0.03);box-shadow:0 6px 18px rgba(2,6,23,0.45);color:#e6eef8;transition:transform .2s ease, background .2s ease, box-shadow .2s ease}\n    .node .val{font-weight:700}\n    .node .idx{position:absolute;bottom:-16px;font-size:11px;color:var(--muted)}\n    .node.compare{background:linear-gradient(180deg,#0d3b66,#083256);transform:scale(1.06);box-shadow:0 14px 36px rgba(13,59,102,0.18)}\n    .node.swap{background:linear-gradient(180deg,#f97316,#ea580c);transform:scale(1.08);box-shadow:0 16px 40px rgba(249,115,22,0.16)}\n    .log{height:200px;overflow:auto;padding:10px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));border:1px dashed rgba(255,255,255,0.02);font-size:13px;color:var(--muted)}\n    .muted{color:var(--muted);font-size:13px}\n    .flex{display:flex;gap:8px}\n    .footer{margin-top:12px;color:var(--muted);font-size:13px}\n    .explain{font-size:13px;line-height:1.45;color:var(--muted)}\n    .controls .actions{display:flex;flex-direction:column;gap:8px}\n    .top-actions{display:flex;gap:8px;align-items:center}\n    .status{font-size:13px;color:var(--muted);margin-top:6px}\n    .sorted{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n    .chip{padding:6px 8px;border-radius:8px;background:rgba(255,255,255,0.02);font-size:13px}\n    footer{padding:12px 18px;color:var(--muted);font-size:13px;text-align:center}\n    @media (max-width:920px){\n      main{grid-template-columns:1fr;height:auto;padding-bottom:60px}\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Max Heap Visualizer</h1>\n    <div class=\"muted\">Interactive demonstration of a binary max-heap using array representation</div>\n  </header>\n\n  <main>\n    <section class=\"panel\">\n      <div class=\"controls\">\n        <div>\n          <label>Insert value</label>\n          <div class=\"row\">\n            <input id=\"valueInput\" type=\"number\" placeholder=\"Enter number\" />\n            <button id=\"insertBtn\" class=\"small\">Insert</button>\n            <button id=\"peekBtn\" class=\"small secondary\">Peek</button>\n          </div>\n        </div>\n\n        <div class=\"top-actions\">\n          <button id=\"extractBtn\" class=\"small danger\">Extract Max</button>\n          <button id=\"randomBtn\" class=\"small secondary\">Randomize</button>\n          <button id=\"clearBtn\" class=\"small secondary\">Clear</button>\n        </div>\n\n        <div>\n          <label>Build from array (comma separated)</label>\n          <div class=\"row\">\n            <input id=\"arrayInput\" type=\"text\" placeholder=\"e.g. 3,1,6,5,2,4\" />\n            <button id=\"buildBtn\" class=\"small\">Build</button>\n          </div>\n        </div>\n\n        <div class=\"actions\">\n          <button id=\"heapifyBtn\" class=\"small\">Heapify (bottom-up)</button>\n          <button id=\"heapSortBtn\" class=\"small secondary\">Heap Sort (extract sequence)</button>\n        </div>\n\n        <div class=\"status\" id=\"status\">Status: idle</div>\n\n        <div style=\"margin-top:8px\">\n          <label>Array representation</label>\n          <div id=\"arrayView\" class=\"array-view\"></div>\n        </div>\n\n        <div style=\"margin-top:8px\">\n          <label>Extracted / Sorted sequence</label>\n          <div id=\"sortedView\" class=\"sorted\"></div>\n        </div>\n\n        <div style=\"margin-top:8px\">\n          <label>Operation log</label>\n          <div id=\"log\" class=\"log\"></div>\n        </div>\n\n        <div class=\"footer\">\n          Tip: Use Insert / Extract to see sift-up and sift-down. Heapify builds a max-heap in O(n) bottom-up.\n        </div>\n      </div>\n    </section>\n\n    <section class=\"panel\">\n      <div style=\"display:flex;gap:12px;align-items:center;justify-content:space-between;margin-bottom:10px\">\n        <div class=\"muted\">Tree view (top is root)</div>\n        <div class=\"muted\">Array indices start at 0</div>\n      </div>\n      <div class=\"tree-canvas\" id=\"treeCanvas\">\n        <svg class=\"lines\" id=\"lines\"></svg>\n      </div>\n\n      <div style=\"margin-top:12px\" class=\"explain\">\n        <strong>How it works (Max Heap):</strong>\n        <ul>\n          <li>Binary heap stored as array: for index i, parent = Math.floor((i-1)/2), children = 2*i+1 and 2*i+2.</li>\n          <li>Insert: place element at end and sift-up while greater than parent (swap).</li>\n          <li>Extract max: swap root with last, pop max, then sift-down from root to restore heap.</li>\n          <li>Heapify (bottom-up): run sift-down from floor(n/2)-1 down to 0 for O(n) build.</li>\n        </ul>\n      </div>\n    </section>\n  </main>\n\n  <footer>\n    Interactive demo — values highlighted during compare/swap. Small delays show step-by-step operations.\n  </footer>\n\n<script>\n(function(){\n  // Utilities\n  const $ = (id)=>document.getElementById(id);\n  const sleep = (ms)=>new Promise(r=>setTimeout(r,ms));\n\n  // DOM elements\n  const valueInput = $('valueInput');\n  const insertBtn = $('insertBtn');\n  const extractBtn = $('extractBtn');\n  const peekBtn = $('peekBtn');\n  const randomBtn = $('randomBtn');\n  const clearBtn = $('clearBtn');\n  const arrayInput = $('arrayInput');\n  const buildBtn = $('buildBtn');\n  const heapifyBtn = $('heapifyBtn');\n  const heapSortBtn = $('heapSortBtn');\n  const arrayView = $('arrayView');\n  const treeCanvas = $('treeCanvas');\n  const linesSvg = $('lines');\n  const logEl = $('log');\n  const statusEl = $('status');\n  const sortedView = $('sortedView');\n\n  let busy = false;\n  const ANIM_DELAY = 450;\n\n  function setBusy(b){\n    busy = b;\n    const buttons = [insertBtn, extractBtn, peekBtn, randomBtn, clearBtn, buildBtn, heapifyBtn, heapSortBtn];\n    buttons.forEach(btn=>btn.disabled = b);\n    statusEl.textContent = 'Status: ' + (b ? 'running...' : 'idle');\n  }\n\n  function log(msg){\n    const time = new Date().toLocaleTimeString();\n    const p = document.createElement('div');\n    p.textContent = `[${time}] ${msg}`;\n    logEl.prepend(p);\n  }\n\n  // Heap class with visualization callbacks\n  class VisualMaxHeap {\n    constructor(arr=[], callbacks={}){\n      this.a = arr.slice();\n      this.onCompare = callbacks.onCompare || (()=>{});\n      this.onSwap = callbacks.onSwap || (()=>{});\n      this.onRender = callbacks.onRender || (()=>{});\n    }\n    size(){return this.a.length;}\n    peek(){ return this.a[0]; }\n\n    async insert(val){\n      this.a.push(val);\n      let i = this.a.length - 1;\n      await this.onRender(this.a, {action:'insert', index:i});\n      while(i>0){\n        let p = Math.floor((i-1)/2);\n        await this.onCompare(p,i);\n        if(this.a[i] > this.a[p]){\n          this._swap(i,p);\n          await this.onSwap(i,p);\n          await this.onRender(this.a, {action:'sift-up', index:i});\n          i = p;\n        } else break;\n      }\n      await this.onRender(this.a, {action:'done'});\n    }\n\n    _swap(i,j){\n      const t = this.a[i]; this.a[i]=this.a[j]; this.a[j]=t;\n    }\n\n    async extractMax(){\n      if(this.a.length===0) return undefined;\n      const max = this.a[0];\n      if(this.a.length === 1){\n        this.a.pop();\n        await this.onRender(this.a, {action:'extract', index:0});\n        return max;\n      }\n      this._swap(0, this.a.length-1);\n      await this.onSwap(0, this.a.length-1);\n      this.a.pop();\n      await this.onRender(this.a, {action:'extract'});\n      await this.siftDown(0);\n      await this.onRender(this.a, {action:'done'});\n      return max;\n    }\n\n    async siftDown(i, limit=this.a.length){\n      while(true){\n        let left = 2*i + 1;\n        let right = 2*i + 2;\n        let largest = i;\n        if(left < limit){\n          await this.onCompare(left, largest);\n          if(this.a[left] > this.a[largest]) largest = left;\n        }\n        if(right < limit){\n          await this.onCompare(right, largest);\n          if(this.a[right] > this.a[largest]) largest = right;\n        }\n        if(largest !== i){\n          this._swap(i, largest);\n          await this.onSwap(i, largest);\n          await this.onRender(this.a, {action:'sift-down', index:largest});\n          i = largest;\n        } else break;\n      }\n    }\n\n    async buildHeap(){\n      const n = this.a.length;\n      await this.onRender(this.a, {action:'build-start'});\n      for(let i = Math.floor(n/2)-1; i>=0; i--){\n        await this.onRender(this.a, {action:'heapify-step', index:i});\n        await this.siftDown(i);\n      }\n      await this.onRender(this.a, {action:'build-done'});\n    }\n  }\n\n  // Visualization\n  function clearChildren(el){ while(el.firstChild) el.removeChild(el.firstChild); }\n\n  function renderArray(arr, highlights={}){\n    clearChildren(arrayView);\n    arr.forEach((v,i)=>{\n      const c = document.createElement('div');\n      c.className = 'cell';\n      if(highlights.compare && highlights.compare.includes(i)) c.classList.add('highlight-compare');\n      if(highlights.swap && highlights.swap.includes(i)) c.classList.add('highlight-swap');\n      if(highlights.peek === i) c.classList.add('peek');\n      const idx = document.createElement('div'); idx.className='index'; idx.textContent=`${i}`;\n      const val = document.createElement('div'); val.className='value'; val.textContent = v;\n      c.appendChild(idx); c.appendChild(val);\n      arrayView.appendChild(c);\n    });\n    if(arr.length === 0){\n      const empty = document.createElement('div'); empty.className='muted'; empty.textContent='[ empty ]';\n      arrayView.appendChild(empty);\n    }\n  }\n\n  function renderTree(arr, highlights={}){\n    // Clear nodes and lines\n    // Remove old nodes\n    const existing = Array.from(treeCanvas.querySelectorAll('.node'));\n    existing.forEach(n=>n.remove());\n    // Clear lines\n    while(linesSvg.firstChild) linesSvg.removeChild(linesSvg.firstChild);\n\n    const width = treeCanvas.clientWidth;\n    const nodeSize = 56;\n    const levels = Math.max(1, Math.ceil(Math.log2(arr.length+1)));\n    const positions = [];\n    for(let i=0;i<arr.length;i++){\n      const level = Math.floor(Math.log2(i+1));\n      const levelStart = (1<<level)-1;\n      const indexInLevel = i - levelStart;\n      const nodesInLevel = 1<<level;\n      const gap = width / (nodesInLevel + 1);\n      const x = gap * (indexInLevel+1) - nodeSize/2;\n      const y = 18 + level * 86;\n      positions[i] = {x,y};\n      const node = document.createElement('div');\n      node.className = 'node';\n      if(highlights.compare && highlights.compare.includes(i)) node.classList.add('compare');\n      if(highlights.swap && highlights.swap.includes(i)) node.classList.add('swap');\n      node.style.left = x + 'px';\n      node.style.top = y + 'px';\n      const v = document.createElement('div'); v.className='val'; v.textContent = arr[i];\n      const idx = document.createElement('div'); idx.className='idx'; idx.textContent = `${i}`;\n      node.appendChild(v); node.appendChild(idx);\n      treeCanvas.appendChild(node);\n    }\n\n    // draw lines (parent -> child)\n    for(let i=0;i<arr.length;i++){\n      const left = 2*i+1, right = 2*i+2;\n      const p = positions[i];\n      if(!p) continue;\n      const cx = p.x + nodeSize/2;\n      const cy = p.y + nodeSize/2;\n      [left,right].forEach(child=>{\n        const cpos = positions[child];\n        if(cpos){\n          const lx = cpos.x + nodeSize/2;\n          const ly = cpos.y + nodeSize/2;\n          const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n          line.setAttribute('x1', cx);\n          line.setAttribute('y1', cy);\n          line.setAttribute('x2', lx);\n          line.setAttribute('y2', ly);\n          line.setAttribute('stroke', 'rgba(255,255,255,0.04)');\n          line.setAttribute('stroke-width','2');\n          line.setAttribute('stroke-linecap','round');\n          linesSvg.appendChild(line);\n        }\n      });\n    }\n  }\n\n  // Controller state\n  let heap = new VisualMaxHeap([], {\n    onCompare: async (i,j)=>{\n      renderArray(heap.a, {compare:[i,j]});\n      renderTree(heap.a, {compare:[i,j]});\n      log(`Compare indices ${i} and ${j}`);\n      await sleep(ANIM_DELAY);\n    },\n    onSwap: async (i,j)=>{\n      renderArray(heap.a, {swap:[i,j]});\n      renderTree(heap.a, {swap:[i,j]});\n      log(`Swap indices ${i} and ${j}`);\n      await sleep(ANIM_DELAY);\n    },\n    onRender: async (arr, info={})=>{\n      // info.action may be used to annotate\n      renderArray(arr, {});\n      renderTree(arr, {});\n      if(info.action){\n        if(info.action==='insert') log(`Inserted ${arr[info.index]} at index ${info.index}`);\n        else if(info.action==='sift-up') log(`Sift-up continued from index ${info.index}`);\n        else if(info.action==='extract') log(`Extract operation`);\n        else if(info.action==='sift-down') log(`Sift-down at index ${info.index}`);\n        else if(info.action==='build-start') log('Heapify (build) started');\n        else if(info.action==='build-done') log('Heapify completed');\n        else if(info.action==='heapify-step') log(`Heapify sift-down from index ${info.index}`);\n        else if(info.action==='done') log('Operation finished');\n      }\n      await sleep(ANIM_DELAY/2);\n    }\n  });\n\n  // Initial render\n  renderArray(heap.a, {});\n  renderTree(heap.a, {});\n  sortedView.innerHTML = '';\n\n  // UI Handlers\n  insertBtn.addEventListener('click', async ()=>{\n    if(busy) return;\n    const raw = valueInput.value;\n    if(raw === '') return alert('Enter a numeric value to insert.');\n    const val = Number(raw);\n    if(Number.isNaN(val)) return alert('Invalid number');\n    setBusy(true);\n    try{\n      await heap.insert(val);\n      log(`Inserted value ${val}`);\n    }catch(e){ console.error(e); }\n    setBusy(false);\n    valueInput.value = '';\n    sortedView.innerHTML = '';\n  });\n\n  extractBtn.addEventListener('click', async ()=>{\n    if(busy) return;\n    if(heap.size()===0) { alert('Heap is empty'); return; }\n    setBusy(true);\n    try{\n      const max = await heap.extractMax();\n      log(`Extracted max ${max}`);\n      // show in sortedView\n      const chip = document.createElement('div'); chip.className='chip'; chip.textContent = max;\n      sortedView.appendChild(chip);\n    }catch(e){ console.error(e); }\n    setBusy(false);\n  });\n\n  peekBtn.addEventListener('click', async ()=>{\n    if(busy) return;\n    if(heap.size()===0) { alert('Heap is empty'); return; }\n    setBusy(true);\n    const idx = 0;\n    renderArray(heap.a, {peek: idx});\n    renderTree(heap.a, {peek: idx});\n    log(`Peek: max = ${heap.peek()}`);\n    await sleep(800);\n    renderArray(heap.a, {});\n    renderTree(heap.a, {});\n    setBusy(false);\n  });\n\n  clearBtn.addEventListener('click', ()=>{\n    if(busy) return;\n    heap = new VisualMaxHeap([], heapCallbacks());\n    renderArray(heap.a, {});\n    renderTree(heap.a, {});\n    sortedView.innerHTML = '';\n    log('Cleared heap');\n  });\n\n  randomBtn.addEventListener('click', ()=>{\n    if(busy) return;\n    const n = Math.floor(Math.random()*8) + 4;\n    const arr = [];\n    for(let i=0;i<n;i++) arr.push(Math.floor(Math.random()*90)+1);\n    heap = new VisualMaxHeap(arr, heapCallbacks());\n    renderArray(heap.a, {});\n    renderTree(heap.a, {});\n    log(`Random array created: [${arr.join(', ')}]`);\n    sortedView.innerHTML = '';\n  });\n\n  buildBtn.addEventListener('click', async ()=>{\n    if(busy) return;\n    const raw = arrayInput.value.trim();\n    if(!raw) return alert('Enter a comma-separated list of numbers');\n    const parts = raw.split(',').map(s=>s.trim()).filter(s=>s!=='');\n    const arr = parts.map(p=>Number(p));\n    if(arr.some(x=>Number.isNaN(x))) return alert('Invalid input: only numbers allowed');\n    heap = new VisualMaxHeap(arr, heapCallbacks());\n    renderArray(heap.a, {});\n    renderTree(heap.a, {});\n    sortedView.innerHTML = '';\n    log(`Array set to [${arr.join(', ')}] (not yet heapified)`);\n  });\n\n  heapifyBtn.addEventListener('click', async ()=>{\n    if(busy) return;\n    if(heap.size()===0) { alert('Heap is empty'); return;}\n    setBusy(true);\n    try{\n      await heap.buildHeap();\n      log('Heap built (bottom-up)');\n    }catch(e){ console.error(e); }\n    setBusy(false);\n    sortedView.innerHTML = '';\n  });\n\n  heapSortBtn.addEventListener('click', async ()=>{\n    if(busy) return;\n    if(heap.size()===0) { alert('Heap is empty'); return;}\n    setBusy(true);\n    try{\n      // Work on a copy so main heap remains intact. We'll visualize on a temporary heap object.\n      const arrCopy = heap.a.slice();\n      const tempHeap = new VisualMaxHeap(arrCopy, heapCallbacks('sort'));\n      // First build\n      await tempHeap.buildHeap();\n      sortedView.innerHTML = '';\n      const sorted = [];\n      while(tempHeap.size()>0){\n        const mx = await tempHeap.extractMax();\n        sorted.push(mx);\n        const chip = document.createElement('div'); chip.className='chip'; chip.textContent = mx;\n        sortedView.appendChild(chip);\n      }\n      log(`Heap sort complete. Extracted sequence (descending): [${sorted.join(', ')}]`);\n      // leave main heap unchanged\n      renderArray(heap.a, {});\n      renderTree(heap.a, {});\n    }catch(e){ console.error(e); }\n    setBusy(false);\n  });\n\n  function heapCallbacks(prefix=''){\n    return {\n      onCompare: async (i,j)=>{\n        renderArray(heap.a, {compare:[i,j]});\n        renderTree(heap.a, {compare:[i,j]});\n        log(`${prefix?prefix+': ':''}Compare ${i} and ${j}`);\n        await sleep(ANIM_DELAY);\n      },\n      onSwap: async (i,j)=>{\n        renderArray(heap.a, {swap:[i,j]});\n        renderTree(heap.a, {swap:[i,j]});\n        log(`${prefix?prefix+': ':''}Swap ${i} and ${j}`);\n        await sleep(ANIM_DELAY);\n      },\n      onRender: async (arr, info={})=>{\n        renderArray(arr, {});\n        renderTree(arr, {});\n        if(info.action){\n          log(`${prefix?prefix+': ':''}${info.action}${info.index!==undefined?` @${info.index}`:''}`);\n        }\n        await sleep(ANIM_DELAY/2);\n      }\n    };\n  }\n\n  // ensure window resizes recalc positions\n  window.addEventListener('resize', ()=>renderTree(heap.a, {}));\n\n  // initial sample\n  (function initSample(){\n    const sample = [45,32,24,18,12,9,6];\n    heap = new VisualMaxHeap(sample, heapCallbacks());\n    renderArray(heap.a, {});\n    renderTree(heap.a, {});\n    log('Sample heap loaded: [45,32,24,18,12,9,6]');\n  })();\n\n})();\n</script>\n</body>\n</html>"
  },
