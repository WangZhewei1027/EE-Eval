  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Binary Search Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --muted:#9aa7c2;\n      --accent:#5eead4;\n      --accent2:#60a5fa;\n      --danger:#fb7185;\n      --box:#111827;\n      --glass: rgba(255,255,255,0.03);\n    }\n    html,body{height:100%;}\n    body{\n      margin:0;\n      font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: linear-gradient(180deg,#031028 0%, #071028 50%, #071018 100%);\n      color:#e6eef8;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding:24px;\n      box-sizing:border-box;\n    }\n    .container{\n      max-width:1100px;\n      margin:0 auto;\n    }\n    header{\n      display:flex;\n      gap:16px;\n      align-items:center;\n      margin-bottom:18px;\n    }\n    header h1{\n      font-size:20px;\n      margin:0;\n      letter-spacing:0.2px;\n    }\n    header p {\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .grid{\n      display:grid;\n      grid-template-columns: 440px 1fr;\n      gap:20px;\n    }\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      padding:16px;\n      border-radius:12px;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n    }\n    .controls{\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n    .row{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n    label{font-size:13px;color:var(--muted);}\n    input[type=\"number\"], input[type=\"text\"], select {\n      background:var(--box);\n      border:1px solid rgba(255,255,255,0.04);\n      color:#e6eef8;\n      padding:8px 10px;\n      border-radius:8px;\n      min-width:110px;\n    }\n    button{\n      background:linear-gradient(90deg,var(--accent2), #7c3aed);\n      color:#04202f;\n      border:none;\n      padding:8px 12px;\n      border-radius:8px;\n      cursor:pointer;\n      font-weight:600;\n    }\n    button.secondary{\n      background:transparent;\n      color:var(--accent);\n      border:1px solid rgba(255,255,255,0.04);\n    }\n    button:disabled{opacity:0.4; cursor:not-allowed;}\n    .array-visual{\n      padding:14px;\n      background:var(--glass);\n      border-radius:10px;\n      display:flex;\n      gap:8px;\n      flex-wrap:wrap;\n      justify-content:flex-start;\n      align-items:flex-end;\n      min-height:120px;\n      position:relative;\n      border:1px dashed rgba(255,255,255,0.02);\n    }\n    .box{\n      width:48px;\n      height:48px;\n      display:flex;\n      justify-content:center;\n      align-items:center;\n      border-radius:8px;\n      background:linear-gradient(180deg,#021426, #072034);\n      border:1px solid rgba(255,255,255,0.03);\n      color:var(--muted);\n      font-weight:700;\n      position:relative;\n      transition:transform 300ms, box-shadow 200ms, background 200ms;\n      user-select:none;\n    }\n    .box.low, .box.high{\n      box-shadow:0 6px 20px rgba(2,6,23,0.6);\n      background: linear-gradient(180deg,#042a2f, #063a3b);\n      color:var(--accent);\n    }\n    .box.mid{\n      transform:scale(1.08);\n      box-shadow:0 10px 30px rgba(96,165,250,0.12);\n      background: linear-gradient(180deg,#0b2547,#07264b);\n      color:var(--accent2);\n    }\n    .box.found{\n      background: linear-gradient(180deg,#164e24,#0f3f1a);\n      color: #b9f6cc;\n    }\n    .range-overlay{\n      position:absolute;\n      left:0; right:0; top:0; bottom:0;\n      pointer-events:none;\n    }\n    .legend{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      margin-top:8px;\n    }\n    .legend .item{display:flex;gap:6px;align-items:center;color:var(--muted);font-size:13px}\n    .legend .sw{width:14px;height:14px;border-radius:4px;background:var(--accent);box-shadow:0 2px 8px rgba(0,0,0,0.4)}\n    .legend .sw2{background:var(--accent2)}\n    .info{\n      background:rgba(255,255,255,0.02);\n      padding:10px;\n      border-radius:8px;\n      color:var(--muted);\n      font-size:13px;\n    }\n    pre.code{\n      background:#051428;\n      border-radius:8px;\n      padding:12px;\n      color:#c8f3ff;\n      font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Helvetica Neue\", monospace;\n      font-size:13px;\n      overflow:auto;\n      max-height:220px;\n    }\n    .status{\n      display:flex;\n      gap:12px;\n      align-items:center;\n      margin-top:8px;\n      flex-wrap:wrap;\n    }\n    .pill{\n      background:rgba(255,255,255,0.02);\n      padding:8px 10px;\n      border-radius:999px;\n      font-size:13px;\n      color:var(--muted);\n    }\n    footer{\n      margin-top:16px;\n      color:var(--muted);\n      font-size:13px;\n    }\n    input[type=\"range\"]{\n      width:150px;\n    }\n    .controls .small{font-size:13px;color:var(--muted);}\n    .top-controls{\n      display:flex;\n      gap:8px;\n      align-items:center;\n      justify-content:space-between;\n    }\n    .explain{\n      font-size:14px;\n      color:var(--muted);\n      line-height:1.45;\n    }\n    @media (max-width:980px){\n      .grid{grid-template-columns:1fr; }\n      .array-visual{min-height:160px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <header>\n      <div>\n        <h1>Binary Search — Interactive Demo</h1>\n        <p>Visualize how binary search finds (or doesn't find) a target in a sorted array.</p>\n      </div>\n    </header>\n\n    <div class=\"grid\">\n      <div class=\"card\">\n        <div class=\"controls\">\n          <div class=\"top-controls\">\n            <div>\n              <label class=\"small\">Array size</label><br>\n              <input id=\"size\" type=\"range\" min=\"5\" max=\"30\" value=\"12\">\n              <span id=\"sizeVal\" style=\"margin-left:8px;color:var(--muted)\">12</span>\n            </div>\n            <div>\n              <label class=\"small\">Generation</label><br>\n              <select id=\"genMode\">\n                <option value=\"unique\">Sorted unique (increasing)</option>\n                <option value=\"dups\">Sorted with duplicates</option>\n              </select>\n            </div>\n            <div>\n              <label class=\"small\">Algorithm</label><br>\n              <select id=\"algo\">\n                <option value=\"iter\">Iterative</option>\n                <option value=\"rec\">Recursive (visualised iteration)</option>\n              </select>\n            </div>\n          </div>\n\n          <div class=\"row\">\n            <label>Array (editable numbers, comma separated)</label><br>\n            <input id=\"arrayInput\" type=\"text\" style=\"width:100%\" placeholder=\"e.g. 1,3,5,7,9\" />\n          </div>\n\n          <div class=\"row\">\n            <label>Target value</label>\n            <input id=\"target\" type=\"text\" placeholder=\"Value to search\" />\n            <button id=\"setTarget\">Set & Start</button>\n            <button id=\"randTarget\" class=\"secondary\">Random target</button>\n            <button id=\"generate\" class=\"secondary\">Generate array</button>\n          </div>\n\n          <div class=\"row\">\n            <button id=\"start\" class=\"\">Start</button>\n            <button id=\"stepBack\" class=\"secondary\" disabled>Step ◀</button>\n            <button id=\"step\" class=\"secondary\" disabled>Step ▶</button>\n            <button id=\"auto\" class=\"secondary\" disabled>Auto Play</button>\n            <label class=\"small\">Speed</label>\n            <input id=\"speed\" type=\"range\" min=\"100\" max=\"1200\" value=\"600\">\n          </div>\n\n          <div class=\"row\">\n            <div class=\"info\" style=\"flex:1\">\n              <div style=\"display:flex;justify-content:space-between;align-items:center\">\n                <div><strong>Status</strong></div>\n                <div style=\"display:flex;gap:8px\">\n                  <div class=\"pill\" id=\"iterCount\">Iterations: 0</div>\n                  <div class=\"pill\" id=\"compCount\">Comparisons: 0</div>\n                </div>\n              </div>\n              <div style=\"margin-top:8px\" id=\"message\">Idle — prepare an array and start searching.</div>\n            </div>\n            <div style=\"width:240px\">\n              <div class=\"legend\">\n                <div class=\"item\"><div class=\"sw\" style=\"background:linear-gradient(180deg,#5eead4,#2dd4bf)\"></div> low/high</div>\n                <div class=\"item\"><div class=\"sw2\" style=\"background:linear-gradient(180deg,#60a5fa,#7dd3fc)\"></div> mid</div>\n                <div class=\"item\"><div style=\"width:14px;height:14px;border-radius:4px;background:#164e24\"></div> found</div>\n              </div>\n\n              <div style=\"margin-top:12px\" class=\"small\">\n                <strong>Hint:</strong> The array must be sorted in ascending order. Use \"Generate array\" or edit and press <em>Start</em>.\n              </div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div style=\"display:flex;gap:12px;align-items:center;justify-content:space-between\">\n          <div>\n            <label style=\"font-weight:600\">Array visualization</label>\n            <div style=\"font-size:13px;color:var(--muted)\">Boxes represent elements. Low/high show current search window; mid is tested.</div>\n          </div>\n          <div style=\"text-align:right\">\n            <div class=\"pill\" id=\"lowHigh\">Low: — &nbsp; High: — &nbsp; Mid: —</div>\n          </div>\n        </div>\n\n        <div id=\"visual\" class=\"array-visual\" style=\"margin-top:12px\">\n          <!-- boxes inserted here -->\n        </div>\n\n        <div class=\"status\" style=\"margin-top:12px\">\n          <div class=\"pill\" id=\"result\">Result: —</div>\n          <div class=\"pill\" id=\"range\">Range length: —</div>\n          <div class=\"pill\" id=\"targetLabel\">Target: —</div>\n        </div>\n\n        <div style=\"margin-top:14px\">\n          <div style=\"display:flex;gap:10px;align-items:center\">\n            <div style=\"flex:1\">\n              <label><strong>Explanation</strong></label>\n              <div class=\"explain\" style=\"margin-top:6px\">\n                Binary search repeatedly divides a sorted array in half. Compare the target with the middle element:\n                if equal — found; if smaller — continue on the left half; if larger — continue on the right half.\n                It runs in O(log n) time for n elements.\n              </div>\n            </div>\n            <div style=\"width:300px\">\n              <label><strong>Pseudocode</strong></label>\n              <pre class=\"code\" id=\"pseudocode\">\nfunction binarySearch(a[], target):\n  low = 0\n  high = length(a)-1\n  while low <= high:\n    mid = floor((low + high) / 2)\n    if a[mid] == target:\n      return mid\n    else if a[mid] < target:\n      low = mid + 1\n    else:\n      high = mid - 1\n  return -1\n              </pre>\n            </div>\n          </div>\n        </div>\n\n        <footer style=\"margin-top:12px\">\n          Time Complexity: Best O(1) if found at mid, Average and Worst O(log n). Space: O(1) iterative, O(log n) recursion stack.\n        </footer>\n      </div>\n    </div>\n\n    <script>\n      // Binary Search Interactive Demo\n      (() => {\n        // Elements\n        const sizeEl = document.getElementById('size');\n        const sizeVal = document.getElementById('sizeVal');\n        const genMode = document.getElementById('genMode');\n        const arrayInput = document.getElementById('arrayInput');\n        const generateBtn = document.getElementById('generate');\n        const startBtn = document.getElementById('start');\n        const stepBtn = document.getElementById('step');\n        const stepBackBtn = document.getElementById('stepBack');\n        const autoBtn = document.getElementById('auto');\n        const targetEl = document.getElementById('target');\n        const setTargetBtn = document.getElementById('setTarget');\n        const randTargetBtn = document.getElementById('randTarget');\n        const visual = document.getElementById('visual');\n        const iterCount = document.getElementById('iterCount');\n        const compCount = document.getElementById('compCount');\n        const message = document.getElementById('message');\n        const lowHigh = document.getElementById('lowHigh');\n        const resultPill = document.getElementById('result');\n        const rangePill = document.getElementById('range');\n        const targetLabel = document.getElementById('targetLabel');\n        const speedEl = document.getElementById('speed');\n        const algoSelect = document.getElementById('algo');\n\n        // state\n        let arr = [];\n        let states = []; // array of snapshots for stepping\n        let current = -1;\n        let comparisons = 0;\n        let iterations = 0;\n        let autoTimer = null;\n\n        // utilities\n        function randomInt(min,max){ return Math.floor(Math.random()*(max-min+1))+min; }\n\n        function generateArray(n, mode='unique'){\n          let a = [];\n          let v = randomInt(0,4);\n          for(let i=0;i<n;i++){\n            if(mode==='unique'){\n              v += randomInt(1,3);\n              a.push(v);\n            } else {\n              // allow some duplicates\n              v += randomInt(0,3);\n              if(Math.random()<0.2 && a.length>0){\n                a.push(a[a.length-1]); // duplicate\n              } else {\n                a.push(v);\n              }\n            }\n          }\n          return a;\n        }\n\n        function renderArray(arr, state){\n          visual.innerHTML = '';\n          const n = arr.length;\n          for(let i=0;i<n;i++){\n            const div = document.createElement('div');\n            div.className = 'box';\n            div.textContent = arr[i];\n            // classes if in state\n            if(state){\n              if(i===state.mid) div.classList.add('mid');\n              if(i===state.low) div.classList.add('low');\n              if(i===state.high) div.classList.add('high');\n              if(state.found && i===state.mid) div.classList.add('found');\n            }\n            // show subtle opacity for elements outside window\n            if(state && (i < state.low || i > state.high)){\n              div.style.opacity = 0.35;\n              div.style.filter = 'grayscale(30%)';\n            }\n            visual.appendChild(div);\n          }\n        }\n\n        function parseArrayInput(text){\n          if(!text) return [];\n          const parts = text.split(',').map(s=>s.trim()).filter(s=>s.length);\n          const vals = parts.map(s=> {\n            const n = Number(s);\n            return Number.isFinite(n) ? n : s;\n          });\n          return vals;\n        }\n\n        function isSortedAscending(a){\n          for(let i=1;i<a.length;i++){\n            if(a[i] < a[i-1]) return false;\n          }\n          return true;\n        }\n\n        // Build step-by-step states for iterative binary search\n        // Each state: { low, high, mid, found, msg, comp, iter }\n        function buildStatesIterative(a, target){\n          const states = [];\n          let low = 0, high = a.length - 1;\n          let iter = 0;\n          let comps = 0;\n          while(low <= high){\n            iter++;\n            const mid = Math.floor((low + high)/2);\n            comps++;\n            const val = a[mid];\n            const found = (val === target);\n            states.push({\n              low, high, mid, found, msg: `Comparing target (${target}) with a[${mid}] = ${val}`,\n              comp: comps, iter\n            });\n            if(found){\n              break;\n            } else if (val < target){\n              low = mid + 1;\n            } else {\n              high = mid - 1;\n            }\n          }\n          if(low > high){\n            // not found; final state show window empty (low > high)\n            states.push({\n              low, high, mid: Math.floor((low+high)/2), found:false, msg: `Target not in array (search window empty)`,\n              comp: comps, iter: iter\n            });\n          }\n          return states;\n        }\n\n        // Recursion can be represented similarly by collecting states\n        function buildStatesRecursive(a, target){\n          const states = [];\n          let comps = 0; let iter = 0;\n          function helper(low, high){\n            if(low > high){\n              states.push({\n                low, high, mid: Math.floor((low+high)/2), found:false, msg:`Target not in array (empty window)`,\n                comp: comps, iter\n              });\n              return -1;\n            }\n            iter++;\n            const mid = Math.floor((low + high)/2);\n            comps++;\n            const val = a[mid];\n            states.push({\n              low, high, mid, found: val===target,\n              msg:`Comparing target (${target}) with a[${mid}] = ${val}`,\n              comp: comps, iter\n            });\n            if(val === target) return mid;\n            if(val < target){\n              return helper(mid+1, high);\n            } else {\n              return helper(low, mid-1);\n            }\n          }\n          helper(0, a.length-1);\n          return states;\n        }\n\n        // UI actions\n        function updateStatsFromState(s){\n          iterCount.textContent = `Iterations: ${s.iter}`;\n          compCount.textContent = `Comparisons: ${s.comp}`;\n          lowHigh.textContent = `Low: ${s.low}   High: ${s.high}   Mid: ${s.mid}`;\n          resultPill.textContent = s.found ? `Result: FOUND at index ${s.mid}` : 'Result: —';\n          rangePill.textContent = `Range length: ${Math.max(0, s.high - s.low + 1)}`;\n          targetLabel.textContent = `Target: ${targetEl.value}`;\n          message.textContent = s.msg;\n        }\n\n        function setStateIndex(i){\n          if(i < 0) i = 0;\n          if(i >= states.length) i = states.length - 1;\n          current = i;\n          const s = states[current];\n          renderArray(arr, s);\n          updateStatsFromState(s);\n          // update buttons\n          stepBackBtn.disabled = current <= 0;\n          stepBtn.disabled = current >= states.length - 1;\n        }\n\n        function resetSimulation(){\n          stopAuto();\n          states = [];\n          current = -1;\n          comparisons = 0;\n          iterations = 0;\n          iterCount.textContent = `Iterations: 0`;\n          compCount.textContent = `Comparisons: 0`;\n          lowHigh.textContent = `Low: —   High: —   Mid: —`;\n          resultPill.textContent = 'Result: —';\n          rangePill.textContent = 'Range length: —';\n          targetLabel.textContent = 'Target: —';\n          message.textContent = 'Idle — prepare an array and start searching.';\n          stepBtn.disabled = true;\n          stepBackBtn.disabled = true;\n          autoBtn.disabled = true;\n        }\n\n        function startSimulation(){\n          const text = arrayInput.value.trim();\n          const parsed = parseArrayInput(text);\n          if(parsed.length === 0){\n            message.textContent = 'Array is empty — generate one or enter numbers.';\n            return;\n          }\n          // check all numbers\n          const allNumbers = parsed.every(v=> typeof v === 'number');\n          if(!allNumbers){\n            message.textContent = 'All elements must be numeric for comparison. Use numbers only.';\n            return;\n          }\n          // require sorted array\n          if(!isSortedAscending(parsed)){\n            message.textContent = 'Array is not sorted ascending. Binary search requires a sorted array. Click \"Generate array\" or sort your input.';\n            return;\n          }\n          arr = parsed.slice();\n          const targetText = targetEl.value.trim();\n          if(targetText.length === 0){\n            message.textContent = 'Set a target to search for.';\n            return;\n          }\n          const targetVal = Number(targetText);\n          if(!Number.isFinite(targetVal)){\n            message.textContent = 'Target must be a numeric value.';\n            return;\n          }\n\n          // build states depending on algorithm choice\n          const algo = algoSelect.value;\n          if(algo === 'iter'){\n            states = buildStatesIterative(arr, targetVal);\n          } else {\n            states = buildStatesRecursive(arr, targetVal);\n          }\n          if(states.length === 0){\n            message.textContent = 'No states produced (unexpected).';\n            return;\n          }\n          // init\n          current = 0;\n          setStateIndex(0);\n          stepBtn.disabled = false;\n          stepBackBtn.disabled = true;\n          autoBtn.disabled = false;\n        }\n\n        function stepForward(){\n          if(states.length === 0) return;\n          if(current < states.length - 1){\n            setStateIndex(current + 1);\n          }\n        }\n        function stepBackward(){\n          if(states.length === 0) return;\n          if(current > 0){\n            setStateIndex(current - 1);\n          }\n        }\n\n        function startAuto(){\n          if(states.length === 0) return;\n          stopAuto();\n          autoBtn.textContent = 'Pause';\n          autoTimer = setInterval(()=>{\n            if(current >= states.length - 1){\n              stopAuto();\n              return;\n            }\n            stepForward();\n          }, Math.max(80, Number(speedEl.value)));\n        }\n        function stopAuto(){\n          if(autoTimer) clearInterval(autoTimer);\n          autoTimer = null;\n          autoBtn.textContent = 'Auto Play';\n        }\n        function toggleAuto(){\n          if(autoTimer) stopAuto();\n          else startAuto();\n        }\n\n        // events\n        sizeEl.addEventListener('input', ()=>{\n          sizeVal.textContent = sizeEl.value;\n        });\n\n        generateBtn.addEventListener('click', ()=>{\n          const n = Number(sizeEl.value);\n          const mode = genMode.value;\n          const a = generateArray(n, mode);\n          arrayInput.value = a.join(', ');\n          message.textContent = 'Generated a sorted array (ascending).';\n          resetSimulation();\n        });\n\n        setTargetBtn.addEventListener('click', ()=>{\n          startSimulation();\n        });\n\n        startBtn.addEventListener('click', ()=>{\n          // same as setTarget but if array changed, pick that\n          startSimulation();\n        });\n\n        randTargetBtn.addEventListener('click', ()=>{\n          // choose a random target (maybe in array or not)\n          const parsed = parseArrayInput(arrayInput.value);\n          if(parsed.length === 0){\n            message.textContent = 'Generate an array first.';\n            return;\n          }\n          const pickMode = Math.random();\n          let target;\n          if(pickMode < 0.7){\n            // pick a value from array\n            target = parsed[randomInt(0, parsed.length-1)];\n          } else {\n            // pick random outside array range\n            const min = parsed[0] - 5;\n            const max = parsed[parsed.length-1] + 5;\n            target = randomInt(min,max);\n            // avoid accidentally picking existing value too often\n          }\n          targetEl.value = String(target);\n          message.textContent = `Random target set to ${target}`;\n        });\n\n        stepBtn.addEventListener('click', ()=>{\n          stepForward();\n        });\n        stepBackBtn.addEventListener('click', ()=>{\n          stepBackward();\n        });\n        autoBtn.addEventListener('click', ()=>{\n          toggleAuto();\n        });\n\n        speedEl.addEventListener('input', ()=> {\n          if(autoTimer){\n            // restart with new speed\n            startAuto();\n          }\n        });\n\n        // clicking on array visual to highlight index info (optional)\n        visual.addEventListener('click', (ev) => {\n          // find index of clicked box\n          const boxes = Array.from(visual.children);\n          const idx = boxes.indexOf(ev.target);\n          if(idx >= 0 && arr.length){\n            message.textContent = `a[${idx}] = ${arr[idx]}`;\n          }\n        });\n\n        // initial generate\n        (function init(){\n          const a = generateArray(Number(sizeEl.value), genMode.value);\n          arrayInput.value = a.join(', ');\n          renderArray(a, null);\n          arr = a;\n          resetSimulation();\n        })();\n\n        // keyboard controls: ArrowRight step, ArrowLeft back, Space toggle auto\n        window.addEventListener('keydown', (e)=>{\n          if(e.code === 'ArrowRight') stepForward();\n          if(e.code === 'ArrowLeft') stepBackward();\n          if(e.code === 'Space') { e.preventDefault(); toggleAuto(); }\n        });\n\n        // show current state if arr changed externally\n        arrayInput.addEventListener('input', ()=>{\n          resetSimulation();\n          const parsed = parseArrayInput(arrayInput.value);\n          if(parsed.length) renderArray(parsed, null);\n        });\n        genMode.addEventListener('change', ()=>{\n          resetSimulation();\n        });\n        algoSelect.addEventListener('change', ()=>{\n          resetSimulation();\n        });\n\n      })();\n    </script>\n  </div>\n</body>\n</html>"
  },
