    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Load Balancing Simulation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n        .server {\n            display: inline-block;\n            width: 150px;\n            height: 120px;\n            margin: 10px;\n            border: 2px solid #007bff;\n            border-radius: 8px;\n            background-color: #fff;\n        }\n        .server h3 {\n            margin: 0;\n            padding: 10px;\n            color: #007bff;\n        }\n        .requests {\n            font-size: 24px;\n            color: green;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Load Balancing Simulation</h1>\n<p>Click the button to send requests to servers.</p>\n\n<div>\n    <div class=\"server\" id=\"server1\">\n        <h3>Server 1</h3>\n        <div class=\"requests\" id=\"load1\">0</div>\n    </div>\n    <div class=\"server\" id=\"server2\">\n        <h3>Server 2</h3>\n        <div class=\"requests\" id=\"load2\">0</div>\n    </div>\n    <div class=\"server\" id=\"server3\">\n        <h3>Server 3</h3>\n        <div class=\"requests\" id=\"load3\">0</div>\n    </div>\n</div>\n\n<button onclick=\"sendRequest()\">Send Request</button>\n\n<script>\n    let loads = [0, 0, 0]; // Array to store load of each server\n\n    function sendRequest() {\n        // Find the server with the least load\n        let minLoadIndex = loads.indexOf(Math.min(...loads));\n        \n        // Increment the load of the selected server\n        loads[minLoadIndex]++;\n        \n        // Update the UI\n        document.getElementById(`load${minLoadIndex + 1}`).innerText = loads[minLoadIndex];\n        console.log(`Request sent to Server ${minLoadIndex + 1}. Current load: ${loads[minLoadIndex]}`);\n    }\n</script>\n\n</body>\n</html>"
