    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Kruskal's Algorithm Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 10px;\n    background: #f0f0f0;\n    user-select: none;\n  }\n  h1 {\n    text-align: center;\n  }\n  #canvas-container {\n    display: flex;\n    justify-content: center;\n    margin-bottom: 10px;\n  }\n  canvas {\n    background: white;\n    border: 1px solid #aaa;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 10px;\n  }\n  button {\n    margin: 0 5px;\n    padding: 8px 14px;\n    font-size: 14px;\n    cursor: pointer;\n  }\n  #info {\n    max-width: 700px;\n    margin: 0 auto;\n    background: #fff;\n    padding: 10px 15px;\n    border-radius: 4px;\n    border: 1px solid #ccc;\n    font-size: 14px;\n  }\n  #info b {\n    color: #333;\n  }\n  #legend {\n    margin-top: 10px;\n    max-width: 700px;\n    margin-left: auto;\n    margin-right: auto;\n    font-size: 14px;\n  }\n  #legend div {\n    display: inline-block;\n    margin-right: 15px;\n  }\n  .legend-color {\n    display: inline-block;\n    width: 20px;\n    height: 10px;\n    vertical-align: middle;\n    margin-right: 5px;\n    border-radius: 2px;\n  }\n  .edge-pending {\n    background: #aaa;\n  }\n  .edge-included {\n    background: #4caf50;\n  }\n  .edge-rejected {\n    background: #f44336;\n  }\n  .vertex {\n    fill: #2196f3;\n    stroke: #0b72d1;\n    stroke-width: 2px;\n  }\n  .vertex-label {\n    font-weight: bold;\n    fill: #222;\n    text-anchor: middle;\n    dominant-baseline: middle;\n    user-select: none;\n    pointer-events:none;\n  }\n  .edge-label {\n    font-size: 12px;\n    fill: #333;\n    user-select: none;\n  }\n</style>\n</head>\n<body>\n<h1>Kruskal's Algorithm Visualization</h1>\n<div id=\"canvas-container\">\n  <canvas id=\"graphCanvas\" width=\"700\" height=\"500\"></canvas>\n</div>\n<div id=\"controls\">\n  <button id=\"btnStep\">Step</button>\n  <button id=\"btnAuto\">Auto Play</button>\n  <button id=\"btnReset\">Reset</button>\n</div>\n<div id=\"info\">\n  <b>Algorithm State:</b> <span id=\"stateText\">Press \"Step\" to start algorithm.</span>\n</div>\n<div id=\"legend\">\n  <div><span class=\"legend-color edge-pending\"></span> Pending edges</div>\n  <div><span class=\"legend-color edge-included\"></span> Included in MST</div>\n  <div><span class=\"legend-color edge-rejected\"></span> Rejected edges (forms cycle)</div>\n</div>\n\n<script>\n(() => {\n  // The graph structure\n  // Vertices have fixed positions for clear visualization\n  const vertices = [\n    {id: 'A', x: 100, y: 100},\n    {id: 'B', x: 300, y: 70},\n    {id: 'C', x: 500, y: 110},\n    {id: 'D', x: 150, y: 300},\n    {id: 'E', x: 350, y: 330},\n    {id: 'F', x: 550, y: 320},\n    {id: 'G', x: 400, y: 200}\n  ];\n\n  // Edges with weights, unordered pairs (undirected)\n  // We will sort edges by weight in the algorithm.\n  const edges = [\n    {v1: 'A', v2: 'B', weight: 4},\n    {v1: 'A', v2: 'D', weight: 8},\n    {v1: 'B', v2: 'C', weight: 8},\n    {v1: 'B', v2: 'D', weight: 11},\n    {v1: 'C', v2: 'F', weight: 2},\n    {v1: 'C', v2: 'G', weight: 7},\n    {v1: 'D', v2: 'E', weight: 7},\n    {v1: 'E', v2: 'F', weight: 4},\n    {v1: 'E', v2: 'G', weight: 14},\n    {v1: 'F', v2: 'G', weight: 10},\n    {v1: 'B', v2: 'G', weight: 1}  // adding an extra edge to show cycle skipping\n  ];\n\n  // Sort edges ascending by weight (copy array)\n  const sortedEdges = edges.slice().sort((a, b) => a.weight - b.weight);\n\n  // Union-Find structure\n  class UnionFind {\n    constructor(elements) {\n      this.parent = {};\n      this.rank = {};\n      elements.forEach(e => {\n        this.parent[e] = e;\n        this.rank[e] = 0;\n      });\n    }\n    find(e) {\n      if (this.parent[e] !== e) {\n        this.parent[e] = this.find(this.parent[e]);\n      }\n      return this.parent[e];\n    }\n    union(e1, e2) {\n      let root1 = this.find(e1);\n      let root2 = this.find(e2);\n      if (root1 === root2) return false; // cycle\n      // union by rank\n      if (this.rank[root1] < this.rank[root2]) {\n        this.parent[root1] = root2;\n      } else if (this.rank[root1] > this.rank[root2]) {\n        this.parent[root2] = root1;\n      } else {\n        this.parent[root2] = root1;\n        this.rank[root1]++;\n      }\n      return true;\n    }\n  }\n\n  // State for the algorithm step by step\n  let uf;\n  let currentEdgeIndex = 0;\n  let edgeStates = {}; // key: \"A-B\" or \"B-A\", value: \"pending\" | \"included\" | \"rejected\"\n  let isRunning = false;\n  let autoTimer = null;\n\n  // Get canvas and context\n  const canvas = document.getElementById('graphCanvas');\n  const ctx = canvas.getContext('2d');\n\n  // UI elements\n  const btnStep = document.getElementById('btnStep');\n  const btnAuto = document.getElementById('btnAuto');\n  const btnReset = document.getElementById('btnReset');\n  const stateText = document.getElementById('stateText');\n\n  // Helpers\n  function edgeKey(e) {\n    // always sort vertex names to have a unique key for edge\n    return [e.v1, e.v2].sort().join('-');\n  }\n\n  function drawGraph() {\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n    // Draw edges\n    edges.forEach(edge => {\n      const state = edgeStates[edgeKey(edge)] || 'pending';\n      const v1 = vertices.find(v => v.id === edge.v1);\n      const v2 = vertices.find(v => v.id === edge.v2);\n\n      // Color edges based on state\n      if (state === 'included') {\n        ctx.strokeStyle = '#4caf50'; // green\n        ctx.lineWidth = 4;\n      } else if (state === 'rejected') {\n        ctx.strokeStyle = '#f44336'; // red\n        ctx.lineWidth = 3;\n        ctx.setLineDash([5, 10]);\n      } else {\n        ctx.strokeStyle = '#aaa';\n        ctx.lineWidth = 2;\n        ctx.setLineDash([]);\n      }\n\n      ctx.beginPath();\n      ctx.moveTo(v1.x, v1.y);\n      ctx.lineTo(v2.x, v2.y);\n      ctx.stroke();\n      ctx.setLineDash([]);\n\n      // Draw weight label near midpoint\n      const midX = (v1.x + v2.x) / 2;\n      const midY = (v1.y + v2.y) / 2;\n\n      // Draw a white background to make text readable\n      const text = edge.weight.toString();\n      ctx.font = '14px Arial';\n      const textWidth = ctx.measureText(text).width;\n      const textHeight = 16;\n      ctx.fillStyle = 'white';\n      ctx.fillRect(midX - textWidth/2 - 3, midY - textHeight/2, textWidth + 6, textHeight);\n\n      ctx.fillStyle = '#333';\n      ctx.fillText(text, midX, midY + 5);\n    });\n\n    // Draw vertices\n    vertices.forEach(v => {\n      ctx.beginPath();\n      ctx.fillStyle = '#2196f3';\n      ctx.strokeStyle = '#0b72d1';\n      ctx.lineWidth = 3;\n      ctx.shadowColor = 'rgba(0,0,0,0.2)';\n      ctx.shadowBlur = 4;\n      ctx.shadowOffsetX = 2;\n      ctx.shadowOffsetY = 2;\n      ctx.arc(v.x, v.y, 18, 0, 2 * Math.PI);\n      ctx.fill();\n      ctx.shadowBlur = 0;\n      ctx.shadowOffsetX = 0;\n      ctx.shadowOffsetY = 0;\n      ctx.stroke();\n\n      // Text label for vertex\n      ctx.fillStyle = '#222';\n      ctx.font = 'bold 18px Arial';\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'middle';\n      ctx.fillText(v.id, v.x, v.y);\n    });\n  }\n\n  function updateStateText(text) {\n    stateText.textContent = text;\n  }\n\n  function resetAlgorithm() {\n    uf = new UnionFind(vertices.map(v => v.id));\n    currentEdgeIndex = 0;\n    edgeStates = {};\n    edges.forEach(e => {\n      edgeStates[edgeKey(e)] = 'pending';\n    });\n    updateStateText('Ready. Press \"Step\" to start algorithm.');\n    drawGraph();\n    if (autoTimer) {\n      clearInterval(autoTimer);\n      autoTimer = null;\n      btnAuto.textContent = 'Auto Play';\n      isRunning = false;\n    }\n  }\n\n  function stepAlgorithm() {\n    if (currentEdgeIndex >= sortedEdges.length) {\n      updateStateText('Algorithm complete! MST formed.');\n      isRunning = false;\n      if (autoTimer) {\n        clearInterval(autoTimer);\n        autoTimer = null;\n        btnAuto.textContent = 'Auto Play';\n      }\n      return;\n    }\n\n    const edge = sortedEdges[currentEdgeIndex];\n    const key = edgeKey(edge);\n\n    updateStateText(\n      `Checking edge (${edge.v1} - ${edge.v2}) with weight ${edge.weight}...`\n    );\n\n    // Check if adding edge forms cycle using union-find\n    const united = uf.union(edge.v1, edge.v2);\n    if (united) {\n      edgeStates[key] = 'included';\n      updateStateText(\n        `Included edge (${edge.v1} - ${edge.v2}, weight ${edge.weight}) in MST.`\n      );\n    } else {\n      edgeStates[key] = 'rejected';\n      updateStateText(\n        `Rejected edge (${edge.v1} - ${edge.v2}, weight ${edge.weight}) to avoid cycle.`\n      );\n    }\n\n    currentEdgeIndex++;\n    drawGraph();\n  }\n\n  btnStep.addEventListener('click', () => {\n    if (currentEdgeIndex >= sortedEdges.length) {\n      updateStateText('Algorithm is already complete! Press Reset to run again.');\n      return;\n    }\n    stepAlgorithm();\n  });\n\n  btnReset.addEventListener('click', () => {\n    resetAlgorithm();\n  });\n\n  btnAuto.addEventListener('click', () => {\n    if (isRunning) {\n      // stop\n      clearInterval(autoTimer);\n      autoTimer = null;\n      btnAuto.textContent = 'Auto Play';\n      isRunning = false;\n      updateStateText('Auto Play stopped.');\n    } else {\n      if (currentEdgeIndex >= sortedEdges.length) {\n        updateStateText('Algorithm already complete. Reset to run again.');\n        return;\n      }\n      // start auto stepping every 1.2 seconds\n      isRunning = true;\n      btnAuto.textContent = 'Pause';\n      updateStateText('Auto Play started.');\n      autoTimer = setInterval(() => {\n        if (currentEdgeIndex >= sortedEdges.length) {\n          clearInterval(autoTimer);\n          autoTimer = null;\n          btnAuto.textContent = 'Auto Play';\n          isRunning = false;\n          updateStateText('Algorithm complete! MST formed.');\n          return;\n        }\n        stepAlgorithm();\n      }, 1200);\n    }\n  });\n\n  // Init\n  resetAlgorithm();\n})();\n</script>\n</body>\n</html>"
  },
