    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<title>Insertion Sort — Interactive Demo</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<style>\n  :root{\n    --bg:#0f1724;\n    --card:#0b1220;\n    --accent:#2dd4bf;\n    --muted:#94a3b8;\n    --bar:#60a5fa;\n    --bar-compare:#facc15;\n    --bar-key:#fb7185;\n    --bar-sorted:#34d399;\n    --glass: rgba(255,255,255,0.03);\n  }\n  html,body{height:100%;margin:0;background:linear-gradient(180deg,#071021 0%, #081426 60%);color:#e6eef8;font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;}\n  .app{max-width:1100px;margin:28px auto;padding:20px;display:grid;grid-template-columns:360px 1fr;gap:20px;}\n  .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:12px;padding:16px;box-shadow:0 6px 18px rgba(2,6,23,0.6);}\n  h2{margin:0 0 10px 0;font-size:18px;color:var(--accent)}\n  p.small{color:var(--muted);margin:8px 0 12px 0;font-size:13px;line-height:1.4}\n  /* Controls */\n  .controls{display:flex;flex-direction:column;gap:12px}\n  .row{display:flex;gap:8px;align-items:center}\n  .row.space{justify-content:space-between}\n  button, input[type=\"button\"]{background:var(--glass);border:1px solid rgba(255,255,255,0.03);color:#e6eef8;padding:8px 12px;border-radius:8px;cursor:pointer}\n  button.primary{background:linear-gradient(90deg,#06b6d4,#60a5fa);color:#052023;border:none}\n  button.ghost{background:transparent;border:1px dashed rgba(255,255,255,0.04)}\n  .smallbtn{padding:6px 8px;font-size:13px}\n  input[type=\"range\"]{width:100%}\n  input[type=\"number\"], input[type=\"text\"]{padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.03);background:transparent;color:#e6eef8}\n  textarea{width:100%;height:70px;background:transparent;color:#e6eef8;border-radius:8px;border:1px solid rgba(255,255,255,0.03);padding:8px}\n  label{font-size:13px;color:var(--muted)}\n  .legend{display:flex;gap:8px;flex-wrap:wrap}\n  .legend .item{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted)}\n  .colorbox{width:14px;height:14px;border-radius:4px}\n  /* Visualizer */\n  .visualizer{display:flex;flex-direction:column;gap:12px}\n  .canvas{height:340px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));border-radius:10px;padding:12px;position:relative;overflow:hidden;border:1px solid rgba(255,255,255,0.03)}\n  .bars{position:absolute;left:12px;right:12px;bottom:12px;top:12px;display:flex;align-items:flex-end;gap:6px;padding:6px}\n  .bar{flex:1 1 auto;display:flex;align-items:flex-end;justify-content:center;border-radius:6px 6px 0 0;background:var(--bar);color:rgba(255,255,255,0.85);font-size:11px;padding-top:6px;box-shadow:0 6px 18px rgba(2,6,23,0.4) inset;border:1px solid rgba(255,255,255,0.03)}\n  .bar.compare{background:var(--bar-compare);color:#072020}\n  .bar.key{background:var(--bar-key)}\n  .bar.sorted{background:var(--bar-sorted)}\n  .status{display:flex;gap:12px;align-items:center;flex-wrap:wrap;color:var(--muted);font-size:13px}\n  .pseudocode{background:rgba(255,255,255,0.02);padding:12px;border-radius:8px;border:1px solid rgba(255,255,255,0.03);font-family:monospace;font-size:13px;color:#cfeff0}\n  pre{margin:0;white-space:pre-wrap;font-family:monospace}\n  .footer{font-size:13px;color:var(--muted);margin-top:10px}\n  .note{background:rgba(255,255,255,0.01);padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);font-size:13px}\n  .topcontrols{display:flex;gap:8px;align-items:center}\n  .center{display:flex;align-items:center;justify-content:center}\n  .smallcaps{font-size:12px;color:var(--muted)}\n  @media (max-width:880px){\n    .app{grid-template-columns:1fr; padding:12px}\n  }\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <div class=\"panel\">\n    <h2>Insertion Sort — Interactive</h2>\n    <p class=\"small\">Step through insertion sort, see comparisons and assignments (moves). Use controls to step, play, randomize, or enter a custom array.</p>\n\n    <div class=\"controls\">\n      <div class=\"row\">\n        <label class=\"smallcaps\">Array size</label>\n        <input id=\"size\" type=\"number\" value=\"18\" min=\"4\" max=\"60\" style=\"width:80px;margin-left:auto\" />\n      </div>\n\n      <div class=\"row\">\n        <label class=\"smallcaps\">Range (min,max)</label>\n        <input id=\"minVal\" type=\"number\" value=\"10\" style=\"width:80px\" />\n        <input id=\"maxVal\" type=\"number\" value=\"100\" style=\"width:80px\" />\n        <button id=\"rand\" class=\"smallbtn\" style=\"margin-left:auto\">Randomize</button>\n      </div>\n\n      <div class=\"row\">\n        <label class=\"smallcaps\">Custom array (comma or space separated)</label>\n      </div>\n      <textarea id=\"custom\" placeholder=\"e.g. 5, 3, 8, 1, 2\"></textarea>\n      <div class=\"row space\">\n        <div style=\"display:flex;gap:8px\">\n          <button id=\"load\" class=\"smallbtn\">Load</button>\n          <button id=\"shuffleLoad\" class=\"smallbtn\">Load & Randomize</button>\n        </div>\n        <div style=\"display:flex;gap:8px\">\n          <label class=\"smallcaps\">Order</label>\n          <select id=\"order\">\n            <option value=\"asc\">Ascending</option>\n            <option value=\"desc\">Descending</option>\n          </select>\n        </div>\n      </div>\n\n      <div class=\"row\">\n        <div class=\"topcontrols\">\n          <button id=\"play\" class=\"primary\">Play</button>\n          <button id=\"step\" class=\"smallbtn\">Step</button>\n          <button id=\"reset\" class=\"smallbtn\">Reset</button>\n          <button id=\"fastForward\" class=\"smallbtn\">Run to End</button>\n        </div>\n        <div style=\"margin-left:auto;width:180px\">\n          <label class=\"smallcaps\">Speed</label>\n          <input id=\"speed\" type=\"range\" min=\"50\" max=\"1200\" value=\"300\" />\n        </div>\n      </div>\n\n      <div class=\"row\">\n        <div class=\"legend\">\n          <div class=\"item\"><span class=\"colorbox\" style=\"background:var(--bar)\"></span> Unexplored</div>\n          <div class=\"item\"><span class=\"colorbox\" style=\"background:var(--bar-compare)\"></span> Comparing</div>\n          <div class=\"item\"><span class=\"colorbox\" style=\"background:var(--bar-key)\"></span> Key</div>\n          <div class=\"item\"><span class=\"colorbox\" style=\"background:var(--bar-sorted)\"></span> Sorted</div>\n        </div>\n      </div>\n\n      <div class=\"row\">\n        <div class=\"pseudocode\" style=\"width:100%\">\n<pre id=\"pseudocode\">\nfor i = 1 to n-1\n    key = A[i]\n    j = i - 1\n    while j >= 0 and A[j] > key\n        A[j+1] = A[j]   // shift right\n        j = j - 1\n    A[j+1] = key       // insert key\n</pre>\n        </div>\n      </div>\n\n      <div class=\"row\">\n        <div class=\"note\">\n          Complexity: Best O(n) (already sorted), Average/Worst O(n^2). Stable: Yes. In-place: Yes.\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"visualizer\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center\">\n        <h2 style=\"color:var(--accent)\">Array Visualization</h2>\n        <div class=\"status\">\n          <div id=\"stepCount\">Step: 0</div>\n          <div id=\"compCount\">Comparisons: 0</div>\n          <div id=\"assignCount\">Assignments: 0</div>\n          <div id=\"statusText\">Status: idle</div>\n        </div>\n      </div>\n\n      <div class=\"canvas\">\n        <div style=\"position:absolute;right:14px;top:14px;color:var(--muted);font-size:13px\">\n          Key: <span id=\"keyVal\">—</span>\n        </div>\n        <div id=\"bars\" class=\"bars\" aria-hidden=\"true\"></div>\n      </div>\n\n      <div style=\"display:flex;gap:10px;align-items:center;justify-content:space-between\">\n        <div style=\"display:flex;gap:8px;align-items:center\">\n          <div class=\"smallcaps\">Current i</div>\n          <div id=\"iIndex\" style=\"font-weight:600\">—</div>\n          <div class=\"smallcaps\">Current j</div>\n          <div id=\"jIndex\" style=\"font-weight:600\">—</div>\n        </div>\n        <div style=\"color:var(--muted);font-size:13px\" id=\"actionText\">Action: —</div>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <div class=\"pseudocode\" id=\"explain\" style=\"font-size:13px\">\n          <strong>Explanation:</strong>\n          Insertion sort builds a sorted left portion of the array by extracting each element (the \"key\") and shifting larger elements right until the correct position for the key is found, then inserting the key there.\n        </div>\n      </div>\n\n    </div>\n    <div class=\"footer\">\n      Try different array sizes and patterns. Use Step to observe each comparison/shift. Assignments count each write to the array.\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  // Utility\n  function randInt(min,max){ return Math.floor(Math.random()*(max-min+1))+min }\n  function clamp(v,a,b){ return Math.max(a,Math.min(b,v)) }\n\n  // DOM\n  const barsEl = document.getElementById('bars');\n  const sizeEl = document.getElementById('size');\n  const randBtn = document.getElementById('rand');\n  const loadBtn = document.getElementById('load');\n  const shuffleLoadBtn = document.getElementById('shuffleLoad');\n  const customEl = document.getElementById('custom');\n  const minValEl = document.getElementById('minVal');\n  const maxValEl = document.getElementById('maxVal');\n  const playBtn = document.getElementById('play');\n  const stepBtn = document.getElementById('step');\n  const resetBtn = document.getElementById('reset');\n  const ffBtn = document.getElementById('fastForward');\n  const speedEl = document.getElementById('speed');\n  const orderEl = document.getElementById('order');\n  const keyValEl = document.getElementById('keyVal');\n  const stepCountEl = document.getElementById('stepCount');\n  const compCountEl = document.getElementById('compCount');\n  const assignCountEl = document.getElementById('assignCount');\n  const statusTextEl = document.getElementById('statusText');\n  const iIndexEl = document.getElementById('iIndex');\n  const jIndexEl = document.getElementById('jIndex');\n  const actionTextEl = document.getElementById('actionText');\n\n  // State\n  let arr = [];\n  let initialArr = [];\n  let iterator = null;\n  let playing = false;\n  let timer = null;\n  let delay = Number(speedEl.value);\n  let stats = {steps:0, comps:0, assigns:0};\n  let lastState = null;\n\n  // Initialize with random array\n  function generateRandom(){\n    const n = clamp(Number(sizeEl.value) || 18, 4, 60);\n    const min = Number(minValEl.value) || 5;\n    const max = Number(maxValEl.value) || 100;\n    const a=[];\n    for(let i=0;i<n;i++) a.push(randInt(min,max));\n    return a;\n  }\n\n  function renderArray(state){\n    // state: {arr, i, j, key, action, sortedIndices: Set}\n    const A = state && state.arr ? state.arr : arr;\n    const n = A.length;\n    // compute heights\n    const min = Math.min(...A);\n    const max = Math.max(...A);\n    const range = Math.max(1, max-min);\n    barsEl.innerHTML = '';\n    for(let idx=0; idx<n; idx++){\n      const v = A[idx];\n      const h = 8 + ((v - min) / range) * (100); // percentish\n      const bar = document.createElement('div');\n      bar.className = 'bar';\n      if(state){\n        if(state.action === 'compare' && (idx === state.compareIndex || idx === state.compareWith)) bar.classList.add('compare');\n        if(state.action === 'select' && idx === state.i) bar.classList.add('key');\n        if(state.action === 'insert' && idx === state.insertIndex) bar.classList.add('key');\n        if(state.action === 'shift' && idx === state.shiftIndex) bar.classList.add('compare');\n        if(state.sortedIndices && state.sortedIndices.has(idx)) bar.classList.add('sorted');\n        // mark key position indicator: original i\n        if(idx === state.i && state.action !== 'done') bar.classList.add('key');\n      }\n      bar.style.height = h + '%';\n      bar.textContent = String(v);\n      barsEl.appendChild(bar);\n    }\n    // show key separately\n    keyValEl.textContent = (state && state.key !== undefined && state.key !== null) ? state.key : '—';\n  }\n\n  // Generator that yields states for visualization\n  function* insertionSortGen(A, ascending=true){\n    const n = A.length;\n    // copy to work on\n    let arr = A.slice();\n    let comps = 0;\n    let assigns = 0;\n    const sortedSet = new Set();\n    // initial state\n    yield {arr:arr.slice(), i:null, j:null, key:null, action:'start', sortedIndices:new Set()};\n    for(let i=1;i<n;i++){\n      const key = arr[i];\n      let j = i - 1;\n      // select key\n      yield {arr:arr.slice(), i:i, j:j, key:key, action:'select', sortedIndices: new Set([...Array(i).keys()])};\n      // while check (we'll count comparisons including the failing one)\n      while(j >= 0){\n        comps++;\n        yield {arr:arr.slice(), i:i, j:j, key:key, action:'compare', compareIndex:j, compareWith:i, comps:comps, assigns:assigns, sortedIndices: new Set([...Array(i).keys()])};\n        const cond = ascending ? (arr[j] > key) : (arr[j] < key);\n        if(cond){\n          // shift\n          arr[j+1] = arr[j];\n          assigns++;\n          yield {arr:arr.slice(), i:i, j:j, key:key, action:'shift', shiftIndex:j+1, comps:comps, assigns:assigns, sortedIndices: new Set([...Array(i).keys()])};\n          j = j - 1;\n        } else {\n          break;\n        }\n      }\n      // insertion\n      arr[j+1] = key;\n      assigns++;\n      // update sorted set\n      for(let k=0;k<=i;k++) sortedSet.add(k);\n      yield {arr:arr.slice(), i:i, j:j, key:key, action:'insert', insertIndex:j+1, comps:comps, assigns:assigns, sortedIndices: new Set(sortedSet)};\n    }\n    // done\n    yield {arr:arr.slice(), i:null, j:null, key:null, action:'done', sortedIndices: new Set([...Array(n).keys()]), comps:comps, assigns:assigns};\n  }\n\n  // Controls\n  function startPlay(){\n    if(playing) return;\n    if(!iterator) iterator = insertionSortGen(arr, orderEl.value==='asc');\n    playing = true;\n    playBtn.textContent = 'Pause';\n    statusTextEl.textContent = 'Status: playing';\n    tick();\n    timer = setInterval(tick, delay);\n  }\n\n  function pausePlay(){\n    playing = false;\n    playBtn.textContent = 'Play';\n    statusTextEl.textContent = 'Status: paused';\n    if(timer){ clearInterval(timer); timer = null; }\n  }\n\n  function reset(){\n    pausePlay();\n    arr = initialArr.slice();\n    iterator = null;\n    stats = {steps:0, comps:0, assigns:0};\n    stepCountEl.textContent = 'Step: 0';\n    compCountEl.textContent = 'Comparisons: 0';\n    assignCountEl.textContent = 'Assignments: 0';\n    iIndexEl.textContent = '—';\n    jIndexEl.textContent = '—';\n    actionTextEl.textContent = 'Action: —';\n    keyValEl.textContent = '—';\n    statusTextEl.textContent = 'Status: idle';\n    renderArray({arr:arr.slice(), action:'start', sortedIndices: new Set()});\n  }\n\n  function stepOne(){\n    if(!iterator) iterator = insertionSortGen(arr, orderEl.value==='asc');\n    const res = iterator.next();\n    stats.steps++;\n    stepCountEl.textContent = 'Step: ' + stats.steps;\n    if(res.done){\n      // shouldn't happen normally because generator yields final done state then done true.\n      statusTextEl.textContent = 'Status: finished';\n      renderArray({arr:arr.slice(), action:'done', sortedIndices: new Set([...Array(arr.length).keys()])});\n      iterator = null;\n      pausePlay();\n      return;\n    }\n    const s = res.value;\n    // update arr if generator included new arr snapshot\n    if(s.arr) arr = s.arr.slice();\n    // update stats\n    if('comps' in s) stats.comps = s.comps;\n    if('assigns' in s) stats.assigns = s.assigns;\n    compCountEl.textContent = 'Comparisons: ' + stats.comps;\n    assignCountEl.textContent = 'Assignments: ' + stats.assigns;\n    // UI\n    iIndexEl.textContent = (s.i===null || s.i===undefined) ? '—' : s.i;\n    jIndexEl.textContent = (s.j===null || s.j===undefined) ? '—' : s.j;\n    actionTextEl.textContent = 'Action: ' + (s.action || '—');\n    if(s.action === 'done'){\n      statusTextEl.textContent = 'Status: finished';\n      pausePlay();\n    } else {\n      statusTextEl.textContent = playing ? 'Status: playing' : 'Status: stepped';\n    }\n    renderArray(s);\n    lastState = s;\n    // if done, stop playing\n    if(s.action === 'done'){\n      iterator = null;\n      pausePlay();\n    }\n  }\n\n  function tick(){\n    if(!iterator) iterator = insertionSortGen(arr, orderEl.value==='asc');\n    const res = iterator.next();\n    stats.steps++;\n    stepCountEl.textContent = 'Step: ' + stats.steps;\n    if(res.done){\n      statusTextEl.textContent = 'Status: finished';\n      renderArray({arr:arr.slice(), action:'done', sortedIndices: new Set([...Array(arr.length).keys()])});\n      iterator = null;\n      pausePlay();\n      return;\n    }\n    const s = res.value;\n    if(s.arr) arr = s.arr.slice();\n    if('comps' in s) stats.comps = s.comps;\n    if('assigns' in s) stats.assigns = s.assigns;\n    compCountEl.textContent = 'Comparisons: ' + stats.comps;\n    assignCountEl.textContent = 'Assignments: ' + stats.assigns;\n    iIndexEl.textContent = (s.i===null || s.i===undefined) ? '—' : s.i;\n    jIndexEl.textContent = (s.j===null || s.j===undefined) ? '—' : s.j;\n    actionTextEl.textContent = 'Action: ' + (s.action || '—');\n    renderArray(s);\n    lastState = s;\n    if(s.action === 'done'){\n      iterator = null;\n      pausePlay();\n    }\n  }\n\n  // Run to end (fast)\n  function runToEnd(){\n    pausePlay();\n    if(!iterator) iterator = insertionSortGen(arr, orderEl.value==='asc');\n    let res;\n    do {\n      res = iterator.next();\n      if(!res.done){\n        const s = res.value;\n        if(s.arr) arr = s.arr.slice();\n        if('comps' in s) stats.comps = s.comps;\n        if('assigns' in s) stats.assigns = s.assigns;\n        stats.steps++;\n      }\n    } while(!res.done);\n    // final state is last value yielded\n    const final = res.value || {arr:arr.slice(), action:'done', sortedIndices:new Set([...Array(arr.length).keys()])};\n    stepCountEl.textContent = 'Step: ' + stats.steps;\n    compCountEl.textContent = 'Comparisons: ' + stats.comps;\n    assignCountEl.textContent = 'Assignments: ' + stats.assigns;\n    renderArray(final);\n    statusTextEl.textContent = 'Status: finished';\n    iterator = null;\n    pausePlay();\n  }\n\n  // Events\n  randBtn.addEventListener('click', ()=>{\n    initialArr = generateRandom();\n    arr = initialArr.slice();\n    reset();\n  });\n\n  loadBtn.addEventListener('click', ()=>{\n    const txt = customEl.value.trim();\n    if(!txt) return;\n    const parts = txt.split(/[\\s,]+/).filter(Boolean);\n    const nums = parts.map(x => Number(x)).filter(x => !Number.isNaN(x));\n    if(nums.length === 0) { alert('No valid numbers found'); return; }\n    initialArr = nums.slice();\n    sizeEl.value = nums.length;\n    arr = initialArr.slice();\n    reset();\n  });\n\n  shuffleLoadBtn.addEventListener('click', ()=>{\n    const txt = customEl.value.trim();\n    if(!txt) return;\n    const parts = txt.split(/[\\s,]+/).filter(Boolean);\n    const nums = parts.map(x => Number(x)).filter(x => !Number.isNaN(x));\n    if(nums.length === 0) { alert('No valid numbers found'); return; }\n    // random shuffle\n    for(let i=nums.length-1;i>0;i--){\n      const j = Math.floor(Math.random()*(i+1));\n      [nums[i], nums[j]] = [nums[j], nums[i]];\n    }\n    initialArr = nums.slice();\n    sizeEl.value = nums.length;\n    arr = initialArr.slice();\n    reset();\n  });\n\n  playBtn.addEventListener('click', ()=>{\n    if(playing) pausePlay(); else startPlay();\n  });\n\n  stepBtn.addEventListener('click', ()=>{\n    pausePlay();\n    stepOne();\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    reset();\n  });\n\n  ffBtn.addEventListener('click', ()=>{\n    runToEnd();\n  });\n\n  speedEl.addEventListener('input', ()=>{\n    delay = Number(speedEl.value);\n    if(playing){\n      pausePlay();\n      startPlay();\n    }\n  });\n\n  orderEl.addEventListener('change', ()=>{\n    reset();\n  });\n\n  // initial\n  initialArr = generateRandom();\n  arr = initialArr.slice();\n  reset();\n\n  // expose simple keyboard controls: Space play/pause, Right step\n  window.addEventListener('keydown', (e)=>{\n    if(e.code === 'Space'){ e.preventDefault(); if(playing) pausePlay(); else startPlay(); }\n    if(e.code === 'ArrowRight'){ e.preventDefault(); pausePlay(); stepOne(); }\n  });\n\n  // small responsive: re-render on window resize\n  window.addEventListener('resize', ()=> renderArray(lastState || {arr:arr.slice(), action:'start', sortedIndices:new Set()}));\n\n})();\n</script>\n</body>\n</html>"
  },
