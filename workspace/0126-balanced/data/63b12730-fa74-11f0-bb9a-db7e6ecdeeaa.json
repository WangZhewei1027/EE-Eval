    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Counting Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9f9f9;\n    color: #222;\n  }\n  h1 {\n    text-align: center;\n  }\n  #inputArray {\n    width: 100%;\n    padding: 10px;\n    font-size: 1.1em;\n  }\n  #btnSort {\n    margin-top: 10px;\n    padding: 10px 20px;\n    font-size: 1.1em;\n    cursor: pointer;\n  }\n  #visualization {\n    margin-top: 30px;\n  }\n  .section {\n    margin-bottom: 40px;\n  }\n  .stepTitle {\n    font-weight: bold;\n    margin-bottom: 10px;\n    font-size: 1.2em;\n    color: #333;\n  }\n  .arrayContainer {\n    display: flex;\n    flex-wrap: nowrap;\n    gap: 6px;\n    margin-bottom: 15px;\n  }\n  .elem {\n    background-color: #4CAF50;\n    color: white;\n    padding: 8px 12px;\n    border-radius: 4px;\n    font-weight: bold;\n    min-width: 28px;\n    text-align: center;\n    user-select: none;\n    transition: background-color 0.3s ease;\n  }\n  .elem.highlight {\n    background-color: #FF5722;\n  }\n  .countElem {\n    background-color: #2196F3;\n    color: white;\n    padding: 6px 10px;\n    border-radius: 6px;\n    min-width: 24px;\n    text-align: center;\n    font-weight: 600;\n    user-select: none;\n  }\n  .countElem.highlight {\n    background-color: #FF9800;\n  }\n  #speedControl {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    margin-top: 10px;\n  }\n  #speedLabel {\n    min-width: 100px;\n  }\n  #message {\n    margin-top: 15px;\n    font-style: italic;\n    color: #555;\n    min-height: 24px;\n  }\n  footer {\n    margin-top: 50px;\n    font-size: 0.9em;\n    color: #666;\n    text-align: center;\n  }\n  a {\n    color: #2196F3;\n  }\n</style>\n</head>\n<body>\n<h1>Counting Sort Visualization</h1>\n<p>Enter a list of non-negative integers separated by commas or spaces (e.g. <code>4, 2, 2, 8, 3, 3, 1</code>):</p>\n<textarea id=\"inputArray\" rows=\"3\" placeholder=\"Example: 4, 2, 2, 8, 3, 3, 1\">4, 2, 2, 8, 3, 3, 1</textarea>\n<br />\n<button id=\"btnSort\">Start Counting Sort</button>\n<div id=\"speedControl\">\n  <label id=\"speedLabel\" for=\"speedRange\">Animation speed:</label>\n  <input type=\"range\" id=\"speedRange\" min=\"100\" max=\"2000\" step=\"100\" value=\"700\" />\n  <span id=\"speedValue\">700 ms</span>\n</div>\n\n<div id=\"visualization\">\n  <!-- Visualization steps will be inserted here -->\n</div>\n<div id=\"message\"></div>\n\n<footer>\n  <p>Counting Sort Visualization &mdash; Algorithm explanation and step-by-step demonstration.</p>\n</footer>\n\n<script>\n(() => {\n  const inputArea = document.getElementById('inputArray');\n  const btnSort = document.getElementById('btnSort');\n  const viz = document.getElementById('visualization');\n  const message = document.getElementById('message');\n  const speedRange = document.getElementById('speedRange');\n  const speedValue = document.getElementById('speedValue');\n\n  function delay(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Helper to create a container with title and array flex container\n  function createStepContainer(titleText) {\n    const container = document.createElement('div');\n    container.className = 'section';\n    const title = document.createElement('div');\n    title.className = 'stepTitle';\n    title.textContent = titleText;\n    container.appendChild(title);\n    const arrContainer = document.createElement('div');\n    arrContainer.className = 'arrayContainer';\n    container.appendChild(arrContainer);\n    return {container, arrContainer};\n  }\n\n  // Render array elements with optional highlights\n  function renderArray(arrContainer, array, highlights = []) {\n    arrContainer.innerHTML = '';\n    array.forEach((val, i) => {\n      const elem = document.createElement('div');\n      elem.className = 'elem';\n      elem.textContent = val;\n      if (highlights.includes(i)) {\n        elem.classList.add('highlight');\n      }\n      arrContainer.appendChild(elem);\n    });\n  }\n\n  // Render count array\n  function renderCountArray(arrContainer, counts, highlights = []) {\n    arrContainer.innerHTML = '';\n    counts.forEach((count, i) => {\n      const elem = document.createElement('div');\n      elem.className = 'countElem';\n      elem.textContent = count;\n      if (highlights.includes(i)) elem.classList.add('highlight');\n      elem.title = `Value ${i} count`;\n      arrContainer.appendChild(elem);\n    });\n  }\n\n  // Parse and validate input array\n  function parseInput(text) {\n    if (!text.trim()) return null;\n    // Split by commas or spaces\n    let parts = text.split(/[\\s,]+/);\n    let arr = [];\n    for (const p of parts) {\n      if (p === '') continue;\n      let num = Number(p);\n      if (!Number.isInteger(num) || num < 0) return null;\n      arr.push(num);\n    }\n    if (arr.length === 0) return null;\n    return arr;\n  }\n\n  // Main async function for sorting and visualizing step by step\n  async function countingSortVisual(array, speed) {\n    viz.innerHTML = '';\n    message.textContent = '';\n    btnSort.disabled = true;\n    inputArea.disabled = true;\n    speedRange.disabled = true;\n\n    // Step 1: Show original array\n    const step1 = createStepContainer('Original Array');\n    viz.appendChild(step1.container);\n    renderArray(step1.arrContainer, array);\n    message.textContent = 'This is the input array we want to sort.';\n    await delay(speed);\n\n    // Find max value in array for count size\n    const maxVal = Math.max(...array);\n\n    // Step 2: Initialize count array\n    let count = new Array(maxVal + 1).fill(0);\n    const step2 = createStepContainer(`Initialize Count Array (size = max value + 1 = ${maxVal + 1})`);\n    viz.appendChild(step2.container);\n    renderCountArray(step2.arrContainer, count);\n    message.textContent = 'Create an array to store counts for each integer value.';\n    await delay(speed);\n\n    // Step 3: Count occurrences\n    message.textContent = 'Counting the occurrences of each value...';\n    for (let i = 0; i < array.length; i++) {\n      count[array[i]]++;\n      renderCountArray(step2.arrContainer, count, [array[i]]);\n      renderArray(step1.arrContainer, array, [i]);\n      message.textContent = `Counting value ${array[i]} (index ${i})...`;\n      await delay(speed);\n    }\n\n    // Step 4: Cumulative sum in count array\n    message.textContent = 'Computing cumulative counts (prefix sums)...';\n    for (let i = 1; i < count.length; i++) {\n      count[i] += count[i - 1];\n      renderCountArray(step2.arrContainer, count, [i, i - 1]);\n      await delay(speed);\n    }\n\n    // Step 5: Output array initialization\n    let output = new Array(array.length).fill(0);\n    const step3 = createStepContainer('Build Output Array');\n    viz.appendChild(step3.container);\n    renderArray(step3.arrContainer, output);\n    message.textContent = 'Build the sorted output array by placing elements at their correct positions.';\n    await delay(speed);\n\n    // Step 6: Build output array by iterating input array backward for stable sort\n    for (let i = array.length - 1; i >= 0; i--) {\n      const val = array[i];\n      count[val]--;\n      const pos = count[val];\n      output[pos] = val;\n      renderCountArray(step2.arrContainer, count, [val]);\n      renderArray(step1.arrContainer, array, [i]);\n      renderArray(step3.arrContainer, output, [pos]);\n      message.textContent = `Placing value ${val} from input index ${i} to output index ${pos}.`;\n      await delay(speed);\n    }\n\n    // Step 7: Final sorted array\n    message.textContent = 'Sorting complete! Here is the sorted array.';\n    renderArray(step3.arrContainer, output);\n    btnSort.disabled = false;\n    inputArea.disabled = false;\n    speedRange.disabled = false;\n  }\n\n  btnSort.addEventListener('click', () => {\n    const rawInput = inputArea.value;\n    const arr = parseInput(rawInput);\n    if (!arr) {\n      alert('Please enter a valid list of non-negative integers, separated by commas or spaces.');\n      return;\n    }\n    countingSortVisual(arr, Number(speedRange.value));\n  });\n\n  speedRange.addEventListener('input', () => {\n    speedValue.textContent = speedRange.value + ' ms';\n  });\n\n  // Initial speed display\n  speedValue.textContent = speedRange.value + ' ms';\n})();\n</script>\n</body>\n</html>"
