    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Git Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            max-width: 500px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #f9f9f9;\n            border: 1px solid #ddd;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .title {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n        .button {\n            padding: 10px 20px;\n            border: none;\n            border-radius: 5px;\n            background-color: #4CAF50;\n            color: #fff;\n            cursor: pointer;\n        }\n        .button:hover {\n            background-color: #3e8e41;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Git Demo</h1>\n        <p>Git is a version control system that allows multiple developers to work on the same project simultaneously.</p>\n        <button class=\"button\" id=\"git-clone-button\">Clone Repository</button>\n        <button class=\"button\" id=\"git-push-button\">Push to GitHub</button>\n        <button class=\"button\" id=\"git-branch-button\">Create New Branch</button>\n        <button class=\"button\" id=\"git-commit-button\">Commit Changes</button>\n        <button class=\"button\" id=\"git-status-button\">Get Git Status</button>\n    </div>\n\n    <script>\n        // Clone repository\n        document.getElementById('git-clone-button').addEventListener('click', () => {\n            const cloneUrl = 'https://github.com/your-username/your-repo-name.git';\n            const cloneButton = document.getElementById('git-clone-button');\n            cloneButton.href = cloneUrl;\n            cloneButton.textContent = 'Clone Repository';\n        });\n\n        // Push to GitHub\n        document.getElementById('git-push-button').addEventListener('click', () => {\n            const pushUrl = 'https://github.com/your-username/your-repo-name.git';\n            const pushButton = document.getElementById('git-push-button');\n            pushButton.href = pushUrl;\n            pushButton.textContent = 'Push to GitHub';\n        });\n\n        // Create new branch\n        document.getElementById('git-branch-button').addEventListener('click', () => {\n            const branchUrl = 'https://github.com/your-username/your-repo-name.git';\n            const branchButton = document.getElementById('git-branch-button');\n            branchButton.href = branchUrl;\n            branchButton.textContent = 'Create New Branch';\n        });\n\n        // Commit changes\n        document.getElementById('git-commit-button').addEventListener('click', () => {\n            const commitUrl = 'https://github.com/your-username/your-repo-name.git';\n            const commitButton = document.getElementById('git-commit-button');\n            commitButton.href = commitUrl;\n            commitButton.textContent = 'Commit Changes';\n        });\n\n        // Get Git status\n        document.getElementById('git-status-button').addEventListener('click', () => {\n            const statusUrl = 'https://github.com/your-username/your-repo-name.git';\n            const statusButton = document.getElementById('git-status-button');\n            statusButton.href = statusUrl;\n            statusButton.textContent = 'Get Git Status';\n        });\n    </script>\n</body>\n</html>"
