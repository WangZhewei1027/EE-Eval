    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree Index Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #bTree {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-top: 20px;\n        }\n        .node {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            border: 1px solid #000;\n            border-radius: 5px;\n            margin: 5px;\n            padding: 10px;\n            width: 60px;\n            background-color: #f9f9f9;\n        }\n        .link {\n            display: block;\n            border-left: 1px solid #000;\n            height: 20px;\n            margin-left: 29px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>B-Tree Index Demonstration</h1>\n<p>This simulation illustrates how a B-Tree Index works with insertion and search operations.</p>\n<div id=\"controls\">\n    <input type=\"number\" id=\"valueInput\" placeholder=\"Value to insert\" min=\"0\">\n    <button onclick=\"insertNode()\">Insert Node</button>\n    <button onclick=\"searchNode()\">Search Node</button>\n</div>\n<div id=\"searchResult\"></div>\n\n<div id=\"bTree\"></div>\n\n<script>\n    class BTreeNode {\n        constructor(t) {\n            this.leaf = true;\n            this.keys = [];\n            this.children = [];\n            this.t = t; // Minimum degree\n        }\n    }\n\n    class BTree {\n        constructor(t) {\n            this.root = null;\n            this.t = t;\n        }\n\n        insert(k) {\n            if (!this.root) {\n                this.root = new BTreeNode(this.t);\n                this.root.keys.push(k);\n            } else {\n                if (this.root.keys.length === 2 * this.t - 1) {\n                    let s = new BTreeNode(this.t);\n                    s.leaf = false;\n                    s.children.push(this.root);\n                    this.splitChild(s, 0);\n                    this.insertNonFull(s, k);\n                    this.root = s;\n                } else {\n                    this.insertNonFull(this.root, k);\n                }\n            }\n            this.render();\n        }\n\n        insertNonFull(node, k) {\n            let i = node.keys.length - 1;\n            if (node.leaf) {\n                node.keys.push(null);\n                while (i >= 0 && k < node.keys[i]) {\n                    node.keys[i + 1] = node.keys[i];\n                    i--;\n                }\n                node.keys[i + 1] = k;\n            } else {\n                while (i >= 0 && k < node.keys[i]) {\n                    i--;\n                }\n                i++;\n                if (node.children[i].keys.length === 2 * this.t - 1) {\n                    this.splitChild(node, i);\n                    if (k > node.keys[i]) {\n                        i++;\n                    }\n                }\n                this.insertNonFull(node.children[i], k);\n            }\n        }\n\n        splitChild(parent, i) {\n            let t = this.t;\n            let y = parent.children[i];\n            let z = new BTreeNode(t);\n            z.leaf = y.leaf;\n            for (let j = 0; j < t - 1; j++) {\n                z.keys.push(y.keys[j + t]);\n            }\n            if (!y.leaf) {\n                for (let j = 0; j < t; j++) {\n                    z.children.push(y.children[j + t]);\n                }\n            }\n            parent.children.splice(i + 1, 0, z);\n            parent.keys.splice(i, 0, y.keys[t - 1]);\n            y.keys.splice(t - 1, t);\n        }\n\n        search(k, node) {\n            if (!node) {\n                return false;\n            }\n            let i = 0;\n            while (i < node.keys.length && k > node.keys[i]) {\n                i++;\n            }\n            if (i < node.keys.length && k === node.keys[i]) {\n                return true;\n            }\n            return node.leaf ? false : this.search(k, node.children[i]);\n        }\n\n        render() {\n            const bTreeDiv = document.getElementById('bTree');\n            bTreeDiv.innerHTML = '';\n            this.renderNode(this.root, bTreeDiv);\n        }\n\n        renderNode(node, parentDiv) {\n            const nodeDiv = document.createElement('div');\n            nodeDiv.className = 'node';\n            nodeDiv.textContent = node.keys.join(', ');\n\n            parentDiv.appendChild(nodeDiv);\n\n            if (!node.leaf) {\n                node.children.forEach(child => {\n                    const link = document.createElement('div');\n                    link.className = 'link';\n                    parentDiv.appendChild(link);\n                    this.renderNode(child, parentDiv);\n                });\n            }\n        }\n    }\n\n    const bTree = new BTree(2);\n\n    function insertNode() {\n        const valueInput = document.getElementById('valueInput');\n        const value = parseInt(valueInput.value, 10);\n        if (!isNaN(value)) {\n            bTree.insert(value);\n            valueInput.value = '';\n        }\n    }\n\n    function searchNode() {\n        const valueInput = document.getElementById('valueInput');\n        const value = parseInt(valueInput.value, 10);\n        const result = bTree.search(value, bTree.root);\n        const searchResultDiv = document.getElementById('searchResult');\n        searchResultDiv.textContent = result ? `Value ${value} found in the B-Tree.` : `Value ${value} not found in the B-Tree.`;\n    }\n\n</script>\n\n</body>\n</html>"
