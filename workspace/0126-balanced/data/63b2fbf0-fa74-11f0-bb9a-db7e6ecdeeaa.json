    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>NoSQL Concept Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    color: #4A90E2;\n  }\n  pre {\n    background: #222;\n    color: #0f0;\n    padding: 1rem;\n    border-radius: 5px;\n    overflow-x: auto;\n  }\n  button {\n    margin: 0.5rem 0;\n    padding: 0.5rem 1rem;\n    border: none;\n    background: #4A90E2;\n    color: white;\n    font-weight: bold;\n    border-radius: 3px;\n    cursor: pointer;\n  }\n  button:hover {\n    background: #357ABD;\n  }\n  #output {\n    background: #fff;\n    padding: 1rem;\n    border: 1px solid #ddd;\n    border-radius: 4px;\n    max-height: 300px;\n    overflow-y: auto;\n    white-space: pre-wrap;\n    margin-top: 1rem;\n  }\n</style>\n</head>\n<body>\n<h1>Understanding NoSQL with JavaScript Objects</h1>\n<p>\n  NoSQL databases store data in flexible, document-like formats (like JSON), rather than fixed tables.\n  Here's a simple demonstration using JavaScript to mimic NoSQL key-value and document storage:\n</p>\n\n<h2>1. Our \"Database\"</h2>\n<pre id=\"db-display\"></pre>\n\n<h2>2. Operations</h2>\n<button onclick=\"insertDocument()\">Insert Document</button>\n<button onclick=\"findDocument()\">Find Document</button>\n<button onclick=\"updateDocument()\">Update Document</button>\n<button onclick=\"deleteDocument()\">Delete Document</button>\n<button onclick=\"showAll()\">Show All Documents</button>\n\n<h2>Output:</h2>\n<div id=\"output\">Click buttons above to interact with the NoSQL database.</div>\n\n<script>\n// A simple in-memory \"NoSQL\" database using an object, where keys are document IDs\nconst noSQLDB = {};\n\n// Display DB contents on page\nfunction displayDB() {\n  const dbDisplay = document.getElementById('db-display');\n  if (Object.keys(noSQLDB).length === 0) {\n    dbDisplay.textContent = '{} (empty)';\n  } else {\n    dbDisplay.textContent = JSON.stringify(noSQLDB, null, 2);\n  }\n}\n\n// Generate a random id like MongoDB's ObjectId (simplified)\nfunction generateId() {\n  return Math.random().toString(16).slice(2) + Date.now().toString(16);\n}\n\n// Insert a new document (like a JSON object) into the DB\nfunction insertDocument() {\n  const id = generateId();\n  // Example document with flexible fields\n  const doc = {\n    name: \"Alice\",\n    age: 28,\n    interests: [\"reading\", \"hiking\", \"coding\"],\n    createdAt: new Date().toISOString()\n  };\n  noSQLDB[id] = doc;\n  updateOutput(`Inserted document with id: ${id}\\n` + JSON.stringify(doc, null, 2));\n  displayDB();\n}\n\n// Find a document by a condition (e.g., name = \"Alice\")\nfunction findDocument() {\n  const results = [];\n  for (const id in noSQLDB) {\n    const doc = noSQLDB[id];\n    if (doc.name === \"Alice\") {\n      results.push({ id, ...doc });\n    }\n  }\n  if (results.length === 0) {\n    updateOutput(\"No documents found with name = 'Alice'.\");\n  } else {\n    updateOutput(`Found ${results.length} document(s) with name = 'Alice':\\n` + JSON.stringify(results, null, 2));\n  }\n}\n\n// Update documents that match a condition (e.g., name = 'Alice') to increment age by 1\nfunction updateDocument() {\n  let updatedCount = 0;\n  for (const id in noSQLDB) {\n    if (noSQLDB[id].name === \"Alice\") {\n      noSQLDB[id].age += 1;\n      updatedCount++;\n    }\n  }\n  if (updatedCount === 0) {\n    updateOutput(\"No documents found to update with name = 'Alice'.\");\n  } else {\n    updateOutput(`Updated age for ${updatedCount} document(s) with name = 'Alice'.`);\n  }\n  displayDB();\n}\n\n// Delete documents with name = 'Alice'\nfunction deleteDocument() {\n  let deletedCount = 0;\n  for (const id in noSQLDB) {\n    if (noSQLDB[id].name === \"Alice\") {\n      delete noSQLDB[id];\n      deletedCount++;\n    }\n  }\n  if (deletedCount === 0) {\n    updateOutput(\"No documents found to delete with name = 'Alice'.\");\n  } else {\n    updateOutput(`Deleted ${deletedCount} document(s) with name = 'Alice'.`);\n  }\n  displayDB();\n}\n\nfunction showAll() {\n  if (Object.keys(noSQLDB).length === 0) {\n    updateOutput(\"Database is empty.\");\n  } else {\n    updateOutput(\"All documents:\\n\" + JSON.stringify(noSQLDB, null, 2));\n  }\n}\n\n// Helper to update output area\nfunction updateOutput(text) {\n  const output = document.getElementById('output');\n  output.textContent = text;\n}\n\n// Initial display\ndisplayDB();\n</script>\n</body>\n</html>"
