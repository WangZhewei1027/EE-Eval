    "content": "<html>\n<head>\n    <title>Interpolation Search</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #search-container {\n            width: 300px;\n            margin: 40px auto;\n        }\n    </style>\n</head>\n<body>\n    <h1>Interpolation Search</h1>\n    <div id=\"search-container\">\n        <input type=\"text\" id=\"search-input\" placeholder=\"Enter a value to search...\">\n        <button id=\"search-button\">Search</button>\n        <p id=\"result\"></p>\n    </div>\n\n    <script>\n        function interpolationSearch(arr, x) {\n            let left = 0;\n            let right = arr.length - 1;\n\n            while (left <= right && x >= arr[left] && x <= arr[right]) {\n                if (x <= arr[left + 1] && x > arr[left]) {\n                    left++;\n                } else if (x < arr[left] && x > arr[left + 1]) {\n                    right--;\n                } else {\n                    return false;\n                }\n            }\n\n            if (left > right) {\n                return true;\n            }\n\n            let index = left;\n            while (x === arr[index]) {\n                result.append(index + 1);\n                index = (index + 1) / 2;\n            }\n\n            return index;\n        }\n\n        function search(arr, x) {\n            let index = interpolationSearch(arr, x);\n            if (index !== -1) {\n                result.append(index + 1);\n            } else {\n                result.append(\"Not Found\");\n            }\n        }\n\n        let arr = [2, 3, 4, 10, 40, 50, 60, 80, 100];\n        let result = document.getElementById(\"result\");\n\n        document.getElementById(\"search-button\").addEventListener(\"click\", function() {\n            let input = document.getElementById(\"search-input\").value;\n            search(arr, input);\n        });\n    </script>\n</body>\n</html>"
