    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Abstract Syntax Tree</title>\n    <style>\n        body {\n            font-family: monospace;\n        }\n        .tree {\n            padding: 10px;\n            border: 1px solid black;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.2);\n        }\n        .node {\n            padding: 10px;\n            border: 1px solid black;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.2);\n        }\n        .node-name {\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <h1>Abstract Syntax Tree</h1>\n    <div id=\"tree\"></div>\n\n    <script>\n        function createNode(name, value) {\n            return {\n                name,\n                value,\n                children: []\n            };\n        }\n\n        function addNode(parent, node) {\n            parent.children.push(node);\n        }\n\n        function printTree(node, indent = 0) {\n            const nodeElement = document.createElement('div');\n            nodeElement.classList.add('node');\n            nodeElement.innerHTML = `${indent}  ${node.name}: ${node.value}`;\n\n            for (const child of node.children) {\n                addNode(nodeElement, child);\n            }\n\n            return nodeElement;\n        }\n\n        const tree = {\n            name: 'root',\n            value: 'This is the root of the tree.',\n            children: [\n                {\n                    name: 'child1',\n                    value: 'This is the child 1.',\n                    children: []\n                },\n                {\n                    name: 'child2',\n                    value: 'This is the child 2.',\n                    children: []\n                }\n            ]\n        };\n\n        const treeElement = printTree(tree, 0);\n\n        document.getElementById('tree').innerHTML = treeElement.outerHTML;\n    </script>\n</body>\n</html>"
