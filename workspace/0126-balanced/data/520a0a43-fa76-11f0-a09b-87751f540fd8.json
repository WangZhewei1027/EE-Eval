    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Thread Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #thread {\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Thread Example</h1>\n    <div id=\"thread\"></div>\n\n    <script>\n        let thread = [];\n        let currentThread = 0;\n\n        function createThread() {\n            const threadElement = document.getElementById(\"thread\");\n            thread.push(threadElement);\n            threadElement.innerHTML = `<p>Thread ${currentThread + 1}: ${ThreadName(currentThread)}</p>`;\n            threadElement.style.display = \"block\";\n            currentThread++;\n            if (currentThread < thread.length) {\n                updateThread();\n            }\n        }\n\n        function updateThread() {\n            const threadElement = document.getElementById(\"thread\");\n            threadElement.innerHTML = \"\";\n            thread.forEach((element, index) => {\n                element.innerHTML = `<p>Thread ${index + 1}: ${ThreadName(index)}</p>`;\n            });\n        }\n\n        function ThreadName(index) {\n            switch (index) {\n                case 0:\n                    return \"Thread 0\";\n                case 1:\n                    return \"Thread 1\";\n                case 2:\n                    return \"Thread 2\";\n                default:\n                    return `Thread ${index}`;\n            }\n        }\n\n        createThread();\n    </script>\n</body>\n</html>"
