    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Linked List Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n  }\n  h1 {\n    margin-bottom: 5px;\n  }\n  #controls {\n    margin-bottom: 15px;\n  }\n  input[type=\"number\"] {\n    width: 60px;\n    padding: 4px;\n    margin-right: 8px;\n  }\n  button {\n    padding: 6px 12px;\n    margin-right: 8px;\n  }\n  #linkedList {\n    margin-top: 20px;\n    display: flex;\n    align-items: center;\n    flex-wrap: wrap;\n  }\n  .node {\n    background-color: #4a90e2;\n    color: white;\n    padding: 12px 18px;\n    border-radius: 6px;\n    margin-right: 12px;\n    position: relative;\n    font-weight: bold;\n    min-width: 40px;\n    text-align: center;\n  }\n  .node::after {\n    content: \"→\";\n    color: #666;\n    font-weight: normal;\n    position: absolute;\n    right: -18px;\n    top: 50%;\n    transform: translateY(-50%);\n    font-size: 24px;\n  }\n  .node:last-child::after {\n    content: \"null\";\n    color: #999;\n    font-weight: normal;\n    right: -38px;\n    font-size: 14px;\n  }\n  #output {\n    margin-top: 20px;\n    white-space: pre-wrap;\n    background: #f9f9f9;\n    padding: 12px;\n    border: 1px solid #ddd;\n    border-radius: 4px;\n    max-height: 180px;\n    overflow-y: auto;\n  }\n</style>\n</head>\n<body>\n<h1>Linked List Demo</h1>\n<div id=\"controls\">\n  <input type=\"number\" id=\"valueInput\" placeholder=\"Value\" />\n  <button id=\"appendBtn\">Append</button>\n  <button id=\"prependBtn\">Prepend</button>\n  <button id=\"removeHeadBtn\">Remove Head</button>\n  <button id=\"removeTailBtn\">Remove Tail</button>\n  <button id=\"clearBtn\">Clear List</button>\n</div>\n<div id=\"linkedList\" aria-label=\"Linked list visualization\"></div>\n<div id=\"output\" aria-live=\"polite\"></div>\n\n<script>\n  // Linked List Node class\n  class ListNode {\n    constructor(value) {\n      this.value = value;\n      this.next = null;\n    }\n  }\n\n  // Linked List class\n  class LinkedList {\n    constructor() {\n      this.head = null;\n      this.tail = null;\n      this.length = 0;\n    }\n\n    append(value) {\n      const newNode = new ListNode(value);\n      if (!this.head) {\n        this.head = newNode;\n        this.tail = newNode;\n      } else {\n        this.tail.next = newNode;\n        this.tail = newNode;\n      }\n      this.length++;\n    }\n\n    prepend(value) {\n      const newNode = new ListNode(value);\n      if (!this.head) {\n        this.head = newNode;\n        this.tail = newNode;\n      } else {\n        newNode.next = this.head;\n        this.head = newNode;\n      }\n      this.length++;\n    }\n\n    removeHead() {\n      if (!this.head) return null;\n      const removedValue = this.head.value;\n      this.head = this.head.next;\n      if (!this.head) this.tail = null;\n      this.length--;\n      return removedValue;\n    }\n\n    removeTail() {\n      if (!this.head) return null;\n      if (this.length === 1) {\n        const val = this.head.value;\n        this.head = null;\n        this.tail = null;\n        this.length = 0;\n        return val;\n      }\n\n      let current = this.head;\n      while (current.next !== this.tail) {\n        current = current.next;\n      }\n      const removedVal = this.tail.value;\n      current.next = null;\n      this.tail = current;\n      this.length--;\n      return removedVal;\n    }\n\n    clear() {\n      this.head = null;\n      this.tail = null;\n      this.length = 0;\n    }\n\n    values() {\n      const vals = [];\n      let current = this.head;\n      while (current) {\n        vals.push(current.value);\n        current = current.next;\n      }\n      return vals;\n    }\n  }\n\n  // UI elements\n  const listContainer = document.getElementById(\"linkedList\");\n  const output = document.getElementById(\"output\");\n  const valueInput = document.getElementById(\"valueInput\");\n  const appendBtn = document.getElementById(\"appendBtn\");\n  const prependBtn = document.getElementById(\"prependBtn\");\n  const removeHeadBtn = document.getElementById(\"removeHeadBtn\");\n  const removeTailBtn = document.getElementById(\"removeTailBtn\");\n  const clearBtn = document.getElementById(\"clearBtn\");\n\n  // Instantiate a linked list\n  const linkedList = new LinkedList();\n\n  // Function to render linked list visually\n  function renderList() {\n    listContainer.innerHTML = \"\";\n    if (!linkedList.head) {\n      listContainer.textContent = \"The list is empty.\";\n      return;\n    }\n    let current = linkedList.head;\n    while (current) {\n      const nodeDiv = document.createElement(\"div\");\n      nodeDiv.className = \"node\";\n      nodeDiv.textContent = current.value;\n      listContainer.appendChild(nodeDiv);\n      current = current.next;\n    }\n  }\n\n  // Function to write output messages\n  function writeOutput(message) {\n    output.textContent = message;\n  }\n\n  // Add event listeners\n  appendBtn.addEventListener(\"click\", () => {\n    const val = valueInput.value.trim();\n    if (val === \"\") {\n      writeOutput(\"Please enter a value to append.\");\n      return;\n    }\n    linkedList.append(val);\n    writeOutput(`Appended \"${val}\" to the list.`);\n    renderList();\n    valueInput.value = \"\";\n    valueInput.focus();\n  });\n\n  prependBtn.addEventListener(\"click\", () => {\n    const val = valueInput.value.trim();\n    if (val === \"\") {\n      writeOutput(\"Please enter a value to prepend.\");\n      return;\n    }\n    linkedList.prepend(val);\n    writeOutput(`Prepended \"${val}\" to the list.`);\n    renderList();\n    valueInput.value = \"\";\n    valueInput.focus();\n  });\n\n  removeHeadBtn.addEventListener(\"click\", () => {\n    const removed = linkedList.removeHead();\n    if (removed === null) {\n      writeOutput(\"List is empty. Nothing to remove from the head.\");\n    } else {\n      writeOutput(`Removed \"${removed}\" from the head of the list.`);\n      renderList();\n    }\n  });\n\n  removeTailBtn.addEventListener(\"click\", () => {\n    const removed = linkedList.removeTail();\n    if (removed === null) {\n      writeOutput(\"List is empty. Nothing to remove from the tail.\");\n    } else {\n      writeOutput(`Removed \"${removed}\" from the tail of the list.`);\n      renderList();\n    }\n  });\n\n  clearBtn.addEventListener(\"click\", () => {\n    linkedList.clear();\n    writeOutput(\"Cleared the entire list.\");\n    renderList();\n  });\n\n  // Initial render\n  renderList();\n  writeOutput(\"Enter a value and use buttons to modify the linked list.\");\n</script>\n</body>\n</html>"
