    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Understanding HTTPS</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            padding: 20px;\n        }\n        h1 {\n            color: #333;\n        }\n        .info {\n            background: #fff;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            padding: 15px;\n            margin: 20px 0;\n        }\n        .secure {\n            color: green;\n        }\n        .insecure {\n            color: red;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Understanding HTTPS</h1>\n<div class=\"info\">\n    <h2>What is HTTPS?</h2>\n    <p>HTTPS stands for HyperText Transfer Protocol Secure. It is an extension of HTTP and is used to secure communication over a computer network.</p>\n</div>\n\n<div class=\"info\">\n    <h2>Benefits of HTTPS</h2>\n    <ul>\n        <li>Data Encryption</li>\n        <li>Data Integrity</li>\n        <li>Authentication</li>\n        <li>Improved SEO Ranking</li>\n    </ul>\n</div>\n\n<div class=\"info\">\n    <h2>Is the connection secure?</h2>\n    <button id=\"checkHttpsBtn\">Check HTTPS Status</button>\n    <p id=\"statusMessage\"></p>\n</div>\n\n<script>\n    document.getElementById('checkHttpsBtn').addEventListener('click', function() {\n        if (window.location.protocol === 'https:') {\n            document.getElementById('statusMessage').innerHTML = 'This connection is secure! <span class=\"secure\">✔️</span>';\n        } else {\n            document.getElementById('statusMessage').innerHTML = 'This connection is NOT secure! <span class=\"insecure\">❌</span>';\n        }\n    });\n</script>\n\n</body>\n</html>"
