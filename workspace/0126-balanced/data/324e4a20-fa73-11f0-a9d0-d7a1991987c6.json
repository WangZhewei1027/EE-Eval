    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Greedy Algorithms Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n            background-color: #f4f4f4;\n        }\n        h1 {\n            text-align: center;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-top: 20px;\n        }\n        .result {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            background-color: #fff;\n        }\n        button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Greedy Algorithms Demonstration</h1>\n<div class=\"container\">\n    <button onclick=\"runGreedyAlgorithm()\">Run Coin Change Greedy Algorithm</button>\n    <div class=\"result\" id=\"result\"></div>\n</div>\n\n<script>\n    function runGreedyAlgorithm() {\n        const coins = [25, 10, 5, 1]; // Coin denominations in cents\n        const amount = 63; // Amount to make change for\n        const result = greedyCoinChange(coins, amount);\n        \n        // Display the result\n        document.getElementById('result').innerHTML = \n            `<strong>Amount:</strong> $${(amount / 100).toFixed(2)}<br>` +\n            `<strong>Coins used:</strong> ${result.coins.join(', ')}<br>` +\n            `<strong>Total coins:</strong> ${result.totalCoins}`;\n    }\n\n    function greedyCoinChange(coins, amount) {\n        const result = [];\n        let totalCoins = 0;\n        \n        for (let coin of coins) {\n            while (amount >= coin) {\n                amount -= coin;\n                result.push(coin);\n                totalCoins++;\n            }\n        }\n        \n        return {\n            coins: result,\n            totalCoins: totalCoins\n        };\n    }\n</script>\n\n</body>\n</html>"
