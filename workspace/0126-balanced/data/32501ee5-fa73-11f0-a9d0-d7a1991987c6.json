    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Encryption Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n            border: 1px solid #ccc;\n        }\n        input, button {\n            margin-top: 10px;\n        }\n        textarea {\n            width: 100%;\n            height: 100px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Simple Encryption Example</h1>\n    <label for=\"inputText\">Enter Text to Encrypt:</label>\n    <textarea id=\"inputText\" placeholder=\"Type your message here...\"></textarea>\n    \n    <button onclick=\"encryptText()\">Encrypt Text</button>\n    <button onclick=\"decryptText()\">Decrypt Text</button>\n    \n    <h2>Output:</h2>\n    <textarea id=\"outputText\" placeholder=\"Encrypted or Decrypted text will appear here...\" readonly></textarea>\n\n    <script>\n        const shift = 3; // Simple Caesar cipher shift value\n\n        function encryptText() {\n            const inputText = document.getElementById('inputText').value;\n            const encryptedText = caesarCipher(inputText, shift);\n            document.getElementById('outputText').value = encryptedText;\n        }\n\n        function decryptText() {\n            const outputText = document.getElementById('outputText').value;\n            const decryptedText = caesarCipher(outputText, -shift);\n            document.getElementById('outputText').value = decryptedText;\n        }\n\n        function caesarCipher(str, shift) {\n            return str.split('').map(char => {\n                if (char.match(/[a-z]/i)) {\n                    const code = char.charCodeAt();\n                    const base = char <= 'Z' ? 65 : 97; // base for uppercase and lowercase\n                    return String.fromCharCode(((code - base + shift) % 26 + 26) % 26 + base);\n                }\n                return char; // Return the character unchanged if it's not a letter\n            }).join('');\n        }\n    </script>\n</body>\n</html>"
