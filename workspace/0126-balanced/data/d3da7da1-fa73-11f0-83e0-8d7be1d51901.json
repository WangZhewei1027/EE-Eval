  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Software Development Life Cycle — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --muted:#9aa8bf;\n      --accent:#3b82f6;\n      --good:#10b981;\n      --warn:#f59e0b;\n      --danger:#ef4444;\n      --glass: rgba(255,255,255,0.03);\n      --phases: #1f2937;\n      color-scheme: dark;\n    }\n    *{box-sizing:border-box;font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;}\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,#071228 0%, #0b1b2b 100%);color:#e6eef8;}\n    header{padding:18px 22px;border-bottom:1px solid rgba(255,255,255,0.04);display:flex;align-items:center;gap:12px;}\n    header h1{font-size:18px;margin:0;letter-spacing:0.2px;}\n    header p{margin:0;color:var(--muted);font-size:13px;}\n    .wrap{display:grid;grid-template-columns:360px 1fr 360px;gap:18px;padding:18px;}\n    /* left column - phases list */\n    .sidebar{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));padding:14px;border-radius:10px;border:1px solid rgba(255,255,255,0.03);}\n    .phase{padding:10px;border-radius:8px;margin-bottom:10px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:transform .15s ease, box-shadow .15s ease;background:var(--glass)}\n    .phase:hover{transform:translateY(-4px);box-shadow:0 6px 18px rgba(0,0,0,0.5)}\n    .badge{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:700;}\n    .p-0{background:#0ea5a4;color:#021;}\n    .p-1{background:#3b82f6;}\n    .p-2{background:#60a5fa;}\n    .p-3{background:#7c3aed;}\n    .p-4{background:#f97316;}\n    .p-5{background:#ef4444;}\n    .p-6{background:#10b981;}\n    .phase-info{flex:1;}\n    .phase-info h3{margin:0;font-size:14px;}\n    .phase-info p{margin:0;color:var(--muted);font-size:13px}\n    .selected{outline:2px solid rgba(99,102,241,0.12);box-shadow:0 6px 18px rgba(30,41,59,0.65)}\n    .controls{display:flex;gap:8px;margin-top:12px;flex-wrap:wrap}\n    .btn{padding:8px 10px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.03);cursor:pointer;color:var(--muted);font-size:13px}\n    .btn.primary{background:linear-gradient(180deg, rgba(79,70,229,0.18), rgba(14,165,233,0.02));border:1px solid rgba(99,102,241,0.18);color:#e6eef8}\n    .btn.warn{background:linear-gradient(180deg, rgba(245,158,11,0.08), rgba(255,255,255,0.01));border:1px solid rgba(245,158,11,0.08);color:var(--muted)}\n    .small{font-size:12px;padding:6px 8px}\n    /* center - simulation area */\n    .main{display:flex;flex-direction:column;gap:12px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));padding:14px;border-radius:10px;border:1px solid rgba(255,255,255,0.03)}\n    .timeline{display:flex;gap:10px;justify-content:space-between;align-items:flex-end;padding:8px}\n    .stage{flex:1;min-height:140px;background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);border-radius:10px;padding:10px;border:1px dashed rgba(255,255,255,0.03);position:relative;overflow:hidden}\n    .stage h4{margin:0 0 8px 0;font-size:13px}\n    .stage .dropzone{min-height:70px;display:flex;flex-direction:column;gap:8px}\n    .task{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);font-size:13px;cursor:grab}\n    .task.dragging{opacity:0.4}\n    .stage-footer{position:absolute;left:10px;right:10px;bottom:8px;display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--muted)}\n    .progress{height:8px;background:rgba(255,255,255,0.04);border-radius:6px;overflow:hidden;width:120px}\n    .progress > i{display:block;height:100%;background:linear-gradient(90deg,#10b981,#3b82f6);width:0%;transition:width .6s ease}\n    .sim-controls{display:flex;gap:8px;align-items:center}\n    .toggles{display:flex;gap:8px;align-items:center}\n    .legend{display:flex;gap:8px;flex-wrap:wrap;align-items:center}\n    .dot{width:10px;height:10px;border-radius:3px}\n    /* right column - inspector and quiz */\n    .inspector{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));padding:14px;border-radius:10px;border:1px solid rgba(255,255,255,0.03)}\n    .inspector h3{margin:0 0 8px 0}\n    .artifact{background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;margin-bottom:8px}\n    .small-muted{font-size:13px;color:var(--muted)}\n    .quiz{margin-top:12px}\n    .q{background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);padding:10px;border-radius:8px;margin-bottom:10px}\n    .choice{display:block;margin:6px 0;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.03);cursor:pointer}\n    .choice.selected{outline:2px solid rgba(59,130,246,0.18);background:rgba(59,130,246,0.03)}\n    footer{padding:12px 22px;font-size:12px;color:var(--muted);display:flex;justify-content:space-between;align-items:center}\n    /* responsive */\n    @media (max-width:1000px){\n      .wrap{grid-template-columns:1fr;padding:10px}\n      .sidebar,.inspector{order:2}\n      .main{order:1}\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <div style=\"display:flex;flex-direction:column;\">\n      <h1>Software Development Life Cycle — Interactive Demo</h1>\n      <p>Explore phases, move tasks, simulate progress and learn SDLC concepts.</p>\n    </div>\n  </header>\n\n  <div class=\"wrap\">\n    <!-- Left: Phases list -->\n    <div class=\"sidebar\" aria-label=\"Phases list\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;\">\n        <div>\n          <strong>Phases</strong>\n          <div class=\"small-muted\" style=\"font-size:12px\">Click to inspect a phase.</div>\n        </div>\n        <div style=\"text-align:right\">\n          <button class=\"btn small\" id=\"addSample\">Add sample tasks</button>\n        </div>\n      </div>\n\n      <div id=\"phasesList\"></div>\n\n      <div style=\"margin-top:8px;\">\n        <div class=\"controls\">\n          <button class=\"btn primary\" id=\"startBtn\">Start simulation</button>\n          <button class=\"btn\" id=\"advanceBtn\">Advance one step</button>\n          <button class=\"btn warn\" id=\"resetBtn\">Reset</button>\n          <button class=\"btn\" id=\"toggleMode\">Mode: Waterfall</button>\n        </div>\n        <div style=\"margin-top:8px;font-size:13px;color:var(--muted)\">Simulation speed:\n          <input id=\"speed\" type=\"range\" min=\"300\" max=\"3000\" value=\"1000\" style=\"vertical-align:middle;margin-left:8px\">\n        </div>\n      </div>\n    </div>\n\n    <!-- Center: Timeline / stages -->\n    <div class=\"main\" aria-live=\"polite\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center\">\n        <div style=\"display:flex;gap:12px;align-items:center\">\n          <strong>Project Board</strong>\n          <div class=\"small-muted\">Drag tasks between phases or run automated simulation.</div>\n        </div>\n        <div class=\"sim-controls\">\n          <div class=\"legend small-muted\">\n            <div style=\"display:flex;gap:8px;align-items:center\">\n              <div class=\"dot\" style=\"background:#7c3aed\"></div><div style=\"font-size:13px\">Phase Node</div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"timeline\" id=\"timeline\">\n        <!-- stages will be injected -->\n      </div>\n\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:6px\">\n        <div class=\"small-muted\">Tasks in flight: <span id=\"inFlight\">0</span></div>\n        <div class=\"small-muted\">Iteration: <span id=\"iteration\">1</span></div>\n      </div>\n    </div>\n\n    <!-- Right: Inspector and Quiz -->\n    <aside class=\"inspector\" id=\"inspector\" aria-live=\"polite\">\n      <h3>Inspector</h3>\n      <div id=\"phaseTitle\" style=\"font-size:15px;font-weight:600\">Select a phase</div>\n      <div id=\"phaseDesc\" class=\"small-muted\" style=\"margin-top:6px\">Click a phase on the left to view definition, typical deliverables and roles.</div>\n\n      <div id=\"artifacts\" style=\"margin-top:12px\"></div>\n\n      <div style=\"margin-top:12px;border-top:1px dashed rgba(255,255,255,0.03);padding-top:12px\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <strong>Quick Quiz</strong>\n          <div class=\"small-muted\">Test your knowledge</div>\n        </div>\n\n        <div class=\"quiz\" id=\"quiz\"></div>\n      </div>\n    </aside>\n  </div>\n\n  <footer>\n    <div>Interactive SDLC demo • Click, drag and simulate to see flows</div>\n    <div class=\"small-muted\">Designed for learning — no external libraries</div>\n  </footer>\n\n  <script>\n    // SDLC phases data\n    const phasesData = [\n      { id:0, name:\"Planning\", short:\"Define scope & feasibility\", colorClass:\"p-0\",\n        desc:\"Determine project goals, scope, feasibility, stakeholders and high-level schedule.\",\n        artifacts:[\"Project charter\",\"Stakeholder analysis\",\"Feasibility study\"], roles:[\"Project Manager\",\"Business Analyst\"]},\n      { id:1, name:\"Requirements\", short:\"Gather & document requirements\", colorClass:\"p-1\",\n        desc:\"Collect and analyze user needs, functional and non-functional requirements; create specifications.\",\n        artifacts:[\"SRS (Software Requirements Specification)\",\"User stories\",\"Use cases\"], roles:[\"Business Analyst\",\"Product Owner\"]},\n      { id:2, name:\"Design\", short:\"Architect & design system\", colorClass:\"p-2\",\n        desc:\"Create high-level and detailed designs including architecture, data models and UI prototypes.\",\n        artifacts:[\"Architecture diagrams\",\"UI mockups\",\"Data models\"], roles:[\"Architect\",\"UI/UX Designer\"]},\n      { id:3, name:\"Implementation\", short:\"Write and integrate code\", colorClass:\"p-3\",\n        desc:\"Develop features, integrate components, and perform code reviews and build pipelines.\",\n        artifacts:[\"Source code\",\"Build artifacts\",\"Integration branches\"], roles:[\"Developers\",\"DevOps\"]},\n      { id:4, name:\"Testing\", short:\"Verify quality & fix defects\", colorClass:\"p-4\",\n        desc:\"Execute tests (unit, integration, system, acceptance), report defects and ensure quality.\",\n        artifacts:[\"Test plans\",\"Test reports\",\"Defect logs\"], roles:[\"QA Engineer\",\"Testers\"]},\n      { id:5, name:\"Deployment\", short:\"Release to production\", colorClass:\"p-5\",\n        desc:\"Deploy software to production or release environments, perform release checks and monitoring.\",\n        artifacts:[\"Release notes\",\"Deployment scripts\",\"Rollback plan\"], roles:[\"DevOps\",\"Release Manager\"]},\n      { id:6, name:\"Maintenance\", short:\"Operate & evolve\", colorClass:\"p-6\",\n        desc:\"Monitor, maintain, support users, and evolve the system with patches and new enhancements.\",\n        artifacts:[\"Issue tracker\",\"Patches\",\"Enhancement backlog\"], roles:[\"Support\",\"Maintenance Engineers\"]},\n    ];\n\n    // State\n    let modeIterative = false; // false -> Waterfall, true -> Iterative\n    let tasks = []; // {id, title, phaseIndex, status}\n    let running = false;\n    let simInterval = null;\n    let iteration = 1;\n\n    // DOM refs\n    const phasesListEl = document.getElementById('phasesList');\n    const inspectorTitle = document.getElementById('phaseTitle');\n    const inspectorDesc = document.getElementById('phaseDesc');\n    const artifactsEl = document.getElementById('artifacts');\n    const timelineEl = document.getElementById('timeline');\n    const startBtn = document.getElementById('startBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const advanceBtn = document.getElementById('advanceBtn');\n    const toggleModeBtn = document.getElementById('toggleMode');\n    const speedInput = document.getElementById('speed');\n    const addSampleBtn = document.getElementById('addSample');\n    const inFlightEl = document.getElementById('inFlight');\n    const iterationEl = document.getElementById('iteration');\n    const quizEl = document.getElementById('quiz');\n\n    // Initialize UI\n    function init(){\n      // phases list\n      phasesListEl.innerHTML = '';\n      phasesData.forEach(p=>{\n        const div = document.createElement('div');\n        div.className = 'phase';\n        div.dataset.id = p.id;\n        div.innerHTML = `<div class=\"badge ${p.colorClass}\">${p.name[0]}</div>\n          <div class=\"phase-info\"><h3>${p.name}</h3><p>${p.short}</p></div>`;\n        div.addEventListener('click', ()=>selectPhase(p.id));\n        phasesListEl.appendChild(div);\n      });\n\n      // timeline slots\n      timelineEl.innerHTML = '';\n      phasesData.forEach((p,i)=>{\n        const stage = document.createElement('div');\n        stage.className = 'stage';\n        stage.dataset.index = i;\n        stage.innerHTML = `<h4>${i+1}. ${p.name}</h4>\n          <div class=\"dropzone\" data-index=\"${i}\"></div>\n          <div class=\"stage-footer\">\n            <div class=\"small-muted\">Artifacts: ${p.artifacts.length}</div>\n            <div style=\"display:flex;gap:8px;align-items:center\">\n              <div class=\"progress\"><i id=\"prog-${i}\"></i></div>\n              <div class=\"small-muted\" id=\"n-${i}\">0</div>\n            </div>\n          </div>`;\n        // drop handling\n        const dz = stage.querySelector('.dropzone');\n        dz.addEventListener('dragover', ev=>{ ev.preventDefault(); dz.style.outline='2px dashed rgba(255,255,255,0.06)'; });\n        dz.addEventListener('dragleave', ev=>{ dz.style.outline='none'; });\n        dz.addEventListener('drop', ev=>{\n          ev.preventDefault(); dz.style.outline='none';\n          const tid = ev.dataTransfer.getData('text/taskid');\n          if(!tid) return;\n          moveTaskTo(parseInt(tid), parseInt(dz.dataset.index));\n        });\n        timelineEl.appendChild(stage);\n      });\n\n      selectPhase(0);\n      renderTasks();\n      buildQuiz();\n    }\n\n    function selectPhase(id){\n      // highlight in list\n      Array.from(phasesListEl.children).forEach(ch=>{\n        ch.classList.toggle('selected', parseInt(ch.dataset.id)===id);\n      });\n      const p = phasesData.find(x=>x.id===id);\n      inspectorTitle.textContent = p.name;\n      inspectorDesc.textContent = p.desc;\n      artifactsEl.innerHTML = '';\n      p.artifacts.forEach(a=>{\n        const el = document.createElement('div');\n        el.className = 'artifact';\n        el.innerHTML = `<strong>${a}</strong><div class=\"small-muted\">Typical deliverable</div>`;\n        artifactsEl.appendChild(el);\n      });\n      // roles\n      const roles = document.createElement('div');\n      roles.style.marginTop = '8px';\n      roles.innerHTML = `<div class=\"small-muted\">Typical roles:</div><div style=\"margin-top:6px\">${p.roles.join(', ')}</div>`;\n      artifactsEl.appendChild(roles);\n    }\n\n    // Task management\n    function addTask(title, phaseIndex=1){\n      const id = Date.now() + Math.floor(Math.random()*1000);\n      const t = {id, title, phaseIndex, status:'todo'};\n      tasks.push(t);\n      renderTasks();\n      return t;\n    }\n\n    function renderTasks(){\n      // clear dropzones\n      const dzones = document.querySelectorAll('.dropzone');\n      dzones.forEach(dz=>dz.innerHTML='');\n      // counts\n      const counts = Array(phasesData.length).fill(0);\n      tasks.forEach(t=>{\n        counts[t.phaseIndex]++;\n        const el = document.createElement('div');\n        el.className = 'task';\n        el.draggable = true;\n        el.id = 'task-'+t.id;\n        el.dataset.id = t.id;\n        el.innerHTML = `<div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div style=\"font-weight:600\">${t.title}</div>\n            <div style=\"font-size:12px;color:var(--muted)\">${phasesData[t.phaseIndex].name}</div>\n          </div>`;\n        el.addEventListener('dragstart', ev=>{\n          ev.dataTransfer.setData('text/taskid', t.id);\n          el.classList.add('dragging');\n        });\n        el.addEventListener('dragend', ev=>el.classList.remove('dragging'));\n        // double click to advance\n        el.addEventListener('dblclick', ()=>moveTaskTo(t.id, Math.min(t.phaseIndex+1, phasesData.length-1)));\n        const dz = document.querySelector(`.dropzone[data-index=\"${t.phaseIndex}\"]`);\n        if (dz) dz.appendChild(el);\n      });\n      // update progress bars and counts\n      counts.forEach((c,i)=>{\n        document.getElementById('n-'+i).textContent = c;\n        const total = tasks.length || 1;\n        // progress = ratio of tasks that have reached or passed this phase\n        const progressed = tasks.filter(t=>t.phaseIndex >= i).length;\n        const p = Math.round((progressed/total)*100);\n        document.getElementById('prog-'+i).style.width = p + '%';\n      });\n      inFlightEl.textContent = tasks.filter(t=>t.phaseIndex>0 && t.phaseIndex<phasesData.length-1).length;\n    }\n\n    function moveTaskTo(taskId, targetPhase){\n      const t = tasks.find(x=>x.id===taskId);\n      if(!t) return;\n      t.phaseIndex = targetPhase;\n      renderTasks();\n    }\n\n    // Simulation\n    function startSimulation(){\n      if(running) return stopSimulation();\n      running = true;\n      startBtn.textContent = 'Stop simulation';\n      startBtn.classList.toggle('primary', false);\n      runInterval();\n    }\n\n    function stopSimulation(){\n      running = false;\n      startBtn.textContent = 'Start simulation';\n      startBtn.classList.toggle('primary', true);\n      if(simInterval) { clearInterval(simInterval); simInterval=null; }\n    }\n\n    function runInterval(){\n      const delay = parseInt(speedInput.value) || 1000;\n      simInterval = setInterval(()=>advanceAllOnce(), delay);\n    }\n\n    function advanceAllOnce(){\n      // Each tick, advance each task one phase forward (respecting mode)\n      tasks.forEach(t=>{\n        if(t.phaseIndex < phasesData.length-1){\n          t.phaseIndex++;\n        } else {\n          // last phase: if iterative mode, send it back to Requirements or Planning depending on iteration\n          if(modeIterative){\n            t.phaseIndex = 1; // back to Requirements\n          }\n        }\n      });\n      // when all tasks at final phase and not iterative, stop simulation\n      const allAtEnd = tasks.every(t=>t.phaseIndex === phasesData.length-1);\n      if(allAtEnd && !modeIterative){\n        stopSimulation();\n      }\n      // increment iteration count when any task wraps back to start\n      if(modeIterative){\n        iteration++;\n        iterationEl.textContent = iteration;\n      }\n      renderTasks();\n    }\n\n    // Single step advance\n    function advanceOne(){\n      advanceAllOnce();\n    }\n\n    // Reset\n    function resetBoard(){\n      stopSimulation();\n      tasks = [];\n      iteration = 1;\n      iterationEl.textContent = iteration;\n      renderTasks();\n    }\n\n    // Mode toggle\n    function toggleMode(){\n      modeIterative = !modeIterative;\n      toggleModeBtn.textContent = 'Mode: ' + (modeIterative ? 'Iterative' : 'Waterfall');\n      toggleModeBtn.classList.toggle('primary', modeIterative);\n    }\n\n    // Add sample tasks for demo\n    function addSampleTasks(){\n      addTask('User login', 1);\n      addTask('Payment integration', 2);\n      addTask('Homepage UI', 2);\n      addTask('API endpoints', 3);\n      addTask('Acceptance tests', 4);\n      renderTasks();\n    }\n\n    // Quiz\n    const sampleQuiz = [\n      {q:\"Which SDLC phase focuses on capturing user stories and requirements?\", choices:[\"Design\",\"Requirements\",\"Testing\",\"Deployment\"], a:1},\n      {q:\"Where would you create architecture diagrams and wireframes?\", choices:[\"Planning\",\"Maintenance\",\"Design\",\"Requirements\"], a:2},\n      {q:\"Which phase typically handles bug fixes after release?\", choices:[\"Implementation\",\"Testing\",\"Maintenance\",\"Requirements\"], a:2},\n    ];\n\n    function buildQuiz(){\n      quizEl.innerHTML = '';\n      sampleQuiz.forEach((qq, idx)=>{\n        const qdiv = document.createElement('div');\n        qdiv.className = 'q';\n        qdiv.innerHTML = `<strong>${idx+1}. ${qq.q}</strong>`;\n        qq.choices.forEach((ch,i)=>{\n          const btn = document.createElement('div');\n          btn.className = 'choice';\n          btn.textContent = ch;\n          btn.addEventListener('click', ()=>selectAnswer(idx,i,btn));\n          qdiv.appendChild(btn);\n        });\n        quizEl.appendChild(qdiv);\n      });\n    }\n\n    function selectAnswer(qIndex, choiceIndex, btn){\n      const qDiv = btn.parentElement;\n      // disable all choices\n      Array.from(qDiv.querySelectorAll('.choice')).forEach(c=>c.classList.remove('selected'));\n      btn.classList.add('selected');\n      // reveal correctness\n      const correct = sampleQuiz[qIndex].a === choiceIndex;\n      if(correct){\n        btn.style.borderColor = 'rgba(16,185,129,0.18)'; btn.style.background = 'rgba(16,185,129,0.03)';\n      } else {\n        btn.style.borderColor = 'rgba(239,68,68,0.18)'; btn.style.background = 'rgba(239,68,68,0.03)';\n        // show correct\n        const choices = qDiv.querySelectorAll('.choice');\n        choices[sampleQuiz[qIndex].a].style.borderColor = 'rgba(16,185,129,0.12)';\n      }\n    }\n\n    // Wire buttons\n    startBtn.addEventListener('click', ()=>{\n      if(running) stopSimulation(); else startSimulation();\n      // ensure sim interval reflects updated speed\n      if(running){\n        if(simInterval) clearInterval(simInterval);\n        runInterval();\n      }\n    });\n    resetBtn.addEventListener('click', resetBoard);\n    advanceBtn.addEventListener('click', advanceOne);\n    toggleModeBtn.addEventListener('click', toggleMode);\n    addSampleBtn.addEventListener('click', addSampleTasks);\n    speedInput.addEventListener('input', ()=>{\n      if(running){\n        if(simInterval) clearInterval(simInterval);\n        runInterval();\n      }\n    });\n\n    // Initialize everything\n    init();\n\n    // Add some initial tasks for first view\n    addTask('Define scope', 0);\n    addTask('Interview stakeholders', 1);\n    addTask('System architecture', 2);\n    addTask('Implement auth', 3);\n    addTask('Write tests', 4);\n    addTask('Deploy v0.1', 5);\n    renderTasks();\n\n    // Helpful keyboard interactions: press SPACE to start/stop\n    window.addEventListener('keydown', (e)=>{\n      if(e.code === 'Space'){\n        e.preventDefault();\n        startBtn.click();\n      }\n    });\n\n    // Small accessibility hint\n    console.log('SDLC demo ready: drag tasks, double-click to advance, press Space to start/stop simulation.');\n  </script>\n</body>\n</html>"
  },
