    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Backpropagation Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin: 20px;\n        }\n        #output {\n            margin-top: 20px;\n        }\n        .layer {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 10px;\n        }\n        .neuron {\n            width: 50px;\n            height: 50px;\n            border: 2px solid #3498db;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            margin: 0 10px;\n            background-color: #ecf0f1;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n    <h1>Backpropagation Neural Network Demo</h1>\n    <div class=\"layer\" id=\"inputLayer\">\n        <div class=\"neuron\">x1</div>\n        <div class=\"neuron\">x2</div>\n    </div>\n    <div class=\"layer\" id=\"hiddenLayer\">\n        <div class=\"neuron\">h1</div>\n        <div class=\"neuron\">h2</div>\n    </div>\n    <div class=\"layer\" id=\"outputLayer\">\n        <div class=\"neuron\">y</div>\n    </div>\n    <button onclick=\"train()\">Train Neural Network</button>\n    <div id=\"output\"></div>\n\n    <script>\n        // Simple Example of Backpropagation\n\n        // Inputs (x1, x2)\n        const inputs = [\n            [0, 0],\n            [0, 1],\n            [1, 0],\n            [1, 1]\n        ];\n\n        // Expected output\n        const expectedOutputs = [0, 0, 0, 1]; // AND operation\n\n        // Initialize weights (hidden layer)\n        let weightsHidden = [\n            [Math.random(), Math.random()],\n            [Math.random(), Math.random()]\n        ];\n        let outputWeights = [Math.random(), Math.random()];\n\n        function sigmoid(x) {\n            return 1 / (1 + Math.exp(-x));\n        }\n\n        function sigmoidDerivative(x) {\n            return x * (1 - x);\n        }\n\n        function feedForward(input) {\n            // Hidden layer\n            let hiddenLayerOutput = weightsHidden.map(weights => \n                sigmoid(weights.reduce((sum, weight, i) => \n                    sum + weight * input[i], 0)\n                )\n            );\n\n            // Output layer\n            let output = sigmoid(hiddenLayerOutput.reduce((sum, weight, i) =>\n                sum + outputWeights[i] * weight, 0)\n            );\n\n            return { hiddenLayerOutput, output };\n        }\n\n        function train() {\n            const learningRate = 0.1;\n\n            for (let epoch = 0; epoch < 5000; epoch++) {\n                inputs.forEach((input, index) => {\n                    // Feed forward\n                    let { hiddenLayerOutput, output } = feedForward(input);\n\n                    // Calculate error\n                    let outputError = expectedOutputs[index] - output;\n\n                    // Backpropagation\n                    let outputDelta = outputError * sigmoidDerivative(output);\n\n                    // Update output weights\n                    outputWeights = outputWeights.map((w, i) => \n                        w + learningRate * outputDelta * hiddenLayerOutput[i]\n                    );\n\n                    hiddenLayerOutput.forEach((hOut, i) => {\n                        // Calculate error for hidden layer\n                        let hiddenError = outputDelta * outputWeights[i];\n                        let hiddenDelta = hiddenError * sigmoidDerivative(hOut);\n\n                        // Update hidden weights\n                        weightsHidden[i] = weightsHidden[i].map((w, j) => \n                            w + learningRate * hiddenDelta * input[j]\n                        );\n                    });\n                });\n            }\n            \n            displayResults();\n        }\n\n        function displayResults() {\n            let resultText = \"Weights after training:<br>\";\n            resultText += \"Hidden Weights:<br>\";\n            weightsHidden.forEach((weights, i) => {\n                resultText += `h${i+1}: [${weights.join(', ')}]<br>`;\n            });\n            resultText += \"Output Weights:<br>\";\n            resultText += `[${outputWeights.join(', ')}]<br>`;\n            document.getElementById(\"output\").innerHTML = resultText;\n        }\n    </script>\n</body>\n</html>"
