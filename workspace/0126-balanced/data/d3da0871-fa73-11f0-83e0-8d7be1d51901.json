  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<title>Interactive DNS Concept Demonstration</title>\n<style>\n  :root{\n    --bg:#0f1720; --card:#0b1220; --muted:#9aa7b2; --accent:#22c1c3; --accent2:#6a8cff; --glass: rgba(255,255,255,0.03);\n    --good:#16a34a; --bad:#ef4444;\n  }\n  html,body{height:100%;margin:0;font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;}\n  body{background: linear-gradient(180deg,#071029 0%, #071a2a 100%); color:#e6eef6; padding:20px; box-sizing:border-box;}\n  .wrap{max-width:1100px;margin:0 auto;}\n  header{display:flex;align-items:center;gap:16px;margin-bottom:18px;}\n  h1{font-size:20px;margin:0;color:var(--accent2);}\n  p.lead{margin:0;color:var(--muted);font-size:13px}\n  .controls{display:flex;gap:12px;margin-top:16px;flex-wrap:wrap;align-items:center;}\n  .card{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.03);\n        padding:12px;border-radius:10px;color:#dbeefd;}\n  .form-row{display:flex;gap:8px;align-items:center;}\n  input[type=\"text\"]{padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:inherit;width:260px;}\n  select{padding:8px;border-radius:8px;background:transparent;border:1px solid rgba(255,255,255,0.04);color:inherit;}\n  button{background:linear-gradient(90deg,var(--accent),var(--accent2));border:0;padding:8px 12px;border-radius:8px;color:#04202b;font-weight:600;cursor:pointer;}\n  button.ghost{background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted);font-weight:500;}\n  .layout{display:grid;grid-template-columns: 1fr 380px; gap:12px;margin-top:16px;align-items:start;}\n  .vis{height:320px;padding:14px;display:flex;flex-direction:column;gap:10px;justify-content:space-between;}\n  .network{flex:1;display:flex;align-items:center;justify-content:space-between;padding:18px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));position:relative;overflow:hidden;}\n  .node{width:150px;min-width:120px;height:80px;border-radius:10px;background:var(--glass);border:1px solid rgba(255,255,255,0.03);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:8px;text-align:center;box-shadow:0 6px 18px rgba(2,6,23,0.6);}\n  .node .title{font-weight:700;color:#e6f7ff;}\n  .node .sub{font-size:12px;color:var(--muted);}\n  .arrow{position:absolute;height:3px;background:linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.04));top:calc(50% - 1.5px);left:160px;right:220px;border-radius:3px;z-index:1;}\n  .packet{position:absolute;left:50%;transform:translateX(-50%);top:36%;background:linear-gradient(90deg,#062033,#063a4b);padding:6px 10px;border-radius:6px;border:1px solid rgba(255,255,255,0.04);font-size:12px;opacity:0;transition:all .25s ease;z-index:2;}\n  .packet.show{opacity:1;top:10%;}\n  .packet.small{font-size:11px;padding:6px;border-radius:6px;}\n  .active{box-shadow:0 12px 32px rgba(34,193,195,0.08), inset 0 0 24px rgba(255,255,255,0.02);}\n  .log{max-height:300px;overflow:auto;padding:10px;border-radius:8px;background:linear-gradient(180deg, rgba(3,8,15,0.7), rgba(3,8,15,0.5));border:1px solid rgba(255,255,255,0.02);font-family:monospace;font-size:12px;color:#bfe8ea;}\n  .log .line{padding:6px 0;border-bottom:1px dashed rgba(255,255,255,0.02);}\n  .status{display:flex;gap:8px;align-items:center;margin-top:8px;}\n  .badge{background:rgba(255,255,255,0.03);padding:6px 8px;border-radius:6px;font-size:12px;color:var(--muted);border:1px solid rgba(255,255,255,0.02);}\n  .cache{margin-top:12px;display:flex;flex-direction:column;gap:8px;}\n  .cache .entry{display:flex;justify-content:space-between;background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;font-size:13px;color:#cfeff1;border:1px solid rgba(255,255,255,0.02);}\n  .small-note{font-size:12px;color:var(--muted);margin-top:8px;}\n  .controls .muted{font-size:13px;color:var(--muted)}\n  .footer{margin-top:18px;color:var(--muted);font-size:13px}\n  .packetview{margin-top:10px;background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);font-family:monospace;font-size:12px;color:#cfeff1;}\n  .row{display:flex;gap:8px;align-items:center}\n  .toggle{display:flex;gap:6px;align-items:center}\n  .ttl{color:var(--muted);font-size:12px}\n  .pill{padding:6px 8px;border-radius:999px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.02);font-size:12px;color:var(--muted)}\n  .legend{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n  .explain{background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01));padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);font-size:13px;color:var(--muted);}\n  .linklike{color:var(--accent2);cursor:pointer;text-decoration:underline}\n  .danger{color:var(--bad)}\n  .success{color:var(--good)}\n  @media (max-width:980px){\n    .layout{grid-template-columns:1fr; }\n    .network{padding:12px;}\n    .node{min-width:100px;height:70px}\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <header>\n    <div>\n      <h1>DNS — Interactive Concept Demonstration</h1>\n      <p class=\"lead\">Explore how domain names are translated into network answers by simulating a DNS lookup step-by-step.</p>\n    </div>\n  </header>\n\n  <div class=\"controls\">\n    <div class=\"card form-row\">\n      <input id=\"domain\" type=\"text\" value=\"www.example.com\" aria-label=\"Domain to resolve\"/>\n      <select id=\"rtype\" title=\"Record type\">\n        <option value=\"A\">A (IPv4)</option>\n        <option value=\"AAAA\">AAAA (IPv6)</option>\n        <option value=\"CNAME\">CNAME (alias)</option>\n        <option value=\"MX\">MX (mail exchanger)</option>\n        <option value=\"NS\">NS (nameserver)</option>\n      </select>\n      <select id=\"mode\" title=\"Resolver mode\">\n        <option value=\"recursive\">Recursive (typical stub resolver)</option>\n        <option value=\"iterative\">Iterative (educational)</option>\n      </select>\n      <select id=\"transport\" title=\"Transport\">\n        <option value=\"udp\">UDP :53</option>\n        <option value=\"tcp\">TCP :53</option>\n        <option value=\"doh\">DoH/DoT (TLS/HTTPS)</option>\n      </select>\n      <button id=\"resolveBtn\">Resolve</button>\n      <button id=\"clearBtn\" class=\"ghost\">Clear</button>\n    </div>\n\n    <div class=\"card\" style=\"min-width:340px;\">\n      <div class=\"row\" style=\"justify-content:space-between;\">\n        <div>\n          <div class=\"pill\" id=\"resolverState\">Resolver: Cache enabled</div>\n        </div>\n        <div class=\"row\">\n          <label class=\"toggle muted\"><input id=\"stepToggle\" type=\"checkbox\" style=\"accent-color:var(--accent)\"/> Step-by-step</label>\n          <label class=\"toggle muted\"><input id=\"cacheToggle\" type=\"checkbox\" checked style=\"accent-color:var(--accent)\"/> Use cache</label>\n        </div>\n      </div>\n      <div class=\"small-note\">Tip: Try domains like \"www.example.com\", \"mail.example.com\", or \"alias-this.example.net\". The simulation uses deterministic rules to produce realistic-looking answers.</div>\n    </div>\n  </div>\n\n  <div class=\"layout\">\n    <div class=\"vis card\">\n      <div class=\"network\" id=\"network\">\n        <div class=\"node\" id=\"clientNode\" aria-hidden=\"true\">\n          <div class=\"title\">Client (stub)</div>\n          <div class=\"sub\">Queries resolver</div>\n        </div>\n\n        <div class=\"node\" id=\"resolverNode\" aria-hidden=\"true\">\n          <div class=\"title\">Caching Resolver</div>\n          <div class=\"sub\">Maintains cache, asks servers</div>\n          <div class=\"ttl\" id=\"cacheInfo\">cache: 0 entries</div>\n        </div>\n\n        <div class=\"node\" id=\"rootNode\" aria-hidden=\"true\">\n          <div class=\"title\">Root servers • “.”</div>\n          <div class=\"sub\">Returns TLD referrals</div>\n        </div>\n\n        <div class=\"node\" id=\"tldNode\" aria-hidden=\"true\">\n          <div class=\"title\" id=\"tldTitle\">TLD</div>\n          <div class=\"sub\" id=\"tldSub\">Nameservers for tld</div>\n        </div>\n\n        <div class=\"node\" id=\"authNode\" aria-hidden=\"true\">\n          <div class=\"title\" id=\"authTitle\">Authoritative</div>\n          <div class=\"sub\" id=\"authSub\">Final answers (A/AAAA/CNAME/MX)</div>\n        </div>\n\n        <div class=\"arrow\"></div>\n        <div class=\"packet\" id=\"packet\">Packet</div>\n      </div>\n\n      <div class=\"legend\">\n        <div class=\"badge\">Transport: <span id=\"transportBadge\">UDP</span></div>\n        <div class=\"badge\">Mode: <span id=\"modeBadge\">Recursive</span></div>\n        <div class=\"badge\">Step-by-step: <span id=\"stepBadge\">Off</span></div>\n        <div class=\"badge\">Cache: <span id=\"cacheBadge\">Enabled</span></div>\n      </div>\n\n      <div class=\"packetview card\" id=\"packetview\">\n        <strong>DNS Packet (simulated)</strong>\n        <div style=\"margin-top:8px;\" id=\"packetFields\">No packet yet. Click Resolve.</div>\n      </div>\n    </div>\n\n    <div>\n      <div class=\"card\" style=\"margin-bottom:12px;\">\n        <strong>Live Log</strong>\n        <div class=\"log\" id=\"log\"></div>\n        <div class=\"status\">\n          <div class=\"badge\">Last event: <span id=\"lastEvent\">—</span></div>\n          <div class=\"badge\">Response code: <span id=\"rcode\">—</span></div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <strong>Resolver Cache</strong>\n        <div id=\"cacheList\" class=\"cache\">\n          <div style=\"color:var(--muted);font-size:13px\">Cache is empty.</div>\n        </div>\n        <div style=\"margin-top:8px;\" class=\"small-note\">Entries expire by TTL. Clearing or disabling cache demonstrates repeated queries to the root/TLD.</div>\n      </div>\n\n      <div style=\"height:12px\"></div>\n\n      <div class=\"card explain\">\n        <strong>Quick notes</strong>\n        <ul style=\"margin:8px 0 0 18px;color:var(--muted)\">\n          <li>Root servers know only TLD servers. TLD servers know authoritative servers for second-level domains (example.com).</li>\n          <li>Recursive resolution: stub asks resolver, resolver does the work and returns final answer.</li>\n          <li>Iterative resolution: resolver may return referrals; this demo highlights the steps so you can watch what happens.</li>\n          <li>CNAME is an alias: an extra query resolves the canonical name.</li>\n        </ul>\n        <div style=\"margin-top:8px;color:var(--muted)\">Want to explore protocol details? Click \"Resolve\" and then watch the packet view and log to see fields like ID, flags, counts, and answers.</div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"footer\">Built for teaching: this is a simulated DNS resolver and servers. No network queries are made. Results are deterministic based on the domain string.</div>\n</div>\n\n<script>\n(function(){\n  // DOM references\n  const domainInput = document.getElementById('domain');\n  const rtypeSelect = document.getElementById('rtype');\n  const modeSelect = document.getElementById('mode');\n  const resolveBtn = document.getElementById('resolveBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const logEl = document.getElementById('log');\n  const packetEl = document.getElementById('packet');\n  const packetFields = document.getElementById('packetFields');\n  const stepToggle = document.getElementById('stepToggle');\n  const cacheToggle = document.getElementById('cacheToggle');\n  const resolverNode = document.getElementById('resolverNode');\n  const rootNode = document.getElementById('rootNode');\n  const tldNode = document.getElementById('tldNode');\n  const authNode = document.getElementById('authNode');\n  const tldTitle = document.getElementById('tldTitle');\n  const tldSub = document.getElementById('tldSub');\n  const authTitle = document.getElementById('authTitle');\n  const authSub = document.getElementById('authSub');\n  const cacheList = document.getElementById('cacheList');\n  const cacheInfo = document.getElementById('cacheInfo');\n  const transportBadge = document.getElementById('transportBadge');\n  const modeBadge = document.getElementById('modeBadge');\n  const stepBadge = document.getElementById('stepBadge');\n  const cacheBadge = document.getElementById('cacheBadge');\n  const resolverState = document.getElementById('resolverState');\n  const rcodeEl = document.getElementById('rcode');\n  const lastEvent = document.getElementById('lastEvent');\n\n  // Simulation state\n  let cacheEnabled = true;\n  let cache = {}; // key: domain|rtype -> {answer, expiresAt, ttl}\n  let interval = null;\n\n  // Known TLDs mapping (simulated)\n  const TLD_HINTS = {\n    \"com\":\"ns1.com-servers.sim\", \"net\":\"ns1.net-servers.sim\", \"org\":\"ns1.org-servers.sim\",\n    \"edu\":\"ns1.edu-servers.sim\", \"io\":\"ns1.io-servers.sim\", \"local\":\"ns1.local\"\n  };\n\n  // Utility: simple hash to deterministic numbers\n  function hashString(s){\n    let h=5381;\n    for(let i=0;i<s.length;i++) h = ((h<<5)+h) + s.charCodeAt(i);\n    return h >>> 0;\n  }\n\n  function makeIPv4FromDomain(domain){\n    const h = hashString(domain);\n    const a = 10 + (h & 0x3f);\n    const b = 0 + ((h>>6) & 0xff);\n    const c = 0 + ((h>>14) & 0xff);\n    const d = 1 + ((h>>22) & 0xfe);\n    return `${a}.${b}.${c}.${d}`;\n  }\n\n  function makeIPv6FromDomain(domain){\n    const h = hashString(domain).toString(16).padStart(8,'0');\n    // make a simple fdb8::/32-like address\n    return `fd${h.slice(0,2)}:${h.slice(2,6)}:${h.slice(6,8)}::1`;\n  }\n\n  // Deterministic \"zone\" answer generation for authoritative server\n  function generateAuthoritativeAnswers(domain){\n    // If domain's first label is \"www\", show CNAME to apex then A for apex.\n    // If domain contains \"alias\" return CNAME to \"target.example.com\"\n    // Always include NS records for zone, and sometimes MX\n    const parts = domain.toLowerCase().split('.');\n    const tld = parts[parts.length-1] || '';\n    const sld = parts.slice(-2,-1)[0] || '';\n    const apex = parts.slice(-2).join('.') || domain;\n    const answers = {A:[], AAAA:[], CNAME:[], MX:[], NS:[]};\n\n    // Nameservers for the zone (simulated)\n    answers.NS.push(`ns1.${apex}`, `ns2.${apex}`);\n\n    // MX present for domains with 'mail' or 'mx' or randomly by hash\n    const h = hashString(domain);\n    if(domain.includes('mail') || (h % 3 === 0)){\n      answers.MX.push({preference:10, exchange:`mail.${apex}`});\n      answers.MX.push({preference:20, exchange:`backup.${apex}`});\n    }\n\n    // CNAME rules\n    if(parts[0] === 'www' && parts.length > 2){\n      // www.foo.example.com -> CNAME to foo.example.com\n      const target = parts.slice(1).join('.');\n      answers.CNAME.push(target);\n      // authoritative server would also have A for the target\n      answers.A.push(makeIPv4FromDomain(target));\n      answers.AAAA.push(makeIPv6FromDomain(target));\n    } else if(domain.includes('alias')){\n      const target = `target.${apex}`;\n      answers.CNAME.push(target);\n      answers.A.push(makeIPv4FromDomain(target));\n    } else {\n      // Provide direct A/AAAA for the requested name\n      answers.A.push(makeIPv4FromDomain(domain));\n      answers.AAAA.push(makeIPv6FromDomain(domain));\n    }\n\n    return answers;\n  }\n\n  // Logging helpers\n  function appendLog(text, meta){\n    const el = document.createElement('div');\n    el.className = 'line';\n    const time = new Date().toLocaleTimeString();\n    el.textContent = `[${time}] ${text}`;\n    if(meta){\n      const m = document.createElement('div');\n      m.style.fontSize = '11px';\n      m.style.color = 'var(--muted)';\n      m.textContent = `   → ${JSON.stringify(meta)}`;\n      el.appendChild(m);\n    }\n    logEl.insertBefore(el, logEl.firstChild);\n    lastEvent.textContent = text;\n  }\n\n  // Packet builder (simulated)\n  function buildPacket(domain, qtype, id, flags){\n    // flags object: {qr, rd, ra, aa, rcode}\n    return {\n      id: id || (Math.floor(Math.random()*65535)),\n      flags: Object.assign({qr:0, rd:1, ra:0, aa:0, tc:0}, flags || {}),\n      qdcount:1,\n      ancount:0,\n      nscount:0,\n      arcount:0,\n      question: {name:domain, type:qtype},\n      answers: []\n    };\n  }\n\n  function showPacketView(pkt){\n    const f = pkt.flags;\n    const rcode = pkt.rcode || 0;\n    packetFields.innerHTML = `\n      ID: ${pkt.id} &nbsp;&nbsp; Flags: QR=${f.qr} RD=${f.rd} RA=${f.ra} AA=${f.aa} TC=${f.tc}  RCODE=${rcode}<br/>\n      Q: ${pkt.question.name} (${pkt.question.type}) &nbsp;&nbsp; ANCOUNT: ${pkt.answers.length} <br/>\n      Answers: ${pkt.answers.length ? JSON.stringify(pkt.answers, null, 2) : '(none)'}\n    `;\n  }\n\n  // Cache management\n  function setCache(key, record){\n    cache[key] = record;\n    updateCacheUI();\n  }\n  function getCache(key){\n    const r = cache[key];\n    if(!r) return null;\n    if(Date.now() > r.expiresAt){\n      // expired\n      delete cache[key];\n      updateCacheUI();\n      return null;\n    }\n    return r;\n  }\n  function clearCache(){\n    cache = {};\n    updateCacheUI();\n  }\n\n  function updateCacheUI(){\n    const keys = Object.keys(cache);\n    cacheInfo.textContent = `cache: ${keys.length} entr${keys.length===1?'y':'ies'}`;\n    cacheList.innerHTML = '';\n    if(!keys.length){\n      cacheList.innerHTML = '<div style=\"color:var(--muted);font-size:13px\">Cache is empty.</div>';\n      return;\n    }\n    keys.forEach(k=>{\n      const e = cache[k];\n      const div = document.createElement('div');\n      div.className = 'entry';\n      const left = document.createElement('div');\n      left.innerHTML = `<strong>${e.name}</strong> <div style=\"font-size:12px;color:var(--muted)\">${e.type}</div>`;\n      const right = document.createElement('div');\n      const ttl = Math.max(0, Math.round((e.expiresAt - Date.now())/1000));\n      right.innerHTML = `<div style=\"text-align:right\">${e.answer.slice(0,2).join(', ')} ${e.answer.length>2? '…':''}</div><div style=\"font-size:12px;color:var(--muted)\">TTL ${ttl}s</div>`;\n      div.appendChild(left); div.appendChild(right);\n      cacheList.appendChild(div);\n    });\n  }\n\n  // Periodic TTL update\n  function startInterval(){\n    if(interval) return;\n    interval = setInterval(()=>updateCacheUI(), 1000);\n  }\n  startInterval();\n\n  // Visual helpers\n  function blinkNode(node, ms=700){\n    node.classList.add('active');\n    setTimeout(()=>node.classList.remove('active'), ms);\n  }\n\n  function showPacket(text){\n    packetEl.textContent = text;\n    packetEl.classList.add('show');\n    setTimeout(()=>packetEl.classList.remove('show'), 1200);\n  }\n\n  // Resolution simulation workflow\n  async function simulateResolution(domain, qtype, opts){\n    const mode = opts.mode; // recursive or iterative\n    const transport = opts.transport;\n    const step = opts.step;\n    const useCache = opts.cache;\n\n    // UI badges\n    transportBadge.textContent = transport.toUpperCase();\n    modeBadge.textContent = mode === 'recursive' ? 'Recursive' : 'Iterative';\n    stepBadge.textContent = step ? 'On' : 'Off';\n    cacheBadge.textContent = useCache ? 'Enabled' : 'Disabled';\n    resolverState.textContent = `Resolver: Cache ${useCache ? 'enabled' : 'disabled'}`;\n\n    appendLog(`Starting ${mode} lookup for ${domain} (type ${qtype})`, {transport});\n\n    // Check cache first (resolver cache)\n    const cacheKey = `${domain}|${qtype}`;\n    if(useCache){\n      const cached = getCache(cacheKey);\n      if(cached){\n        appendLog(`Cache HIT at resolver for ${domain} ${qtype}`, {ttl: Math.max(0,Math.round((cached.expiresAt-Date.now())/1000))});\n        rcodeEl.textContent = 'NOERROR (cached)';\n        // Show final packet\n        const pkt = buildPacket(domain, qtype, 0, {qr:1, rd:1, ra:1, aa:0});\n        pkt.answers = cached.answer.map(a => typeof a === 'object' ? a : {name:domain, type:qtype, data:a});\n        pkt.ancount = pkt.answers.length;\n        showPacketView(pkt);\n        return;\n      } else {\n        appendLog(`No cache entry at resolver for ${domain} ${qtype}`);\n      }\n    }\n\n    // Step-by-step helper\n    async function maybeStep(note){\n      appendLog(note);\n      if(step){\n        showPacket(note);\n        await waitForNext();\n      }\n    }\n\n    // Interactive step control: returns a promise that resolves when user clicks next or after small delay if step disabled\n    let nextResolver = null;\n    function waitForNext(){\n      return new Promise(resolve=>{\n        if(!step) return setTimeout(resolve, 700);\n        // show a small floating \"Next\" button overlay\n        const btn = document.createElement('button');\n        btn.textContent = 'Next';\n        btn.style.position = 'fixed';\n        btn.style.right = '20px';\n        btn.style.bottom = '20px';\n        btn.style.zIndex = 9999;\n        btn.style.padding='10px 14px';\n        btn.style.borderRadius='8px';\n        document.body.appendChild(btn);\n        function cleanup(){\n          btn.removeEventListener('click', onClick);\n          document.body.removeChild(btn);\n        }\n        function onClick(){\n          cleanup();\n          resolve();\n        }\n        btn.addEventListener('click', onClick);\n      });\n    }\n\n    // Simulation of contacting servers:\n    // For recursive mode: client -> resolver -> root -> tld -> authoritative, final answer back to client.\n    // For iterative: resolver does similar steps but we show referrals between servers and resolver.\n    // We will highlight nodes and add packet logs.\n\n    // client -> resolver\n    await maybeStep('Client sends query to resolver (RD=1)');\n    blinkNode(document.getElementById('clientNode'));\n    blinkNode(resolverNode);\n    showPacket(`Query: ${domain} (${qtype})`);\n    appendLog(`Client -> Resolver: Q=${domain} (${qtype})`, {flags:'RD=1', transport});\n    await sleep(350);\n\n    // resolver checks cache for referrals (we already did top-level)\n    // resolver -> root\n    await maybeStep('Resolver queries root servers for TLD referral');\n    blinkNode(resolverNode);\n    blinkNode(rootNode);\n    showPacket('Query to Root (.)');\n    appendLog('Resolver -> Root: who is responsible for TLD?', {question:getTLD(domain)});\n    await sleep(700);\n\n    // Root responds with referral to TLD servers or NXDOMAIN if unknown TLD\n    const tld = getTLD(domain);\n    if(!tld || !TLD_HINTS[tld]){\n      appendLog(`Root: NXDOMAIN (unknown TLD)`, {tld});\n      rcodeEl.textContent = 'NXDOMAIN';\n      showPacketView(buildPacket(domain, qtype, 0, {qr:1, rd:1, ra:1, aa:0}));\n      return;\n    }\n\n    const tldServer = TLD_HINTS[tld];\n    tldTitle.textContent = `TLD: .${tld}`;\n    tldSub.textContent = `ns: ${tldServer}`;\n    appendLog(`Root -> Resolver: Referral to TLD servers for .${tld}`, {server:tldServer});\n    await sleep(500);\n\n    // resolver -> TLD server\n    await maybeStep('Resolver queries the TLD server for the domain\\'s authoritative nameserver');\n    blinkNode(resolverNode); blinkNode(tldNode);\n    showPacket(`Query to TLD (.${tld})`);\n    appendLog(`Resolver -> TLD (.${tld}): WHO is authoritative for ${domain}?`, {server:tldServer});\n    await sleep(700);\n\n    // TLD server returns NS records for the zone (simulated)\n    const zone = domain.split('.').slice(-2).join('.');\n    const authNS = `ns1.${zone}`;\n    authTitle.textContent = `Authoritative for ${zone}`;\n    authSub.textContent = `ns: ${authNS}`;\n    appendLog(`TLD -> Resolver: Referral to authoritative server ${authNS}`, {zone});\n    await sleep(500);\n\n    // resolver -> authoritative\n    await maybeStep('Resolver queries authoritative server for the final answer');\n    blinkNode(resolverNode); blinkNode(authNode);\n    showPacket(`Query to ${authNS}`);\n    appendLog(`Resolver -> Authoritative (${authNS}): Q=${domain} (${qtype})`);\n    await sleep(900);\n\n    // Authoritative server determines answers\n    const answers = generateAuthoritativeAnswers(domain);\n    appendLog(`Authoritative (${authNS}) -> Resolver: answers generated`, {answersPreview:previewAnswers(answers)});\n    await sleep(400);\n\n    // Compose response according to requested qtype:\n    let responseList = [];\n    if(qtype === 'A') responseList = answers.A.map(v=>({name:domain,type:'A',data:v}));\n    else if(qtype === 'AAAA') responseList = answers.AAAA.map(v=>({name:domain,type:'AAAA',data:v}));\n    else if(qtype === 'CNAME') responseList = answers.CNAME.map(v=>({name:domain,type:'CNAME',data:v}));\n    else if(qtype === 'MX') responseList = answers.MX.map(v=>({name:domain,type:'MX',data:v.exchange, pref:v.preference}));\n    else if(qtype === 'NS') responseList = answers.NS.map(v=>({name:domain,type:'NS',data:v}));\n\n    // If there is a CNAME and client requested A, authoritative might include CNAME + A for target (additional)\n    if(qtype === 'A' && answers.CNAME.length){\n      // include CNAME then A for target (simulate)\n      const target = answers.CNAME[0];\n      responseList.unshift({name:domain,type:'CNAME',data:target});\n      responseList.push({name:target,type:'A',data:makeIPv4FromDomain(target)});\n    }\n\n    // If no answer available, return NXDOMAIN\n    if(responseList.length === 0){\n      appendLog('Authoritative -> Resolver: NO ERROR but no data (empty answer) or NXDOMAIN', {});\n      rcodeEl.textContent = 'NOERROR (no data)';\n      // Build packet view\n      const pktNo = buildPacket(domain, qtype, 0, {qr:1, rd:1, ra:1});\n      showPacketView(pktNo);\n      // Optionally cache negative result (not implemented here)\n      return;\n    }\n\n    // Cache the answer at resolver if cache is enabled\n    const ttlSeconds = 300 + (hashString(domain) % 300); // deterministic TTL 300-599\n    if(useCache){\n      setCache(cacheKey, {name:domain, type:qtype, answer: responseList.map(a=>a.data), ttl:ttlSeconds, expiresAt: Date.now() + ttlSeconds*1000});\n      appendLog(`Resolver caches answer for ${domain} ${qtype} (TTL ${ttlSeconds}s)`);\n    }\n\n    // Return to client\n    await maybeStep('Resolver returns final answer to client');\n    blinkNode(resolverNode); blinkNode(document.getElementById('clientNode'));\n    appendLog('Resolver -> Client: Final answer', {answerPreview: responseList.slice(0,2)});\n    rcodeEl.textContent = 'NOERROR';\n    const finalPkt = buildPacket(domain, qtype, 0, {qr:1, rd:1, ra:1, aa:1});\n    finalPkt.answers = responseList;\n    finalPkt.ancount = responseList.length;\n    showPacketView(finalPkt);\n  }\n\n  function previewAnswers(answers){\n    // returns a short preview object\n    const p = {};\n    Object.keys(answers).forEach(k=>{\n      if(answers[k] && answers[k].length) p[k] = answers[k].slice(0,2);\n    });\n    return p;\n  }\n\n  function getTLD(domain){\n    if(!domain) return null;\n    const parts = domain.split('.');\n    return parts.length>1 ? parts[parts.length-1].toLowerCase() : null;\n  }\n\n  // UI actions\n  resolveBtn.addEventListener('click', async ()=>{\n    const domain = domainInput.value.trim();\n    if(!domain){\n      appendLog('Please enter a domain name');\n      return;\n    }\n    const qtype = rtypeSelect.value;\n    const opts = {\n      mode: modeSelect.value,\n      transport: document.getElementById('transport').value,\n      step: stepToggle.checked,\n      cache: cacheToggle.checked\n    };\n    try {\n      await simulateResolution(domain, qtype, opts);\n    } catch(e){\n      appendLog('Error during simulation: ' + String(e));\n    }\n  });\n\n  clearBtn.addEventListener('click', ()=>{\n    logEl.innerHTML = '';\n    packetFields.innerHTML = 'No packet yet. Click Resolve.';\n    rcodeEl.textContent = '—';\n  });\n\n  cacheToggle.addEventListener('change', ()=>{\n    cacheEnabled = cacheToggle.checked;\n    cacheBadge.textContent = cacheEnabled ? 'Enabled' : 'Disabled';\n    resolverState.textContent = `Resolver: Cache ${cacheEnabled ? 'enabled' : 'disabled'}`;\n  });\n\n  // utility sleep\n  function sleep(ms){ return new Promise(resolve=>setTimeout(resolve, ms)); }\n\n  // Initialize some visible defaults\n  updateCacheUI();\n  appendLog('Simulation ready. Enter a domain and click Resolve.');\n  // Pre-populate some sample lines\n  appendLog('Example: try \"www.example.com\" or \"mail.example.net\" or \"alias-some.example.com\"');\n\n  // Expose a console-like debug interface in case of step mode\n  window._dnsSim = {cache, clearCache};\n})();\n</script>\n</body>\n</html>"
