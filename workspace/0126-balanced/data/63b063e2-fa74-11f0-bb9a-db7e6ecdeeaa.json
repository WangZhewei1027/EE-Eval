    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Search Tree (BST) Visualization & Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 0;\n    padding: 1rem;\n    background: #f5f7fa;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #container {\n    max-width: 900px;\n    margin: 0 auto;\n  }\n  #controls {\n    margin-bottom: 1rem;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 1rem;\n    align-items: center;\n  }\n  input[type=\"number\"] {\n    width: 100px;\n    padding: 0.3rem;\n    font-size: 1rem;\n  }\n  button {\n    padding: 0.4rem 0.8rem;\n    font-size: 1rem;\n    cursor: pointer;\n    border: none;\n    border-radius: 3px;\n    background: #007bff;\n    color: white;\n    transition: background-color 0.2s ease;\n  }\n  button:hover:not(:disabled) {\n    background: #0056b3;\n  }\n  button:disabled {\n    background: #cccccc;\n    cursor: not-allowed;\n  }\n  #info {\n    margin-top: 1rem;\n    line-height: 1.4;\n  }\n  svg {\n    background: white;\n    border: 1px solid #ccc;\n    border-radius: 5px;\n    width: 100%;\n    height: 480px;\n    user-select: none;\n  }\n  .node circle {\n    fill: #4d90fe;\n    stroke: #2f68d2;\n    stroke-width: 2px;\n    transition: fill 0.3s;\n  }\n  .node.highlight circle {\n    fill: #f5a623;\n  }\n  .node text {\n    fill: white;\n    font-weight: bold;\n    font-size: 14px;\n    pointer-events: none;\n  }\n  .edge path {\n    stroke: #666;\n    stroke-width: 2px;\n    fill: none;\n  }\n</style>\n</head>\n<body>\n<div id=\"container\">\n  <h1>Binary Search Tree (BST) Demo & Visualization</h1>\n  <div id=\"controls\">\n    <input type=\"number\" id=\"valueInput\" placeholder=\"Enter value\" />\n    <button id=\"insertBtn\">Insert</button>\n    <button id=\"deleteBtn\">Delete</button>\n    <button id=\"searchBtn\">Search</button>\n    <button id=\"resetBtn\" title=\"Clear the tree\">Reset</button>\n  </div>\n  <svg id=\"bstSvg\" viewBox=\"0 0 900 480\" ></svg>\n  <div id=\"info\">\n    <p><strong>Instructions:</strong> Enter an integer and press Insert to add it to the BST. You can also Delete or Search for values. The tree will be visualized below, highlighting searched nodes. The BST invariant means:\n    <br> - Left subtree nodes contain smaller values,\n    <br> - Right subtree nodes contain larger values.\n    <br> Duplicate values are not allowed.</p>\n  </div>\n</div>\n\n<script>\n(() => {\n  // BST Node class\n  class Node {\n    constructor(value) {\n      this.value = value;\n      this.left = null;\n      this.right = null;\n    }\n  }\n\n  // BST class\n  class BST {\n    constructor() {\n      this.root = null;\n    }\n\n    insert(value) {\n      if (this.root === null) {\n        this.root = new Node(value);\n        return true;\n      }\n      return this._insertNode(this.root, value);\n    }\n\n    _insertNode(node, value) {\n      if (value === node.value) {\n        return false; // duplicate not allowed\n      } else if (value < node.value) {\n        if (node.left === null) {\n          node.left = new Node(value);\n          return true;\n        } else {\n          return this._insertNode(node.left, value);\n        }\n      } else {\n        if (node.right === null) {\n          node.right = new Node(value);\n          return true;\n        } else {\n          return this._insertNode(node.right, value);\n        }\n      }\n    }\n\n    search(value) {\n      return this._searchNode(this.root, value);\n    }\n\n    _searchNode(node, value) {\n      if (node === null) return null;\n      if (value === node.value) return node;\n      if (value < node.value) return this._searchNode(node.left, value);\n      else return this._searchNode(node.right, value);\n    }\n\n    // Returns the new root after deletion, and if deleted\n    remove(value) {\n      const result = this._removeNode(this.root, value);\n      if (result.deleted) this.root = result.node;\n      return result.deleted;\n    }\n\n    _removeNode(node, value) {\n      if (node === null) return { node: null, deleted: false };\n\n      if (value < node.value) {\n        const res = this._removeNode(node.left, value);\n        node.left = res.node;\n        return { node, deleted: res.deleted };\n      } else if (value > node.value) {\n        const res = this._removeNode(node.right, value);\n        node.right = res.node;\n        return { node, deleted: res.deleted };\n      } else {\n        // node.value === value, delete this node\n        // Case 1: no children\n        if (node.left === null && node.right === null) {\n          return { node: null, deleted: true };\n        }\n        // Case 2: one child\n        if (node.left === null) {\n          return { node: node.right, deleted: true };\n        }\n        if (node.right === null) {\n          return { node: node.left, deleted: true };\n        }\n        // Case 3: two children — find smallest in right subtree\n        let smallestValue = this._minValue(node.right);\n        node.value = smallestValue;\n        const res = this._removeNode(node.right, smallestValue);\n        node.right = res.node;\n        return { node, deleted: true };\n      }\n    }\n\n    _minValue(node) {\n      while (node.left !== null) {\n        node = node.left;\n      }\n      return node.value;\n    }\n  }\n\n  // Visualization & UI part\n  const svg = document.getElementById(\"bstSvg\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const deleteBtn = document.getElementById(\"deleteBtn\");\n  const searchBtn = document.getElementById(\"searchBtn\");\n  const resetBtn = document.getElementById(\"resetBtn\");\n  const valueInput = document.getElementById(\"valueInput\");\n\n  const bst = new BST();\n\n  // layout parameters\n  const nodeRadius = 18;\n  const verticalSpacing = 70;\n  const svgWidth = 900;\n  const svgHeight = 480;\n\n  function clearSvg() {\n    while (svg.firstChild) {\n      svg.removeChild(svg.firstChild);\n    }\n  }\n\n  // Calculate x positions in order to visualize BST nicely.\n  // We'll do an in-order traversal for horizontal positioning,\n  // and vertical positioning based on depth.\n  function layoutTree(root) {\n    let positions = new Map(); // node -> {x, y}\n    let xCounter = 0;\n\n    function inOrder(node, depth) {\n      if (!node) return;\n      inOrder(node.left, depth + 1);\n      positions.set(node, { x: xCounter, y: depth });\n      xCounter++;\n      inOrder(node.right, depth + 1);\n    }\n    inOrder(root, 0);\n    return positions;\n  }\n\n  function drawLine(x1, y1, x2, y2) {\n    const path = document.createElementNS(\"http://www.w3.org/2000/svg\", \"path\");\n    // Make a path from parent to child with a smooth curve\n    const midX = (x1 + x2) / 2;\n    const d = `M${x1},${y1} C${midX},${y1} ${midX},${y2} ${x2},${y2}`;\n    path.setAttribute(\"d\", d);\n    path.setAttribute(\"stroke\", \"#666\");\n    path.setAttribute(\"stroke-width\", \"2\");\n    path.setAttribute(\"fill\", \"none\");\n    path.classList.add(\"edge\");\n    svg.appendChild(path);\n  }\n\n  function drawNode(x, y, value, highlight = false) {\n    const g = document.createElementNS(\"http://www.w3.org/2000/svg\", \"g\");\n    g.classList.add(\"node\");\n    if (highlight) g.classList.add(\"highlight\");\n\n    const circle = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n    circle.setAttribute(\"cx\", x);\n    circle.setAttribute(\"cy\", y);\n    circle.setAttribute(\"r\", nodeRadius);\n    circle.setAttribute(\"stroke\", \"#2f68d2\");\n    circle.setAttribute(\"stroke-width\", 2);\n    circle.setAttribute(\"fill\", highlight ? \"#f5a623\" : \"#4d90fe\");\n    g.appendChild(circle);\n\n    const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n    text.setAttribute(\"x\", x);\n    text.setAttribute(\"y\", y + 5);\n    text.setAttribute(\"text-anchor\", \"middle\");\n    text.setAttribute(\"fill\", \"white\");\n    text.setAttribute(\"font-weight\", \"bold\");\n    text.setAttribute(\"font-size\", \"14px\");\n    text.textContent = value;\n    g.appendChild(text);\n\n    svg.appendChild(g);\n  }\n\n  // Re-draw the whole tree\n  function renderTree(searchValue = null) {\n    clearSvg();\n    if (!bst.root) return;\n\n    // Get positions (xCounter increments per node in-order)\n    const positionsMap = layoutTree(bst.root);\n    // We want to spread nodes horizontally across svgWidth\n    const totalNodes = positionsMap.size;\n    const xSpacing = svgWidth / (totalNodes + 1);\n\n    // Build an array of nodes with positions for SVG connections\n    // We'll also keep a map from node to screen coords\n    const nodeCoords = new Map();\n    for (const [node, pos] of positionsMap.entries()) {\n      const x = (pos.x + 1) * xSpacing;\n      const y = (pos.y + 1) * verticalSpacing;\n      nodeCoords.set(node, { x, y });\n    }\n\n    // Draw edges first for layering underneath nodes\n    function drawEdges(node) {\n      if (!node) return;\n      if (node.left) {\n        const p1 = nodeCoords.get(node);\n        const p2 = nodeCoords.get(node.left);\n        drawLine(p1.x, p1.y + nodeRadius, p2.x, p2.y - nodeRadius);\n        drawEdges(node.left);\n      }\n      if (node.right) {\n        const p1 = nodeCoords.get(node);\n        const p2 = nodeCoords.get(node.right);\n        drawLine(p1.x, p1.y + nodeRadius, p2.x, p2.y - nodeRadius);\n        drawEdges(node.right);\n      }\n    }\n    drawEdges(bst.root);\n\n    // Draw nodes on top of edges and highlight search result\n    function drawAllNodes(node) {\n      if (!node) return;\n      const coord = nodeCoords.get(node);\n      const highlight = node.value === searchValue;\n      drawNode(coord.x, coord.y, node.value, highlight);\n      drawAllNodes(node.left);\n      drawAllNodes(node.right);\n    }\n    drawAllNodes(bst.root);\n  }\n\n  function getInputValue() {\n    const val = valueInput.value.trim();\n    if (val === \"\") return null;\n    const num = parseInt(val, 10);\n    if (isNaN(num)) return null;\n    return num;\n  }\n\n  insertBtn.addEventListener(\"click\", () => {\n    const value = getInputValue();\n    if (value === null) {\n      alert(\"Please enter a valid integer.\");\n      return;\n    }\n    const success = bst.insert(value);\n    if (!success) {\n      alert(\"Value already exists in the BST. No duplicates allowed.\");\n    }\n    valueInput.value = \"\";\n    renderTree();\n  });\n\n  deleteBtn.addEventListener(\"click\", () => {\n    const value = getInputValue();\n    if (value === null) {\n      alert(\"Please enter a valid integer.\");\n      return;\n    }\n    const deleted = bst.remove(value);\n    if (!deleted) {\n      alert(\"Value not found in the BST.\");\n    }\n    valueInput.value = \"\";\n    renderTree();\n  });\n\n  searchBtn.addEventListener(\"click\", () => {\n    const value = getInputValue();\n    if (value === null) {\n      alert(\"Please enter a valid integer.\");\n      return;\n    }\n    const foundNode = bst.search(value);\n    if (foundNode) {\n      renderTree(value);\n    } else {\n      alert(\"Value not found in the BST.\");\n      renderTree();\n    }\n  });\n\n  resetBtn.addEventListener(\"click\", () => {\n    bst.root = null;\n    valueInput.value = \"\";\n    clearSvg();\n  });\n\n  // Optional: allow pressing Enter key to trigger Insert\n  valueInput.addEventListener(\"keydown\", (e) => {\n    if (e.key === \"Enter\") {\n      insertBtn.click();\n    }\n  });\n\n  // Initial tree example (optional)\n  function initialInsert(values) {\n    for (const v of values) {\n      bst.insert(v);\n    }\n    renderTree();\n  }\n\n  initialInsert([50, 30, 70, 20, 40, 60, 80]);\n})();\n</script>\n</body>\n</html>"
  },
