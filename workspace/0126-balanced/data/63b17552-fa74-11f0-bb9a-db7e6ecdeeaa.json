    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Breadth-First Search (BFS) Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f2f5;\n  }\n  h1 {\n    text-align: center;\n  }\n  #graph {\n    margin: 20px auto;\n    width: 600px;\n    height: 400px;\n    border: 2px solid #444;\n    background: #fff;\n    position: relative;\n    border-radius: 8px;\n  }\n  .node {\n    position: absolute;\n    width: 40px;\n    height: 40px;\n    background: #89CFF0;\n    border-radius: 50%;\n    border: 2px solid #2176FF;\n    line-height: 40px;\n    text-align: center;\n    font-weight: bold;\n    color: #034078;\n    user-select: none;\n    transition: background-color 0.3s, border-color 0.3s;\n    z-index: 2;\n  }\n  .node.visited {\n    background: #ffb347;\n    border-color: #ff6f00;\n    color: #4a2700;\n  }\n  .node.current {\n    background: #00c176;\n    border-color: #007737;\n    color: white;\n    font-weight: 900;\n  }\n  svg {\n    position: absolute;\n    left: 0;\n    top: 0;\n    pointer-events: none;\n    z-index: 1;\n  }\n  #controls {\n    width: 600px;\n    margin: 0 auto 20px auto;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n  }\n  #startNode {\n    font-weight: bold;\n    width: 50px;\n    padding: 5px;\n  }\n  button {\n    background-color: #2176FF;\n    border: none;\n    color: white;\n    padding: 10px 15px;\n    font-size: 16px;\n    border-radius: 5px;\n    cursor: pointer;\n    user-select: none;\n    transition: background-color 0.25s ease;\n  }\n  button:hover:not(:disabled) {\n    background-color: #0141a9;\n  }\n  button:disabled {\n    background-color: #a0aec0;\n    cursor: default;\n  }\n  #log {\n    width: 600px;\n    margin: 0 auto;\n    height: 140px;\n    background: white;\n    border: 2px solid #444;\n    border-radius: 8px;\n    overflow-y: auto;\n    padding: 10px;\n    font-family: \"Courier New\", Courier, monospace;\n    font-size: 14px;\n    box-sizing: border-box;\n  }\n  #log .step {\n    margin-bottom: 8px;\n  }\n  #footer {\n    margin-top: 40px;\n    font-size: 0.9em;\n    color: #666;\n    text-align: center;\n    font-style: italic;\n  }\n</style>\n</head>\n<body>\n<h1>Breadth-First Search (BFS) Visualization</h1>\n<div id=\"controls\">\n  <label for=\"startNode\">Start Node: </label>\n  <select id=\"startNode\" aria-label=\"Select start node for BFS\"></select>\n  <button id=\"startBtn\">Start BFS</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n<div id=\"graph\" aria-label=\"Graph visualization area\" role=\"region\" tabindex=\"0\"></div>\n<div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\" aria-label=\"BFS step log\"></div>\n<div id=\"footer\">Demonstration of BFS traversal on an undirected graph.</div>\n\n<script>\n(() => {\n  // Graph data: adjacency list representation and node positions for display\n  const graphData = {\n    nodes: [\n      { id: 'A', x: 100, y: 50 },\n      { id: 'B', x: 250, y: 100 },\n      { id: 'C', x: 400, y: 50 },\n      { id: 'D', x: 500, y: 150 },\n      { id: 'E', x: 400, y: 250 },\n      { id: 'F', x: 250, y: 270 },\n      { id: 'G', x: 100, y: 220 },\n      { id: 'H', x: 150, y: 150 },\n    ],\n    edges: [\n      ['A', 'B'],\n      ['A', 'H'],\n      ['B', 'C'],\n      ['B', 'H'],\n      ['C', 'D'],\n      ['D', 'E'],\n      ['E', 'F'],\n      ['F', 'G'],\n      ['G', 'H'],\n      ['H', 'F'],\n    ],\n  };\n\n  // Build adjacency list from edges\n  const adjacencyList = {};\n  for (const node of graphData.nodes) adjacencyList[node.id] = [];\n  for (const [u, v] of graphData.edges) {\n    adjacencyList[u].push(v);\n    adjacencyList[v].push(u);\n  }\n\n  // DOM Elements\n  const graphDiv = document.getElementById('graph');\n  const logDiv = document.getElementById('log');\n  const startNodeSelect = document.getElementById('startNode');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // Create SVG for edges\n  const svgNS = \"http://www.w3.org/2000/svg\";\n  const svgEdges = document.createElementNS(svgNS, 'svg');\n  svgEdges.setAttribute('width', '600');\n  svgEdges.setAttribute('height', '400');\n  graphDiv.appendChild(svgEdges);\n\n  // Store references to node divs\n  const nodeElements = {};\n\n  // Initialize the graph display\n  function createGraph() {\n    // Clear any previous nodes\n    graphDiv.querySelectorAll('.node').forEach(n => n.remove());\n    // Draw edges lines\n    while (svgEdges.firstChild) svgEdges.removeChild(svgEdges.firstChild);\n\n    // Draw edges as lines\n    for (const [u, v] of graphData.edges) {\n      const fromNode = graphData.nodes.find(n => n.id === u);\n      const toNode = graphData.nodes.find(n => n.id === v);\n      const line = document.createElementNS(svgNS, 'line');\n      line.setAttribute('x1', fromNode.x + 20);\n      line.setAttribute('y1', fromNode.y + 20);\n      line.setAttribute('x2', toNode.x + 20);\n      line.setAttribute('y2', toNode.y + 20);\n      line.setAttribute('stroke', '#888');\n      line.setAttribute('stroke-width', '2');\n      svgEdges.appendChild(line);\n    }\n\n    // Create nodes\n    for (const { id, x, y } of graphData.nodes) {\n      const div = document.createElement('div');\n      div.classList.add('node');\n      div.textContent = id;\n      div.style.left = x + 'px';\n      div.style.top = y + 'px';\n      div.setAttribute('role', 'button');\n      div.setAttribute('tabindex', '0');\n      div.setAttribute('aria-label', 'Node ' + id);\n      graphDiv.appendChild(div);\n      nodeElements[id] = div;\n    }\n  }\n\n  // Fill start node selection dropdown\n  function populateStartNodeSelect() {\n    for (const { id } of graphData.nodes) {\n      const option = document.createElement('option');\n      option.value = id;\n      option.textContent = id;\n      startNodeSelect.appendChild(option);\n    }\n  }\n\n  // BFS algorithm as async generator for step-by-step demonstration\n  async function* bfs(graph, start) {\n    let queue = [];\n    let visited = new Set();\n\n    queue.push(start);\n    visited.add(start);\n\n    while (queue.length > 0) {\n      const current = queue.shift();\n      yield { type: 'visit', node: current };\n\n      for (const neighbor of graph[current]) {\n        if (!visited.has(neighbor)) {\n          visited.add(neighbor);\n          queue.push(neighbor);\n          yield { type: 'enqueue', node: neighbor };\n        }\n      }\n    }\n  }\n\n  // Delay helper\n  const delay = ms => new Promise(res => setTimeout(res, ms));\n\n  // BFS visualization controller\n  let bfsIterator = null;\n  let running = false;\n\n  async function runBFS(startNode) {\n    running = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n    startNodeSelect.disabled = true;\n    logDiv.textContent = '';\n    // Reset all nodes classes\n    for (const id in nodeElements) {\n      nodeElements[id].classList.remove('visited', 'current');\n    }\n\n    bfsIterator = bfs(adjacencyList, startNode);\n    const visitedOrder = [];\n\n    while (running) {\n      const { value, done } = await bfsIterator.next();\n      if (done) break;\n\n      if (value.type === 'visit') {\n        // Mark current node\n        for (const id in nodeElements) {\n          nodeElements[id].classList.remove('current');\n        }\n        nodeElements[value.node].classList.add('current', 'visited');\n        visitedOrder.push(value.node);\n        logStep(`Visited node: ${value.node}`);\n      } else if (value.type === 'enqueue') {\n        logStep(`Enqueued node: ${value.node}`);\n      }\n      await delay(1000);\n    }\n\n    // Final cleanup, remove current markers\n    for (const id in nodeElements) {\n      nodeElements[id].classList.remove('current');\n    }\n\n    logStep('BFS complete. Order of visit: ' + visitedOrder.join(', '));\n    running = false;\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n    startNodeSelect.disabled = true;\n  }\n\n  // Logging helper\n  function logStep(text) {\n    const p = document.createElement('div');\n    p.className = 'step';\n    p.textContent = text;\n    logDiv.appendChild(p);\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n\n  // Reset the visualization\n  function reset() {\n    running = false;\n    bfsIterator = null;\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n    startNodeSelect.disabled = false;\n    logDiv.textContent = '';\n    for (const id in nodeElements) {\n      nodeElements[id].classList.remove('visited', 'current');\n    }\n  }\n\n  // User interaction events\n  startBtn.addEventListener('click', () => {\n    const startNode = startNodeSelect.value;\n    if (startNode) {\n      runBFS(startNode);\n    }\n  });\n  resetBtn.addEventListener('click', () => {\n    reset();\n  });\n\n  // Initialize the page\n  createGraph();\n  populateStartNodeSelect();\n  reset();\n})();\n</script>\n</body>\n</html>"
  },
