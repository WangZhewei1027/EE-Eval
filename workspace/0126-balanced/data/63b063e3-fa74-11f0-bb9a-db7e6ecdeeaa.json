    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>AVL Tree Visualization and Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 10px;\n    background: #f4f4f9;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #controls {\n    max-width: 600px;\n    margin: 10px auto;\n    text-align: center;\n  }\n  input[type=\"number\"] {\n    font-size: 1.1em;\n    padding: 5px 8px;\n    width: 100px;\n  }\n  button {\n    font-size: 1em;\n    padding: 6px 12px;\n    margin-left: 10px;\n    cursor: pointer;\n    background-color: #0066cc;\n    border: none;\n    color: white;\n    border-radius: 3px;\n  }\n  button:disabled {\n    background-color: #999;\n    cursor: not-allowed;\n  }\n  #message {\n    margin-top: 15px;\n    height: 22px;\n    font-weight: bold;\n    min-height: 22px;\n    color: #005500;\n  }\n  #canvasContainer {\n    max-width: 960px;\n    margin: 20px auto;\n    text-align: center;\n  }\n  canvas {\n    background-color: white;\n    border: 1px solid #ccc;\n    border-radius: 4px;\n    max-width: 100%;\n  }\n  #legend {\n    max-width: 600px;\n    margin: 20px auto;\n    font-size: 0.9em;\n    line-height: 1.4em;\n    background: #eaeaea;\n    padding: 10px;\n    border-radius: 5px;\n  }\n</style>\n</head>\n<body>\n\n<h1>AVL Tree Visualization & Demo</h1>\n<div id=\"controls\">\n  <input type=\"number\" id=\"valueInput\" placeholder=\"Enter integer\" />\n  <button id=\"insertBtn\">Insert</button>\n  <button id=\"removeBtn\">Remove</button>\n  <button id=\"clearBtn\">Clear Tree</button>\n  <div id=\"message\"></div>\n</div>\n\n<div id=\"canvasContainer\">\n  <canvas id=\"treeCanvas\" width=\"960\" height=\"480\"></canvas>\n</div>\n\n<div id=\"legend\">\n  <strong>AVL Tree Basics:</strong><br/>\n  - An <em>AVL Tree</em> is a self-balancing binary search tree.<br/>\n  - Each node maintains a balance factor = height(left subtree) - height(right subtree).<br/>\n  - Valid balance factors are -1, 0, or 1.<br/>\n  - Rotations (single and double) are used to restore balance after insertions or removals.<br/>\n  <br/>\n  <strong>Controls:</strong> Input an integer and click Insert or Remove.<br/>\n  <strong>Visualization:</strong> Nodes are shown as circles with their values.<br/>\n  Red edges & nodes highlight rotations and rebalancing actions.\n</div>\n\n<script>\n(() => {\n  // AVL Tree Node class\n  class AVLNode {\n    constructor(value) {\n      this.value = value;\n      this.left = null;\n      this.right = null;\n      this.height = 1;\n    }\n  }\n\n  // AVL Tree class with insert, remove, and balancing\n  class AVLTree {\n    constructor() {\n      this.root = null;\n      this.actions = []; // To track rotations for visualization\n    }\n\n    height(node) {\n      return node ? node.height : 0;\n    }\n\n    balanceFactor(node) {\n      return node ? this.height(node.left) - this.height(node.right) : 0;\n    }\n\n    updateHeight(node) {\n      node.height = Math.max(this.height(node.left), this.height(node.right)) + 1;\n    }\n\n    rotateRight(y) {\n      const x = y.left;\n      const T2 = x.right;\n      // Perform rotation\n      x.right = y;\n      y.left = T2;\n      // Update heights\n      this.updateHeight(y);\n      this.updateHeight(x);\n      this.actions.push({type: \"rotateRight\", pivot: x.value});\n      return x;\n    }\n\n    rotateLeft(x) {\n      const y = x.right;\n      const T2 = y.left;\n      // Perform rotation\n      y.left = x;\n      x.right = T2;\n      // Update heights\n      this.updateHeight(x);\n      this.updateHeight(y);\n      this.actions.push({type: \"rotateLeft\", pivot: y.value});\n      return y;\n    }\n\n    // Balance node and return the new root\n    balance(node) {\n      this.updateHeight(node);\n      const bf = this.balanceFactor(node);\n\n      // Left heavy\n      if (bf > 1) {\n        // Left-Left case\n        if (this.balanceFactor(node.left) >= 0) {\n          this.actions.push({type: \"balanceLeftLeft\", node: node.value});\n          return this.rotateRight(node);\n        }\n        // Left-Right case\n        else {\n          this.actions.push({type: \"balanceLeftRight\", node: node.value});\n          node.left = this.rotateLeft(node.left);\n          return this.rotateRight(node);\n        }\n      }\n      // Right heavy\n      if (bf < -1) {\n        // Right-Right case\n        if (this.balanceFactor(node.right) <= 0) {\n          this.actions.push({type: \"balanceRightRight\", node: node.value});\n          return this.rotateLeft(node);\n        }\n        // Right-Left case\n        else {\n          this.actions.push({type: \"balanceRightLeft\", node: node.value});\n          node.right = this.rotateRight(node.right);\n          return this.rotateLeft(node);\n        }\n      }\n\n      return node;\n    }\n\n    // Insert value into AVL tree, returns new root\n    insertNode(node, value) {\n      if (!node) {\n        this.actions.push({type: \"insert\", node: value});\n        return new AVLNode(value);\n      }\n      if (value === node.value) {\n        this.actions.push({type: \"duplicate\", node: value});\n        return node; // duplicates not inserted\n      }\n      else if (value < node.value) {\n        node.left = this.insertNode(node.left, value);\n      }\n      else {\n        node.right = this.insertNode(node.right, value);\n      }\n      return this.balance(node);\n    }\n\n    insert(value) {\n      this.actions = [];\n      this.root = this.insertNode(this.root, value);\n      return this.actions;\n    }\n\n    minValueNode(node) {\n      let current = node;\n      while (current.left !== null) current = current.left;\n      return current;\n    }\n\n    removeNode(node, value) {\n      if (!node) {\n        this.actions.push({type: \"notFound\", node: value});\n        return node;\n      }\n      if (value < node.value) {\n        node.left = this.removeNode(node.left, value);\n      }\n      else if (value > node.value) {\n        node.right = this.removeNode(node.right, value);\n      }\n      else {\n        this.actions.push({type: \"remove\", node: value});\n        // Node with only one child or no child\n        if (!node.left) {\n          let temp = node.right;\n          node = null;\n          return temp;\n        }\n        else if (!node.right) {\n          let temp = node.left;\n          node = null;\n          return temp;\n        }\n\n        // Node with two children: get inorder successor\n        let temp = this.minValueNode(node.right);\n        node.value = temp.value;\n        node.right = this.removeNode(node.right, temp.value);\n      }\n      if (!node) return node;\n      return this.balance(node);\n    }\n\n    remove(value) {\n      this.actions = [];\n      this.root = this.removeNode(this.root, value);\n      return this.actions;\n    }\n  }\n\n  // Visualization utilities\n  const canvas = document.getElementById(\"treeCanvas\");\n  const ctx = canvas.getContext(\"2d\");\n  const WIDTH = canvas.width;\n  const HEIGHT = canvas.height;\n  const NODE_RADIUS = 22;\n  const LEVEL_HEIGHT = 80;\n  let animationSteps = [];\n\n  // Store node positions for drawing edges and nodes\n  // Output an array of [{node, x, y, color}]\n  function layoutTree(root, width = WIDTH, startX = 20, endX = WIDTH - 20, startY = 50, positions=[]) {\n    if (!root) return positions;\n    const x = (startX + endX) / 2;\n    const y = startY;\n    positions.push({node: root, x, y, color: \"#4a90e2\"});\n\n    // Recursive layout for children\n    layoutTree(root.left, width, startX, x - 30, startY + LEVEL_HEIGHT, positions);\n    layoutTree(root.right, width, x + 30, endX, startY + LEVEL_HEIGHT, positions);\n    return positions;\n  }\n\n  // Draw an arrowed line between two points\n  function drawEdge(x1, y1, x2, y2, color = \"#333\") {\n    ctx.strokeStyle = color;\n    ctx.lineWidth = 2;\n    ctx.beginPath();\n\n    // Calculate line endpoint so arrowhead fits nicely\n    const angle = Math.atan2(y2 - y1, x2 - x1);\n    const endX = x2 - NODE_RADIUS * Math.cos(angle);\n    const endY = y2 - NODE_RADIUS * Math.sin(angle);\n\n    ctx.moveTo(x1, y1);\n    ctx.lineTo(endX, endY);\n    ctx.stroke();\n\n    // Draw arrowhead\n    const headlen = 10; // length of head in pixels\n    ctx.beginPath();\n    ctx.moveTo(endX, endY);\n    ctx.lineTo(endX - headlen * Math.cos(angle - Math.PI / 6), endY - headlen * Math.sin(angle - Math.PI / 6));\n    ctx.lineTo(endX - headlen * Math.cos(angle + Math.PI / 6), endY - headlen * Math.sin(angle + Math.PI / 6));\n    ctx.lineTo(endX, endY);\n    ctx.fillStyle = color;\n    ctx.fill();\n  }\n\n  // Draw a single node circle with value and height below\n  function drawNode(x, y, value, heightVal, color = \"#4a90e2\", highlight = false) {\n    ctx.fillStyle = color;\n    ctx.strokeStyle = highlight ? \"#e74c3c\" : \"#333\";\n    ctx.lineWidth = highlight ? 4 : 2;\n    ctx.beginPath();\n    ctx.arc(x, y, NODE_RADIUS, 0, 2 * Math.PI);\n    ctx.fill();\n    ctx.stroke();\n\n    // Value text\n    ctx.fillStyle = \"white\";\n    ctx.font = \"bold 16px Arial\";\n    ctx.textAlign = \"center\";\n    ctx.textBaseline = \"middle\";\n    ctx.fillText(value, x, y);\n\n    // Height text below the node\n    ctx.fillStyle = \"#222\";\n    ctx.font = \"12px Arial\";\n    ctx.fillText(\"h:\" + heightVal, x, y + NODE_RADIUS + 14);\n  }\n\n  // Clear canvas\n  function clearCanvas() {\n    ctx.clearRect(0, 0, WIDTH, HEIGHT);\n  }\n\n  // Draw entire tree\n  // Optionally highlight nodes involved in rotations or insert/remove\n  function drawTree(tree, highlightNodes = [], highlightEdges = [], highlightType = \"\") {\n    clearCanvas();\n    if (!tree.root) return;\n\n    // Get positions\n    const positions = [];\n\n    // We calculate inorder index positions for balanced x placement:\n    let nodesInOrder = [];\n    function inorder(node) {\n      if (!node) return;\n      inorder(node.left);\n      nodesInOrder.push(node);\n      inorder(node.right);\n    }\n    inorder(tree.root);\n\n    // Map node to x position based on inorder index\n    let nodeToPos = new Map();\n    let h = tree.root.height;\n    function assignPositions(node, depth = 1) {\n      if (!node) return;\n      assignPositions(node.left, depth + 1);\n      let idx = nodesInOrder.indexOf(node);\n      let segmentWidth = WIDTH / (nodesInOrder.length + 1);\n      let x = segmentWidth * (idx + 1);\n      let y = LEVEL_HEIGHT * depth;\n      nodeToPos.set(node, {x, y});\n      assignPositions(node.right, depth + 1);\n    }\n    assignPositions(tree.root);\n\n    // Draw edges first\n    for (const [node, pos] of nodeToPos.entries()) {\n      if (node.left) {\n        const c1 = highlightEdges.some(e => (e.parent === node.value && e.child === node.left.value));\n        drawEdge(pos.x, pos.y, nodeToPos.get(node.left).x, nodeToPos.get(node.left).y, c1 ? \"#e74c3c\" : \"#555\");\n      }\n      if (node.right) {\n        const c2 = highlightEdges.some(e => (e.parent === node.value && e.child === node.right.value));\n        drawEdge(pos.x, pos.y, nodeToPos.get(node.right).x, nodeToPos.get(node.right).y, c2 ? \"#e74c3c\" : \"#555\");\n      }\n    }\n\n    // Draw nodes on top\n    for (const [node, pos] of nodeToPos.entries()) {\n      const highlightNode = highlightNodes.includes(node.value);\n      drawNode(pos.x, pos.y, node.value, node.height, highlightNode ? \"#e74c3c\" : \"#4a90e2\", highlightNode);\n    }\n\n    // Draw info on top\n    if (highlightType) {\n      ctx.fillStyle = \"#e74c3c\";\n      ctx.font = \"18px Arial\";\n      ctx.textAlign = \"center\";\n      ctx.fillText(\"Action: \" + highlightType, WIDTH / 2, 30);\n    }\n  }\n\n  // Animate array of actions with pauses highlighting rotations, insert, delete\n  function animateActions(tree, actions) {\n    if (!actions.length) {\n      drawTree(tree);\n      setMessage(\"Operation complete.\");\n      return;\n    }\n    let i = 0;\n    const stepDelay = 1300;\n\n    function nextStep() {\n      if (i >= actions.length) {\n        drawTree(tree);\n        setMessage(\"Operation complete.\");\n        return;\n      }\n      const action = actions[i];\n      let highlightNodes = [];\n      let highlightEdges = [];\n      let text = \"\";\n      switch(action.type) {\n        case \"insert\":\n          text = `Inserted node ${action.node}`;\n          highlightNodes = [action.node];\n          break;\n        case \"duplicate\":\n          text = `Value ${action.node} already exists (no duplicates).`;\n          highlightNodes = [action.node];\n          break;\n        case \"remove\":\n          text = `Removed node ${action.node}`;\n          highlightNodes = [action.node];\n          break;\n        case \"notFound\":\n          text = `Value ${action.node} not found for removal.`;\n          break;\n        case \"rotateLeft\":\n          text = `Rotate left at node ${action.pivot}`;\n          highlightNodes = [action.pivot];\n          break;\n        case \"rotateRight\":\n          text = `Rotate right at node ${action.pivot}`;\n          highlightNodes = [action.pivot];\n          break;\n        case \"balanceLeftLeft\":\n          text = `Balance Case: Left-Left at node ${action.node}`;\n          highlightNodes = [action.node];\n          break;\n        case \"balanceLeftRight\":\n          text = `Balance Case: Left-Right at node ${action.node}`;\n          highlightNodes = [action.node];\n          break;\n        case \"balanceRightRight\":\n          text = `Balance Case: Right-Right at node ${action.node}`;\n          highlightNodes = [action.node];\n          break;\n        case \"balanceRightLeft\":\n          text = `Balance Case: Right-Left at node ${action.node}`;\n          highlightNodes = [action.node];\n          break;\n        default:\n          text = \"\";\n      }\n      drawTree(tree, highlightNodes, highlightEdges, text);\n      setMessage(text);\n      i++;\n      setTimeout(nextStep, stepDelay);\n    }\n    nextStep();\n  }\n\n  // Message display helper\n  function setMessage(msg) {\n    document.getElementById(\"message\").textContent = msg;\n  }\n\n  // Initialize tree and controls\n  const avl = new AVLTree();\n\n  const input = document.getElementById(\"valueInput\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const removeBtn = document.getElementById(\"removeBtn\");\n  const clearBtn = document.getElementById(\"clearBtn\");\n\n  function disableButtons(state) {\n    insertBtn.disabled = state;\n    removeBtn.disabled = state;\n    clearBtn.disabled = state;\n  }\n\n  insertBtn.addEventListener(\"click\", () => {\n    const val = parseInt(input.value);\n    if (isNaN(val)) {\n      setMessage(\"Please enter a valid integer.\");\n      return;\n    }\n\n    disableButtons(true);\n    const actions = avl.insert(val);\n    animateActions(avl, actions);\n    setTimeout(() => disableButtons(false), actions.length * 1300 + 300);\n    input.value = \"\";\n    input.focus();\n  });\n\n  removeBtn.addEventListener(\"click\", () => {\n    const val = parseInt(input.value);\n    if (isNaN(val)) {\n      setMessage(\"Please enter a valid integer.\");\n      return;\n    }\n    disableButtons(true);\n    const actions = avl.remove(val);\n    animateActions(avl, actions);\n    setTimeout(() => disableButtons(false), actions.length * 1300 + 300);\n    input.value = \"\";\n    input.focus();\n  });\n\n  clearBtn.addEventListener(\"click\", () => {\n    avl.root = null;\n    clearCanvas();\n    setMessage(\"Tree cleared.\");\n    input.value = \"\";\n    input.focus();\n  });\n\n  // Initial draw\n  drawTree(avl);\n  setMessage(\"Enter a value and insert or remove nodes to see AVL Tree balancing.\");\n\n})();\n</script>\n\n</body>\n</html>"
