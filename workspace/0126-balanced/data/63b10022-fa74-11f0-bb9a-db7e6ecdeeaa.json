    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Merge Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1em;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #arrayContainer {\n    display: flex;\n    justify-content: center;\n    margin: 2em 0;\n    min-height: 150px;\n  }\n  .bar {\n    margin: 0 2px;\n    background-color: #6495ED;\n    width: 20px;\n    transition: all 0.4s ease;\n    border-radius: 3px;\n    position: relative;\n  }\n  .bar.highlight {\n    background-color: #FF6347;\n  }\n  .bar.merging {\n    background-color: #32CD32;\n  }\n  .bar.finished {\n    background-color: #6a9955;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 1.5em;\n  }\n  button {\n    font-size: 1rem;\n    padding: 0.5em 1.2em;\n    margin: 0 0.5em;\n    cursor: pointer;\n  }\n  input[type=number] {\n    width: 3em;\n    font-size: 1rem;\n    text-align: center;\n  }\n  #explanation {\n    max-width: 800px;\n    margin: 0 auto 2em auto;\n    line-height: 1.5;\n    background: #e3f2fd;\n    border-left: 6px solid #2196F3;\n    padding: 1em 1.5em;\n    border-radius: 8px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Merge Sort Demonstration</h1>\n<div id=\"explanation\">\n  <strong>Merge Sort</strong> is a divide-and-conquer sorting algorithm.\n  It divides the array into two halves, recursively sorts each half,\n  and then merges the sorted halves back together.\n  <br /><br />\n  This visualization shows the process step-by-step:\n  <ul>\n    <li><em>Blue bars</em> represent unsorted elements.</li>\n    <li><em>Red bars</em> indicate elements currently being compared/merged.</li>\n    <li><em>Green bars</em> highlight the elements being merged together.</li>\n    <li><em>Dark green bars</em> mean elements that are finalized in the sorted order.</li>\n  </ul>\n</div>\n\n<div id=\"controls\">\n  <label for=\"arraySize\">Array size: </label>\n  <input type=\"number\" id=\"arraySize\" min=\"5\" max=\"50\" value=\"20\" />\n  <button id=\"generateBtn\">Generate New Array</button>\n  <button id=\"sortBtn\">Start Merge Sort</button>\n</div>\n\n<div id=\"arrayContainer\"></div>\n\n<script>\n  const arrayContainer = document.getElementById(\"arrayContainer\");\n  const generateBtn = document.getElementById(\"generateBtn\");\n  const sortBtn = document.getElementById(\"sortBtn\");\n  const arraySizeInput = document.getElementById(\"arraySize\");\n\n  let array = [];\n  let speed = 400; // delay in ms\n\n  // Generate random array\n  function generateArray(size = 20) {\n    array = [];\n    for (let i = 0; i < size; i++) {\n      array.push(Math.floor(Math.random() * 100) + 5);\n    }\n  }\n\n  // Render bars\n  function renderArray(highlights = {}, merging = {}, finishedIndices = {}) {\n    // highlights: indices marked as being compared\n    // merging: indices currently in merging process\n    // finishedIndices: indices that are already placed in final sorted position\n    arrayContainer.innerHTML = \"\";\n    for (let i = 0; i < array.length; i++) {\n      const bar = document.createElement(\"div\");\n      bar.classList.add(\"bar\");\n      bar.style.height = array[i] * 3 + \"px\";\n      bar.title = array[i];\n      if (finishedIndices[i]) {\n        bar.classList.add(\"finished\");\n      } else if (merging[i]) {\n        bar.classList.add(\"merging\");\n      } else if (highlights[i]) {\n        bar.classList.add(\"highlight\");\n      }\n      arrayContainer.appendChild(bar);\n    }\n  }\n\n  // Sleep for ms milliseconds\n  function sleep(ms) {\n    return new Promise((resolve) => setTimeout(resolve, ms));\n  }\n\n  // Merge sort with visualization\n  async function mergeSortVisual(arr, left, right) {\n    if (left >= right) {\n      return;\n    }\n    const mid = Math.floor((left + right) / 2);\n\n    await mergeSortVisual(arr, left, mid);\n    await mergeSortVisual(arr, mid + 1, right);\n    await merge(arr, left, mid, right);\n  }\n\n  async function merge(arr, left, mid, right) {\n    let n1 = mid - left + 1;\n    let n2 = right - mid;\n\n    let leftArr = [];\n    let rightArr = [];\n\n    for (let i = 0; i < n1; i++) {\n      leftArr.push(arr[left + i]);\n    }\n    for (let j = 0; j < n2; j++) {\n      rightArr.push(arr[mid + 1 + j]);\n    }\n\n    let i = 0,\n      j = 0,\n      k = left;\n\n    // Highlight merging segment\n    const mergingSegment = {};\n    for (let x = left; x <= right; x++) {\n      mergingSegment[x] = true;\n    }\n\n    while (i < n1 && j < n2) {\n      // Highlight comparison\n      const highlights = {};\n      highlights[k] = true;\n      renderArray(highlights, mergingSegment);\n      await sleep(speed);\n\n      if (leftArr[i] <= rightArr[j]) {\n        arr[k] = leftArr[i];\n        i++;\n      } else {\n        arr[k] = rightArr[j];\n        j++;\n      }\n      renderArray({}, mergingSegment);\n      await sleep(speed / 1.5);\n      k++;\n    }\n\n    while (i < n1) {\n      const highlights = {};\n      highlights[k] = true;\n      renderArray(highlights, mergingSegment);\n      await sleep(speed);\n\n      arr[k] = leftArr[i];\n      i++;\n      renderArray({}, mergingSegment);\n      await sleep(speed / 1.5);\n      k++;\n    }\n    while (j < n2) {\n      const highlights = {};\n      highlights[k] = true;\n      renderArray(highlights, mergingSegment);\n      await sleep(speed);\n\n      arr[k] = rightArr[j];\n      j++;\n      renderArray({}, mergingSegment);\n      await sleep(speed / 1.5);\n      k++;\n    }\n\n    // After merge finished, show merged segment briefly as finished (dark green)\n    const finished = {};\n    for (let x = left; x <= right; x++) {\n      finished[x] = true;\n    }\n    renderArray({}, {}, finished);\n    await sleep(speed);\n  }\n\n  // Disable/enable control buttons\n  function setControlsDisabled(state) {\n    generateBtn.disabled = state;\n    sortBtn.disabled = state;\n    arraySizeInput.disabled = state;\n  }\n\n  function init() {\n    const size = parseInt(arraySizeInput.value, 10);\n    if (isNaN(size) || size < 5 || size > 50) {\n      alert(\"Please enter a valid array size between 5 and 50.\");\n      return;\n    }\n    generateArray(size);\n    renderArray();\n  }\n\n  generateBtn.addEventListener(\"click\", () => {\n    init();\n  });\n\n  sortBtn.addEventListener(\"click\", async () => {\n    setControlsDisabled(true);\n    await mergeSortVisual(array, 0, array.length - 1);\n    // All sorted - final display\n    const finished = {};\n    for (let i = 0; i < array.length; i++) {\n      finished[i] = true;\n    }\n    renderArray({}, {}, finished);\n    setControlsDisabled(false);\n  });\n\n  // Initialize on page load\n  window.onload = () => {\n    init();\n  };\n</script>\n\n</body>\n</html>"
