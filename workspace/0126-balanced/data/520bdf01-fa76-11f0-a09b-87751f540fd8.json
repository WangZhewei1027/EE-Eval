    "content": "<html>\n<head>\n    <title>Overfitting Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .chart {\n            width: 800px;\n            height: 400px;\n            border: 1px solid black;\n        }\n    </style>\n</head>\n<body>\n<h1>Overfitting Example</h1>\n<script>\n    // Create a simple dataset\n    const data = {\n        labels: ['A', 'B', 'C', 'D', 'E'],\n        datasets: [{\n            label: 'Training',\n            data: [10, 15, 7, 12, 20],\n            backgroundColor: 'rgba(255, 99, 132, 0.2)',\n            borderColor: 'rgba(255, 99, 132, 1)',\n            borderWidth: 1\n        }, {\n            label: 'Test',\n            data: [5, 8, 3, 7, 12],\n            backgroundColor: 'rgba(54, 162, 235, 0.2)',\n            borderColor: 'rgba(54, 162, 235, 1)',\n            borderWidth: 1\n        }]\n    };\n\n    // Create the chart\n    const ctx = document.getElementById('chart').getContext('2d');\n    const chart = new Chart(ctx, {\n        type: 'bar',\n        data: data,\n        options: {\n            title: {\n                display: true,\n                text: 'Overfitting Example'\n            },\n            scales: {\n                y: {\n                    beginAtZero: true\n                }\n            }\n        }\n    });\n\n    // Train the model\n    for (let i = 0; i < 100; i++) {\n        // Simulate data generation\n        const x = new Array(100).fill(0).map((_, index) => index);\n        const y = new Array(100).fill(Math.sin(x).toFixed(2));\n\n        // Train the model\n        chart.data.datasets[0].data = y;\n        chart.data.datasets[1].data = y;\n        chart.update();\n    }\n\n    // Plot the data\n    chart.data.datasets[0].data.forEach((value, index) => {\n        document.getElementById('label').innerHTML = data.labels[index];\n        document.getElementById('value').innerHTML = value;\n    });\n</script>\n<div id=\"chart\"></div>\n<div id=\"label\"></div>\n<div id=\"value\"></div>\n</body>\n</html>"
