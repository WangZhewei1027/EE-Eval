    "content": "<html>\n<head>\n    <title>Heap Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            max-width: 500px;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h2>Heap Sort</h2>\n        <p>Heap Sort is a comparison-based sorting algorithm that uses a binary heap data structure.</p>\n        <button onclick=\"heapSort(array, 0, array.length - 1)\">Heap Sort</button>\n        <div id=\"result\"></div>\n    </div>\n\n    <script>\n        function heapSort(array, start, end) {\n            if (start < end) {\n                // Swap the root with the last element\n                let root = array[start];\n                let last = end;\n                while (last > start && array[last] > root) {\n                    // Swap the elements\n                    let temp = array[last];\n                    array[last] = root;\n                    root = temp;\n                    last--;\n                }\n\n                // Heapify the reduced heap\n                heapify(array, start, last);\n            }\n        }\n\n        function heapify(array, start, end) {\n            let largest = start;\n            let left = 2 * start + 1;\n            let right = 2 * start + 2;\n\n            if (left < end && array[left] > array[largest]) {\n                largest = left;\n            }\n\n            if (right < end && array[right] > array[largest]) {\n                largest = right;\n            }\n\n            if (largest !== start) {\n                let temp = array[start];\n                array[start] = array[largest];\n                array[largest] = temp;\n                heapify(array, start, largest);\n            }\n        }\n\n        let array = [12, 11, 13, 5, 6, 7];\n        let result = document.getElementById(\"result\");\n        result.innerHTML = \"Original array: \";\n        for (let i = 0; i < array.length; i++) {\n            result.innerHTML += array[i] + \" \";\n        }\n        heapSort(array, 0, array.length - 1);\n        result.innerHTML = \"Sorted array: \";\n        for (let i = 0; i < array.length; i++) {\n            result.innerHTML += array[i] + \" \";\n        }\n    </script>\n</body>\n</html>"
