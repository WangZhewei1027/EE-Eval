  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>SQL Concepts — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 0; padding: 0; color: #222; background: #f7f9fb; }\n    header { background: linear-gradient(90deg,#2b6cb0,#2c7a7b); color: white; padding: 28px 20px; }\n    header h1 { margin: 0 0 6px 0; font-size: 20px; }\n    header p { margin: 0; opacity: 0.95; font-size: 13px; }\n    main { display: grid; grid-template-columns: 1fr 420px; gap: 20px; padding: 20px; max-width: 1200px; margin: 0 auto; }\n    .panel { background: white; border-radius: 8px; padding: 16px; box-shadow: 0 6px 18px rgba(15,23,42,0.06); }\n    .panel h2 { margin: 0 0 12px 0; font-size: 16px; }\n    .editor { display: flex; flex-direction: column; gap: 8px; }\n    textarea { width: 100%; min-height: 160px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Courier New\", monospace; font-size: 13px; padding: 12px; border-radius: 6px; border: 1px solid #e2e8f0; background: #fcfeff; resize: vertical; }\n    select, button { font-size: 13px; padding: 8px 10px; border-radius: 6px; border: 1px solid #cbd5e1; background: white; cursor: pointer; }\n    .controls { display: flex; gap: 8px; flex-wrap: wrap; }\n    .small { font-size: 12px; padding: 6px 8px; }\n    .results { max-height: 420px; overflow: auto; border-radius: 6px; border: 1px solid #e2e8f0; padding: 10px; background: #fff; }\n    table { border-collapse: collapse; width: 100%; font-size: 13px; }\n    th, td { border: 1px solid #eef2f7; padding: 8px 10px; text-align: left; }\n    th { background: linear-gradient(180deg,#f8fafc,#eef2f9); position: sticky; top: 0; z-index: 1; }\n    .meta { font-size: 12px; color: #475569; margin-top: 8px; }\n    aside { padding: 0 0 0 4px; }\n    .examples { display: grid; gap: 8px; }\n    .example { padding: 10px; border-radius: 6px; border: 1px dashed #e2e8f0; background: #fcfdff; cursor: pointer; }\n    .example:hover { background: #f0f9ff; }\n    .kbd { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace; background: #f1f5f9; padding: 2px 6px; border-radius: 4px; font-size: 12px; }\n    footer { text-align: center; padding: 14px; color: #94a3b8; font-size: 13px; }\n    .flex { display: flex; gap: 8px; align-items: center; }\n    .muted { color: #64748b; font-size: 13px; }\n    .tag { background: #e6f3ff; color: #0369a1; padding: 4px 8px; border-radius: 999px; font-size: 12px; border: 1px solid #cfeeff; }\n    .split { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }\n    .toggle { display: inline-flex; gap: 8px; align-items: center; }\n    .checkbox { width: 16px; height: 16px; }\n    @media (max-width: 980px) {\n      main { grid-template-columns: 1fr; padding: 12px; }\n      aside { order: 2; }\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <div style=\"max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;gap:12px;\">\n      <div>\n        <h1>SQL Concepts — Interactive Demo</h1>\n        <p>Learn SQL by running real queries against an in-memory database in your browser. Try SELECT, JOINs, GROUP BY, INSERT, UPDATE and more.</p>\n      </div>\n      <div style=\"text-align:right;\">\n        <span class=\"tag\">No backend — runs locally</span>\n      </div>\n    </div>\n  </header>\n\n  <main>\n    <section class=\"panel\">\n      <h2>SQL Editor</h2>\n      <div class=\"editor\">\n        <label class=\"muted\">Write one or more SQL statements (semicolon-separated). Example database preloaded: users, products, orders.</label>\n        <textarea id=\"sqlInput\" spellcheck=\"false\"></textarea>\n\n        <div class=\"controls\">\n          <button id=\"runBtn\">Run SQL</button>\n          <button id=\"resetBtn\">Reset DB</button>\n          <button id=\"loadSamplesBtn\">Load Sample Data</button>\n          <select id=\"examplesSelect\" title=\"Choose example\">\n            <option value=\"\">-- Examples --</option>\n          </select>\n          <button id=\"insertExampleBtn\" class=\"small\">Insert Example into Editor</button>\n          <button id=\"clearBtn\" class=\"small\">Clear</button>\n        </div>\n\n        <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:8px;\">\n          <div class=\"muted\">Query results:</div>\n          <div class=\"muted\">Use multiple statements and try UPDATE / DELETE / JOIN</div>\n        </div>\n\n        <div id=\"output\" class=\"results\" style=\"margin-top:10px;\">\n          <em>Run a query to see results here.</em>\n        </div>\n        <div id=\"status\" class=\"meta\"></div>\n      </div>\n    </section>\n\n    <aside class=\"panel\">\n      <h2>Quick Reference & Examples</h2>\n      <div style=\"font-size:13px;color:#334155;\">\n        <p><strong>Common SQL statements</strong></p>\n        <ul style=\"padding-left:20px;\">\n          <li><span class=\"kbd\">SELECT</span> — read rows: SELECT col1, col2 FROM table WHERE condition ORDER BY col LIMIT n</li>\n          <li><span class=\"kbd\">INSERT</span> — add rows: INSERT INTO table (col1,col2) VALUES (v1,v2)</li>\n          <li><span class=\"kbd\">UPDATE</span> — modify rows: UPDATE table SET col = expr WHERE condition</li>\n          <li><span class=\"kbd\">DELETE</span> — remove rows: DELETE FROM table WHERE condition</li>\n          <li><span class=\"kbd\">JOIN</span> — combine tables: SELECT ... FROM a JOIN b ON a.id = b.a_id</li>\n          <li><span class=\"kbd\">GROUP BY</span> — aggregate: SELECT col, COUNT(*) FROM table GROUP BY col HAVING COUNT(*) &gt; 1</li>\n        </ul>\n\n        <h3 style=\"margin-top:10px;\">Examples</h3>\n        <div class=\"examples\" id=\"examplesList\" style=\"margin-bottom:10px;\"></div>\n\n        <div style=\"margin-top:10px;\">\n          <button id=\"showTablesBtn\" class=\"small\">Show Tables</button>\n          <button id=\"exportBtn\" class=\"small\">Export DB (JSON)</button>\n        </div>\n\n        <div style=\"margin-top:12px;\">\n          <h4 style=\"margin:6px 0;\">Tables (sample)</h4>\n          <div id=\"tablesMeta\" class=\"muted\">users (id, name, email, city), products (id, name, price), orders (id, user_id, product_id, qty, created)</div>\n        </div>\n      </div>\n    </aside>\n  </main>\n\n  <footer>\n    This demo uses an in-memory SQL engine in your browser. Use responsibly — data is not sent anywhere.\n  </footer>\n\n  <!-- Load AlaSQL from CDN (small, zero-backend SQL engine in JS) -->\n  <script src=\"https://cdn.jsdelivr.net/npm/alasql@1.7.6/dist/alasql.min.js\"></script>\n  <script>\n    // Simple interactive demo wiring using AlaSQL library.\n    // We preload a sample database and provide example queries.\n\n    // Sample data definitions and rows\n    const SAMPLE_SETUP = `\n      DROP TABLE IF EXISTS users;\n      DROP TABLE IF EXISTS products;\n      DROP TABLE IF EXISTS orders;\n\n      CREATE TABLE users (id INT PRIMARY KEY, name STRING, email STRING, city STRING);\n      INSERT INTO users VALUES (1, 'Alice', 'alice@example.com', 'Seattle');\n      INSERT INTO users VALUES (2, 'Bob', 'bob@example.com', 'Portland');\n      INSERT INTO users VALUES (3, 'Carmen', 'carmen@example.com', 'Seattle');\n      INSERT INTO users VALUES (4, 'Diego', 'diego@example.com', 'San Francisco');\n\n      CREATE TABLE products (id INT PRIMARY KEY, name STRING, price FLOAT);\n      INSERT INTO products VALUES (1, 'Coffee', 3.5);\n      INSERT INTO products VALUES (2, 'Tea', 2.5);\n      INSERT INTO products VALUES (3, 'Muffin', 2.75);\n\n      CREATE TABLE orders (id INT PRIMARY KEY, user_id INT, product_id INT, qty INT, created STRING);\n      INSERT INTO orders VALUES (1, 1, 1, 2, '2023-12-01');\n      INSERT INTO orders VALUES (2, 2, 3, 1, '2023-12-01');\n      INSERT INTO orders VALUES (3, 1, 3, 3, '2023-12-02');\n      INSERT INTO orders VALUES (4, 3, 2, 4, '2023-12-03');\n    `;\n\n    // Example queries with descriptions\n    const EXAMPLES = [\n      {\n        name: \"Simple SELECT (projection)\",\n        sql: \"SELECT id, name, city FROM users;\",\n        desc: \"Basic SELECT returns specified columns from a table.\"\n      },\n      {\n        name: \"Filtering with WHERE\",\n        sql: \"SELECT * FROM users WHERE city = 'Seattle';\",\n        desc: \"Use WHERE to filter rows. Supports =, <, >, <=, >=, <>, AND, OR.\"\n      },\n      {\n        name: \"ORDER BY and LIMIT\",\n        sql: \"SELECT id, name FROM users ORDER BY name DESC LIMIT 3;\",\n        desc: \"ORDER BY sorts rows. LIMIT restricts the number of rows returned.\"\n      },\n      {\n        name: \"JOIN two tables\",\n        sql: \"SELECT o.id AS order_id, u.name AS customer, p.name AS product, o.qty\\nFROM orders o\\nJOIN users u ON o.user_id = u.id\\nJOIN products p ON o.product_id = p.id\\nORDER BY o.id;\",\n        desc: \"JOIN combines rows from multiple tables based on a condition (here, matching IDs).\"\n      },\n      {\n        name: \"Aggregation with GROUP BY\",\n        sql: \"SELECT u.city, COUNT(*) AS orders_count\\nFROM orders o JOIN users u ON o.user_id = u.id\\nGROUP BY u.city\\nORDER BY orders_count DESC;\",\n        desc: \"GROUP BY groups rows; use aggregation functions like COUNT(), SUM(), AVG().\"\n      },\n      {\n        name: \"INSERT a new row\",\n        sql: \"INSERT INTO users (id, name, email, city) VALUES (5, 'Eve', 'eve@example.com', 'Austin');\\nSELECT * FROM users WHERE id = 5;\",\n        desc: \"INSERT adds rows. Here we then SELECT the new row to confirm.\"\n      },\n      {\n        name: \"UPDATE rows\",\n        sql: \"UPDATE users SET city = 'Seattle' WHERE name = 'Bob';\\nSELECT id, name, city FROM users WHERE name = 'Bob';\",\n        desc: \"UPDATE modifies existing rows matching the WHERE condition.\"\n      },\n      {\n        name: \"DELETE rows\",\n        sql: \"DELETE FROM users WHERE name = 'Eve';\\nSELECT id, name FROM users;\",\n        desc: \"DELETE removes rows that match the WHERE clause.\"\n      },\n      {\n        name: \"Subquery in WHERE\",\n        sql: \"SELECT name FROM users WHERE id IN (SELECT user_id FROM orders WHERE product_id = 3);\",\n        desc: \"Subqueries let you use a SELECT inside another statement. Here we find users who ordered product 3.\"\n      },\n      {\n        name: \"HAVING after GROUP BY\",\n        sql: \"SELECT user_id, SUM(qty) AS total_qty FROM orders GROUP BY user_id HAVING SUM(qty) > 2;\",\n        desc: \"HAVING filters groups after aggregation (unlike WHERE which filters rows before grouping).\"\n      }\n    ];\n\n    // UI elements\n    const sqlInput = document.getElementById('sqlInput');\n    const runBtn = document.getElementById('runBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const loadSamplesBtn = document.getElementById('loadSamplesBtn');\n    const output = document.getElementById('output');\n    const status = document.getElementById('status');\n    const examplesSelect = document.getElementById('examplesSelect');\n    const examplesList = document.getElementById('examplesList');\n    const insertExampleBtn = document.getElementById('insertExampleBtn');\n    const clearBtn = document.getElementById('clearBtn');\n    const showTablesBtn = document.getElementById('showTablesBtn');\n    const exportBtn = document.getElementById('exportBtn');\n\n    // Initialize AlaSQL DB\n    function resetDatabase() {\n      try {\n        alasql('CREATE DATABASE IF NOT EXISTS demo');\n        alasql('USE demo');\n        alasql(SAMPLE_SETUP);\n        status.textContent = 'Sample database loaded.';\n        renderTablesMeta();\n      } catch (e) {\n        status.textContent = 'Error initializing DB: ' + e.message;\n      }\n    }\n\n    // Run SQL statements from textarea\n    function runSQL() {\n      const sql = sqlInput.value.trim();\n      if (!sql) {\n        output.innerHTML = '<em>No SQL to run.</em>';\n        return;\n      }\n      // AlaSQL can execute multiple statements separated by semicolon\n      try {\n        // Use a unique DB to avoid collisions if re-running multiple times\n        alasql('USE demo');\n        // alasql returns result of the last statement. But we want to capture results\n        // for each statement. We'll split by semicolons in a naive way (works for most examples).\n        const statements = splitStatements(sql);\n        const results = [];\n        let lastMeta = null;\n        for (let stmt of statements) {\n          if (!stmt.trim()) continue;\n          const res = alasql(stmt);\n          results.push({ sql: stmt.trim(), result: res });\n          lastMeta = { stmt: stmt.trim(), rows: Array.isArray(res) ? res.length : res };\n        }\n        displayResults(results);\n        status.textContent = 'Executed ' + results.length + ' statement(s). ' + (lastMeta ? ('Last returned ' + (lastMeta.rows || 'N/A') + ' rows') : '');\n      } catch (err) {\n        output.innerHTML = '<div style=\"color:#b91c1c;\"><strong>Error:</strong> ' + escapeHtml(err.message) + '</div>';\n        status.textContent = 'Execution failed.';\n      }\n      renderTablesMeta();\n    }\n\n    // Naive statement splitter that handles semicolons. Good enough for this demo.\n    function splitStatements(sql) {\n      // Remove line comments starting with --\n      let cleaned = sql.replace(/--.*$/gm, '');\n      // For simplicity, split on semicolons not in quotes\n      const stmts = [];\n      let cur = '';\n      let inS = false, inD = false;\n      for (let i = 0; i < cleaned.length; i++) {\n        const ch = cleaned[i];\n        if (ch === \"'\" && !inD) inS = !inS;\n        if (ch === '\"' && !inS) inD = !inD;\n        if (ch === ';' && !inS && !inD) {\n          stmts.push(cur);\n          cur = '';\n        } else {\n          cur += ch;\n        }\n      }\n      if (cur.trim()) stmts.push(cur);\n      return stmts;\n    }\n\n    // Display results (for each statement)\n    function displayResults(results) {\n      // If single result and it's an array of rows, render a table. If multiple, render sections.\n      if (results.length === 1) {\n        renderResultBlock(results[0]);\n      } else {\n        let html = '';\n        for (let i = 0; i < results.length; i++) {\n          const r = results[i];\n          html += '<div style=\"margin-bottom:12px;\"><div style=\"font-weight:600;margin-bottom:6px;\">Statement ' + (i+1) + ':</div>';\n          html += '<div style=\"font-family: ui-monospace, Menlo, monospace; background:#f8fafc; padding:8px; border-radius:6px; border:1px solid #eef2f7;\">' + escapeHtml(r.sql) + '</div>';\n          html += '<div style=\"margin-top:8px;\">' + renderResultHtml(r.result) + '</div>';\n          html += '</div>';\n        }\n        output.innerHTML = html;\n      }\n    }\n\n    function renderResultBlock(item) {\n      const html = '<div style=\"font-family: ui-monospace, Menlo, monospace; background:#f8fafc; padding:8px; border-radius:6px; border:1px solid #eef2f7; margin-bottom:8px;\">' +\n        escapeHtml(item.sql) + '</div>' +\n        '<div>' + renderResultHtml(item.result) + '</div>';\n      output.innerHTML = html;\n    }\n\n    // Render AlaSQL result (could be array of objects or a scalar)\n    function renderResultHtml(res) {\n      if (Array.isArray(res)) {\n        if (res.length === 0) return '<em>No rows returned.</em>';\n        // Collect columns\n        const cols = Object.keys(res[0]);\n        let h = '<table><thead><tr>';\n        for (const c of cols) h += '<th>' + escapeHtml(c) + '</th>';\n        h += '</tr></thead><tbody>';\n        for (const row of res) {\n          h += '<tr>';\n          for (const c of cols) {\n            h += '<td>' + escapeHtml(cellToString(row[c])) + '</td>';\n          }\n          h += '</tr>';\n        }\n        h += '</tbody></table>';\n        return h;\n      } else if (typeof res === 'number' || typeof res === 'string' || typeof res === 'boolean') {\n        return '<div><strong>Result:</strong> ' + escapeHtml(String(res)) + '</div>';\n      } else if (res === null || res === undefined) {\n        return '<em>No result.</em>';\n      } else {\n        // Fallback: JSON stringify\n        return '<pre>' + escapeHtml(JSON.stringify(res, null, 2)) + '</pre>';\n      }\n    }\n\n    function cellToString(v) {\n      if (v === null || v === undefined) return '';\n      if (typeof v === 'object') return JSON.stringify(v);\n      return String(v);\n    }\n\n    function escapeHtml(s) {\n      return String(s).replace(/[&<>\"']/g, function(m) {\n        return ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[m]);\n      });\n    }\n\n    // Populate examples dropdown and list\n    function populateExamples() {\n      EXAMPLES.forEach((ex, idx) => {\n        const opt = document.createElement('option');\n        opt.value = idx;\n        opt.textContent = ex.name;\n        examplesSelect.appendChild(opt);\n\n        const div = document.createElement('div');\n        div.className = 'example';\n        div.innerHTML = '<strong>' + escapeHtml(ex.name) + '</strong><div style=\"font-size:12px;color:#475569;margin-top:6px;\">' + escapeHtml(ex.desc) + '</div>';\n        div.addEventListener('click', () => {\n          sqlInput.value = ex.sql;\n          window.scrollTo({top:0,behavior:'smooth'});\n        });\n        examplesList.appendChild(div);\n      });\n    }\n\n    // Insert selected example into editor\n    insertExampleBtn.addEventListener('click', () => {\n      const idx = examplesSelect.value;\n      if (idx === '') return;\n      const ex = EXAMPLES[Number(idx)];\n      sqlInput.value = ex.sql;\n    });\n\n    // Wire buttons\n    runBtn.addEventListener('click', runSQL);\n    resetBtn.addEventListener('click', () => {\n      resetDatabase();\n      output.innerHTML = '<em>Database reset to initial sample state.</em>';\n      status.textContent = 'Database reset.';\n    });\n    loadSamplesBtn.addEventListener('click', () => {\n      resetDatabase();\n      output.innerHTML = '<em>Sample data loaded.</em>';\n    });\n    clearBtn.addEventListener('click', () => { sqlInput.value = ''; output.innerHTML = '<em>Editor cleared.</em>'; status.textContent = ''; });\n\n    showTablesBtn.addEventListener('click', () => {\n      try {\n        alasql('USE demo');\n        const tables = alasql('SHOW TABLES');\n        let html = '<div style=\"font-weight:600;margin-bottom:8px;\">Tables</div>';\n        for (const t of tables) {\n          html += '<div style=\"margin-bottom:6px;\"><button class=\"small\" onclick=\"showTable(\\'' + t.tableid + '\\')\">' + escapeHtml(t.tableid) + '</button></div>';\n        }\n        html += '<div style=\"margin-top:8px;color:#475569;font-size:13px;\">Click a table to display its rows.</div>';\n        output.innerHTML = html;\n      } catch (e) {\n        output.innerHTML = '<div style=\"color:#b91c1c;\"><strong>Error:</strong> ' + escapeHtml(e.message) + '</div>';\n      }\n    });\n\n    // Export DB to JSON\n    exportBtn.addEventListener('click', () => {\n      try {\n        alasql('USE demo');\n        const tables = alasql('SHOW TABLES');\n        const dump = {};\n        for (const t of tables) {\n          dump[t.tableid] = alasql('SELECT * FROM ' + t.tableid);\n        }\n        const blob = new Blob([JSON.stringify(dump, null, 2)], {type: 'application/json'});\n        const url = URL.createObjectURL(blob);\n        const a = document.createElement('a');\n        a.href = url;\n        a.download = 'db_export.json';\n        document.body.appendChild(a);\n        a.click();\n        a.remove();\n        URL.revokeObjectURL(url);\n        status.textContent = 'Exported DB as JSON.';\n      } catch (e) {\n        status.textContent = 'Export failed: ' + e.message;\n      }\n    });\n\n    // Helper to render tables meta\n    function renderTablesMeta() {\n      try {\n        alasql('USE demo');\n        const tables = alasql('SHOW TABLES');\n        const names = tables.map(t => t.tableid).join(', ');\n        document.getElementById('tablesMeta').textContent = names ? names : 'No tables';\n      } catch (e) {\n        document.getElementById('tablesMeta').textContent = 'Error retrieving tables';\n      }\n    }\n\n    // Expose showTable for button generated earlier\n    window.showTable = function(table) {\n      try {\n        alasql('USE demo');\n        const rows = alasql('SELECT * FROM ' + table);\n        output.innerHTML = '<div style=\"font-weight:600;margin-bottom:8px;\">' + escapeHtml(table) + ' (' + rows.length + ' rows)</div>' + renderResultHtml(rows);\n      } catch (e) {\n        output.innerHTML = '<div style=\"color:#b91c1c;\"><strong>Error:</strong> ' + escapeHtml(e.message) + '</div>';\n      }\n    };\n\n    // Initialize page\n    (function init() {\n      populateExamples();\n      resetDatabase();\n      // Seed the editor with an example\n      sqlInput.value = EXAMPLES[3].sql; // JOIN example\n      output.innerHTML = '<em>Try the preloaded example or choose one from the list.</em>';\n    })();\n\n    // Small UX: allow Ctrl+Enter to run\n    sqlInput.addEventListener('keydown', (e) => {\n      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {\n        e.preventDefault();\n        runSQL();\n      }\n    });\n\n    // Provide basic description of concept under status on load\n    status.textContent = 'Ready — select an example and press \"Run SQL\" (or Ctrl+Enter).';\n  </script>\n</body>\n</html>"
  },
