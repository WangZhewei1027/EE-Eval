    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Deque (Double-Ended Queue) Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1rem;\n    max-width: 600px;\n  }\n  h1 {\n    text-align: center;\n  }\n  #deque {\n    display: flex;\n    gap: 0.5rem;\n    min-height: 50px;\n    margin: 1rem 0;\n    border: 2px solid #4a90e2;\n    border-radius: 6px;\n    padding: 0.5rem;\n    background: #e6f0fa;\n  }\n  .item {\n    background: #4a90e2;\n    color: white;\n    padding: 0.5rem 0.8rem;\n    border-radius: 4px;\n    font-weight: bold;\n    min-width: 30px;\n    text-align: center;\n  }\n  label, input, button {\n    font-size: 1rem;\n  }\n  .controls {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 1rem 1.5rem;\n    justify-content: center;\n    margin-bottom: 1rem;\n  }\n  .control-group {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n  }\n  button {\n    background-color: #4a90e2;\n    border: none;\n    color: white;\n    border-radius: 4px;\n    padding: 0.4rem 1rem;\n    cursor: pointer;\n    transition: background-color 0.3s ease;\n  }\n  button:hover {\n    background-color: #357abd;\n  }\n  #log {\n    background: #f9f9f9;\n    border: 1px solid #999;\n    border-radius: 4px;\n    padding: 1rem;\n    height: 140px;\n    overflow-y: auto;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n  footer {\n    text-align: center;\n    margin-top: 2rem;\n    color: #666;\n    font-size: 0.9rem;\n  }\n</style>\n</head>\n<body>\n<h1>Deque (Double-Ended Queue) Demo</h1>\n\n<div class=\"controls\">\n  <div class=\"control-group\">\n    <label for=\"inputValue\">Value:</label>\n    <input type=\"text\" id=\"inputValue\" placeholder=\"Enter value\" />\n  </div>\n  <div class=\"control-group\">\n    <button id=\"addFrontBtn\" title=\"Add value to the front\">Add Front</button>\n    <button id=\"addBackBtn\" title=\"Add value to the back\">Add Back</button>\n  </div>\n  <div class=\"control-group\">\n    <button id=\"removeFrontBtn\" title=\"Remove value from front\">Remove Front</button>\n    <button id=\"removeBackBtn\" title=\"Remove value from back\">Remove Back</button>\n  </div>\n  <div class=\"control-group\">\n    <button id=\"clearBtn\" title=\"Clear the deque\">Clear Deque</button>\n  </div>\n</div>\n\n<h3>Current Deque:</h3>\n<div id=\"deque\" aria-live=\"polite\" aria-label=\"Deque contents\"></div>\n\n<h3>Operations Log:</h3>\n<div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<script>\n  // Deque class implementing double-ended queue functionality\n  class Deque {\n    constructor() {\n      this.items = [];\n    }\n    addFront(element) {\n      this.items.unshift(element);\n    }\n    addBack(element) {\n      this.items.push(element);\n    }\n    removeFront() {\n      return this.items.shift();\n    }\n    removeBack() {\n      return this.items.pop();\n    }\n    clear() {\n      this.items = [];\n    }\n    toArray() {\n      return this.items.slice();\n    }\n    isEmpty() {\n      return this.items.length === 0;\n    }\n    size() {\n      return this.items.length;\n    }\n  }\n\n  // Initialization\n  const deque = new Deque();\n  const dequeDiv = document.getElementById('deque');\n  const logDiv = document.getElementById('log');\n  const inputValue = document.getElementById('inputValue');\n\n  function log(message) {\n    const time = new Date().toLocaleTimeString();\n    logDiv.textContent += `[${time}] ${message}\\n`;\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n\n  function renderDeque() {\n    dequeDiv.innerHTML = ''; // Clear current display\n    const items = deque.toArray();\n\n    if (items.length === 0) {\n      const emptyMsg = document.createElement('em');\n      emptyMsg.textContent = 'Deque is empty';\n      emptyMsg.style.color = '#777';\n      dequeDiv.appendChild(emptyMsg);\n      return;\n    }\n\n    items.forEach((item, index) => {\n      const span = document.createElement('div');\n      span.className = 'item';\n      span.textContent = item;\n      span.title = `Index: ${index}`;\n      dequeDiv.appendChild(span);\n    });\n  }\n\n  // Button click handlers\n  document.getElementById('addFrontBtn').addEventListener('click', () => {\n    const val = inputValue.value.trim();\n    if (val === '') {\n      alert('Please enter a value to add to the front.');\n      inputValue.focus();\n      return;\n    }\n    deque.addFront(val);\n    log(`Added '${val}' to front`);\n    renderDeque();\n    inputValue.value = '';\n    inputValue.focus();\n  });\n\n  document.getElementById('addBackBtn').addEventListener('click', () => {\n    const val = inputValue.value.trim();\n    if (val === '') {\n      alert('Please enter a value to add to the back.');\n      inputValue.focus();\n      return;\n    }\n    deque.addBack(val);\n    log(`Added '${val}' to back`);\n    renderDeque();\n    inputValue.value = '';\n    inputValue.focus();\n  });\n\n  document.getElementById('removeFrontBtn').addEventListener('click', () => {\n    if (deque.isEmpty()) {\n      alert('Deque is empty, cannot remove from front.');\n      return;\n    }\n    const removed = deque.removeFront();\n    log(`Removed '${removed}' from front`);\n    renderDeque();\n  });\n\n  document.getElementById('removeBackBtn').addEventListener('click', () => {\n    if (deque.isEmpty()) {\n      alert('Deque is empty, cannot remove from back.');\n      return;\n    }\n    const removed = deque.removeBack();\n    log(`Removed '${removed}' from back`);\n    renderDeque();\n  });\n\n  document.getElementById('clearBtn').addEventListener('click', () => {\n    deque.clear();\n    log('Deque cleared');\n    renderDeque();\n  });\n\n  // Initial rendering\n  renderDeque();\n</script>\n<footer>\n  &copy; 2024 Deque Concept Demo\n</footer>\n</body>\n</html>"
