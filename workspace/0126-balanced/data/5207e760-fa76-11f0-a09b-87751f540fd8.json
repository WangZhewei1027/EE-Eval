    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Dynamic Array</title>\n    <style>\n        #dynamic-array {\n            width: 500px;\n            height: 200px;\n            border: 1px solid #ccc;\n            padding: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Dynamic Array</h1>\n    <button id=\"add-btn\">Add Element</button>\n    <button id=\"remove-btn\">Remove Element</button>\n    <button id=\"update-btn\">Update Element</button>\n    <button id=\"clear-btn\">Clear Array</button>\n    <div id=\"array-container\"></div>\n\n    <script>\n        let dynamicArray = [];\n\n        document.getElementById('add-btn').addEventListener('click', function() {\n            let element = document.createElement('button');\n            element.textContent = 'Dynamic Array ' + dynamicArray.length + ' elements';\n            element.onclick = function() {\n                dynamicArray.push(element.textContent);\n                updateDisplay();\n            };\n            document.body.appendChild(element);\n        });\n\n        document.getElementById('remove-btn').addEventListener('click', function() {\n            let index = parseInt(document.getElementById('remove-index').value);\n            if (index >= 0 && index < dynamicArray.length) {\n                dynamicArray.splice(index, 1);\n                updateDisplay();\n            } else {\n                alert('Invalid index');\n            }\n        });\n\n        document.getElementById('update-btn').addEventListener('click', function() {\n            let index = parseInt(document.getElementById('update-index').value);\n            if (index >= 0 && index < dynamicArray.length) {\n                document.getElementById('update-value').value = dynamicArray[index];\n                updateDisplay();\n            } else {\n                alert('Invalid index');\n            }\n        });\n\n        document.getElementById('clear-btn').addEventListener('click', function() {\n            dynamicArray = [];\n            updateDisplay();\n        });\n\n        function updateDisplay() {\n            let display = document.getElementById('array-container');\n            display.innerHTML = '';\n            dynamicArray.forEach(function(element) {\n                let div = document.createElement('div');\n                div.textContent = element;\n                div.onclick = function() {\n                    element.parentNode.removeChild(element);\n                    updateDisplay();\n                };\n                display.appendChild(div);\n            });\n        }\n\n        let removeIndex = 0;\n        let updateIndex = 0;\n        let updateValue = '';\n\n        function addElement() {\n            dynamicArray.push(document.createElement('button'));\n            updateDisplay();\n        }\n\n        function removeElement() {\n            if (removeIndex < dynamicArray.length) {\n                document.getElementById('remove-index').value = removeIndex;\n                updateDisplay();\n            } else {\n                alert('No elements to remove');\n            }\n        }\n\n        function updateElement() {\n            if (updateIndex < dynamicArray.length) {\n                document.getElementById('update-index').value = updateIndex;\n                document.getElementById('update-value').value = dynamicArray[updateIndex];\n                updateDisplay();\n            } else {\n                alert('No elements to update');\n            }\n        }\n\n        addElement();\n    </script>\n</body>\n</html>"
