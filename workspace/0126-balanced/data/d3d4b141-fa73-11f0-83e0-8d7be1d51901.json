    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Queue Demonstration</title>\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --accent:#4f46e5;\n      --muted:#94a3b8;\n      --ok:#10b981;\n      --danger:#ef4444;\n      --glass: rgba(255,255,255,0.03);\n    }\n    *{box-sizing:border-box;font-family:Inter,ui-sans-serif,system-ui,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,#071024 0%, #071a2b 100%);color:#e6eef8;}\n    .app{\n      max-width:980px;margin:28px auto;padding:22px;background:linear-gradient(180deg,var(--card), #071421);\n      border-radius:12px;box-shadow:0 8px 30px rgba(1,6,16,0.7);border:1px solid rgba(255,255,255,0.03);\n    }\n    h1{margin:0 0 8px;font-size:20px;color:var(--accent); letter-spacing:0.2px}\n    p.lead{margin:0 0 18px;color:var(--muted);font-size:13px}\n    .controls{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:14px}\n    input[type=\"text\"]{padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,0.04);background:var(--glass);color:inherit;min-width:160px}\n    button{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));color:#e6eef8;border:1px solid rgba(255,255,255,0.04);padding:8px 12px;border-radius:8px;cursor:pointer}\n    button.primary{background:linear-gradient(180deg,var(--accent),#3f3ad9);border:none}\n    button.ghost{background:transparent;border:1px dashed rgba(255,255,255,0.03)}\n    button:disabled{opacity:0.45;cursor:not-allowed}\n    .status{margin-left:auto;display:flex;gap:8px;align-items:center}\n    .pill{padding:6px 10px;border-radius:999px;background:rgba(255,255,255,0.03);font-size:13px;color:var(--muted);border:1px solid rgba(255,255,255,0.02)}\n    .visual{\n      margin-top:18px;padding:18px;border-radius:10px;background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);\n      min-height:160px;display:flex;flex-direction:column;gap:12px;border:1px solid rgba(255,255,255,0.02)\n    }\n    .line{height:1px;background:rgba(255,255,255,0.02);margin:2px 0;border-radius:1px}\n    .queue-wrap{display:flex;gap:10px;align-items:center;flex-wrap:nowrap;overflow:auto;padding:8px 6px}\n    .node{\n      min-width:68px;height:68px;border-radius:10px;background:linear-gradient(180deg,#0b1228,#061025);display:flex;flex-direction:column;align-items:center;justify-content:center;\n      border:1px solid rgba(255,255,255,0.03);position:relative;box-shadow:0 6px 18px rgba(2,6,23,0.6);\n      transition:transform 300ms, opacity 300ms;\n      color:#e6eef8;font-weight:600;font-size:18px;\n    }\n    .node.small{min-width:54px;height:54px;font-size:15px}\n    .label{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.4);font-size:12px;padding:3px 8px;border-radius:999px;color:var(--muted);border:1px solid rgba(255,255,255,0.02)}\n    .pointer{font-size:12px;color:var(--muted);position:absolute;bottom:-18px;left:50%;transform:translateX(-50%);white-space:nowrap}\n    .front{border:2px solid rgba(79,70,229,0.95);box-shadow:0 10px 26px rgba(79,70,229,0.08)}\n    .rear{border:2px solid rgba(16,185,129,0.12)}\n    .toast{position:fixed;right:18px;bottom:18px;background:rgba(0,0,0,0.6);padding:10px 14px;border-radius:10px;border:1px solid rgba(255,255,255,0.03);color:#e6eef8}\n    .info{font-size:13px;color:var(--muted)}\n    .complex{display:flex;gap:14px;flex-wrap:wrap;margin-top:8px}\n    .card-mini{background:rgba(255,255,255,0.02);padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);font-size:13px;color:var(--muted)}\n    .ops{display:flex;gap:8px;flex-wrap:wrap}\n    .controls-row{display:flex;gap:8px;align-items:center;flex-wrap:wrap;width:100%}\n    .grow{flex:1}\n    /* small-screen tweaks */\n    @media (max-width:640px){\n      .queue-wrap{padding:8px}\n      .node{min-width:60px;height:60px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"app\" role=\"main\" aria-labelledby=\"title\">\n    <h1 id=\"title\">Queue — FIFO Data Structure</h1>\n    <p class=\"lead\">A Queue is First-In-First-Out: elements are added at the rear and removed from the front. Use the controls below to interact with a live Queue implementation and watch the visualization.</p>\n\n    <div class=\"controls\">\n      <div class=\"controls-row\" style=\"gap:8px;\">\n        <input id=\"valueInput\" type=\"text\" placeholder=\"Value to enqueue (string or number)\" />\n        <button id=\"enqueueBtn\" class=\"primary\">Enqueue</button>\n        <button id=\"dequeueBtn\">Dequeue</button>\n        <button id=\"peekBtn\" class=\"ghost\">Peek</button>\n        <button id=\"clearBtn\">Clear</button>\n        <button id=\"randomBtn\" title=\"Enqueue random value\">Random</button>\n        <div class=\"status\">\n          <div class=\"pill\" id=\"sizePill\">Size: 0</div>\n          <div class=\"pill\" id=\"peekPill\">Peek: —</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"visual\" aria-live=\"polite\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;gap:10px\">\n        <div class=\"info\">Visualization: front (left) → rear (right)</div>\n        <div class=\"complex\">\n          <div class=\"card-mini\"><strong>Enqueue:</strong> O(1) amortized</div>\n          <div class=\"card-mini\"><strong>Dequeue:</strong> O(1)</div>\n          <div class=\"card-mini\"><strong>Peek:</strong> O(1)</div>\n        </div>\n      </div>\n\n      <div class=\"line\"></div>\n\n      <div class=\"queue-wrap\" id=\"queueWrap\" aria-label=\"Queue visualization\">\n        <!-- nodes will go here -->\n      </div>\n\n      <div class=\"line\"></div>\n\n      <div style=\"display:flex;gap:12px;align-items:center;flex-wrap:wrap;\">\n        <div class=\"info\">Implementation: Array-based queue (internally uses a circular buffer to avoid O(n) shifts).</div>\n        <div style=\"margin-left:auto;color:var(--muted);font-size:13px\">Try enqueuing multiple values then dequeue to watch the animation.</div>\n      </div>\n    </div>\n  </div>\n\n  <div id=\"toast\" class=\"toast\" style=\"display:none\"></div>\n\n  <script>\n    // Simple queue implemented with circular buffer for O(1) enqueue/dequeue\n    class Queue {\n      constructor(capacity = 8){\n        this._cap = Math.max(8, capacity);\n        this._data = new Array(this._cap);\n        this._head = 0; // index of front element\n        this._size = 0;\n      }\n      size(){ return this._size; }\n      isEmpty(){ return this._size === 0; }\n      _resize(newCap){\n        const arr = new Array(newCap);\n        for(let i=0;i<this._size;i++){\n          arr[i] = this._data[(this._head + i) % this._cap];\n        }\n        this._data = arr;\n        this._cap = newCap;\n        this._head = 0;\n      }\n      enqueue(value){\n        if(this._size === this._cap){\n          this._resize(this._cap * 2);\n        }\n        const idx = (this._head + this._size) % this._cap;\n        this._data[idx] = value;\n        this._size++;\n      }\n      dequeue(){\n        if(this.isEmpty()) return undefined;\n        const val = this._data[this._head];\n        this._data[this._head] = undefined; // help GC\n        this._head = (this._head + 1) % this._cap;\n        this._size--;\n        // shrink when quarter full to save memory\n        if(this._cap > 8 && this._size <= this._cap / 4){\n          this._resize(Math.max(8, Math.floor(this._cap / 2)));\n        }\n        return val;\n      }\n      peek(){\n        if(this.isEmpty()) return undefined;\n        return this._data[this._head];\n      }\n      clear(){\n        this._data = new Array(8);\n        this._cap = 8;\n        this._head = 0;\n        this._size = 0;\n      }\n      // return array of current elements in order from front to rear\n      toArray(){\n        const out = [];\n        for(let i=0;i<this._size;i++){\n          out.push(this._data[(this._head + i) % this._cap]);\n        }\n        return out;\n      }\n    }\n\n    // UI wiring\n    const q = new Queue(8);\n    const queueWrap = document.getElementById('queueWrap');\n    const valueInput = document.getElementById('valueInput');\n    const enqueueBtn = document.getElementById('enqueueBtn');\n    const dequeueBtn = document.getElementById('dequeueBtn');\n    const peekBtn = document.getElementById('peekBtn');\n    const clearBtn = document.getElementById('clearBtn');\n    const randomBtn = document.getElementById('randomBtn');\n    const sizePill = document.getElementById('sizePill');\n    const peekPill = document.getElementById('peekPill');\n    const toast = document.getElementById('toast');\n\n    // helpers\n    function showToast(msg, timeout=1800){\n      toast.textContent = msg;\n      toast.style.display = 'block';\n      clearTimeout(showToast._t);\n      showToast._t = setTimeout(()=>{ toast.style.opacity = '0'; setTimeout(()=>toast.style.display='none',300); toast.style.opacity='1'; }, timeout);\n    }\n\n    function render(){\n      // clear nodes\n      const items = q.toArray();\n      queueWrap.innerHTML = '';\n      if(items.length === 0){\n        const emptyNote = document.createElement('div');\n        emptyNote.style.color = 'var(--muted)';\n        emptyNote.style.padding = '24px';\n        emptyNote.textContent = 'Queue is empty. Enqueue an item to get started.';\n        queueWrap.appendChild(emptyNote);\n      } else {\n        items.forEach((val, i) => {\n          const node = document.createElement('div');\n          node.className = 'node' + (items.length>12? ' small' : '');\n          node.setAttribute('aria-label', 'Queue element ' + i);\n          node.textContent = String(val);\n          if(i === 0){\n            const lbl = document.createElement('div');\n            lbl.className = 'label';\n            lbl.textContent = 'front';\n            node.appendChild(lbl);\n            const ptr = document.createElement('div');\n            ptr.className = 'pointer';\n            ptr.style.color = 'var(--accent)';\n            ptr.textContent = 'dequeue from here';\n            node.appendChild(ptr);\n            node.classList.add('front');\n          }\n          if(i === items.length-1){\n            const lbl2 = document.createElement('div');\n            lbl2.style.position = 'absolute';\n            lbl2.style.top = '8px';\n            lbl2.style.right = '8px';\n            lbl2.style.fontSize = '11px';\n            lbl2.style.color = 'var(--muted)';\n            lbl2.textContent = 'rear';\n            node.appendChild(lbl2);\n            node.classList.add('rear');\n          }\n          queueWrap.appendChild(node);\n        });\n      }\n      sizePill.textContent = 'Size: ' + q.size();\n      const p = q.peek();\n      peekPill.textContent = 'Peek: ' + (p === undefined ? '—' : String(p));\n      // enable/disable buttons\n      dequeueBtn.disabled = q.isEmpty();\n      peekBtn.disabled = q.isEmpty();\n      clearBtn.disabled = q.isEmpty();\n    }\n\n    // animations for enqueue and dequeue\n    function animateEnqueue(value){\n      // perform enqueue logically first (so internal buffer reflects correct order),\n      // then animate adding a node at the end with fade-in.\n      q.enqueue(value);\n      render(); // quick render to create elements\n      const nodes = queueWrap.querySelectorAll('.node');\n      const last = nodes[nodes.length - 1];\n      if(last){\n        last.style.transform = 'translateY(-12px)';\n        last.style.opacity = '0';\n        requestAnimationFrame(()=>{\n          last.style.transition = 'transform 320ms cubic-bezier(.2,.9,.2,1), opacity 320ms';\n          last.style.transform = 'translateY(0)';\n          last.style.opacity = '1';\n        });\n      }\n      showToast('Enqueued: ' + String(value));\n    }\n\n    function animateDequeue(){\n      if(q.isEmpty()){\n        showToast('Queue is empty');\n        return;\n      }\n      // visually remove the front element first, then dequeue logically after animation\n      const nodes = queueWrap.querySelectorAll('.node');\n      const first = nodes[0];\n      if(first){\n        first.style.transition = 'transform 320ms ease, opacity 320ms ease';\n        first.style.transform = 'translateX(-18px) scale(0.95)';\n        first.style.opacity = '0';\n        setTimeout(()=>{\n          const val = q.dequeue();\n          render();\n          showToast('Dequeued: ' + String(val));\n        }, 320);\n      } else {\n        const val = q.dequeue();\n        render();\n        showToast('Dequeued: ' + String(val));\n      }\n    }\n\n    // event listeners\n    enqueueBtn.addEventListener('click', ()=>{\n      const val = valueInput.value.trim();\n      if(val === ''){\n        showToast('Enter a value to enqueue');\n        valueInput.focus();\n        return;\n      }\n      animateEnqueue(val);\n      valueInput.value = '';\n      valueInput.focus();\n    });\n\n    valueInput.addEventListener('keydown', (e)=>{\n      if(e.key === 'Enter') enqueueBtn.click();\n    });\n\n    dequeueBtn.addEventListener('click', ()=>{\n      animateDequeue();\n    });\n\n    peekBtn.addEventListener('click', ()=>{\n      const p = q.peek();\n      if(p === undefined) showToast('Queue is empty');\n      else showToast('Peek: ' + String(p));\n    });\n\n    clearBtn.addEventListener('click', ()=>{\n      q.clear();\n      render();\n      showToast('Queue cleared');\n    });\n\n    randomBtn.addEventListener('click', ()=>{\n      const sample = ['A','B','C','1','2','3','🍎','🤖','X','Y','Z','foo','bar','42'];\n      const val = sample[Math.floor(Math.random()*sample.length)];\n      animateEnqueue(val);\n    });\n\n    // initial render\n    render();\n\n    // Accessibility: keyboard shortcuts\n    document.addEventListener('keydown', (e)=>{\n      if(e.ctrlKey && e.key.toLowerCase() === 'e'){\n        e.preventDefault();\n        valueInput.focus();\n      } else if(e.key === 'Delete'){\n        dequeueBtn.focus();\n        dequeueBtn.click();\n      }\n    });\n\n    // Small demo script: prefill some values on load (commented out)\n    // ['first','second','third'].forEach(v => q.enqueue(v)); render();\n\n    // comments for learners (visible in source):\n    /*\n      Key points shown by this demo:\n      - Queue is FIFO: first element you enqueue is the first you dequeue.\n      - Here we implemented a circular buffer to keep enqueue/dequeue O(1) without shifting elements.\n      - The internal array resizes (grows/shrinks) similar to many dynamic array implementations.\n    */\n  </script>\n</body>\n</html>"
  },
