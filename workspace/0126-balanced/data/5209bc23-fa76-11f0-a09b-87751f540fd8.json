    "content": "<html>\n<head>\n    <title>Sliding Window</title>\n    <style>\n        #window {\n            width: 400px;\n            height: 200px;\n            border: 1px solid black;\n            padding: 10px;\n            margin: 20px auto;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"window\"></div>\n    <script>\n        let windowSize = 20;\n        let elements = [\"apple\", \"banana\", \"cherry\", \"date\", \"elderberry\"];\n        let currentElement = 0;\n        let windowStart = 0;\n        let windowEnd = 0;\n        let result = [];\n\n        function slidingWindow() {\n            if (currentElement >= elements.length) {\n                return;\n            }\n\n            let windowStart = Math.max(windowStart, currentElement - windowSize);\n            let windowEnd = Math.min(windowEnd, currentElement + windowSize);\n            result.push(elements[currentElement]);\n\n            if (windowStart > windowEnd) {\n                windowStart = 0;\n                windowEnd = currentElement - windowSize;\n            }\n\n            currentElement++;\n        }\n\n        slidingWindow();\n\n        console.log(result);\n    </script>\n</body>\n</html>"
