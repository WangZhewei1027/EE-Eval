  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>NoSQL Concept Playground</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    :root{--bg:#0f1720;--panel:#0b1220;--accent:#07c;--muted:#9aa6b2;--card:#071027}\n    body{font-family:Inter,system-ui,Segoe UI,Roboto,\"Helvetica Neue\",Arial;background:linear-gradient(180deg,#071022 0%, #071029 60%, #071726 100%);color:#e6eef6;margin:0;padding:18px;}\n    header{display:flex;gap:16px;align-items:center;margin-bottom:14px}\n    h1{font-size:20px;margin:0}\n    .container{display:grid;grid-template-columns:320px 1fr 320px;gap:14px;align-items:start}\n    .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);border:1px solid rgba(255,255,255,0.03);padding:12px;border-radius:8px;box-shadow:0 6px 18px rgba(2,6,23,0.6)}\n    .menu{display:flex;flex-direction:column;gap:8px}\n    button,select,input,textarea{font-family:inherit}\n    .store-btn{display:flex;justify-content:space-between;align-items:center;padding:8px 10px;border-radius:6px;background:transparent;border:1px solid rgba(255,255,255,0.03);color:var(--muted);cursor:pointer}\n    .store-btn.active{background:linear-gradient(90deg, rgba(7,125,255,0.12), rgba(7,200,255,0.06));border-color:rgba(7,125,255,0.3);color:#dff3ff}\n    .info{font-size:13px;color:var(--muted);line-height:1.45}\n    .section{margin-bottom:12px}\n    label{display:block;font-size:13px;color:var(--muted);margin-bottom:6px}\n    input[type=\"text\"], textarea, select{width:100%;padding:8px;border-radius:6px;background:transparent;border:1px solid rgba(255,255,255,0.03);color:inherit}\n    textarea{min-height:74px;resize:vertical}\n    .row{display:flex;gap:8px}\n    .row > *{flex:1}\n    .list{max-height:360px;overflow:auto;padding:6px;border-radius:6px;border:1px dashed rgba(255,255,255,0.02);background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00))}\n    .item{padding:8px;border-radius:6px;margin-bottom:8px;background:rgba(255,255,255,0.01);border:1px solid rgba(255,255,255,0.02)}\n    .muted{color:var(--muted);font-size:13px}\n    .small{font-size:12px;color:var(--muted)}\n    .log{font-family:monospace;background:#02101a;padding:8px;border-radius:6px;max-height:220px;overflow:auto;border:1px solid rgba(255,255,255,0.02);}\n    .controls{display:flex;gap:8px;flex-wrap:wrap}\n    .btn{padding:8px 10px;border-radius:6px;border:0;background:var(--accent);color:#022940;cursor:pointer}\n    .btn.ghost{background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted)}\n    pre{white-space:pre-wrap;font-family:monospace;font-size:13px}\n    .grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px}\n    footer{margin-top:14px;font-size:12px;color:var(--muted)}\n    .badge{font-size:12px;padding:4px 8px;border-radius:999px;background:rgba(255,255,255,0.03);color:var(--muted)}\n    .kpi{display:flex;gap:8px;align-items:center}\n    .kpi div{font-size:13px}\n  </style>\n</head>\n<body>\n  <header>\n    <h1>NoSQL Concept Playground</h1>\n    <div class=\"muted\">Interactive single-file demo: Document, Key-Value, Column-Family, Graph</div>\n  </header>\n\n  <div class=\"container\">\n    <aside class=\"panel\">\n      <div class=\"section\">\n        <div class=\"muted\">Choose a NoSQL model</div>\n        <div class=\"menu\" id=\"storeMenu\">\n          <button class=\"store-btn active\" data-store=\"document\">Document Store (JSON)</button>\n          <button class=\"store-btn\" data-store=\"kv\">Key-Value Store</button>\n          <button class=\"store-btn\" data-store=\"column\">Column-Family</button>\n          <button class=\"store-btn\" data-store=\"graph\">Graph DB</button>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <div class=\"muted\">Quick info</div>\n        <div id=\"storeInfo\" class=\"info\" style=\"margin-top:8px\">\n          Document stores hold JSON-like documents. Flexible schema, nested objects and arrays. Examples: MongoDB, CouchDB.\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <div class=\"muted\">Settings</div>\n        <div style=\"margin-top:8px\" class=\"small\">Replication / Consistency</div>\n        <div class=\"row\" style=\"margin-top:6px\">\n          <label style=\"margin:0\">Simulate eventual consistency (document store)</label>\n        </div>\n        <div class=\"row\" style=\"margin-top:6px\">\n          <input type=\"checkbox\" id=\"evConsistent\"> <label for=\"evConsistent\" class=\"small\" style=\"margin-left:8px\">Enable replication delay</label>\n        </div>\n        <div class=\"row\" style=\"margin-top:6px\">\n          <label class=\"small\">Replication delay (ms)</label>\n          <input type=\"text\" id=\"repDelay\" value=\"1500\">\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <div class=\"muted\">Activity</div>\n        <div id=\"log\" class=\"log\" style=\"margin-top:8px\"></div>\n      </div>\n\n      <footer>\n        Tip: change data schemas, add indices, and run simple queries to see core NoSQL principles.\n      </footer>\n    </aside>\n\n    <main class=\"panel\" id=\"mainPanel\">\n      <!-- Dynamic content appears here -->\n    </main>\n\n    <aside class=\"panel\">\n      <div class=\"section\">\n        <div class=\"muted\">Performance snapshot</div>\n        <div class=\"kpi\" style=\"margin-top:8px\">\n          <div class=\"badge\">Docs: <span id=\"k_docs\">0</span></div>\n          <div class=\"badge\">KV entries: <span id=\"k_kv\">0</span></div>\n          <div class=\"badge\">Rows: <span id=\"k_rows\">0</span></div>\n          <div class=\"badge\">Nodes: <span id=\"k_nodes\">0</span></div>\n        </div>\n      </div>\n\n      <div class=\"section\" style=\"margin-top:12px\">\n        <div class=\"muted\">About this demo</div>\n        <div class=\"info\" style=\"margin-top:8px;font-size:13px\">\n          This single-page app simulates several NoSQL models in memory. It's for learning: no data is persisted to disk.\n        </div>\n      </div>\n    </aside>\n  </div>\n\n  <script>\n    /************************************************************************\n     * In-memory NoSQL concept implementations + UI\n     ************************************************************************/\n\n    // Helpers\n    const $ = (sel, el=document) => el.querySelector(sel);\n    const $$ = (sel, el=document) => Array.from(el.querySelectorAll(sel));\n    const logEl = $('#log');\n    function log(...args){ const t = new Date().toLocaleTimeString(); logEl.innerText = [t, ...args].join(' | ') + '\\\\n' + logEl.innerText; }\n\n    // Global stores\n    const docStore = {\n      collections: {}, // name -> {docs: Map(_id -> doc), indices: {field: Map(value -> Set(ids))}, replicas: []}\n      createCollection(name){\n        if(this.collections[name]) return this.collections[name];\n        this.collections[name] = {docs: new Map(), indices: {}, replicas: new Map()};\n        return this.collections[name];\n      }\n    };\n\n    const kvStore = new Map(); // key-> {value, ttl, created}\n    const columnStore = new Map(); // rowKey -> {family: {qualifier: value}}\n    const graph = { nodes: new Map(), edges: new Map(), nextNodeId: 1, nextEdgeId: 1 };\n\n    // Bootstrap sample data\n    (function initSample(){\n      const users = docStore.createCollection('users');\n      const sample = [\n        {name:'Alice', age:29, tags:['admin','sales'], address:{city:'Seattle'}},\n        {name:'Bob', age:34, tags:['engineering'], projects:[{name:'x',budget:1200}]},\n        {name:'Carol', age:41, active:false, address:{city:'Austin',zip:78701}},\n      ];\n      sample.forEach(s => {\n        const id = 'd' + Math.random().toString(36).substring(2,9);\n        users.docs.set(id, JSON.parse(JSON.stringify(s)));\n        users.docs.get(id)._id = id;\n      });\n\n      // some KV\n      kvStore.set('site:title', 'Demo NoSQL Playground');\n      kvStore.set('cache:user:Alice', JSON.stringify({lastSeen:Date.now()}));\n\n      // column-family rows\n      columnStore.set('row1', {profile: {name:'Zoe',age:'27'}, metrics: {visits:'12'}});\n      columnStore.set('row2', {profile: {name:'Yan'}, metrics: {visits:'3',bounce:'0.8'}});\n\n      // graph small network\n      const n1 = addGraphNode('Alice',{role:'admin'});\n      const n2 = addGraphNode('Bob',{role:'engineer'});\n      const n3 = addGraphNode('Carla',{role:'analyst'});\n      addGraphEdge(n1,n2,'works_with',{since:2019});\n      addGraphEdge(n2,n3,'mentors',{since:2021});\n    })();\n\n    // Utilities for document queries (support simple Mongo-like-ish operators)\n    function matchQuery(doc, query){\n      // query is an object: value equality or operator object\n      if(!query || typeof query !== 'object') return false;\n      for(const k of Object.keys(query)){\n        const qv = query[k];\n        const dv = getPath(doc, k);\n        if(typeof qv === 'object' && qv !== null && !Array.isArray(qv)){\n          // operators\n          for(const op of Object.keys(qv)){\n            const vv = qv[op];\n            if(op === '$gt'){ if(!(dv > vv)) return false; }\n            else if(op === '$lt'){ if(!(dv < vv)) return false; }\n            else if(op === '$gte'){ if(!(dv >= vv)) return false; }\n            else if(op === '$lte'){ if(!(dv <= vv)) return false; }\n            else if(op === '$ne'){ if(dv === vv) return false; }\n            else if(op === '$in'){ if(!Array.isArray(vv) || !vv.includes(dv)) return false; }\n            else if(op === '$exists'){ if((dv === undefined) === (!vv)) return false; }\n            else return false;\n          }\n        } else {\n          // equality (supports nested path)\n          if(Array.isArray(qv)){\n            // match if every element in qv is in dv (if dv array)\n            if(Array.isArray(dv)){\n              for(const item of qv) if(!dv.includes(item)) return false;\n            } else return false;\n          } else {\n            if(dv === undefined) return false;\n            if(String(dv) !== String(qv)) return false;\n          }\n        }\n      }\n      return true;\n    }\n    function getPath(obj, path){\n      // simple dot path\n      const parts = path.split('.');\n      let cur = obj;\n      for(const p of parts){\n        if(cur == null) return undefined;\n        cur = cur[p];\n      }\n      return cur;\n    }\n\n    // Index helpers for document store (simple single-field equality index)\n    function buildIndex(collection, field){\n      const map = new Map(); // value -> Set(ids)\n      for(const [id, doc] of collection.docs){\n        const v = getPath(doc, field);\n        const key = JSON.stringify(v);\n        if(!map.has(key)) map.set(key, new Set());\n        map.get(key).add(id);\n      }\n      collection.indices[field] = map;\n      return map;\n    }\n    function queryCollection(collName, query){\n      const coll = docStore.collections[collName];\n      if(!coll) return [];\n      // Try to use an index for a top-level equality if available\n      const topFields = Object.keys(query);\n      for(const f of topFields){\n        const qv = query[f];\n        if(!(typeof qv === 'object' && qv !== null) ){\n          // equality on field f\n          if(coll.indices[f]){\n            log('Index used on', f);\n            const key = JSON.stringify(qv);\n            const ids = coll.indices[f].get(key);\n            if(!ids) return [];\n            const results = [];\n            for(const id of ids) {\n              const d = coll.docs.get(id);\n              if(matchQuery(d, query)) results.push(d);\n            }\n            return results;\n          }\n        }\n      }\n      // full scan\n      const res = [];\n      for(const [id, doc] of coll.docs){\n        if(matchQuery(doc, query)) res.push(doc);\n      }\n      return res;\n    }\n\n    // Graph helpers\n    function addGraphNode(label, props={}){\n      const id = 'n' + (graph.nextNodeId++);\n      graph.nodes.set(id, {id, label, props});\n      return id;\n    }\n    function addGraphEdge(from, to, label='', props={}){\n      const id = 'e' + (graph.nextEdgeId++);\n      graph.edges.set(id, {id, from, to, label, props});\n      return id;\n    }\n    function findNeighbors(nodeId){\n      const out = [];\n      for(const e of graph.edges.values()){\n        if(e.from === nodeId) out.push({edge:e, node:graph.nodes.get(e.to)});\n        else if(e.to === nodeId) out.push({edge:e, node:graph.nodes.get(e.from)});\n      }\n      return out;\n    }\n    function bfs(from, depth=2, labelFilter=null){\n      const q = [{id:from, depth:0, path:[from]}];\n      const visited = new Set([from]);\n      const paths = [];\n      while(q.length){\n        const cur = q.shift();\n        if(cur.depth>0) paths.push(cur.path.map(id => graph.nodes.get(id)));\n        if(cur.depth>=depth) continue;\n        for(const e of graph.edges.values()){\n          if(e.from===cur.id || e.to===cur.id){\n            if(labelFilter && e.label !== labelFilter) continue;\n            const other = e.from===cur.id ? e.to : e.from;\n            if(visited.has(other)) continue;\n            visited.add(other);\n            q.push({id:other, depth:cur.depth+1, path:cur.path.concat([other])});\n          }\n        }\n      }\n      return paths;\n    }\n\n    // Replication simulation for document store: a \"replica\" map which gets updated with a delay\n    function replicateWithDelay(collName, id, doc){\n      const enabled = !!$('#evConsistent').checked;\n      const delay = parseInt($('#repDelay').value) || 1000;\n      const coll = docStore.collections[collName];\n      if(!coll) return;\n      if(!enabled){\n        coll.replicas.set(id, JSON.parse(JSON.stringify(doc)));\n        log('Replicated immediately', collName, id);\n      } else {\n        // simulate eventual consistency: primary updated immediately, replica after delay\n        const snapshot = JSON.parse(JSON.stringify(doc));\n        setTimeout(()=> {\n          coll.replicas.set(id, snapshot);\n          log('Replica updated (delayed)', collName, id);\n        }, delay);\n      }\n    }\n\n    // UI and rendering\n    const storeMenu = $('#storeMenu');\n    const main = $('#mainPanel');\n    let currentStore = 'document';\n\n    function setActiveStore(name){\n      currentStore = name;\n      $$('.store-btn').forEach(b => b.classList.toggle('active', b.dataset.store===name));\n      renderMain();\n      updateInfo();\n    }\n\n    function updateInfo(){\n      const i = $('#storeInfo');\n      if(currentStore==='document'){\n        i.innerHTML = 'Documents are hierarchical JSON-like objects. Flexible schema; good for user profiles, events, content. Supports indexing and rich queries. Try: add docs with different fields.';\n      } else if(currentStore==='kv'){\n        i.innerHTML = 'Key-Value stores map a key (string) to an opaque value (string/blob). Extremely fast, simple operations (get/set). Good for caches, sessions.';\n      } else if(currentStore==='column'){\n        i.innerHTML = 'Column-Family stores group columns into families per row. Columns are dynamic and sparse. Great for time-series and wide tables (e.g., Bigtable, Cassandra).';\n      } else if(currentStore==='graph'){\n        i.innerHTML = 'Graph DBs store nodes and edges; queries traverse relationships (friends, dependencies). Useful for social networks, recommendations.';\n      }\n    }\n\n    storeMenu.addEventListener('click', e => {\n      const b = e.target.closest('button');\n      if(!b) return;\n      setActiveStore(b.dataset.store);\n    });\n\n    // Renders\n    function renderMain(){\n      if(currentStore==='document') renderDocumentPanel();\n      else if(currentStore==='kv') renderKVPanel();\n      else if(currentStore==='column') renderColumnPanel();\n      else if(currentStore==='graph') renderGraphPanel();\n      updateStats();\n    }\n\n    function updateStats(){\n      $('#k_docs').innerText = (() => {\n        let n=0; for(const c of Object.values(docStore.collections)) n += c.docs.size; return n;\n      })();\n      $('#k_kv').innerText = kvStore.size;\n      $('#k_rows').innerText = columnStore.size;\n      $('#k_nodes').innerText = graph.nodes.size;\n    }\n\n    // Document UI\n    function renderDocumentPanel(){\n      main.innerHTML = '';\n      const coll = docStore.createCollection('users'); // show users collection by default\n\n      const wrapper = document.createElement('div');\n      wrapper.innerHTML = `\n        <div class=\"section\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div>\n              <strong>Document Store: collection \"users\"</strong>\n              <div class=\"small muted\">Flexible JSON documents. Try queries using operators like $gt, $in, $exists.</div>\n            </div>\n            <div class=\"small\">Docs: <span id=\"docCount\">${coll.docs.size}</span></div>\n          </div>\n        </div>\n\n        <div class=\"section grid2\">\n          <div>\n            <label>New document (JSON)</label>\n            <textarea id=\"newDoc\">{ \"name\": \"Dave\", \"age\": 28 }</textarea>\n            <div class=\"row\" style=\"margin-top:8px\">\n              <button class=\"btn\" id=\"addDoc\">Insert</button>\n              <button class=\"btn ghost\" id=\"clearNew\">Clear</button>\n            </div>\n          </div>\n          <div>\n            <label>Query (JSON). Example: { \"age\": { \"$gt\": 30 } }  OR { \"tags\": [\"admin\"] }</label>\n            <textarea id=\"docQuery\">{ \"age\": { \"$gt\": 30 } }</textarea>\n            <div class=\"row\" style=\"margin-top:8px\">\n              <button class=\"btn\" id=\"runQuery\">Run Query</button>\n              <button class=\"btn ghost\" id=\"explainBtn\">Explain (index)</button>\n            </div>\n            <div style=\"margin-top:8px\">\n              <label class=\"small\">Index field (single-field equality index)</label>\n              <div class=\"row\"><input id=\"indexField\" type=\"text\" placeholder=\"e.g. name\"><button class=\"btn\" id=\"buildIndex\">Build index</button></div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <label>Results</label>\n          <div class=\"list\" id=\"docList\"></div>\n        </div>\n      `;\n      main.appendChild(wrapper);\n\n      // Actions\n      $('#addDoc').onclick = () => {\n        const txt = $('#newDoc').value.trim();\n        try {\n          const obj = JSON.parse(txt);\n          const id = 'd' + Math.random().toString(36).substring(2,9);\n          obj._id = id;\n          coll.docs.set(id, obj);\n          // replicate\n          replicateWithDelay('users', id, obj);\n          // update indices if exist\n          for(const f of Object.keys(coll.indices)) {\n            const v = JSON.stringify(getPath(obj,f));\n            if(!coll.indices[f].has(v)) coll.indices[f].set(v,new Set());\n            coll.indices[f].get(v).add(id);\n          }\n          log('Inserted doc', id);\n          renderDocumentPanel();\n        } catch(err){ alert('Invalid JSON: ' + err.message); }\n      };\n      $('#clearNew').onclick = () => { $('#newDoc').value = ''; };\n\n      $('#runQuery').onclick = () => {\n        const qtxt = $('#docQuery').value.trim();\n        try {\n          const q = JSON.parse(qtxt);\n          const t0 = performance.now();\n          const res = queryCollection('users', q);\n          const t1 = performance.now();\n          showDocs(res, coll);\n          log('Query returned ' + res.length + ' docs in ' + Math.round((t1-t0)) + 'ms');\n        } catch(err){ alert('Invalid JSON query: ' + err.message); }\n      };\n\n      $('#buildIndex').onclick = () => {\n        const f = $('#indexField').value.trim();\n        if(!f) return alert('Provide a field name');\n        buildIndex(coll, f);\n        log('Built index on', f);\n        renderDocumentPanel();\n      };\n\n      $('#explainBtn').onclick = () => {\n        const qtxt = $('#docQuery').value.trim();\n        try {\n          const q = JSON.parse(qtxt);\n          const topFields = Object.keys(q);\n          const hasIdx = topFields.some(f => coll.indices[f]);\n          alert('Query fields: ' + topFields.join(', ') + '\\\\nIndex present? ' + (hasIdx ? 'Yes' : 'No') );\n        } catch(err){ alert('Invalid JSON query: ' + err.message); }\n      };\n\n      // show initial\n      showDocs(Array.from(coll.docs.values()), coll);\n      $('#docCount').innerText = coll.docs.size;\n      updateStats();\n\n      // helper to render docs as editable items\n      function showDocs(docs, collection){\n        const list = $('#docList');\n        list.innerHTML = '';\n        for(const doc of docs){\n          const item = document.createElement('div');\n          item.className = 'item';\n          const pretty = JSON.stringify(doc, null, 2);\n          item.innerHTML = `\n            <div style=\"display:flex;justify-content:space-between;align-items:center\">\n              <div><strong>${doc._id}</strong> <span class=\"small muted\">${doc.name ? ' / ' + doc.name : ''}</span></div>\n              <div>\n                <button class=\"btn ghost btn-edit\">Edit</button>\n                <button class=\"btn ghost btn-del\">Delete</button>\n              </div>\n            </div>\n            <pre style=\"margin-top:8px\">${escapeHtml(pretty)}</pre>\n            <div style=\"display:none\" class=\"editor\">\n              <label class=\"small\">Edit JSON</label>\n              <textarea class=\"editArea\">${escapeHtml(pretty)}</textarea>\n              <div class=\"row\" style=\"margin-top:8px\">\n                <button class=\"btn saveBtn\">Save</button>\n                <button class=\"btn ghost cancelBtn\">Cancel</button>\n              </div>\n            </div>\n          `;\n          list.appendChild(item);\n\n          $('button.btn-edit', item).onclick = () => {\n            $('.editor', item).style.display = 'block';\n          };\n          $('button.cancelBtn', item).onclick = () => { $('.editor', item).style.display = 'none'; };\n          $('button.saveBtn', item).onclick = () => {\n            const txt = $('.editArea', item).value;\n            try {\n              const newdoc = JSON.parse(txt);\n              if(!newdoc._id) newdoc._id = doc._id;\n              collection.docs.set(doc._id, newdoc);\n              replicateWithDelay('users', doc._id, newdoc);\n              // rebuild indices simply for demo (naive)\n              for(const f of Object.keys(collection.indices)) buildIndex(collection, f);\n              log('Updated doc', doc._id);\n              renderDocumentPanel();\n            } catch(err){ alert('Invalid JSON: '+err.message); }\n          };\n          $('button.btn-del', item).onclick = () => {\n            if(!confirm('Delete doc ' + doc._id + '?')) return;\n            collection.docs.delete(doc._id);\n            collection.replicas.delete(doc._id);\n            // remove from indices\n            for(const f of Object.keys(collection.indices)){\n              for(const [k,s] of collection.indices[f]){\n                s.delete(doc._id);\n                if(s.size===0) collection.indices[f].delete(k);\n              }\n            }\n            log('Deleted doc ' + doc._id);\n            renderDocumentPanel();\n          };\n        }\n      }\n    }\n\n    // Key-Value UI\n    function renderKVPanel(){\n      main.innerHTML = '';\n      const wrapper = document.createElement('div');\n      wrapper.innerHTML = `\n        <div class=\"section\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div><strong>Key-Value Store</strong><div class=\"small muted\">Simple map: get/set/delete. Values are opaque (strings or JSON).</div></div>\n            <div class=\"small\">Entries: <span id=\"kvCount\">${kvStore.size}</span></div>\n          </div>\n        </div>\n\n        <div class=\"section grid2\">\n          <div>\n            <label>Set key</label>\n            <input type=\"text\" id=\"kvKey\" placeholder=\"key\">\n            <label style=\"margin-top:8px\">Value (string or JSON)</label>\n            <textarea id=\"kvVal\">{\"hello\":\"world\"}</textarea>\n            <div class=\"row\" style=\"margin-top:8px\">\n              <button class=\"btn\" id=\"kvSet\">Set</button>\n              <button class=\"btn ghost\" id=\"kvGet\">Get</button>\n            </div>\n          </div>\n          <div>\n            <label>Scan keys by prefix</label>\n            <input type=\"text\" id=\"kvPrefix\" placeholder=\"prefix (e.g. cache:user:)\">\n            <div class=\"row\" style=\"margin-top:8px\">\n              <button class=\"btn\" id=\"kvScan\">Scan</button>\n              <button class=\"btn ghost\" id=\"kvClearAll\">Clear all</button>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <label>Entries</label>\n          <div class=\"list\" id=\"kvList\"></div>\n        </div>\n      `;\n      main.appendChild(wrapper);\n\n      $('#kvSet').onclick = () => {\n        const k = $('#kvKey').value.trim();\n        if(!k) return alert('Provide a key');\n        let val = $('#kvVal').value;\n        // store raw string; optional JSON parse attempt\n        try {\n          const parsed = JSON.parse(val);\n          val = parsed;\n        } catch(_) { /* keep as string */ }\n        kvStore.set(k, {value: val, created: Date.now()});\n        log('KV set', k);\n        renderKVPanel();\n      };\n      $('#kvGet').onclick = () => {\n        const k = $('#kvKey').value.trim();\n        if(!kvStore.has(k)) return alert('Key not found');\n        const entry = kvStore.get(k);\n        alert('Value:\\\\n' + JSON.stringify(entry.value, null, 2));\n      };\n      $('#kvScan').onclick = () => {\n        const pref = $('#kvPrefix').value;\n        const matched = [];\n        for(const [k,v] of kvStore){\n          if(k.startsWith(pref)) matched.push([k,v]);\n        }\n        showEntries(matched);\n      };\n      $('#kvClearAll').onclick = () => {\n        if(!confirm('Clear all KV entries?')) return;\n        kvStore.clear();\n        log('Cleared KV store');\n        renderKVPanel();\n      };\n\n      // show all entries\n      showEntries(Array.from(kvStore.entries()));\n      updateStats();\n\n      function showEntries(entries){\n        const list = $('#kvList');\n        list.innerHTML = '';\n        for(const [k,v] of entries.slice(0,200)){\n          const it = document.createElement('div');\n          it.className = 'item';\n          it.innerHTML = `\n            <div style=\"display:flex;justify-content:space-between;align-items:center\">\n              <div><strong>${escapeHtml(k)}</strong><div class=\"small muted\">created: ${new Date(v.created).toLocaleString()}</div></div>\n              <div>\n                <button class=\"btn ghost btn-get\">Get</button>\n                <button class=\"btn ghost btn-del\">Del</button>\n              </div>\n            </div>\n            <pre style=\"margin-top:8px\">${escapeHtml(JSON.stringify(v.value, null, 2))}</pre>\n          `;\n          list.appendChild(it);\n          $('.btn-get', it).onclick = () => alert(JSON.stringify(v.value, null, 2));\n          $('.btn-del', it).onclick = () => {\n            kvStore.delete(k); log('KV deleted ' + k); renderKVPanel();\n          };\n        }\n      }\n    }\n\n    // Column-family UI\n    function renderColumnPanel(){\n      main.innerHTML = '';\n      const wrapper = document.createElement('div');\n      wrapper.innerHTML = `\n        <div class=\"section\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div><strong>Column-Family Store</strong><div class=\"small muted\">Rows have dynamic columns grouped in families. Sparse and wide.</div></div>\n            <div class=\"small\">Rows: <span id=\"rowCount\">${columnStore.size}</span></div>\n          </div>\n        </div>\n\n        <div class=\"section\" style=\"display:grid;grid-template-columns:1fr 1fr;gap:8px\">\n          <div>\n            <label>Row key</label>\n            <input id=\"cfRow\" type=\"text\" placeholder=\"row1\">\n            <label style=\"margin-top:8px\">Family</label>\n            <input id=\"cfFamily\" type=\"text\" placeholder=\"profile\">\n            <label style=\"margin-top:8px\">Qualifier</label>\n            <input id=\"cfQual\" type=\"text\" placeholder=\"name\">\n            <label style=\"margin-top:8px\">Value</label>\n            <input id=\"cfVal\" type=\"text\" placeholder=\"Zoe\">\n            <div class=\"row\" style=\"margin-top:8px\">\n              <button class=\"btn\" id=\"cfSet\">Set Column</button>\n              <button class=\"btn ghost\" id=\"cfDelete\">Delete Column</button>\n            </div>\n          </div>\n          <div>\n            <label>Query rows by column value (simple)</label>\n            <input id=\"cfQuery\" placeholder='e.g. family=profile qualifier=name value=Zoe'>\n            <div class=\"row\" style=\"margin-top:8px\">\n              <button class=\"btn\" id=\"cfFind\">Find</button>\n              <button class=\"btn ghost\" id=\"cfDump\">Dump All</button>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <label>Rows</label>\n          <div class=\"list\" id=\"cfList\"></div>\n        </div>\n      `;\n      main.appendChild(wrapper);\n\n      $('#cfSet').onclick = () => {\n        const r = $('#cfRow').value.trim(); if(!r) return alert('Row key required');\n        const fam = $('#cfFamily').value.trim() || 'default';\n        const qual = $('#cfQual').value.trim() || 'col';\n        const val = $('#cfVal').value;\n        if(!columnStore.has(r)) columnStore.set(r, {});\n        const row = columnStore.get(r);\n        if(!row[fam]) row[fam] = {};\n        row[fam][qual] = val;\n        log('Set column', r, fam+':'+qual);\n        renderColumnPanel();\n      };\n\n      $('#cfDelete').onclick = () => {\n        const r = $('#cfRow').value.trim(); if(!columnStore.has(r)) return alert('Unknown row');\n        const fam = $('#cfFamily').value.trim() || 'default';\n        const qual = $('#cfQual').value.trim();\n        const row = columnStore.get(r);\n        if(row[fam] && qual && row[fam][qual] !== undefined){\n          delete row[fam][qual];\n          log('Deleted column', r, fam+':'+qual);\n          renderColumnPanel();\n        } else alert('Column not found');\n      };\n\n      $('#cfFind').onclick = () => {\n        const q = $('#cfQuery').value.trim();\n        const m = /family\\s*=\\s*(\\\\S+)\\\\s+qualifier\\\\s*=\\\\s*(\\\\S+)\\\\s+value\\\\s*=\\\\s*(.+)/i.exec(q);\n        const hits = [];\n        if(m){\n          const fam = m[1], qual = m[2], val = m[3];\n          for(const [r,row] of columnStore){\n            if(row[fam] && String(row[fam][qual]) === val) hits.push([r,row]);\n          }\n        } else {\n          alert('Query parse failed. Use: family=profile qualifier=name value=Zoe');\n          return;\n        }\n        showRows(hits);\n      };\n\n      $('#cfDump').onclick = () => {\n        showRows(Array.from(columnStore.entries()));\n      };\n\n      function showRows(rows){\n        const list = $('#cfList');\n        list.innerHTML = '';\n        for(const [r,row] of rows){\n          const it = document.createElement('div');\n          it.className = 'item';\n          it.innerHTML = `<div style=\"display:flex;justify-content:space-between\">\n            <div><strong>${escapeHtml(r)}</strong><div class=\"small muted\">families: ${Object.keys(row).length}</div></div>\n            <div><button class=\"btn ghost btn-del\">Del Row</button></div>\n          </div><pre style=\"margin-top:8px\">${escapeHtml(JSON.stringify(row, null, 2))}</pre>`;\n          list.appendChild(it);\n          $('.btn-del', it).onclick = () => { columnStore.delete(r); log('Deleted row ' + r); renderColumnPanel(); };\n        }\n      }\n\n      showRows(Array.from(columnStore.entries()));\n      updateStats();\n    }\n\n    // Graph UI\n    function renderGraphPanel(){\n      main.innerHTML = '';\n      const wrapper = document.createElement('div');\n      wrapper.innerHTML = `\n        <div class=\"section\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div><strong>Graph Database</strong><div class=\"small muted\">Nodes and edges; traverse relationships.</div></div>\n            <div class=\"small\">Nodes: <span id=\"nodeCount\">${graph.nodes.size}</span></div>\n          </div>\n        </div>\n\n        <div class=\"section\" style=\"display:grid;grid-template-columns:1fr 1fr;gap:8px\">\n          <div>\n            <label>New node label</label>\n            <input id=\"gNodeLabel\" placeholder=\"Alice\">\n            <label style=\"margin-top:8px\">Props (JSON)</label>\n            <textarea id=\"gNodeProps\">{ \"role\": \"user\" }</textarea>\n            <div class=\"row\" style=\"margin-top:8px\">\n              <button class=\"btn\" id=\"gAddNode\">Add Node</button>\n              <button class=\"btn ghost\" id=\"gList\">List Nodes</button>\n            </div>\n          </div>\n          <div>\n            <label>Create edge</label>\n            <input id=\"gFrom\" placeholder=\"from node id (e.g. n1)\">\n            <input id=\"gTo\" placeholder=\"to node id (e.g. n2)\" style=\"margin-top:6px\">\n            <input id=\"gLabel\" placeholder=\"label (e.g. knows)\" style=\"margin-top:6px\">\n            <div class=\"row\" style=\"margin-top:8px\">\n              <button class=\"btn\" id=\"gAddEdge\">Add Edge</button>\n              <button class=\"btn ghost\" id=\"gNeighbors\">Neighbors</button>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <label>Traversal</label>\n          <div class=\"row\">\n            <input id=\"gStart\" placeholder=\"start node id (e.g. n1)\">\n            <input id=\"gDepth\" placeholder=\"depth (2)\" value=\"2\" style=\"max-width:80px\">\n            <button class=\"btn\" id=\"gTraverse\">BFS Traverse</button>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <label>Graph</label>\n          <div class=\"list\" id=\"gListArea\"></div>\n        </div>\n      `;\n      main.appendChild(wrapper);\n\n      $('#gAddNode').onclick = () => {\n        const lab = $('#gNodeLabel').value.trim() || 'node';\n        let props = {};\n        try { props = JSON.parse($('#gNodeProps').value || '{}'); }\n        catch(err){ return alert('Invalid JSON props'); }\n        const id = addGraphNode(lab, props);\n        log('Added node', id);\n        renderGraphPanel();\n      };\n      $('#gList').onclick = () => { showAll(); };\n      $('#gAddEdge').onclick = () => {\n        const f = $('#gFrom').value.trim(), t = $('#gTo').value.trim();\n        if(!graph.nodes.has(f) || !graph.nodes.has(t)) return alert('Unknown node id(s)');\n        const label = $('#gLabel').value.trim();\n        let props={};\n        const id = addGraphEdge(f,t,label,props);\n        log('Added edge', id, f+'->'+t);\n        renderGraphPanel();\n      };\n      $('#gNeighbors').onclick = () => {\n        const id = $('#gFrom').value.trim();\n        if(!graph.nodes.has(id)) return alert('Unknown node id');\n        const neigh = findNeighbors(id);\n        const out = neigh.map(n => `${n.edge.id} (${n.edge.label}): ${n.node.id} ${n.node.label}`).join('\\\\n');\n        alert('Neighbors:\\\\n' + out);\n      };\n      $('#gTraverse').onclick = () => {\n        const start = $('#gStart').value.trim();\n        const depth = parseInt($('#gDepth').value) || 2;\n        if(!graph.nodes.has(start)) return alert('Unknown start node');\n        const paths = bfs(start, depth);\n        const pretty = paths.map(p => p.map(n=>n.id+'('+n.label+')').join(' -> ')).join('\\\\n');\n        alert('Paths found:\\\\n' + pretty);\n      };\n\n      function showAll(){\n        const area = $('#gListArea');\n        area.innerHTML = '';\n        for(const n of graph.nodes.values()){\n          const item = document.createElement('div'); item.className='item';\n          const neighCount = findNeighbors(n.id).length;\n          item.innerHTML = `<div style=\"display:flex;justify-content:space-between\">\n            <div><strong>${n.id}</strong> ${escapeHtml(n.label)} <div class=\"small muted\">${JSON.stringify(n.props)}</div></div>\n            <div><span class=\"small muted\">${neighCount} relations</span></div>\n          </div>`;\n          area.appendChild(item);\n        }\n        // edges\n        const edgesHeader = document.createElement('div'); edgesHeader.className='muted small'; edgesHeader.style.marginTop='8px'; edgesHeader.innerText='Edges';\n        area.appendChild(edgesHeader);\n        for(const e of graph.edges.values()){\n          const item = document.createElement('div'); item.className='item';\n          item.style.marginTop='6px';\n          item.innerHTML = `<div style=\"display:flex;justify-content:space-between\">\n            <div><strong>${e.id}</strong> ${escapeHtml(e.label)} <div class=\"small muted\">${e.from} -> ${e.to}</div></div>\n            <div><button class=\"btn ghost btn-del-edge\">Del</button></div>\n          </div>`;\n          area.appendChild(item);\n          $('.btn-del-edge', item).onclick = () => { graph.edges.delete(e.id); log('Deleted edge ' + e.id); renderGraphPanel(); };\n        }\n        updateStats();\n      }\n\n      showAll();\n    }\n\n    // Utility\n    function escapeHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\n\n    // Initialize\n    setActiveStore('document');\n\n    // Expose some functions globally for debugging\n    window._docStore = docStore;\n    window._kvStore = kvStore;\n    window._columnStore = columnStore;\n    window._graph = graph;\n\n    // Periodic UI stats update\n    setInterval(updateStats, 1500);\n\n    // Initial log\n    log('Demo initialized');\n  </script>\n</body>\n</html>"
