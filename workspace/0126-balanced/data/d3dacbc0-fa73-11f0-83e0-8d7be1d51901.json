  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Design Patterns - Interactive Demos</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root { --bg: #0f1724; --panel: #0b1220; --muted: #9aa7bf; --accent: #7dd3fc; --card: #071022; color-scheme: dark; }\n    html,body { height:100%; margin:0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; background: linear-gradient(180deg,#071229 0%, #02111b 100%); color:#e6eef8; }\n    header { padding:18px 24px; background:linear-gradient(90deg, rgba(125,211,252,0.06), transparent); border-bottom:1px solid rgba(255,255,255,0.02); display:flex; gap:12px; align-items:center; }\n    header h1 { font-size:18px; margin:0; letter-spacing:0.2px; }\n    header p { margin:0; color:var(--muted); font-size:13px; }\n    .container { display:flex; height:calc(100vh - 68px); gap:18px; padding:18px; box-sizing:border-box; }\n    .sidebar { width:280px; background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border-radius:10px; padding:12px; box-sizing:border-box; overflow:auto; }\n    .main { flex:1; display:flex; flex-direction:column; gap:12px; }\n    .card { background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005)); border-radius:10px; padding:12px; box-sizing:border-box; box-shadow: 0 2px 10px rgba(2,6,23,0.6); }\n    .pattern-list { display:flex; flex-direction:column; gap:8px; }\n    .group { margin-bottom:8px; }\n    .group h3 { margin:6px 0 6px 6px; font-size:13px; color:var(--muted); }\n    .pattern-btn { display:flex; justify-content:space-between; align-items:center; gap:8px; padding:8px 10px; border-radius:8px; background:transparent; border:1px solid transparent; color:inherit; cursor:pointer; font-size:14px; }\n    .pattern-btn:hover { background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.02); }\n    .pattern-btn.active { background: linear-gradient(90deg, rgba(125,211,252,0.06), rgba(125,211,252,0.02)); border-color: rgba(125,211,252,0.12); color:var(--accent); }\n    .meta { font-size:12px; color:var(--muted); }\n    .controls { display:flex; gap:8px; align-items:center; margin-bottom:6px; }\n    button.primary { background:linear-gradient(90deg,#38bdf8,#7dd3fc); color:#012028; border:none; padding:8px 12px; border-radius:8px; cursor:pointer; font-weight:600; }\n    button.ghost { background:transparent; border:1px solid rgba(255,255,255,0.04); padding:8px 10px; border-radius:8px; color:var(--muted); cursor:pointer; }\n    pre.code { background:#02111b; padding:10px; border-radius:8px; overflow:auto; max-height:260px; font-size:12px; color:#cfeefb; }\n    .output { background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.006)); border-radius:8px; padding:12px; min-height:160px; max-height:420px; overflow:auto; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Courier New\", monospace; font-size:13px; color:#dff7ff; }\n    .inline-input { padding:6px 10px; border-radius:8px; border:1px solid rgba(255,255,255,0.04); background:transparent; color:inherit; }\n    footer { color:var(--muted); padding:8px 18px; font-size:13px; text-align:center; }\n    small.hint { color:var(--muted); font-size:12px; display:block; margin-top:6px; }\n    .badge { padding:4px 8px; border-radius:999px; background:rgba(255,255,255,0.02); color:var(--muted); font-size:12px; }\n    .flex { display:flex; gap:8px; align-items:center; }\n    @media (max-width:900px) {\n      .container { flex-direction:column; height:auto; }\n      .sidebar { width:100%; order:2; }\n      .main { order:1; }\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <div>\n      <h1>Design Patterns — Interactive Playground</h1>\n      <p>Small, focused JavaScript examples of common patterns. Pick a pattern to view description, code, and run a demo.</p>\n    </div>\n  </header>\n\n  <div class=\"container\">\n    <aside class=\"sidebar card\" aria-label=\"Patterns\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;\">\n        <div>\n          <div class=\"badge\">Categories: Creational • Structural • Behavioral</div>\n        </div>\n        <div class=\"meta\">Live demos</div>\n      </div>\n\n      <div class=\"pattern-list\" id=\"patternList\"></div>\n\n      <small class=\"hint\">Click a pattern to inspect and run its demo. Code is simplified for learning.</small>\n    </aside>\n\n    <main class=\"main\">\n      <section class=\"card\" style=\"display:flex;flex-direction:column;gap:10px;\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <div>\n            <strong id=\"pname\">Select a pattern</strong>\n            <div id=\"pcategory\" class=\"meta\">Category</div>\n          </div>\n          <div class=\"flex\">\n            <button class=\"ghost\" id=\"showCodeBtn\">Toggle code</button>\n            <button class=\"primary\" id=\"runBtn\">Run demo</button>\n            <button class=\"ghost\" id=\"resetBtn\">Reset output</button>\n          </div>\n        </div>\n\n        <div id=\"pdesc\" class=\"meta\">Choose a pattern from the left to see details, code and run a simple interactive demo.</div>\n\n        <div id=\"codeWrap\" style=\"display:none;\">\n          <pre class=\"code\" id=\"pcode\"></pre>\n        </div>\n      </section>\n\n      <section class=\"card\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;\">\n          <strong>Demo output</strong>\n          <div class=\"meta\">Interactions appear here</div>\n        </div>\n        <div id=\"output\" class=\"output\">Output will appear here when you run a demo.</div>\n      </section>\n\n      <section class=\"card\" id=\"controls\" style=\"display:none;\">\n        <!-- Dynamic controls per pattern -->\n      </section>\n    </main>\n  </div>\n\n  <footer>\n    Minimal, self-contained examples — patterns are conceptual; real-world code may adapt them to project needs.\n  </footer>\n\n  <script>\n    // Patterns data model: name, category, description, code (string), demo (function that receives output container and controls)\n    const patterns = [\n      {\n        id: 'singleton',\n        name: 'Singleton',\n        category: 'Creational',\n        desc: 'Ensure a class has only one instance. Demo: a counter service that always returns the same instance.',\n        code:\n\\`// Simple Singleton via closure\nconst CounterSingleton = (function() {\n  let instance;\n  function create() {\n    let count = 0;\n    return {\n      increment() { count++; return count; },\n      get() { return count; }\n    };\n  }\n  return {\n    getInstance() {\n      if (!instance) instance = create();\n      return instance;\n    }\n  };\n})();\n\n// Usage:\nconst a = CounterSingleton.getInstance();\na.increment(); // 1\nconst b = CounterSingleton.getInstance();\nb.increment(); // 2 (same instance)\\`,\n        demo(output) {\n          output.innerHTML = '';\n          const a = CounterSingleton.getInstance();\n          appendLine('Initial count (a): ' + a.get());\n          appendLine('a.increment(): ' + a.increment());\n          const b = CounterSingleton.getInstance();\n          appendLine('Got instance b, b.increment(): ' + b.increment());\n          appendLine('a.get() after b.increment(): ' + a.get());\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      },\n\n      // Factory\n      {\n        id: 'factory',\n        name: 'Factory',\n        category: 'Creational',\n        desc: 'Encapsulate object creation. Demo: shape factory that returns different shape objects with a draw() method.',\n        code:\n\\`// Factory function creating different shapes\nfunction ShapeFactory() {\n  return {\n    create(type) {\n      if (type === 'circle') return { type:'circle', draw(){ return '○'; } };\n      if (type === 'square') return { type:'square', draw(){ return '▢'; } };\n      if (type === 'triangle') return { type:'triangle', draw(){ return '△'; } };\n      throw new Error('Unknown shape: ' + type);\n    }\n  };\n}\n\n// Usage:\nconst factory = ShapeFactory();\nconst s = factory.create('circle');\ns.draw(); // '○'\\`,\n        demo(output, controls) {\n          output.innerHTML = '';\n          const factory = ShapeFactory();\n          const select = document.createElement('select');\n          ['circle','square','triangle'].forEach(t=> {\n            const o = document.createElement('option'); o.value=t; o.textContent=t; select.appendChild(o);\n          });\n          const btn = document.createElement('button'); btn.textContent='Create';\n          btn.className='primary';\n          controls.appendChild(select); controls.appendChild(btn);\n          btn.onclick = () => {\n            const shape = factory.create(select.value);\n            appendLine('Created: ' + shape.type + ' → draw(): ' + shape.draw());\n          };\n          appendLine('Factory ready. Choose a shape and click Create.');\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      },\n\n      // Builder\n      {\n        id: 'builder',\n        name: 'Builder',\n        category: 'Creational',\n        desc: 'Separate construction of a complex object from its representation. Demo: chainable User builder.',\n        code:\n\\`// Builder with chainable API\nfunction UserBuilder() {\n  const user = {};\n  return {\n    setName(name){ user.name = name; return this; },\n    setEmail(email){ user.email = email; return this; },\n    setAge(age){ user.age = age; return this; },\n    build(){ return Object.freeze({...user}); }\n  };\n}\n\n// Usage:\nconst u = UserBuilder().setName('Ana').setEmail('a@x').setAge(30).build();\\`,\n        demo(output, controls) {\n          output.innerHTML = '';\n          controls.innerHTML = '';\n          const name = input('Name','Ana');\n          const email = input('Email','ana@example.com');\n          const age = input('Age','28');\n          const btn = document.createElement('button'); btn.textContent='Build User'; btn.className='primary';\n          controls.appendChild(btn);\n          btn.onclick = () => {\n            const u = UserBuilder().setName(name.value).setEmail(email.value).setAge(Number(age.value)).build();\n            appendLine('Built user: ' + JSON.stringify(u));\n          };\n          appendLine('Fill fields and click Build User.');\n          function input(placeholder, val='') {\n            const el = document.createElement('input'); el.className='inline-input'; el.placeholder=placeholder; el.value=val; controls.appendChild(el); return el;\n          }\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      },\n\n      // Adapter\n      {\n        id: 'adapter',\n        name: 'Adapter',\n        category: 'Structural',\n        desc: 'Convert an interface of a class into another interface clients expect. Demo: temperature sensor providing Celsius adapted to Fahrenheit consumer.',\n        code:\n\\`// Adaptee: sensor returns Celsius\nclass CelsiusSensor {\n  read() { return 25; } // degrees Celsius\n}\n// Adapter converts to Fahrenheit\nclass FahrenheitAdapter {\n  constructor(sensor) { this.sensor = sensor; }\n  readF() { return this.sensor.read() * 9/5 + 32; }\n}\\`,\n        demo(output, controls) {\n          output.innerHTML = '';\n          const sensor = new CelsiusSensor();\n          appendLine('Sensor reads (C): ' + sensor.read());\n          const adapter = new FahrenheitAdapter(sensor);\n          appendLine('Adapter reads (F): ' + adapter.readF());\n          appendLine('Adapter allows a Fahrenheit-only client to consume the Celsius sensor.');\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      },\n\n      // Decorator\n      {\n        id: 'decorator',\n        name: 'Decorator',\n        category: 'Structural',\n        desc: 'Attach additional responsibilities to an object dynamically. Demo: decorating a Coffee with extras that change description and cost.',\n        code:\n\\`// Base object\nfunction Coffee() {\n  return { cost:0.5, desc:'Coffee' };\n}\n// Decorators wrap a beverage and add behavior\nfunction withMilk(bev) {\n  return { cost: bev.cost + 0.2, desc: bev.desc + ' + Milk' };\n}\nfunction withSugar(bev) {\n  return { cost: bev.cost + 0.1, desc: bev.desc + ' + Sugar' };\n}\\`,\n        demo(output, controls) {\n          output.innerHTML = '';\n          const base = Coffee();\n          appendLine('Base: ' + base.desc + ' $' + base.cost.toFixed(2));\n          const milkBtn = document.createElement('button'); milkBtn.textContent='Add Milk'; milkBtn.className='ghost';\n          const sugarBtn = document.createElement('button'); sugarBtn.textContent='Add Sugar'; sugarBtn.className='ghost';\n          const resetBtn = document.createElement('button'); resetBtn.textContent='Reset'; resetBtn.className='primary';\n          controls.appendChild(milkBtn); controls.appendChild(sugarBtn); controls.appendChild(resetBtn);\n          let current = base;\n          function show(){ appendLine('Current: ' + current.desc + ' $' + current.cost.toFixed(2)); }\n          milkBtn.onclick = () => { current = withMilk(current); show(); };\n          sugarBtn.onclick = () => { current = withSugar(current); show(); };\n          resetBtn.onclick = () => { current = Coffee(); appendLine('Reset to base'); show(); };\n          show();\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      },\n\n      // Proxy\n      {\n        id: 'proxy',\n        name: 'Proxy',\n        category: 'Structural',\n        desc: 'Provide a surrogate for another object to control access. Demo: property access logger and validator.',\n        code:\n\\`const target = { name: 'Alice', age: 30 };\nconst prox = new Proxy(target, {\n  get(t,k){ console.log('get',k); return t[k]; },\n  set(t,k,v){ if (k === 'age' && (typeof v !== 'number' || v < 0)) throw new Error('Invalid age'); t[k]=v; return true; }\n});\\`,\n        demo(output, controls) {\n          output.innerHTML = '';\n          const target = { name:'Alice', age:30 };\n          const prox = new Proxy(target, {\n            get(t,k){ appendLine('[proxy] get ' + String(k)); return t[k]; },\n            set(t,k,v){ appendLine('[proxy] set ' + String(k) + ' = ' + JSON.stringify(v)); \n              if (k === 'age' && (typeof v !== 'number' || v < 0)) { appendLine('Validation failed: age must be non-negative number'); return false; }\n              t[k]=v; return true;\n            }\n          });\n          appendLine('Initial prox.name: ' + prox.name);\n          appendLine('Initial prox.age: ' + prox.age);\n          const setAge = document.createElement('input'); setAge.className='inline-input'; setAge.placeholder='new age';\n          const btn = document.createElement('button'); btn.className='primary'; btn.textContent='Set age';\n          controls.appendChild(setAge); controls.appendChild(btn);\n          btn.onclick = () => {\n            const v = Number(setAge.value);\n            try {\n              const ok = (prox.age = v);\n              appendLine('Assignment returned: ' + ok);\n              appendLine('Now prox.age: ' + prox.age);\n            } catch (e) { appendLine('Error: ' + e.message); }\n          };\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      },\n\n      // Observer\n      {\n        id: 'observer',\n        name: 'Observer (Pub/Sub)',\n        category: 'Behavioral',\n        desc: 'Define a one-to-many dependency so that when one object changes state, its dependents are notified. Demo: simple Pub/Sub.',\n        code:\n\\`function createPubSub() {\n  const subs = {};\n  return {\n    subscribe(topic, fn){ (subs[topic] = subs[topic] || []).push(fn); },\n    publish(topic, data){ (subs[topic]||[]).forEach(fn => fn(data)); }\n  };\n}\\`,\n        demo(output, controls) {\n          output.innerHTML = '';\n          const bus = createPubSub();\n          const log = (label) => (data) => appendLine(label + ' received: ' + data);\n          const s1 = () => appendLine('Subscriber 1 received event');\n          bus.subscribe('news', log('S1'));\n          bus.subscribe('news', log('S2'));\n          const publishBtn = document.createElement('button'); publishBtn.className='primary'; publishBtn.textContent='Publish \"Hello\"';\n          controls.appendChild(publishBtn);\n          publishBtn.onclick = () => { bus.publish('news', 'Hello at ' + new Date().toLocaleTimeString()); };\n          appendLine('Two subscribers subscribed to topic \"news\". Click Publish to notify them.');\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      },\n\n      // Strategy\n      {\n        id: 'strategy',\n        name: 'Strategy',\n        category: 'Behavioral',\n        desc: 'Define a family of algorithms and make them interchangeable. Demo: choosing a tax strategy to calculate total.',\n        code:\n\\`const Strategies = {\n  standard(amount){ return amount * 0.05; },\n  premium(amount){ return amount * 0.1; },\n  none(amount){ return 0; }\n};\nfunction priceWithTax(amount, strategyFn) {\n  return amount + strategyFn(amount);\n}\\`,\n        demo(output, controls) {\n          output.innerHTML = '';\n          const select = document.createElement('select');\n          [['standard','Standard 5%'],['premium','Premium 10%'],['none','No Tax']].forEach(([v,l]) => {\n            const o=document.createElement('option'); o.value=v; o.textContent=l; select.appendChild(o);\n          });\n          const amount = document.createElement('input'); amount.className='inline-input'; amount.placeholder='Amount'; amount.value='100';\n          const btn = document.createElement('button'); btn.textContent='Compute'; btn.className='primary';\n          controls.appendChild(amount); controls.appendChild(select); controls.appendChild(btn);\n          const strategies = {\n            standard: a => a * 0.05,\n            premium: a => a * 0.10,\n            none: a => 0\n          };\n          btn.onclick = () => {\n            const a = Number(amount.value);\n            const s = strategies[select.value];\n            const total = priceWithTax(a, s);\n            appendLine('Amount: $' + a.toFixed(2) + ' | Strategy: ' + select.value + ' → Total: $' + total.toFixed(2));\n          };\n          appendLine('Choose a strategy and compute total.');\n          function priceWithTax(amount, strategyFn) { return amount + strategyFn(amount); }\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      },\n\n      // Command\n      {\n        id: 'command',\n        name: 'Command',\n        category: 'Behavioral',\n        desc: 'Encapsulate a request as an object, allowing parameterization and queuing. Demo: simple toggle commands with undo.',\n        code:\n\\`class Toggle {\n  constructor(receiver) { this.receiver = receiver; }\n  execute() { this.receiver.on(); }\n  undo() { this.receiver.off(); }\n}\nclass Light {\n  on() { console.log('Light on'); }\n  off() { console.log('Light off'); }\n}\\`,\n        demo(output, controls) {\n          output.innerHTML = '';\n          // Receiver\n          const light = { on(){ state = true; render(); }, off(){ state=false; render(); } };\n          let state = false;\n          // Command\n          function ToggleCommand(receiver) {\n            return {\n              execute() { receiver.on(); },\n              undo() { receiver.off(); }\n            };\n          }\n          const history = [];\n          const execBtn = document.createElement('button'); execBtn.className='primary'; execBtn.textContent='Execute Toggle';\n          const undoBtn = document.createElement('button'); undoBtn.className='ghost'; undoBtn.textContent='Undo';\n          controls.appendChild(execBtn); controls.appendChild(undoBtn);\n          execBtn.onclick = () => {\n            const cmd = ToggleCommand(light);\n            cmd.execute();\n            history.push(cmd);\n            appendLine('Executed toggle. History length: ' + history.length);\n          };\n          undoBtn.onclick = () => {\n            const cmd = history.pop();\n            if (cmd) { cmd.undo(); appendLine('Undid last command. History length: ' + history.length); } else appendLine('Nothing to undo.');\n          };\n          function render() {\n            output.innerHTML = '';\n            appendLine('Light is ' + (state ? 'ON' : 'OFF'));\n          }\n          render();\n          function appendLine(s){ const p=document.createElement('div'); p.textContent=s; output.appendChild(p); }\n        }\n      }\n    ];\n\n    // Some helper functions used by demos (they rely on being available globally)\n    // Provide implementations used in code strings above (CelsiusSensor, FahrenheitAdapter, Coffee, CounterSingleton, createPubSub, ShapeFactory, UserBuilder)\n    // Implementations below correspond to those in code examples:\n    const CounterSingleton = (function() {\n      let instance;\n      function create() {\n        let count = 0;\n        return {\n          increment() { count++; return count; },\n          get() { return count; }\n        };\n      }\n      return {\n        getInstance() {\n          if (!instance) instance = create();\n          return instance;\n        }\n      };\n    })();\n\n    function ShapeFactory() {\n      return {\n        create(type) {\n          if (type === 'circle') return { type:'circle', draw(){ return '○'; } };\n          if (type === 'square') return { type:'square', draw(){ return '▢'; } };\n          if (type === 'triangle') return { type:'triangle', draw(){ return '△'; } };\n          throw new Error('Unknown shape: ' + type);\n        }\n      };\n    }\n\n    function UserBuilder() {\n      const user = {};\n      return {\n        setName(name){ user.name = name; return this; },\n        setEmail(email){ user.email = email; return this; },\n        setAge(age){ user.age = age; return this; },\n        build(){ return Object.freeze({...user}); }\n      };\n    }\n\n    class CelsiusSensor {\n      read() { return Math.floor(15 + Math.random()*15); } // random-ish Celsius\n    }\n    class FahrenheitAdapter {\n      constructor(sensor) { this.sensor = sensor; }\n      readF() { return this.sensor.read() * 9/5 + 32; }\n    }\n\n    function Coffee(){ return { cost:0.5, desc:'Coffee' }; }\n    function withMilk(bev){ return { cost: bev.cost + 0.2, desc: bev.desc + ' + Milk' }; }\n    function withSugar(bev){ return { cost: bev.cost + 0.1, desc: bev.desc + ' + Sugar' }; }\n\n    function createPubSub() {\n      const subs = {};\n      return {\n        subscribe(topic, fn){ (subs[topic] = subs[topic] || []).push(fn); },\n        publish(topic, data){ (subs[topic]||[]).forEach(fn => fn(data)); }\n      };\n    }\n\n    // UI wiring\n    const patternList = document.getElementById('patternList');\n    const pname = document.getElementById('pname');\n    const pcategory = document.getElementById('pcategory');\n    const pdesc = document.getElementById('pdesc');\n    const pcode = document.getElementById('pcode');\n    const codeWrap = document.getElementById('codeWrap');\n    const runBtn = document.getElementById('runBtn');\n    const showCodeBtn = document.getElementById('showCodeBtn');\n    const resetBtn = document.getElementById('resetBtn');\n    const output = document.getElementById('output');\n    const controls = document.getElementById('controls');\n\n    let active = null;\n    let controlCleanup = null;\n\n    function clearControls() {\n      controls.style.display = 'none';\n      controls.innerHTML = '';\n      controlCleanup = null;\n    }\n\n    function showPattern(p) {\n      active = p;\n      // set sidebar active class\n      document.querySelectorAll('.pattern-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.id === p.id));\n      pname.textContent = p.name;\n      pcategory.textContent = p.category;\n      pdesc.textContent = p.desc;\n      pcode.textContent = p.code;\n      codeWrap.style.display = 'none';\n      clearControls();\n      output.innerHTML = 'Ready. Click \"Run demo\" to execute.';\n    }\n\n    function buildSidebar() {\n      const groups = {};\n      patterns.forEach(p => { (groups[p.category] = groups[p.category] || []).push(p); });\n      for (const cat of Object.keys(groups)) {\n        const gdiv = document.createElement('div'); gdiv.className='group';\n        const h = document.createElement('h3'); h.textContent = cat; gdiv.appendChild(h);\n        groups[cat].forEach(p => {\n          const b = document.createElement('button');\n          b.className = 'pattern-btn';\n          b.dataset.id = p.id;\n          b.innerHTML = '<span>' + p.name + '</span><span class=\"meta\">View</span>';\n          b.onclick = () => showPattern(p);\n          gdiv.appendChild(b);\n        });\n        patternList.appendChild(gdiv);\n      }\n    }\n\n    showCodeBtn.onclick = () => {\n      if (!active) return;\n      codeWrap.style.display = codeWrap.style.display === 'none' ? 'block' : 'none';\n    };\n\n    resetBtn.onclick = () => { output.innerHTML = 'Output cleared.'; clearControls(); };\n\n    runBtn.onclick = () => {\n      if (!active) { output.innerHTML = 'Please select a pattern first.'; return; }\n      // clear output and controls\n      output.innerHTML = '';\n      controls.style.display = 'none';\n      controls.innerHTML = '';\n      // Provide a helper to append lines from demo if needed\n      // Many demo functions expect (output, controls)\n      try {\n        // Show controls area if the demo will add things\n        controls.style.display = 'flex';\n        controls.style.flexWrap = 'wrap';\n        controls.style.alignItems = 'center';\n        active.demo(output, controls);\n      } catch (e) {\n        output.innerHTML = 'Demo error: ' + e.message;\n      }\n    };\n\n    // initialize\n    buildSidebar();\n    // auto-select the first pattern\n    if (patterns.length) showPattern(patterns[0]);\n  </script>\n</body>\n</html>"
  },
