    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            margin: 20px;\n        }\n        #tree {\n            margin: 20px auto;\n            position: relative;\n            width: 600px;\n            height: 400px;\n        }\n        .node {\n            width: 40px;\n            height: 40px;\n            background: #6ca0f6;\n            color: white;\n            border-radius: 50%;\n            line-height: 40px;\n            position: absolute;\n            text-align: center;\n            transition: background 0.3s;\n        }\n        .node:hover {\n            background: #4a90e2;\n        }\n        .line {\n            position: absolute;\n            height: 2px;\n            background: black;\n            transform-origin: top left;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Binary Tree Visualization</h1>\n<div id=\"tree\"></div>\n<button onclick=\"createBinaryTree()\">Generate Binary Tree</button>\n\n<script>\n    class Node {\n        constructor(value) {\n            this.value = value;\n            this.left = null;\n            this.right = null;\n        }\n    }\n\n    class BinaryTree {\n        constructor() {\n            this.root = null;\n        }\n\n        insert(value) {\n            const newNode = new Node(value);\n            if (!this.root) {\n                this.root = newNode;\n                return;\n            }\n            const queue = [this.root];\n            while (queue.length > 0) {\n                const current = queue.shift();\n                if (!current.left) {\n                    current.left = newNode;\n                    return;\n                } else if (!current.right) {\n                    current.right = newNode;\n                    return;\n                }\n                queue.push(current.left);\n                queue.push(current.right);\n            }\n        }\n\n        getNodes() {\n            const nodes = [];\n            const queue = [this.root];\n            while (queue.length > 0) {\n                const current = queue.shift();\n                if (current) {\n                    nodes.push(current);\n                    queue.push(current.left);\n                    queue.push(current.right);\n                }\n            }\n            return nodes;\n        }\n    }\n\n    function drawTree(tree) {\n        const treeDiv = document.getElementById('tree');\n        treeDiv.innerHTML = '';\n        const nodes = tree.getNodes();\n        const levels = Math.ceil(Math.log2(nodes.length + 1));\n        const positions = [];\n\n        for (let i = 0; i < nodes.length; i++) {\n            const level = Math.floor(Math.log2(i + 1));\n            const position = (i - Math.pow(2, level) + 1) / Math.pow(2, level);\n            const x = (position + 0.5) * (treeDiv.clientWidth) / Math.pow(2, level + 1);\n            const y = (level + 1) * (treeDiv.clientHeight) / (levels + 1);\n            positions.push({ x, y });\n        }\n\n        for (let i = 0; i < nodes.length; i++) {\n            const { x, y } = positions[i];\n            const nodeDiv = document.createElement('div');\n            nodeDiv.className = 'node';\n            nodeDiv.style.left = `${x - 20}px`;\n            nodeDiv.style.top = `${y - 20}px`;\n            nodeDiv.innerText = nodes[i].value;\n            treeDiv.appendChild(nodeDiv);\n\n            // Draw lines from parent to child\n            if (i > 0) {\n                const parentIndex = Math.floor((i - 1) / 2);\n                const parentPos = positions[parentIndex];\n                const lineDiv = document.createElement('div');\n                lineDiv.className = 'line';\n                lineDiv.style.left = `${parentPos.x}px`;\n                lineDiv.style.top = `${parentPos.y}px`;\n                lineDiv.style.width = `${Math.abs(x - parentPos.x)}px`;\n                lineDiv.style.height = `${Math.abs(y - parentPos.y)}px`;\n                lineDiv.style.transform = `rotate(${Math.atan2(y - parentPos.y, x - parentPos.x) * 180 / Math.PI}deg)`;\n                treeDiv.appendChild(lineDiv);\n            }\n        }\n    }\n\n    function createBinaryTree() {\n        const tree = new BinaryTree();\n        for (let i = 1; i <= 15; i++) {\n            tree.insert(i);\n        }\n        drawTree(tree);\n    }\n\n</script>\n</body>\n</html>"
