  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Undirected Graph Explorer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#f7f9fc;\n      --panel:#ffffff;\n      --muted:#6b7280;\n      --accent:#2563eb;\n      --danger:#ef4444;\n      --good:#16a34a;\n      --node:#0ea5a4;\n    }\n    html,body{height:100%;margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    body{background:linear-gradient(180deg,#eef2ff,#f8fafc);display:flex;gap:12px;padding:12px;box-sizing:border-box}\n    .app{display:flex;flex-direction:row;gap:12px;width:100%;height:calc(100% - 24px);}\n    .left{\n      flex:1;\n      background:var(--panel);\n      border-radius:10px;\n      box-shadow:0 6px 18px rgba(2,6,23,0.08);\n      padding:12px;\n      display:flex;\n      flex-direction:column;\n      min-width:480px;\n    }\n    .header{display:flex;align-items:center;gap:12px;margin-bottom:8px;}\n    .title{font-weight:700;font-size:18px}\n    .controls{display:flex;gap:8px;flex-wrap:wrap;align-items:center}\n    button{background:#fff;border:1px solid #e6e9ef;padding:8px 10px;border-radius:8px;cursor:pointer}\n    button.active{background:linear-gradient(90deg,#e6f0ff,#f3fbff);border-color:var(--accent);box-shadow:0 4px 12px rgba(37,99,235,0.08)}\n    button.warning{border-color:var(--danger);color:var(--danger)}\n    .small{padding:6px 8px;font-size:13px}\n    .canvasWrap{flex:1;display:flex;border-radius:8px;overflow:hidden; background:linear-gradient(180deg,#ffffff,#fafcff);align-items:stretch}\n    svg{flex:1;width:100%;height:100%;touch-action:none;background-image:\n      radial-gradient(circle at 12px 12px, rgba(37,99,235,0.02) 1px, transparent 1px),\n      radial-gradient(circle at 6px 6px, rgba(37,99,235,0.02) 1px, transparent 1px);\n      background-size:24px 24px;}\n    .right{\n      width:360px;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n    .panel{\n      background:var(--panel);\n      border-radius:10px;\n      padding:10px;\n      box-shadow:0 6px 18px rgba(2,6,23,0.06);\n      max-height:50%;\n      overflow:auto;\n    }\n    h3{margin:4px 0 8px 0;font-size:14px}\n    pre{white-space:pre-wrap;margin:0;font-size:13px;background:#fbfdff;padding:8px;border-radius:6px;border:1px solid #eef2ff}\n    .info{font-size:13px;color:var(--muted);margin-bottom:6px}\n    table{border-collapse:collapse;margin-top:6px}\n    td,th{border:1px solid #e9eef8;padding:6px;text-align:center;font-size:13px}\n    .legend{display:flex;gap:10px;flex-wrap:wrap;margin-top:6px}\n    .chip{display:inline-flex;align-items:center;gap:8px;padding:6px;border-radius:8px;background:#fbfdff;border:1px solid #eef2ff;font-size:13px}\n    .dot{width:14px;height:14px;border-radius:50%}\n    .nodeDot{background:var(--node)}\n    .visit{background:var(--accent)}\n    .edgeLine{height:10px;width:28px;border-radius:4px;background:linear-gradient(90deg,#e2e8ff,#fafcff)}\n    .footer{display:flex;gap:8px;align-items:center;margin-top:8px}\n    input[type=number]{width:70px;padding:6px;border-radius:8px;border:1px solid #e6e9ef}\n    input[type=file]{display:none}\n    label.file{cursor:pointer;padding:6px 8px;border-radius:8px;border:1px solid #e6e9ef;background:#fff}\n    .muted{color:var(--muted);font-size:13px}\n    .status{font-size:13px;padding:6px 8px;border-radius:8px;background:#fff;border:1px solid #eef2ff}\n    .matrixWrap{overflow:auto;max-height:200px}\n    .adjList{font-size:13px}\n    .nodeLabel{font-weight:700;fill:white;font-size:12px;pointer-events:none}\n    .edgeSelected{stroke:#f97316;stroke-width:4}\n    .nodeSelected{stroke:#f97316;stroke-width:3;fill:#ffd8bf}\n    .visitedNode{fill:var(--accent)}\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <div class=\"left\">\n      <div class=\"header\">\n        <div style=\"flex:1\">\n          <div class=\"title\">Undirected Graph Explorer</div>\n          <div class=\"muted\">Interactive graph building and traversal (BFS / DFS). Click empty space to add nodes. Drag nodes to move.</div>\n        </div>\n        <div class=\"controls\" id=\"controls\">\n          <button id=\"mode-add\" class=\"active small\">Add Node (click)</button>\n          <button id=\"mode-connect\" class=\"small\">Connect</button>\n          <button id=\"mode-move\" class=\"small\">Move</button>\n          <button id=\"clear\" class=\"small warning\">Clear</button>\n        </div>\n      </div>\n\n      <div class=\"canvasWrap\">\n        <svg id=\"svg\" viewBox=\"0 0 1000 700\" preserveAspectRatio=\"xMidYMid meet\">\n          <defs>\n            <marker id=\"dot\" markerWidth=\"8\" markerHeight=\"8\" refX=\"4\" refY=\"4\">\n              <circle cx=\"4\" cy=\"4\" r=\"3\" fill=\"#111827\"/>\n            </marker>\n          </defs>\n          <!-- edges and nodes will be added dynamically -->\n        </svg>\n      </div>\n\n      <div style=\"display:flex;gap:8px;margin-top:8px;align-items:center\">\n        <div style=\"display:flex;gap:6px;align-items:center\">\n          <label class=\"muted\">Start node:</label>\n          <select id=\"startNode\" style=\"padding:6px;border-radius:8px;border:1px solid #e6e9ef\"></select>\n        </div>\n        <button id=\"bfs\" class=\"small\">Run BFS</button>\n        <button id=\"dfs\" class=\"small\">Run DFS</button>\n        <button id=\"step\" class=\"small\">Step-by-step</button>\n        <button id=\"resetVisit\" class=\"small\">Reset</button>\n        <div class=\"status\" id=\"status\">Nodes: 0 &nbsp; Edges: 0</div>\n      </div>\n    </div>\n\n    <div class=\"right\">\n      <div class=\"panel\">\n        <h3>Graph Info</h3>\n        <div class=\"info\">Adjacency list (undirected). Click an item to highlight neighbors.</div>\n        <div class=\"adjList\" id=\"adjList\"></div>\n        <div class=\"legend\">\n          <div class=\"chip\"><div class=\"dot nodeDot\"></div> Node</div>\n          <div class=\"chip\"><div class=\"dot visit\"></div> Visited</div>\n          <div class=\"chip\"><div class=\"edgeLine\"></div> Edge</div>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <h3>Adjacency Matrix</h3>\n        <div class=\"matrixWrap\" id=\"matrixWrap\"></div>\n        <div style=\"margin-top:8px;display:flex;gap:8px;align-items:center\">\n          <input type=\"number\" id=\"randN\" min=\"1\" max=\"20\" value=\"6\" />\n          <input type=\"number\" id=\"probP\" min=\"0\" max=\"1\" step=\"0.05\" value=\"0.35\" />\n          <button id=\"randGraph\" class=\"small\">Random Graph</button>\n        </div>\n      </div>\n\n      <div class=\"panel\">\n        <h3>Save / Load</h3>\n        <div class=\"info\">Export and import graph JSON (nodes with positions and edge list).</div>\n        <div style=\"display:flex;gap:8px\">\n          <button id=\"export\" class=\"small\">Export JSON</button>\n          <label class=\"file\"><input id=\"fileInput\" type=\"file\" accept=\"application/json\" />Load JSON</label>\n        </div>\n        <pre id=\"jsonOut\"></pre>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Undirected Graph Explorer\n    // Single-file demo: build nodes by clicking empty canvas, drag nodes to move,\n    // connect nodes by selecting \"Connect\" mode then clicking two nodes.\n    // Run BFS/DFS from selected start node to visualize visitation order.\n\n    // Data model\n    let nodes = []; // {id,x,y}\n    let edges = []; // {a,b} undirected, a<b\n    let nextId = 0;\n\n    // State\n    let mode = 'add'; // add, connect, move\n    let svg = document.getElementById('svg');\n    let modeAddBtn = document.getElementById('mode-add');\n    let modeConnectBtn = document.getElementById('mode-connect');\n    let modeMoveBtn = document.getElementById('mode-move');\n    let clearBtn = document.getElementById('clear');\n    let adjListEl = document.getElementById('adjList');\n    let matrixWrap = document.getElementById('matrixWrap');\n    let statusEl = document.getElementById('status');\n    let startSelect = document.getElementById('startNode');\n    let bfsBtn = document.getElementById('bfs');\n    let dfsBtn = document.getElementById('dfs');\n    let stepBtn = document.getElementById('step');\n    let resetBtn = document.getElementById('resetVisit');\n    let randN = document.getElementById('randN');\n    let probP = document.getElementById('probP');\n    let randBtn = document.getElementById('randGraph');\n    let exportBtn = document.getElementById('export');\n    let fileInput = document.getElementById('fileInput');\n    let jsonOut = document.getElementById('jsonOut');\n\n    // SVG groups\n    let edgesGroup = document.createElementNS('http://www.w3.org/2000/svg','g');\n    let nodesGroup = document.createElementNS('http://www.w3.org/2000/svg','g');\n    svg.appendChild(edgesGroup);\n    svg.appendChild(nodesGroup);\n\n    // Visual maps\n    let nodeEls = new Map(); // id -> {g,circle,text}\n    let edgeEls = new Map(); // \"a_b\" -> line\n\n    // Selection & interaction\n    let selectedNode = null; // for connect or selection highlight\n    let dragging = null;\n    let dragOffset = {x:0,y:0};\n    let visited = new Set();\n    let highlightEdge = null;\n    let selectedEdgeKey = null;\n\n    // Utilities\n    function toKey(a,b){\n      if (a===b) return a+'_'+b;\n      return a<b ? a+'_'+b : b+'_'+a;\n    }\n    function updateStatus(){\n      statusEl.textContent = `Nodes: ${nodes.length}  Edges: ${edges.length}`;\n      rebuildStartSelect();\n    }\n\n    function rebuildStartSelect(){\n      while(startSelect.firstChild) startSelect.removeChild(startSelect.firstChild);\n      nodes.forEach(n=>{\n        let opt = document.createElement('option');\n        opt.value = n.id;\n        opt.textContent = `Node ${n.id}`;\n        startSelect.appendChild(opt);\n      });\n    }\n\n    function addNode(x,y,id){\n      let nid = (id!==undefined)?id:nextId++;\n      nodes.push({id:nid,x,y});\n      drawNode(nid,x,y);\n      updateAdjDisplays();\n      updateStatus();\n    }\n\n    function removeNode(id){\n      nodes = nodes.filter(n=>n.id!==id);\n      // remove edges touching id\n      edges = edges.filter(e=>!(e.a===id||e.b===id));\n      // remove visuals\n      let nEl = nodeEls.get(String(id));\n      if(nEl) nodesGroup.removeChild(nEl.g);\n      nodeEls.delete(String(id));\n      // remove edge visuals\n      Array.from(edgeEls.keys()).forEach(k=>{\n        if(k.split('_').map(Number).includes(Number(id))){\n          edgesGroup.removeChild(edgeEls.get(k));\n          edgeEls.delete(k);\n        }\n      });\n      if(selectedNode===id) selectedNode=null;\n      updateAdjDisplays();\n      updateStatus();\n    }\n\n    function addEdge(a,b){\n      if(a===b) return;\n      let key = toKey(a,b);\n      if(edges.some(e=>toKey(e.a,e.b)===key)) return;\n      edges.push({a:Math.min(a,b), b:Math.max(a,b)});\n      drawEdge(a,b);\n      updateAdjDisplays();\n      updateStatus();\n    }\n\n    function removeEdgeKey(key){\n      let [a,b] = key.split('_').map(Number);\n      edges = edges.filter(e=>toKey(e.a,e.b)!==toKey(a,b));\n      let el = edgeEls.get(key);\n      if(el) edgesGroup.removeChild(el);\n      edgeEls.delete(key);\n      updateAdjDisplays();\n      updateStatus();\n    }\n\n    function drawNode(id,x,y){\n      let g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      g.setAttribute('transform',`translate(${x},${y})`);\n      g.style.cursor='pointer';\n      let circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      circle.setAttribute('r',18);\n      circle.setAttribute('fill',getComputedStyle(document.documentElement).getPropertyValue('--node').trim() || '#0ea5a4');\n      circle.setAttribute('stroke','#0b1220');\n      circle.setAttribute('stroke-opacity','0.08');\n      circle.setAttribute('stroke-width',1);\n      circle.setAttribute('data-id',id);\n      let text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('x',0); text.setAttribute('y',4); text.setAttribute('text-anchor','middle');\n      text.setAttribute('class','nodeLabel');\n      text.textContent = id;\n      g.appendChild(circle); g.appendChild(text);\n      nodesGroup.appendChild(g);\n      nodeEls.set(String(id),{g,circle,text});\n\n      // events\n      circle.addEventListener('pointerdown', e=>{\n        e.stopPropagation();\n        let pt = svgPoint(e.clientX,e.clientY);\n        // pointer capture for dragging\n        if(mode==='move'){\n          dragging = id;\n          dragOffset.x = nodes.find(n=>n.id===id).x - pt.x;\n          dragOffset.y = nodes.find(n=>n.id===id).y - pt.y;\n          circle.setPointerCapture(e.pointerId);\n        } else if(mode==='connect'){\n          if(selectedNode===null){\n            selectedNode = id;\n            setNodeSelectedVisual(id,true);\n          } else if(selectedNode===id){\n            // unselect\n            setNodeSelectedVisual(id,false); selectedNode=null;\n          } else {\n            addEdge(selectedNode,id);\n            setNodeSelectedVisual(selectedNode,false);\n            selectedNode = null;\n          }\n        } else { // add mode or default: just select\n          if(selectedNode!==null){\n            setNodeSelectedVisual(selectedNode,false);\n          }\n          selectedNode = id;\n          setNodeSelectedVisual(id,true);\n        }\n      });\n\n      circle.addEventListener('pointerup', e=>{\n        try{ circle.releasePointerCapture(e.pointerId); }catch(_){}\n        if(mode==='move'){\n          dragging = null;\n        }\n      });\n\n      circle.addEventListener('dblclick', e=>{\n        e.stopPropagation();\n        // delete node on double-click\n        removeNode(id);\n      });\n\n      // edge selection on right click near edges is handled separately\n    }\n\n    function drawEdge(a,b){\n      let nA = nodes.find(n=>n.id===a);\n      let nB = nodes.find(n=>n.id===b);\n      if(!nA || !nB) return;\n      let key = toKey(a,b);\n      if(edgeEls.has(key)) return;\n      let line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1',nA.x); line.setAttribute('y1',nA.y);\n      line.setAttribute('x2',nB.x); line.setAttribute('y2',nB.y);\n      line.setAttribute('stroke','#94a3b8'); line.setAttribute('stroke-width',2.4);\n      line.setAttribute('stroke-linecap','round');\n      line.dataset.key = key;\n      line.style.cursor='pointer';\n      // insert behind nodes\n      edgesGroup.appendChild(line);\n      edgeEls.set(key,line);\n\n      line.addEventListener('pointerdown', e=>{\n        e.stopPropagation();\n        // select edge\n        if(selectedEdgeKey){\n          setEdgeSelectedVisual(selectedEdgeKey,false);\n        }\n        selectedEdgeKey = line.dataset.key;\n        setEdgeSelectedVisual(selectedEdgeKey,true);\n      });\n\n      line.addEventListener('dblclick', e=>{\n        e.stopPropagation();\n        removeEdgeKey(key);\n      });\n    }\n\n    function updateEdgePositions(){\n      edges.forEach(e=>{\n        let key = toKey(e.a,e.b);\n        let el = edgeEls.get(key);\n        if(!el) return;\n        let nA = nodes.find(n=>n.id===e.a);\n        let nB = nodes.find(n=>n.id===e.b);\n        if(nA && nB){\n          el.setAttribute('x1',nA.x);\n          el.setAttribute('y1',nA.y);\n          el.setAttribute('x2',nB.x);\n          el.setAttribute('y2',nB.y);\n        }\n      });\n    }\n\n    function setNodeSelectedVisual(id,on){\n      let ref = nodeEls.get(String(id));\n      if(!ref) return;\n      if(on){\n        ref.circle.classList.add('nodeSelected');\n        ref.circle.setAttribute('stroke','#f97316');\n        ref.circle.setAttribute('stroke-width','3');\n      } else {\n        ref.circle.classList.remove('nodeSelected');\n        ref.circle.setAttribute('stroke','#0b1220');\n        ref.circle.setAttribute('stroke-width','1');\n      }\n    }\n\n    function setEdgeSelectedVisual(key,on){\n      let el = edgeEls.get(key);\n      if(!el) return;\n      if(on){\n        el.classList.add('edgeSelected');\n        el.setAttribute('stroke','#f97316');\n        el.setAttribute('stroke-width','4');\n      } else {\n        el.classList.remove('edgeSelected');\n        el.setAttribute('stroke','#94a3b8');\n        el.setAttribute('stroke-width','2.4');\n      }\n    }\n\n    function svgPoint(clientX,clientY){\n      // convert screen coordinates to svg coordinates (viewBox)\n      let pt = svg.createSVGPoint();\n      pt.x = clientX; pt.y = clientY;\n      let ctm = svg.getScreenCTM().inverse();\n      let res = pt.matrixTransform(ctm);\n      return {x:res.x, y:res.y};\n    }\n\n    // canvas interactions\n    svg.addEventListener('pointerdown', e=>{\n      if(e.button!==0) return;\n      let pt = svgPoint(e.clientX,e.clientY);\n      // determine if clicked on empty space (no node)\n      let hitNode = nodes.find(n=>{\n        let dx = n.x - pt.x; let dy = n.y - pt.y;\n        return Math.sqrt(dx*dx+dy*dy) < 20;\n      });\n      if(!hitNode){\n        if(mode==='add'){\n          addNode(pt.x,pt.y);\n        } else {\n          // clear node selection if any\n          if(selectedNode!==null){\n            setNodeSelectedVisual(selectedNode,false);\n            selectedNode = null;\n          }\n        }\n      }\n    });\n\n    svg.addEventListener('pointermove', e=>{\n      if(dragging!==null){\n        let pt = svgPoint(e.clientX,e.clientY);\n        let node = nodes.find(n=>n.id===dragging);\n        if(node){\n          node.x = pt.x + dragOffset.x;\n          node.y = pt.y + dragOffset.y;\n          let el = nodeEls.get(String(node.id));\n          el.g.setAttribute('transform',`translate(${node.x},${node.y})`);\n          updateEdgePositions();\n        }\n      }\n    });\n\n    svg.addEventListener('dblclick', e=>{\n      // clear selection on dblclick empty\n      if(selectedNode!==null){\n        setNodeSelectedVisual(selectedNode,false); selectedNode=null;\n      }\n      if(selectedEdgeKey){\n        setEdgeSelectedVisual(selectedEdgeKey,false); selectedEdgeKey=null;\n      }\n    });\n\n    // Keyboard delete to remove selected node or edge\n    window.addEventListener('keydown', e=>{\n      if(e.key==='Delete' || e.key==='Backspace'){\n        if(selectedEdgeKey){\n          removeEdgeKey(selectedEdgeKey);\n          selectedEdgeKey = null;\n        } else if(selectedNode!==null){\n          removeNode(selectedNode);\n          selectedNode = null;\n        }\n      }\n    });\n\n    // UI buttons\n    function setMode(m){\n      mode = m;\n      [modeAddBtn, modeConnectBtn, modeMoveBtn].forEach(b=>b.classList.remove('active'));\n      if(m==='add') modeAddBtn.classList.add('active');\n      if(m==='connect') modeConnectBtn.classList.add('active');\n      if(m==='move') modeMoveBtn.classList.add('active');\n    }\n    modeAddBtn.addEventListener('click', ()=>setMode('add'));\n    modeConnectBtn.addEventListener('click', ()=>setMode('connect'));\n    modeMoveBtn.addEventListener('click', ()=>setMode('move'));\n    clearBtn.addEventListener('click', ()=>{\n      // remove all\n      nodes = []; edges = []; nextId=0;\n      nodeEls.forEach(v=> nodesGroup.removeChild(v.g));\n      nodeEls.clear();\n      edgeEls.forEach(v=> edgesGroup.removeChild(v));\n      edgeEls.clear();\n      selectedNode = null; selectedEdgeKey = null;\n      updateAdjDisplays();\n      updateStatus();\n    });\n\n    // adjacency displays\n    function buildAdjList(){\n      let map = new Map();\n      nodes.forEach(n=>map.set(n.id,[]));\n      edges.forEach(e=>{\n        map.get(e.a).push(e.b);\n        map.get(e.b).push(e.a);\n      });\n      return map;\n    }\n\n    function updateAdjDisplays(){\n      let map = buildAdjList();\n      // adjacency list HTML\n      adjListEl.innerHTML = '';\n      map.forEach((arr,id)=>{\n        let div = document.createElement('div');\n        div.style.display='flex';\n        div.style.alignItems='center';\n        div.style.justifyContent='space-between';\n        div.style.padding='6px';\n        div.style.borderBottom='1px dashed #f1f5f9';\n        let left = document.createElement('div');\n        left.textContent = `Node ${id}: [ ${arr.join(', ') || ''} ]`;\n        left.style.cursor='pointer';\n        left.addEventListener('click', ()=>{\n          // highlight neighbors\n          highlightNeighbors(Number(id));\n        });\n        let right = document.createElement('div');\n        let btnDelete = document.createElement('button'); btnDelete.textContent='Delete'; btnDelete.className='small';\n        btnDelete.addEventListener('click', ()=>{\n          removeNode(Number(id));\n        });\n        right.appendChild(btnDelete);\n        div.appendChild(left); div.appendChild(right);\n        adjListEl.appendChild(div);\n      });\n\n      // adjacency matrix\n      matrixWrap.innerHTML = '';\n      if(nodes.length===0) return;\n      // sort nodes by id for consistent matrix order\n      let ids = nodes.map(n=>n.id).sort((a,b)=>a-b);\n      let table = document.createElement('table');\n      let headerRow = document.createElement('tr');\n      let th = document.createElement('th'); th.textContent=''; headerRow.appendChild(th);\n      ids.forEach(i=>{ let th = document.createElement('th'); th.textContent = i; headerRow.appendChild(th); });\n      table.appendChild(headerRow);\n      ids.forEach(r=>{\n        let tr = document.createElement('tr');\n        let th = document.createElement('th'); th.textContent = r; tr.appendChild(th);\n        ids.forEach(c=>{\n          let td = document.createElement('td');\n          let present = edges.some(e=> (e.a===r && e.b===c) || (e.a===c && e.b===r));\n          td.textContent = present? '1' : '0';\n          tr.appendChild(td);\n        });\n        table.appendChild(tr);\n      });\n      matrixWrap.appendChild(table);\n      // update start select\n      updateStatus();\n      jsonOut.textContent = ''; // clear export preview\n    }\n\n    function highlightNeighbors(id){\n      // quick flash neighbor nodes\n      let map = buildAdjList();\n      let neighbors = map.get(id) || [];\n      // highlight selected node\n      nodeEls.forEach((v,k)=>{\n        if(Number(k)===id){\n          v.circle.setAttribute('stroke','#111827'); v.circle.setAttribute('stroke-width','3');\n        } else if(neighbors.includes(Number(k))){\n          v.circle.setAttribute('stroke','#2563eb'); v.circle.setAttribute('stroke-width','3');\n        } else {\n          v.circle.setAttribute('stroke','#0b1220'); v.circle.setAttribute('stroke-width','1');\n        }\n      });\n      setTimeout(()=>{ // revert after 900ms\n        nodeEls.forEach(v=>{\n          v.circle.setAttribute('stroke','#0b1220'); v.circle.setAttribute('stroke-width','1');\n        });\n      },900);\n    }\n\n    // Traversals\n    function resetVisitVisuals(){\n      visited.clear();\n      nodeEls.forEach(v=>{\n        v.circle.setAttribute('fill',getComputedStyle(document.documentElement).getPropertyValue('--node').trim() || '#0ea5a4');\n        v.circle.classList.remove('visitedNode');\n      });\n      edgeEls.forEach(el=>{\n        el.setAttribute('stroke','#94a3b8');\n        el.setAttribute('stroke-width','2.4');\n      });\n    }\n    resetBtn.addEventListener('click', resetVisitVisuals);\n\n    function animateVisits(orderEdges, orderNodes, stepDelay=500){\n      resetVisitVisuals();\n      // orderNodes: [nodeId ...] visitation order\n      // orderEdges: [(a,b) ...] edges traversed in order\n      for(let i=0;i<orderNodes.length;i++){\n        ((i)=>{\n          setTimeout(()=>{\n            let nid = orderNodes[i];\n            let nEl = nodeEls.get(String(nid));\n            if(nEl){\n              nEl.circle.setAttribute('fill',getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#2563eb');\n              nEl.circle.classList.add('visitedNode');\n            }\n            if(orderEdges[i-1]){\n              // highlight edge used to reach this node (previous edge)\n              let [a,b] = orderEdges[i-1];\n              let key = toKey(a,b);\n              let el = edgeEls.get(key);\n              if(el){\n                el.setAttribute('stroke','#16a34a');\n                el.setAttribute('stroke-width','4');\n              }\n            }\n          }, i*stepDelay);\n        })(i);\n      }\n    }\n\n    function runBFS(startId, animate=true, stepDelay=450){\n      startId = Number(startId);\n      let map = buildAdjList();\n      let q = [startId];\n      let seen = new Set([startId]);\n      let orderNodes = [];\n      let orderEdges = [];\n      while(q.length){\n        let v = q.shift();\n        orderNodes.push(v);\n        let neighbors = (map.get(v) || []).slice().sort((a,b)=>a-b);\n        for(let nb of neighbors){\n          if(!seen.has(nb)){\n            seen.add(nb);\n            q.push(nb);\n            orderEdges.push([v,nb]); // edge from v to nb\n          }\n        }\n      }\n      if(animate) animateVisits(orderEdges, orderNodes, stepDelay);\n      return {orderNodes, orderEdges};\n    }\n\n    function runDFS(startId, animate=true, stepDelay=450){\n      startId = Number(startId);\n      let map = buildAdjList();\n      let seen = new Set();\n      let orderNodes = [];\n      let orderEdges = [];\n      function dfs(v){\n        seen.add(v);\n        orderNodes.push(v);\n        let neighbors = (map.get(v)||[]).slice().sort((a,b)=>a-b);\n        for(let nb of neighbors){\n          if(!seen.has(nb)){\n            orderEdges.push([v,nb]);\n            dfs(nb);\n          }\n        }\n      }\n      dfs(startId);\n      if(animate) animateVisits(orderEdges, orderNodes, stepDelay);\n      return {orderNodes,orderEdges};\n    }\n\n    bfsBtn.addEventListener('click', ()=>{\n      if(nodes.length===0) return;\n      let sid = startSelect.value || nodes[0].id;\n      runBFS(sid,true,450);\n    });\n    dfsBtn.addEventListener('click', ()=>{\n      if(nodes.length===0) return;\n      let sid = startSelect.value || nodes[0].id;\n      runDFS(sid,true,450);\n    });\n\n    // Step-by-step traversal (manual stepping)\n    stepBtn.addEventListener('click', ()=>{\n      if(nodes.length===0) return;\n      let sid = startSelect.value || nodes[0].id;\n      let {orderNodes, orderEdges} = runBFS(sid,false);\n      // show one by one with Next button\n      resetVisitVisuals();\n      let i=0;\n      let nextBtn = document.createElement('button'); nextBtn.textContent='Next'; nextBtn.className='small';\n      let stopBtn = document.createElement('button'); stopBtn.textContent='Stop'; stopBtn.className='small';\n      let ctrlBar = document.createElement('div'); ctrlBar.style.display='flex'; ctrlBar.style.gap='8px'; ctrlBar.style.marginTop='8px';\n      ctrlBar.appendChild(nextBtn); ctrlBar.appendChild(stopBtn);\n      let panel = document.querySelector('.left');\n      panel.appendChild(ctrlBar);\n      function cleanup(){\n        panel.removeChild(ctrlBar);\n        resetVisitVisuals();\n      }\n      nextBtn.addEventListener('click', ()=>{\n        if(i>=orderNodes.length) return;\n        let nid = orderNodes[i];\n        let nEl = nodeEls.get(String(nid));\n        if(nEl){\n          nEl.circle.setAttribute('fill',getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#2563eb');\n          nEl.circle.classList.add('visitedNode');\n        }\n        if(orderEdges[i-1]){\n          let [a,b]=orderEdges[i-1];\n          let el = edgeEls.get(toKey(a,b));\n          if(el){\n            el.setAttribute('stroke','#16a34a'); el.setAttribute('stroke-width','4');\n          }\n        }\n        i++;\n        if(i>=orderNodes.length){\n          nextBtn.disabled = true;\n        }\n      });\n      stopBtn.addEventListener('click', ()=>{ cleanup(); });\n    });\n\n    // Random graph generator\n    randBtn.addEventListener('click', ()=>{\n      let n = Math.max(1, Math.min(20, Number(randN.value)||6));\n      let p = Math.max(0, Math.min(1, Number(probP.value)||0.35));\n      // clear\n      nodes = []; edges = []; nodeEls.forEach(v=> nodesGroup.removeChild(v.g)); nodeEls.clear();\n      edgeEls.forEach(v=> edgesGroup.removeChild(v)); edgeEls.clear();\n      nextId = 0;\n      // place nodes in a circle\n      let cx = 500, cy = 350, r = Math.min(280, 40*n);\n      for(let i=0;i<n;i++){\n        let ang = (i/n)*Math.PI*2;\n        let x = cx + r*Math.cos(ang);\n        let y = cy + r*Math.sin(ang);\n        addNode(x,y);\n      }\n      // add edges with prob p\n      for(let i=0;i<n;i++){\n        for(let j=i+1;j<n;j++){\n          if(Math.random() < p) addEdge(i,j);\n        }\n      }\n    });\n\n    // Export / Import\n    exportBtn.addEventListener('click', ()=>{\n      let data = {nodes, edges};\n      let s = JSON.stringify(data, null, 2);\n      jsonOut.textContent = s;\n      let blob = new Blob([s], {type:'application/json'});\n      let url = URL.createObjectURL(blob);\n      let a = document.createElement('a'); a.href = url; a.download = 'graph.json'; a.click();\n      URL.revokeObjectURL(url);\n    });\n\n    fileInput.addEventListener('change', ()=>{\n      let f = fileInput.files[0];\n      if(!f) return;\n      let reader = new FileReader();\n      reader.onload = ()=> {\n        try{\n          let obj = JSON.parse(reader.result);\n          loadGraphFromJSON(obj);\n          fileInput.value = '';\n        }catch(err){\n          alert('Invalid JSON');\n        }\n      };\n      reader.readAsText(f);\n    });\n\n    function loadGraphFromJSON(obj){\n      if(!obj || !Array.isArray(obj.nodes) || !Array.isArray(obj.edges)) return;\n      // clear\n      nodes = []; edges = []; nodeEls.forEach(v=> nodesGroup.removeChild(v.g)); nodeEls.clear();\n      edgeEls.forEach(v=> edgesGroup.removeChild(v)); edgeEls.clear();\n      nextId = 0;\n      // load nodes\n      let maxId = -1;\n      obj.nodes.forEach(n=>{\n        addNode(n.x||100, n.y||100, n.id);\n        maxId = Math.max(maxId, n.id);\n      });\n      // load edges\n      obj.edges.forEach(e=>{\n        if(typeof e.a!=='number' || typeof e.b!=='number') return;\n        addEdge(e.a,e.b);\n      });\n      nextId = maxId+1;\n    }\n\n    // update edge positions whenever nodes move/created\n    const rafUpdate = ()=>{ updateEdgePositions(); requestAnimationFrame(rafUpdate); };\n    requestAnimationFrame(rafUpdate);\n\n    // initial demo graph\n    (function seedDemo(){\n      addNode(220,150); addNode(380,120); addNode(560,170); addNode(300,300); addNode(520,320); addNode(720,220);\n      addEdge(0,1); addEdge(1,2); addEdge(0,3); addEdge(1,3); addEdge(3,4); addEdge(2,5);\n      updateAdjDisplays();\n      updateStatus();\n    })();\n\n    // Prevent context menu on SVG to make right-click free\n    svg.addEventListener('contextmenu', e=>e.preventDefault());\n  </script>\n</body>\n</html>"
