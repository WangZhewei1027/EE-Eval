    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>CPU Scheduling</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .cpu {\n            width: 100px;\n            height: 100px;\n            border: 1px solid black;\n            margin: 10px;\n        }\n        .process {\n            width: 100px;\n            height: 100px;\n            border: 1px solid red;\n            margin: 10px;\n            display: inline-block;\n        }\n    </style>\n</head>\n<body>\n    <h1>CPU Scheduling</h1>\n    <div class=\"cpu\">\n        <div class=\"process\">Process 1</div>\n        <div class=\"process\">Process 2</div>\n        <div class=\"process\">Process 3</div>\n    </div>\n    <script>\n        // Create an array to store the processes\n        let processes = [\n            { id: 1, name: 'Process 1', priority: 1, timeSpent: 0 },\n            { id: 2, name: 'Process 2', priority: 2, timeSpent: 0 },\n            { id: 3, name: 'Process 3', priority: 3, timeSpent: 0 }\n        ];\n\n        // Define a function to schedule the processes\n        function scheduleProcesses(processes) {\n            // Sort the processes based on their priority and timeSpent\n            processes.sort((a, b) => b.priority - a.priority || a.timeSpent - b.timeSpent);\n\n            // Initialize the current time\n            let currentTime = 0;\n\n            // Iterate over the sorted processes\n            for (let process of processes) {\n                // Print the process name\n                console.log(`Process ${process.name} started at ${currentTime} seconds`);\n\n                // Update the current time\n                currentTime += process.timeSpent;\n\n                // Print the process name\n                console.log(`Process ${process.name} finished at ${currentTime} seconds`);\n\n                // Update the timeSpent\n                process.timeSpent = currentTime;\n            }\n        }\n\n        // Schedule the processes\n        scheduleProcesses(processes);\n\n        // Create an array to store the processes with their execution time\n        let processesWithTime = [\n            { id: 1, name: 'Process 1', priority: 1, timeSpent: 10 },\n            { id: 2, name: 'Process 2', priority: 2, timeSpent: 5 },\n            { id: 3, name: 'Process 3', priority: 3, timeSpent: 8 }\n        ];\n\n        // Define a function to execute the processes\n        function executeProcesses(processesWithTime) {\n            // Initialize the current time\n            let currentTime = 0;\n\n            // Iterate over the processes with their execution time\n            for (let process of processesWithTime) {\n                // Print the process name\n                console.log(`Process ${process.name} started at ${currentTime} seconds`);\n\n                // Update the current time\n                currentTime += process.timeSpent;\n\n                // Print the process name\n                console.log(`Process ${process.name} finished at ${currentTime} seconds`);\n\n                // Update the timeSpent\n                process.timeSpent = currentTime;\n            }\n        }\n\n        // Execute the processes\n        executeProcesses(processesWithTime);\n    </script>\n</body>\n</html>"
