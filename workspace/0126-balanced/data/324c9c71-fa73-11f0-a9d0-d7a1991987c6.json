    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Hash Table Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            background-color: #f8f8f8;\n        }\n        h1 {\n            color: #333;\n        }\n        input {\n            margin: 5px 0;\n        }\n        button {\n            margin: 5px 10px;\n            padding: 5px 10px;\n            background-color: #007bff;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #0056b3;\n        }\n        #output {\n            margin-top: 20px;\n            padding: 10px;\n            background-color: #fff;\n            border: 1px solid #ddd;\n            border-radius: 4px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Hash Table Demo</h1>\n<label for=\"key\">Key:</label>\n<input type=\"text\" id=\"key\" placeholder=\"Enter key\"><br>\n<label for=\"value\">Value:</label>\n<input type=\"text\" id=\"value\" placeholder=\"Enter value\"><br>\n<button id=\"insert\">Insert</button>\n<button id=\"retrieve\">Retrieve</button>\n<button id=\"delete\">Delete</button>\n\n<div id=\"output\"></div>\n\n<script>\n    class HashTable {\n        constructor(size) {\n            this.table = new Array(size);\n        }\n\n        // Hash function\n        hash(key) {\n            let total = 0;\n            for (let char of key) {\n                total += char.charCodeAt(0);\n            }\n            return total % this.table.length;\n        }\n\n        // Insert key-value pair\n        insert(key, value) {\n            const index = this.hash(key);\n            if (!this.table[index]) {\n                this.table[index] = [];\n            }\n            // Check if the key already exists and update the value\n            const existingPair = this.table[index].find(pair => pair[0] === key);\n            if (existingPair) {\n                existingPair[1] = value;\n            } else {\n                this.table[index].push([key, value]);\n            }\n        }\n\n        // Retrieve value by key\n        retrieve(key) {\n            const index = this.hash(key);\n            const bucket = this.table[index];\n            if (bucket) {\n                const pair = bucket.find(pair => pair[0] === key);\n                return pair ? pair[1] : undefined;\n            }\n            return undefined;\n        }\n\n        // Delete key-value pair\n        remove(key) {\n            const index = this.hash(key);\n            const bucket = this.table[index];\n            if (bucket) {\n                this.table[index] = bucket.filter(pair => pair[0] !== key);\n            }\n        }\n\n        // Display hash table content\n        display() {\n            let output = \"\";\n            for (let i = 0; i < this.table.length; i++) {\n                if (this.table[i]) {\n                    output += `Index ${i}: ${JSON.stringify(this.table[i])}<br>`;\n                }\n            }\n            return output || \"Hash Table is empty.\";\n        }\n    }\n\n    const hashTable = new HashTable(10);\n\n    document.getElementById(\"insert\").onclick = function() {\n        const key = document.getElementById(\"key\").value;\n        const value = document.getElementById(\"value\").value;\n        hashTable.insert(key, value);\n        document.getElementById(\"output\").innerHTML = \"Inserted: \" + JSON.stringify({ key, value }) + \"<br>\" + hashTable.display();\n    };\n\n    document.getElementById(\"retrieve\").onclick = function() {\n        const key = document.getElementById(\"key\").value;\n        const value = hashTable.retrieve(key);\n        document.getElementById(\"output\").innerHTML = value !== undefined ? \"Retrieved value: \" + value : \"Key not found.\";\n    };\n\n    document.getElementById(\"delete\").onclick = function() {\n        const key = document.getElementById(\"key\").value;\n        hashTable.remove(key);\n        document.getElementById(\"output\").innerHTML = \"Deleted key: \" + key + \"<br>\" + hashTable.display();\n    };\n</script>\n\n</body>\n</html>"
