    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\"/>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n  <title>Hash Map (Hash Table) Interactive Demo</title>\n  <style>\n    :root{\n      --bg:#0f1720;\n      --panel:#0b1220;\n      --card:#0f1b2a;\n      --accent:#6ee7b7;\n      --muted:#94a3b8;\n      --danger:#ff7b7b;\n      --glass: rgba(255,255,255,0.03);\n      --glass-2: rgba(255,255,255,0.02);\n      --font-sans: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    *{box-sizing:border-box}\n    body{\n      margin:0;\n      font-family:var(--font-sans);\n      background: linear-gradient(180deg,#071025 0%, #081224 50%, #091423 100%);\n      color:#e6eef8;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      padding:20px;\n      min-height:100vh;\n    }\n    .container{\n      max-width:1100px;\n      margin:0 auto;\n    }\n    header{\n      display:flex;\n      align-items:baseline;\n      gap:16px;\n      margin-bottom:18px;\n    }\n    h1{\n      margin:0;\n      font-size:20px;\n      color:var(--accent);\n      letter-spacing:0.6px;\n    }\n    p.lead{\n      margin:0;\n      color:var(--muted);\n      font-size:13px;\n    }\n    .layout{\n      display:grid;\n      grid-template-columns: 370px 1fr;\n      gap:18px;\n      align-items:start;\n    }\n    .panel{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      padding:14px;\n      border-radius:10px;\n      box-shadow: 0 6px 20px rgba(2,6,23,0.6);\n    }\n    .controls h2{margin:0 0 8px 0; font-size:15px; color:#dff5e8}\n    label{display:block; font-size:13px; color:var(--muted); margin-top:8px}\n    input[type=\"text\"], input[type=\"number\"]{\n      width:100%;\n      padding:8px 10px;\n      margin-top:6px;\n      border-radius:8px;\n      border:1px solid rgba(255,255,255,0.04);\n      background:var(--glass);\n      color:#eaf6ee;\n      outline:none;\n      font-size:14px;\n    }\n    .row{display:flex; gap:8px; margin-top:10px}\n    button{\n      padding:8px 10px;\n      border-radius:8px;\n      border:1px solid rgba(255,255,255,0.04);\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      color:#e9fbf0;\n      cursor:pointer;\n      font-size:13px;\n      flex:1;\n    }\n    button.primary{background:linear-gradient(180deg,#1b9f73,#127955); border:1px solid rgba(255,255,255,0.04)}\n    button.warn{background:linear-gradient(180deg,#b95a5a,#9e4444)}\n    .muted{background:transparent; border:1px dashed rgba(255,255,255,0.03); color:var(--muted); flex:0 0 auto; padding:6px 10px}\n    .visual {\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n    .legend{display:flex; gap:10px; align-items:center; font-size:13px; color:var(--muted)}\n    .legend .dot{width:12px;height:12px;border-radius:3px;background:var(--accent);display:inline-block;margin-right:6px}\n    .hash-table{\n      display:flex;\n      gap:8px;\n      flex-wrap:wrap;\n      padding:8px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));\n      border-radius:10px;\n      min-height:120px;\n    }\n    .bucket{\n      min-width:120px;\n      max-width:140px;\n      flex:0 0 120px;\n      background:var(--glass-2);\n      border-radius:8px;\n      padding:8px;\n      border:1px solid rgba(255,255,255,0.02);\n      position:relative;\n      transition:transform .18s ease, box-shadow .18s ease;\n    }\n    .bucket.highlight{\n      box-shadow: 0 8px 30px rgba(20,140,100,0.12), inset 0 0 0 1px rgba(110,231,183,0.06);\n      transform:translateY(-6px);\n    }\n    .bucket .index{font-size:12px;color:var(--muted); margin-bottom:6px}\n    .chain{display:flex;flex-direction:column;gap:6px}\n    .node{\n      display:flex;\n      align-items:center;\n      gap:8px;\n      padding:6px;\n      border-radius:8px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      font-size:13px;\n    }\n    .node .kv{flex:1; word-break:break-word}\n    .node .key{color:#fff; font-weight:600}\n    .node .val{color:var(--muted); font-size:12px}\n    .node button{flex:0 0 auto;padding:6px 8px;font-size:12px;border-radius:6px;background:transparent;border:1px solid rgba(255,255,255,0.03)}\n    .controls .small{font-size:12px;color:var(--muted); margin-top:6px}\n    .info{\n      margin-top:8px;\n      font-size:13px;\n      color:var(--muted);\n      display:flex;\n      gap:10px;\n      align-items:center;\n    }\n    .stats{display:flex;gap:10px;align-items:center}\n    .stat{\n      background:rgba(255,255,255,0.02);\n      border-radius:8px;padding:8px 10px;font-size:13px;color:var(--muted);\n    }\n    .log{\n      margin-top:12px;\n      background:rgba(255,255,255,0.02);\n      padding:10px;border-radius:8px;max-height:210px;overflow:auto;font-size:13px;color:var(--muted);\n    }\n    .controls .small input{width:auto; display:inline-block}\n    footer{margin-top:18px;color:var(--muted);font-size:13px;text-align:center}\n    .highlight-result{\n      padding:8px;border-radius:8px;background:rgba(110,231,183,0.07);color:var(--accent);display:inline-block;margin-left:8px;font-weight:600\n    }\n    @media (max-width:900px){\n      .layout{grid-template-columns:1fr; }\n      .bucket{flex:1 1 46%}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <header>\n      <div>\n        <h1>Hash Map (Hash Table) — Interactive Demo</h1>\n        <p class=\"lead\">Explore how keys are hashed into buckets, see collisions, chaining, insertion, lookup and deletion.</p>\n      </div>\n    </header>\n\n    <div class=\"layout\">\n      <div class=\"panel controls\">\n        <h2>Operations</h2>\n\n        <label>Key (string or number)\n          <input id=\"inputKey\" type=\"text\" placeholder=\"e.g. apple or 123\">\n        </label>\n\n        <label>Value\n          <input id=\"inputValue\" type=\"text\" placeholder=\"e.g. 42, red, {json}...\">\n        </label>\n\n        <div class=\"row\">\n          <button id=\"btnPut\" class=\"primary\">Put / Update</button>\n          <button id=\"btnGet\">Get</button>\n        </div>\n\n        <div class=\"row\">\n          <button id=\"btnDelete\" class=\"warn\">Delete</button>\n          <button id=\"btnContains\" class=\"muted\">Contains Key?</button>\n        </div>\n\n        <div class=\"row\">\n          <button id=\"btnRandom\">Insert Random Keys</button>\n          <button id=\"btnClear\" class=\"muted\">Clear Table</button>\n        </div>\n\n        <div class=\"small\">Capacity:\n          <input id=\"inputCapacity\" type=\"number\" min=\"2\" value=\"8\" style=\"width:72px;margin-left:8px\">\n          <button id=\"btnResize\" class=\"muted\" style=\"width:110px;margin-left:6px\">Resize Now</button>\n        </div>\n\n        <div class=\"small\" style=\"margin-top:8px\">\n          Auto-resize (expand on loadFactor > 0.75): <input id=\"toggleAutoResize\" type=\"checkbox\" checked>\n        </div>\n\n        <div class=\"info\">\n          <div class=\"stats\">\n            <div class=\"stat\">Size: <span id=\"statSize\">0</span></div>\n            <div class=\"stat\">Capacity: <span id=\"statCapacity\">8</span></div>\n            <div class=\"stat\">Load Factor: <span id=\"statLoad\">0.00</span></div>\n          </div>\n        </div>\n\n        <div class=\"log\" id=\"log\" aria-live=\"polite\"></div>\n      </div>\n\n      <div class=\"panel visual\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div class=\"legend\">\n            <span class=\"dot\"></span> Bucket highlighted for last operation\n          </div>\n          <div style=\"font-size:13px;color:var(--muted)\">\n            Click node Delete buttons to remove specific entry\n          </div>\n        </div>\n\n        <div class=\"hash-table\" id=\"hashTable\" aria-live=\"polite\"></div>\n\n        <div style=\"display:flex;gap:8px;align-items:center\">\n          <div style=\"font-size:13px;color:var(--muted)\">Last result:</div>\n          <div id=\"lastResult\" style=\"min-width:100px\"></div>\n        </div>\n\n        <footer>\n          Simple separate chaining implementation (each bucket holds a small linked list / array).\n        </footer>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  HashMap demo implementation (JavaScript)\n  - Uses separate chaining (each bucket is an array of entries)\n  - Simple string hash function (djb2 variant) then modulo capacity\n  - Supports put/get/remove/contains and automatic resize (double capacity)\n*/\n\nclass HashMap {\n  constructor(initialCapacity = 8, autoResize = true) {\n    this._capacity = Math.max(2, initialCapacity | 0);\n    this._buckets = Array.from({length: this._capacity}, () => []);\n    this._size = 0;\n    this._autoResize = !!autoResize;\n    this._maxLoadFactor = 0.75;\n  }\n\n  _hash(key) {\n    // Convert key to string and compute a deterministic numeric hash\n    const s = typeof key === 'string' ? key : String(key);\n    // djb2\n    let h = 5381;\n    for (let i = 0; i < s.length; i++) {\n      h = ((h << 5) + h) + s.charCodeAt(i);\n      h = h | 0;\n    }\n    return Math.abs(h) % this._capacity;\n  }\n\n  put(key, value) {\n    if (key === undefined || key === null) throw new Error(\"Key cannot be null/undefined\");\n    const idx = this._hash(key);\n    const bucket = this._buckets[idx];\n    // Try to find existing entry\n    for (let entry of bucket) {\n      if (this._equals(entry.key, key)) {\n        const old = entry.value;\n        entry.value = value;\n        return {updated: true, index: idx, oldValue: old};\n      }\n    }\n    // Insert new\n    bucket.push({key, value});\n    this._size++;\n    if (this._autoResize && this.loadFactor() > this._maxLoadFactor) {\n      this._resize(this._capacity * 2);\n    }\n    return {updated: false, index: idx};\n  }\n\n  get(key) {\n    const idx = this._hash(key);\n    const bucket = this._buckets[idx];\n    for (let entry of bucket) {\n      if (this._equals(entry.key, key)) return {found: true, value: entry.value, index: idx};\n    }\n    return {found: false, index: idx};\n  }\n\n  remove(key) {\n    const idx = this._hash(key);\n    const bucket = this._buckets[idx];\n    for (let i = 0; i < bucket.length; i++) {\n      if (this._equals(bucket[i].key, key)) {\n        const removed = bucket.splice(i,1)[0];\n        this._size--;\n        return {removed: true, value: removed.value, index: idx};\n      }\n    }\n    return {removed: false, index: idx};\n  }\n\n  containsKey(key) {\n    return this.get(key).found;\n  }\n\n  keys() {\n    const res = [];\n    for (let b of this._buckets) for (let e of b) res.push(e.key);\n    return res;\n  }\n\n  entries() {\n    const res = [];\n    for (let b of this._buckets) for (let e of b) res.push({key:e.key, value:e.value});\n    return res;\n  }\n\n  size() { return this._size; }\n  capacity() { return this._capacity; }\n  loadFactor() { return this._size / this._capacity; }\n\n  clear() {\n    this._buckets = Array.from({length: this._capacity}, () => []);\n    this._size = 0;\n  }\n\n  setAutoResize(flag) { this._autoResize = !!flag; }\n\n  _equals(a,b){\n    // simple strict equality; numbers and strings will match straightforwardly\n    return a === b;\n  }\n\n  _resize(newCap) {\n    newCap = Math.max(2, newCap | 0);\n    if (newCap === this._capacity) return;\n    const old = this._buckets;\n    this._capacity = newCap;\n    this._buckets = Array.from({length: this._capacity}, () => []);\n    const oldSize = this._size;\n    this._size = 0;\n    for (let bucket of old) {\n      for (let entry of bucket) {\n        const idx = this._hash(entry.key);\n        this._buckets[idx].push({key: entry.key, value: entry.value});\n        this._size++;\n      }\n    }\n    // size should remain same\n    if (this._size !== oldSize) {\n      // fallback: keep accurate\n      this._size = oldSize;\n    }\n  }\n\n  resizeTo(newCap) {\n    this._resize(newCap);\n  }\n}\n\n// --- UI wiring ---\nconst hm = new HashMap(8, true);\n\nconst el = {\n  inputKey: document.getElementById('inputKey'),\n  inputValue: document.getElementById('inputValue'),\n  btnPut: document.getElementById('btnPut'),\n  btnGet: document.getElementById('btnGet'),\n  btnDelete: document.getElementById('btnDelete'),\n  btnContains: document.getElementById('btnContains'),\n  btnRandom: document.getElementById('btnRandom'),\n  btnClear: document.getElementById('btnClear'),\n  btnResize: document.getElementById('btnResize'),\n  inputCapacity: document.getElementById('inputCapacity'),\n  toggleAutoResize: document.getElementById('toggleAutoResize'),\n  hashTable: document.getElementById('hashTable'),\n  statSize: document.getElementById('statSize'),\n  statCapacity: document.getElementById('statCapacity'),\n  statLoad: document.getElementById('statLoad'),\n  log: document.getElementById('log'),\n  lastResult: document.getElementById('lastResult')\n};\n\nfunction log(msg, type='info') {\n  const line = document.createElement('div');\n  const now = new Date();\n  line.textContent = `[${now.toLocaleTimeString()}] ${msg}`;\n  line.style.marginBottom = '6px';\n  if (type === 'warn') line.style.color = '#ffd9d9';\n  el.log.prepend(line);\n}\n\nfunction renderTable(highlightIndex = -1) {\n  el.hashTable.innerHTML = '';\n  const cap = hm.capacity();\n  for (let i = 0; i < cap; i++) {\n    const bucket = document.createElement('div');\n    bucket.className = 'bucket';\n    if (i === highlightIndex) bucket.classList.add('highlight');\n    const idx = document.createElement('div');\n    idx.className = 'index';\n    idx.textContent = `index ${i}`;\n    bucket.appendChild(idx);\n\n    const chain = document.createElement('div');\n    chain.className = 'chain';\n\n    const entries = hm._buckets[i];\n    if (!entries || entries.length === 0) {\n      const empty = document.createElement('div');\n      empty.className = 'node';\n      empty.textContent = '(empty)';\n      empty.style.opacity = 0.45;\n      chain.appendChild(empty);\n    } else {\n      for (let e of entries) {\n        const node = document.createElement('div');\n        node.className = 'node';\n        const kv = document.createElement('div');\n        kv.className = 'kv';\n        const keySpan = document.createElement('div');\n        keySpan.className = 'key';\n        keySpan.textContent = e.key;\n        const valSpan = document.createElement('div');\n        valSpan.className = 'val';\n        valSpan.textContent = String(e.value);\n        kv.appendChild(keySpan);\n        kv.appendChild(valSpan);\n        node.appendChild(kv);\n\n        const del = document.createElement('button');\n        del.textContent = 'Delete';\n        del.title = 'Delete this entry';\n        del.onclick = (ev) => {\n          const res = hm.remove(e.key);\n          if (res.removed) {\n            log(`Removed key=\"${e.key}\" from index ${res.index}`, 'info');\n            showResult(`Removed \"${e.key}\"`);\n            renderTable(res.index);\n            updateStats();\n          } else {\n            log(`Failed to remove key=\"${e.key}\"`, 'warn');\n          }\n        };\n        node.appendChild(del);\n\n        chain.appendChild(node);\n      }\n    }\n\n    bucket.appendChild(chain);\n    el.hashTable.appendChild(bucket);\n  }\n  updateStats();\n}\n\nfunction updateStats() {\n  el.statSize.textContent = hm.size();\n  el.statCapacity.textContent = hm.capacity();\n  el.statLoad.textContent = hm.loadFactor().toFixed(2);\n}\n\nfunction showResult(text, clearAfter=4500) {\n  el.lastResult.textContent = text;\n  if (clearAfter) {\n    setTimeout(() => {\n      el.lastResult.textContent = '';\n    }, clearAfter);\n  }\n}\n\n// Button behaviors\nel.btnPut.onclick = () => {\n  const keyRaw = el.inputKey.value.trim();\n  if (keyRaw === '') { alert('Please provide a key'); return; }\n  const key = parsePossibleJSONOrNumber(keyRaw);\n  const valueRaw = el.inputValue.value;\n  const value = parsePossibleJSONOrNumber(valueRaw);\n  try {\n    const r = hm.put(key, value);\n    if (r.updated) {\n      log(`Updated key=\"${key}\" at index ${r.index} (old value replaced)`);\n      showResult('Updated');\n    } else {\n      log(`Inserted key=\"${key}\" at index ${r.index}`);\n      showResult('Inserted');\n    }\n    renderTable(r.index);\n  } catch (e) {\n    alert(e.message);\n  }\n};\n\nel.btnGet.onclick = () => {\n  const keyRaw = el.inputKey.value.trim();\n  if (keyRaw === '') { alert('Please provide a key'); return; }\n  const key = parsePossibleJSONOrNumber(keyRaw);\n  const r = hm.get(key);\n  if (r.found) {\n    log(`Get key=\"${key}\" found at index ${r.index}: ${JSON.stringify(r.value)}`);\n    showResult(`Found: ${String(r.value)}`);\n  } else {\n    log(`Get key=\"${key}\" NOT FOUND (would map to index ${r.index})`, 'warn');\n    showResult('Not found');\n  }\n  renderTable(r.index);\n};\n\nel.btnDelete.onclick = () => {\n  const keyRaw = el.inputKey.value.trim();\n  if (keyRaw === '') { alert('Please provide a key'); return; }\n  const key = parsePossibleJSONOrNumber(keyRaw);\n  const r = hm.remove(key);\n  if (r.removed) {\n    log(`Removed key=\"${key}\" from index ${r.index}`);\n    showResult('Removed');\n  } else {\n    log(`Failed to remove key=\"${key}\" (not found). Index would be ${r.index}`, 'warn');\n    showResult('Not found');\n  }\n  renderTable(r.index);\n};\n\nel.btnContains.onclick = () => {\n  const keyRaw = el.inputKey.value.trim();\n  if (keyRaw === '') { alert('Please provide a key'); return; }\n  const key = parsePossibleJSONOrNumber(keyRaw);\n  const c = hm.containsKey(key);\n  log(`Contains key=\"${key}\"? ${c}`);\n  showResult(c ? 'Yes' : 'No');\n  renderTable(hm._hash(key));\n};\n\nel.btnRandom.onclick = () => {\n  const count = 7;\n  const words = ['apple','banana','carrot','dog','elephant','fox','grape','house','ice','jazz','kite','lion','moon','nut','orange','pear','quartz'];\n  for (let i = 0; i < count; i++) {\n    const k = words[Math.floor(Math.random()*words.length)] + (Math.random() < 0.5 ? '' : String(Math.floor(Math.random()*100)));\n    const v = Math.floor(Math.random()*1000);\n    hm.put(k, v);\n  }\n  log('Inserted some random keys (may produce collisions).');\n  renderTable();\n};\n\nel.btnClear.onclick = () => {\n  hm.clear();\n  log('Cleared table.');\n  renderTable();\n  showResult('Cleared');\n};\n\nel.btnResize.onclick = () => {\n  let n = parseInt(el.inputCapacity.value,10);\n  if (!isFinite(n) || n < 2) { alert('Capacity must be a number >= 2'); return; }\n  hm.resizeTo(n);\n  log(`Resized table to capacity ${n}. Rehashed all entries.`);\n  renderTable();\n};\n\nel.inputCapacity.onchange = () => {\n  const n = parseInt(el.inputCapacity.value,10);\n  if (isFinite(n) && n >= 2) {\n    // nothing\n  } else {\n    el.inputCapacity.value = hm.capacity();\n  }\n};\n\nel.toggleAutoResize.onchange = () => {\n  hm.setAutoResize(el.toggleAutoResize.checked);\n  log(`Auto-resize is now ${el.toggleAutoResize.checked ? 'ON' : 'OFF'}`);\n};\n\n// helper to parse numeric or JSON-like values\nfunction parsePossibleJSONOrNumber(s) {\n  if (s === '') return '';\n  // try number\n  if (!isNaN(Number(s)) && s.trim() !== '') {\n    return Number(s);\n  }\n  // try JSON (object/array/true/false/null)\n  try {\n    const j = JSON.parse(s);\n    return j;\n  } catch(e){\n    // plain string\n    return s;\n  }\n}\n\n// initialize render\nrenderTable();\n\n// Pre-populate with a few entries to demonstrate collisions\nconst initialPairs = [\n  ['apple', 'red'],\n  ['banana', 'yellow'],\n  ['grape', 'purple'],\n  ['111', 111],\n  ['222', 222],\n  ['123', {nested:true}],\n  ['apple1', 'collision?']\n];\nfor (const [k,v] of initialPairs) hm.put(k,v);\nlog('Initialized table with some sample keys.');\nrenderTable();\n\n// Accessibility: allow Enter key on inputs to trigger Put\nel.inputValue.addEventListener('keydown', (e) => { if (e.key === 'Enter') el.btnPut.click(); });\nel.inputKey.addEventListener('keydown', (e) => { if (e.key === 'Enter') el.btnPut.click(); });\n\n</script>\n</body>\n</html>"
  },
