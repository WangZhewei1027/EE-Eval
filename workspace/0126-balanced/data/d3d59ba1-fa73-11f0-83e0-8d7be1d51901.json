    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Min Heap Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --accent:#38bdf8;\n      --muted:#94a3b8;\n      --good:#10b981;\n      --bad:#ef4444;\n      --node-bg:#0b1220;\n      --node-border:#334155;\n      --node-text:#e6eef8;\n      --highlight:#fde68a;\n      --swap:#fda4af;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    html,body{height:100%; margin:0; background:linear-gradient(180deg,#071028 0%, #071226 70%); color:var(--node-text);}\n    .app {\n      max-width:1100px;\n      margin:28px auto;\n      padding:20px;\n    }\n    header{\n      display:flex;\n      align-items:center;\n      gap:16px;\n      margin-bottom:18px;\n    }\n    h1{font-size:20px;margin:0;color:var(--accent)}\n    .card{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      border-radius:12px;\n      padding:14px;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n    }\n    .controls{\n      display:flex;\n      gap:10px;\n      align-items:center;\n      flex-wrap:wrap;\n    }\n    input[type=\"number\"], input[type=\"text\"], select {\n      padding:8px 10px;\n      border-radius:8px;\n      border:1px solid rgba(255,255,255,0.06);\n      background:rgba(255,255,255,0.02);\n      color:var(--node-text);\n      outline:none;\n    }\n    button{\n      padding:8px 12px;\n      border-radius:8px;\n      border:0;\n      background:var(--accent);\n      color:#03203a;\n      font-weight:600;\n      cursor:pointer;\n    }\n    button.ghost{\n      background:transparent;\n      border:1px solid rgba(255,255,255,0.06);\n      color:var(--node-text);\n    }\n    .row { display:flex; gap:12px; align-items:center; margin-top:12px; flex-wrap:wrap; }\n    .visual {\n      margin-top:18px;\n      display:flex;\n      gap:18px;\n    }\n    .panel{\n      flex:1;\n      min-width:300px;\n    }\n    .heap-array{\n      display:flex;\n      gap:8px;\n      flex-wrap:wrap;\n      padding:10px;\n      border-radius:10px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border:1px solid rgba(255,255,255,0.02);\n      min-height:64px;\n      align-items:center;\n    }\n    .cell{\n      min-width:44px;\n      height:44px;\n      background:var(--node-bg);\n      border:1px solid var(--node-border);\n      border-radius:8px;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      font-weight:700;\n      color:var(--node-text);\n      position:relative;\n      transition:transform 220ms ease, box-shadow 220ms ease;\n    }\n    .cell.index::after{\n      content:attr(data-idx);\n      position:absolute;\n      top:-14px;\n      font-size:10px;\n      color:var(--muted);\n    }\n    .cell.highlight{\n      box-shadow:0 6px 22px rgba(56,189,248,0.12);\n      transform:translateY(-6px);\n      background:linear-gradient(180deg, rgba(56,189,248,0.06), rgba(56,189,248,0.03));\n    }\n    .cell.swap{\n      box-shadow:0 10px 34px rgba(253,164,175,0.12);\n      transform:translateY(-8px);\n      background:linear-gradient(180deg, rgba(253,164,175,0.06), rgba(253,164,175,0.03));\n    }\n\n    .tree-wrap{\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border-radius:10px;\n      padding:10px;\n      border:1px solid rgba(255,255,255,0.02);\n      min-height:280px;\n      position:relative;\n    }\n    svg { width:100%; height:100%; position:absolute; inset:0; pointer-events:none; overflow:visible;}\n    .node{\n      position:absolute;\n      width:52px;\n      height:52px;\n      border-radius:50%;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      background:var(--node-bg);\n      border:2px solid var(--node-border);\n      color:var(--node-text);\n      font-weight:700;\n      transform:translate(-50%,-50%);\n      transition:transform 260ms ease, box-shadow 260ms ease;\n      z-index:2;\n    }\n    .node .idx{\n      display:block;\n      font-size:10px;\n      color:var(--muted);\n      font-weight:600;\n      position:absolute;\n      bottom:-14px;\n      left:50%;\n      transform:translateX(-50%);\n    }\n    .node.highlight{\n      box-shadow:0 8px 28px rgba(56,189,248,0.12);\n      transform:translate(-50%,-50%) scale(1.06);\n      border-color:var(--accent);\n      background:linear-gradient(180deg, rgba(56,189,248,0.05), rgba(56,189,248,0.02));\n    }\n    .node.swap{\n      box-shadow:0 8px 28px rgba(253,164,175,0.12);\n      transform:translate(-50%,-50%) scale(1.06);\n      border-color:var(--bad);\n      background:linear-gradient(180deg, rgba(253,164,175,0.05), rgba(253,164,175,0.02));\n    }\n    .log {\n      margin-top:12px;\n      max-height:160px;\n      overflow:auto;\n      background:rgba(255,255,255,0.01);\n      border-radius:8px;\n      padding:10px;\n      border:1px solid rgba(255,255,255,0.02);\n      font-size:13px;\n      color:var(--muted);\n    }\n    .small{\n      font-size:13px;\n      color:var(--muted);\n    }\n    .controls-right { margin-left:auto; display:flex; gap:8px; align-items:center;}\n    .speed { width:120px; }\n    footer { margin-top:18px; font-size:13px; color:var(--muted); }\n    @media (max-width:880px){\n      .visual { flex-direction:column; }\n      .controls-right { margin-left:0; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <header>\n      <div>\n        <h1>Min Heap Visualizer</h1>\n        <div class=\"small\">Explore insertions, extract-min, and building a min-heap (array & tree views)</div>\n      </div>\n    </header>\n\n    <div class=\"card\">\n      <div class=\"controls\">\n        <div style=\"display:flex;gap:8px;align-items:center\">\n          <input id=\"valueInput\" type=\"number\" placeholder=\"value to insert\" />\n          <button id=\"insertBtn\">Insert</button>\n          <button id=\"extractBtn\">Extract Min</button>\n          <button id=\"peekBtn\" class=\"ghost\">Peek</button>\n        </div>\n\n        <div class=\"controls-right\">\n          <input id=\"arrayInput\" type=\"text\" placeholder=\"comma-separated values (e.g. 5,3,8,1)\" style=\"width:260px\" />\n          <button id=\"buildBtn\" class=\"ghost\">Build Heap</button>\n          <button id=\"randomBtn\" class=\"ghost\">Randomize</button>\n          <button id=\"clearBtn\" class=\"ghost\">Clear</button>\n        </div>\n      </div>\n\n      <div class=\"row\" style=\"margin-top:14px;\">\n        <div class=\"small\">Animation speed</div>\n        <input id=\"speed\" class=\"speed\" type=\"range\" min=\"50\" max=\"1200\" step=\"50\" value=\"300\" />\n        <div class=\"small\" id=\"speedVal\">300 ms</div>\n      </div>\n\n      <div class=\"visual\">\n        <div class=\"panel\">\n          <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:8px\">\n            <div class=\"small\">Array representation (index shown above each cell)</div>\n            <div class=\"small\">Size: <span id=\"size\">0</span></div>\n          </div>\n          <div id=\"arrayArea\" class=\"heap-array card\" aria-live=\"polite\"></div>\n\n          <div style=\"display:flex;gap:10px;margin-top:12px\">\n            <button id=\"stepInsert\" class=\"ghost\">Step Insert Example</button>\n            <button id=\"stepExtract\" class=\"ghost\">Step Extract Example</button>\n          </div>\n\n        </div>\n\n        <div class=\"panel\">\n          <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:8px\">\n            <div class=\"small\">Binary tree view</div>\n            <div class=\"small\">Levels: <span id=\"levels\">0</span></div>\n          </div>\n          <div class=\"tree-wrap card\" id=\"treeWrap\">\n            <svg id=\"lines\"></svg>\n            <!-- nodes will be absolutely positioned here -->\n          </div>\n        </div>\n      </div>\n\n      <div class=\"log\" id=\"log\"></div>\n    </div>\n\n    <footer>\n      Tip: Insert numbers and watch the bubble-up (sift-up). Extract Min pops the smallest element and sifts-down to restore the min-heap.\n    </footer>\n  </div>\n\n  <script>\n    // Min Heap implementation with visualization hooks.\n    class MinHeap {\n      constructor(onChange) {\n        this.data = [];\n        this.onChange = onChange; // callback to update UI and animate steps\n      }\n\n      size(){ return this.data.length; }\n      peek(){ return this.data[0]; }\n\n      parent(i){ return Math.floor((i-1)/2); }\n      left(i){ return 2*i+1; }\n      right(i){ return 2*i+2; }\n\n      async insert(val, animate=true){\n        this.data.push(val);\n        if (this.onChange) await this.onChange({type:'insert', index:this.data.length-1, heap:this.data.slice(), animate});\n        await this.bubbleUp(this.data.length-1, animate);\n      }\n\n      async bubbleUp(i, animate=true){\n        while (i>0){\n          const p = this.parent(i);\n          if (this.data[p] <= this.data[i]) break;\n          if (this.onChange) await this.onChange({type:'compare', a:p, b:i, heap:this.data.slice(), animate});\n          this.swap(p,i);\n          if (this.onChange) await this.onChange({type:'swap', a:p, b:i, heap:this.data.slice(), animate});\n          i = p;\n        }\n        if (this.onChange) await this.onChange({type:'done', heap:this.data.slice(), animate});\n      }\n\n      async extractMin(animate=true){\n        if (this.data.length===0) return undefined;\n        const min = this.data[0];\n        const last = this.data.pop();\n        if (this.onChange) await this.onChange({type:'extract', value:min, heap:this.data.slice(), animate});\n        if (this.data.length>0){\n          this.data[0]=last;\n          if (this.onChange) await this.onChange({type:'placeRoot', heap:this.data.slice(), animate});\n          await this.bubbleDown(0, animate);\n        } else {\n          if (this.onChange) await this.onChange({type:'done', heap:this.data.slice(), animate});\n        }\n        return min;\n      }\n\n      async bubbleDown(i, animate=true){\n        const n = this.data.length;\n        while (true){\n          const l = this.left(i);\n          const r = this.right(i);\n          let smallest = i;\n          if (l<n && this.data[l] < this.data[smallest]) smallest = l;\n          if (r<n && this.data[r] < this.data[smallest]) smallest = r;\n          if (smallest === i) break;\n          if (this.onChange) await this.onChange({type:'compare', a:i, b:smallest, heap:this.data.slice(), animate});\n          this.swap(i, smallest);\n          if (this.onChange) await this.onChange({type:'swap', a:i, b:smallest, heap:this.data.slice(), animate});\n          i = smallest;\n        }\n        if (this.onChange) await this.onChange({type:'done', heap:this.data.slice(), animate});\n      }\n\n      swap(i,j){\n        const t=this.data[i]; this.data[i]=this.data[j]; this.data[j]=t;\n      }\n\n      async buildFromArray(arr, animate=true){\n        this.data = arr.slice();\n        if (this.onChange) await this.onChange({type:'buildStart', heap:this.data.slice(), animate});\n        // heapify bottom-up\n        for (let i = Math.floor(this.data.length/2)-1; i>=0; i--){\n          await this.bubbleDown(i, animate);\n        }\n        if (this.onChange) await this.onChange({type:'done', heap:this.data.slice(), animate});\n      }\n\n      clear(){\n        this.data = [];\n        if (this.onChange) this.onChange({type:'clear', heap:[]});\n      }\n    }\n\n    // UI & visualization code\n    const arrayArea = document.getElementById('arrayArea');\n    const treeWrap = document.getElementById('treeWrap');\n    const linesSVG = document.getElementById('lines');\n    const logEl = document.getElementById('log');\n    const sizeEl = document.getElementById('size');\n    const levelsEl = document.getElementById('levels');\n    const speedInput = document.getElementById('speed');\n    const speedVal = document.getElementById('speedVal');\n\n    let speed = parseInt(speedInput.value,10);\n    speedInput.addEventListener('input', ()=>{ speed = parseInt(speedInput.value,10); speedVal.textContent = speed + ' ms'; });\n\n    const heap = new MinHeap(onChange);\n\n    // helpers\n    function delay(ms){ return new Promise(res => setTimeout(res, ms)); }\n\n    function log(msg){\n      const p = document.createElement('div');\n      p.textContent = msg;\n      logEl.prepend(p);\n    }\n\n    // Rendering: show array and tree with positions\n    function renderImmediate(heapArr){\n      // Array view\n      arrayArea.innerHTML = '';\n      heapArr.forEach((v,i)=>{\n        const c = document.createElement('div');\n        c.className = 'cell index';\n        c.setAttribute('data-idx', i);\n        c.textContent = v;\n        arrayArea.appendChild(c);\n      });\n      sizeEl.textContent = heapArr.length;\n\n      // Tree view\n      // Remove existing nodes\n      // We'll compute node positions per level using simple layout: assign x across width by index using inorder mapping.\n      const wrapRect = treeWrap.getBoundingClientRect();\n      const width = Math.max(wrapRect.width, 300);\n      const height = Math.max(wrapRect.height, 260);\n      linesSVG.setAttribute('viewBox', `0 0 ${width} ${height}`);\n      // clear nodes and lines\n      // Remove old node elements\n      Array.from(treeWrap.querySelectorAll('.node')).forEach(n=>n.remove());\n      while (linesSVG.firstChild) linesSVG.removeChild(linesSVG.firstChild);\n\n      if (heapArr.length===0){\n        levelsEl.textContent = '0';\n        return;\n      }\n\n      const levels = Math.floor(Math.log2(heapArr.length))+1;\n      levelsEl.textContent = ''+levels;\n\n      // compute horizontal spacing for each level\n      const levelYGap = Math.max(60, Math.floor(height / (levels+1)));\n      const positions = [];\n\n      for (let i=0;i<heapArr.length;i++){\n        const level = Math.floor(Math.log2(i+1));\n        const levelStart = Math.pow(2, level)-1;\n        const posInLevel = i - levelStart;\n        const nodesInLevel = Math.pow(2, level);\n        const x = Math.round((posInLevel+0.5) * (width / nodesInLevel));\n        const y = (level+0.5) * levelYGap;\n        positions.push({x,y});\n      }\n\n      // draw lines first\n      for (let i=0;i<heapArr.length;i++){\n        const l = heap.left(i);\n        const r = heap.right(i);\n        const p = positions[i];\n        if (l < heapArr.length){\n          const c = positions[l];\n          const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n          line.setAttribute('x1',p.x);\n          line.setAttribute('y1',p.y+26);\n          line.setAttribute('x2',c.x);\n          line.setAttribute('y2',c.y-26);\n          line.setAttribute('stroke','#18324a');\n          line.setAttribute('stroke-width','2');\n          line.setAttribute('stroke-linecap','round');\n          linesSVG.appendChild(line);\n        }\n        if (r < heapArr.length){\n          const c = positions[r];\n          const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n          line.setAttribute('x1',p.x);\n          line.setAttribute('y1',p.y+26);\n          line.setAttribute('x2',c.x);\n          line.setAttribute('y2',c.y-26);\n          line.setAttribute('stroke','#18324a');\n          line.setAttribute('stroke-width','2');\n          line.setAttribute('stroke-linecap','round');\n          linesSVG.appendChild(line);\n        }\n      }\n\n      // create nodes\n      for (let i=0;i<heapArr.length;i++){\n        const pos = positions[i];\n        const node = document.createElement('div');\n        node.className = 'node';\n        node.style.left = pos.x + 'px';\n        node.style.top = pos.y + 'px';\n        node.setAttribute('data-idx', i);\n        node.innerHTML = `<span class=\"val\">${heapArr[i]}</span><span class=\"idx\">${i}</span>`;\n        treeWrap.appendChild(node);\n      }\n    }\n\n    // Animated visual updates and step highlighting based on event types from MinHeap\n    let animating = false;\n    async function onChange(event){\n      // if animations disabled (animate false) skip delays but still update UI\n      const animate = event.animate !== false;\n      switch (event.type){\n        case 'insert':\n          renderImmediate(event.heap);\n          highlightArrayCell(event.index,'highlight', animate);\n          log(`Insert: appended ${event.heap[event.heap.length-1]} at index ${event.index}`);\n          break;\n        case 'compare':\n          renderImmediate(event.heap);\n          highlightCompare(event.a, event.b, animate);\n          log(`Compare: index ${event.a} (val=${event.heap[event.a]}) vs index ${event.b} (val=${event.heap[event.b]})`);\n          break;\n        case 'swap':\n          renderImmediate(event.heap);\n          highlightSwap(event.a, event.b, animate);\n          log(`Swap: index ${event.a} (val=${event.heap[event.a]}) with index ${event.b} (val=${event.heap[event.b]})`);\n          break;\n        case 'extract':\n          renderImmediate(event.heap);\n          log(`Extract Min: removed ${event.value}`);\n          break;\n        case 'placeRoot':\n          renderImmediate(event.heap);\n          highlightArrayCell(0,'highlight', animate);\n          log(`Place last element at root, will sift-down`);\n          break;\n        case 'buildStart':\n          renderImmediate(event.heap);\n          log(`Build heap from array: [${event.heap.join(', ')}]`);\n          break;\n        case 'done':\n          renderImmediate(event.heap);\n          log(`Operation complete. Heap: [${event.heap.join(', ')}]`);\n          break;\n        case 'clear':\n          renderImmediate([]);\n          log(`Heap cleared`);\n          break;\n      }\n      // wait small delay for animation\n      if (animate) await delay(speed);\n      removeHighlights();\n    }\n\n    function highlightArrayCell(index, cls='highlight', animate=true){\n      const cells = Array.from(arrayArea.querySelectorAll('.cell'));\n      if (index>=0 && index<cells.length){\n        cells[index].classList.add(cls);\n      }\n      const node = treeWrap.querySelector(`.node[data-idx=\"${index}\"]`);\n      if (node) node.classList.add(cls==='swap'?'swap':'highlight');\n    }\n\n    function highlightCompare(a,b, animate=true){\n      highlightArrayCell(a,'highlight',animate);\n      highlightArrayCell(b,'highlight',animate);\n    }\n\n    function highlightSwap(a,b, animate=true){\n      const cells = Array.from(arrayArea.querySelectorAll('.cell'));\n      if (a>=0 && a<cells.length) cells[a].classList.add('swap');\n      if (b>=0 && b<cells.length) cells[b].classList.add('swap');\n\n      const na = treeWrap.querySelector(`.node[data-idx=\"${a}\"]`);\n      const nb = treeWrap.querySelector(`.node[data-idx=\"${b}\"]`);\n      if (na) na.classList.add('swap');\n      if (nb) nb.classList.add('swap');\n    }\n\n    function removeHighlights(){\n      Array.from(arrayArea.querySelectorAll('.cell')).forEach(c=>c.classList.remove('highlight','swap'));\n      Array.from(treeWrap.querySelectorAll('.node')).forEach(n=>n.classList.remove('highlight','swap'));\n    }\n\n    // UI event bindings\n    document.getElementById('insertBtn').addEventListener('click', async ()=>{\n      const valEl = document.getElementById('valueInput');\n      const v = Number(valEl.value);\n      if (Number.isNaN(v)) { alert('Please enter a number to insert.'); return; }\n      valEl.value = '';\n      await heap.insert(v, true);\n    });\n\n    document.getElementById('extractBtn').addEventListener('click', async ()=>{\n      if (heap.size()===0){ alert('Heap is empty'); return; }\n      await heap.extractMin(true);\n    });\n\n    document.getElementById('peekBtn').addEventListener('click', ()=>{\n      if (heap.size()===0){ alert('Heap is empty'); return; }\n      alert('Min: ' + heap.peek());\n    });\n\n    document.getElementById('buildBtn').addEventListener('click', async ()=>{\n      const arrStr = document.getElementById('arrayInput').value.trim();\n      if (!arrStr){ alert('Enter comma-separated numbers'); return; }\n      const arr = arrStr.split(',').map(s=>Number(s.trim())).filter(x=>!Number.isNaN(x));\n      await heap.buildFromArray(arr, true);\n    });\n\n    document.getElementById('randomBtn').addEventListener('click', async ()=>{\n      const n = Math.floor(Math.random()*7)+4; // 4..10\n      const arr = Array.from({length:n},()=>Math.floor(Math.random()*90)+1);\n      document.getElementById('arrayInput').value = arr.join(', ');\n      await heap.buildFromArray(arr, true);\n    });\n\n    document.getElementById('clearBtn').addEventListener('click', ()=>{\n      heap.clear();\n    });\n\n    document.getElementById('stepInsert').addEventListener('click', async ()=>{\n      // Step-by-step demonstration: start from empty, insert a few numbers with longer pause\n      log('Starting step-by-step insert demo (7 numbers).');\n      const demo = [15, 6, 23, 4, 7, 2, 9];\n      heap.clear();\n      for (let v of demo){\n        await heap.insert(v, true);\n        await delay(200); // additional pause\n      }\n      log('Demo complete.');\n    });\n\n    document.getElementById('stepExtract').addEventListener('click', async ()=>{\n      if (heap.size()===0){ alert('Heap is empty. Build or insert some elements first.'); return; }\n      log('Step-by-step extract demo: repeatedly extract min until empty.');\n      while (heap.size()>0){\n        await heap.extractMin(true);\n        await delay(180);\n      }\n      log('All elements extracted.');\n    });\n\n    // initial render\n    renderImmediate(heap.data);\n\n    // Make visualization responsive to size changes\n    window.addEventListener('resize', ()=> renderImmediate(heap.data));\n  </script>\n</body>\n</html>"
  },
