  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Version Control Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root { --bg:#0f1724; --panel:#0b1220; --muted:#9fb3d5; --accent:#7dd3fc; --good:#22c55e; --bad:#fb7185; --card:#071022; }\n    body { margin:0; font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial; background: linear-gradient(180deg,#071024 0%, #051428 100%); color:#e6f0fb; min-height:100vh; }\n    header { padding:18px 24px; display:flex; gap:18px; align-items:center; border-bottom:1px solid rgba(255,255,255,0.03); }\n    h1 { font-size:18px; margin:0; letter-spacing:0.4px; color:var(--accent); }\n    main { display:grid; grid-template-columns: 1fr 420px; gap:16px; padding:18px; max-width:1200px; margin:0 auto; }\n    .panel { background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border-radius:8px; padding:12px; box-shadow: 0 6px 18px rgba(2,6,23,0.6); border:1px solid rgba(255,255,255,0.02); }\n    .editor { height:420px; display:flex; flex-direction:column; gap:8px; }\n    textarea { width:100%; height:100%; resize:vertical; background:transparent; color: #dff3ff; border:1px dashed rgba(255,255,255,0.04); padding:10px; border-radius:6px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace; font-size:13px; line-height:1.45; }\n    .row { display:flex; gap:8px; align-items:center; }\n    input[type=\"text\"], select { background:transparent; color:var(--muted); border:1px solid rgba(255,255,255,0.03); padding:8px 10px; border-radius:6px; min-width:0; }\n    button { background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.04); color:var(--accent); padding:8px 10px; border-radius:6px; cursor:pointer; }\n    button.ghost { background:transparent; color:var(--muted); border:1px dashed rgba(255,255,255,0.03); }\n    .muted { color:var(--muted); font-size:13px; }\n    .small { font-size:12px; color:#9bb8d6; }\n    .commits { max-height:520px; overflow:auto; padding:6px; display:flex; flex-direction:column; gap:8px; }\n    .commit { padding:8px; border-radius:8px; background:linear-gradient(90deg, rgba(255,255,255,0.01), transparent); border:1px solid rgba(255,255,255,0.02); display:flex; justify-content:space-between; gap:8px; align-items:center; }\n    .commit .meta { display:flex; gap:8px; align-items:center; }\n    .id { font-family: ui-monospace, Menlo, monospace; color:#9ec5e6; font-size:12px; background:rgba(255,255,255,0.02); padding:4px 6px; border-radius:6px; }\n    .msg { font-weight:600; color:#dff3ff; }\n    .ts { color:#89b6d8; font-size:12px; }\n    .branches { display:flex; gap:8px; flex-wrap:wrap; }\n    .branch { background:rgba(125,211,252,0.08); color:var(--accent); padding:6px 8px; border-radius:999px; font-size:12px; border:1px solid rgba(125,211,252,0.08); }\n    .controls { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }\n    .diff { white-space:pre-wrap; font-family: ui-monospace, Menlo, monospace; background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00)); padding:8px; border-radius:6px; border:1px dashed rgba(255,255,255,0.03); color:#dff3ff; max-height:300px; overflow:auto; font-size:13px; }\n    .good { color:var(--good); }\n    .bad { color:var(--bad); }\n    footer { padding:12px 18px; color:var(--muted); font-size:13px; display:flex; justify-content:center; gap:12px; }\n    .split { display:flex; gap:8px; align-items:center; }\n    .commit-actions { display:flex; gap:6px; }\n    .tag { background:rgba(255,255,255,0.02); color:var(--muted); padding:4px 6px; border-radius:6px; font-size:12px; }\n    .conflict { background: rgba(251,113,133,0.06); border-left:3px solid rgba(251,113,133,0.4); padding:6px; border-radius:4px; color:var(--bad); font-weight:600; }\n    .ok { background: rgba(34,197,94,0.06); border-left:3px solid rgba(34,197,94,0.3); padding:6px; border-radius:4px; color:var(--good); font-weight:600; }\n    .hint { color:#9fb3d5; font-size:13px; }\n    .small-muted { font-size:12px; color:#8fb0d9; }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Version Control — Interactive Demo</h1>\n    <div class=\"muted small\">Simple local demo: commits, branches, diffs, merge & revert</div>\n  </header>\n\n  <main>\n    <!-- Left: Editor and commit controls -->\n    <section class=\"panel editor\">\n      <div class=\"row\" style=\"justify-content:space-between;align-items:flex-start;\">\n        <div style=\"display:flex;flex-direction:column;gap:6px;\">\n          <div class=\"small-muted\">Current branch</div>\n          <div class=\"row\">\n            <div id=\"currentBranch\" class=\"branch\">main</div>\n            <div id=\"statusTag\" class=\"tag\">No repo</div>\n          </div>\n        </div>\n\n        <div style=\"display:flex;flex-direction:column;gap:6px;align-items:flex-end;\">\n          <div class=\"small-muted\">Repository</div>\n          <div class=\"row\">\n            <input id=\"repoName\" type=\"text\" placeholder=\"repo-demo\" value=\"repo-demo\" />\n            <button id=\"initBtn\">Init / Load</button>\n            <button id=\"clearBtn\" class=\"ghost\">Clear</button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"small-muted\">File: document.txt</div>\n      <textarea id=\"editor\" placeholder=\"Start typing...\"></textarea>\n\n      <div style=\"display:flex;gap:8px;align-items:center;\">\n        <input id=\"commitMsg\" type=\"text\" placeholder=\"Commit message...\" style=\"flex:1;\" />\n        <button id=\"commitBtn\">Commit</button>\n        <button id=\"revertBtn\" class=\"ghost\">Revert to commit</button>\n        <button id=\"diffBtn\" class=\"ghost\">Diff</button>\n      </div>\n\n      <div class=\"small muted\" id=\"editorHint\">Tip: Make changes and click Commit. Create branches, switch and merge.</div>\n\n      <div style=\"display:flex;gap:8px;align-items:center;margin-top:6px;\">\n        <select id=\"branchSelect\"></select>\n        <input id=\"newBranchInput\" placeholder=\"new-branch\" />\n        <button id=\"createBranchBtn\">Create & Switch</button>\n        <button id=\"switchBtn\" class=\"ghost\">Switch</button>\n        <button id=\"mergeBtn\" class=\"ghost\">Merge into current</button>\n      </div>\n\n      <div style=\"margin-top:8px;display:flex;gap:8px;align-items:center;\">\n        <div class=\"hint small-muted\">Last commit:</div>\n        <div id=\"lastCommit\" class=\"tag\">—</div>\n        <div id=\"lastMsg\" class=\"small-muted\"></div>\n      </div>\n    </section>\n\n    <!-- Right: commits, history, diffs -->\n    <aside class=\"panel\" style=\"display:flex;flex-direction:column;\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n        <div style=\"display:flex;flex-direction:column;\">\n          <div class=\"small-muted\">Commit History</div>\n          <div class=\"small-muted\" id=\"commitCount\">0 commits</div>\n        </div>\n        <div class=\"controls\">\n          <button id=\"showGraph\" class=\"ghost\">Show Graph</button>\n          <button id=\"exportBtn\">Export</button>\n        </div>\n      </div>\n\n      <div class=\"commits\" id=\"commitsList\" aria-live=\"polite\"></div>\n\n      <div style=\"margin-top:6px;\">\n        <div class=\"small-muted\">Diff / Merge Output</div>\n        <div id=\"diffOutput\" class=\"diff\">No diff selected.</div>\n      </div>\n    </aside>\n  </main>\n\n  <footer>\n    <div class=\"muted small\">Local-only demo — no server. Data stored in browser localStorage under a repo name.</div>\n  </footer>\n\n  <script>\n    // Simple Version Control Demo\n    // Repo model in localStorage: { commits: {id:commit}, branches: {name:id}, head: {branch:name, commit:id}, created }\n    (function(){\n      // Utilities\n      function nowISO(){ return new Date().toISOString(); }\n      function shortId(s){\n        // quick non-crypto hash for readable id\n        let h=2166136261>>>0;\n        for(let i=0;i<s.length;i++){ h ^= s.charCodeAt(i); h += (h<<1)+(h<<4)+(h<<7)+(h<<8)+(h<<24); }\n        return (h>>>0).toString(16).slice(0,8);\n      }\n      function uid(seed=\"\"){\n        return shortId(seed + Math.random().toString(36).slice(2) + Date.now());\n      }\n      function saveRepo(name, repo){ localStorage.setItem('vc_demo::'+name, JSON.stringify(repo)); }\n      function loadRepo(name){ try{ return JSON.parse(localStorage.getItem('vc_demo::'+name)); }catch(e){return null;} }\n      function removeRepo(name){ localStorage.removeItem('vc_demo::'+name); }\n\n      // DOM\n      const editor = document.getElementById('editor');\n      const commitMsg = document.getElementById('commitMsg');\n      const commitBtn = document.getElementById('commitBtn');\n      const initBtn = document.getElementById('initBtn');\n      const repoNameIn = document.getElementById('repoName');\n      const clearBtn = document.getElementById('clearBtn');\n      const branchSelect = document.getElementById('branchSelect');\n      const createBranchBtn = document.getElementById('createBranchBtn');\n      const newBranchInput = document.getElementById('newBranchInput');\n      const switchBtn = document.getElementById('switchBtn');\n      const mergeBtn = document.getElementById('mergeBtn');\n      const commitsList = document.getElementById('commitsList');\n      const currentBranchEl = document.getElementById('currentBranch');\n      const statusTag = document.getElementById('statusTag');\n      const lastCommitEl = document.getElementById('lastCommit');\n      const lastMsgEl = document.getElementById('lastMsg');\n      const commitCountEl = document.getElementById('commitCount');\n      const diffOutput = document.getElementById('diffOutput');\n      const diffBtn = document.getElementById('diffBtn');\n      const revertBtn = document.getElementById('revertBtn');\n      const exportBtn = document.getElementById('exportBtn');\n      const showGraphBtn = document.getElementById('showGraph');\n\n      let repo = null;\n      let repoName = repoNameIn.value || 'repo-demo';\n\n      // Initialize a new repository object\n      function makeRepo(){\n        return {\n          created: nowISO(),\n          commits: {},\n          branches: { main: null },\n          head: { branch: 'main', commit: null }\n        };\n      }\n\n      function setStatus(text){\n        statusTag.textContent = text;\n      }\n\n      function load(name){\n        repoName = name;\n        const r = loadRepo(name);\n        if(r){\n          repo = r;\n          setStatus('Loaded');\n        } else {\n          repo = makeRepo();\n          saveRepo(repoName, repo);\n          setStatus('New repo');\n        }\n        renderAll();\n      }\n\n      // Commit current editor content with message\n      function makeCommit(message, parents){\n        const content = editor.value;\n        const ts = nowISO();\n        const id = uid(content + message + ts);\n        const commit = { id, message: message||'(no message)', content, parents: parents||[], timestamp: ts };\n        repo.commits[id] = commit;\n        return commit;\n      }\n\n      function commitCurrent(){\n        if(!repo) return;\n        const msg = commitMsg.value.trim() || 'wip';\n        const headId = repo.head.commit;\n        const parents = headId ? [headId] : [];\n        const newC = makeCommit(msg, parents);\n        // update branch head\n        repo.head.commit = newC.id;\n        repo.branches[repo.head.branch] = newC.id;\n        saveRepo(repoName, repo);\n        commitMsg.value = '';\n        setStatus('Committed');\n        renderAll();\n      }\n\n      // Render functions\n      function renderBranches(){\n        branchSelect.innerHTML = '';\n        for(const b of Object.keys(repo.branches)){\n          const opt = document.createElement('option');\n          opt.value = b;\n          opt.textContent = b;\n          branchSelect.appendChild(opt);\n        }\n        currentBranchEl.textContent = repo.head.branch || 'main';\n      }\n\n      function getCommitChain(startId){\n        // return list of commit ids walking parents depth-first (single parent chain mostly)\n        const out = [];\n        const seen = new Set();\n        function walk(id){\n          if(!id || seen.has(id)) return;\n          seen.add(id);\n          out.push(id);\n          const c = repo.commits[id];\n          if(!c) return;\n          for(const p of c.parents) walk(p);\n        }\n        walk(startId);\n        return out;\n      }\n\n      function renderCommits(){\n        commitsList.innerHTML = '';\n        const head = repo.head.commit;\n        if(!head){\n          commitsList.innerHTML = '<div class=\"small-muted\">No commits yet.</div>';\n          commitCountEl.textContent = '0 commits';\n          lastCommitEl.textContent = '—';\n          lastMsgEl.textContent = '';\n          return;\n        }\n        // Flatten commits reachable from heads of branches, but order by timestamp desc\n        const ids = Object.values(repo.commits).map(c=>c.id);\n        const commits = ids.map(id=>repo.commits[id]).sort((a,b)=> b.timestamp.localeCompare(a.timestamp));\n        commitCountEl.textContent = commits.length + ' commits';\n        // Show branches labels per commit\n        const branchMap = {};\n        for(const b of Object.keys(repo.branches)){\n          const id = repo.branches[b];\n          if(id) branchMap[id] = branchMap[id]||[];\n          if(id) branchMap[id].push(b);\n        }\n        for(const c of commits){\n          const item = document.createElement('div');\n          item.className = 'commit';\n          const left = document.createElement('div');\n          left.className = 'meta';\n          const idspan = document.createElement('div');\n          idspan.className = 'id';\n          idspan.textContent = c.id.slice(0,8);\n          const msg = document.createElement('div');\n          msg.className = 'msg';\n          msg.textContent = c.message;\n          const ts = document.createElement('div');\n          ts.className = 'ts';\n          ts.textContent = new Date(c.timestamp).toLocaleString();\n          left.appendChild(idspan);\n          left.appendChild(msg);\n          left.appendChild(ts);\n\n          const right = document.createElement('div');\n          right.style.display = 'flex';\n          right.style.gap = '6px';\n          right.style.alignItems = 'center';\n\n          // branch labels\n          if(branchMap[c.id]){\n            for(const b of branchMap[c.id]){\n              const bdiv = document.createElement('div');\n              bdiv.className = 'branch';\n              bdiv.textContent = b;\n              right.appendChild(bdiv);\n            }\n          }\n\n          const actions = document.createElement('div');\n          actions.className = 'commit-actions';\n          const viewBtn = document.createElement('button'); viewBtn.className='ghost'; viewBtn.textContent='View';\n          viewBtn.onclick = ()=>{ editor.value = c.content; setStatus('Checked out content'); };\n          const checkoutBtn = document.createElement('button'); checkoutBtn.textContent='Checkout';\n          checkoutBtn.onclick = ()=> { // detach HEAD (simple checkout -> create branch named temp and point head)\n            const name = prompt('Create a branch name to checkout this commit (or leave to detach HEAD):','detached-'+c.id.slice(0,6));\n            if(name){\n              repo.branches[name] = c.id;\n              repo.head.branch = name;\n              repo.head.commit = c.id;\n              saveRepo(repoName, repo);\n              renderAll();\n            } else {\n              repo.head.commit = c.id;\n              // leave branch unchanged but HEAD points to commit (detached state not fully modeled)\n              saveRepo(repoName, repo);\n              renderAll();\n            }\n            setStatus('Checked out commit');\n          };\n          const diffBtnLocal = document.createElement('button'); diffBtnLocal.className='ghost'; diffBtnLocal.textContent='Diff→Editor';\n          diffBtnLocal.onclick = ()=>{ showDiff(c.id, repo.head.commit); };\n\n          const revertLocal = document.createElement('button'); revertLocal.className='ghost'; revertLocal.textContent='Revert';\n          revertLocal.onclick = ()=>{ if(confirm('Revert editor to this commit?')){ editor.value = c.content; setStatus('Reverted editor'); } };\n\n          actions.appendChild(viewBtn);\n          actions.appendChild(checkoutBtn);\n          actions.appendChild(diffBtnLocal);\n          actions.appendChild(revertLocal);\n\n          right.appendChild(actions);\n\n          item.appendChild(left);\n          item.appendChild(right);\n          commitsList.appendChild(item);\n        }\n\n        const last = commits[0];\n        lastCommitEl.textContent = last.id.slice(0,8);\n        lastMsgEl.textContent = last.message;\n      }\n\n      // Basic diff: line-based unified diff-ish\n      function diffStrings(a,b){\n        const A = a.split(/\\r?\\n/);\n        const B = b.split(/\\r?\\n/);\n        const max = Math.max(A.length, B.length);\n        const out = [];\n        for(let i=0;i<max;i++){\n          const la = A[i], lb = B[i];\n          if(la===lb){\n            out.push('  '+(la===undefined?'':la));\n          } else {\n            if(la!==undefined) out.push('- '+la);\n            if(lb!==undefined) out.push('+ '+lb);\n          }\n        }\n        return out.join('\\n');\n      }\n\n      // Find common ancestor (LCA) by exploring ancestors sets\n      function getAncestorsSet(id){\n        const s = new Set();\n        function walk(cid){\n          if(!cid || s.has(cid)) return;\n          s.add(cid);\n          const c = repo.commits[cid];\n          if(!c) return;\n          for(const p of c.parents) walk(p);\n        }\n        walk(id);\n        return s;\n      }\n      function findCommonAncestor(a,b){\n        const As = getAncestorsSet(a);\n        // BFS from b's ancestors until we find one in As, prefer newest by timestamp\n        const queue = [b];\n        const visited = new Set();\n        while(queue.length){\n          const cid = queue.shift();\n          if(!cid || visited.has(cid)) continue;\n          visited.add(cid);\n          if(As.has(cid)) return cid;\n          const c = repo.commits[cid];\n          if(!c) continue;\n          for(const p of c.parents) queue.push(p);\n        }\n        return null;\n      }\n\n      // Three-way merge (simple line-based): base, ours, theirs -> auto-merge when possible, else conflict markers\n      function threeWayMerge(base, ours, theirs){\n        const Ba = base.split(/\\r?\\n/);\n        const Oa = ours.split(/\\r?\\n/);\n        const Ta = theirs.split(/\\r?\\n/);\n        const max = Math.max(Ba.length, Oa.length, Ta.length);\n        const out = [];\n        let conflict = false;\n        for(let i=0;i<max;i++){\n          const b = Ba[i], o = Oa[i], t = Ta[i];\n          if(o===t){\n            out.push(o===undefined?'':o);\n          } else if(b===o){\n            out.push(t===undefined?'':t);\n          } else if(b===t){\n            out.push(o===undefined?'':o);\n          } else {\n            // conflict\n            conflict = true;\n            out.push('<<<<<<< OURS');\n            out.push(o===undefined?'':o);\n            out.push('=======');\n            out.push(t===undefined?'':t);\n            out.push('>>>>>>> THEIRS');\n          }\n        }\n        return { text: out.join('\\n'), conflict };\n      }\n\n      // Merge branch into current branch\n      function mergeIntoCurrent(theirBranchName){\n        const ourBranch = repo.head.branch;\n        const ourId = repo.head.commit;\n        const theirId = repo.branches[theirBranchName];\n        if(!theirId){ alert('Branch has no commits'); return; }\n        if(theirId === ourId){ alert('Already same commit'); return; }\n\n        const baseId = findCommonAncestor(ourId, theirId);\n        const base = baseId ? repo.commits[baseId].content : '';\n        const ours = ourId ? repo.commits[ourId].content : '';\n        const theirs = repo.commits[theirId].content;\n        const merged = threeWayMerge(base, ours, theirs);\n\n        // Create merge commit with two parents\n        const message = `Merge ${theirBranchName} into ${ourBranch}`;\n        const mergeCommit = makeCommit(message, [ourId, theirId]);\n        mergeCommit.content = merged.text;\n        // Save commit into repo and update head\n        repo.commits[mergeCommit.id] = mergeCommit;\n        repo.head.commit = mergeCommit.id;\n        repo.branches[ourBranch] = mergeCommit.id;\n        saveRepo(repoName, repo);\n        renderAll();\n        if(merged.conflict){\n          diffOutput.innerHTML = '<div class=\"conflict\">Merge created with conflicts. Resolve in editor then commit.</div><pre class=\"diff\">'+escapeHtml(merged.text)+'</pre>';\n        } else {\n          diffOutput.innerHTML = '<div class=\"ok\">Merge successful (auto-merged).</div><pre class=\"diff\">'+escapeHtml(merged.text)+'</pre>';\n        }\n      }\n\n      // Show diff between two commits: choose commit id or current editor\n      function showDiff(aId, bId){\n        let A = '', B = '';\n        if(aId && repo.commits[aId]) A = repo.commits[aId].content;\n        if(bId && repo.commits[bId]) B = repo.commits[bId].content;\n        if(!aId && bId) A = editor.value;\n        if(!bId) B = editor.value;\n        const d = diffStrings(A,B);\n        diffOutput.innerHTML = '<pre class=\"diff\">'+escapeHtml(d)+'</pre>';\n      }\n\n      function escapeHtml(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\n\n      // UI actions\n      initBtn.onclick = ()=> load(repoNameIn.value.trim() || 'repo-demo');\n      clearBtn.onclick = ()=> { if(confirm('Clear local repo data?')){ removeRepo(repoNameIn.value.trim()||'repo-demo'); load(repoNameIn.value.trim()||'repo-demo'); } };\n\n      commitBtn.onclick = commitCurrent;\n      createBranchBtn.onclick = ()=>{\n        const name = (newBranchInput.value||'').trim();\n        if(!name){ alert('Enter branch name'); return; }\n        if(repo.branches[name]){ alert('Branch exists'); return; }\n        repo.branches[name] = repo.head.commit;\n        repo.head.branch = name;\n        saveRepo(repoName, repo);\n        renderAll();\n        setStatus('Created branch '+name);\n      };\n      switchBtn.onclick = ()=>{\n        const b = branchSelect.value;\n        if(!b) return;\n        repo.head.branch = b;\n        // move head.commit to branch head\n        repo.head.commit = repo.branches[b];\n        saveRepo(repoName, repo);\n        renderAll();\n        setStatus('Switched to '+b);\n      };\n      mergeBtn.onclick = ()=>{\n        const target = branchSelect.value;\n        if(!target){ alert('Select a branch to merge'); return; }\n        if(target === repo.head.branch){ alert('Cannot merge a branch into itself'); return; }\n        if(!confirm(`Merge branch \"${target}\" into current \"${repo.head.branch}\"?`)) return;\n        mergeIntoCurrent(target);\n      };\n      diffBtn.onclick = ()=>{\n        // prompt to pick a commit to diff against current editor\n        const commitList = Object.values(repo.commits).map(c=> c.id.slice(0,8) + ' — ' + c.message);\n        const pick = prompt('Enter commit id (short) to diff against editor:\\n' + commitList.join('\\n') + '\\n\\nLeave blank to diff editor vs HEAD', '');\n        if(pick===null) return;\n        let pickedId = null;\n        if(pick.trim() === '') pickedId = repo.head.commit;\n        else {\n          // find commit by prefix\n          const found = Object.values(repo.commits).find(c=>c.id.startsWith(pick.trim()));\n          if(found) pickedId = found.id;\n          else { alert('Commit not found'); return; }\n        }\n        showDiff(pickedId, null);\n      };\n      revertBtn.onclick = ()=>{\n        const pick = prompt('Enter commit id (short) to revert editor to:', '');\n        if(!pick) return;\n        const found = Object.values(repo.commits).find(c=>c.id.startsWith(pick.trim()));\n        if(!found){ alert('Commit not found'); return; }\n        if(!confirm('Revert editor content to commit '+found.id.slice(0,8)+'?')) return;\n        editor.value = found.content;\n        setStatus('Editor reverted');\n      };\n\n      exportBtn.onclick = ()=>{\n        const data = JSON.stringify(repo, null, 2);\n        const blob = new Blob([data], {type:'application/json'});\n        const url = URL.createObjectURL(blob);\n        const a = document.createElement('a');\n        a.href = url; a.download = repoName + '-export.json'; document.body.appendChild(a); a.click(); a.remove();\n        URL.revokeObjectURL(url);\n      };\n\n      showGraphBtn.onclick = ()=>{\n        // simple \"graph\": show reachability per branch\n        const lines = [];\n        for(const b of Object.keys(repo.branches)){\n          lines.push(b + ' -> ' + (repo.branches[b] ? repo.branches[b].slice(0,8) : '(empty)'));\n        }\n        alert('Branches:\\n' + lines.join('\\n') + '\\n\\nNote: commits can have multiple parents for merges.');\n      };\n\n      // Render all UI parts\n      function renderAll(){\n        if(!repo) return;\n        renderBranches();\n        renderCommits();\n        currentBranchEl.textContent = repo.head.branch;\n        // update editor with head content only if repository freshly loaded and editor is empty\n        if(editor.value.trim()===''){\n          if(repo.head.commit){\n            const c = repo.commits[repo.head.commit];\n            if(c) editor.value = c.content;\n            else editor.value = '';\n          } else {\n            editor.value = '';\n          }\n        }\n        setStatus('Ready');\n      }\n\n      // Initialize default load\n      load(repoName);\n\n      // Keyboard: Ctrl+Enter to commit\n      editor.addEventListener('keydown', (e)=>{\n        if((e.ctrlKey||e.metaKey) && e.key==='Enter'){ commitCurrent(); e.preventDefault(); }\n      });\n\n      // For demonstration: create an initial commit if none exists when user first inits repo\n      initBtn.addEventListener('click', ()=>{\n        if(repo && !repo.head.commit){\n          if(confirm('Repository empty. Create initial commit from current editor content?')){\n            const c = makeCommit('Initial commit', []);\n            repo.commits[c.id] = c;\n            repo.head.commit = c.id;\n            repo.branches[repo.head.branch] = c.id;\n            saveRepo(repoName, repo);\n            renderAll();\n            setStatus('Initial commit created');\n          }\n        }\n      });\n    })();\n  </script>\n</body>\n</html>"
