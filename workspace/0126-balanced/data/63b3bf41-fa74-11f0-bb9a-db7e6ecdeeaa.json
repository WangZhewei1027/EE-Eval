    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Unit Testing Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2em;\n      background: #f9f9f9;\n    }\n    h1 {\n      color: #333;\n    }\n    #testResults {\n      margin-top: 1em;\n      padding: 1em;\n      background: #fff;\n      border: 1px solid #ddd;\n      max-width: 600px;\n    }\n    .test-pass {\n      color: green;\n    }\n    .test-fail {\n      color: red;\n    }\n    pre {\n      background: #eee;\n      padding: 0.5em;\n      overflow-x: auto;\n    }\n  </style>\n</head>\n<body>\n  <h1>Unit Testing Demo</h1>\n  <p>This example demonstrates the concept of <strong>Unit Testing</strong> using plain JavaScript. Unit tests verify that individual parts of your code (units) work as expected.</p>\n\n  <h2>Example function: <code>add(a, b)</code></h2>\n  <p>We will write unit tests to verify that this function works correctly.</p>\n\n  <pre>\nfunction add(a, b) {\n  return a + b;\n}\n  </pre>\n\n  <button id=\"runTestsBtn\">Run Unit Tests</button>\n\n  <div id=\"testResults\"></div>\n\n  <script>\n    // Example function to unit test\n    function add(a, b) {\n      return a + b;\n    }\n\n    /**\n     * Simple unit test framework\n     * - test(name, function)\n     * - assertEquals(actual, expected)\n     */\n    const testResultsDiv = document.getElementById('testResults');\n\n    function assertEquals(actual, expected) {\n      // Strict equality check\n      if (actual === expected) {\n        return { pass: true };\n      } else {\n        return {\n          pass: false,\n          message: `Expected: ${expected}, but got: ${actual}`\n        };\n      }\n    }\n\n    const tests = [];\n\n    function test(name, testFunction) {\n      tests.push({ name, testFunction });\n    }\n\n    // Define tests\n    test(\"add(1, 2) should return 3\", () => {\n      return assertEquals(add(1, 2), 3);\n    });\n\n    test(\"add(-1, -1) should return -2\", () => {\n      return assertEquals(add(-1, -1), -2);\n    });\n\n    test(\"add(0, 0) should return 0\", () => {\n      return assertEquals(add(0, 0), 0);\n    });\n\n    test(\"add(1.5, 2.5) should return 4\", () => {\n      return assertEquals(add(1.5, 2.5), 4);\n    });\n\n    test(\"add('Hello', ' World') should return 'Hello World'\", () => {\n      return assertEquals(add(\"Hello\", \" World\"), \"Hello World\");\n    });\n\n    // Run tests and show results\n    function runAllTests() {\n      testResultsDiv.innerHTML = \"\"; // Clear previous results\n      let passedCount = 0;\n      let failedCount = 0;\n\n      tests.forEach(({ name, testFunction }) => {\n        try {\n          const result = testFunction();\n          if (result.pass) {\n            passedCount++;\n            const passElem = document.createElement(\"div\");\n            passElem.className = \"test-pass\";\n            passElem.textContent = `✓ ${name}`;\n            testResultsDiv.appendChild(passElem);\n          } else {\n            failedCount++;\n            const failElem = document.createElement(\"div\");\n            failElem.className = \"test-fail\";\n            failElem.innerHTML = `✗ ${name} <br/><small>${result.message}</small>`;\n            testResultsDiv.appendChild(failElem);\n          }\n        } catch (e) {\n          failedCount++;\n          const errorElem = document.createElement(\"div\");\n          errorElem.className = \"test-fail\";\n          errorElem.innerHTML = `✗ ${name} <br/><small>Error: ${e.message}</small>`;\n          testResultsDiv.appendChild(errorElem);\n        }\n      });\n\n      const summary = document.createElement(\"div\");\n      summary.style.marginTop = \"1em\";\n      summary.style.fontWeight = \"bold\";\n      summary.textContent = `Passed: ${passedCount}, Failed: ${failedCount}`;\n      testResultsDiv.appendChild(summary);\n    }\n\n    document.getElementById(\"runTestsBtn\").addEventListener(\"click\", () => {\n      runAllTests();\n    });\n  </script>\n</body>\n</html>"
