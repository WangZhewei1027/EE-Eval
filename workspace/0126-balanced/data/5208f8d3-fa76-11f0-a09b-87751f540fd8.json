    "content": "<html>\n<head>\n    <title>Binary Search</title>\n</head>\n<body>\n    <h1>Binary Search</h1>\n    <input type=\"number\" id=\"searchValue\" placeholder=\"Enter a value to search for\">\n    <button id=\"searchButton\">Search</button>\n    <div id=\"result\"></div>\n\n    <script>\n        function binarySearch(value, array) {\n            let left = 0;\n            let right = array.length - 1;\n            let mid;\n\n            while (left <= right) {\n                mid = Math.floor((left + right) / 2);\n                if (value === array[mid]) {\n                    return true;\n                } else if (value < array[mid]) {\n                    right = mid - 1;\n                } else {\n                    left = mid + 1;\n                }\n            }\n\n            return false;\n        }\n\n        const array = [2, 5, 8, 12, 16, 23, 38, 56, 72, 91];\n        const searchValue = parseInt(document.getElementById(\"searchValue\").value);\n\n        const result = document.getElementById(\"result\");\n        result.innerHTML = \"\";\n\n        if (binarySearch(searchValue, array)) {\n            result.innerHTML = \"Value found: \" + searchValue;\n        } else {\n            result.innerHTML = \"Value not found\";\n        }\n    </script>\n</body>\n</html>"
