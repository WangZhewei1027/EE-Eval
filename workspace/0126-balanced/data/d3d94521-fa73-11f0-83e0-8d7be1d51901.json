  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Paging Demo — Virtual Memory</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1720;\n      --card:#0b1220;\n      --muted:#98a0b0;\n      --accent:#3fb0ff;\n      --accent2:#7bffb0;\n      --danger:#ff7b7b;\n      --ok:#7bffb0;\n      --glass: rgba(255,255,255,0.03);\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,#071020 0%, #072233 60%);color:#e6eef6;}\n    .wrap{max-width:1100px;margin:28px auto;padding:22px;background:linear-gradient(180deg,rgba(255,255,255,0.02),transparent);border-radius:12px;box-shadow:0 6px 30px rgba(0,0,0,0.6)}\n    h1{margin:0 0 8px;font-size:20px}\n    p.lead{margin:4px 0 18px;color:var(--muted);font-size:13px}\n    .controls{\n      display:flex;gap:12px;flex-wrap:wrap;margin-bottom:18px;\n    }\n    .card{\n      background:var(--card);padding:12px;border-radius:10px;flex:1;min-width:220px;\n      box-shadow:inset 0 1px 0 rgba(255,255,255,0.02);\n    }\n    label{font-size:12px;color:var(--muted);display:block;margin-bottom:6px}\n    input[type=\"number\"],select,input[type=\"text\"]{\n      width:100%;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.04);\n      background:var(--glass);color:inherit;font-size:13px;\n    }\n    .row{display:flex;gap:8px}\n    .row > *{flex:1}\n    button{\n      background:linear-gradient(90deg,var(--accent) 0%, #79c7ff 100%);border:none;padding:8px 12px;border-radius:8px;color:#012338;font-weight:600;cursor:pointer;\n      box-shadow:0 6px 18px rgba(63,176,255,0.08);\n    }\n    button.ghost{background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted);font-weight:600}\n    .main-grid{display:grid;grid-template-columns:1fr 420px;gap:14px}\n    .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);padding:12px;border-radius:10px}\n    table{width:100%;border-collapse:collapse;font-size:13px}\n    th,td{padding:6px 8px;text-align:left;border-bottom:1px dashed rgba(255,255,255,0.03)}\n    th{font-size:12px;color:var(--muted)}\n    .small{font-size:12px;color:var(--muted)}\n    .frames{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n    .frame{\n      min-width:60px;padding:8px;border-radius:8px;text-align:center;background:linear-gradient(180deg,#08141e,#07131b);\n      border:1px solid rgba(255,255,255,0.03);\n    }\n    .frame .id{font-size:11px;color:var(--muted)}\n    .frame .page{font-weight:700;font-size:15px;margin-top:6px}\n    .valid{color:var(--ok)}\n    .invalid{color:var(--muted)}\n    .log{height:260px;overflow:auto;padding:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);border-radius:8px;border:1px solid rgba(255,255,255,0.02);font-family:monospace;font-size:13px}\n    .stats{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n    .stat{padding:8px;border-radius:8px;background:rgba(255,255,255,0.02);min-width:110px}\n    .tlb{display:flex;gap:8px;flex-wrap:wrap}\n    .tlb .entry{padding:8px;border-radius:8px;background:rgba(255,255,255,0.01);border:1px solid rgba(255,255,255,0.02);min-width:80px}\n    .hilite{background:linear-gradient(90deg,rgba(127,191,255,0.12),transparent);border-radius:6px;padding:6px}\n    footer{margin-top:14px;color:var(--muted);font-size:12px}\n    .controls .card.small{flex:0 0 220px}\n    .muted{color:var(--muted)}\n    .danger{color:var(--danger)}\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <h1>Paging Demo — Virtual Memory</h1>\n    <p class=\"lead\">Interactive simulation of paging: break virtual addresses into page number + offset, translate via page table (and optional TLB), simulate page faults and replacements (FIFO / LRU).</p>\n\n    <div class=\"controls\">\n      <div class=\"card small\">\n        <label>Number of virtual pages</label>\n        <input id=\"numPages\" type=\"number\" min=\"2\" max=\"256\" value=\"16\" />\n      </div>\n      <div class=\"card small\">\n        <label>Page size (bytes)</label>\n        <input id=\"pageSize\" type=\"number\" min=\"4\" max=\"4096\" step=\"4\" value=\"64\" />\n      </div>\n      <div class=\"card small\">\n        <label>Physical frames</label>\n        <input id=\"numFrames\" type=\"number\" min=\"1\" max=\"64\" value=\"4\" />\n      </div>\n      <div class=\"card small\">\n        <label>Replacement policy</label>\n        <select id=\"policy\">\n          <option value=\"fifo\">FIFO</option>\n          <option value=\"lru\">LRU</option>\n        </select>\n      </div>\n      <div class=\"card small\">\n        <label>Enable TLB</label>\n        <select id=\"tlbEnable\">\n          <option value=\"false\">No</option>\n          <option value=\"true\" selected>Yes</option>\n        </select>\n        <label class=\"small\" style=\"margin-top:6px\">TLB entries</label>\n        <input id=\"tlbEntries\" type=\"number\" min=\"1\" max=\"64\" value=\"4\" />\n      </div>\n\n      <div style=\"flex:0 0 210px\" class=\"card\">\n        <label>Reset / Build</label>\n        <div class=\"row\">\n          <button id=\"buildBtn\">Build</button>\n          <button id=\"resetBtn\" class=\"ghost\">Reset</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"main-grid\">\n      <div>\n        <div class=\"panel\">\n          <div style=\"display:flex;gap:12px;align-items:center\">\n            <div style=\"flex:1\">\n              <label>Access virtual address (decimal or 0xhex)</label>\n              <input id=\"accessAddr\" type=\"text\" placeholder=\"e.g. 123 or 0x7B\" />\n            </div>\n            <div style=\"width:260px;display:flex;gap:8px\">\n              <button id=\"accessBtn\">Access</button>\n              <button id=\"randBtn\" class=\"ghost\">Random</button>\n              <button id=\"seqBtn\" class=\"ghost\">Seq (20)</button>\n            </div>\n          </div>\n\n          <div style=\"display:flex;gap:12px;margin-top:12px;flex-wrap:wrap\">\n            <div style=\"flex:1\" class=\"hilite\">\n              <label>Address breakdown</label>\n              <div id=\"breakdown\" style=\"padding:8px;font-family:monospace\"></div>\n            </div>\n            <div style=\"width:200px\">\n              <label>Counters</label>\n              <div class=\"stats\">\n                <div class=\"stat\"><div class=\"small\">Accesses</div><div id=\"cntAccess\">0</div></div>\n                <div class=\"stat\"><div class=\"small\">Hits</div><div id=\"cntHit\">0</div></div>\n                <div class=\"stat\"><div class=\"small\">Page faults</div><div id=\"cntPF\">0</div></div>\n              </div>\n            </div>\n          </div>\n\n          <div style=\"margin-top:12px;display:flex;gap:10px\">\n            <div style=\"flex:1\">\n              <label>Page table</label>\n              <div id=\"ptableWrap\" style=\"margin-top:8px\"></div>\n            </div>\n            <div style=\"width:220px\">\n              <label>Physical frames</label>\n              <div id=\"framesWrap\" class=\"frames\"></div>\n            </div>\n          </div>\n\n        </div>\n\n        <div class=\"panel\" style=\"margin-top:12px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div>\n              <label>TLB (if enabled)</label>\n            </div>\n            <div class=\"small muted\">replacement: LRU</div>\n          </div>\n          <div class=\"tlb\" id=\"tlbWrap\" style=\"margin-top:8px\"></div>\n\n          <div style=\"margin-top:12px\">\n            <label>Event log</label>\n            <div id=\"log\" class=\"log\"></div>\n          </div>\n        </div>\n\n      </div>\n\n      <div>\n        <div class=\"panel\">\n          <label>Visualization / Legend</label>\n          <div style=\"margin-top:8px;font-size:13px;color:var(--muted)\">\n            - Virtual addresses are split: <b>Page number</b> + <b>Offset</b>. Page size determines offset bits.<br>\n            - Page table maps each virtual page to a physical frame (or invalid). A page fault happens when a page is not in memory.<br>\n            - Replacement policy decides which resident page to evict when frames are full.<br>\n            - TLB caches recent translations for faster hits.\n          </div>\n\n          <hr style=\"margin:10px 0;border:none;border-top:1px dashed rgba(255,255,255,0.03)\" />\n\n          <div style=\"display:flex;gap:8px;flex-wrap:wrap\">\n            <div class=\"frame\"><div class=\"id\">Valid</div><div class=\"page valid\">In memory</div></div>\n            <div class=\"frame\"><div class=\"id\">Invalid</div><div class=\"page invalid\">Not present</div></div>\n            <div class=\"frame\"><div class=\"id\">TLB</div><div class=\"page\">Cache</div></div>\n            <div class=\"frame\"><div class=\"id\">PF</div><div class=\"page danger\">Page fault</div></div>\n          </div>\n\n        </div>\n\n        <div class=\"panel\" style=\"margin-top:12px\">\n          <label>Sequence control</label>\n          <div style=\"display:flex;gap:8px;margin-top:8px\">\n            <button id=\"runSeq\">Run sequence (auto)</button>\n            <button id=\"stepSeq\" class=\"ghost\">Step</button>\n            <button id=\"clearLog\" class=\"ghost\">Clear log</button>\n          </div>\n          <div style=\"margin-top:8px\" class=\"small muted\">The \"Seq (20)\" button generates a pattern with locality to demonstrate replacement.</div>\n        </div>\n      </div>\n    </div>\n\n    <footer>Simple educational simulator — addresses limited to virtual space; no real disk I/O, just simulated loads/evictions.</footer>\n  </div>\n\n<script>\n(() => {\n  // Elements\n  const numPagesEl = document.getElementById('numPages');\n  const pageSizeEl = document.getElementById('pageSize');\n  const numFramesEl = document.getElementById('numFrames');\n  const policyEl = document.getElementById('policy');\n  const buildBtn = document.getElementById('buildBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const accessAddrEl = document.getElementById('accessAddr');\n  const accessBtn = document.getElementById('accessBtn');\n  const randBtn = document.getElementById('randBtn');\n  const seqBtn = document.getElementById('seqBtn');\n  const breakdownEl = document.getElementById('breakdown');\n  const ptableWrap = document.getElementById('ptableWrap');\n  const framesWrap = document.getElementById('framesWrap');\n  const cntAccessEl = document.getElementById('cntAccess');\n  const cntHitEl = document.getElementById('cntHit');\n  const cntPFEl = document.getElementById('cntPF');\n  const logEl = document.getElementById('log');\n  const tlbEnableEl = document.getElementById('tlbEnable');\n  const tlbEntriesEl = document.getElementById('tlbEntries');\n  const tlbWrap = document.getElementById('tlbWrap');\n  const runSeqBtn = document.getElementById('runSeq');\n  const stepSeqBtn = document.getElementById('stepSeq');\n  const clearLogBtn = document.getElementById('clearLog');\n\n  let state = null;\n  let seq = [];\n  let seqIndex = 0;\n  let autoRunTimer = null;\n\n  function log(...args){\n    const s = args.join(' ');\n    const p = document.createElement('div');\n    p.textContent = s;\n    logEl.prepend(p);\n  }\n\n  function build(){\n    const numPages = parseInt(numPagesEl.value,10);\n    const pageSize = parseInt(pageSizeEl.value,10);\n    const numFrames = parseInt(numFramesEl.value,10);\n    const policy = policyEl.value;\n    const tlbEnabled = (tlbEnableEl.value === 'true');\n    const tlbSize = parseInt(tlbEntriesEl.value,10);\n\n    // Basic validation\n    if(!(numPages>0 && pageSize>0 && numFrames>0)){\n      alert('Please set positive numbers.');\n      return;\n    }\n\n    // State initialization\n    state = {\n      numPages, pageSize, numFrames, policy, tlbEnabled, tlbSize,\n      // page table: array of {valid:boolean, frame:int, lastUsed:number}\n      ptable: new Array(numPages).fill(null).map(()=>({valid:false, frame:-1, lastUsed:0})),\n      // frames: array mapping frame -> vpage or -1 if free\n      frames: new Array(numFrames).fill(-1),\n      // free frames list\n      freeFrames: [...Array(numFrames).keys()],\n      // replacement metadata\n      fifoQueue: [], // for FIFO store vpage order\n      accessCounter: 0,\n      hits: 0,\n      pf: 0,\n      time: 0,\n      // TLB: array of entries {vpage, frame, lastUsed}\n      tlb: tlbEnabled ? [] : null\n    };\n\n    seq = [];\n    seqIndex = 0;\n    clearLog();\n    renderAll();\n    log(`Built: ${numPages} virtual pages, page size ${pageSize} bytes, ${numFrames} frames, policy=${policy}${tlbEnabled ? ', TLB size='+tlbSize : ''}`);\n  }\n\n  function reset(){\n    state = null;\n    seq = [];\n    seqIndex = 0;\n    clearLog();\n    ptableWrap.innerHTML = '';\n    framesWrap.innerHTML = '';\n    tlbWrap.innerHTML = '';\n    cntAccessEl.textContent = '0';\n    cntHitEl.textContent = '0';\n    cntPFEl.textContent = '0';\n    breakdownEl.textContent = '';\n  }\n\n  function clearLog(){\n    logEl.innerHTML = '';\n  }\n\n  function renderAll(){\n    if(!state) return;\n    renderPT();\n    renderFrames();\n    renderTLB();\n    updateCounters();\n  }\n\n  function renderPT(){\n    const n = state.numPages;\n    let html = '<table><thead><tr><th>VPN</th><th>Valid</th><th>Frame</th><th>LastUsed</th></tr></thead><tbody>';\n    for(let i=0;i<n;i++){\n      const e = state.ptable[i];\n      html += `<tr><td>${i}</td><td class=\"${e.valid ? 'valid':'invalid'}\">${e.valid ? 'yes':'no'}</td><td>${e.valid ? e.frame : '-'}</td><td>${e.lastUsed||'-'}</td></tr>`;\n    }\n    html += '</tbody></table>';\n    ptableWrap.innerHTML = html;\n  }\n\n  function renderFrames(){\n    framesWrap.innerHTML = '';\n    for(let f=0;f<state.numFrames;f++){\n      const vpage = state.frames[f];\n      const div = document.createElement('div');\n      div.className = 'frame';\n      div.innerHTML = `<div class=\"id\">Frame ${f}</div><div class=\"page\">${vpage===-1?'<span class=\"invalid\">free</span>':'Page '+vpage}</div>`;\n      framesWrap.appendChild(div);\n    }\n  }\n\n  function renderTLB(){\n    tlbWrap.innerHTML = '';\n    if(!state.tlb) {\n      tlbWrap.innerHTML = '<div class=\"small muted\">TLB disabled</div>';\n      return;\n    }\n    if(state.tlb.length===0){\n      tlbWrap.innerHTML = '<div class=\"small muted\">empty</div>';\n      return;\n    }\n    for(const ent of state.tlb){\n      const div = document.createElement('div');\n      div.className = 'entry';\n      div.innerHTML = `<div style=\"font-weight:700\">${ent.vpage}</div><div class=\"small\">frame ${ent.frame}</div><div class=\"small muted\">lu:${ent.lastUsed}</div>`;\n      tlbWrap.appendChild(div);\n    }\n  }\n\n  function updateCounters(){\n    cntAccessEl.textContent = state.accessCounter;\n    cntHitEl.textContent = state.hits;\n    cntPFEl.textContent = state.pf;\n  }\n\n  function parseAddr(input){\n    input = (''+input).trim();\n    if(input.startsWith('0x') || input.startsWith('0X')) return parseInt(input,16);\n    return parseInt(input,10);\n  }\n\n  function breakdown(address){\n    const pageSize = state.pageSize;\n    const pageNum = Math.floor(address/pageSize);\n    const offset = address % pageSize;\n    const pageBits = Math.ceil(Math.log2(state.numPages));\n    const offBits = Math.ceil(Math.log2(pageSize));\n    const bin = address.toString(2);\n    breakdownEl.innerHTML = `\n      <div class=\"small muted\">Address: ${address} (0x${address.toString(16)})</div>\n      <div style=\"margin-top:6px\"><b>Page:</b> ${pageNum} &nbsp; <b>Offset:</b> ${offset} <span class=\"small muted\">(${offBits} offset bits)</span></div>\n      <div class=\"small muted\">Virtual address bits (approx): pageBits=${pageBits}, offsetBits=${offBits}</div>\n    `;\n    return {pageNum,offset};\n  }\n\n  function checkTLB(vpage){\n    if(!state.tlb) return null;\n    for(const ent of state.tlb){\n      if(ent.vpage === vpage) {\n        ent.lastUsed = ++state.time;\n        return ent;\n      }\n    }\n    return null;\n  }\n\n  function insertTLB(vpage,frame){\n    if(!state.tlb) return;\n    // if exists update; else insert and evict by LRU if needed\n    for(const ent of state.tlb){\n      if(ent.vpage===vpage){ ent.frame=frame; ent.lastUsed=++state.time; return; }\n    }\n    if(state.tlb.length < state.tlbSize){\n      state.tlb.push({vpage,frame,lastUsed:++state.time});\n    } else {\n      // evict LRU\n      let lruIdx = 0, lruVal = state.tlb[0].lastUsed;\n      for(let i=1;i<state.tlb.length;i++){\n        if(state.tlb[i].lastUsed < lruVal){ lruVal = state.tlb[i].lastUsed; lruIdx = i; }\n      }\n      state.tlb[lruIdx] = {vpage,frame,lastUsed:++state.time};\n    }\n  }\n\n  function evictPage(vpage){\n    // remove from frame and page table\n    const entry = state.ptable[vpage];\n    if(!entry.valid) return; // nothing\n    const f = entry.frame;\n    state.frames[f] = -1;\n    entry.valid = false;\n    entry.frame = -1;\n    entry.lastUsed = 0;\n    // remove from FIFO queue if present\n    const idx = state.fifoQueue.indexOf(vpage);\n    if(idx!==-1) state.fifoQueue.splice(idx,1);\n    // remove TLB entries referencing this vpage\n    if(state.tlb){\n      state.tlb = state.tlb.filter(e => e.vpage!==vpage);\n    }\n    // mark frame free\n    state.freeFrames.push(f);\n    log(`Evicted page ${vpage} from frame ${f}`);\n  }\n\n  function chooseVictim(){\n    if(state.freeFrames.length>0){\n      return null; // free\n    }\n    if(state.policy === 'fifo'){\n      // FIFO: take oldest enqueued page\n      const victim = state.fifoQueue.shift();\n      return victim;\n    } else if(state.policy === 'lru'){\n      // choose page with smallest lastUsed in ptable among valid pages\n      let victim = -1, lu = Infinity;\n      for(let p=0;p<state.numPages;p++){\n        const e = state.ptable[p];\n        if(e.valid && e.lastUsed < lu){\n          lu = e.lastUsed; victim = p;\n        }\n      }\n      return victim;\n    }\n    return null;\n  }\n\n  function bringPage(vpage){\n    // allocate frame\n    if(state.freeFrames.length===0){\n      const victim = chooseVictim();\n      if(victim===null || victim===-1) { log('No victim found?'); return; }\n      evictPage(victim);\n    }\n    // allocate a free frame\n    const frame = state.freeFrames.shift();\n    state.frames[frame] = vpage;\n    state.ptable[vpage].valid = true;\n    state.ptable[vpage].frame = frame;\n    state.ptable[vpage].lastUsed = ++state.time;\n    // track for replacement\n    if(state.policy === 'fifo'){\n      state.fifoQueue.push(vpage);\n    }\n    // insert to TLB optionally\n    insertTLB(vpage,frame);\n    log(`Loaded page ${vpage} into frame ${frame}`);\n    return frame;\n  }\n\n  function accessAddressRaw(address){\n    if(!state) { alert('Build the configuration first.'); return; }\n    const maxAddr = state.numPages * state.pageSize - 1;\n    if(address<0 || address>maxAddr) {\n      log(`Address ${address} out of range (0..${maxAddr})`);\n      return;\n    }\n    state.accessCounter++;\n    state.time++;\n    const {pageNum,offset} = breakdown(address);\n    let typed = `Access VA ${address} => VPN ${pageNum}, offset ${offset}`;\n    // Check TLB\n    const tlbEnt = checkTLB(pageNum);\n    if(state.tlb){\n      if(tlbEnt){\n        // TLB hit\n        state.hits++;\n        const paddr = tlbEnt.frame*state.pageSize + offset;\n        log(`TLB hit: VPN ${pageNum} -> frame ${tlbEnt.frame} => PA ${paddr}`);\n        // update ptable lastUsed for LRU\n        state.ptable[pageNum].lastUsed = state.time;\n        renderAll();\n        return;\n      } else {\n        log(`TLB miss for VPN ${pageNum}`);\n      }\n    }\n    // check page table\n    const pte = state.ptable[pageNum];\n    if(pte.valid){\n      state.hits++;\n      pte.lastUsed = state.time;\n      // update TLB with this translation\n      insertTLB(pageNum, pte.frame);\n      const paddr = pte.frame * state.pageSize + offset;\n      log(`Page table hit: VPN ${pageNum} -> frame ${pte.frame} => PA ${paddr}`);\n    } else {\n      // page fault\n      state.pf++;\n      log(`Page fault on VPN ${pageNum}`);\n      // bring page into memory\n      const frame = bringPage(pageNum);\n      const paddr = frame * state.pageSize + offset;\n      log(`After load: VPN ${pageNum} -> frame ${frame} => PA ${paddr}`);\n    }\n    renderAll();\n  }\n\n  function randomAddr(){\n    if(!state) { alert('Build first.'); return; }\n    const max = state.numPages * state.pageSize;\n    return Math.floor(Math.random()*max);\n  }\n\n  function generateSequence(length=20){\n    // generate a sequence with locality: choose a hot set of pages\n    const pages = state.numPages;\n    const hot = Math.max(1, Math.floor(pages/4));\n    const hotStart = Math.floor(Math.random()*(pages-hot+1));\n    const seq = [];\n    for(let i=0;i<length;i++){\n      if(Math.random() < 0.7){\n        // pick from hot set\n        const p = hotStart + Math.floor(Math.random()*hot);\n        const addr = p*state.pageSize + Math.floor(Math.random()*state.pageSize);\n        seq.push(addr);\n      } else {\n        // random elsewhere\n        seq.push(Math.floor(Math.random()*pages)*state.pageSize + Math.floor(Math.random()*state.pageSize));\n      }\n    }\n    return seq;\n  }\n\n  // Event listeners\n  buildBtn.addEventListener('click', build);\n  resetBtn.addEventListener('click', reset);\n\n  accessBtn.addEventListener('click', ()=>{\n    const raw = accessAddrEl.value.trim();\n    if(raw==='') { alert('Enter an address or press Random.'); return; }\n    const a = parseAddr(raw);\n    if(Number.isNaN(a)) { alert('Invalid address'); return; }\n    accessAddressRaw(a);\n  });\n\n  randBtn.addEventListener('click', ()=>{\n    if(!state) { alert('Build first.'); return; }\n    const a = randomAddr();\n    accessAddrEl.value = a;\n    accessAddressRaw(a);\n  });\n\n  seqBtn.addEventListener('click', ()=>{\n    if(!state) { alert('Build first.'); return; }\n    seq = generateSequence(20);\n    seqIndex = 0;\n    log('Generated sequence (20) with locality. Use Step or Run.');\n    // show the seq in log\n    log('Sequence addresses (first 8): ' + seq.slice(0,8).join(', '));\n  });\n\n  stepSeqBtn.addEventListener('click', ()=>{\n    if(!state) { alert('Build first.'); return; }\n    if(seq.length===0){ alert('No sequence generated. Press \"Seq (20)\".'); return; }\n    if(seqIndex >= seq.length) { log('Sequence complete.'); return; }\n    accessAddressRaw(seq[seqIndex++]);\n  });\n\n  runSeqBtn.addEventListener('click', ()=>{\n    if(!state) { alert('Build first.'); return; }\n    if(seq.length===0){ alert('No sequence generated. Press \"Seq (20)\".'); return; }\n    if(autoRunTimer) { clearInterval(autoRunTimer); autoRunTimer = null; runSeqBtn.textContent = 'Run sequence (auto)'; return; }\n    autoRunTimer = setInterval(()=>{\n      if(seqIndex>=seq.length){ clearInterval(autoRunTimer); autoRunTimer=null; runSeqBtn.textContent='Run sequence (auto)'; log('Sequence finished.'); return; }\n      accessAddressRaw(seq[seqIndex++]);\n    }, 450);\n    runSeqBtn.textContent = 'Stop';\n  });\n\n  clearLogBtn.addEventListener('click', clearLog);\n\n  // Allow Enter to access\n  accessAddrEl.addEventListener('keydown', (e)=>{\n    if(e.key === 'Enter'){ accessBtn.click(); }\n  });\n\n  // Build initial\n  build();\n\n  // Expose for debug (optional)\n  window.pagingState = () => state;\n\n})();\n</script>\n</body>\n</html>"
  },
