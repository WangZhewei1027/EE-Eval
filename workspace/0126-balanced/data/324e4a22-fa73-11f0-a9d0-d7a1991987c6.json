    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Branch and Bound - Knapsack Problem</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        h1 { text-align: center; }\n        #inputs { display: flex; flex-direction: column; align-items: center; margin: 20px; }\n        label { margin: 5px; }\n        button { margin-top: 10px; }\n        pre { background-color: #f0f0f0; padding: 10px; border-radius: 5px; }\n    </style>\n</head>\n<body>\n\n<h1>Branch and Bound - Knapsack Problem</h1>\n<div id=\"inputs\">\n    <label for=\"weights\">Weights (comma-separated):</label>\n    <input type=\"text\" id=\"weights\" placeholder=\"e.g. 2,3,4,5\">\n    \n    <label for=\"values\">Values (comma-separated):</label>\n    <input type=\"text\" id=\"values\" placeholder=\"e.g. 3,4,5,6\">\n    \n    <label for=\"capacity\">Capacity of Knapsack:</label>\n    <input type=\"number\" id=\"capacity\" value=\"5\">\n    \n    <button onclick=\"solveKnapsack()\">Solve Knapsack</button>\n</div>\n\n<pre id=\"result\"></pre>\n\n<script>\n    class Item {\n        constructor(value, weight) {\n            this.value = value;\n            this.weight = weight;\n            this.ratio = value / weight; // Value-to-weight ratio\n        }\n    }\n\n    function solveKnapsack() {\n        const weightsInput = document.getElementById('weights').value.split(',').map(Number);\n        const valuesInput = document.getElementById('values').value.split(',').map(Number);\n        const capacity = parseInt(document.getElementById('capacity').value);\n\n        const items = weightsInput.map((weight, index) => new Item(valuesInput[index], weight));\n        items.sort((a, b) => b.ratio - a.ratio); // Sort items by value-to-weight ratio\n\n        let maxValue = 0;\n        let result = '';\n        \n        const n = items.length;\n        const queue = [{ level: 0, value: 0, weight: 0, bound: bound(0, 0, capacity, items) }]; // Initial node\n\n        while (queue.length > 0) {\n            const node = queue.shift(); // Remove the first item\n\n            if (node.level === n) continue;\n\n            // Explore left branch (include current item)\n            const includeNode = {\n                level: node.level + 1,\n                value: node.value + items[node.level].value,\n                weight: node.weight + items[node.level].weight,\n                bound: bound(node.level + 1, node.value + items[node.level].value, capacity, items)\n            };\n\n            if (includeNode.weight <= capacity && includeNode.value > maxValue) {\n                maxValue = includeNode.value;\n                result = `Max Value Updated: ${maxValue} with Weight: ${includeNode.weight}`;\n            }\n\n            if (includeNode.bound > maxValue) {\n                queue.push(includeNode); // Only add to queue if it can possibly improve maxValue\n            }\n\n            // Explore right branch (exclude current item)\n            const excludeNode = {\n                level: node.level + 1,\n                value: node.value,\n                weight: node.weight,\n                bound: bound(node.level + 1, node.value, capacity, items)\n            };\n\n            if (excludeNode.bound > maxValue) {\n                queue.push(excludeNode); // Only add to queue if it can possibly improve maxValue\n            }\n        }\n\n        document.getElementById('result').innerText = `Maximum Value: ${maxValue}\\n${result}`;\n    }\n\n    function bound(level, value, capacity, items) {\n        if (capacity <= 0) return 0;\n\n        let totalValue = value;\n        let j = level;\n        let totalWeight = 0;\n\n        while (j < items.length && totalWeight + items[j].weight <= capacity) {\n            totalWeight += items[j].weight;\n            totalValue += items[j].value;\n            j++;\n        }\n\n        if (j < items.length) {\n            totalValue += (capacity - totalWeight) * items[j].ratio; // fractional part\n        }\n\n        return totalValue;\n    }\n</script>\n\n</body>\n</html>"
