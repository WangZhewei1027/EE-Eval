    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<title>CPU Scheduling Visualizer</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<style>\n  :root{\n    --bg:#0f1724;\n    --card:#0b1220;\n    --muted:#9aa7bf;\n    --accent:#60a5fa;\n    --glass: rgba(255,255,255,0.03);\n    --green:#34d399;\n    --danger:#fb7185;\n  }\n  html,body{height:100%;margin:0;background:linear-gradient(180deg,var(--bg),#071021);font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;}\n  .app{max-width:1100px;margin:28px auto;padding:20px;color:#e6eef8;}\n  header{display:flex;align-items:center;gap:16px;margin-bottom:16px;}\n  header h1{margin:0;font-size:20px;}\n  header p{margin:0;color:var(--muted);font-size:13px;}\n  .main{display:grid;grid-template-columns:360px 1fr;gap:18px;}\n  .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:10px;padding:14px;box-shadow:0 6px 18px rgba(2,6,23,0.6);}\n  .panel h3{margin:0 0 8px 0;font-size:15px;}\n  label{display:block;font-size:12px;color:var(--muted);margin-bottom:6px;}\n  .row{display:flex;gap:8px;margin-bottom:8px;align-items:center;}\n  input[type=number], input[type=text], select{width:100%;padding:8px;border-radius:6px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:inherit;font-size:13px;box-sizing:border-box;}\n  button{background:linear-gradient(180deg,var(--accent),#3b82f6);color:#021024;border:0;padding:8px 10px;border-radius:8px;font-weight:600;cursor:pointer;}\n  button.ghost{background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted);font-weight:500;}\n  .small{padding:6px 8px;font-size:13px;border-radius:6px;}\n  .process-list{max-height:220px;overflow:auto;margin-top:8px;border-radius:8px;border:1px dashed rgba(255,255,255,0.03);padding:8px;background:linear-gradient(0deg, rgba(255,255,255,0.01), transparent);}\n  .proc{display:flex;gap:8px;align-items:center;padding:8px;border-radius:8px;margin-bottom:6px;background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);}\n  .pill{min-width:36px;text-align:center;padding:6px;border-radius:6px;background:rgba(0,0,0,0.25);font-weight:700;}\n  .proc-info{flex:1;display:flex;gap:8px;align-items:center;}\n  .muted{color:var(--muted);font-size:13px;}\n  .controls{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}\n  .visual{display:flex;flex-direction:column;gap:12px;}\n  .gantt-wrap{background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);overflow:auto;}\n  .gantt{height:72px;position:relative;display:flex;align-items:center;gap:4px;min-width:600px;}\n  .gseg{height:42px;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#011026;font-weight:700;font-size:12px;}\n  .gseg.idle{background:linear-gradient(90deg,#334155,#0b1220);color:var(--muted);opacity:0.85;}\n  .time-row{display:flex;justify-content:space-between;margin-top:6px;font-size:12px;color:var(--muted);}\n  .metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:10px;}\n  table{width:100%;border-collapse:collapse;color:inherit;}\n  th,td{padding:8px;border-bottom:1px dashed rgba(255,255,255,0.03);font-size:13px;text-align:left;}\n  th{color:var(--muted);font-weight:600;}\n  .playback{display:flex;align-items:center;gap:8px;margin-top:8px;}\n  .slider{width:160px;}\n  .legend{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;}\n  .legend .item{display:flex;gap:8px;align-items:center;padding:6px;border-radius:6px;background:var(--glass);font-size:13px;}\n  .idle-label{background:linear-gradient(90deg,#334155,#0b1220);padding:6px;border-radius:6px;}\n  .caption{font-size:13px;color:var(--muted);margin-top:6px;}\n  footer{margin-top:14px;color:var(--muted);font-size:13px;}\n  .hint{font-size:12px;color:var(--muted);margin-top:6px;}\n  .small-input{width:72px;}\n  .algo-row{display:flex;gap:8px;align-items:center;margin-bottom:8px;}\n  .danger{color:var(--danger);}\n  @media (max-width:980px){\n    .main{grid-template-columns:1fr; padding-bottom:40px;}\n    .gantt{min-width:900px;}\n  }\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <header>\n    <div>\n      <h1>CPU Scheduling Visualizer</h1>\n      <p>Interactive demonstration of classical CPU scheduling algorithms and metrics (Waiting, Turnaround, Response).</p>\n    </div>\n  </header>\n\n  <div class=\"main\">\n    <div class=\"panel\">\n      <h3>Process Configuration</h3>\n\n      <div class=\"row\" style=\"align-items:flex-end;\">\n        <div style=\"flex:1\">\n          <label>Process name</label>\n          <input id=\"pname\" type=\"text\" value=\"P1\" placeholder=\"P1\"/>\n        </div>\n        <div>\n          <label>Arrival</label>\n          <input id=\"parr\" type=\"number\" min=\"0\" value=\"0\" class=\"small-input\"/>\n        </div>\n        <div>\n          <label>Burst</label>\n          <input id=\"pburst\" type=\"number\" min=\"1\" value=\"5\" class=\"small-input\"/>\n        </div>\n        <div>\n          <label>Priority</label>\n          <input id=\"pprio\" type=\"number\" min=\"0\" value=\"0\" class=\"small-input\"/>\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:8px;margin-top:8px;\">\n        <button id=\"addBtn\">Add Process</button>\n        <button id=\"clearBtn\" class=\"ghost\">Clear All</button>\n        <button id=\"sampleBtn\" class=\"ghost\">Load Sample</button>\n      </div>\n\n      <div class=\"process-list\" id=\"plist\" aria-live=\"polite\"></div>\n\n      <hr style=\"border:none;border-top:1px dashed rgba(255,255,255,0.03);margin:10px 0;\">\n\n      <div class=\"algo-row\">\n        <div style=\"flex:1\">\n          <label>Algorithm</label>\n          <select id=\"algo\">\n            <option value=\"FCFS\">FCFS (First-Come, First-Served)</option>\n            <option value=\"SJF\">SJF (Shortest Job First) - Non-preemptive</option>\n            <option value=\"SRTF\">SRTF (Shortest Remaining Time First) - Preemptive</option>\n            <option value=\"PRIO_NP\">Priority - Non-preemptive</option>\n            <option value=\"PRIO_P\">Priority - Preemptive</option>\n            <option value=\"RR\">Round Robin</option>\n          </select>\n        </div>\n        <div>\n          <label>Quantum</label>\n          <input id=\"quantum\" type=\"number\" min=\"1\" value=\"2\" class=\"small-input\"/>\n        </div>\n      </div>\n\n      <div class=\"controls\">\n        <button id=\"runBtn\">Run Simulation</button>\n        <button id=\"resetBtn\" class=\"ghost\">Reset View</button>\n        <button id=\"exportBtn\" class=\"ghost\">Export CSV</button>\n      </div>\n\n      <div class=\"hint\">Tip: Add processes, pick an algorithm, then Run. Use Round Robin quantum for RR.</div>\n    </div>\n\n    <div class=\"panel visual\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n        <h3>Gantt Chart & Playback</h3>\n        <div class=\"caption\">Timeline is proportional to CPU time units</div>\n      </div>\n\n      <div class=\"gantt-wrap\">\n        <div id=\"gantt\" class=\"gantt\" role=\"img\" aria-label=\"Gantt chart\"></div>\n        <div id=\"timeRow\" class=\"time-row\"></div>\n      </div>\n\n      <div class=\"playback\">\n        <button id=\"playPause\" class=\"small\">Play</button>\n        <button id=\"stepBack\" class=\"small ghost\">Step -1</button>\n        <button id=\"stepFwd\" class=\"small ghost\">Step +1</button>\n        <div style=\"display:flex;align-items:center;gap:6px;margin-left:8px;\">\n          <label class=\"muted\">Speed</label>\n          <input id=\"speed\" type=\"range\" min=\"0.1\" max=\"5\" step=\"0.1\" value=\"1\" class=\"slider\">\n        </div>\n        <div style=\"margin-left:auto;color:var(--muted);\" id=\"timeIndicator\">t = 0</div>\n      </div>\n\n      <div class=\"legend\" id=\"legend\"></div>\n\n      <div class=\"metrics\">\n        <div class=\"panel\" style=\"padding:10px;\">\n          <h3>Per-process Metrics</h3>\n          <table id=\"metricsTable\"><thead><tr><th>Proc</th><th>Arrival</th><th>Burst</th><th>Priority</th><th>Start</th><th>Completion</th><th>Turnaround</th><th>Waiting</th><th>Response</th></tr></thead><tbody></tbody></table>\n        </div>\n\n        <div class=\"panel\" style=\"padding:10px;\">\n          <h3>Summary</h3>\n          <div id=\"summary\" style=\"font-size:14px;color:var(--muted)\"></div>\n        </div>\n\n        <div style=\"grid-column: span 2;\" class=\"panel\">\n          <h3>How it works</h3>\n          <div class=\"muted\">This visualizer simulates CPU scheduling algorithms. It produces a Gantt chart with contiguous CPU segments. Metrics:\n            - Turnaround = Completion - Arrival\n            - Waiting = Turnaround - Burst\n            - Response = First Start - Arrival\n            For preemptive algorithms a process can have multiple CPU segments; the first start is used for response time. Idle intervals are shown when CPU is waiting for the next arrival.</div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <footer>\n    Created as a single-file demonstration. Modify processes, select algorithm, and explore scheduling behavior.\n  </footer>\n</div>\n\n<script>\n(function(){\n  // Utility functions\n  function el(id){return document.getElementById(id);}\n  function fmt(n){return (Math.round(n*100)/100).toString();}\n  function clamp(v,a,b){return Math.max(a,Math.min(b,v));}\n\n  // State\n  let processes = []; // {id,name,arrival,burst,priority}\n  let nextId = 1;\n  const plist = el('plist');\n  const ganttEl = el('gantt');\n  const legendEl = el('legend');\n  const metricsTableBody = el('metricsTable').querySelector('tbody');\n  const summaryEl = el('summary');\n  const timeRow = el('timeRow');\n  const timeIndicator = el('timeIndicator');\n\n  // Playback\n  let timeline = []; // segments {start,end,pid,name}\n  let maxTime = 0;\n  let playing = false;\n  let playInterval = null;\n  let playPos = 0; // current simulation time (float)\n  let speed = 1; // units per second (sim-time per real-second)\n  let lastUpdate = 0;\n\n  // Elements\n  const pname = el('pname'), parr = el('parr'), pburst = el('pburst'), pprio = el('pprio');\n  const addBtn = el('addBtn'), clearBtn = el('clearBtn'), sampleBtn = el('sampleBtn');\n  const runBtn = el('runBtn'), resetBtn = el('resetBtn'), exportBtn = el('exportBtn');\n  const algoSelect = el('algo'), quantumInput = el('quantum');\n  const playPauseBtn = el('playPause'), stepBackBtn = el('stepBack'), stepFwdBtn = el('stepFwd'), speedSlider = el('speed');\n\n  // Colors\n  function colorFor(id){\n    // deterministic pastel colors\n    const golden = 0.61803398875;\n    let h = (id * 137.508) % 360;\n    let s = 60 + (id * 29) % 20;\n    let l = 55 + (id * 13) % 10;\n    return `hsl(${h}deg ${s}% ${l}%)`;\n  }\n\n  // Render list\n  function renderProcessList(){\n    plist.innerHTML='';\n    processes.sort((a,b)=>a.id-b.id);\n    for(const p of processes){\n      const d = document.createElement('div'); d.className='proc';\n      const pcolor = colorFor(p.id);\n      const pill = document.createElement('div'); pill.className='pill'; pill.style.background=pcolor; pill.textContent=p.name;\n      const info = document.createElement('div'); info.className='proc-info';\n      const text = document.createElement('div');\n      text.innerHTML = `<div><strong>${p.name}</strong> <span style=\"color:var(--muted);font-weight:500\">(id:${p.id})</span></div>\n                        <div class=\"muted\">Arrival: ${p.arrival} &nbsp; Burst: ${p.burst} &nbsp; Priority: ${p.priority}</div>`;\n      info.appendChild(text);\n      const del = document.createElement('button'); del.className='ghost small'; del.textContent='Delete';\n      del.onclick = ()=>{ processes = processes.filter(x=>x.id!==p.id); renderProcessList(); };\n      d.appendChild(pill); d.appendChild(info); d.appendChild(del);\n      plist.appendChild(d);\n    }\n  }\n\n  // Add process\n  addBtn.addEventListener('click', ()=>{\n    const name = (pname.value || ('P'+(nextId))).trim();\n    const arrival = Number(parr.value);\n    const burst = Number(pburst.value);\n    const prio = Number(pprio.value);\n    if(!name){ alert('Provide a name'); return; }\n    if(!Number.isFinite(arrival) || arrival<0){ alert('Arrival must be >=0'); return; }\n    if(!Number.isFinite(burst) || burst<=0){ alert('Burst must be >0'); return; }\n    processes.push({id: nextId++, name:name, arrival: Math.floor(arrival), burst: Math.floor(burst), priority: prio});\n    renderProcessList();\n  });\n\n  clearBtn.addEventListener('click', ()=>{\n    if(!confirm('Clear all processes?')) return;\n    processes = []; nextId = 1; renderProcessList();\n  });\n\n  sampleBtn.addEventListener('click', ()=>{\n    processes = [\n      {id:1,name:'P1',arrival:0,burst:7,priority:2},\n      {id:2,name:'P2',arrival:2,burst:4,priority:1},\n      {id:3,name:'P3',arrival:4,burst:1,priority:3},\n      {id:4,name:'P4',arrival:5,burst:4,priority:2},\n    ];\n    nextId = 5;\n    renderProcessList();\n  });\n\n  // Scheduling algorithms\n  function deepCopyProcs(arr){\n    return arr.map(p=>({id:p.id,name:p.name,arrival: p.arrival, burst: p.burst, priority: p.priority}));\n  }\n\n  function scheduleFCFS(procList){\n    const procs = deepCopyProcs(procList).sort((a,b)=> a.arrival - b.arrival || a.id - b.id);\n    let t = 0; const segs = [];\n    const meta = {};\n    for(const p of procs){\n      if(t < p.arrival){\n        segs.push({start:t,end:p.arrival,pid:null,name:'idle'});\n        t = p.arrival;\n      }\n      segs.push({start:t,end:t+p.burst,pid:p.id,name:p.name});\n      meta[p.id] = {start: t, completion: t+p.burst};\n      t += p.burst;\n    }\n    return {segs, meta};\n  }\n\n  function scheduleSJF(procList){\n    // Non-preemptive\n    const procs = deepCopyProcs(procList);\n    let t = 0;\n    const segs = [];\n    const remaining = new Map();\n    procs.forEach(p=>remaining.set(p.id, p));\n    const meta = {};\n    while(remaining.size>0){\n      // find arrived\n      const arrived = [...remaining.values()].filter(p=>p.arrival <= t);\n      if(arrived.length===0){\n        const next = [...remaining.values()].reduce((a,b)=> a.arrival < b.arrival ? a : b);\n        segs.push({start:t,end:next.arrival,pid:null,name:'idle'});\n        t = next.arrival;\n        continue;\n      }\n      arrived.sort((a,b)=> a.burst - b.burst || a.arrival - b.arrival || a.id - b.id);\n      const p = arrived[0];\n      segs.push({start:t,end:t+p.burst,pid:p.id,name:p.name});\n      meta[p.id] = {start:t, completion: t+p.burst};\n      t += p.burst;\n      remaining.delete(p.id);\n    }\n    return {segs, meta};\n  }\n\n  function scheduleSRTF(procList){\n    // Preemptive SJF\n    const procs = deepCopyProcs(procList);\n    const rem = new Map();\n    procs.forEach(p=>rem.set(p.id, {id:p.id,name:p.name,arrival:p.arrival,remaining:p.burst,burst:p.burst,priority:p.priority}));\n    let t = 0; const segs = []; const meta = {};\n    while([...rem.values()].some(x=>x.remaining>0)){\n      const arrived = [...rem.values()].filter(p=>p.arrival <= t && p.remaining>0);\n      if(arrived.length===0){\n        // jump to next arrival\n        const next = [...rem.values()].filter(p=>p.remaining>0).reduce((a,b)=>a.arrival<b.arrival?a:b);\n        if(next.arrival>t){\n          segs.push({start:t,end:next.arrival,pid:null,name:'idle'});\n          t = next.arrival;\n          continue;\n        }\n      }\n      // choose shortest remaining\n      const cand = arrived.reduce((a,b)=>{\n        if(a.remaining !== b.remaining) return a.remaining < b.remaining ? a : b;\n        if(a.arrival !== b.arrival) return a.arrival < b.arrival ? a : b;\n        return a.id < b.id ? a : b;\n      });\n      // find next arrival time strictly after t\n      const nextArrival = [...rem.values()].filter(p=>p.arrival>t).reduce((a,b)=> Math.min(a,b.arrival), Infinity);\n      const runUntil = Math.min(cand.remaining, nextArrival - t || Infinity);\n      const run = runUntil === Infinity ? cand.remaining : runUntil;\n      const segStart = t, segEnd = t + run;\n      segs.push({start:segStart,end:segEnd,pid:cand.id,name:cand.name});\n      if(meta[cand.id]===undefined) meta[cand.id] = {start:segStart};\n      cand.remaining -= run;\n      if(cand.remaining<=0){\n        meta[cand.id].completion = segEnd;\n      }\n      t = segEnd;\n    }\n    return {segs, meta};\n  }\n\n  function schedulePriorityNonPreemptive(procList){\n    const procs = deepCopyProcs(procList);\n    let t = 0; const segs = []; const remaining = new Map(); procs.forEach(p=>remaining.set(p.id, p));\n    const meta = {};\n    while(remaining.size>0){\n      const arrived = [...remaining.values()].filter(p=>p.arrival <= t);\n      if(arrived.length===0){\n        const next = [...remaining.values()].reduce((a,b)=> a.arrival < b.arrival ? a : b);\n        segs.push({start:t,end:next.arrival,pid:null,name:'idle'});\n        t = next.arrival;\n        continue;\n      }\n      arrived.sort((a,b)=> a.priority - b.priority || a.arrival - b.arrival || a.burst - b.burst);\n      const p = arrived[0];\n      segs.push({start:t,end:t+p.burst,pid:p.id,name:p.name});\n      meta[p.id] = {start:t, completion: t+p.burst};\n      t += p.burst;\n      remaining.delete(p.id);\n    }\n    return {segs, meta};\n  }\n\n  function schedulePriorityPreemptive(procList){\n    const procs = deepCopyProcs(procList);\n    const rem = new Map();\n    procs.forEach(p=>rem.set(p.id, {id:p.id,name:p.name,arrival:p.arrival,remaining:p.burst,burst:p.burst,priority:p.priority}));\n    let t = 0; const segs = []; const meta = {};\n    while([...rem.values()].some(x=>x.remaining>0)){\n      const arrived = [...rem.values()].filter(p=>p.arrival <= t && p.remaining>0);\n      if(arrived.length===0){\n        const next = [...rem.values()].filter(p=>p.remaining>0).reduce((a,b)=>a.arrival<b.arrival?a:b);\n        if(next.arrival>t){\n          segs.push({start:t,end:next.arrival,pid:null,name:'idle'});\n          t = next.arrival;\n          continue;\n        }\n      }\n      // choose highest priority (lower value => higher priority)\n      const cand = arrived.reduce((a,b)=>{\n        if(a.priority !== b.priority) return a.priority < b.priority ? a : b;\n        if(a.remaining !== b.remaining) return a.remaining < b.remaining ? a: b;\n        return a.id < b.id ? a : b;\n      });\n      const nextArrival = [...rem.values()].filter(p=>p.arrival>t).reduce((a,b)=> Math.min(a,b.arrival), Infinity);\n      const runUntil = Math.min(cand.remaining, nextArrival - t || Infinity);\n      const run = runUntil === Infinity ? cand.remaining : runUntil;\n      const segStart = t, segEnd = t + run;\n      segs.push({start:segStart,end:segEnd,pid:cand.id,name:cand.name});\n      if(meta[cand.id]===undefined) meta[cand.id] = {start:segStart};\n      cand.remaining -= run;\n      if(cand.remaining<=0) meta[cand.id].completion = segEnd;\n      t = segEnd;\n    }\n    return {segs, meta};\n  }\n\n  function scheduleRR(procList, quantum){\n    const procs = deepCopyProcs(procList).sort((a,b)=>a.arrival-b.arrival || a.id-b.id);\n    const rem = new Map(); procs.forEach(p=>rem.set(p.id, {id:p.id,name:p.name,arrival:p.arrival,remaining:p.burst,burst:p.burst,priority:p.priority}));\n    const arrivedQueue = [];\n    let t = 0; const segs = []; const meta = {};\n    let idxNextArrival = 0;\n    const totalCount = procs.length;\n    function pushArrivalsUpTo(time){\n      while(idxNextArrival < procs.length && procs[idxNextArrival].arrival <= time){\n        const p = procs[idxNextArrival];\n        if(rem.has(p.id) && !arrivedQueue.find(x=>x.id===p.id)) arrivedQueue.push(rem.get(p.id));\n        idxNextArrival++;\n      }\n    }\n    while([...rem.values()].some(x=>x.remaining>0)){\n      pushArrivalsUpTo(t);\n      if(arrivedQueue.length===0){\n        if(idxNextArrival < procs.length){\n          const nextArr = procs[idxNextArrival].arrival;\n          segs.push({start:t,end:nextArr,pid:null,name:'idle'});\n          t = nextArr;\n          continue;\n        } else break;\n      }\n      const cur = arrivedQueue.shift();\n      if(!cur || cur.remaining<=0) continue;\n      if(meta[cur.id]===undefined) meta[cur.id] = {start:t};\n      const run = Math.min(quantum, cur.remaining);\n      const segStart = t, segEnd = t + run;\n      segs.push({start:segStart,end:segEnd,pid:cur.id,name:cur.name});\n      cur.remaining -= run;\n      t = segEnd;\n      // add arrivals that came during this time\n      pushArrivalsUpTo(t);\n      if(cur.remaining>0){\n        // requeue\n        arrivedQueue.push(cur);\n      } else {\n        meta[cur.id].completion = t;\n        rem.delete(cur.id);\n      }\n    }\n    return {segs, meta};\n  }\n\n  // Compose timeline from segments: merge adjacent segments with same pid\n  function normalizeSegments(segs){\n    if(segs.length===0) return [];\n    segs.sort((a,b)=>a.start-b.start);\n    const out=[];\n    for(const s of segs){\n      if(s.end<=s.start) continue;\n      if(out.length>0 && out[out.length-1].pid === s.pid && Math.abs(out[out.length-1].end - s.start) < 1e-9){\n        out[out.length-1].end = s.end;\n      } else out.push(Object.assign({},s));\n    }\n    return out;\n  }\n\n  // Build timeline based on chosen algorithm\n  function buildTimeline(){\n    if(processes.length===0){\n      timeline=[]; maxTime=0; return;\n    }\n    const alg = algoSelect.value;\n    let res = {segs:[], meta:{}};\n    try{\n      if(alg==='FCFS') res = scheduleFCFS(processes);\n      else if(alg==='SJF') res = scheduleSJF(processes);\n      else if(alg==='SRTF') res = scheduleSRTF(processes);\n      else if(alg==='PRIO_NP') res = schedulePriorityNonPreemptive(processes);\n      else if(alg==='PRIO_P') res = schedulePriorityPreemptive(processes);\n      else if(alg==='RR') res = scheduleRR(processes, Math.max(1, Math.floor(Number(quantumInput.value) || 1)));\n      else res = scheduleFCFS(processes);\n    } catch(e){\n      console.error(e);\n      alert('Error in scheduling: ' + e.message);\n    }\n    timeline = normalizeSegments(res.segs);\n    // fill small gaps (floating precision)\n    for(let i=0;i<timeline.length-1;i++){\n      if(timeline[i].end < timeline[i+1].start){\n        // leave gap; but it should be idle; create idle in between\n        const gapStart = timeline[i].end, gapEnd = timeline[i+1].start;\n        timeline.splice(i+1,0,{start:gapStart,end:gapEnd,pid:null,name:'idle'});\n        i++;\n      }\n    }\n    // compute maxTime\n    maxTime = timeline.length ? Math.max(...timeline.map(s=>s.end)) : 0;\n    return res.meta || {};\n  }\n\n  // Compute metrics table\n  function computeMetrics(metaMap){\n    // metaMap: {pid: {start, completion}}\n    const rows = [];\n    for(const p of processes){\n      const m = metaMap[p.id] || {};\n      const start = m.start === undefined ? null : m.start;\n      const comp = m.completion === undefined ? null : m.completion;\n      const turnaround = (comp===null) ? null : comp - p.arrival;\n      const waiting = (turnaround===null) ? null : turnaround - p.burst;\n      const response = (start===null) ? null : start - p.arrival;\n      rows.push({pid:p.id, name:p.name, arrival:p.arrival, burst:p.burst, priority:p.priority, start, completion:comp, turnaround, waiting, response});\n    }\n    // sort by pid\n    rows.sort((a,b)=>a.pid-b.pid);\n    return rows;\n  }\n\n  // Render Gantt\n  function renderGantt(){\n    ganttEl.innerHTML=''; legendEl.innerHTML=''; timeRow.innerHTML='';\n    if(timeline.length===0){\n      ganttEl.innerHTML = '<div style=\"color:var(--muted)\">No schedule</div>';\n      timeRow.textContent='';\n      return;\n    }\n    const total = Math.max(maxTime, 1);\n    const pxPerUnit = Math.max(12, Math.min(40, 760/total)); // scale\n    ganttEl.style.width = (total * pxPerUnit + 40) + 'px';\n    for(const s of timeline){\n      const w = Math.max(3, (s.end - s.start) * pxPerUnit);\n      const block = document.createElement('div');\n      block.className='gseg' + (s.pid===null ? ' idle' : '');\n      block.style.width = w + 'px';\n      block.style.flex = '0 0 ' + w + 'px';\n      block.style.background = s.pid===null ? null : colorFor(s.pid);\n      block.style.border = '1px solid rgba(0,0,0,0.2)';\n      const label = (s.pid===null) ? 'idle' : s.name;\n      const labelText = (s.end - s.start) >= Math.max(1, pxPerUnit/6) ? label : '';\n      block.textContent = labelText;\n      block.title = `${label} [${s.start} → ${s.end}]`;\n      block.dataset.start = s.start;\n      block.dataset.end = s.end;\n      block.dataset.pid = s.pid;\n      ganttEl.appendChild(block);\n    }\n    // time ticks\n    const ticks = [];\n    for(let t=0;t<=maxTime;t++){\n      ticks.push(`<span>${t}</span>`);\n    }\n    timeRow.innerHTML = ticks.join('');\n    // legend\n    const used = {};\n    for(const s of timeline) if(s.pid!==null) used[s.pid]=s.name;\n    for(const pid in used){\n      const item = document.createElement('div'); item.className='item';\n      const sw = document.createElement('div'); sw.style.width='18px'; sw.style.height='14px'; sw.style.background = colorFor(parseInt(pid)); sw.style.borderRadius='4px';\n      const lab = document.createElement('div'); lab.textContent = `${used[pid]} (id:${pid})`; lab.style.color='var(--muted)';\n      item.appendChild(sw); item.appendChild(lab);\n      legendEl.appendChild(item);\n    }\n    const idleItem = document.createElement('div'); idleItem.className='item';\n    idleItem.innerHTML = `<div class=\"idle-label\">Idle</div><div style=\"color:var(--muted)\">CPU Idle</div>`;\n    legendEl.appendChild(idleItem);\n  }\n\n  // Render metrics table and summary\n  function renderMetrics(metaMap){\n    const rows = computeMetrics(metaMap);\n    metricsTableBody.innerHTML='';\n    let totalT=0,totalW=0,totalR=0,count=0;\n    for(const r of rows){\n      const tr = document.createElement('tr');\n      tr.innerHTML = `<td><strong>${r.name}</strong></td>\n                      <td>${r.arrival}</td>\n                      <td>${r.burst}</td>\n                      <td>${r.priority}</td>\n                      <td>${r.start===null?'-':r.start}</td>\n                      <td>${r.completion===null?'-':r.completion}</td>\n                      <td>${r.turnaround===null?'-':fmt(r.turnaround)}</td>\n                      <td>${r.waiting===null?'-':fmt(r.waiting)}</td>\n                      <td>${r.response===null?'-':fmt(r.response)}</td>`;\n      metricsTableBody.appendChild(tr);\n      if(r.turnaround!==null){ totalT += r.turnaround; totalW += r.waiting; totalR += r.response; count++; }\n    }\n    if(count>0){\n      summaryEl.innerHTML = `<div>Average Turnaround: <strong>${fmt(totalT/count)}</strong></div>\n                             <div>Average Waiting: <strong>${fmt(totalW/count)}</strong></div>\n                             <div>Average Response: <strong>${fmt(totalR/count)}</strong></div>\n                             <div>Total time (makespan): <strong>${fmt(maxTime)}</strong></div>`;\n    } else summaryEl.textContent = 'No complete metrics available.';\n  }\n\n  // Playback functions\n  function resetPlayback(){\n    playing=false; clearInterval(playInterval); playInterval=null; playPauseBtn.textContent='Play';\n    playPos = 0; updatePlaybackUI();\n  }\n\n  function updatePlaybackUI(){\n    timeIndicator.textContent = 't = ' + fmt(playPos);\n    // highlight current segment\n    const children = Array.from(ganttEl.children);\n    children.forEach(ch=>{\n      const s = Number(ch.dataset.start), e = Number(ch.dataset.end);\n      if(playPos >= s && playPos < e){\n        ch.style.outline = '3px solid rgba(255,255,255,0.12)';\n        ch.style.transform = 'scale(1.02)';\n      } else {\n        ch.style.outline = 'none';\n        ch.style.transform = 'none';\n      }\n    });\n  }\n\n  function play(){\n    if(timeline.length===0) return;\n    playing = true;\n    playPauseBtn.textContent = 'Pause';\n    const unitsPerSecond = speed * 1; // sim-time units per real second\n    const msPerFrame = 60;\n    const deltaUnitPerMs = unitsPerSecond/1000;\n    if(playInterval) clearInterval(playInterval);\n    lastUpdate = performance.now();\n    playInterval = setInterval(()=>{\n      const now = performance.now();\n      const dt = now - lastUpdate;\n      lastUpdate = now;\n      playPos += dt * deltaUnitPerMs;\n      if(playPos > maxTime) { playPos = maxTime; pause(); }\n      updatePlaybackUI();\n    }, msPerFrame);\n  }\n\n  function pause(){\n    playing = false;\n    playPauseBtn.textContent = 'Play';\n    if(playInterval){ clearInterval(playInterval); playInterval=null; }\n  }\n\n  playPauseBtn.addEventListener('click', ()=>{\n    if(playing) pause(); else play();\n  });\n\n  stepBackBtn.addEventListener('click', ()=>{\n    playPos = Math.max(0, playPos - 1);\n    updatePlaybackUI();\n  });\n  stepFwdBtn.addEventListener('click', ()=>{\n    playPos = Math.min(maxTime, playPos + 1);\n    updatePlaybackUI();\n  });\n  speedSlider.addEventListener('input', ()=>{\n    speed = Number(speedSlider.value);\n    if(playing){ play(); } // restart interval with new speed\n  });\n\n  // Run simulation\n  runBtn.addEventListener('click', ()=>{\n    const meta = buildTimeline();\n    renderGantt();\n    renderMetrics(meta);\n    resetPlayback();\n    if(timeline.length>0){\n      // set initial to timeline start 0 or first segment start\n      playPos = Math.min(...timeline.map(s=>s.start));\n    } else playPos = 0;\n    updatePlaybackUI();\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    renderGantt();\n    updatePlaybackUI();\n  });\n\n  exportBtn.addEventListener('click', ()=>{\n    const meta = buildTimeline();\n    const rows = computeMetrics(meta);\n    let csv = 'Process,Arrival,Burst,Priority,Start,Completion,Turnaround,Waiting,Response\\n';\n    for(const r of rows){\n      csv += `${r.name},${r.arrival},${r.burst},${r.priority},${(r.start===null?'':r.start)},${(r.completion===null?'':r.completion)},${(r.turnaround===null?'':r.turnaround)},${(r.waiting===null?'':r.waiting)},${(r.response===null?'':r.response)}\\n`;\n    }\n    const blob = new Blob([csv], {type:'text/csv'});\n    const url = URL.createObjectURL(blob);\n    const a = document.createElement('a'); a.href = url; a.download = 'scheduling_metrics.csv'; a.click();\n    URL.revokeObjectURL(url);\n  });\n\n  // Initialize with a sample\n  sampleBtn.click();\n\n  // Minor: allow pressing Enter in fields to add\n  [pname,parr,pburst,pprio].forEach(inp=>{\n    inp.addEventListener('keydown', (e)=>{\n      if(e.key==='Enter'){ addBtn.click(); }\n    });\n  });\n\n  // Info: rebuild timeline when algorithm or quantum changes\n  algoSelect.addEventListener('change', ()=>{ /* keep existing processes */ });\n  quantumInput.addEventListener('change', ()=>{ quantumInput.value = Math.max(1, Math.floor(Number(quantumInput.value) || 1)); });\n\n  // Accessibility: click on Gantt block to jump playPos\n  ganttEl.addEventListener('click', (e)=>{\n    const tgt = e.target.closest('.gseg');\n    if(!tgt) return;\n    const s = Number(tgt.dataset.start);\n    playPos = s;\n    updatePlaybackUI();\n  });\n\n  // initial run\n  runBtn.click();\n\n})();\n</script>\n</body>\n</html>"
