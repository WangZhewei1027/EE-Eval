  "question": "Asymmetric Cryptography",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Asymmetric Cryptography Demo (Web Crypto)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, Arial; margin: 18px; color: #111; }\n    h1 { font-size: 1.4rem; margin-bottom: 6px; }\n    p.lead { margin-top: 0; color: #444; }\n    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 12px; }\n    .panel { border: 1px solid #ddd; padding: 12px; border-radius: 8px; background: #fff; }\n    label { display:block; font-weight:600; margin-bottom:6px; }\n    textarea, input[type=\"text\"] { width:100%; box-sizing:border-box; padding:8px; font-family: monospace; font-size:0.9rem; }\n    textarea { min-height:80px; resize:vertical; }\n    button { margin-top:8px; padding:8px 10px; border-radius:6px; background:#0066cc; color:white; border:0; cursor:pointer; }\n    button.secondary { background:#666; }\n    .small { font-size:0.85rem; color:#555; margin-top:6px; }\n    .output { font-family: monospace; background:#f7f7f7; padding:8px; border-radius:6px; overflow:auto; max-height:160px; }\n    .row { display:flex; gap:8px; align-items:center; }\n    .nowrap { white-space:nowrap; }\n    footer { margin-top:18px; font-size:0.85rem; color:#666; }\n    .status { margin-top:8px; font-size:0.9rem; color:#007700; }\n    .error { color:#cc0000; }\n  </style>\n</head>\n<body>\n  <h1>Asymmetric Cryptography Demo</h1>\n  <p class=\"lead\">\n    This page demonstrates public-key (asymmetric) cryptography using the Web Crypto API.\n    You can generate key pairs for \"Alice\" (signing) and \"Bob\" (encryption), export/import public keys,\n    encrypt a message with Bob's public key, and sign it with Alice's private key. Bob can then decrypt\n    and verify the signature.\n  </p>\n\n  <div class=\"grid\">\n    <!-- Alice (Signer) -->\n    <div class=\"panel\" id=\"alicePanel\">\n      <label>Alice (Signer) — Signing Key Pair (RSASSA-PKCS1-v1_5, SHA-256)</label>\n      <div class=\"row\">\n        <button id=\"aliceGen\">Generate Alice's Signing Keys</button>\n        <button id=\"aliceExport\" class=\"secondary\">Export Alice's Public Key</button>\n      </div>\n      <div class=\"small\">Note: For demo purposes keys are exportable. In a real application private keys should be non-exportable.</div>\n\n      <label style=\"margin-top:8px\">Alice's Public Key (SPKI, Base64)</label>\n      <textarea id=\"alicePub\" placeholder=\"Alice's exported public key will appear here\"></textarea>\n\n      <label style=\"margin-top:8px\">Alice's Private Key (PKCS8, Base64) — (do NOT share)</label>\n      <textarea id=\"alicePriv\" placeholder=\"Alice's private key (exported)\"></textarea>\n\n      <div id=\"aliceStatus\" class=\"status\"></div>\n    </div>\n\n    <!-- Bob (Receiver) -->\n    <div class=\"panel\" id=\"bobPanel\">\n      <label>Bob (Receiver) — Encryption Key Pair (RSA-OAEP, SHA-256)</label>\n      <div class=\"row\">\n        <button id=\"bobGen\">Generate Bob's Encryption Keys</button>\n        <button id=\"bobExport\" class=\"secondary\">Export Bob's Public Key</button>\n      </div>\n\n      <label style=\"margin-top:8px\">Bob's Public Key (SPKI, Base64)</label>\n      <textarea id=\"bobPub\" placeholder=\"Bob's exported public key will appear here\"></textarea>\n\n      <label style=\"margin-top:8px\">Bob's Private Key (PKCS8, Base64) — (do NOT share)</label>\n      <textarea id=\"bobPriv\" placeholder=\"Bob's private key (exported)\"></textarea>\n\n      <div id=\"bobStatus\" class=\"status\"></div>\n    </div>\n  </div>\n\n  <!-- Messaging area -->\n  <div class=\"panel\" style=\"margin-top:12px;\">\n    <label>Compose Message (Alice)</label>\n    <textarea id=\"message\" placeholder=\"Type a message Alice will send to Bob...\">Hello Bob — this is Alice! Confidential and signed.</textarea>\n\n    <div class=\"row\" style=\"margin-top:10px;\">\n      <button id=\"encryptBtn\">Encrypt for Bob</button>\n      <button id=\"signBtn\" class=\"secondary\">Sign (Alice)</button>\n      <button id=\"encryptSignBtn\">Encrypt & Sign</button>\n    </div>\n\n    <div style=\"margin-top:10px;\">\n      <label>Ciphertext (Base64)</label>\n      <textarea id=\"ciphertext\" placeholder=\"Ciphertext will appear here\"></textarea>\n\n      <label style=\"margin-top:8px\">Signature (Base64)</label>\n      <textarea id=\"signature\" placeholder=\"Signature will appear here\"></textarea>\n    </div>\n\n    <div style=\"margin-top:10px;\">\n      <button id=\"decryptBtn\">Bob: Decrypt</button>\n      <button id=\"verifyBtn\" class=\"secondary\">Bob: Verify Signature</button>\n      <button id=\"decryptVerifyBtn\">Bob: Decrypt & Verify</button>\n    </div>\n\n    <div style=\"margin-top:10px;\">\n      <label>Decrypted Message</label>\n      <textarea id=\"decrypted\" placeholder=\"Decrypted plaintext will appear here\"></textarea>\n    </div>\n\n    <div id=\"msgStatus\" class=\"status\"></div>\n  </div>\n\n  <footer>\n    Quick notes:\n    - RSA-OAEP is used for encryption/decryption; RSASSA-PKCS1-v1_5 is used for signing/verifying.\n    - Public keys are exported as SPKI and encoded in Base64 to simulate exchanging keys.\n    - This page uses extractable keys for demonstration; in production, keep private keys non-extractable and protected.\n  </footer>\n\n  <script>\n    // Utilities: Base64 <-> ArrayBuffer and string conversions\n    function abToBase64(buf) {\n      return btoa(String.fromCharCode(...new Uint8Array(buf)));\n    }\n    function base64ToAb(b64) {\n      const binary = atob(b64);\n      const len = binary.length;\n      const bytes = new Uint8Array(len);\n      for (let i = 0; i < len; i++) bytes[i] = binary.charCodeAt(i);\n      return bytes.buffer;\n    }\n    function strToAb(str) {\n      return new TextEncoder().encode(str).buffer;\n    }\n    function abToStr(ab) {\n      return new TextDecoder().decode(ab);\n    }\n\n    // State: hold key objects in memory for Alice and Bob\n    const state = {\n      aliceSignKeyPair: null, // RSASSA-PKCS1-v1_5\n      bobEncKeyPair: null     // RSA-OAEP\n    };\n\n    // DOM\n    const aliceGenBtn = document.getElementById('aliceGen');\n    const aliceExportBtn = document.getElementById('aliceExport');\n    const alicePubTA = document.getElementById('alicePub');\n    const alicePrivTA = document.getElementById('alicePriv');\n    const aliceStatus = document.getElementById('aliceStatus');\n\n    const bobGenBtn = document.getElementById('bobGen');\n    const bobExportBtn = document.getElementById('bobExport');\n    const bobPubTA = document.getElementById('bobPub');\n    const bobPrivTA = document.getElementById('bobPriv');\n    const bobStatus = document.getElementById('bobStatus');\n\n    const messageTA = document.getElementById('message');\n    const encryptBtn = document.getElementById('encryptBtn');\n    const signBtn = document.getElementById('signBtn');\n    const encryptSignBtn = document.getElementById('encryptSignBtn');\n\n    const ciphertextTA = document.getElementById('ciphertext');\n    const signatureTA = document.getElementById('signature');\n\n    const decryptBtn = document.getElementById('decryptBtn');\n    const verifyBtn = document.getElementById('verifyBtn');\n    const decryptVerifyBtn = document.getElementById('decryptVerifyBtn');\n\n    const decryptedTA = document.getElementById('decrypted');\n    const msgStatus = document.getElementById('msgStatus');\n\n    // Generate Alice's signing key pair (RSASSA-PKCS1-v1_5)\n    aliceGenBtn.addEventListener('click', async () => {\n      aliceStatus.textContent = 'Generating Alice signing keys...';\n      try {\n        const kp = await crypto.subtle.generateKey(\n          {\n            name: \"RSASSA-PKCS1-v1_5\",\n            modulusLength: 2048,\n            publicExponent: new Uint8Array([0x01, 0x00, 0x01]),\n            hash: 'SHA-256'\n          },\n          true, // extractable for demonstration only\n          [\"sign\", \"verify\"]\n        );\n        state.aliceSignKeyPair = kp;\n        aliceStatus.textContent = 'Alice signing key pair generated.';\n        // optionally export to display in UI\n        const pub = await exportPublicKeyBase64(kp.publicKey);\n        const priv = await exportPrivateKeyBase64(kp.privateKey);\n        alicePubTA.value = pub;\n        alicePrivTA.value = priv;\n      } catch (err) {\n        aliceStatus.textContent = '';\n        alert('Alice key generation failed: ' + err);\n      }\n    });\n\n    // Generate Bob's encryption key pair (RSA-OAEP)\n    bobGenBtn.addEventListener('click', async () => {\n      bobStatus.textContent = 'Generating Bob encryption keys...';\n      try {\n        const kp = await crypto.subtle.generateKey(\n          {\n            name: \"RSA-OAEP\",\n            modulusLength: 2048,\n            publicExponent: new Uint8Array([0x01, 0x00, 0x01]),\n            hash: 'SHA-256'\n          },\n          true, // extractable for demo only\n          [\"encrypt\", \"decrypt\"]\n        );\n        state.bobEncKeyPair = kp;\n        bobStatus.textContent = 'Bob encryption key pair generated.';\n        const pub = await exportPublicKeyBase64(kp.publicKey);\n        const priv = await exportPrivateKeyBase64(kp.privateKey);\n        bobPubTA.value = pub;\n        bobPrivTA.value = priv;\n      } catch (err) {\n        bobStatus.textContent = '';\n        alert('Bob key generation failed: ' + err);\n      }\n    });\n\n    // Export Alice's public key (if in memory)\n    aliceExportBtn.addEventListener('click', async () => {\n      if (!state.aliceSignKeyPair) {\n        aliceStatus.classList.add('error');\n        aliceStatus.textContent = 'No Alice key pair in memory. Generate first.';\n        return;\n      }\n      const pub = await exportPublicKeyBase64(state.aliceSignKeyPair.publicKey);\n      alicePubTA.value = pub;\n      aliceStatus.textContent = 'Alice public key exported.';\n    });\n\n    // Export Bob's public key\n    bobExportBtn.addEventListener('click', async () => {\n      if (!state.bobEncKeyPair) {\n        bobStatus.classList.add('error');\n        bobStatus.textContent = 'No Bob key pair in memory. Generate first.';\n        return;\n      }\n      const pub = await exportPublicKeyBase64(state.bobEncKeyPair.publicKey);\n      bobPubTA.value = pub;\n      bobStatus.textContent = 'Bob public key exported.';\n    });\n\n    // encrypt plaintext using Bob's public key (SPKI Base64 from bobPubTA)\n    encryptBtn.addEventListener('click', async () => {\n      clearMsgStatus();\n      try {\n        const bobPubB64 = bobPubTA.value.trim();\n        if (!bobPubB64) throw 'Paste Bob\\'s public key into the \"Bob\\'s Public Key\" box first.';\n        const bobPub = await importBobPublicKeyFromSPKI(bobPubB64);\n        const plaintext = messageTA.value;\n        const cipherBuf = await crypto.subtle.encrypt(\n          { name: \"RSA-OAEP\" },\n          bobPub,\n          strToAb(plaintext)\n        );\n        ciphertextTA.value = abToBase64(cipherBuf);\n        msgStatus.textContent = 'Message encrypted with Bob\\'s public key.';\n      } catch (err) {\n        showError(err);\n      }\n    });\n\n    // sign plaintext using Alice's private key (state)\n    signBtn.addEventListener('click', async () => {\n      clearMsgStatus();\n      try {\n        if (!state.aliceSignKeyPair) throw 'Alice has no signing key pair in memory. Generate Alice keys first.';\n        const sig = await crypto.subtle.sign(\n          { name: \"RSASSA-PKCS1-v1_5\" },\n          state.aliceSignKeyPair.privateKey,\n          strToAb(messageTA.value)\n        );\n        signatureTA.value = abToBase64(sig);\n        msgStatus.textContent = 'Message signed with Alice\\'s private key.';\n      } catch (err) {\n        showError(err);\n      }\n    });\n\n    // encrypt and then sign (encrypt first, then sign the plaintext)\n    encryptSignBtn.addEventListener('click', async () => {\n      clearMsgStatus();\n      try {\n        // ensure bob pub available\n        const bobPubB64 = bobPubTA.value.trim();\n        if (!bobPubB64) throw 'Paste Bob\\'s public key into the \"Bob\\'s Public Key\" box first.';\n        if (!state.aliceSignKeyPair) throw 'Alice has no signing key pair in memory. Generate Alice keys first.';\n\n        const bobPub = await importBobPublicKeyFromSPKI(bobPubB64);\n        const plaintext = messageTA.value;\n\n        // encrypt\n        const cipherBuf = await crypto.subtle.encrypt({ name: \"RSA-OAEP\" }, bobPub, strToAb(plaintext));\n        ciphertextTA.value = abToBase64(cipherBuf);\n\n        // sign plaintext\n        const sigBuf = await crypto.subtle.sign({ name: \"RSASSA-PKCS1-v1_5\" }, state.aliceSignKeyPair.privateKey, strToAb(plaintext));\n        signatureTA.value = abToBase64(sigBuf);\n\n        msgStatus.textContent = 'Message encrypted (for Bob) and signed (by Alice).';\n      } catch (err) {\n        showError(err);\n      }\n    });\n\n    // Bob: decrypt using his private key (from bobPrivTA)\n    decryptBtn.addEventListener('click', async () => {\n      clearMsgStatus();\n      try {\n        const bobPrivB64 = bobPrivTA.value.trim();\n        if (!bobPrivB64) throw 'Paste Bob\\'s private key into the \"Bob\\'s Private Key\" box (for demo only).';\n        const priv = await importBobPrivateKeyFromPKCS8(bobPrivB64);\n        const cipherB64 = ciphertextTA.value.trim();\n        if (!cipherB64) throw 'No ciphertext present. Encrypt a message first or paste a ciphertext.';\n        const plainBuf = await crypto.subtle.decrypt({ name: \"RSA-OAEP\" }, priv, base64ToAb(cipherB64));\n        const plain = abToStr(plainBuf);\n        decryptedTA.value = plain;\n        msgStatus.textContent = 'Bob decrypted the message.';\n      } catch (err) {\n        showError(err);\n      }\n    });\n\n    // Bob: verify signature using Alice's public key (from alicePubTA). Message to verify is in decryptedTA if available, otherwise uses messageTA.\n    verifyBtn.addEventListener('click', async () => {\n      clearMsgStatus();\n      try {\n        const alicePubB64 = alicePubTA.value.trim();\n        if (!alicePubB64) throw 'Paste Alice\\'s public key into \"Alice\\'s Public Key\" box.';\n        const alicePub = await importAlicePublicKeyFromSPKI(alicePubB64);\n        // message to verify: prefer decrypted text (if Bob previously decrypted), else the original message text (in demo both are available)\n        const msg = decryptedTA.value || messageTA.value;\n        if (!msg) throw 'No message available to verify.';\n        const sigB64 = signatureTA.value.trim();\n        if (!sigB64) throw 'No signature present. Sign the message first or paste a signature.';\n        const verified = await crypto.subtle.verify(\n          { name: \"RSASSA-PKCS1-v1_5\" },\n          alicePub,\n          base64ToAb(sigB64),\n          strToAb(msg)\n        );\n        msgStatus.textContent = verified ? 'Signature VERIFIED — it was signed by Alice.' : 'Signature NOT valid.';\n      } catch (err) {\n        showError(err);\n      }\n    });\n\n    // Bob: decrypt then verify in one step\n    decryptVerifyBtn.addEventListener('click', async () => {\n      clearMsgStatus();\n      try {\n        // decrypt\n        const bobPrivB64 = bobPrivTA.value.trim();\n        if (!bobPrivB64) throw 'Paste Bob\\'s private key into the \"Bob\\'s Private Key\" box.';\n        const priv = await importBobPrivateKeyFromPKCS8(bobPrivB64);\n        const cipherB64 = ciphertextTA.value.trim();\n        if (!cipherB64) throw 'No ciphertext present. Encrypt a message first or paste a ciphertext.';\n        const plainBuf = await crypto.subtle.decrypt({ name: \"RSA-OAEP\" }, priv, base64ToAb(cipherB64));\n        const plain = abToStr(plainBuf);\n        decryptedTA.value = plain;\n\n        // verify\n        const alicePubB64 = alicePubTA.value.trim();\n        if (!alicePubB64) throw 'Paste Alice\\'s public key into \"Alice\\'s Public Key\" box.';\n        const alicePub = await importAlicePublicKeyFromSPKI(alicePubB64);\n        const sigB64 = signatureTA.value.trim();\n        if (!sigB64) throw 'No signature present.';\n        const verified = await crypto.subtle.verify(\n          { name: \"RSASSA-PKCS1-v1_5\" },\n          alicePub,\n          base64ToAb(sigB64),\n          strToAb(plain)\n        );\n        msgStatus.textContent = verified ? 'Decrypted and signature VERIFIED.' : 'Decrypted but signature NOT valid.';\n      } catch (err) {\n        showError(err);\n      }\n    });\n\n    // Helpers for export/import\n    async function exportPublicKeyBase64(publicKey) {\n      const spki = await crypto.subtle.exportKey('spki', publicKey);\n      return abToBase64(spki);\n    }\n    async function exportPrivateKeyBase64(privateKey) {\n      const pkcs8 = await crypto.subtle.exportKey('pkcs8', privateKey);\n      return abToBase64(pkcs8);\n    }\n\n    async function importBobPublicKeyFromSPKI(spkiB64) {\n      const ab = base64ToAb(spkiB64);\n      return await crypto.subtle.importKey(\n        'spki',\n        ab,\n        { name: \"RSA-OAEP\", hash: 'SHA-256' },\n        false,\n        [\"encrypt\"]\n      );\n    }\n    async function importBobPrivateKeyFromPKCS8(pkcs8B64) {\n      const ab = base64ToAb(pkcs8B64);\n      return await crypto.subtle.importKey(\n        'pkcs8',\n        ab,\n        { name: \"RSA-OAEP\", hash: 'SHA-256' },\n        false,\n        [\"decrypt\"]\n      );\n    }\n\n    async function importAlicePublicKeyFromSPKI(spkiB64) {\n      const ab = base64ToAb(spkiB64);\n      return await crypto.subtle.importKey(\n        'spki',\n        ab,\n        { name: \"RSASSA-PKCS1-v1_5\", hash: 'SHA-256' },\n        false,\n        [\"verify\"]\n      );\n    }\n\n    // Utility: show error message in msgStatus\n    function showError(err) {\n      console.error(err);\n      msgStatus.classList.add('error');\n      msgStatus.textContent = 'Error: ' + (err && err.message ? err.message : String(err));\n    }\n    function clearMsgStatus() {\n      msgStatus.classList.remove('error');\n      msgStatus.textContent = '';\n    }\n  </script>\n</body>\n</html>"
  },
