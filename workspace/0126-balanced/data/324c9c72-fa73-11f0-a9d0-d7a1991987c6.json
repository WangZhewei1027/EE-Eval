    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Hash Map Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        input {\n            margin-bottom: 10px;\n        }\n        #output {\n            margin-top: 20px;\n            white-space: pre-wrap;\n            background-color: #f4f4f4;\n            padding: 10px;\n            border-radius: 5px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Hash Map Demonstration</h1>\n\n<label for=\"key\">Key:</label>\n<input type=\"text\" id=\"key\">\n<br>\n<label for=\"value\">Value:</label>\n<input type=\"text\" id=\"value\">\n<br>\n<button id=\"addButton\">Add to Hash Map</button>\n<button id=\"getButton\">Get from Hash Map</button>\n<button id=\"removeButton\">Remove from Hash Map</button>\n\n<h2>Hash Map Contents:</h2>\n<div id=\"output\"></div>\n\n<script>\n    class HashMap {\n        constructor() {\n            this.map = {};\n        }\n\n        // Add key-value pair to the Hash Map\n        set(key, value) {\n            this.map[key] = value;\n        }\n\n        // Get value by key\n        get(key) {\n            return this.map[key] !== undefined ? this.map[key] : \"Key not found.\";\n        }\n\n        // Remove key-value pair\n        remove(key) {\n            if (this.map[key]) {\n                delete this.map[key];\n                return `${key} removed.`;\n            }\n            return \"Key not found.\";\n        }\n\n        // Get all key-value pairs as a string\n        getAll() {\n            return JSON.stringify(this.map, null, 4);\n        }\n    }\n\n    const hashMap = new HashMap();\n    const outputDiv = document.getElementById('output');\n\n    document.getElementById('addButton').onclick = function () {\n        const key = document.getElementById('key').value;\n        const value = document.getElementById('value').value;\n        hashMap.set(key, value);\n        updateOutput();\n        clearInputs();\n    };\n\n    document.getElementById('getButton').onclick = function () {\n        const key = document.getElementById('key').value;\n        const result = hashMap.get(key);\n        outputDiv.textContent = `Value for \"${key}\": ${result}`;\n    };\n\n    document.getElementById('removeButton').onclick = function () {\n        const key = document.getElementById('key').value;\n        const result = hashMap.remove(key);\n        outputDiv.textContent = result;\n        updateOutput();\n    };\n\n    function updateOutput() {\n        outputDiv.textContent = hashMap.getAll();\n    }\n\n    function clearInputs() {\n        document.getElementById('key').value = '';\n        document.getElementById('value').value = '';\n    }\n</script>\n\n</body>\n</html>"
