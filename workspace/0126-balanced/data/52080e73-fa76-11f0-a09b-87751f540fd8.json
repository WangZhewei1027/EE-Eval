    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deque</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #deque {\n            width: 300px;\n            height: 200px;\n            border: 1px solid #ccc;\n            padding: 20px;\n            margin: 40px auto;\n        }\n    </style>\n</head>\n<body>\n    <h1>Deque Example</h1>\n    <div id=\"deque\"></div>\n\n    <script>\n        let deque = new Array(10).fill(null);\n\n        function pushFront(element) {\n            deque.unshift(element);\n        }\n\n        function pushBack(element) {\n            deque.push(element);\n        }\n\n        function popFront() {\n            if (deque.length > 0) {\n                return deque.shift();\n            } else {\n                return null;\n            }\n        }\n\n        function popBack() {\n            if (deque.length > 0) {\n                return deque.pop();\n            } else {\n                return null;\n            }\n        }\n\n        function peekFront() {\n            if (deque.length > 0) {\n                return deque[0];\n            } else {\n                return null;\n            }\n        }\n\n        function peekBack() {\n            if (deque.length > 0) {\n                return deque[deque.length - 1];\n            } else {\n                return null;\n            }\n        }\n\n        console.log(\"Push Front: \", pushFront(1));\n        console.log(\"Push Back: \", pushBack(2));\n        console.log(\"Push Front: \", pushFront(3));\n        console.log(\"Push Back: \", pushBack(4));\n\n        console.log(\"Pop Front: \", popFront());\n        console.log(\"Pop Front: \", popFront());\n        console.log(\"Pop Back: \", popBack());\n        console.log(\"Pop Back: \", popBack());\n\n        console.log(\"Peek Front: \", peekFront());\n        console.log(\"Peek Back: \", peekBack());\n    </script>\n</body>\n</html>"
