    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Radix Sort Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1em;\n    background: #fafafa;\n    color: #222;\n  }\n  h1 {\n    text-align: center;\n    color: #007acc;\n  }\n  #input-section {\n    max-width: 600px;\n    margin: 0 auto 1.5em auto;\n    text-align: center;\n  }\n  input[type=\"text\"] {\n    width: 80%;\n    font-size: 1.1em;\n    padding: 0.5em;\n    margin-bottom: 0.5em;\n  }\n  button {\n    font-size: 1em;\n    padding: 0.5em 1.2em;\n    cursor: pointer;\n    background-color: #007acc;\n    border: none;\n    color: white;\n    border-radius: 4px;\n  }\n  button:disabled {\n    background: #cccccc;\n    cursor: default;\n  }\n  #steps {\n    max-width: 700px;\n    margin: 0 auto;\n    background: white;\n    border-radius: 6px;\n    box-shadow: 0 0 10px #ddd;\n    padding: 1.5em;\n  }\n  .step {\n    margin-bottom: 1.2em;\n    border-bottom: 1px solid #eee;\n    padding-bottom: 1em;\n  }\n  .step h3 {\n    margin: 0 0 0.6em 0;\n    color: #004a99;\n    font-weight: 600;\n  }\n  .array-container {\n    font-family: monospace;\n    font-size: 1.2em;\n    margin-top: 0.7em;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 0.5em;\n  }\n  .array-item {\n    background: #e1f0ff;\n    padding: 0.3em 0.7em;\n    border-radius: 4px;\n    color: #004a99;\n    border: 1.5px solid #007acc;\n    min-width: 2.8em;\n    text-align: center;\n    user-select: none;\n  }\n  .bucket-label {\n    font-weight: 700;\n    margin-right: 0.6em;\n    color: #00507a;\n    min-width: 3em;\n  }\n  .bucket {\n    display: flex;\n    align-items: center;\n    margin-bottom: 0.3em;\n  }\n  #legend {\n    max-width: 700px;\n    margin: 1.5em auto;\n    font-size: 0.9em;\n    color: #666;\n  }\n  #error {\n    color: #c00;\n    margin-top: 0.5em;\n  }\n  footer {\n    margin-top: 3em;\n    text-align: center;\n    font-size: 0.8em;\n    color: #999;\n  }\n</style>\n</head>\n<body>\n<h1>Radix Sort Visualization</h1>\n<div id=\"input-section\">\n  <p>Enter a list of non-negative integers separated by commas or spaces:</p>\n  <input type=\"text\" id=\"input-array\" placeholder=\"e.g. 170, 45, 75, 90, 802, 24, 2, 66\" aria-label=\"Input array\" />\n  <br />\n  <button id=\"start-btn\">Start Radix Sort</button>\n  <div id=\"error\" role=\"alert\" aria-live=\"polite\"></div>\n</div>\n\n<div id=\"steps\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions\"></div>\n\n<div id=\"legend\">\n  <strong>How Radix Sort Works:</strong> <br/>\n  Radix Sort sorts numbers digit by digit, starting from the least significant digit (units place) to the most significant digit. At each step, it distributes numbers into buckets (0-9) based on the current digit, then collects them back in order. This continues until all digits have been processed.\n</div>\n\n<footer>© 2024 Radix Sort Demo</footer>\n\n<script>\n(function() {\n  const inputEl = document.getElementById('input-array');\n  const startBtn = document.getElementById('start-btn');\n  const stepsEl = document.getElementById('steps');\n  const errorEl = document.getElementById('error');\n\n  // Helper: create array item element with value\n  function createArrayItem(value) {\n    const span = document.createElement('span');\n    span.classList.add('array-item');\n    span.textContent = value;\n    return span;\n  }\n\n  // Helper: render full array visually\n  function renderArray(arr) {\n    const container = document.createElement('div');\n    container.classList.add('array-container');\n    arr.forEach(num => {\n      container.appendChild(createArrayItem(num));\n    });\n    return container;\n  }\n\n  // Helper: render buckets (0-9) containing arrays of numbers visually\n  function renderBuckets(buckets) {\n    const container = document.createElement('div');\n    for(let i=0; i<10; i++) {\n      const bucketDiv = document.createElement('div');\n      bucketDiv.classList.add('bucket');\n      const label = document.createElement('span');\n      label.classList.add('bucket-label');\n      label.textContent = i + ':';\n      bucketDiv.appendChild(label);\n      buckets[i].forEach(num => {\n        bucketDiv.appendChild(createArrayItem(num));\n      });\n      container.appendChild(bucketDiv);\n    }\n    return container;\n  }\n\n  // Get digit at position (0-based from right)\n  function getDigit(num, pos) {\n    return Math.floor(num / Math.pow(10, pos)) % 10;\n  }\n\n  // Radix sort function with steps visualization\n  function radixSort(arr) {\n    let steps = [];\n    // Copy array for sorting\n    let output = arr.slice();\n    // Get max value to know digit count\n    let maxNum = Math.max(...output);\n    let maxDigits = maxNum.toString().length;\n\n    steps.push({\n      title: `Initial array`,\n      array: output.slice()\n    });\n\n    for(let digitPos = 0; digitPos < maxDigits; digitPos++) {\n      // Prepare buckets 0-9\n      let buckets = Array.from({length:10}, () => []);\n      // Distribute elements based on current digit\n      output.forEach(num => {\n        let digit = getDigit(num, digitPos);\n        buckets[digit].push(num);\n      });\n\n      steps.push({\n        title: `Distribute by digit at position ${digitPos} (from right)`,\n        buckets: buckets.map(b => b.slice())\n      });\n\n      // Collect back: concat all buckets in order\n      output = [].concat(...buckets);\n\n      steps.push({\n        title: `Array after collecting buckets for digit position ${digitPos}`,\n        array: output.slice()\n      });\n    }\n    return steps;\n  }\n\n  // Clear previous steps output\n  function clearSteps() {\n    stepsEl.innerHTML = '';\n  }\n  // Show error message\n  function showError(msg) {\n    errorEl.textContent = msg;\n  }\n  // Clear error message\n  function clearError() {\n    errorEl.textContent = '';\n  }\n\n  // Render all steps with smooth scrolling\n  function renderSteps(steps) {\n    clearSteps();\n    steps.forEach((step, index) => {\n      const stepDiv = document.createElement('section');\n      stepDiv.classList.add('step');\n      stepDiv.tabIndex = 0; // Make focusable for screen readers\n      const title = document.createElement('h3');\n      title.textContent = `Step ${index + 1}: ${step.title}`;\n      stepDiv.appendChild(title);\n\n      if(step.array) {\n        stepDiv.appendChild(renderArray(step.array));\n      }\n      if(step.buckets) {\n        stepDiv.appendChild(renderBuckets(step.buckets));\n      }\n      stepsEl.appendChild(stepDiv);\n    });\n    // Scroll to the first step\n    if (stepsEl.firstChild) {\n      stepsEl.firstChild.focus();\n    }\n  }\n\n  // Parse input string into array of non-negative integers\n  function parseInput(str) {\n    if (!str.trim()) return null;\n    const tokens = str.split(/[\\s,]+/);\n    const nums = [];\n    for(let token of tokens) {\n      if(token === '') continue;\n      if(!/^\\d+$/.test(token)) return null;\n      let n = Number(token);\n      if (!Number.isSafeInteger(n) || n < 0) return null;\n      nums.push(n);\n    }\n    return nums;\n  }\n\n  startBtn.addEventListener('click', () => {\n    clearError();\n    clearSteps();\n    const inputStr = inputEl.value;\n    const arr = parseInput(inputStr);\n    if (!arr || arr.length === 0) {\n      showError('Please enter one or more non-negative integers separated by commas or spaces.');\n      return;\n    }\n    startBtn.disabled = true;\n\n    // Run radix sort and gather steps\n    let steps = radixSort(arr);\n\n    // Render steps\n    renderSteps(steps);\n\n    startBtn.disabled = false;\n  });\n})();\n</script>\n</body>\n</html>"
