    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Indexing Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #indexing {\n            width: 80%;\n            margin: 40px auto;\n            text-align: center;\n        }\n        #indexing h2 {\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h2>Indexing Example</h2>\n    <div id=\"indexing\">\n        <h2>Original List:</h2>\n        <ul>\n            <li>Item 1</li>\n            <li>Item 2</li>\n            <li>Item 3</li>\n        </ul>\n        <h2>Indexed List:</h2>\n        <ol>\n            <li>Item 1</li>\n            <li>Item 2</li>\n            <li>Item 3</li>\n        </ol>\n    </div>\n\n    <script>\n        // Original list\n        let originalList = ['Item 1', 'Item 2', 'Item 3'];\n        console.log('Original List:', originalList);\n\n        // Indexing\n        let indexedList = originalList.map((item, index) => `${index + 1}. ${item}`);\n        console.log('Indexed List:', indexedList);\n\n        // Update the original list with the indexed list\n        originalList = indexedList;\n        console.log('Updated Original List:', originalList);\n    </script>\n</body>\n</html>"
