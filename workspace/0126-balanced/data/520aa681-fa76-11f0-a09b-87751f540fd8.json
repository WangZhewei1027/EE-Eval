    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Query Optimization</title>\n    <style>\n        table {\n            border-collapse: collapse;\n        }\n        th, td {\n            border: 1px solid black;\n            padding: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Query Optimization</h1>\n    <table id=\"query-optimization-table\">\n        <tr>\n            <th>Query</th>\n            <th>Indexing</th>\n            <th>Execution Time</th>\n            <th>Cost</th>\n        </tr>\n        <tr>\n            <td>SELECT * FROM users WHERE age > 18;</td>\n            <td>Indexing: index on age;</td>\n            <td>Execution Time: 0.0001s</td>\n            <td>Cost: 0</td>\n        </tr>\n        <tr>\n            <td>SELECT * FROM users WHERE age > 18 AND country='USA';</td>\n            <td>Indexing: index on age AND country;</td>\n            <td>Execution Time: 0.0002s</td>\n            <td>Cost: 0</td>\n        </tr>\n        <tr>\n            <td>SELECT * FROM users WHERE age > 18 AND country='USA' AND city='New York';</td>\n            <td>Indexing: index on age AND country AND city;</td>\n            <td>Execution Time: 0.0003s</td>\n            <td>Cost: 0</td>\n        </tr>\n    </table>\n\n    <script>\n        let query = \"SELECT * FROM users WHERE age > 18 AND country='USA' AND city='New York';\";\n        let index = \"index on age AND country AND city;\";\n        let executionTime = 0.0003;\n        let cost = 0;\n\n        // Simulate execution time\n        setTimeout(() => {\n            executionTime = Math.random() * 0.0001 + 0.0001;\n            cost = Math.random() * 100 + 0;\n            console.log(`Execution Time: ${executionTime.toFixed(2)}s, Cost: ${cost}`);\n        }, 100);\n\n        // Simulate indexing\n        setTimeout(() => {\n            index = \"index on age AND country AND city;\";\n            console.log(`Indexing: ${index}`);\n        }, 200);\n\n        // Simulate query execution\n        setTimeout(() => {\n            query = \"SELECT * FROM users WHERE age > 18 AND country='USA' AND city='New York';\";\n            console.log(`Query: ${query}`);\n        }, 300);\n\n        // Simulate cost calculation\n        setTimeout(() => {\n            cost = Math.random() * 100 + 0;\n            console.log(`Cost: ${cost}`);\n        }, 400);\n    </script>\n</body>\n</html>"
