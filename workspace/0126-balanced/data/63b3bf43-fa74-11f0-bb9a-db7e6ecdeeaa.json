    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Design Patterns Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2rem;\n      background: #f5f7fa;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n      margin-bottom: 1rem;\n    }\n    h2 {\n      margin-top: 2rem;\n      color: #005f73;\n    }\n    .pattern {\n      background: white;\n      border-radius: 8px;\n      padding: 1rem;\n      margin-bottom: 1.5rem;\n      box-shadow: 0 2px 5px rgba(0,0,0,0.1);\n    }\n    code {\n      background: #e0e0e0;\n      padding: 2px 6px;\n      border-radius: 3px;\n      font-family: monospace;\n    }\n    button {\n      margin-top: 0.5rem;\n      background: #0a9396;\n      border: none;\n      padding: 0.4rem 1rem;\n      color: white;\n      font-size: 1rem;\n      border-radius: 5px;\n      cursor: pointer;\n      transition: background 0.3s ease;\n    }\n    button:hover {\n      background: #007f7f;\n    }\n    pre {\n      background: #222;\n      color: #0f0;\n      padding: 1rem;\n      border-radius: 6px;\n      overflow-x: auto;\n      max-height: 120px;\n    }\n  </style>\n</head>\n<body>\n  <h1>Design Patterns Demo in JavaScript</h1>\n  <p>This page demonstrates four common design patterns with simple examples and interactive output.</p>\n  \n  <div class=\"pattern\" id=\"singleton-pattern\">\n    <h2>Singleton Pattern</h2>\n    <p>The Singleton pattern ensures that a class has only one instance and provides a global point of access to it.</p>\n    <pre><code>\nclass Singleton {\n  constructor() {\n    if (Singleton.instance) {\n      return Singleton.instance;\n    }\n    this.timestamp = new Date();\n    Singleton.instance = this;\n  }\n  getTime() {\n    return this.timestamp.toLocaleTimeString();\n  }\n}\n    </code></pre>\n    <button onclick=\"demoSingleton()\">Create Two Instances and Show Timestamps</button>\n    <div id=\"singleton-output\"></div>\n  </div>\n\n  <div class=\"pattern\" id=\"factory-pattern\">\n    <h2>Factory Pattern</h2>\n    <p>The Factory pattern defines an interface for creating an object, but lets subclasses decide which class to instantiate.</p>\n    <pre><code>\nclass Dog {\n  speak() { return 'Woof!'; }\n}\nclass Cat {\n  speak() { return 'Meow!'; }\n}\nfunction animalFactory(type) {\n  if (type === 'dog') return new Dog();\n  if (type === 'cat') return new Cat();\n  return null;\n}\n    </code></pre>\n    <button onclick=\"demoFactory()\">Create Dog and Cat, then speak</button>\n    <div id=\"factory-output\"></div>\n  </div>\n\n  <div class=\"pattern\" id=\"strategy-pattern\">\n    <h2>Strategy Pattern</h2>\n    <p>The Strategy pattern enables selecting an algorithm’s behavior at runtime.</p>\n    <pre><code>\nclass Sorter {\n  constructor(strategy) {\n    this.strategy = strategy;\n  }\n  sort(data) {\n    return this.strategy(data);\n  }\n}\nconst bubbleSort = (arr) => {\n  let array = [...arr];\n  for(let i = 0; i < array.length; i++) {\n    for(let j=0; j < array.length-i-1; j++) {\n      if(array[j] > array[j+1]) {\n        [array[j],array[j+1]] = [array[j+1],array[j]];\n      }\n    }\n  }\n  return array;\n};\nconst quickSort = (arr) => {\n  if(arr.length <= 1) return arr;\n  let pivot = arr[0];\n  let left = arr.slice(1).filter(x => x < pivot);\n  let right = arr.slice(1).filter(x => x >= pivot);\n  return [...quickSort(left), pivot, ...quickSort(right)];\n};\n    </code></pre>\n    <button onclick=\"demoStrategy()\">Sort array using both strategies</button>\n    <div id=\"strategy-output\"></div>\n  </div>\n\n  <div class=\"pattern\" id=\"observer-pattern\">\n    <h2>Observer Pattern</h2>\n    <p>The Observer pattern allows objects to subscribe to events and be notified when those events occur.</p>\n    <pre><code>\nclass Subject {\n  constructor() {\n    this.observers = [];\n  }\n  subscribe(fn) {\n    this.observers.push(fn);\n  }\n  unsubscribe(fn) {\n    this.observers = this.observers.filter(obs => obs !== fn);\n  }\n  notify(data) {\n    this.observers.forEach(obs => obs(data));\n  }\n}\n    </code></pre>\n    <button onclick=\"demoObserver()\">Subscribe, Notify, and Unsubscribe Observers</button>\n    <div id=\"observer-output\"></div>\n  </div>\n\n  <script>\n    // Singleton Pattern Demo\n    function demoSingleton() {\n      const output = document.getElementById('singleton-output');\n      class Singleton {\n        constructor() {\n          if (Singleton.instance) {\n            return Singleton.instance;\n          }\n          this.timestamp = new Date();\n          Singleton.instance = this;\n        }\n        getTime() {\n          return this.timestamp.toLocaleTimeString();\n        }\n      }\n      const s1 = new Singleton();\n      const s2 = new Singleton();\n      output.innerHTML = `\n      <p>Instance 1 timestamp: <strong>${s1.getTime()}</strong></p>\n      <p>Instance 2 timestamp: <strong>${s2.getTime()}</strong></p>\n      <p>Are both instances equal? <strong>${s1 === s2}</strong></p>\n      <p><em>Note: The timestamps are the same because only one instance is created.</em></p>\n      `;\n    }\n\n    // Factory Pattern Demo\n    function demoFactory() {\n      const output = document.getElementById('factory-output');\n      class Dog {\n        speak() { return 'Woof!'; }\n      }\n      class Cat {\n        speak() { return 'Meow!'; }\n      }\n      function animalFactory(type) {\n        if (type === 'dog') return new Dog();\n        if (type === 'cat') return new Cat();\n        return null;\n      }\n      const dog = animalFactory('dog');\n      const cat = animalFactory('cat');\n      output.innerHTML = `\n        <p>Dog says: <strong>${dog.speak()}</strong></p>\n        <p>Cat says: <strong>${cat.speak()}</strong></p>\n      `;\n    }\n\n    // Strategy Pattern Demo\n    function demoStrategy() {\n      const output = document.getElementById('strategy-output');\n      class Sorter {\n        constructor(strategy) {\n          this.strategy = strategy;\n        }\n        sort(data) {\n          return this.strategy(data);\n        }\n      }\n      const bubbleSort = (arr) => {\n        let array = [...arr];\n        for(let i = 0; i < array.length; i++) {\n          for(let j=0; j < array.length-i-1; j++) {\n            if(array[j] > array[j+1]) {\n              [array[j],array[j+1]] = [array[j+1],array[j]];\n            }\n          }\n        }\n        return array;\n      };\n      const quickSort = (arr) => {\n        if(arr.length <= 1) return arr;\n        let pivot = arr[0];\n        let left = arr.slice(1).filter(x => x < pivot);\n        let right = arr.slice(1).filter(x => x >= pivot);\n        return [...quickSort(left), pivot, ...quickSort(right)];\n      };\n      const numbers = [5,3,8,4,2,7,1,6];\n      const bubbleSorter = new Sorter(bubbleSort);\n      const quickSorter = new Sorter(quickSort);\n      output.innerHTML = `\n        <p>Original array: [${numbers.join(', ')}]</p>\n        <p>Bubble sort result: [${bubbleSorter.sort(numbers).join(', ')}]</p>\n        <p>Quick sort result: [${quickSorter.sort(numbers).join(', ')}]</p>\n      `;\n    }\n\n    // Observer Pattern Demo\n    function demoObserver() {\n      const output = document.getElementById('observer-output');\n      class Subject {\n        constructor() {\n          this.observers = [];\n        }\n        subscribe(fn) {\n          this.observers.push(fn);\n        }\n        unsubscribe(fn) {\n          this.observers = this.observers.filter(obs => obs !== fn);\n        }\n        notify(data) {\n          this.observers.forEach(obs => obs(data));\n        }\n      }\n      const subject = new Subject();\n\n      const observer1 = (data) => {\n        output.innerHTML += `<p>Observer 1 received: ${data}</p>`;\n      };\n      const observer2 = (data) => {\n        output.innerHTML += `<p>Observer 2 received: ${data}</p>`;\n      };\n\n      output.innerHTML = '<p>Subscribing Observer 1 and Observer 2...</p>';\n      subject.subscribe(observer1);\n      subject.subscribe(observer2);\n\n      setTimeout(() => {\n        output.innerHTML += '<p>Notifying observers with \"Event #1\"...</p>';\n        subject.notify('Event #1');\n      }, 1000);\n\n      setTimeout(() => {\n        output.innerHTML += '<p>Unsubscribing Observer 2...</p>';\n        subject.unsubscribe(observer2);\n      }, 2200);\n\n      setTimeout(() => {\n        output.innerHTML += '<p>Notifying observers with \"Event #2\"...</p>';\n        subject.notify('Event #2');\n      }, 3000);\n    }\n  </script>\n</body>\n</html>"
