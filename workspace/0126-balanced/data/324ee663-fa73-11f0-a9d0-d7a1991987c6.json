    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Indexing Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        .output {\n            margin-top: 20px;\n            border: 1px solid #ccc;\n            padding: 10px;\n            background-color: #f9f9f9;\n        }\n    </style>\n</head>\n<body>\n    <h1>Indexing Demonstration</h1>\n    <p>Indexing is the process of mapping values to their positions in a data structure, making retrieval more efficient.</p>\n    \n    <h2>Example List of Items</h2>\n    <input type=\"text\" id=\"searchInput\" placeholder=\"Search for an item...\" />\n    <button onclick=\"searchItem()\">Search</button>\n    \n    <div class=\"output\" id=\"resultOutput\"></div>\n    \n    <script>\n        // Sample data array\n        const items = [\n            { id: 0, name: \"Apple\" },\n            { id: 1, name: \"Banana\" },\n            { id: 2, name: \"Orange\" },\n            { id: 3, name: \"Grapes\" },\n            { id: 4, name: \"Pineapple\" },\n            { id: 5, name: \"Mango\" },\n            { id: 6, name: \"Strawberry\" }\n        ];\n\n        // Function to create an index\n        function createIndex(data) {\n            const index = {};\n            data.forEach(item => {\n                index[item.name.toLowerCase()] = item;\n            });\n            return index;\n        }\n\n        // Create index for fast lookup\n        const indexedItems = createIndex(items);\n        \n        // Function to search for an item\n        function searchItem() {\n            const searchInput = document.getElementById(\"searchInput\").value.toLowerCase();\n            const resultOutput = document.getElementById(\"resultOutput\");\n            resultOutput.innerHTML = \"\"; // Clear previous results\n            \n            if (indexedItems[searchInput]) {\n                const item = indexedItems[searchInput];\n                resultOutput.innerHTML = `<strong>Found:</strong> ${item.name} (ID: ${item.id})`;\n            } else {\n                resultOutput.innerHTML = \"Item not found.\";\n            }\n        }\n    </script>\n</body>\n</html>"
