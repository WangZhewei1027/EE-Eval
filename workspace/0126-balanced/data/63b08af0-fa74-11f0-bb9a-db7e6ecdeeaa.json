  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Red-Black Tree Visualization and Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 10px;\n    background: #f9f9f9;\n    overflow-x: hidden;\n  }\n  h1 {\n    text-align: center;\n  }\n  #controls {\n    max-width: 600px;\n    margin: 0 auto 15px;\n    text-align: center;\n  }\n  #controls input[type=\"number\"] {\n    width: 100px;\n    padding: 6px;\n    font-size: 1rem;\n  }\n  #controls button {\n    padding: 6px 15px;\n    font-size: 1rem;\n    margin-left: 5px;\n    cursor: pointer;\n  }\n  #message {\n    max-width: 600px;\n    margin: 5px auto;\n    text-align: center;\n    min-height: 1.4em;\n    font-weight: bold;\n  }\n  #treeContainer {\n    display: flex;\n    justify-content: center;\n    overflow-x: auto;\n    margin-top: 15px;\n    padding-bottom: 40px;\n  }\n  svg {\n    background: white;\n    border: 1px solid #ccc;\n    border-radius: 6px;\n  }\n</style>\n</head>\n<body>\n<h1>Red-Black Tree Visualization & Demonstration</h1>\n\n<div id=\"controls\">\n  <input type=\"number\" id=\"inputValue\" placeholder=\"Enter integer\" />\n  <button id=\"insertBtn\">Insert</button>\n  <button id=\"clearBtn\">Clear Tree</button>\n</div>\n<div id=\"message\"></div>\n<div id=\"treeContainer\">\n  <svg id=\"treeSVG\" width=\"1000\" height=\"500\"></svg>\n</div>\n\n<script>\n  /*\n    Simple Red-Black Tree implementation with visualization.\n    Node colors: Red or Black.\n   \n    Properties:\n      1. Every node is either red or black.\n      2. The root is always black.\n      3. All leaves (NIL) are black.\n      4. If a red node has children, the children are always black (no two reds in a row).\n      5. Every path from a node to its descendant NIL nodes contains the same number of black nodes.\n  */\n\n  // Define colors\n  const RED = 'red';\n  const BLACK = 'black';\n\n  // Node class for RB tree\n  class RBNode {\n    constructor(key) {\n      this.key = key;\n      this.color = RED;\n      this.left = null;\n      this.right = null;\n      this.parent = null;\n    }\n  }\n\n  // Nil node for leaves (always black)\n  const NIL = new RBNode(null);\n  NIL.color = BLACK;\n  NIL.left = null;\n  NIL.right = null;\n  NIL.parent = null;\n\n  class RedBlackTree {\n    constructor() {\n      this.root = NIL;\n    }\n\n    leftRotate(x) {\n      const y = x.right;\n      x.right = y.left;\n      if (y.left !== NIL) {\n        y.left.parent = x;\n      }\n      y.parent = x.parent;\n      if (x.parent === null) {\n        this.root = y;\n      } else if (x === x.parent.left) {\n        x.parent.left = y;\n      } else {\n        x.parent.right = y;\n      }\n      y.left = x;\n      x.parent = y;\n    }\n\n    rightRotate(y) {\n      const x = y.left;\n      y.left = x.right;\n      if (x.right !== NIL) {\n        x.right.parent = y;\n      }\n      x.parent = y.parent;\n      if (y.parent === null) {\n        this.root = x;\n      } else if (y === y.parent.right) {\n        y.parent.right = x;\n      } else {\n        y.parent.left = x;\n      }\n      x.right = y;\n      y.parent = x;\n    }\n\n    insert(key) {\n      const newNode = new RBNode(key);\n      newNode.left = NIL;\n      newNode.right = NIL;\n\n      let y = null;\n      let x = this.root;\n\n      while (x !== NIL) {\n        y = x;\n        if (newNode.key === x.key) {\n          // Duplicate key — do not insert\n          return false;\n        } else if (newNode.key < x.key) {\n          x = x.left;\n        } else {\n          x = x.right;\n        }\n      }\n\n      newNode.parent = y;\n      if (y === null) {\n        this.root = newNode;\n      } else if (newNode.key < y.key) {\n        y.left = newNode;\n      } else {\n        y.right = newNode;\n      }\n\n      newNode.color = RED;\n      this.insertFixup(newNode);\n      return true;\n    }\n\n    insertFixup(z) {\n      while (z.parent && z.parent.color === RED) {\n        if (z.parent === z.parent.parent.left) {\n          const y = z.parent.parent.right;\n          if (y.color === RED) {\n            z.parent.color = BLACK;\n            y.color = BLACK;\n            z.parent.parent.color = RED;\n            z = z.parent.parent;\n          } else {\n            if (z === z.parent.right) {\n              z = z.parent;\n              this.leftRotate(z);\n            }\n            z.parent.color = BLACK;\n            z.parent.parent.color = RED;\n            this.rightRotate(z.parent.parent);\n          }\n        } else {\n          const y = z.parent.parent.left;\n          if (y.color === RED) {\n            z.parent.color = BLACK;\n            y.color = BLACK;\n            z.parent.parent.color = RED;\n            z = z.parent.parent;\n          } else {\n            if (z === z.parent.left) {\n              z = z.parent;\n              this.rightRotate(z);\n            }\n            z.parent.color = BLACK;\n            z.parent.parent.color = RED;\n            this.leftRotate(z.parent.parent);\n          }\n        }\n      }\n      this.root.color = BLACK;\n    }\n\n    // For visualization: convert tree to a structure with x,y coordinates and parent link positions\n    getVisualNodes() {\n      if (this.root === NIL) return [];\n\n      // Assign coordinates via BFS layer traversal + horizontal positioning using inorder index\n      const nodes = [];\n      const levels = [];\n\n      // First assign levels and references\n      const queue = [{ node: this.root, depth: 0, parent: null }];\n      while (queue.length > 0) {\n        const { node, depth, parent } = queue.shift();\n        if (!levels[depth]) levels[depth] = [];\n        levels[depth].push(node);\n\n        node._depth = depth;\n        node._parent = parent;\n\n        if (node.left !== NIL) queue.push({ node: node.left, depth: depth + 1, parent: node });\n        if (node.right !== NIL) queue.push({ node: node.right, depth: depth + 1, parent: node });\n      }\n\n      // Get inorder nodes to assign horizontal positions\n      let inorderNodes = [];\n      function inorder(n) {\n        if (n === NIL) return;\n        inorder(n.left);\n        inorderNodes.push(n);\n        inorder(n.right);\n      }\n      inorder(this.root);\n\n      // Assign x positions based on inorder index spacing\n      const horizontalSpacing = 45;\n      const verticalSpacing = 70;\n      inorderNodes.forEach((node, i) => {\n        node._x = (i + 1) * horizontalSpacing;\n        node._y = node._depth * verticalSpacing + 40;\n      });\n\n      return inorderNodes;\n    }\n  }\n\n  // Visualization\n  const svg = document.getElementById('treeSVG');\n  const insertBtn = document.getElementById('insertBtn');\n  const inputValue = document.getElementById('inputValue');\n  const clearBtn = document.getElementById('clearBtn');\n  const messageBox = document.getElementById('message');\n\n  const tree = new RedBlackTree();\n\n  function clearSVG() {\n    while (svg.firstChild) {\n      svg.removeChild(svg.firstChild);\n    }\n  }\n\n  function createSVGElement(tag, attrs) {\n    const elem = document.createElementNS('http://www.w3.org/2000/svg', tag);\n    for (const k in attrs) {\n      if (k === 'textContent') {\n        elem.textContent = attrs[k];\n      } else {\n        elem.setAttribute(k, attrs[k]);\n      }\n    }\n    return elem;\n  }\n\n  function drawTree() {\n    clearSVG();\n    const nodes = tree.getVisualNodes();\n    if (nodes.length === 0) {\n      messageBox.textContent = \"Tree is empty\";\n      return;\n    } else {\n      messageBox.textContent = \"\";\n    }\n\n    // Draw edges\n    nodes.forEach((node) => {\n      if (node._parent && node._parent !== null) {\n        // Draw a line from parent to this node\n        const line = createSVGElement('line', {\n          x1: node._parent._x,\n          y1: node._parent._y + 15,\n          x2: node._x,\n          y2: node._y - 15,\n          stroke: '#888',\n          'stroke-width': 2,\n        });\n        svg.appendChild(line);\n      }\n    });\n\n    // Draw nodes\n    nodes.forEach((node) => {\n      const group = createSVGElement('g', {});\n\n      // Circle for node\n      const circle = createSVGElement('circle', {\n        cx: node._x,\n        cy: node._y,\n        r: 15,\n        fill: node.color === RED ? '#e74c3c' : '#34495e',\n        stroke: '#333',\n        'stroke-width': 2,\n      });\n      group.appendChild(circle);\n\n      // Text inside circle\n      const text = createSVGElement('text', {\n        x: node._x,\n        y: node._y + 5,\n        'text-anchor': 'middle',\n        'font-size': '14px',\n        fill: '#fff',\n        'font-weight': 'bold',\n        'pointer-events': 'none',\n        textContent: node.key,\n      });\n      group.appendChild(text);\n\n      svg.appendChild(group);\n    });\n  }\n\n  insertBtn.addEventListener('click', () => {\n    let val = inputValue.value.trim();\n    if (val === '') {\n      messageBox.textContent = 'Please enter a number.';\n      return;\n    }\n    let num = Number(val);\n    if (!Number.isInteger(num)) {\n      messageBox.textContent = 'Please enter an integer value.';\n      return;\n    }\n    if (num < -999999 || num > 999999) {\n      messageBox.textContent = 'Please enter a number between -999999 and 999999.';\n      return;\n    }\n    const inserted = tree.insert(num);\n    if (!inserted) {\n      messageBox.textContent = `Value ${num} already exists in the tree.`;\n    } else {\n      messageBox.textContent = `Inserted value: ${num}`;\n      drawTree();\n    }\n    inputValue.value = '';\n    inputValue.focus();\n  });\n\n  clearBtn.addEventListener('click', () => {\n    tree.root = NIL;\n    clearSVG();\n    messageBox.textContent = 'Tree cleared.';\n  });\n\n  // Initial draw empty tree\n  drawTree();\n\n  // Enable inserting nodes by pressing Enter\n  inputValue.addEventListener('keydown', (ev) => {\n    if (ev.key === 'Enter') {\n      insertBtn.click();\n    }\n  });\n</script>\n</body>\n</html>"
  },
