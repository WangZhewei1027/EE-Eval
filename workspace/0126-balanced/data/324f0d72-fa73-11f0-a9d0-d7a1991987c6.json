    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Query Optimization Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n            background-color: #f4f4f4;\n        }\n        .query-container {\n            margin-bottom: 20px;\n        }\n        .result {\n            background-color: #fff;\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin-top: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Query Optimization Demo</h1>\n    <p>This is a simple demonstration of how query optimization works.</p>\n\n    <div class=\"query-container\">\n        <label for=\"query\">Enter a SQL query:</label>\n        <input type=\"text\" id=\"query\" placeholder=\"SELECT * FROM users WHERE age > 30\">\n        <button onclick=\"optimizeQuery()\">Optimize Query</button>\n    </div>\n    \n    <div class=\"result\" id=\"result\"></div>\n\n    <script>\n        function optimizeQuery() {\n            const query = document.getElementById('query').value;\n            let optimizedQuery = query;\n\n            // Basic optimization techniques\n            if (query.includes(\"SELECT *\")) {\n                optimizedQuery = optimizedQuery.replace(\"SELECT *\", \"SELECT id, name, email\");\n            }\n\n            if (query.includes(\"WHERE\")) {\n                if (!query.includes(\"ORDER BY\") && !query.includes(\"LIMIT\")) {\n                    optimizedQuery += \" ORDER BY id LIMIT 10\";\n                }\n            } else {\n                optimizedQuery += \" WHERE id IS NOT NULL\";\n            }\n\n            // Display the optimized query\n            document.getElementById('result').innerHTML = \n                `<strong>Original Query:</strong> ${query}<br>\n                <strong>Optimized Query:</strong> ${optimizedQuery}`;\n        }\n    </script>\n</body>\n</html>"
