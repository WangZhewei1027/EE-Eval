formance.now();\n  let found = null;\n  const n = arr.length;\n  const total = 1<<Math.min(31,n); // safe cap for bit shifts\n  for(let mask=0; mask< (1<<n); mask++){\n    let s=0; const subset=[];\n    for(let i=0;i<n;i++) if(mask & (1<<i)){ s+=arr[i]; subset.push(arr[i]); }\n    if(s === target){ found = subset; break; }\n  }\n  const elapsed = (performance.now()-start).toFixed(2);\n  const out = document.getElementById('ssOutput');\n  if(found) out.innerHTML = `<span class=\"good\">YES</span> — subset found in ${elapsed} ms: [${found.join(', ')}]`;\n  else out.innerHTML = `<span class=\"bad\">NO</span> — no subset equals ${target} (took ${elapsed} ms)`;\n});\n\ndocument.getElementById('ssDPBtn').addEventListener('click', ()=>{\n  const arr = parseNumbers(document.getElementById('ssNumbers').value);\n  const target = Number(document.getElementById('ssTarget').value);\n  if(arr.some(isNaN) || isNaN(target)){ document.getElementById('ssOutput').textContent = 'Invalid input'; return; }\n  const start = performance.now();\n  // naive DP boolean table\n  const dp = new Array(target+1).fill(false);\n  const parent = new Array(target+1).fill(null);\n  dp[0]=true;\n  for(let i=0;i<arr.length;i++){\n    const val = arr[i];\n    for(let s=target; s>=val; s--){\n      if(!dp[s] && dp[s-val]){\n        dp[s] = true;\n        parent[s] = {prev: s-val, idx:i};\n      }\n    }\n  }\n  const elapsed = (performance.now()-start).toFixed(2);\n  const out = document.getElementById('ssOutput');\n  if(dp[target]){\n    const subset = [];\n    let s = target;\n    while(s>0 && parent[s]){\n      subset.push(arr[parent[s].idx]);\n      s = parent[s].prev;\n    }\n    out.innerHTML = `<span class=\"good\">YES</span> (DP) — subset found in ${elapsed} ms: [${subset.reverse().join(', ')}]`;\n  } else {\n    out.innerHTML = `<span class=\"bad\">NO</span> (DP) — no subset equals ${target} (took ${elapsed} ms)`;\n  }\n});\n\n/* Complexity experiment (timing exponential) */\ndocument.getElementById('runExpBtn').addEventListener('click', async ()=>{\n  const maxN = Math.min(24, Number(document.getElementById('expMaxN').value) || 20);\n  const trials = Math.min(10, Number(document.getElementById('expTrials').value) || 3);\n  const out = document.getElementById('expOutput');\n  out.innerHTML = 'Running... collecting times (small trials). This may take a few seconds.';\n  // For each n, generate random formula with n variables and ~n clauses and test brute-force time to find a satisfying assignment or determine unsat.\n  const results = [];\n  for(let n=2; n<=maxN; n++){\n    let sum = 0;\n    for(let t=0;t<trials;t++){\n      // build a simple formula with n variables and n clauses of size 3 (may be unsat or sat)\n      const vars = Array.from({length:n}, (_,i)=>'x'+(i+1));\n      const clauses = [];\n      for(let c=0;c<Math.max(1,n);c++){\n        const picks = new Set();\n        while(picks.size < 3){\n          const idx = Math.floor(Math.random()*vars.length);\n          picks.add((Math.random()<0.45? '~':'') + vars[idx]);\n        }\n        clauses.push(Array.from(picks).join(' or '));\n      }\n      const txt = clauses.join('\\n');\n      const parsed = parseFormula(txt);\n      const start = performance.now();\n      // run limited brute-force: stop after 1<<n assignments or if time > 250ms\n      let tested=0, sat=false;\n      const limitTime = 250 + (n*10);\n      for(let mask=0; mask < (1<<n); mask++){\n        const assign = {};\n        for(let i=0;i<n;i++) assign[vars[i]] = !!(mask & (1<<i));\n        tested++;\n        if(evalFormula(parsed.clauses, assign)){ sat=true; break; }\n        if(tested % 4096 === 0 && performance.now() - start > limitTime) break;\n      }\n      const elapsed = performance.now() - start;\n      sum += elapsed;\n      // small sleep to let UI breathe occasionally\n      if(t%3===0) await new Promise(r=>setTimeout(r,1));\n    }\n    const avg = sum / trials;\n    results.push({n, avg});\n    out.innerHTML = `Measured n=${n} avg=${avg.toFixed(2)} ms (trials=${trials})...`;\n  }\n  // present succinct summary\n  const rows = results.map(r=>`n=${r.n}: ${r.avg.toFixed(2)} ms`).join('\\n');\n  out.innerHTML = `<strong>Timing summary (small randomized experiments):</strong><pre>${rows}</pre><div class=\"muted small\">Observe how time tends to grow rapidly with n — exponential growth dominates for brute-force.</div>`;\n});\n\ndocument.getElementById('clearExpBtn').addEventListener('click', ()=>{\n  document.getElementById('expOutput').innerHTML = 'No experiment yet.';\n});\n\n/* Initialize drawing */\nbuildGraphFromFormula();\n</script>\n</body>\n</html>"
