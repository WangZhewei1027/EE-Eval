  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\"/>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n  <title>Interactive Demonstration: NP-Completeness</title>\n  <style>\n    :root{\n      --bg:#0f1724; --card:#0b1220; --accent:#63b3ed; --muted:#94a3b8;\n      --good:#16a34a; --bad:#ef4444; --glass: rgba(255,255,255,0.03);\n    }\n    body{\n      margin:0; font-family:Inter,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\n      background: linear-gradient(180deg,#071126,#081224 40%, #071124);\n      color:#e6eef8; line-height:1.45;\n    }\n    header{\n      padding:28px 28px 10px 28px;\n      border-bottom:1px solid rgba(255,255,255,0.03);\n      display:flex; gap:20px; align-items:center;\n    }\n    header h1{margin:0; font-size:20px; letter-spacing:0.2px;}\n    header p{margin:0; color:var(--muted); font-size:13px;}\n    main{display:grid; grid-template-columns: 380px 1fr; gap:20px; padding:22px;}\n    .panel{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:12px; padding:14px; box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n      border:1px solid rgba(255,255,255,0.03);\n    }\n    .panel h2{margin:0 0 10px 0; font-size:16px;}\n    .muted{color:var(--muted); font-size:13px;}\n    .section{margin-bottom:14px;}\n    textarea, input[type=\"text\"], input[type=\"number\"], select{\n      width:100%; padding:8px 10px; border-radius:8px; border:1px solid rgba(255,255,255,0.04);\n      background:var(--card); color:inherit; resize:vertical; min-height:36px;\n    }\n    button{\n      background:linear-gradient(90deg,var(--accent),#38bdf8); border:none; padding:8px 12px;\n      border-radius:9px; color:#04263b; font-weight:600; cursor:pointer;\n    }\n    button.ghost{\n      background:transparent; border:1px solid rgba(255,255,255,0.04); color:var(--muted);\n    }\n    .row{display:flex; gap:8px; align-items:center;}\n    .small{font-size:13px;}\n    pre{background:rgba(255,255,255,0.02); padding:10px; border-radius:8px; overflow:auto; white-space:pre-wrap;}\n    svg{width:100%; height:360px; background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent); border-radius:8px;}\n    .node{cursor:pointer;}\n    .legend{display:flex; gap:8px; align-items:center; margin-top:8px;}\n    .chip{padding:6px 8px; border-radius:999px; background:var(--glass); color:var(--muted); font-size:13px;}\n    .status{padding:8px; border-radius:8px; background:rgba(255,255,255,0.02); font-size:13px;}\n    .good{color:var(--good); font-weight:700;}\n    .bad{color:var(--bad); font-weight:700;}\n    footer{grid-column:1/-1; padding:18px 28px; color:var(--muted); font-size:13px;}\n    small.note{display:block; color:var(--muted); margin-top:6px;}\n    a.link{color:var(--accent); text-decoration:none;}\n    label{display:block; font-size:13px; margin-bottom:6px; color:var(--muted);}\n    .controls{display:flex; gap:8px; margin-top:8px;}\n    .flex{display:flex; gap:8px;}\n    .kbd{padding:6px 8px; background:rgba(255,255,255,0.02); border-radius:6px; color:var(--muted); font-size:13px;}\n    .important{background: linear-gradient(90deg,#fff2, #fff0); padding:8px; border-radius:8px; color:inherit;}\n    .grid-2{display:grid; grid-template-columns:1fr 1fr; gap:8px;}\n  </style>\n</head>\n<body>\n  <header>\n    <div>\n      <h1>Interactive: NP, NP-Complete & Reductions</h1>\n      <p>Explore the definitions, small solvers, and a concrete reduction (3-SAT → CLIQUE) that illustrates NP-Completeness.</p>\n    </div>\n    <div style=\"margin-left:auto;text-align:right\">\n      <div class=\"chip\">Accessible demo • Browser-only • No external code</div>\n      <div class=\"muted\" style=\"margin-top:6px\">Run small examples to learn — large instances are intentionally limited.</div>\n    </div>\n  </header>\n\n  <main>\n    <aside class=\"panel\">\n      <div class=\"section\">\n        <h2>Quick Definitions</h2>\n        <div class=\"muted\">\n          <p><strong>P</strong>: problems solvable by an algorithm in polynomial time (fast).</p>\n          <p><strong>NP</strong>: decision problems where a candidate solution can be verified in polynomial time.</p>\n          <p><strong>NP-Complete</strong>: problems in NP that are at least as hard as any other problem in NP — every NP problem can be reduced to an NP-Complete problem in polynomial time. If any NP-Complete problem is in P, then P = NP.</p>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <h2>Why reductions?</h2>\n        <div class=\"muted\">\n          Reductions translate instances of one problem to another so that a solution to the target gives a solution to the source. A single polynomial-time reduction from every problem in NP to one target problem makes that target NP-Complete.\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <h2>Common NP-Complete problems</h2>\n        <div class=\"muted\">\n          - SAT / 3-SAT (satisfiability of boolean formulas)<br>\n          - CLIQUE, VERTEX COVER, INDEPENDENT SET (graph problems)<br>\n          - SUBSET-SUM / KNAPSACK (numbers & targets)<br>\n          - HAMILTONIAN CYCLE, TRAVELING SALESMAN (variants)\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <h2>Notes</h2>\n        <div class=\"muted\">\n          This demo focuses on 3-SAT and its classic reduction to CLIQUE (a standard NP-Complete reduction). It also shows brute-force and dynamic approaches to give intuition about \"exponential\" behavior.\n        </div>\n      </div>\n    </aside>\n\n    <section class=\"panel\">\n      <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n        <h2>Interactive: 3-SAT (create, solve, and reduce)</h2>\n        <div class=\"chip\">3-SAT → CLIQUE</div>\n      </div>\n\n      <div class=\"section\">\n        <label>Enter a 3-CNF formula (one clause per line). Use variables like x1, x2 and negation with ~ or !</label>\n        <textarea id=\"formulaInput\" rows=\"6\" spellcheck=\"false\">x1 or x2 or ~x3\n~x1 or x3 or x4\n~x2 or ~x3 or x4</textarea>\n\n        <div class=\"controls\" style=\"margin-top:8px;\">\n          <button id=\"solveBtn\">Brute-force solve</button>\n          <button id=\"reduceBtn\" class=\"ghost\">Reduce to CLIQUE (build graph)</button>\n          <button id=\"randomBtn\" class=\"ghost\">Random small formula</button>\n          <div style=\"margin-left:auto\" class=\"muted small\" id=\"varsCount\">Vars: -  Clauses: -</div>\n        </div>\n\n        <div style=\"margin-top:10px;\">\n          <div id=\"solveOutput\" class=\"status muted\">Solver output will appear here.</div>\n          <small class=\"note\">Brute-force enumerates assignments (exponential). This demo caps work so the page stays responsive.</small>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <h3>Reduction visualization (3-SAT → CLIQUE)</h3>\n        <div class=\"muted\">We create one node per literal occurrence (each clause gives 3 nodes). Connect nodes from different clauses unless they are complementary literals (x and ~x). A clique of size m (#clauses) corresponds to picking one literal per clause that are pairwise compatible, giving a satisfying assignment.</div>\n\n        <div style=\"display:flex; gap:8px; margin-top:8px;\">\n          <div style=\"flex:1;\">\n            <svg id=\"graphSvg\" viewBox=\"0 0 600 360\" aria-label=\"clique graph\"></svg>\n          </div>\n          <div style=\"width:260px;\">\n            <div class=\"muted small\">Clique target (k): <span id=\"cliqueK\">-</span></div>\n            <div style=\"margin-top:8px;\">\n              <button id=\"findCliqueBtn\">Find clique of size k</button>\n              <button id=\"clearGraphBtn\" class=\"ghost\">Clear highlights</button>\n            </div>\n            <div style=\"margin-top:12px;\">\n              <div id=\"cliqueResult\" class=\"status muted\">Result will appear here.</div>\n            </div>\n            <div style=\"margin-top:12px;\">\n              <div class=\"muted small\"><strong>Legend</strong></div>\n              <div class=\"legend\">\n                <div class=\"chip\">node = literal instance</div>\n                <div class=\"chip\">edge = compatibility</div>\n              </div>\n              <small class=\"note\">Click a node to toggle highlight and see its literal. Hover edges/nodes for info.</small>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <h3>Try it: modify and explore</h3>\n        <div class=\"muted small\">Tip: After reducing, press \"Find clique\" to see whether the graph contains a clique of size equal to clause count. If it does, we can read off a satisfying assignment (one literal from each clause).</div>\n      </div>\n    </section>\n\n    <section class=\"panel\">\n      <h2>Subset Sum: Brute-force vs. Dynamic Programming</h2>\n      <div class=\"section\">\n        <label>Enter numbers (comma separated) and a target sum</label>\n        <input id=\"ssNumbers\" type=\"text\" value=\"3,7,1,8,4\"/>\n        <div class=\"flex\" style=\"margin-top:8px;\">\n          <input id=\"ssTarget\" type=\"number\" value=\"11\"/>\n          <button id=\"ssSolveBtn\">Solve</button>\n          <button id=\"ssDPBtn\" class=\"ghost\">Solve (DP)</button>\n        </div>\n        <div style=\"margin-top:10px;\">\n          <div id=\"ssOutput\" class=\"status muted\">Output will appear here.</div>\n          <small class=\"note\">Brute-force checks all subsets (2^n). Dynamic programming can be faster when target and values are small (pseudo-polynomial).</small>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <h3>Complexity demo: Exponential growth</h3>\n        <div class=\"muted small\">Measure time to check all assignments for random 3-SAT-like formulas with increasing variable counts. This runs short experiments (kept tiny to avoid freezing the browser).</div>\n        <div style=\"margin-top:8px;\" class=\"grid-2\">\n          <div>\n            <label>Max variables (<=24)</label>\n            <input id=\"expMaxN\" type=\"number\" min=\"1\" max=\"24\" value=\"20\"/>\n          </div>\n          <div>\n            <label>Trials / N</label>\n            <input id=\"expTrials\" type=\"number\" min=\"1\" max=\"20\" value=\"3\"/>\n          </div>\n        </div>\n        <div style=\"margin-top:8px;\">\n          <div class=\"controls\">\n            <button id=\"runExpBtn\">Run timing experiment</button>\n            <button id=\"clearExpBtn\" class=\"ghost\">Clear graph</button>\n          </div>\n          <div id=\"expOutput\" class=\"status muted\" style=\"margin-top:10px;\">No experiment yet.</div>\n        </div>\n      </div>\n    </section>\n\n    <footer class=\"panel\">\n      <strong>How the demo connects to NP-Completeness</strong>\n      <p class=\"muted small\">3-SAT is a canonical NP-Complete problem (Cook–Levin theorem shows SAT is NP-complete; 3-SAT is a standard restriction still NP-Complete). The reduction to CLIQUE shown here is a textbook example: a polynomial-time transformation that preserves satisfiability. If you could solve CLIQUE quickly (in polynomial time), you could solve 3-SAT quickly by reducing and solving, implying P = NP.</p>\n      <div style=\"display:flex; gap:12px; margin-top:8px;\">\n        <div class=\"kbd\">Try creating unsatisfiable formulas and see the graph lacks a clique of the required size.</div>\n        <div class=\"kbd\">Try small examples only — exponential algorithms will grow very quickly.</div>\n      </div>\n    </footer>\n  </main>\n\n<script>\n/* Helper utilities */\nfunction parseFormula(text){\n  // Returns {clauses: [ [ {var:'x1', neg:false}, ... ], ... ], vars:Set }\n  const lines = text.split(/\\n/).map(s=>s.trim()).filter(Boolean);\n  const clauses = [];\n  const vars = new Set();\n  for(const line of lines){\n    // split by \"or\"\n    const parts = line.split(/\\bor\\b/i).map(s=>s.trim()).filter(Boolean);\n    const lits = [];\n    for(const p of parts){\n      const m = p.match(/^(!|~)?\\s*([A-Za-z]\\w*)$/);\n      if(!m){\n        // try with parentheses or extra spaces\n        const clean = p.replace(/[\\(\\)\\s]+/g,'');\n        const m2 = clean.match(/^(!|~)?([A-Za-z]\\w*)$/);\n        if(!m2) {\n          // fallback: attempt to parse something like -x1\n          const m3 = p.match(/(-)?([A-Za-z]\\w*)/);\n          if(m3) {\n            lits.push({var:m3[2], neg: !!m3[1]});\n            vars.add(m3[2]);\n          } else {\n            // skip malformed\n          }\n        } else {\n          lits.push({var:m2[2], neg: m2[1] === '!' || m2[1] === '~'});\n          vars.add(m2[2]);\n        }\n      } else {\n        lits.push({var:m[2], neg: m[1] === '!' || m[1] === '~'});\n        vars.add(m[2]);\n      }\n    }\n    clauses.push(lits);\n  }\n  return {clauses, vars: Array.from(vars).sort()};\n}\n\nfunction evalClause(clause, assign){\n  for(const lit of clause){\n    const val = !!assign[lit.var];\n    if(lit.neg ? !val : val) return true;\n  }\n  return false;\n}\nfunction evalFormula(clauses, assign){\n  for(const c of clauses) if(!evalClause(c,assign)) return false;\n  return true;\n}\n\n/* Brute-force 3-SAT solver */\ndocument.getElementById('solveBtn').addEventListener('click', ()=>{\n  const text = document.getElementById('formulaInput').value;\n  const parsed = parseFormula(text);\n  const clauses = parsed.clauses;\n  const vars = parsed.vars;\n  document.getElementById('varsCount').textContent = `Vars: ${vars.length}  Clauses: ${clauses.length}`;\n\n  if(vars.length > 26){\n    document.getElementById('solveOutput').innerHTML = '<span class=\"bad\">Too many variables (cap: 26)</span>';\n    return;\n  }\n  // limit effort: if 2^n is huge, warn and require confirmation\n  const assignments = 1<<Math.min(26,vars.length);\n  if(vars.length >= 24){\n    if(!confirm('Brute-force with >=24 variables may be slow. Continue?')) return;\n  }\n\n  const start = performance.now();\n  let tested = 0;\n  let sat = false;\n  let satAssign = null;\n  for(let mask=0; mask < (1<<vars.length); mask++){\n    const assign = {};\n    for(let i=0;i<vars.length;i++) assign[vars[i]] = !!(mask & (1<<i));\n    tested++;\n    if(evalFormula(clauses, assign)){\n      sat = true; satAssign = {...assign}; break;\n    }\n    // small cooperative multitasking for UI responsiveness\n    if(tested % 100000 === 0 && performance.now() - start > 500){\n      // allow UI to update\n    }\n  }\n  const elapsed = (performance.now() - start).toFixed(2);\n  const out = document.getElementById('solveOutput');\n  if(sat){\n    out.innerHTML = `<span class=\"good\">SAT</span> — assignment found in ${elapsed} ms, tested ${tested} assignments. <pre>${JSON.stringify(satAssign,null,2)}</pre>`;\n  } else {\n    out.innerHTML = `<span class=\"bad\">UNSAT</span> — no assignment (tested ${tested}) in ${elapsed} ms.`;\n  }\n});\n\n/* Random generator */\ndocument.getElementById('randomBtn').addEventListener('click', ()=>{\n  // generate small random 3-CNF\n  const vars = ['x1','x2','x3','x4','x5','x6'];\n  const nVars = Math.floor(Math.random()*4)+3;\n  const nClauses = Math.floor(Math.random()*4)+2;\n  const chosen = vars.slice(0,nVars);\n  const lines = [];\n  for(let i=0;i<nClauses;i++){\n    const clause = [];\n    const used = new Set();\n    while(clause.length < 3){\n      const v = chosen[Math.floor(Math.random()*chosen.length)];\n      if(used.has(v)) continue;\n      used.add(v);\n      const neg = Math.random() < 0.4;\n      clause.push((neg ? '~' : '') + v);\n    }\n    lines.push(clause.join(' or '));\n  }\n  document.getElementById('formulaInput').value = lines.join('\\n');\n  document.getElementById('varsCount').textContent = `Vars: ${nVars}  Clauses: ${nClauses}`;\n});\n\n/* Reduction to clique: build graph */\nlet lastGraph = {nodes:[], edges:[], clauseCount:0};\nfunction buildGraphFromFormula(){\n  const text = document.getElementById('formulaInput').value;\n  const parsed = parseFormula(text);\n  const clauses = parsed.clauses;\n  const nodes = []; // {id, clauseIdx, lit: {var,neg}, label}\n  const edges = []; // {a,b}\n  // Node id = clauseIdx + '_' + litIdx\n  for(let i=0;i<clauses.length;i++){\n    const c = clauses[i];\n    for(let j=0;j<c.length;j++){\n      const lit = c[j];\n      nodes.push({id: `${i}_${j}`, clause:i, lit, label: `${lit.neg ? '~' : ''}${lit.var}`});\n    }\n  }\n  // edges between nodes from different clauses if not complementary\n  for(let a=0;a<nodes.length;a++){\n    for(let b=a+1;b<nodes.length;b++){\n      const na = nodes[a], nb = nodes[b];\n      if(na.clause === nb.clause) continue;\n      // complementary if same var and one negated and other not\n      if(na.lit.var === nb.lit.var && na.lit.neg !== nb.lit.neg) continue;\n      edges.push({a:na.id, b:nb.id});\n    }\n  }\n  lastGraph = {nodes, edges, clauseCount:clauses.length, clauses};\n  drawGraph();\n}\n\nfunction drawGraph(){\n  const svg = document.getElementById('graphSvg');\n  while(svg.firstChild) svg.removeChild(svg.firstChild);\n  const W = 600, H = 360;\n  svg.setAttribute('viewBox', `0 0 ${W} ${H}`);\n  const nodes = lastGraph.nodes;\n  const edges = lastGraph.edges;\n  const m = lastGraph.clauseCount;\n  document.getElementById('cliqueK').textContent = m || '-';\n  if(nodes.length===0){\n    const t = document.createElementNS('http://www.w3.org/2000/svg','text');\n    t.setAttribute('x',20); t.setAttribute('y',30); t.setAttribute('fill','#9fb7d9');\n    t.textContent = 'Graph empty — reduce a formula to build the graph.';\n    svg.appendChild(t);\n    return;\n  }\n\n  // layout: place nodes of each clause along circles\n  const clauses = lastGraph.clauses;\n  const clauseAngles = [];\n  const cx = W/2, cy = H/2;\n  const R = Math.min(W,H)/2 - 40;\n  const cCount = clauses.length || 1;\n  for(let i=0;i<cCount;i++){\n    const angle = i * (2*Math.PI / cCount);\n    const cx_i = cx + Math.cos(angle) * (R*0.45);\n    const cy_i = cy + Math.sin(angle) * (R*0.45);\n    clauseAngles.push({cx:cx_i, cy:cy_i});\n  }\n  // map node id to pos\n  const pos = {};\n  const nodesByClause = {};\n  for(const n of nodes){\n    nodesByClause[n.clause] = nodesByClause[n.clause] || [];\n    nodesByClause[n.clause].push(n);\n  }\n  for(const ci in nodesByClause){\n    const arr = nodesByClause[ci];\n    const center = clauseAngles[ci];\n    const r = 36;\n    for(let i=0;i<arr.length;i++){\n      const angle = Math.PI*2 * (i/arr.length);\n      const nx = center.cx + Math.cos(angle) * r;\n      const ny = center.cy + Math.sin(angle) * r;\n      pos[arr[i].id] = {x: nx, y: ny};\n    }\n  }\n  // draw edges first\n  for(const e of edges){\n    const p1 = pos[e.a], p2 = pos[e.b];\n    const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n    line.setAttribute('x1', p1.x); line.setAttribute('y1', p1.y);\n    line.setAttribute('x2', p2.x); line.setAttribute('y2', p2.y);\n    line.setAttribute('stroke', 'rgba(140,190,230,0.18)');\n    line.setAttribute('stroke-width', 1.6);\n    line.setAttribute('data-a', e.a); line.setAttribute('data-b', e.b);\n    svg.appendChild(line);\n  }\n  // draw nodes\n  for(const n of nodes){\n    const p = pos[n.id];\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('transform', `translate(${p.x},${p.y})`);\n    g.setAttribute('class','node');\n    g.setAttribute('data-id', n.id);\n    // circle\n    const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    circle.setAttribute('r', 18);\n    circle.setAttribute('fill', '#072233');\n    circle.setAttribute('stroke', 'rgba(99,179,237,0.12)');\n    circle.setAttribute('stroke-width', 1.6);\n    g.appendChild(circle);\n    // text\n    const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n    text.setAttribute('x', 0); text.setAttribute('y', 5);\n    text.setAttribute('fill', '#bfe7ff');\n    text.setAttribute('font-size', 11);\n    text.setAttribute('text-anchor','middle');\n    text.textContent = n.label;\n    g.appendChild(text);\n    // small clause badge\n    const badge = document.createElementNS('http://www.w3.org/2000/svg','text');\n    badge.setAttribute('x', 12); badge.setAttribute('y', 26);\n    badge.setAttribute('fill', '#8fb3d1'); badge.setAttribute('font-size',9);\n    badge.textContent = `c${n.clause}`;\n    g.appendChild(badge);\n\n    // interactions\n    g.addEventListener('mouseenter', ()=> {\n      circle.setAttribute('fill','#0b3b50');\n      circle.setAttribute('stroke','#6ed0ff');\n    });\n    g.addEventListener('mouseleave', ()=> {\n      if(!g.classList.contains('selected')){\n        circle.setAttribute('fill','#072233');\n        circle.setAttribute('stroke','rgba(99,179,237,0.12)');\n      }\n    });\n    g.addEventListener('click', ()=> {\n      g.classList.toggle('selected');\n      if(g.classList.contains('selected')){\n        circle.setAttribute('fill','#145e73');\n        circle.setAttribute('stroke','#7ff1ff');\n      } else {\n        circle.setAttribute('fill','#072233');\n        circle.setAttribute('stroke','rgba(99,179,237,0.12)');\n      }\n      // show label summary\n      document.getElementById('cliqueResult').innerHTML = `<div class=\"muted\">Clicked: <strong>${n.label}</strong> (clause ${n.clause})</div>`;\n    });\n\n    svg.appendChild(g);\n  }\n}\n\n/* Buttons */\ndocument.getElementById('reduceBtn').addEventListener('click', ()=>{\n  buildGraphFromFormula();\n});\n\ndocument.getElementById('clearGraphBtn').addEventListener('click', ()=>{\n  // clear selections\n  const svg = document.getElementById('graphSvg');\n  svg.querySelectorAll('.selected').forEach(n=>n.classList.remove('selected'));\n  svg.querySelectorAll('circle').forEach(c=>{ c.setAttribute('fill','#072233'); c.setAttribute('stroke','rgba(99,179,237,0.12)'); });\n  document.getElementById('cliqueResult').innerHTML = 'Cleared highlights.';\n});\n\n/* Find clique (brute force backtracking) */\ndocument.getElementById('findCliqueBtn').addEventListener('click', ()=>{\n  const g = lastGraph;\n  if(!g || !g.nodes || g.nodes.length===0){\n    document.getElementById('cliqueResult').innerHTML = '<span class=\"muted\">No graph to search. Reduce a formula first.</span>';\n    return;\n  }\n  const k = g.clauseCount;\n  const nodes = g.nodes;\n  const idToIdx = {};\n  nodes.forEach((n,i)=>idToIdx[n.id]=i);\n  // adjacency matrix\n  const n = nodes.length;\n  const adj = Array.from({length:n}, ()=>Array(n).fill(false));\n  for(const e of g.edges){\n    const a = idToIdx[e.a], b = idToIdx[e.b];\n    adj[a][b] = adj[b][a] = true;\n  }\n  // also nodes from same clause are not connected; but adj already lacks them.\n\n  // search for clique size k but respecting clause uniqueness: clique must pick one per clause\n  const clauseToNodes = {};\n  for(let i=0;i<n;i++){\n    clauseToNodes[nodes[i].clause] = clauseToNodes[nodes[i].clause] || [];\n    clauseToNodes[nodes[i].clause].push(i);\n  }\n  // simple backtracking by clauses: choose one node per clause, check pairwise adjacency\n  const clauseCount = g.clauseCount;\n  const clauseIndices = Array.from({length:clauseCount}, (_,i)=>i);\n  if(Object.keys(clauseToNodes).length !== clauseCount){\n    // some clause has 0 literals -> unsat trivially\n    document.getElementById('cliqueResult').innerHTML = '<span class=\"bad\">Graph malformed: at least one clause has no literal.</span>';\n    return;\n  }\n  let found = null;\n  const chosen = [];\n  function backtrack(ci){\n    if(found) return;\n    if(ci === clauseCount){\n      found = chosen.slice();\n      return;\n    }\n    const nodeList = clauseToNodes[ci];\n    for(const idx of nodeList){\n      let ok = true;\n      for(const cIdx of chosen){\n        if(!adj[idx][cIdx]) { ok = false; break; }\n      }\n      if(!ok) continue;\n      cho