    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Big-Theta Notation Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #plot {\n            margin-top: 20px;\n        }\n        canvas {\n            border: 1px solid #ddd;\n        }\n    </style>\n</head>\n<body>\n    <h1>Big-Theta Notation Demonstration</h1>\n    <p>Big-Theta notation (<code>Θ</code>) provides a tight bound on the growth rate of a function. Specifically, it describes both an upper and lower bound.</p>\n    <p>Let's visualize a function and show how to find Big-Theta by comparing it with linear and quadratic functions.</p>\n\n    <label for=\"input-n\">Enter a value for n: </label>\n    <input type=\"number\" id=\"input-n\" value=\"10\" min=\"1\" max=\"100\">\n    <button onclick=\"drawGraphs()\">Draw Graphs</button>\n\n    <div id=\"plot\">\n        <canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n    </div>\n\n    <script>\n        function drawGraphs() {\n            const n = parseInt(document.getElementById('input-n').value);\n            const canvas = document.getElementById('canvas');\n            const ctx = canvas.getContext('2d');\n            \n            // Clear the canvas\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            \n            const scale = 10; // Scale factors for drawing\n            const offsetX = 50;\n            const offsetY = 350;\n            const maxHeight = 300;\n\n            // Function f(n) = n\n            drawLine(ctx, n, (x) => x, 'blue', 'f(n) = n');\n            \n            // Function g(n) = n^2\n            drawLine(ctx, n, (x) => x * x, 'red', 'g(n) = n^2');\n            \n            // Big-Theta representation\n            drawTheta(ctx, n, (x) => x * x, 'green', 'Θ(n^2)');\n\n            // Draw Axes\n            drawAxes(ctx);\n        }\n\n        function drawLine(ctx, n, func, color, label) {\n            ctx.beginPath();\n            ctx.strokeStyle = color;\n            for (let x = 1; x <= n; x++) {\n                const y = func(x) / 10; // scale down for visibility\n                const canvasX = x * 20 + 50;\n                const canvasY = 350 - y;\n                ctx.lineTo(canvasX, canvasY);\n                ctx.fillText(`(${x}, ${Math.round(y)})`, canvasX, canvasY);\n            }\n            ctx.stroke();\n            ctx.fillStyle = color;\n            ctx.fillText(label, 20, n * 20 - 100);\n        }\n\n        function drawTheta(ctx, n, func, color, label) {\n            ctx.beginPath();\n            ctx.strokeStyle = color;\n            for (let x = 1; x <= n; x++) {\n                const y = func(x) / 15; // scale down for visibility\n                const canvasX = x * 20 + 50;\n                const canvasY = 350 - y;\n                ctx.lineTo(canvasX, canvasY);\n            }\n            ctx.stroke();\n            ctx.fillStyle = color;\n            ctx.fillText(label, 20, n * 20 - 100);\n        }\n\n        function drawAxes(ctx) {\n            ctx.beginPath();\n            ctx.moveTo(50, 350);\n            ctx.lineTo(50, 50);\n            ctx.lineTo(600, 50);\n            ctx.stroke();\n            ctx.fillText('n', 580, 370); // x-axis\n            ctx.fillText('f(n)', 10, 20); // y-axis\n        }\n\n    </script>\n</body>\n</html>"
