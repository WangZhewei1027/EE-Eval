    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Means Clustering Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n        }\n        canvas {\n            border: 1px solid black;\n            margin: 20px auto;\n            display: block;\n        }\n    </style>\n</head>\n<body>\n    <h1>K-Means Clustering Demo</h1>\n    <canvas id=\"canvas\" width=\"800\" height=\"600\"></canvas>\n    <br>\n    <button id=\"start\">Start Clustering</button>\n    \n    <script>\n        const canvas = document.getElementById('canvas');\n        const ctx = canvas.getContext('2d');\n        const numPoints = 100;\n        const numClusters = 3;\n        let points = [];\n        let centroids = [];\n        let assignments = [];\n        let iteration = 0;\n\n        // Generate random points\n        function generatePoints() {\n            points = [];\n            for (let i = 0; i < numPoints; i++) {\n                points.push({\n                    x: Math.random() * canvas.width,\n                    y: Math.random() * canvas.height\n                });\n            }\n        }\n\n        // Initialize centroids\n        function initializeCentroids() {\n            centroids = [];\n            for (let i = 0; i < numClusters; i++) {\n                centroids.push({\n                    x: Math.random() * canvas.width,\n                    y: Math.random() * canvas.height\n                });\n            }\n        }\n\n        // Assign points to the nearest centroid\n        function assignClusters() {\n            assignments = points.map(point => {\n                let closestCentroidIndex = 0;\n                let minDistance = Infinity;\n\n                centroids.forEach((centroid, index) => {\n                    const dist = Math.sqrt(Math.pow(point.x - centroid.x, 2) + Math.pow(point.y - centroid.y, 2));\n                    if (dist < minDistance) {\n                        closestCentroidIndex = index;\n                        minDistance = dist;\n                    }\n                });\n\n                return closestCentroidIndex;\n            });\n        }\n\n        // Update centroids based on the current assignments\n        function updateCentroids() {\n            const newCentroids = Array.from({ length: numClusters }, () => ({ x: 0, y: 0, count: 0 }));\n\n            points.forEach((point, index) => {\n                const clusterIndex = assignments[index];\n                newCentroids[clusterIndex].x += point.x;\n                newCentroids[clusterIndex].y += point.y;\n                newCentroids[clusterIndex].count++;\n            });\n\n            centroids = newCentroids.map(centroid => {\n                return {\n                    x: centroid.count > 0 ? centroid.x / centroid.count : Math.random() * canvas.width,\n                    y: centroid.count > 0 ? centroid.y / centroid.count : Math.random() * canvas.height\n                };\n            });\n        }\n\n        // Draw points and centroids\n        function draw() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            // Draw points\n            points.forEach((point, index) => {\n                ctx.fillStyle = `hsl(${(assignments[index] * 360) / numClusters}, 100%, 50%)`;\n                ctx.beginPath();\n                ctx.arc(point.x, point.y, 5, 0, Math.PI * 2);\n                ctx.fill();\n            });\n            // Draw centroids\n            centroids.forEach(centroid => {\n                ctx.fillStyle = 'black';\n                ctx.beginPath();\n                ctx.arc(centroid.x, centroid.y, 7, 0, Math.PI * 2);\n                ctx.fill();\n            });\n        }\n\n        // K-Means algorithm\n        function kMeans() {\n            assignClusters();\n            updateCentroids();\n            iteration++;\n            draw();\n            // Stop if no changes in assignments, or iterate 10 times as a max\n            if (iteration < 10) {\n                setTimeout(kMeans, 1000);\n            }\n        }\n\n        document.getElementById('start').onclick = () => {\n            generatePoints();\n            initializeCentroids();\n            iteration = 0;\n            kMeans();\n        };\n\n        // Initial draw\n        generatePoints();\n        initializeCentroids();\n        draw();\n    </script>\n</body>\n</html>"
