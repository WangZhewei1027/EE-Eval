  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>CPU Scheduling Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n            line-height: 1.6;\n        }\n        h1 {\n            color: #2c3e50;\n            text-align: center;\n        }\n        .controls {\n            background: #f5f5f5;\n            padding: 15px;\n            border-radius: 5px;\n            margin-bottom: 20px;\n        }\n        .process-input {\n            margin-bottom: 10px;\n        }\n        button {\n            background: #3498db;\n            color: white;\n            border: none;\n            padding: 8px 15px;\n            border-radius: 3px;\n            cursor: pointer;\n            margin-right: 10px;\n        }\n        button:hover {\n            background: #2980b9;\n        }\n        .gantt-chart {\n            margin-top: 30px;\n            overflow-x: auto;\n        }\n        .gantt-container {\n            display: flex;\n            margin-top: 10px;\n        }\n        .gantt-process {\n            height: 40px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: white;\n            font-weight: bold;\n            border: 1px solid #333;\n        }\n        .time-marker {\n            display: flex;\n            margin-top: 5px;\n        }\n        .time-unit {\n            width: 40px;\n            text-align: center;\n            font-size: 12px;\n        }\n        .stats {\n            margin-top: 20px;\n            background: #ecf0f1;\n            padding: 15px;\n            border-radius: 5px;\n        }\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 15px;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n    </style>\n</head>\n<body>\n    <h1>CPU Scheduling Algorithms Visualization</h1>\n    \n    <div class=\"controls\">\n        <h2>Process Input</h2>\n        <div id=\"process-inputs\">\n            <div class=\"process-input\">\n                Process 1:\n                <input type=\"number\" class=\"arrival-time\" placeholder=\"Arrival Time\" value=\"0\">\n                <input type=\"number\" class=\"burst-time\" placeholder=\"Burst Time\" value=\"5\">\n                <button onclick=\"removeProcess(this)\">Remove</button>\n            </div>\n            <div class=\"process-input\">\n                Process 2:\n                <input type=\"number\" class=\"arrival-time\" placeholder=\"Arrival Time\" value=\"1\">\n                <input type=\"number\" class=\"burst-time\" placeholder=\"Burst Time\" value=\"3\">\n                <button onclick=\"removeProcess(this)\">Remove</button>\n            </div>\n            <div class=\"process-input\">\n                Process 3:\n                <input type=\"number\" class=\"arrival-time\" placeholder=\"Arrival Time\" value=\"2\">\n                <input type=\"number\" class=\"burst-time\" placeholder=\"Burst Time\" value=\"8\">\n                <button onclick=\"removeProcess(this)\">Remove</button>\n            </div>\n            <div class=\"process-input\">\n                Process 4:\n                <input type=\"number\" class=\"arrival-time\" placeholder=\"Arrival Time\" value=\"3\">\n                <input type=\"number\" class=\"burst-time\" placeholder=\"Burst Time\" value=\"6\">\n                <button onclick=\"removeProcess(this)\">Remove</button>\n            </div>\n        </div>\n        <button onclick=\"addProcess()\">Add Process</button>\n        \n        <h2>Algorithm Selection</h2>\n        <select id=\"algorithm\">\n            <option value=\"fcfs\">First Come First Serve (FCFS)</option>\n            <option value=\"sjf\">Shortest Job First (SJF)</option>\n            <option value=\"srtf\">Shortest Remaining Time First (SRTF)</option>\n            <option value=\"rr\">Round Robin (RR)</option>\n            <option value=\"priority\">Priority Scheduling</option>\n        </select>\n        \n        <div id=\"quantum-container\" style=\"display: none;\">\n            Time Quantum: <input type=\"number\" id=\"quantum\" value=\"2\" min=\"1\">\n        </div>\n        \n        <button onclick=\"runScheduling()\">Run Scheduling</button>\n    </div>\n    \n    <div class=\"gantt-chart\">\n        <h2>Gantt Chart</h2>\n        <div id=\"gantt-container\" class=\"gantt-container\"></div>\n        <div id=\"time-markers\" class=\"time-marker\"></div>\n    </div>\n    \n    <div class=\"stats\">\n        <h2>Performance Metrics</h2>\n        <table id=\"process-table\">\n            <thead>\n                <tr>\n                    <th>Process</th>\n                    <th>Arrival Time</th>\n                    <th>Burst Time</th>\n                    <th>Completion Time</th>\n                    <th>Turnaround Time</th>\n                    <th>Waiting Time</th>\n                </tr>\n            </thead>\n            <tbody id=\"process-table-body\"></tbody>\n        </table>\n        <div id=\"avg-metrics\"></div>\n    </div>\n\n    <script>\n        // Process colors for visualization\n        const processColors = [\n            '#e74c3c', '#3498db', '#2ecc71', '#f39c12', \n            '#9b59b6', '#1abc9c', '#d35400', '#34495e'\n        ];\n        \n        // Setup algorithm selection change\n        document.getElementById('algorithm').addEventListener('change', function() {\n            const quantumContainer = document.getElementById('quantum-container');\n            if (this.value === 'rr') {\n                quantumContainer.style.display = 'block';\n            } else {\n                quantumContainer.style.display = 'none';\n            }\n        });\n        \n        // Add a new process input\n        function addProcess() {\n            const inputsContainer = document.getElementById('process-inputs');\n            const processCount = inputsContainer.children.length + 1;\n            \n            const newInput = document.createElement('div');\n            newInput.className = 'process-input';\n            newInput.innerHTML = `\n                Process ${processCount}:\n                <input type=\"number\" class=\"arrival-time\" placeholder=\"Arrival Time\" value=\"0\">\n                <input type=\"number\" class=\"burst-time\" placeholder=\"Burst Time\" value=\"1\">\n                <button onclick=\"removeProcess(this)\">Remove</button>\n            `;\n            \n            inputsContainer.appendChild(newInput);\n        }\n        \n        // Remove a process input\n        function removeProcess(button) {\n            const inputsContainer = document.getElementById('process-inputs');\n            if (inputsContainer.children.length > 1) {\n                button.parentNode.remove();\n                // Renumber remaining processes\n                const inputs = inputsContainer.querySelectorAll('.process-input');\n                inputs.forEach((input, index) => {\n                    input.firstChild.textContent = `Process ${index + 1}: `;\n                });\n            } else {\n                alert(\"You need at least one process!\");\n            }\n        }\n        \n        // Run the selected scheduling algorithm\n        function runScheduling() {\n            const processes = getProcesses();\n            const algorithm = document.getElementById('algorithm').value;\n            \n            // Clear previous results\n            document.getElementById('gantt-container').innerHTML = '';\n            document.getElementById('time-markers').innerHTML = '';\n            document.getElementById('process-table-body').innerHTML = '';\n            document.getElementById('avg-metrics').innerHTML = '';\n            \n            let result;\n            switch(algorithm) {\n                case 'fcfs':\n                    result = FCFS(processes);\n                    break;\n                case 'sjf':\n                    result = SJF(processes);\n                    break;\n                case 'srtf':\n                    result = SRTF(processes);\n                    break;\n                case 'rr':\n                    const quantum = parseInt(document.getElementById('quantum').value);\n                    result = roundRobin(processes, quantum);\n                    break;\n                case 'priority':\n                    // In a real implementation, you'd collect priority values\n                    alert(\"Priority scheduling would require priority inputs for each process\");\n                    return;\n                default:\n                    result = FCFS(processes);\n            }\n            \n            visualizeGanttChart(result.ganttChart);\n            displayProcessMetrics(result.processes);\n            displayAverageMetrics(result.processes);\n        }\n        \n        // Get processes from input fields\n        function getProcesses() {\n            const inputs = document.querySelectorAll('.process-input');\n            const processes = [];\n            \n            inputs.forEach((input, index) => {\n                const arrivalTime = parseInt(input.querySelector('.arrival-time').value) || 0;\n                const burstTime = parseInt(input.querySelector('.burst-time').value) || 1;\n                \n                processes.push({\n                    id: index + 1,\n                    arrivalTime: arrivalTime,\n                    burstTime: burstTime,\n                    remainingTime: burstTime,\n                    completionTime: 0,\n                    turnaroundTime: 0,\n                    waitingTime: 0\n                });\n            });\n            \n            return processes;\n        }\n        \n        // First Come First Serve algorithm\n        function FCFS(processes) {\n            // Sort by arrival time\n            const sortedProcesses = [...processes].sort((a, b) => a.arrivalTime - b.arrivalTime);\n            \n            let currentTime = 0;\n            const ganttChart = [];\n            \n            for (const process of sortedProcesses) {\n                if (currentTime < process.arrivalTime) {\n                    currentTime = process.arrivalTime;\n                }\n                \n                ganttChart.push({\n                    process: process.id,\n                    start: currentTime,\n                    end: currentTime + process.burstTime\n                });\n                \n                process.completionTime = currentTime + process.burstTime;\n                process.turnaroundTime = process.completionTime - process.arrivalTime;\n                process.waitingTime = process.turnaroundTime - process.burstTime;\n                \n                currentTime = process.completionTime;\n            }\n            \n            return { processes: sortedProcesses, ganttChart: ganttChart };\n        }\n        \n        // Shortest Job First (non-preemptive)\n        function SJF(processes) {\n            let currentTime = 0;\n            const completedProcesses = [];\n            const remainingProcesses = [...processes];\n            const ganttChart = [];\n            \n            while (remainingProcesses.length > 0) {\n                // Get arrived processes\n                const arrivedProcesses = remainingProcesses.filter(p => p.arrivalTime <= currentTime);\n                \n                if (arrivedProcesses.length === 0) {\n                    currentTime++;\n                    continue;\n                }\n                \n                // Sort by burst time\n                arrivedProcesses.sort((a, b) => a.burstTime - b.burstTime);\n                \n                const nextProcess = arrivedProcesses[0];\n                \n                ganttChart.push({\n                    process: nextProcess.id,\n                    start: currentTime,\n                    end: currentTime + nextProcess.burstTime\n                });\n                \n                nextProcess.completionTime = currentTime + nextProcess.burstTime;\n                nextProcess.turnaroundTime = nextProcess.completionTime - nextProcess.arrivalTime;\n                nextProcess.waitingTime = nextProcess.turnaroundTime - nextProcess.burstTime;\n                \n                currentTime = nextProcess.completionTime;\n                \n                // Remove from remaining processes\n                remainingProcesses.splice(remainingProcesses.findIndex(p => p.id === nextProcess.id), 1);\n                completedProcesses.push(nextProcess);\n            }\n            \n            // Sort by process ID for display\n            completedProcesses.sort((a, b) => a.id - b.id);\n            \n            return { processes: completedProcesses, ganttChart: ganttChart };\n        }\n        \n        // Shortest Remaining Time First (preemptive)\n        function SRTF(processes) {\n            let currentTime = 0;\n            const completedProcesses = [];\n            const remainingProcesses = [...processes].map(p => ({\n                ...p,\n                remainingTime: p.burstTime\n            }));\n            const ganttChart = [];\n            \n            while (remainingProcesses.length > 0) {\n                // Get arrived processes\n                const arrivedProcesses = remainingProcesses.filter(p => p.arrivalTime <= currentTime);\n                \n                if (arrivedProcesses.length === 0) {\n                    currentTime++;\n                    continue;\n                }\n                \n                // Sort by remaining time\n                arrivedProcesses.sort((a, b) => a.remainingTime - b.remainingTime);\n                \n                const nextProcess = arrivedProcesses[0];\n                \n                // Find next event time (arrival or completion)\n                let nextEventTime = currentTime + nextProcess.remainingTime;\n                for (const p of remainingProcesses) {\n                    if (p.id !== nextProcess.id && p.arrivalTime > currentTime && p.arrivalTime < nextEventTime) {\n                        nextEventTime = p.arrivalTime;\n                    }\n                }\n                \n                const executionTime = nextEventTime - currentTime;\n                \n                ganttChart.push({\n                    process: nextProcess.id,\n                    start: currentTime,\n                    end: currentTime + executionTime\n                });\n                \n                nextProcess.remainingTime -= executionTime;\n                currentTime += executionTime;\n                \n                if (nextProcess.remainingTime === 0) {\n                    nextProcess.completionTime = currentTime;\n                    nextProcess.turnaroundTime = nextProcess.completionTime - nextProcess.arrivalTime;\n                    nextProcess.waitingTime = nextProcess.turnaroundTime - nextProcess.burstTime;\n                    \n                    // Remove from remaining processes\n                    remainingProcesses.splice(remainingProcesses.findIndex(p => p.id === nextProcess.id), 1);\n                    completedProcesses.push(nextProcess);\n                }\n            }\n            \n            // Sort by process ID for display\n            completedProcesses.sort((a, b) => a.id - b.id);\n            \n            return { processes: completedProcesses, ganttChart: ganttChart };\n        }\n        \n        // Round Robin algorithm\n        function roundRobin(processes, quantum) {\n            let currentTime = 0;\n            const completedProcesses = [];\n            const remainingProcesses = [...processes].map(p => ({\n                ...p,\n                remainingTime: p.burstTime\n            }));\n            const ganttChart = [];\n            const queue = [];\n            \n            // Initial queue population\n            remainingProcesses\n                .filter(p => p.arrivalTime <= currentTime)\n                .sort((a, b) => a.arrivalTime - b.arrivalTime)\n                .forEach(p => queue.push(p));\n            \n            while (remainingProcesses.length > 0) {\n                if (queue.length === 0) {\n                    currentTime++;\n                    // Check for new arrivals\n                    remainingProcesses\n                        .filter(p => p.arrivalTime <= currentTime && !queue.includes(p))\n                        .sort((a, b) => a.arrivalTime - b.arrivalTime)\n                        .forEach(p => queue.push(p));\n                    continue;\n                }\n                \n                const currentProcess = queue.shift();\n                \n                const executionTime = Math.min(quantum, currentProcess.remainingTime);\n                \n                ganttChart.push({\n                    process: currentProcess.id,\n                    start: currentTime,\n                    end: currentTime + executionTime\n                });\n                \n                currentProcess.remainingTime -= executionTime;\n                currentTime += executionTime;\n                \n                // Check for new arrivals during this execution\n                remainingProcesses\n                    .filter(p => \n                        p.arrivalTime <= currentTime && \n                        !queue.includes(p) && \n                        p.id !== currentProcess.id\n                    )\n                    .sort((a, b) => a.arrivalTime - b.arrivalTime)\n                    .forEach(p => queue.push(p));\n                \n                if (currentProcess.remainingTime === 0) {\n                    currentProcess.completionTime = currentTime;\n                    currentProcess.turnaroundTime = currentProcess.completionTime - currentProcess.arrivalTime;\n                    currentProcess.waitingTime = currentProcess.turnaroundTime - currentProcess.burstTime;\n                    \n                    // Remove from remaining processes\n                    remainingProcesses.splice(remainingProcesses.findIndex(p => p.id === currentProcess.id), 1);\n                    completedProcesses.push(currentProcess);\n                } else {\n                    // Put back in queue\n                    queue.push(currentProcess);\n                }\n            }\n            \n            // Sort by process ID for display\n            completedProcesses.sort((a, b) => a.id - b.id);\n            \n            return { processes: completedProcesses, ganttChart: ganttChart };\n        }\n        \n        // Visualize the Gantt chart\n        function visualizeGanttChart(ganttChart) {\n            const container = document.getElementById('gantt-container');\n            const timeMarkers = document.getElementById('time-markers');\n            \n            if (ganttChart.length === 0) return;\n            \n            // Find max time for scaling\n            const maxTime = ganttChart[ganttChart.length - 1].end;\n            \n            // Create time markers\n            for (let i = 0; i <= maxTime; i++) {\n                const timeUnit = document.createElement('div');\n                timeUnit.className = 'time-unit';\n                timeUnit.textContent = i;\n                timeMarkers.appendChild(timeUnit);\n            }\n            \n            // Create Gantt chart bars\n            ganttChart.forEach((entry, index) => {\n                const width = ((entry.end - entry.start) / maxTime) * 100;\n                \n                const processBar = document.createElement('div');\n                processBar.className = 'gantt-process';\n                processBar.textContent = `P${entry.process}`;\n                processBar.style.width = `${width}%`;\n                processBar.style.backgroundColor = processColors[(entry.process - 1) % processColors.length];\n                \n                // Add tooltip\n                processBar.title = `P${entry.process}: ${entry.start}-${entry.end}`;\n                \n                container.appendChild(processBar);\n            });\n        }\n        \n        // Display process metrics in table\n        function displayProcessMetrics(processes) {\n            const tableBody = document.getElementById('process-table-body');\n            \n            processes.forEach(process => {\n                const row = document.createElement('tr');\n                \n                row.innerHTML = `\n                    <td>P${process.id}</td>\n                    <td>${process.arrivalTime}</td>\n                    <td>${process.burstTime}</td>\n                    <td>${process.completionTime}</td>\n                    <td>${process.turnaroundTime}</td>\n                    <td>${process.waitingTime}</td>\n                `;\n                \n                tableBody.appendChild(row);\n            });\n        }\n        \n        // Display average metrics\n        function displayAverageMetrics(processes) {\n            const totalTurnaround = processes.reduce((sum, p) => sum + p.turnaroundTime, 0);\n            const totalWaiting = processes.reduce((sum, p) => sum + p.waitingTime, 0);\n            \n            const avgTurnaround = (totalTurnaround / processes.length).toFixed(2);\n            const avgWaiting = (totalWaiting / processes.length).toFixed(2);\n            \n            const metricsDiv = document.getElementById('avg-metrics');\n            metricsDiv.innerHTML = `\n                <p><strong>Average Turnaround Time:</strong> ${avgTurnaround}</p>\n                <p><strong>Average Waiting Time:</strong> ${avgWaiting}</p>\n            `;\n        }\n    </script>\n</body>\n</html>"
  },
