  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Logistic Regression Visualization</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/numjs@0.16.0/dist/numjs.min.js\"></script>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        .container {\n            display: flex;\n            flex-direction: column;\n            gap: 20px;\n        }\n        .chart-container {\n            width: 100%;\n            height: 400px;\n        }\n        .controls {\n            display: flex;\n            gap: 10px;\n            flex-wrap: wrap;\n        }\n        button {\n            padding: 8px 16px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #45a049;\n        }\n        .explanation {\n            background-color: #f8f9fa;\n            padding: 15px;\n            border-radius: 5px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Logistic Regression Demonstration</h1>\n        \n        <div class=\"explanation\">\n            <p>Logistic regression is a statistical model that uses a logistic function to model a binary dependent variable.</p>\n            <p>The sigmoid function used in logistic regression: σ(z) = 1 / (1 + e<sup>-z</sup>)</p>\n            <p>This visualization shows how logistic regression separates two classes with a decision boundary.</p>\n        </div>\n\n        <div class=\"controls\">\n            <button id=\"generateData\">Generate New Data</button>\n            <button id=\"trainModel\">Train Model</button>\n            <div>\n                <label for=\"learningRate\">Learning Rate:</label>\n                <input type=\"range\" id=\"learningRate\" min=\"0.001\" max=\"0.1\" step=\"0.001\" value=\"0.01\">\n                <span id=\"lrValue\">0.01</span>\n            </div>\n            <div>\n                <label for=\"epochs\">Epochs:</label>\n                <input type=\"range\" id=\"epochs\" min=\"100\" max=\"5000\" step=\"100\" value=\"1000\">\n                <span id=\"epochsValue\">1000</span>\n            </div>\n        </div>\n\n        <div class=\"chart-container\">\n            <canvas id=\"scatterPlot\"></canvas>\n        </div>\n\n        <div class=\"chart-container\">\n            <canvas id=\"costChart\"></canvas>\n        </div>\n    </div>\n\n    <script>\n        // Initialize charts\n        const scatterCtx = document.getElementById('scatterPlot').getContext('2d');\n        const costCtx = document.getElementById('costChart').getContext('2d');\n        \n        let scatterChart, costChart;\n        let dataPoints = [];\n        let weights = [0, 0];\n        let bias = 0;\n        let costHistory = [];\n        \n        // Initialize charts\n        function initCharts() {\n            // Scatter plot\n            scatterChart = new Chart(scatterCtx, {\n                type: 'scatter',\n                data: {\n                    datasets: [\n                        {\n                            label: 'Class 0',\n                            data: [],\n                            backgroundColor: 'rgba(255, 99, 132, 0.8)',\n                            pointRadius: 6\n                        },\n                        {\n                            label: 'Class 1',\n                            data: [],\n                            backgroundColor: 'rgba(54, 162, 235, 0.8)',\n                            pointRadius: 6\n                        }\n                    ]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    scales: {\n                        x: {\n                            min: -10,\n                            max: 10,\n                            title: {\n                                display: true,\n                                text: 'Feature 1'\n                            }\n                        },\n                        y: {\n                            min: -10,\n                            max: 10,\n                            title: {\n                                display: true,\n                                text: 'Feature 2'\n                            }\n                        }\n                    },\n                    plugins: {\n                        legend: {\n                            position: 'top',\n                        },\n                        title: {\n                            display: true,\n                            text: 'Logistic Regression Decision Boundary'\n                        }\n                    }\n                }\n            });\n            \n            // Cost chart\n            costChart = new Chart(costCtx, {\n                type: 'line',\n                data: {\n                    labels: [],\n                    datasets: [{\n                        label: 'Cost (Log Loss)',\n                        data: [],\n                        borderColor: 'rgb(75, 192, 192)',\n                        tension: 0.1,\n                        fill: false\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    scales: {\n                        y: {\n                            beginAtZero: false,\n                            title: {\n                                display: true,\n                                text: 'Cost'\n                            }\n                        },\n                        x: {\n                            title: {\n                                display: true,\n                                text: 'Epoch'\n                            }\n                        }\n                    },\n                    plugins: {\n                        title: {\n                            display: true,\n                            text: 'Training Cost Over Time'\n                        }\n                    }\n                }\n            });\n        }\n        \n        // Sigmoid function\n        function sigmoid(z) {\n            return 1 / (1 + Math.exp(-z));\n        }\n        \n        // Generate random data\n        function generateData() {\n            dataPoints = [];\n            const class0Center = [-3, -3];\n            const class1Center = [3, 3];\n            const spread = 2;\n            \n            for (let i = 0; i < 100; i++) {\n                // Class 0 points\n                dataPoints.push({\n                    x: class0Center[0] + (Math.random() - 0.5) * spread * 2,\n                    y: class0Center[1] + (Math.random() - 0.5) * spread * 2,\n                    label: 0\n                });\n                \n                // Class 1 points\n                dataPoints.push({\n                    x: class1Center[0] + (Math.random() - 0.5) * spread * 2,\n                    y: class1Center[1] + (Math.random() - 0.5) * spread * 2,\n                    label: 1\n                });\n            }\n            \n            updateScatterPlot();\n            \n            // Reset model\n            weights = [0, 0];\n            bias = 0;\n            costHistory = [];\n            updateCostChart();\n            \n            // Remove decision boundary if it exists\n            if (scatterChart.data.datasets.length > 2) {\n                scatterChart.data.datasets = scatterChart.data.datasets.slice(0, 2);\n            }\n            scatterChart.update();\n        }\n        \n        // Update scatter plot with current data\n        function updateScatterPlot() {\n            const class0 = dataPoints.filter(p => p.label === 0);\n            const class1 = dataPoints.filter(p => p.label === 1);\n            \n            scatterChart.data.datasets[0].data = class0.map(p => ({x: p.x, y: p.y}));\n            scatterChart.data.datasets[1].data = class1.map(p => ({x: p.x, y: p.y}));\n            scatterChart.update();\n        }\n        \n        // Update cost chart\n        function updateCostChart() {\n            costChart.data.labels = Array.from({length: costHistory.length}, (_, i) => i + 1);\n            costChart.data.datasets[0].data = costHistory;\n            costChart.update();\n        }\n        \n        // Calculate cost (log loss)\n        function calculateCost() {\n            let totalCost = 0;\n            for (const point of dataPoints) {\n                const z = weights[0] * point.x + weights[1] * point.y + bias;\n                const prediction = sigmoid(z);\n                const y = point.label;\n                \n                // Avoid log(0) which is -Infinity\n                const term1 = y * Math.log(Math.max(prediction, 1e-15));\n                const term2 = (1 - y) * Math.log(Math.max(1 - prediction, 1e-15));\n                \n                totalCost += -(term1 + term2);\n            }\n            return totalCost / dataPoints.length;\n        }\n        \n        // Train logistic regression model\n        function trainModel() {\n            const learningRate = parseFloat(document.getElementById('learningRate').value);\n            const epochs = parseInt(document.getElementById('epochs').value);\n            \n            costHistory = [];\n            \n            for (let epoch = 0; epoch < epochs; epoch++) {\n                let dW1 = 0;\n                let dW2 = 0;\n                let dB = 0;\n                \n                // Calculate gradients\n                for (const point of dataPoints) {\n                    const z = weights[0] * point.x + weights[1] * point.y + bias;\n                    const prediction = sigmoid(z);\n                    const error = prediction - point.label;\n                    \n                    dW1 += error * point.x;\n                    dW2 += error * point.y;\n                    dB += error;\n                }\n                \n                // Update weights and bias\n                weights[0] -= (learningRate * dW1) / dataPoints.length;\n                weights[1] -= (learningRate * dW2) / dataPoints.length;\n                bias -= (learningRate * dB) / dataPoints.length;\n                \n                // Record cost\n                if (epoch % 10 === 0) {\n                    costHistory.push(calculateCost());\n                }\n            }\n            \n            updateCostChart();\n            drawDecisionBoundary();\n        }\n        \n        // Draw decision boundary\n        function drawDecisionBoundary() {\n            // Remove old boundary if it exists\n            if (scatterChart.data.datasets.length > 2) {\n                scatterChart.data.datasets = scatterChart.data.datasets.slice(0, 2);\n            }\n            \n            // Generate boundary points\n            const boundaryPoints = [];\n            for (let x = -10; x <= 10; x += 0.5) {\n                // Solve w1*x + w2*y + b = 0 => y = (-w1*x - b) / w2\n                const y = (-weights[0] * x - bias) / weights[1];\n                if (y >= -10 && y <= 10) {\n                    boundaryPoints.push({x: x, y: y});\n                }\n            }\n            \n            // Add boundary to chart\n            scatterChart.data.datasets.push({\n                label: 'Decision Boundary',\n                data: boundaryPoints,\n                type: 'line',\n                borderColor: 'rgba(75, 192, 192, 1)',\n                backgroundColor: 'rgba(75, 192, 192, 0.1)',\n                borderWidth: 2,\n                pointRadius: 0,\n                fill: false,\n                showLine: true\n            });\n            \n            scatterChart.update();\n        }\n        \n        // Event listeners\n        document.getElementById('generateData').addEventListener('click', generateData);\n        document.getElementById('trainModel').addEventListener('click', trainModel);\n        \n        document.getElementById('learningRate').addEventListener('input', function() {\n            document.getElementById('lrValue').textContent = this.value;\n        });\n        \n        document.getElementById('epochs').addEventListener('input', function() {\n            document.getElementById('epochsValue').textContent = this.value;\n        });\n        \n        // Initialize\n        window.onload = function() {\n            initCharts();\n            generateData();\n        };\n    </script>\n</body>\n</html>"
  },
