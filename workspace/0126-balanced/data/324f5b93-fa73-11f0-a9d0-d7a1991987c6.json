    "content": "<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Version Control Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            background-color: #f4f4f4;\n        }\n\n        h1 {\n            color: #333;\n        }\n\n        .version-display {\n            background: #fff;\n            border: 1px solid #ddd;\n            padding: 10px;\n            margin-bottom: 20px;\n            border-radius: 5px;\n        }\n\n        .button {\n            padding: 10px 15px;\n            background-color: #5cb85c;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            margin-right: 5px;\n        }\n\n        .button:hover {\n            background-color: #4cae4c;\n        }\n    </style>\n</head>\n\n<body>\n\n    <h1>Version Control Demonstration</h1>\n\n    <div class=\"version-display\">\n        <strong>Current Version:</strong> <span id=\"current-version\">1.0.0</span>\n    </div>\n\n    <button class=\"button\" id=\"increment-version\">Increment Version</button>\n    <button class=\"button\" id=\"reset-version\">Reset Version</button>\n\n    <script>\n        let version = \"1.0.0\";\n\n        function incrementVersion() {\n            const versionParts = version.split('.');\n            const patch = parseInt(versionParts[2]) + 1;\n            versionParts[2] = patch.toString();\n            version = versionParts.join('.');\n            document.getElementById(\"current-version\").textContent = version;\n        }\n\n        function resetVersion() {\n            version = \"1.0.0\";\n            document.getElementById(\"current-version\").textContent = version;\n        }\n\n        document.getElementById(\"increment-version\").addEventListener(\"click\", incrementVersion);\n        document.getElementById(\"reset-version\").addEventListener(\"click\", resetVersion);\n    </script>\n\n</body>\n\n</html>"
