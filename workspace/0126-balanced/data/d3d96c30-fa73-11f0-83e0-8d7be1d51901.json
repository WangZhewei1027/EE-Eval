  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Relational Database Demo (Single-file)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{font-family:system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial; color:#222}\n    body{margin:0; padding:16px; background:#f6f8fb;}\n    header{display:flex; align-items:center; gap:12px; margin-bottom:14px}\n    h1{font-size:18px; margin:0}\n    .container{display:flex; gap:12px}\n    .sidebar{width:260px; background:#fff; border:1px solid #e2e6ef; padding:12px; border-radius:8px; box-shadow:0 1px 3px rgba(20,30,60,0.04)}\n    .main{flex:1; display:flex; flex-direction:column; gap:12px}\n    .card{background:#fff; border:1px solid #e2e6ef; padding:12px; border-radius:8px; box-shadow:0 1px 3px rgba(20,30,60,0.04)}\n    .table-list{list-style:none; margin:0; padding:0}\n    .table-list li{padding:8px; border-radius:6px; cursor:pointer; display:flex; justify-content:space-between; align-items:center}\n    .table-list li:hover{background:#f0f4ff}\n    .table-list li.active{background:#eef2ff; font-weight:600}\n    .meta{font-size:12px; color:#666}\n    .rows{margin-top:8px; font-size:13px}\n    table{width:100%; border-collapse:collapse; margin-top:8px}\n    th,td{border-bottom:1px solid #eef0f5; padding:8px; text-align:left; font-size:13px}\n    th{background:#fafbfd; font-weight:600}\n    .small{font-size:12px; color:#666}\n    .form-row{display:flex; gap:8px; flex-wrap:wrap}\n    .form-row input, .form-row select{padding:6px 8px; border:1px solid #dfe6f0; border-radius:6px}\n    .btn{background:#2563eb; color:#fff; border:none; padding:8px 10px; border-radius:6px; cursor:pointer}\n    .btn.secondary{background:#6b7280}\n    .btn.danger{background:#ef4444}\n    .controls{display:flex; gap:8px; margin-top:8px}\n    .sql{background:#0f1724; color:#e6eef8; padding:10px; border-radius:6px; font-family:monospace; font-size:13px; overflow:auto}\n    .svg-wrap{position:relative; height:160px; background:linear-gradient(180deg,#fff,#fbfdff); border-radius:6px; overflow:visible}\n    #erCanvas{position:absolute; left:0; top:0; width:100%; height:100%}\n    .table-box{display:inline-block; background:#fff; border:1px solid #dbe7ff; padding:8px; border-radius:6px; margin:8px; min-width:160px}\n    .field{font-size:12px; color:#284; margin:2px 0}\n    .pk{font-weight:700; color:#0b3}\n    .fk{color:#0a58b4}\n    .note{font-size:12px; color:#475569}\n    footer{margin-top:12px; font-size:12px; color:#566; text-align:center}\n    .result{background:#fff; border:1px solid #eef2ff; padding:8px; border-radius:6px; max-height:220px; overflow:auto}\n    .warning{color:#a44; font-weight:600}\n    .success{color:#0a7; font-weight:600}\n  </style>\n</head>\n<body>\n  <header>\n    <img src=\"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='38' height='38' viewBox='0 0 24 24' fill='none' stroke='rgb(37,99,235)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M3 7h6v14H3z'/><path d='M15 3h6v18h-6z'/><path d='M9 3h6v18H9z'/></svg>\" alt=\"icon\" />\n    <div>\n      <h1>Relational Database Demo</h1>\n      <div class=\"small\">Client-side simulation of tables, primary/foreign keys, joins and referential integrity</div>\n    </div>\n  </header>\n\n  <div class=\"container\">\n    <aside class=\"sidebar card\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:10px\">\n        <strong>Tables</strong>\n        <span class=\"meta\">PK = primary key, FK = foreign key</span>\n      </div>\n      <ul class=\"table-list\" id=\"tableList\"></ul>\n\n      <div style=\"margin-top:12px\">\n        <div style=\"display:flex;gap:6px;align-items:center\">\n          <label class=\"small\">Delete mode:</label>\n          <select id=\"deleteMode\">\n            <option value=\"restrict\">Restrict (prevent delete if referenced)</option>\n            <option value=\"cascade\">Cascade (delete dependent rows)</option>\n          </select>\n        </div>\n        <div class=\"note\" style=\"margin-top:8px\">Try deleting customers or products and observe referential integrity.</div>\n      </div>\n    </aside>\n\n    <main class=\"main\">\n      <div class=\"card\" id=\"tableView\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div>\n            <strong id=\"tableTitle\">Select a table</strong>\n            <div id=\"tableInfo\" class=\"meta\"></div>\n          </div>\n          <div class=\"controls\">\n            <button class=\"btn secondary\" id=\"resetBtn\">Reset sample DB</button>\n            <button class=\"btn\" id=\"exportBtn\">Export JSON</button>\n          </div>\n        </div>\n\n        <div id=\"tableContent\" style=\"margin-top:10px\">\n          <div class=\"note\">Choose a table on the left to view or edit its rows. Primary keys are unique identifiers. Foreign keys reference other tables.</div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <strong>ER Diagram (visualizes relationships)</strong>\n        <div class=\"svg-wrap\" id=\"erWrap\" style=\"margin-top:8px\">\n          <svg id=\"erCanvas\" xmlns=\"http://www.w3.org/2000/svg\"></svg>\n        </div>\n        <div style=\"margin-top:8px\" class=\"small\">Lines show foreign key → primary key. Hover tables to highlight relations.</div>\n      </div>\n\n      <div class=\"card\">\n        <strong>Queries & Joins</strong>\n        <div style=\"display:flex;gap:8px;align-items:center;margin-top:8px\">\n          <label class=\"small\">Preset:</label>\n          <select id=\"presetQuery\">\n            <option value=\"\">-- choose example query --</option>\n            <option value=\"customers_orders_inner\">Customers INNER JOIN Orders</option>\n            <option value=\"customers_orders_left\">Customers LEFT JOIN Orders (include customers with no orders)</option>\n            <option value=\"order_details\">Order details: Orders → OrderItems → Products</option>\n            <option value=\"orders_with_total\">Orders with total amount (aggregate)</option>\n          </select>\n          <button class=\"btn\" id=\"runQuery\">Run</button>\n        </div>\n\n        <div style=\"margin-top:8px\">\n          <div class=\"sql\" id=\"sqlText\">-- Query output will appear here --</div>\n        </div>\n\n        <div style=\"margin-top:8px\">\n          <strong>Result:</strong>\n          <div class=\"result\" id=\"queryResult\">No results yet.</div>\n        </div>\n      </div>\n\n      <footer class=\"small\">This demo is purely client-side and educational. It demonstrates core relational concepts: tables, rows, primary keys, foreign keys, joins, and referential integrity.</footer>\n    </main>\n  </div>\n\n  <script>\n  // Relational Database Demo - single-file client-side simulation\n  // Data model: tables with schema (fields, pk, fks) and rows (array of objects).\n  (() => {\n    // Schema definition\n    let db = null;\n\n    function defaultDB() {\n      return {\n        tables: {\n          Customers: {\n            fields: [\n              {name: 'id', type: 'int', pk: true},\n              {name: 'name', type: 'string'},\n              {name: 'email', type: 'string'}\n            ],\n            rows: [\n              {id: 1, name: 'Alice', email: 'alice@example.com'},\n              {id: 2, name: 'Bob', email: 'bob@domain.com'},\n              {id: 3, name: 'Carmen', email: 'carmen@shop.com'}\n            ]\n          },\n          Products: {\n            fields: [\n              {name: 'id', type: 'int', pk: true},\n              {name: 'name', type: 'string'},\n              {name: 'price', type: 'number'}\n            ],\n            rows: [\n              {id: 1, name: 'Widget', price: 9.99},\n              {id: 2, name: 'Gadget', price: 19.5},\n              {id: 3, name: 'Doohickey', price: 4.75}\n            ]\n          },\n          Orders: {\n            fields: [\n              {name: 'id', type: 'int', pk: true},\n              {name: 'customer_id', type: 'int', fk: {table: 'Customers', field: 'id'}},\n              {name: 'date', type: 'string'}\n            ],\n            rows: [\n              {id: 101, customer_id: 1, date: '2024-12-01'},\n              {id: 102, customer_id: 1, date: '2025-01-10'},\n              {id: 103, customer_id: 2, date: '2025-01-15'}\n            ]\n          },\n          OrderItems: {\n            // join table representing many-to-many between Orders and Products\n            fields: [\n              {name: 'order_id', type: 'int', fk: {table: 'Orders', field: 'id'}},\n              {name: 'product_id', type: 'int', fk: {table: 'Products', field: 'id'}},\n              {name: 'quantity', type: 'int'}\n            ],\n            rows: [\n              {order_id: 101, product_id: 1, quantity: 3},\n              {order_id: 101, product_id: 3, quantity: 1},\n              {order_id: 102, product_id: 2, quantity: 2},\n              {order_id: 103, product_id: 1, quantity: 1},\n              {order_id: 103, product_id: 2, quantity: 1}\n            ]\n          }\n        }\n      };\n    }\n\n    // Utility functions to inspect schema\n    function getTableNames() { return Object.keys(db.tables); }\n    function getTable(name) { return db.tables[name]; }\n    function findPKField(table) {\n      return table.fields.find(f => f.pk) || null;\n    }\n    function isFK(field) { return !!field.fk; }\n\n    // Primary key value getter for a row (returns single PK value or composite as array if none)\n    function getPKValue(tableName, row) {\n      const table = getTable(tableName);\n      const pk = findPKField(table);\n      if (!pk) return null;\n      return row[pk.name];\n    }\n\n    // Referential integrity checks\n    function checkFKsOnInsert(tableName, row) {\n      const table = getTable(tableName);\n      for (const f of table.fields.filter(isFK)) {\n        const fk = f.fk;\n        const targetTable = getTable(fk.table);\n        const found = targetTable.rows.some(r => r[fk.field] === row[f.name]);\n        if (!found) {\n          return {ok:false, message:`FK violation: value ${row[f.name]} for ${tableName}.${f.name} does not reference existing ${fk.table}.${fk.field}`};\n        }\n      }\n      return {ok:true};\n    }\n\n    function findReferences(tableName, pkField, pkValue) {\n      // returns array of {table, row, field} referencing this pk\n      const refs = [];\n      for (const tn of getTableNames()) {\n        const t = getTable(tn);\n        for (const field of t.fields.filter(isFK)) {\n          if (field.fk.table === tableName && field.fk.field === pkField) {\n            for (const r of t.rows) {\n              if (r[field.name] === pkValue) refs.push({table: tn, row: r, field: field.name});\n            }\n          }\n        }\n      }\n      return refs;\n    }\n\n    // CRUD operations\n    function insertRow(tableName, row) {\n      const table = getTable(tableName);\n      const pkField = findPKField(table);\n      if (pkField) {\n        // enforce uniqueness\n        if (table.rows.some(r => r[pkField.name] === row[pkField.name])) {\n          return {ok:false, message:`PK violation: ${tableName}.${pkField.name}=${row[pkField.name]} already exists`};\n        }\n      }\n      // check FK constraints\n      const fkCheck = checkFKsOnInsert(tableName, row);\n      if (!fkCheck.ok) return fkCheck;\n      table.rows.push(row);\n      return {ok:true};\n    }\n\n    function deleteRow(tableName, pkValue, mode='restrict') {\n      const table = getTable(tableName);\n      const pkField = findPKField(table);\n      if (!pkField) return {ok:false, message:'No primary key on table; deletion by PK not supported in this demo'};\n\n      const idx = table.rows.findIndex(r => r[pkField.name] === pkValue);\n      if (idx === -1) return {ok:false, message:`Row not found in ${tableName} with ${pkField.name}=${pkValue}`};\n\n      const refs = findReferences(tableName, pkField.name, pkValue);\n      if (refs.length > 0 && mode === 'restrict') {\n        return {ok:false, message:`Cannot delete ${tableName}.${pkField.name}=${pkValue}: referenced by ${refs.length} row(s). Use cascade mode to delete dependents.`};\n      }\n      if (refs.length > 0 && mode === 'cascade') {\n        // delete referencing rows recursively\n        for (const ref of refs.slice()) {\n          const refTable = ref.table;\n          const refTableDef = getTable(refTable);\n          // if referenced row might be referenced further: call deleteRow on those\n          const refPk = findPKField(refTableDef);\n          if (refPk && ref.field === refPk.name) {\n            // referencing using PK of ref table (rare), delete by PK\n            deleteRow(refTable, ref.row[refPk.name], 'cascade');\n          } else {\n            // delete the specific row object from its table\n            const i = refTableDef.rows.indexOf(ref.row);\n            if (i !== -1) refTableDef.rows.splice(i,1);\n          }\n        }\n      }\n      // now delete the requested row\n      table.rows.splice(idx,1);\n      return {ok:true};\n    }\n\n    function updateRow(tableName, pkValue, updates) {\n      const table = getTable(tableName);\n      const pkField = findPKField(table);\n      const row = table.rows.find(r => r[pkField.name] === pkValue);\n      if (!row) return {ok:false, message:'Row not found'};\n      // create tentative row to validate fks if any changed\n      const newRow = Object.assign({}, row, updates);\n      const fkCheck = checkFKsOnInsert(tableName, newRow);\n      if (!fkCheck.ok) return fkCheck;\n      Object.assign(row, updates);\n      return {ok:true};\n    }\n\n    // UI elements\n    const tableListEl = document.getElementById('tableList');\n    const tableTitleEl = document.getElementById('tableTitle');\n    const tableInfoEl = document.getElementById('tableInfo');\n    const tableContentEl = document.getElementById('tableContent');\n    const erCanvas = document.getElementById('erCanvas');\n    const erWrap = document.getElementById('erWrap');\n    const presetQuery = document.getElementById('presetQuery');\n    const sqlText = document.getElementById('sqlText');\n    const queryResult = document.getElementById('queryResult');\n    const deleteModeSel = document.getElementById('deleteMode');\n    const resetBtn = document.getElementById('resetBtn');\n    const exportBtn = document.getElementById('exportBtn');\n    const runQueryBtn = document.getElementById('runQuery');\n\n    let selectedTable = null;\n\n    function renderTableList() {\n      tableListEl.innerHTML = '';\n      for (const name of getTableNames()) {\n        const li = document.createElement('li');\n        li.textContent = name;\n        const meta = document.createElement('span');\n        const t = getTable(name);\n        const pk = findPKField(t);\n        meta.textContent = pk ? `PK:${pk.name}` : '';\n        meta.className = 'meta';\n        li.appendChild(meta);\n        li.addEventListener('click', () => {\n          selectedTable = name;\n          renderTableView(name);\n          highlightActive();\n        });\n        li.addEventListener('mouseenter', () => drawERHighlight(name));\n        li.addEventListener('mouseleave', () => drawER());\n        tableListEl.appendChild(li);\n      }\n      highlightActive();\n    }\n\n    function highlightActive() {\n      [...tableListEl.children].forEach(li => {\n        li.classList.toggle('active', li.firstChild.textContent === selectedTable);\n      });\n    }\n\n    function renderTableView(name) {\n      const table = getTable(name);\n      tableTitleEl.textContent = name;\n      tableInfoEl.textContent = `Fields: ${table.fields.map(f => f.name + (f.pk? ' (PK)':'' ) + (f.fk? ` (FK→${f.fk.table}.${f.fk.field})` : '')).join(', ')}`;\n      // Build rows table\n      const pkField = findPKField(table);\n      const headers = table.fields.map(f => f.name);\n      let html = '';\n      html += '<div style=\"display:flex;gap:8px;align-items:center;flex-wrap:wrap\">';\n      html += `<div class=\"meta\">${table.rows.length} row(s)</div>`;\n      html += `<button class=\"btn secondary\" id=\"addRowBtn\">Insert new row</button>`;\n      if (pkField) {\n        html += `<button class=\"btn danger\" id=\"deleteSelectedBtn\">Delete selected PK</button>`;\n      }\n      html += '</div>';\n      html += '<table><thead><tr>';\n      html += '<th></th>';\n      for (const h of headers) html += `<th>${h}</th>`;\n      html += '</tr></thead><tbody>';\n      table.rows.forEach((r, i) => {\n        html += `<tr data-index=\"${i}\"><td><input type=\"radio\" name=\"rowSel\" value=\"${i}\"></td>`;\n        for (const f of table.fields) {\n          const val = r[f.name];\n          const cls = f.pk ? 'pk' : (f.fk ? 'fk' : '');\n          html += `<td class=\"${cls}\">${escapeHTML(String(val===undefined?'':val))}</td>`;\n        }\n        html += '</tr>';\n      });\n      html += '</tbody></table>';\n      // Add small form area for add/update\n      html += '<div style=\"margin-top:10px\"><div class=\"small\">Insert / Update Row</div>';\n      html += '<div class=\"form-row\" id=\"rowForm\"></div>';\n      html += '<div class=\"controls\" style=\"margin-top:8px\">';\n      html += '<button class=\"btn\" id=\"saveRowBtn\">Save (Insert)</button>';\n      html += '<button class=\"btn secondary\" id=\"updateRowBtn\">Update selected</button>';\n      html += '</div></div>';\n\n      tableContentEl.innerHTML = html;\n\n      document.getElementById('addRowBtn').addEventListener('click', () => {\n        // clear form inputs\n        for (const f of table.fields) {\n          const el = document.getElementById('input_' + f.name);\n          if (el) el.value = '';\n        }\n      });\n\n      // build row form fields\n      const rowForm = document.getElementById('rowForm');\n      rowForm.innerHTML = '';\n      for (const f of table.fields) {\n        const wrapper = document.createElement('div');\n        wrapper.style.minWidth = '140px';\n        const label = document.createElement('div');\n        label.className = 'small';\n        label.textContent = f.name + (f.pk?' (PK)':'') + (f.fk?` (FK→${f.fk.table}.${f.fk.field})`:'');\n        const input = document.createElement('input');\n        input.id = 'input_' + f.name;\n        input.placeholder = f.type;\n        if (f.type === 'int' || f.type === 'number') input.type = 'number';\n        wrapper.appendChild(label);\n        wrapper.appendChild(input);\n        rowForm.appendChild(wrapper);\n      }\n\n      document.getElementById('saveRowBtn').addEventListener('click', () => {\n        const newRow = {};\n        for (const f of table.fields) {\n          const val = document.getElementById('input_' + f.name).value;\n          newRow[f.name] = convertValue(val, f.type);\n        }\n        const res = insertRow(name, newRow);\n        if (!res.ok) alert('Insert failed: ' + res.message);\n        else {\n          renderTableView(name);\n          renderER();\n        }\n      });\n\n      document.getElementById('updateRowBtn').addEventListener('click', () => {\n        const sel = document.querySelector('input[name=\"rowSel\"]:checked');\n        if (!sel) { alert('Select a row to update'); return; }\n        const idx = Number(sel.value);\n        const row = table.rows[idx];\n        const pkField = findPKField(table);\n        if (!pkField) { alert('Update requires a primary key in this demo'); return; }\n        const pkVal = row[pkField.name];\n        const updates = {};\n        for (const f of table.fields) {\n          const val = document.getElementById('input_' + f.name).value;\n          if (val !== '') updates[f.name] = convertValue(val, f.type);\n        }\n        const res = updateRow(name, pkVal, updates);\n        if (!res.ok) alert('Update failed: ' + res.message);\n        else {\n          renderTableView(name);\n          renderER();\n        }\n      });\n\n      const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');\n      if (deleteSelectedBtn) {\n        deleteSelectedBtn.addEventListener('click', () => {\n          const sel = document.querySelector('input[name=\"rowSel\"]:checked');\n          if (!sel) { alert('Select a row to delete'); return; }\n          const idx = Number(sel.value);\n          const row = table.rows[idx];\n          const pkField = findPKField(table);\n          const pkVal = row[pkField.name];\n          const mode = deleteModeSel.value;\n          const res = deleteRow(name, pkVal, mode);\n          if (!res.ok) alert('Delete failed: ' + res.message);\n          else {\n            renderTableView(name);\n            renderER();\n          }\n        });\n      }\n    }\n\n    function escapeHTML(s) {\n      return s.replace(/[&<>'\"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;',\"'\":'&#39;','\"':'&quot;'}[c]));\n    }\n\n    function convertValue(val, type) {\n      if (val === '') return null;\n      if (type === 'int' || type === 'number') return Number(val);\n      return val;\n    }\n\n    // ER drawing functions\n    function renderER() {\n      const wrapRect = erWrap.getBoundingClientRect();\n      erCanvas.setAttribute('width', wrapRect.width);\n      erCanvas.setAttribute('height', wrapRect.height);\n      // simple layout: place boxes horizontally\n      const pad = 8;\n      const boxWidth = 180;\n      const boxHeight = 84;\n      const names = getTableNames();\n      const positions = {};\n      let x = pad;\n      let y = pad;\n      const boxHTML = [];\n      // We'll render boxes as foreign DOM elements for hover and then draw lines in SVG\n      erWrap.querySelectorAll('.table-box').forEach(n => n.remove());\n      for (const name of names) {\n        const box = document.createElement('div');\n        box.className = 'table-box';\n        box.style.left = x + 'px';\n        box.style.top = y + 'px';\n        box.style.position = 'absolute';\n        box.dataset.table = name;\n        box.innerHTML = `<div style=\"font-weight:700\">${name}</div>`;\n        const t = getTable(name);\n        for (const f of t.fields) {\n          const cls = f.pk ? 'pk' : (f.fk ? 'fk' : '');\n          const span = document.createElement('div');\n          span.className = 'field ' + cls;\n          span.textContent = f.name + (f.pk? ' (PK)':'') + (f.fk? ' (FK→' + f.fk.table + '.' + f.fk.field + ')':'');\n          box.appendChild(span);\n        }\n        erWrap.appendChild(box);\n        positions[name] = {x:x + 8, y:y + 18, w: boxWidth, h: boxHeight};\n        x += boxWidth + 24;\n        if (x + boxWidth > wrapRect.width - 40) { x = pad; y += boxHeight + 18; }\n        // hover highlighting\n        box.addEventListener('mouseenter', () => drawERHighlight(name));\n        box.addEventListener('mouseleave', () => drawER());\n      }\n\n      // draw lines for each FK\n      const svgNS = \"http://www.w3.org/2000/svg\";\n      while (erCanvas.firstChild) erCanvas.removeChild(erCanvas.firstChild);\n      for (const name of names) {\n        const t = getTable(name);\n        const posFrom = positions[name];\n        if (!posFrom) continue;\n        let fieldIndex = 0;\n        for (const f of t.fields) {\n          if (f.fk) {\n            const to = positions[f.fk.table];\n            if (!to) continue;\n            // compute simple points:\n            const fromX = posFrom.x + posFrom.w - 10;\n            const fromY = posFrom.y + 20 + fieldIndex * 14;\n            const toX = to.x + 10;\n            const toY = to.y + 20 + 0; // approximate\n            const path = document.createElementNS(svgNS, 'path');\n            const d = `M ${fromX} ${fromY} C ${fromX+30} ${fromY} ${toX-30} ${toY} ${toX} ${toY}`;\n            path.setAttribute('d', d);\n            path.setAttribute('stroke', '#8aa0ff');\n            path.setAttribute('fill', 'none');\n            path.setAttribute('stroke-width', '2');\n            path.setAttribute('opacity', '0.9');\n            erCanvas.appendChild(path);\n            // arrow\n            const arrow = document.createElementNS(svgNS, 'circle');\n            arrow.setAttribute('cx', toX);\n            arrow.setAttribute('cy', toY);\n            arrow.setAttribute('r', 3.5);\n            arrow.setAttribute('fill', '#1e40af');\n            erCanvas.appendChild(arrow);\n          }\n          fieldIndex++;\n        }\n      }\n    }\n\n    function drawER() { renderER(); }\n    function drawERHighlight(tableName) {\n      // draw ER and highlight relations (simpler: recolor SVG lines touching this table)\n      renderER();\n      // find which paths touch table by checking target names - for demo we recolor all lines (keeps simple)\n      const paths = erCanvas.querySelectorAll('path');\n      paths.forEach(p => p.setAttribute('stroke', '#4f46e5'));\n    }\n\n    // Query examples and join implementations\n    function runPreset(preset) {\n      sqlText.textContent = '';\n      queryResult.innerHTML = '';\n      if (!preset) return;\n      if (preset === 'customers_orders_inner') {\n        sqlText.textContent = `-- SQL:\nSELECT Customers.id, Customers.name, Orders.id AS order_id, Orders.date\nFROM Customers\nINNER JOIN Orders ON Customers.id = Orders.customer_id;`;\n        const out = [];\n        for (const c of getTable('Customers').rows) {\n          for (const o of getTable('Orders').rows) {\n            if (o.customer_id === c.id) {\n              out.push({customer_id: c.id, customer_name: c.name, order_id: o.id, date: o.date});\n            }\n          }\n        }\n        renderQueryResult(out);\n      } else if (preset === 'customers_orders_left') {\n        sqlText.textContent = `-- SQL:\nSELECT Customers.id, Customers.name, Orders.id AS order_id\nFROM Customers\nLEFT JOIN Orders ON Customers.id = Orders.customer_id;`;\n        const out = [];\n        for (const c of getTable('Customers').rows) {\n          let matched = false;\n          for (const o of getTable('Orders').rows) {\n            if (o.customer_id === c.id) {\n              matched = true;\n              out.push({customer_id: c.id, customer_name: c.name, order_id: o.id, date: o.date});\n            }\n          }\n          if (!matched) out.push({customer_id: c.id, customer_name: c.name, order_id: null, date: null});\n        }\n        renderQueryResult(out);\n      } else if (preset === 'order_details') {\n        sqlText.textContent = `-- SQL:\nSELECT Orders.id AS order_id, Customers.name AS customer, Products.name AS product, OrderItems.quantity\nFROM Orders\nJOIN Customers ON Orders.customer_id = Customers.id\nJOIN OrderItems ON Orders.id = OrderItems.order_id\nJOIN Products ON OrderItems.product_id = Products.id\nORDER BY Orders.id;`;\n        const out = [];\n        const orders = getTable('Orders').rows;\n        const customers = getTable('Customers').rows;\n        const items = getTable('OrderItems').rows;\n        const products = getTable('Products').rows;\n        for (const o of orders) {\n          const c = customers.find(x => x.id === o.customer_id);\n          for (const it of items.filter(x => x.order_id === o.id)) {\n            const p = products.find(x => x.id === it.product_id);\n            out.push({order_id: o.id, customer: c ? c.name : null, product: p ? p.name : null, quantity: it.quantity});\n          }\n        }\n        renderQueryResult(out);\n      } else if (preset === 'orders_with_total') {\n        sqlText.textContent = `-- SQL (aggregate):\nSELECT Orders.id AS order_id, Customers.name AS customer, SUM(Products.price * OrderItems.quantity) AS total\nFROM Orders\nJOIN Customers ON Orders.customer_id = Customers.id\nJOIN OrderItems ON Orders.id = OrderItems.order_id\nJOIN Products ON OrderItems.product_id = Products.id\nGROUP BY Orders.id, Customers.name;`;\n        const out = [];\n        const orders = getTable('Orders').rows;\n        const customers = getTable('Customers').rows;\n        const items = getTable('OrderItems').rows;\n        const products = getTable('Products').rows;\n        for (const o of orders) {\n          const itms = items.filter(x => x.order_id === o.id);\n          let sum = 0;\n          for (const it of itms) {\n            const p = products.find(x => x.id === it.product_id);\n            if (p) sum += p.price * it.quantity;\n          }\n          const c = customers.find(x => x.id === o.customer_id);\n          out.push({order_id: o.id, customer: c ? c.name : null, total: Number(sum.toFixed(2))});\n        }\n        renderQueryResult(out);\n      }\n    }\n\n    function renderQueryResult(rows) {\n      if (!rows || rows.length === 0) {\n        queryResult.innerHTML = '<div class=\"small\">No rows</div>';\n        return;\n      }\n      // build table\n      const keys = Object.keys(rows[0]);\n      let html = '<table><thead><tr>';\n      for (const k of keys) html += `<th>${escapeHTML(k)}</th>`;\n      html += '</tr></thead><tbody>';\n      for (const r of rows) {\n        html += '<tr>';\n        for (const k of keys) html += `<td>${escapeHTML(String(r[k]===null?'NULL':r[k]))}</td>`;\n        html += '</tr>';\n      }\n      html += '</tbody></table>';\n      queryResult.innerHTML = html;\n    }\n\n    // Export DB to JSON\n    function exportJSON() {\n      const out = JSON.stringify(db, null, 2);\n      const blob = new Blob([out], {type:'application/json'});\n      const url = URL.createObjectURL(blob);\n      const a = document.createElement('a');\n      a.href = url;\n      a.download = 'sample-db.json';\n      a.click();\n      URL.revokeObjectURL(url);\n    }\n\n    // Initialize\n    function init() {\n      db = defaultDB();\n      renderTableList();\n      renderER();\n      // select first table\n      const names = getTableNames();\n      if (names.length) {\n        selectedTable = names[0];\n        renderTableView(selectedTable);\n      }\n    }\n\n    // Wire up controls\n    resetBtn.addEventListener('click', () => {\n      if (!confirm('Reset database to sample state? This will discard all current changes.')) return;\n      db = defaultDB();\n      renderTableList();\n      renderTableView(selectedTable || getTableNames()[0]);\n      renderER();\n      sqlText.textContent = '-- Database reset to sample state';\n      queryResult.innerHTML = '';\n    });\n\n    exportBtn.addEventListener('click', exportJSON);\n    runQueryBtn.addEventListener('click', () => runPreset(presetQuery.value));\n    presetQuery.addEventListener('change', () => {\n      // preview SQL in box\n      const p = presetQuery.value;\n      if (!p) { sqlText.textContent = '-- Query output will appear here --'; queryResult.innerHTML=''; return; }\n      runPreset(p);\n    });\n\n    // Initialize on load\n    init();\n\n    // Expose small helpers in console for power users (optional)\n    window._rdb_demo = {\n      db,\n      insertRow: (t, r) => { const res = insertRow(t,r); renderTableList(); renderTableView(selectedTable); renderER(); return res; },\n      deleteRow: (t, pk) => { const res = deleteRow(t, pk, deleteModeSel.value); renderTableList(); renderTableView(selectedTable); renderER(); return res; },\n      updateRow: (t, pk, u) => { const res = updateRow(t, pk, u); renderTableList(); renderTableView(selectedTable); renderER(); return res; }\n    };\n\n    // small responsive adjustment\n    window.addEventListener('resize', () => {\n      renderER();\n    });\n\n  })();\n  </script>\n</body>\n</html>"
