    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Mutex (Mutual Exclusion) Demonstration</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 20px; color: #111; }\n    h1 { margin-top: 0; }\n    .controls { display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-bottom:12px; }\n    label { font-size: 0.9rem; }\n    input[type=\"number\"] { width:70px; padding:6px; }\n    button { padding:8px 12px; border-radius:6px; border:1px solid #ccc; background:#f7f7f7; cursor:pointer; }\n    button:hover { background:#eee; }\n    .panel { border:1px solid #ddd; border-radius:8px; padding:12px; margin-bottom:12px; background:#fafafa; }\n    .status { display:flex; gap:12px; align-items:center; margin-bottom:8px; }\n    .badge { padding:6px 10px; border-radius:999px; background:#222; color:#fff; font-weight:600; font-size:0.9rem; }\n    #log { height:280px; overflow:auto; background:#111; color:#0f0; padding:12px; border-radius:6px; font-family: monospace; font-size:12px; }\n    .task-list { display:flex; gap:8px; flex-wrap:wrap; margin-top:8px; }\n    .task { padding:6px 8px; border-radius:6px; background:#fff; border:1px solid #ccc; font-size:12px; min-width:80px; text-align:center; }\n    .task.running { background: #fffae6; border-color:#ffd95a; }\n    .task.locked { background: #e6f7ff; border-color:#7fd2ff; }\n    .task.done { background:#e6ffe6; border-color:#7fdc7f; }\n    .muted { color:#666; font-size:0.9rem; }\n    footer { margin-top:18px; color:#666; font-size:0.9rem; }\n  </style>\n</head>\n<body>\n  <h1>Mutex (Mutual Exclusion) Demo</h1>\n\n  <div class=\"panel\">\n    <div class=\"controls\">\n      <label>Number of tasks: <input id=\"numTasks\" type=\"number\" value=\"10\" min=\"1\" /></label>\n      <label>Min critical (ms): <input id=\"minDelay\" type=\"number\" value=\"20\" min=\"0\" /></label>\n      <label>Max critical (ms): <input id=\"maxDelay\" type=\"number\" value=\"120\" min=\"1\" /></label>\n      <button id=\"startNoMutex\">Start (No Mutex)</button>\n      <button id=\"startWithMutex\">Start (With Mutex)</button>\n      <button id=\"clearLog\">Clear / Reset</button>\n    </div>\n\n    <div class=\"status\">\n      <div>Shared counter: <span id=\"counterBadge\" class=\"badge\">0</span></div>\n      <div>Mutex locked: <span id=\"lockedBadge\" class=\"badge\" style=\"background:#888;\">false</span></div>\n      <div>Queue length: <span id=\"queueBadge\" class=\"badge\" style=\"background:#666;\">0</span></div>\n      <div class=\"muted\">(Tasks will read counter, sleep, then write back: shows lost updates when no mutex.)</div>\n    </div>\n\n    <div>\n      <strong>Task visualizer:</strong>\n      <div id=\"taskContainer\" class=\"task-list\"></div>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <strong>Event log:</strong>\n    <pre id=\"log\"></pre>\n  </div>\n\n  <footer>\n    This demo shows how a Mutex enforces exclusive access to a critical section so concurrent tasks don't corrupt shared state.\n  </footer>\n\n<script>\n/*\n  Mutex implementation (non-reentrant, FIFO fairness).\n  acquire() returns a Promise that resolves to a release() function.\n  release() must be called exactly once per acquire.\n*/\nclass Mutex {\n  constructor() {\n    this._locked = false;\n    this._waiters = [];\n  }\n\n  // Acquire the lock. Returns Promise<releaseFn>\n  acquire() {\n    return new Promise(resolve => {\n      if (!this._locked) {\n        this._locked = true;\n        resolve(this._createReleaser());\n      } else {\n        this._waiters.push(resolve);\n      }\n    });\n  }\n\n  // Try to acquire immediately. Returns releaseFn or null.\n  tryAcquire() {\n    if (!this._locked) {\n      this._locked = true;\n      return this._createReleaser();\n    }\n    return null;\n  }\n\n  // Internal: create a release function that moves to next waiter when called.\n  _createReleaser() {\n    let released = false;\n    return () => {\n      if (released) return; // protect against double-release\n      released = true;\n      if (this._waiters.length > 0) {\n        const nextResolve = this._waiters.shift();\n        // nextResolve expects a release function\n        nextResolve(this._createReleaser());\n      } else {\n        this._locked = false;\n      }\n    };\n  }\n\n  // Convenience helper to run an async function with the lock held.\n  async runExclusive(fn) {\n    const release = await this.acquire();\n    try {\n      return await fn();\n    } finally {\n      release();\n    }\n  }\n\n  isLocked() { return this._locked; }\n  queueLength() { return this._waiters.length; }\n}\n\n/* UI + Demo logic */\n\nconst logEl = document.getElementById('log');\nconst counterBadge = document.getElementById('counterBadge');\nconst lockedBadge = document.getElementById('lockedBadge');\nconst queueBadge = document.getElementById('queueBadge');\nconst taskContainer = document.getElementById('taskContainer');\nconst numTasksInput = document.getElementById('numTasks');\nconst minDelayInput = document.getElementById('minDelay');\nconst maxDelayInput = document.getElementById('maxDelay');\nconst startNoMutexBtn = document.getElementById('startNoMutex');\nconst startWithMutexBtn = document.getElementById('startWithMutex');\nconst clearLogBtn = document.getElementById('clearLog');\n\nlet sharedCounter = 0;\nlet taskIdCounter = 0;\nconst mutex = new Mutex();\n\nfunction now() {\n  return new Date().toLocaleTimeString();\n}\nfunction log(...args) {\n  const line = '[' + now() + '] ' + args.join(' ');\n  logEl.textContent += line + '\\n';\n  logEl.scrollTop = logEl.scrollHeight;\n}\n\nfunction updateBadges() {\n  counterBadge.textContent = String(sharedCounter);\n  lockedBadge.textContent = String(mutex.isLocked());\n  lockedBadge.style.background = mutex.isLocked() ? '#b33' : '#888';\n  queueBadge.textContent = String(mutex.queueLength());\n  queueBadge.style.background = mutex.queueLength() ? '#d68' : '#666';\n}\n\nfunction randInt(min, max) {\n  return Math.floor(Math.random() * (max - min + 1)) + min;\n}\n\nfunction sleep(ms) {\n  return new Promise(r => setTimeout(r, ms));\n}\n\nfunction createTaskElement(id) {\n  const el = document.createElement('div');\n  el.className = 'task';\n  el.id = 'task-' + id;\n  el.textContent = 'Task ' + id + '\\nidle';\n  return el;\n}\n\nfunction setTaskState(id, stateText, cssClass='') {\n  const el = document.getElementById('task-' + id);\n  if (!el) return;\n  el.textContent = 'Task ' + id + '\\n' + stateText;\n  el.className = 'task ' + cssClass;\n}\n\n/*\n  The \"critical section\" simulate:\n   - read value\n   - await sleep(random)\n   - write value + 1\n  Without mutex this produces lost updates because multiple tasks can read the same value before writes.\n  With mutex the critical section is sequentialized.\n*/\n\nasync function startTasks({count, useMutex}) {\n  const minDelay = Math.max(0, Number(minDelayInput.value) || 0);\n  const maxDelay = Math.max(minDelay, Number(maxDelayInput.value) || minDelay);\n  const startingCounter = sharedCounter;\n  const expectedFinal = startingCounter + count;\n  log(`Starting ${count} tasks ${useMutex ? 'with' : 'without'} mutex. Expected final=${expectedFinal}`);\n\n  const tasks = [];\n  for (let i=0; i<count; i++) {\n    const id = ++taskIdCounter;\n    const el = createTaskElement(id);\n    taskContainer.appendChild(el);\n    setTaskState(id, 'queued', '');\n\n    // Slightly stagger the task spawn so some tasks hit the queue\n    const spawnDelay = randInt(0, 40);\n    tasks.push((async () => {\n      await sleep(spawnDelay);\n      setTaskState(id, 'starting', 'running');\n\n      if (useMutex) {\n        log(`Task ${id} -> acquiring mutex`);\n        const release = await mutex.acquire();\n        updateBadges();\n        log(`Task ${id} -> acquired mutex`);\n        setTaskState(id, 'in critical', 'locked');\n\n        // critical section\n        const read = sharedCounter;\n        log(`Task ${id} read counter=${read}`);\n        await sleep(randInt(minDelay, maxDelay));\n        sharedCounter = read + 1;\n        log(`Task ${id} updated counter=${sharedCounter}`);\n\n        // release\n        release();\n        log(`Task ${id} -> released mutex`);\n        updateBadges();\n        setTaskState(id, 'done', 'done');\n      } else {\n        // No mutex: simulate critical section but nothing prevents interleaving.\n        setTaskState(id, 'in critical (no lock)', 'locked');\n        const read = sharedCounter;\n        log(`Task ${id} read counter=${read}`);\n        await sleep(randInt(minDelay, maxDelay));\n        sharedCounter = read + 1;\n        log(`Task ${id} updated counter=${sharedCounter}`);\n        setTaskState(id, 'done', 'done');\n        updateBadges();\n      }\n\n      return id;\n    })());\n  }\n\n  // Update badges while tasks are running\n  const monitor = setInterval(updateBadges, 50);\n  await Promise.all(tasks);\n  clearInterval(monitor);\n  updateBadges();\n  log(`All tasks finished. final counter=${sharedCounter} (expected ${expectedFinal}). Lost updates = ${expectedFinal - sharedCounter}`);\n}\n\nstartNoMutexBtn.addEventListener('click', async () => {\n  const count = Math.max(1, Number(numTasksInput.value) || 1);\n  startNoMutexBtn.disabled = startWithMutexBtn.disabled = true;\n  try {\n    await startTasks({count, useMutex:false});\n  } finally {\n    startNoMutexBtn.disabled = startWithMutexBtn.disabled = false;\n  }\n});\n\nstartWithMutexBtn.addEventListener('click', async () => {\n  const count = Math.max(1, Number(numTasksInput.value) || 1);\n  startNoMutexBtn.disabled = startWithMutexBtn.disabled = true;\n  try {\n    await startTasks({count, useMutex:true});\n  } finally {\n    startNoMutexBtn.disabled = startWithMutexBtn.disabled = false;\n  }\n});\n\nclearLogBtn.addEventListener('click', () => {\n  sharedCounter = 0;\n  logEl.textContent = '';\n  taskContainer.innerHTML = '';\n  updateBadges();\n  log('Reset counter and cleared tasks/log.');\n});\n\n// Initialize\nupdateBadges();\nlog('Mutex demo ready. Press \"Start (No Mutex)\" to observe race conditions, or \"Start (With Mutex)\" to enforce exclusive access.');\n\n/* Extra demonstration: show what happens if a task tries to re-enter the same mutex.\n   The implementation is non-reentrant: if a task that already holds the lock calls acquire() again,\n   it will deadlock (it will be queued behind itself). Uncomment below to see the effect.\n*/\n/*\n(async () => {\n  await sleep(2000);\n  log('Demonstrating reentrancy: acquiring mutex, then trying to acquire again (will block).');\n  const release = await mutex.acquire();\n  log('Acquired once. Now trying to acquire again (this will be queued and block).');\n  mutex.acquire().then(release2 => {\n    log('Acquired second time (unexpected).');\n    release2();\n  });\n  await sleep(1500);\n  log('Now releasing the first lock -> second acquisition will proceed (deadlock if same task was waiting).');\n  release();\n})();\n*/\n</script>\n</body>\n</html>"
  },
