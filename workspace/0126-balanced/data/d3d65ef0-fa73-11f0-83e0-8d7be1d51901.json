  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Quick Sort Visualization</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#00d1b2;\n      --muted:#94a3b8;\n      --bar:#38bdf8;\n      --pivot:#ffb020;\n      --compare:#f97316;\n      --swap:#ef4444;\n      --sorted:#34d399;\n      --text:#e6eef6;\n    }\n    html,body{height:100%;margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    body{background:linear-gradient(180deg,#071029 0%,#051226 100%);color:var(--text);display:flex;align-items:stretch;padding:18px;box-sizing:border-box;}\n    .container{display:grid;grid-template-columns:360px 1fr;gap:18px;width:100%;}\n    .panel{background:linear-gradient(180deg,var(--panel),#071225);border-radius:12px;padding:16px;box-sizing:border-box;box-shadow:0 6px 30px rgba(2,6,23,0.6);overflow:auto;}\n    h1{font-size:18px;margin:0 0 12px 0;color:var(--text);}\n    label{display:block;font-size:12px;color:var(--muted);margin-top:8px;}\n    .controls{display:flex;flex-direction:column;gap:8px;}\n    .row{display:flex;gap:8px;align-items:center;}\n    input[type=range]{width:100%;}\n    select,input[type=number]{background:#0b1624;border:1px solid rgba(255,255,255,0.04);color:var(--text);padding:6px;border-radius:6px;}\n    button{background:linear-gradient(180deg,#0ea5a4,#02867f);color:#042;border:none;padding:8px 10px;border-radius:8px;cursor:pointer;font-weight:600;}\n    button.secondary{background:transparent;border:1px solid rgba(255,255,255,0.06);color:var(--text);font-weight:600;padding:8px 10px;}\n    .controls-row{display:flex;gap:8px;}\n    .bars-wrap{height:60vh;background:linear-gradient(180deg,#021022,#031a28);border-radius:12px;padding:12px;box-sizing:border-box;display:flex;align-items:end;gap:2px;overflow:hidden;position:relative;}\n    .bar{flex:1 1 auto;background:var(--bar);height:10px;border-radius:6px;transition:height 120ms linear,background 120ms linear,transform 120ms linear;display:flex;align-items:end;justify-content:center;font-size:10px;color:#021;box-shadow:inset 0 -10px 30px rgba(0,0,0,0.3);}\n    .legend{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;color:var(--muted);font-size:13px;}\n    .legend span{display:inline-flex;gap:6px;align-items:center}\n    .dot{width:12px;height:12px;border-radius:3px;display:inline-block;}\n    .info{margin-top:12px;font-size:13px;color:var(--muted);display:flex;gap:12px;flex-wrap:wrap;}\n    .pseudocode{background:#031827;border-radius:8px;padding:10px;margin-top:12px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px;color:var(--muted);line-height:1.5;}\n    .code-line{padding:2px 6px;border-radius:6px;}\n    .code-line.active{background:rgba(2,6,23,0.7);color:var(--accent);font-weight:700;}\n    .stats{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}\n    .chip{background:rgba(255,255,255,0.03);padding:6px 8px;border-radius:8px;font-size:13px;color:var(--muted);}\n    .stack{margin-top:12px;color:var(--muted);font-size:13px;}\n    footer{margin-top:14px;color:var(--muted);font-size:12px;}\n    @media (max-width:900px){\n      .container{grid-template-columns:1fr;gap:12px;}\n      .panel{max-height:46vh;}\n      .bars-wrap{height:48vh;}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"panel\" id=\"controlsPanel\">\n      <h1>Quick Sort — Interactive Demo</h1>\n      <div class=\"controls\">\n        <label>Array Size: <span id=\"sizeLabel\">40</span></label>\n        <input id=\"size\" type=\"range\" min=\"6\" max=\"120\" value=\"40\">\n        <label>Pivot Strategy</label>\n        <select id=\"pivotStrategy\">\n          <option value=\"last\">Last element (Lomuto)</option>\n          <option value=\"first\">First element</option>\n          <option value=\"random\">Random</option>\n          <option value=\"median\">Median-of-three</option>\n        </select>\n        <label>Order</label>\n        <select id=\"order\">\n          <option value=\"asc\">Ascending</option>\n          <option value=\"desc\">Descending</option>\n        </select>\n\n        <div class=\"controls-row\">\n          <button id=\"generate\" class=\"secondary\">Generate</button>\n          <button id=\"start\">Start</button>\n          <button id=\"pause\" class=\"secondary\" disabled>Pause</button>\n          <button id=\"step\" class=\"secondary\">Step</button>\n          <button id=\"reset\" class=\"secondary\">Reset</button>\n        </div>\n\n        <label>Speed (ms per action): <span id=\"speedLabel\">60</span>ms</label>\n        <input id=\"speed\" type=\"range\" min=\"10\" max=\"800\" value=\"60\">\n\n        <div class=\"legend\">\n          <span><i class=\"dot\" style=\"background:var(--bar)\"></i> Default</span>\n          <span><i class=\"dot\" style=\"background:var(--pivot)\"></i> Pivot</span>\n          <span><i class=\"dot\" style=\"background:var(--compare)\"></i> Comparing</span>\n          <span><i class=\"dot\" style=\"background:var(--swap)\"></i> Swapping</span>\n          <span><i class=\"dot\" style=\"background:var(--sorted)\"></i> Sorted/Fixed</span>\n        </div>\n\n        <div class=\"info\">\n          <div class=\"chip\">Comparisons: <span id=\"compCount\">0</span></div>\n          <div class=\"chip\">Swaps: <span id=\"swapCount\">0</span></div>\n          <div class=\"chip\">Actions: <span id=\"actionCount\">0</span></div>\n          <div class=\"chip\">Recursion Depth: <span id=\"recDepth\">0</span></div>\n        </div>\n\n        <div class=\"stack\">\n          Recursion Stack: <span id=\"stackView\">[]</span>\n        </div>\n\n        <div class=\"pseudocode\" id=\"pseudocode\">\n          <!-- Pseudocode lines will be injected -->\n        </div>\n\n        <footer>\n          This demo uses Lomuto-style partition by default. You can step, auto-play, choose different pivot strategies and observe how the algorithm progresses.\n        </footer>\n      </div>\n    </div>\n\n    <div class=\"panel\" id=\"visualPanel\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n        <div style=\"font-weight:700\">Array Visualization</div>\n        <div style=\"font-size:13px;color:var(--muted)\">Hover bars to see value</div>\n      </div>\n      <div id=\"bars\" class=\"bars-wrap\" title=\"Array bars\"></div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // Utilities\n  const $ = id => document.getElementById(id);\n  const randInt = (a,b) => Math.floor(Math.random()*(b-a+1))+a;\n  // Elements\n  const barsWrap = $('bars');\n  const sizeEl = $('size');\n  const sizeLabel = $('sizeLabel');\n  const generateBtn = $('generate');\n  const startBtn = $('start');\n  const pauseBtn = $('pause');\n  const stepBtn = $('step');\n  const resetBtn = $('reset');\n  const speedEl = $('speed');\n  const speedLabel = $('speedLabel');\n  const pivotSelect = $('pivotStrategy');\n  const orderSelect = $('order');\n  const compCountEl = $('compCount');\n  const swapCountEl = $('swapCount');\n  const actionCountEl = $('actionCount');\n  const recDepthEl = $('recDepth');\n  const stackView = $('stackView');\n  const pseudoEl = $('pseudocode');\n\n  let array = [];\n  let bars = [];\n  let maxVal = 100;\n  let running = false;\n  let paused = false;\n  let autoTimer = null;\n  let gen = null;\n  let actionDelay = +speedEl.value;\n  let comparisonCount = 0;\n  let swapCount = 0;\n  let actionCount = 0;\n  let currentStack = [];\n  let currentActive = {compare:[], pivot:-1, swap:[] , sorted: new Set()};\n\n  // Pseudocode for Lomuto QuickSort (annotated)\n  const pseudocodeLines = [\n    \"function quicksort(A, low, high):\",\n    \"  if low < high:\",\n    \"    pivotIndex := choosePivot(A, low, high)\",\n    \"    swap(A[pivotIndex], A[high])  // move pivot to end\",\n    \"    p := partition(A, low, high)\",\n    \"    quicksort(A, low, p-1)\",\n    \"    quicksort(A, p+1, high)\",\n    \"\",\n    \"function partition(A, low, high):\",\n    \"  pivot := A[high]\",\n    \"  i := low\",\n    \"  for j from low to high-1:\",\n    \"    if A[j] <= pivot:\",\n    \"      swap(A[i], A[j])\",\n    \"      i := i + 1\",\n    \"  swap(A[i], A[high])\",\n    \"  return i\"\n  ];\n\n  // Render pseudocode\n  function renderPseudocode(){}\n  (function initPseudocode(){\n    pseudoEl.innerHTML = '';\n    pseudocodeLines.forEach((ln, idx)=>{\n      const div = document.createElement('div');\n      div.className = 'code-line';\n      div.dataset.line = idx;\n      div.textContent = ln;\n      pseudoEl.appendChild(div);\n    });\n  })();\n\n  function highlightPseudocode(lineIdx){\n    const lines = pseudoEl.querySelectorAll('.code-line');\n    lines.forEach(l => l.classList.toggle('active', +l.dataset.line === lineIdx));\n  }\n\n  // Initialize\n  function generateArray(n){\n    array = [];\n    maxVal = Math.max(50, n*2);\n    for(let i=0;i<n;i++){ array.push(randInt(10,maxVal)); }\n    renderBars();\n    resetStats();\n  }\n\n  function renderBars(){\n    barsWrap.innerHTML = '';\n    bars = [];\n    const n = array.length;\n    for(let i=0;i<n;i++){\n      const b = document.createElement('div');\n      b.className = 'bar';\n      b.style.height = (array[i]/maxVal*100) + '%';\n      b.title = String(array[i]);\n      barsWrap.appendChild(b);\n      bars.push(b);\n    }\n    updateBarColors();\n  }\n\n  function updateBarColors(){\n    for(let i=0;i<bars.length;i++){\n      const b = bars[i];\n      b.style.background = 'var(--bar)';\n      b.style.transform = 'translateY(0)';\n      if(currentActive.sorted.has(i)) b.style.background = 'var(--sorted)';\n      else if(i === currentActive.pivot) b.style.background = 'var(--pivot)';\n      else if(currentActive.swap.includes(i)) b.style.background = 'var(--swap)';\n      else if(currentActive.compare.includes(i)) b.style.background = 'var(--compare)';\n      else b.style.background = 'var(--bar)';\n      b.title = array[i];\n    }\n  }\n\n  function resetStats(){\n    comparisonCount = 0;\n    swapCount = 0;\n    actionCount = 0;\n    currentStack = [];\n    currentActive = {compare:[], pivot:-1, swap:[], sorted:new Set()};\n    updateStats();\n    highlightPseudocode(-1);\n    updateBarColors();\n  }\n\n  function updateStats(){\n    compCountEl.textContent = comparisonCount;\n    swapCountEl.textContent = swapCount;\n    actionCountEl.textContent = actionCount;\n    recDepthEl.textContent = currentStack.length;\n    stackView.textContent = JSON.stringify(currentStack);\n  }\n\n  // Action generator: yields actions describing algorithm steps.\n  // Action types: {type:'pushRange'|'popRange'|'setPivot'|'compare'|'swap'|'markSorted'|'finish', payload:...}\n  function* quickSortGen(A, low, high, pivotStrategy, order='asc'){\n    // push current range\n    yield {type:'pushRange', range:[low,high]};\n    if(low < high){\n      // choose pivot\n      let pivotIndex;\n      if(pivotStrategy === 'last') pivotIndex = high;\n      else if(pivotStrategy === 'first') pivotIndex = low;\n      else if(pivotStrategy === 'random') pivotIndex = randInt(low,high);\n      else if(pivotStrategy === 'median'){\n        const mid = Math.floor((low+high)/2);\n        const trio = [[A[low],low],[A[mid],mid],[A[high],high]];\n        trio.sort((a,b)=>a[0]-b[0]);\n        pivotIndex = trio[1][1];\n      } else pivotIndex = high;\n      yield {type:'setPivot', index:pivotIndex, line:3};\n      // swap pivot to end\n      if(pivotIndex !== high){\n        yield {type:'swap', i:pivotIndex, j:high, line:3};\n        [A[pivotIndex], A[high]] = [A[high], A[pivotIndex]];\n      }\n      // partition\n      const p = yield* partitionGen(A, low, high, order);\n      // mark pivot fixed\n      yield {type:'markSorted', index:p, line:15};\n      // quicksort left\n      yield* quickSortGen(A, low, p-1, pivotStrategy, order);\n      // quicksort right\n      yield* quickSortGen(A, p+1, high, pivotStrategy, order);\n    } else {\n      // length <=1, mark as sorted if valid index\n      if(low>=0 && high>=0 && low===high){\n        yield {type:'markSorted', index:low, line:15};\n      }\n    }\n    yield {type:'popRange', range:[low,high]};\n    if(low===0 && high===A.length-1) yield {type:'finish'};\n  }\n\n  function* partitionGen(A, low, high, order='asc'){\n    yield {type:'pseudoline', line:8};\n    const pivot = A[high];\n    yield {type:'setPivot', index:high, line:9};\n    let i = low;\n    yield {type:'pseudoline', line:10};\n    for(let j=low;j<=high-1;j++){\n      // compare A[j] and pivot\n      yield {type:'compare', i:j, j:high, line:11};\n      const cond = (order==='asc') ? (A[j] <= pivot) : (A[j] >= pivot);\n      if(cond){\n        yield {type:'swap', i:i, j:j, line:12};\n        [A[i], A[j]] = [A[j], A[i]];\n        i++;\n      }\n    }\n    // place pivot to its correct position\n    yield {type:'swap', i:i, j:high, line:14};\n    [A[i], A[high]] = [A[high], A[i]];\n    return i;\n  }\n\n  // Driving execution\n  function startAuto(){\n    if(!gen) return;\n    running = true;\n    paused = false;\n    startBtn.disabled = true;\n    pauseBtn.disabled = false;\n    stepBtn.disabled = true;\n    generateBtn.disabled = true;\n    resetBtn.disabled = false;\n    scheduleNext();\n  }\n\n  function scheduleNext(){\n    if(autoTimer) clearTimeout(autoTimer);\n    autoTimer = setTimeout(stepAction, actionDelay);\n  }\n\n  function stepAction(){\n    if(paused) return;\n    const next = gen.next();\n    if(next.done){\n      finalizeRun();\n      return;\n    }\n    processAction(next.value);\n    if(running && !paused) scheduleNext();\n  }\n\n  function processAction(action){\n    actionCount++;\n    actionCountEl.textContent = actionCount;\n    switch(action.type){\n      case 'pushRange':\n        currentStack.push(action.range);\n        updateStats();\n        break;\n      case 'popRange':\n        // remove only one matching range from stack (from top)\n        currentStack.pop();\n        updateStats();\n        break;\n      case 'setPivot':\n        currentActive.pivot = action.index;\n        highlightPseudocode(action.line ?? 3);\n        updateBarColors();\n        break;\n      case 'compare':\n        comparisonCount++;\n        compCountEl.textContent = comparisonCount;\n        currentActive.compare = [action.i, action.j];\n        highlightPseudocode(action.line ?? 11);\n        updateBarColors();\n        break;\n      case 'swap':\n        swapCount++;\n        swapCountEl.textContent = swapCount;\n        currentActive.swap = [action.i, action.j];\n        highlightPseudocode(action.line ?? 12);\n        // animate swap visually by swapping heights & values\n        animateSwap(action.i, action.j);\n        break;\n      case 'markSorted':\n        currentActive.sorted.add(action.index);\n        highlightPseudocode(action.line ?? 15);\n        updateBarColors();\n        break;\n      case 'pseudoline':\n        highlightPseudocode(action.line);\n        break;\n      case 'finish':\n        finalizeRun();\n        break;\n      default:\n        break;\n    }\n    // subtle reset of transient states after a small delay to let color show (unless auto-play speed is slow)\n    setTimeout(()=>{ currentActive.compare=[]; currentActive.swap=[]; updateBarColors(); }, Math.max(120, actionDelay*0.6));\n    updateStats();\n  }\n\n  function animateSwap(i,j){\n    if(!bars[i] || !bars[j]) return;\n    const bi = bars[i], bj = bars[j];\n    // swap heights and titles\n    const h1 = bi.style.height, h2 = bj.style.height;\n    bi.style.transform = 'translateY(-6px)';\n    bj.style.transform = 'translateY(-6px)';\n    setTimeout(()=>{\n      bi.style.height = h2;\n      bj.style.height = h1;\n      bi.title = bj.title;\n      bj.title = bi.title;\n      // swap DOM inner positions for accessibility (but keep bars array indices consistent)\n      // We'll just swap array values to keep consistent\n      const tmp = array[i]; array[i]=array[j]; array[j]=tmp;\n      bi.style.transform = 'translateY(0)';\n      bj.style.transform = 'translateY(0)';\n    }, Math.min(180, actionDelay));\n  }\n\n  function finalizeRun(){\n    running = false;\n    paused = false;\n    if(autoTimer) clearTimeout(autoTimer);\n    // mark all sorted\n    for(let i=0;i<array.length;i++) currentActive.sorted.add(i);\n    updateBarColors();\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = true;\n    generateBtn.disabled = false;\n    resetBtn.disabled = false;\n    highlightPseudocode(-1);\n  }\n\n  // Controls\n  sizeEl.addEventListener('input', ()=>{ sizeLabel.textContent = sizeEl.value; });\n  speedEl.addEventListener('input', ()=>{ actionDelay = +speedEl.value; speedLabel.textContent = actionDelay; });\n  generateBtn.addEventListener('click', ()=>{\n    generateArray(+sizeEl.value);\n    startBtn.disabled = false;\n    stepBtn.disabled = false;\n    pauseBtn.disabled = true;\n    resetBtn.disabled = false;\n  });\n\n  startBtn.addEventListener('click', ()=>{\n    if(running && !paused){\n      // already running\n      return;\n    }\n    if(!gen || genDone){\n      // (re)create generator on first start or after reset\n      gen = quickSortGen(array.slice(0), 0, array.length-1, pivotSelect.value, orderSelect.value);\n      // we will work on a working array copy but update live bars as swaps occur by modifying global array:\n      // To sync, set generator to operate on global array directly by creating anew with reference.\n      gen = quickSortGen(array, 0, array.length-1, pivotSelect.value, orderSelect.value);\n    }\n    running = true;\n    paused = false;\n    startBtn.disabled = true;\n    pauseBtn.disabled = false;\n    stepBtn.disabled = true;\n    generateBtn.disabled = true;\n    scheduleNext();\n  });\n\n  pauseBtn.addEventListener('click', ()=>{\n    paused = !paused;\n    pauseBtn.textContent = paused ? 'Resume' : 'Pause';\n    if(!paused){\n      scheduleNext();\n    } else {\n      if(autoTimer) clearTimeout(autoTimer);\n    }\n  });\n\n  let genDone = false;\n  stepBtn.addEventListener('click', ()=>{\n    // single step\n    if(!gen){\n      gen = quickSortGen(array, 0, array.length-1, pivotSelect.value, orderSelect.value);\n    }\n    paused = true;\n    running = false;\n    const next = gen.next();\n    if(next.done){\n      genDone = true;\n      finalizeRun();\n      return;\n    }\n    processAction(next.value);\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n    generateBtn.disabled = false;\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    if(autoTimer) clearTimeout(autoTimer);\n    running = false; paused = false;\n    gen = null; genDone = false;\n    // keep current array as generated but not sorted; just re-render initial values\n    // We'll regenerate to a new array with same elements in original order: just re-render bars from array.\n    currentActive = {compare:[], pivot:-1, swap:[], sorted:new Set()};\n    updateBarColors();\n    resetStats();\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n    generateBtn.disabled = false;\n  });\n\n  // initialize defaults\n  sizeLabel.textContent = sizeEl.value;\n  speedLabel.textContent = speedEl.value;\n\n  // initial generate\n  generateArray(+sizeEl.value);\n\n  // Extra: show values on hover by title; clicking a bar toggles mark\n  barsWrap.addEventListener('mouseover', (e)=>{\n    if(e.target.classList.contains('bar')){\n      e.target.style.filter = 'brightness(1.06)';\n    }\n  });\n  barsWrap.addEventListener('mouseout', (e)=>{\n    if(e.target.classList.contains('bar')){\n      e.target.style.filter = '';\n    }\n  });\n\n  // Allow clicking a bar to pin it as pivot for demonstration (not used by algorithm, just visual)\n  barsWrap.addEventListener('click', (e)=>{\n    if(e.target.classList.contains('bar')){\n      const idx = Array.from(barsWrap.children).indexOf(e.target);\n      // toggle sorted highlight\n      if(currentActive.sorted.has(idx)) currentActive.sorted.delete(idx);\n      else currentActive.sorted.add(idx);\n      updateBarColors();\n    }\n  });\n\n  // Keyboard shortcuts\n  window.addEventListener('keydown', (e)=>{\n    if(e.key === ' ') { e.preventDefault(); if(startBtn.disabled) stepBtn.click(); else startBtn.click(); }\n    if(e.key === 'p') pauseBtn.click();\n    if(e.key === 's') stepBtn.click();\n  });\n\n  // Initial pseudocode highlight none\n})();\n</script>\n</body>\n</html>"
  },
