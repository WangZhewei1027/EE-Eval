    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Doubly Linked List</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #listContainer {\n            margin-top: 20px;\n        }\n        .node {\n            display: inline-block;\n            margin: 5px;\n            padding: 10px;\n            border: 1px solid #000;\n            border-radius: 5px;\n        }\n        .pointer {\n            margin: 0 10px;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Doubly Linked List Visualization</h1>\n<input type=\"text\" id=\"nodeValue\" placeholder=\"Enter node value\" />\n<button onclick=\"addNode()\">Add Node</button>\n<button onclick=\"removeNode()\">Remove Node</button>\n<div id=\"listContainer\"></div>\n\n<script>\n    class Node {\n        constructor(value) {\n            this.value = value;\n            this.prev = null;\n            this.next = null;\n        }\n    }\n\n    class DoublyLinkedList {\n        constructor() {\n            this.head = null;\n            this.tail = null;\n        }\n\n        add(value) {\n            const newNode = new Node(value);\n            if (!this.head) {\n                this.head = newNode;\n                this.tail = newNode;\n            } else {\n                newNode.prev = this.tail;\n                this.tail.next = newNode;\n                this.tail = newNode;\n            }\n            this.render();\n        }\n\n        remove() {\n            if (!this.tail) return; // Nothing to remove\n            if (this.tail.prev) {\n                this.tail = this.tail.prev;\n                this.tail.next = null;\n            } else {\n                this.head = null;\n                this.tail = null;\n            }\n            this.render();\n        }\n\n        render() {\n            const listContainer = document.getElementById(\"listContainer\");\n            listContainer.innerHTML = \"\";\n            let currentNode = this.head;\n\n            while (currentNode) {\n                const nodeElement = document.createElement(\"div\");\n                nodeElement.className = \"node\";\n                nodeElement.innerText = currentNode.value;\n\n                if (currentNode.prev) {\n                    const backPointer = document.createElement(\"span\");\n                    backPointer.className = 'pointer';\n                    backPointer.innerText = \"<-\";\n                    listContainer.appendChild(backPointer);\n                }\n\n                listContainer.appendChild(nodeElement);\n\n                if (currentNode.next) {\n                    const forwardPointer = document.createElement(\"span\");\n                    forwardPointer.className = 'pointer';\n                    forwardPointer.innerText = \"->\";\n                    listContainer.appendChild(forwardPointer);\n                }\n\n                currentNode = currentNode.next;\n            }\n        }\n    }\n\n    const doublyLinkedList = new DoublyLinkedList();\n\n    function addNode() {\n        const nodeValue = document.getElementById(\"nodeValue\").value;\n        if (nodeValue) {\n            doublyLinkedList.add(nodeValue);\n            document.getElementById(\"nodeValue\").value = \"\"; // Clear input\n        }\n    }\n\n    function removeNode() {\n        doublyLinkedList.remove();\n    }\n</script>\n\n</body>\n</html>"
