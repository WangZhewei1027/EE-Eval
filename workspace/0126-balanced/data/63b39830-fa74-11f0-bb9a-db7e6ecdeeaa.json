    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>REST API Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f4f7f8;\n    color: #333;\n  }\n  h1 {\n    color: #007acc;\n  }\n  button {\n    background-color: #007acc;\n    color: white;\n    border: none;\n    padding: 0.5rem 1rem;\n    margin: 0.5rem 0;\n    cursor: pointer;\n    border-radius: 4px;\n    font-size: 1rem;\n  }\n  button:disabled {\n    background-color: #99cbee;\n    cursor: not-allowed;\n  }\n  pre {\n    background: #e8f0fe;\n    padding: 1rem;\n    border-radius: 4px;\n    overflow-x: auto;\n  }\n  .container {\n    max-width: 700px;\n    margin: auto;\n    background: white;\n    padding: 2rem;\n    border-radius: 8px;\n    box-shadow: 0 0 10px #ccc;\n  }\n  label {\n    font-weight: bold;\n    display: block;\n    margin: 1rem 0 0.25rem;\n  }\n  input, select {\n    width: 100%;\n    padding: 0.4rem 0.6rem;\n    font-size: 1rem;\n    border: 1px solid #ccc;\n    border-radius: 4px;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>REST API Demo</h1>\n  <p>This demo shows how to interact with a <strong>REST API</strong> using JavaScript's <code>fetch()</code> method.</p>\n\n  <label for=\"method\">HTTP Method:</label>\n  <select id=\"method\">\n    <option value=\"GET\">GET</option>\n    <option value=\"POST\">POST</option>\n    <option value=\"PUT\">PUT</option>\n    <option value=\"DELETE\">DELETE</option>\n  </select>\n\n  <label for=\"url\">API Endpoint URL:</label>\n  <input type=\"text\" id=\"url\" readonly value=\"https://jsonplaceholder.typicode.com/posts\" />\n\n  <label for=\"payload\">Request Payload (JSON):</label>\n  <textarea id=\"payload\" placeholder='e.g. {\"title\": \"foo\",\"body\": \"bar\",\"userId\": 1}' rows=\"5\" style=\"width: 100%; font-family: monospace;\"></textarea>\n\n  <button id=\"sendBtn\">Send Request</button>\n\n  <h2>Response:</h2>\n  <pre id=\"responseArea\">Click \"Send Request\" to perform a REST API call.</pre>\n</div>\n\n<script>\n  const methodSelect = document.getElementById('method');\n  const payloadInput = document.getElementById('payload');\n  const sendBtn = document.getElementById('sendBtn');\n  const responseArea = document.getElementById('responseArea');\n\n  function updatePayloadVisibility() {\n    // GET and DELETE usually do not have body\n    const method = methodSelect.value;\n    if (method === 'GET' || method === 'DELETE') {\n      payloadInput.disabled = true;\n      payloadInput.value = '';\n      payloadInput.placeholder = 'No request payload for GET or DELETE';\n    } else {\n      payloadInput.disabled = false;\n      payloadInput.placeholder = 'e.g. {\"title\": \"foo\",\"body\": \"bar\",\"userId\": 1}';\n    }\n  }\n\n  methodSelect.addEventListener('change', updatePayloadVisibility);\n  updatePayloadVisibility();\n\n  async function sendRequest() {\n    const method = methodSelect.value;\n    const url = document.getElementById('url').value.trim();\n\n    let options = {\n      method,\n      headers: {\n        'Accept': 'application/json',\n      },\n    };\n\n    if (method === 'POST' || method === 'PUT') {\n      if (!payloadInput.value.trim()) {\n        alert('Please enter valid JSON payload for ' + method + ' request.');\n        return;\n      }\n      try {\n        JSON.parse(payloadInput.value); // validate JSON\n      } catch (e) {\n        alert('Invalid JSON payload: ' + e.message);\n        return;\n      }\n      options.headers['Content-Type'] = 'application/json; charset=UTF-8';\n      options.body = payloadInput.value;\n    }\n\n    sendBtn.disabled = true;\n    responseArea.textContent = 'Sending request...';\n\n    try {\n      const res = await fetch(url, options);\n      const contentType = res.headers.get('content-type') || '';\n\n      let responseText;\n      if (contentType.includes('application/json')) {\n        const json = await res.json();\n        responseText = JSON.stringify(json, null, 2);\n      } else {\n        responseText = await res.text();\n      }\n\n      responseArea.textContent = \n        `Status: ${res.status} ${res.statusText}\\n\\nHeaders:\\n` +\n        [...res.headers.entries()]\n          .map(([k,v]) => `${k}: ${v}`)\n          .join('\\n') +\n        `\\n\\nBody:\\n${responseText}`;\n    } catch (err) {\n      responseArea.textContent = 'Error: ' + err.message;\n    } finally {\n      sendBtn.disabled = false;\n    }\n  }\n\n  sendBtn.addEventListener('click', sendRequest);\n</script>\n</body>\n</html>"
