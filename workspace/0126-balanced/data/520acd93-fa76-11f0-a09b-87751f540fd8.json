    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Congestion Control</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        \n        #traffic-light {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            border: 1px solid black;\n            border-radius: 10px;\n            padding: 10px;\n            font-size: 24px;\n            color: white;\n        }\n        \n        #traffic-light-red {\n            background-color: red;\n        }\n        \n        #traffic-light-green {\n            background-color: green;\n        }\n        \n        #traffic-light-yellow {\n            background-color: yellow;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"traffic-light\" class=\"traffic-light\"></div>\n    <script>\n        let trafficLight = document.getElementById('traffic-light');\n        let red = document.createElement('div');\n        red.classList.add('traffic-light-red');\n        trafficLight.appendChild(red);\n        \n        let green = document.createElement('div');\n        green.classList.add('traffic-light-green');\n        trafficLight.appendChild(green);\n        \n        let yellow = document.createElement('div');\n        yellow.classList.add('traffic-light-yellow');\n        trafficLight.appendChild(yellow);\n        \n        let intervalId = setInterval(() => {\n            if (trafficLight.style.backgroundColor === 'red') {\n                green.style.backgroundColor = 'yellow';\n                trafficLight.style.backgroundColor = 'yellow';\n                clearInterval(intervalId);\n            } else if (trafficLight.style.backgroundColor === 'green') {\n                green.style.backgroundColor = 'yellow';\n                trafficLight.style.backgroundColor = 'green';\n                clearInterval(intervalId);\n            } else if (trafficLight.style.backgroundColor === 'yellow') {\n                green.style.backgroundColor = 'yellow';\n                trafficLight.style.backgroundColor = 'green';\n                clearInterval(intervalId);\n            }\n        }, 1000);\n    </script>\n</body>\n</html>"
