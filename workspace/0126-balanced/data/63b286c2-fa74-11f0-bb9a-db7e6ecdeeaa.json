    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Demonstration of Process Concept</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4ff;\n    color: #222;\n  }\n  h1 {\n    color: #1a237e;\n  }\n  .process-container {\n    margin-top: 1rem;\n  }\n  .step {\n    background: white;\n    padding: 1rem 1.5rem;\n    margin: 0.5rem 0;\n    border-left: 6px solid #3949ab;\n    box-shadow: 0 2px 6px rgb(57 73 171 / 0.2);\n    transition: background 0.3s ease;\n  }\n  .step.active {\n    background: #c5cae9;\n    border-left-color: #0d47a1;\n    font-weight: bold;\n    color: #0d47a1;\n  }\n  button {\n    margin-top: 1.5rem;\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    border: none;\n    border-radius: 4px;\n    background: #3949ab;\n    color: white;\n    cursor: pointer;\n    transition: background 0.3s ease;\n  }\n  button:hover {\n    background: #303f9f;\n  }\n  p.description {\n    max-width: 600px;\n    margin-bottom: 1.5rem;\n  }\n</style>\n</head>\n<body>\n<h1>Understanding <em>Process</em></h1>\n<p class=\"description\">\n  A process is a sequence of actions or steps taken in order to achieve a particular result. This demonstration will animate a simple 5-step process to illustrate how a process flows from start to finish.\n</p>\n\n<div class=\"process-container\" id=\"process\">\n  <div class=\"step\" id=\"step1\">Step 1: Gather Requirements</div>\n  <div class=\"step\" id=\"step2\">Step 2: Design Solution</div>\n  <div class=\"step\" id=\"step3\">Step 3: Develop Code</div>\n  <div class=\"step\" id=\"step4\">Step 4: Test Implementation</div>\n  <div class=\"step\" id=\"step5\">Step 5: Deploy to Production</div>\n</div>\n\n<button id=\"startBtn\">Start Process</button>\n\n<script>\n  const steps = document.querySelectorAll('.step');\n  const startBtn = document.getElementById('startBtn');\n\n  let currentStep = -1;\n  let intervalId = null;\n\n  function resetSteps() {\n    steps.forEach(s => s.classList.remove('active'));\n    currentStep = -1;\n  }\n\n  function highlightNextStep() {\n    // Remove highlight from previous step\n    if(currentStep >= 0) {\n      steps[currentStep].classList.remove('active');\n    }\n\n    currentStep++;\n\n    if(currentStep >= steps.length) {\n      clearInterval(intervalId);\n      startBtn.disabled = false;\n      alert(\"Process Complete!\");\n      return;\n    }\n\n    steps[currentStep].classList.add('active');\n  }\n\n  function startProcess() {\n    resetSteps();\n    startBtn.disabled = true;\n    highlightNextStep();\n    intervalId = setInterval(highlightNextStep, 1500);\n  }\n\n  startBtn.addEventListener('click', startProcess);\n</script>\n</body>\n</html>"
