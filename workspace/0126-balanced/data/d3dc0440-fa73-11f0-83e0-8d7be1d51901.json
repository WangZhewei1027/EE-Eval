  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Neural Networks — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --accent:#6ee7b7;\n      --muted:#9aa6b2;\n      --card:#0f1724;\n      --glass: rgba(255,255,255,0.03);\n    }\n    html,body{height:100%;margin:0;font-family:Inter,Segoe UI,Roboto,Helvetica,Arial,sans-serif;background:linear-gradient(180deg,#071023 0%, #071420 100%);color:#dbe7ef}\n    .wrap{display:flex;gap:18px;padding:18px;box-sizing:border-box;height:100%}\n    .left{width:60%;display:flex;flex-direction:column;gap:12px}\n    .right{width:40%;display:flex;flex-direction:column;gap:12px}\n    .card{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.03);padding:12px;border-radius:10px;box-sizing:border-box;}\n    h1{margin:0;font-size:18px;color:white}\n    .top-row{display:flex;gap:12px;align-items:center;justify-content:space-between}\n    .controls{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}\n    label{font-size:12px;color:var(--muted)}\n    select,input,button,textarea{background:transparent;border:1px solid rgba(255,255,255,0.06);padding:8px;border-radius:6px;color:#dbe7ef;font-size:13px;outline:none}\n    button{cursor:pointer}\n    .canvas-wrap{display:flex;gap:12px}\n    #boundary{width:100%;height:420px;border-radius:8px;background:#07111a;display:block}\n    .panel-row{display:flex;gap:12px}\n    .network-canvas{width:100%;height:220px;background:#07111a;border-radius:8px}\n    .loss-canvas{width:100%;height:160px;background:#07111a;border-radius:8px}\n    .small{font-size:12px;color:var(--muted)}\n    .btn-row{display:flex;gap:8px}\n    .stat{font-size:13px;color:var(--muted)}\n    .legend{display:flex;gap:8px;align-items:center}\n    .dot{width:12px;height:12px;border-radius:50%}\n    .dot.pos{background:rgba(110,231,183,0.95)}\n    .dot.neg{background:rgba(255,99,132,0.9)}\n    .footer{font-size:12px;color:var(--muted);margin-top:6px}\n    input[type=range]{-webkit-appearance:none;height:6px;border-radius:6px;background:rgba(255,255,255,0.05);outline:none}\n    input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--accent);border:2px solid rgba(0,0,0,0.2)}\n    .grid-controls{display:flex;gap:6px;flex-wrap:wrap}\n    .small-input{width:60px}\n    .big-input{min-width:180px}\n    .muted-block{font-size:12px;color:var(--muted);line-height:1.4}\n    .codebox{background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));padding:8px;border-radius:6px;border:1px solid rgba(255,255,255,0.02);font-family:monospace;font-size:12px;color:#bfe9d6}\n    .row{display:flex;gap:8px;align-items:center}\n    footer{font-size:12px;color:var(--muted);text-align:center;padding:8px}\n    a{color:var(--accent)}\n    /* responsive */\n    @media (max-width:900px){\n      .wrap{flex-direction:column}\n      .left,.right{width:100%}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <div class=\"left\">\n      <div class=\"card\">\n        <div class=\"top-row\">\n          <div>\n            <h1>Neural Networks — Interactive Demo</h1>\n            <div class=\"small\">Visualize a small feedforward network learning 2D classification tasks. Try XOR to see non-linear learning.</div>\n          </div>\n          <div class=\"legend\">\n            <div class=\"dot pos\"></div><div class=\"small\">class 1</div>\n            <div style=\"width:10px\"></div>\n            <div class=\"dot neg\"></div><div class=\"small\">class 0</div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:12px\" class=\"controls\">\n          <div>\n            <label>Dataset</label><br>\n            <select id=\"dataset\">\n              <option value=\"AND\">AND (linearly separable)</option>\n              <option value=\"OR\">OR (linearly separable)</option>\n              <option value=\"XOR\" selected>XOR (non-linearly separable)</option>\n              <option value=\"circle\">Circle (non-linear)</option>\n              <option value=\"random\">Random clusters</option>\n            </select>\n          </div>\n\n          <div>\n            <label>Hidden layers (comma-separated)</label><br>\n            <input id=\"hidden\" class=\"big-input\" value=\"4\" placeholder=\"e.g. 8,6\">\n          </div>\n\n          <div>\n            <label>Activation</label><br>\n            <select id=\"activation\">\n              <option value=\"sigmoid\">sigmoid</option>\n              <option value=\"tanh\" selected>tanh</option>\n              <option value=\"relu\">ReLU</option>\n            </select>\n          </div>\n\n          <div>\n            <label>Learning rate</label><br>\n            <input id=\"lr\" type=\"range\" min=\"0.001\" max=\"1\" step=\"0.001\" value=\"0.2\">\n            <div class=\"small\" id=\"lrLabel\">0.200</div>\n          </div>\n\n          <div>\n            <label>Batch size</label><br>\n            <input id=\"batch\" class=\"small-input\" value=\"4\" type=\"number\">\n          </div>\n\n          <div>\n            <label>Epochs / step</label><br>\n            <input id=\"epochsPerStep\" class=\"small-input\" value=\"1\" type=\"number\">\n          </div>\n\n          <div>\n            <label>Points per class</label><br>\n            <input id=\"ptsPerClass\" class=\"small-input\" value=\"80\" type=\"number\">\n          </div>\n        </div>\n\n        <div style=\"margin-top:12px\" class=\"btn-row\">\n          <button id=\"resetBtn\">New dataset & reset</button>\n          <button id=\"initNetBtn\">Init network</button>\n          <button id=\"trainBtn\">Start training</button>\n          <button id=\"stepBtn\">Step</button>\n          <button id=\"stopBtn\">Stop</button>\n          <button id=\"randomizeBtn\">Randomize weights</button>\n          <button id=\"downloadBtn\">Download snapshot</button>\n        </div>\n\n        <div style=\"margin-top:12px\" class=\"panel-row\">\n          <canvas id=\"boundary\" width=\"900\" height=\"420\"></canvas>\n        </div>\n\n        <div style=\"margin-top:10px\" class=\"panel-row\">\n          <canvas id=\"network\" class=\"network-canvas\" width=\"900\" height=\"220\"></canvas>\n        </div>\n        <div style=\"margin-top:8px\" class=\"panel-row\">\n          <canvas id=\"loss\" class=\"loss-canvas\" width=\"900\" height=\"160\"></canvas>\n        </div>\n\n        <div style=\"margin-top:8px;display:flex;justify-content:space-between;align-items:center\">\n          <div>\n            <div class=\"stat\">Epochs trained: <span id=\"epochCount\">0</span></div>\n            <div class=\"stat\">Last loss: <span id=\"lastLoss\">-</span></div>\n          </div>\n          <div class=\"small muted-block\">\n            Tips: Toggle datasets, change hidden layer sizes. XOR requires at least one hidden layer. Watch decision boundary evolve.\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card\" style=\"margin-top:12px\">\n        <h1>How it works (short)</h1>\n        <div class=\"small muted-block\" style=\"margin-top:8px\">\n          A feedforward neural network maps input -> hidden layers -> output. Each connection has a weight; nodes add a bias and apply an activation function (sigmoid/tanh/ReLU).\n          Training adjusts weights by computing gradients of a loss (difference between predictions and labels) using backpropagation and gradient descent.\n          This demo trains a small network on 2D points and shows the decision boundary (color map), node activations (node color), and weight magnitudes (line widths).\n        </div>\n      </div>\n    </div>\n\n    <div class=\"right\">\n      <div class=\"card\">\n        <h1>Network settings / state</h1>\n        <div style=\"margin-top:8px\" class=\"small\">\n          Layers: <span id=\"layerSpec\">-</span><br>\n          Weights: <span id=\"weightCount\">-</span><br>\n          Biases: <span id=\"biasCount\">-</span>\n        </div>\n\n        <hr style=\"border:0;border-top:1px solid rgba(255,255,255,0.03);margin:12px 0\">\n\n        <div>\n          <h1 style=\"font-size:14px\">Examples & experiments</h1>\n          <div class=\"small\" style=\"margin-top:8px\">\n            - XOR: Non-linear, needs hidden layer(s)<br>\n            - AND/OR: Linearly separable, a single neuron can learn it<br>\n            - Circle: Concentric class separation showcases non-linear boundaries\n          </div>\n        </div>\n\n        <hr style=\"border:0;border-top:1px solid rgba(255,255,255,0.03);margin:12px 0\">\n\n        <div>\n          <h1 style=\"font-size:14px\">Export / Save</h1>\n          <div class=\"small\" style=\"margin-top:8px\">\n            Click \"Download snapshot\" to save the decision boundary image and current network weights (text) in a small package for inspection.\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <h1>Quick inspector</h1>\n        <div class=\"small\" style=\"margin-top:8px\">\n          <textarea id=\"weightsView\" class=\"codebox\" rows=\"12\" style=\"width:100%;resize:vertical\"></textarea>\n        </div>\n        <div style=\"margin-top:8px;display:flex;gap:8px\">\n          <button id=\"copyWeights\">Copy weights</button>\n          <button id=\"loadWeights\">Load weights from textarea</button>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <h1 style=\"font-size:14px\">Notes</h1>\n        <div class=\"small muted-block\" style=\"margin-top:8px\">\n          This is an educational demo. The implementation uses simple SGD and mean-squared loss for binary classification to keep computations explicit and readable.\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  Interactive Neural Network demo (single-file).\n  - Small feedforward network with backpropagation (MSE).\n  - Binary classification on 2D datasets.\n  - Visualizes decision boundary, network structure, activations, weights, and loss curve.\n*/\n\n// ---------- Utility ----------\nfunction randn() {\n  // Box-Muller\n  let u = 0, v = 0;\n  while(u===0) u = Math.random();\n  while(v===0) v = Math.random();\n  return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);\n}\nfunction clamp(v,a,b){return Math.max(a,Math.min(b,v));}\nfunction sigmoid(x){return 1/(1+Math.exp(-x))}\nfunction dsigmoid(x){ let s = sigmoid(x); return s*(1-s); }\nfunction dtanh(x){ let t = Math.tanh(x); return 1 - t*t; }\nfunction drelu(x){ return x>0?1:0; }\n\n// ---------- Neural Network ----------\nclass SimpleNN {\n  constructor(layerSizes, activation='tanh') {\n    this.layerSizes = layerSizes.slice(); // includes input and output\n    this.activationName = activation;\n    this.initParams();\n  }\n  initParams() {\n    this.weights = []; // weights[l] shape: [n_out][n_in]\n    this.biases = [];  // biases[l] shape: [n_out]\n    for (let l=1;l<this.layerSizes.length;l++){\n      let n_in = this.layerSizes[l-1];\n      let n_out = this.layerSizes[l];\n      let w = new Array(n_out);\n      for (let i=0;i<n_out;i++){\n        w[i] = new Array(n_in);\n        for (let j=0;j<n_in;j++){\n          w[i][j] = randn()*Math.sqrt(2/(n_in+n_out)); // Xavier-ish\n        }\n      }\n      this.weights.push(w);\n      this.biases.push(new Array(n_out).fill(0));\n    }\n  }\n  cloneParamsFrom(other) {\n    this.weights = JSON.parse(JSON.stringify(other.weights));\n    this.biases = JSON.parse(JSON.stringify(other.biases));\n  }\n  forward(x) {\n    // x: array input length n0\n    let activations = [x.slice()];\n    let zs = [];\n    for (let l=0;l<this.weights.length;l++){\n      let w = this.weights[l];\n      let b = this.biases[l];\n      let prev = activations[activations.length-1];\n      let z = new Array(w.length);\n      let a = new Array(w.length);\n      for (let i=0;i<w.length;i++){\n        let sum = b[i];\n        for (let j=0;j<w[i].length;j++){\n          sum += w[i][j]*prev[j];\n        }\n        z[i] = sum;\n        // activation\n        if (l === this.weights.length-1) {\n          // final layer: use sigmoid for binary classification (single output) or identity if >1\n          if (w.length === 1) {\n            a[i] = sigmoid(sum);\n          } else {\n            // multiple outputs -> softmax? but keep sigmoid for demonstration of binary tasks\n            a[i] = sigmoid(sum);\n          }\n        } else {\n          a[i] = this.activate(sum);\n        }\n      }\n      zs.push(z);\n      activations.push(a);\n    }\n    return {activations, zs};\n  }\n  activate(x){\n    if (this.activationName === 'tanh') return Math.tanh(x);\n    if (this.activationName === 'sigmoid') return sigmoid(x);\n    if (this.activationName === 'relu') return x>0?x:0;\n    return Math.tanh(x);\n  }\n  activateDerivAt(z){\n    if (this.activationName === 'tanh') return dtanh(z);\n    if (this.activationName === 'sigmoid') return dsigmoid(z);\n    if (this.activationName === 'relu') return drelu(z);\n    return dtanh(z);\n  }\n\n  // Train on a mini-batch (sgd) using MSE loss. xbatch: [ [x1,x2], ... ], ybatch: [0/1,...]\n  trainStep(xbatch, ybatch, lr=0.1) {\n    // Initialize gradients with zeros\n    const nabla_w = this.weights.map(w => w.map(row => new Array(row.length).fill(0)));\n    const nabla_b = this.biases.map(b => new Array(b.length).fill(0));\n    let totalLoss = 0;\n    for (let k=0;k<xbatch.length;k++){\n      const x = xbatch[k];\n      const y = ybatch[k];\n      const {activations, zs} = this.forward(x);\n      const L = activations[activations.length-1][0];\n      const loss = 0.5 * Math.pow(L - y, 2);\n      totalLoss += loss;\n      // Backpropagate\n      // delta = dL/dz for last layer: (a-y)*sigmoid'(z)\n      const deltas = new Array(this.weights.length);\n      const last = this.weights.length - 1;\n      const aL = activations[activations.length-1][0];\n      const zL = zs[zs.length-1][0];\n      const deltaL = (aL - y) * dsigmoid(zL);\n      deltas[last] = [deltaL];\n\n      // gradients for last layer\n      const aPrev = activations[activations.length-2];\n      for (let i=0;i<this.weights[last].length;i++){\n        for (let j=0;j<this.weights[last][i].length;j++){\n          nabla_w[last][i][j] += deltas[last][i] * aPrev[j];\n        }\n        nabla_b[last][i] += deltas[last][i];\n      }\n\n      // backprop for earlier layers\n      for (let l = this.weights.length-2; l>=0; l--){\n        const wNext = this.weights[l+1]; // shape [n_next][n_curr]\n        const deltaNext = deltas[l+1];   // array length n_next\n        const z = zs[l];                 // z at layer l\n        const delta = new Array(this.weights[l].length).fill(0);\n        for (let i=0;i<delta.length;i++){\n          let sum = 0;\n          for (let j=0;j<wNext.length;j++){\n            sum += wNext[j][i] * deltaNext[j];\n          }\n          delta[i] = sum * this.activateDerivAt(z[i]);\n        }\n        deltas[l] = delta;\n        const aPrev = activations[l];\n        for (let i=0;i<this.weights[l].length;i++){\n          for (let j=0;j<this.weights[l][i].length;j++){\n            nabla_w[l][i][j] += delta[i] * aPrev[j];\n          }\n          nabla_b[l][i] += delta[i];\n        }\n      }\n    }\n\n    // Update parameters with averaged gradients\n    const m = xbatch.length;\n    for (let l=0;l<this.weights.length;l++){\n      for (let i=0;i<this.weights[l].length;i++){\n        for (let j=0;j<this.weights[l][i].length;j++){\n          this.weights[l][i][j] -= (lr/m) * nabla_w[l][i][j];\n        }\n        this.biases[l][i] -= (lr/m) * nabla_b[l][i];\n      }\n    }\n\n    return totalLoss / xbatch.length;\n  }\n\n  predict(x){\n    const out = this.forward(x).activations.pop();\n    return out[0];\n  }\n\n  toJSON(){\n    return JSON.stringify({\n      layerSizes:this.layerSizes,\n      activation:this.activationName,\n      weights:this.weights,\n      biases:this.biases\n    }, null, 2);\n  }\n  fromJSON(str){\n    try {\n      const obj = JSON.parse(str);\n      if (!obj.layerSizes) return false;\n      this.layerSizes = obj.layerSizes;\n      this.activationName = obj.activation || this.activationName;\n      this.initParams();\n      if (obj.weights && obj.biases) {\n        this.weights = obj.weights;\n        this.biases = obj.biases;\n      }\n      return true;\n    } catch(e){ return false; }\n  }\n}\n\n// ---------- Dataset ----------\nfunction generateDataset(mode, ptsPerClass=80){\n  const data = [];\n  if (mode === 'AND' || mode === 'OR' || mode === 'XOR') {\n    // canonical four points plus jitter\n    const base = [[0,0],[0,1],[1,0],[1,1]];\n    const labels = mode==='AND'? [0,0,0,1] : mode==='OR'? [0,1,1,1] : [0,1,1,0]; // XOR last is 0\n    for (let i=0;i<base.length;i++){\n      const [cx,cy] = base[i];\n      for (let k=0;k<ptsPerClass/4;k++){\n        const x = cx + (Math.random()-0.5)*0.2;\n        const y = cy + (Math.random()-0.5)*0.2;\n        data.push({x:[x,y], y: labels[i]});\n      }\n    }\n  } else if (mode === 'circle') {\n    // two concentric circles\n    for (let i=0;i<ptsPerClass;i++){\n      const r = 0.2 + Math.random()*0.6;\n      const t = Math.random()*Math.PI*2;\n      const x = 0.5 + Math.cos(t)*r + (Math.random()-0.5)*0.05;\n      const y = 0.5 + Math.sin(t)*r + (Math.random()-0.5)*0.05;\n      const label = r>0.4 ? 1 : 0;\n      data.push({x:[x,y], y: label});\n    }\n  } else if (mode === 'random') {\n    // two gaussian clusters\n    for (let i=0;i<ptsPerClass;i++){\n      let a = randn()*0.12 + 0.3;\n      let b = randn()*0.12 + 0.3;\n      data.push({x:[a,b], y:0});\n    }\n    for (let i=0;i<ptsPerClass;i++){\n      let a = randn()*0.12 + 0.7;\n      let b = randn()*0.12 + 0.7;\n      data.push({x:[a,b], y:1});\n    }\n  }\n  return data;\n}\n\n// ---------- Visualization ----------\nconst boundaryCanvas = document.getElementById('boundary');\nconst bctx = boundaryCanvas.getContext('2d');\n\nconst netCanvas = document.getElementById('network');\nconst nctx = netCanvas.getContext('2d');\n\nconst lossCanvas = document.getElementById('loss');\nconst lctx = lossCanvas.getContext('2d');\n\nconst datasetSelect = document.getElementById('dataset');\nconst hiddenInput = document.getElementById('hidden');\nconst activationSelect = document.getElementById('activation');\nconst lrSlider = document.getElementById('lr');\nconst lrLabel = document.getElementById('lrLabel');\nconst batchInput = document.getElementById('batch');\nconst epochsPerStepInput = document.getElementById('epochsPerStep');\nconst ptsPerClassInput = document.getElementById('ptsPerClass');\n\nconst resetBtn = document.getElementById('resetBtn');\nconst initNetBtn = document.getElementById('initNetBtn');\nconst trainBtn = document.getElementById('trainBtn');\nconst stepBtn = document.getElementById('stepBtn');\nconst stopBtn = document.getElementById('stopBtn');\nconst randomizeBtn = document.getElementById('randomizeBtn');\nconst downloadBtn = document.getElementById('downloadBtn');\n\nconst epochCountEl = document.getElementById('epochCount');\nconst lastLossEl = document.getElementById('lastLoss');\nconst layerSpecEl = document.getElementById('layerSpec');\nconst weightCountEl = document.getElementById('weightCount');\nconst biasCountEl = document.getElementById('biasCount');\n\nconst weightsView = document.getElementById('weightsView');\nconst copyWeightsBtn = document.getElementById('copyWeights');\nconst loadWeightsBtn = document.getElementById('loadWeights');\n\nlet dataset = [];\nlet net = null;\nlet training = false;\nlet epochCount = 0;\nlet lastLoss = 0;\nlet lossHistory = [];\nlet activationName = activationSelect.value;\nlet drawGridResolution = 120;\n\n// Initialize\nfunction resetDataset() {\n  const mode = datasetSelect.value;\n  const pts = parseInt(ptsPerClassInput.value) || 80;\n  dataset = generateDataset(mode, pts);\n  epochCount = 0;\n  lastLoss = 0;\n  lossHistory = [];\n  updateStats();\n}\nfunction parseHidden() {\n  const raw = hiddenInput.value.trim();\n  if (!raw) return [];\n  return raw.split(',').map(s=>parseInt(s.trim())).filter(n=>!isNaN(n) && n>0);\n}\nfunction initNetwork() {\n  const hidden = parseHidden();\n  // inputs 2, outputs 1\n  const layerSizes = [2].concat(hidden).concat([1]);\n  net = new SimpleNN(layerSizes, activationSelect.value);\n  lossHistory = [];\n  epochCount = 0;\n  lastLoss = 0;\n  updateStats();\n  weightsView.value = net.toJSON();\n}\nfunction updateStats() {\n  if (!net) {\n    layerSpecEl.textContent = '-';\n    weightCountEl.textContent = '-';\n    biasCountEl.textContent = '-';\n  } else {\n    layerSpecEl.textContent = net.layerSizes.join(' - ');\n    let wc = 0, bc=0;\n    net.weights.forEach(w=> w.forEach(r=> wc += r.length));\n    net.biases.forEach(b=> bc += b.length);\n    weightCountEl.textContent = wc;\n    biasCountEl.textContent = bc;\n  }\n  epochCountEl.textContent = epochCount;\n  lastLossEl.textContent = lastLoss.toFixed(4);\n}\n\n// Draw dataset points and decision boundary\nfunction drawBoundary() {\n  const w = boundaryCanvas.width;\n  const h = boundaryCanvas.height;\n  // clear\n  bctx.clearRect(0,0,w,h);\n  // draw background grid of predictions\n  const res = drawGridResolution;\n  const cellW = w/res;\n  const cellH = h/res;\n  for (let i=0;i<res;i++){\n    for (let j=0;j<res;j++){\n      const gx = (i + 0.5)/res;\n      const gy = 1 - ((j + 0.5)/res); // flip y so 0 bottom -> top in canvas\n      let p = 0.5;\n      if (net) p = net.predict([gx,gy]);\n      const r = Math.floor(255*(1-p));\n      const gCol = Math.floor(180*p+20);\n      bctx.fillStyle = `rgba(${r},${gCol},${150},${0.9})`;\n      bctx.fillRect(i*cellW, j*cellH, cellW+1, cellH+1);\n    }\n  }\n  // draw decision contour line (approx)\n  // draw dataset points\n  dataset.forEach(pt => {\n    const px = pt.x[0]*w;\n    const py = (1-pt.x[1])*h;\n    bctx.beginPath();\n    bctx.arc(px,py,4,0,Math.PI*2);\n    bctx.fillStyle = pt.y===1 ? 'rgba(110,231,183,0.95)' : 'rgba(255,99,132,0.9)';\n    bctx.fill();\n    bctx.lineWidth = 1;\n    bctx.strokeStyle = 'rgba(0,0,0,0.25)';\n    bctx.stroke();\n  });\n}\n\n// Draw network with nodes and connections\nfunction drawNetwork() {\n  const w = netCanvas.width;\n  const h = netCanvas.height;\n  nctx.clearRect(0,0,w,h);\n  if (!net) return;\n  const layers = net.layerSizes;\n  const L = layers.length;\n  const margin = 20;\n  const layerSpacing = (w - 2*margin) / (L-1);\n  const maxNodes = Math.max(...layers);\n  // compute activations for a representative input (center)\n  const sample = [0.5,0.5];\n  const fwd = net.forward(sample);\n  const activations = fwd.activations;\n  const zs = fwd.zs;\n\n  // draw connections\n  for (let l=1;l<layers.length;l++){\n    const nOut = layers[l];\n    const nIn = layers[l-1];\n    const xOut = margin + l*layerSpacing;\n    const xIn = margin + (l-1)*layerSpacing;\n    for (let i=0;i<nOut;i++){\n      const yOut = margin + (h-2*margin) * (i+0.5)/nOut;\n      for (let j=0;j<nIn;j++){\n        const yIn = margin + (h-2*margin) * (j+0.5)/nIn;\n        const wval = net.weights[l-1][i][j];\n        const mag = Math.abs(wval);\n        const hue = wval>0 ? 150 : 340;\n        const alpha = Math.min(0.95, 0.15 + mag*2);\n        nctx.beginPath();\n        nctx.moveTo(xIn, yIn);\n        nctx.lineTo(xOut, yOut);\n        nctx.lineWidth = clamp(1 + mag*3, 0.5, 6);\n        nctx.strokeStyle = `hsla(${hue},70%,60%,${alpha})`;\n        nctx.stroke();\n      }\n    }\n  }\n  // draw nodes\n  for (let l=0;l<layers.length;l++){\n    const n = layers[l];\n    const x = margin + l*layerSpacing;\n    for (let i=0;i<n;i++){\n      const y = margin + (h-2*margin) * (i+0.5)/n;\n      // activation if available\n      let a = 0;\n      if (activations[l]) a = activations[l][i] || 0;\n      // color node by activation\n      const col = activationToColor(a);\n      nctx.beginPath();\n      nctx.arc(x,y,14,0,Math.PI*2);\n      nctx.fillStyle = col;\n      nctx.fill();\n      nctx.lineWidth = 1;\n      nctx.strokeStyle = 'rgba(0,0,0,0.3)';\n      nctx.stroke();\n      // text\n      nctx.fillStyle = 'rgba(255,255,255,0.85)';\n      nctx.font = '11px sans-serif';\n      nctx.textAlign = 'center';\n      nctx.textBaseline = 'middle';\n      if (l===0) {\n        // input names\n        nctx.fillStyle = 'rgba(255,255,255,0.85)';\n        nctx.fillText(['x1','x2'][i] || 'in', x, y);\n      } else {\n        const aStr = a.toFixed(2);\n        nctx.fillText(aStr, x, y);\n      }\n    }\n  }\n}\nfunction activationToColor(a){\n  // a in approx [-1,1] for tanh, or [0,1] for sigmoid\n  // map to color: negative blue, positive green\n  let val = a;\n  if (activationSelect.value === 'tanh') {\n    // tanh approx -1..1 -> map\n    const g = Math.round((val*0.5+0.5)*200 + 30);\n    const r = Math.round((1-val*0.5)*50);\n    return `rgba(${r},${g},${120},0.95)`;\n  } else {\n    // sigmoid / relu -> 0..1\n    const g = Math.round(val*200 + 30);\n    const r = Math.round((1-val)*180 + 20);\n    return `rgba(${r},${g},${120},0.95)`;\n  }\n}\n\n// Loss chart\nfunction drawLoss() {\n  const w = lossCanvas.width;\n  const h = lossCanvas.height;\n  lctx.clearRect(0,0,w,h);\n  // axes\n  lctx.strokeStyle = 'rgba(255,255,255,0.04)';\n  lctx.lineWidth = 1;\n  lctx.beginPath();\n  lctx.moveTo(40,10);\n  lctx.lineTo(40,h-30);\n  lctx.lineTo(w-10,h-30);\n  lctx.stroke();\n  // plot lossHistory\n  if (lossHistory.length === 0) return;\n  const maxPoints = w-60;\n  const slice = lossHistory.slice(-maxPoints);\n  const maxLoss = Math.max(...slice);\n  const minLoss = Math.min(...slice);\n  const range = Math.max(1e-6, maxLoss - minLoss);\n  lctx.beginPath();\n  for (let i=0;i<slice.length;i++){\n    const lx = 40 + i;\n    const ly = 10 + (h-40) * (1 - (slice[i] - minLoss)/range);\n    if (i===0) lctx.moveTo(lx,ly); else lctx.lineTo(lx,ly);\n  }\n  lctx.strokeStyle = 'rgba(110,231,183,0.95)';\n  lctx.lineWidth = 2;\n  lctx.stroke();\n  // labels\n  lctx.fillStyle = 'rgba(255,255,255,0.6)';\n  lctx.font = '12px sans-serif';\n  lctx.fillText('Loss', 8, 18);\n  lctx.fillStyle = 'rgba(255,255,255,0.45)';\n  lctx.fillText((maxLoss).toFixed(3), 8, 34);\n  lctx.fillText((minLoss).toFixed(3), 8, h-28);\n}\n\n// Training loop\nfunction doTrainingStep() {\n  if (!net || dataset.length === 0) return;\n  const lr = parseFloat(lrSlider.value);\n  const batchSize = parseInt(batchInput.value) || 4;\n  const epochs = parseInt(epochsPerStepInput.value) || 1;\n  let avgLoss = 0;\n  for (let e=0;e<epochs;e++){\n    // shuffle dataset\n    for (let i=dataset.length-1;i>0;i--){\n      const j = Math.floor(Math.random()*(i+1));\n      [dataset[i],dataset[j]]=[dataset[j],dataset[i]];\n    }\n    // mini-batch\n    for (let s=0;s<dataset.length;s+=batchSize){\n      const chunk = dataset.slice(s,s+batchSize);\n      const xb = chunk.map(it=>it.x);\n      const yb = chunk.map(it=>it.y);\n      const loss = net.trainStep(xb,yb,lr);\n      avgLoss += loss;\n      epochCount++;\n    }\n  }\n  avgLoss = avgLoss / (epochs * Math.ceil(dataset.length / batchSize));\n  lastLoss = avgLoss;\n  lossHistory.push(avgLoss);\n  if (lossHistory.length > 2000) lossHistory.shift();\n  updateStats();\n}\n\n// Animation & control\nlet animId = null;\nfunction startTraining() {\n  if (!net) initNetwork();\n  training = true;\n  trainBtn.disabled = true;\n  stopBtn.disabled = false;\n  stepBtn.disabled = true;\n  function frame(){\n    if (!training) return;\n    // perform a chunk of training then draw\n    doTrainingStep();\n    drawBoundary();\n    drawNetwork();\n    drawLoss();\n    weightsView.value = net.toJSON();\n    animId = requestAnimationFrame(frame);\n  }\n  frame();\n}\nfunction stopTraining(){\n  training = false;\n  trainBtn.disabled = false;\n  stopBtn.disabled = true;\n  stepBtn.disabled = false;\n  if (animId) cancelAnimationFrame(animId);\n}\nresetDataset();\ninitNetwork();\ndrawBoundary();\ndrawNetwork();\ndrawLoss();\n\n// ---------- UI bindings ----------\nlrSlider.addEventListener('input', ()=>{\n  lrLabel.textContent = parseFloat(lrSlider.value).toFixed(3);\n});\nresetBtn.addEventListener('click', ()=>{\n  resetDataset();\n  initNetwork();\n  drawBoundary();\n  drawNetwork();\n  drawLoss();\n});\ninitNetBtn.addEventListener('click', ()=>{\n  initNetwork();\n  drawBoundary();\n  drawNetwork();\n  drawLoss();\n});\ntrainBtn.addEventListener('click', ()=>{\n  startTraining();\n});\nstopBtn.addEventListener('click', ()=>{\n  stopTraining();\n});\nstepBtn.addEventListener('click', ()=>{\n  doTrainingStep();\n  drawBoundary();\n  drawNetwork();\n  drawLoss();\n});\nrandomizeBtn.addEventListener('click', ()=>{\n  if (!net) initNetwork();\n  net.initParams();\n  weightsView.value = net.toJSON();\n  drawBoundary();\n  drawNetwork();\n  drawLoss();\n});\ndatasetSelect.addEventListener('change', ()=>{\n  resetDataset();\n  drawBoundary();\n});\nhiddenInput.addEventListener('change', ()=>{\n  // re-init net with new hidden config\n  initNetwork();\n  drawBoundary();\n  drawNetwork();\n  drawLoss();\n});\nactivationSelect.addEventListener('change', ()=>{\n  if (net) net.activationName = activationSelect.value;\n  drawNetwork();\n});\nptsPerClassInput.addEventListener('change', ()=>{\n  resetDataset();\n  drawBoundary();\n});\ndownloadBtn.addEventListener('click', ()=>{\n  // snapshot decision boundary + weights\n  const imgData = boundaryCanvas.toDataURL('image/png');\n  const blob = dataURLtoBlob(imgData);\n  const a = document.createElement('a');\n  a.href = URL.createObjectURL(blob);\n  a.download = `nn_decision_${datasetSelect.value}.png`;\n  a.click();\n  setTimeout(()=>URL.revokeObjectURL(a.href),1000);\n  // also open weights in new tab\n  const wBlob = new Blob([net.toJSON()], {type:'application/json'});\n  const wa = document.createElement('a');\n  wa.href = URL.createObjectURL(wBlob);\n  wa.download = `nn_weights_${Date.now()}.json`;\n  wa.click();\n  setTimeout(()=>URL.revokeObjectURL(wa.href),1000);\n});\nfunction dataURLtoBlob(dataurl) {\n  var arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1],\n      bstr = atob(arr[1]), n = bstr.length, u8arr = new Uint8Array(n);\n  while(n--) u8arr[n] = bstr.charCodeAt(n);\n  return new Blob([u8arr], {type:mime});\n}\n\nweightsView.addEventListener('change', ()=>{\n  // no-op until load pressed\n});\ncopyWeightsBtn.addEventListener('click', ()=>{\n  weightsView.select();\n  document.execCommand('copy');\n});\nloadWeightsBtn.addEventListener('click', ()=>{\n  const s = weightsView.value;\n  if (!net) initNetwork();\n  const ok = net.fromJSON(s);\n  if (!ok) {\n    alert('Failed to parse network JSON');\n  } else {\n    updateStats();\n    drawBoundary();\n    drawNetwork();\n    drawLoss();\n  }\n});\n\n// keyboard shortcuts\nwindow.addEventListener('keydown', (e)=>{\n  if (e.key === ' ') { e.preventDefault(); if (training) stopTraining(); else startTraining(); }\n  if (e.key === 's') { doTrainingStep(); drawBoundary(); drawNetwork(); drawLoss(); }\n});\n\n// initial UI state\nstopBtn.disabled = true;\ntrainBtn.disabled = false;\nstepBtn.disabled = false;\nlrLabel.textContent = parseFloat(lrSlider.value).toFixed(3);\nweightsView.value = net.toJSON();\nupdateStats();\ndrawBoundary();\ndrawNetwork();\ndrawLoss();\n\n</script>\n</body>\n</html>"
