  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Binary Tree (BST) Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#f6f9fc;\n      --card:#ffffff;\n      --accent:#2b7cff;\n      --muted:#6b7280;\n      --danger:#e46060;\n      --success:#2fb978;\n      --shadow: 0 6px 18px rgba(29,41,81,0.08);\n      --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Noto Mono\", monospace;\n      --ui-sans: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    html,body{height:100%;margin:0;font-family:var(--ui-sans);background:linear-gradient(180deg,#eef6ff 0%,var(--bg) 40%);color:#0f172a;}\n    .container{max-width:1100px;margin:28px auto;padding:20px;}\n    .card{background:var(--card);border-radius:12px;padding:18px;margin-bottom:18px;box-shadow:var(--shadow);}\n    header{display:flex;align-items:center;gap:16px;}\n    h1{font-size:20px;margin:0;}\n    p.lead{margin:6px 0 0;color:var(--muted);font-size:13px;}\n    .controls{display:flex;gap:12px;flex-wrap:wrap;margin-top:14px;align-items:center;}\n    .controls input[type=\"number\"], .controls input[type=\"text\"]{\n      padding:8px 10px;border-radius:8px;border:1px solid #e6eef9;width:120px;font-size:14px;\n    }\n    .btn{background:var(--accent);color:white;padding:8px 12px;border-radius:8px;border:0;cursor:pointer;font-weight:600}\n    .btn.secondary{background:#f0f6ff;color:var(--accent);border:1px solid rgba(43,124,255,0.14)}\n    .btn.warn{background:var(--danger)}\n    .btn.ghost{background:transparent;color:var(--muted);border:1px solid #eef2ff}\n    .stats{display:flex;gap:12px;flex-wrap:wrap;margin-top:12px}\n    .stat{background:#ffffff;border-radius:8px;padding:8px 12px;border:1px solid #f1f5f9;font-size:13px;color:var(--muted)}\n    .canvas-wrap{height:520px;border-radius:12px;background:linear-gradient(180deg,#ffffff,#fbfdff);display:flex;align-items:center;justify-content:center;padding:12px;margin-top:14px;border:1px solid #eef2ff}\n    svg{width:100%;height:100%}\n    .node{cursor:pointer;transition:transform .12s ease}\n    .node text{font-family:var(--mono);font-size:12px;fill:#ffffff;font-weight:700}\n    .traversal-log{max-height:80px;overflow:auto;padding:8px;background:#fbfdff;border-radius:8px;border:1px solid #eef2ff;font-size:13px;color:var(--muted)}\n    .explain{font-size:13px;color:var(--muted);margin-top:10px}\n    footer{margin-top:6px;font-size:12px;color:var(--muted)}\n    .small{font-size:12px;color:var(--muted)}\n    .controls .group{display:flex;gap:8px;align-items:center}\n    @media (max-width:720px){\n      .controls{flex-direction:column;align-items:stretch}\n      .canvas-wrap{height:420px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"card\">\n      <header>\n        <div style=\"width:44px;height:44px;border-radius:8px;background:linear-gradient(135deg,var(--accent),#6fb8ff);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:20px\">\n          BT\n        </div>\n        <div>\n          <h1>Binary Search Tree — Interactive Demo</h1>\n          <p class=\"lead\">Insert, remove, search and watch traversals on a Binary Search Tree (BST). Click nodes to highlight.</p>\n        </div>\n      </header>\n\n      <div class=\"controls\">\n        <div class=\"group\">\n          <input id=\"valueInput\" type=\"number\" placeholder=\"Value (e.g. 42)\" />\n          <button id=\"insertBtn\" class=\"btn\">Insert</button>\n          <button id=\"removeBtn\" class=\"btn secondary\">Remove</button>\n          <button id=\"searchBtn\" class=\"btn ghost\">Search</button>\n        </div>\n\n        <div class=\"group\">\n          <input id=\"countInput\" type=\"number\" placeholder=\"# nodes\" min=\"1\" max=\"50\" />\n          <button id=\"randomBtn\" class=\"btn\">Randomize</button>\n          <button id=\"clearBtn\" class=\"btn warn\">Clear</button>\n        </div>\n\n        <div class=\"group\">\n          <button id=\"preorderBtn\" class=\"btn secondary\">Preorder</button>\n          <button id=\"inorderBtn\" class=\"btn secondary\">Inorder</button>\n          <button id=\"postorderBtn\" class=\"btn secondary\">Postorder</button>\n          <button id=\"levelBtn\" class=\"btn secondary\">Level-order</button>\n        </div>\n\n        <div class=\"group\">\n          <button id=\"balanceCheckBtn\" class=\"btn ghost\">Check Balanced</button>\n          <button id=\"exportBtn\" class=\"btn secondary\">Export</button>\n        </div>\n      </div>\n\n      <div class=\"stats\" id=\"stats\">\n        <div class=\"stat\">Nodes: <span id=\"nodeCount\">0</span></div>\n        <div class=\"stat\">Height: <span id=\"treeHeight\">0</span></div>\n        <div class=\"stat\">Root: <span id=\"rootVal\">—</span></div>\n        <div class=\"stat\">Balanced: <span id=\"balanced\">—</span></div>\n      </div>\n\n      <div class=\"canvas-wrap card\" style=\"margin-top:14px;\">\n        <svg id=\"svgCanvas\" viewBox=\"0 0 1200 520\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\" aria-label=\"Binary tree visualization\"></svg>\n      </div>\n\n      <div style=\"display:flex;gap:12px;margin-top:12px;flex-wrap:wrap;align-items:flex-start\">\n        <div style=\"flex:1\">\n          <div class=\"card\" style=\"padding:12px\">\n            <div style=\"display:flex;justify-content:space-between;align-items:center\">\n              <strong>Traversal Log</strong>\n              <button id=\"clearLog\" class=\"btn ghost\">Clear</button>\n            </div>\n            <div class=\"traversal-log\" id=\"log\"></div>\n          </div>\n\n          <div class=\"card explain\">\n            <strong>About this demo</strong>\n            <p style=\"margin:6px 0 0\">This demo implements a Binary Search Tree (BST). Inserted values are placed so that for any node, left children are smaller and right children are larger. Traversals show different visiting orders:\n            <ul style=\"margin:6px 0 0 18px\">\n              <li>Preorder: Node → Left → Right</li>\n              <li>Inorder: Left → Node → Right (sorted order)</li>\n              <li>Postorder: Left → Right → Node</li>\n              <li>Level-order: Breadth-first by levels</li>\n            </ul>\n            Click a node to highlight it. Use \"Check Balanced\" to test if the tree is height-balanced (difference of heights ≤ 1 at every node).</p>\n          </div>\n        </div>\n\n        <div style=\"width:320px\">\n          <div class=\"card\" style=\"padding:12px\">\n            <strong>Quick tips</strong>\n            <ul style=\"margin:8px 0 0 18px;color:var(--muted)\">\n              <li>Insert duplicate values are ignored.</li>\n              <li>Export gives you JSON of nodes (preorder) to restore later.</li>\n              <li>Try <em>Randomize</em> to create varied trees and then visualize traversals.</li>\n            </ul>\n          </div>\n\n          <div class=\"card\" style=\"padding:12px;margin-top:10px\">\n            <strong>Example</strong>\n            <p class=\"small\">Try inserting: 50, 30, 70, 20, 40, 60, 80. Then click Inorder — you'll see a sorted sequence.</p>\n            <button id=\"exampleBtn\" class=\"btn\">Load Example</button>\n          </div>\n        </div>\n      </div>\n\n      <footer class=\"small\">Built with plain JavaScript & SVG • Click nodes or traversal buttons to animate</footer>\n    </div>\n  </div>\n\n<script>\n/*\n  Binary Search Tree interactive demo\n  - BST implementation with insert, remove, search, traversals\n  - Visualization using SVG\n  - Traversal animation highlighting nodes\n*/\n\n(function(){\n  // Utilities\n  function $(id){ return document.getElementById(id); }\n  function clamp(v,min,max){return Math.max(min,Math.min(max,v));}\n\n  // Node & BST classes\n  class Node {\n    constructor(val){\n      this.val = val;\n      this.left = null;\n      this.right = null;\n      // for visualization:\n      this.x = 0;\n      this.y = 0;\n      this.id = Node.nextId++;\n    }\n  }\n  Node.nextId = 1;\n\n  class BST {\n    constructor(){\n      this.root = null;\n      this.size = 0;\n    }\n\n    insert(val){\n      if(this.root === null){\n        this.root = new Node(val);\n        this.size = 1;\n        return true;\n      }\n      let cur = this.root;\n      while(true){\n        if(val === cur.val) return false; // ignore duplicates\n        if(val < cur.val){\n          if(!cur.left){\n            cur.left = new Node(val);\n            this.size++;\n            return true;\n          }\n          cur = cur.left;\n        } else {\n          if(!cur.right){\n            cur.right = new Node(val);\n            this.size++;\n            return true;\n          }\n          cur = cur.right;\n        }\n      }\n    }\n\n    search(val){\n      let cur = this.root;\n      while(cur){\n        if(val === cur.val) return cur;\n        cur = (val < cur.val) ? cur.left : cur.right;\n      }\n      return null;\n    }\n\n    // Remove a value (standard BST delete)\n    remove(val){\n      const removeNode = (node, val) => {\n        if(!node) return null;\n        if(val < node.val){\n          node.left = removeNode(node.left, val);\n          return node;\n        } else if(val > node.val){\n          node.right = removeNode(node.right, val);\n          return node;\n        } else {\n          // no children\n          if(!node.left && !node.right){\n            this.size--;\n            return null;\n          }\n          // one child\n          if(!node.left){\n            this.size--;\n            return node.right;\n          }\n          if(!node.right){\n            this.size--;\n            return node.left;\n          }\n          // two children: find inorder successor (min in right subtree)\n          let succParent = node;\n          let succ = node.right;\n          while(succ.left){\n            succParent = succ;\n            succ = succ.left;\n          }\n          node.val = succ.val;\n          // remove succ\n          node.right = removeNode(node.right, succ.val);\n          return node;\n        }\n      };\n      const before = this.size;\n      this.root = removeNode(this.root,val);\n      return this.size < before;\n    }\n\n    // Traversals returning arrays of nodes\n    inorder(node=this.root, arr=[]){\n      if(!node) return arr;\n      this.inorder(node.left, arr);\n      arr.push(node);\n      this.inorder(node.right, arr);\n      return arr;\n    }\n    preorder(node=this.root, arr=[]){\n      if(!node) return arr;\n      arr.push(node);\n      this.preorder(node.left, arr);\n      this.preorder(node.right, arr);\n      return arr;\n    }\n    postorder(node=this.root, arr=[]){\n      if(!node) return arr;\n      this.postorder(node.left, arr);\n      this.postorder(node.right, arr);\n      arr.push(node);\n      return arr;\n    }\n    levelOrder(){\n      const res = [];\n      if(!this.root) return res;\n      const q = [this.root];\n      while(q.length){\n        const n = q.shift();\n        res.push(n);\n        if(n.left) q.push(n.left);\n        if(n.right) q.push(n.right);\n      }\n      return res;\n    }\n\n    height(node=this.root){\n      if(!node) return 0;\n      return 1 + Math.max(this.height(node.left), this.height(node.right));\n    }\n\n    isBalanced(node=this.root){\n      // returns [isBalanced, height]\n      function helper(n){\n        if(!n) return [true, 0];\n        const left = helper(n.left);\n        const right = helper(n.right);\n        const balanced = left[0] && right[0] && Math.abs(left[1] - right[1]) <= 1;\n        return [balanced, 1 + Math.max(left[1], right[1])];\n      }\n      return helper(node)[0];\n    }\n\n    clear(){\n      this.root = null;\n      this.size = 0;\n    }\n\n    // collect nodes in preorder values (for export)\n    exportValues(){\n      return this.preorder().map(n=>n.val);\n    }\n\n    // build tree from array of values (in order, calling insert)\n    static fromArray(vals){\n      const tree = new BST();\n      vals.forEach(v=>tree.insert(v));\n      return tree;\n    }\n  }\n\n  // Visualization\n  const svg = $('svgCanvas');\n  const width = 1200;\n  const height = 520;\n  const hPad = 40;\n  const vSpacing = 68;\n  const nodeRadius = 20;\n\n  let tree = new BST();\n\n  function clearSVG(){\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n  }\n\n  // Layout: assign x,y to nodes based on inorder index and depth\n  function layout(tree){\n    let positions = [];\n    let index = 0;\n    function dfs(node, depth){\n      if(!node) return;\n      dfs(node.left, depth+1);\n      node.x = hPad + index * ((width - 2*hPad) / Math.max(1, tree.size));\n      node.y = 40 + depth * vSpacing;\n      index++;\n      dfs(node.right, depth+1);\n    }\n    // If tree is empty, nothing to do\n    index = 0;\n    dfs(tree.root, 0);\n  }\n\n  // Better layout: use inorder order positions but center by subtree widths to avoid overlap\n  function computePositionsBetter(tree){\n    // postorder compute widths (# of leaves in subtree)\n    function measure(node){\n      if(!node) return 0;\n      if(!node.left && !node.right) {\n        node._width = 1;\n        return 1;\n      }\n      const lw = measure(node.left);\n      const rw = measure(node.right);\n      node._width = Math.max(1, lw + rw);\n      return node._width;\n    }\n    measure(tree.root);\n    // assign x positions based on accumulated widths\n    let cursor = 0;\n    function assign(node, depth){\n      if(!node) return;\n      assign(node.left, depth+1);\n      // average position across its allocated width\n      const span = (node._width);\n      // set x to center of current chunk\n      const leftBound = cursor;\n      cursor += 1;\n      const mid = leftBound + 0.5;\n      // scale to canvas width\n      const usable = width - 2*hPad;\n      const x = hPad + (mid / Math.max(1, Math.max(1, tree.size))) * usable;\n      node.x = x;\n      node.y = 40 + depth * vSpacing;\n      assign(node.right, depth+1);\n    }\n    // fallback to simple layout if size small\n    if(tree.size <= 1){\n      if(tree.root) { tree.root.x = width/2; tree.root.y = 40; }\n    } else {\n      // We'll use inorder-based positioning scaled by (size)\n      let idx = 0;\n      function inorderAssign(n, depth){\n        if(!n) return;\n        inorderAssign(n.left, depth+1);\n        n.x = hPad + idx * ((width - 2*hPad) / (tree.size - 1 || 1));\n        n.y = 40 + depth * vSpacing;\n        idx++;\n        inorderAssign(n.right, depth+1);\n      }\n      inorderAssign(tree.root,0);\n    }\n  }\n\n  function drawTree(tree){\n    clearSVG();\n    if(!tree.root) {\n      // draw placeholder text\n      const text = document.createElementNS(\"http://www.w3.org/2000/svg\",'text');\n      text.setAttribute('x', width/2);\n      text.setAttribute('y', height/2);\n      text.setAttribute('text-anchor','middle');\n      text.setAttribute('fill','#94a3b8');\n      text.setAttribute('font-size','18');\n      text.textContent = 'Tree is empty — insert values to begin';\n      svg.appendChild(text);\n      return;\n    }\n\n    // compute positions\n    computePositionsBetter(tree);\n\n    // draw edges then nodes\n    function drawEdge(from, to){\n      if(!from || !to) return;\n      const line = document.createElementNS(\"http://www.w3.org/2000/svg\",'line');\n      line.setAttribute('x1', from.x);\n      line.setAttribute('y1', from.y + nodeRadius);\n      line.setAttribute('x2', to.x);\n      line.setAttribute('y2', to.y - nodeRadius);\n      line.setAttribute('stroke', '#cfe6ff');\n      line.setAttribute('stroke-width', '2');\n      svg.appendChild(line);\n    }\n\n    // gather edges by traversing\n    function drawEdges(node){\n      if(!node) return;\n      if(node.left) drawEdge(node, node.left);\n      if(node.right) drawEdge(node, node.right);\n      drawEdges(node.left);\n      drawEdges(node.right);\n    }\n    drawEdges(tree.root);\n\n    // nodes: create group with circle + text\n    function createNodeElement(node){\n      const g = document.createElementNS(\"http://www.w3.org/2000/svg\",'g');\n      g.classList.add('node');\n      g.dataset.nodeId = node.id;\n      g.dataset.val = node.val;\n\n      // circle\n      const circle = document.createElementNS(\"http://www.w3.org/2000/svg\",'circle');\n      circle.setAttribute('cx', node.x);\n      circle.setAttribute('cy', node.y);\n      circle.setAttribute('r', nodeRadius);\n      circle.setAttribute('fill', '#2b7cff');\n      circle.setAttribute('stroke', '#eaf4ff');\n      circle.setAttribute('stroke-width', '2');\n      g.appendChild(circle);\n\n      // text\n      const text = document.createElementNS(\"http://www.w3.org/2000/svg\",'text');\n      text.setAttribute('x', node.x);\n      text.setAttribute('y', node.y + 4);\n      text.setAttribute('text-anchor', 'middle');\n      text.textContent = node.val;\n      g.appendChild(text);\n\n      // small tooltip on hover (title)\n      const title = document.createElementNS(\"http://www.w3.org/2000/svg\",'title');\n      title.textContent = 'Value: ' + node.val;\n      g.appendChild(title);\n\n      // position group\n      g.style.transformOrigin = `${node.x}px ${node.y}px`;\n\n      // click to highlight single node\n      g.addEventListener('click', (e) => {\n        e.stopPropagation();\n        highlightNode(node, {flash: true});\n        log(`Clicked node ${node.val}`);\n      });\n\n      svg.appendChild(g);\n    }\n\n    // draw nodes in level-order to keep z-order reasonable\n    const q = [tree.root];\n    while(q.length){\n      const n = q.shift();\n      createNodeElement(n);\n      if(n.left) q.push(n.left);\n      if(n.right) q.push(n.right);\n    }\n  }\n\n  // Highlighting / animation\n  let activeHighlights = new Set();\n  function highlightNode(node, options={color:'#ffb36b', duration:1000, flash:false}){\n    // find svg group by node id\n    const groups = svg.querySelectorAll('g.node');\n    let target = null;\n    for(const g of groups){\n      if(Number(g.dataset.nodeId) === node.id){ target = g; break; }\n    }\n    if(!target) return;\n    const circle = target.querySelector('circle');\n    if(!circle) return;\n\n    const origFill = circle.getAttribute('fill');\n    const origStroke = circle.getAttribute('stroke');\n\n    circle.setAttribute('fill', options.color || '#ffb36b');\n    circle.setAttribute('stroke', '#fff2e6');\n    circle.setAttribute('stroke-width', '3');\n    target.style.transform = 'scale(1.12)';\n\n    if(options.flash){\n      setTimeout(()=> {\n        circle.setAttribute('fill', origFill);\n        circle.setAttribute('stroke', origStroke);\n        circle.setAttribute('stroke-width','2');\n        target.style.transform = '';\n      }, options.duration || 1000);\n    }\n  }\n\n  function clearHighlights(){\n    const groups = svg.querySelectorAll('g.node');\n    groups.forEach(g => {\n      const circle = g.querySelector('circle');\n      if(circle){\n        circle.setAttribute('fill', '#2b7cff');\n        circle.setAttribute('stroke', '#eaf4ff');\n        circle.setAttribute('stroke-width','2');\n      }\n      g.style.transform = '';\n    });\n  }\n\n  // Traversal animation: highlights nodes in order\n  let animHandle = null;\n  function animateTraversal(nodes, speed=650){\n    clearAnimation();\n    if(!nodes || nodes.length===0) return;\n    let i = 0;\n    clearHighlights();\n    log('Traversal start: ' + nodes.map(n=>n.val).join(', '));\n    animHandle = setInterval(()=>{\n      if(i>0){\n        // reset previous\n        const prev = nodes[i-1];\n        // find prev group\n        const gPrev = svg.querySelector(`g.node[data-node-id=\"${prev.id}\"]`);\n        if(gPrev){\n          const c = gPrev.querySelector('circle');\n          if(c){\n            c.setAttribute('fill','#6fb8ff');\n            c.setAttribute('stroke','#eaf4ff');\n            c.setAttribute('stroke-width','2');\n            gPrev.style.transform = 'scale(1.02)';\n            setTimeout(()=> {\n              c.setAttribute('fill','#2b7cff');\n              gPrev.style.transform = '';\n            }, speed/1.5);\n          }\n        }\n      }\n      if(i >= nodes.length){\n        clearAnimation();\n        log('Traversal complete');\n        return;\n      }\n      const node = nodes[i];\n      const g = svg.querySelector(`g.node[data-node-id=\"${node.id}\"]`);\n      if(g){\n        const circle = g.querySelector('circle');\n        circle.setAttribute('fill','#ff9b5c');\n        circle.setAttribute('stroke','#fff4ee');\n        circle.setAttribute('stroke-width','3');\n        g.style.transform = 'scale(1.18)';\n      }\n      i++;\n    }, speed);\n  }\n\n  function clearAnimation(){\n    if(animHandle) clearInterval(animHandle);\n    animHandle = null;\n    setTimeout(()=> clearHighlights(), 50);\n  }\n\n  // Logging\n  const logEl = $('log');\n  function log(msg){\n    const time = new Date().toLocaleTimeString();\n    const line = document.createElement('div');\n    line.textContent = `[${time}] ${msg}`;\n    logEl.appendChild(line);\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  // UI wiring\n  function updateStats(){\n    $('nodeCount').textContent = tree.size;\n    $('treeHeight').textContent = tree.height();\n    $('rootVal').textContent = tree.root ? tree.root.val : '—';\n    $('balanced').textContent = tree.root ? (tree.isBalanced() ? 'Yes' : 'No') : '—';\n  }\n\n  function refresh(){\n    updateStats();\n    drawTree(tree);\n  }\n\n  // Buttons\n  $('insertBtn').addEventListener('click', ()=>{\n    const val = Number($('valueInput').value);\n    if(!Number.isFinite(val)){\n      alert('Enter a numeric value to insert.');\n      return;\n    }\n    const ok = tree.insert(val);\n    if(ok){\n      log('Inserted ' + val);\n      $('valueInput').value = '';\n    } else {\n      log('Ignored duplicate ' + val);\n    }\n    refresh();\n  });\n\n  $('removeBtn').addEventListener('click', ()=>{\n    const val = Number($('valueInput').value);\n    if(!Number.isFinite(val)){\n      alert('Enter a numeric value to remove.');\n      return;\n    }\n    const ok = tree.remove(val);\n    if(ok) log('Removed ' + val);\n    else log('Value not found: ' + val);\n    refresh();\n  });\n\n  $('searchBtn').addEventListener('click', ()=>{\n    const val = Number($('valueInput').value);\n    if(!Number.isFinite(val)){\n      alert('Enter a numeric value to search.');\n      return;\n    }\n    const node = tree.search(val);\n    if(node){\n      highlightNode(node, {color:'#38bdf8', flash:true, duration:900});\n      log('Found ' + val);\n    } else {\n      log('Not found: ' + val);\n    }\n  });\n\n  $('randomBtn').addEventListener('click', ()=>{\n    const n = Number($('countInput').value) || 10;\n    const count = clamp(Math.floor(n),1,50);\n    tree.clear();\n    // generate count unique random ints in range 1..200\n    const set = new Set();\n    while(set.size < count){\n      set.add(Math.floor(Math.random()*200)+1);\n    }\n    Array.from(set).forEach(v => tree.insert(v));\n    log('Randomized with ' + count + ' nodes');\n    refresh();\n  });\n\n  $('clearBtn').addEventListener('click', ()=>{\n    tree.clear();\n    clearAnimation();\n    clearHighlights();\n    log('Tree cleared');\n    refresh();\n  });\n\n  $('preorderBtn').addEventListener('click', ()=>{\n    const nodes = tree.preorder([]);\n    if(nodes.length === 0){ log('Tree empty'); return; }\n    animateTraversal(nodes);\n    log('Preorder: ' + nodes.map(n=>n.val).join(', '));\n  });\n\n  $('inorderBtn').addEventListener('click', ()=>{\n    const nodes = tree.inorder([]);\n    if(nodes.length === 0){ log('Tree empty'); return; }\n    animateTraversal(nodes);\n    log('Inorder: ' + nodes.map(n=>n.val).join(', '));\n  });\n\n  $('postorderBtn').addEventListener('click', ()=>{\n    const nodes = tree.postorder([]);\n    if(nodes.length === 0){ log('Tree empty'); return; }\n    animateTraversal(nodes);\n    log('Postorder: ' + nodes.map(n=>n.val).join(', '));\n  });\n\n  $('levelBtn').addEventListener('click', ()=>{\n    const nodes = tree.levelOrder();\n    if(nodes.length === 0){ log('Tree empty'); return; }\n    animateTraversal(nodes, 550);\n    log('Level-order: ' + nodes.map(n=>n.val).join(', '));\n  });\n\n  $('balanceCheckBtn').addEventListener('click', ()=>{\n    if(!tree.root){ log('Tree empty'); return; }\n    const balanced = tree.isBalanced();\n    log('Balanced? ' + (balanced ? 'Yes' : 'No'));\n    refresh();\n  });\n\n  $('exportBtn').addEventListener('click', ()=>{\n    const data = tree.exportValues();\n    if(data.length === 0){ alert('Tree empty'); return; }\n    const json = JSON.stringify(data);\n    navigator.clipboard?.writeText(json).then(()=> {\n      alert('Preorder values copied to clipboard (JSON). You can recreate the tree by inserting these values in order.');\n    }, ()=>{\n      prompt('Copy this JSON:', json);\n    });\n  });\n\n  $('clearLog').addEventListener('click', ()=>{ logEl.innerHTML=''; });\n\n  $('exampleBtn').addEventListener('click', ()=>{\n    tree.clear();\n    const example = [50,30,70,20,40,60,80];\n    example.forEach(v=>tree.insert(v));\n    log('Loaded example tree: ' + example.join(', '));\n    refresh();\n  });\n\n  // initial render\n  refresh();\n\n  // clicking background clears highlights and stops animation\n  svg.addEventListener('click', () => {\n    clearAnimation();\n    clearHighlights();\n  });\n\n  // keyboard shortcuts: Enter to insert, Delete to remove\n  document.addEventListener('keydown', (e)=>{\n    if(e.key === 'Enter'){\n      $('insertBtn').click();\n    } else if(e.key === 'Delete'){\n      $('removeBtn').click();\n    }\n  });\n\n  // allow building tree from exported JSON by pasting into value input and pressing a small handler\n  // (support paste into valueInput as comma-separated or JSON)\n  $('valueInput').addEventListener('keydown', (e)=>{\n    if(e.key === 'v' && (e.ctrlKey || e.metaKey)){\n      // noop; allow paste\n    }\n  });\n\n  // small helper: if user types JSON array into value input and clicks insert, interpret as batch\n  $('insertBtn').addEventListener('mousedown', (e)=>{\n    // no-op prepare\n  });\n  $('insertBtn').addEventListener('click', ()=>{\n    const raw = $('valueInput').value.trim();\n    if(!raw) return;\n    // detect JSON array like \"[1,2,3]\" or comma separated \"1,2,3\"\n    try {\n      if(raw.startsWith('[') && raw.endsWith(']')){\n        const arr = JSON.parse(raw);\n        if(Array.isArray(arr)){\n          arr.forEach(v=> {\n            const num = Number(v);\n            if(Number.isFinite(num)) tree.insert(num);\n          });\n          $('valueInput').value = '';\n          log('Inserted array of values from JSON');\n          refresh();\n          return;\n        }\n      }\n    } catch(err){\n      // ignore\n    }\n    // otherwise normal single value handled earlier\n  });\n\n  // small touch: when window resizes, re-render positions to maintain layout\n  window.addEventListener('resize', debounce(()=> {\n    refresh();\n  }, 200));\n\n  // debounce utility\n  function debounce(fn, wait){\n    let t;\n    return function(...args){\n      clearTimeout(t);\n      t = setTimeout(()=>fn.apply(this,args), wait);\n    };\n  }\n\n})();\n</script>\n</body>\n</html>"
