    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Authentication Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f5f7fa;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    color: #0275d8;\n  }\n  #loginForm, #welcomeMessage {\n    max-width: 350px;\n    margin: 1.5rem auto;\n    background: white;\n    padding: 1.5rem;\n    border-radius: 8px;\n    box-shadow: 0 4px 10px rgba(0,0,0,0.1);\n  }\n  label {\n    display: block;\n    margin-bottom: .25rem;\n    font-weight: bold;\n  }\n  input[type=\"text\"],\n  input[type=\"password\"] {\n    width: 100%;\n    padding: .5rem;\n    margin-bottom: 1rem;\n    border: 1px solid #ccc;\n    border-radius: 4px;\n  }\n  button {\n    background-color: #0275d8;\n    border: none;\n    padding: 0.6rem 1.2rem;\n    color: white;\n    font-weight: bold;\n    border-radius: 4px;\n    cursor: pointer;\n    width: 100%;\n  }\n  button:hover {\n    background-color: #025aa5;\n  }\n  #errorMessage {\n    color: #d9534f;\n    margin-bottom: 1rem;\n    text-align: center;\n  }\n  #logoutBtn {\n    background-color: #d9534f;\n    margin-top: 1rem;\n  }\n  #logoutBtn:hover {\n    background-color: #c9302c;\n  }\n  .note {\n    font-size: 0.85rem;\n    color: #555;\n    margin-top: 0.5rem;\n  }\n</style>\n</head>\n<body>\n\n<h1>Simple Authentication Demo</h1>\n\n<div id=\"loginForm\">\n  <div id=\"errorMessage\"></div>\n  <label for=\"username\">Username:</label>\n  <input type=\"text\" id=\"username\" autocomplete=\"username\" />\n  <label for=\"password\">Password:</label>\n  <input type=\"password\" id=\"password\" autocomplete=\"current-password\" />\n  <button id=\"loginBtn\">Login</button>\n  <div class=\"note\">Try: <strong>user123 / pass123</strong></div>\n</div>\n\n<div id=\"welcomeMessage\" style=\"display:none;\">\n  <h2>Welcome, <span id=\"userDisplay\"></span>!</h2>\n  <p>You are now logged in.</p>\n  <button id=\"logoutBtn\">Logout</button>\n</div>\n\n<script>\n  /*\n   * Authentication Demo:\n   * This example demonstrates a very basic authentication flow on the client side.\n   * WARNING: This is NOT secure for real production use.\n   * It uses a hardcoded username/password and stores a token in sessionStorage\n   * just to show the concept of signing in, signing out and state persistence.\n   */\n\n  (function() {\n    // Hardcoded user \"database\"\n    const USERS = {\n      'user123': 'pass123'\n    };\n\n    // Elements\n    const loginForm = document.getElementById('loginForm');\n    const welcomeMessage = document.getElementById('welcomeMessage');\n    const loginBtn = document.getElementById('loginBtn');\n    const logoutBtn = document.getElementById('logoutBtn');\n    const errorMessage = document.getElementById('errorMessage');\n    const userDisplay = document.getElementById('userDisplay');\n\n    // Simple token generator for demo (not secure)\n    function generateToken(username) {\n      return btoa(username + ':' + new Date().getTime());\n    }\n\n    // Check if user is authenticated on page load\n    function checkAuth() {\n      const token = sessionStorage.getItem('authToken');\n      const user = sessionStorage.getItem('authUser');\n      if(token && user) {\n        showWelcome(user);\n      } else {\n        showLogin();\n      }\n    }\n\n    // Show login form\n    function showLogin() {\n      welcomeMessage.style.display = 'none';\n      loginForm.style.display = 'block';\n      errorMessage.textContent = '';\n      document.getElementById('username').value = '';\n      document.getElementById('password').value = '';\n      document.getElementById('username').focus();\n    }\n\n    // Show welcome message after login\n    function showWelcome(username) {\n      userDisplay.textContent = username;\n      loginForm.style.display = 'none';\n      welcomeMessage.style.display = 'block';\n    }\n\n    // Handle login attempt\n    function login() {\n      const username = document.getElementById('username').value.trim();\n      const password = document.getElementById('password').value;\n\n      if(!username || !password) {\n        errorMessage.textContent = 'Please enter both username and password.';\n        return;\n      }\n\n      if(USERS[username] && USERS[username] === password) {\n        // Auth success: store token and user in sessionStorage\n        const token = generateToken(username);\n        sessionStorage.setItem('authToken', token);\n        sessionStorage.setItem('authUser', username);\n        showWelcome(username);\n      } else {\n        errorMessage.textContent = 'Invalid username or password.';\n      }\n    }\n\n    // Handle logout\n    function logout() {\n      sessionStorage.removeItem('authToken');\n      sessionStorage.removeItem('authUser');\n      showLogin();\n    }\n\n    // Event listeners\n    loginBtn.addEventListener('click', login);\n    logoutBtn.addEventListener('click', logout);\n\n    // Also allow Enter key to submit login form\n    loginForm.addEventListener('keyup', function(e) {\n      if(e.key === 'Enter') {\n        login();\n      }\n    });\n\n    // On load check if already authenticated\n    checkAuth();\n  })();\n</script>\n\n</body>\n</html>"
