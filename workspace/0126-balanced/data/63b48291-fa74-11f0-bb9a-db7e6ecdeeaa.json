  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Neural Networks Demonstration</title>\n<style>\n  body {\n    font-family: \"Segoe UI\", Tahoma, Geneva, Verdana, sans-serif;\n    margin: 20px;\n    background: #f9f9f9;\n  }\n  h1 {\n    text-align: center;\n    color: #222;\n  }\n  #networkCanvas {\n    background: #fff;\n    display: block;\n    margin: 20px auto;\n    border: 1px solid #ccc;\n    border-radius: 8px;\n  }\n  #controls {\n    max-width: 600px;\n    margin: 0 auto 20px;\n    text-align: center;\n  }\n  label {\n    margin: 0 8px;\n    font-size: 14px;\n  }\n  input[type=\"range\"] {\n    vertical-align: middle;\n  }\n  button {\n    margin-top: 10px;\n    padding: 8px 16px;\n    font-size: 16px;\n    cursor: pointer;\n  }\n  #info {\n    max-width: 600px;\n    margin: 0 auto;\n    font-size: 14px;\n    line-height: 1.5;\n    color: #333;\n    background: #fff;\n    padding: 15px;\n    border-radius: 8px;\n    box-shadow: 0px 0px 10px #ccc;\n  }\n  #outputValue {\n    font-weight: bold;\n    color: #007acc;\n  }\n</style>\n</head>\n<body>\n<h1>Neural Networks: Interactive Demo</h1>\n\n<div id=\"controls\">\n  <div>\n    <label for=\"input0\">Input 0:</label>\n    <input type=\"range\" id=\"input0\" min=\"0\" max=\"1\" step=\"0.01\" value=\"0.5\" />\n    <span id=\"input0Val\">0.50</span>\n  </div>\n  <div>\n    <label for=\"input1\">Input 1:</label>\n    <input type=\"range\" id=\"input1\" min=\"0\" max=\"1\" step=\"0.01\" value=\"0.5\" />\n    <span id=\"input1Val\">0.50</span>\n  </div>\n  <button id=\"trainBtn\">Train Network</button>\n  <button id=\"resetBtn\">Reset Network</button>\n</div>\n\n<canvas id=\"networkCanvas\" width=\"600\" height=\"350\" aria-label=\"Neural network visualization\"></canvas>\n\n<div id=\"info\">\n<p>\n  This is a simple demonstration of a feedforward neural network with <b>2 input neurons</b>, <b>2 hidden neurons</b>, and <b>1 output neuron</b>.\n  Use the sliders above to change input values. The network computes its output and displays it below.\n</p>\n<p>\n  Clicking <b>Train Network</b> runs a few iterations of training using the <b>AND logic gate</b> as the target function.\n  Watch how the network adjusts its weights to correctly model the AND gate.\n</p>\n<p>\n  The weights are visualized as connections between neurons; thicker and darker lines mean stronger weights.\n  Hover over neurons to see their current activation values.\n</p>\n<p>\n  <b>Output value:</b> <span id=\"outputValue\">-</span>\n</p>\n</div>\n\n<script>\n// Neural Network structure:\n// 2 input neurons, 2 hidden neurons, 1 output neuron\n// Activation function: Sigmoid\n// Training task: learn AND gate\n\nclass NeuralNetwork {\n  constructor(inputSize, hiddenSize, outputSize) {\n    this.inputSize = inputSize;\n    this.hiddenSize = hiddenSize;\n    this.outputSize = outputSize;\n\n    // Initialize weights with small random values\n    this.weightsInputHidden = new Array(inputSize).fill(0).map(() => \n      new Array(hiddenSize).fill(0).map(() => Math.random() * 2 -1)\n    );\n    this.weightsHiddenOutput = new Array(hiddenSize).fill(0).map(() => \n      new Array(outputSize).fill(0).map(() => Math.random() * 2 -1)\n    );\n\n    // Biases\n    this.biasHidden = new Array(hiddenSize).fill(0).map(() => Math.random()*2 -1);\n    this.biasOutput = new Array(outputSize).fill(0).map(() => Math.random()*2 -1);\n\n    // Placeholders for activations\n    this.input = new Array(inputSize).fill(0);\n    this.hidden = new Array(hiddenSize).fill(0);\n    this.output = new Array(outputSize).fill(0);\n\n    // Learning rate\n    this.learningRate = 0.5;\n  }\n\n  sigmoid(x) {\n    return 1 / (1 + Math.exp(-x));\n  }\n  dsigmoid(y) {\n    // derivative of sigmoid given output y\n    return y * (1 - y);\n  }\n\n  // Feed forward\n  forward(inputArray) {\n    this.input = inputArray.slice();\n\n    // Calculate hidden layer activations\n    for(let i=0; i<this.hiddenSize; i++) {\n      let sum = this.biasHidden[i];\n      for(let j=0; j<this.inputSize; j++) {\n        sum += this.input[j] * this.weightsInputHidden[j][i];\n      }\n      this.hidden[i] = this.sigmoid(sum);\n    }\n    // Calculate output layer activations\n    for(let i=0; i<this.outputSize; i++) {\n      let sum = this.biasOutput[i];\n      for(let j=0; j<this.hiddenSize; j++) {\n        sum += this.hidden[j] * this.weightsHiddenOutput[j][i];\n      }\n      this.output[i] = this.sigmoid(sum);\n    }\n    return this.output.slice();\n  }\n\n  // Train with backpropagation\n  train(inputArray, targetArray) {\n    this.forward(inputArray);\n\n    // Calculate output errors\n    let outputErrors = new Array(this.outputSize);\n    for(let i=0; i<this.outputSize; i++) {\n      outputErrors[i] = targetArray[i] - this.output[i];\n    }\n\n    // Calculate gradients for output layer\n    let gradients = new Array(this.outputSize);\n    for(let i=0; i<this.outputSize; i++) {\n      gradients[i] = outputErrors[i] * this.dsigmoid(this.output[i]) * this.learningRate;\n    }\n\n    // Calculate hidden->output weight deltas\n    let weightsHiddenOutputDeltas = new Array(this.hiddenSize).fill(0).map(() => new Array(this.outputSize).fill(0));\n    for(let i=0; i<this.hiddenSize; i++) {\n      for(let j=0; j<this.outputSize; j++) {\n        weightsHiddenOutputDeltas[i][j] = gradients[j] * this.hidden[i];\n      }\n    }\n\n    // Update weightsHiddenOutput and biasOutput\n    for(let i=0; i<this.hiddenSize; i++) {\n      for(let j=0; j<this.outputSize; j++) {\n        this.weightsHiddenOutput[i][j] += weightsHiddenOutputDeltas[i][j];\n      }\n    }\n    for(let i=0; i<this.outputSize; i++) {\n      this.biasOutput[i] += gradients[i];\n    }\n\n    // Calculate hidden layer errors\n    let hiddenErrors = new Array(this.hiddenSize).fill(0);\n    for(let i=0; i<this.hiddenSize; i++) {\n      let errorSum = 0;\n      for(let j=0; j<this.outputSize; j++) {\n        errorSum += this.weightsHiddenOutput[i][j] * outputErrors[j];\n      }\n      hiddenErrors[i] = errorSum;\n    }\n\n    // Calculate hidden gradients\n    let hiddenGradients = new Array(this.hiddenSize);\n    for(let i=0; i<this.hiddenSize; i++) {\n      hiddenGradients[i] = hiddenErrors[i] * this.dsigmoid(this.hidden[i]) * this.learningRate;\n    }\n\n    // Calculate input->hidden weight deltas\n    let weightsInputHiddenDeltas = new Array(this.inputSize).fill(0).map(() => new Array(this.hiddenSize).fill(0));\n    for(let i=0; i<this.inputSize; i++) {\n      for(let j=0; j<this.hiddenSize; j++) {\n        weightsInputHiddenDeltas[i][j] = hiddenGradients[j] * this.input[i];\n      }\n    }\n\n    // Update weightsInputHidden and biasHidden\n    for(let i=0; i<this.inputSize; i++) {\n      for(let j=0; j<this.hiddenSize; j++) {\n        this.weightsInputHidden[i][j] += weightsInputHiddenDeltas[i][j];\n      }\n    }\n    for(let i=0; i<this.hiddenSize; i++) {\n      this.biasHidden[i] += hiddenGradients[i];\n    }\n  }\n}\n\n// Visualization & Interaction\n\nconst canvas = document.getElementById(\"networkCanvas\");\nconst ctx = canvas.getContext(\"2d\");\n\nconst inputSliders = [document.getElementById('input0'), document.getElementById('input1')];\nconst inputVals = [document.getElementById('input0Val'), document.getElementById('input1Val')];\nconst outputValDisplay = document.getElementById('outputValue');\n\nlet nn = new NeuralNetwork(2, 2, 1);\n\n// Positions for neurons to draw\nconst neuronRadius = 20;\nconst layerX = {\n  input: 100,\n  hidden: 300,\n  output: 500\n};\nconst layerYPositions = {\n  input: [120, 230],\n  hidden: [120, 230],\n  output: [175]\n};\n\n// Store neuron activations for hover\nlet neurons = {\n  input: [0, 0],\n  hidden: [0, 0],\n  output: [0]\n};\n// Store weights for drawing connections\n// nn.weightsInputHidden and nn.weightsHiddenOutput\n\nfunction drawNeuron(x, y, activation, label, isHover = false) {\n  // Color intensity based on activation (0..1)\n  let colorIntensity = Math.floor(activation * 200 + 55);\n  let fillColor = `rgb(${255 - colorIntensity},${colorIntensity},${150})`;\n\n  ctx.beginPath();\n  ctx.arc(x, y, neuronRadius, 0, Math.PI*2);\n  ctx.fillStyle = fillColor;\n  ctx.shadowColor = 'rgba(0,0,0,0.3)';\n  ctx.shadowBlur = isHover? 10 : 5;\n  ctx.fill();\n  ctx.shadowBlur = 0;\n\n  ctx.strokeStyle = '#444';\n  ctx.lineWidth = isHover? 4 : 2;\n  ctx.stroke();\n\n  // Label\n  ctx.fillStyle = \"#000\";\n  ctx.font = \"14px Arial\";\n  ctx.textAlign = \"center\";\n  ctx.textBaseline = \"middle\";\n  ctx.fillText(label, x, y);\n\n  // Activation text inside neuron (rounded)\n  ctx.fillStyle = \"white\";\n  ctx.font = \"12px monospace\";\n  ctx.fillText(activation.toFixed(2), x, y + neuronRadius + 15);\n}\n\nfunction drawWeight(x1, y1, x2, y2, weight) {\n  // Map weight (-1 to 1) to line width and color\n  let absWeight = Math.min(Math.abs(weight), 1);\n  let lineWidth = 1 + absWeight * 7;\n  let alpha = 0.3 + absWeight * 0.7;\n\n  // Color: positive (green), negative (red)\n  let color = weight >=0 ? `rgba(0, 170, 50, ${alpha.toFixed(2)})` : `rgba(200, 0, 0, ${alpha.toFixed(2)})`;\n\n  ctx.strokeStyle = color;\n  ctx.lineWidth = lineWidth;\n  ctx.beginPath();\n\n  // Draw line with small curve to distinguish layers\n  const cpX = (x1 + x2) / 2;\n  const cpY = (y1 + y2) / 2 + (weight >= 0 ? -15 : 15);\n  ctx.moveTo(x1, y1);\n  ctx.quadraticCurveTo(cpX, cpY, x2, y2);\n  ctx.stroke();\n}\n\n// Check if mouse is over a neuron for tooltip highlight and info\nfunction isPointInCircle(px, py, cx, cy, r) {\n  let dx = px - cx;\n  let dy = py - cy;\n  return dx*dx + dy*dy <= r*r;\n}\n\n// Draw the entire network\nfunction drawNetwork(hoveredNeuron = null) {\n  ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n  // Draw connections input->hidden\n  for(let i=0; i<nn.inputSize; i++) {\n    for(let j=0; j<nn.hiddenSize; j++) {\n      drawWeight(layerX.input + neuronRadius, layerYPositions.input[i], layerX.hidden - neuronRadius, layerYPositions.hidden[j], nn.weightsInputHidden[i][j]);\n    }\n  }\n  // Draw connections hidden->output\n  for(let i=0; i<nn.hiddenSize; i++) {\n    for(let j=0; j<nn.outputSize; j++) {\n      drawWeight(layerX.hidden + neuronRadius, layerYPositions.hidden[i], layerX.output - neuronRadius, layerYPositions.output[j], nn.weightsHiddenOutput[i][j]);\n    }\n  }\n\n  // Draw neurons - input layer\n  for(let i=0; i<nn.inputSize; i++) {\n    drawNeuron(layerX.input, layerYPositions.input[i], neurons.input[i], `In${i}`,\n      hoveredNeuron && hoveredNeuron.type === 'input' && hoveredNeuron.index === i);\n  }\n  // Hidden layer\n  for(let i=0; i<nn.hiddenSize; i++) {\n    drawNeuron(layerX.hidden, layerYPositions.hidden[i], neurons.hidden[i], `H${i}`,\n      hoveredNeuron && hoveredNeuron.type === 'hidden' && hoveredNeuron.index === i);\n  }\n  // Output layer\n  for(let i=0; i<nn.outputSize; i++) {\n    drawNeuron(layerX.output, layerYPositions.output[i], neurons.output[i], `Out${i}`,\n      hoveredNeuron && hoveredNeuron.type === 'output' && hoveredNeuron.index === i);\n  }\n}\n\n// Update activations from current nn state\nfunction updateActivations(inputArray) {\n  const output = nn.forward(inputArray);\n  neurons.input = inputArray.slice();\n  neurons.hidden = nn.hidden.slice();\n  neurons.output = nn.output.slice();\n  outputValDisplay.textContent = neurons.output[0].toFixed(3);\n  drawNetwork();\n}\n\n// Event handling for input sliders\ninputSliders.forEach((slider, i) => {\n  slider.addEventListener('input', () => {\n    inputVals[i].textContent = parseFloat(slider.value).toFixed(2);\n    let inputs = inputSliders.map(s => parseFloat(s.value));\n    updateActivations(inputs);\n  });\n});\n\n// Initial draw with default inputs\nupdateActivations(inputSliders.map(s => parseFloat(s.value)));\n\n// Handle mouse hover on neurons for highlight and tooltip\ncanvas.addEventListener('mousemove', (e) => {\n  const rect = canvas.getBoundingClientRect();\n  const mouseX = e.clientX - rect.left;\n  const mouseY = e.clientY - rect.top;\n\n  // Check neurons to hover\n  let hoveredNeuron = null;\n  function checkHover(type, positions) {\n    for(let i=0; i<positions.length; i++) {\n      let nx = layerX[type];\n      let ny = positions[i];\n      if(isPointInCircle(mouseX, mouseY, nx, ny, neuronRadius)){\n        hoveredNeuron = {type:type, index:i};\n        break;\n      }\n    }\n  }\n  checkHover('input', layerYPositions.input);\n  if(!hoveredNeuron) checkHover('hidden', layerYPositions.hidden);\n  if(!hoveredNeuron) checkHover('output', layerYPositions.output);\n\n  if(hoveredNeuron) {\n    // Redraw network with highlight\n    drawNetwork(hoveredNeuron);\n\n    // Show tooltip near mouse\n    showTooltip(e.clientX, e.clientY, hoveredNeuron);\n  } else {\n    drawNetwork();\n    hideTooltip();\n  }\n});\n\ncanvas.addEventListener('mouseleave', e => {\n  drawNetwork();\n  hideTooltip();\n});\n\n// Tooltip for neuron activation details\nlet tooltipDiv = document.createElement('div');\ntooltipDiv.style.position = 'fixed';\ntooltipDiv.style.pointerEvents = 'none';\ntooltipDiv.style.padding = '6px 10px';\ntooltipDiv.style.background = 'rgba(0,0,0,0.75)';\ntooltipDiv.style.color = 'white';\ntooltipDiv.style.borderRadius = '5px';\ntooltipDiv.style.fontSize = '13px';\ntooltipDiv.style.fontFamily = 'monospace';\ntooltipDiv.style.display = 'none';\ntooltipDiv.style.zIndex = '1000';\ndocument.body.appendChild(tooltipDiv);\n\nfunction showTooltip(x, y, neuron) {\n  let label = \"\";\n  let val = 0;\n  if (neuron.type === \"input\") {\n    label = `Input ${neuron.index}`;\n    val = neurons.input[neuron.index];\n  } else if (neuron.type === \"hidden\") {\n    label = `Hidden ${neuron.index}`;\n    val = neurons.hidden[neuron.index];\n  } else if (neuron.type === \"output\") {\n    label = `Output ${neuron.index}`;\n    val = neurons.output[neuron.index];\n  }\n  tooltipDiv.innerHTML = `${label}<br>Activation: ${val.toFixed(3)}`;\n  tooltipDiv.style.left = (x + 15) + 'px';\n  tooltipDiv.style.top = (y + 15) + 'px';\n  tooltipDiv.style.display = 'block';\n}\nfunction hideTooltip() {\n  tooltipDiv.style.display = 'none';\n}\n\n// Training functionality\nconst trainBtn = document.getElementById('trainBtn');\nconst resetBtn = document.getElementById('resetBtn');\n\nlet training = false;\n\ntrainBtn.addEventListener('click', () => {\n  if(training) return;\n  training = true;\n  trainBtn.disabled = true;\n  resetBtn.disabled = true;\n\n  // Training data for AND gate\n  // Inputs: [0,0],[0,1],[1,0],[1,1]\n  // Targets: [0],[0],[0],[1]\n  const trainingData = [\n    {input:[0,0], target:[0]},\n    {input:[0,1], target:[0]},\n    {input:[1,0], target:[0]},\n    {input:[1,1], target:[1]}\n  ];\n  let epochs = 2000;\n  let epoch = 0;\n\n  function trainingStep() {\n    for(let i=0; i<trainingData.length; i++) {\n      let data = trainingData[i];\n      nn.train(data.input, data.target);\n    }\n    epoch++;\n    // Show progress updating UI output with input sliders set to all 4 cases cycling\n    const testInput = trainingData[epoch % trainingData.length].input;\n    inputSliders.forEach((s,i) => {\n      s.value = testInput[i];\n      inputVals[i].textContent = testInput[i].toFixed(2);\n    });\n    updateActivations(testInput);\n\n    if(epoch < epochs) {\n      requestAnimationFrame(trainingStep);\n    } else {\n      training = false;\n      trainBtn.disabled = false;\n      resetBtn.disabled = false;\n      alert(\"Training completed! The network has learned the AND gate.\");\n    }\n  }\n  trainingStep();\n});\n\nresetBtn.addEventListener('click', () => {\n  if(training) return;\n  nn = new NeuralNetwork(2, 2, 1);\n  inputSliders.forEach((s,i) => {\n    s.value = 0.5;\n    inputVals[i].textContent = \"0.50\";\n  });\n  updateActivations([0.5,0.5]);\n});\n\n</script>\n</body>\n</html>"
  },
