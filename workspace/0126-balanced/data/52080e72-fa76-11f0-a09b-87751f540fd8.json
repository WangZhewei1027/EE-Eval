    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Queue</title>\n</head>\n<body>\n    <h1>Queue Example</h1>\n    <p id=\"message\"></p>\n    <button id=\"enqueue\">Enqueue</button>\n    <button id=\"dequeue\">Dequeue</button>\n    <button id=\"peek\">Peek</button>\n    <button id=\"clear\">Clear</button>\n\n    <script>\n        let queue = [];\n\n        function enqueue(item) {\n            queue.push(item);\n            updateMessage();\n        }\n\n        function dequeue() {\n            if (queue.length === 0) {\n                updateMessage(\"Queue is empty.\");\n            } else {\n                let item = queue.shift();\n                updateMessage(item);\n            }\n        }\n\n        function peek() {\n            if (queue.length === 0) {\n                updateMessage(\"Queue is empty.\");\n            } else {\n                let item = queue[0];\n                updateMessage(item);\n            }\n        }\n\n        function clear() {\n            queue = [];\n            updateMessage(\"Queue cleared.\");\n        }\n\n        function updateMessage(item) {\n            document.getElementById(\"message\").innerHTML = item;\n        }\n\n        document.getElementById(\"enqueue\").addEventListener(\"click\", enqueue);\n        document.getElementById(\"dequeue\").addEventListener(\"click\", dequeue);\n        document.getElementById(\"peek\").addEventListener(\"click\", peek);\n        document.getElementById(\"clear\").addEventListener(\"click\", clear);\n    </script>\n</body>\n</html>"
  },
