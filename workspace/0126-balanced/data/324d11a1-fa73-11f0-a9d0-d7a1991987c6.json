    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Priority Queue Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n        }\n        h1 {\n            text-align: center;\n        }\n        #queueContainer {\n            margin-top: 20px;\n        }\n        #queueList {\n            list-style-type: none;\n            padding: 0;\n        }\n        #queueList li {\n            background-color: #f4f4f4;\n            margin: 5px 0;\n            padding: 10px;\n            border-radius: 3px;\n            display: flex;\n            justify-content: space-between;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Priority Queue Demonstration</h1>\n    \n    <div>\n        <label for=\"item\">Add Item:</label>\n        <input type=\"text\" id=\"item\" placeholder=\"Item (e.g., Task1)\" />\n        <label for=\"priority\">Priority:</label>\n        <input type=\"number\" id=\"priority\" min=\"1\" placeholder=\"Priority (a number)\" />\n        <button onclick=\"enqueue()\">Add to Queue</button>\n    </div>\n\n    <div id=\"queueContainer\">\n        <h3>Current Priority Queue</h3>\n        <ul id=\"queueList\"></ul>\n    </div>\n\n    <button onclick=\"dequeue()\">Process Next Item</button>\n    \n    <script>\n        class PriorityQueue {\n            constructor() {\n                this.elements = [];\n            }\n\n            isEmpty() {\n                return this.elements.length === 0;\n            }\n\n            enqueue(item, priority) {\n                this.elements.push({ item, priority });\n                this.elements.sort((a, b) => a.priority - b.priority);\n            }\n\n            dequeue() {\n                return this.elements.shift();\n            }\n\n            peek() {\n                return this.elements[0];\n            }\n\n            getQueue() {\n                return this.elements;\n            }\n        }\n\n        const queue = new PriorityQueue();\n\n        function updateQueueUI() {\n            const queueList = document.getElementById('queueList');\n            queueList.innerHTML = '';\n            const elements = queue.getQueue();\n            elements.forEach(element => {\n                const li = document.createElement('li');\n                li.textContent = `${element.item} (Priority: ${element.priority})`;\n                queueList.appendChild(li);\n            });\n        }\n\n        function enqueue() {\n            const itemInput = document.getElementById('item');\n            const priorityInput = document.getElementById('priority');\n            const item = itemInput.value.trim();\n            const priority = parseInt(priorityInput.value);\n\n            if (item && !isNaN(priority)) {\n                queue.enqueue(item, priority);\n                updateQueueUI();\n                itemInput.value = '';\n                priorityInput.value = '';\n            } else {\n                alert('Please enter a valid item and priority.');\n            }\n        }\n\n        function dequeue() {\n            if (!queue.isEmpty()) {\n                const processed = queue.dequeue();\n                alert(`Processed: ${processed.item} (Priority: ${processed.priority})`);\n                updateQueueUI();\n            } else {\n                alert('The queue is empty!');\n            }\n        }\n    </script>\n</body>\n</html>"
