    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Interactive Git Concept Demo</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n  :root{\n    --bg:#0b1220;\n    --panel:#0f1724;\n    --accent:#7cc6ff;\n    --muted:#94a3b8;\n    --ok:#7ee787;\n    --danger:#ff7b7b;\n    --glass: rgba(255,255,255,0.03);\n    font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n  html,body{height:100%;margin:0;background:linear-gradient(180deg,#071020 0%, #071826 60%);color:#e6eef8}\n  .app{display:flex;gap:16px;padding:20px;box-sizing:border-box;height:100%}\n  .left, .right{background:var(--panel);border-radius:10px;padding:16px;box-shadow:0 6px 30px rgba(2,6,23,0.6)}\n  .left{width:420px;flex-shrink:0;display:flex;flex-direction:column;gap:12px}\n  .right{flex:1;display:flex;flex-direction:column;gap:12px}\n  h1{font-size:18px;margin:0 0 8px 0;color:var(--accent)}\n  .subtitle{font-size:12px;color:var(--muted);margin-bottom:6px}\n  .panel-row{display:flex;gap:8px;align-items:center}\n  button{background:linear-gradient(180deg,rgba(255,255,255,0.02),transparent);border:1px solid rgba(255,255,255,0.04);color:var(--accent);padding:8px 10px;border-radius:8px;cursor:pointer}\n  button.secondary{color:var(--muted);border-color:rgba(255,255,255,0.02);background:transparent}\n  .small{font-size:12px;padding:6px 8px;border-radius:6px}\n  .info{background:var(--glass);padding:10px;border-radius:8px;color:var(--muted);font-size:13px}\n  .repo-status{display:flex;gap:8px;align-items:center;flex-wrap:wrap}\n  .pill{background:rgba(255,255,255,0.03);padding:6px 8px;border-radius:999px;font-size:13px;color:var(--muted);display:inline-flex;gap:8px;align-items:center}\n  .pill .dot{width:10px;height:10px;border-radius:50%;}\n  .dot.branch{background:var(--accent)} .dot.clean{background:var(--ok)} .dot.dirty{background:var(--danger)}\n  .editor{display:flex;gap:12px;height:520px}\n  .files{width:320px;background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent);border-radius:8px;padding:10px;box-sizing:border-box;overflow:auto}\n  .files h3{margin:0 0 8px 0;font-size:14px;color:var(--muted)}\n  .file-item{display:flex;align-items:center;gap:8px;padding:6px;border-radius:6px;margin-bottom:6px;background:rgba(255,255,255,0.01)}\n  .file-item .name{flex:1;font-size:13px;color:#eaf4ff}\n  .file-actions button{padding:4px 6px;font-size:12px}\n  .editor-area{flex:1;display:flex;flex-direction:column;gap:8px}\n  textarea{width:100%;height:100%;resize:none;background:transparent;border:1px dashed rgba(255,255,255,0.04);border-radius:8px;padding:10px;color:#dff5ff;font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Courier New\", monospace;font-size:13px}\n  .staging{background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);padding:10px;border-radius:8px}\n  .stage-list{display:flex;flex-direction:column;gap:6px;max-height:140px;overflow:auto}\n  .stage-item{display:flex;justify-content:space-between;gap:8px;padding:6px;border-radius:6px;background:rgba(255,255,255,0.01)}\n  .commit-box{display:flex;gap:8px;align-items:center}\n  .commit-msg{flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.03);background:transparent;color:#dff5ff}\n  .branches{display:flex;gap:8px;flex-wrap:wrap}\n  .branch-pill{padding:6px 8px;border-radius:999px;background:rgba(255,255,255,0.02);cursor:pointer;border:1px solid rgba(255,255,255,0.02)}\n  .branch-pill.current{border-color:var(--accent);box-shadow:0 4px 16px rgba(124,198,255,0.08)}\n  .graph{background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);padding:10px;border-radius:8px;max-height:240px;overflow:auto}\n  .commit-node{display:flex;align-items:center;gap:8px;padding:6px;border-radius:6px;margin-bottom:6px;background:rgba(255,255,255,0.01);cursor:pointer}\n  .commit-id{font-family:ui-monospace, monospace;color:var(--muted);font-size:12px}\n  .commit-msg-line{font-size:13px;color:#eaf4ff}\n  .parents{font-size:12px;color:var(--muted)}\n  .log{background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);padding:10px;border-radius:8px;overflow:auto;height:200px}\n  .conflict{background:linear-gradient(180deg,#2b1b1b, #341a1a);padding:6px;border-radius:6px;border:1px solid rgba(255,0,0,0.08);color:var(--danger)}\n  .muted{color:var(--muted);font-size:13px}\n  .flex-between{display:flex;justify-content:space-between;align-items:center}\n  .center{display:flex;align-items:center;gap:8px}\n  .hint{font-size:12px;color:var(--muted)}\n  a.link{color:var(--accent);text-decoration:none}\n  footer{font-size:12px;color:var(--muted);text-align:center;margin-top:8px}\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <div class=\"left\">\n    <div>\n      <h1>Git: Interactive Concept Demo</h1>\n      <div class=\"subtitle\">A simplified, educational simulation of Git: working directory, index (staging), commits, branches and merges.</div>\n    </div>\n\n    <div class=\"info\">\n      <div class=\"repo-status\">\n        <div class=\"pill\"><span class=\"dot branch\" title=\"current branch\"></span> <span id=\"currentBranch\">-</span></div>\n        <div class=\"pill\"><span class=\"dot clean\" id=\"cleanDot\"></span> <span id=\"statusText\">clean</span></div>\n        <div class=\"pill\"><span class=\"dot\" style=\"background:transparent\"></span> HEAD: <span id=\"headId\" style=\"margin-left:6px;font-family:ui-monospace,monospace;color:#dff5ff\"></span></div>\n      </div>\n      <div style=\"margin-top:8px\" class=\"muted\">Click commits in the graph to inspect. You can create branches, checkout, edit files, stage and commit. Try creating a branch then merging it back to see conflicts and resolutions.</div>\n    </div>\n\n    <div>\n      <div class=\"flex-between\"><div class=\"subtitle\">Branches</div>\n        <div><button id=\"btnNewBranch\" class=\"small\">New</button> <button id=\"btnCheckout\" class=\"small secondary\">Checkout</button></div>\n      </div>\n      <div class=\"branches\" id=\"branchesList\" style=\"margin-top:8px\"></div>\n      <div style=\"margin-top:8px\" class=\"hint\">Create a branch from the current commit, then switch to it and make changes. Merge will attempt a 3-way merge and show conflicts inline.</div>\n    </div>\n\n    <div>\n      <div class=\"flex-between\"><div class=\"subtitle\">Commit Graph</div>\n        <div><button id=\"btnRefresh\" class=\"small secondary\">Refresh</button></div>\n      </div>\n      <div class=\"graph\" id=\"graph\"></div>\n    </div>\n\n    <div>\n      <div class=\"subtitle\">Log / History</div>\n      <div class=\"log\" id=\"log\"></div>\n    </div>\n    <footer>Simple Git concept demo — purely client-side, educational only.</footer>\n  </div>\n\n  <div class=\"right\">\n    <div class=\"editor\">\n      <div class=\"files\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <h3>Working Directory</h3>\n          <div>\n            <button id=\"btnAddFile\" class=\"small\">Add File</button>\n            <button id=\"btnDeleteFile\" class=\"small secondary\">Delete Selected</button>\n          </div>\n        </div>\n        <div id=\"filesList\" style=\"margin-top:8px\"></div>\n        <div style=\"margin-top:8px\" class=\"muted\">Select a file to view and edit its content. Changes are in the working directory until you stage them.</div>\n      </div>\n\n      <div class=\"editor-area\">\n        <div style=\"display:flex;gap:8px;align-items:center\">\n          <div style=\"flex:1\">\n            <div class=\"subtitle\">File Editor</div>\n            <textarea id=\"fileEditor\" placeholder=\"Select a file or create a new one...\"></textarea>\n          </div>\n          <div style=\"width:260px;display:flex;flex-direction:column;gap:8px\">\n            <div class=\"staging\">\n              <div style=\"display:flex;justify-content:space-between;align-items:center\">\n                <div class=\"subtitle\">Staging</div>\n                <div><button id=\"btnStage\" class=\"small\">Stage</button> <button id=\"btnUnstage\" class=\"small secondary\">Unstage</button></div>\n              </div>\n              <div class=\"stage-list\" id=\"stageList\" style=\"margin-top:8px\"></div>\n            </div>\n\n            <div class=\"commit-box\">\n              <input id=\"commitMsg\" class=\"commit-msg\" placeholder=\"Commit message (required)\"/>\n              <button id=\"btnCommit\" class=\"small\">Commit</button>\n            </div>\n\n            <div style=\"display:flex;gap:8px\">\n              <button id=\"btnMerge\" class=\"small\">Merge Into Current</button>\n              <button id=\"btnAbortMerge\" class=\"small secondary\">Abort Merge</button>\n            </div>\n\n            <div style=\"margin-top:8px\" class=\"muted\">Use merge to bring another branch into the current branch. Conflicts will be marked in-file with conflict markers; resolve and stage before committing the merge.</div>\n          </div>\n        </div>\n\n        <div style=\"display:flex;gap:12px;margin-top:8px\">\n          <div style=\"flex:1\">\n            <div class=\"subtitle\">Selected Commit</div>\n            <div class=\"info\" id=\"selectedCommit\">Click a commit in the graph to inspect details.</div>\n          </div>\n          <div style=\"width:260px\">\n            <div class=\"subtitle\">Actions & Inspect</div>\n            <div style=\"display:flex;gap:8px;margin-bottom:8px\">\n              <button id=\"btnShowStatus\" class=\"small\">Status</button>\n              <button id=\"btnShowBranches\" class=\"small secondary\">Refs</button>\n            </div>\n            <div id=\"inspectArea\" class=\"info muted\"></div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n/*\n  Simplified Git simulation:\n  - commits: full snapshot of files (map filename->content or null for deleted)\n  - refs: branches map to commit ids\n  - HEAD: {type:'branch'|'detached', name:branchName, commit:commitId}\n  - index: stagedFiles map filename -> content or '__deleted__' marker\n  - workdir: files map filename->content\n  - mergeState: null or {merging: true, ours: commitId, theirs: commitId, base: commitId}\n*/\n\n// Utilities\nfunction short(id){return id.slice(0,7)}\nfunction now(){return new Date().toLocaleString()}\n\n// repo data\nconst repo = {\n  commits: {}, // id -> {id, parents:[], tree: {filename:content|null}, msg, time}\n  refs: {}, // branchName -> commitId\n  HEAD: {type:'branch', name:'main', commit:null},\n  index: {}, // staged map filename -> content OR '__deleted__'\n  workdir: {}, // current files\n  mergeState: null,\n  idCounter: 1\n};\n\n// Initialize repository with an initial commit\nfunction initRepo(){\n  const id = genId();\n  const commit = {id, parents: [], tree: {}, msg: 'Initial commit', time: now()};\n  repo.commits[id] = commit;\n  repo.refs['main'] = id;\n  repo.HEAD = {type:'branch', name:'main', commit: id};\n  repo.workdir = {}; // start empty\n  repo.index = {};\n  repo.mergeState = null;\n  renderAll();\n}\n\nfunction genId(){\n  const id = 'c' + (repo.idCounter++).toString(16).padStart(6,'0') + Math.random().toString(16).slice(2,8);\n  return id;\n}\n\n// Helpers to clone tree\nfunction cloneTree(tree){\n  return Object.assign({}, tree);\n}\n\n// Get commit by id\nfunction getCommit(id){ return repo.commits[id] || null }\n\n// Status detection\nfunction getStatus(){\n  const headCommit = getCommit(repo.HEAD.commit);\n  const committedTree = headCommit? headCommit.tree : {};\n  const workdir = repo.workdir;\n  const staged = repo.index;\n  let dirty = false;\n  // check for differences between working dir and commit or staged area\n  // if staged has entries, it's dirty\n  if(Object.keys(staged).length>0) dirty = true;\n  // if workdir differs from committedTree for any file not staged, also dirty\n  const names = new Set([...Object.keys(committedTree), ...Object.keys(workdir)]);\n  for(let n of names){\n    const committed = committedTree[n] === undefined ? null : committedTree[n];\n    const working = workdir[n] === undefined ? null : workdir[n];\n    if(staged[n] !== undefined) continue; // staged overrides\n    if(committed !== working) { dirty = true; break }\n  }\n  return {dirty, stagedFiles: Object.keys(staged)};\n}\n\n// Stage file: copy current workdir content to index; if file deleted, mark as deleted\nfunction stageFile(filename){\n  if(repo.workdir[filename] === undefined){\n    repo.index[filename] = '__deleted__';\n  } else {\n    repo.index[filename] = repo.workdir[filename];\n  }\n  renderAll();\n}\n\n// Unstage file\nfunction unstageFile(filename){\n  delete repo.index[filename];\n  renderAll();\n}\n\n// Commit staged changes, optionally providing parents explicitly (for merges)\nfunction commitStaged(message, parentsOverride){\n  const staged = repo.index;\n  if(Object.keys(staged).length === 0) {\n    alert(\"Nothing staged to commit.\");\n    return null;\n  }\n  if(!message || !message.trim()){\n    alert(\"Commit message required.\");\n    return null;\n  }\n  const parent = repo.HEAD.commit;\n  const parents = parentsOverride || (parent?[parent]:[]);\n  // build tree: start with parent's tree\n  const baseTree = parent ? cloneTree(getCommit(parent).tree) : {};\n  const newTree = cloneTree(baseTree);\n  // apply staged\n  for(const [name, val] of Object.entries(staged)){\n    if(val === '__deleted__') {\n      delete newTree[name];\n    } else {\n      newTree[name] = val;\n    }\n  }\n  const id = genId();\n  const commit = {id, parents: parents.slice(), tree: newTree, msg: message, time: now()};\n  repo.commits[id] = commit;\n  // update current ref\n  if(repo.HEAD.type === 'branch'){\n    repo.refs[repo.HEAD.name] = id;\n    repo.HEAD.commit = id;\n  } else {\n    // detached\n    repo.HEAD.commit = id;\n  }\n  // clear index\n  repo.index = {};\n  // If merging, clear merge state after a merge commit\n  if(repo.mergeState && parents.length >= 2){\n    repo.mergeState = null;\n  }\n  renderAll();\n  return id;\n}\n\n// Create a new branch at current commit\nfunction createBranch(name){\n  if(!name) return alert(\"Branch name required\");\n  if(repo.refs[name]) return alert(\"Branch already exists\");\n  repo.refs[name] = repo.HEAD.commit;\n  renderAll();\n}\n\n// Checkout branch (or commit)\nfunction checkout(refName){\n  if(repo.refs[refName] === undefined) return alert(\"No such branch\");\n  // check for uncommitted changes\n  const status = getStatus();\n  if(status.dirty){\n    if(!confirm(\"You have uncommitted changes that will be lost when checking out. Continue?\")) return;\n  }\n  repo.HEAD = {type:'branch', name:refName, commit: repo.refs[refName]};\n  // update working dir to branch commit snapshot\n  const tree = getCommit(repo.HEAD.commit).tree;\n  repo.workdir = cloneTree(tree);\n  repo.index = {};\n  repo.mergeState = null;\n  renderAll();\n}\n\n// Add new file with name and optional content\nfunction addFile(name, content){\n  if(!name) return;\n  if(repo.workdir[name] !== undefined){\n    alert(\"File already exists in working directory\");\n    return;\n  }\n  repo.workdir[name] = content || \"\";\n  renderAll();\n}\n\n// Delete selected file from working dir (marks as deleted until staged)\nfunction deleteFile(name){\n  if(!name) return;\n  delete repo.workdir[name];\n  renderAll();\n}\n\n// Merge source branch into current branch (ours = current HEAD)\nfunction mergeBranchIntoCurrent(sourceBranch){\n  if(!repo.refs[sourceBranch]) return alert(\"No such branch\");\n  if(sourceBranch === repo.HEAD.name) return alert(\"Cannot merge a branch into itself\");\n  const oursId = repo.HEAD.commit;\n  const theirsId = repo.refs[sourceBranch];\n  const baseId = findCommonAncestor(oursId, theirsId);\n  if(!baseId) {\n    if(!confirm(\"No common ancestor found. Proceed with simple merge?\")) return;\n  }\n  const base = baseId ? getCommit(baseId).tree : {};\n  const ours = getCommit(oursId).tree;\n  const theirs = getCommit(theirsId).tree;\n\n  // perform three-way merge\n  const allFiles = new Set([...Object.keys(base), ...Object.keys(ours), ...Object.keys(theirs)]);\n  let conflicts = [];\n  let mergedTree = cloneTree(ours); // start from ours\n  // We'll put conflict markers in working dir; mergedTree won't be committed automatically if conflicts exist\n  for(let file of allFiles){\n    const b = base[file] === undefined ? null : base[file];\n    const o = ours[file] === undefined ? null : ours[file];\n    const t = theirs[file] === undefined ? null : theirs[file];\n    if(o === t){\n      // same in ours and theirs -> keep\n      continue;\n    }\n    if(b === o && t !== b){\n      // changed only in theirs -> take theirs\n      if(t === null) delete mergedTree[file]; else mergedTree[file] = t;\n      continue;\n    }\n    if(b === t && o !== b){\n      // changed only in ours -> keep ours\n      continue;\n    }\n    // if different and none are base same -> conflict\n    if(o !== t){\n      conflicts.push(file);\n      const conflictContent = buildConflictContent(o, t, sourceBranch);\n      // put conflict markers into workdir (user must resolve and stage)\n      repo.workdir[file] = conflictContent;\n      // mark file as unmerged: do not apply to mergedTree (we leave ours version until resolved)\n    }\n  }\n\n  if(conflicts.length > 0){\n    // enter merge state, with parents info\n    repo.mergeState = {merging:true, ours:oursId, theirs:theirsId, base:baseId, branch: sourceBranch, conflicts: conflicts.slice()};\n    // update workdir for non-conflicting auto-merged files\n    for(const [f, content] of Object.entries(mergedTree)){\n      repo.workdir[f] = content;\n    }\n    renderAll();\n    alert(\"Merge resulted in conflicts in: \" + conflicts.join(\", \") + \". Resolve them in the editor, then stage and commit the merge.\");\n    return;\n  } else {\n    // no conflicts: create merge commit with two parents and mergedTree snapshot\n    const id = genId();\n    const commit = {id, parents: [oursId, theirsId], tree: mergedTree, msg: `Merge branch '${sourceBranch}' into ${repo.HEAD.name}`, time: now()};\n    repo.commits[id] = commit;\n    // move branch\n    if(repo.HEAD.type === 'branch'){\n      repo.refs[repo.HEAD.name] = id;\n      repo.HEAD.commit = id;\n    } else {\n      repo.HEAD.commit = id;\n    }\n    // update working dir\n    repo.workdir = cloneTree(mergedTree);\n    repo.index = {};\n    repo.mergeState = null;\n    renderAll();\n    alert(\"Merge completed with no conflicts. New merge commit created.\");\n    return;\n  }\n}\n\nfunction buildConflictContent(ours, theirs, sourceBranch){\n  const o = ours === null ? \"\" : ours;\n  const t = theirs === null ? \"\" : theirs;\n  return [\n    \"<<<<<<< HEAD\",\n    o,\n    \"=======\",\n    t,\n    \">>>>>>> \" + sourceBranch\n  ].join(\"\\n\");\n}\n\n// Find common ancestor of two commits by walking ancestors (simple approach)\nfunction findCommonAncestor(a, b){\n  if(!a || !b) return null;\n  // get all ancestors of a\n  const ancestorsA = new Set();\n  const stack = [a];\n  while(stack.length){\n    const cur = stack.pop();\n    if(!cur || ancestorsA.has(cur)) continue;\n    ancestorsA.add(cur);\n    const commit = getCommit(cur);\n    if(commit) for(const p of commit.parents) stack.push(p);\n  }\n  // BFS from b upward until find one in ancestorsA: search depth-first too\n  const stack2 = [b];\n  while(stack2.length){\n    const cur = stack2.pop();\n    if(!cur) continue;\n    if(ancestorsA.has(cur)) return cur;\n    const commit = getCommit(cur);\n    if(commit) for(const p of commit.parents) stack2.push(p);\n  }\n  return null;\n}\n\n// Abort merge: reset mergeState and reload working tree from HEAD commit (discard conflict work)\nfunction abortMerge(){\n  if(!repo.mergeState) return alert(\"No merge in progress\");\n  if(!confirm(\"Abort merge? This will discard conflict edits and return working directory to HEAD.\")) return;\n  const headTree = getCommit(repo.HEAD.commit).tree;\n  repo.workdir = cloneTree(headTree);\n  repo.index = {};\n  repo.mergeState = null;\n  renderAll();\n}\n\n// UI rendering\nlet selectedFile = null;\nlet selectedCommitId = null;\n\nfunction renderAll(){\n  renderStatus();\n  renderBranches();\n  renderGraph();\n  renderFiles();\n  renderStage();\n  renderLog();\n  renderSelectedCommit();\n  renderInspectArea();\n}\n\nfunction renderStatus(){\n  document.getElementById('currentBranch').innerText = repo.HEAD.type === 'branch' ? repo.HEAD.name : '(detached)';\n  const headId = repo.HEAD.commit ? short(repo.HEAD.commit) : '-';\n  document.getElementById('headId').innerText = headId;\n  const s = getStatus();\n  document.getElementById('statusText').innerText = s.dirty ? 'dirty' : 'clean';\n  const cleanDot = document.getElementById('cleanDot');\n  cleanDot.className = 'dot ' + (s.dirty ? 'dirty' : 'clean');\n}\n\nfunction renderBranches(){\n  const container = document.getElementById('branchesList');\n  container.innerHTML = '';\n  const names = Object.keys(repo.refs).sort();\n  for(const n of names){\n    const pill = document.createElement('div');\n    pill.className = 'branch-pill' + (repo.HEAD.type==='branch' && repo.HEAD.name===n ? ' current': '');\n    pill.innerText = n;\n    pill.title = 'Commit: ' + short(repo.refs[n]);\n    pill.onclick = ()=> {\n      // quick checkout\n      if(confirm(\"Checkout branch '\" + n + \"'?\")){\n        checkout(n);\n      }\n    };\n    container.appendChild(pill);\n  }\n}\n\nfunction renderGraph(){\n  const graph = document.getElementById('graph');\n  graph.innerHTML = '';\n  // We'll show commits in reverse chronological order by time of creation using idCounter order not perfect but fine\n  const commits = Object.values(repo.commits).slice().sort((a,b)=> a.time < b.time ? 1 : -1);\n  // But include branches mapping for quick indicator\n  const headCommit = repo.HEAD.commit;\n  for(const c of commits){\n    const node = document.createElement('div');\n    node.className = 'commit-node';\n    node.onclick = ()=> { selectedCommitId = c.id; renderSelectedCommit(); };\n    const idSpan = document.createElement('div');\n    idSpan.className = 'commit-id';\n    idSpan.innerText = short(c.id);\n    const center = document.createElement('div');\n    center.style.flex = '1';\n    const msg = document.createElement('div');\n    msg.className = 'commit-msg-line';\n    msg.innerText = c.msg;\n    const parents = document.createElement('div');\n    parents.className = 'parents';\n    parents.innerText = 'parents: ' + (c.parents.length ? c.parents.map(p=>short(p)).join(', ') : '(none)');\n    center.appendChild(msg);\n    center.appendChild(parents);\n    const right = document.createElement('div');\n    right.style.display='flex'; right.style.flexDirection='column'; right.style.alignItems='flex-end'; right.style.gap='6px';\n    if(c.id === headCommit){\n      const b = document.createElement('div'); b.className='pill'; b.innerText='HEAD'; right.appendChild(b);\n    }\n    // which branches point to this commit?\n    const pointing = Object.entries(repo.refs).filter(([name,id])=>id===c.id).map(x=>x[0]);\n    for(const p of pointing){\n      const b = document.createElement('div'); b.className = 'pill'; b.innerText = p;\n      right.appendChild(b);\n    }\n    node.appendChild(idSpan);\n    node.appendChild(center);\n    node.appendChild(right);\n    graph.appendChild(node);\n  }\n}\n\nfunction renderFiles(){\n  const list = document.getElementById('filesList');\n  list.innerHTML = '';\n  // gather files from working dir\n  const names = Object.keys(repo.workdir).sort();\n  // also include files that were in commit but deleted from workdir? Show deleted only if staged deletion or in commit?\n  // We'll show only current working directory entries\n  for(const n of names){\n    const it = document.createElement('div');\n    it.className = 'file-item';\n    it.onclick = ()=> { selectedFile = n; renderFiles(); loadFileToEditor(n); };\n    it.style.background = (selectedFile === n) ? 'rgba(124,198,255,0.06)' : 'transparent';\n    const name = document.createElement('div'); name.className='name'; name.innerText = n;\n    const actions = document.createElement('div'); actions.className='file-actions';\n    const stageBtn = document.createElement('button'); stageBtn.className='small'; stageBtn.innerText='Stage';\n    stageBtn.onclick = (e)=>{ e.stopPropagation(); stageFile(n); };\n    const delBtn = document.createElement('button'); delBtn.className='small secondary'; delBtn.innerText='Delete';\n    delBtn.onclick = (e)=>{ e.stopPropagation(); if(confirm(\"Delete '\" + n + \"' from working directory?\")){ deleteFile(n); } };\n    actions.appendChild(stageBtn); actions.appendChild(delBtn);\n    it.appendChild(name); it.appendChild(actions);\n    list.appendChild(it);\n  }\n  if(names.length===0){\n    const p = document.createElement('div'); p.className='muted'; p.innerText='Working directory is empty. Add a file to get started.'; list.appendChild(p);\n  }\n}\n\nfunction loadFileToEditor(name){\n  const editor = document.getElementById('fileEditor');\n  if(!name){ editor.value = ''; editor.placeholder = 'Select a file or create a new one...'; return; }\n  selectedFile = name;\n  editor.value = repo.workdir[name] === undefined ? '' : repo.workdir[name];\n  editor.placeholder = '';\n}\n\ndocument.getElementById('fileEditor').addEventListener('input', (e)=>{\n  if(selectedFile){\n    repo.workdir[selectedFile] = e.target.value;\n    renderStatus();\n  }\n});\n\nfunction renderStage(){\n  const list = document.getElementById('stageList');\n  list.innerHTML = '';\n  const staged = repo.index;\n  if(Object.keys(staged).length === 0){\n    const p = document.createElement('div'); p.className='muted'; p.innerText='No staged changes';\n    list.appendChild(p); return;\n  }\n  for(const [n, v] of Object.entries(staged)){\n    const item = document.createElement('div'); item.className='stage-item';\n    const left = document.createElement('div'); left.innerHTML = '<div style=\"font-family:ui-monospace,monospace;color:#eaf4ff\">' + n + '</div><div class=\"muted\" style=\"font-size:12px\">' + (v === '__deleted__' ? 'deleted' : 'staged change') + '</div>';\n    const btn = document.createElement('button'); btn.className='small secondary'; btn.innerText='Unstage';\n    btn.onclick = ()=> { unstageFile(n); };\n    item.appendChild(left); item.appendChild(btn);\n    list.appendChild(item);\n  }\n}\n\nfunction renderLog(){\n  const log = document.getElementById('log');\n  log.innerHTML = '';\n  const commits = Object.values(repo.commits).slice().sort((a,b)=> a.time < b.time ? 1 : -1);\n  for(const c of commits){\n    const d = document.createElement('div'); d.style.marginBottom='8px';\n    const h = document.createElement('div'); h.style.display='flex'; h.style.justifyContent='space-between';\n    const left = document.createElement('div'); left.innerHTML = '<div style=\"font-family:ui-monospace,monospace\">' + short(c.id) + '</div><div class=\"muted\" style=\"font-size:12px\">' + c.time + '</div>';\n    const right = document.createElement('div'); right.innerHTML = '<div style=\"font-weight:600\">' + c.msg + '</div>';\n    h.appendChild(left); h.appendChild(right);\n    d.appendChild(h);\n    log.appendChild(d);\n  }\n}\n\nfunction renderSelectedCommit(){\n  const el = document.getElementById('selectedCommit');\n  if(!selectedCommitId){ el.innerText = 'Click a commit in the graph to inspect details.'; return; }\n  const c = getCommit(selectedCommitId);\n  if(!c) { el.innerText = 'Commit not found.'; return; }\n  el.innerHTML = '<div style=\"font-family:ui-monospace,monospace;color:var(--muted)\">' + short(c.id) + '</div><div style=\"margin-top:6px\"><b>' + c.msg + '</b></div><div class=\"muted\" style=\"margin-top:6px\">Parents: ' + (c.parents.length? c.parents.map(p=>short(p)).join(', '): '(none)') + '</div><div style=\"margin-top:8px\" class=\"muted\">Files snapshot:</div>';\n  const list = document.createElement('div'); list.style.marginTop='6px';\n  for(const [f,content] of Object.entries(c.tree)){\n    const pre = document.createElement('div'); pre.style.padding='6px'; pre.style.borderRadius='6px'; pre.style.background='rgba(255,255,255,0.01)'; pre.style.marginBottom='6px';\n    pre.innerHTML = '<div style=\"font-family:ui-monospace,monospace;color:#dff5ff\">' + f + '</div><div class=\"muted\" style=\"font-size:12px;max-height:80px;overflow:auto;padding-top:4px\">' + escapeHtml(content).slice(0,120) + (content.length>120? '…':'') + '</div>';\n    list.appendChild(pre);\n  }\n  el.appendChild(list);\n}\n\nfunction renderInspectArea(){\n  const el = document.getElementById('inspectArea');\n  const s = getStatus();\n  const staged = Object.keys(repo.index);\n  let html = '';\n  html += '<div class=\"muted\">Uncommitted changes: <b>' + (s.dirty ? 'Yes':'No') + '</b></div>';\n  html += '<div style=\"margin-top:6px\" class=\"muted\">Staged files: <b>' + (staged.length? staged.join(', '): '(none)') + '</b></div>';\n  if(repo.mergeState){\n    html += '<div style=\"margin-top:8px\" class=\"conflict\">Merge in progress: merging branch <b>' + repo.mergeState.branch + '</b>. Conflicts: ' + repo.mergeState.conflicts.join(', ') + '</div>';\n  }\n  el.innerHTML = html;\n}\n\n// UI - Buttons wiring\ndocument.getElementById('btnAddFile').addEventListener('click', ()=>{\n  const name = prompt(\"Enter new file name (e.g. hello.txt):\");\n  if(!name) return;\n  if(repo.workdir[name] !== undefined) return alert(\"File exists\");\n  addFile(name, \"\");\n  selectedFile = name;\n  loadFileToEditor(name);\n});\n\ndocument.getElementById('btnDeleteFile').addEventListener('click', ()=>{\n  if(!selectedFile) return alert(\"Select a file first\");\n  if(!confirm(\"Delete '\" + selectedFile + \"' from working directory? You can stage the deletion to remove it from the next commit.\")) return;\n  deleteFile(selectedFile);\n  selectedFile = null;\n  document.getElementById('fileEditor').value = '';\n});\n\ndocument.getElementById('btnStage').addEventListener('click', ()=>{\n  if(!selectedFile) return alert(\"Select a file to stage\");\n  stageFile(selectedFile);\n});\n\ndocument.getElementById('btnUnstage').addEventListener('click', ()=>{\n  if(!selectedFile) return alert(\"Select a file to unstage\");\n  unstageFile(selectedFile);\n});\n\ndocument.getElementById('btnCommit').addEventListener('click', ()=>{\n  const msg = document.getElementById('commitMsg').value;\n  // If merge in progress, must ensure mergeState and parents\n  if(repo.mergeState){\n    // Must have staged files resolving conflicts and no unresolved conflicts remain\n    const unresolved = repo.mergeState.conflicts.filter(f => {\n      // unresolved if in workdir it still contains '<<<<<<<' marker OR if not staged\n      const w = repo.workdir[f] || '';\n      const staged = repo.index[f];\n      const containsMarkers = (w.indexOf('<<<<<<<') >= 0);\n      if(containsMarkers) return true;\n      // if resolved and staged or not changed from ours? We'll require staged\n      if(repo.index[f] === undefined) return true;\n      return false;\n    });\n    if(unresolved.length){\n      return alert(\"You must resolve and stage these files before completing the merge: \" + unresolved.join(', '));\n    }\n    // commit with two parents\n    commitStaged(msg, [repo.mergeState.ours, repo.mergeState.theirs]);\n    alert(\"Merge commit created.\");\n    return;\n  } else {\n    commitStaged(msg);\n  }\n  document.getElementById('commitMsg').value = '';\n});\n\ndocument.getElementById('btnNewBranch').addEventListener('click', ()=>{\n  const name = prompt(\"New branch name:\");\n  if(!name) return;\n  createBranch(name);\n});\n\ndocument.getElementById('btnCheckout').addEventListener('click', ()=>{\n  const name = prompt(\"Checkout branch name:\");\n  if(!name) return;\n  checkout(name);\n});\n\ndocument.getElementById('btnShowStatus').addEventListener('click', ()=>{\n  alert(JSON.stringify(getStatus(), null, 2));\n});\ndocument.getElementById('btnShowBranches').addEventListener('click', ()=>{\n  alert(JSON.stringify(repo.refs, null, 2));\n});\n\ndocument.getElementById('btnMerge').addEventListener('click', ()=>{\n  const name = prompt(\"Merge which branch into current? (enter branch name)\");\n  if(!name) return;\n  mergeBranchIntoCurrent(name);\n});\n\ndocument.getElementById('btnAbortMerge').addEventListener('click', ()=>{\n  abortMerge();\n});\n\ndocument.getElementById('btnRefresh').addEventListener('click', ()=> renderAll());\n\n// simple escape\nfunction escapeHtml(s){ return (s+'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') }\n\n// Initialize with some example content to demonstrate behavior\nfunction seedExample(){\n  initRepo();\n  // Add a file and commit\n  repo.workdir['README.md'] = \"# Demo Repo\\nThis is a demo repository.\";\n  stageFile('README.md');\n  commitStaged('Add README');\n  // create a branch feature\n  createBranch('feature');\n  // switch to feature and change README\n  checkout('feature');\n  repo.workdir['README.md'] = \"# Demo Repo\\nThis is a demo repository.\\n\\nFeature work started.\";\n  repo.workdir['file.txt'] = \"Hello from feature branch\";\n  stageFile('README.md'); stageFile('file.txt');\n  commitStaged('Start feature');\n  // switch back to main and change README differently\n  checkout('main');\n  repo.workdir['README.md'] = \"# Demo Repo\\nThis is a demo repository.\\n\\nHotfix on main.\";\n  stageFile('README.md');\n  commitStaged('Hotfix main');\n  // create another branch from main and change file to produce more branching\n  createBranch('topic');\n  checkout('topic');\n  repo.workdir['topic.md'] = \"Notes for topic branch\";\n  stageFile('topic.md');\n  commitStaged('Add topic notes');\n  checkout('main');\n  renderAll();\n}\n\n// run\nseedExample();\n\n</script>\n</body>\n</html>"
