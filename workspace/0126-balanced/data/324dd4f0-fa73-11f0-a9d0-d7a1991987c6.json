    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dijkstra's Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n        canvas {\n            border: 1px solid #ccc;\n            background-color: #fff;\n        }\n        #controls {\n            margin: 20px 0;\n        }\n        .node {\n            fill: #3498db;\n            cursor: pointer;\n        }\n        .visited {\n            fill: #2ecc71;\n        }\n        .line {\n            stroke: #34495e;\n            stroke-width: 2;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Dijkstra's Algorithm Visualization</h1>\n<canvas id=\"graphCanvas\" width=\"600\" height=\"400\"></canvas>\n<div id=\"controls\">\n    <button id=\"startButton\">Start Dijkstra's Algorithm</button>\n</div>\n<script>\n    const canvas = document.getElementById(\"graphCanvas\");\n    const ctx = canvas.getContext(\"2d\");\n\n    const nodes = [\n        { id: 0, x: 100, y: 100, edges: [{ to: 1, weight: 4 }, { to: 2, weight: 1 }] },\n        { id: 1, x: 300, y: 100, edges: [{ to: 3, weight: 1 }] },\n        { id: 2, x: 100, y: 300, edges: [{ to: 1, weight: 2 }, { to: 3, weight: 5 }] },\n        { id: 3, x: 300, y: 300, edges: [] }\n    ];\n    \n    let shortestPaths = [];\n    const startNode = 0;\n\n    function drawGraph() {\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n        nodes.forEach(node => {\n            // Draw edges\n            node.edges.forEach(edge => {\n                const targetNode = nodes[edge.to];\n                ctx.beginPath();\n                ctx.moveTo(node.x, node.y);\n                ctx.lineTo(targetNode.x, targetNode.y);\n                ctx.strokeStyle = \"rgba(52, 73, 94, 0.5)\";\n                ctx.stroke();\n                ctx.fillText(edge.weight, (node.x + targetNode.x) / 2, (node.y + targetNode.y) / 2);\n            });\n\n            // Draw nodes\n            ctx.beginPath();\n            ctx.arc(node.x, node.y, 20, 0, Math.PI * 2);\n            ctx.fillStyle = shortestPaths[node.id] ? \"#2ecc71\" : \"#3498db\"; // Visited or not\n            ctx.fill();\n            ctx.stroke();\n            ctx.fillText(node.id, node.x - 5, node.y + 5); // Node ID\n        });\n    }\n\n    async function dijkstra() {\n        const distances = new Array(nodes.length).fill(Infinity);\n        const visited = new Array(nodes.length).fill(false);\n        distances[startNode] = 0;\n\n        for (let i = 0; i < nodes.length; i++) {\n            // Get the unvisited node with the smallest distance\n            let minDistance = Infinity;\n            let currentNode = -1;\n\n            for (let j = 0; j < nodes.length; j++) {\n                if (!visited[j] && distances[j] < minDistance) {\n                    minDistance = distances[j];\n                    currentNode = j;\n                }\n            }\n\n            if (currentNode === -1) break; // All remaining nodes are inaccessible\n\n            visited[currentNode] = true;\n            shortestPaths[currentNode] = true;\n            drawGraph();\n\n            await new Promise(resolve => setTimeout(resolve, 1000)); // Slow down for visualization\n\n            nodes[currentNode].edges.forEach(edge => {\n                const newDist = distances[currentNode] + edge.weight;\n                if (newDist < distances[edge.to]) {\n                    distances[edge.to] = newDist;\n                }\n            });\n        }\n        \n        drawGraph();\n        console.log(\"Shortest Distances: \", distances);\n    }\n\n    document.getElementById(\"startButton\").addEventListener(\"click\", () => {\n        shortestPaths = [];\n        drawGraph();\n        dijkstra();\n    });\n\n    drawGraph();\n</script>\n\n</body>\n</html>"
