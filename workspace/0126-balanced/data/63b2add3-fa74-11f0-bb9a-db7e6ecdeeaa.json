    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Semaphore Concept Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2em;\n      background-color: #f5f5f5;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n    }\n    #container {\n      max-width: 600px;\n      margin: 0 auto;\n      padding: 1em;\n      background: white;\n      border-radius: 8px;\n      box-shadow: 0 0 10px rgba(0,0,0,0.1);\n    }\n    #semaphore-status {\n      font-size: 1.2em;\n      margin: 1em 0;\n      text-align: center;\n    }\n    #tasks {\n      display: flex;\n      justify-content: center;\n      gap: 1em;\n      margin-bottom: 2em;\n      flex-wrap: wrap;\n    }\n    .task {\n      width: 100px;\n      height: 100px;\n      border-radius: 12px;\n      background: #ddd;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-weight: bold;\n      color: #555;\n      cursor: pointer;\n      user-select: none;\n      transition: background-color 0.3s, color 0.3s;\n      box-shadow: 0 0 5px rgba(0,0,0,0.1);\n      position: relative;\n    }\n    .task.queued {\n      background: #f5b342;\n      color: #fff;\n      cursor: wait;\n      box-shadow: 0 0 10px #f5b342;\n    }\n    .task.running {\n      background: #4caf50;\n      color: white;\n      cursor: default;\n      box-shadow: 0 0 12px #4caf50;\n    }\n    .task.done {\n      background: #2196f3;\n      color: white;\n      cursor: default;\n      box-shadow: 0 0 12px #2196f3;\n    }\n    button {\n      background-color: #2196f3;\n      border: none;\n      color: white;\n      padding: 10px 18px;\n      font-size: 1em;\n      border-radius: 6px;\n      cursor: pointer;\n      margin-top: 1em;\n      width: 100%;\n      max-width: 180px;\n      display: block;\n      margin-left: auto;\n      margin-right: auto;\n      transition: background-color 0.3s;\n    }\n    button:disabled {\n      background-color: #bbb;\n      cursor: not-allowed;\n    }\n    footer {\n      text-align: center;\n      margin-top: 3em;\n      font-size: 0.9em;\n      color: #888;\n    }\n  </style>\n</head>\n<body>\n  <div id=\"container\">\n    <h1>Semaphore Demonstration</h1>\n    <p>\n      This demo shows how a <strong>Semaphore</strong> controls access to a limited number of resources (permits).\n      Only a fixed number of \"tasks\" can run simultaneously; others wait in a queue until a permit is free.\n    </p>\n    <div id=\"semaphore-status\">\n      Semaphore permits available: <span id=\"permits-count\"></span>\n    </div>\n\n    <div id=\"tasks\" aria-label=\"Tasks container\" role=\"list\">\n      <!-- Task boxes appear here -->\n    </div>\n\n    <button id=\"add-task-btn\" aria-label=\"Add a new task to the queue\">\n      Add New Task\n    </button>\n\n    <footer>\n      Click on a running task to release its permit and make room for queued tasks.\n    </footer>\n  </div>\n\n  <script>\n    // Simple Semaphore class in JS using async/await and Promises\n    class Semaphore {\n      constructor(maxPermits) {\n        this._maxPermits = maxPermits;\n        this._permits = maxPermits;\n        this._queue = [];\n      }\n\n      // Acquire a permit\n      acquire() {\n        return new Promise(resolve => {\n          if (this._permits > 0) {\n            this._permits--;\n            updatePermitsDisplay();\n            resolve();\n          } else {\n            // No permit available, enqueue the resolver\n            this._queue.push(resolve);\n          }\n        });\n      }\n\n      // Release a permit\n      release() {\n        this._permits++;\n        if (this._permits > this._maxPermits) {\n          this._permits = this._maxPermits; // Safety clamp\n        }\n        updatePermitsDisplay();\n\n        if (this._queue.length > 0) {\n          // Dequeue and resolve the first waiting acquire() Promise\n          const nextResolve = this._queue.shift();\n          this._permits--;\n          updatePermitsDisplay();\n          nextResolve();\n        }\n      }\n\n      // Get number of available permits\n      availablePermits() {\n        return this._permits;\n      }\n\n      // Get number of waiting tasks\n      waitingCount() {\n        return this._queue.length;\n      }\n    }\n\n    // UI logic\n\n    const MAX_PERMITS = 3;\n    const semaphore = new Semaphore(MAX_PERMITS);\n\n    const permitsCountEl = document.getElementById('permits-count');\n    const tasksContainer = document.getElementById('tasks');\n    const addTaskBtn = document.getElementById('add-task-btn');\n\n    let taskIdCounter = 0;\n    const tasks = new Map(); // Map taskId => Task object with state\n\n    function updatePermitsDisplay() {\n      permitsCountEl.textContent = semaphore.availablePermits() + ' / ' + MAX_PERMITS;\n    }\n\n    function createTaskElement(task) {\n      const div = document.createElement('div');\n      div.classList.add('task');\n      div.textContent = 'Task ' + task.id;\n      div.setAttribute('role', 'listitem');\n      div.setAttribute('tabindex', '0'); // Make focusable\n      updateTaskAppearance(div, task.state);\n\n      // On click for running tasks to release permit early\n      div.addEventListener('click', () => {\n        if (task.state === 'running') {\n          // User manually finishes the task\n          finishTask(task.id, true);\n        }\n      });\n\n      // Accessibility: allow Enter or Space to trigger click\n      div.addEventListener('keydown', e => {\n        if ((e.key === 'Enter' || e.key === ' ') && task.state === 'running') {\n          e.preventDefault();\n          finishTask(task.id, true);\n        }\n      });\n\n      return div;\n    }\n\n    function updateTaskAppearance(element, state) {\n      element.classList.remove('queued', 'running', 'done');\n      if (state === 'queued') {\n        element.classList.add('queued');\n        element.setAttribute('aria-label', element.textContent + ' queued, waiting for permit');\n      } else if (state === 'running') {\n        element.classList.add('running');\n        element.setAttribute('aria-label', element.textContent + ' running, click or press Enter/Space to finish');\n      } else if (state === 'done') {\n        element.classList.add('done');\n        element.setAttribute('aria-label', element.textContent + ' completed');\n      }\n    }\n\n    async function startTask(task) {\n      // Change state to queued first\n      task.state = 'queued';\n      updateTaskAppearance(task.element, 'queued');\n\n      // Acquire semaphore permit\n      await semaphore.acquire();\n\n      // Permit acquired: running state\n      task.state = 'running';\n      updateTaskAppearance(task.element, 'running');\n      updatePermitsDisplay();\n\n      // Simulate task work duration (5 to 10 seconds)\n      const workDuration = 5000 + Math.random() * 5000;\n\n      // Promise that resolves when task ends (either timeout or manual release)\n      task.runningTimeout = setTimeout(() => {\n        finishTask(task.id, false);\n      }, workDuration);\n    }\n\n    function finishTask(taskId, manual = false) {\n      const task = tasks.get(taskId);\n      if (!task || task.state !== 'running') {\n        return;\n      }\n\n      // Clear any running timeout if manual finish\n      if (manual && task.runningTimeout) {\n        clearTimeout(task.runningTimeout);\n      }\n\n      // Change state to done\n      task.state = 'done';\n      updateTaskAppearance(task.element, 'done');\n\n      // Release the semaphore permit\n      semaphore.release();\n\n      // After short delay, remove the task visually\n      setTimeout(() => {\n        tasksContainer.removeChild(task.element);\n        tasks.delete(taskId);\n      }, 3000);\n    }\n\n    addTaskBtn.addEventListener('click', () => {\n      addNewTask();\n    });\n\n    function addNewTask() {\n      taskIdCounter++;\n      const task = {\n        id: taskIdCounter,\n        state: 'initialized',\n        element: null,\n        runningTimeout: null,\n      };\n      const el = createTaskElement(task);\n      task.element = el;\n      tasksContainer.appendChild(el);\n      tasks.set(task.id, task);\n\n      // Start the process of acquiring permit and running the task\n      startTask(task);\n    }\n\n    // Initialize permit display\n    updatePermitsDisplay();\n\n    // Add initial tasks to illustrate the semaphore\n    for(let i=0; i<5; i++) {\n      addNewTask();\n    }\n  </script>\n</body>\n</html>"
