    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>A* Search Algorithm Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 20px;\n        }\n        .grid {\n            display: grid;\n            grid-template-columns: repeat(10, 40px);\n            grid-template-rows: repeat(10, 40px);\n            gap: 2px;\n            margin: 20px 0;\n        }\n        .cell {\n            width: 40px;\n            height: 40px;\n            border: 1px solid #ccc;\n            display: flex\";\n            justify-content: center;\n            align-items: center;\n            cursor: pointer;\n            font-size: 12px;\n        }\n        .start {\n            background-color: #4CAF50;\n        }\n        .end {\n            background-color: #F44336;\n        }\n        .wall {\n            background-color: #333;\n        }\n        .path {\n            background-color: #2196F3;\n        }\n        .visited {\n            background-color: #90CAF9;\n        }\n        .controls {\n            margin: 20px 0;\n        }\n        button {\n            padding: 8px 16px;\n            margin: 0 5px;\n            cursor: pointer;\n        }\n        .info {\n            margin-top: 20px;\n            max-width: 600px;\n        }\n    </style>\n</head>\n<body>\n    <h1>A* Search Algorithm</h1>\n    <div class=\"controls\">\n        <button id=\"setStart\">Set Start (Green)</button>\n        <button id=\"setEnd\">Set End (Red)</button>\n        <button id=\"setWall\">Set Wall (Black)</button>\n        <button id=\"clearCell\">Clear Cell</button>\n        <button id=\"runAStar\">Run A* Search</button>\n        <button id=\"reset\">Reset Grid</button>\n    </div>\n    <div class=\"grid\" id=\"grid\"></div>\n    <div class=\"info\">\n        <h3>How to use:</h3>\n        <ol>\n            <li>Click \"Set Start\" then click a cell to set the starting point</li>\n            <li>Click \"Set End\" then click a cell to set the destination</li>\n            <li>Click \"Set Wall\" then click cells to add obstacles</li>\n            <li>Click \"Run A* Search\" to find the shortest path</li>\n        </ol>\n        <p>A* Search is a pathfinding algorithm that finds the shortest path between two points by combining the cost to reach a node (g) with a heuristic estimate of the cost to the goal (h). It prioritizes nodes with the lowest f = g + h value.</p>\n    </div>\n\n    <script>\n        const ROWS = 10;\n        const COLS = 10;\n        const grid = [];\n        let start = { row: 0, col: 0 };\n        let end = { row: ROWS-1, col: COLS-1 };\n        let mode = 'start'; // 'start', 'end', 'wall', 'clear'\n        let isRunning = false;\n\n        // Initialize grid\n        function initGrid() {\n            const gridElement = document.getElementById('grid');\n            gridElement.innerHTML = '';\n            grid.length = 0;\n\n            for (let row = 0; row < ROWS; row++) {\n                const rowArray = [];\n                for (let col = 0; col < COLS; col++) {\n                    const cell = document.createElement('div');\n                    cell.className = 'cell';\n                    cell.dataset.row = row;\n                    cell.dataset.col = col;\n                    cell.addEventListener('click', () => handleCellClick(row, col));\n                    gridElement.appendChild(cell);\n                    rowArray.push({\n                        row,\n                        col,\n                        element: cell,\n                        isWall: false,\n                        g: Infinity,\n                        h: 0,\n                        f: Infinity,\n                        parent: null\n                    });\n                }\n                grid.push(rowArray);\n            }\n\n            // Set start and end points\n            grid[start.row][start.col].element.classList.add('start');\n            grid[end.row][end.col].element.classList.add('end');\n        }\n\n        // Handle cell clicks\n        function handleCellClick(row, col) {\n            if (isRunning) return;\n\n            const cell = grid[row][col];\n            \n            if (mode === 'start') {\n                // Remove previous start\n                grid[start.row][start.col].element.classList.remove('start');\n                // Set new start\n                start = { row, col };\n                cell.element.classList.add('start');\n            } else if (mode === 'end') {\n                // Remove previous end\n                grid[end.row][end.col].element.classList.remove('end');\n                // Set new end\n                end = { row, col };\n                cell.element.classList.add('end');\n            } else if (mode === 'wall') {\n                if ((row === start.row && col === start.col) || (row === end.row && col === end.col)) {\n                    return;\n                }\n                cell.isWall = true;\n                cell.element.classList.add('wall');\n            } else if (mode === 'clear') {\n                cell.isWall = false;\n                cell.element.classList.remove('wall', 'visited', 'path');\n            }\n        }\n\n        // Heuristic function (Manhattan distance)\n        function heuristic(a, b) {\n            return Math.abs(a.row - b.row) + Math.abs(a.col - b.col);\n        }\n\n        // A* Search\n        async function aStarSearch() {\n            if (isRunning) return;\n            isRunning = true;\n\n            // Reset grid values (except walls)\n            for (let row = 0; row < ROWS; row++) {\n                for (let col = 0; col < COLS; col++) {\n                    const cell = grid[row][col];\n                    cell.g = Infinity;\n                    cell.f = Infinity;\n                    cell.parent = null;\n                    cell.element.classList.remove('visited', 'path');\n                }\n            }\n\n            const openSet = [];\n            const closedSet = new Set();\n\n            // Initialize start node\n            const startNode = grid[start.row][start.col];\n            startNode.g = 0;\n            startNode.h = heuristic(start, end);\n            startNode.f = startNode.g + startNode.h;\n            openSet.push(startNode);\n\n            while (openSet.length > 0) {\n                // Find node with lowest f in openSet\n                openSet.sort((a, b) => a.f - b.f);\n                const current = openSet.shift();\n\n                // Check if we've reached the end\n                if (current.row === end.row && current.col === end.col) {\n                    await reconstructPath(current);\n                    isRunning = false;\n                    return;\n                }\n\n                closedSet.add(current);\n\n                // Visualize visited node\n                if (!(current.row === start.row && current.col === start.col) && \n                    !(current.row === end.row && current.col === end.col)) {\n                    current.element.classList.add('visited');\n                    await new Promise(resolve => setTimeout(resolve, 20));\n                }\n\n                // Check neighbors\n                const neighbors = [];\n                const directions = [\n                    { row: -1, col: 0 }, // up\n                    { row: 1, col: 0 },  // down\n                    { row: 0, col: -1 }, // left\n                    { row: 0, col: 1 }   // right\n                ];\n\n                for (const dir of directions) {\n                    const newRow = current.row + dir.row;\n                    const newCol = current.col + dir.col;\n\n                    if (newRow >= 0 && newRow < ROWS && newCol >= 0 && newCol < COLS) {\n                        const neighbor = grid[newRow][newCol];\n                        if (!neighbor.isWall && !closedSet.has(neighbor)) {\n                            neighbors.push(neighbor);\n                        }\n                    }\n                }\n\n                for (const neighbor of neighbors) {\n                    const tentativeG = current.g + 1; // Assuming each step has cost 1\n\n                    if (tentativeG < neighbor.g) {\n                        neighbor.parent = current;\n                        neighbor.g = tentativeG;\n                        neighbor.h = heuristic({ row: neighbor.row, col: neighbor.col }, end);\n                        neighbor.f = neighbor.g + neighbor.h;\n\n                        if (!openSet.includes(neighbor)) {\n                            openSet.push(neighbor);\n                        }\n                    }\n                }\n            }\n\n            // No path found\n            alert(\"No path found!\");\n            isRunning = false;\n        }\n\n        // Reconstruct path from end to start\n        async function reconstructPath(node) {\n            const path = [];\n            while (node !== null) {\n                path.unshift(node);\n                node = node.parent;\n            }\n\n            for (const cell of path) {\n                if (!(cell.row === start.row && cell.col === start.col) && \n                    !(cell.row === end.row && cell.col === end.col)) {\n                    cell.element.classList.add('path');\n                    await new Promise(resolve => setTimeout(resolve, 50));\n                }\n            }\n        }\n\n        // Reset grid\n        function resetGrid() {\n            if (isRunning) return;\n            start = { row: 0, col: 0 };\n            end = { row: ROWS-1, col: COLS-1 };\n            initGrid();\n        }\n\n        // Event listeners for buttons\n        document.getElementById('setStart').addEventListener('click', () => { mode = 'start'; });\n        document.getElementById('setEnd').addEventListener('click', () => { mode = 'end'; });\n        document.getElementById('setWall').addEventListener('click', () => { mode = 'wall'; });\n        document.getElementById('clearCell').addEventListener('click', () => { mode = 'clear'; });\n        document.getElementById('runAStar').addEventListener('click', aStarSearch);\n        document.getElementById('reset').addEventListener('click', resetGrid);\n\n        // Initialize\n        initGrid();\n    </script>\n</body>\n</html>"
