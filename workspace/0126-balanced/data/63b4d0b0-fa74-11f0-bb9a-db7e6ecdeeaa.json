    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Digital Signatures Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    color: #007acc;\n  }\n  textarea {\n    width: 100%;\n    height: 100px;\n    font-family: monospace;\n    font-size: 1rem;\n    margin-bottom: 1rem;\n  }\n  pre {\n    background: #e7f1ff;\n    padding: 1rem;\n    overflow-x: auto;\n    border-radius: 4px;\n    font-family: monospace;\n  }\n  button {\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    margin-right: 1rem;\n    border-radius: 4px;\n    border: 1px solid #007acc;\n    background: #008cff;\n    color: white;\n    cursor: pointer;\n    transition: background-color 0.2s ease;\n  }\n  button:hover:not(:disabled) {\n    background: #005f99;\n  }\n  button:disabled {\n    background: #aaccee;\n    cursor: not-allowed;\n  }\n  section {\n    margin-bottom: 2rem;\n  }\n  label {\n    font-weight: bold;\n    display: block;\n    margin-bottom: 0.3rem;\n  }\n  #status {\n    color: green;\n    margin-top: 0.7rem;\n  }\n  #error {\n    color: red;\n    margin-top: 0.7rem;\n  }\n  small {\n    color: #666;\n  }\n</style>\n</head>\n<body>\n<h1>Digital Signatures Demonstration</h1>\n\n<section>\n  <label for=\"message\">Step 1: Enter a message to sign</label>\n  <textarea id=\"message\" placeholder=\"Type your message here...\">Hello World!</textarea>\n  <br />\n  <button id=\"generateKeyBtn\">Generate Key Pair</button>\n  <span id=\"keyStatus\"></span>\n</section>\n\n<section id=\"keysSection\" style=\"display:none;\">\n  <label>Public Key (Base64):</label>\n  <pre id=\"publicKey\"></pre>\n\n  <label>Private Key (Base64, keep secret):</label>\n  <pre id=\"privateKey\"></pre>\n</section>\n\n<section id=\"signSection\" style=\"display:none;\">\n  <label>Step 2: Sign the message</label>\n  <button id=\"signBtn\">Sign Message</button>\n  <pre id=\"signature\"></pre>\n</section>\n\n<section id=\"verifySection\" style=\"display:none;\">\n  <label>Step 3: Verify the signature</label>\n  <button id=\"verifyBtn\">Verify Signature</button>\n  <div id=\"verificationResult\"></div>\n</section>\n\n<hr />\n<p><strong>About:</strong> This demonstration uses Web Crypto API to generate an RSA key pair, sign a message using the private key, then verify the signature using the public key. Digital signatures ensure message authenticity, integrity, and non-repudiation.</p>\n\n<script>\n(async () => {\n  const generateKeyBtn = document.getElementById('generateKeyBtn');\n  const signBtn = document.getElementById('signBtn');\n  const verifyBtn = document.getElementById('verifyBtn');\n  const messageInput = document.getElementById('message');\n  const keyStatus = document.getElementById('keyStatus');\n  const publicKeyPre = document.getElementById('publicKey');\n  const privateKeyPre = document.getElementById('privateKey');\n  const signaturePre = document.getElementById('signature');\n  const verificationResult = document.getElementById('verificationResult');\n  const keysSection = document.getElementById('keysSection');\n  const signSection = document.getElementById('signSection');\n  const verifySection = document.getElementById('verifySection');\n\n  let keyPair = null;\n  let signature = null;\n\n  function arrayBufferToBase64(buffer) {\n    // Convert an ArrayBuffer to Base64 string\n    let binary = '';\n    const bytes = new Uint8Array(buffer);\n    for (let b of bytes) binary += String.fromCharCode(b);\n    return window.btoa(binary);\n  }\n  function base64ToArrayBuffer(base64) {\n    // Convert Base64 to ArrayBuffer\n    const binary = window.atob(base64);\n    const buffer = new Uint8Array(binary.length);\n    for (let i = 0; i < binary.length; i++) {\n      buffer[i] = binary.charCodeAt(i);\n    }\n    return buffer.buffer;\n  }\n\n  // Encode text to Uint8Array\n  function encodeUTF8(str) {\n    return new TextEncoder().encode(str);\n  }\n\n  // Decode Uint8Array to string\n  function decodeUTF8(buf) {\n    return new TextDecoder().decode(buf);\n  }\n\n  generateKeyBtn.onclick = async () => {\n    keyStatus.textContent = 'Generating keys...';\n    try {\n      keyPair = await window.crypto.subtle.generateKey(\n        {\n          name: \"RSASSA-PKCS1-v1_5\",\n          modulusLength: 2048,\n          publicExponent: new Uint8Array([1, 0, 1]),\n          hash: \"SHA-256\",\n        },\n        true,\n        [\"sign\", \"verify\"]\n      );\n      keyStatus.textContent = 'Key pair generated successfully.';\n      // Export keys as Base64 PEM strings for display\n      const pubKeyBuffer = await window.crypto.subtle.exportKey(\"spki\", keyPair.publicKey);\n      const privKeyBuffer = await window.crypto.subtle.exportKey(\"pkcs8\", keyPair.privateKey);\n\n      // Format keys as PEM for better readability\n      publicKeyPre.textContent = `-----BEGIN PUBLIC KEY-----\\n${arrayBufferToBase64(pubKeyBuffer).match(/.{1,64}/g).join('\\n')}\\n-----END PUBLIC KEY-----`;\n      privateKeyPre.textContent = `-----BEGIN PRIVATE KEY-----\\n${arrayBufferToBase64(privKeyBuffer).match(/.{1,64}/g).join('\\n')}\\n-----END PRIVATE KEY-----`;\n\n      keysSection.style.display = 'block';\n      signSection.style.display = 'block';\n      verifySection.style.display = 'none';\n      signaturePre.textContent = '';\n      verificationResult.textContent = '';\n      signature = null;\n    } catch (e) {\n      keyStatus.textContent = 'Error generating keys: ' + e.message;\n      keysSection.style.display = 'none';\n      signSection.style.display = 'none';\n      verifySection.style.display = 'none';\n      signaturePre.textContent = '';\n      verificationResult.textContent = '';\n    }\n  };\n\n  signBtn.onclick = async () => {\n    if (!keyPair) {\n      alert(\"Please generate the key pair first.\");\n      return;\n    }\n    const message = messageInput.value;\n    if (!message) {\n      alert(\"Please enter a message to sign.\");\n      return;\n    }\n    try {\n      const encodedMsg = encodeUTF8(message);\n      signature = await window.crypto.subtle.sign(\n        {\n          name: \"RSASSA-PKCS1-v1_5\",\n        },\n        keyPair.privateKey,\n        encodedMsg\n      );\n      signaturePre.textContent = arrayBufferToBase64(signature);\n      verificationResult.textContent = '';\n      verifySection.style.display = 'block';\n    } catch (e) {\n      signaturePre.textContent = 'Error signing message: ' + e.message;\n      verificationResult.textContent = '';\n      verifySection.style.display = 'none';\n    }\n  };\n\n  verifyBtn.onclick = async () => {\n    if (!keyPair) {\n      alert(\"Please generate the key pair first.\");\n      return;\n    }\n    if (!signature) {\n      alert(\"Please sign the message first.\");\n      return;\n    }\n    const message = messageInput.value;\n    if (!message) {\n      alert(\"Please enter a message to verify.\");\n      return;\n    }\n    try {\n      const encodedMsg = encodeUTF8(message);\n      const isValid = await window.crypto.subtle.verify(\n        {\n          name: \"RSASSA-PKCS1-v1_5\",\n        },\n        keyPair.publicKey,\n        signature,\n        encodedMsg\n      );\n      if (isValid) {\n        verificationResult.style.color = 'green';\n        verificationResult.textContent = '✅ Signature is VALID. Message is authentic and unaltered.';\n      } else {\n        verificationResult.style.color = 'red';\n        verificationResult.textContent = '❌ Signature is INVALID. Message or signature has been tampered with.';\n      }\n    } catch (e) {\n      verificationResult.style.color = 'red';\n      verificationResult.textContent = 'Error verifying signature: ' + e.message;\n    }\n  };\n})();\n</script>\n</body>\n</html>"
