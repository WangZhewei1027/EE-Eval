    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Time Complexity Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 20px;\n            padding: 20px;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        h1 {\n            text-align: center;\n        }\n        button {\n            padding: 10px 20px;\n            font-size: 16px;\n            margin: 10px;\n        }\n        #result {\n            margin-top: 20px;\n            font-weight: bold;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Time Complexity Demonstration</h1>\n    \n    <button id=\"constant-time\">O(1) - Constant Time</button>\n    <button id=\"linear-time\">O(n) - Linear Time</button>\n    <button id=\"quadratic-time\">O(n^2) - Quadratic Time</button>\n\n    <div id=\"result\"></div>\n\n    <script>\n        function constantTime() {\n            let result = \"O(1) - Constant Time: This operation takes the same amount of time regardless of input size.\";\n            document.getElementById('result').innerText = result;\n        }\n\n        function linearTime(n) {\n            let start = Date.now();\n            let sum = 0;\n            for (let i = 0; i < n; i++) {\n                sum += i; // This loop runs 'n' times\n            }\n            let end = Date.now();\n            let timeTaken = end - start;\n            let result = `O(n) - Linear Time: Time taken for n = ${n} is ${timeTaken} milliseconds.`;\n            document.getElementById('result').innerText = result;\n        }\n\n        function quadraticTime(n) {\n            let start = Date.now();\n            let sum = 0;\n            for (let i = 0; i < n; i++) {\n                for (let j = 0; j < n; j++) {\n                    sum += i * j; // This nested loop runs 'n*n' times\n                }\n            }\n            let end = Date.now();\n            let timeTaken = end - start;\n            let result = `O(n^2) - Quadratic Time: Time taken for n = ${n} is ${timeTaken} milliseconds.`;\n            document.getElementById('result').innerText = result;\n        }\n\n        document.getElementById('constant-time').addEventListener('click', constantTime);\n\n        document.getElementById('linear-time').addEventListener('click', function() {\n            linearTime(10000); // Running with n = 10000 to get a measurable linear time\n        });\n\n        document.getElementById('quadratic-time').addEventListener('click', function() {\n            quadraticTime(100); // Running with n = 100 to keep the quadratic time manageable\n        });\n    </script>\n</body>\n</html>"
