  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Transaction Demo — ACID, Locks, Optimistic Concurrency</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root {\n      --bg: #0f1724;\n      --card: #0b1220;\n      --muted: #9aa5bd;\n      --accent: #7dd3fc;\n      --good: #10b981;\n      --bad: #ef4444;\n      --yellow: #f59e0b;\n      --glass: rgba(255,255,255,0.03);\n      --panel-pad: 12px;\n    }\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,#071023 0%, #071a2a 100%);font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;}\n    .wrap{max-width:1200px;margin:28px auto;padding:20px;color:#e6eef8}\n    h1{margin:0 0 6px;font-size:20px}\n    .subtitle{color:var(--muted);font-size:13px;margin-bottom:18px}\n    .grid{display:grid;grid-template-columns:360px 1fr;gap:18px;align-items:start}\n    .card{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.03);border-radius:10px;padding:var(--panel-pad);box-shadow:0 6px 18px rgba(2,6,23,0.6)}\n    .accounts-table{width:100%;border-collapse:collapse;margin-top:8px}\n    .accounts-table th,.accounts-table td{padding:8px 6px;text-align:left;font-size:13px;color:#dfe9f8}\n    .accounts-table th{color:var(--muted);font-weight:600;font-size:12px}\n    .balance{font-weight:700}\n    .btn{display:inline-block;padding:8px 10px;border-radius:8px;background:var(--glass);border:1px solid rgba(255,255,255,0.03);color:var(--accent);cursor:pointer;margin:4px 6px 0 0;font-size:13px}\n    .btn:hover{filter:brightness(1.08)}\n    .btn.small{padding:6px 8px;font-size:12px;border-radius:7px}\n    .controls{margin-top:12px}\n    .tx-list{display:flex;flex-wrap:wrap;gap:10px}\n    .tx-card{background:linear-gradient(180deg, rgba(125,211,252,0.06), rgba(255,255,255,0.02));padding:10px;border-radius:8px;border:1px solid rgba(125,211,252,0.06);min-width:260px}\n    .tx-header{display:flex;justify-content:space-between;align-items:center}\n    .tx-id{font-weight:700}\n    .muted{color:var(--muted);font-size:13px}\n    .ops{margin-top:8px;padding-top:8px;border-top:1px dashed rgba(255,255,255,0.03);font-size:13px}\n    .op-row{display:flex;gap:8px;align-items:center;margin-bottom:6px}\n    .select, input[type=\"number\"], input[type=\"text\"]{padding:6px;border-radius:6px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:#e6eef8;font-size:13px}\n    label{font-size:13px;color:var(--muted);display:block;margin-bottom:6px}\n    .log{max-height:240px;overflow:auto;margin-top:8px;padding:8px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.01));font-family:monospace;font-size:12px;color:#cbe9ff}\n    .status{font-size:12px;padding:6px 8px;border-radius:6px;display:inline-block;margin-left:6px}\n    .status.ok{background:rgba(16,185,129,0.12);color:var(--good);border:1px solid rgba(16,185,129,0.08)}\n    .status.bad{background:rgba(239,68,68,0.08);color:var(--bad);border:1px solid rgba(239,68,68,0.06)}\n    .status.warn{background:rgba(245,158,11,0.08);color:var(--yellow);border:1px solid rgba(245,158,11,0.06)}\n    .lite{color:var(--muted);font-size:13px}\n    .row{display:flex;gap:12px;align-items:center}\n    .small-muted{color:var(--muted);font-size:12px}\n    .preview{margin-top:8px;padding:8px;border-radius:8px;background:rgba(7,26,36,0.4);font-size:13px}\n    .locked{background:rgba(239,68,68,0.06);border-radius:6px;padding:4px;color:var(--bad);font-size:12px}\n    .success{color:var(--good);font-weight:700}\n    .danger{color:var(--bad);font-weight:700}\n    footer{margin-top:18px;color:var(--muted);font-size:13px}\n    .explain{font-size:13px;color:var(--muted);margin-top:10px;padding:10px;border-radius:8px;background:rgba(255,255,255,0.01)}\n    .mode-select{display:flex;gap:8px;align-items:center}\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <h1>Transaction Demonstration</h1>\n    <div class=\"subtitle\">Interactive simulation of transactions (ACID): atomicity, consistency, isolation, durability. Try multiple transactions and see commits, rollbacks, locks and optimistic conflicts.</div>\n\n    <div class=\"grid\">\n      <div class=\"card\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div>\n            <div style=\"font-weight:700\">Accounts</div>\n            <div class=\"small-muted\">Balances reflect current committed state</div>\n          </div>\n          <div class=\"mode-select\">\n            <label class=\"lite\" style=\"margin-right:6px\">Concurrency mode</label>\n            <select id=\"mode\" class=\"select\" title=\"Choose concurrency behavior\">\n              <option value=\"pessimistic\">Pessimistic (locks)</option>\n              <option value=\"optimistic\">Optimistic (version checks)</option>\n              <option value=\"snapshot\">Snapshot isolation (read-only snapshot + optimistic write)</option>\n            </select>\n          </div>\n        </div>\n\n        <table class=\"accounts-table\" id=\"accountsTable\" aria-live=\"polite\">\n          <thead>\n            <tr><th>Account</th><th>Balance</th><th>Version</th></tr>\n          </thead>\n          <tbody id=\"accountsBody\"></tbody>\n        </table>\n\n        <div class=\"controls\">\n          <button class=\"btn\" id=\"resetBtn\">Reset Demo</button>\n          <button class=\"btn\" id=\"persistBtn\">Persist committed state (Durability)</button>\n          <button class=\"btn\" id=\"clearPersistBtn\">Clear persisted</button>\n        </div>\n\n        <div class=\"explain\" id=\"explainBox\">\n          <strong>How it works:</strong>\n          <ul style=\"margin:8px 0 0 18px;color:var(--muted)\">\n            <li>Begin transactions on the right; add operations (deposit, withdraw, transfer).</li>\n            <li>In Pessimistic mode, write locks prevent concurrent writes.</li>\n            <li>In Optimistic mode, transactions check versions at commit and abort on conflict (you can retry).</li>\n            <li>Committed state is saved to localStorage with \"Persist committed state\". This demonstrates durability across reloads.</li>\n          </ul>\n        </div>\n      </div>\n\n      <div class=\"card\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div>\n            <div style=\"font-weight:700\">Transactions</div>\n            <div class=\"small-muted\">Open multiple transactions to simulate concurrency</div>\n          </div>\n          <div>\n            <button class=\"btn small\" id=\"newTxBtn\">New Transaction</button>\n            <button class=\"btn small\" id=\"scenarioBtn\">Run 2-TX Scenario</button>\n          </div>\n        </div>\n\n        <div id=\"txContainer\" style=\"margin-top:10px\" class=\"tx-list\"></div>\n\n        <div style=\"margin-top:10px\">\n          <div style=\"font-weight:700\">Log</div>\n          <div class=\"log\" id=\"log\"></div>\n        </div>\n      </div>\n    </div>\n\n    <footer>\n      Tip: create two transactions, make conflicting updates and commit in different orders to see locking or optimistic failures. This is a simplified educational model.\n    </footer>\n  </div>\n\n  <script>\n    // Simple in-memory database with persistence to localStorage for durability demonstration.\n    (function(){\n      // Utilities\n      const $ = id => document.getElementById(id);\n      const formatMoney = n => \"$\" + n.toFixed(2);\n      const randomId = () => Math.random().toString(36).slice(2,9);\n\n      // Local storage keys\n      const LS_ACCOUNTS = \"tx-demo-accounts-v1\";\n      const LS_LOG = \"tx-demo-log-v1\";\n\n      // Default accounts\n      const defaultAccounts = [\n        { id: \"A\", name: \"Checking\", balance: 1000.00, version: 1 },\n        { id: \"B\", name: \"Savings\", balance: 2500.00, version: 1 },\n        { id: \"C\", name: \"Investment\", balance: 5000.00, version: 1 }\n      ];\n\n      // Global state\n      let accounts = []; // committed state\n      let locks = {}; // accountId -> txId (pessimistic mode)\n      let txs = {}; // txId -> tx object\n      let logEntries = [];\n\n      // UI elements\n      const accountsBody = $(\"accountsBody\");\n      const txContainer = $(\"txContainer\");\n      const logDiv = $(\"log\");\n      const modeSelect = $(\"mode\");\n\n      // Initialize from persisted or default\n      function loadState() {\n        const stored = localStorage.getItem(LS_ACCOUNTS);\n        if (stored) {\n          try {\n            accounts = JSON.parse(stored);\n            appendLog(\"Loaded persisted committed state (durability).\");\n          } catch(e) {\n            accounts = JSON.parse(JSON.stringify(defaultAccounts));\n          }\n        } else {\n          accounts = JSON.parse(JSON.stringify(defaultAccounts));\n        }\n        const storedLog = localStorage.getItem(LS_LOG);\n        if (storedLog) {\n          try { logEntries = JSON.parse(storedLog); } catch(e){ logEntries = []; }\n        } else {\n          logEntries = [];\n        }\n      }\n\n      function persistState() {\n        localStorage.setItem(LS_ACCOUNTS, JSON.stringify(accounts));\n        localStorage.setItem(LS_LOG, JSON.stringify(logEntries));\n        appendLog(\"Persisted committed state to localStorage (Durability).\");\n      }\n\n      // Reset demo to defaults (clears persisted)\n      function resetDemo() {\n        accounts = JSON.parse(JSON.stringify(defaultAccounts));\n        locks = {};\n        txs = {};\n        logEntries = [];\n        localStorage.removeItem(LS_ACCOUNTS);\n        localStorage.removeItem(LS_LOG);\n        renderAll();\n        appendLog(\"Demo reset to defaults.\");\n      }\n\n      // Logging\n      function appendLog(msg) {\n        const time = new Date().toLocaleTimeString();\n        logEntries.unshift(`[${time}] ${msg}`);\n        if (logEntries.length > 200) logEntries.length = 200;\n        renderLog();\n      }\n      function renderLog() {\n        logDiv.textContent = logEntries.join(\"\\n\");\n      }\n\n      // Account helpers\n      function findAccount(id) {\n        return accounts.find(a => a.id === id);\n      }\n\n      function renderAccounts() {\n        accountsBody.innerHTML = \"\";\n        accounts.forEach(a => {\n          const tr = document.createElement(\"tr\");\n          const nameTd = document.createElement(\"td\");\n          nameTd.innerHTML = `<strong>${a.name}</strong> <div class=\"small-muted\">${a.id}</div>`;\n          const balTd = document.createElement(\"td\");\n          balTd.innerHTML = `<span class=\"balance\">${formatMoney(a.balance)}</span>`;\n          const verTd = document.createElement(\"td\");\n          verTd.innerHTML = `<span class=\"small-muted\">v${a.version}</span>`;\n          tr.appendChild(nameTd);\n          tr.appendChild(balTd);\n          tr.appendChild(verTd);\n          accountsBody.appendChild(tr);\n        });\n      }\n\n      // Transaction model\n      // Each transaction:\n      //  - id\n      //  - mode (reads snapshot versions at begin if snapshot or optimistic)\n      //  - ops: list of operations to apply at commit {type, from, to, amount}\n      //  - state: 'active'|'committed'|'aborted'\n      //  - tentativeBalances: computed preview when adding ops\n      //  - readVersions: snapshot of versions at begin (for optimistic/snapshot)\n      //  - acquiredLocks: set of accountIds locked (for pessimistic)\n      class Transaction {\n        constructor() {\n          this.id = randomId();\n          this.ops = [];\n          this.state = \"active\";\n          this.acquiredLocks = new Set();\n          this.readVersions = {};\n          this.createdAt = new Date();\n          // capture snapshot versions if mode requires\n          const mode = modeSelect.value;\n          if (mode === \"optimistic\" || mode === \"snapshot\") {\n            accounts.forEach(a => { this.readVersions[a.id] = a.version; });\n          }\n        }\n\n        addOp(op) {\n          if (this.state !== \"active\") throw new Error(\"Transaction not active\");\n          this.ops.push(op);\n        }\n\n        // compute tentative balances by applying ops to committed accounts\n        computeTentative() {\n          const base = accounts.reduce((m,a)=>{ m[a.id]= {id:a.id,name:a.name,balance:a.balance,version:a.version}; return m; },{});\n          for (let op of this.ops) {\n            if (op.type === \"deposit\") {\n              base[op.to].balance += op.amount;\n            } else if (op.type === \"withdraw\") {\n              base[op.from].balance -= op.amount;\n            } else if (op.type === \"transfer\") {\n              base[op.from].balance -= op.amount;\n              base[op.to].balance += op.amount;\n            }\n          }\n          return base;\n        }\n\n        validateTentative() {\n          const tentative = this.computeTentative();\n          // check for negative balances\n          for (let id in tentative) {\n            if (tentative[id].balance < -0.0001) {\n              return { ok:false, reason: `Account ${tentative[id].name} would go negative (${formatMoney(tentative[id].balance)})` };\n            }\n          }\n          return { ok:true };\n        }\n\n        // Attempt commit according to mode\n        async commit() {\n          if (this.state !== \"active\") {\n            throw new Error(\"Can only commit active transaction\");\n          }\n          const mode = modeSelect.value;\n          if (mode === \"pessimistic\") {\n            return this._commitPessimistic();\n          } else if (mode === \"optimistic\") {\n            return this._commitOptimistic();\n          } else if (mode === \"snapshot\") {\n            return this._commitSnapshot();\n          } else {\n            throw new Error(\"Unknown mode\");\n          }\n        }\n\n        // Pessimistic: attempt to acquire locks for all accounts that will be written.\n        _accountsTouched() {\n          const set = new Set();\n          for (let op of this.ops) {\n            if (op.type === \"deposit\") set.add(op.to);\n            else if (op.type === \"withdraw\") set.add(op.from);\n            else if (op.type === \"transfer\") { set.add(op.from); set.add(op.to); }\n          }\n          return Array.from(set);\n        }\n\n        _acquireLocksForTouched() {\n          const touched = this._accountsTouched();\n          // Acquire if free; if any locked by different tx -> fail to acquire\n          for (let acc of touched) {\n            const owner = locks[acc];\n            if (owner && owner !== this.id) {\n              return { ok:false, conflictWith: owner, account: acc };\n            }\n          }\n          // Acquire\n          touched.forEach(a => { locks[a] = this.id; this.acquiredLocks.add(a); });\n          return { ok:true, touched };\n        }\n\n        _releaseLocks() {\n          this.acquiredLocks.forEach(a => { if (locks[a] === this.id) delete locks[a]; });\n          this.acquiredLocks.clear();\n        }\n\n        _applyOps() {\n          // Mutate committed accounts atomically in our single-threaded JS.\n          for (let op of this.ops) {\n            if (op.type === \"deposit\") {\n              const a = findAccount(op.to); a.balance += op.amount; a.version++;\n            } else if (op.type === \"withdraw\") {\n              const a = findAccount(op.from); a.balance -= op.amount; a.version++;\n            } else if (op.type === \"transfer\") {\n              const a1 = findAccount(op.from), a2 = findAccount(op.to);\n              a1.balance -= op.amount; a1.version++;\n              a2.balance += op.amount; a2.version++;\n            }\n          }\n        }\n\n        _commitPessimistic() {\n          // Try to acquire locks\n          const acq = this._acquireLocksForTouched();\n          if (!acq.ok) {\n            appendLog(`TX ${this.id}: cannot acquire lock on ${acq.account} (held by ${acq.conflictWith}). Commit blocked.`);\n            return { ok:false, reason:`Lock conflict on ${acq.account} with ${acq.conflictWith}` };\n          }\n          // Validate tentative\n          const v = this.validateTentative();\n          if (!v.ok) {\n            this._releaseLocks();\n            this.state = \"aborted\";\n            appendLog(`TX ${this.id}: aborted during validation: ${v.reason}`);\n            return { ok:false, reason:v.reason };\n          }\n          // Apply\n          this._applyOps();\n          this.state = \"committed\";\n          appendLog(`TX ${this.id}: committed (pessimistic).`);\n          // release locks after commit\n          this._releaseLocks();\n          renderAll();\n          return { ok:true };\n        }\n\n        _commitOptimistic() {\n          // Validate tentative first\n          const v = this.validateTentative();\n          if (!v.ok) {\n            this.state = \"aborted\";\n            appendLog(`TX ${this.id}: aborted during validation: ${v.reason}`);\n            return { ok:false, reason:v.reason };\n          }\n\n          // Check versions of all touched accounts are unchanged since transaction began\n          const touched = this._accountsTouched();\n          let conflicts = [];\n          for (let acc of touched) {\n            const current = findAccount(acc);\n            const readVersion = this.readVersions[acc] ?? 0;\n            if (current.version !== readVersion) {\n              conflicts.push({acc, expected:readVersion, actual:current.version});\n            }\n          }\n          if (conflicts.length) {\n            this.state = \"aborted\";\n            appendLog(`TX ${this.id}: optimistic conflict, aborting. Conflicts: ${conflicts.map(c=>c.acc).join(\", \")}`);\n            return { ok:false, reason:\"Optimistic conflict\", conflicts };\n          }\n\n          // Apply\n          this._applyOps();\n          this.state = \"committed\";\n          appendLog(`TX ${this.id}: committed (optimistic).`);\n          renderAll();\n          return { ok:true };\n        }\n\n        _commitSnapshot() {\n          // Snapshot: reads are from snapshot taken at begin; writes use optimistic check on write-set\n          const v = this.validateTentative();\n          if (!v.ok) {\n            this.state = \"aborted\";\n            appendLog(`TX ${this.id}: aborted during validation: ${v.reason}`);\n            return { ok:false, reason:v.reason };\n          }\n          // Only check versions of accounts in write-set\n          const touched = this._accountsTouched();\n          let conflicts = [];\n          for (let acc of touched) {\n            const current = findAccount(acc);\n            const readVersion = this.readVersions[acc] ?? 0;\n            if (current.version !== readVersion) {\n              conflicts.push({acc, expected:readVersion, actual:current.version});\n            }\n          }\n          if (conflicts.length) {\n            this.state = \"aborted\";\n            appendLog(`TX ${this.id}: snapshot write conflict, aborting. ${conflicts.map(c=>c.acc).join(\", \")}`);\n            return { ok:false, reason:\"Snapshot conflict\", conflicts };\n          }\n          // Apply\n          this._applyOps();\n          this.state = \"committed\";\n          appendLog(`TX ${this.id}: committed (snapshot).`);\n          renderAll();\n          return { ok:true };\n        }\n\n        rollback() {\n          if (this.state !== \"active\") {\n            appendLog(`TX ${this.id}: cannot rollback, state=${this.state}`);\n            return { ok:false };\n          }\n          // release any locks\n          this._releaseLocks();\n          this.state = \"aborted\";\n          appendLog(`TX ${this.id}: rolled back by user.`);\n          renderAll();\n          return { ok:true };\n        }\n      }\n\n      // UI: create transaction card\n      function createTxCard(tx) {\n        const card = document.createElement(\"div\");\n        card.className = \"tx-card\";\n        card.id = \"tx-\" + tx.id;\n\n        const header = document.createElement(\"div\");\n        header.className = \"tx-header\";\n        const title = document.createElement(\"div\");\n        title.innerHTML = `<div class=\"tx-id\">TX ${tx.id}</div><div class=\"small-muted\">state: <span id=\"state-${tx.id}\">${tx.state}</span></div>`;\n        header.appendChild(title);\n\n        const actions = document.createElement(\"div\");\n        const commitBtn = document.createElement(\"button\");\n        commitBtn.className = \"btn small\";\n        commitBtn.textContent = \"Commit\";\n        const rollbackBtn = document.createElement(\"button\");\n        rollbackBtn.className = \"btn small\";\n        rollbackBtn.textContent = \"Rollback\";\n        const addOpBtn = document.createElement(\"button\");\n        addOpBtn.className = \"btn small\";\n        addOpBtn.textContent = \"Add Op\";\n        const delBtn = document.createElement(\"button\");\n        delBtn.className = \"btn small\";\n        delBtn.textContent = \"Close\";\n        actions.appendChild(addOpBtn);\n        actions.appendChild(commitBtn);\n        actions.appendChild(rollbackBtn);\n        actions.appendChild(delBtn);\n        header.appendChild(actions);\n        card.appendChild(header);\n\n        // operations list\n        const opsDiv = document.createElement(\"div\");\n        opsDiv.className = \"ops\";\n        opsDiv.id = \"ops-\" + tx.id;\n        card.appendChild(opsDiv);\n\n        // preview\n        const preview = document.createElement(\"div\");\n        preview.className = \"preview\";\n        preview.id = \"preview-\" + tx.id;\n        card.appendChild(preview);\n\n        // op builder form (hidden until \"Add Op\")\n        function renderOpEditor() {\n          const form = document.createElement(\"div\");\n          form.style.marginTop = \"8px\";\n          const typeSel = document.createElement(\"select\");\n          typeSel.className = \"select\";\n          typeSel.innerHTML = `<option value=\"transfer\">Transfer</option><option value=\"deposit\">Deposit</option><option value=\"withdraw\">Withdraw</option>`;\n          const fromSel = document.createElement(\"select\");\n          fromSel.className = \"select\";\n          const toSel = document.createElement(\"select\");\n          toSel.className = \"select\";\n          const amt = document.createElement(\"input\");\n          amt.type = \"number\"; amt.step = \"0.01\"; amt.placeholder = \"Amount\"; amt.className = \"select\";\n          amt.style.width = \"120px\";\n          const addBtn = document.createElement(\"button\");\n          addBtn.className = \"btn small\";\n          addBtn.textContent = \"Add\";\n          const cancelBtn = document.createElement(\"button\");\n          cancelBtn.className = \"btn small\";\n          cancelBtn.textContent = \"Cancel\";\n\n          function fillAccs() {\n            fromSel.innerHTML = \"\"; toSel.innerHTML = \"\";\n            accounts.forEach(a => {\n              const o1 = document.createElement(\"option\"); o1.value = a.id; o1.textContent = `${a.name} (${a.id})`;\n              const o2 = document.createElement(\"option\"); o2.value = a.id; o2.textContent = `${a.name} (${a.id})`;\n              fromSel.appendChild(o1); toSel.appendChild(o2);\n            });\n          }\n          fillAccs();\n\n          form.appendChild(typeSel);\n          form.appendChild(fromSel);\n          form.appendChild(toSel);\n          form.appendChild(amt);\n          form.appendChild(addBtn);\n          form.appendChild(cancelBtn);\n          opsDiv.prepend(form);\n\n          function refreshEditor() {\n            const t = typeSel.value;\n            if (t === \"transfer\") { fromSel.style.display = \"\"; toSel.style.display = \"\"; }\n            if (t === \"deposit\") { fromSel.style.display = \"none\"; toSel.style.display = \"\"; }\n            if (t === \"withdraw\") { fromSel.style.display = \"\"; toSel.style.display = \"none\"; }\n          }\n          typeSel.addEventListener(\"change\", refreshEditor);\n          cancelBtn.addEventListener(\"click\", ()=>{ form.remove(); });\n          addBtn.addEventListener(\"click\", ()=>{\n            const t = typeSel.value;\n            const amount = parseFloat(amt.value);\n            if (!amount || amount <= 0) { alert(\"Enter a positive amount\"); return; }\n            let op;\n            if (t === \"transfer\") op = { type:\"transfer\", from: fromSel.value, to: toSel.value, amount };\n            else if (t === \"deposit\") op = { type:\"deposit\", to: toSel.value, amount };\n            else if (t === \"withdraw\") op = { type:\"withdraw\", from: fromSel.value, amount };\n            tx.addOp(op);\n            appendLog(`TX ${tx.id}: added op ${JSON.stringify(op)}`);\n            form.remove();\n            renderTxOps(tx);\n            renderPreview(tx);\n          });\n          refreshEditor();\n        }\n\n        function renderTxOps(tx) {\n          const opsEl = document.getElementById(\"ops-\"+tx.id);\n          opsEl.innerHTML = \"\";\n          tx.ops.forEach((op, idx) => {\n            const row = document.createElement(\"div\");\n            row.className = \"op-row\";\n            row.style.justifyContent = \"space-between\";\n            const left = document.createElement(\"div\");\n            left.style.flex = \"1\";\n            const text = (() => {\n              if (op.type===\"deposit\") return `Deposit ${formatMoney(op.amount)} → ${op.to}`;\n              if (op.type===\"withdraw\") return `Withdraw ${formatMoney(op.amount)} ← ${op.from}`;\n              return `Transfer ${formatMoney(op.amount)} ${op.from} → ${op.to}`;\n            })();\n            left.innerHTML = text;\n            const right = document.createElement(\"div\");\n            const rem = document.createElement(\"button\");\n            rem.className = \"btn small\";\n            rem.textContent = \"Remove\";\n            rem.addEventListener(\"click\", ()=>{ tx.ops.splice(idx,1); appendLog(`TX ${tx.id}: removed op`); renderTxOps(tx); renderPreview(tx); });\n            right.appendChild(rem);\n            row.appendChild(left); row.appendChild(right);\n            opsEl.appendChild(row);\n          });\n        }\n\n        function renderPreview(tx) {\n          const pre = document.getElementById(\"preview-\" + tx.id);\n          if (tx.state !== \"active\") {\n            pre.innerHTML = `<div class=\"small-muted\">Transaction ${tx.state}</div>`;\n            return;\n          }\n          const tentative = tx.computeTentative();\n          let html = `<div style=\"font-weight:700\">Tentative balances</div><div class=\"small-muted\">Preview based on committed state + ops</div><div style=\"margin-top:8px\">`;\n          for (let id in tentative) {\n            const t = tentative[id];\n            const committed = findAccount(id);\n            let diff = t.balance - committed.balance;\n            let diffStr = diff >= 0 ? `+${formatMoney(diff)}` : `${formatMoney(diff)}`;\n            html += `<div style=\"display:flex;justify-content:space-between;padding:4px 0\"><div>${t.name} (${t.id})</div><div>${formatMoney(t.balance)} <span class=\"small-muted\">(${diffStr})</span></div></div>`;\n          }\n          html += `</div>`;\n          const validation = tx.validateTentative();\n          if (!validation.ok) {\n            html += `<div style=\"margin-top:8px\" class=\"status bad\">Invalid: ${validation.reason}</div>`;\n          } else {\n            html += `<div style=\"margin-top:8px\" class=\"status ok\">Valid (no negative balances)</div>`;\n          }\n          // show locks if any\n          const mode = modeSelect.value;\n          if (mode === \"pessimistic\") {\n            const touched = tx._accountsTouched();\n            const lockInfo = touched.map(a => {\n              const owner = locks[a];\n              if (owner && owner !== tx.id) return `<div class=\"locked\">${a} locked by ${owner}</div>`;\n              if (owner === tx.id) return `<div style=\"color:var(--good)\">Locked by this TX: ${a}</div>`;\n              return `<div style=\"color:var(--muted)\">Not locked: ${a}</div>`;\n            }).join(\"\");\n            html += `<div style=\"margin-top:8px\">${lockInfo}</div>`;\n          } else if (mode === \"optimistic\" || mode === \"snapshot\") {\n            html += `<div style=\"margin-top:8px\" class=\"small-muted\">Snapshot versions captured at start: ${Object.keys(tx.readVersions).length ? 'yes' : 'no'}</div>`;\n          }\n          pre.innerHTML = html;\n        }\n\n        // Event handlers\n        addOpBtn.addEventListener(\"click\", ()=> { renderOpEditor(); });\n        commitBtn.addEventListener(\"click\", async () => {\n          commitBtn.disabled = true;\n          rollbackBtn.disabled = true;\n          try {\n            const res = await tx.commit();\n            if (res.ok) {\n              appendLog(`TX ${tx.id}: SUCCESS`);\n              renderTxState(tx);\n            } else {\n              appendLog(`TX ${tx.id}: COMMIT FAILED — ${res.reason || 'unknown'}`);\n              // For optimistic aborts, we may offer retry dialog — simplified: show message\n              renderTxState(tx);\n            }\n          } catch(e) {\n            appendLog(`TX ${tx.id}: error during commit: ${e.message}`);\n          } finally {\n            commitBtn.disabled = false;\n            rollbackBtn.disabled = false;\n          }\n        });\n        rollbackBtn.addEventListener(\"click\", ()=> {\n          tx.rollback();\n          renderTxState(tx);\n        });\n        delBtn.addEventListener(\"click\", ()=> {\n          if (tx.state === \"active\") {\n            if (!confirm(\"Transaction still active — rollback and close?\")) return;\n            tx.rollback();\n          }\n          delete txs[tx.id];\n          card.remove();\n        });\n\n        function renderTxState(tx) {\n          const stateEl = document.getElementById(\"state-\"+tx.id);\n          stateEl.textContent = tx.state;\n          if (tx.state !== \"active\") {\n            commitBtn.disabled = true;\n            addOpBtn.disabled = true;\n          }\n          renderTxOps(tx);\n          renderPreview(tx);\n          renderAccounts(); // committed state may have changed\n          renderLocks();\n          persistLogOnly(); // keep log in UI (not always persisted)\n        }\n\n        // initial render\n        txContainer.prepend(card);\n        renderTxOps(tx);\n        renderPreview(tx);\n        return card;\n      }\n\n      function persistLogOnly() {\n        localStorage.setItem(LS_LOG, JSON.stringify(logEntries));\n      }\n\n      // Render locks summary somewhere (we'll append to explainBox)\n      function renderLocks() {\n        const explainBox = $(\"explainBox\");\n        // remove any existing locks display\n        const existing = explainBox.querySelector(\".locks\");\n        if (existing) existing.remove();\n        const div = document.createElement(\"div\");\n        div.className = \"locks\";\n        div.style.marginTop = \"8px\";\n        let keys = Object.keys(locks);\n        if (!keys.length) {\n          div.innerHTML = `<div class=\"small-muted\">No locks held</div>`;\n        } else {\n          div.innerHTML = `<div style=\"font-weight:700\">Locks held</div>` + keys.map(k => {\n            return `<div class=\"small-muted\">${k} → ${locks[k]}</div>`;\n          }).join(\"\");\n        }\n        explainBox.appendChild(div);\n      }\n\n      // Rendering everything\n      function renderAll() {\n        renderAccounts();\n        renderLog();\n        renderLocks();\n      }\n\n      // UI actions\n      $(\"newTxBtn\").addEventListener(\"click\", ()=> {\n        const tx = new Transaction();\n        txs[tx.id] = tx;\n        createTxCard(tx);\n        appendLog(`TX ${tx.id}: created (mode=${modeSelect.value})`);\n      });\n\n      $(\"resetBtn\").addEventListener(\"click\", ()=> {\n        if (!confirm(\"Reset demo (this clears persisted state)?\")) return;\n        resetDemo();\n      });\n\n      $(\"persistBtn\").addEventListener(\"click\", ()=> {\n        persistState();\n      });\n\n      $(\"clearPersistBtn\").addEventListener(\"click\", ()=> {\n        if (!confirm(\"Clear persisted committed state from localStorage?\")) return;\n        localStorage.removeItem(LS_ACCOUNTS);\n        localStorage.removeItem(LS_LOG);\n        appendLog(\"Cleared persisted state.\");\n      });\n\n      modeSelect.addEventListener(\"change\", ()=> {\n        appendLog(\"Mode switched to: \" + modeSelect.value);\n      });\n\n      // scenario: two transactions conflicting\n      $(\"scenarioBtn\").addEventListener(\"click\", async ()=> {\n        // Create two txs\n        const tx1 = new Transaction();\n        const tx2 = new Transaction();\n        txs[tx1.id] = tx1; txs[tx2.id] = tx2;\n        createTxCard(tx1); createTxCard(tx2);\n        // TX1: transfer $600 from Checking (A) to Savings (B)\n        tx1.addOp({type:\"transfer\", from:\"A\", to:\"B\", amount:600.00});\n        // TX2: withdraw $500 from Checking (A)\n        tx2.addOp({type:\"withdraw\", from:\"A\", amount:500.00});\n        renderAll();\n        appendLog(`Scenario created: TX ${tx1.id} (transfer $600 A→B), TX ${tx2.id} (withdraw $500 from A). Mode=${modeSelect.value}`);\n\n        // Now simulate committing in order: commit TX2 first, then TX1, to provoke conflict if optimistic\n        await new Promise(r=>setTimeout(r, 500));\n        appendLog(`Committing TX ${tx2.id} first...`);\n        const res2 = await tx2.commit();\n        if (!res2.ok) appendLog(`TX ${tx2.id} failed: ${res2.reason||'unknown'}`);\n        await new Promise(r=>setTimeout(r, 500));\n        appendLog(`Committing TX ${tx1.id} next...`);\n        const res1 = await tx1.commit();\n        if (!res1.ok) {\n          appendLog(`TX ${tx1.id} failed: ${res1.reason||'unknown'}`);\n        }\n        renderAll();\n      });\n\n      // Initial load\n      loadState();\n      renderAll();\n\n      // For convenience, create an initial transaction\n      (function createInitialTx(){\n        const tx = new Transaction();\n        txs[tx.id] = tx;\n        createTxCard(tx);\n        appendLog(`TX ${tx.id}: created (starter)`);\n      })();\n\n      // Expose reset for console for advanced tinkering\n      window.__txdemo = { accounts, txs, locks, appendLog, resetDemo, persistState };\n    })();\n  </script>\n</body>\n</html>"
