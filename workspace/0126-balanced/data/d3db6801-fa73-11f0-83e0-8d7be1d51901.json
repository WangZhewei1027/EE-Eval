    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Decision Trees — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, Arial; margin: 0; padding: 0; color: #111; background: #f7f9fc; }\n    header { padding: 18px 24px; background: linear-gradient(90deg,#1E88E5,#5E35B1); color: white; }\n    header h1 { margin: 0; font-size: 20px; }\n    .wrap { display:flex; gap:16px; padding: 16px; }\n    .panel { background: white; border-radius:8px; box-shadow: 0 2px 8px rgba(20,30,50,0.08); padding:12px; }\n    .left { width: 640px; }\n    .right { flex: 1; min-width: 320px; }\n    .controls { display:flex; gap:8px; flex-wrap:wrap; padding-bottom:8px; align-items:center; }\n    label { font-size:13px; color:#333; }\n    input[type=range] { vertical-align: middle; }\n    input[type=number] { width:64px; padding:4px; margin-left:6px; }\n    button { background:#1E88E5; color:white; border:0; padding:8px 10px; border-radius:6px; cursor:pointer; }\n    button.secondary { background:#546e7a; }\n    .canvas-box { border-radius:6px; overflow:hidden; border:1px solid #e6eef8; background:linear-gradient(180deg,#ffffff,#f1f6ff); position:relative; }\n    svg { display:block; background:transparent; }\n    .info { margin-top:10px; font-size:13px; color:#333; }\n    .stat { font-size:13px; color:#444; margin-bottom:6px; }\n    .legend { display:flex; gap:10px; align-items:center; margin-top:6px; }\n    .legend .item { display:flex; gap:6px; align-items:center; font-size:13px; color:#333; }\n    .dot { width:12px;height:12px;border-radius:50%; display:inline-block; }\n    .tree-area { max-height:560px; overflow:auto; padding:8px; }\n    .node-card { border-radius:8px; padding:8px; background:#fff; border:1px solid #e9eef8; margin-bottom:8px; }\n    .small { font-size:12px; color:#555; }\n    .footer { padding:12px 18px; font-size:12px; color:#666; }\n    .badge { background:#eef3ff; color:#1E3A8A; padding:4px 8px; border-radius:999px; font-weight:600; }\n    .muted { color:#6b7280; font-size:13px; }\n    .control-row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }\n    .toggle { display:inline-flex; gap:8px; align-items:center; cursor:pointer; user-select:none; }\n    .highlight { stroke:#ff9800; stroke-width:3px; fill-opacity:0.06; }\n    .pred-dot { stroke:#222; stroke-width:1.2px; }\n    .node-rect { fill:#fff; stroke:#c5d6f2; }\n    .node-rect.highlight { stroke:#ff9800; stroke-width:2.5px; }\n    .control-note { font-size:12px; color:#666; }\n    a { color:#1E88E5; text-decoration:none; }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Decision Trees — Interactive Demo</h1>\n    <div style=\"font-size:13px; margin-top:6px; opacity:0.95\">Explore how axis-aligned decision trees partition data, choose splits (using Gini), and make predictions. Click points or tree nodes to inspect paths.</div>\n  </header>\n\n  <div class=\"wrap\">\n    <div class=\"left panel\">\n      <div class=\"controls\">\n        <div class=\"control-row\">\n          <label>Samples/class</label>\n          <input id=\"nPerClass\" type=\"number\" min=\"10\" max=\"1000\" value=\"120\">\n        </div>\n\n        <div class=\"control-row\">\n          <label>Spread</label>\n          <input id=\"spread\" type=\"range\" min=\"0.05\" max=\"0.6\" step=\"0.01\" value=\"0.18\">\n          <span class=\"control-note\" id=\"spreadVal\">0.18</span>\n        </div>\n\n        <div class=\"control-row\">\n          <label>Max depth</label>\n          <input id=\"maxDepth\" type=\"range\" min=\"1\" max=\"8\" value=\"4\">\n          <span class=\"control-note\" id=\"maxDepthVal\">4</span>\n        </div>\n\n        <div class=\"control-row\">\n          <label>Min samples to split</label>\n          <input id=\"minSamples\" type=\"number\" min=\"1\" max=\"50\" value=\"8\">\n        </div>\n\n        <div style=\"display:flex; gap:8px; align-items:center;\">\n          <button id=\"regen\">Regenerate</button>\n          <button id=\"train\">Build Tree</button>\n          <button id=\"toggleBound\" class=\"secondary\">Toggle Boundaries</button>\n        </div>\n      </div>\n\n      <div style=\"display:flex; gap:8px; margin-bottom:8px; align-items:center;\">\n        <div class=\"legend\">\n          <div class=\"item\"><span class=\"dot\" style=\"background:#E53935\"></span>Class A</div>\n          <div class=\"item\"><span class=\"dot\" style=\"background:#1E88E5\"></span>Class B</div>\n          <div style=\"width:18px\"></div>\n          <div class=\"item\"><span style=\"display:inline-block;width:14px;height:10px;background:#ff9800;border-radius:3px\"></span>Selected Node</div>\n        </div>\n      </div>\n\n      <div class=\"canvas-box panel\" style=\"padding:8px;\">\n        <svg id=\"plot\" width=\"600\" height=\"600\"></svg>\n        <div class=\"info\">\n          <div class=\"stat\">Tip: Click on the plot to classify a new point (it will show the predicted class and the path). Click a node in the tree to highlight its region and points.</div>\n          <div class=\"stat\">Gini impurity is used to choose splits. Boundaries are axis-aligned (x or y).</div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <div class=\"small muted\">Selected point prediction:</div>\n        <div id=\"predictionBox\" class=\"node-card small\">None</div>\n      </div>\n    </div>\n\n    <div class=\"right panel\">\n      <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n        <div>\n          <div class=\"badge\" id=\"nodeCount\">Nodes: 0</div>\n        </div>\n        <div class=\"muted small\">Interactive tree & region view</div>\n      </div>\n\n      <div class=\"tree-area\" id=\"treeArea\">\n        <svg id=\"treeSvg\" width=\"100%\" height=\"420\"></svg>\n      </div>\n\n      <div style=\"margin-top:8px;\">\n        <div class=\"small muted\">Tree text:</div>\n        <pre id=\"treeText\" class=\"node-card small\" style=\"white-space:pre-wrap;word-break:break-word;\"></pre>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"footer panel\">\n    Built-in demo implementing a simple CART-style decision tree (binary splits on x or y), using Gini impurity. Click the plot to add a test point. Adjust complexity with max depth and min samples. Source: self-contained in this single HTML.\n  </div>\n\n<script>\n(() => {\n  // ---- Data & state ----\n  const plot = document.getElementById('plot');\n  const treeSvg = document.getElementById('treeSvg');\n  const treeText = document.getElementById('treeText');\n  const nodeCount = document.getElementById('nodeCount');\n  const predictionBox = document.getElementById('predictionBox');\n\n  const nPerClassInput = document.getElementById('nPerClass');\n  const spreadInput = document.getElementById('spread');\n  const spreadVal = document.getElementById('spreadVal');\n  const regenBtn = document.getElementById('regen');\n  const trainBtn = document.getElementById('train');\n  const maxDepthInput = document.getElementById('maxDepth');\n  const maxDepthVal = document.getElementById('maxDepthVal');\n  const minSamplesInput = document.getElementById('minSamples');\n  const toggleBoundBtn = document.getElementById('toggleBound');\n\n  let SHOW_BOUNDARIES = true;\n\n  spreadVal.textContent = spreadInput.value;\n  maxDepthVal.textContent = maxDepthInput.value;\n\n  let data = [];\n  let tree = null;\n  let selected = { type: null, item: null }; // {type: 'point'|'node', item: ...}\n\n  // data domain and pixel mapping\n  const PAD = 20;\n  const W = 600, H = 600;\n\n  function mapX(x) { return PAD + (x - domain.xmin) / (domain.xmax - domain.xmin) * (W - 2*PAD); }\n  function mapY(y) { return H - PAD - (y - domain.ymin) / (domain.ymax - domain.ymin) * (H - 2*PAD); }\n\n  let domain = { xmin:-1, xmax:1, ymin:-1, ymax:1 };\n\n  // ---- Utils ----\n  function randn_bm() {\n    // Box-Muller\n    let u=0,v=0; while(u===0) u=Math.random(); while(v===0) v=Math.random();\n    return Math.sqrt(-2.0*Math.log(u))*Math.cos(2.0*Math.PI*v);\n  }\n\n  function generateData(nPer, spread) {\n    const pts = [];\n    // two classes A (label 0) and B (label 1)\n    const centers = [{x:-0.4,y:-0.2},{x:0.45,y:0.25}];\n    for (let k=0;k<2;k++){\n      for (let i=0;i<nPer;i++){\n        const x = centers[k].x + randn_bm()*spread;\n        const y = centers[k].y + randn_bm()*spread;\n        pts.push({x,y,ytrue:k});\n      }\n    }\n    // adjust domain slightly beyond data for nice margins\n    const xs = pts.map(p=>p.x), ys = pts.map(p=>p.y);\n    const xmin = Math.min(...xs), xmax = Math.max(...xs), ymin = Math.min(...ys), ymax = Math.max(...ys);\n    const padx = Math.max(0.3,(xmax-xmin)*0.25), pady = Math.max(0.3,(ymax-ymin)*0.25);\n    domain = { xmin: xmin - padx, xmax: xmax + padx, ymin: ymin - pady, ymax: ymax + pady };\n    return pts;\n  }\n\n  // Gini impurity\n  function gini(labels) {\n    if (labels.length === 0) return 0;\n    const c0 = labels.filter(v=>v===0).length / labels.length;\n    const c1 = 1 - c0;\n    return 1 - (c0*c0 + c1*c1);\n  }\n\n  // Best split (features: x or y)\n  function findBestSplit(samples) {\n    const best = {feature:null, thr:null, score:-Infinity, left:null, right:null, leftIdx:[], rightIdx:[]};\n    const features = ['x','y'];\n    const N = samples.length;\n    const labels = samples.map(s=>s.ytrue);\n    const parentGini = gini(labels);\n\n    // If pure, no split\n    if (parentGini === 0) return null;\n\n    for (const feat of features) {\n      // candidate thresholds: midpoints between sorted values\n      const vals = samples.map(s => s[feat]).sort((a,b)=>a-b);\n      const uniq = [];\n      for (let v of vals) if (uniq.length===0 || Math.abs(v-uniq[uniq.length-1])>1e-8) uniq.push(v);\n      if (uniq.length < 2) continue;\n      for (let i=0;i<uniq.length-1;i++){\n        const thr = (uniq[i] + uniq[i+1]) / 2;\n        // partition\n        const leftIdx = [], rightIdx = [];\n        for (let j=0;j<samples.length;j++){\n          if (samples[j][feat] <= thr) leftIdx.push(j); else rightIdx.push(j);\n        }\n        if (leftIdx.length===0 || rightIdx.length===0) continue;\n        const leftLabels = leftIdx.map(i=>samples[i].ytrue);\n        const rightLabels = rightIdx.map(i=>samples[i].ytrue);\n        const gl = gini(leftLabels), gr = gini(rightLabels);\n        const w = (leftIdx.length / N) * gl + (rightIdx.length / N) * gr;\n        const gain = parentGini - w;\n        if (gain > best.score + 1e-12) {\n          best.feature = feat; best.thr = thr; best.score = gain;\n          best.leftIdx = leftIdx.slice(); best.rightIdx = rightIdx.slice();\n        }\n      }\n    }\n    if (!best.feature) return null;\n    return best;\n  }\n\n  // Build tree recursively\n  function buildTree(samples, depth=0, maxDepth=4, minSamples=2) {\n    const labels = samples.map(s=>s.ytrue);\n    const counts = [labels.filter(l=>l===0).length, labels.filter(l=>l===1).length];\n    const node = {\n      isLeaf: false,\n      prediction: counts[0] >= counts[1] ? 0 : 1,\n      count: samples.length,\n      counts,\n      gini: gini(labels),\n      depth,\n      feature: null,\n      thr: null,\n      left: null,\n      right: null,\n      samples\n    };\n    if (node.count <= minSamples || node.gini === 0 || depth >= maxDepth) {\n      node.isLeaf = true;\n      return node;\n    }\n    const split = findBestSplit(samples);\n    if (!split) { node.isLeaf = true; return node; }\n    // respect minSamples\n    if (split.leftIdx.length < minSamples || split.rightIdx.length < minSamples) {\n      node.isLeaf = true; return node;\n    }\n    // create children\n    const leftSamples = split.leftIdx.map(i=>samples[i]);\n    const rightSamples = split.rightIdx.map(i=>samples[i]);\n    node.feature = split.feature;\n    node.thr = split.thr;\n    node.left = buildTree(leftSamples, depth+1, maxDepth, minSamples);\n    node.right = buildTree(rightSamples, depth+1, maxDepth, minSamples);\n    return node;\n  }\n\n  // Predict and collect path\n  function predictPath(node, pt) {\n    const path = [];\n    let cur = node;\n    while (cur && !cur.isLeaf) {\n      path.push(cur);\n      if (pt[cur.feature] <= cur.thr) cur = cur.left; else cur = cur.right;\n    }\n    if (cur) path.push(cur);\n    const pred = path[path.length-1].prediction;\n    return {pred, path};\n  }\n\n  // Build region rectangles for leaves by following constraints\n  function regionsFromTree(node) {\n    const regions = [];\n    function recurse(n, bounds) {\n      // bounds: {xmin,xmax,ymin,ymax}\n      if (!n) return;\n      if (n.isLeaf) {\n        regions.push({bounds: {...bounds}, prediction:n.prediction, node: n, count: n.count});\n        return;\n      }\n      const f = n.feature, t = n.thr;\n      if (f==='x') {\n        // left: x <= t\n        recurse(n.left, {...bounds, xmax: Math.min(bounds.xmax, t)});\n        recurse(n.right, {...bounds, xmin: Math.max(bounds.xmin, t)});\n      } else {\n        recurse(n.left, {...bounds, ymax: Math.min(bounds.ymax, t)});\n        recurse(n.right, {...bounds, ymin: Math.max(bounds.ymin, t)});\n      }\n    }\n    recurse(node, {...domain});\n    return regions;\n  }\n\n  // ---- Drawing ----\n  function clearSvg(svg) {\n    while (svg.firstChild) svg.removeChild(svg.firstChild);\n  }\n\n  function drawPlot() {\n    clearSvg(plot);\n    // background\n    const rect = document.createElementNS(\"http://www.w3.org/2000/svg\",\"rect\");\n    rect.setAttribute(\"x\",0); rect.setAttribute(\"y\",0); rect.setAttribute(\"width\",W); rect.setAttribute(\"height\",H);\n    rect.setAttribute(\"fill\",\"transparent\");\n    plot.appendChild(rect);\n\n    // boundaries (colored regions)\n    if (tree && SHOW_BOUNDARIES) {\n      const regions = regionsFromTree(tree);\n      for (const r of regions) {\n        const bx = mapX(r.bounds.xmin), by = mapY(r.bounds.ymax); // y max maps to top\n        const bw = mapX(r.bounds.xmax) - mapX(r.bounds.xmin);\n        const bh = mapY(r.bounds.ymin) - mapY(r.bounds.ymax);\n        const g = document.createElementNS(\"http://www.w3.org/2000/svg\",\"rect\");\n        g.setAttribute(\"x\", bx);\n        g.setAttribute(\"y\", by);\n        g.setAttribute(\"width\", bw);\n        g.setAttribute(\"height\", bh);\n        g.setAttribute(\"fill\", r.prediction===0 ? \"#E539351a\" : \"#1E88E51a\");\n        g.setAttribute(\"stroke\",\"none\");\n        plot.appendChild(g);\n      }\n      // draw split lines too\n      drawSplitLines(tree,{xmin:domain.xmin,xmax:domain.xmax,ymin:domain.ymin,ymax:domain.ymax});\n    }\n\n    // points\n    for (let i=0;i<data.length;i++){\n      const p = data[i];\n      const cx = mapX(p.x), cy = mapY(p.y);\n      const c = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n      c.setAttribute(\"cx\",cx); c.setAttribute(\"cy\",cy); c.setAttribute(\"r\",4.2);\n      c.setAttribute(\"fill\", p.ytrue===0 ? \"#E53935\" : \"#1E88E5\");\n      c.setAttribute(\"stroke\",\"#fff\"); c.setAttribute(\"stroke-width\",\"1\");\n      c.dataset.i = i;\n      plot.appendChild(c);\n    }\n\n    // if user clicked to predict, show that point and path\n    if (selected.type === 'point' && selected.item) {\n      const pt = selected.item;\n      const px = mapX(pt.x), py = mapY(pt.y);\n      const circ = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n      circ.setAttribute(\"cx\",px); circ.setAttribute(\"cy\",py); circ.setAttribute(\"r\",6);\n      circ.setAttribute(\"fill\", pt.pred===0 ? \"#E53935\" : \"#1E88E5\");\n      circ.setAttribute(\"class\",\"pred-dot\");\n      circ.setAttribute(\"opacity\",\"0.95\");\n      plot.appendChild(circ);\n    }\n\n    // highlight selected node region (if any)\n    if (selected.type === 'node' && selected.item) {\n      const n = selected.item;\n      // compute bounds by walking path from root to this node\n      const path = findPathToNode(tree, n);\n      if (path) {\n        let bounds = {...domain};\n        for (const nd of path) {\n          if (!nd.feature) break;\n          if (nd === path[path.length-1]) break; // stop at parent of target node\n          // apply constraint based on whether next in path is left or right\n        }\n        // easier: compute regions and pick matching node\n        const regs = regionsFromTree(tree);\n        for (const r of regs) {\n          if (r.node === n) {\n            const bx = mapX(r.bounds.xmin), by = mapY(r.bounds.ymax); // y max maps to top\n            const bw = mapX(r.bounds.xmax) - mapX(r.bounds.xmin);\n            const bh = mapY(r.bounds.ymin) - mapY(r.bounds.ymax);\n            const highlight = document.createElementNS(\"http://www.w3.org/2000/svg\",\"rect\");\n            highlight.setAttribute(\"x\", bx);\n            highlight.setAttribute(\"y\", by);\n            highlight.setAttribute(\"width\", bw);\n            highlight.setAttribute(\"height\", bh);\n            highlight.setAttribute(\"class\",\"highlight\");\n            highlight.setAttribute(\"fill\",\"#ff98001a\");\n            plot.appendChild(highlight);\n            break;\n          }\n        }\n      }\n    }\n  }\n\n  function drawSplitLines(node, bounds) {\n    if (!node || node.isLeaf) return;\n    const f = node.feature, t = node.thr;\n    if (f==='x') {\n      const xPx = mapX(t);\n      const y1 = mapY(bounds.ymax), y2 = mapY(bounds.ymin);\n      const line = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n      line.setAttribute(\"x1\",xPx); line.setAttribute(\"y1\",y1); line.setAttribute(\"x2\",xPx); line.setAttribute(\"y2\",y2);\n      line.setAttribute(\"stroke\",\"#0f172a\"); line.setAttribute(\"stroke-width\",\"1\"); line.setAttribute(\"opacity\",\"0.12\");\n      plot.appendChild(line);\n      // left region\n      drawSplitLines(node.left, {...bounds, xmax: Math.min(bounds.xmax, t)});\n      drawSplitLines(node.right, {...bounds, xmin: Math.max(bounds.xmin, t)});\n    } else {\n      const yPx = mapY(t);\n      const x1 = mapX(bounds.xmin), x2 = mapX(bounds.xmax);\n      const line = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n      line.setAttribute(\"x1\",x1); line.setAttribute(\"y1\",yPx); line.setAttribute(\"x2\",x2); line.setAttribute(\"y2\",yPx);\n      line.setAttribute(\"stroke\",\"#0f172a\"); line.setAttribute(\"stroke-width\",\"1\"); line.setAttribute(\"opacity\",\"0.12\");\n      plot.appendChild(line);\n      drawSplitLines(node.left, {...bounds, ymax: Math.min(bounds.ymax, t)});\n      drawSplitLines(node.right, {...bounds, ymin: Math.max(bounds.ymin, t)});\n    }\n  }\n\n  function drawTree() {\n    clearSvg(treeSvg);\n    if (!tree) return;\n    // layout: compute positions\n    const nodes = [];\n    function walk(n, x0, x1, depth) {\n      const x = (x0 + x1) / 2;\n      const y = 20 + depth * 90;\n      nodes.push({node:n, x, y, depth});\n      if (n.left && n.right) {\n        // split horizontal space proportionally by counts\n        const leftFrac = n.left.count / n.count;\n        const mid = x0 + (x1-x0) * leftFrac;\n        walk(n.left, x0, mid, depth+1);\n        walk(n.right, mid, x1, depth+1);\n      }\n    }\n    walk(tree, 10, parseInt(treeSvg.getAttribute('width') || treeSvg.clientWidth) - 10, 0);\n\n    // map node -> coords\n    const coords = new Map(nodes.map(n=>[n.node,{x:n.x,y:n.y}]));\n\n    // draw connectors\n    for (const item of nodes) {\n      const n = item.node;\n      if (n.left && n.right) {\n        const p = coords.get(n), pl = coords.get(n.left), pr = coords.get(n.right);\n        const lineL = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n        lineL.setAttribute(\"x1\",p.x); lineL.setAttribute(\"y1\",p.y+26); lineL.setAttribute(\"x2\",pl.x); lineL.setAttribute(\"y2\",pl.y-16);\n        lineL.setAttribute(\"stroke\",\"#cbd5e1\"); lineL.setAttribute(\"stroke-width\",\"1\");\n        treeSvg.appendChild(lineL);\n        const lineR = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n        lineR.setAttribute(\"x1\",p.x); lineR.setAttribute(\"y1\",p.y+26); lineR.setAttribute(\"x2\",pr.x); lineR.setAttribute(\"y2\",pr.y-16);\n        lineR.setAttribute(\"stroke\",\"#cbd5e1\"); lineR.setAttribute(\"stroke-width\",\"1\");\n        treeSvg.appendChild(lineR);\n      }\n    }\n\n    // draw nodes\n    for (const item of nodes) {\n      const n = item.node;\n      const g = document.createElementNS(\"http://www.w3.org/2000/svg\",\"g\");\n      g.setAttribute(\"transform\",`translate(${item.x-70},${item.y-14})`);\n      g.style.cursor = \"pointer\";\n\n      const rect = document.createElementNS(\"http://www.w3.org/2000/svg\",\"rect\");\n      rect.setAttribute(\"width\",140); rect.setAttribute(\"height\",60); rect.setAttribute(\"rx\",8);\n      rect.setAttribute(\"class\",\"node-rect\");\n      rect.dataset.nodeIndex = nodes.indexOf(item);\n      g.appendChild(rect);\n\n      // small colored strip\n      const strip = document.createElementNS(\"http://www.w3.org/2000/svg\",\"rect\");\n      strip.setAttribute(\"x\",0); strip.setAttribute(\"y\",0); strip.setAttribute(\"width\",8); strip.setAttribute(\"height\",60);\n      strip.setAttribute(\"fill\", n.prediction===0 ? \"#E53935\" : \"#1E88E5\");\n      strip.setAttribute(\"rx\",8);\n      g.appendChild(strip);\n\n      // text lines\n      const t1 = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n      t1.setAttribute(\"x\",14); t1.setAttribute(\"y\",16); t1.setAttribute(\"font-size\",12); t1.setAttribute(\"fill\",\"#0f172a\");\n      if (n.isLeaf) t1.textContent = `Leaf — pred=${n.prediction} (n=${n.count})`;\n      else t1.textContent = `${n.feature} ≤ ${n.thr.toFixed(3)} (n=${n.count})`;\n      g.appendChild(t1);\n\n      const t2 = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n      t2.setAttribute(\"x\",14); t2.setAttribute(\"y\",34); t2.setAttribute(\"font-size\",11); t2.setAttribute(\"fill\",\"#334155\");\n      t2.textContent = `counts: [${n.counts[0]}, ${n.counts[1]}] gini=${n.gini.toFixed(3)}`;\n      g.appendChild(t2);\n\n      // attach click to highlight region\n      g.addEventListener('click', (ev) => {\n        ev.stopPropagation();\n        selected = {type:'node', item: n};\n        updateUI();\n      });\n\n      treeSvg.appendChild(g);\n    }\n  }\n\n  // find path from root to a node (by reference)\n  function findPathToNode(root, target) {\n    const path = [];\n    let found = false;\n    function dfs(n) {\n      if (!n || found) return false;\n      path.push(n);\n      if (n === target) { found = true; return true; }\n      if (dfs(n.left) || dfs(n.right)) return true;\n      path.pop(); return false;\n    }\n    dfs(root);\n    return found ? path : null;\n  }\n\n  // textual representation\n  function treeToString(n, indent=\"\") {\n    if (!n) return \"\";\n    if (n.isLeaf) return `${indent}Leaf: predict=${n.prediction}, n=${n.count}, counts=[${n.counts[0]},${n.counts[1]}], gini=${n.gini.toFixed(3)}\\n`;\n    return `${indent}${n.feature} ≤ ${n.thr.toFixed(4)}  (n=${n.count}, gini=${n.gini.toFixed(3)})\\n` +\n           treeToString(n.left, indent+\"  \") + treeToString(n.right, indent+\"  \");\n  }\n\n  // ---- interactions ----\n  function updateUI() {\n    drawPlot();\n    drawTree();\n    treeText.textContent = tree ? treeToString(tree) : \"No tree yet. Click Build Tree.\";\n    nodeCount.textContent = \"Nodes: \" + (countNodes(tree));\n    // prediction box\n    if (selected.type==='point' && selected.item) {\n      predictionBox.innerHTML = `Point at (${selected.item.x.toFixed(3)}, ${selected.item.y.toFixed(3)}) → predicted class <b>${selected.item.pred}</b>`;\n    } else if (selected.type==='node' && selected.item) {\n      const n = selected.item;\n      predictionBox.innerHTML = `Selected node: ${n.isLeaf ? 'Leaf' : (n.feature + ' ≤ ' + n.thr.toFixed(3))} | counts: [${n.counts[0]},${n.counts[1]}]`;\n    } else {\n      predictionBox.innerHTML = `None`;\n    }\n    // update highlight on tree nodes rectangles\n    // (rendering in drawTree re-creates nodes, so we will re-select rects)\n    // find all rects and if node corresponds to selected, add highlight\n    if (tree) {\n      // We re-rendered, so just iterate through tree svg groups to style\n      const groups = treeSvg.querySelectorAll('g');\n      groups.forEach(g => {\n        const rect = g.querySelector('rect.node-rect');\n        if (!rect) return;\n        const texts = g.querySelectorAll('text');\n        let primary = texts[0] ? texts[0].textContent : \"\";\n        // simple matching: if primary contains the selected node descriptor\n        if (selected.type==='node' && selected.item) {\n          const sel = selected.item;\n          let selText = sel.isLeaf ? `Leaf — pred=${sel.prediction}` : `${sel.feature} ≤ ${sel.thr.toFixed(3)}`;\n          if (primary.indexOf(selText.replace(/[^\\d\\w≤.\\s-]/g,'')) !== -1) {\n            rect.classList.add(\"highlight\");\n          } else {\n            rect.classList.remove(\"highlight\");\n          }\n        } else {\n          rect.classList.remove(\"highlight\");\n        }\n      });\n    }\n  }\n\n  function countNodes(n) {\n    if (!n) return 0;\n    if (n.isLeaf) return 1;\n    return 1 + countNodes(n.left) + countNodes(n.right);\n  }\n\n  // events\n  regenBtn.addEventListener('click', () => {\n    data = generateData(parseInt(nPerClassInput.value), parseFloat(spreadInput.value));\n    tree = null;\n    selected = {type:null, item:null};\n    updateUI();\n  });\n\n  trainBtn.addEventListener('click', () => {\n    tree = buildTree(data, 0, parseInt(maxDepthInput.value), parseInt(minSamplesInput.value));\n    selected = {type:null, item:null};\n    updateUI();\n  });\n\n  spreadInput.addEventListener('input', ()=> { spreadVal.textContent = spreadInput.value; });\n  maxDepthInput.addEventListener('input', ()=> { maxDepthVal.textContent = maxDepthInput.value; });\n\n  toggleBoundBtn.addEventListener('click', ()=> {\n    SHOW_BOUNDARIES = !SHOW_BOUNDARIES;\n    updateUI();\n  });\n\n  // clicking on plot to classify a point\n  plot.addEventListener('click', (ev) => {\n    const rect = plot.getBoundingClientRect();\n    const xPx = ev.clientX - rect.left;\n    const yPx = ev.clientY - rect.top;\n    // invert mapping\n    const x = domain.xmin + (xPx - PAD) / (W - 2*PAD) * (domain.xmax - domain.xmin);\n    const y = domain.ymax - (yPx - PAD) / (H - 2*PAD) * (domain.ymax - domain.ymin);\n    let pred = null, path = [];\n    if (tree) {\n      const res = predictPath(tree, {x,y});\n      pred = res.pred; path = res.path;\n    }\n    selected = {type:'point', item:{x,y,pred, path}};\n    updateUI();\n  });\n\n  // click outside tree to clear selection\n  document.body.addEventListener('click', (ev) => {\n    // if clicked outside tree svg and plot, clear node selection (but keep point selection if any)\n    if (!treeSvg.contains(ev.target) && !plot.contains(ev.target)) {\n      // keep point selection\n      if (selected.type === 'node') selected = {type:null, item:null};\n      updateUI();\n    }\n  });\n\n  // clicking on tree area groups handled during drawTree (attached to groups)\n\n  // initialize\n  data = generateData(parseInt(nPerClassInput.value), parseFloat(spreadInput.value));\n  updateUI();\n\n  // expose for debugging (optional)\n  window._demo = {data, buildTree, predictPath};\n\n})();\n</script>\n</body>\n</html>"
