    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<title>Heap Sort Visualization</title>\n<style>\n  :root{\n    --bg:#0f1724;\n    --panel:#0b1220;\n    --accent:#60a5fa;\n    --muted:#94a3b8;\n    --good:#10b981;\n    --bad:#ef4444;\n    --card:#0f1724;\n  }\n  html,body{height:100%;margin:0;background:linear-gradient(180deg,#071225, #071834);font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color:#e6eef8}\n  .container{max-width:1100px;margin:18px auto;padding:18px;display:grid;grid-template-columns:1fr 360px;gap:18px}\n  header{grid-column:1/-1;display:flex;align-items:center;justify-content:space-between;gap:12px}\n  header h1{font-size:1.1rem;margin:0;color:white}\n  .controls{background:rgba(255,255,255,0.03);padding:14px;border-radius:10px;display:flex;flex-direction:column;gap:10px}\n  .controls .row{display:flex;gap:10px;align-items:center}\n  .controls label{font-size:12px;color:var(--muted);min-width:70px}\n  .controls input[type=range]{width:100%}\n  .controls input[type=number]{width:100%;padding:6px;border-radius:6px;border:1px solid rgba(255,255,255,0.06);background:transparent;color:inherit}\n  button{background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.04);color:var(--accent);padding:8px 10px;border-radius:8px;cursor:pointer}\n  button.secondary{background:transparent;color:var(--muted);border:1px solid rgba(255,255,255,0.03)}\n  button:disabled{opacity:0.45;cursor:not-allowed}\n  .visual{background:rgba(255,255,255,0.02);border-radius:10px;padding:14px;min-height:420px;display:flex;flex-direction:column;gap:12px}\n  .bars{flex:1;display:flex;align-items:end;gap:2px;height:360px;padding:6px;background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent);border-radius:6px;overflow:hidden}\n  .bar{flex:1;height:20px;background:linear-gradient(180deg,#58a6ff,#1e90ff);margin:0 1px;border-radius:3px;transition:height 120ms linear, background-color 120ms linear, transform 120ms linear;display:flex;align-items:flex-end;justify-content:center;font-size:11px;color:rgba(255,255,255,0.9);font-weight:600}\n  .bar.small{font-size:9px}\n  .bar .val{transform:translateY(-4px);opacity:0.9}\n  .bar.comparing{background:linear-gradient(180deg,#f97316,#fb923c);z-index:3}\n  .bar.swapping{background:linear-gradient(180deg,#ef4444,#f43f5e);transform:scale(1.03)}\n  .bar.sorted{background:linear-gradient(180deg,#10b981,#34d399)}\n  .bar.heap{box-shadow:0 0 0 2px rgba(99,102,241,0.08) inset}\n  .status{display:flex;gap:10px;align-items:center;justify-content:space-between;font-size:13px;color:var(--muted)}\n  .panel{background:rgba(255,255,255,0.02);padding:12px;border-radius:10px;height:100%;overflow:auto}\n  pre{margin:0;padding:8px;background:transparent;border-radius:6px;overflow:auto}\n  .code-line{display:block;padding:4px 6px;border-radius:6px;color:var(--muted);font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px}\n  .code-line.active{background:rgba(96,165,250,0.09);color:var(--accent);font-weight:600}\n  .legend{display:flex;gap:8px;flex-wrap:wrap}\n  .legend .item{font-size:12px;color:var(--muted);display:flex;gap:6px;align-items:center}\n  .chip{width:16px;height:12px;border-radius:3px}\n  .chip.compare{background:linear-gradient(180deg,#f97316,#fb923c)}\n  .chip.swap{background:linear-gradient(180deg,#ef4444,#f43f5e)}\n  .chip.heap{box-shadow:0 0 0 2px rgba(99,102,241,0.08) inset;background:#1f2937}\n  .chip.sorted{background:linear-gradient(180deg,#10b981,#34d399)}\n  footer{grid-column:1/-1;font-size:12px;color:var(--muted);padding-top:6px}\n  @media(max-width:980px){.container{grid-template-columns:1fr; padding:12px} .panel{height:auto}}\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <header>\n    <h1>Heap Sort — Interactive Visualization</h1>\n    <div style=\"font-size:12px;color:var(--muted)\">Array / Heap operations visualized step-by-step</div>\n  </header>\n\n  <div class=\"visual\">\n    <div style=\"display:flex;justify-content:space-between;align-items:center;gap:10px\">\n      <div style=\"display:flex;flex-direction:column\">\n        <div style=\"font-size:13px;color:var(--muted)\">Array</div>\n        <div style=\"font-size:12px;color:var(--muted)\">Elements: <span id=\"sizeLabel\">30</span></div>\n      </div>\n      <div class=\"legend\">\n        <div class=\"item\"><span class=\"chip compare\"></span> Compare</div>\n        <div class=\"item\"><span class=\"chip swap\"></span> Swap</div>\n        <div class=\"item\"><span class=\"chip heap\"></span> In heap</div>\n        <div class=\"item\"><span class=\"chip sorted\"></span> Sorted</div>\n      </div>\n    </div>\n\n    <div class=\"bars\" id=\"bars\" aria-live=\"polite\"></div>\n\n    <div class=\"status\" style=\"margin-top:6px\">\n      <div id=\"phase\">Phase: Ready</div>\n      <div id=\"indices\" style=\"color:var(--muted)\"></div>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <div class=\"controls\">\n      <div class=\"row\">\n        <label for=\"size\">Size</label>\n        <input id=\"size\" type=\"number\" min=\"5\" max=\"120\" value=\"30\"/>\n      </div>\n      <div class=\"row\">\n        <label for=\"speed\">Speed</label>\n        <input id=\"speed\" type=\"range\" min=\"0\" max=\"1000\" value=\"200\"/>\n      </div>\n      <div class=\"row\" style=\"justify-content:space-between\">\n        <button id=\"generate\">Generate</button>\n        <button id=\"shuffle\" class=\"secondary\">Shuffle</button>\n        <button id=\"randomMax\" class=\"secondary\">Random Range</button>\n      </div>\n\n      <div style=\"display:flex;gap:8px\">\n        <button id=\"start\">Start</button>\n        <button id=\"pause\" disabled>Pause</button>\n        <button id=\"step\">Step</button>\n        <button id=\"reset\" class=\"secondary\">Reset</button>\n      </div>\n\n      <div style=\"font-size:12px;color:var(--muted);margin-top:6px\">Tip: Use Step to advance one visualization action at a time. Pause stops automatic playback.</div>\n    </div>\n\n    <div style=\"margin-top:12px\">\n      <div style=\"font-size:13px;margin-bottom:8px;color:var(--muted)\">Algorithm (pseudocode)</div>\n      <pre id=\"code\">\n<span class=\"code-line\" data-line=\"1\">1  function heapSort(A)</span>\n<span class=\"code-line\" data-line=\"2\">2      n := length(A)</span>\n<span class=\"code-line\" data-line=\"3\">3      // Build max heap</span>\n<span class=\"code-line\" data-line=\"4\">4      for i := floor(n/2)-1 downto 0</span>\n<span class=\"code-line\" data-line=\"5\">5          siftDown(A, i, n-1)</span>\n<span class=\"code-line\" data-line=\"6\">6      // Extract elements from heap</span>\n<span class=\"code-line\" data-line=\"7\">7      for end := n-1 downto 1</span>\n<span class=\"code-line\" data-line=\"8\">8          swap(A[0], A[end])</span>\n<span class=\"code-line\" data-line=\"9\">9          siftDown(A, 0, end-1)</span>\n\n<span class=\"code-line\" data-line=\"11\">11 function siftDown(A, start, end)</span>\n<span class=\"code-line\" data-line=\"12\">12     root := start</span>\n<span class=\"code-line\" data-line=\"13\">13     while root*2+1 <= end</span>\n<span class=\"code-line\" data-line=\"14\">14         child := root*2+1</span>\n<span class=\"code-line\" data-line=\"15\">15         swapIdx := root</span>\n<span class=\"code-line\" data-line=\"16\">16         if A[swapIdx] &lt; A[child] then swapIdx := child</span>\n<span class=\"code-line\" data-line=\"17\">17         if child+1 <= end and A[swapIdx] &lt; A[child+1] then swapIdx := child+1</span>\n<span class=\"code-line\" data-line=\"18\">18         if swapIdx = root then return</span>\n<span class=\"code-line\" data-line=\"19\">19         else swap(A[root], A[swapIdx]); root := swapIdx</span>\n      </pre>\n    </div>\n  </div>\n\n  <footer>\n    Visualization shows comparisons (orange), swaps (red), items currently considered part of the heap (outlined), and sorted elements (green).\n  </footer>\n</div>\n\n<script>\n(() => {\n  // Utility helpers\n  const $ = (id) => document.getElementById(id);\n  const bars = $('bars');\n  const sizeInput = $('size');\n  const sizeLabel = $('sizeLabel');\n  const speedInput = $('speed');\n  const startBtn = $('start');\n  const pauseBtn = $('pause');\n  const stepBtn = $('step');\n  const resetBtn = $('reset');\n  const generateBtn = $('generate');\n  const shuffleBtn = $('shuffle');\n  const randomMaxBtn = $('randomMax');\n  const phaseEl = $('phase');\n  const indicesEl = $('indices');\n  const codeLines = [...document.querySelectorAll('.code-line')];\n\n  let arr = [];\n  let maxValue = 100;\n  let running = false;\n  let paused = false;\n  let gen = null;\n  let autoRunner = null;\n  let lastAction = null;\n  let stepMode = false;\n\n  // Initialize\n  function clamp(v, a, b){ return Math.max(a, Math.min(b, v)); }\n  function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n\n  function generateArray(n){\n    arr = [];\n    for(let i=0;i<n;i++) arr.push(randInt(5, maxValue));\n  }\n\n  function shuffleArray(){\n    for (let i = arr.length-1; i>0; i--){\n      const j = Math.floor(Math.random()*(i+1));\n      [arr[i], arr[j]] = [arr[j], arr[i]];\n    }\n  }\n\n  function renderBars(highlights = {}) {\n    const n = arr.length;\n    bars.innerHTML = '';\n    const max = Math.max(...arr, 1);\n    for (let i=0;i<n;i++){\n      const b = document.createElement('div');\n      b.className = 'bar';\n      if (arr.length > 60) b.classList.add('small');\n      b.style.height = (arr[i]/max*100) + '%';\n      b.style.flexBasis = `${100/n}%`;\n      b.setAttribute('data-index', i);\n      b.title = String(arr[i]);\n      const v = document.createElement('div'); v.className='val'; v.textContent = arr[i];\n      b.appendChild(v);\n\n      // Apply highlight classes\n      if (highlights.compare && (i===highlights.compare[0] || i===highlights.compare[1])) b.classList.add('comparing');\n      if (highlights.swap && (i===highlights.swap[0] || i===highlights.swap[1])) b.classList.add('swapping');\n      if (highlights.heap && i<=highlights.heapEnd) b.classList.add('heap');\n      if (highlights.sorted && i>=highlights.sortedStart) b.classList.add('sorted');\n\n      bars.appendChild(b);\n    }\n    sizeLabel.textContent = n;\n  }\n\n  // Highlight code lines by numbers\n  function highlightCode(line){\n    codeLines.forEach(el => {\n      el.classList.toggle('active', Number(el.dataset.line) === line);\n    });\n  }\n\n  // Generator that yields visualization actions\n  // Actions: {type:'compare', i, j}, {type:'swap', i, j}, {type:'heapifyStart', i, heapEnd}, {type:'heapifyEnd'}, {type:'markSorted', index}, {type:'phase', text}, {type:'code', line}\n  function* heapSortGen(a){\n    const n = a.length;\n    // Build max heap\n    yield {type:'phase', text:'Building max heap'};\n    for (let i = Math.floor(n/2)-1; i>=0; i--){\n      yield {type:'code', line:4};\n      yield* siftDownGen(a, i, n-1);\n    }\n    // Extract elements\n    yield {type:'phase', text:'Sorting (extract elements)'};\n    for (let end = n-1; end > 0; end--){\n      yield {type:'code', line:8};\n      yield {type:'swap', i:0, j:end};\n      [a[0], a[end]] = [a[end], a[0]];\n      yield {type:'markSorted', index:end};\n      yield* siftDownGen(a, 0, end-1);\n    }\n    yield {type:'phase', text:'Completed'};\n    yield {type:'markSorted', index:0};\n  }\n\n  // Generator for siftDown visualized\n  function* siftDownGen(a, start, end){\n    yield {type:'code', line:11};\n    let root = start;\n    yield {type:'code', line:12};\n    while (root*2 + 1 <= end){\n      yield {type:'code', line:13};\n      let child = root*2 + 1;\n      let swapIdx = root;\n      yield {type:'code', line:14};\n      // Compare root and child\n      yield {type:'compare', i:swapIdx, j:child, heapEnd:end};\n      if (a[swapIdx] < a[child]) {\n        swapIdx = child;\n        yield {type:'code', line:16};\n      }\n      if (child+1 <= end){\n        yield {type:'code', line:17};\n        yield {type:'compare', i:swapIdx, j:child+1, heapEnd:end};\n        if (a[swapIdx] < a[child+1]){\n          swapIdx = child+1;\n        }\n      }\n      yield {type:'code', line:18};\n      if (swapIdx === root){\n        // nothing to do\n        yield {type:'heapifyEnd'};\n        return;\n      } else {\n        yield {type:'code', line:19};\n        yield {type:'swap', i:root, j:swapIdx, heapEnd:end};\n        [a[root], a[swapIdx]] = [a[swapIdx], a[root]];\n        root = swapIdx;\n      }\n    }\n    yield {type:'heapifyEnd'};\n  }\n\n  // Apply a single action to UI state; returns promise resolved after applying\n  function applyAction(action){\n    // General updates\n    if (!action) return Promise.resolve();\n    lastAction = action;\n    // Default highlights\n    const highlights = { compare: null, swap: null, heap: null, sorted: null };\n\n    if (action.type === 'phase'){\n      phaseEl.textContent = 'Phase: ' + action.text;\n      highlightCode(null);\n      renderBars();\n      return Promise.resolve();\n    }\n\n    if (action.type === 'code'){\n      highlightCode(action.line);\n      return Promise.resolve();\n    }\n\n    if (action.type === 'compare'){\n      phaseEl.textContent = 'Phase: Comparing';\n      indicesEl.textContent = `i=${action.i}, j=${action.j}`;\n      highlights.compare = [action.i, action.j];\n      if (typeof action.heapEnd === 'number') highlights.heapEnd = action.heapEnd;\n      renderBars(highlights);\n      return Promise.resolve();\n    }\n\n    if (action.type === 'swap'){\n      phaseEl.textContent = 'Phase: Swapping';\n      indicesEl.textContent = `i=${action.i}, j=${action.j}`;\n      highlights.swap = [action.i, action.j];\n      if (typeof action.heapEnd === 'number') highlights.heapEnd = action.heapEnd;\n      // Render immediate before swap to show red\n      renderBars(highlights);\n      return Promise.resolve();\n    }\n\n    if (action.type === 'heapifyEnd'){\n      phaseEl.textContent = 'Phase: Heapify step finished';\n      indicesEl.textContent = '';\n      highlightCode(null);\n      renderBars();\n      return Promise.resolve();\n    }\n\n    if (action.type === 'markSorted'){\n      // mark element at index and render\n      phaseEl.textContent = 'Phase: Mark sorted';\n      indicesEl.textContent = `index=${action.index}`;\n      // For sorted, we show sorted region as indices >= action.index\n      renderBars({sortedStart: action.index});\n      return Promise.resolve();\n    }\n\n    return Promise.resolve();\n  }\n\n  // Driver to run the generator with delays and control\n  async function runGenerator(generator){\n    running = true;\n    paused = false;\n    startBtn.disabled = true;\n    pauseBtn.disabled = false;\n    stepBtn.disabled = false;\n    resetBtn.disabled = true;\n    generateBtn.disabled = true;\n    shuffleBtn.disabled = true;\n    randomMaxBtn.disabled = true;\n    sizeInput.disabled = true;\n\n    const delayMs = () => {\n      // slider 0..1000, map 0 => fast (5ms), 1000 => slow (800ms)\n      const v = Number(speedInput.value);\n      const ms = Math.round(5 + (800 * v / 1000));\n      return ms;\n    };\n\n    let res;\n    while (true){\n      if (!running) break;\n      if (paused){\n        // Wait until unpaused or step clicked\n        await new Promise(resolve => {\n          const check = () => {\n            if (!running) return resolve();\n            if (!paused) return resolve();\n            // stepMode triggers a single step then pauses again\n            if (stepMode) return resolve();\n            setTimeout(check, 50);\n          };\n          check();\n        });\n      }\n\n      // If generator is done, break\n      try {\n        res = generator.next();\n      } catch (e) {\n        console.error('Generator crashed:', e);\n        break;\n      }\n      if (res.done) break;\n      const action = res.value;\n      await applyAction(action);\n\n      // If swap action, visually update array in UI after short micro delay to show effect\n      if (action.type === 'swap'){\n        // briefly show swap highlight, then render bars with actual swapped values\n        await wait( Math.max(40, delayMs()/2) );\n        renderBars({swap:[action.i, action.j], heapEnd:action.heapEnd});\n        // After another short delay show final array state\n        await wait( Math.max(40, delayMs()/2) );\n        renderBars({heapEnd:action.heapEnd});\n      }\n\n      // For comparisons and others, wait delay unless stepMode active\n      if (stepMode){\n        // advance a single step then pause again\n        stepMode = false;\n        paused = true;\n      } else {\n        await wait(delayMs());\n      }\n    }\n\n    // finalize\n    running = false;\n    paused = false;\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n    resetBtn.disabled = false;\n    generateBtn.disabled = false;\n    shuffleBtn.disabled = false;\n    randomMaxBtn.disabled = false;\n    sizeInput.disabled = false;\n    phaseEl.textContent = 'Phase: Ready';\n    indicesEl.textContent = '';\n    highlightCode(null);\n    renderBars();\n  }\n\n  function wait(ms){ return new Promise(res => setTimeout(res, ms)); }\n\n  // Button handlers\n  function reset(){\n    running = false;\n    paused = false;\n    stepMode = false;\n    gen = null;\n    startBtn.disabled = false;\n    pauseBtn.disabled = true;\n    stepBtn.disabled = false;\n    resetBtn.disabled = false;\n    generateBtn.disabled = false;\n    shuffleBtn.disabled = false;\n    randomMaxBtn.disabled = false;\n    sizeInput.disabled = false;\n    phaseEl.textContent = 'Phase: Ready';\n    indicesEl.textContent = '';\n    highlightCode(null);\n    renderBars();\n  }\n\n  startBtn.addEventListener('click', ()=>{\n    if (running) return;\n    gen = heapSortGen(arr.slice()); // work on a copy for internal logic but UI modifies arr on swaps\n    paused = false;\n    stepMode = false;\n    runGenerator(gen);\n  });\n\n  pauseBtn.addEventListener('click', ()=>{\n    if (!running) return;\n    paused = !paused;\n    pauseBtn.textContent = paused ? 'Resume' : 'Pause';\n  });\n\n  stepBtn.addEventListener('click', ()=>{\n    if (!running){\n      // start generator in paused mode and immediately step one action\n      gen = heapSortGen(arr.slice());\n      running = true;\n      paused = true;\n      startBtn.disabled = true;\n      pauseBtn.disabled = false;\n      resetBtn.disabled = true;\n      generateBtn.disabled = true;\n      shuffleBtn.disabled = true;\n      randomMaxBtn.disabled = true;\n      sizeInput.disabled = true;\n      stepMode = true;\n      runGenerator(gen);\n    } else {\n      // if running but paused, allow a single step\n      if (paused){\n        stepMode = true;\n      } else {\n        // if running and not paused, pause then step\n        paused = true;\n        stepMode = true;\n      }\n    }\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    reset();\n    generateArray(Number(sizeInput.value));\n    renderBars();\n  });\n\n  generateBtn.addEventListener('click', ()=>{\n    generateArray(Number(sizeInput.value));\n    reset();\n    renderBars();\n  });\n\n  shuffleBtn.addEventListener('click', ()=>{\n    shuffleArray();\n    reset();\n    renderBars();\n  });\n\n  randomMaxBtn.addEventListener('click', ()=>{\n    // change max value randomly to demonstrate range\n    maxValue = randInt(30, 200);\n    generateArray(Number(sizeInput.value));\n    reset();\n    renderBars();\n  });\n\n  sizeInput.addEventListener('change', ()=>{\n    let v = Number(sizeInput.value);\n    v = clamp(v, 5, 120);\n    sizeInput.value = v;\n    sizeLabel.textContent = v;\n  });\n\n  // On load initialize\n  (function init(){\n    const startSize = Number(sizeInput.value) || 30;\n    sizeLabel.textContent = startSize;\n    generateArray(startSize);\n    renderBars();\n  })();\n\n  // keyboard shortcuts\n  document.addEventListener('keydown', (e) => {\n    if (e.key === ' ') { e.preventDefault(); if (running) pauseBtn.click(); else startBtn.click(); }\n    if (e.key === 's') stepBtn.click();\n    if (e.key === 'r') generateBtn.click();\n  });\n\n})();\n</script>\n</body>\n</html>"
