    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B+ Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .bplus-tree {\n            display: inline-block;\n            margin: 20px;\n        }\n        .bplus-tree-node {\n            background-color: #f0f0f0;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            margin: 5px;\n            display: inline-block;\n            vertical-align: top;\n        }\n        .bplus-tree-node-content {\n            display: inline-block;\n            vertical-align: top;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"bplus-tree\">\n        <div class=\"bplus-tree-node\">\n            <div class=\"bplus-tree-node-content\">A</div>\n            <div class=\"bplus-tree-node-content\">B</div>\n        </div>\n        <div class=\"bplus-tree-node\">\n            <div class=\"bplus-tree-node-content\">C</div>\n            <div class=\"bplus-tree-node-content\">D</div>\n        </div>\n        <div class=\"bplus-tree-node\">\n            <div class=\"bplus-tree-node-content\">E</div>\n            <div class=\"bplus-tree-node-content\">F</div>\n        </div>\n        <div class=\"bplus-tree-node\">\n            <div class=\"bplus-tree-node-content\">G</div>\n            <div class=\"bplus-tree-node-content\">H</div>\n        </div>\n    </div>\n\n    <script>\n        class Node {\n            constructor(key, value, left = null, right = null) {\n                this.key = key;\n                this.value = value;\n                this.left = left;\n                this.right = right;\n            }\n        }\n\n        class BPlusTree {\n            constructor() {\n                this.root = new Node(null, null);\n            }\n\n            insert(key, value) {\n                if (this.root.key === null) {\n                    this.root = new Node(key, value);\n                } else {\n                    this._insert(this.root, key, value);\n                }\n            }\n\n            _insert(node, key, value) {\n                if (key < node.key) {\n                    if (node.left === null) {\n                        node.left = new Node(key, value);\n                    } else {\n                        this._insert(node.left, key, value);\n                    }\n                } else {\n                    if (node.right === null) {\n                        node.right = new Node(key, value);\n                    } else {\n                        this._insert(node.right, key, value);\n                    }\n                }\n            }\n\n            search(key) {\n                return this._search(this.root, key);\n            }\n\n            _search(node, key) {\n                if (node === null) {\n                    return null;\n                }\n                if (key === node.key) {\n                    return node.value;\n                }\n                if (key < node.key) {\n                    return this._search(node.left, key);\n                }\n                return this._search(node.right, key);\n            }\n\n            delete(key) {\n                this.root = this._delete(this.root, key);\n            }\n\n            _delete(node, key) {\n                if (node === null) {\n                    return null;\n                }\n                if (key < node.key) {\n                    node.left = this._delete(node.left, key);\n                } else if (key > node.key) {\n                    node.right = this._delete(node.right, key);\n                } else {\n                    if (node.left === null && node.right === null) {\n                        return null;\n                    } else if (node.left === null) {\n                        return node.right;\n                    } else if (node.right === null) {\n                        return node.left;\n                    } else {\n                        let min = this._findMin(node.right);\n                        node.key = min.key;\n                        node.value = min.value;\n                        node.right = this._delete(node.right, min.key);\n                    }\n                }\n                return node;\n            }\n\n            _findMin(node) {\n                while (node.left !== null) {\n                    node = node.left;\n                }\n                return node;\n            }\n        }\n\n        let tree = new BPlusTree();\n        tree.insert(5, 'five');\n        tree.insert(2, 'two');\n        tree.insert(8, 'eight');\n        tree.insert(3, 'three');\n        tree.insert(9, 'nine');\n        tree.insert(1, 'one');\n        tree.insert(4, 'four');\n\n        console.log(tree.search(5)); // five\n        console.log(tree.search(8)); // eight\n        console.log(tree.search(3)); // three\n        console.log(tree.search(9)); // nine\n        console.log(tree.search(1)); // one\n        console.log(tree.search(4)); // four\n\n        tree.delete(5);\n        console.log(tree.search(5)); // null\n    </script>\n</body>\n</html>"
