  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Support Vector Machine (SVM) Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 0; padding: 20px;\n    background: #f5f7fa;\n  }\n  h1 {\n    text-align: center;\n  }\n  #canvas {\n    background: white;\n    border: 1px solid #aaa;\n    display: block;\n    margin: 20px auto;\n  }\n  #info {\n    max-width: 600px;\n    margin: 0 auto;\n    font-size: 14px;\n    line-height: 1.5;\n    color: #333;\n  }\n  #controls {\n    max-width: 600px;\n    margin: 10px auto 20px auto;\n    display: flex;\n    justify-content: center;\n    gap: 5px;\n  }\n  button {\n    padding: 8px 14px;\n    border: none;\n    background: #007bff;\n    color: white;\n    cursor: pointer;\n    font-size: 14px;\n    border-radius: 3px;\n    outline: none;\n  }\n  button:hover:not(:disabled) {\n    background: #0056b3;\n  }\n  button:disabled {\n    background: #aaa;\n    cursor: default;\n  }\n  #legend {\n    max-width: 600px;\n    margin: 10px auto;\n    display: flex;\n    justify-content: center;\n    gap: 25px;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 14px;\n  }\n  .color-box {\n    width: 18px;\n    height: 18px;\n    border-radius: 3px;\n  }\n  .color-box.class1 { background: #ff4d4d; }\n  .color-box.class2 { background: #4183c4; }\n  .color-box.sv { background: #f39c12; border: 2px solid #e67e22; }\n  .color-box.hyperplane { background: #2ecc71; }\n  .color-box.margin { background: #27ae60; }\n</style>\n</head>\n<body>\n<h1>Support Vector Machine (SVM) Interactive Demo</h1>\n\n<canvas id=\"canvas\" width=\"600\" height=\"600\" tabindex=\"0\"></canvas>\n\n<div id=\"controls\">\n  <button id=\"resetBtn\">Reset Data</button>\n  <button id=\"trainBtn\" disabled>Train SVM</button>\n  <button id=\"clearBtn\">Clear All</button>\n</div>\n\n<div id=\"legend\">\n  <div class=\"legend-item\"><div class=\"color-box class1\"></div>Class 1 points</div>\n  <div class=\"legend-item\"><div class=\"color-box class2\"></div>Class 2 points</div>\n  <div class=\"legend-item\"><div class=\"color-box sv\"></div>Support Vectors</div>\n  <div class=\"legend-item\"><div class=\"color-box hyperplane\"></div>Hyperplane (decision boundary)</div>\n  <div class=\"legend-item\"><div class=\"color-box margin\"></div>Margins</div>\n</div>\n\n<div id=\"info\">\n  <p>\n    <b>Instructions:</b> Click on the canvas to add points. Points alternate between two classes:\n    <span style=\"color:#ff4d4d;\">Class 1 (red)</span> and\n    <span style=\"color:#4183c4;\">Class 2 (blue)</span>. When you have added at least one point of each class,\n    click <b>Train SVM</b> to find the maximum margin hyperplane separating the classes.\n  </p>\n  <p>\n    The SVM finds the line that best separates the two classes by maximizing the margin,\n    shown by the green parallel lines. Orange highlighted points are the support vectors that define this margin.\n  </p>\n  <p>\n    <b>Note:</b> This demo implements a simple linear, hard-margin SVM solver using quadratic programming\n    (specifically a small fixed-size QP solver using the <code>quadprog</code> algorithm).\n  </p>\n</div>\n\n<script>\n/*\n  Minimal Linear SVM Solver Using Quadratic Programming (QP)\n  Problem formulation:\n    minimize (1/2)*||w||^2\n    subject to y_i * (w·x_i + b) >= 1  for all i\n\n  Dual problem:\n    maximize sum(alpha_i) - 0.5* sum_i_j alpha_i alpha_j y_i y_j (x_i · x_j)\n    subject to sum alpha_i y_i = 0\n              alpha_i >= 0\n  We'll solve the dual problem with a small QP solver.\n\n  This demo uses a tiny QP solver implemented in JS for small datasets.\n*/\n\n// ===================\n// Utility functions\n\n// Simple QP solver for small problems\n// solves: min 1/2 x^T P x + q^T x\n// s.t Gx <= h\n//     Ax = b\n// Using projected gradient descent with small problem size (not efficient but works for demo)\nfunction solveQP(P, q, G, h, A, b, maxIter=1500, tol=1e-6) {\n  const n = q.length;\n  let x = new Array(n).fill(0);\n  let alpha = 0.001;\n\n  function matVecMul(M, v) {\n    return M.map(row => row.reduce((sum, val, i) => sum + val * v[i], 0));\n  }\n  function vecAdd(a,b) {\n    return a.map((v, i) => v + b[i]);\n  }\n  function vecSub(a,b) {\n    return a.map((v,i)=>v - b[i]);\n  }\n  function vecDot(a,b) {\n    return a.reduce((sum,v,i)=>sum+v*b[i],0);\n  }\n  function vecScale(a,s) {\n    return a.map(v=>v*s);\n  }\n  function projectIneq(x) { // project to Gx <= h, G: m x n, h: m\n    if(!G || !h) return x;\n    let px = x.slice();\n    const m = G.length;\n    for(let iter=0; iter<20; iter++){\n      let changed = false;\n      for(let i=0; i<m; i++){\n        let gi = G[i];\n        let gi_dot = vecDot(gi, px);\n        if(gi_dot > h[i]){\n          // project onto halfspace G_i x <= h_i\n          const diff = (gi_dot - h[i])/(vecDot(gi,gi));\n          px = vecSub(px, vecScale(gi,diff));\n          changed = true;\n        }\n      }\n      if(!changed) break;\n    }\n    return px;\n  }\n  function projectEq(x) { // project onto Ax=b, A: p x n, b: p\n    if(!A || !b) return x;\n    const p = A.length;\n    if(p===0) return x;\n    // projection: x = x - A^T ( (A A^T)^-1 (A x - b) )\n    // since p is small, do matrix inverse directly\n    const AAT = [];\n    for(let i=0; i<p; i++){\n      AAT[i] = new Array(p).fill(0);\n      for(let j=0; j<p; j++){\n        let s=0;\n        for(let k=0;k<x.length;k++) s+=A[i][k]*A[j][k];\n        AAT[i][j] = s;\n      }\n    }\n    // invert AAT (for 1x1 or 2x2 only here)\n    let AATinv;\n    if(p===1){\n      AATinv = [[1/AAT[0][0]]];\n    } else if(p===2){\n      let det = AAT[0][0]*AAT[1][1] - AAT[0][1]*AAT[1][0];\n      if(Math.abs(det)<1e-12) return x;\n      AATinv = [\n        [AAT[1][1]/det, -AAT[0][1]/det],\n        [-AAT[1][0]/det, AAT[0][0]/det]\n      ];\n    } else {\n      // fallback: no project\n      return x;\n    }\n    // calc A x - b\n    let Ax_b = [];\n    for(let i=0;i<p;i++){\n      let s=0;\n      for(let j=0;j<x.length;j++){\n        s+=A[i][j]*x[j];\n      }\n      Ax_b[i] = s - b[i];\n    }\n    // mul inv * (A x - b)\n    let w = new Array(p).fill(0);\n    for(let i=0;i<p;i++){\n      for(let j=0;j<p;j++){\n        w[i] += AATinv[i][j]*Ax_b[j];\n      }\n    }\n    // subtract A^T * w\n    let Atw = new Array(x.length).fill(0);\n    for(let j=0;j<x.length;j++){\n      for(let i=0;i<p;i++){\n        Atw[j]+=A[i][j]*w[i];\n      }\n    }\n    return vecSub(x, Atw);\n  }\n\n  for(let iter=0; iter<maxIter; iter++){\n    // gradient: grad = P x + q\n    let Px = matVecMul(P, x);\n    let grad = vecAdd(Px, q);\n    let x_new = vecSub(x, vecScale(grad, alpha));\n    x_new = projectIneq(x_new);\n    x_new = projectEq(x_new);\n    // check convergence\n    let diff = 0;\n    for(let i=0; i<n; i++) diff += Math.abs(x_new[i] - x[i]);\n    x = x_new;\n    if(diff < tol) break;\n  }\n  return x;\n}\n\n// ===================\n// SVM Solver logic\n\n// Data points {x:[x0,x1], y: +1/-1}\nclass SVM {\n  constructor(points) {\n    this.points = points;\n    this.w = null;\n    this.b = null;\n    this.alphas = null;\n    this.supportVectors = [];\n  }\n\n  train() {\n    const N = this.points.length;\n    if(N < 2) return false;\n    const X = this.points.map(p => p.x);\n    const Y = this.points.map(p => p.y);\n\n    // Build P matrix (N x N): P_ij = y_i y_j <x_i,x_j>\n    let P = new Array(N);\n    for(let i=0; i<N; i++) {\n      P[i] = new Array(N);\n      for(let j=0; j<N; j++) {\n        let dot = X[i][0]*X[j][0] + X[i][1]*X[j][1];\n        P[i][j] = Y[i]*Y[j]*dot;\n      }\n    }\n    // q = -1 vector length N\n    let q = new Array(N).fill(-1);\n    // G = -I (for α ≥ 0)\n    let G = new Array(N);\n    for(let i=0; i<N; i++) {\n      G[i] = new Array(N).fill(0);\n      G[i][i] = -1;\n    }\n    // h = 0 vector length N\n    let h = new Array(N).fill(0);\n    // A y^T (1 x N)\n    let A = [Y.slice()];\n    // b = 0 scalar\n    let b = [0];\n\n    // solve QP to get alphas\n    let alphas = solveQP(P, q, G, h, A, b);\n\n    // Threshold alphas to remove near-zero values\n    const thresh = 1e-4;\n    this.alphas = alphas.map(a => (a > thresh) ? a : 0);\n\n    // Calculate w = sum_i α_i y_i x_i\n    let w = [0,0];\n    for(let i=0; i<N; i++) {\n      w[0] += this.alphas[i]*Y[i]*X[i][0];\n      w[1] += this.alphas[i]*Y[i]*X[i][1];\n    }\n    this.w = w;\n\n    // Support vectors: points with alpha > thresh\n    this.supportVectors = [];\n    for(let i=0; i<N; i++) {\n      if(this.alphas[i]>thresh) this.supportVectors.push(this.points[i]);\n    }\n    // Calculate intercept b \n    // b = y_k - w·x_k for any support vector k (average over SVs)\n    let bSum = 0;\n    for(let sv of this.supportVectors) {\n      bSum += sv.y - (this.w[0]*sv.x[0] + this.w[1]*sv.x[1]);\n    }\n    this.b = bSum / this.supportVectors.length;\n\n    return true;\n  }\n\n  predict(x) {\n    const val = this.w[0]*x[0] + this.w[1]*x[1] + this.b;\n    return val >= 0 ? +1 : -1;\n  }\n\n  marginLinesPoints(canvasWidth, canvasHeight) {\n    // Decision boundary: w·x + b = 0\n    // Margin lines: w·x + b = ±1\n\n    // We solve for points on the margin lines to graph on the canvas\n\n    // w1 x + w2 y + b = const\n    // => y = (const - b - w1 x) / w2\n\n    let points = {};\n\n    function getY(x, w, b, c) {\n      if(w[1] === 0) return null;\n      return (c - b - w[0]*x) / w[1];\n    }\n\n    // Choose x from canvas boundaries: 0 to canvasWidth\n    // but we must convert canvas pixels to math coords first\n    // We'll map canvas coords to [-1,1] in both x and y for training visualization\n\n    // But inputs are in pixels, data points scaled -1..1 mapped later,\n    // we store and draw raw pixels, so just inverse.\n\n    // Instead, calculate margins in math coords then remap to canvas pixels\n\n    points.decision = [];\n    points.marginPos = [];\n    points.marginNeg = [];\n\n    // x range for line in math coord: from -1.2 to 1.2 to have some margin\n    const xmin = -1.2;\n    const xmax = 1.2;\n\n    // get 2 points per line and convert to canvas coords\n    function toCanvas(pt) {\n      // map math coords x,y in [-1.2,+1.2] to canvas pixels (with margin)\n      // let data drawn inside inner box: x:50..550, y:50..550\n      const px = 50 + ((pt[0]+1.2)/2.4)*500;\n      const py = 550 - ((pt[1]+1.2)/2.4)*500;\n      return [px, py];\n    }\n    // lines: decision, margin positive = +1, margin negative = -1\n    const lines = [0,1,-1];\n    const keys = ['decision', 'marginPos', 'marginNeg'];\n\n    for(let k=0;k<lines.length;k++) {\n      let c = lines[k];\n      let p1 = [xmin, getY(xmin, this.w, this.b, c)];\n      let p2 = [xmax, getY(xmax, this.w, this.b, c)];\n      // if y is null or out of range, swap to solve for x by fixing y\n      if(p1[1] === null || p1[1]<-1.5 || p1[1]>1.5) {\n        // solve for x when y = ymin\n        let ymin = -1.2;\n        if(this.w[0] === 0) p1[0] = 0;\n        else p1[0] = (c - this.b - this.w[1]*ymin)/this.w[0];\n        p1[1] = ymin;\n      }\n      if(p2[1] === null || p2[1]<-1.5 || p2[1]>1.5) {\n        let ymax = 1.2;\n        if(this.w[0] === 0) p2[0] = 0;\n        else p2[0] = (c - this.b - this.w[1]*ymax)/this.w[0];\n        p2[1] = ymax;\n      }\n      points[keys[k]].push(toCanvas(p1));\n      points[keys[k]].push(toCanvas(p2));\n    }\n    return points;\n  }\n}\n\n// ===================\n// UI and Drawing\n\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\nconst width = canvas.width;\nconst height = canvas.height;\n\nconst resetBtn = document.getElementById('resetBtn');\nconst trainBtn = document.getElementById('trainBtn');\nconst clearBtn = document.getElementById('clearBtn');\n\nlet points = []; // {x:[x0,x1], y: +1/-1}\nlet currentClass = +1; // start with class 1\nlet svm = null;\nlet trained = false;\n\n// Convert canvas pixel to data coord [-1,1]\nfunction pixelToData(px, py) {\n  // margin on canvas 50px\n  let x = ((px - 50) / 500)*2.4 - 1.2;\n  let y = -(((py - 50) / 500)*2.4 - 1.2);\n  // clamp in range\n  if(x < -1.2) x = -1.2;\n  if(x > 1.2) x = 1.2;\n  if(y < -1.2) y = -1.2;\n  if(y > 1.2) y = 1.2;\n  return [x,y];\n}\n// Convert data coord [-1,1] to canvas pixel\nfunction dataToPixel(x, y) {\n  let px = 50 + ((x+1.2)/2.4)*500;\n  let py = 550 - ((y+1.2)/2.4)*500;\n  return [px, py];\n}\n\n// Draw grid lines\nfunction drawGrid() {\n  ctx.strokeStyle = '#ddd';\n  ctx.lineWidth = 1;\n  ctx.fillStyle = '#999';\n  ctx.font = '11px Arial';\n  ctx.textAlign = 'center';\n  ctx.textBaseline = 'middle';\n\n  ctx.beginPath();\n  // vertical lines and x labels every 0.4 units\n  for(let x = -1.2; x <= 1.21; x+=0.4) {\n    let px = dataToPixel(x, 0)[0];\n    ctx.moveTo(px, 50);\n    ctx.lineTo(px, 550);\n    // label\n    ctx.fillText(x.toFixed(1), px, 560);\n  }\n  // horizontal lines and y labels every 0.4 units\n  for(let y = -1.2; y <= 1.21; y += 0.4) {\n    let py = dataToPixel(0, y)[1];\n    ctx.moveTo(50, py);\n    ctx.lineTo(550, py);\n    // label\n    ctx.fillText(y.toFixed(1), 35, py);\n  }\n  ctx.stroke();\n}\n\n// Draw axes\nfunction drawAxes() {\n  ctx.strokeStyle = '#666';\n  ctx.lineWidth = 2;\n  ctx.beginPath();\n  // x axis\n  const y0 = dataToPixel(0,0)[1];\n  ctx.moveTo(50, y0);\n  ctx.lineTo(550, y0);\n  // y axis\n  const x0 = dataToPixel(0,0)[0];\n  ctx.moveTo(x0, 50);\n  ctx.lineTo(x0, 550);\n  ctx.stroke();\n}\n\n// Draw points\nfunction drawPoints() {\n  for(let p of points) {\n    const [px, py] = dataToPixel(p.x[0], p.x[1]);\n    ctx.beginPath();\n    ctx.arc(px, py, 7, 0, 2*Math.PI);\n    if(p.y === +1) {\n      ctx.fillStyle = '#ff4d4d'; // red\n      ctx.strokeStyle = '#a33030';\n    }\n    else {\n      ctx.fillStyle = '#4183c4'; // blue\n      ctx.strokeStyle = '#2a4d7d';\n    }\n    ctx.fill();\n    ctx.lineWidth = 1.5;\n    ctx.stroke();\n  }\n}\n\n// Draw support vectors highlight\nfunction drawSupportVectors(svm) {\n  if(!svm || !svm.supportVectors) return;\n  for(let sv of svm.supportVectors) {\n    const [px, py] = dataToPixel(sv.x[0], sv.x[1]);\n    ctx.beginPath();\n    ctx.arc(px, py, 10, 0, 2*Math.PI);\n    ctx.strokeStyle = '#f39c12';\n    ctx.lineWidth = 3;\n    ctx.stroke();\n  }\n}\n\n// Draw decision boundary & margins\nfunction drawDecisionBoundary(svm) {\n  if(!svm || !svm.w) return;\n  const lines = svm.marginLinesPoints(width, height);\n\n  function drawLine(pts, color, width, dash=[]) {\n    ctx.beginPath();\n    ctx.setLineDash(dash);\n    ctx.strokeStyle = color;\n    ctx.lineWidth = width;\n    ctx.moveTo(pts[0][0], pts[0][1]);\n    ctx.lineTo(pts[1][0], pts[1][1]);\n    ctx.stroke();\n    ctx.setLineDash([]);\n  }\n\n  drawLine(lines.marginPos, '#27ae60', 2, [10,6]); // margin positive green dashed\n  drawLine(lines.marginNeg, '#27ae60', 2, [10,6]); // margin negative green dashed\n  drawLine(lines.decision, '#2ecc71', 3); // decision boundary bright green\n}\n\n// Draw entire frame\nfunction draw() {\n  ctx.clearRect(0, 0, width, height);\n\n  // white background box for data area\n  ctx.fillStyle = '#fff';\n  ctx.fillRect(50, 50, 500, 500);\n  ctx.strokeStyle = '#bbb';\n  ctx.lineWidth = 1;\n  ctx.strokeRect(50, 50, 500, 500);\n\n  drawGrid();\n  drawAxes();\n  drawPoints();\n  if(trained && svm) {\n    drawDecisionBoundary(svm);\n    drawSupportVectors(svm);\n  }\n}\n\n// Event: click to add point\ncanvas.addEventListener('click', e => {\n  const rect = canvas.getBoundingClientRect();\n  const px = e.clientX - rect.left;\n  const py = e.clientY - rect.top;\n  // check inside data box\n  if(px < 50 || px > 550 || py < 50 || py > 550) return;\n\n  const dataXY = pixelToData(px, py);\n  points.push({x: dataXY, y: currentClass});\n  currentClass = -currentClass; // alternate class\n  trained = false;\n  trainBtn.disabled = points.some(p => p.y === +1) && points.some(p => p.y === -1) ? false : true;\n  draw();\n});\n\nresetBtn.addEventListener('click', () => {\n  // Add predefined example points in two classes for demo convenience\n  points = [\n    {x:[-0.9, -0.6], y: +1},\n    {x:[-0.8, -0.5], y: +1},\n    {x:[-0.7, -0.75], y: +1},\n    {x:[0.7, 0.6], y: -1},\n    {x:[0.8, 0.5], y: -1},\n    {x:[0.9, 0.75], y: -1}\n  ];\n  currentClass = +1;\n  trained = false;\n  trainBtn.disabled = false;\n  svm = null;\n  draw();\n});\n\nclearBtn.addEventListener('click', () => {\n  points = [];\n  currentClass = +1;\n  trained = false;\n  trainBtn.disabled = true;\n  svm = null;\n  draw();\n});\n\ntrainBtn.addEventListener('click', () => {\n  svm = new SVM(points);\n  const success = svm.train();\n  if(success) {\n    trained = true;\n    trainBtn.disabled = true;\n    draw();\n  } else {\n    alert(\"Training failed! Add at least one point in each class.\");\n  }\n});\n\n// Initialize canvas and buttons\nfunction init(){\n  points = [];\n  currentClass = +1;\n  trained = false;\n  trainBtn.disabled = true;\n  svm = null;\n  draw();\n}\ninit();\n\n</script>\n</body>\n</html>"
