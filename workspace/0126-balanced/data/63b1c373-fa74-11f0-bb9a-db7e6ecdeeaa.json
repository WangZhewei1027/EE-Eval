    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Topological Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n  }\n  #container {\n    display: flex;\n    gap: 40px;\n  }\n  #graph, #result {\n    flex: 1;\n  }\n  svg {\n    border: 1px solid #ccc;\n    background: #fafafa;\n    width: 100%;\n    height: 400px;\n  }\n  .node {\n    cursor: default;\n    stroke: #333;\n    stroke-width: 1.5px;\n  }\n  .node circle {\n    fill: #69b3a2;\n    stroke: #333;\n    stroke-width: 1.5px;\n  }\n  .node.done circle {\n    fill: #4CAF50;\n  }\n  .node.current circle {\n    fill: #f39c12;\n  }\n  .edge path {\n    fill: none;\n    stroke: #333;\n    stroke-width: 1.2px;\n    marker-end: url(#arrowhead);\n  }\n  .edge.highlight path {\n    stroke: #f39c12;\n    stroke-width: 2.5px;\n  }\n  .edge.done path {\n    stroke: #4CAF50;\n    stroke-width: 2.5px;\n  }\n  #controls {\n    margin-bottom: 20px;\n  }\n  #order {\n    font-size: 1.1em;\n    margin-top: 10px;\n    min-height: 30px;\n  }\n  button {\n    padding: 8px 16px;\n    font-size: 1em;\n  }\n  label {\n    display: block;\n    margin-top: 10px;\n  }\n  textarea {\n    width: 100%;\n    height: 100px;\n    font-family: monospace;\n    font-size: 14px;\n  }\n  h2 {\n    margin-top: 0;\n  }\n  #message {\n    font-weight: bold;\n    margin-top: 10px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Topological Sort Demonstration</h1>\n<div id=\"controls\">\n  <label for=\"graphInput\">Enter graph edges (one per line) in format:<br>\n  <code>fromNode toNode</code></label>\n  <textarea id=\"graphInput\" spellcheck=\"false\">A C\nB C\nC D\nD E\nB F\nF E</textarea>\n\n  <button id=\"startBtn\">Start Topological Sort</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n  <div id=\"message\"></div>\n</div>\n\n<div id=\"container\">\n  <div id=\"graph\">\n    <h2>Graph Visualization</h2>\n    <svg id=\"svg\" viewBox=\"0 0 600 400\"></svg>\n  </div>\n  <div id=\"result\">\n    <h2>Topological Order</h2>\n    <div id=\"order\"></div>\n  </div>\n</div>\n\n<script>\n(() => {\n  const svgNS = \"http://www.w3.org/2000/svg\";\n  const svg = document.getElementById('svg');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const graphInput = document.getElementById('graphInput');\n  const orderDiv = document.getElementById('order');\n  const messageDiv = document.getElementById('message');\n\n  // We will lay out nodes in a circular pattern for clarity.\n  const radius = 150;\n  const centerX = 300;\n  const centerY = 200;\n\n  let graph = new Map();\n  let nodes = new Set();\n  let positions = new Map();\n  let adjacencyList = new Map();\n  let inDegree = new Map();\n\n  // Animation control\n  let topoOrder = [];\n  let step = 0;\n  let intervalId = null;\n\n  // Parse input\n  function parseInput(){\n    graph.clear();\n    nodes.clear();\n    adjacencyList.clear();\n    inDegree.clear();\n\n    const lines = graphInput.value.trim().split('\\n');\n    for(let line of lines){\n      line = line.trim();\n      if(!line) continue;\n      const parts = line.split(/\\s+/);\n      if(parts.length !== 2) continue;\n      const from = parts[0];\n      const to = parts[1];\n\n      nodes.add(from);\n      nodes.add(to);\n\n      if(!adjacencyList.has(from)) adjacencyList.set(from, []);\n      adjacencyList.get(from).push(to);\n    }\n\n    // Add nodes who have no outgoing edges but might be isolated\n    for(let n of nodes){\n      if(!adjacencyList.has(n)) adjacencyList.set(n, []);\n    }\n\n    // Compute inDegree\n    for(let n of nodes){\n      inDegree.set(n, 0);\n    }\n    for(let [from, tos] of adjacencyList.entries()){\n      for(let to of tos){\n        inDegree.set(to, (inDegree.get(to) || 0) + 1);\n      }\n    }\n  }\n\n  // Clear SVG and draw graph\n  function drawGraph(){\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n\n    // Define arrowhead marker\n    const marker = document.createElementNS(svgNS, \"marker\");\n    marker.setAttribute(\"id\", \"arrowhead\");\n    marker.setAttribute(\"markerWidth\", \"10\");\n    marker.setAttribute(\"markerHeight\", \"7\");\n    marker.setAttribute(\"refX\", \"10\");\n    marker.setAttribute(\"refY\", \"3.5\");\n    marker.setAttribute(\"orient\", \"auto\");\n    marker.setAttribute(\"markerUnits\", \"strokeWidth\");\n    const path = document.createElementNS(svgNS, \"path\");\n    path.setAttribute(\"d\", \"M0,0 L10,3.5 L0,7 Z\");\n    path.setAttribute(\"fill\", \"#333\");\n    marker.appendChild(path);\n    const defs = document.createElementNS(svgNS, \"defs\");\n    defs.appendChild(marker);\n    svg.appendChild(defs);\n\n    // Position nodes evenly in circle\n    const nodeCount = nodes.size;\n    let i = 0;\n    positions.clear();\n    for(let n of nodes){\n      const angle = (2 * Math.PI * i) / nodeCount - Math.PI / 2;\n      const x = centerX + radius * Math.cos(angle);\n      const y = centerY + radius * Math.sin(angle);\n      positions.set(n, {x, y});\n      i++;\n    }\n\n    // Draw edges\n    for(let [from, tos] of adjacencyList.entries()){\n      const p1 = positions.get(from);\n      for(let to of tos){\n        const p2 = positions.get(to);\n        drawEdge(p1, p2, `${from}->${to}`);\n      }\n    }\n\n    // Draw nodes\n    for(let n of nodes){\n      const p = positions.get(n);\n      drawNode(n, p.x, p.y);\n    }\n  }\n\n  function drawEdge(p1, p2, id){\n    const g = document.createElementNS(svgNS, \"g\");\n    g.setAttribute(\"class\", \"edge\");\n    g.setAttribute(\"id\", \"edge-\" + id);\n\n    // Calculate edge line points with padding so arrow does not overlap circle\n    const dx = p2.x - p1.x;\n    const dy = p2.y - p1.y;\n    const distance = Math.sqrt(dx*dx + dy*dy);\n    const normX = dx / distance;\n    const normY = dy / distance;\n    const r = 20; // node radius\n    const startX = p1.x + normX*r;\n    const startY = p1.y + normY*r;\n    const endX = p2.x - normX*r;\n    const endY = p2.y - normY*r;\n\n    const path = document.createElementNS(svgNS, \"path\");\n    // curve path to avoid overlapping node circles\n    // We'll do a simple quadratic curve with control point midpoint plus offset\n    const mx = (startX + endX) / 2;\n    const my = (startY + endY) / 2;\n    const ox = -normY * 20; // perpendicular offset for curve\n    const oy = normX * 20;\n    const qx = mx + ox;\n    const qy = my + oy;\n    const d = `M${startX},${startY} Q${qx},${qy} ${endX},${endY}`;\n\n    path.setAttribute(\"d\", d);\n\n    g.appendChild(path);\n    svg.appendChild(g);\n  }\n\n  function drawNode(id, x, y){\n    const g = document.createElementNS(svgNS, \"g\");\n    g.setAttribute(\"class\", \"node\");\n    g.setAttribute(\"id\", \"node-\" + id);\n\n    const circle = document.createElementNS(svgNS, \"circle\");\n    circle.setAttribute(\"cx\", x);\n    circle.setAttribute(\"cy\", y);\n    circle.setAttribute(\"r\", 20);\n    g.appendChild(circle);\n\n    const text = document.createElementNS(svgNS, \"text\");\n    text.setAttribute(\"x\", x);\n    text.setAttribute(\"y\", y + 5);\n    text.setAttribute(\"text-anchor\", \"middle\");\n    text.setAttribute(\"font-size\", \"16px\");\n    text.setAttribute(\"fill\", \"white\");\n    text.textContent = id;\n    g.appendChild(text);\n\n    svg.appendChild(g);\n  }\n\n  // Topological sort with animation support:\n  // We use Kahn's algorithm step by step\n  // At each step:\n  //  - Highlight nodes with inDegree 0 (candidates to remove)\n  //  - Remove one node: show it as \"current\" and then as \"done\"\n  //  - Remove edges from it, update inDegrees highlighted\n\n  function disableInterface(disabled){\n    startBtn.disabled = disabled;\n    graphInput.disabled = disabled;\n    resetBtn.disabled = !disabled;\n  }\n\n  function resetGraphStyles(){\n    for(let n of nodes){\n      const nodeG = document.getElementById(\"node-\" + n);\n      if(nodeG){\n        nodeG.classList.remove(\"done\", \"current\");\n      }\n    }\n    for(let [from, tos] of adjacencyList.entries()){\n      for(let to of tos){\n        let edgeG = document.getElementById(\"edge-\" + from + \"->\" + to);\n        if(edgeG){\n          edgeG.classList.remove(\"highlight\", \"done\");\n        }\n      }\n    }\n  }\n\n  function highlightCandidates(candidates){\n    for(let c of candidates){\n      const nodeG = document.getElementById(\"node-\" + c);\n      if(nodeG){\n        nodeG.classList.add(\"current\");\n      }\n    }\n  }\n\n  function clearHighlights(){\n    for(let n of nodes){\n      const nodeG = document.getElementById(\"node-\" + n);\n      if(nodeG){\n        nodeG.classList.remove(\"current\");\n      }\n    }\n    for(let [from, tos] of adjacencyList.entries()){\n      for(let to of tos){\n        let edgeG = document.getElementById(\"edge-\" + from + \"->\" + to);\n        if(edgeG){\n          edgeG.classList.remove(\"highlight\");\n        }\n      }\n    }\n  }\n\n  // Perform a topological sort step-by-step with animation\n  function* topologicalSortGen(){\n    // clone inDegree map to mutate\n    let inDeg = new Map(inDegree);\n    let adj = new Map();\n    for(let [k,v] of adjacencyList.entries()){\n      adj.set(k, v.slice());\n    }\n    let queue = [];\n    for(let [n, deg] of inDeg.entries()){\n      if(deg === 0) queue.push(n);\n    }\n\n    let order = [];\n\n    while(queue.length){\n      // Highlight current candidates\n      clearHighlights();\n      highlightCandidates(queue);\n\n      // Yield to show candidates\n      yield {type: \"candidates\", candidates: queue.slice()};\n\n      // Choose first node to remove (could be randomized, but deterministic here)\n      const n = queue.shift();\n\n      clearHighlights();\n      const nodeG = document.getElementById(\"node-\" + n);\n      if(nodeG){\n        nodeG.classList.add(\"current\");\n      }\n\n      yield {type: \"removing\", node: n};\n\n      order.push(n);\n\n      // remove edges from n\n      for(let m of adj.get(n) || []){\n        // highlight edge being removed\n        let edgeG = document.getElementById(\"edge-\" + n + \"->\" + m);\n        if(edgeG){\n          edgeG.classList.add(\"highlight\");\n        }\n        yield {type: \"removingEdge\", from: n, to: m};\n\n        inDeg.set(m, inDeg.get(m) - 1);\n\n        // after removal, edge done\n        if(edgeG){\n          edgeG.classList.remove(\"highlight\");\n          edgeG.classList.add(\"done\");\n        }\n\n        if(inDeg.get(m) === 0){\n          queue.push(m);\n        }\n      }\n\n      // mark node done\n      if(nodeG){\n        nodeG.classList.remove(\"current\");\n        nodeG.classList.add(\"done\");\n      }\n\n      yield {type: \"doneNode\", node: n, order: order.slice()};\n    }\n\n    // Check if all nodes visited\n    if(order.length !== nodes.size){\n      yield {type: \"cycleDetected\"};\n      return;\n    }\n    yield {type: \"finished\", order};\n  }\n\n  let gen = null;\n\n  function startAnimation(){\n    resetGraphStyles();\n    orderDiv.textContent = \"\";\n    messageDiv.textContent = \"\";\n    disableInterface(true);\n\n    gen = topologicalSortGen();\n\n    function stepAnimation(){\n      const res = gen.next();\n      if(res.done){\n        disableInterface(false);\n        return;\n      }\n      handleStep(res.value);\n    }\n\n    function handleStep(stepInfo){\n      switch(stepInfo.type){\n        case \"candidates\":\n          messageDiv.textContent = \"Nodes with in-degree 0 (candidates): \" + stepInfo.candidates.join(\", \");\n          break;\n        case \"removing\":\n          messageDiv.textContent = \"Removing node: \" + stepInfo.node;\n          break;\n        case \"removingEdge\":\n          messageDiv.textContent = `Removing edge: ${stepInfo.from} → ${stepInfo.to}`;\n          break;\n        case \"doneNode\":\n          orderDiv.textContent = stepInfo.order.join(\" → \");\n          messageDiv.textContent = \"Node completed: \" + stepInfo.node;\n          break;\n        case \"cycleDetected\":\n          messageDiv.textContent = \"Cycle detected! Topological sort not possible.\";\n          disableInterface(false);\n          clearInterval(intervalId);\n          intervalId = null;\n          return;\n        case \"finished\":\n          orderDiv.textContent = stepInfo.order.join(\" → \");\n          messageDiv.textContent = \"Topological sort completed!\";\n          disableInterface(false);\n          clearInterval(intervalId);\n          intervalId = null;\n          return;\n      }\n    }\n\n    // run stepAnimation every 1500ms\n    stepAnimation();\n    intervalId = setInterval(() => {\n      stepAnimation();\n      if(intervalId === null){\n        clearInterval(intervalId);\n      }\n    }, 1500);\n  }\n\n  function resetAll(){\n    messageDiv.textContent = \"\";\n    orderDiv.textContent = \"\";\n    disableInterface(false);\n    if(intervalId){\n      clearInterval(intervalId);\n      intervalId = null;\n    }\n    resetGraphStyles();\n  }\n\n  // Button handlers\n  startBtn.addEventListener(\"click\", () => {\n    parseInput();\n\n    if(nodes.size === 0){\n      messageDiv.textContent = \"No nodes detected! Please enter graph edges.\";\n      return;\n    }\n\n    drawGraph();\n    resetGraphStyles();\n    startAnimation();\n  });\n\n  resetBtn.addEventListener(\"click\", () => {\n    resetAll();\n    parseInput();\n    drawGraph();\n  });\n\n  // Initial draw\n  parseInput();\n  drawGraph();\n\n})();\n</script>\n\n</body>\n</html>"
  },
