    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Priority Queue Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 1rem;\n  }\n  .container {\n    max-width: 600px;\n    margin: 0 auto;\n    background: #ffffff;\n    padding: 1.5rem 2rem;\n    border-radius: 8px;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n  }\n  label {\n    display: block;\n    margin-top: 1rem;\n  }\n  input[type=\"text\"],\n  input[type=\"number\"] {\n    width: 100%;\n    padding: 0.4rem;\n    margin-top: 0.25rem;\n    box-sizing: border-box;\n    border: 1px solid #ccc;\n    border-radius: 4px;\n  }\n  button {\n    margin-top: 1rem;\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    border-radius: 4px;\n    border: none;\n    background: #1976d2;\n    color: white;\n    cursor: pointer;\n    transition: background-color 0.2s ease;\n  }\n  button:hover {\n    background: #135ba1;\n  }\n  .queue-display, .output {\n    background: #e9f0fe;\n    border-radius: 4px;\n    padding: 1rem;\n    margin-top: 1.5rem;\n    min-height: 50px;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n  .footer {\n    text-align: center;\n    margin-top: 2rem;\n    font-size: 0.9rem;\n    color: #666;\n  }\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Priority Queue Demo</h1>\n\n    <label for=\"element\">Element (value):</label>\n    <input type=\"text\" id=\"element\" placeholder=\"Enter element value\" />\n\n    <label for=\"priority\">Priority (number, lower = higher priority):</label>\n    <input type=\"number\" id=\"priority\" placeholder=\"Enter priority (e.g. 1 is highest)\" min=\"0\" />\n\n    <button id=\"enqueueBtn\">Enqueue</button>\n    <button id=\"dequeueBtn\">Dequeue</button>\n    <button id=\"peekBtn\">Peek</button>\n    <button id=\"clearBtn\">Clear Queue</button>\n\n    <h3>Current Priority Queue:</h3>\n    <div class=\"queue-display\" id=\"queueDisplay\">Queue is empty</div>\n\n    <h3>Output:</h3>\n    <div class=\"output\" id=\"output\"></div>\n\n  </div>\n\n<script>\n  // PriorityQueue implementation (min-priority queue: smaller priorities come out first)\n  class PriorityQueue {\n    constructor() {\n      this.items = [];\n    }\n\n    enqueue(element, priority) {\n      // Create a queue element\n      const queueElement = { element, priority };\n      if (this.isEmpty()) {\n        this.items.push(queueElement);\n      } else {\n        let added = false;\n        // Insert element in sorted order by priority\n        for (let i = 0; i < this.items.length; i++) {\n          if (priority < this.items[i].priority) {\n            this.items.splice(i, 0, queueElement);\n            added = true;\n            break;\n          }\n        }\n        if (!added) {\n          this.items.push(queueElement);\n        }\n      }\n    }\n\n    dequeue() {\n      if (this.isEmpty()) return null;\n      return this.items.shift();\n    }\n\n    peek() {\n      if (this.isEmpty()) return null;\n      return this.items[0];\n    }\n\n    isEmpty() {\n      return this.items.length === 0;\n    }\n\n    clear() {\n      this.items = [];\n    }\n\n    toString() {\n      if (this.isEmpty()) return \"Queue is empty\";\n      return this.items\n        .map((item, index) => `[${index}] ${item.element} (priority: ${item.priority})`)\n        .join(\"\\n\");\n    }\n  }\n\n  // DOM elements\n  const elementInput = document.getElementById('element');\n  const priorityInput = document.getElementById('priority');\n  const enqueueBtn = document.getElementById('enqueueBtn');\n  const dequeueBtn = document.getElementById('dequeueBtn');\n  const peekBtn = document.getElementById('peekBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const queueDisplay = document.getElementById('queueDisplay');\n  const output = document.getElementById('output');\n\n  // Create new priority queue\n  const pq = new PriorityQueue();\n\n  // Update queue display\n  function updateDisplay() {\n    queueDisplay.textContent = pq.toString();\n  }\n\n  // Enqueue handler\n  enqueueBtn.addEventListener('click', () => {\n    const element = elementInput.value.trim();\n    const priorityValue = priorityInput.value.trim();\n\n    if (element === \"\") {\n      alert(\"Please enter an element value.\");\n      elementInput.focus();\n      return;\n    }\n\n    if (priorityValue === \"\" || isNaN(priorityValue)) {\n      alert(\"Please enter a valid priority number.\");\n      priorityInput.focus();\n      return;\n    }\n\n    const priority = Number(priorityValue);\n    if (priority < 0) {\n      alert(\"Priority must be zero or positive.\");\n      priorityInput.focus();\n      return;\n    }\n\n    pq.enqueue(element, priority);\n    output.textContent = `Enqueued: \"${element}\" with priority ${priority}`;\n    updateDisplay();\n\n    // Clear inputs for next add\n    elementInput.value = \"\";\n    priorityInput.value = \"\";\n    elementInput.focus();\n  });\n\n  // Dequeue handler\n  dequeueBtn.addEventListener('click', () => {\n    if (pq.isEmpty()) {\n      output.textContent = \"Cannot dequeue. Queue is empty.\";\n      return;\n    }\n    const removed = pq.dequeue();\n    output.textContent = `Dequeued: \"${removed.element}\" with priority ${removed.priority}`;\n    updateDisplay();\n  });\n\n  // Peek handler\n  peekBtn.addEventListener('click', () => {\n    if (pq.isEmpty()) {\n      output.textContent = \"Queue is empty.\";\n      return;\n    }\n    const peeked = pq.peek();\n    output.textContent = `Front element: \"${peeked.element}\" with priority ${peeked.priority}`;\n  });\n\n  // Clear handler\n  clearBtn.addEventListener('click', () => {\n    pq.clear();\n    output.textContent = \"Queue cleared.\";\n    updateDisplay();\n  });\n\n  // Initialize display\n  updateDisplay();\n\n</script>\n</body>\n</html>"
  },
