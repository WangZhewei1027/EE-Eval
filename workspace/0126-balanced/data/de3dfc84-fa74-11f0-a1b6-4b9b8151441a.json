  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Support Vector Machine (SVM) Visualization</title>\n    <script src=\"https://d3js.org/d3.v7.min.js\"></script>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            padding: 20px;\n        }\n        .container {\n            margin-top: 20px;\n            position: relative;\n        }\n        .point {\n            fill-opacity: 0.8;\n            stroke: #fff;\n            stroke-width: 1.5px;\n        }\n        .decision-boundary {\n            fill: none;\n            stroke: #333;\n            stroke-width: 2px;\n            stroke-dasharray: 5,5;\n        }\n        .margin {\n            fill: none;\n            stroke: #999;\n            stroke-width: 1px;\n            stroke-dasharray: 3,3;\n        }\n        .support-vector {\n            stroke: #000;\n            stroke-width: 2px;\n        }\n        .controls {\n            margin: 20px 0;\n        }\n        button {\n            padding: 8px 12px;\n            margin: 0 5px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n    <h1>Support Vector Machine (SVM) Visualization</h1>\n    <p>Click to add data points (alternate colors with each click). SVM will find the optimal decision boundary.</p>\n    \n    <div class=\"controls\">\n        <button id=\"reset-btn\">Reset</button>\n        <button id=\"random-btn\">Add Random Points</button>\n        <div>\n            <label>Kernel: </label>\n            <select id=\"kernel-select\">\n                <option value=\"linear\">Linear</option>\n                <option value=\"rbf\">RBF (Gaussian)</option>\n            </select>\n        </div>\n    </div>\n    \n    <div class=\"container\" id=\"svm-container\"></div>\n\n    <script>\n        // Configuration\n        const width = 600;\n        const height = 400;\n        const margin = {top: 20, right: 20, bottom: 20, left: 20};\n        const innerWidth = width - margin.left - margin.right;\n        const innerHeight = height - margin.top - margin.bottom;\n        \n        // Create SVG\n        const svg = d3.select(\"#svm-container\")\n            .append(\"svg\")\n            .attr(\"width\", width)\n            .attr(\"height\", height)\n            .append(\"g\")\n            .attr(\"transform\", `translate(${margin.left},${margin.top})`);\n        \n        // Data storage\n        let points = [];\n        let currentColor = 0;\n        const colors = [\"steelblue\", \"orange\"];\n        \n        // Training data for SVM (scaled to [0,1])\n        let trainingData = [];\n        \n        // Initialize SVM\n        let svm = {\n            weights: [0, 0],\n            bias: 0,\n            margin: 0.1,\n            kernel: 'linear',\n            gamma: 10,\n            predict: function(x, y) {\n                const scaledX = x / innerWidth;\n                const scaledY = y / innerHeight;\n                \n                if (this.kernel === 'linear') {\n                    return this.weights[0] * scaledX + this.weights[1] * scaledY + this.bias;\n                } else if (this.kernel === 'rbf') {\n                    // RBF kernel - simplified for visualization\n                    // In a real SVM, we'd compute kernel between test point and all support vectors\n                    // Here we just look at distance to the margin line\n                    const distToLine = Math.abs(this.weights[0] * scaledX + this.weights[1] * scaledY + this.bias) / \n                                      Math.sqrt(this.weights[0] * this.weights[0] + this.weights[1] * this.weights[1]);\n                    const kernelVal = Math.exp(-this.gamma * distToLine * distToLine);\n                    return kernelVal > 0.5 ? 1 : -1;\n                }\n            }\n        };\n        \n        // Click handler to add points\n        svg.on(\"click\", function(event) {\n            const [x, y] = d3.pointer(event);\n            addPoint(x, y);\n        });\n        \n        // Reset button\n        d3.select(\"#reset-btn\").on(\"click\", function() {\n            points = [];\n            trainingData = [];\n            currentColor = 0;\n            svm.weights = [0, 0];\n            svm.bias = 0;\n            updateVisualization();\n        });\n        \n        // Random points button\n        d3.select(\"#random-btn\").on(\"click\", function() {\n            for (let i = 0; i < 10; i++) {\n                const x = Math.random() * innerWidth;\n                const y = Math.random() * innerHeight;\n                addPoint(x, y);\n            }\n        });\n        \n        // Kernel selector\n        d3.select(\"#kernel-select\").on(\"change\", function() {\n            svm.kernel = this.value;\n            trainSVM();\n            updateVisualization();\n        });\n        \n        // Add a point to the visualization and training data\n        function addPoint(x, y) {\n            const color = colors[currentColor];\n            currentColor = (currentColor + 1) % colors.length;\n            \n            points.push({x, y, color});\n            trainingData.push({\n                x: x / innerWidth,\n                y: y / innerHeight,\n                label: currentColor === 0 ? 1 : -1  // Alternate labels\n            });\n            \n            trainSVM();\n            updateVisualization();\n        }\n        \n        // Simplified SVM training (not a real SVM implementation)\n        function trainSVM() {\n            if (trainingData.length < 2) return;\n            \n            // For visualization, we'll do a simplified version:\n            // 1. Find class centroids\n            let classA = {x: 0, y: 0, count: 0};\n            let classB = {x: 0, y: 0, count: 0};\n            \n            trainingData.forEach(d => {\n                if (d.label > 0) {\n                    classA.x += d.x;\n                    classA.y += d.y;\n                    classA.count++;\n                } else {\n                    classB.x += d.x;\n                    classB.y += d.y;\n                    classB.count++;\n                }\n            });\n            \n            if (classA.count > 0) {\n                classA.x /= classA.count;\n                classA.y /= classA.count;\n            }\n            if (classB.count > 0) {\n                classB.x /= classB.count;\n                classB.y /= classB.count;\n            }\n            \n            // 2. The weights vector is the vector between centroids\n            svm.weights = [\n                classB.x - classA.x,\n                classB.y - classA.y\n            ];\n            \n            // 3. The bias is set to be at the midpoint\n            const midX = (classA.x + classB.x) / 2;\n            const midY = (classA.y + classB.y) / 2;\n            \n            svm.bias = -svm.weights[0] * midX - svm.weights[1] * midY;\n            \n            // 4. For non-linear kernel, we'll just increase the margin\n            svm.margin = svm.kernel === 'rbf' ? 0.2 : 0.1;\n        }\n        \n        // Update visualization\n        function updateVisualization() {\n            // Clear previous elements\n            svg.selectAll(\".point\").remove();\n            svg.selectAll(\".decision-boundary\").remove();\n            svg.selectAll(\".margin\").remove();\n            \n            // Draw points\n            svg.selectAll(\".point\")\n                .data(points)\n                .enter()\n                .append(\"circle\")\n                .attr(\"class\", \"point\")\n                .attr(\"cx\", d => d.x)\n                .attr(\"cy\", d => d.y)\n                .attr(\"r\", 8)\n                .attr(\"fill\", d => d.color);\n            \n            if (trainingData.length >= 2) {\n                // Draw decision boundary (where wTx + b = 0)\n                if (svm.kernel === 'linear') {\n                    const w = svm.weights;\n                    const b = svm.bias;\n                    \n                    // Find two points on the boundary line (scaled coordinates)\n                    let p1, p2;\n                    \n                    if (w[1] !== 0) {\n                        // Solve for y when x=0 and x=1\n                        p1 = {x: 0, y: (-b) / w[1]};\n                        p2 = {x: 1, y: (-b - w[0]) / w[1]};\n                    } else {\n                        // Vertical line when w[1]=0\n                        p1 = {x: -b / w[0], y: 0};\n                        p2 = {x: -b / w[0], y: 1};\n                    }\n                    \n                    // Scale back to pixel coordinates\n                    p1.x *= innerWidth;\n                    p1.y *= innerHeight;\n                    p2.x *= innerWidth;\n                    p2.y *= innerHeight;\n                    \n                    // Draw line\n                    svg.append(\"line\")\n                        .attr(\"class\", \"decision-boundary\")\n                        .attr(\"x1\", p1.x)\n                        .attr(\"y1\", p1.y)\n                        .attr(\"x2\", p2.x)\n                        .attr(\"y2\", p2.y);\n                    \n                    // Draw margin lines (where wTx + b = ±1)\n                    const margin1P1 = {x: 0, y: (-b + 1) / w[1]};\n                    const margin1P2 = {x: 1, y: (-b + 1 - w[0]) / w[1]};\n                    const margin2P1 = {x: 0, y: (-b - 1) / w[1]};\n                    const margin2P2 = {x: 1, y: (-b - 1 - w[0]) / w[1]};\n                    \n                    svg.append(\"line\")\n                        .attr(\"class\", \"margin\")\n                        .attr(\"x1\", margin1P1.x * innerWidth)\n                        .attr(\"y1\", margin1P1.y * innerHeight)\n                        .attr(\"x2\", margin1P2.x * innerWidth)\n                        .attr(\"y2\", margin1P2.y * innerHeight);\n                    \n                    svg.append(\"line\")\n                        .attr(\"class\", \"margin\")\n                        .attr(\"x1\", margin2P1.x * innerWidth)\n                        .attr(\"y1\", margin2P1.y * innerHeight)\n                        .attr(\"x2\", margin2P2.x * innerWidth)\n                        .attr(\"y2\", margin2P2.y * innerHeight);\n                    \n                } else if (svm.kernel === 'rbf') {\n                    // For RBF kernel, create contour of the decision boundary\n                    const gridSize = 10;\n                    const gridData = [];\n                    \n                    for (let x = 0; x <= innerWidth; x += gridSize) {\n                        for (let y = 0; y <= innerHeight; y += gridSize) {\n                            gridData.push({x, y, val: svm.predict(x, y)});\n                        }\n                    }\n                    \n                    // Draw contours\n                    const contourGenerator = d3.contourDensity()\n                        .x(d => d.x)\n                        .y(d => d.y)\n                        .weight(d => d.val)\n                        .size([innerWidth, innerHeight])\n                        .bandwidth(20)\n                        .thresholds([0]);\n                    \n                    svg.append(\"path\")\n                        .attr(\"class\", \"decision-boundary\")\n                        .attr(\"d\", contourGenerator(gridData));\n                }\n                \n                // Highlight support vectors (for visualization, we'll use points closest to margin)\n                if (trainingData.length > 2) {\n                    trainingData.forEach((d, i) => {\n                        const dist = Math.abs(\n                            svm.weights[0] * d.x + \n                            svm.weights[1] * d.y + \n                            svm.bias);\n                        \n                        if (dist < svm.margin) {\n                            svg.append(\"circle\")\n                                .attr(\"class\", \"point support-vector\")\n                                .attr(\"cx\", d.x * innerWidth)\n                                .attr(\"cy\", d.y * innerHeight)\n                                .attr(\"r\", 8)\n                                .attr(\"fill\", d.label > 0 ? colors[0] : colors[1])\n                                .attr(\"stroke\", \"black\");\n                        }\n                    });\n                }\n            }\n        }\n    </script>\n</body>\n</html>"
  },
