ent = `ways(${k}) = ${val}`;\n      await sleep(delay);\n      return val;\n    }\n\n    // LCS (bottom-up table visualization)\n    async function runLCS(s1, s2, opts){\n      const delay = opts.delay || 120;\n      visualArea.innerHTML='';\n      updateStatus('Running LCS DP');\n      const m = s1.length, n = s2.length;\n      if (m > 30 || n > 30) {\n        if(!confirm('Large strings may produce large tables. Continue?')) return;\n      }\n\n      const table = document.createElement('table'); table.className='dp-table';\n      const thead = document.createElement('thead'); const tbody = document.createElement('tbody');\n      table.appendChild(thead); table.appendChild(tbody);\n      // header row with characters of s2 plus an initial blank\n      const headerRow = document.createElement('tr');\n      headerRow.appendChild(document.createElement('th')); // top-left blank\n      for (let j=0;j<n;j++){\n        const th = document.createElement('th'); th.textContent = s2[j]; headerRow.appendChild(th);\n      }\n      thead.appendChild(headerRow);\n\n      // create table body with m+1 rows (initial row for empty prefix)\n      const dp = Array.from({length: m+1}, ()=> new Array(n+1).fill(0));\n      // initialize first row\n      const firstRow = document.createElement('tr');\n      const th0 = document.createElement('th'); th0.textContent = ' '; firstRow.appendChild(th0);\n      for(let j=0;j<=n;j++){\n        const td = document.createElement('td'); td.textContent = dp[0][j];\n        if (j===0) td.className='cell-current';\n        firstRow.appendChild(td);\n      }\n      tbody.appendChild(firstRow);\n\n      for (let i=1;i<=m;i++){\n        const row = document.createElement('tr');\n        const th = document.createElement('th'); th.textContent = s1[i-1]; row.appendChild(th);\n        for (let j=0;j<=n;j++){\n          const td = document.createElement('td'); td.textContent = dp[i][j];\n          row.appendChild(td);\n        }\n        tbody.appendChild(ro