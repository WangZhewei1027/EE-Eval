    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Stack (LIFO) — Interactive Demo</title>\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --accent:#60a5fa;\n      --muted:#94a3b8;\n      --glass: rgba(255,255,255,0.03);\n      --green:#10b981;\n      --red:#ef4444;\n      --item-bg: linear-gradient(180deg,#0f1724,#08101a);\n    }\n    html,body{height:100%;}\n    body{\n      margin:0;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      background: linear-gradient(180deg,var(--bg), #031020 80%);\n      color:#e6eef8;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      padding:28px;\n    }\n    .app{\n      width:980px;\n      max-width:100%;\n      display:grid;\n      grid-template-columns: 360px 1fr;\n      gap:20px;\n      align-items:start;\n    }\n    .card{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow: 0 6px 30px rgba(2,6,23,0.6);\n      border-radius:12px;\n      padding:18px;\n      backdrop-filter: blur(6px);\n    }\n    .left .title{\n      display:flex;\n      align-items:center;\n      gap:10px;\n      margin-bottom:10px;\n    }\n    h1{font-size:18px;margin:0;}\n    p.lead{color:var(--muted);font-size:13px;margin:6px 0 14px;}\n    .controls {\n      display:flex;\n      gap:8px;\n      margin-bottom:12px;\n      flex-wrap:wrap;\n    }\n    input[type=\"text\"]{\n      flex:1;\n      min-width:120px;\n      padding:8px 10px;\n      border-radius:8px;\n      border:1px solid rgba(255,255,255,0.04);\n      background:transparent;\n      color:inherit;\n      outline:none;\n    }\n    button{\n      background:linear-gradient(180deg,var(--accent), #3b82f6);\n      color:#021024;\n      border:none;\n      padding:8px 12px;\n      border-radius:8px;\n      cursor:pointer;\n      font-weight:600;\n      box-shadow: 0 6px 18px rgba(59,130,246,0.14);\n    }\n    button.secondary{\n      background:transparent;\n      color:var(--muted);\n      border:1px solid rgba(255,255,255,0.03);\n      box-shadow:none;\n    }\n    .small{\n      padding:6px 8px;\n      font-size:13px;\n    }\n    .stack-visual {\n      display:flex;\n      flex-direction:column;\n      align-items:center;\n      gap:12px;\n      margin-top:6px;\n    }\n    .stack-canvas{\n      width:280px;\n      height:420px;\n      background:var(--glass);\n      border-radius:10px;\n      border:1px solid rgba(255,255,255,0.02);\n      padding:14px;\n      box-sizing:border-box;\n      display:flex;\n      flex-direction:column;\n      align-items:stretch;\n      justify-content:flex-start;\n      position:relative;\n      overflow:hidden;\n    }\n    .stack-container{\n      display:flex;\n      flex-direction:column;\n      gap:10px;\n      align-items:center;\n      padding-top:6px;\n      transition:all .25s ease;\n      width:100%;\n    }\n    .stack-item{\n      width:88%;\n      height:44px;\n      border-radius:8px;\n      background:var(--item-bg);\n      border:1px solid rgba(255,255,255,0.03);\n      display:flex;\n      align-items:center;\n      justify-content:center;\n      color:var(--accent);\n      font-weight:700;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.45);\n      transform-origin:center;\n      opacity:1;\n      transform:translateY(0) scale(1);\n      transition:transform .28s cubic-bezier(.2,.9,.3,1), opacity .18s ease;\n      position:relative;\n    }\n    .stack-item.top::after{\n      content:\"TOP\";\n      position:absolute;\n      right:8px;\n      top:6px;\n      font-size:11px;\n      color:var(--muted);\n      font-weight:600;\n    }\n    .stack-item.push{\n      transform:translateY(-20px) scale(.95);\n      opacity:0;\n    }\n    .stack-item.pop{\n      transform:translateY(-18px) scale(.9) rotate(-6deg);\n      opacity:0;\n    }\n    .info-row{\n      display:flex;\n      gap:8px;\n      margin-top:10px;\n      flex-wrap:wrap;\n    }\n    .pill{\n      background:rgba(255,255,255,0.02);\n      padding:6px 10px;\n      border-radius:999px;\n      font-size:13px;\n      color:var(--muted);\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .log{\n      height:220px;\n      overflow:auto;\n      margin-top:12px;\n      border-radius:8px;\n      padding:8px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border:1px solid rgba(255,255,255,0.02);\n      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace;\n      font-size:13px;\n      color:var(--muted);\n    }\n    .log .msg{\n      padding:8px;\n      border-radius:6px;\n      margin-bottom:6px;\n      background:transparent;\n      border:1px dashed rgba(255,255,255,0.01);\n    }\n    .right .header{\n      display:flex;\n      align-items:center;\n      justify-content:space-between;\n      gap:12px;\n    }\n    .right .explain{\n      margin-top:6px;\n      color:var(--muted);\n      font-size:13px;\n      line-height:1.35;\n    }\n    pre.code{\n      margin:12px 0 0;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      padding:12px;\n      border-radius:8px;\n      overflow:auto;\n      color:#cbd5e1;\n      font-size:13px;\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .array-view{\n      margin-top:12px;\n      display:flex;\n      gap:8px;\n      flex-wrap:wrap;\n    }\n    .array-item{\n      background:rgba(255,255,255,0.02);\n      border:1px solid rgba(255,255,255,0.03);\n      padding:8px 10px;\n      border-radius:6px;\n      color:var(--muted);\n      font-weight:600;\n    }\n    .badge {\n      padding:6px 8px;\n      border-radius:8px;\n      background:rgba(255,255,255,0.02);\n      color:var(--muted);\n      font-weight:600;\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .small-muted{font-size:12px;color:var(--muted);}\n    .status {\n      display:inline-flex;\n      gap:8px;\n      align-items:center;\n    }\n    .notice {\n      padding:8px;\n      border-radius:8px;\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n      border:1px solid rgba(255,255,255,0.03);\n      color:var(--muted);\n      margin-top:10px;\n      font-size:13px;\n    }\n    footer{margin-top:12px;color:var(--muted);font-size:12px;}\n    @media (max-width:880px){\n      .app{grid-template-columns:1fr; width:100%;}\n      .stack-canvas{height:320px;}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"app\" role=\"application\" aria-label=\"Stack interactive demo\">\n    <div class=\"card left\" aria-hidden=\"false\">\n      <div class=\"title\">\n        <h1>Stack (LIFO) — Interactive</h1>\n      </div>\n      <p class=\"lead\">A stack is a Last-In-First-Out data structure. Use the controls to push &amp; pop values and watch the visual stack change.</p>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <input id=\"valueInput\" type=\"text\" placeholder=\"Value to push (string or number)\" aria-label=\"Value to push\" />\n        <button id=\"pushBtn\" class=\"small\" title=\"Push value\">Push</button>\n        <button id=\"popBtn\" class=\"small secondary\" title=\"Pop top\">Pop</button>\n        <button id=\"peekBtn\" class=\"small secondary\" title=\"Peek top\">Peek</button>\n        <button id=\"clearBtn\" class=\"small secondary\" title=\"Clear stack\">Clear</button>\n      </div>\n\n      <div class=\"stack-visual\" aria-hidden=\"false\">\n        <div class=\"stack-canvas\" role=\"region\" aria-label=\"Stack visualization\">\n          <div id=\"stackContainer\" class=\"stack-container\" aria-live=\"polite\"></div>\n        </div>\n\n        <div class=\"info-row\">\n          <div class=\"pill\">Size: <span id=\"size\" style=\"margin-left:6px;font-weight:800;color:var(--accent)\">0</span></div>\n          <div class=\"pill\">Top: <span id=\"topValue\" style=\"margin-left:6px;font-weight:800;color:var(--accent)\">—</span></div>\n          <div class=\"pill\">Empty: <span id=\"isEmpty\" style=\"margin-left:6px;font-weight:800;color:var(--accent)\">true</span></div>\n        </div>\n\n        <div class=\"notice\" id=\"notice\" aria-live=\"polite\">Try pushing values. The most recently pushed item is at the top and will be removed first.</div>\n\n        <div class=\"log\" id=\"log\" aria-live=\"polite\"></div>\n      </div>\n    </div>\n\n    <div class=\"card right\" aria-hidden=\"false\">\n      <div class=\"header\">\n        <div>\n          <h2 style=\"margin:0;font-size:15px\">Stack API (JavaScript)</h2>\n          <div class=\"small-muted\" style=\"margin-top:6px\">Implementation built into this demo. See the code and the array view below.</div>\n        </div>\n        <div class=\"status\">\n          <div class=\"badge\" id=\"capacityBadge\">Capacity: ∞</div>\n        </div>\n      </div>\n\n      <div class=\"explain\">\n        <p style=\"margin-top:8px;margin-bottom:6px\">Operations:</p>\n        <ul style=\"margin-top:0;color:var(--muted);line-height:1.5\">\n          <li><strong>push(item)</strong> — add item to the top</li>\n          <li><strong>pop()</strong> — remove and return the top item</li>\n          <li><strong>peek()</strong> — view the top item without removing</li>\n          <li><strong>isEmpty()</strong> / <strong>size()</strong> — check stack state</li>\n          <li><strong>clear()</strong> — empty the stack</li>\n        </ul>\n      </div>\n\n      <pre class=\"code\" id=\"codeBlock\" aria-hidden=\"false\"><code>// Simple Stack class used in this demo\nclass Stack {\n  constructor(max = Infinity){\n    this._items = [];\n    this.max = max;\n  }\n  push(item){\n    if(this._items.length >= this.max) throw new Error(\"Stack overflow\");\n    this._items.push(item);\n  }\n  pop(){\n    return this._items.pop();\n  }\n  peek(){\n    return this._items.length === 0 ? undefined : this._items[this._items.length-1];\n  }\n  size(){ return this._items.length; }\n  isEmpty(){ return this._items.length === 0; }\n  clear(){ this._items.length = 0; }\n}</code></pre>\n\n      <div style=\"margin-top:12px;\">\n        <strong style=\"font-size:13px\">Array view (bottom → top)</strong>\n        <div class=\"array-view\" id=\"arrayView\" aria-live=\"polite\" style=\"margin-top:8px;\"></div>\n      </div>\n\n      <footer>\n        Tip: Stacks are used for undo systems, parsing, call stacks, and depth-first search.\n      </footer>\n    </div>\n  </div>\n\n  <script>\n    // Stack implementation used for the demo\n    class Stack {\n      constructor(max = Infinity){\n        this._items = [];\n        this.max = max;\n      }\n      push(item){\n        if(this._items.length >= this.max) throw new Error(\"Stack overflow\");\n        this._items.push(item);\n      }\n      pop(){\n        return this._items.pop();\n      }\n      peek(){\n        return this._items.length === 0 ? undefined : this._items[this._items.length - 1];\n      }\n      size(){ return this._items.length; }\n      isEmpty(){ return this._items.length === 0; }\n      clear(){ this._items.length = 0; }\n      toArray(){ return this._items.slice(); }\n    }\n\n    // UI wiring\n    const stack = new Stack(); // no capacity by default\n    const stackContainer = document.getElementById('stackContainer');\n    const sizeEl = document.getElementById('size');\n    const isEmptyEl = document.getElementById('isEmpty');\n    const topEl = document.getElementById('topValue');\n    const logEl = document.getElementById('log');\n    const arrayView = document.getElementById('arrayView');\n    const notice = document.getElementById('notice');\n    const capacityBadge = document.getElementById('capacityBadge');\n\n    const valueInput = document.getElementById('valueInput');\n    const pushBtn = document.getElementById('pushBtn');\n    const popBtn = document.getElementById('popBtn');\n    const peekBtn = document.getElementById('peekBtn');\n    const clearBtn = document.getElementById('clearBtn');\n\n    // Helpers for logging & UI\n    function log(message, type = 'info'){\n      const el = document.createElement('div');\n      el.className = 'msg';\n      el.textContent = message;\n      if(type === 'error') el.style.borderColor = 'rgba(239,68,68,0.12)';\n      logEl.prepend(el);\n    }\n\n    function updateStats(){\n      const s = stack.size();\n      sizeEl.textContent = s;\n      isEmptyEl.textContent = String(stack.isEmpty());\n      const top = stack.peek();\n      topEl.textContent = top === undefined ? '—' : String(top);\n      // array view shows bottom → top (left → right)\n      arrayView.innerHTML = '';\n      const arr = stack.toArray();\n      if(arr.length === 0){\n        const empty = document.createElement('div');\n        empty.className = 'array-item';\n        empty.textContent = 'empty';\n        arrayView.appendChild(empty);\n      } else {\n        arr.forEach((v, idx) => {\n          const it = document.createElement('div');\n          it.className = 'array-item';\n          it.textContent = String(v);\n          if(idx === arr.length - 1){\n            it.style.border = '1px solid rgba(96,165,250,0.14)';\n            it.style.color = 'var(--accent)';\n          }\n          arrayView.appendChild(it);\n        });\n      }\n    }\n\n    // Visual push: create element, insert at top, animate in\n    function visualPush(value){\n      const el = document.createElement('div');\n      el.className = 'stack-item push';\n      el.textContent = String(value);\n      // Always mark top class for the first item\n      // Insert at top (index 0 represents top)\n      if(stackContainer.children.length > 0){\n        // remove previous \"top\" label\n        stackContainer.children[0].classList.remove('top');\n      }\n      stackContainer.insertBefore(el, stackContainer.firstChild);\n      // Force a layout so the transition is applied\n      requestAnimationFrame(() => {\n        el.classList.remove('push');\n        el.classList.add('top');\n      });\n    }\n\n    // Visual pop: animate the top item out then remove\n    function visualPop(){\n      const topElItem = stackContainer.firstChild;\n      if(!topElItem) return null;\n      topElItem.classList.add('pop');\n      // After animation, remove element and re-mark new top\n      topElItem.addEventListener('transitionend', function rm(e){\n        if(e.propertyName !== 'transform') return;\n        topElItem.removeEventListener('transitionend', rm);\n        if(topElItem.parentNode) topElItem.parentNode.removeChild(topElItem);\n        if(stackContainer.firstChild) stackContainer.firstChild.classList.add('top');\n      });\n    }\n\n    // Hook up buttons\n    pushBtn.addEventListener('click', () => {\n      const raw = valueInput.value.trim();\n      if(raw === ''){\n        notice.textContent = 'Enter a value to push (non-empty).';\n        return;\n      }\n      try {\n        // Try to coerce numbers, but keep as string if not a pure number\n        const num = Number(raw);\n        const value = (raw !== '' && !Number.isNaN(num) && raw.match(/^[-]?\\d+(\\.\\d+)?$/)) ? num : raw;\n        stack.push(value);\n        visualPush(value);\n        updateStats();\n        log(`push(${JSON.stringify(value)}) — size now ${stack.size()}`);\n        notice.textContent = `Pushed ${JSON.stringify(value)}. Top updated.`;\n        valueInput.value = '';\n        valueInput.focus();\n      } catch (err){\n        notice.textContent = err.message || 'Error pushing value';\n        log('Error: ' + (err.message || err), 'error');\n      }\n    });\n\n    popBtn.addEventListener('click', () => {\n      if(stack.isEmpty()){\n        notice.textContent = 'Stack is empty — nothing to pop.';\n        log('pop() called on empty stack', 'error');\n        return;\n      }\n      const val = stack.pop();\n      visualPop();\n      updateStats();\n      log(`pop() => ${JSON.stringify(val)} — size now ${stack.size()}`);\n      notice.textContent = `Popped ${JSON.stringify(val)}.`;\n    });\n\n    peekBtn.addEventListener('click', () => {\n      const val = stack.peek();\n      if(val === undefined){\n        notice.textContent = 'Stack is empty.';\n        log('peek() => undefined', 'info');\n      } else {\n        notice.textContent = `Top is ${JSON.stringify(val)} (not removed).`;\n        log(`peek() => ${JSON.stringify(val)}`, 'info');\n      }\n    });\n\n    clearBtn.addEventListener('click', () => {\n      if(stack.isEmpty()){\n        notice.textContent = 'Stack already empty.';\n        log('clear() — already empty');\n        return;\n      }\n      stack.clear();\n      // Remove all DOM children\n      Array.from(stackContainer.children).forEach(n => n.remove());\n      updateStats();\n      log('clear() — stack emptied');\n      notice.textContent = 'Stack cleared.';\n    });\n\n    // Allow Enter key to push\n    valueInput.addEventListener('keydown', (e) => {\n      if(e.key === 'Enter'){\n        e.preventDefault();\n        pushBtn.click();\n      }\n    });\n\n    // Seed with example values to demonstrate\n    (function seedDemo(){\n      const sample = ['A', 'B', 'C'];\n      sample.forEach((v, i) => {\n        // small delay to show animation in sequence\n        setTimeout(() => {\n          stack.push(v);\n          visualPush(v);\n          updateStats();\n          log(`push(${JSON.stringify(v)})`);\n        }, 220 * (i+1));\n      });\n    })();\n\n    // Keep focus on input for quick interactions\n    valueInput.focus();\n\n    // Expose for debugging (optional)\n    window._stackDemo = {\n      stack, updateStats, visualPush, visualPop, log\n    };\n\n    // Initial UI update\n    updateStats();\n  </script>\n</body>\n</html>"
  },
