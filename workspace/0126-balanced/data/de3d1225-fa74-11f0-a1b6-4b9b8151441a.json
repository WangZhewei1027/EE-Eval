    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>TCP/IP Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n            line-height: 1.6;\n        }\n        .container {\n            max-width: 800px;\n            margin: 0 auto;\n        }\n        .packet {\n            border: 1px solid #ccc;\n            padding: 10px;\n            margin: 10px 0;\n            background-color: #f9f9f9;\n        }\n        .sender {\n            color: #2e7d32;\n        }\n        .receiver {\n            color: #c62828;\n        }\n        button {\n            padding: 8px 16px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            cursor: pointer;\n            margin: 5px;\n        }\n        button:hover {\n            background-color: #45a049;\n        }\n        .log {\n            height: 200px;\n            overflow-y: auto;\n            border: 1px solid #ddd;\n            padding: 10px;\n            margin-top: 20px;\n            background-color: #f5f5f5;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>TCP/IP Protocol Demonstration</h1>\n        <p>This simulation shows the basic concepts of TCP/IP communication between a client and server.</p>\n        \n        <div>\n            <h2>TCP Three-Way Handshake</h2>\n            <p>The foundation of TCP communication is the three-way handshake:</p>\n            <ol>\n                <li>SYN: Client sends a synchronization packet to the server</li>\n                <li>SYN-ACK: Server acknowledges and synchronizes with the client</li>\n                <li>ACK: Client acknowledges the server's synchronization</li>\n            </ol>\n            <button onclick=\"startHandshake()\">Start Handshake</button>\n        </div>\n\n        <div>\n            <h2>Data Transmission</h2>\n            <p>After establishing a connection, data can be sent reliably between devices.</p>\n            <input type=\"text\" id=\"messageInput\" placeholder=\"Enter message to send\">\n            <button onclick=\"sendMessage()\">Send Message</button>\n        </div>\n\n        <div>\n            <h2>Connection Termination</h2>\n            <p>TCP uses a four-way handshake to gracefully close connections.</p>\n            <button onclick=\"closeConnection()\">Close Connection</button>\n        </div>\n\n        <h3>Communication Log:</h3>\n        <div id=\"log\" class=\"log\"></div>\n    </div>\n\n    <script>\n        const logElement = document.getElementById('log');\n        let connectionEstablished = false;\n        let sequenceNumber = 1000;\n        let ackNumber = 5000;\n\n        function logMessage(message, sender) {\n            const prefix = sender === 'client' ? '<span class=\"sender\">[Client]</span>' : '<span class=\"receiver\">[Server]</span>';\n            logElement.innerHTML += `${prefix} ${message}<br>`;\n            logElement.scrollTop = logElement.scrollHeight;\n        }\n\n        function generatePacket(type, payload = '') {\n            return {\n                type,\n                seq: sequenceNumber,\n                ack: ackNumber,\n                payload,\n                timestamp: new Date().toISOString()\n            };\n        }\n\n        function startHandshake() {\n            if (connectionEstablished) {\n                logMessage('Connection already established!', 'client');\n                return;\n            }\n\n            // Step 1: Client sends SYN\n            const synPacket = generatePacket('SYN');\n            logMessage(`Sending SYN packet (seq=${synPacket.seq})`, 'client');\n            sequenceNumber += 1;\n\n            // Simulate network delay\n            setTimeout(() => {\n                logMessage(`Received SYN packet (seq=${synPacket.seq})`, 'server');\n                \n                // Step 2: Server responds with SYN-ACK\n                const synAckPacket = generatePacket('SYN-ACK');\n                synAckPacket.ack = synPacket.seq + 1;\n                logMessage(`Sending SYN-ACK packet (seq=${synAckPacket.seq}, ack=${synAckPacket.ack})`, 'server');\n                ackNumber = synAckPacket.seq + 1;\n\n                setTimeout(() => {\n                    logMessage(`Received SYN-ACK packet (seq=${synAckPacket.seq}, ack=${synAckPacket.ack})`, 'client');\n                    \n                    // Step 3: Client sends ACK\n                    const ackPacket = generatePacket('ACK');\n                    ackPacket.ack = synAckPacket.seq + 1;\n                    logMessage(`Sending ACK packet (ack=${ackPacket.ack})`, 'client');\n                    \n                    setTimeout(() => {\n                        logMessage(`Received ACK packet (ack=${ackPacket.ack})`, 'server');\n                        logMessage('TCP connection established!', 'server');\n                        connectionEstablished = true;\n                    }, 500);\n                }, 500);\n            }, 500);\n        }\n\n        function sendMessage() {\n            if (!connectionEstablished) {\n                logMessage('Cannot send data - no connection established!', 'client');\n                return;\n            }\n\n            const message = document.getElementById('messageInput').value;\n            if (!message) return;\n\n            // Client sends data\n            const dataPacket = generatePacket('DATA', message);\n            logMessage(`Sending data: \"${message}\" (seq=${dataPacket.seq})`, 'client');\n            sequenceNumber += message.length;\n\n            // Simulate network delay\n            setTimeout(() => {\n                logMessage(`Received data: \"${message}\" (seq=${dataPacket.seq})`, 'server');\n                \n                // Server acknowledges\n                const ackPacket = generatePacket('ACK');\n                ackPacket.ack = dataPacket.seq + message.length;\n                logMessage(`Sending ACK for data (ack=${ackPacket.ack})`, 'server');\n                \n                setTimeout(() => {\n                    logMessage(`Received ACK for data (ack=${ackPacket.ack})`, 'client');\n                }, 300);\n            }, 500);\n\n            document.getElementById('messageInput').value = '';\n        }\n\n        function closeConnection() {\n            if (!connectionEstablished) {\n                logMessage('No active connection to close!', 'client');\n                return;\n            }\n\n            // Step 1: Client sends FIN\n            const finPacket = generatePacket('FIN');\n            logMessage(`Sending FIN packet (seq=${finPacket.seq})`, 'client');\n            \n            setTimeout(() => {\n                logMessage(`Received FIN packet (seq=${finPacket.seq})`, 'server');\n                \n                // Step 2: Server responds with ACK\n                const ackPacket = generatePacket('ACK');\n                ackPacket.ack = finPacket.seq + 1;\n                logMessage(`Sending ACK for FIN (ack=${ackPacket.ack})`, 'server');\n                \n                // Step 3: Server sends its own FIN\n                setTimeout(() => {\n                    const serverFinPacket = generatePacket('FIN');\n                    logMessage(`Sending FIN packet (seq=${serverFinPacket.seq})`, 'server');\n                    \n                    setTimeout(() => {\n                        logMessage(`Received FIN packet (seq=${serverFinPacket.seq})`, 'client');\n                        \n                        // Step 4: Client responds with ACK\n                        const finalAckPacket = generatePacket('ACK');\n                        finalAckPacket.ack = serverFinPacket.seq + 1;\n                        logMessage(`Sending final ACK (ack=${finalAckPacket.ack})`, 'client');\n                        \n                        setTimeout(() => {\n                            logMessage(`Received final ACK (ack=${finalAckPacket.ack})`, 'server');\n                            logMessage('TCP connection closed gracefully', 'server');\n                            connectionEstablished = false;\n                        }, 300);\n                    }, 300);\n                }, 300);\n            }, 500);\n        }\n    </script>\n</body>\n</html>"
