  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Priority Queue (Binary Heap) Demonstration</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n  body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 18px; color:#222; }\n  h1 { margin: 0 0 8px 0; font-size: 22px; }\n  p.lead { margin: 6px 0 18px 0; color:#444; max-width: 860px; }\n  .layout { display: grid; grid-template-columns: 360px 1fr; gap: 18px; align-items:start; }\n  .panel { background: #fff; border: 1px solid #e1e1e1; padding: 12px; border-radius: 8px; box-shadow: 0 1px 2px rgba(0,0,0,0.03); }\n  label { display:block; margin-top:8px; font-size:13px; color:#444; }\n  input[type=\"text\"], input[type=\"number\"], select { width: 100%; padding:8px 10px; margin-top:6px; border-radius:6px; border:1px solid #ccc; box-sizing:border-box; font-size:14px; }\n  .row { display:flex; gap:8px; margin-top:10px; }\n  button { padding:8px 10px; border-radius:6px; border:1px solid #bbb; background: #f6f6f6; cursor:pointer; font-size:14px; }\n  button.primary { background:#0366d6; color:white; border-color: #0366d6; }\n  button.warn { background:#ffb86b; border-color:#e6952f; color:#2b1500; }\n  button.danger { background:#ff6b6b; border-color:#d64545; color:white; }\n  .controls small { color:#666; display:block; margin-top:6px; }\n  .vis { min-height: 360px; display:flex; flex-direction:column; gap:12px; }\n  .arrayView { display:flex; flex-wrap:wrap; gap:8px; padding:8px; border-radius:8px; background:#fafafa; border:1px dashed #eee; }\n  .node { padding:8px 10px; border-radius:8px; background:white; border:1px solid #ddd; display:inline-flex; gap:8px; align-items:center; min-width:72px; justify-content:center; box-shadow:0 1px 0 rgba(0,0,0,0.02); font-weight:600; }\n  .node small { display:block; font-weight:400; font-size:12px; color:#444; }\n  .index { font-size:11px; color:#888; margin-left:6px; font-weight:500; }\n  .highlight-insert { background: #fff7cc; border-color:#ffd24d; }\n  .highlight-swap { background:#ffe6e6; border-color:#ff9b9b; }\n  .highlight-final { background:#dff7e3; border-color:#7bd08f; }\n  .treeView { min-height:220px; border-radius:8px; background:#fff; border:1px dashed #eee; padding:12px; position:relative; }\n  .treeRow { display:flex; justify-content:center; gap:12px; margin-top:12px; }\n  .logArea { height:130px; overflow:auto; background:#0b0f13; color:#cce7ff; padding:8px; border-radius:6px; font-family: monospace; font-size:13px; }\n  .meta { font-size:13px; color:#555; margin-top:8px; }\n  .small { font-size:12px; color:#666; }\n  .legend { display:flex; gap:8px; margin-top:8px; align-items:center; }\n  .legend div { display:flex; gap:6px; align-items:center; }\n  .badge { width:16px; height:12px; border-radius:3px; border:1px solid #aaa; }\n  footer { margin-top:16px; font-size:13px; color:#555; }\n  @media (max-width:900px) { .layout { grid-template-columns: 1fr; } }\n</style>\n</head>\n<body>\n  <h1>Priority Queue (Binary Heap) Interactive Demonstration</h1>\n  <p class=\"lead\">This page demonstrates a Priority Queue implemented with a binary heap. You can add items with a priority, remove the top item, change priorities, and watch how the heap restructures itself. Choose Min-heap (lowest priority = highest importance) or Max-heap.</p>\n\n  <div class=\"layout\">\n    <div class=\"panel\">\n      <strong>Controls</strong>\n      <div class=\"controls\">\n        <label>Heap type\n          <select id=\"heapType\">\n            <option value=\"min\">Min-Heap (smallest priority first)</option>\n            <option value=\"max\">Max-Heap (largest priority first)</option>\n          </select>\n        </label>\n\n        <label>Value (string)\n          <input id=\"valueInput\" type=\"text\" placeholder=\"e.g. TaskA\">\n        </label>\n\n        <label>Priority (number)\n          <input id=\"priorityInput\" type=\"number\" value=\"10\">\n        </label>\n\n        <div class=\"row\">\n          <button id=\"enqueueBtn\" class=\"primary\">Enqueue</button>\n          <button id=\"dequeueBtn\" class=\"warn\">Dequeue (pop top)</button>\n          <button id=\"peekBtn\">Peek</button>\n        </div>\n\n        <div class=\"row\" style=\"margin-top:10px;\">\n          <button id=\"randomBtn\">Insert random 6</button>\n          <button id=\"clearBtn\" class=\"danger\">Clear</button>\n        </div>\n\n        <label style=\"margin-top:12px;\">Change priority of a value\n          <input id=\"changeValue\" type=\"text\" placeholder=\"value to change (first match)\">\n          <input id=\"changePriority\" type=\"number\" placeholder=\"new priority\" style=\"margin-top:6px;\">\n        </label>\n        <div class=\"row\">\n          <button id=\"changeBtn\">Change Priority</button>\n          <button id=\"removeBtn\" class=\"\">Remove first match</button>\n        </div>\n\n        <small>Notes: duplicate values allowed; priority is a number. Animation is performed for swap operations so you can follow the reordering.</small>\n\n        <div class=\"meta\">\n          <div>Size: <span id=\"size\">0</span> &nbsp; • &nbsp; Top: <span id=\"topVal\">—</span></div>\n        </div>\n\n        <div class=\"legend\">\n          <div><div class=\"badge\" style=\"background:#fff7cc;border-color:#ffd24d\"></div><span class=\"small\">Inserted</span></div>\n          <div><div class=\"badge\" style=\"background:#ffe6e6;border-color:#ff9b9b\"></div><span class=\"small\">Swapping</span></div>\n          <div><div class=\"badge\" style=\"background:#dff7e3;border-color:#7bd08f\"></div><span class=\"small\">Settled</span></div>\n        </div>\n\n        <div style=\"margin-top:12px;\">\n          <small>Time complexities (binary heap): enqueue O(log n), dequeue O(log n), peek O(1), change priority O(n) if you search by value (or O(log n) if you have an index map).</small>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"panel vis\">\n      <strong>Heap visualization</strong>\n      <div class=\"section\">\n        <div style=\"margin-top:8px;\" class=\"small\">Array representation (level order):</div>\n        <div id=\"arrayView\" class=\"arrayView\" aria-live=\"polite\"></div>\n      </div>\n\n      <div style=\"margin-top:12px;\" class=\"small\">Tree (levels):</div>\n      <div id=\"treeView\" class=\"treeView\" aria-hidden=\"false\"></div>\n\n      <div style=\"margin-top:8px;\" class=\"small\">Event log:</div>\n      <div id=\"log\" class=\"logArea\" aria-live=\"polite\"></div>\n    </div>\n  </div>\n\n<script>\n/*\n  Priority Queue (binary heap) visualization code.\n  Features:\n  - Min-heap / Max-heap mode\n  - enqueue(value, priority)\n  - dequeue()\n  - peek()\n  - changePriority(value, newPriority) -> adjusts by bubbling up/down\n  - remove(value) -> removes first matching value\n  - animated swaps (async)\n  - visual array and simple tree layout\n*/\n\n(function(){\n  // Utilities\n  const $ = id => document.getElementById(id);\n  function sleep(ms){ return new Promise(r => setTimeout(r, ms)); }\n  function log(msg){ const el = $('log'); el.textContent = `${new Date().toLocaleTimeString()}  —  ${msg}\\n` + el.textContent; }\n\n  // PriorityQueue implemented as binary heap array\n  class PriorityQueue {\n    constructor(type = 'min', visualOptions = {}) {\n      this.type = type; // 'min' or 'max'\n      this.data = []; // elements: { value, priority }\n      this.animDelay = visualOptions.animDelay ?? 360; // ms per swap\n    }\n\n    comparator(a, b){\n      // returns true if a should be higher priority than b (i.e., a is above b in heap)\n      if(this.type === 'min') return a.priority < b.priority;\n      return a.priority > b.priority;\n    }\n\n    size(){ return this.data.length; }\n    isEmpty(){ return this.data.length === 0; }\n\n    async enqueue(value, priority, onStep){\n      const node = { value: String(value), priority: Number(priority) };\n      this.data.push(node);\n      let i = this.data.length - 1;\n      if(onStep) await onStep('insert', i, i); // highlight insertion\n\n      // bubble up with animation\n      while(i > 0){\n        const parent = Math.floor((i - 1) / 2);\n        if(this.comparator(this.data[i], this.data[parent])){\n          // swap and animate\n          [this.data[i], this.data[parent]] = [this.data[parent], this.data[i]];\n          if(onStep) {\n            await onStep('swap', i, parent);\n            await sleep(this.animDelay);\n          }\n          i = parent;\n        } else break;\n      }\n      if(onStep) await onStep('settle', i, i);\n      return node;\n    }\n\n    peek(){ return this.data[0] ?? null; }\n\n    async dequeue(onStep){\n      if(this.data.length === 0) return null;\n      if(onStep) await onStep('removeTop', 0, 0);\n      const top = this.data[0];\n      const last = this.data.pop();\n      if(this.data.length === 0){\n        if(onStep) await onStep('cleared', 0, 0);\n        return top;\n      }\n      this.data[0] = last;\n      // bubble down (heapify)\n      let i = 0;\n      while(true){\n        const left = 2 * i + 1;\n        const right = left + 1;\n        let candidate = i;\n        if(left < this.data.length && this.comparator(this.data[left], this.data[candidate])) candidate = left;\n        if(right < this.data.length && this.comparator(this.data[right], this.data[candidate])) candidate = right;\n        if(candidate === i) break;\n        [this.data[i], this.data[candidate]] = [this.data[candidate], this.data[i]];\n        if(onStep){\n          await onStep('swap', i, candidate);\n          await sleep(this.animDelay);\n        }\n        i = candidate;\n      }\n      if(onStep) await onStep('settle', i, i);\n      return top;\n    }\n\n    // find first index with matching value (string match)\n    indexOfValue(value){\n      const s = String(value);\n      for(let i=0;i<this.data.length;i++) if(this.data[i].value === s) return i;\n      return -1;\n    }\n\n    // change priority of first matched value and restore heap condition; returns new index or -1\n    async changePriority(value, newPriority, onStep){\n      const idx = this.indexOfValue(value);\n      if(idx === -1) return -1;\n      const old = this.data[idx].priority;\n      this.data[idx].priority = Number(newPriority);\n      if(onStep) await onStep('change', idx, idx);\n      // Decide direction\n      if(this.type === 'min' ? this.data[idx].priority < old : this.data[idx].priority > old){\n        // bubble up\n        let i = idx;\n        while(i > 0){\n          const parent = Math.floor((i-1)/2);\n          if(this.comparator(this.data[i], this.data[parent])){\n            [this.data[i], this.data[parent]] = [this.data[parent], this.data[i]];\n            if(onStep){ await onStep('swap', i, parent); await sleep(this.animDelay); }\n            i = parent;\n          } else break;\n        }\n        if(onStep) await onStep('settle', i, i);\n        return i;\n      } else {\n        // bubble down\n        let i = idx;\n        while(true){\n          const left = 2*i+1, right = left+1;\n          let candidate = i;\n          if(left < this.data.length && this.comparator(this.data[left], this.data[candidate])) candidate = left;\n          if(right < this.data.length && this.comparator(this.data[right], this.data[candidate])) candidate = right;\n          if(candidate === i) break;\n          [this.data[i], this.data[candidate]] = [this.data[candidate], this.data[i]];\n          if(onStep){ await onStep('swap', i, candidate); await sleep(this.animDelay); }\n          i = candidate;\n        }\n        if(onStep) await onStep('settle', i, i);\n        return i;\n      }\n    }\n\n    // remove first matching value by swapping it with last and heapifying from that index\n    async remove(value, onStep){\n      const idx = this.indexOfValue(value);\n      if(idx === -1) return null;\n      if(onStep) await onStep('removeAt', idx, idx);\n      const last = this.data.pop();\n      const removed = this.data[idx];\n      if(idx === this.data.length) { if(onStep) await onStep('cleared', idx, idx); return removed; }\n      this.data[idx] = last;\n      // Try bubble up then down\n      if(idx > 0 && this.comparator(this.data[idx], this.data[Math.floor((idx-1)/2)])){\n        // bubble up\n        let i = idx;\n        while(i > 0){\n          const parent = Math.floor((i-1)/2);\n          if(this.comparator(this.data[i], this.data[parent])){\n            [this.data[i], this.data[parent]] = [this.data[parent], this.data[i]];\n            if(onStep){ await onStep('swap', i, parent); await sleep(this.animDelay); }\n            i = parent;\n          } else break;\n        }\n        if(onStep) await onStep('settle', i, i);\n      } else {\n        // bubble down\n        let i = idx;\n        while(true){\n          const left = 2*i+1, right = left+1;\n          let candidate = i;\n          if(left < this.data.length && this.comparator(this.data[left], this.data[candidate])) candidate = left;\n          if(right < this.data.length && this.comparator(this.data[right], this.data[candidate])) candidate = right;\n          if(candidate === i) break;\n          [this.data[i], this.data[candidate]] = [this.data[candidate], this.data[i]];\n          if(onStep){ await onStep('swap', i, candidate); await sleep(this.animDelay); }\n          i = candidate;\n        }\n        if(onStep) await onStep('settle', i, i);\n      }\n      return removed;\n    }\n\n    // rebuild heap (useful when switching min<->max). We'll do a simple buildHeap.\n    async rebuild(type, onStep){\n      this.type = type;\n      // Build heap by heapifying down from last parent\n      for(let i = Math.floor(this.data.length/2)-1; i>=0; i--){\n        // bubble down from i\n        let idx = i;\n        while(true){\n          const left = 2*idx + 1;\n          const right = left + 1;\n          let candidate = idx;\n          if(left < this.data.length && this.comparator(this.data[left], this.data[candidate])) candidate = left;\n          if(right < this.data.length && this.comparator(this.data[right], this.data[candidate])) candidate = right;\n          if(candidate === idx) break;\n          [this.data[idx], this.data[candidate]] = [this.data[candidate], this.data[idx]];\n          if(onStep){ await onStep('swap', idx, candidate); await sleep(this.animDelay); }\n          idx = candidate;\n        }\n      }\n      if(onStep) await onStep('rebuild', 0, 0);\n    }\n  }\n\n  // UI wiring and visualization\n  const pq = new PriorityQueue('min', { animDelay: 260 });\n\n  const arrayView = $('arrayView');\n  const treeView = $('treeView');\n  const sizeEl = $('size');\n  const topEl = $('topVal');\n\n  function render(){\n    // render array view\n    arrayView.innerHTML = '';\n    pq.data.forEach((node, i) => {\n      const div = document.createElement('div');\n      div.className = 'node';\n      div.dataset.index = i;\n      div.innerHTML = `<div style=\"text-align:center;\"><div>${escapeHtml(node.value)}</div><small>prio: ${node.priority}</small></div><div class=\"index\">#${i}</div>`;\n      arrayView.appendChild(div);\n    });\n\n    // render tree view by levels\n    treeView.innerHTML = '';\n    if(pq.data.length === 0){\n      treeView.innerHTML = '<div class=\"small\" style=\"padding:8px;color:#666\">Heap is empty</div>';\n    } else {\n      const levels = [];\n      let level = 0, start = 0;\n      while(start < pq.data.length){\n        const count = Math.min(2**level, pq.data.length - start);\n        levels.push(pq.data.slice(start, start + count));\n        start += count; level++;\n      }\n      levels.forEach((lvl, li) => {\n        const row = document.createElement('div');\n        row.className = 'treeRow';\n        lvl.forEach((node, j) => {\n          const index = (2**li - 1) + j;\n          const nd = document.createElement('div');\n          nd.className = 'node';\n          nd.style.minWidth = (120 / (li+1)) + 'px';\n          nd.dataset.index = index;\n          nd.innerHTML = `<div style=\"text-align:center;\"><div>${escapeHtml(node.value)}</div><small>prio: ${node.priority}</small></div><div class=\"index\">#${index}</div>`;\n          row.appendChild(nd);\n        });\n        treeView.appendChild(row);\n      });\n    }\n    sizeEl.textContent = pq.size();\n    topEl.textContent = pq.peek() ? `${pq.peek().value} (prio ${pq.peek().priority})` : '—';\n  }\n\n  // helpers for highlighting and continuous render during animations\n  function highlight(index, klass){\n    const els = Array.from(document.querySelectorAll(`[data-index=\"${index}\"]`));\n    els.forEach(e => { e.classList.add(klass); });\n  }\n  function unhighlightAll(klass){\n    Array.from(document.querySelectorAll(`.${klass}`)).forEach(e => e.classList.remove(klass));\n  }\n\n  // onStep callback used by PQ to animate steps\n  async function onStep(action, i, j){\n    // action can be: 'insert', 'swap', 'settle', 'removeTop', 'cleared', 'change', 'removeAt', 'rebuild'\n    // We'll update render and add highlights\n    render();\n    unhighlightAll('highlight-insert');\n    unhighlightAll('highlight-swap');\n    unhighlightAll('highlight-final');\n\n    if(action === 'insert'){\n      highlight(i, 'highlight-insert');\n      log(`Inserted at index ${i}`);\n    } else if(action === 'swap'){\n      highlight(i, 'highlight-swap');\n      highlight(j, 'highlight-swap');\n      log(`Swap index ${i} ↔ ${j}`);\n    } else if(action === 'settle') {\n      highlight(i, 'highlight-final');\n      log(`Settled at index ${i}`);\n    } else if(action === 'removeTop'){\n      log(`Removing top`);\n    } else if(action === 'cleared'){\n      log(`Heap emptied`);\n    } else if(action === 'change'){\n      highlight(i, 'highlight-insert');\n      log(`Priority changed at index ${i}`);\n    } else if(action === 'removeAt'){\n      highlight(i, 'highlight-insert');\n      log(`Removing at index ${i}`);\n    } else if(action === 'rebuild'){\n      log(`Heap rebuilt with ${pq.type.toUpperCase()}`);\n    }\n    // small delay to make highlight visible before next action (higher-level code may also sleep)\n    await sleep(40);\n    render();\n  }\n\n  // escape for simple safety in display\n  function escapeHtml(s){\n    return String(s).replace(/[&<>\"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[c]));\n  }\n\n  // Wire UI buttons\n  $('enqueueBtn').addEventListener('click', async () => {\n    const v = $('valueInput').value.trim() || `V${Math.floor(Math.random()*1000)}`;\n    const p = Number($('priorityInput').value || 0);\n    $('enqueueBtn').disabled = true;\n    await pq.enqueue(v, p, onStep);\n    $('enqueueBtn').disabled = false;\n    render();\n  });\n\n  $('dequeueBtn').addEventListener('click', async () => {\n    $('dequeueBtn').disabled = true;\n    const removed = await pq.dequeue(onStep);\n    if(removed) log(`Dequeued top: ${removed.value} (prio ${removed.priority})`);\n    else log(`Dequeue called on empty heap`);\n    $('dequeueBtn').disabled = false;\n    render();\n  });\n\n  $('peekBtn').addEventListener('click', () => {\n    const t = pq.peek();\n    if(t) log(`Peek: ${t.value} (prio ${t.priority})`);\n    else log('Peek: heap empty');\n  });\n\n  $('randomBtn').addEventListener('click', async () => {\n    $('randomBtn').disabled = true;\n    // insert 6 random items\n    for(let i=0;i<6;i++){\n      const v = `R${Math.floor(Math.random()*900)+100}`;\n      const p = Math.floor(Math.random()*40);\n      await pq.enqueue(v, p, onStep);\n      await sleep(70);\n    }\n    $('randomBtn').disabled = false;\n    render();\n  });\n\n  $('clearBtn').addEventListener('click', () => {\n    pq.data = [];\n    log('Cleared heap');\n    render();\n  });\n\n  $('changeBtn').addEventListener('click', async () => {\n    const val = $('changeValue').value.trim();\n    const np = $('changePriority').value;\n    if(val === '' || np === ''){ alert('Enter both value and new priority'); return; }\n    $('changeBtn').disabled = true;\n    const idx = await pq.changePriority(val, Number(np), onStep);\n    if(idx === -1) log(`Value \"${val}\" not found`);\n    else log(`Changed priority of \"${val}\", new index ${idx}`);\n    $('changeBtn').disabled = false;\n    render();\n  });\n\n  $('removeBtn').addEventListener('click', async () => {\n    const val = $('changeValue').value.trim();\n    if(val === ''){ alert('Enter value to remove (first match)'); return; }\n    $('removeBtn').disabled = true;\n    const rem = await pq.remove(val, onStep);\n    if(rem) log(`Removed ${rem.value} (prio ${rem.priority})`);\n    else log(`Value \"${val}\" not found`);\n    $('removeBtn').disabled = false;\n    render();\n  });\n\n  $('heapType').addEventListener('change', async () => {\n    const t = $('heapType').value;\n    $('heapType').disabled = true;\n    log(`Switching to ${t.toUpperCase()}`);\n    await pq.rebuild(t, onStep);\n    render();\n    $('heapType').disabled = false;\n  });\n\n  // initial render\n  render();\n  log('Ready — use the controls to interact with the priority queue.');\n\n})();\n</script>\n</body>\n</html>"
  },
