    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Typing Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n        .result {\n            margin-top: 20px;\n            padding: 10px;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            background-color: #f9f9f9;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Dynamic Typing in JavaScript</h1>\n<p>\n    JavaScript is a dynamically typed language, meaning variables can hold values of any type \n    without explicit type definitions. Below, you can see how values can change types dynamically.\n</p>\n\n<button onclick=\"demonstrateDynamicTyping()\">Demonstrate Dynamic Typing</button>\n\n<div class=\"result\" id=\"result\"></div>\n\n<script>\n    function demonstrateDynamicTyping() {\n        let dynamicVar; // Initially undefined\n        let resultDiv = document.getElementById('result');\n        resultDiv.innerHTML = ''; // Clear previous results\n\n        // Assigning a number\n        dynamicVar = 5;\n        resultDiv.innerHTML += `<p>After assigning a number: <strong>${dynamicVar} (${typeof dynamicVar})</strong></p>`;\n\n        // Assigning a string\n        dynamicVar = \"Hello, world!\";\n        resultDiv.innerHTML += `<p>After assigning a string: <strong>${dynamicVar} (${typeof dynamicVar})</strong></p>`;\n\n        // Assigning a boolean\n        dynamicVar = true;\n        resultDiv.innerHTML += `<p>After assigning a boolean: <strong>${dynamicVar} (${typeof dynamicVar})</strong></p>`;\n\n        // Assigning an array\n        dynamicVar = [1, 2, 3];\n        resultDiv.innerHTML += `<p>After assigning an array: <strong>${dynamicVar} (${typeof dynamicVar})</strong></p>`;\n\n        // Assigning an object\n        dynamicVar = { key: \"value\" };\n        resultDiv.innerHTML += `<p>After assigning an object: <strong>${JSON.stringify(dynamicVar)} (${typeof dynamicVar})</strong></p>`;\n        \n        // Assigning null\n        dynamicVar = null;\n        resultDiv.innerHTML += `<p>After assigning null: <strong>${dynamicVar} (${typeof dynamicVar})</strong></p>`;\n    }\n</script>\n\n</body>\n</html>"
