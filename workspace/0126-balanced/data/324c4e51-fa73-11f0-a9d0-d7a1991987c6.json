    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Linked List Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f0f0;\n            padding: 20px;\n        }\n        #listContainer {\n            border: 1px solid #ccc;\n            border-radius: 8px;\n            background: white;\n            padding: 16px;\n            margin-bottom: 20px;\n            display: flex;\n            flex-direction: row;\n            overflow: auto;\n        }\n        .node {\n            border: 1px solid #007bff;\n            border-radius: 5px;\n            padding: 10px;\n            margin: 0 5px;\n            position: relative;\n        }\n        .node:hover {\n            background-color: #e7f3ff;\n        }\n        .arrow {\n            width: 30px;\n            height: 30px;\n            position: relative;\n            margin: 0 -15px;\n        }\n        .arrow:after {\n            content: '→';\n            font-size: 30px;\n            position: absolute;\n            right: 0;\n            top: 50%;\n            transform: translateY(-50%);\n        }\n    </style>\n</head>\n<body>\n\n<h1>Linked List Visualization</h1>\n<div id=\"listContainer\"></div>\n<input type=\"text\" id=\"nodeValue\" placeholder=\"Enter node value\" />\n<button id=\"addNodeButton\">Add Node</button>\n<button id=\"deleteNodeButton\">Delete Node</button>\n<button id=\"clearListButton\">Clear List</button>\n\n<script>\n    class Node {\n        constructor(value) {\n            this.value = value;\n            this.next = null;\n        }\n    }\n\n    class LinkedList {\n        constructor() {\n            this.head = null;\n        }\n\n        add(value) {\n            const newNode = new Node(value);\n            if (!this.head) {\n                this.head = newNode;\n            } else {\n                let current = this.head;\n                while (current.next) {\n                    current = current.next;\n                }\n                current.next = newNode;\n            }\n            this.render();\n        }\n\n        delete(value) {\n            if (!this.head) return;\n\n            if (this.head.value === value) {\n                this.head = this.head.next;\n            } else {\n                let current = this.head;\n                while (current.next && current.next.value !== value) {\n                    current = current.next;\n                }\n                if (current.next) {\n                    current.next = current.next.next;\n                }\n            }\n            this.render();\n        }\n\n        clear() {\n            this.head = null;\n            this.render();\n        }\n\n        render() {\n            const container = document.getElementById('listContainer');\n            container.innerHTML = '';\n            let current = this.head;\n            while (current) {\n                const nodeDiv = document.createElement('div');\n                nodeDiv.className = 'node';\n                nodeDiv.textContent = current.value;\n                container.appendChild(nodeDiv);\n\n                if (current.next) {\n                    const arrowDiv = document.createElement('div');\n                    arrowDiv.className = 'arrow';\n                    container.appendChild(arrowDiv);\n                }\n\n                current = current.next;\n            }\n        }\n    }\n\n    const linkedList = new LinkedList();\n    \n    document.getElementById('addNodeButton').onclick = function() {\n        const value = document.getElementById('nodeValue').value;\n        if (value) {\n            linkedList.add(value);\n            document.getElementById('nodeValue').value = '';\n        }\n    };\n\n    document.getElementById('deleteNodeButton').onclick = function() {\n        const value = document.getElementById('nodeValue').value;\n        if (value) {\n            linkedList.delete(value);\n            document.getElementById('nodeValue').value = '';\n        }\n    };\n\n    document.getElementById('clearListButton').onclick = function() {\n        linkedList.clear();\n    };\n</script>\n\n</body>\n</html>"
