    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Semaphore Example</title>\n    <style>\n        #semaphore {\n            position: absolute;\n            width: 50px;\n            height: 50px;\n            border: 1px solid black;\n            border-radius: 50%;\n            display: inline-block;\n            font-size: 24px;\n            line-height: 50px;\n            cursor: pointer;\n        }\n\n        #semaphore:hover {\n            background-color: #ccc;\n        }\n    </style>\n</head>\n<body>\n    <button id=\"semaphore\">Start</button>\n    <p id=\"message\"></p>\n\n    <script>\n        let semaphore = document.getElementById('semaphore');\n        let message = document.getElementById('message');\n\n        semaphore.addEventListener('click', function() {\n            if (semaphore.classList.contains('running')) {\n                semaphore.classList.remove('running');\n                semaphore.textContent = 'Running';\n                setTimeout(function() {\n                    semaphore.classList.add('running');\n                    semaphore.textContent = 'Waiting';\n                    message.textContent = 'Waiting for semaphore to be released';\n                }, 500);\n            } else {\n                semaphore.classList.remove('running');\n                semaphore.textContent = 'Running';\n                setTimeout(function() {\n                    semaphore.classList.add('running');\n                    semaphore.textContent = 'Waiting';\n                    message.textContent = 'Semaphore released';\n                }, 500);\n            }\n        });\n    </script>\n</body>\n</html>"
