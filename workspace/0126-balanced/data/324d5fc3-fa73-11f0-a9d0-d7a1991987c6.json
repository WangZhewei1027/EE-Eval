    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Radix Sort Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            text-align: center;\n            padding: 20px;\n        }\n        .bar {\n            display: inline-block;\n            width: 20px;\n            margin: 1px;\n            background-color: #3498db;\n        }\n        #arrayContainer {\n            margin: 20px 0;\n        }\n        button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n            margin-top: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Radix Sort Visualization</h1>\n    <div id=\"arrayContainer\"></div>\n    <button onclick=\"startSorting()\">Sort Array</button>\n\n    <script>\n        let array = [170, 45, 75, 90, 802, 24, 2, 66];\n        let maxDigits = 3;\n\n        function startSorting() {\n            radixSort(array);\n        }\n\n        function displayArray(arr, highlightIndex = -1) {\n            const container = document.getElementById('arrayContainer');\n            container.innerHTML = '';\n            arr.forEach((num, index) => {\n                const bar = document.createElement('div');\n                bar.className = 'bar';\n                bar.style.height = `${num * 2}px`; // Scale the bar height\n                if (index === highlightIndex) {\n                    bar.style.backgroundColor = 'red'; // Highlighting the current digit processing\n                }\n                container.appendChild(bar);\n            });\n        }\n\n        function getDigit(num, digit) {\n            return Math.floor(Math.abs(num) / Math.pow(10, digit)) % 10;\n        }\n\n        function getMax(arr) {\n            return Math.max(...arr);\n        }\n\n        function countingSort(arr, digit) {\n            const output = new Array(arr.length);\n            const count = Array.from({ length: 10 }, () => 0);\n\n            for (let i = 0; i < arr.length; i++) {\n                const digitValue = getDigit(arr[i], digit);\n                count[digitValue]++;\n            }\n\n            for (let i = 1; i < count.length; i++) {\n                count[i] += count[i - 1];\n            }\n\n            for (let i = arr.length - 1; i >= 0; i--) {\n                const digitValue = getDigit(arr[i], digit);\n                output[count[digitValue] - 1] = arr[i];\n                count[digitValue]--;\n                displayArray(output);\n            }\n\n            for (let i = 0; i < arr.length; i++) {\n                arr[i] = output[i];\n            }\n        }\n\n        function radixSort(arr) {\n            const max = getMax(arr);\n            const maxDigits = Math.floor(Math.log10(max)) + 1;\n\n            for (let digit = 0; digit < maxDigits; digit++) {\n                countingSort(arr, digit);\n                displayArray(arr, digit); // Highlight the current digit being sorted\n            }\n        }\n\n        // Initial display\n        displayArray(array);\n    </script>\n</body>\n</html>"
