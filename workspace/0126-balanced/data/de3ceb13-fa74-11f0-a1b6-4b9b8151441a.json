  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Relational Database Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        h1 {\n            color: #2c3e50;\n            text-align: center;\n        }\n        .tables-container {\n            display: flex;\n            gap: 20px;\n            margin-top: 30px;\n        }\n        table {\n            border-collapse: collapse;\n            width: 100%;\n            margin-bottom: 20px;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        th {\n            background-color: #3498db;\n            color: white;\n        }\n        tr:nth-child(even) {\n            background-color: #f2f2f2;\n        }\n        .query-results {\n            margin-top: 30px;\n            padding: 15px;\n            background-color: #f8f9fa;\n            border-radius: 5px;\n        }\n        button {\n            background-color: #2ecc71;\n            color: white;\n            border: none;\n            padding: 10px 15px;\n            border-radius: 5px;\n            cursor: pointer;\n            margin-top: 10px;\n        }\n        button:hover {\n            background-color: #27ae60;\n        }\n        pre {\n            background-color: #f0f0f0;\n            padding: 10px;\n            border-radius: 5px;\n            overflow-x: auto;\n        }\n    </style>\n</head>\n<body>\n    <h1>Relational Database Concept Demonstration</h1>\n    \n    <p>This demo shows the principles of relational databases with three related tables: Users, Orders, and Products.</p>\n    \n    <div class=\"tables-container\">\n        <div>\n            <h2>Users Table</h2>\n            <table id=\"users-table\">\n                <thead>\n                    <tr>\n                        <th>user_id</th>\n                        <th>name</th>\n                        <th>email</th>\n                    </tr>\n                </thead>\n                <tbody></tbody>\n            </table>\n        </div>\n        \n        <div>\n            <h2>Products Table</h2>\n            <table id=\"products-table\">\n                <thead>\n                    <tr>\n                        <th>product_id</th>\n                        <th>name</th>\n                        <th>price</th>\n                    </tr>\n                </thead>\n                <tbody></tbody>\n            </table>\n        </div>\n    </div>\n    \n    <h2>Orders Table (Joining Users and Products)</h2>\n    <table id=\"orders-table\">\n        <thead>\n            <tr>\n                <th>order_id</th>\n                <th>user_id</th>\n                <th>product_id</th>\n                <th>quantity</th>\n                <th>order_date</th>\n            </tr>\n        </thead>\n        <tbody></tbody>\n    </table>\n    \n    <div class=\"query-results\">\n        <h2>Query Examples</h2>\n        \n        <h3>1. Get all orders with user and product information</h3>\n        <button onclick=\"runJoinQuery()\">Run Query</button>\n        <pre id=\"join-query-results\"></pre>\n        \n        <h3>2. Find total spending per user</h3>\n        <button onclick=\"runAggregateQuery()\">Run Query</button>\n        <pre id=\"aggregate-query-results\"></pre>\n        \n        <h3>3. Find users who bought more than 1 product</h3>\n        <button onclick=\"runSubquery()\">Run Query</button>\n        <pre id=\"subquery-results\"></pre>\n    </div>\n    \n    <script>\n        // Simple in-memory relational database\n        const database = {\n            users: [\n                { user_id: 1, name: 'Alice Johnson', email: 'alice@example.com' },\n                { user_id: 2, name: 'Bob Smith', email: 'bob@example.com' },\n                { user_id: 3, name: 'Charlie Brown', email: 'charlie@example.com' }\n            ],\n            products: [\n                { product_id: 101, name: 'Laptop', price: 999.99 },\n                { product_id: 102, name: 'Smartphone', price: 699.99 },\n                { product_id: 103, name: 'Headphones', price: 149.99 }\n            ],\n            orders: [\n                { order_id: 1001, user_id: 1, product_id: 101, quantity: 1, order_date: '2023-05-15' },\n                { order_id: 1002, user_id: 2, product_id: 102, quantity: 1, order_date: '2023-05-16' },\n                { order_id: 1003, user_id: 1, product_id: 103, quantity: 2, order_date: '2023-05-17' },\n                { order_id: 1004, user_id: 3, product_id: 101, quantity: 1, order_date: '2023-05-18' },\n                { order_id: 1005, user_id: 2, product_id: 103, quantity: 3, order_date: '2023-05-19' }\n            ]\n        };\n\n        // Display tables on page load\n        document.addEventListener('DOMContentLoaded', function() {\n            displayTable('users-table', database.users);\n            displayTable('products-table', database.products);\n            displayTable('orders-table', database.orders);\n        });\n\n        // Helper function to display a table\n        function displayTable(tableId, data) {\n            const table = document.getElementById(tableId).getElementsByTagName('tbody')[0];\n            table.innerHTML = '';\n            \n            data.forEach(item => {\n                const row = table.insertRow();\n                for (const key in item) {\n                    const cell = row.insertCell();\n                    cell.textContent = item[key];\n                }\n            });\n        }\n\n        // Query 1: Join orders with users and products\n        function runJoinQuery() {\n            const results = [];\n            \n            database.orders.forEach(order => {\n                const user = database.users.find(u => u.user_id === order.user_id);\n                const product = database.products.find(p => p.product_id === order.product_id);\n                \n                results.push({\n                    order_id: order.order_id,\n                    user_name: user.name,\n                    product_name: product.name,\n                    quantity: order.quantity,\n                    total_price: (product.price * order.quantity).toFixed(2),\n                    order_date: order.order_date\n                });\n            });\n            \n            document.getElementById('join-query-results').textContent = \n                'Results:\\n' + JSON.stringify(results, null, 2) +\n                '\\n\\nSQL equivalent:\\nSELECT o.order_id, u.name AS user_name, p.name AS product_name, \\n' +\n                '       o.quantity, (p.price * o.quantity) AS total_price, o.order_date\\n' +\n                'FROM orders o\\n' +\n                'JOIN users u ON o.user_id = u.user_id\\n' +\n                'JOIN products p ON o.product_id = p.product_id';\n        }\n\n        // Query 2: Aggregate total spending per user\n        function runAggregateQuery() {\n            const userTotals = {};\n            \n            database.orders.forEach(order => {\n                const product = database.products.find(p => p.product_id === order.product_id);\n                const amount = product.price * order.quantity;\n                \n                if (!userTotals[order.user_id]) {\n                    userTotals[order.user_id] = 0;\n                }\n                userTotals[order.user_id] += amount;\n            });\n            \n            const results = Object.keys(userTotals).map(userId => {\n                const user = database.users.find(u => u.user_id === parseInt(userId));\n                return {\n                    user_id: userId,\n                    name: user.name,\n                    total_spent: userTotals[userId].toFixed(2)\n                };\n            });\n            \n            document.getElementById('aggregate-query-results').textContent = \n                'Results:\\n' + JSON.stringify(results, null, 2) +\n                '\\n\\nSQL equivalent:\\nSELECT u.user_id, u.name, SUM(p.price * o.quantity) AS total_spent\\n' +\n                'FROM users u\\n' +\n                'JOIN orders o ON u.user_id = o.user_id\\n' +\n                'JOIN products p ON o.product_id = p.product_id\\n' +\n                'GROUP BY u.user_id, u.name';\n        }\n\n        // Query 3: Subquery to find users who bought more than 1 product\n        function runSubquery() {\n            const userOrderCounts = {};\n            \n            database.orders.forEach(order => {\n                if (!userOrderCounts[order.user_id]) {\n                    userOrderCounts[order.user_id] = 0;\n                }\n                userOrderCounts[order.user_id]++;\n            });\n            \n            const activeUsers = Object.keys(userOrderCounts)\n                .filter(userId => userOrderCounts[userId] > 1)\n                .map(userId => {\n                    const user = database.users.find(u => u.user_id === parseInt(userId));\n                    return {\n                        user_id: userId,\n                        name: user.name,\n                        order_count: userOrderCounts[userId]\n                    };\n                });\n            \n            document.getElementById('subquery-results').textContent = \n                'Results:\\n' + JSON.stringify(activeUsers, null, 2) +\n                '\\n\\nSQL equivalent:\\nSELECT u.user_id, u.name, COUNT(o.order_id) AS order_count\\n' +\n                'FROM users u\\n' +\n                'JOIN orders o ON u.user_id = o.user_id\\n' +\n                'GROUP BY u.user_id, u.name\\n' +\n                'HAVING COUNT(o.order_id) > 1';\n        }\n    </script>\n</body>\n</html>"
  },
