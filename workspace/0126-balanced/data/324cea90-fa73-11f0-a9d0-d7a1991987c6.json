    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>AVL Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #tree-container {\n            width: 100%;\n            height: 400px;\n            position: relative;\n            border: 1px solid #ccc;\n        }\n        .node {\n            position: absolute;\n            width: 40px;\n            height: 40px;\n            background-color: #4CAF50;\n            color: white;\n            border-radius: 20px;\n            text-align: center;\n            line-height: 40px;\n            box-shadow: 2px 2px 5px rgba(0,0,0,0.3);\n        }\n        .link {\n            position: absolute;\n            background-color: black;\n            height: 2px;\n            transition: height 0.2s, left 0.2s, top 0.2s;\n        }\n    </style>\n</head>\n<body>\n\n<h1>AVL Tree Visualization</h1>\n<div id=\"tree-container\"></div>\n<label for=\"nodeValue\">Enter a number: </label>\n<input type=\"number\" id=\"nodeValue\" />\n<button onclick=\"insertNode()\">Insert Node</button>\n\n<script>\n    class AVLTreeNode {\n        constructor(value) {\n            this.value = value;\n            this.height = 1;\n            this.left = null;\n            this.right = null;\n        }\n    }\n\n    class AVLTree {\n        constructor() {\n            this.root = null;\n        }\n\n        getHeight(node) {\n            return node ? node.height : 0;\n        }\n\n        getBalance(node) {\n            return node ? this.getHeight(node.left) - this.getHeight(node.right) : 0;\n        }\n\n        rightRotate(y) {\n            let x = y.left;\n            let T2 = x.right;\n            x.right = y;\n            y.left = T2;\n            y.height = Math.max(this.getHeight(y.left), this.getHeight(y.right)) + 1;\n            x.height = Math.max(this.getHeight(x.left), this.getHeight(x.right)) + 1;\n            return x;\n        }\n\n        leftRotate(x) {\n            let y = x.right;\n            let T2 = y.left;\n            y.left = x;\n            x.right = T2;\n            x.height = Math.max(this.getHeight(x.left), this.getHeight(x.right)) + 1;\n            y.height = Math.max(this.getHeight(y.left), this.getHeight(y.right)) + 1;\n            return y;\n        }\n\n        insert(node, value) {\n            if (!node) return new AVLTreeNode(value);\n            if (value < node.value) {\n                node.left = this.insert(node.left, value);\n            } else if (value > node.value) {\n                node.right = this.insert(node.right, value);\n            } else {\n                return node;\n            }\n\n            node.height = Math.max(this.getHeight(node.left), this.getHeight(node.right)) + 1;\n\n            let balance = this.getBalance(node);\n\n            if (balance > 1 && value < node.left.value) return this.rightRotate(node);\n            if (balance < -1 && value > node.right.value) return this.leftRotate(node);\n            if (balance > 1 && value > node.left.value) {\n                node.left = this.leftRotate(node.left);\n                return this.rightRotate(node);\n            }\n            if (balance < -1 && value < node.right.value) {\n                node.right = this.rightRotate(node.right);\n                return this.leftRotate(node);\n            }\n            return node;\n        }\n\n        insertNode(value) {\n            this.root = this.insert(this.root, value);\n            this.renderTree();\n        }\n\n        renderTree() {\n            const container = document.getElementById('tree-container');\n            container.innerHTML = '';\n            this.draw(this.root, container, window.innerWidth / 2, 50, 100);\n        }\n\n        draw(node, container, x, y, xOffset) {\n            if (!node) return;\n            const nodeElement = document.createElement('div');\n            nodeElement.className = 'node';\n            nodeElement.style.left = `${x}px`;\n            nodeElement.style.top = `${y}px`;\n            nodeElement.innerText = node.value;\n            container.appendChild(nodeElement);\n\n            if (node.left) {\n                const leftX = x - xOffset;\n                const leftY = y + 50;\n                const link = this.createLink(x + 20, y + 40, leftX + 20, leftY);\n                container.appendChild(link);\n                this.draw(node.left, container, leftX, leftY, xOffset / 2);\n            }\n            if (node.right) {\n                const rightX = x + xOffset;\n                const rightY = y + 50;\n                const link = this.createLink(x + 20, y + 40, rightX + 20, rightY);\n                container.appendChild(link);\n                this.draw(node.right, container, rightX, rightY, xOffset / 2);\n            }\n        }\n\n        createLink(x1, y1, x2, y2) {\n            const link = document.createElement('div');\n            link.className = 'link';\n            const height = Math.sqrt((x2 - x1) ** 2 + (y2 - y1) ** 2);\n            link.style.width = `${height}px`;\n            link.style.left = `${x1}px`;\n            link.style.top = `${y1}px`;\n            link.style.transform = `rotate(${Math.atan2(y2 - y1, x2 - x1)}rad)`;\n            return link;\n        }\n    }\n\n    const avlTree = new AVLTree();\n\n    function insertNode() {\n        const value = parseInt(document.getElementById('nodeValue').value);\n        if (!isNaN(value)) {\n            avlTree.insertNode(value);\n            document.getElementById('nodeValue').value = '';\n        } else {\n            alert('Please enter a valid number');\n        }\n    }\n</script>\n\n</body>\n</html>"
