  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\"/>\n  <title>Breadth-First Search (BFS) Demonstration</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#071029;\n      --accent:#60a5fa;\n      --muted:#94a3b8;\n      --good:#10b981;\n      --bad:#ef4444;\n      --cell-size:28px;\n      --font-family:Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    }\n    *{box-sizing:border-box}\n    body{\n      margin:0;\n      font-family:var(--font-family);\n      background:linear-gradient(180deg,#07112a,#041229);\n      color:#e6eef8;\n      display:flex;\n      min-height:100vh;\n      align-items:center;\n      justify-content:center;\n      padding:24px;\n    }\n    .container{\n      width:100%;\n      max-width:1200px;\n      display:grid;\n      grid-template-columns: 1fr 340px;\n      gap:20px;\n    }\n    .left {\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:12px;\n      padding:16px;\n      box-shadow: 0 6px 20px rgba(2,6,23,0.6);\n      min-height:520px;\n    }\n    .right {\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:12px;\n      padding:14px;\n      box-shadow: 0 6px 20px rgba(2,6,23,0.6);\n      color:var(--muted);\n      overflow:auto;\n      max-height:720px;\n    }\n    h1{margin:4px 0 8px;font-size:18px;color:#dbeafe}\n    p.lead{margin:6px 0 14px;color:var(--muted);font-size:13px}\n    canvas{\n      width:100%;\n      height:560px;\n      border-radius:8px;\n      background:linear-gradient(180deg,#001826,#002538);\n      display:block;\n      cursor:crosshair;\n      border:1px solid rgba(255,255,255,0.04);\n    }\n    .controls{\n      display:flex;\n      gap:8px;\n      flex-wrap:wrap;\n      margin-bottom:10px;\n    }\n    button, select{\n      background:transparent;\n      color:#dbeafe;\n      border:1px solid rgba(255,255,255,0.06);\n      padding:8px 10px;\n      border-radius:8px;\n      cursor:pointer;\n      font-size:13px;\n    }\n    button.primary{\n      background:linear-gradient(90deg,#2563eb,#60a5fa);\n      border:0;\n      color:white;\n    }\n    .small{\n      padding:6px 8px;font-size:12px;border-radius:6px;\n    }\n    .row{\n      display:flex;gap:8px;align-items:center;margin-bottom:8px;\n    }\n    label{font-size:13px;color:var(--muted);margin-right:8px}\n    input[type=range]{width:160px}\n    .legend{\n      display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;\n    }\n    .legend-item{\n      display:flex;gap:8px;align-items:center;padding:6px 8px;border-radius:8px;background:rgba(255,255,255,0.02);\n      color:var(--muted);font-size:13px;\n    }\n    .swatch{width:22px;height:22px;border-radius:4px;border:1px solid rgba(255,255,255,0.03)}\n    .sw-start{background:linear-gradient(90deg,#10b981,#34d399)}\n    .sw-target{background:linear-gradient(90deg,#f97316,#fb923c)}\n    .sw-wall{background:#111827}\n    .sw-frontier{background:linear-gradient(90deg,#60a5fa,#3b82f6)}\n    .sw-visited{background:linear-gradient(90deg,#64748b,#7b93a9)}\n    .sw-path{background:linear-gradient(90deg,#f43f5e,#fb7185)}\n    .info {font-size:13px;color:var(--muted);margin-top:12px}\n    .queue-box{\n      margin-top:12px;\n      background:rgba(255,255,255,0.02);\n      padding:8px;border-radius:8px;\n      color:#e6eef8;font-size:13px;\n    }\n    .queue-list{\n      display:flex;flex-wrap:wrap;gap:6px;max-height:200px;overflow:auto;padding-top:6px;\n    }\n    .queue-item{\n      background:rgba(255,255,255,0.03);padding:6px 8px;border-radius:6px;font-size:13px;\n    }\n    pre{\n      background:transparent;color:var(--muted);font-size:12px;white-space:pre-wrap;margin:6px 0;\n    }\n    .footer{\n      margin-top:12px;font-size:12px;color:var(--muted);\n    }\n    .mode-btn{\n      border:1px dashed rgba(255,255,255,0.03);\n      background:transparent;padding:6px 8px;border-radius:6px;color:var(--muted);\n    }\n    .mode-active{\n      background:rgba(96,165,250,0.12);border:1px solid rgba(96,165,250,0.16);color:#dbeafe;\n    }\n    .grid-size{\n      display:flex;gap:8px;align-items:center;\n    }\n    @media (max-width:980px){\n      .container{grid-template-columns:1fr; padding-bottom:40px;}\n      canvas{height:460px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\" role=\"main\">\n    <div class=\"left\" aria-label=\"BFS visualization area\">\n      <h1>Breadth-First Search (BFS) — Interactive Visualization</h1>\n      <p class=\"lead\">Explore how BFS visits nodes by layers. Click to add/remove walls, set start/target, then run BFS to see the frontier (queue), visited order, and shortest path (if any).</p>\n\n      <div class=\"controls\" aria-hidden=\"false\">\n        <button id=\"startBtn\" class=\"primary\">Start</button>\n        <button id=\"stepBtn\" class=\"small\">Step</button>\n        <button id=\"pauseBtn\" class=\"small\">Pause</button>\n        <button id=\"resetBtn\" class=\"small\">Reset</button>\n\n        <div style=\"margin-left:8px;display:flex;align-items:center;gap:8px\">\n          <label for=\"speed\">Speed</label>\n          <input id=\"speed\" type=\"range\" min=\"50\" max=\"1000\" value=\"180\" step=\"10\" />\n        </div>\n      </div>\n\n      <div class=\"row\">\n        <button id=\"modeWall\" class=\"mode-btn mode-active\">Draw Walls</button>\n        <button id=\"modeStart\" class=\"mode-btn\">Set Start</button>\n        <button id=\"modeTarget\" class=\"mode-btn\">Set Target</button>\n        <button id=\"randomWalls\" class=\"small\">Random Walls</button>\n        <button id=\"clearWalls\" class=\"small\">Clear Walls</button>\n        <div style=\"margin-left:auto\" class=\"grid-size\">\n          <label for=\"cols\">Cols</label>\n          <select id=\"cols\">\n            <option>20</option><option>30</option><option selected>40</option><option>50</option>\n          </select>\n          <label for=\"rows\">Rows</label>\n          <select id=\"rows\">\n            <option>10</option><option selected>15</option><option>20</option><option>25</option>\n          </select>\n          <button id=\"resize\" class=\"small\">Resize Grid</button>\n        </div>\n      </div>\n\n      <canvas id=\"grid\"></canvas>\n\n      <div class=\"legend\" aria-hidden=\"false\">\n        <div class=\"legend-item\"><div class=\"swatch sw-start\"></div> Start</div>\n        <div class=\"legend-item\"><div class=\"swatch sw-target\"></div> Target</div>\n        <div class=\"legend-item\"><div class=\"swatch sw-wall\"></div> Wall</div>\n        <div class=\"legend-item\"><div class=\"swatch sw-frontier\"></div> Frontier (in queue)</div>\n        <div class=\"legend-item\"><div class=\"swatch sw-visited\"></div> Visited</div>\n        <div class=\"legend-item\"><div class=\"swatch sw-path\"></div> Final Shortest Path</div>\n      </div>\n    </div>\n\n    <aside class=\"right\" aria-label=\"Control panel\">\n      <h2 style=\"margin:0;color:#dbeafe;font-size:16px\">Queue / BFS State</h2>\n      <div class=\"info\">The \"frontier\" (blue) shows nodes currently in the queue. BFS explores nodes in FIFO order, visiting neighbors level-by-level.</div>\n\n      <div class=\"queue-box\" id=\"statsBox\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div>Queue (front → back)</div>\n          <div style=\"font-size:12px;color:var(--muted)\"><span id=\"visitCount\">Visited: 0</span></div>\n        </div>\n        <div class=\"queue-list\" id=\"queueList\" aria-live=\"polite\"></div>\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div style=\"font-weight:600;color:#dbeafe\">Last action</div>\n          <div style=\"color:var(--muted);font-size:13px\" id=\"lastAction\">Ready</div>\n        </div>\n        <pre id=\"log\" style=\"height:120px;overflow:auto;padding-top:6px;\">Click on the grid to add walls (or change mode). Then press Start to run BFS.</pre>\n      </div>\n\n      <div style=\"margin-top:10px\">\n        <div style=\"font-weight:600;color:#dbeafe\">BFS (pseudocode)</div>\n        <pre>\nBFS(start):\n  queue ← [start]\n  visited[start] ← true\n  while queue not empty:\n    v ← queue.pop_front()\n    for each neighbor u of v:\n      if not visited[u] and not wall:\n        visited[u] ← true\n        parent[u] ← v\n        queue.push_back(u)\n        if u == target: reconstruct path and stop\n        </pre>\n      </div>\n\n      <div class=\"footer\">\n        Tip: Use \"Step\" to execute one BFS operation at a time and watch the queue update. Resize the grid, create mazes, and observe how BFS finds the shortest path in an unweighted grid.\n      </div>\n    </aside>\n  </div>\n\n<script>\n/*\n  BFS Visualization - single-file demo.\n  - Grid of cells\n  - Modes: draw walls, set start, set target\n  - Start / Step / Pause / Reset\n  - Shows queue contents and visited order numbers\n  - Animates BFS exploring neighbors in FIFO order (4-directional)\n*/\n\n(() => {\n  // Config\n  let cols = parseInt(document.getElementById('cols').value,10);\n  let rows = parseInt(document.getElementById('rows').value,10);\n  const canvas = document.getElementById('grid');\n  const ctx = canvas.getContext('2d', {alpha:false});\n  let devicePixelRatio = window.devicePixelRatio || 1;\n\n  // State\n  let grid = []; // 2D array of cells\n  let start = {x: 1, y: 1};\n  let target = {x: cols - 2, y: rows - 2};\n  let mode = 'wall'; // 'wall' | 'start' | 'target'\n  let running = false;\n  let paused = false;\n  let bfsGen = null;\n  let timer = null;\n  let speed = parseInt(document.getElementById('speed').value,10);\n  let visitCount = 0;\n  let visitOrder = {}; // key => order number\n  let lastActionEl = document.getElementById('lastAction');\n  const queueListEl = document.getElementById('queueList');\n  const logEl = document.getElementById('log');\n  const visitCountEl = document.getElementById('visitCount');\n\n  // Visual styles\n  function cellColor(cell){\n    if (cell.isStart) return '#10b981'; // green\n    if (cell.isTarget) return '#f97316'; // orange\n    if (cell.isPath) return '#f43f5e'; // pink\n    if (cell.isWall) return '#0b1220'; // dark\n    if (cell.inFrontier) return '#3b82f6'; // blue\n    if (cell.visited) return '#64748b'; // gray\n    return '#002538'; // default\n  }\n\n  // Initialize grid\n  function initGrid(c,r){\n    cols = c; rows = r;\n    grid = new Array(rows);\n    for (let y=0;y<rows;y++){\n      grid[y] = new Array(cols);\n      for (let x=0;x<cols;x++){\n        grid[y][x] = {\n          x,y,\n          isWall: false,\n          visited: false,\n          inFrontier: false,\n          parent: null,\n          isStart:false,\n          isTarget:false,\n          isPath:false,\n          order: null\n        };\n      }\n    }\n    // set border walls by default\n    for (let x=0;x<cols;x++){\n      grid[0][x].isWall=true;\n      grid[rows-1][x].isWall=true;\n    }\n    for (let y=0;y<rows;y++){\n      grid[y][0].isWall=true;\n      grid[y][cols-1].isWall=true;\n    }\n    // default positions (clamp)\n    start = clampCoord(start);\n    target = clampCoord(target);\n    getCell(start).isStart = true;\n    getCell(target).isTarget = true;\n\n    resetBFSState();\n    resizeCanvas();\n    draw();\n  }\n\n  function clampCoord(pt){\n    return {\n      x: Math.max(1, Math.min(cols-2, pt.x)),\n      y: Math.max(1, Math.min(rows-2, pt.y))\n    };\n  }\n\n  function getCell(pt){ return grid[pt.y][pt.x]; }\n\n  // Canvas sizing\n  function resizeCanvas(){\n    // compute cell size to fit\n    const containerRect = canvas.parentElement.getBoundingClientRect();\n    // Choose canvas pixel size based on cols/rows and desired cell size\n    // We'll compute cell size so canvas fits width of container\n    const maxWidth = Math.max(200, containerRect.width - 32);\n    const maxHeight = 560; // fixed height for left panel\n    let cellW = Math.floor(maxWidth / cols);\n    let cellH = Math.floor(maxHeight / rows);\n    let cell = Math.max(14, Math.min(32, Math.min(cellW, cellH)));\n    // set css var\n    document.documentElement.style.setProperty('--cell-size', cell+'px');\n\n    const cssWidth = cols * cell;\n    const cssHeight = rows * cell;\n\n    canvas.style.width = cssWidth + 'px';\n    canvas.style.height = cssHeight + 'px';\n\n    // handle device pixel ratio for crisp lines\n    devicePixelRatio = Math.max(1, window.devicePixelRatio || 1);\n    canvas.width = Math.floor(cssWidth * devicePixelRatio);\n    canvas.height = Math.floor(cssHeight * devicePixelRatio);\n    ctx.setTransform(devicePixelRatio,0,0,devicePixelRatio,0,0);\n    draw();\n  }\n\n  // Drawing\n  function draw(){\n    const cell = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--cell-size')) || 20;\n    // background\n    ctx.fillStyle = '#001726';\n    ctx.fillRect(0,0,canvas.width,canvas.height);\n    // draw cells\n    for (let y=0;y<rows;y++){\n      for (let x=0;x<cols;x++){\n        const c = grid[y][x];\n        // base\n        ctx.fillStyle = cellColor(c);\n        ctx.fillRect(x*cell,y*cell,cell,cell);\n        // outline\n        ctx.strokeStyle = 'rgba(0,0,0,0.12)';\n        ctx.lineWidth = 1;\n        ctx.strokeRect(x*cell+0.5,y*cell+0.5,cell-1,cell-1);\n\n        // visited order number\n        if (c.visited && c.order!=null && !c.isStart && !c.isTarget){\n          ctx.fillStyle = '#e6eef8';\n          ctx.font = Math.max(10, Math.floor(cell*0.42))+'px monospace';\n          ctx.textAlign = 'center';\n          ctx.textBaseline = 'middle';\n          ctx.fillText(String(c.order), x*cell + cell/2, y*cell + cell/2);\n        }\n      }\n    }\n    // small cross for start/target for clarity\n    // (start/target already colored)\n  }\n\n  // Utilities\n  function log(msg){\n    const time = new Date().toLocaleTimeString();\n    logEl.textContent = `[${time}] ${msg}\\n` + logEl.textContent;\n  }\n\n  function resetBFSState(){\n    // clear visited/frontier/path and bookkeeping\n    visitCount = 0;\n    visitOrder = {};\n    for (let y=0;y<rows;y++){\n      for (let x=0;x<cols;x++){\n        const c = grid[y][x];\n        c.visited = false;\n        c.inFrontier = false;\n        c.parent = null;\n        c.isPath = false;\n        c.order = null;\n      }\n    }\n    getCell(start).isStart = true;\n    getCell(target).isTarget = true;\n    updateQueueUI([]);\n    visitCountEl.textContent = 'Visited: 0';\n    lastActionEl.textContent = 'Ready';\n    logEl.textContent = '';\n  }\n\n  // BFS generator for stepwise execution\n  function* bfsGenerator(){\n    // standard 4-directional BFS\n    const startCell = getCell(start);\n    const targetCell = getCell(target);\n    const q = [];\n    const key = (x,y) => `${x},${y}`;\n\n    q.push(start);\n    startCell.visited = true;\n    visitCount++;\n    startCell.order = visitCount;\n    visitOrder[key(start.x,start.y)] = visitCount;\n    startCell.inFrontier = true;\n\n    // initial UI\n    updateQueueUI(q);\n\n    while(q.length>0){\n      // dequeue\n      const cur = q.shift();\n      const curCell = getCell(cur);\n      curCell.inFrontier = false;\n      lastActionEl.textContent = `Dequeue (${cur.x},${cur.y})`;\n      yield {type:'dequeue', node:cur, queue:Array.from(q)};\n\n      // mark as explored (visited already set when enqueued)\n      // check neighbors\n      const dirs = [{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}];\n      for (const d of dirs){\n        const nx = cur.x + d.x;\n        const ny = cur.y + d.y;\n        if (nx<0||nx>=cols||ny<0||ny>=rows) continue;\n        const nCell = grid[ny][nx];\n        if (nCell.isWall) continue;\n        if (nCell.visited) continue;\n        // visit neighbor\n        nCell.visited = true;\n        visitCount++;\n        nCell.order = visitCount;\n        visitOrder[key(nx,ny)] = visitCount;\n        nCell.parent = {x:cur.x,y:cur.y};\n        q.push({x:nx,y:ny});\n        nCell.inFrontier = true;\n        lastActionEl.textContent = `Enqueue (${nx},${ny})`;\n        yield {type:'enqueue', node:{x:nx,y:ny}, queue:Array.from(q)};\n        // if target found\n        if (nx===target.x && ny===target.y){\n          lastActionEl.textContent = `Target found at (${nx},${ny})`;\n          // reconstruct path\n          let path = [{x:nx,y:ny}];\n          let p = nCell.parent;\n          while(p){\n            path.push({x:p.x,y:p.y});\n            const pc = grid[p.y][p.x];\n            p = pc.parent;\n          }\n          path.reverse();\n          // mark path\n          for (const pt of path){\n            const pc = grid[pt.y][pt.x];\n            if (!pc.isStart && !pc.isTarget) pc.isPath = true;\n          }\n          updateQueueUI(q);\n          yield {type:'found', path: path, queue:Array.from(q)};\n          return;\n        }\n      }\n      updateQueueUI(q);\n      yield {type:'afterExplore', node:cur, queue:Array.from(q)};\n    }\n    lastActionEl.textContent = 'Queue empty, target not found';\n    yield {type:'notfound'};\n  }\n\n  // UI updates for queue\n  function updateQueueUI(q){\n    queueListEl.innerHTML = '';\n    for (let i=0;i<q.length;i++){\n      const it = document.createElement('div');\n      it.className = 'queue-item';\n      it.textContent = `(${q[i].x},${q[i].y})`;\n      if (i===0) it.style.fontWeight = '700';\n      queueListEl.appendChild(it);\n    }\n    visitCountEl.textContent = 'Visited: ' + visitCount;\n    draw();\n  }\n\n  // Step the generator once\n  function stepOnce(){\n    if (!bfsGen) {\n      bfsGen = bfsGenerator();\n    }\n    const res = bfsGen.next();\n    if (res.done){\n      running = false;\n      bfsGen = null;\n      paused = false;\n      clearInterval(timer);\n      timer = null;\n      draw();\n      if (res.value && res.value.type === 'found') {\n        log('Target found — shortest path highlighted.');\n      } else {\n        log('BFS complete. Target not reachable.');\n      }\n      return res;\n    } else {\n      // handle yielded value\n      const val = res.value;\n      if (val.type==='enqueue' || val.type==='dequeue' || val.type==='afterExplore'){\n        // update rendering and queue UI\n        updateQueueUI(val.queue);\n        log(`${val.type.toUpperCase()}: ${val.node ? `(${val.node.x},${val.node.y})` : ''}`);\n      } else if (val.type==='found'){\n        updateQueueUI(val.queue);\n        draw();\n        log('FOUND target, path length: ' + val.path.length);\n      } else if (val.type==='notfound'){\n        draw();\n        log('BFS finished; target not found.');\n      }\n      return res;\n    }\n  }\n\n  // Controls\n  const startBtn = document.getElementById('startBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const modeWall = document.getElementById('modeWall');\n  const modeStart = document.getElementById('modeStart');\n  const modeTarget = document.getElementById('modeTarget');\n  const randomWallsBtn = document.getElementById('randomWalls');\n  const clearWallsBtn = document.getElementById('clearWalls');\n  const speedInput = document.getElementById('speed');\n\n  function setMode(m){\n    mode = m;\n    [modeWall, modeStart, modeTarget].forEach(el => el.classList.remove('mode-active'));\n    if (m==='wall') modeWall.classList.add('mode-active');\n    if (m==='start') modeStart.classList.add('mode-active');\n    if (m==='target') modeTarget.classList.add('mode-active');\n  }\n\n  modeWall.addEventListener('click', ()=>setMode('wall'));\n  modeStart.addEventListener('click', ()=>setMode('start'));\n  modeTarget.addEventListener('click', ()=>setMode('target'));\n\n  startBtn.addEventListener('click', ()=>{\n    if (running && !paused){\n      // already running\n      return;\n    }\n    if (!bfsGen) {\n      // reset previous BFS state (keep walls, start, target)\n      resetVisitDisplay();\n      bfsGen = bfsGenerator();\n    }\n    running = true;\n    paused = false;\n    // start interval\n    clearInterval(timer);\n    timer = setInterval(()=> {\n      if (!paused) {\n        const res = stepOnce();\n        if (res && res.done) {\n          clearInterval(timer);\n          timer = null;\n          running = false;\n          bfsGen = null;\n        }\n      }\n    }, Math.max(10, speed));\n  });\n\n  pauseBtn.addEventListener('click', ()=>{\n    paused = !paused;\n    pauseBtn.textContent = paused ? 'Resume' : 'Pause';\n  });\n\n  stepBtn.addEventListener('click', ()=>{\n    if (!bfsGen){\n      resetVisitDisplay();\n      bfsGen = bfsGenerator();\n    }\n    paused = true;\n    pauseBtn.textContent = 'Resume';\n    const res = stepOnce();\n    if (res && res.done){\n      bfsGen = null;\n      running = false;\n      paused = false;\n      pauseBtn.textContent = 'Pause';\n    }\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    // stop and reset BFS state (but keep walls)\n    clearInterval(timer);\n    timer = null;\n    running = false;\n    paused = false;\n    bfsGen = null;\n    pauseBtn.textContent = 'Pause';\n    // clear visitation and path\n    resetBFSState();\n    draw();\n    log('Reset BFS state (kept walls and start/target).');\n  });\n\n  function resetVisitDisplay(){\n    for (let y=0;y<rows;y++){\n      for (let x=0;x<cols;x++){\n        const c = grid[y][x];\n        c.visited = false;\n        c.inFrontier = false;\n        c.parent = null;\n        c.isPath = false;\n        c.order = null;\n      }\n    }\n    visitCount = 0;\n    visitOrder = {};\n    getCell(start).isStart = true;\n    getCell(target).isTarget = true;\n    updateQueueUI([]);\n    draw();\n  }\n\n  randomWallsBtn.addEventListener('click', ()=>{\n    // create random walls inside (not start/target)\n    for (let y=1;y<rows-1;y++){\n      for (let x=1;x<cols-1;x++){\n        if ((x===start.x && y===start.y) || (x===target.x && y===target.y)) continue;\n        grid[y][x].isWall = (Math.random() < 0.22);\n      }\n    }\n    resetBFSState();\n    draw();\n    log('Random walls generated.');\n  });\n\n  clearWallsBtn.addEventListener('click', ()=>{\n    for (let y=1;y<rows-1;y++){\n      for (let x=1;x<cols-1;x++){\n        grid[y][x].isWall = false;\n      }\n    }\n    resetBFSState();\n    draw();\n    log('All walls cleared.');\n  });\n\n  speedInput.addEventListener('input', (e)=>{\n    speed = parseInt(e.target.value,10);\n  });\n\n  // Grid interactions\n  let isDragging = false;\n  let dragMakeWall = true;\n\n  function getMousePos(evt){\n    const rect = canvas.getBoundingClientRect();\n    const cell = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--cell-size')) || 20;\n    const x = Math.floor((evt.clientX - rect.left) / (rect.width / (cols))) ;\n    const y = Math.floor((evt.clientY - rect.top) / (rect.height / (rows)));\n    // clamp\n    return {\n      x: Math.max(0, Math.min(cols-1, x)),\n      y: Math.max(0, Math.min(rows-1, y))\n    };\n  }\n\n  canvas.addEventListener('pointerdown', (ev) => {\n    ev.preventDefault();\n    const pos = getMousePos(ev);\n    isDragging = true;\n    if (mode==='wall'){\n      const c = grid[pos.y][pos.x];\n      // do not toggle border walls or start/target\n      if (c.isStart || c.isTarget) return;\n      dragMakeWall = !c.isWall;\n      c.isWall = dragMakeWall;\n      resetBFSState();\n      draw();\n    } else if (mode==='start'){\n      // move start\n      const prev = getCell(start);\n      prev.isStart = false;\n      start = clampCoord(pos);\n      const nc = getCell(start);\n      nc.isStart = true;\n      // ensure start not on wall\n      nc.isWall = false;\n      resetBFSState();\n      draw();\n      log(`Start set to (${start.x},${start.y})`);\n    } else if (mode==='target'){\n      const prev = getCell(target);\n      prev.isTarget = false;\n      target = clampCoord(pos);\n      const nc = getCell(target);\n      nc.isTarget = true;\n      nc.isWall = false;\n      resetBFSState();\n      draw();\n      log(`Target set to (${target.x},${target.y})`);\n    }\n  });\n  window.addEventListener('pointerup', ()=> isDragging=false);\n  canvas.addEventListener('pointermove', (ev)=>{\n    if (!isDragging) return;\n    if (mode!=='wall') return;\n    const pos = getMousePos(ev);\n    const c = grid[pos.y][pos.x];\n    if (c.isStart || c.isTarget) return;\n    c.isWall = dragMakeWall;\n    resetBFSState();\n    draw();\n  });\n\n  // Size controls\n  document.getElementById('resize').addEventListener('click', ()=>{\n    const newCols = parseInt(document.getElementById('cols').value,10);\n    const newRows = parseInt(document.getElementById('rows').value,10);\n    // clamp start/target into new dims\n    start.x = Math.min(start.x, newCols-2);\n    start.y = Math.min(start.y, newRows-2);\n    target.x = Math.min(target.x, newCols-2);\n    target.y = Math.min(target.y, newRows-2);\n    initGrid(newCols,newRows);\n    log(`Grid resized to ${newCols} x ${newRows}`);\n  });\n\n  // Keyboard shortcuts\n  window.addEventListener('keydown', (e)=>{\n    if (e.key === ' ') { // space to start/pause\n      e.preventDefault();\n      if (!running) startBtn.click(); else pauseBtn.click();\n    } else if (e.key === 's') {\n      setMode('start');\n    } else if (e.key === 't') {\n      setMode('target');\n    } else if (e.key === 'w') {\n      setMode('wall');\n    } else if (e.key === 'r') {\n      randomWallsBtn.click();\n    } else if (e.key === 'c') {\n      clearWallsBtn.click();\n    }\n  });\n\n  // Responsiveness\n  window.addEventListener('resize', ()=>{\n    resizeCanvas();\n  });\n\n  // Initialize\n  initGrid(cols,rows);\n  log('Ready. Use the controls to create walls and run BFS.');\n})();\n</script>\n</body>\n</html>"
