    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Dynamic Programming Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #result {\n            margin-top: 20px;\n            font-size: 20px;\n            font-weight: bold;\n            color: green;\n        }\n    </style>\n</head>\n<body>\n    <h1>Dynamic Programming Demo: Fibonacci Sequence</h1>\n    <p>Calculate the nth Fibonacci number using Dynamic Programming</p>\n    <label for=\"numInput\">Enter a number (n): </label>\n    <input type=\"number\" id=\"numInput\" min=\"0\" value=\"0\">\n    <button onclick=\"calculateFibonacci()\">Calculate Fibonacci</button>\n    \n    <div id=\"result\"></div>\n\n    <script>\n        function calculateFibonacci() {\n            const n = parseInt(document.getElementById('numInput').value);\n            if (isNaN(n) || n < 0) {\n                document.getElementById('result').innerText = 'Please enter a non-negative integer.';\n                return;\n            }\n            \n            const fib = fibonacci(n);\n            document.getElementById('result').innerText = `Fibonacci(${n}) = ${fib}`;\n        }\n\n        function fibonacci(n) {\n            if (n === 0) return 0;\n            if (n === 1) return 1;\n            \n            const fibArray = new Array(n + 1);\n            fibArray[0] = 0;\n            fibArray[1] = 1;\n            \n            for (let i = 2; i <= n; i++) {\n                fibArray[i] = fibArray[i - 1] + fibArray[i - 2];\n            }\n            return fibArray[n];\n        }\n    </script>\n</body>\n</html>"
