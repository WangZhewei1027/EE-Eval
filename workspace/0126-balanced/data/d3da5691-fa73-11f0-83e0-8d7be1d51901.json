  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"/>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n<title>REST API Concept Demo (Single File)</title>\n<style>\n  :root { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; color: #222; }\n  body { margin: 0; display: flex; height: 100vh; gap: 12px; padding: 12px; box-sizing: border-box; background: #f5f7fb; }\n  header { font-weight: 700; padding: 8px 0; }\n  .panel { background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(20,30,50,0.08); padding: 12px; }\n  .left { width: 420px; display: flex; flex-direction: column; gap: 10px; }\n  .right { flex: 1; display:flex; flex-direction: column; gap: 10px; }\n  label { display:block; font-size: 13px; margin-bottom:6px; color:#444; }\n  input[type=\"text\"], input[type=\"number\"], select, textarea { width:100%; padding:8px; box-sizing:border-box; border-radius:6px; border:1px solid #d8e0ee; background:#fbfdff; }\n  button { padding:8px 10px; border-radius:6px; border: none; cursor:pointer; background:#2563eb; color:white; font-weight:600; }\n  button.ghost { background: #e6eefc; color:#184ea8; border:1px solid #dbeafe; }\n  .row { display:flex; gap:8px; }\n  .small { width: 120px; }\n  .log { height: 240px; overflow:auto; background:#0b1220; color:#cbd5e1; padding:10px; border-radius:6px; font-family: monospace; font-size:13px; }\n  pre { margin:0; font-family: monospace; font-size:13px; white-space: pre-wrap; }\n  .db { height: 200px; overflow:auto; background:#fff; border:1px dashed #e2e8f0; padding:8px; border-radius:6px; font-family:monospace; font-size:13px; }\n  .meta { font-size:12px; color:#586069; }\n  .controls { display:flex; gap:8px; flex-wrap:wrap; }\n  .section-title { font-weight:700; margin-bottom:6px; }\n  .status-200 { color:#16a34a; font-weight:700; }\n  .status-201 { color:#0ea5e9; font-weight:700; }\n  .status-204 { color:#64748b; font-weight:700; }\n  .status-4xx { color:#d9462f; font-weight:700; }\n  .status-5xx { color:#7c3aed; font-weight:700; }\n  footer { font-size:12px; color:#475569; margin-top:6px; }\n  .hint { font-size:13px; color:#334155; background:#f1f5f9; padding:8px; border-radius:6px; }\n</style>\n</head>\n<body>\n  <div class=\"left panel\">\n    <header>REST API Demo</header>\n    <div class=\"hint\">\n      This single-page demo simulates a REST API for a \"books\" resource. Use the controls below to send simulated HTTP requests (GET, POST, PUT, PATCH, DELETE). Responses, status codes, headers and the server database state are shown on the right.\n    </div>\n\n    <div>\n      <div class=\"section-title\">Create a Book (POST /books)</div>\n      <label>Title<input id=\"newTitle\" type=\"text\" placeholder=\"e.g. The Art of REST\"></label>\n      <label>Author<input id=\"newAuthor\" type=\"text\" placeholder=\"Author name\"></label>\n      <div class=\"row\">\n        <button id=\"btnCreate\">Create</button>\n        <button id=\"btnCreateSample\" class=\"ghost\">Create sample</button>\n        <button id=\"btnReset\" class=\"ghost\">Reset DB</button>\n      </div>\n    </div>\n\n    <hr/>\n\n    <div>\n      <div class=\"section-title\">Query / Read</div>\n      <label>Endpoint<select id=\"listMethod\"><option value=\"GET\">GET /books</option></select></label>\n      <label>Search (q)<input id=\"q\" type=\"text\" placeholder=\"title or author\"></label>\n      <div class=\"row\">\n        <input id=\"page\" type=\"number\" class=\"small\" min=\"1\" value=\"1\">\n        <input id=\"limit\" type=\"number\" class=\"small\" min=\"1\" value=\"5\">\n        <button id=\"btnList\">Send</button>\n      </div>\n\n      <hr/>\n\n      <div class=\"section-title\">Single Resource</div>\n      <label>ID <input id=\"singleId\" type=\"number\" min=\"1\" placeholder=\"book id\"></label>\n      <div class=\"row\">\n        <button id=\"btnGet\">GET</button>\n        <button id=\"btnDelete\" class=\"ghost\">DELETE</button>\n      </div>\n    </div>\n\n    <hr/>\n\n    <div>\n      <div class=\"section-title\">Update</div>\n      <label>ID <input id=\"updId\" type=\"number\" min=\"1\"></label>\n      <label>Title <input id=\"updTitle\" type=\"text\"></label>\n      <label>Author <input id=\"updAuthor\" type=\"text\"></label>\n      <div class=\"row\">\n        <button id=\"btnPut\">PUT (replace)</button>\n        <button id=\"btnPatch\" class=\"ghost\">PATCH (partial)</button>\n      </div>\n    </div>\n\n    <footer>\n      Principles shown: resources (URIs), verbs (GET/POST/PUT/PATCH/DELETE), status codes, stateless requests, HATEOAS links in responses.\n    </footer>\n  </div>\n\n  <div class=\"right\">\n    <div class=\"panel\" style=\"display:flex; gap:10px; align-items:flex-start;\">\n      <div style=\"flex:1\">\n        <div style=\"display:flex; justify-content:space-between; align-items:center;\">\n          <div><strong>Request & Response Log</strong> <span class=\"meta\">(click a request to re-run)</span></div>\n          <div class=\"meta\">Simulated latency: <span id=\"latencyDisplay\">300ms</span></div>\n        </div>\n        <div id=\"log\" class=\"log\" aria-live=\"polite\"></div>\n      </div>\n\n      <div style=\"width:380px\">\n        <div style=\"margin-bottom:10px;\"><strong>Server Database (in-memory)</strong></div>\n        <div class=\"db\" id=\"dbView\"></div>\n\n        <hr style=\"margin:8px 0\"/>\n\n        <div style=\"margin-top:8px;\"><strong>Last Response Details</strong></div>\n        <div id=\"lastResp\" style=\"margin-top:6px; font-family: monospace; font-size:13px; white-space:pre-wrap;\"></div>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <div style=\"display:flex; gap:8px; align-items:center;\">\n        <label class=\"meta\" style=\"margin:0\">Simulate errors</label>\n        <select id=\"errorMode\"><option value=\"none\">None</option><option value=\"server\">Random 500</option><option value=\"validation\">Validation error for empty title</option></select>\n        <label class=\"meta\" style=\"margin-left:auto\">Clear log <button id=\"btnClearLog\" class=\"ghost\">Clear</button></label>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\n  REST API Concept Demo (single file)\n  - Simulates an in-memory RESTful server for /books\n  - Provides a client that \"requests\" the API and displays request/response\n  - Demonstrates HTTP verbs, status codes, headers and HATEOAS links\n*/\n\n(() => {\n  // Utilities\n  const $ = id => document.getElementById(id);\n  const now = () => new Date().toISOString();\n\n  // Simple in-memory \"database\"\n  class InMemoryDB {\n    constructor() {\n      this.reset();\n    }\n    reset() {\n      this._nextId = 1;\n      this.books = [];\n      // seed with sample data\n      this.create({title: \"REST in Practice\", author: \"Jim Webber\"});\n      this.create({title: \"Designing Web APIs\", author: \"Brenda Jin\"});\n      this.create({title: \"HTTP: The Definitive Guide\", author: \"David Gourley\"});\n      this.create({title: \"The Art of Scalability\", author: \"Martin L. Abbott\"});\n      this.create({title: \"Refactoring\", author: \"Martin Fowler\"});\n    }\n    create(data) {\n      const book = {\n        id: this._nextId++,\n        title: data.title || \"Untitled\",\n        author: data.author || \"Unknown\",\n        createdAt: now()\n      };\n      this.books.push(book);\n      return book;\n    }\n    list({q, page=1, limit=10}={}) {\n      let items = this.books.slice();\n      if (q) {\n        const ql = q.toLowerCase();\n        items = items.filter(b => (b.title + \" \" + b.author).toLowerCase().includes(ql));\n      }\n      const total = items.length;\n      const start = (page-1)*limit;\n      const pageItems = items.slice(start, start+limit);\n      return {items: pageItems, total};\n    }\n    get(id) {\n      return this.books.find(b => b.id===id) || null;\n    }\n    replace(id, data) {\n      const idx = this.books.findIndex(b => b.id===id);\n      if (idx===-1) return null;\n      const book = { id, title: data.title || \"Untitled\", author: data.author || \"Unknown\", createdAt: this.books[idx].createdAt, updatedAt: now() };\n      this.books[idx] = book;\n      return book;\n    }\n    patch(id, data) {\n      const book = this.get(id);\n      if (!book) return null;\n      if (data.title !== undefined) book.title = data.title;\n      if (data.author !== undefined) book.author = data.author;\n      book.updatedAt = now();\n      return book;\n    }\n    remove(id) {\n      const idx = this.books.findIndex(b => b.id===id);\n      if (idx===-1) return false;\n      this.books.splice(idx,1);\n      return true;\n    }\n    toJSON() {\n      return { nextId: this._nextId, books: this.books.slice() };\n    }\n  }\n\n  // Fake REST server\n  class FakeServer {\n    constructor(db) {\n      this.db = db;\n    }\n\n    // Parse path like /books or /books/3\n    parsePath(path) {\n      const url = new URL(path, \"http://example\");\n      const parts = url.pathname.split('/').filter(Boolean);\n      return { url, parts, query: Object.fromEntries(url.searchParams.entries()) };\n    }\n\n    // Build HATEOAS links\n    bookLinks(book) {\n      return {\n        self: `/books/${book.id}`,\n        collection: `/books`,\n        update: `/books/${book.id}`,\n        delete: `/books/${book.id}`\n      };\n    }\n\n    async handle(method, path, {headers={}, body=null}={}, errorMode='none') {\n      // Simulated random server error if requested\n      if (errorMode === 'server' && Math.random() < 0.15) {\n        return this._resp(500, { error: \"Internal Server Error\" }, { 'Content-Type':'application/json' });\n      }\n\n      const {parts, query} = this.parsePath(path);\n\n      try {\n        // /books collection\n        if (parts.length === 1 && parts[0] === 'books') {\n          if (method === 'GET') {\n            const page = Math.max(1, parseInt(query.page||'1',10));\n            const limit = Math.max(1, parseInt(query.limit||'10',10));\n            const q = query.q || '';\n            const {items,total} = this.db.list({q,page,limit});\n            // Compose response with pagination and HATEOAS links\n            const meta = { page, limit, total };\n            const links = {\n              self: `/books?page=${page}&limit=${limit}`,\n            };\n            if ((page*limit) < total) links.next = `/books?page=${page+1}&limit=${limit}`;\n            if (page>1) links.prev = `/books?page=${page-1}&limit=${limit}`;\n            const data = items.map(b => ({...b, links:this.bookLinks(b)}));\n            return this._resp(200, { data, meta, links }, { 'Content-Type':'application/json' });\n          }\n\n          if (method === 'POST') {\n            // body is expected to be JSON\n            if (!body || typeof body.title !== 'string' || body.title.trim() === '') {\n              if (errorMode === 'validation') {\n                // simulate a validation error\n                return this._resp(422, { error: 'Validation failed', details: { title: 'Title is required' } }, { 'Content-Type':'application/json' });\n              } else {\n                return this._resp(400, { error: 'Bad Request: title required' }, { 'Content-Type':'application/json' });\n              }\n            }\n            const created = this.db.create({ title: body.title.trim(), author: (body.author||'').trim() || 'Unknown' });\n            const headersResp = { 'Location': `/books/${created.id}`, 'Content-Type': 'application/json' };\n            return this._resp(201, { data: {...created, links:this.bookLinks(created)} }, headersResp);\n          }\n        }\n\n        // /books/:id\n        if (parts.length === 2 && parts[0] === 'books') {\n          const id = parseInt(parts[1],10);\n          const book = this.db.get(id);\n          if (!book) return this._resp(404, { error: 'Not Found' }, { 'Content-Type':'application/json' });\n\n          if (method === 'GET') {\n            return this._resp(200, { data: {...book, links:this.bookLinks(book)} }, { 'Content-Type':'application/json' });\n          }\n\n          if (method === 'PUT') {\n            if (!body || typeof body.title !== 'string') return this._resp(400, { error: 'Bad Request: title required' }, { 'Content-Type':'application/json' });\n            const replaced = this.db.replace(id, { title: body.title.trim(), author: (body.author||'').trim() || 'Unknown' });\n            return this._resp(200, { data: {...replaced, links:this.bookLinks(replaced)} }, { 'Content-Type':'application/json' });\n          }\n\n          if (method === 'PATCH') {\n            const patched = this.db.patch(id, body||{});\n            return this._resp(200, { data: {...patched, links:this.bookLinks(patched)} }, { 'Content-Type':'application/json' });\n          }\n\n          if (method === 'DELETE') {\n            const ok = this.db.remove(id);\n            if (!ok) return this._resp(404, { error: 'Not Found' }, { 'Content-Type':'application/json' });\n            return this._resp(204, null, {}); // No Content\n          }\n        }\n\n        // Not found\n        return this._resp(404, { error: 'Not Found' }, { 'Content-Type':'application/json' });\n\n      } catch (err) {\n        // unexpected\n        return this._resp(500, { error: 'Server Error', message: String(err) }, { 'Content-Type':'application/json' });\n      }\n    }\n\n    _resp(status, body, headers={}) {\n      // Return a Response-like object promise\n      return {\n        status,\n        headers,\n        json: async () => body,\n        text: async () => (typeof body === 'string' ? body : JSON.stringify(body, null, 2))\n      };\n    }\n  }\n\n  // Client wrapper that \"fetches\" from fake server (simulates network)\n  class ApiClient {\n    constructor(server, options={latency:300, errorMode:'none'}) {\n      this.server = server;\n      this.latency = options.latency || 300;\n      this.errorMode = options.errorMode || 'none';\n      this.history = [];\n    }\n\n    async request(method, path, { headers={}, body=null }={}) {\n      const req = { method, path, headers, body, time: new Date().toISOString() };\n      // simulate network latency\n      await new Promise(r => setTimeout(r, this.latency * (0.7 + Math.random()*0.6)));\n      const response = await this.server.handle(method, path, { headers, body }, this.errorMode);\n\n      const entry = { req, res: { status: response.status, headers: response.headers, body: await response.json() }, receivedAt: new Date().toISOString() };\n      this.history.unshift(entry);\n      return entry;\n    }\n  }\n\n  // Instantiate DB and server\n  const db = new InMemoryDB();\n  const server = new FakeServer(db);\n  const client = new ApiClient(server, { latency: 300, errorMode: 'none' });\n\n  // UI helpers\n  const logEl = $('log');\n  const dbView = $('dbView');\n  const lastResp = $('lastResp');\n  const latencyDisplay = $('latencyDisplay');\n\n  function renderDB() {\n    dbView.textContent = JSON.stringify(db.toJSON(), null, 2);\n  }\n\n  function appendLog(entry) {\n    // clickable entry to re-run\n    const div = document.createElement('div');\n    div.style.cursor = 'pointer';\n    div.style.marginBottom = '10px';\n    div.innerHTML = `<div style=\"color:#9aa6b2;font-size:12px\">${entry.req.time} · ${entry.req.method} ${entry.req.path}</div>\n      <pre style=\"margin:6px 0 0 0; color:#e6eefc\">${JSON.stringify(entry.req.body || {}, null, 2)}</pre>\n      <div style=\"margin-top:6px; font-size:13px;\"><span style=\"color:${statusColor(entry.res.status)};font-weight:700\">HTTP ${entry.res.status}</span> · ${entry.receivedAt}</div>\n      <pre style=\"margin-top:6px\">${JSON.stringify(entry.res.body, null, 2)}</pre>`;\n    // re-run on click\n    div.addEventListener('click', async () => {\n      await runRequest(entry.req.method, entry.req.path, entry.req.body);\n    });\n    logEl.prepend(div);\n  }\n\n  function statusColor(status) {\n    if (status >= 500) return '#7c3aed';\n    if (status >= 400) return '#d9462f';\n    if (status === 204) return '#64748b';\n    if (status === 201) return '#0ea5e9';\n    return '#16a34a';\n  }\n\n  async function runRequest(method, path, body=null) {\n    // Update latency and errorMode from UI\n    client.latency = Math.max(20, parseInt($('latencyInput')?.value || client.latency, 10)) || client.latency;\n    client.errorMode = $('errorMode').value;\n    latencyDisplay.textContent = client.latency + 'ms';\n\n    // Log a minimal \"request\" entry\n    const entry = await client.request(method, path, { body });\n    appendLog(entry);\n    renderDB();\n    renderLastResponse(entry);\n  }\n\n  function renderLastResponse(entry) {\n    if (!entry) { lastResp.textContent = ''; return; }\n    const {req,res} = entry;\n    const h = [];\n    h.push(`REQUEST: ${req.method} ${req.path}`);\n    h.push(`Sent: ${req.time}`);\n    h.push('');\n    h.push('Request body:');\n    h.push(JSON.stringify(req.body || {}, null, 2));\n    h.push('');\n    h.push(`RESPONSE: HTTP ${res.status}`);\n    h.push('');\n    h.push('Response body:');\n    h.push(JSON.stringify(res.body, null, 2));\n    lastResp.textContent = h.join('\\n');\n  }\n\n  // Wire up UI\n  function initUI() {\n    renderDB();\n\n    // Create\n    $('btnCreate').addEventListener('click', async () => {\n      const title = $('newTitle').value.trim();\n      const author = $('newAuthor').value.trim();\n      await runRequest('POST', '/books', { title, author });\n      $('newTitle').value = '';\n      $('newAuthor').value = '';\n    });\n\n    $('btnCreateSample').addEventListener('click', async () => {\n      const samples = [\n        {title: \"Clean Architecture\", author: \"Robert C. Martin\"},\n        {title: \"You Don't Know JS\", author: \"Kyle Simpson\"},\n        {title: \"Practical API Design\", author: \"Kunal\"}\n      ];\n      const s = samples[Math.floor(Math.random()*samples.length)];\n      await runRequest('POST', '/books', s);\n    });\n\n    $('btnReset').addEventListener('click', () => {\n      db.reset();\n      renderDB();\n      logEl.innerHTML = '';\n      lastResp.textContent = '';\n    });\n\n    // List / query\n    $('btnList').addEventListener('click', async () => {\n      const q = $('q').value.trim();\n      const page = Math.max(1, parseInt($('page').value||'1',10));\n      const limit = Math.max(1, parseInt($('limit').value||'5',10));\n      const path = `/books?page=${page}&limit=${limit}` + (q ? `&q=${encodeURIComponent(q)}` : '');\n      await runRequest('GET', path, null);\n    });\n\n    // Single GET / DELETE\n    $('btnGet').addEventListener('click', async () => {\n      const id = parseInt($('singleId').value,10);\n      if (!id) return alert('Enter id');\n      await runRequest('GET', `/books/${id}`, null);\n    });\n    $('btnDelete').addEventListener('click', async () => {\n      const id = parseInt($('singleId').value,10);\n      if (!id) return alert('Enter id');\n      if (!confirm('DELETE /books/' + id + ' ?')) return;\n      await runRequest('DELETE', `/books/${id}`, null);\n    });\n\n    // Update\n    $('btnPut').addEventListener('click', async () => {\n      const id = parseInt($('updId').value,10);\n      if (!id) return alert('Enter id');\n      const title = $('updTitle').value.trim();\n      const author = $('updAuthor').value.trim();\n      await runRequest('PUT', `/books/${id}`, { title, author });\n    });\n    $('btnPatch').addEventListener('click', async () => {\n      const id = parseInt($('updId').value,10);\n      if (!id) return alert('Enter id');\n      const payload = {};\n      if ($('updTitle').value.trim()) payload.title = $('updTitle').value.trim();\n      if ($('updAuthor').value.trim()) payload.author = $('updAuthor').value.trim();\n      if (Object.keys(payload).length === 0) return alert('Fill at least one field to PATCH');\n      await runRequest('PATCH', `/books/${id}`, payload);\n    });\n\n    // Error mode\n    $('errorMode').addEventListener('change', () => {\n      client.errorMode = $('errorMode').value;\n    });\n\n    // Clear log\n    $('btnClearLog').addEventListener('click', () => {\n      logEl.innerHTML = '';\n    });\n\n    // Keyboard shortcuts for convenience\n    document.addEventListener('keydown', (e) => {\n      if (e.ctrlKey && e.key === 'Enter') {\n        $('btnList').click();\n      }\n    });\n\n    // Add a small latency control (not visible as input by default) - but we show value\n    // We'll add a hidden input to tweak latency with the console in dev mode:\n    const latInput = document.createElement('input');\n    latInput.type = 'number';\n    latInput.id = 'latencyInput';\n    latInput.value = client.latency;\n    latInput.min = 20;\n    latInput.style.display = 'none';\n    document.body.appendChild(latInput);\n  }\n\n  initUI();\n  // initial list to show current data\n  (async () => {\n    await runRequest('GET', '/books?page=1&limit=5', null);\n  })();\n\n})();\n</script>\n</body>\n</html>"
  },
