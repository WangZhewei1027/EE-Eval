    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Hash Map Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            width: 50%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .map-container {\n            width: 80%;\n            margin: 0 auto;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Hash Map Demo</h1>\n        <div class=\"map-container\">\n            <canvas id=\"hash-map\"></canvas>\n        </div>\n    </div>\n\n    <script>\n        const canvas = document.getElementById('hash-map');\n        const ctx = canvas.getContext('2d');\n        const mapData = {\n            '0,0': '#ff0000',\n            '0,1': '#00ff00',\n            '0,2': '#0000ff',\n            '1,0': '#ffff00',\n            '1,1': '#ff00ff',\n            '1,2': '#00ffff',\n            '2,0': '#ffff00',\n            '2,1': '#ff00ff',\n            '2,2': '#0000ff'\n        };\n\n        const hashMap = new Map();\n        let points = [];\n\n        function drawMap() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            for (let [key, value] of Object.entries(mapData)) {\n                const [x, y] = key.split(',').map(Number);\n                ctx.fillStyle = value;\n                ctx.beginPath();\n                ctx.arc(x, y, 10, 0, 2 * Math.PI);\n                ctx.fill();\n            }\n        }\n\n        function addPoint(x, y) {\n            points.push([x, y]);\n            hashMap.set(`${x},${y}`, `Point ${points.length}`);\n        }\n\n        function removePoint(x, y) {\n            const pointIndex = points.findIndex(([pX, pY]) => pX === x && pY === y);\n            if (pointIndex !== -1) {\n                points.splice(pointIndex, 1);\n                hashMap.delete(`${x},${y}`);\n            }\n        }\n\n        canvas.addEventListener('click', (e) => {\n            if (e.target.classList.contains('point')) {\n                const [x, y] = e.target.getAttribute('data-x').split(',').map(Number);\n                addPoint(x, y);\n            } else if (e.target.classList.contains('point')) {\n                const [x, y] = e.target.getAttribute('data-x').split(',').map(Number);\n                removePoint(x, y);\n            }\n        });\n\n        drawMap();\n    </script>\n</body>\n</html>"
