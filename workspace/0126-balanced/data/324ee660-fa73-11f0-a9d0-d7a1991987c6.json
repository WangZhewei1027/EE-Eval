    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Relational Database Example</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 20px;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n        }\n        th {\n            background-color: #f2f2f2;\n        }\n        h2 {\n            color: #333;\n        }\n    </style>\n</head>\n<body>\n\n<h2>Relational Database Example</h2>\n\n<div>\n    <h3>Customers</h3>\n    <table id=\"customersTable\">\n        <thead>\n            <tr>\n                <th>ID</th>\n                <th>Name</th>\n                <th>Email</th>\n            </tr>\n        </thead>\n        <tbody></tbody>\n    </table>\n</div>\n\n<div>\n    <h3>Orders</h3>\n    <table id=\"ordersTable\">\n        <thead>\n            <tr>\n                <th>Order ID</th>\n                <th>Customer ID</th>\n                <th>Product</th>\n                <th>Quantity</th>\n            </tr>\n        </thead>\n        <tbody></tbody>\n    </table>\n</div>\n\n<script>\n    // Sample Data\n    const customers = [\n        { id: 1, name: \"Alice Smith\", email: \"alice@example.com\" },\n        { id: 2, name: \"Bob Johnson\", email: \"bob@example.com\" },\n        { id: 3, name: \"Charlie Brown\", email: \"charlie@example.com\" }\n    ];\n\n    const orders = [\n        { orderId: 101, customerId: 1, product: \"Laptop\", quantity: 1 },\n        { orderId: 102, customerId: 1, product: \"Mouse\", quantity: 2 },\n        { orderId: 103, customerId: 2, product: \"Keyboard\", quantity: 1 },\n        { orderId: 104, customerId: 3, product: \"Monitor\", quantity: 1 },\n        { orderId: 105, customerId: 2, product: \"USB Cable\", quantity: 5 }\n    ];\n\n    // Function to populate customers table\n    function populateCustomersTable() {\n        const customersTableBody = document.getElementById('customersTable').getElementsByTagName('tbody')[0];\n        customers.forEach(customer => {\n            const row = customersTableBody.insertRow();\n            row.insertCell(0).innerText = customer.id;\n            row.insertCell(1).innerText = customer.name;\n            row.insertCell(2).innerText = customer.email;\n        });\n    }\n\n    // Function to populate orders table\n    function populateOrdersTable() {\n        const ordersTableBody = document.getElementById('ordersTable').getElementsByTagName('tbody')[0];\n        orders.forEach(order => {\n            const row = ordersTableBody.insertRow();\n            row.insertCell(0).innerText = order.orderId;\n            row.insertCell(1).innerText = order.customerId;\n            row.insertCell(2).innerText = order.product;\n            row.insertCell(3).innerText = order.quantity;\n        });\n    }\n\n    // Executing functions to populate tables on page load\n    window.onload = () => {\n        populateCustomersTable();\n        populateOrdersTable();\n    };\n</script>\n\n</body>\n</html>"
