    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>B+ Tree Visualization and Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 1em;\n      background-color: #f9f9f9;\n    }\n    h1 {\n      text-align: center;\n      margin-bottom: 0.2em;\n    }\n    #container {\n      max-width: 900px;\n      margin: auto;\n    }\n    #controls {\n      margin: 1em 0;\n      display: flex;\n      gap: 1em;\n      flex-wrap: wrap;\n      justify-content: center;\n    }\n    input[type=number] {\n      width: 80px;\n      padding: 0.3em 0.5em;\n      font-size: 1em;\n    }\n    button {\n      padding: 0.4em 1em;\n      font-size: 1em;\n      cursor: pointer;\n      border-radius: 4px;\n      border: 1px solid #007acc;\n      background-color: #007acc;\n      color: white;\n      transition: background-color 0.3s;\n    }\n    button:hover {\n      background-color: #005a9e;\n    }\n    #message {\n      text-align: center;\n      min-height: 1.2em;\n      margin-bottom: 1em;\n      font-weight: bold;\n      color: #007acc;\n    }\n    #tree {\n      overflow-x: auto;\n      background-color: white;\n      border: 1px solid #ddd;\n      border-radius: 6px;\n      padding: 1em;\n      font-family: monospace;\n      white-space: pre;\n      box-shadow: 0 0 10px rgba(0,0,0,0.05);\n    }\n    .legend {\n      margin-top: 1em;\n      font-size: 0.9em;\n      color: #555;\n      text-align: center;\n    }\n    footer {\n      margin-top: 3em;\n      text-align: center;\n      font-size: 0.8em;\n      color: #888;\n    }\n  </style>\n</head>\n<body>\n  <div id=\"container\">\n    <h1>B+ Tree Demo & Visualization</h1>\n    <div class=\"legend\">\n      <div><strong>Note:</strong> This demo uses a B+ Tree of order <span id=\"orderDisplay\">3</span> (max 2 keys per node).</div>\n      <div>Internal nodes show keys; leaf nodes show keys and are linked (linked list shown by arrows).</div>\n    </div>\n    <div id=\"controls\">\n      <input type=\"number\" id=\"inputKey\" placeholder=\"Key (int)\" />\n      <button id=\"insertBtn\">Insert</button>\n      <button id=\"searchBtn\">Search</button>\n      <button id=\"resetBtn\" title=\"Reset Tree\">Reset</button>\n    </div>\n    <div id=\"message\"></div>\n    <pre id=\"tree\" aria-live=\"polite\" aria-label=\"B+ Tree visualization\"></pre>\n  </div>\n  <footer>By ChatGPT - B+ Tree Interactive Demo</footer>\n\n  <script>\n  /*\n   B+ Tree implementation and visualization.\n   Order defines max number of children in internal nodes: order = 3 means max 3 children and 2 keys.\n   Leaf nodes hold up to order - 1 keys.\n  */\n\n  class BPlusNode {\n    constructor(isLeaf = false) {\n      this.isLeaf = isLeaf;\n      this.keys = [];\n      this.children = []; // internal nodes: children nodes; leaves: values / references (we store keys only)\n      this.next = null;  // leaf pointer to next leaf (for linked list)\n    }\n  }\n\n  class BPlusTree {\n    constructor(order = 3) {\n      this.order = order;\n      this.root = new BPlusNode(true);\n    }\n\n    // Search for a key and return {found: bool, node, index}\n    search(key) {\n      let cur = this.root;\n      while (!cur.isLeaf) {\n        let i = 0;\n        while (i < cur.keys.length && key >= cur.keys[i]) i++;\n        cur = cur.children[i];\n      }\n      let idx = cur.keys.indexOf(key);\n      return { found: idx !== -1, node: cur, index: idx };\n    }\n\n    // Insert a key into the tree\n    insert(key) {\n      if (typeof key !== 'number' || !Number.isInteger(key)) {\n        throw new Error('Only integer keys are supported.');\n      }\n      // Avoid duplicates for this demo\n      const searchRes = this.search(key);\n      if(searchRes.found){\n        return false; // duplicate, no insert\n      }\n      const root = this.root;\n      const splitInfo = this._insertNonFull(root, key);\n      if (splitInfo) {\n        // root split - create new root\n        const newRoot = new BPlusNode(false);\n        newRoot.keys = [splitInfo.key];\n        newRoot.children = [root, splitInfo.rightNode];\n        this.root = newRoot;\n      }\n      return true;\n    }\n\n    _insertNonFull(node, key) {\n      if (node.isLeaf) {\n        // Insert the key in sorted order in leaf node\n        let pos = 0;\n        while (pos < node.keys.length && node.keys[pos] < key) pos++;\n        node.keys.splice(pos, 0, key);\n\n        // Check if overflow\n        if (node.keys.length >= this.order) {\n          // Split leaf node\n          const rightNode = new BPlusNode(true);\n          const mid = Math.floor(this.order / 2);\n          rightNode.keys = node.keys.splice(mid);\n          // Fix leaf linked list pointers\n          rightNode.next = node.next;\n          node.next = rightNode;\n\n          // Promote first key of right node\n          const promoteKey = rightNode.keys[0];\n          return { key: promoteKey, rightNode };\n        }\n        return null;\n      } else {\n        // internal node\n        // find index of child for insert\n        let pos = 0;\n        while (pos < node.keys.length && key >= node.keys[pos]) pos++;\n\n        // recurse\n        const splitInfo = this._insertNonFull(node.children[pos], key);\n\n        if (splitInfo) {\n          // insert promoted key in node\n          let insertPos = 0;\n          while (insertPos < node.keys.length && node.keys[insertPos] < splitInfo.key) insertPos++;\n          node.keys.splice(insertPos, 0, splitInfo.key);\n          node.children.splice(insertPos + 1, 0, splitInfo.rightNode);\n\n          // Check overflow\n          if (node.keys.length >= this.order) {\n            // split internal node\n            const rightNode = new BPlusNode(false);\n            const mid = Math.floor(this.order / 2);\n            const promoteKey = node.keys[mid];\n\n            // keys and children for right node\n            rightNode.keys = node.keys.splice(mid + 1);\n            rightNode.children = node.children.splice(mid + 1);\n\n            // Remove promoteKey from left node keys\n            node.keys.splice(mid, 1);\n\n            return { key: promoteKey, rightNode };\n          }\n        }\n        return null;\n      }\n    }\n\n    // For visualization: return levels of the tree\n    getLevels() {\n      if (!this.root) return [];\n      const levels = [];\n      let currentLevel = [this.root];\n      while (currentLevel.length > 0) {\n        levels.push(currentLevel);\n        const nextLevel = [];\n        for (const node of currentLevel) {\n          if (!node.isLeaf) {\n            for (const child of node.children) {\n              nextLevel.push(child);\n            }\n          }\n        }\n        if (nextLevel.length === 0) break;\n        currentLevel = nextLevel;\n      }\n      return levels;\n    }\n\n    // For visualization: returns all leaf nodes in linked list order\n    getLeaves() {\n      let leaves = [];\n      let node = this.root;\n      // First go to leftmost leaf\n      while (!node.isLeaf) node = node.children[0];\n      while (node) {\n        leaves.push(node);\n        node = node.next;\n      }\n      return leaves;\n    }\n\n  }\n\n  // Rendering logic - plain text visualization\n\n  function renderBPlusTree(tree) {\n    let output = '';\n    const levels = tree.getLevels();\n\n    // For each level, show nodes left to right\n    // Show keys in [ ] brackets for internal nodes\n    // Show leaf keys with arrows to next leaf\n    // We will print level by level, indenting for clarity\n    levels.forEach((level, lvlIndex) => {\n      let line = '';\n      line += `Level ${lvlIndex} (${level[0].isLeaf ? 'Leaves' : 'Internal'} nodes) : \\n`;\n\n      // Each node in level\n      const nodeStrs = level.map((node, i) => {\n        if (node.isLeaf) {\n          return '[' + node.keys.join('|') + ']';\n        } else {\n          return '(' + node.keys.join(',') + ')';\n        }\n      });\n      line += nodeStrs.join('    ') + '\\n\\n';\n      output += line;\n    });\n\n    // Show leaf linkage:\n    const leaves = tree.getLeaves();\n    output += 'Leaf node linked list:\\n';\n    output += leaves.map(leaf => '[' + leaf.keys.join('|') + ']').join(' -> ') + '\\n';\n\n    return output;\n  }\n\n  // UI and interaction\n\n  const order = 3; // You can adjust order here for the demo\n  document.getElementById('orderDisplay').textContent = order;\n\n  const tree = new BPlusTree(order);\n\n  const inputKey = document.getElementById('inputKey');\n  const insertBtn = document.getElementById('insertBtn');\n  const searchBtn = document.getElementById('searchBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const treeOutput = document.getElementById('tree');\n  const message = document.getElementById('message');\n\n  function updateView(msg='') {\n    treeOutput.textContent = renderBPlusTree(tree);\n    message.textContent = msg;\n  }\n\n  insertBtn.addEventListener('click', () => {\n    const val = parseInt(inputKey.value);\n    if (isNaN(val)) {\n      message.textContent = 'Please enter a valid integer key.';\n      return;\n    }\n    const inserted = tree.insert(val);\n    if (!inserted) {\n      message.textContent = `Key ${val} already exists, duplicate insert ignored.`;\n    } else {\n      message.textContent = `Inserted key ${val}.`;\n    }\n    updateView(message.textContent);\n    inputKey.value = '';\n    inputKey.focus();\n  });\n\n  searchBtn.addEventListener('click', () => {\n    const val = parseInt(inputKey.value);\n    if (isNaN(val)) {\n      message.textContent = 'Please enter a valid integer key to search.';\n      return;\n    }\n    const result = tree.search(val);\n    if (result.found) {\n      message.textContent = `Key ${val} found in leaf node.`;\n    } else {\n      message.textContent = `Key ${val} NOT found in the tree.`;\n    }\n    updateView(message.textContent);\n    inputKey.value = '';\n    inputKey.focus();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    // Reset the tree\n    tree.root = new BPlusNode(true);\n    message.textContent = 'Tree has been reset.';\n    updateView();\n    inputKey.value = '';\n    inputKey.focus();\n  });\n\n  // Initial view\n  updateView('Empty B+ Tree ready.');\n\n  </script>\n</body>\n</html>"
  },
