    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Decision Trees Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n        h1 {\n            text-align: center;\n        }\n        .decision-tree {\n            text-align: center;\n            margin: 20px;\n            padding: 20px;\n            border: 2px solid #007BFF;\n            background-color: #fff;\n            border-radius: 8px;\n        }\n        .node {\n            margin: 20px;\n        }\n        .node > div {\n            padding: 10px;\n            border: 2px solid #007BFF;\n            border-radius: 6px;\n            display: inline-block;\n        }\n        .child {\n            margin-left: 50px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Decision Trees Demo</h1>\n<div class=\"decision-tree\" id=\"treeContainer\">\n    <div class=\"node\">\n        <div onclick=\"showChildren('A')\" id=\"A\">Is it raining?</div>\n    </div>\n</div>\n\n<script>\n    const treeData = {\n        A: {\n            yes: {\n                question: \"Is it cold?\",\n                yes: \"Take an umbrella and wear a coat.\",\n                no: \"Take an umbrella.\"\n            },\n            no: {\n                question: \"Is it hot?\",\n                yes: \"Wear sunglasses.\",\n                no: \"Enjoy your day.\"\n            }\n        }\n    };\n\n    const showChildren = (node) => {\n        const container = document.getElementById('treeContainer');\n        container.innerHTML = ''; // Clear the current content\n\n        const children = treeData[node];\n\n        if (children) {\n            const questionDiv = document.createElement('div');\n            questionDiv.className = 'node';\n            questionDiv.innerHTML = children.question;\n\n            const yesButton = document.createElement('div');\n            yesButton.innerHTML = 'Yes';\n            yesButton.onclick = () => showResult(children.yes);\n            questionDiv.appendChild(yesButton);\n\n            const noButton = document.createElement('div');\n            noButton.innerHTML = 'No';\n            noButton.onclick = () => showResult(children.no);\n            questionDiv.appendChild(noButton);\n\n            container.appendChild(questionDiv);\n        }\n    };\n\n    const showResult = (result) => {\n        const container = document.getElementById('treeContainer');\n        container.innerHTML = `<div class=\"node\"><strong>Result:</strong> ${result}</div>`;\n        \n        // Optionally, you could add navigation back to restart the question flow\n        const backButton = document.createElement('div');\n        backButton.innerHTML = 'Restart';\n        backButton.onclick = () => {\n            container.innerHTML = `\n                <div class=\"node\">\n                    <div onclick=\"showChildren('A')\" id=\"A\">Is it raining?</div>\n                </div>`;\n        };\n        container.appendChild(backButton);\n    };\n\n    // Initialize the decision tree on page load\n    window.onload = () => {\n        showChildren('A');\n    };\n</script>\n\n</body>\n</html>"
