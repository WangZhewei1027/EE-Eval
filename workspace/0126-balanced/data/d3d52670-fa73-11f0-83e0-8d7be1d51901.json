  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>JavaScript Set — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 20px; color: #111; }\n    h1 { margin: 0 0 8px 0; font-size: 22px; }\n    p.lead { margin: 0 0 18px 0; color: #444; }\n    .panel { border: 1px solid #ddd; border-radius: 8px; padding: 12px; margin-bottom: 14px; background: #fafafa; }\n    label { display:inline-block; margin-right: 8px; }\n    input[type=\"text\"] { padding: 6px 8px; width: 220px; margin-right: 8px; }\n    button { padding: 6px 10px; margin-right: 6px; cursor: pointer; }\n    .small { font-size: 13px; color: #555; }\n    .row { display:flex; gap:12px; align-items:center; flex-wrap:wrap; }\n    .members { margin-top: 10px; }\n    .member { padding: 6px 8px; border-radius: 6px; background: #fff; border: 1px solid #e6e6e6; margin: 6px 6px 0 0; display:inline-flex; gap:8px; align-items:center; }\n    .badge { font-size: 12px; color:#666; background:#eee; padding:2px 6px; border-radius:999px; }\n    pre { background:#111; color:#eee; padding:10px; border-radius:6px; overflow:auto; }\n    .log { max-height: 160px; overflow:auto; background:#fff; padding:10px; border-radius:6px; border:1px solid #eee; }\n    .examples button { margin-top:6px; }\n    footer { margin-top: 18px; font-size:13px; color:#666; }\n    .inline { display:inline-flex; gap:8px; align-items:center; }\n  </style>\n</head>\n<body>\n  <h1>JavaScript Set — Interactive Demo</h1>\n  <p class=\"lead\">Explore how ES6 Set works: add/remove/check values, uniqueness, iteration, and set operations (union / intersection / difference).</p>\n\n  <div class=\"panel\">\n    <div class=\"row\">\n      <label for=\"inputValue\">Value</label>\n      <input id=\"inputValue\" type=\"text\" placeholder='e.g. hello, 42, true, {\"a\":1}'>\n      <label class=\"small inline\"><input id=\"typeSelect\" type=\"radio\" name=\"type\" checked> string</label>\n      <label class=\"small inline\"><input id=\"asNumber\" type=\"radio\" name=\"type\"> number</label>\n      <label class=\"small inline\"><input id=\"asJSON\" type=\"radio\" name=\"type\"> JSON (object)</label>\n      <button id=\"addBtn\">Add to Set</button>\n      <button id=\"deleteBtn\">Delete</button>\n      <button id=\"hasBtn\">Has?</button>\n      <button id=\"clearBtn\">Clear Set</button>\n    </div>\n    <div style=\"margin-top:10px;\" class=\"row\">\n      <button id=\"addSameObjectBtn\">Add same object twice (show reference identity)</button>\n      <button id=\"fromArrayBtn\">Create Set from array (dedupe)</button>\n      <button id=\"toArrayBtn\">Set → Array</button>\n      <button id=\"copyArrayBtn\">Copy array to clipboard</button>\n    </div>\n\n    <div class=\"members\" id=\"setDisplay\"></div>\n\n    <div style=\"margin-top:10px;\">\n      <span class=\"badge\">Size: <b id=\"size\">0</b></span>\n      <span style=\"margin-left:12px;\" class=\"small\">Iteration order is insertion order for Set.</span>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <h3 style=\"margin:0 0 8px 0;\">Set Operations (examples)</h3>\n    <div class=\"examples\">\n      <div class=\"row\">\n        <button id=\"unionExample\">Union</button>\n        <button id=\"intersectionExample\">Intersection</button>\n        <button id=\"differenceExample\">Difference (A \\\\ B)</button>\n      </div>\n      <div style=\"margin-top:10px;\" class=\"small\">Examples use A = [1,2,3,4], B = [3,4,5,6]. Results shown below.</div>\n      <pre id=\"opsResult\">Run an operation...</pre>\n    </div>\n  </div>\n\n  <div class=\"panel\">\n    <h3 style=\"margin:0 0 8px 0;\">Live log / output</h3>\n    <div class=\"log\" id=\"log\"></div>\n  </div>\n\n  <footer>\n    Quick facts: Set stores unique values (SameValueZero equality). Objects are unique by reference, primitives by value. WeakSet exists for object-only weak references (not covered interactively here).\n  </footer>\n\n  <script>\n    // Single Set used for the demo\n    const demoSet = new Set();\n    const setDisplay = document.getElementById('setDisplay');\n    const sizeEl = document.getElementById('size');\n    const logEl = document.getElementById('log');\n\n    function log(...args) {\n      const line = document.createElement('div');\n      line.textContent = args.map(formatForLog).join(' ');\n      logEl.prepend(line);\n    }\n\n    function formatForLog(v) {\n      if (typeof v === 'string') return v;\n      try { return JSON.stringify(v); } catch (e) { return String(v); }\n    }\n\n    function displaySet() {\n      setDisplay.innerHTML = '';\n      let index = 0;\n      for (const v of demoSet) {\n        const item = document.createElement('span');\n        item.className = 'member';\n        const type = typeof v;\n        let labelText;\n        if (v && typeof v === 'object') {\n          // show a concise object representation and an internal id if present\n          labelText = JSON.stringify(v);\n        } else if (typeof v === 'symbol') {\n          labelText = v.toString();\n        } else {\n          labelText = String(v);\n        }\n        item.innerHTML = `<strong>#${index}</strong>&nbsp;<span style=\"font-family:monospace\">${escapeHtml(labelText)}</span>&nbsp;<span class=\"badge\">${escapeHtml(type)}</span>`;\n        setDisplay.appendChild(item);\n        index++;\n      }\n      sizeEl.textContent = demoSet.size;\n    }\n\n    function escapeHtml(s) {\n      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\n    }\n\n    function parseInput() {\n      const raw = document.getElementById('inputValue').value;\n      const asNumber = document.getElementById('asNumber').checked;\n      const asJSON = document.getElementById('asJSON').checked;\n\n      if (asJSON) {\n        try {\n          return JSON.parse(raw);\n        } catch (e) {\n          alert('Invalid JSON; please enter valid JSON for object creation (e.g. {\"a\":1}).');\n          throw e;\n        }\n      }\n      if (asNumber) {\n        const n = Number(raw);\n        if (Number.isNaN(n)) {\n          alert('Value cannot be converted to Number.');\n          throw new Error('Invalid number');\n        }\n        return n;\n      }\n      // default string\n      return String(raw);\n    }\n\n    // Buttons\n    document.getElementById('addBtn').addEventListener('click', () => {\n      try {\n        const v = parseInput();\n        demoSet.add(v);\n        log('add', v);\n        displaySet();\n      } catch {}\n    });\n\n    document.getElementById('deleteBtn').addEventListener('click', () => {\n      try {\n        const v = parseInput();\n        const removed = demoSet.delete(v);\n        log('delete', v, '=>', removed);\n        displaySet();\n      } catch {}\n    });\n\n    document.getElementById('hasBtn').addEventListener('click', () => {\n      try {\n        const v = parseInput();\n        const exists = demoSet.has(v);\n        log('has', v, '=>', exists);\n      } catch {}\n    });\n\n    document.getElementById('clearBtn').addEventListener('click', () => {\n      demoSet.clear();\n      log('clear set');\n      displaySet();\n    });\n\n    // Add same object twice to demonstrate reference equality\n    document.getElementById('addSameObjectBtn').addEventListener('click', () => {\n      // two objects with same content but different references\n      const objA = { x: 1, createdAt: Date.now() };\n      const objB = { x: 1, createdAt: objA.createdAt }; // same content but different object\n      demoSet.add(objA);\n      demoSet.add(objB);\n      log('added two distinct objects with same content:', objA, objB);\n      displaySet();\n    });\n\n    // Create set from array (dedupe)\n    document.getElementById('fromArrayBtn').addEventListener('click', () => {\n      const arr = [1,2,3,2,3,4,'a','a','b',NaN,NaN];\n      const s = new Set(arr);\n      // show result in log and replace demoSet contents with this example\n      demoSet.clear();\n      for (const v of s) demoSet.add(v);\n      log('fromArray (dedupe):', arr, '=>', Array.from(s));\n      displaySet();\n    });\n\n    // Set -> Array\n    document.getElementById('toArrayBtn').addEventListener('click', () => {\n      const arr = Array.from(demoSet);\n      log('set to array:', arr);\n      document.getElementById('opsResult').textContent = 'Set → Array: ' + JSON.stringify(arr);\n    });\n\n    // Clipboard copy\n    document.getElementById('copyArrayBtn').addEventListener('click', async () => {\n      try {\n        const arr = JSON.stringify(Array.from(demoSet));\n        await navigator.clipboard.writeText(arr);\n        log('copied to clipboard:', arr);\n      } catch (e) {\n        alert('Copy failed: ' + e);\n      }\n    });\n\n    // Set operation helpers\n    function union(a, b) {\n      return new Set([...a, ...b]);\n    }\n    function intersection(a, b) {\n      const res = new Set();\n      for (const v of a) if (b.has(v)) res.add(v);\n      return res;\n    }\n    function difference(a, b) {\n      const res = new Set();\n      for (const v of a) if (!b.has(v)) res.add(v);\n      return res;\n    }\n\n    document.getElementById('unionExample').addEventListener('click', () => {\n      const A = new Set([1,2,3,4]);\n      const B = new Set([3,4,5,6]);\n      const U = union(A,B);\n      document.getElementById('opsResult').textContent = `A = [1,2,3,4]\\nB = [3,4,5,6]\\nUnion = ${JSON.stringify(Array.from(U))}`;\n      log('union A,B =>', Array.from(U));\n    });\n\n    document.getElementById('intersectionExample').addEventListener('click', () => {\n      const A = new Set([1,2,3,4]);\n      const B = new Set([3,4,5,6]);\n      const I = intersection(A,B);\n      document.getElementById('opsResult').textContent = `A = [1,2,3,4]\\nB = [3,4,5,6]\\nIntersection = ${JSON.stringify(Array.from(I))}`;\n      log('intersection A,B =>', Array.from(I));\n    });\n\n    document.getElementById('differenceExample').addEventListener('click', () => {\n      const A = new Set([1,2,3,4]);\n      const B = new Set([3,4,5,6]);\n      const D = difference(A,B);\n      document.getElementById('opsResult').textContent = `A = [1,2,3,4]\\nB = [3,4,5,6]\\nDifference A \\\\ B = ${JSON.stringify(Array.from(D))}`;\n      log('difference A \\\\ B =>', Array.from(D));\n    });\n\n    // Initialize display and example logs\n    displaySet();\n    log('Demo ready. Try adding strings, numbers, JSON objects. Note: NaN is considered equal to NaN in Set.');\n\n    // Small UX: press Enter to add\n    document.getElementById('inputValue').addEventListener('keydown', (e) => {\n      if (e.key === 'Enter') document.getElementById('addBtn').click();\n    });\n\n    // Show how NaN behaves and SameValueZero equality\n    (function showNaNBehavior() {\n      const s = new Set();\n      s.add(NaN);\n      s.add(NaN);\n      log('NaN uniqueness: add(NaN) twice → size', s.size, 'Array:', Array.from(s));\n    })();\n\n  </script>\n</body>\n</html>"
  },
