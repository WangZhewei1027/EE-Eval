    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Simple Routing Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 0; padding: 0;\n      background: #f5f5f5;\n    }\n    header {\n      background: #007acc;\n      color: white;\n      padding: 1rem;\n      text-align: center;\n    }\n    nav {\n      background: #004d99;\n      padding: 0.5rem;\n      text-align: center;\n    }\n    nav a {\n      color: white;\n      margin: 0 1rem;\n      text-decoration: none;\n      font-weight: bold;\n      cursor: pointer;\n    }\n    nav a:hover {\n      text-decoration: underline;\n    }\n    main {\n      padding: 2rem;\n      min-height: 60vh;\n      background: white;\n      max-width: 600px;\n      margin: 2rem auto;\n      box-shadow: 0 0 10px rgba(0,0,0,0.1);\n      border-radius: 4px;\n    }\n    footer {\n      text-align: center;\n      padding: 1rem;\n      color: #666;\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Simple JavaScript Routing Demo</h1>\n  </header>\n  <nav>\n    <a href=\"/\" data-link>Home</a>\n    <a href=\"/about\" data-link>About</a>\n    <a href=\"/contact\" data-link>Contact</a>\n  </nav>\n  <main id=\"app\">\n    <!-- Content will be loaded here -->\n  </main>\n  <footer>\n    &copy; 2024 Routing Demo\n  </footer>\n\n  <script>\n    // Pages/templates\n    const routes = {\n      \"/\": `<h2>Home Page</h2><p>Welcome to our simple routing demo site! Click the links above to navigate.</p>`,\n      \"/about\": `<h2>About Us</h2><p>This demonstration shows basic client-side routing using JavaScript and the History API.</p>`,\n      \"/contact\": `<h2>Contact</h2>\n        <p>You can reach us by email at <a href=\"mailto:contact@example.com\">contact@example.com</a>.</p>`\n    };\n\n    const appDiv = document.getElementById('app');\n\n    // Render route contents\n    function render(path) {\n      if (routes[path]) {\n        appDiv.innerHTML = routes[path];\n      } else {\n        appDiv.innerHTML = `<h2>404 - Not Found</h2>\n        <p>The page you are looking for does not exist.</p>`;\n      }\n    }\n\n    // Handle navigation\n    function onNavigate(event) {\n      if (event.target.matches('a[data-link]')) {\n        event.preventDefault();\n        const href = event.target.getAttribute('href');\n        history.pushState(null, null, href);\n        render(href);\n      }\n    }\n\n    // Handle back/forward buttons\n    window.addEventListener('popstate', () => {\n      render(window.location.pathname);\n    });\n\n    // Initial render\n    document.addEventListener('DOMContentLoaded', () => {\n      render(window.location.pathname);\n      document.body.addEventListener('click', onNavigate);\n    });\n  </script>\n</body>\n</html>"
