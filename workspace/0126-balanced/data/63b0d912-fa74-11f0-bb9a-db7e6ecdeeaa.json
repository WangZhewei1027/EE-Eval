    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Undirected Graph Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 0; padding: 0;\n    background: #fafafa;\n  }\n  header {\n    background: #2c3e50;\n    color: white;\n    padding: 1rem;\n    text-align: center;\n  }\n  #canvas-container {\n    display: flex;\n    justify-content: center;\n    margin-top: 1em;\n  }\n  canvas {\n    border: 1px solid #ccc;\n    background: white;\n  }\n  #info {\n    max-width: 700px;\n    margin: 20px auto;\n    background: white;\n    padding: 1em;\n    border-radius: 5px;\n    box-shadow: 0 0 8px rgba(0,0,0,0.1);\n  }\n  ul {\n    list-style: none;\n    padding-left: 0;\n  }\n  .node {\n    font-weight: bold;\n  }\n</style>\n</head>\n<body>\n<header>\n  <h1>Undirected Graph Visualization</h1>\n  <p>Drag nodes to reposition. Hover edges to see connections.</p>\n</header>\n\n<div id=\"canvas-container\">\n  <canvas id=\"graphCanvas\" width=\"700\" height=\"500\"></canvas>\n</div>\n\n<div id=\"info\">\n  <h2>Graph Representation (Adjacency List):</h2>\n  <pre id=\"adjList\"></pre>\n  <h3>Details:</h3>\n  <p>This graph is <strong>undirected</strong>, meaning edges have no direction. Edges connect two nodes bi-directionally.</p>\n</div>\n\n<script>\n// Undirected Graph Data and Visualization\n\nclass UndirectedGraph {\n  constructor() {\n    this.adjList = new Map();\n  }\n  \n  addVertex(v) {\n    if (!this.adjList.has(v)) {\n      this.adjList.set(v, new Set());\n    }\n  }\n  \n  addEdge(v, w) {\n    this.addVertex(v);\n    this.addVertex(w);\n    this.adjList.get(v).add(w);\n    this.adjList.get(w).add(v);\n  }\n  \n  getVertices() {\n    return Array.from(this.adjList.keys());\n  }\n  \n  getEdges() {\n    const edges = new Set();\n    for(let [v, neighbors] of this.adjList.entries()) {\n      for(let w of neighbors) {\n        // Sort pair to avoid duplicates since undirected\n        const edge = [v,w].sort().join('-');\n        edges.add(edge);\n      }\n    }\n    return Array.from(edges).map(e => e.split('-'));\n  }\n  \n  toString() {\n    let str = '';\n    for(let [v, neighbors] of this.adjList.entries()) {\n      str += v + ' -> ' + Array.from(neighbors).join(', ') + '\\n';\n    }\n    return str.trim();\n  }\n}\n\n// Setup graph\nconst graph = new UndirectedGraph();\n\n// Example graph with 7 nodes\nconst nodes = ['A','B','C','D','E','F','G'];\nnodes.forEach(n => graph.addVertex(n));\n\ngraph.addEdge('A','B');\ngraph.addEdge('A','C');\ngraph.addEdge('B','D');\ngraph.addEdge('C','D');\ngraph.addEdge('C','E');\ngraph.addEdge('D','F');\ngraph.addEdge('E','F');\ngraph.addEdge('F','G');\n\nconst canvas = document.getElementById('graphCanvas');\nconst ctx = canvas.getContext('2d');\n\nconst NODE_RADIUS = 20;\n\n// Nodes with their positions\nconst nodePositions = {\n  A: {x: 150, y: 100},\n  B: {x: 100, y: 200},\n  C: {x: 200, y: 200},\n  D: {x: 150, y: 300},\n  E: {x: 300, y: 200},\n  F: {x: 250, y: 350},\n  G: {x: 300, y: 450}\n};\n\n// We'll make nodes draggable\nlet dragNode = null;\nlet offsetX = 0;\nlet offsetY = 0;\n\nfunction drawGraph() {\n  ctx.clearRect(0, 0, canvas.width, canvas.height);\n  \n  // Draw edges first\n  ctx.strokeStyle = '#34495e';\n  ctx.lineWidth = 2;\n  ctx.font = '14px Arial';\n\n  let edges = graph.getEdges();\n  \n  edges.forEach(edge => {\n    const [v,w] = edge;\n    const p1 = nodePositions[v];\n    const p2 = nodePositions[w];\n    ctx.beginPath();\n    ctx.moveTo(p1.x, p1.y);\n    ctx.lineTo(p2.x, p2.y);\n    ctx.stroke();\n  });\n  \n  // Draw nodes\n  for(let v of graph.getVertices()) {\n    const p = nodePositions[v];\n    // Circle\n    ctx.beginPath();\n    ctx.fillStyle = '#2980b9';\n    ctx.strokeStyle = '#1c5980';\n    ctx.lineWidth = 3;\n    ctx.arc(p.x, p.y, NODE_RADIUS, 0, 2 * Math.PI);\n    ctx.fill();\n    ctx.stroke();\n    // Text\n    ctx.fillStyle = 'white';\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'middle';\n    ctx.font = 'bold 18px Arial';\n    ctx.fillText(v, p.x, p.y);\n  }\n}\n\n// Utility to check if point is inside a node\nfunction getNodeAtPosition(x, y) {\n  for(let v of graph.getVertices()) {\n    let p = nodePositions[v];\n    let dx = x - p.x;\n    let dy = y - p.y;\n    if (dx*dx + dy*dy <= NODE_RADIUS*NODE_RADIUS) {\n      return v;\n    }\n  }\n  return null;\n}\n\n// Mouse events for dragging nodes\ncanvas.addEventListener('mousedown', e => {\n  const rect = canvas.getBoundingClientRect();\n  let x = e.clientX - rect.left;\n  let y = e.clientY - rect.top;\n  let node = getNodeAtPosition(x, y);\n  if (node) {\n    dragNode = node;\n    offsetX = x - nodePositions[node].x;\n    offsetY = y - nodePositions[node].y;\n  }\n});\n\ncanvas.addEventListener('mousemove', e => {\n  const rect = canvas.getBoundingClientRect();\n  let x = e.clientX - rect.left;\n  let y = e.clientY - rect.top;\n  \n  if (dragNode) {\n    nodePositions[dragNode].x = x - offsetX;\n    nodePositions[dragNode].y = y - offsetY;\n    drawGraph();\n  } else {\n    // Optional: change cursor style on hover\n    if(getNodeAtPosition(x,y)) {\n      canvas.style.cursor = 'pointer';\n    } else {\n      canvas.style.cursor = 'default';\n    }\n  }\n});\n\ncanvas.addEventListener('mouseup', e => {\n  dragNode = null;\n});\n\ncanvas.addEventListener('mouseleave', e => {\n  dragNode = null;\n});\n\n// Display adjacency list in info box\nfunction displayAdjacency() {\n  const adjListElem = document.getElementById('adjList');\n  adjListElem.textContent = graph.toString();\n}\n\ndisplayAdjacency();\ndrawGraph();\n\n</script>\n</body>\n</html>"
