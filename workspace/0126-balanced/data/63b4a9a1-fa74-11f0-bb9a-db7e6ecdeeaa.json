    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Symmetric Cryptography Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem; \n    background: #f9f9f9;\n    color: #222;\n  }\n  h1 {\n    text-align: center;\n    color: #004085;\n  }\n  .container {\n    max-width: 600px;\n    margin: auto;\n    background: white;\n    border-radius: 8px;\n    box-shadow: 0 0 10px #ccc;\n    padding: 1.5rem 2rem;\n  }\n  label {\n    display: block;\n    margin: 1rem 0 0.4rem 0;\n    font-weight: bold;\n  }\n  textarea, input[type=\"text\"] {\n    width: 100%;\n    padding: 0.5rem;\n    font-size: 1rem;\n    border-radius: 4px;\n    border: 1px solid #bbb;\n    resize: vertical;\n  }\n  button {\n    margin: 1rem 0;\n    padding: 0.7rem 1.5rem;\n    font-size: 1rem;\n    font-weight: bold;\n    border: none;\n    border-radius: 4px;\n    background: #007bff;\n    color: white;\n    cursor: pointer;\n    transition: background-color 0.25s ease;\n  }\n  button:hover:not(:disabled) {\n    background: #0056b3;\n  }\n  button:disabled {\n    background: #a0a0a0;\n    cursor: not-allowed;\n  }\n  .output {\n    word-wrap: break-word;\n    background: #e9ecef;\n    padding: 0.7rem;\n    border-radius: 4px;\n    font-family: monospace;\n    white-space: pre-wrap;\n    min-height: 50px;\n  }\n  small {\n    color: #666;\n  }\n</style>\n</head>\n<body>\n  <h1>Symmetric Cryptography Demo</h1>\n  <div class=\"container\">\n    <p>\n      This demo shows <strong>Symmetric Cryptography</strong>, where the same key is used to both <em>encrypt</em> and <em>decrypt</em> a message.\n    </p>\n\n    <label for=\"keyInput\">Secret Key (16 characters):</label>\n    <input id=\"keyInput\" maxlength=\"16\" placeholder=\"Enter a 16-char secret key\" />\n\n    <label for=\"plaintextInput\">Plaintext Message:</label>\n    <textarea id=\"plaintextInput\" rows=\"4\" placeholder=\"Type your message here...\"></textarea>\n\n    <button id=\"encryptBtn\" disabled>Encrypt</button>\n\n    <label for=\"ciphertextOutput\">Encrypted Message (Base64):</label>\n    <textarea id=\"ciphertextOutput\" rows=\"4\" readonly placeholder=\"Encrypted message will appear here\"></textarea>\n\n    <button id=\"decryptBtn\" disabled>Decrypt</button>\n\n    <label for=\"decryptedOutput\">Decrypted Message:</label>\n    <textarea id=\"decryptedOutput\" rows=\"4\" readonly placeholder=\"Decrypted message will appear here\"></textarea>\n\n    <p style=\"margin-top:2rem; font-size: 0.9rem; color: #555;\">\n      <strong>Note:</strong> This demo uses AES-GCM with a 128-bit key and the Web Crypto API.<br>\n      You must enter a 16-character key to enable encryption and decryption.\n    </p>\n  </div>\n\n<script>\n(() => {\n  const enc = new TextEncoder();\n  const dec = new TextDecoder();\n\n  const keyInput = document.getElementById(\"keyInput\");\n  const plaintextInput = document.getElementById(\"plaintextInput\");\n  const encryptBtn = document.getElementById(\"encryptBtn\");\n  const ciphertextOutput = document.getElementById(\"ciphertextOutput\");\n  const decryptBtn = document.getElementById(\"decryptBtn\");\n  const decryptedOutput = document.getElementById(\"decryptedOutput\");\n\n  let cryptoKey = null;\n  let iv = null; // Initialization vector for AES-GCM\n\n  // Enable or disable buttons based on inputs\n  function updateButtons() {\n    const hasValidKey = keyInput.value.length === 16;\n    encryptBtn.disabled = !(hasValidKey && plaintextInput.value.trim() !== \"\");\n    decryptBtn.disabled = ciphertextOutput.value.trim() === \"\" || !hasValidKey;\n  }\n\n  // Convert a base64 string to ArrayBuffer\n  function base64ToArrayBuffer(base64) {\n    const binary = window.atob(base64);\n    const length = binary.length;\n    const bytes = new Uint8Array(length);\n    for (let i = 0; i < length; i++) {\n      bytes[i] = binary.charCodeAt(i);\n    }\n    return bytes.buffer;\n  }\n\n  // Convert ArrayBuffer to base64 string\n  function arrayBufferToBase64(buffer) {\n    const bytes = new Uint8Array(buffer);\n    let binary = \"\";\n    for (let i = 0; i < bytes.byteLength; i++) {\n      binary += String.fromCharCode(bytes[i]);\n    }\n    return window.btoa(binary);\n  }\n\n  // Import raw AES key (expects length 16 bytes for AES-128)\n  async function importKey(rawKey) {\n    return await crypto.subtle.importKey(\n      \"raw\",\n      rawKey,\n      { name: \"AES-GCM\" },\n      false,\n      [\"encrypt\", \"decrypt\"]\n    );\n  }\n\n  // Encrypt plaintext using AES-GCM\n  async function encryptMessage(key, plaintext) {\n    iv = crypto.getRandomValues(new Uint8Array(12)); // 96-bit IV recommended for AES-GCM\n    const encoded = enc.encode(plaintext);\n    const cipherBuffer = await crypto.subtle.encrypt(\n      { name: \"AES-GCM\", iv: iv },\n      key,\n      encoded\n    );\n\n    // Combine IV + cipher text for transport\n    const combined = new Uint8Array(iv.byteLength + cipherBuffer.byteLength);\n    combined.set(iv, 0);\n    combined.set(new Uint8Array(cipherBuffer), iv.byteLength);\n    return combined.buffer;\n  }\n\n  // Decrypt ciphertext using AES-GCM (expects combined IV + ciphertext)\n  async function decryptMessage(key, combinedBuffer) {\n    const combined = new Uint8Array(combinedBuffer);\n    const iv = combined.slice(0, 12); // First 12 bytes = IV\n    const ciphertext = combined.slice(12);\n    const decryptedBuffer = await crypto.subtle.decrypt(\n      { name: \"AES-GCM\", iv: iv },\n      key,\n      ciphertext\n    );\n    return dec.decode(decryptedBuffer);\n  }\n\n  // Event listeners\n  keyInput.addEventListener(\"input\", async () => {\n    if (keyInput.value.length === 16) {\n      try {\n        cryptoKey = await importKey(enc.encode(keyInput.value));\n      } catch {\n        cryptoKey = null;\n      }\n    } else {\n      cryptoKey = null;\n    }\n    updateButtons();\n  });\n\n  plaintextInput.addEventListener(\"input\", () => {\n    updateButtons();\n  });\n\n  encryptBtn.addEventListener(\"click\", async () => {\n    if (!cryptoKey) {\n      alert(\"Invalid key\");\n      return;\n    }\n    const plaintext = plaintextInput.value;\n    try {\n      const encryptedBuffer = await encryptMessage(cryptoKey, plaintext);\n      const b64 = arrayBufferToBase64(encryptedBuffer);\n      ciphertextOutput.value = b64;\n      decryptedOutput.value = \"\";\n      decryptBtn.disabled = false;\n    } catch (e) {\n      alert(\"Encryption failed: \" + e.message);\n    }\n  });\n\n  decryptBtn.addEventListener(\"click\", async () => {\n    if (!cryptoKey) {\n      alert(\"Invalid key\");\n      return;\n    }\n    const ciphertextB64 = ciphertextOutput.value;\n    if (!ciphertextB64) {\n      alert(\"No ciphertext to decrypt\");\n      return;\n    }\n    try {\n      const combinedBuffer = base64ToArrayBuffer(ciphertextB64);\n      const decryptedText = await decryptMessage(cryptoKey, combinedBuffer);\n      decryptedOutput.value = decryptedText;\n    } catch (e) {\n      alert(\"Decryption failed: \" + e.message);\n      decryptedOutput.value = \"\";\n    }\n  });\n\n  updateButtons();\n})();\n</script>\n</body>\n</html>"
