    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Query Optimization Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f2f5;\n  }\n  h1 {\n    color: #2c3e50;\n  }\n  .container {\n    background: #fff;\n    padding: 20px;\n    border-radius: 8px;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n    max-width: 900px;\n    margin: auto;\n  }\n  textarea {\n    width: 100%;\n    height: 80px;\n    font-family: monospace;\n    font-size: 14px;\n    padding: 10px;\n    border: 1px solid #ddd;\n    border-radius: 4px;\n    resize: vertical;\n  }\n  button {\n    margin-top: 15px;\n    background-color: #2980b9;\n    color: #fff;\n    border: none;\n    padding: 12px 20px;\n    font-size: 16px;\n    border-radius: 4px;\n    cursor: pointer;\n    transition: background-color 0.25s ease;\n  }\n  button:hover {\n    background-color: #1c5980;\n  }\n  pre {\n    background: #272822;\n    color: #f8f8f2;\n    padding: 15px;\n    border-radius: 5px;\n    overflow-x: auto;\n    font-size: 14px;\n  }\n  .explanation {\n    margin-top: 20px;\n    line-height: 1.5;\n  }\n  .performance {\n    margin-top: 20px;\n    font-weight: bold;\n  }\n  .highlight {\n    color: #c0392b;\n    font-weight: bold;\n  }\n  mark {\n    background: #fffb91;\n    border-radius: 3px;\n    padding: 0 3px;\n  }\n  table {\n    border-collapse: collapse;\n    margin-top: 10px;\n    width: 100%;\n  }\n  th, td {\n    border: 1px solid #ddd;\n    padding: 6px 10px;\n    text-align: left;\n  }\n  th {\n    background-color: #34495e;\n    color: white;\n  }\n  .index-label {\n    background-color: #27ae60;\n    color: white;\n    padding: 2px 6px;\n    border-radius: 3px;\n    font-size: 13px;\n    font-weight: normal;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Query Optimization Demonstration</h1>\n  <p>\n    Enter a SQL query against the sample <code>employees</code> dataset below.\n    The demo will compare an unoptimized and an optimized query and show the difference\n    in execution steps (simulated) to demonstrate the concept of Query Optimization.\n  </p>\n  <label for=\"queryInput\"><strong>Input SQL Query:</strong></label>\n  <textarea id=\"queryInput\" spellcheck=\"false\">SELECT * FROM employees WHERE department = 'Sales' AND salary > 60000;</textarea>\n  <button id=\"runBtn\">Run and Compare</button>\n\n  <div id=\"output\" style=\"margin-top:30px;\"></div>\n</div>\n\n<script>\n// Sample data simulating an employee table\nconst employees = [];\nconst departments = ['Sales', 'Engineering', 'HR', 'Marketing', 'Finance'];\n\nfunction randomSalary() {\n  return Math.floor(Math.random() * 80000) + 30000; // 30k to 110k\n}\n// Populate employees with 1000 dummy records\nfor(let i=1; i<=1000; i++) {\n  const dept = departments[Math.floor(Math.random()*departments.length)];\n  employees.push({\n    id: i,\n    name: 'Emp_' + i,\n    department: dept,\n    salary: randomSalary()\n  });\n}\n\n/**\n * Parsing a very simple subset of SQL for demonstration:\n * Only support SELECT * FROM employees WHERE conditions;\n * Conditions only support AND between equality or greater-than conditions\n *\n * Returns an object with filters\n */\nfunction parseQuery(sql) {\n  sql = sql.trim().replace(/\\s+/g, ' ');\n  // Basic validation and parsing:\n  const regex = /^SELECT \\* FROM employees(?: WHERE (.+))?;?$/i;\n  const match = sql.match(regex);\n  if (!match) return null;\n  const whereClause = match[1];\n  if (!whereClause) return null; // no WHERE means select all\n  // Split conditions by AND (case insensitive)\n  const conditions = whereClause.split(/ AND /i).map(cond => cond.trim());\n  const filters = [];\n  for (const cond of conditions) {\n    // Condition could be: column = 'value' or column > number\n    let mEq = cond.match(/^(\\w+)\\s*=\\s*'(.+)'$/);\n    let mGt = cond.match(/^(\\w+)\\s*>\\s*(\\d+)$/);\n    if (mEq) {\n      filters.push({col:mEq[1], op:'=', val:mEq[2]});\n    } else if (mGt) {\n      filters.push({col:mGt[1], op:'>', val:Number(mGt[2])});\n    } else {\n      // Unsupported condition\n      return null;\n    }\n  }\n  return filters;\n}\n\n// Simulate query execution without optimization (full scan)\nfunction executeQueryUnoptimized(filters) {\n  // We'll measure steps as number of records checked\n  let steps = 0;\n  const results = [];\n  for (const row of employees) {\n    steps++;\n    let pass = true;\n    for (const f of filters) {\n      if (f.op === '=') {\n        if (row[f.col] !== f.val) {\n          pass = false; break;\n        }\n      } else if (f.op === '>') {\n        if (!(row[f.col] > f.val)) {\n          pass = false; break;\n        }\n      }\n    }\n    if (pass) results.push(row);\n  }\n  return {results, steps};\n}\n\n// Simulate query execution with optimization (use index for department)\n// We'll simulate having an index on department for '=' lookups\nconst departmentIndex = {};\nfunction buildDepartmentIndex() {\n  for (const row of employees) {\n    if (!departmentIndex[row.department]) {\n      departmentIndex[row.department] = [];\n    }\n    departmentIndex[row.department].push(row);\n  }\n}\nbuildDepartmentIndex();\n\nfunction executeQueryOptimized(filters) {\n  let steps = 0;\n  let filteredSet = employees;\n  let departmentFilter = null;\n  let otherFilters = [];\n\n  for (const f of filters) {\n    if (f.col === 'department' && f.op === '=') {\n      departmentFilter = f.val;\n    } else {\n      otherFilters.push(f);\n    }\n  }\n\n  // Use index on department if possible\n  if (departmentFilter != null && departmentIndex[departmentFilter]) {\n    filteredSet = departmentIndex[departmentFilter];\n  }\n  // Count steps as number of rows scanned in filteredSet\n  for (const row of filteredSet) {\n    steps++;\n    let pass = true;\n    for (const f of otherFilters) {\n      if (f.op === '=') {\n        if (row[f.col] !== f.val) {\n          pass = false; break;\n        }\n      } else if (f.op === '>') {\n        if (!(row[f.col] > f.val)) {\n          pass = false; break;\n        }\n      }\n    }\n    if (pass) {\n      // nothing to do, just count in steps and results count\n    }\n  }\n\n  // To get actual results for demonstration:\n  const results = filteredSet.filter(row => {\n    for (const f of otherFilters) {\n      if (f.op === '=' && row[f.col] !== f.val) return false;\n      if (f.op === '>' && !(row[f.col] > f.val)) return false;\n    }\n    return true;\n  })\n\n  return {results, steps};\n}\n\nfunction highlightSQL(sql) {\n  // Simple highlight for keywords and string literals\n  return sql.replace(/\\b(SELECT|FROM|WHERE|AND)\\b/gi, m => `<mark>${m.toUpperCase()}</mark>`)\n    .replace(/'[^']*'/g, m => `<span style=\"color:#d35400;\">${m}</span>`);\n}\n\ndocument.getElementById('runBtn').addEventListener('click', () => {\n  const query = document.getElementById('queryInput').value.trim();\n  const output = document.getElementById('output');\n  output.innerHTML = '';\n\n  if (!query) {\n    output.innerHTML = '<p style=\"color:red;\">Please enter a SQL query.</p>';\n    return;\n  }\n  const filters = parseQuery(query);\n  if (filters === null) {\n    output.innerHTML = '<p style=\"color:red;\">Unsupported or invalid query. Please use format:<br><code>SELECT * FROM employees WHERE [conditions];</code><br>Conditions support AND of equality (column = \\'value\\') or greater than (column &gt; number).</p>';\n    return;\n  }\n\n  // Run unoptimized\n  const startUn = performance.now();\n  const unopt = executeQueryUnoptimized(filters);\n  const endUn = performance.now();\n\n  // Run optimized\n  const startOpt = performance.now();\n  const opt = executeQueryOptimized(filters);\n  const endOpt = performance.now();\n\n  // Output results\n  output.innerHTML = `\n    <h2>Query:</h2>\n    <pre>${highlightSQL(query)}</pre>\n\n    <h3>Explanation:</h3>\n    <p class=\"explanation\">\n      <strong>Unoptimized query:</strong> Scans all <mark>${employees.length}</mark> rows to check conditions.<br/>\n      <strong>Optimized query:</strong> Uses an <span class=\"index-label\">INDEX</span> on the <code>department</code> column to reduce the number of scanned rows.\n    </p>\n\n    <h3>Performance Simulation:</h3>\n    <table>\n      <thead><tr><th>Method</th><th>Rows Scanned (Steps)</th><th>Time Taken (ms)</th><th>Returned Rows</th></tr></thead>\n      <tbody>\n        <tr>\n          <td>Unoptimized (Full Table Scan)</td>\n          <td>${unopt.steps.toLocaleString()}</td>\n          <td>${(endUn - startUn).toFixed(3)}</td>\n          <td>${unopt.results.length}</td>\n        </tr>\n        <tr>\n          <td>Optimized (Using Index on <code>department</code>)</td>\n          <td>${opt.steps.toLocaleString()}</td>\n          <td>${(endOpt - startOpt).toFixed(3)}</td>\n          <td>${opt.results.length}</td>\n        </tr>\n      </tbody>\n    </table>\n\n    <h3>Details:</h3>\n    <p>\n      - The unoptimized query checks every employee record in the dataset.<br>\n      - The optimized query reduces scanned rows by directly using the index on <code>department</code> to fetch only relevant records.<br>\n      - This reduces CPU and I/O and results in faster queries, especially for large datasets.\n    </p>\n    <p><em>Note: This demo simulates query steps and does not execute real SQL.</em></p>\n  `;\n});\n</script>\n</body>\n</html>"
  },
