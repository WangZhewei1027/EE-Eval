    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Deque (Double-Ended Queue) — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --accent:#60a5fa;\n      --muted:#94a3b8;\n      --good:#10b981;\n      --danger:#ef4444;\n      --glass: rgba(255,255,255,0.04);\n      --glass-2: rgba(255,255,255,0.02);\n      --text:#e6eef8;\n    }\n    *{box-sizing:border-box;font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;}\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,var(--bg),#08101a);color:var(--text);}\n    .wrap{max-width:1100px;margin:28px auto;padding:22px;border-radius:12px; background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); box-shadow: 0 8px 30px rgba(2,6,23,0.6);}\n    header{display:flex;align-items:center;gap:16px;margin-bottom:18px;}\n    header h1{font-size:20px;margin:0;}\n    header p{margin:0;color:var(--muted);font-size:13px;}\n    .grid{display:grid;grid-template-columns: 420px 1fr; gap:18px;}\n    .card{background:var(--card);border-radius:10px;padding:14px;box-shadow: 0 6px 18px rgba(2,6,23,0.6);}\n    .controls{display:flex;flex-direction:column;gap:12px;}\n    .row{display:flex;gap:8px;align-items:center;}\n    input[type=\"text\"]{flex:1;padding:8px 10px;border-radius:8px;border:1px solid transparent;background:var(--glass);color:var(--text);}\n    button{padding:8px 10px;border-radius:8px;border:0;background:linear-gradient(180deg,var(--accent),#3b82f6);color:#06223a;cursor:pointer;font-weight:600;}\n    button.secondary{background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--text);font-weight:600;}\n    button.warn{background:linear-gradient(180deg,var(--danger),#d32f2f); color:#fff;}\n    button.small{padding:6px 8px;font-size:13px;border-radius:7px;}\n    .vis{min-height:180px;display:flex;flex-direction:column;gap:12px;align-items:stretch;}\n    .deque-area{background:linear-gradient(90deg,var(--glass),var(--glass-2));border-radius:10px;padding:14px;overflow:hidden;position:relative;border:1px solid rgba(255,255,255,0.02);}\n    .belt{display:flex;gap:10px;align-items:center;transition:all 300ms ease;min-height:70px;padding:6px;}\n    .node{min-width:64px;padding:10px;border-radius:8px;background:linear-gradient(180deg,#0b2033,#062231);border:1px solid rgba(255,255,255,0.03);color:var(--text);text-align:center;font-weight:700;box-shadow: 0 6px 14px rgba(2,6,23,0.5);transform:translateY(0);opacity:1;transition:transform 300ms ease, opacity 280ms ease;}\n    .node.removing{transform:translateY(16px) scale(0.95);opacity:0;}\n    .node.adding{transform:translateY(-8px);opacity:0;animation: dropIn 300ms forwards;}\n    @keyframes dropIn{to{transform:translateY(0);opacity:1;}}\n    .label{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted);}\n    .meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px;}\n    .pill{background:rgba(255,255,255,0.02);padding:6px 8px;border-radius:8px;border:1px solid rgba(255,255,255,0.03);font-size:13px;color:var(--muted);}\n    .arrows{position:absolute;left:12px;right:12px;top:8px;display:flex;justify-content:space-between;pointer-events:none;}\n    .arrow-box{display:flex;align-items:center;gap:8px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));padding:6px 8px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);font-size:13px;color:var(--muted);}\n    .info{font-size:13px;color:var(--muted);line-height:1.5;}\n    .log{max-height:140px;overflow:auto;padding:8px;border-radius:8px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.02);font-family:monospace;font-size:13px;color:var(--muted);}\n    .internal{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:10px;}\n    .index-box{display:flex;gap:6px;align-items:center;background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:8px;padding:8px;border:1px solid rgba(255,255,255,0.02);}\n    .strong{color:var(--text);font-weight:700}\n    .table{margin-top:10px;border-radius:8px;padding:8px;background:rgba(255,255,255,0.01);border:1px solid rgba(255,255,255,0.02);}\n    .table .row{justify-content:space-between;padding:6px 8px;border-radius:6px;}\n    .row.alt{background:rgba(255,255,255,0.008);}\n    .footer{margin-top:12px;font-size:13px;color:var(--muted)}\n    .hint{font-size:12px;color:var(--muted)}\n    .flex-center{display:flex;align-items:center;gap:8px;}\n    .muted{color:var(--muted)}\n    .keys{display:flex;gap:6px;flex-wrap:wrap;}\n    .key{background:rgba(255,255,255,0.02);padding:6px 8px;border-radius:6px;border:1px solid rgba(255,255,255,0.02);font-size:13px;}\n    @media (max-width:920px){ .grid{grid-template-columns:1fr; } header{flex-direction:column;align-items:flex-start;gap:6px;} .wrap{margin:16px;} }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\" role=\"main\">\n    <header>\n      <div>\n        <h1>Deque (Double-Ended Queue) — Interactive Demo</h1>\n        <p>Operate on both ends efficiently. Try pushing, popping, and peeking from front and back.</p>\n      </div>\n    </header>\n\n    <div class=\"grid\">\n      <div class=\"card\">\n        <div class=\"controls\">\n          <div class=\"row\">\n            <input id=\"valueInput\" type=\"text\" placeholder=\"Value (string/number)\">\n            <button id=\"pushFrontBtn\" title=\"Insert at front\">Push Front</button>\n            <button id=\"pushBackBtn\" title=\"Insert at back\">Push Back</button>\n          </div>\n\n          <div class=\"row\">\n            <button id=\"popFrontBtn\" class=\"small secondary\" title=\"Remove from front\">Pop Front</button>\n            <button id=\"popBackBtn\" class=\"small secondary\" title=\"Remove from back\">Pop Back</button>\n            <button id=\"peekFrontBtn\" class=\"small\" title=\"Peek front\">Peek Front</button>\n            <button id=\"peekBackBtn\" class=\"small\" title=\"Peek back\">Peek Back</button>\n          </div>\n\n          <div class=\"row\">\n            <button id=\"clearBtn\" class=\"warn\">Clear</button>\n            <button id=\"randomBtn\" class=\"small\">Fill Random (5)</button>\n            <button id=\"demoOpsBtn\" class=\"small secondary\">Auto Demo</button>\n            <div style=\"flex:1\" />\n            <span class=\"pill\">Size: <span id=\"sizeBadge\">0</span></span>\n          </div>\n\n          <div class=\"row\">\n            <div class=\"hint\">Last result:</div>\n            <div id=\"lastResult\" class=\"pill\" style=\"margin-left:8px\">—</div>\n          </div>\n\n          <div class=\"label\">Notes</div>\n          <div class=\"info\">\n            - A deque (double-ended queue) allows insertion and removal at both ends.<br>\n            - Typical implementations: doubly-linked list or circular buffer for O(1) operations.<br>\n            - This demo uses an index-based map (head/tail indices) to show efficient O(1) semantics.\n          </div>\n        </div>\n      </div>\n\n      <div class=\"card vis\">\n        <div class=\"deque-area\" aria-live=\"polite\">\n          <div class=\"arrows\">\n            <div class=\"arrow-box\"><strong>Front</strong> ←</div>\n            <div class=\"arrow-box\">→ <strong>Back</strong></div>\n          </div>\n\n          <div id=\"belt\" class=\"belt\" style=\"overflow:auto\"></div>\n\n          <div class=\"meta\">\n            <div class=\"pill\">Head index: <span id=\"headIdx\" class=\"strong\">0</span></div>\n            <div class=\"pill\">Tail index: <span id=\"tailIdx\" class=\"strong\">0</span></div>\n            <div class=\"pill\">Underlying keys: <span id=\"keysList\" class=\"muted\">[]</span></div>\n          </div>\n\n          <div class=\"internal\">\n            <div class=\"index-box\">\n              <div class=\"muted\">Implementation:</div>\n              <div class=\"strong\" style=\"margin-left:4px\">Map with head/tail indices</div>\n            </div>\n            <div class=\"index-box\">\n              <div class=\"muted\">Front operation:</div>\n              <div class=\"muted\">pushFront/popFront</div>\n            </div>\n            <div class=\"index-box\">\n              <div class=\"muted\">Back operation:</div>\n              <div class=\"muted\">pushBack/popBack</div>\n            </div>\n          </div>\n\n          <div class=\"table\" style=\"margin-top:10px\">\n            <div class=\"row alt\"><div class=\"muted\">Operation</div><div class=\"muted\">Complexity</div></div>\n            <div class=\"row\"><div>pushFront / pushBack</div><div class=\"strong\">O(1)</div></div>\n            <div class=\"row alt\"><div>popFront / popBack</div><div class=\"strong\">O(1)</div></div>\n            <div class=\"row\"><div>peekFront / peekBack</div><div class=\"strong\">O(1)</div></div>\n          </div>\n        </div>\n\n        <div style=\"display:flex;gap:12px;margin-top:12px\">\n          <div style=\"flex:1\">\n            <div class=\"label\">Operation Log</div>\n            <div id=\"log\" class=\"log\" role=\"log\" aria-live=\"polite\"></div>\n          </div>\n\n          <div style=\"width:260px\">\n            <div class=\"label\">Internal Map (indices → value)</div>\n            <div id=\"mapView\" class=\"log\" style=\"height:160px;overflow:auto\"></div>\n          </div>\n        </div>\n\n        <div class=\"footer\">\n          Tip: Click \"Auto Demo\" to run a short scripted sequence.\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Deque implementation using an object map with head & tail indices (efficient O(1) at both ends)\n    class Deque {\n      constructor() {\n        this._data = {};    // map from integer index -> value\n        this._head = 0;     // inclusive index of front element\n        this._tail = 0;     // exclusive index: next free index at back\n      }\n\n      pushBack(val) {\n        this._data[this._tail] = val;\n        this._tail++;\n      }\n\n      pushFront(val) {\n        this._head--;\n        this._data[this._head] = val;\n      }\n\n      popBack() {\n        if (this.isEmpty()) return undefined;\n        this._tail--;\n        const v = this._data[this._tail];\n        delete this._data[this._tail];\n        return v;\n      }\n\n      popFront() {\n        if (this.isEmpty()) return undefined;\n        const v = this._data[this._head];\n        delete this._data[this._head];\n        this._head++;\n        return v;\n      }\n\n      peekFront() {\n        return this.isEmpty() ? undefined : this._data[this._head];\n      }\n\n      peekBack() {\n        return this.isEmpty() ? undefined : this._data[this._tail - 1];\n      }\n\n      size() {\n        return this._tail - this._head;\n      }\n\n      isEmpty() {\n        return this.size() === 0;\n      }\n\n      clear() {\n        this._data = {};\n        this._head = 0;\n        this._tail = 0;\n      }\n\n      // Return elements in order from front to back (for visualization)\n      elements() {\n        const out = [];\n        for (let i = this._head; i < this._tail; i++) {\n          if (Object.prototype.hasOwnProperty.call(this._data, i)) out.push({ idx: i, val: this._data[i] });\n        }\n        return out;\n      }\n\n      // Return a shallow copy of the underlying map (for debug)\n      internalMap() {\n        const copy = {};\n        for (const k in this._data) copy[k] = this._data[k];\n        return copy;\n      }\n\n      headIndex() { return this._head; }\n      tailIndex() { return this._tail; }\n    }\n\n    // UI wiring\n    const dq = new Deque();\n\n    const belt = document.getElementById('belt');\n    const headIdx = document.getElementById('headIdx');\n    const tailIdx = document.getElementById('tailIdx');\n    const keysList = document.getElementById('keysList');\n    const logEl = document.getElementById('log');\n    const mapView = document.getElementById('mapView');\n    const sizeBadge = document.getElementById('sizeBadge');\n    const lastResult = document.getElementById('lastResult');\n\n    const valueInput = document.getElementById('valueInput');\n    const pushFrontBtn = document.getElementById('pushFrontBtn');\n    const pushBackBtn = document.getElementById('pushBackBtn');\n    const popFrontBtn = document.getElementById('popFrontBtn');\n    const popBackBtn = document.getElementById('popBackBtn');\n    const peekFrontBtn = document.getElementById('peekFrontBtn');\n    const peekBackBtn = document.getElementById('peekBackBtn');\n    const clearBtn = document.getElementById('clearBtn');\n    const randomBtn = document.getElementById('randomBtn');\n    const demoOpsBtn = document.getElementById('demoOpsBtn');\n\n    function log(msg) {\n      const time = new Date().toLocaleTimeString();\n      const line = document.createElement('div');\n      line.textContent = `[${time}] ${msg}`;\n      logEl.prepend(line);\n    }\n\n    function updateMeta() {\n      headIdx.textContent = dq.headIndex();\n      tailIdx.textContent = dq.tailIndex();\n      keysList.textContent = JSON.stringify(Object.keys(dq.internalMap()).map(k => Number(k)));\n      sizeBadge.textContent = dq.size();\n      mapView.innerHTML = '';\n      const m = dq.internalMap();\n      const keys = Object.keys(m).map(k => Number(k)).sort((a,b)=>a-b);\n      if (keys.length === 0) {\n        mapView.textContent = '(empty)';\n      } else {\n        keys.forEach(k => {\n          const row = document.createElement('div');\n          row.textContent = `${k} → ${String(m[k])}`;\n          mapView.appendChild(row);\n        });\n      }\n    }\n\n    // Visualize elements: nodes shown left-to-right from front to back\n    function renderDeque(animated=true) {\n      const elems = dq.elements();\n      // Remove nodes not present\n      const existing = Array.from(belt.children);\n      // Simple diff strategy: clear and rebuild to keep code simple & robust\n      // We'll add animation classes when creating nodes\n      belt.innerHTML = '';\n      elems.forEach((entry, i) => {\n        const n = document.createElement('div');\n        n.className = 'node adding';\n        n.textContent = String(entry.val);\n        // small label for internal index\n        const idxLabel = document.createElement('div');\n        idxLabel.style.fontSize='11px';\n        idxLabel.style.opacity='0.6';\n        idxLabel.style.marginTop='6px';\n        idxLabel.textContent = `idx:${entry.idx}`;\n        n.appendChild(idxLabel);\n        belt.appendChild(n);\n        // after animation, remove 'adding' class\n        requestAnimationFrame(()=> {\n          n.classList.remove('adding');\n        });\n      });\n\n      // update meta\n      updateMeta();\n    }\n\n    function performOp(opName, fn) {\n      try {\n        const res = fn();\n        lastResult.textContent = (res === undefined) ? 'undefined' : String(res);\n        log(`${opName} -> ${lastResult.textContent}`);\n      } catch (e) {\n        lastResult.textContent = 'Error';\n        log(`${opName} -> Error: ${e.message}`);\n      }\n      renderDeque();\n    }\n\n    pushFrontBtn.addEventListener('click', ()=> {\n      const v = valueInput.value.trim();\n      if (v === '') { alert('Enter a value to push'); return;}\n      performOp('pushFront('+v+')', ()=> dq.pushFront(v));\n      valueInput.value = '';\n      valueInput.focus();\n    });\n\n    pushBackBtn.addEventListener('click', ()=> {\n      const v = valueInput.value.trim();\n      if (v === '') { alert('Enter a value to push'); return;}\n      performOp('pushBack('+v+')', ()=> dq.pushBack(v));\n      valueInput.value = '';\n      valueInput.focus();\n    });\n\n    popFrontBtn.addEventListener('click', ()=> {\n      performOp('popFront()', ()=> dq.popFront());\n    });\n\n    popBackBtn.addEventListener('click', ()=> {\n      performOp('popBack()', ()=> dq.popBack());\n    });\n\n    peekFrontBtn.addEventListener('click', ()=> {\n      performOp('peekFront()', ()=> dq.peekFront());\n    });\n\n    peekBackBtn.addEventListener('click', ()=> {\n      performOp('peekBack()', ()=> dq.peekBack());\n    });\n\n    clearBtn.addEventListener('click', ()=> {\n      performOp('clear()', ()=> { dq.clear(); return 'cleared'; });\n    });\n\n    randomBtn.addEventListener('click', ()=> {\n      const sample = Array.from({length:5}, ()=> Math.floor(Math.random()*90)+10);\n      sample.forEach(v=>dq.pushBack(v));\n      log('fill random -> ['+sample.join(', ')+']');\n      lastResult.textContent = 'random fill';\n      renderDeque();\n    });\n\n    // Auto demo: scripted sequence of operations to demonstrate both ends\n    demoOpsBtn.addEventListener('click', async ()=> {\n      demoOpsBtn.disabled = true;\n      valueInput.disabled = true;\n      const steps = [\n        {delay:300, op: ()=> { dq.clear(); log('demo: cleared'); renderDeque(); }},\n        {delay:400, op: ()=> { dq.pushBack('A'); log('demo: pushBack A'); renderDeque(); }},\n        {delay:400, op: ()=> { dq.pushBack('B'); log('demo: pushBack B'); renderDeque(); }},\n        {delay:400, op: ()=> { dq.pushFront('1'); log('demo: pushFront 1'); renderDeque(); }},\n        {delay:400, op: ()=> { dq.pushFront('0'); log('demo: pushFront 0'); renderDeque(); }},\n        {delay:500, op: ()=> { const p=dq.popBack(); log('demo: popBack -> '+String(p)); renderDeque(); }},\n        {delay:500, op: ()=> { const p=dq.popFront(); log('demo: popFront -> '+String(p)); renderDeque(); }},\n        {delay:400, op: ()=> { dq.pushBack('C'); log('demo: pushBack C'); renderDeque(); }},\n        {delay:400, op: ()=> { dq.pushFront('Z'); log('demo: pushFront Z'); renderDeque(); }},\n        {delay:500, op: ()=> { log('demo: peekFront -> '+String(dq.peekFront())); }},\n        {delay:400, op: ()=> { log('demo: peekBack -> '+String(dq.peekBack())); }},\n      ];\n      for (const s of steps) {\n        await new Promise(r=>setTimeout(r, s.delay));\n        s.op();\n      }\n      valueInput.disabled = false;\n      demoOpsBtn.disabled = false;\n      lastResult.textContent = 'demo finished';\n    });\n\n    // Initialize with a few values\n    dq.pushBack('X'); dq.pushBack('Y'); dq.pushBack('Z');\n    renderDeque();\n\n    // small keyboard convenience\n    valueInput.addEventListener('keydown', (e)=>{\n      if (e.key === 'Enter') {\n        pushBackBtn.click();\n      }\n    });\n  </script>\n</body>\n</html>"
  },
