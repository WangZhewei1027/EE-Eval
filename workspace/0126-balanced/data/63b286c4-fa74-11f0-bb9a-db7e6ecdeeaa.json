    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Context Switching Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2em;\n    background: #f4f4f4;\n  }\n  h1 {\n    text-align: center;\n  }\n  #log {\n    background: #222;\n    color: #0f0;\n    font-family: monospace;\n    height: 300px;\n    overflow-y: scroll;\n    padding: 1em;\n    border-radius: 5px;\n    margin-top: 1em;\n  }\n  button {\n    font-size: 1rem;\n    padding: 0.5em 1.5em;\n    margin: 0.5em 0;\n    cursor: pointer;\n    border-radius: 5px;\n    border: none;\n    background: #0078d4;\n    color: white;\n    transition: background 0.3s;\n  }\n  button:hover:not(:disabled) {\n    background: #005a9e;\n  }\n  button:disabled {\n    background: #888;\n    cursor: not-allowed;\n  }\n  .task-list {\n    display: flex;\n    gap: 1em;\n    flex-wrap: wrap;\n  }\n  .task {\n    background: white;\n    border-radius: 5px;\n    padding: 1em;\n    flex: 1 1 200px;\n    box-shadow: 0 2px 5px rgb(0 0 0 / 0.1);\n  }\n  .task h3 {\n    margin-top: 0;\n  }\n  .task button {\n    width: 100%;\n  }\n</style>\n</head>\n<body>\n<h1>Context Switching Demo</h1>\n<p>\n  This demonstration simulates two tasks that take turns running on a \"CPU\". \n  Each task runs a series of computations and then \"switches\" context to the other task,\n  showing how the CPU saves state and resumes later.\n</p>\n\n<div class=\"task-list\">\n  <div class=\"task\">\n    <h3>Task 1 (Counter)</h3>\n    <p>Counts upward with brief pauses to simulate work.</p>\n    <button id=\"startTask1\">Start Task 1</button>\n    <button id=\"pauseTask1\" disabled>Pause Task 1</button>\n    <div>Current Count: <span id=\"count1\">0</span></div>\n  </div>\n  <div class=\"task\">\n    <h3>Task 2 (Factorial)</h3>\n    <p>Calculates factorial step-by-step with pauses.</p>\n    <button id=\"startTask2\">Start Task 2</button>\n    <button id=\"pauseTask2\" disabled>Pause Task 2</button>\n    <div>Current n: <span id=\"n2\">1</span></div>\n    <div>Current factorial: <span id=\"fact2\">1</span></div>\n  </div>\n</div>\n\n<button id=\"startContextSwitching\" disabled>Start Context Switching</button>\n\n<div id=\"log\" aria-live=\"polite\" aria-label=\"Context switch log\"></div>\n\n<script>\n  /*\n   * Context Switching Concept:\n   * We simulate two tasks that each perform a CPU-bound operation:\n   * - Task 1 counts from 0 upwards.\n   * - Task 2 calculates factorial of increasing numbers.\n   * \n   * Instead of running to completion, we simulate a CPU scheduler\n   * preemptively switching between them every 500ms.\n   * \n   * We save task \"contexts\" (their variable states),\n   * and resume them on subsequent turns.\n   */\n\n  const logEl = document.getElementById('log');\n  function log(msg) {\n    const time = new Date().toLocaleTimeString();\n    logEl.textContent += `[${time}] ${msg}\\n`;\n    logEl.scrollTop = logEl.scrollHeight;\n  }\n\n  // Task 1: Counting\n  const count1El = document.getElementById('count1');\n  let task1Context = {\n    count: 0,\n    running: false,\n  };\n\n  // Task 2: Factorial calculation\n  const n2El = document.getElementById('n2');\n  const fact2El = document.getElementById('fact2');\n  let task2Context = {\n    n: 1,\n    factorial: 1,\n    running: false,\n  };\n\n  // Buttons\n  const startTask1Btn = document.getElementById('startTask1');\n  const pauseTask1Btn = document.getElementById('pauseTask1');\n  const startTask2Btn = document.getElementById('startTask2');\n  const pauseTask2Btn = document.getElementById('pauseTask2');\n  const startContextSwitchingBtn = document.getElementById('startContextSwitching');\n\n  // Each task will be implemented as a generator so we can yield control and resume.\n  \n  // Task 1 generator function simulating increments with work chunks\n  function* task1Generator(ctx) {\n    while (true) {\n      ctx.count++;\n      count1El.textContent = ctx.count;\n      log(`Task 1: counted to ${ctx.count}`);\n      // Simulate some work by looping many times (blocking CPU for a moment)\n      for (let i=0; i<1e6; i++) {\n        // busy wait to simulate work\n        if(i === 1e6 -1) yield; // yield context switch point after work chunk\n      }\n    }\n  }\n\n  // Task 2 generator function simulating factorial calculation stepwise\n  function* task2Generator(ctx) {\n    while (true) {\n      ctx.factorial *= ctx.n;\n      n2El.textContent = ctx.n;\n      fact2El.textContent = ctx.factorial;\n      log(`Task 2: factorial(${ctx.n}) = ${ctx.factorial}`);\n      ctx.n++;\n      // Simulate work loop\n      for(let i=0; i<8e5; i++) {\n        if(i === 8e5 -1) yield; // yield context switch point\n      }\n    }\n  }\n\n  let genTask1 = null;\n  let genTask2 = null;\n\n  function resetTask1() {\n    task1Context.count = 0;\n    count1El.textContent = 0;\n    pauseTask1Btn.disabled = true;\n    startTask1Btn.disabled = false;\n    task1Context.running = false;\n    genTask1 = null;\n  }\n\n  function resetTask2() {\n    task2Context.n = 1;\n    task2Context.factorial = 1;\n    n2El.textContent = 1;\n    fact2El.textContent = 1;\n    pauseTask2Btn.disabled = true;\n    startTask2Btn.disabled = false;\n    task2Context.running = false;\n    genTask2 = null;\n  }\n\n  startTask1Btn.onclick = () => {\n    if(!genTask1) {\n      genTask1 = task1Generator(task1Context);\n    }\n    task1Context.running = true;\n    pauseTask1Btn.disabled = false;\n    startTask1Btn.disabled = true;\n    log(\"Task 1 started.\");\n    startContextSwitchingBtn.disabled = false;\n    runTask1Once();\n  };\n  pauseTask1Btn.onclick = () => {\n    task1Context.running = false;\n    pauseTask1Btn.disabled = true;\n    startTask1Btn.disabled = false;\n    log(\"Task 1 paused.\");\n  };\n\n  startTask2Btn.onclick = () => {\n    if(!genTask2) {\n      genTask2 = task2Generator(task2Context);\n    }\n    task2Context.running = true;\n    pauseTask2Btn.disabled = false;\n    startTask2Btn.disabled = true;\n    log(\"Task 2 started.\");\n    startContextSwitchingBtn.disabled = false;\n    runTask2Once();\n  };\n  pauseTask2Btn.onclick = () => {\n    task2Context.running = false;\n    pauseTask2Btn.disabled = true;\n    startTask2Btn.disabled = false;\n    log(\"Task 2 paused.\");\n  };\n\n  // Single step execution for demonstration when starting tasks independently:\n  function runTask1Once() {\n    if(task1Context.running && genTask1) {\n      const res = genTask1.next();\n      // auto-pause after one step so user can see output\n      pauseTask1Btn.click();\n    }\n  }\n  function runTask2Once() {\n    if(task2Context.running && genTask2) {\n      const res = genTask2.next();\n      pauseTask2Btn.click();\n    }\n  }\n\n  /*************\n    Context Switching Scheduler\n  *************/\n  let schedulerInterval = null;\n  const quantumMs = 500; // timeslice 500ms per task\n  let currentTask = 1;\n\n  startContextSwitchingBtn.onclick = () => {\n    if(!genTask1 || !genTask2) {\n      alert(\"Start both tasks first to enable context switching.\");\n      return;\n    }\n    if(schedulerInterval) {\n      // Stop scheduler\n      clearInterval(schedulerInterval);\n      schedulerInterval = null;\n      startContextSwitchingBtn.textContent = \"Start Context Switching\";\n      // Enable all buttons again\n      [startTask1Btn, startTask2Btn].forEach(b => b.disabled = false);\n      [pauseTask1Btn, pauseTask2Btn].forEach(b => b.disabled = true);\n      task1Context.running = false;\n      task2Context.running = false;\n      log(\"Context switching stopped.\");\n      return;\n    }\n    \n    // Prepare and disable direct control buttons during scheduling\n    startTask1Btn.disabled = true;\n    pauseTask1Btn.disabled = true;\n    startTask2Btn.disabled = true;\n    pauseTask2Btn.disabled = true;\n    task1Context.running = false;\n    task2Context.running = false;\n\n    startContextSwitchingBtn.textContent = \"Stop Context Switching\";\n    log(\"Context switching started.\");\n\n    // Scheduler repeatedly runs each task generator for a timeslice\n    schedulerInterval = setInterval(() => {\n      if(currentTask === 1) {\n        log(\"Scheduler: Running Task 1\");\n        try {\n          genTask1.next();\n        } catch(e) {\n          log(\"Task 1 finished or error occurred: \" + e);\n          clearInterval(schedulerInterval);\n        }\n        currentTask = 2;\n      } else {\n        log(\"Scheduler: Running Task 2\");\n        try {\n          genTask2.next();\n        } catch(e) {\n          log(\"Task 2 finished or error occurred: \" + e);\n          clearInterval(schedulerInterval);\n        }\n        currentTask = 1;\n      }\n    }, quantumMs);\n  };\n\n  // Reset tasks on page load\n  resetTask1();\n  resetTask2();\n\n  // Log initial info\n  log(\"Load complete. Please start both tasks to enable context switching.\");\n</script>\n</body>\n</html>"
  },
