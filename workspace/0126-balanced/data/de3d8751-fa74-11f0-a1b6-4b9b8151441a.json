  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Agile Methodology Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            line-height: 1.6;\n            max-width: 1000px;\n            margin: 0 auto;\n            padding: 20px;\n            color: #333;\n        }\n        h1 {\n            color: #2c3e50;\n            text-align: center;\n        }\n        .container {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 20px;\n            justify-content: center;\n        }\n        .card {\n            background: #f9f9f9;\n            border-radius: 8px;\n            padding: 20px;\n            box-shadow: 0 2px 5px rgba(0,0,0,0.1);\n            width: 300px;\n            transition: transform 0.3s;\n        }\n        .card:hover {\n            transform: translateY(-5px);\n        }\n        .card h3 {\n            margin-top: 0;\n            color: #3498db;\n        }\n        .sprint-board {\n            background: #ecf0f1;\n            padding: 15px;\n            border-radius: 8px;\n            margin: 20px 0;\n        }\n        .status-column {\n            background: white;\n            padding: 10px;\n            border-radius: 5px;\n            margin-bottom: 15px;\n        }\n        .task {\n            background: #fff;\n            padding: 8px;\n            margin: 5px 0;\n            border-left: 4px solid #3498db;\n            cursor: pointer;\n        }\n        .task:hover {\n            background: #f0f7fc;\n        }\n        button {\n            background: #3498db;\n            color: white;\n            border: none;\n            padding: 8px 15px;\n            border-radius: 4px;\n            cursor: pointer;\n            margin: 5px;\n        }\n        button:hover {\n            background: #2980b9;\n        }\n        .burndown-container {\n            width: 100%;\n            height: 300px;\n            margin: 20px 0;\n        }\n        #burndownChart {\n            width: 100%;\n            height: 100%;\n            border: 1px solid #ddd;\n            background: white;\n        }\n    </style>\n</head>\n<body>\n    <h1>Agile Methodology Demonstration</h1>\n    \n    <div class=\"container\">\n        <div class=\"card\">\n            <h3>Agile Principles</h3>\n            <ul id=\"principlesList\"></ul>\n        </div>\n        \n        <div class=\"card\">\n            <h3>Scrum Events</h3>\n            <ul id=\"scrumEventsList\"></ul>\n        </div>\n        \n        <div class=\"card\">\n            <h3>Roles</h3>\n            <ul id=\"rolesList\"></ul>\n        </div>\n    </div>\n    \n    <h2>Sprint Simulation</h2>\n    <div class=\"sprint-board\">\n        <h3>Sprint Backlog</h3>\n        <div id=\"backlogItems\" class=\"status-column\"></div>\n        \n        <h3>Sprint Board</h3>\n        <div class=\"container\">\n            <div style=\"width: 23%\">\n                <h4>To Do</h4>\n                <div id=\"todoColumn\" class=\"status-column\"></div>\n            </div>\n            <div style=\"width: 23%\">\n                <h4>In Progress</h4>\n                <div id=\"inProgressColumn\" class=\"status-column\"></div>\n            </div>\n            <div style=\"width: 23%\">\n                <h4>In Review</h4>\n                <div id=\"reviewColumn\" class=\"status-column\"></div>\n            </div>\n            <div style=\"width: 23%\">\n                <h4>Done</h4>\n                <div id=\"doneColumn\" class=\"status-column\"></div>\n            </div>\n        </div>\n        \n        <div>\n            <button id=\"startSprintBtn\">Start Sprint</button>\n            <button id=\"dailyScrumBtn\">Daily Scrum</button>\n            <button id=\"completeTaskBtn\">Complete Task</button>\n            <button id=\"endSprintBtn\">End Sprint</button>\n        </div>\n    </div>\n    \n    <div class=\"burndown-container\">\n        <h3>Burndown Chart</h3>\n        <canvas id=\"burndownChart\"></canvas>\n    </div>\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n    <script>\n        // Agile Data\n        const agilePrinciples = [\n            \"Customer satisfaction through early and continuous delivery\",\n            \"Welcome changing requirements, even late in development\",\n            \"Deliver working software frequently\",\n            \"Business people and developers work together daily\",\n            \"Build projects around motivated individuals\",\n            \"Face-to-face conversation is best\",\n            \"Working software is the primary measure of progress\",\n            \"Sustainable development pace\",\n            \"Continuous attention to technical excellence\",\n            \"Simplicity is essential\",\n            \"Self-organizing teams create the best architectures\",\n            \"Regular reflection and adaptation\"\n        ];\n        \n        const scrumEvents = [\n            \"Sprint Planning\",\n            \"Daily Scrum\",\n            \"Sprint Review\",\n            \"Sprint Retrospective\"\n        ];\n        \n        const roles = [\n            \"Product Owner - Manages the product backlog\",\n            \"Scrum Master - Facilitates the Scrum process\",\n            \"Development Team - Cross-functional team that delivers the product\"\n        ];\n        \n        // Sprint Simulation Data\n        let sprintBacklog = [];\n        let todoTasks = [];\n        let inProgressTasks = [];\n        let reviewTasks = [];\n        let doneTasks = [];\n        let sprintActive = false;\n        let sprintDaysRemaining = 0;\n        let totalStoryPoints = 0;\n        let remainingStoryPoints = 0;\n        let burndownData = [];\n        let burndownChart;\n        \n        // DOM Elements\n        const principlesListEl = document.getElementById('principlesList');\n        const scrumEventsListEl = document.getElementById('scrumEventsList');\n        const rolesListEl = document.getElementById('rolesList');\n        const backlogItemsEl = document.getElementById('backlogItems');\n        const todoColumnEl = document.getElementById('todoColumn');\n        const inProgressColumnEl = document.getElementById('inProgressColumn');\n        const reviewColumnEl = document.getElementById('reviewColumn');\n        const doneColumnEl = document.getElementById('doneColumn');\n        const startSprintBtn = document.getElementById('startSprintBtn');\n        const dailyScrumBtn = document.getElementById('dailyScrumBtn');\n        const completeTaskBtn = document.getElementById('completeTaskBtn');\n        const endSprintBtn = document.getElementById('endSprintBtn');\n        \n        // Initialize the page\n        function init() {\n            renderLists();\n            setupSprintBacklog();\n            setupEventListeners();\n            initBurndownChart();\n        }\n        \n        function renderLists() {\n            agilePrinciples.forEach(principle => {\n                const li = document.createElement('li');\n                li.textContent = principle;\n                principlesListEl.appendChild(li);\n            });\n            \n            scrumEvents.forEach(event => {\n                const li = document.createElement('li');\n                li.textContent = event;\n                scrumEventsListEl.appendChild(li);\n            });\n            \n            roles.forEach(role => {\n                const li = document.createElement('li');\n                li.textContent = role;\n                rolesListEl.appendChild(li);\n            });\n        }\n        \n        function setupSprintBacklog() {\n            const sampleTasks = [\n                { id: 1, title: \"User login functionality\", points: 5 },\n                { id: 2, title: \"Product listing page\", points: 8 },\n                { id: 3, title: \"Shopping cart feature\", points: 13 },\n                { id: 4, title: \"Checkout process\", points: 8 },\n                { id: 5, title: \"User profile page\", points: 3 },\n                { id: 6, title: \"Search functionality\", points: 5 },\n                { id: 7, title: \"Admin dashboard\", points: 8 }\n            ];\n            \n            sprintBacklog = [...sampleTasks];\n            renderBacklog();\n        }\n        \n        function renderBacklog() {\n            backlogItemsEl.innerHTML = '';\n            sprintBacklog.forEach(task => {\n                const taskEl = document.createElement('div');\n                taskEl.className = 'task';\n                taskEl.innerHTML = `<strong>${task.title}</strong> (${task.points} pts)`;\n                taskEl.addEventListener('click', () => moveToSprint(task.id));\n                backlogItemsEl.appendChild(taskEl);\n            });\n        }\n        \n        function moveToSprint(taskId) {\n            if (!sprintActive) {\n                const taskIndex = sprintBacklog.findIndex(t => t.id === taskId);\n                if (taskIndex !== -1) {\n                    const task = sprintBacklog[taskIndex];\n                    todoTasks.push(task);\n                    sprintBacklog.splice(taskIndex, 1);\n                    renderBacklog();\n                    renderSprintBoard();\n                }\n            } else {\n                alert(\"Cannot add tasks during an active sprint!\");\n            }\n        }\n        \n        function renderSprintBoard() {\n            todoColumnEl.innerHTML = '';\n            inProgressColumnEl.innerHTML = '';\n            reviewColumnEl.innerHTML = '';\n            doneColumnEl.innerHTML = '';\n            \n            todoTasks.forEach(task => {\n                const taskEl = createTaskElement(task, 'todo');\n                todoColumnEl.appendChild(taskEl);\n            });\n            \n            inProgressTasks.forEach(task => {\n                const taskEl = createTaskElement(task, 'inProgress');\n                inProgressColumnEl.appendChild(taskEl);\n            });\n            \n            reviewTasks.forEach(task => {\n                const taskEl = createTaskElement(task, 'review');\n                reviewColumnEl.appendChild(taskEl);\n            });\n            \n            doneTasks.forEach(task => {\n                const taskEl = createTaskElement(task, 'done');\n                doneColumnEl.appendChild(taskEl);\n            });\n            \n            updateBurndownChart();\n        }\n        \n        function createTaskElement(task, status) {\n            const taskEl = document.createElement('div');\n            taskEl.className = 'task';\n            taskEl.innerHTML = `<strong>${task.title}</strong> (${task.points} pts)`;\n            \n            if (status !== 'done') {\n                taskEl.addEventListener('click', () => moveTask(task.id, status));\n            }\n            \n            return taskEl;\n        }\n        \n        function moveTask(taskId, currentStatus) {\n            if (!sprintActive) return;\n            \n            let sourceArray, destArray;\n            \n            switch(currentStatus) {\n                case 'todo':\n                    sourceArray = todoTasks;\n                    destArray = inProgressTasks;\n                    break;\n                case 'inProgress':\n                    sourceArray = inProgressTasks;\n                    destArray = reviewTasks;\n                    break;\n                case 'review':\n                    sourceArray = reviewTasks;\n                    destArray = doneTasks;\n                    remainingStoryPoints -= sourceArray.find(t => t.id === taskId).points;\n                    break;\n                default:\n                    return;\n            }\n            \n            const taskIndex = sourceArray.findIndex(t => t.id === taskId);\n            if (taskIndex !== -1) {\n                const task = sourceArray[taskIndex];\n                destArray.push(task);\n                sourceArray.splice(taskIndex, 1);\n                renderSprintBoard();\n            }\n        }\n        \n        function setupEventListeners() {\n            startSprintBtn.addEventListener('click', startSprint);\n            dailyScrumBtn.addEventListener('click', dailyScrum);\n            completeTaskBtn.addEventListener('click', completeRandomTask);\n            endSprintBtn.addEventListener('click', endSprint);\n        }\n        \n        function startSprint() {\n            if (todoTasks.length === 0) {\n                alert(\"Please add tasks to the sprint before starting!\");\n                return;\n            }\n            \n            sprintActive = true;\n            sprintDaysRemaining = 14; // 2-week sprint\n            totalStoryPoints = todoTasks.concat(inProgressTasks, reviewTasks, doneTasks)\n                                       .reduce((sum, task) => sum + task.points, 0);\n            remainingStoryPoints = totalStoryPoints - doneTasks.reduce((sum, task) => sum + task.points, 0);\n            \n            // Initialize burndown data\n            burndownData = [remainingStoryPoints];\n            \n            startSprintBtn.disabled = true;\n            dailyScrumBtn.disabled = false;\n            completeTaskBtn.disabled = false;\n            endSprintBtn.disabled = false;\n            \n            alert(`Sprint started! ${sprintDaysRemaining} days remaining.`);\n            updateBurndownChart();\n        }\n        \n        function dailyScrum() {\n            if (!sprintActive) return;\n            \n            sprintDaysRemaining--;\n            \n            if (sprintDaysRemaining <= 0) {\n                alert(\"Sprint completed! Time for the sprint review and retrospective.\");\n                endSprint();\n                return;\n            }\n            \n            // Move some tasks randomly to simulate progress\n            if (Math.random() > 0.3 && inProgressTasks.length > 0) {\n                const randomIndex = Math.floor(Math.random() * inProgressTasks.length);\n                const task = inProgressTasks[randomIndex];\n                reviewTasks.push(task);\n                inProgressTasks.splice(randomIndex, 1);\n            }\n            \n            if (Math.random() > 0.3 && todoTasks.length > 0) {\n                const randomIndex = Math.floor(Math.random() * todoTasks.length);\n                const task = todoTasks[randomIndex];\n                inProgressTasks.push(task);\n                todoTasks.splice(randomIndex, 1);\n            }\n            \n            // Add to burndown data\n            burndownData.push(remainingStoryPoints);\n            \n            renderSprintBoard();\n            alert(`Daily scrum completed! ${sprintDaysRemaining} days remaining.`);\n        }\n        \n        function completeRandomTask() {\n            if (!sprintActive || reviewTasks.length === 0) return;\n            \n            const randomIndex = Math.floor(Math.random() * reviewTasks.length);\n            const task = reviewTasks[randomIndex];\n            doneTasks.push(task);\n            reviewTasks.splice(randomIndex, 1);\n            remainingStoryPoints -= task.points;\n            \n            renderSprintBoard();\n            alert(`Task completed: ${task.title}`);\n        }\n        \n        function endSprint() {\n            sprintActive = false;\n            \n            // Calculate velocity\n            const completedPoints = doneTasks.reduce((sum, task) => sum + task.points, 0);\n            const velocity = completedPoints / 2; // points per week\n            \n            startSprintBtn.disabled = false;\n            dailyScrumBtn.disabled = true;\n            completeTaskBtn.disabled = true;\n            endSprintBtn.disabled = true;\n            \n            alert(`Sprint ended! Team velocity: ${velocity.toFixed(1)} points per week.`);\n            \n            // Prepare for next sprint\n            const incompleteTasks = todoTasks.concat(inProgressTasks, reviewTasks);\n            todoTasks = [];\n            inProgressTasks = [];\n            reviewTasks = [];\n            doneTasks = [];\n            \n            // Some tasks go back to backlog\n            incompleteTasks.forEach(task => {\n                if (Math.random() > 0.5) { // 50% chance to return to backlog\n                    sprintBacklog.push(task);\n                } else {\n                    todoTasks.push(task); // carry over to next sprint\n                }\n            });\n            \n            renderBacklog();\n            renderSprintBoard();\n        }\n        \n        function initBurndownChart() {\n            const ctx = document.getElementById('burndownChart').getContext('2d');\n            burndownChart = new Chart(ctx, {\n                type: 'line',\n                data: {\n                    labels: [],\n                    datasets: [{\n                        label: 'Remaining Story Points',\n                        data: [],\n                        borderColor: 'rgb(75, 192, 192)',\n                        tension: 0.1,\n                        fill: false\n                    }, {\n                        label: 'Ideal Burndown',\n                        data: [],\n                        borderColor: 'rgb(255, 99, 132)',\n                        borderDash: [5, 5],\n                        tension: 0,\n                        fill: false\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    scales: {\n                        y: {\n                            beginAtZero: true,\n                            title: {\n                                display: true,\n                                text: 'Story Points'\n                            }\n                        },\n                        x: {\n                            title: {\n                                display: true,\n                                text: 'Sprint Days'\n                            }\n                        }\n                    }\n                }\n            });\n        }\n        \n        function updateBurndownChart() {\n            if (!burndownChart) return;\n            \n            const days = Array.from({length: burndownData.length}, (_, i) => i+1);\n            const idealBurndown = [];\n            \n            if (burndownData.length > 0) {\n                const increment = burndownData[0] / (days.length - 1);\n                for (let i = 0; i < days.length; i++) {\n                    idealBurndown.push(Math.max(0, burndownData[0] - (i * increment)));\n                }\n            }\n            \n            burndownChart.data.labels = days;\n            burndownChart.data.datasets[0].data = burndownData;\n            burndownChart.data.datasets[1].data = idealBurndown;\n            burndownChart.update();\n        }\n        \n        // Initialize the application\n        init();\n    </script>\n</body>\n</html>"
  },
