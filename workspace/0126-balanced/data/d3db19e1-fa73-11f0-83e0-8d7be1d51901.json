    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Static Typing Demo (TypeScript in the Browser)</title>\n<style>\n  :root { --bg:#0f1724; --panel:#0b1220; --muted:#98a0b3; --accent:#7dd3fc; --success:#86efac; --danger:#fb7185; --glass: rgba(255,255,255,0.03); }\n  body { font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin:0; background:linear-gradient(180deg,#071024,#071524 60%); color:#e6eef6; }\n  header { padding:18px 22px; border-bottom:1px solid rgba(255,255,255,0.04); display:flex; gap:16px; align-items:center; }\n  h1 { margin:0; font-size:18px; letter-spacing:0.2px; }\n  .container { display:grid; grid-template-columns: 1fr 420px; gap:18px; padding:18px; height:calc(100vh - 74px); box-sizing:border-box; }\n  .left, .right { background:var(--panel); border-radius:10px; padding:12px; box-shadow: 0 6px 18px rgba(2,6,23,0.6); overflow:auto; }\n  .left { display:flex; flex-direction:column; gap:10px; }\n  textarea { width:100%; height:320px; background:var(--glass); border:1px solid rgba(255,255,255,0.03); color: #e6eef6; padding:12px; border-radius:8px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size:13px; resize:vertical; line-height:1.5; }\n  pre { background:linear-gradient(180deg, rgba(255,255,255,0.02), transparent); padding:10px; border-radius:8px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size:13px; color:var(--muted); overflow:auto; max-height:240px; margin:0; }\n  .row { display:flex; gap:8px; align-items:center; }\n  button { background:linear-gradient(180deg,#0ea5e9,#0284c7); color:#022; border:none; padding:8px 10px; border-radius:8px; cursor:pointer; font-weight:600; }\n  button.secondary { background:transparent; color:var(--accent); border:1px solid rgba(125,211,252,0.12); }\n  select { background:transparent; color:var(--muted); border:1px solid rgba(255,255,255,0.03); padding:6px 8px; border-radius:6px; }\n  .diagnostics { background:linear-gradient(180deg, rgba(255,255,255,0.01), transparent); padding:10px; border-radius:8px; min-height:80px; }\n  .diag { padding:8px; border-radius:6px; margin-bottom:6px; font-size:13px; display:flex; gap:8px; align-items:flex-start; }\n  .diag .tag { width:72px; text-align:center; font-weight:700; border-radius:6px; padding:6px; }\n  .diag.error .tag { background:linear-gradient(180deg, rgba(251,113,133,0.12), rgba(251,113,133,0.06)); color:var(--danger); border:1px solid rgba(251,113,133,0.08); }\n  .diag.warning .tag { background:linear-gradient(180deg, rgba(255,219,92,0.08), rgba(255,219,92,0.03)); color:#ffd84c; border:1px solid rgba(255,219,92,0.06); }\n  .diag .text { color:var(--muted); }\n  .meta { font-size:12px; color:var(--muted); margin-bottom:8px; }\n  .panel-title { margin:0 0 8px 0; font-size:13px; color:var(--accent); }\n  iframe { width:100%; height:200px; border-radius:8px; border:1px solid rgba(255,255,255,0.03); background:#061022; }\n  footer { padding:12px 18px; font-size:12px; color:var(--muted); border-top:1px solid rgba(255,255,255,0.02); display:flex; justify-content:space-between; align-items:center; }\n  a { color:var(--accent); text-decoration:none; }\n  .small { font-size:12px; color:var(--muted); }\n  .flex { display:flex; gap:8px; align-items:center; }\n  .tag-inline { padding:6px 8px; border-radius:6px; font-weight:700; background:rgba(255,255,255,0.02); color:var(--muted); border:1px solid rgba(255,255,255,0.03); }\n</style>\n</head>\n<body>\n<header>\n  <div style=\"display:flex;flex-direction:column\">\n    <h1>Static Typing — Interactive Demo (TypeScript compiled in your browser)</h1>\n    <div class=\"small\">TypeScript is used here to illustrate \"static typing\": types are checked at compile time, preventing many bugs before running code.</div>\n  </div>\n  <div style=\"margin-left:auto;\" class=\"flex\">\n    <div class=\"tag-inline\">Static typing = compile-time checks</div>\n    <div class=\"small\">Dynamic typing = runtime type behavior</div>\n  </div>\n</header>\n\n<div class=\"container\">\n  <div class=\"left\">\n    <div style=\"display:flex;gap:12px;align-items:center;justify-content:space-between\">\n      <div>\n        <div class=\"panel-title\">TypeScript editor</div>\n        <div class=\"meta\">Edit TypeScript code below. Click \"Check Types\" to see compile-time diagnostics. \"Transpile & Run\" will run the emitted JavaScript in a sandboxed iframe.</div>\n      </div>\n      <div class=\"row\">\n        <select id=\"exampleSelect\" title=\"Choose an example\">\n          <option value=\"1\">1) Basic type mismatch</option>\n          <option value=\"2\">2) Interface / structural typing</option>\n          <option value=\"3\">3) Generics - safe containers</option>\n          <option value=\"4\">4) Dynamic JS equivalent (no static checks)</option>\n        </select>\n        <button id=\"checkBtn\">Check Types</button>\n        <button class=\"secondary\" id=\"transpileRunBtn\">Transpile & Run</button>\n      </div>\n    </div>\n\n    <textarea id=\"src\" spellcheck=\"false\"></textarea>\n\n    <div style=\"display:flex;gap:8px;\">\n      <button id=\"showJsBtn\" class=\"secondary\">Show emitted JavaScript</button>\n      <button id=\"resetBtn\" class=\"secondary\">Reset</button>\n      <div style=\"margin-left:auto\" class=\"small\">TypeScript compiled in browser via TypeScript compiler library</div>\n    </div>\n\n    <div style=\"display:grid;grid-template-columns:1fr 1fr; gap:10px; margin-top:10px;\">\n      <div>\n        <div class=\"panel-title\">Diagnostics</div>\n        <div id=\"diagnostics\" class=\"diagnostics\">No checks yet. Click \"Check Types\" to run the static checker.</div>\n      </div>\n\n      <div>\n        <div class=\"panel-title\">Runtime console (sandbox)</div>\n        <div style=\"background:var(--glass); padding:8px; border-radius:8px; min-height:84px;\">\n          <div id=\"consoleOutput\" class=\"small\">Run code to see console output and runtime errors here.</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"right\">\n    <div class=\"panel-title\">Emitted JavaScript</div>\n    <pre id=\"outJs\">// Emitted JavaScript will appear here after \"Transpile & Run\" or \"Show emitted JavaScript\".</pre>\n\n    <div style=\"margin-top:12px;\">\n      <div class=\"panel-title\">Sandboxed Run</div>\n      <iframe id=\"runner\" sandbox=\"allow-scripts\" srcdoc=\"<script>console.log('Sandbox ready')</script>\"></iframe>\n    </div>\n\n    <div style=\"margin-top:12px;\">\n      <div class=\"panel-title\">Explanation</div>\n      <div class=\"small\" style=\"line-height:1.5\">\n        Static typing (as in TypeScript) checks the code for type mismatches before you run it. That prevents many classes of bugs,\n        like passing wrong argument types, accessing missing properties, or incorrectly assuming a function returns a certain type.\n        This demo compiles TypeScript in your browser and shows diagnostics produced by the compiler.\n      </div>\n    </div>\n  </div>\n</div>\n\n<footer>\n  <div>This page uses the TypeScript compiler loaded in your browser. No code leaves your machine.</div>\n  <div>Want to learn more? <a href=\"https://www.typescriptlang.org/\" target=\"_blank\" rel=\"noopener\">TypeScript official site</a></div>\n</footer>\n\n<!-- Load TypeScript compiler from unpkg -->\n<script src=\"https://unpkg.com/typescript@latest/lib/typescript.js\"></script>\n<script>\n(function(){\n  const src = document.getElementById('src');\n  const diagnosticsEl = document.getElementById('diagnostics');\n  const outJs = document.getElementById('outJs');\n  const runner = document.getElementById('runner');\n  const consoleOutput = document.getElementById('consoleOutput');\n  const exampleSelect = document.getElementById('exampleSelect');\n\n  // Provide a set of examples illustrating static typing vs dynamic JS\n  const examples = {\n    \"1\": `// Basic type mismatch: TypeScript catches the error before running.\n// Try changing the line with \"age = 'thirty'\" to see a diagnostic.\n\nfunction greet(name: string) {\n  return \"Hello, \" + name.toUpperCase();\n}\n\nlet age: number = 30;\nage = 'thirty'; // <-- Type error: string assigned to number\n\nconsole.log(greet(\"Alice\"));\nconsole.log(\"Age:\", age);`,\n\n    \"2\": `// Interfaces and structural typing\ninterface Person {\n  name: string;\n  age: number;\n}\n\nfunction birthday(p: Person) {\n  p.age += 1;\n  console.log(\\`\\${p.name} is now \\${p.age}\\`);\n}\n\nconst data = { name: \"Bob\", age: 41, hobby: \"guitar\" }; // extra props allowed (structural typing)\nbirthday(data);\n\n// Missing property example (TypeScript will complain if you uncomment the next line)\n// const incomplete = { name: \"Carol\" };\n// birthday(incomplete);`,\n\n    \"3\": `// Generics: a statically-typed container\nclass Box<T> {\n  constructor(public value: T) {}\n  map<U>(fn: (v: T) => U): Box<U> {\n    return new Box(fn(this.value));\n  }\n}\n\nconst box = new Box<number>(10);\nconst strBox = box.map(n => \"Number:\" + (n * 2));\nconsole.log(strBox.value);\n\n// If you try to treat the number as a string the compiler will warn:\n// const wrong: Box<string> = box; // Type error: Box<number> is not assignable to Box<string>`,\n\n    \"4\": `// Dynamic JavaScript equivalent: no static checks here\nfunction greet(name) {\n  return \"Hello, \" + name.toUpperCase();\n}\n\nlet age = 30;\nage = 'thirty'; // no compile-time error, this might produce surprising behaviors at runtime\n\nconsole.log(greet(\"Alice\"));\nconsole.log(\"Age:\", age);`\n  };\n\n  // Initialize editor with first example\n  src.value = examples[\"1\"];\n\n  // Utility: flatten diagnostics text\n  function diagMessageText(msg) {\n    if (!msg) return \"\";\n    if (typeof msg === \"string\") return msg;\n    // TypeScript exposes ts.flattenDiagnosticMessageText\n    if (window.ts && typeof ts.flattenDiagnosticMessageText === \"function\") {\n      return ts.flattenDiagnosticMessageText(msg, '\\n');\n    }\n    // fallback\n    let out = \"\";\n    function walk(m) {\n      if (typeof m === \"string\") out += m;\n      else if (m && m.messageText) {\n        walk(m.messageText);\n        if (m.next) m.next.forEach(w => walk(w));\n      }\n    }\n    walk(msg);\n    return out;\n  }\n\n  // Display diagnostics in the UI\n  function showDiagnostics(diags) {\n    if (!diags || diags.length === 0) {\n      diagnosticsEl.innerHTML = '<div class=\"diag\" style=\"padding:10px\"><div class=\"tag\" style=\"background:linear-gradient(180deg, rgba(134,239,172,0.08), rgba(134,239,172,0.03)); color:' + getComputedStyle(document.documentElement).getPropertyValue('--success') + ';\">OK</div><div class=\"text\">No compile-time issues found.</div></div>';\n      return;\n    }\n    diagnosticsEl.innerHTML = '';\n    diags.forEach(d => {\n      const kind = ts.DiagnosticCategory[d.category] || 'Error';\n      const cls = d.category === ts.DiagnosticCategory.Error ? 'error' : (d.category === ts.DiagnosticCategory.Warning ? 'warning' : 'info');\n      const node = document.createElement('div');\n      node.className = 'diag ' + cls;\n      const tag = document.createElement('div');\n      tag.className = 'tag';\n      tag.textContent = kind.toUpperCase();\n      const text = document.createElement('div');\n      text.className = 'text';\n      let loc = '';\n      if (d.file && typeof d.start === 'number') {\n        const pos = d.file.getLineAndCharacterOfPosition(d.start);\n        loc = `${d.file.fileName}:${pos.line+1}:${pos.character+1} — `;\n      }\n      text.textContent = loc + diagMessageText(d.messageText);\n      node.appendChild(tag);\n      node.appendChild(text);\n      diagnosticsEl.appendChild(node);\n    });\n  }\n\n  // Transpile (and collect diagnostics)\n  function transpileTypeScript(source) {\n    if (!window.ts) {\n      alert('TypeScript compiler failed to load. Make sure you are online.');\n      return { js: '// compiler not available', diagnostics: [{category:2, messageText:'TypeScript compiler not available in this page.'}] };\n    }\n\n    // Use transpileModule with diagnostics reporting.\n    // Note: transpileModule provides syntactic and some semantic diagnostics.\n    const result = ts.transpileModule(source, {\n      compilerOptions: {\n        target: ts.ScriptTarget.ES2017,\n        module: ts.ModuleKind.None,\n        strict: true,\n        esModuleInterop: true,\n        skipLibCheck: true,\n        noImplicitAny: false\n      },\n      reportDiagnostics: true,\n      fileName: \"playground.ts\"\n    });\n\n    // result.diagnostics is an array of diagnostics\n    return { js: result.outputText, diagnostics: result.diagnostics || [] };\n  }\n\n  // Run transpile check and show diagnostics only\n  function checkTypes() {\n    consoleOutput.textContent = '---';\n    const value = src.value;\n    const { js, diagnostics } = transpileTypeScript(value);\n    showDiagnostics(diagnostics);\n    outJs.textContent = js;\n  }\n\n  // Transpile and run in sandboxed iframe\n  function runTranspiled() {\n    consoleOutput.textContent = '';\n    const source = src.value;\n    const { js, diagnostics } = transpileTypeScript(source);\n    showDiagnostics(diagnostics);\n    outJs.textContent = js;\n\n    // Prepare iframe content: intercept console methods and errors to show in the UI\n    const iframeHtml = `\n<!doctype html>\n<html>\n  <head><meta charset=\"utf-8\"></head>\n  <body>\n    <script>\n      (function(){\n        function send(type, args) {\n          parent.postMessage({type:type, args: Array.from(args)}, '*');\n        }\n        ['log','info','warn','error'].forEach(fn => {\n          const orig = console[fn];\n          console[fn] = function() {\n            send('console.' + fn, arguments);\n            orig.apply(console, arguments);\n          };\n        });\n        window.onerror = function(message, source, lineno, colno, error) {\n          send('runtime.error', [String(message) + ' (at ' + lineno + ':' + colno + ')']);\n        };\n      })();\n    <\\/script>\n    <script>\n    try {\n      ${js}\n    } catch(e) {\n      // If a runtime exception occurs, post it to parent\n      parent.postMessage({type:'runtime.error', args:[String(e)]}, '*');\n    }\n    <\\/script>\n  </body>\n</html>"
  },
