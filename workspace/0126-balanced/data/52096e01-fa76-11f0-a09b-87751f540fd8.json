    "content": "<html>\n<head>\n    <title>Topological Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .graph {\n            width: 800px;\n            margin: 40px auto;\n            border: 1px solid #ccc;\n            padding: 20px;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .edge {\n            width: 50px;\n            height: 10px;\n            margin: 5px;\n            background-color: #ccc;\n            border: 1px solid #ccc;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n        .edge:hover {\n            background-color: #eee;\n        }\n    </style>\n</head>\n<body>\n    <h1>Topological Sort</h1>\n    <canvas id=\"graph\"></canvas>\n    <script>\n        const graph = document.getElementById('graph');\n        const edges = [\n            ['A', 'B'],\n            ['A', 'C'],\n            ['B', 'D'],\n            ['B', 'E'],\n            ['C', 'F'],\n            ['D', 'E'],\n            ['D', 'F'],\n            ['E', 'F']\n        ];\n        const nodes = ['A', 'B', 'C', 'D', 'E', 'F'];\n\n        const drawGraph = (edges, nodes) => {\n            const canvas = document.createElement('canvas');\n            canvas.width = 800;\n            canvas.height = 600;\n            const ctx = canvas.getContext('2d');\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            ctx.beginPath();\n            ctx.strokeStyle = 'black';\n            ctx.lineWidth = 2;\n            for (let i = 0; i < edges.length; i++) {\n                ctx.moveTo(edges[i][0].x, edges[i][0].y);\n                ctx.lineTo(edges[i][1].x, edges[i][1].y);\n                ctx.stroke();\n            }\n            for (let i = 0; i < nodes.length; i++) {\n                ctx.fillStyle = 'blue';\n                ctx.beginPath();\n                ctx.arc(nodes[i].x, nodes[i].y, 20, 0, 2 * Math.PI);\n                ctx.fill();\n            }\n            graph.innerHTML = '';\n            graph.appendChild(canvas);\n        }\n\n        drawGraph(edges, nodes);\n        const mouse = document.createEvent('Mouse');\n        const event = document.createEvent('Mouse');\n        event.initEvent('click', true, false);\n        graph.addEventListener('click', (e) => {\n            const rect = e.target.getBoundingClientRect();\n            const x = e.clientX - rect.left;\n            const y = e.clientY - rect.top;\n            const node = nodes[(y / 50) * 10];\n            event = document.createEvent('Mouse', { clientX: x, clientY: y, button: 0, ctrl: false, alt: false });\n            event.initEvent('click', true, false);\n            event.target = e.target;\n            graph.dispatchEvent(event);\n        });\n\n        const sort = (graph) => {\n            const visited = new Array(graph.children.length).fill(false);\n            const stack = [];\n            const result = [];\n\n            function dfs(node) {\n                visited[node] = true;\n                for (const edge of graph.children[node]) {\n                    if (!visited[edge]) {\n                        dfs(edge);\n                    }\n                }\n                stack.push(node);\n            }\n\n            for (let i = 0; i < graph.children.length; i++) {\n                if (!visited[i]) {\n                    dfs(i);\n                }\n            }\n\n            while (stack.length > 0) {\n                const node = stack.pop();\n                result.push(node);\n                graph.children[node].forEach((edge) => {\n                    visited[edge] = false;\n                });\n                for (const edge of graph.children[node]) {\n                    if (!visited[edge]) {\n                        stack.push(edge);\n                    }\n                }\n            }\n\n            return result.reverse();\n        };\n\n        const sorted = sort(graph);\n        const sortedNodes = sorted.map((node) => nodes[node]);\n        const sortedEdges = [];\n        for (let i = 0; i < sorted.length; i++) {\n            for (let j = i + 1; j < sorted.length; j++) {\n                if (sorted[i] < sorted[j]) {\n                    sortedEdges.push([sorted[i], sorted[j]]);\n                }\n            }\n        }\n\n        drawGraph(sortedEdges, sortedNodes);\n    </script>\n</body>\n</html>"
