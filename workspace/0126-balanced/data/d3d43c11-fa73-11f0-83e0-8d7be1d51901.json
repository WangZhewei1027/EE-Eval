  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Linked List Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --card:#0b1220;\n      --muted:#94a3b8;\n      --accent:#60a5fa;\n      --accent-2:#7c3aed;\n      --good:#10b981;\n      --danger:#ef4444;\n      --glass: rgba(255,255,255,0.02);\n    }\n    *{box-sizing:border-box;font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    body{\n      margin:0;\n      min-height:100vh;\n      background:\n        linear-gradient(180deg, rgba(12,18,30,1) 0%, rgba(4,6,10,1) 100%);\n      color:#e6eef8;\n      padding:24px;\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n    }\n    .app{\n      max-width:1100px;\n      margin:0 auto;\n      display:grid;\n      grid-template-columns: 370px 1fr;\n      gap:20px;\n      align-items:start;\n    }\n    .panel{\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      padding:18px;\n      border-radius:12px;\n      box-shadow: 0 6px 30px rgba(2,6,23,0.6);\n    }\n    h1{font-size:20px;margin:0 0 8px 0;color:#f8fafc;}\n    p.lead{margin:0 0 12px 0;color:var(--muted);font-size:13px}\n    .controls{\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n    .row{display:flex;gap:8px;align-items:center;}\n    input[type=\"text\"], input[type=\"number\"], select{\n      padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:inherit;\n      outline:none;flex:1;\n    }\n    button{\n      padding:8px 10px;border-radius:8px;border:0;background:linear-gradient(90deg,var(--accent),var(--accent-2));\n      color:white;font-weight:600;cursor:pointer;\n      box-shadow:0 6px 18px rgba(99,102,241,0.12);\n    }\n    button.ghost{\n      background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted);font-weight:600;\n      box-shadow:none;\n    }\n    .small{padding:6px 8px;font-size:13px;}\n    .visual.panel{\n      min-height:320px;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n    }\n    .canvas{\n      background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));\n      border-radius:10px;padding:18px;min-height:200px;overflow:auto;border:1px dashed rgba(255,255,255,0.03);\n    }\n    .nodes{\n      display:flex;gap:18px;align-items:center;height:120px;padding:10px;\n    }\n    .node{\n      min-width:70px; height:60px;border-radius:10px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center;position:relative;\n      font-weight:700;color:#e6eef8;font-size:16px;box-shadow:0 4px 14px rgba(2,6,23,0.45);\n    }\n    .node .meta{\n      position:absolute;left:6px;top:6px;font-size:11px;color:var(--muted);font-weight:600;\n    }\n    .node .nil{\n      position:absolute;right:6px;bottom:6px;font-size:12px;color:var(--muted);\n    }\n    .arrow{\n      width:60px;height:60px;display:flex;align-items:center;justify-content:center;\n    }\n    svg{overflow:visible;}\n    .highlight{background:linear-gradient(90deg, rgba(96,165,250,0.12), rgba(124,58,237,0.08));border:1px solid rgba(96,165,250,0.15);box-shadow:0 6px 24px rgba(96,165,250,0.06);}\n    .found{background:linear-gradient(90deg, rgba(16,185,129,0.12), rgba(96,165,250,0.06));border:1px solid rgba(16,185,129,0.12);}\n    .log{\n      height:120px;overflow:auto;background:var(--glass);padding:10px;border-radius:8px;font-size:13px;color:var(--muted);\n      border:1px solid rgba(255,255,255,0.02);\n    }\n    .footer{\n      display:flex;gap:8px;align-items:center;margin-top:6px;flex-wrap:wrap;\n    }\n    .legend{display:flex;gap:8px;align-items:center;color:var(--muted);font-size:13px;}\n    .badge{width:12px;height:12px;border-radius:3px;}\n    .badge.h{background:linear-gradient(90deg,var(--accent),var(--accent-2));}\n    .badge.f{background:linear-gradient(90deg,var(--good),#34d399);}\n    .muted{color:var(--muted)}\n    .top-controls{display:flex;gap:8px;align-items:center;margin-bottom:6px;flex-wrap:wrap}\n    .tiny{font-size:12px;padding:6px 8px}\n    .note{font-size:12px;color:var(--muted);margin-top:6px}\n    @media (max-width:880px){\n      .app{grid-template-columns:1fr; padding:12px}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <div class=\"panel\">\n      <h1>Linked List (Singly) Visualizer</h1>\n      <p class=\"lead\">Interactive demo to learn how a singly linked list works. Add, insert, remove, find or reverse the list and watch the nodes and pointers update.</p>\n\n      <div class=\"controls\">\n        <div class=\"top-controls\">\n          <input id=\"valueInput\" type=\"text\" placeholder=\"Node value (string or number)\" />\n          <button id=\"appendBtn\" class=\"small\">Append</button>\n          <button id=\"prependBtn\" class=\"small ghost\">Prepend</button>\n        </div>\n\n        <div class=\"row\">\n          <input id=\"indexInput\" type=\"number\" placeholder=\"Index (0-based)\" />\n          <button id=\"insertBtn\" class=\"small\">Insert at Index</button>\n          <button id=\"removeAtBtn\" class=\"small ghost\">Remove at Index</button>\n        </div>\n\n        <div class=\"row\">\n          <input id=\"valueRemoveInput\" type=\"text\" placeholder=\"Remove by value\" />\n          <button id=\"removeValueBtn\" class=\"small\">Remove Value</button>\n          <button id=\"findBtn\" class=\"small ghost\">Find Value</button>\n        </div>\n\n        <div class=\"row\">\n          <button id=\"reverseBtn\" class=\"small\">Reverse List</button>\n          <button id=\"clearBtn\" class=\"small ghost\">Clear</button>\n          <button id=\"randomBtn\" class=\"small\">Random List</button>\n        </div>\n\n        <div class=\"row\">\n          <button id=\"traverseBtn\" class=\"small\">Traverse (animate)</button>\n          <label class=\"muted\" style=\"margin-left:8px\">Speed:\n            <select id=\"speedSelect\" style=\"margin-left:6px\">\n              <option value=\"800\">Slow</option>\n              <option value=\"400\" selected>Normal</option>\n              <option value=\"150\">Fast</option>\n            </select>\n          </label>\n        </div>\n\n        <div class=\"note\">Tips: Index 0 refers to head. Removing an absent value will do nothing. Reverse mutates the list.</div>\n      </div>\n    </div>\n\n    <div class=\"panel visual\">\n      <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n        <div>\n          <h1 style=\"font-size:16px;margin:0\">List Visualization</h1>\n          <div class=\"muted\" style=\"font-size:13px;margin-top:4px\">Nodes show value. Arrows show \"next\" pointers. Head and tail are labeled.</div>\n        </div>\n        <div style=\"text-align:right;font-size:13px;\">\n          <div class=\"muted\">Length: <span id=\"length\">0</span></div>\n          <div class=\"muted\">Head: <span id=\"headVal\">null</span></div>\n          <div class=\"muted\">Tail: <span id=\"tailVal\">null</span></div>\n        </div>\n      </div>\n\n      <div class=\"canvas\" id=\"canvas\">\n        <div class=\"nodes\" id=\"nodes\"></div>\n      </div>\n\n      <div class=\"footer\">\n        <div style=\"flex:1\">\n          <div class=\"log\" id=\"log\"></div>\n        </div>\n\n        <div style=\"min-width:180px;display:flex;flex-direction:column;gap:8px;\">\n          <div class=\"legend\"><div class=\"badge h\"></div><div class=\"muted\">Current node (traversing)</div></div>\n          <div class=\"legend\"><div class=\"badge f\"></div><div class=\"muted\">Found / removed</div></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Singly linked list implementation with common methods\n    class LinkedList {\n      constructor(){\n        this.head = null;\n        this.tail = null;\n        this.length = 0;\n      }\n\n      // Internal node structure\n      _createNode(value){\n        return { value, next: null };\n      }\n\n      append(value){\n        const node = this._createNode(value);\n        if(!this.head){\n          this.head = node;\n          this.tail = node;\n        } else {\n          this.tail.next = node;\n          this.tail = node;\n        }\n        this.length++;\n        return this;\n      }\n\n      prepend(value){\n        const node = this._createNode(value);\n        if(!this.head){\n          this.head = node;\n          this.tail = node;\n        } else {\n          node.next = this.head;\n          this.head = node;\n        }\n        this.length++;\n        return this;\n      }\n\n      insertAt(value, index){\n        if(index <= 0) return this.prepend(value);\n        if(index >= this.length) return this.append(value);\n\n        const node = this._createNode(value);\n        let prev = this.head;\n        for(let i=0;i<index-1;i++){\n          prev = prev.next;\n        }\n        node.next = prev.next;\n        prev.next = node;\n        this.length++;\n        return this;\n      }\n\n      removeAt(index){\n        if(this.length === 0) return null;\n        if(index <= 0){\n          const removed = this.head;\n          this.head = this.head.next;\n          if(!this.head) this.tail = null;\n          this.length--;\n          return removed ? removed.value : null;\n        }\n        if(index >= this.length - 1){\n          // remove tail\n          let prev = this.head;\n          for(let i=0;i<this.length-2;i++){\n            prev = prev.next;\n          }\n          const removed = this.tail;\n          prev.next = null;\n          this.tail = prev;\n          this.length--;\n          if(this.length===0) { this.head = null; this.tail = null; }\n          return removed ? removed.value : null;\n        }\n        let prev = this.head;\n        for(let i=0;i<index-1;i++){\n          prev = prev.next;\n        }\n        const removed = prev.next;\n        prev.next = removed.next;\n        this.length--;\n        return removed ? removed.value : null;\n      }\n\n      removeValue(value){\n        if(this.length === 0) return false;\n        if(this.head.value == value){\n          this.head = this.head.next;\n          this.length--;\n          if(this.length === 0) this.tail = null;\n          return true;\n        }\n        let prev = this.head;\n        while(prev.next && prev.next.value != value){\n          prev = prev.next;\n        }\n        if(prev.next){\n          if(prev.next === this.tail){\n            this.tail = prev;\n            prev.next = null;\n          } else {\n            prev.next = prev.next.next;\n          }\n          this.length--;\n          return true;\n        }\n        return false;\n      }\n\n      find(value){\n        let index = 0;\n        let node = this.head;\n        while(node){\n          if(node.value == value) return index;\n          node = node.next;\n          index++;\n        }\n        return -1;\n      }\n\n      toArray(){\n        const arr = [];\n        let node = this.head;\n        while(node){\n          arr.push(node.value);\n          node = node.next;\n        }\n        return arr;\n      }\n\n      clear(){\n        this.head = null;\n        this.tail = null;\n        this.length = 0;\n      }\n\n      reverse(){\n        let prev = null;\n        let current = this.head;\n        this.tail = this.head;\n        while(current){\n          const next = current.next;\n          current.next = prev;\n          prev = current;\n          current = next;\n        }\n        this.head = prev;\n      }\n    }\n\n    // UI bindings and visualization logic\n    const list = new LinkedList();\n\n    const nodesContainer = document.getElementById('nodes');\n    const lengthEl = document.getElementById('length');\n    const headVal = document.getElementById('headVal');\n    const tailVal = document.getElementById('tailVal');\n    const logEl = document.getElementById('log');\n\n    // Input elements\n    const valueInput = document.getElementById('valueInput');\n    const appendBtn = document.getElementById('appendBtn');\n    const prependBtn = document.getElementById('prependBtn');\n    const insertBtn = document.getElementById('insertBtn');\n    const indexInput = document.getElementById('indexInput');\n    const removeAtBtn = document.getElementById('removeAtBtn');\n    const removeValueBtn = document.getElementById('removeValueBtn');\n    const valueRemoveInput = document.getElementById('valueRemoveInput');\n    const findBtn = document.getElementById('findBtn');\n    const reverseBtn = document.getElementById('reverseBtn');\n    const clearBtn = document.getElementById('clearBtn');\n    const randomBtn = document.getElementById('randomBtn');\n    const traverseBtn = document.getElementById('traverseBtn');\n    const speedSelect = document.getElementById('speedSelect');\n\n    // Utility: log messages\n    function log(msg, type){\n      const line = document.createElement('div');\n      line.textContent = (new Date()).toLocaleTimeString() + ' — ' + msg;\n      if(type === 'error') line.style.color = 'var(--danger)';\n      else if(type === 'ok') line.style.color = 'var(--good)';\n      logEl.prepend(line);\n    }\n\n    // Render function: builds DOM nodes + arrows for current list\n    function render(highlightIndex = -1, foundIndex = -1){\n      nodesContainer.innerHTML = '';\n      const arr = list.toArray();\n      lengthEl.textContent = list.length;\n      headVal.textContent = list.head ? String(list.head.value) : 'null';\n      tailVal.textContent = list.tail ? String(list.tail.value) : 'null';\n\n      arr.forEach((val, i) => {\n        const nodeEl = document.createElement('div');\n        nodeEl.className = 'node';\n        if(i === highlightIndex) nodeEl.classList.add('highlight');\n        if(i === foundIndex) nodeEl.classList.add('found');\n\n        const meta = document.createElement('div');\n        meta.className='meta';\n        if(i===0) meta.textContent = 'head';\n        else if(i===arr.length-1) meta.textContent = 'tail';\n        nodeEl.appendChild(meta);\n\n        const text = document.createElement('div');\n        text.textContent = String(val);\n        nodeEl.appendChild(text);\n\n        const nil = document.createElement('div');\n        nil.className='nil';\n        nil.textContent = (i===arr.length-1) ? 'null' : '';\n        nodeEl.appendChild(nil);\n\n        nodesContainer.appendChild(nodeEl);\n\n        // arrow between nodes (except after last)\n        if(i < arr.length -1){\n          const arrowWrap = document.createElement('div');\n          arrowWrap.className='arrow';\n          arrowWrap.innerHTML = `\n            <svg width=\"40\" height=\"24\" viewBox=\"0 0 40 24\" xmlns=\"http://www.w3.org/2000/svg\">\n              <defs>\n                <marker id=\"arrowhead\" viewBox=\"0 0 10 10\" refX=\"9\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto\">\n                  <path d=\"M 0 0 L 10 5 L 0 10 z\" fill=\"#cfe8ff\"></path>\n                </marker>\n              </defs>\n              <path d=\"M0 12 L34 12\" stroke=\"#9fbbe6\" stroke-width=\"2\" fill=\"none\" marker-end=\"url(#arrowhead)\"></path>\n            </svg>\n          `;\n          nodesContainer.appendChild(arrowWrap);\n        }\n      });\n\n      if(arr.length === 0){\n        const placeholder = document.createElement('div');\n        placeholder.className = 'muted';\n        placeholder.textContent = 'The list is empty. Use append or prepend to add nodes.';\n        nodesContainer.appendChild(placeholder);\n      }\n    }\n\n    // Basic operations wired to UI\n    appendBtn.addEventListener('click', ()=>{\n      const v = valueInput.value.trim();\n      if(v === '') { log('Please enter a value to append.', 'error'); return; }\n      list.append(parsedValue(v));\n      render();\n      log(`Appended \"${v}\"`, 'ok');\n      valueInput.value='';\n    });\n\n    prependBtn.addEventListener('click', ()=>{\n      const v = valueInput.value.trim();\n      if(v === '') { log('Please enter a value to prepend.', 'error'); return; }\n      list.prepend(parsedValue(v));\n      render();\n      log(`Prepended \"${v}\"`, 'ok');\n      valueInput.value='';\n    });\n\n    insertBtn.addEventListener('click', ()=>{\n      const v = valueInput.value.trim();\n      const idx = parseInt(indexInput.value, 10);\n      if(isNaN(idx)) { log('Enter a valid index to insert at.', 'error'); return; }\n      if(v === '') { log('Enter a value to insert.', 'error'); return; }\n      list.insertAt(parsedValue(v), idx);\n      render();\n      log(`Inserted \"${v}\" at index ${idx}`, 'ok');\n      valueInput.value=''; indexInput.value='';\n    });\n\n    removeAtBtn.addEventListener('click', ()=>{\n      const idx = parseInt(indexInput.value, 10);\n      if(isNaN(idx)) { log('Enter a valid index to remove.', 'error'); return; }\n      const removed = list.removeAt(idx);\n      if(removed === null || removed === undefined){\n        log(`Nothing removed at index ${idx}.`, 'error');\n      } else {\n        render();\n        log(`Removed value \"${removed}\" at index ${idx}`, 'ok');\n      }\n      indexInput.value='';\n    });\n\n    removeValueBtn.addEventListener('click', ()=>{\n      const v = valueRemoveInput.value.trim();\n      if(v === '') { log('Enter a value to remove.', 'error'); return; }\n      const ok = list.removeValue(parsedValue(v));\n      if(ok){\n        render();\n        log(`Removed first occurrence of \"${v}\"`, 'ok');\n      } else {\n        log(`Value \"${v}\" not found.`, 'error');\n      }\n      valueRemoveInput.value='';\n    });\n\n    findBtn.addEventListener('click', async ()=>{\n      const v = valueRemoveInput.value.trim() || valueInput.value.trim();\n      if(v === '') { log('Enter a value to find (in value or remove input).', 'error'); return; }\n      const idx = list.find(parsedValue(v));\n      if(idx === -1){\n        log(`Value \"${v}\" not found.`, 'error');\n        render();\n      } else {\n        log(`Value \"${v}\" found at index ${idx}`, 'ok');\n        // animate highlight when found\n        await animateTraversal(idx);\n        render(-1, idx);\n      }\n    });\n\n    reverseBtn.addEventListener('click', ()=>{\n      list.reverse();\n      render();\n      log('List reversed', 'ok');\n    });\n\n    clearBtn.addEventListener('click', ()=>{\n      list.clear();\n      render();\n      log('List cleared', 'ok');\n    });\n\n    randomBtn.addEventListener('click', ()=>{\n      list.clear();\n      const n = Math.floor(Math.random()*6)+2;\n      for(let i=0;i<n;i++){\n        list.append(Math.floor(Math.random()*100));\n      }\n      render();\n      log(`Random list generated (${n} nodes)`, 'ok');\n    });\n\n    // Traversal animation: highlights nodes one by one\n    let traversalCancel = false;\n    traverseBtn.addEventListener('click', async ()=>{\n      if(list.length === 0){ log('List is empty.', 'error'); return; }\n      traversalCancel = false;\n      await animateTraversal();\n    });\n\n    // animateTraversal optionally stops at foundIndex\n    async function animateTraversal(stopIndex = -1){\n      const speed = parseInt(speedSelect.value, 10);\n      let node = list.head;\n      let idx = 0;\n      while(node){\n        if(traversalCancel) break;\n        render(idx, -1);\n        log(`Visiting index ${idx} (value: ${String(node.value)})`);\n        await sleep(speed);\n        if(idx === stopIndex){\n          render(idx, idx);\n          log(`Stopped at index ${idx}. Found value.`);\n          return;\n        }\n        node = node.next;\n        idx++;\n      }\n      render();\n    }\n\n    function sleep(ms){ return new Promise(r => setTimeout(r, ms)); }\n\n    // Allow clicking on nodes to remove them (for exploration)\n    nodesContainer.addEventListener('click', (e)=>{\n      const nodeDiv = e.target.closest('.node');\n      if(!nodeDiv) return;\n      const parent = Array.from(nodesContainer.children).filter(c => c.classList && c.classList.contains('node'));\n      const index = parent.indexOf(nodeDiv);\n      if(index >=0){\n        const val = list.removeAt(index);\n        render();\n        log(`Removed node at index ${index} (value: \"${val}\")`, 'ok');\n      }\n    });\n\n    // Parse entered string into number if looks numeric (so user can type numbers easily)\n    function parsedValue(s){\n      if(s === null || s === undefined) return s;\n      // treat as number if it is a numeric literal (integer or float)\n      if(/^[-+]?\\d+(\\.\\d+)?$/.test(s.trim())) return Number(s);\n      return s;\n    }\n\n    // Initialize with a small sample list\n    list.append(10);\n    list.append(20);\n    list.append(30);\n    render();\n\n    // Prevent long text selection annoyances\n    document.addEventListener('selectstart', (e)=>{\n      // allow input selection only\n      if(e.target.tagName !== 'INPUT' && e.target.tagName !== 'TEXTAREA') e.preventDefault();\n    });\n\n    // Accessibility: keyboard shortcuts (optional)\n    document.addEventListener('keydown', (e)=>{\n      if(e.ctrlKey && e.key.toLowerCase() === 'z'){ // Ctrl+Z clears logs\n        logEl.innerHTML='';\n        log('Logs cleared.');\n      }\n    });\n\n    // expose some helpers for debugging in console (optional)\n    window._list = list;\n    window._render = render;\n  </script>\n</body>\n</html>"
  },
