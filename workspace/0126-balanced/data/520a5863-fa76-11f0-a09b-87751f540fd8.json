    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Paging</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        table {\n            border-collapse: collapse;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n        th {\n            background-color: #f0f0f0;\n        }\n    </style>\n</head>\n<body>\n    <h1>Paging</h1>\n    <table>\n        <thead>\n            <tr>\n                <th>Page Number</th>\n                <th>First Name</th>\n                <th>Last Name</th>\n                <th>Age</th>\n                <th>City</th>\n            </tr>\n        </thead>\n        <tbody id=\"data\">\n            <!-- data will be generated dynamically -->\n        </tbody>\n    </table>\n    <script>\n        let data = [];\n        let currentPage = 1;\n        let totalPages = 10;\n\n        function loadData() {\n            fetch('data.json')\n                .then(response => response.json())\n                .then(data => {\n                    let body = document.getElementById('data');\n                    body.innerHTML = '';\n                    data.forEach(item => {\n                        let row = document.createElement('tr');\n                        row.innerHTML = `\n                            <td>${item.pageNumber}</td>\n                            <td>${item.firstName}</td>\n                            <td>${item.lastName}</td>\n                            <td>${item.age}</td>\n                            <td>${item.city}</td>\n                        `;\n                        body.appendChild(row);\n                    });\n                });\n        }\n\n        function paging() {\n            loadData();\n            let paginatedData = [];\n            for (let i = 0; i < data.length; i += 10) {\n                paginatedData.push(data.slice(i, i + 10));\n            }\n            let startIndex = (currentPage - 1) * 10;\n            let endIndex = startIndex + 10;\n            paginatedData = paginatedData.slice(startIndex, endIndex);\n            let tableBody = document.getElementById('data');\n            tableBody.innerHTML = '';\n            paginatedData.forEach(item => {\n                let row = document.createElement('tr');\n                row.innerHTML = `\n                    <td>${item.pageNumber}</td>\n                    <td>${item.firstName}</td>\n                    <td>${item.lastName}</td>\n                    <td>${item.age}</td>\n                    <td>${item.city}</td>\n                `;\n                tableBody.appendChild(row);\n            });\n            currentPage++;\n        }\n\n        loadData();\n        paging();\n    </script>\n</body>\n</html>"
