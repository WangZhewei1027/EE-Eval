natureElement.innerText = 'Signature verification failed!';\n                }\n            });\n\n            function generateSignature() {\n                const message = document.createElement('textarea');\n                message.value = signatureData;\n                message.style.display = 'block';\n                generateSignatureButton.disabled = true;\n                verifySignatureButton.disabled = false;\n\n                let canvas = document.createElement('canvas');\n                canvas.width = 200;\n                canvas.height = 100;\n                const ctx = canvas.getContext('2d');\n                ctx.clearRect(0, 0, canvas.width, canvas.height);\n                ctx.font = '24px Arial';\n                ctx.textAlign = 'left';\n                ctx.textBaseline = 'top';\n                ctx.fillStyle = 'black';\n                ctx.fillText(signatureData, 10, 10);\n                ctx.stroke();\n\n                signature = canvas.toDataURL();\n                generateSignatureButton.disabled = false;\n                verifySignatureButton.disabled = true;\n            }\n\n            function verifySignature() {\n                const message = document.createElement('textarea');\n                message.value = signature;\n                message.style.display = 'block';\n                generateSignatureButton.disabled = true;\n                verifySignatureButton.disabled = false;\n\n                let canvas = document.createElement('canvas');\n                canvas.width = 200;\n                canvas.height = 100;\n                const ctx = canvas.getContext('2d');\n                ctx.clearRect(0, 0, canvas.width, canvas.height);\n                ctx.font = '24px Arial';\n                ctx.textAlign = 'left';\n                ctx.textBaseline = 'top';\n                ctx.fillStyle = 'black';\n                ctx.fillText(message.value, 10, 10);\n                ctx.stroke();\n\n                try {\n                    const dataURL = canvas.toDataURL();\n                    if (dataURL === signature) {\n                        signatureElement.innerText = 'Signature verified!';\n                    } else {\n                        signatureElement.innerText = 'Signature verification failed!';\n                    }\n                } catch (e) {\n                    signatureElement.innerText = 'Error: ' + e.message;\n                }\n\n                return false;\n            }\n        </script>\n    </div>\n</body>\n</html>"
