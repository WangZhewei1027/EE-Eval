    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Backtracking Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        #output {\n            margin-top: 20px;\n            white-space: pre-wrap; /* Preserve whitespace */\n        }\n        .btn {\n            padding: 10px 20px;\n            margin-top: 20px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Backtracking Demo: N-Queens Problem</h1>\n<p>This demo demonstrates the backtracking algorithm using the N-Queens problem, where we place N queens on an N×N chessboard such that no two queens threaten each other.</p>\n<div>\n    <label for=\"n\">Enter the number of queens (N): </label>\n    <input type=\"number\" id=\"n\" value=\"4\" min=\"1\" />\n    <button class=\"btn\" id=\"solve\">Solve</button>\n</div>\n\n<h2>Solution(s)</h2>\n<pre id=\"output\"></pre>\n\n<script>\n    function isSafe(board, row, col, N) {\n        // Check this row on left side\n        for (let i = 0; i < col; i++) {\n            if (board[row][i]) return false;\n        }\n        // Check upper diagonal on left side\n        for (let i = row, j = col; i >= 0 && j >= 0; i--, j--) {\n            if (board[i][j]) return false;\n        }\n        // Check lower diagonal on left side\n        for (let i = row, j = col; j >= 0 && i < N; i++, j--) {\n            if (board[i][j]) return false;\n        }\n        return true;\n    }\n\n    function solveNQueensUtil(board, col, N, solutions) {\n        if (col >= N) {\n            const solution = board.map(row => row.map(val => (val ? 'Q' : '.')).join('')).join('\\n');\n            solutions.push(solution);\n            return;\n        }\n\n        for (let i = 0; i < N; i++) {\n            if (isSafe(board, i, col, N)) {\n                board[i][col] = true; // Place queen\n                solveNQueensUtil(board, col + 1, N, solutions); // Recur to place the rest\n                board[i][col] = false; // Backtrack\n            }\n        }\n    }\n\n    function solveNQueens(N) {\n        const board = Array.from({ length: N }, () => Array(N).fill(false));\n        const solutions = [];\n        solveNQueensUtil(board, 0, N, solutions);\n        return solutions;\n    }\n\n    document.getElementById('solve').addEventListener('click', () => {\n        const N = parseInt(document.getElementById('n').value);\n        const outputElement = document.getElementById('output');\n        outputElement.textContent = '';\n\n        if (N < 1) {\n            outputElement.textContent = 'Please enter a valid number of queens.';\n            return;\n        }\n\n        const solutions = solveNQueens(N);\n        if (solutions.length === 0) {\n            outputElement.textContent = 'No solutions found.';\n        } else {\n            outputElement.textContent = solutions.join('\\n\\n'); // separate solutions\n        }\n    });\n</script>\n\n</body>\n</html>"
