    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Bubble Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    padding: 1rem;\n    background: #f0f4f8;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    margin-bottom: 0.2rem;\n  }\n  #array-container {\n    margin-top: 2rem;\n    display: flex;\n    align-items: flex-end;\n    gap: 4px;\n    height: 200px;\n    width: 90vw;\n    max-width: 600px;\n    border-bottom: 2px solid #333;\n  }\n  .bar {\n    background-color: #48a9e6;\n    width: 20px;\n    transition: background-color 0.3s ease;\n    border-radius: 3px 3px 0 0;\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n    color: white;\n    font-size: 12px;\n    user-select: none;\n  }\n  .bar.comparing {\n    background-color: #f08c00;\n  }\n  .bar.swapped {\n    background-color: #e63946;\n  }\n  button {\n    margin-top: 1rem;\n    padding: 0.5rem 1.5rem;\n    font-size: 1rem;\n    cursor: pointer;\n    border: none;\n    background-color: #48a9e6;\n    color: white;\n    border-radius: 4px;\n    transition: background-color 0.3s ease;\n  }\n  button:disabled {\n    background-color: #a0c8f8;\n    cursor: not-allowed;\n  }\n  #description {\n    max-width: 600px;\n    margin-top: 1rem;\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n<h1>Bubble Sort Visualization</h1>\n<div id=\"array-container\"></div>\n<button id=\"start-btn\">Start Bubble Sort</button>\n<div id=\"description\">\n  <p>\n    Bubble Sort is a simple sorting algorithm that works by repeatedly swapping adjacent elements if they are in the wrong order.\n  </p>\n  <p>\n    The largest values \"bubble\" to the end of the array with each pass.\n  </p>\n</div>\n\n<script>\n  const container = document.getElementById('array-container');\n  const startBtn = document.getElementById('start-btn');\n\n  const ARRAY_SIZE = 20;\n  const DELAY = 250; // ms delay for visualization\n\n  // Generate a random array of integers\n  let array = [];\n  function generateArray() {\n    array = [];\n    for (let i = 0; i < ARRAY_SIZE; i++) {\n      array.push(Math.floor(Math.random() * 150) + 10);\n    }\n  }\n\n  // Render the array as bars\n  function renderArray(arr, highlighted = [], swapped = []) {\n    container.innerHTML = '';\n    for (let i = 0; i < arr.length; i++) {\n      const bar = document.createElement('div');\n      bar.classList.add('bar');\n      bar.style.height = arr[i] + 'px';\n      bar.textContent = arr[i];\n\n      if (highlighted.includes(i)) bar.classList.add('comparing');\n      if (swapped.includes(i)) bar.classList.add('swapped');\n\n      container.appendChild(bar);\n    }\n  }\n\n  // Sleep function for delay\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Bubble Sort with visualization\n  async function bubbleSort(arr) {\n    const n = arr.length;\n    let swappedSomething = false;\n    for (let i = 0; i < n - 1; i++) {\n      swappedSomething = false;\n      for (let j = 0; j < n - i - 1; j++) {\n        renderArray(arr, [j, j+1]);\n        await sleep(DELAY);\n\n        if (arr[j] > arr[j + 1]) {\n          // Swap\n          [arr[j], arr[j + 1]] = [arr[j + 1], arr[j]];\n          swappedSomething = true;\n\n          renderArray(arr, [], [j, j + 1]);\n          await sleep(DELAY);\n        }\n      }\n      if (!swappedSomething) break; // If no swaps, array is sorted\n    }\n    renderArray(arr); // Final render with no highlights\n  }\n\n  // Initialize and render random array\n  generateArray();\n  renderArray(array);\n\n  startBtn.addEventListener('click', async () => {\n    startBtn.disabled = true;\n    await bubbleSort(array);\n    startBtn.disabled = false;\n  });\n</script>\n</body>\n</html>"
