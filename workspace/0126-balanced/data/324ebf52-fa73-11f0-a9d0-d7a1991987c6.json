    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Semaphore Concept Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background-color: #f0f0f0;\n        }\n        #semaphore {\n            width: 100px;\n            height: 300px;\n            border: 5px solid #333;\n            position: relative;\n            margin: 0 20px;\n        }\n        .light {\n            width: 100%;\n            height: 100px;\n            border-radius: 50%;\n            margin: 5px 0;\n            opacity: 0.3;\n            transition: opacity 0.5s;\n        }\n        #red { background: red; }\n        #yellow { background: yellow; }\n        #green { background: green; }\n        button {\n            padding: 10px 20px;\n            font-size: 16px;\n            cursor: pointer;\n        }\n    </style>\n</head>\n<body>\n\n<div id=\"semaphore\">\n    <div id=\"red\" class=\"light\"></div>\n    <div id=\"yellow\" class=\"light\"></div>\n    <div id=\"green\" class=\"light\"></div>\n</div>\n<button onclick=\"startSemaphore()\">Start Semaphore</button>\n\n<script>\n    let currentLight = 0; // start with the red light\n    const lights = ['red', 'yellow', 'green'];\n    \n    function startSemaphore() {\n        currentLight = 0; // reset to red\n        setLight(currentLight);\n        \n        // Change lights every 2 seconds\n        setInterval(() => {\n            currentLight = (currentLight + 1) % lights.length; // cycle through lights\n            setLight(currentLight);\n        }, 2000);\n    }\n\n    function setLight(index) {\n        // Turn off all lights\n        document.querySelectorAll('.light').forEach(light => {\n            light.style.opacity = '0.3';\n        });\n        // Turn on current light\n        document.getElementById(lights[index]).style.opacity = '1';\n    }\n</script>\n\n</body>\n</html>"
