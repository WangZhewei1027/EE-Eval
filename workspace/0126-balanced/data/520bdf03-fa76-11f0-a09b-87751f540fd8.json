    "content": "<html>\n<head>\n    <title>Symmetric Cryptography</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        .container {\n            max-width: 400px;\n            margin: 40px auto;\n            padding: 20px;\n            background-color: #f9f9f9;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        .header {\n            text-align: center;\n            margin-bottom: 20px;\n        }\n        .header h1 {\n            font-size: 24px;\n            margin-bottom: 10px;\n        }\n        .header p {\n            font-size: 18px;\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <h1>Symmetric Cryptography</h1>\n        <p>Symmetric cryptography is a method of secure communication where the same key is used for both encryption and decryption.</p>\n        <p>It uses a single key for both encryption and decryption, and it is typically used for data that needs to be transmitted securely.</p>\n        <button onclick=\"symmetricCryptography()\">Symmetric Cryptography Example</button>\n        <div id=\"output\"></div>\n    </div>\n\n    <script>\n        let symmetricCryptography = (key, data) => {\n            let encrypted = crypto.subtle.encrypt({\n                name: 'AES-GCM',\n                iv: crypto.randomBytes(12),\n                mode: 'gcm',\n                padding: 'pkcs7',\n                live: true\n            }, key, data);\n            return encrypted;\n        };\n\n        let encryptedData = symmetricCryptography('mySecretKey', 'Hello, World!');\n        let decryptedData = symmetricCryptography(encryptedData, 'mySecretKey');\n        document.getElementById('output').innerHTML = 'Encrypted: <pre>' + encryptedData + '</pre><br>Decrypted: <pre>' + decryptedData + '</pre>';\n    </script>\n</body>\n</html>"
