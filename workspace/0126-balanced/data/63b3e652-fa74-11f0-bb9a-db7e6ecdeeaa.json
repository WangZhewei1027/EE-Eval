    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Interpreter Pattern Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2rem;\n      background: #f5f5f5;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n      margin-bottom: 1rem;\n    }\n    #inputArea, #outputArea {\n      width: 100%;\n      box-sizing: border-box;\n      font-size: 1rem;\n      padding: 0.5rem;\n      border: 1px solid #ccc;\n      border-radius: 4px;\n      margin-bottom: 1rem;\n      font-family: monospace;\n      background: white;\n    }\n    button {\n      padding: 0.5rem 1rem;\n      font-size: 1rem;\n      border: none;\n      border-radius: 4px;\n      background-color: #007bff;\n      color: white;\n      cursor: pointer;\n    }\n    button:disabled {\n      background-color: #a0c7ff;\n      cursor: not-allowed;\n    }\n    #explanation {\n      max-width: 600px;\n      margin: 2rem auto 0 auto;\n      font-size: 1rem;\n      line-height: 1.4;\n      background: white;\n      padding: 1rem;\n      border-radius: 8px;\n      box-shadow: 0 0 10px rgba(0,0,0,0.1);\n    }\n    #history {\n      max-width: 600px;\n      margin: 1rem auto 0 auto;\n      background: white;\n      padding: 1rem;\n      border-radius: 8px;\n      box-shadow: 0 0 10px rgba(0,0,0,0.1);\n      max-height: 150px;\n      overflow-y: auto;\n      font-family: monospace;\n      font-size: 0.9rem;\n    }\n    #history h3 {\n      margin-top: 0;\n    }\n  </style>\n</head>\n<body>\n  <h1>Interpreter Pattern Demo</h1>\n  <textarea id=\"inputArea\" rows=\"3\" placeholder=\"Enter simple arithmetic expressions (e.g. '7 + 3 - 2')\"></textarea>\n  <br />\n  <button id=\"interpretBtn\">Interpret Expression</button>\n  <h3>Result:</h3>\n  <pre id=\"outputArea\"></pre>\n\n  <div id=\"explanation\">\n    <h2>About the Interpreter Pattern</h2>\n    <p>\n      The <b>Interpreter Pattern</b> is a behavioral design pattern that defines a grammatical representation for a language,\n      and provides an interpreter to deal with this grammar.\n    </p>\n    <p>\n      In this demo, we interpret simple arithmetic expressions containing addition and subtraction of integers.\n      Each number or operation is represented by an Expression object.\n      The <code>interpret()</code> method executes the expression and returns a result.\n    </p>\n    <p>\n      The key concept is to represent sentences or expressions as a tree of expressions, each knowing how to interpret itself.\n    </p>\n  </div>\n\n  <div id=\"history\">\n    <h3>Evaluation History</h3>\n    <ul id=\"historyList\"></ul>\n  </div>\n\n<script>\n  // Abstract Expression interface\n  class Expression {\n    interpret() {\n      throw new Error(\"interpret() not implemented\");\n    }\n  }\n\n  // Terminal Expression: Number\n  class NumberExpression extends Expression {\n    constructor(number) {\n      super();\n      this.number = number;\n    }\n    interpret() {\n      return this.number;\n    }\n  }\n\n  // Non-Terminal Expression: Plus\n  class AddExpression extends Expression {\n    constructor(left, right) {\n      super();\n      this.left = left;\n      this.right = right;\n    }\n    interpret() {\n      return this.left.interpret() + this.right.interpret();\n    }\n  }\n\n  // Non-Terminal Expression: Minus\n  class SubtractExpression extends Expression {\n    constructor(left, right) {\n      super();\n      this.left = left;\n      this.right = right;\n    }\n    interpret() {\n      return this.left.interpret() - this.right.interpret();\n    }\n  }\n\n  // Parser and Interpreter for basic expressions with + and -\n  class Interpreter {\n    constructor(expressionStr) {\n      this.tokens = this.tokenize(expressionStr);\n      this.current = 0;\n    }\n\n    // Simple tokenizer: splits numbers and operators\n    tokenize(str) {\n      // Remove spaces and split by operators and numbers\n      // e.g. \"7 + 3 - 2\" -> [\"7\", \"+\", \"3\", \"-\", \"2\"]\n      const regex = /\\s*([-+])\\s*|\\s*(\\d+)\\s*/g;\n      let tokens = [];\n      let match;\n      let lastIndex = 0;\n\n      while((match = regex.exec(str)) !== null) {\n        if (match.index > lastIndex) {\n          // Extract any leftover whitespace or invalid tokens\n          const leftover = str.substring(lastIndex, match.index).trim();\n          if (leftover) {\n            throw new Error(\"Invalid token: \" + leftover);\n          }\n        }\n        if(match[1]) {\n          tokens.push(match[1]);\n        } else if(match[2]) {\n          tokens.push(match[2]);\n        }\n        lastIndex = regex.lastIndex;\n      }\n      // check if leftover at end\n      if(lastIndex < str.length) {\n        let leftoverEnd = str.substring(lastIndex).trim();\n        if(leftoverEnd) {\n          throw new Error(\"Invalid token at end: \" + leftoverEnd);\n        }\n      }\n      return tokens;\n    }\n\n    // Parse tokens into an abstract syntax tree (AST)\n    parse() {\n      if(this.tokens.length === 0) {\n        throw new Error(\"Empty expression\");\n      }\n      // Grammar (Left to Right Evaluation):\n      // expr := number {( \"+\" | \"-\" ) number}\n\n      let left = this.parseNumber();\n\n      while(this.current < this.tokens.length) {\n        const operator = this.tokens[this.current++];\n        const right = this.parseNumber();\n\n        if(operator === \"+\") {\n          left = new AddExpression(left, right);\n        } else if(operator === \"-\") {\n          left = new SubtractExpression(left, right);\n        } else {\n          throw new Error(\"Unknown operator: \" + operator);\n        }\n      }\n\n      return left;\n    }\n\n    parseNumber() {\n      if(this.current >= this.tokens.length) {\n        throw new Error(\"Number expected but no more tokens\");\n      }\n      const token = this.tokens[this.current++];\n      if(!/^\\d+$/.test(token)) {\n        throw new Error(\"Number expected but got: \" + token);\n      }\n      return new NumberExpression(parseInt(token, 10));\n    }\n  }\n\n  // UI bindings\n  const inputArea = document.getElementById(\"inputArea\");\n  const outputArea = document.getElementById(\"outputArea\");\n  const interpretBtn = document.getElementById(\"interpretBtn\");\n  const historyList = document.getElementById(\"historyList\");\n\n  interpretBtn.addEventListener(\"click\", () => {\n    const input = inputArea.value.trim();\n    outputArea.textContent = \"\";\n    if(!input) {\n      outputArea.textContent = \"Please enter an expression to interpret.\";\n      return;\n    }\n\n    try {\n      const interpreter = new Interpreter(input);\n      const expressionTree = interpreter.parse();\n      const result = expressionTree.interpret();\n      outputArea.textContent = `${input} = ${result}`;\n      addHistoryItem(input, result);\n    } catch (e) {\n      outputArea.textContent = \"Error: \" + e.message;\n    }\n  });\n\n  function addHistoryItem(expr, result) {\n    const li = document.createElement(\"li\");\n    li.textContent = `${expr} = ${result}`;\n    historyList.prepend(li);\n  }\n</script>\n</body>\n</html>"
