    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>Binary Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 0;\n            overflow-x: hidden;\n            background: #f4f4f9;\n        }\n        header {\n            background-color: #3f51b5;\n            color: white;\n            padding: 1em;\n            text-align: center;\n        }\n        #tree-container {\n            width: 100%;\n            height: 600px;\n            background: white;\n            border: 1px solid #ccc;\n            margin: 1em auto;\n            position: relative;\n            overflow: auto;\n        }\n        #controls {\n            max-width: 700px;\n            margin: 1em auto;\n            padding: 1em;\n            background: white;\n            border-radius: 8px;\n            box-shadow: 0 2px 6px rgba(0,0,0,0.1);\n        }\n        #controls input[type=\"number\"] {\n            width: 100px;\n            padding: 5px;\n            font-size: 1rem;\n            margin-right: 0.5em;\n        }\n        #controls button {\n            padding: 6px 12px;\n            font-size: 1rem;\n            background-color: #3f51b5;\n            border: none;\n            border-radius: 4px;\n            color: white;\n            cursor: pointer;\n            margin-right: 0.5em;\n        }\n        #controls button:hover{\n            background-color: #303f9f;\n        }\n        #description {\n            max-width: 700px;\n            margin: 1em auto;\n            background: white;\n            padding: 1em;\n            border-radius: 8px;\n            box-shadow: 0 2px 6px rgba(0,0,0,0.1);\n            line-height: 1.5;\n        }\n        svg {\n            overflow: visible;\n            user-select: none;\n        }\n        .node circle {\n            fill: #3f51b5;\n            stroke: #2c387e;\n            stroke-width: 2px;\n            cursor: pointer;\n            transition: fill 0.3s;\n        }\n        .node text {\n            fill: white;\n            font-weight: bold;\n            pointer-events: none;\n            user-select: none;\n        }\n        .node:hover circle {\n            fill: #283593;\n        }\n        .edge {\n            stroke: #555;\n            stroke-width: 2px;\n        }\n    </style>\n</head>\n<body>\n\n<header>\n    <h1>Binary Tree Visualization</h1>\n</header>\n\n<section id=\"description\">\n    <p>\n        A <strong>binary tree</strong> is a hierarchical data structure in which each node has at most two children,\n        referred to as <em>left</em> child and <em>right</em> child. It is commonly used in computer science for efficient searching, sorting, and hierarchical data representation.\n    </p>\n    <p>\n        In this demo, you can insert nodes to create a binary tree. The tree will be displayed graphically with edges connecting parent and child nodes.\n        Nodes are arranged visually to demonstrate the binary tree structure.\n    </p>\n</section>\n\n<section id=\"controls\">\n    <input type=\"number\" id=\"inputValue\" placeholder=\"Enter node value\" />\n    <button id=\"insertBtn\">Insert Node</button>\n    <button id=\"clearBtn\">Clear Tree</button>\n</section>\n\n<div id=\"tree-container\">\n    <svg id=\"tree-svg\" width=\"100%\" height=\"600\"></svg>\n</div>\n\n<script>\n    /**********************\n     * Binary Tree Classes *\n     **********************/\n\n    class TreeNode {\n        constructor(value) {\n            this.value = value;\n            this.left = null;\n            this.right = null;\n            this.x = 0; // position for visualization\n            this.y = 0;\n        }\n    }\n\n    class BinaryTree {\n        constructor() {\n            this.root = null;\n        }\n\n        insert(value) {\n            const newNode = new TreeNode(value);\n            if (this.root === null) {\n                this.root = newNode;\n                return;\n            }\n            this._insertNode(this.root, newNode);\n        }\n\n        _insertNode(node, newNode) {\n            if (newNode.value === node.value) {\n                // duplicate: ignore or could allow. For this demo we ignore\n                alert(\"Value already exists in the tree.\");\n                return;\n            }\n            if (newNode.value < node.value) {\n                if (node.left === null) {\n                    node.left = newNode;\n                } else {\n                    this._insertNode(node.left, newNode);\n                }\n            } else {\n                if (node.right === null) {\n                    node.right = newNode;\n                } else {\n                    this._insertNode(node.right, newNode);\n                }\n            }\n        }\n\n        clear() {\n            this.root = null;\n        }\n    }\n\n    /******************************\n     * Tree Visualization Section *\n     ******************************/\n\n    const svgNS = \"http://www.w3.org/2000/svg\";\n    const treeSvg = document.getElementById('tree-svg');\n\n    const nodeRadius = 20;\n    const verticalSpacing = 80;\n    const horizontalSpacing = 40;\n\n    /**\n     * Calculate x,y positions for each node for visualization.\n     * Uses an in-order traversal to position nodes horizontally.\n     * Returns number of nodes in subtree and minX, maxX to adjust subtree positioning.\n     */\n\n    function positionTree(root) {\n        // Positioning variables\n        let currentX = 0;\n\n        function inOrder(node, depth) {\n            if (!node) return;\n\n            inOrder(node.left, depth + 1);\n            node.x = currentX * horizontalSpacing;\n            node.y = depth * verticalSpacing;\n            currentX++;\n            inOrder(node.right, depth + 1);\n        }\n\n        inOrder(root, 0);\n    }\n\n    /**\n     * Clear the current SVG content\n     */\n    function clearSVG() {\n        while (treeSvg.firstChild) {\n            treeSvg.removeChild(treeSvg.firstChild);\n        }\n    }\n\n    /**\n     * Draw lines between parent and child\n     */\n    function drawEdge(parent, child) {\n        if (!parent || !child) return;\n        const line = document.createElementNS(svgNS, 'line');\n        line.setAttribute('x1', parent.x + nodeRadius);\n        line.setAttribute('y1', parent.y + nodeRadius);\n        line.setAttribute('x2', child.x + nodeRadius);\n        line.setAttribute('y2', child.y + nodeRadius);\n        line.setAttribute('class', 'edge');\n        treeSvg.appendChild(line);\n    }\n\n    /**\n     * Draw a node as circle with text\n     */\n    function drawNode(node) {\n        const g = document.createElementNS(svgNS, 'g');\n        g.setAttribute('class', 'node');\n        g.setAttribute('transform', `translate(${node.x},${node.y})`);\n\n        const circle = document.createElementNS(svgNS, 'circle');\n        circle.setAttribute('r', nodeRadius);\n        circle.setAttribute('cx', nodeRadius);\n        circle.setAttribute('cy', nodeRadius);\n\n        const text = document.createElementNS(svgNS, 'text');\n        text.setAttribute('x', nodeRadius);\n        text.setAttribute('y', nodeRadius + 6);\n        text.setAttribute('text-anchor', 'middle');\n        text.textContent = node.value;\n\n        g.appendChild(circle);\n        g.appendChild(text);\n\n        treeSvg.appendChild(g);\n    }\n\n    /**\n     * Recursively draw the tree edges and nodes\n     */\n    function drawTree(tree) {\n        if (!tree.root) return;\n\n        clearSVG();\n        positionTree(tree.root);\n\n        // Expand SVG width dynamically depending on node positions\n        // Find max x after positioning\n        let maxX = 0;\n        let maxY = 0;\n        function updateMax(node) {\n            if (!node) return;\n            if (node.x > maxX) maxX = node.x;\n            if (node.y > maxY) maxY = node.y;\n            updateMax(node.left);\n            updateMax(node.right);\n        }\n        updateMax(tree.root);\n\n        treeSvg.setAttribute('width', maxX + nodeRadius * 3);\n        treeSvg.setAttribute('height', maxY + nodeRadius * 3);\n\n        // Draw edges first (so nodes are on top)\n        function drawEdges(node) {\n            if (!node) return;\n            if (node.left) {\n                drawEdge(node, node.left);\n                drawEdges(node.left);\n            }\n            if (node.right) {\n                drawEdge(node, node.right);\n                drawEdges(node.right);\n            }\n        }\n        drawEdges(tree.root);\n\n        // Draw nodes\n        function drawNodes(node) {\n            if (!node) return;\n            drawNode(node);\n            drawNodes(node.left);\n            drawNodes(node.right);\n        }\n        drawNodes(tree.root);\n    }\n\n    /*******************\n     * Interaction Code *\n     *******************/\n\n    const tree = new BinaryTree();\n\n    const insertBtn = document.getElementById('insertBtn');\n    const inputValue = document.getElementById('inputValue');\n    const clearBtn = document.getElementById('clearBtn');\n\n    insertBtn.addEventListener('click', () => {\n        const valStr = inputValue.value.trim();\n        if (valStr === \"\") {\n            alert(\"Please enter a value to insert.\");\n            return;\n        }\n        const val = Number(valStr);\n        if (isNaN(val)) {\n            alert(\"Please enter a numeric value.\");\n            return;\n        }\n        tree.insert(val);\n        inputValue.value = \"\";\n        drawTree(tree);\n    });\n\n    clearBtn.addEventListener('click', () => {\n        tree.clear();\n        clearSVG();\n    });\n\n    // Allow pressing Enter to insert\n    inputValue.addEventListener('keydown', e => {\n        if (e.key === 'Enter') {\n            insertBtn.click();\n        }\n    });\n\n    // Initial empty tree draw\n    drawTree(tree);\n</script>\n\n</body>\n</html>"
