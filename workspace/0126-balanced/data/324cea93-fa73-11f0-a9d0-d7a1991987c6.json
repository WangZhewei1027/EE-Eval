    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B+ Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n        #tree-container {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-top: 20px;\n        }\n        .node {\n            border: 1px solid #ccc;\n            background: #fff;\n            margin: 5px;\n            padding: 10px;\n            border-radius: 5px;\n            display: inline-block;\n            text-align: center;\n        }\n        #insert-form {\n            margin-top: 20px;\n        }\n        input[type=\"number\"] {\n            width: 60px;\n            margin-right: 10px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>B+ Tree Visualization</h1>\n<div id=\"tree-container\"></div>\n<div id=\"insert-form\">\n    <input type=\"number\" id=\"valueInput\" placeholder=\"Enter a number\" />\n    <button onclick=\"insertValue()\">Insert</button>\n</div>\n\n<script>\n    class BPlusTree {\n        constructor(order) {\n            this.root = new LeafNode(order);\n            this.order = order;\n        }\n\n        insert(value) {\n            const result = this.root.insert(value);\n            if (result) {\n                const newRoot = new InternalNode(this.order);\n                newRoot.children.push(this.root);\n                newRoot.children.push(result);\n                newRoot.keys.push(result.keys[0]);\n                this.root = newRoot;\n            }\n            this.render();\n        }\n\n        render() {\n            const container = document.getElementById('tree-container');\n            container.innerHTML = '';\n            this.root.render(container);\n        }\n    }\n\n    class Node {\n        constructor(order) {\n            this.keys = [];\n            this.children = [];\n            this.order = order;\n        }\n    }\n\n    class LeafNode extends Node {\n        constructor(order) {\n            super(order);\n        }\n\n        insert(value) {\n            this.keys.push(value);\n            this.keys.sort((a, b) => a - b);\n            if (this.keys.length > this.order) {\n                const newLeaf = new LeafNode(this.order);\n                const mid = Math.ceil(this.order / 2);\n                newLeaf.keys = this.keys.splice(mid);\n                return newLeaf;\n            }\n            return null;\n        }\n\n        render(container) {\n            const nodeDiv = document.createElement('div');\n            nodeDiv.className = 'node';\n            nodeDiv.innerHTML = `Leaf: ${this.keys.join(', ')}`;\n            container.appendChild(nodeDiv);\n        }\n    }\n\n    class InternalNode extends Node {\n        constructor(order) {\n            super(order);\n        }\n\n        insert(value) {\n            let childIndex = this.children.length - 1;\n            while (childIndex >= 0 && value < this.children[childIndex].keys[0]) {\n                childIndex--;\n            }\n            childIndex++;\n            const result = this.children[childIndex].insert(value);\n            if (result) {\n                this.keys.push(result.keys[0]);\n                this.keys.sort((a, b) => a - b);\n                this.children.splice(childIndex + 1, 0, result);\n                if (this.keys.length > this.order) {\n                    const newInternal = new InternalNode(this.order);\n                    const mid = Math.floor(this.keys.length / 2);\n                    newInternal.keys = this.keys.splice(mid + 1);\n                    newInternal.children = this.children.splice(mid + 1);\n                    return newInternal;\n                }\n            }\n            return null;\n        }\n\n        render(container) {\n            const nodeDiv = document.createElement('div');\n            nodeDiv.className = 'node';\n            nodeDiv.innerHTML = `Internal: ${this.keys.join(', ')}`;\n            container.appendChild(nodeDiv);\n            for (const child of this.children) {\n                child.render(container);\n            }\n        }\n    }\n\n    const bPlusTree = new BPlusTree(3);\n\n    function insertValue() {\n        const valueInput = document.getElementById('valueInput');\n        const value = parseInt(valueInput.value);\n        if (!isNaN(value)) {\n            bPlusTree.insert(value);\n            valueInput.value = '';\n        } else {\n            alert('Please enter a valid number.');\n        }\n    }\n</script>\n\n</body>\n</html>"
