    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Congestion Control Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f4f6f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #network {\n    margin: 20px auto;\n    width: 90%;\n    max-width: 900px;\n    border: 2px solid #666;\n    border-radius: 10px;\n    padding: 10px;\n    background: white;\n    min-height: 300px;\n    position: relative;\n    overflow: hidden;\n  }\n  .queue {\n    border: 2px solid #0077cc;\n    border-radius: 8px;\n    width: 300px;\n    height: 180px;\n    margin: 10px auto;\n    position: relative;\n    background: #e6f0fa;\n  }\n  .queue h3 {\n    margin: 5px;\n    text-align: center;\n    font-weight: 600;\n    color: #004a99;\n  }\n  .packet {\n    width: 25px;\n    height: 15px;\n    background-color: #0099ff;\n    border-radius: 3px;\n    margin: 2px;\n    display: inline-block;\n    position: relative;\n    box-shadow: 0 0 3px #007acc;\n  }\n  #stats {\n    max-width: 900px;\n    margin: 20px auto;\n    background: #fff;\n    border-radius: 10px;\n    border: 1px solid #ccc;\n    padding: 15px;\n    font-size: 16px;\n    line-height: 1.5;\n  }\n  #controls {\n    max-width: 900px;\n    margin: 0 auto 20px auto;\n    text-align: center;\n  }\n  #controls button {\n    padding: 10px 18px;\n    margin: 5px;\n    font-weight: 600;\n    border-radius: 6px;\n    border: none;\n    cursor: pointer;\n    background-color: #0077cc;\n    color: white;\n    transition: background-color 0.2s ease;\n  }\n  #controls button:hover:not(:disabled) {\n    background-color: #005fa3;\n  }\n  #controls button:disabled {\n    background-color: #888;\n    cursor: not-allowed;\n  }\n  #explanation {\n    max-width: 900px;\n    margin: 0 auto 30px auto;\n    background: #e3f2fd;\n    border-radius: 10px;\n    border: 1px solid #90caf9;\n    padding: 15px;\n    font-size: 14px;\n    color: #0d47a1;\n  }\n</style>\n</head>\n<body>\n\n<h1>Congestion Control Demonstration</h1>\n\n<div id=\"explanation\">\n  <strong>What is Congestion Control?</strong><br />\n  Congestion control is a network mechanism to prevent excessive data from overwhelming network devices (routers, switches), avoiding packet loss and delays.\n  This demo shows how a sender's transmission rate adjusts based on network congestion.<br />\n  <br />\n  <em>Blue boxes (packets) move from Sender through the Router Queue (limited capacity) to Receiver.</em><br />\n  When the queue fills (congestion happens), the sender reduces its sending rate (\"Throttle\"). When the queue empties,\n  the sender increases the rate (\"Additive Increase\") to use available capacity efficiently.<br />\n  <br />\n  This models TCP's congestion control principles: Slow Start, Congestion Avoidance, and reacting to packet loss/congestion.\n</div>\n\n<div id=\"network\" aria-label=\"Network congestion control animated demonstration\">\n  <div class=\"queue\" id=\"senderQueue\">\n    <h3>Sender Buffer</h3>\n    <div id=\"senderPackets\"></div>\n  </div>\n\n  <div class=\"queue\" id=\"routerQueue\" style=\"margin-top: 30px;\">\n    <h3>Router Queue (Capacity: 10 packets)</h3>\n    <div id=\"routerPackets\"></div>\n  </div>\n\n  <div class=\"queue\" id=\"receiverBuffer\" style=\"margin-top: 30px;\">\n    <h3>Receiver</h3>\n    <div id=\"receiverPackets\"></div>\n  </div>\n</div>\n\n<div id=\"stats\" aria-live=\"polite\" aria-atomic=\"true\">\n  <strong>Statistics:</strong><br />\n  <div>Current Sending Rate: <span id=\"sendRate\">1</span> packets/sec</div>\n  <div>Router Queue Size: <span id=\"queueSize\">0</span> / 10 packets</div>\n  <div>Packets Sent: <span id=\"packetsSent\">0</span></div>\n  <div>Packets Received: <span id=\"packetsReceived\">0</span></div>\n  <div>Packets Dropped (due to congestion): <span id=\"packetsDropped\">0</span></div>\n  <div>Current State: <span id=\"currentState\">Slow Start</span></div>\n</div>\n\n<div id=\"controls\">\n  <button id=\"startBtn\" aria-label=\"Start simulation\">Start</button>\n  <button id=\"pauseBtn\" disabled aria-label=\"Pause simulation\">Pause</button>\n  <button id=\"resetBtn\" disabled aria-label=\"Reset simulation\">Reset</button>\n</div>\n\n<script>\n(() => {\n// Constants\nconst ROUTER_CAPACITY = 10;\nconst MAX_SEND_RATE = 16; // Maximum packets per second allowed (for demo)\nconst MIN_SEND_RATE = 0.25; // Minimum send rate (packets/sec before we stop)\nconst SEND_RATE_INCREMENT_SLOW_START = 1; // Increase per RTT in slow start (doubling approx)\nconst SEND_RATE_INCREMENT_CONGESTION_AVOIDANCE = 0.2; // Additive increase per RTT\n\n// Elements\nconst senderPacketsEl = document.getElementById(\"senderPackets\");\nconst routerPacketsEl = document.getElementById(\"routerPackets\");\nconst receiverPacketsEl = document.getElementById(\"receiverPackets\");\nconst sendRateEl = document.getElementById(\"sendRate\");\nconst queueSizeEl = document.getElementById(\"queueSize\");\nconst packetsSentEl = document.getElementById(\"packetsSent\");\nconst packetsReceivedEl = document.getElementById(\"packetsReceived\");\nconst packetsDroppedEl = document.getElementById(\"packetsDropped\");\nconst currentStateEl = document.getElementById(\"currentState\");\n\nconst startBtn = document.getElementById(\"startBtn\");\nconst pauseBtn = document.getElementById(\"pauseBtn\");\nconst resetBtn = document.getElementById(\"resetBtn\");\n\n// State variables\nlet sendRate = 1.0; // packets per second\nlet senderBuffer = [];\nlet routerQueue = [];\nlet receiverBuffer = [];\n\nlet packetsSent = 0;\nlet packetsReceived = 0;\nlet packetsDropped = 0;\n\n// Simulation Control\nlet isRunning = false;\nlet simInterval = null;\nlet rtt = 1000; // round trip time approx 1 second\n\n// Congestion Control States\nconst STATES = {\n  SLOW_START: \"Slow Start\",\n  CONGESTION_AVOIDANCE: \"Congestion Avoidance\",\n  FAST_RECOVERY: \"Fast Recovery\"\n};\n\nlet currentState = STATES.SLOW_START;\n\n// Packet ID generator\nlet nextPacketId = 1;\n\n// Utility to create a packet element\nfunction createPacketElement(id) {\n  const span = document.createElement(\"span\");\n  span.className = \"packet\";\n  span.title = `Packet ${id}`;\n  span.setAttribute(\"aria-label\", `Packet ${id}`);\n  span.dataset.id = id;\n  return span;\n}\n\nfunction renderQueues() {\n  // Clear all\n  senderPacketsEl.innerHTML = \"\";\n  routerPacketsEl.innerHTML = \"\";\n  receiverPacketsEl.innerHTML = \"\";\n\n  // Display sender buffer (show packets waiting to be sent)\n  senderBuffer.forEach((pktId) => {\n    senderPacketsEl.appendChild(createPacketElement(pktId));\n  });\n\n  // Display router queue\n  routerQueue.forEach((pktId) => {\n    routerPacketsEl.appendChild(createPacketElement(pktId));\n  });\n\n  // Display receiver packets (just show count as \"received\", so put fixed 10 max)\n  // We'll show last 10 packets received for visualization\n  let lastPackets = receiverBuffer.slice(-10);\n  lastPackets.forEach((pktId) => {\n    receiverPacketsEl.appendChild(createPacketElement(pktId));\n  });\n}\n\nfunction updateStats() {\n  sendRateEl.textContent = sendRate.toFixed(2);\n  queueSizeEl.textContent = routerQueue.length;\n  packetsSentEl.textContent = packetsSent;\n  packetsReceivedEl.textContent = packetsReceived;\n  packetsDroppedEl.textContent = packetsDropped;\n  currentStateEl.textContent = currentState;\n}\n\n// Logic for sending packets from sender buffer to router queue based on current sendRate\n// The sender creates packets at its current send rate (packets/sec)\nfunction sendPackets(deltaTimeMs) {\n  // Calculate how many packets to send in this tick (deltaTimeMs in ms)\n  // sendRate is packets/sec => packets/ms = sendRate / 1000\n  let packetsToSend = sendRate * (deltaTimeMs / 1000);\n  // We'll accumulate fractional packets each tick\n  if (typeof sendPackets.packetFraction === \"undefined\") {\n    sendPackets.packetFraction = 0;\n  }\n  packetsToSend += sendPackets.packetFraction;\n  let integerPackets = Math.floor(packetsToSend);\n  sendPackets.packetFraction = packetsToSend - integerPackets;\n\n  for (let i=0; i<integerPackets; i++) {\n    // Create new packet in sender buffer (sender generates packets)\n    senderBuffer.push(nextPacketId++);\n  }\n}\n\n// Logic for moving packets from sender buffer to router queue if router not full\nfunction transferToRouter() {\n  // Try to move packet from sender buffer to router queue\n  while (senderBuffer.length > 0 && routerQueue.length < ROUTER_CAPACITY) {\n    let pkt = senderBuffer.shift();\n    routerQueue.push(pkt);\n    packetsSent++;\n  }\n\n  // If router queue is full, packets in sender buffer start accumulating (simulating delay)\n  // However, if router is full, new packets cannot enter router and are effectively \"congested\".\n  // In TCP, sender reduces send rate upon congestion event (here simulated below).\n}\n\nconst SEND_INTERVAL_MS = 100; // 100ms tick for smoother animations\n\n// Logic for router sending packets to receiver, one packet per tick if any\nfunction routerToReceiver() {\n  if (routerQueue.length > 0) {\n    // Simulate router output rate, fixed/output link speed\n    let pkt = routerQueue.shift();\n    receiverBuffer.push(pkt);\n    packetsReceived++;\n  }\n}\n\n// Detect congestion: if routerQueue is at capacity (can be treated as congestion signal)\nfunction checkCongestion() {\n  return routerQueue.length >= ROUTER_CAPACITY;\n}\n\n// Congestion control state update logic\nfunction updateCongestionControl() {\n  // Simple model:\n  // - If congestion detected => packet drop => reduce send rate multiplicatively and enter slow start or fast recovery\n  // - If no congestion for several RTTs => increase send rate additively (congestion avoidance)\n  // This is simplified from TCP Reno behavior.\n\n  if (checkCongestion()) {\n    // Congestion occurred\n    packetsDropped += senderBuffer.length; // Excess packets stuck waiting will be dropped for simplicity\n    senderBuffer = [];\n\n    if (currentState === STATES.SLOW_START) {\n      // Slow start: multiplicative decrease\n      sendRate /= 2;\n      if (sendRate < MIN_SEND_RATE) sendRate = MIN_SEND_RATE;\n      currentState = STATES.CONGESTION_AVOIDANCE;\n    } else if (currentState === STATES.CONGESTION_AVOIDANCE) {\n      // Enter slow start on congestion repeatedly\n      sendRate /= 2;\n      if (sendRate < MIN_SEND_RATE) sendRate = MIN_SEND_RATE;\n      // stay in congestion avoidance or slow start?\n      currentState = STATES.SLOW_START;\n    } else {\n      // Fast recovery (not fully modeled here) just reduce rate\n      sendRate /= 2;\n      if (sendRate < MIN_SEND_RATE) sendRate = MIN_SEND_RATE;\n      currentState = STATES.CONGESTION_AVOIDANCE;\n    }\n  } else {\n    // No congestion detected. Increase send rate depending on state.\n    if (currentState === STATES.SLOW_START) {\n      // exponential increase approx: double each RTT\n      // We'll increment sendRate by 1 pkt/sec per RTT\n      sendRate += SEND_RATE_INCREMENT_SLOW_START * (SEND_INTERVAL_MS / rtt);\n      if (sendRate >= MAX_SEND_RATE) {\n        sendRate = MAX_SEND_RATE;\n        currentState = STATES.CONGESTION_AVOIDANCE;\n      }\n    } else if (currentState === STATES.CONGESTION_AVOIDANCE) {\n      // Additive increase\n      sendRate += SEND_RATE_INCREMENT_CONGESTION_AVOIDANCE * (SEND_INTERVAL_MS / rtt);\n      if (sendRate > MAX_SEND_RATE) sendRate = MAX_SEND_RATE;\n    }\n  }\n}\n\nfunction simulationStep(deltaTimeMs) {\n  if (!isRunning) return;\n\n  // 1) Sender generates packets based on current send rate\n  sendPackets(deltaTimeMs);\n\n  // 2) Send packets from sender buffer to router queue if space\n  transferToRouter();\n\n  // 3) Router outputs packets to receiver buffer\n  routerToReceiver();\n\n  // 4) Update congestion control based on router queue state\n  updateCongestionControl();\n\n  // 5) Render update\n  renderQueues();\n  updateStats();\n}\n\nlet lastTime = null;\n\nfunction gameLoop(timestamp) {\n  if (!lastTime) lastTime = timestamp;\n  const delta = timestamp - lastTime;\n  lastTime = timestamp;\n\n  simulationStep(delta);\n\n  if (isRunning) {\n    requestAnimationFrame(gameLoop);\n  }\n}\n\nfunction startSimulation() {\n  if (isRunning) return;\n\n  isRunning = true;\n  lastTime = null;\n  requestAnimationFrame(gameLoop);\n  startBtn.disabled = true;\n  pauseBtn.disabled = false;\n  resetBtn.disabled = false;\n}\n\nfunction pauseSimulation() {\n  if (!isRunning) return;\n  isRunning = false;\n  startBtn.disabled = false;\n  pauseBtn.disabled = true;\n  resetBtn.disabled = false;\n}\n\nfunction resetSimulation() {\n  isRunning = false;\n  senderBuffer = [];\n  routerQueue = [];\n  receiverBuffer = [];\n  packetsSent = 0;\n  packetsReceived = 0;\n  packetsDropped = 0;\n  sendRate = 1.0;\n  currentState = STATES.SLOW_START;\n  nextPacketId = 1;\n  sendPackets.packetFraction = 0;\n\n  renderQueues();\n  updateStats();\n\n  startBtn.disabled = false;\n  pauseBtn.disabled = true;\n  resetBtn.disabled = true;\n}\n\nstartBtn.addEventListener(\"click\", startSimulation);\npauseBtn.addEventListener(\"click\", pauseSimulation);\nresetBtn.addEventListener(\"click\", resetSimulation);\n\n// Initial render\nresetSimulation();\n\n})();\n</script>\n\n</body>\n</html>"
