    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Deque Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            padding: 20px;\n        }\n        #deque {\n            margin: 20px 0;\n            border: 1px solid #ccc;\n            padding: 10px;\n            min-height: 40px;\n            display: flex;\n            flex-direction: row;\n            align-items: center;\n        }\n        .item {\n            margin: 5px;\n            padding: 5px 10px;\n            background-color: #e7f3fe;\n            border: 1px solid #b3d7ff;\n            border-radius: 4px;\n        }\n    </style>\n</head>\n<body>\n\n<h2>Deque (Double-Ended Queue) Demonstration</h2>\n<div id=\"deque\"></div>\n\n<input type=\"number\" id=\"inputValue\" placeholder=\"Enter a number\" />\n<button onclick=\"addFront()\">Add to Front</button>\n<button onclick=\"addBack()\">Add to Back</button>\n<button onclick=\"removeFront()\">Remove from Front</button>\n<button onclick=\"removeBack()\">Remove from Back</button>\n\n<script>\n    class Deque {\n        constructor() {\n            this.items = [];\n        }\n\n        addFront(element) {\n            this.items.unshift(element);\n            this.render();\n        }\n\n        addBack(element) {\n            this.items.push(element);\n            this.render();\n        }\n\n        removeFront() {\n            if (this.isEmpty()) {\n                alert('Deque is empty!');\n                return;\n            }\n            this.items.shift();\n            this.render();\n        }\n\n        removeBack() {\n            if (this.isEmpty()) {\n                alert('Deque is empty!');\n                return;\n            }\n            this.items.pop();\n            this.render();\n        }\n\n        isEmpty() {\n            return this.items.length === 0;\n        }\n\n        render() {\n            const dequeElement = document.getElementById('deque');\n            dequeElement.innerHTML = '';\n            this.items.forEach(item => {\n                const div = document.createElement('div');\n                div.className = 'item';\n                div.textContent = item;\n                dequeElement.appendChild(div);\n            });\n        }\n    }\n\n    const deque = new Deque();\n\n    function addFront() {\n        const value = document.getElementById('inputValue').value;\n        if (value) {\n            deque.addFront(value);\n            document.getElementById('inputValue').value = '';\n        } else {\n            alert('Please enter a value');\n        }\n    }\n\n    function addBack() {\n        const value = document.getElementById('inputValue').value;\n        if (value) {\n            deque.addBack(value);\n            document.getElementById('inputValue').value = '';\n        } else {\n            alert('Please enter a value');\n        }\n    }\n\n    function removeFront() {\n        deque.removeFront();\n    }\n\n    function removeBack() {\n        deque.removeBack();\n    }\n</script>\n\n</body>\n</html>"
