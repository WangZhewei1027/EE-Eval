    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>JavaScript Set Demonstration</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      max-width: 600px;\n      margin: 2rem auto;\n      padding: 0 1rem;\n      background: #f9f9f9;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n      color: #2c3e50;\n    }\n    section {\n      background: white;\n      border-radius: 8px;\n      padding: 1rem 1.5rem;\n      box-shadow: 0 2px 6px rgba(0,0,0,0.1);\n      margin-bottom: 2rem;\n    }\n    pre {\n      background: #eee;\n      padding: 1rem;\n      border-radius: 5px;\n      overflow-x: auto;\n    }\n    button {\n      background-color: #2980b9;\n      border: none;\n      color: white;\n      padding: 0.5rem 1rem;\n      margin-top: 1rem;\n      border-radius: 5px;\n      cursor: pointer;\n      font-size: 1rem;\n    }\n    button:hover {\n      background-color: #1c5980;\n    }\n    .output {\n      margin-top: 1rem;\n      background: #eef6fb;\n      border: 1px solid #b3d4fc;\n      padding: 1rem;\n      border-radius: 5px;\n      font-family: monospace;\n      white-space: pre-wrap;\n      min-height: 4rem;\n    }\n  </style>\n</head>\n<body>\n  <h1>JavaScript <code>Set</code> Demonstration</h1>\n\n  <section>\n    <h2>What is a Set?</h2>\n    <p>A <code>Set</code> is a built-in JavaScript object that allows you to store unique values of any type. It does NOT allow duplicates.</p>\n  </section>\n\n  <section>\n    <h2>Basic Operations</h2>\n    <pre id=\"code-sample\">\n// Create a new Set\nconst mySet = new Set();\n\n// Add some values\nmySet.add(1);\nmySet.add(5);\nmySet.add(5); // duplicate, won't be added\nmySet.add('hello');\nmySet.add({a:1});\n\n// Display size\nconsole.log('Size:', mySet.size);\n\n// Check for presence\nconsole.log('Has 5?', mySet.has(5));\n\n// Remove a value\nmySet.delete(1);\n\nconsole.log('Values:', Array.from(mySet));\n    </pre>\n    <button id=\"run-basic\">Run Basic Example</button>\n    <div class=\"output\" id=\"output-basic\"></div>\n  </section>\n\n  <section>\n    <h2>Iterating a Set</h2>\n    <pre id=\"code-iterate\">\n// Iterate over values\nfor (const value of mySet) {\n  console.log(value);\n}\n\n// Or using forEach\nmySet.forEach(value => {\n  console.log(value);\n});\n    </pre>\n    <button id=\"run-iterate\">Run Iteration Example</button>\n    <div class=\"output\" id=\"output-iterate\"></div>\n  </section>\n\n  <section>\n    <h2>Use Cases</h2>\n    <p>Examples where <code>Set</code> is useful:</p>\n    <ul>\n      <li>Removing duplicate values from an array</li>\n      <li>Checking for existence quickly</li>\n      <li>Tracking unique items (like visited URLs or user IDs)</li>\n    </ul>\n\n    <h3>Remove duplicates from array</h3>\n    <pre id=\"code-unique\">\n// From an array with duplicates\nconst numbers = [1,2,2,3,4,4,5];\n\n// Create a unique array using Set\nconst uniqueNumbers = [...new Set(numbers)];\n\nconsole.log(uniqueNumbers);\n    </pre>\n    <button id=\"run-unique\">Run Remove Duplicates</button>\n    <div class=\"output\" id=\"output-unique\"></div>\n  </section>\n\n<script>\n  // Utility for capturing console output for buttons\n  function runAndCapture(fn, outputEl) {\n    outputEl.textContent = '';\n    const origConsoleLog = console.log;\n    console.log = (...args) => {\n      outputEl.textContent += args.map(a => {\n        if (typeof a === 'object' && a !== null) {\n          try { return JSON.stringify(a, null,2); } catch { return String(a); }\n        }\n        return String(a);\n      }).join(' ') + '\\n';\n    };\n    try {\n      fn();\n    } catch(e) {\n      outputEl.textContent += 'Error: ' + e.message;\n    }\n    console.log = origConsoleLog;\n  }\n\n  // Basic example function\n  function exampleBasic() {\n    const mySet = new Set();\n\n    mySet.add(1);\n    mySet.add(5);\n    mySet.add(5); // duplicate, won't be added\n    mySet.add('hello');\n    mySet.add({a:1});\n\n    console.log('Size:', mySet.size);\n\n    console.log('Has 5?', mySet.has(5));\n\n    mySet.delete(1);\n\n    // Convert Set to Array for display\n    const displayValues = Array.from(mySet).map(v => {\n      if (typeof v === 'object') return JSON.stringify(v);\n      else return v;\n    });\n\n    console.log('Values:', displayValues);\n  }\n\n  // Iteration example\n  function exampleIterate() {\n    const mySet = new Set([10, 20, 30, 40]);\n    console.log('Using for...of:');\n    for (const value of mySet) {\n      console.log(value);\n    }\n\n    console.log('Using forEach:');\n    mySet.forEach(value => {\n      console.log(value);\n    });\n  }\n\n  // Remove duplicates example\n  function exampleUnique() {\n    const numbers = [1,2,2,3,4,4,5];\n    const uniqueNumbers = [...new Set(numbers)];\n    console.log(uniqueNumbers);\n  }\n\n  document.getElementById('run-basic').onclick = () => {\n    runAndCapture(exampleBasic, document.getElementById('output-basic'));\n  };\n  document.getElementById('run-iterate').onclick = () => {\n    runAndCapture(exampleIterate, document.getElementById('output-iterate'));\n  };\n  document.getElementById('run-unique').onclick = () => {\n    runAndCapture(exampleUnique, document.getElementById('output-unique'));\n  };\n</script>\n</body>\n</html>"
