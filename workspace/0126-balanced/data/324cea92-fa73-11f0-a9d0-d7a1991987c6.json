    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>B-Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background-color: #f0f0f0;\n        }\n        #tree {\n            margin-top: 20px;\n        }\n        .node {\n            display: inline-block;\n            border: 1px solid #333;\n            border-radius: 5px;\n            padding: 10px;\n            margin: 5px;\n            background-color: #fff;\n        }\n        .link {\n            height: 20px;\n            width: 50px;\n            border-left: 2px solid #333;\n            position: relative;\n            top: 0;\n            margin-left: 30px;\n        }\n    </style>\n</head>\n<body>\n\n<div>\n    <h2>B-Tree Visualization</h2>\n    <input type=\"number\" id=\"input\" placeholder=\"Enter a number\" />\n    <button onclick=\"insert()\">Insert</button>\n    <div id=\"tree\"></div>\n</div>\n\n<script>\n    class BTreeNode {\n        constructor(t) {\n            this.t = t; // Minimum degree\n            this.keys = [];\n            this.children = [];\n            this.leaf = true;\n        }\n    }\n\n    class BTree {\n        constructor(t) {\n            this.root = new BTreeNode(t);\n            this.t = t;\n        }\n\n        insert(k) {\n            let root = this.root;\n            if (root.keys.length === 2 * this.t - 1) {\n                let s = new BTreeNode(this.t);\n                this.root = s;\n                s.leaf = false;\n                s.children.push(root);\n                this.splitChild(s, 0);\n                this.insertNonFull(s, k);\n            } else {\n                this.insertNonFull(root, k);\n            }\n            this.draw();\n        }\n\n        insertNonFull(node, k) {\n            let i = node.keys.length - 1;\n            if (node.leaf) {\n                node.keys.push(k);\n                node.keys.sort((a, b) => a - b);\n            } else {\n                while (i >= 0 && k < node.keys[i]) {\n                    i--;\n                }\n                i++;\n                if (node.children[i].keys.length === 2 * this.t - 1) {\n                    this.splitChild(node, i);\n                    if (k > node.keys[i]) {\n                        i++;\n                    }\n                }\n                this.insertNonFull(node.children[i], k);\n            }\n        }\n\n        splitChild(parent, i) {\n            let t = this.t;\n            let y = parent.children[i];\n            let z = new BTreeNode(t);\n            z.leaf = y.leaf;\n\n            for (let j = 0; j < t - 1; j++) {\n                z.keys.push(y.keys.pop());\n            }\n\n            parent.children.splice(i + 1, 0, z);\n            parent.keys.splice(i, 0, y.keys.pop());\n        }\n\n        draw() {\n            const treeDiv = document.getElementById('tree');\n            treeDiv.innerHTML = '';  // Clear previous visualization\n            this.drawNode(this.root, treeDiv);\n        }\n\n        drawNode(node, parentDiv) {\n            const nodeDiv = document.createElement('div');\n            nodeDiv.className = 'node';\n            nodeDiv.innerHTML = node.keys.join(', ');\n            parentDiv.appendChild(nodeDiv);\n            \n            if (!node.leaf) {\n                const childrenDiv = document.createElement('div');\n                childrenDiv.style.display = 'flex';\n                childrenDiv.style.justifyContent = 'center';\n\n                for (let child of node.children) {\n                    const linkDiv = document.createElement('div');\n                    linkDiv.className = 'link';\n                    childrenDiv.appendChild(linkDiv);\n                    \n                    this.drawNode(child, childrenDiv);\n                }\n                \n                parentDiv.appendChild(childrenDiv);\n            }\n        }\n    }\n\n    const bTree = new BTree(2); // Create a B-Tree of minimum degree 2\n\n    function insert() {\n        const input = document.getElementById('input');\n        const value = parseInt(input.value);\n        if (!isNaN(value)) {\n            bTree.insert(value);\n            input.value = '';\n        } else {\n            alert('Please enter a valid number');\n        }\n    }\n</script>\n\n</body>\n</html>"
