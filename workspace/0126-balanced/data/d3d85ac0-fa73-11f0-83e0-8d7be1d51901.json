  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Big-O Notation Visualizer</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724;\n      --panel:#0b1220;\n      --muted:#9aa4b2;\n      --accent:#7dd3fc;\n      --good:#86efac;\n      --danger:#fb7185;\n      --card:#0b1220aa;\n      --white:#e6eef6;\n    }\n    html,body{height:100%;margin:0;background:linear-gradient(180deg,var(--bg),#071028 80%);color:var(--white);font-family:Inter,Segoe UI,Roboto,Helvetica,Arial,sans-serif}\n    .wrap{max-width:1100px;margin:28px auto;padding:22px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));box-shadow:0 10px 30px rgba(0,0,0,0.6)}\n    h1{margin:0 0 8px;font-weight:600}\n    p.lead{margin:0 0 18px;color:var(--muted)}\n    .controls{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:18px;align-items:center}\n    .card{background:var(--card);padding:14px;border-radius:10px;flex:1;min-width:220px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.02)}\n    .small{font-size:13px;color:var(--muted)}\n    label{display:block;color:var(--muted);font-size:13px;margin-bottom:6px}\n    input[type=range]{width:100%}\n    .row{display:flex;gap:12px;flex-wrap:wrap}\n    canvas{width:100%;height:340px;border-radius:8px;background:linear-gradient(180deg,rgba(255,255,255,0.02),rgba(255,255,255,0.01));display:block}\n    .legend{display:flex;gap:10px;flex-wrap:wrap;margin-top:8px}\n    .legend .item{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted)}\n    .swatch{width:14px;height:6px;border-radius:4px}\n    table{width:100%;border-collapse:collapse;margin-top:12px}\n    th,td{padding:8px;text-align:left;font-size:13px;color:var(--muted)}\n    th{color:var(--white);font-weight:600}\n    .btn{background:transparent;border:1px solid rgba(255,255,255,0.06);padding:8px 10px;border-radius:8px;color:var(--white);cursor:pointer}\n    .btn:active{transform:translateY(1px)}\n    pre{background:#071322;padding:12px;border-radius:8px;overflow:auto;color:var(--muted);font-size:13px}\n    .explain{display:grid;grid-template-columns:1fr 320px;gap:12px;margin-top:14px}\n    @media (max-width:900px){ .explain{grid-template-columns:1fr} .legend{justify-content:flex-start}}\n    .stat{font-size:18px;color:var(--white);font-weight:600}\n    .muted{color:var(--muted);font-size:13px}\n    footer{margin-top:18px;color:var(--muted);font-size:13px;text-align:center}\n  </style>\n</head>\n<body>\n  <div class=\"wrap\" role=\"main\">\n    <h1>Big-O Notation — Visualizer & Interactive Demo</h1>\n    <p class=\"lead\">Big-O describes how an algorithm's runtime or memory grows as the input size (n) grows. Use the controls to explore common complexity classes, compare their growth, and run small timing experiments.</p>\n\n    <div class=\"controls\">\n      <div class=\"card\">\n        <label for=\"nRange\">Input size n: <span id=\"nVal\" class=\"stat\">50</span></label>\n        <input id=\"nRange\" type=\"range\" min=\"1\" max=\"200\" value=\"50\" />\n        <div style=\"display:flex;gap:10px;margin-top:8px;align-items:center\">\n          <button id=\"runBench\" class=\"btn\">Run micro-bench</button>\n          <button id=\"resetBtn\" class=\"btn\">Reset</button>\n        </div>\n        <div style=\"margin-top:8px\" class=\"muted\">Micro-bench runs small operations to roughly illustrate runtime differences (not precise benchmarking).</div>\n      </div>\n\n      <div class=\"card\">\n        <label>Chart scale</label>\n        <div style=\"display:flex;gap:8px;align-items:center\">\n          <label style=\"display:inline-flex;gap:6px;align-items:center\"><input type=\"radio\" name=\"scale\" value=\"linear\" checked/> Linear</label>\n          <label style=\"display:inline-flex;gap:6px;align-items:center\"><input type=\"radio\" name=\"scale\" value=\"log\" /> Log (base 10)</label>\n        </div>\n        <div style=\"margin-top:12px\" class=\"muted\">When values grow very large (exponential/factorial), log scale reveals relative growth better.</div>\n      </div>\n\n      <div class=\"card\">\n        <label>Toggle complexity classes</label>\n        <div style=\"display:flex;flex-direction:column;gap:6px\">\n          <label><input type=\"checkbox\" class=\"toggleFunc\" data-func=\"O1\" checked /> O(1) — constant</label>\n          <label><input type=\"checkbox\" class=\"toggleFunc\" data-func=\"Ologn\" checked /> O(log n)</label>\n          <label><input type=\"checkbox\" class=\"toggleFunc\" data-func=\"On\" checked /> O(n)</label>\n          <label><input type=\"checkbox\" class=\"toggleFunc\" data-func=\"Onlogn\" checked /> O(n log n)</label>\n          <label><input type=\"checkbox\" class=\"toggleFunc\" data-func=\"On2\" checked /> O(n²)</label>\n          <label><input type=\"checkbox\" class=\"toggleFunc\" data-func=\"O2n\" checked /> O(2ⁿ)</label>\n          <label><input type=\"checkbox\" class=\"toggleFunc\" data-func=\"Onfact\" checked /> O(n!)</label>\n        </div>\n      </div>\n    </div>\n\n    <div style=\"background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005));padding:12px;border-radius:8px\">\n      <canvas id=\"chart\" width=\"1000\" height=\"340\"></canvas>\n      <div class=\"legend\" id=\"legend\"></div>\n    </div>\n\n    <div class=\"explain\">\n      <div>\n        <h3 style=\"margin-top:12px\">Interactive values at n = <span id=\"nValText\">50</span></h3>\n        <table id=\"valTable\" aria-live=\"polite\">\n          <thead><tr><th>Complexity</th><th>Value (approx)</th><th>Growth (relative)</th></tr></thead>\n          <tbody></tbody>\n        </table>\n\n        <h3 style=\"margin-top:12px\">Code examples</h3>\n        <div class=\"muted\">Short illustrations showing why the complexity is what it is.</div>\n\n        <h4>O(1) — constant</h4>\n        <pre>// access an array element\nconst arr = [1,2,3,4];\nreturn arr[0]; // always one step -> O(1)</pre>\n\n        <h4>O(n) — linear</h4>\n        <pre>// sum of array elements\nlet sum = 0;\nfor (let i = 0; i &lt; n; i++) {\n  sum += arr[i];\n}\n// ~n steps -> O(n)</pre>\n\n        <h4>O(n²) — quadratic</h4>\n        <pre>// naive pair checking\nfor (let i = 0; i &lt; n; i++) {\n  for (let j = 0; j &lt; n; j++) {\n    // constant work\n  }\n}\n// ~n * n steps -> O(n²)</pre>\n\n        <h4>O(n log n) — divide/conquer sorts</h4>\n        <pre>// merge sort or quicksort average\n// splits -> log n levels, work per level ~ n -> n log n</pre>\n\n        <h4>O(2ⁿ), O(n!) — exponential / factorial</h4>\n        <pre>// naive recursive subset enumeration (2ⁿ)\n// permutations (n!) — grow extremely fast!</pre>\n\n      </div>\n\n      <aside class=\"card\">\n        <h4 style=\"margin:0 0 8px\">Micro-bench results</h4>\n        <div id=\"benchResults\" class=\"muted\">Press \"Run micro-bench\" to measure operations for three simple routines.</div>\n        <div style=\"margin-top:10px\">\n          <button id=\"runStep\" class=\"btn\">Run step-by-step demo (visual)</button>\n        </div>\n      </aside>\n    </div>\n\n    <footer>\n      Quick notes: Big-O abstracts constant factors and lower-order terms. It's a way to reason about scalability rather than precise timing.\n    </footer>\n  </div>\n\n  <script>\n    // Complexity functions and colors\n    const FUNCTIONS = [\n      {id:'O1', label:'O(1)', fn: n => 1, color:'#7dd3fc', desc:'Constant'},\n      {id:'Ologn', label:'O(log n)', fn: n => n>1 ? Math.log2(n) : 0, color:'#60a5fa', desc:'Logarithmic'},\n      {id:'On', label:'O(n)', fn: n => n, color:'#34d399', desc:'Linear'},\n      {id:'Onlogn', label:'O(n log n)', fn: n => n>1 ? n * Math.log2(n) : 0, color:'#fbbf24', desc:'n log n'},\n      {id:'On2', label:'O(n²)', fn: n => n*n, color:'#fb7185', desc:'Quadratic'},\n      {id:'O2n', label:'O(2ⁿ)', fn: n => {\n        // use floating large values, cap\n        if (n > 60) return Number.POSITIVE_INFINITY;\n        return Math.pow(2, n);\n      }, color:'#a78bfa', desc:'Exponential'},\n      {id:'Onfact', label:'O(n!)', fn: n => {\n        // factorial but cap\n        if (n > 20) return Number.POSITIVE_INFINITY;\n        let f=1;\n        for (let i=2;i<=n;i++) f*=i;\n        return f;\n      }, color:'#f97316', desc:'Factorial'}\n    ];\n\n    // DOM\n    const nRange = document.getElementById('nRange');\n    const nVal = document.getElementById('nVal');\n    const nValText = document.getElementById('nValText');\n    const chart = document.getElementById('chart');\n    const ctx = chart.getContext('2d');\n    const legendDiv = document.getElementById('legend');\n    const valTableBody = document.querySelector('#valTable tbody');\n    const runBench = document.getElementById('runBench');\n    const benchResults = document.getElementById('benchResults');\n    const resetBtn = document.getElementById('resetBtn');\n    const runStep = document.getElementById('runStep');\n\n    // State\n    let n = parseInt(nRange.value,10);\n    let maxN = 200;\n    let scale = 'linear';\n    let visible = {};\n    FUNCTIONS.forEach(f=> visible[f.id]=true);\n\n    // Set up legend and toggles\n    function buildLegend(){\n      legendDiv.innerHTML='';\n      FUNCTIONS.forEach(fn=>{\n        const el = document.createElement('div');\n        el.className='item';\n        const sw = document.createElement('span');\n        sw.className='swatch';\n        sw.style.background=fn.color;\n        const chk = document.querySelector('.toggleFunc[data-func=\"'+fn.id+'\"]');\n        const span = document.createElement('span');\n        span.textContent = fn.label + ' — ' + fn.desc;\n        el.appendChild(sw);\n        el.appendChild(span);\n        legendDiv.appendChild(el);\n        // Also wire checkbox\n        chk.addEventListener('change', e=>{\n          visible[fn.id]=chk.checked;\n          draw();\n          updateTable();\n        });\n      });\n    }\n\n    // Chart draw\n    function clearCanvas(){\n      ctx.clearRect(0,0,chart.width,chart.height);\n      // background\n      ctx.fillStyle = 'rgba(255,255,255,0.01)';\n      ctx.fillRect(0,0,chart.width,chart.height);\n    }\n\n    function draw(){\n      // High DPI scaling\n      const dpr = window.devicePixelRatio || 1;\n      const w = chart.clientWidth;\n      const h = chart.clientHeight;\n      chart.width = Math.floor(w * dpr);\n      chart.height = Math.floor(h * dpr);\n      ctx.setTransform(dpr,0,0,dpr,0,0);\n\n      clearCanvas();\n\n      // margins\n      const margin = {l:48,r:18,t:18,b:36};\n      const cw = canvasWidth();\n      const ch = canvasHeight();\n\n      // compute points for all functions up to maxN\n      const values = {};\n      let maxVal = 0;\n      for (const f of FUNCTIONS){\n        const arr = [];\n        for (let i=1;i<=n;i++){\n          const v = f.fn(i);\n          arr.push(v);\n          if (isFinite(v)) maxVal = Math.max(maxVal, v);\n        }\n        values[f.id]=arr;\n      }\n\n      // choose y scaling, if log scale selected, transform using log10\n      let transform = x => x;\n      let labelY = (v)=> formatNumber(v);\n      if (scale === 'log') {\n        transform = x => isFinite(x) && x>0 ? Math.log10(x) : x>0?Math.log10(x): -10;\n        // maxVal transform\n        maxVal = 0;\n        for (const f of FUNCTIONS){\n          values[f.id] = values[f.id].map(v => (isFinite(v) && v>0) ? Math.log10(v) : (v>0?Math.log10(v):-10));\n          maxVal = Math.max(maxVal, ...values[f.id].filter(v=>isFinite(v)));\n        }\n        labelY = (v)=> {\n          // convert back if possible: show 10^v\n          if (!isFinite(v)) return '∞';\n          return '10^' + (Math.round(v*100)/100);\n        };\n      }\n\n      // Prepare axes\n      drawGridAndAxes(ctx, margin, cw, ch, maxVal, labelY);\n\n      // draw each function\n      for (const f of FUNCTIONS){\n        if (!visible[f.id]) continue;\n        ctx.beginPath();\n        ctx.lineWidth = 2;\n        ctx.strokeStyle = f.color;\n        for (let i=1;i<=n;i++){\n          let raw = f.fn(i);\n          let v = raw;\n          if (scale==='log') {\n            v = (isFinite(raw) && raw>0) ? Math.log10(raw) : -10;\n          }\n          // if value is Infinity or NaN, skip\n          if (!isFinite(v)) continue;\n          const x = margin.l + ((i-1)/(n-1 || 1)) * cw;\n          const y = margin.t + (1 - (v / (maxVal || 1))) * ch;\n          if (i===1) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n        }\n        ctx.stroke();\n\n        // draw circle/marker at selected n\n        const rawVal = f.fn(n);\n        if (isFinite(rawVal) && (scale!=='log' || rawVal>0)) {\n          const v = (scale==='log') ? Math.log10(rawVal) : rawVal;\n          const x = margin.l + ((n-1)/(n-1 || 1)) * cw;\n          const y = margin.t + (1 - (v / (maxVal || 1))) * ch;\n          ctx.fillStyle = f.color;\n          ctx.beginPath();\n          ctx.arc(x,y,4,0,Math.PI*2);\n          ctx.fill();\n        }\n      }\n\n      // vertical marker line at n\n      ctx.strokeStyle = 'rgba(255,255,255,0.06)';\n      ctx.setLineDash([4,4]);\n      ctx.beginPath();\n      const xmarker = margin.l + ((n-1)/(n-1 || 1)) * cw;\n      ctx.moveTo(xmarker, margin.t);\n      ctx.lineTo(xmarker, margin.t + ch);\n      ctx.stroke();\n      ctx.setLineDash([]);\n    }\n\n    function canvasWidth(){ return chart.clientWidth - 48 - 18; }\n    function canvasHeight(){ return chart.clientHeight - 18 - 36; }\n\n    function drawGridAndAxes(ctx, margin, cw, ch, maxVal, labelY){\n      // background grid\n      ctx.strokeStyle = 'rgba(255,255,255,0.03)';\n      ctx.lineWidth = 1;\n      ctx.beginPath();\n      const gridLines = 6;\n      for (let i=0;i<=gridLines;i++){\n        const y = margin.t + (i/gridLines)*ch;\n        ctx.moveTo(margin.l, y);\n        ctx.lineTo(margin.l + cw, y);\n      }\n      ctx.stroke();\n\n      // y labels\n      ctx.fillStyle = 'rgba(230,238,246,0.9)';\n      ctx.font = '12px Inter, Arial';\n      ctx.textAlign = 'right';\n      ctx.textBaseline = 'middle';\n      const steps = 6;\n      for (let i=0;i<=steps;i++){\n        const v = (1 - i/steps) * maxVal;\n        const y = margin.t + (i/steps)*ch;\n        const label = labelY(v);\n        ctx.fillStyle = 'rgba(170,190,205,0.9)';\n        ctx.fillText(label, margin.l - 8, y);\n      }\n\n      // x labels: 1, n/4, n/2, n\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'top';\n      const ns = [1, Math.floor(n/4), Math.floor(n/2), n];\n      ns.forEach(v=>{\n        const x = margin.l + ((v-1)/(n-1 || 1)) * cw;\n        ctx.fillStyle = 'rgba(170,190,205,0.8)';\n        ctx.fillText(String(v), x, margin.t + ch + 8);\n      });\n    }\n\n    function formatNumber(x){\n      if (!isFinite(x)) return '∞';\n      if (x === 0) return '0';\n      if (x < 1e3) return x.toString();\n      if (x < 1e6) return (Math.round(x*100)/100).toLocaleString();\n      if (x < 1e9) return (x/1e6).toFixed(2) + 'M';\n      if (x < 1e12) return (x/1e9).toFixed(2) + 'B';\n      return x.toExponential(3);\n    }\n\n    // update numeric table\n    function updateTable(){\n      nVal.textContent = n;\n      nValText.textContent = n;\n      valTableBody.innerHTML = '';\n      // compute base values\n      const base = 1;\n      for (const f of FUNCTIONS){\n        const val = f.fn(n);\n        const tr = document.createElement('tr');\n        const tdName = document.createElement('td');\n        tdName.textContent = f.label;\n        const tdVal = document.createElement('td');\n        tdVal.textContent = formatNumber(val);\n        const tdRel = document.createElement('td');\n        // relative: compare to O(n) value or to f(1)\n        const ref = FUNCTIONS.find(x=>x.id==='On').fn(n);\n        let rel;\n        if (!isFinite(val) && isFinite(ref)) rel = '≫ ' + formatNumber(ref);\n        else if (!isFinite(val) && !isFinite(ref)) rel = '≫';\n        else rel = (ref===0)? '—' : '≈ ' + ( (val / ref).toFixed(3) + '× O(n)' );\n        tdRel.textContent = rel;\n        if (!visible[f.id]) {\n          tr.style.opacity = 0.45;\n        }\n        tr.appendChild(tdName);\n        tr.appendChild(tdVal);\n        tr.appendChild(tdRel);\n        valTableBody.appendChild(tr);\n      }\n    }\n\n    // events\n    nRange.addEventListener('input', e=>{\n      n = parseInt(e.target.value,10);\n      updateTable();\n      draw();\n    });\n\n    document.querySelectorAll('input[name=\"scale\"]').forEach(r=>{\n      r.addEventListener('change', e=>{\n        scale = e.target.value;\n        draw();\n      });\n    });\n\n    resetBtn.addEventListener('click', ()=>{\n      nRange.value = 50;\n      n = 50;\n      document.querySelectorAll('.toggleFunc').forEach(ch=>{ ch.checked = true; visible[ch.dataset.func]=true; });\n      document.querySelector('input[name=\"scale\"][value=\"linear\"]').checked = true;\n      scale = 'linear';\n      updateTable();\n      draw();\n      benchResults.textContent = 'Press \"Run micro-bench\" to measure operations for three simple routines.';\n    });\n\n    // small micro-bench: run three routines (O(1), O(n), O(n^2))\n    function microBench(runN){\n      // prepare array of length runN\n      const arr = new Array(runN).fill(1);\n      const results = {};\n      // O(1)\n      const t0 = performance.now();\n      for (let i=0;i<100000;i++){ // do many repeats to get measurable time\n        const x = arr[0];\n        void x;\n      }\n      const t1 = performance.now();\n      results.O1 = (t1 - t0);\n\n      // O(n)\n      const t2 = performance.now();\n      let s = 0;\n      for (let r=0;r<300;r++){ // repeat to amplify\n        for (let i=0;i<runN;i++) s+=arr[i];\n      }\n      const t3 = performance.now();\n      results.On = (t3 - t2);\n\n      // O(n^2) - careful with size\n      const safeN = Math.min(runN, 400); // cap to prevent long blocking\n      const t4 = performance.now();\n      let c = 0;\n      for (let i=0;i<safeN;i++){\n        for (let j=0;j<safeN;j++){\n          c += (i+j) & 1;\n        }\n      }\n      const t5 = performance.now();\n      results.On2 = (t5 - t4);\n\n      return results;\n    }\n\n    runBench.addEventListener('click', ()=>{\n      const runN = n;\n      benchResults.textContent = 'Running micro-bench...';\n      // run in a small timeout to update UI\n      setTimeout(()=>{\n        const res = microBench(runN);\n        benchResults.innerHTML = `<div><strong>n = ${runN}</strong></div>\n          <div style=\"margin-top:6px\">O(1) demo: ${res.O1.toFixed(3)} ms</div>\n          <div>O(n) demo (repeated loops): ${res.On.toFixed(3)} ms</div>\n          <div>O(n²) demo (capped N for safety): ${res.On2.toFixed(3)} ms</div>\n          <div style=\"margin-top:8px;color:var(--muted)\">Note: Many factors influence absolute times (hardware, JS engine). These numbers are illustrative of relative trends.</div>`;\n      }, 40);\n    });\n\n    // step-by-step visual demo: animate two routines marking operations\n    runStep.addEventListener('click', ()=>{\n      runStep.disabled = true;\n      runStep.textContent = 'Animating...';\n      animateDemo().finally(()=>{\n        runStep.disabled = false;\n        runStep.textContent = 'Run step-by-step demo (visual)';\n      });\n    });\n\n    async function animateDemo(){\n      // create small canvas overlay\n      const overlay = document.createElement('div');\n      overlay.style.position='fixed';\n      overlay.style.left='0';\n      overlay.style.top='0';\n      overlay.style.width='100%';\n      overlay.style.height='100%';\n      overlay.style.display='flex';\n      overlay.style.alignItems='center';\n      overlay.style.justifyContent='center';\n      overlay.style.background='rgba(1,6,14,0.6)';\n      overlay.style.zIndex='9999';\n      const panel = document.createElement('div');\n      panel.style.background='#071322';\n      panel.style.padding='14px';\n      panel.style.borderRadius='12px';\n      panel.style.maxWidth='900px';\n      panel.style.color='var(--white)';\n      panel.innerHTML = `<h3 style=\"margin:0 0 8px\">Step-by-step: O(n) vs O(n²)</h3>\n        <div style=\"display:flex;gap:12px;align-items:flex-start\">\n          <div style=\"width:420px\"><canvas id=\"animCanvas\" width=\"420\" height=\"220\" style=\"border-radius:8px;background:#071a2a\"></canvas></div>\n          <div style=\"flex:1\">\n            <div id=\"animInfo\" style=\"font-size:13px;color:var(--muted)\"></div>\n            <div style=\"margin-top:12px\"><button id=\"animClose\" class=\"btn\">Close</button></div>\n          </div>\n        </div>`;\n      overlay.appendChild(panel);\n      document.body.appendChild(overlay);\n      const animCanvas = document.getElementById('animCanvas');\n      const actx = animCanvas.getContext('2d');\n      const animInfo = document.getElementById('animInfo');\n      const closeBtn = document.getElementById('animClose');\n      const A = 12; // visual \"n\"\n      // animate O(n): highlight each element once\n      actx.clearRect(0,0,animCanvas.width,animCanvas.height);\n      const cellW = 30;\n      const cellH = 30;\n      const marginX = 20;\n      const y1 = 40;\n      const y2 = 140;\n      // draw arrays\n      function drawArray(){\n        actx.clearRect(0,0,animCanvas.width,animCanvas.height);\n        actx.fillStyle='rgba(255,255,255,0.04)';\n        actx.fillRect(0,0,animCanvas.width,animCanvas.height);\n        actx.fillStyle='rgba(255,255,255,0.07)';\n        actx.font='12px Inter';\n        actx.textAlign='center';\n        actx.textBaseline='middle';\n        for (let i=0;i<A;i++){\n          actx.fillStyle='rgba(255,255,255,0.06)';\n          actx.fillRect(marginX + i*(cellW+6), y1, cellW, cellH);\n          actx.fillStyle='#9aa4b2';\n          actx.fillText(String(i), marginX + i*(cellW+6)+cellW/2, y1+cellH/2);\n        }\n        // draw two nested loops row\n        for (let i=0;i<A;i++){\n          actx.fillStyle='rgba(255,255,255,0.04)';\n          actx.fillRect(marginX + i*(cellW+6), y2, cellW, cellH);\n          actx.fillStyle='#9aa4b2';\n          actx.fillText(String(i), marginX + i*(cellW+6)+cellW/2, y2+cellH/2);\n        }\n        actx.fillStyle='#7dd3fc';\n        actx.fillText('O(n): visit each element once', animCanvas.width/2, y1-16);\n        actx.fillStyle='#fb7185';\n        actx.fillText('O(n²): visit each pair (i,j)', animCanvas.width/2, y2-16);\n      }\n      drawArray();\n      animInfo.textContent = 'O(n): highlighting each element in a single loop...';\n      // animate linear\n      for (let i=0;i<A;i++){\n        highlight(actx, marginX + i*(cellW+6), y1, cellW, cellH, '#34d399');\n        await sleep(140);\n        highlight(actx, marginX + i*(cellW+6), y1, cellW, cellH, 'rgba(255,255,255,0.06)');\n      }\n      // animate quadratic\n      animInfo.textContent = 'O(n²): nested loop — for each i, iterate j from 0..n-1';\n      for (let i=0;i<A;i++){\n        for (let j=0;j<A;j++){\n          highlight(actx, marginX + i*(cellW+6), y2, cellW, cellH, '#fb7185', true);\n          highlight(actx, marginX + j*(cellW+6), y2, cellW, cellH, '#fb7185', false);\n          await sleep(28);\n          // restore\n          drawArray();\n        }\n      }\n      animInfo.innerHTML = '<strong>Takeaway:</strong> O(n) performs ~n steps; O(n²) ~ n×n steps. Quadratic grows much faster.';\n      closeBtn.onclick = () => { document.body.removeChild(overlay); };\n      // auto close after a while\n      await sleep(2200);\n      // leave for user to close or auto close after 6s\n      await sleep(4000);\n      if (document.body.contains(overlay)) document.body.removeChild(overlay);\n    }\n\n    function highlight(ctx,x,y,w,h,color,outlineOnly=false){\n      ctx.fillStyle = color;\n      if (!outlineOnly) ctx.fillRect(x,y,w,h);\n      ctx.strokeStyle = '#ffffff';\n      ctx.lineWidth = 2;\n      ctx.strokeRect(x+1,y+1,w-2,h-2);\n      ctx.fillStyle='white';\n      ctx.font='12px Inter';\n      ctx.textAlign='center';\n      ctx.textBaseline='middle';\n    }\n\n    function sleep(ms){ return new Promise(res=>setTimeout(res, ms)); }\n\n    // initialize\n    buildLegend();\n    updateTable();\n    draw();\n\n    // accessibility: redraw on resize\n    window.addEventListener('resize', ()=> draw());\n  </script>\n</body>\n</html>"
