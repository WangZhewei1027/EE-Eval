    "content": "<html>\n<head>\n    <title>Encryption</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #output {\n            font-size: 24px;\n            font-weight: bold;\n            margin-bottom: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Encryption</h1>\n    <button id=\"encrypt-btn\">Encrypt</button>\n    <button id=\"decrypt-btn\">Decrypt</button>\n    <div id=\"output\"></div>\n\n    <script>\n        const encryptBtn = document.getElementById('encrypt-btn');\n        const decryptBtn = document.getElementById('decrypt-btn');\n        const outputDiv = document.getElementById('output');\n\n        encryptBtn.addEventListener('click', () => {\n            const text = 'This is a secret message';\n            const key = prompt('Enter the encryption key:', '123456');\n            if (key) {\n                const encryptedText = encrypt(text, key);\n                outputDiv.innerText = `Encrypted text: ${encryptedText}`;\n            } else {\n                alert('Please enter a valid key');\n            }\n        });\n\n        decryptBtn.addEventListener('click', () => {\n            const text = 'This is a secret message';\n            const key = prompt('Enter the decryption key:', '123456');\n            if (key) {\n                const decryptedText = decrypt(text, key);\n                outputDiv.innerText = `Decrypted text: ${decryptedText}`;\n            } else {\n                alert('Please enter a valid key');\n            }\n        });\n\n        function encrypt(text, key) {\n            const encryptedText = '';\n            for (let i = 0; i < text.length; i++) {\n                const char = text[i];\n                if (char.match(/[a-zA-Z]/)) {\n                    const asciiOffset = char === char.toUpperCase() ? 65 : 97;\n                    encryptedText += String.fromCharCode((char.charCodeAt(0) - asciiOffset + key.charCodeAt(0) - 65) % 26 + asciiOffset);\n                } else {\n                    encryptedText += char;\n                }\n            }\n            return encryptedText;\n        }\n\n        function decrypt(text, key) {\n            const decryptedText = '';\n            for (let i = 0; i < text.length; i++) {\n                const char = text[i];\n                if (char.match(/[a-zA-Z]/)) {\n                    const asciiOffset = char === char.toUpperCase() ? 65 : 97;\n                    decryptedText += String.fromCharCode((char.charCodeAt(0) - asciiOffset - key.charCodeAt(0) + 65) % 26 + asciiOffset);\n                } else {\n                    decryptedText += char;\n                }\n            }\n            return decryptedText;\n        }\n    </script>\n</body>\n</html>"
