    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Unit Testing Demo (Single File)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root {\n      --bg: #0f1724;\n      --panel: #0b1220;\n      --muted: #9aa4b2;\n      --success: #16a34a;\n      --danger: #ef4444;\n      --accent: #60a5fa;\n      --card: #0f1724;\n      --text: #e6eef6;\n    }\n    body {\n      font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n      margin: 0;\n      padding: 18px;\n      background: linear-gradient(180deg,#071022 0%, #051124 100%);\n      color: var(--text);\n      -webkit-font-smoothing:antialiased;\n      -moz-osx-font-smoothing:grayscale;\n    }\n    header {\n      display:flex;\n      align-items:center;\n      gap:12px;\n    }\n    h1 { margin: 0; font-size: 20px; }\n    p.lead { margin: 6px 0 18px 0; color: var(--muted); font-size: 13px; }\n\n    .controls {\n      display:flex; gap:8px; margin-bottom:12px; align-items:center;\n    }\n    button {\n      background: linear-gradient(180deg, #1e293b, #0f1724);\n      border: 1px solid #263247;\n      color: var(--text);\n      padding: 8px 12px;\n      border-radius: 8px;\n      cursor:pointer;\n      font-size:13px;\n    }\n    button:active { transform: translateY(1px); }\n    input[type=\"checkbox\"] { transform:scale(1.15); margin-right:6px; }\n\n    .layout { display:grid; grid-template-columns: 480px 1fr; gap:14px; align-items:start; }\n    .card {\n      background: linear-gradient(180deg,#071326 0%, #071022 100%);\n      padding: 12px;\n      border-radius: 10px;\n      box-shadow: 0 6px 18px rgba(2,6,23,0.6);\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n    .summary {\n      display:flex; gap:10px; align-items:center; flex-wrap:wrap;\n    }\n    .badge {\n      display:inline-flex; gap:8px; padding:8px 10px; align-items:center; border-radius:8px;\n      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.02); font-size:13px;\n    }\n    .badge .num { font-weight:700; margin-left:6px; }\n    .badge.pass { color: var(--success); border-color: rgba(22,163,74,0.12); background: rgba(16,185,129,0.03); }\n    .badge.fail { color: var(--danger); border-color: rgba(239,68,68,0.12); background: rgba(239,68,68,0.03); }\n    .badge.time { color: var(--muted); }\n\n    .tests-list { max-height: 540px; overflow:auto; margin-top:12px; }\n    .test-item {\n      display:flex; gap:12px; align-items:center; padding:8px; border-radius:8px;\n      border: 1px solid rgba(255,255,255,0.02); margin-bottom:8px;\n      transition: background 160ms, border-color 160ms;\n      cursor: pointer;\n    }\n    .test-item.pass { background: linear-gradient(90deg, rgba(16,185,129,0.03), transparent); border-color: rgba(16,185,129,0.06); }\n    .test-item.fail { background: linear-gradient(90deg, rgba(239,68,68,0.03), transparent); border-color: rgba(239,68,68,0.06); }\n    .test-item .status {\n      width:36px; height:36px; display:grid; place-items:center; border-radius:8px; font-weight:700;\n      background: rgba(255,255,255,0.03);\n    }\n    .status.pass { color: var(--success); border: 1px solid rgba(22,163,74,0.10); }\n    .status.fail { color: var(--danger); border: 1px solid rgba(239,68,68,0.10); }\n    .test-item .meta { color: var(--muted); font-size:12px; margin-left:auto; }\n\n    .details {\n      font-size:13px;\n      color: var(--muted);\n      margin-top:10px;\n      background: rgba(255,255,255,0.01);\n      padding:10px;\n      border-radius:8px;\n      max-height:520px; overflow:auto;\n    }\n    pre { margin:0; white-space:pre-wrap; word-break:break-word; color: #d6e9ff; font-size:13px; }\n    code { background: rgba(255,255,255,0.02); padding:2px 6px; border-radius:6px; color: #e9f3ff; font-size:12px; }\n\n    footer { margin-top:14px; color:var(--muted); font-size:13px; }\n    .small { font-size:12px; color:var(--muted); }\n\n    /* responsive */\n    @media (max-width: 880px) {\n      .layout { grid-template-columns: 1fr; }\n      .tests-list { max-height: 320px; }\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <div>\n      <h1>Unit Testing Demo</h1>\n      <p class=\"lead\">A tiny, self-contained unit testing playground implemented in plain JavaScript. Click \"Run All\" to execute the sample test suite.</p>\n    </div>\n  </header>\n\n  <div class=\"controls\">\n    <button id=\"runBtn\">Run All Tests</button>\n    <label title=\"Auto-run on load\"><input type=\"checkbox\" id=\"autoRun\" checked /> Auto-run</label>\n    <label title=\"Show full error stacks\"><input type=\"checkbox\" id=\"showStack\" /> Show stack traces</label>\n    <div style=\"flex:1\"></div>\n    <div class=\"small\">Note: This is a demonstration — not a production test runner.</div>\n  </div>\n\n  <div class=\"layout\">\n    <div class=\"card\">\n      <div class=\"summary\">\n        <div class=\"badge\"><strong>Tests</strong> <span class=\"num\" id=\"total\">0</span></div>\n        <div class=\"badge pass\"><strong>Passed</strong> <span class=\"num\" id=\"passed\">0</span></div>\n        <div class=\"badge fail\"><strong>Failed</strong> <span class=\"num\" id=\"failed\">0</span></div>\n        <div class=\"badge time\"><strong>Time</strong> <span class=\"num\" id=\"time\">0ms</span></div>\n      </div>\n\n      <div class=\"tests-list\" id=\"testsList\" aria-live=\"polite\" aria-atomic=\"true\">\n        <!-- tests will be rendered here -->\n      </div>\n    </div>\n\n    <div class=\"card\">\n      <div style=\"display:flex; gap:12px; align-items:center;\">\n        <div style=\"font-weight:700; font-size:15px;\">Details</div>\n        <div style=\"color:var(--muted); font-size:13px;\">Click a test to inspect results & error output</div>\n      </div>\n      <div class=\"details\" id=\"details\">\n        <div class=\"small\">No test selected. Run the suite to see results here.</div>\n      </div>\n    </div>\n  </div>\n\n  <footer>\n    <div style=\"margin-top:12px;\" class=\"small\">This tiny runner demonstrates: assertions, synchronous & asynchronous tests, hooks (beforeEach/afterEach), spying/mocking, and reporting.</div>\n  </footer>\n\n  <script>\n    /************************************************************************\n     * Tiny Unit Test Runner\n     *\n     * Features:\n     *  - describe / it style registration\n     *  - beforeEach / afterEach\n     *  - supports sync tests, async tests returning Promise, and done callback\n     *  - assertion helpers (assert, equal, deepEqual, throws, rejects)\n     *  - simple spy/mock\n     *  - UI rendering and interactive details\n     *\n     * Note: This is educational and intentionally small. It does not implement\n     * all edge cases of production test frameworks.\n     ************************************************************************/\n\n    (function() {\n      // Minimal assertion utilities\n      function fail(message) {\n        throw new Error(message || \"Test failed\");\n      }\n\n      function isDeepEqual(a, b) {\n        // Simple deep equality using JSON stringify for demo (works for plain data)\n        try {\n          return JSON.stringify(a) === JSON.stringify(b);\n        } catch (e) {\n          return a === b;\n        }\n      }\n\n      const assert = {\n        ok(value, msg) {\n          if (!value) fail(msg || `Expected truthy value, got ${value}`);\n        },\n        equal(actual, expected, msg) {\n          if (actual !== expected) fail(msg || `Expected ${expected} but got ${actual}`);\n        },\n        deepEqual(actual, expected, msg) {\n          if (!isDeepEqual(actual, expected)) {\n            fail(msg || `Deep equality failed.\\nExpected: ${JSON.stringify(expected)}\\nActual: ${JSON.stringify(actual)}`);\n          }\n        },\n        throws(fn, expectedMessage) {\n          try {\n            fn();\n          } catch (err) {\n            if (expectedMessage && !String(err.message).includes(expectedMessage)) {\n              fail(`Expected error message to include \"${expectedMessage}\", got \"${err.message}\"`);\n            }\n            return;\n          }\n          fail(\"Expected function to throw, but it did not.\");\n        },\n        async rejects(promiseOrFn, expectedMessage) {\n          // Accepts either a Promise or a function returning a Promise\n          try {\n            const p = (typeof promiseOrFn === 'function') ? promiseOrFn() : promiseOrFn;\n            await p;\n          } catch (err) {\n            if (expectedMessage && !String(err.message).includes(expectedMessage)) {\n              fail(`Expected rejection message to include \"${expectedMessage}\", got \"${err.message}\"`);\n            }\n            return;\n          }\n          fail(\"Expected promise to reject but it resolved.\");\n        },\n      };\n\n      // Spy / Mock helper\n      function createSpy(returnValue) {\n        function spy(...args) {\n          spy.calls.push({ args });\n          spy.called = true;\n          return spy.returnValue;\n        }\n        spy.called = false;\n        spy.calls = [];\n        spy.returnValue = returnValue;\n        spy.andReturn = (v) => { spy.returnValue = v; return spy; };\n        spy.reset = () => { spy.called = false; spy.calls.length = 0; };\n        return spy;\n      }\n\n      function spyOn(obj, methodName) {\n        const original = obj[methodName];\n        const spy = createSpy();\n        obj[methodName] = function(...args) {\n          spy.calls.push({ args });\n          spy.called = true;\n          return original.apply(this, args);\n        };\n        return {\n          spy,\n          restore() { obj[methodName] = original; }\n        };\n      }\n\n      // Test registration\n      const rootSuites = [];\n      const suiteStack = [];\n\n      function describe(name, fn) {\n        const suite = { name, beforeEach: [], afterEach: [], tests: [] };\n        if (suiteStack.length === 0) rootSuites.push(suite);\n        else suiteStack[suiteStack.length-1].suites = suiteStack[suiteStack.length-1].suites || [], suiteStack[suiteStack.length-1].suites.push(suite);\n        suiteStack.push(suite);\n        try { fn(); } finally { suiteStack.pop(); }\n      }\n\n      function beforeEach(fn) {\n        if (!suiteStack.length) throw new Error(\"beforeEach must be called inside describe\");\n        suiteStack[suiteStack.length-1].beforeEach.push(fn);\n      }\n      function afterEach(fn) {\n        if (!suiteStack.length) throw new Error(\"afterEach must be called inside describe\");\n        suiteStack[suiteStack.length-1].afterEach.push(fn);\n      }\n\n      function it(name, fn) {\n        if (!suiteStack.length) {\n          // Allow top-level tests\n          rootSuites.push({ name: '‹root›', tests: [{ name, fn }], beforeEach: [], afterEach: [] });\n          return;\n        }\n        const current = suiteStack[suiteStack.length-1];\n        current.tests.push({ name, fn });\n      }\n\n      // Flatten tests into list with hooks captured by ancestor chain.\n      function collectTests() {\n        const out = [];\n        function walk(suite, ancestors) {\n          const newAnc = ancestors.concat(suite);\n          if (suite.tests) {\n            for (const t of suite.tests) {\n              const fullName = newAnc.map(s => s.name).filter(Boolean).join(' > ') + ' > ' + t.name;\n              const befores = newAnc.flatMap(s => s.beforeEach || []);\n              const afters = newAnc.flatMap(s => s.afterEach || []);\n              out.push({ name: fullName, fn: t.fn, beforeEach: befores, afterEach: afters });\n            }\n          }\n          if (suite.suites) {\n            for (const s2 of suite.suites) walk(s2, newAnc);\n          }\n        }\n        for (const s of rootSuites) walk(s, []);\n        return out;\n      }\n\n      // Runner\n      async function runAllTests(renderCallback) {\n        const tests = collectTests();\n        const results = [];\n        const start = performance.now();\n        for (const t of tests) {\n          // run beforeEach hooks\n          try {\n            for (const b of t.beforeEach) b();\n          } catch (e) {\n            // beforeEach failure -> mark test as failed and continue\n            results.push({ name: t.name, status: 'fail', error: e, duration: 0 });\n            renderCallback && renderCallback(results, []); // update UI inline\n            continue;\n          }\n\n          const testStart = performance.now();\n          let status = 'pass', error = null;\n          try {\n            const res = t.fn.length >= 1 ? await runWithDone(t.fn) : t.fn();\n            if (res instanceof Promise) {\n              await res;\n            }\n          } catch (err) {\n            status = 'fail';\n            error = err;\n          }\n          const testEnd = performance.now();\n\n          // run afterEach hooks even if test failed\n          try {\n            for (const a of t.afterEach) a();\n          } catch (e) {\n            // If test already failed, keep it failed; otherwise fail due to afterEach\n            if (status === 'pass') {\n              status = 'fail';\n              error = e;\n            } else {\n              // attach but don't override original error\n              // chain? for demo we'll append\n              error = error || e;\n            }\n          }\n\n          results.push({ name: t.name, status, error, duration: Math.round(testEnd - testStart) });\n          renderCallback && renderCallback(results, []);\n        }\n        const end = performance.now();\n        const totalTime = Math.round(end - start);\n        return { results, totalTime };\n      }\n\n      function runWithDone(fn) {\n        // Wraps a test function that expects a 'done' callback.\n        return new Promise((resolve, reject) => {\n          let finished = false;\n          const timeout = setTimeout(() => {\n            if (!finished) {\n              finished = true;\n              reject(new Error(\"Test timed out (done callback not called)\"));\n            }\n          }, 2000);\n          try {\n            fn(function done(err) {\n              if (finished) return;\n              finished = true;\n              clearTimeout(timeout);\n              if (err) reject(err);\n              else resolve();\n            });\n          } catch (e) {\n            if (!finished) {\n              finished = true;\n              clearTimeout(timeout);\n              reject(e);\n            }\n          }\n        });\n      }\n\n      // expose minimal API to the sample tests\n      window.testAPI = {\n        describe, it, beforeEach, afterEach, assert, createSpy, spyOn\n      };\n\n      /***********************************************************************\n       * Sample functions under test (pure functions and async simulation)\n       ***********************************************************************/\n      function add(a,b) {\n        if (typeof a !== 'number' || typeof b !== 'number') throw new TypeError(\"Arguments must be numbers\");\n        return a + b;\n      }\n\n      function asyncMultiply(a, b) {\n        return new Promise(resolve => setTimeout(() => resolve(a * b), 60));\n      }\n\n      function fetchUser(id) {\n        // Simulate network call:\n        return new Promise((resolve, reject) => {\n          setTimeout(() => {\n            if (id === 0) reject(new Error('Not found'));\n            else resolve({ id, name: 'User' + id });\n          }, 80);\n        });\n      }\n\n      // A function that uses dependency we can spy on:\n      const mathLib = {\n        multiply(a,b) { return a*b; }\n      };\n      function multiplyAndLog(a,b, logger) {\n        const result = mathLib.multiply(a,b);\n        if (logger && typeof logger.log === 'function') logger.log('result', result);\n        return result;\n      }\n\n      /***********************************************************************\n       * Register sample tests demonstrating various features\n       ***********************************************************************/\n      (function registerSampleTests() {\n        const { describe, it, beforeEach, afterEach, assert, createSpy, spyOn } = window.testAPI;\n\n        describe('Addition', () => {\n          it('adds two positive numbers', () => {\n            assert.equal(add(2,3), 5);\n          });\n\n          it('adds negative numbers', () => {\n            assert.equal(add(-2, -4), -6);\n          });\n\n          it('throws when given non-numbers', () => {\n            assert.throws(() => add('x', 2), 'Arguments must be numbers');\n          });\n        });\n\n        describe('Asynchronous operations', () => {\n          it('asyncMultiply returns the product (Promise)', async () => {\n            const res = await asyncMultiply(3,4);\n            assert.equal(res, 12);\n          });\n\n          it('fetchUser resolves for valid id (Promise)', () => {\n            return fetchUser(2).then(u => {\n              assert.equal(u.id, 2);\n              assert.equal(u.name, 'User2');\n            });\n          });\n\n          it('fetchUser rejects for id 0 (assert.rejects)', async () => {\n            await assert.rejects(fetchUser(0), 'Not found');\n          });\n\n          it('supports done(callback) style', (done) => {\n            asyncMultiply(2,5).then(v => {\n              try {\n                assert.equal(v, 10);\n                done();\n              } catch (e) {\n                done(e);\n              }\n            });\n          }, );\n        });\n\n        describe('Hooks and state isolation', () => {\n          let arr;\n          beforeEach(() => {\n            arr = [];\n          });\n          afterEach(() => {\n            arr = null;\n          });\n\n          it('beforeEach resets array before each test', () => {\n            arr.push(1);\n            assert.equal(arr.length, 1);\n          });\n\n          it('previous test does not affect next', () => {\n            assert.equal(arr.length, 0);\n          });\n        });\n\n        describe('Spying & mocking', () => {\n          it('spy detects calls and arguments', () => {\n            const spy = createSpy();\n            spy(1,2);\n            spy('x');\n            assert.ok(spy.called);\n            assert.equal(spy.calls.length, 2);\n            assert.equal(spy.calls[0].args[0], 1);\n            assert.equal(spy.calls[1].args[0], 'x');\n          });\n\n          it('spyOn wraps object method and can be restored', () => {\n            const { spy, restore } = spyOn(mathLib, 'multiply');\n            const logger = { log: () => {} };\n            const res = multiplyAndLog(4,5, logger);\n            assert.equal(res, 20);\n            assert.ok(spy.called);\n            assert.equal(spy.calls[0].args[0], 4);\n            restore();\n            // ensure original restored works\n            assert.equal(mathLib.multiply(2,3), 6);\n          });\n        });\n\n        describe('Failing examples (to illustrate failures)', () => {\n          it('intentional failure: wrong expectation', () => {\n            // This will fail so you can see how errors are reported\n            assert.equal(add(1,1), 3);\n          });\n\n          it('intentional deep-equal failure', () => {\n            assert.deepEqual({a:1, b:2}, {a: 1, b: 3});\n          });\n        });\n      })();\n\n      /***********************************************************************\n       * UI Rendering & Interaction\n       ***********************************************************************/\n      const runBtn = document.getElementById('runBtn');\n      const testsListEl = document.getElementById('testsList');\n      const totalEl = document.getElementById('total');\n      const passedEl = document.getElementById('passed');\n      const failedEl = document.getElementById('failed');\n      const timeEl = document.getElementById('time');\n      const detailsEl = document.getElementById('details');\n      const autoRunEl = document.getElementById('autoRun');\n      const showStackEl = document.getElementById('showStack');\n\n      function renderResults(results, elapsed) {\n        // results is array with {name, status, error, duration}\n        testsListEl.innerHTML = '';\n        let passed = 0, failed = 0, total = results.length;\n        results.forEach((r, idx) => {\n          const item = document.createElement('div');\n          item.className = 'test-item ' + (r.status === 'pass' ? 'pass':'fail');\n          item.title = r.name;\n          const status = document.createElement('div');\n          status.className = 'status ' + (r.status === 'pass' ? 'pass':'fail');\n          status.textContent = r.status === 'pass' ? '✓' : '✕';\n          const title = document.createElement('div');\n          title.innerHTML = '<strong style=\"color:inherit\">' + escapeHtml(shortName(r.name)) + '</strong><div class=\"small\" style=\"color:var(--muted)\">' + escapeHtml(r.name) + '</div>';\n\n          const meta = document.createElement('div');\n          meta.className = 'meta';\n          meta.innerHTML = (r.duration ? (r.duration + 'ms') : '') + (r.error ? (' • ' + (r.error.message || 'Error')) : '');\n\n          item.appendChild(status);\n          item.appendChild(title);\n          item.appendChild(meta);\n\n          item.addEventListener('click', () => showDetails(r, idx));\n          testsListEl.appendChild(item);\n\n          if (r.status === 'pass') passed++; else failed++;\n        });\n\n        totalEl.textContent = total;\n        passedEl.textContent = passed;\n        failedEl.textContent = failed;\n        timeEl.textContent = elapsed + 'ms';\n      }\n\n      function shortName(full) {\n        const parts = full.split(' > ');\n        return parts[parts.length-1];\n      }\n\n      function escapeHtml(s) {\n        if (!s) return '';\n        return String(s).replace(/[&<>\"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',\"'\":'&#39;'}[ch]));\n      }\n\n      let lastResults = [];\n      let lastElapsed = 0;\n      function showDetails(result, index) {\n        detailsEl.innerHTML = '';\n        const header = document.createElement('div');\n        header.innerHTML = '<div style=\"font-weight:700; margin-bottom:6px;\">' + escapeHtml(shortName(result.name)) + '</div>';\n        detailsEl.appendChild(header);\n\n        const path = document.createElement('div');\n        path.className = 'small';\n        path.style.marginBottom = '10px';\n        path.textContent = result.name;\n        detailsEl.appendChild(path);\n\n        const status = document.createElement('div');\n        status.innerHTML = '<strong>Status:</strong> ' + (result.status === 'pass' ? '<span style=\"color:var(--success)\">PASS</span>' : '<span style=\"color:var(--danger)\">FAIL</span>') + ' • ' + (result.duration || 0) + 'ms';\n        status.style.marginBottom = '8px';\n        detailsEl.appendChild(status);\n\n        if (result.error) {\n          const errBox = document.createElement('pre');\n          errBox.style.background = 'rgba(255,255,255,0.02)';\n          errBox.style.padding = '10px';\n          errBox.style.borderRadius = '8px';\n          const showStack = showStackEl.checked;\n          const text = showStack && result.error.stack ? result.error.stack : (result.error.message || String(result.error));\n          errBox.textContent = text;\n          detailsEl.appendChild(errBox);\n        } else {\n          const ok = document.createElement('div');\n          ok.textContent = 'No errors. Test passed.';\n          ok.style.color = 'var(--muted)';\n          detailsEl.appendChild(ok);\n        }\n\n        // show full summary below\n        const summ = document.createElement('div');\n        summ.style.marginTop = '12px';\n        summ.className = 'small';\n        summ.innerHTML = `Total: ${lastResults.length} • Passed: ${lastResults.filter(r=>r.status==='pass').length} • Failed: ${lastResults.filter(r=>r.status!=='pass').length} • Time: ${lastElapsed}ms`;\n        detailsEl.appendChild(summ);\n      }\n\n      runBtn.addEventListener('click', async () => {\n        runBtn.disabled = true;\n        runBtn.textContent = 'Running...';\n        detailsEl.innerHTML = '<div class=\"small\">Running tests...</div>';\n        const { results, totalTime } = await runAllTests((partialResults) => {\n          // partial update while running\n          lastResults = partialResults;\n          lastElapsed = 0;\n          renderResults(partialResults, lastElapsed);\n        });\n        lastResults = results;\n        lastElapsed = totalTime;\n        renderResults(results, totalTime);\n        runBtn.disabled = false;\n        runBtn.textContent = 'Run All Tests';\n      });\n\n      // Auto-run on load if enabled\n      window.addEventListener('load', () => {\n        if (autoRunEl.checked) runBtn.click();\n      });\n\n      // Allow toggling stack traces; re-show details if one selected\n      showStackEl.addEventListener('change', () => {\n        // if a test was selected, re-render its details (we can't tell which is selected in current simple UI)\n        if (lastResults.length > 0) {\n          // find first failed or first test\n          const r = lastResults.find(r => r.status === 'fail') || lastResults[0];\n          if (r) showDetails(r);\n        }\n      });\n\n      // Expose helper to console for interactive experimentation\n      window.__tinyTestRunner = {\n        runAllTests: async () => {\n          return await runAllTests();\n        },\n        collectTests,\n        rootSuites,\n      };\n\n      // Initial render (no results)\n      renderResults([], 0);\n\n    })();\n  </script>\n</body>\n</html>"
