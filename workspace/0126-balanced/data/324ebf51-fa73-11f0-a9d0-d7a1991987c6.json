    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Mutex Demonstration</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #log {\n            margin-top: 20px;\n            border: 1px solid #ccc;\n            padding: 10px;\n            height: 200px;\n            overflow-y: scroll;\n        }\n        #status {\n            margin-top: 10px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Mutex Demonstration</h1>\n    <button id=\"start\">Start Mutex Operations</button>\n    <div id=\"status\"></div>\n    <div id=\"log\"></div>\n\n    <script>\n        class Mutex {\n            constructor() {\n                this.queue = [];\n                this.locked = false;\n            }\n\n            async acquire() {\n                if (this.locked) {\n                    await new Promise(resolve => this.queue.push(resolve));\n                }\n                this.locked = true;\n            }\n\n            release() {\n                if (this.queue.length > 0) {\n                    const next = this.queue.shift();\n                    next();\n                } else {\n                    this.locked = false;\n                }\n            }\n        }\n\n        const mutex = new Mutex();\n        const log = document.getElementById('log');\n        const statusDiv = document.getElementById('status');\n\n        function logMessage(message) {\n            log.innerHTML += `<div>${message}</div>`;\n            log.scrollTop = log.scrollHeight; // Auto-scroll to the bottom\n        }\n\n        async function criticalSection(id) {\n            await mutex.acquire(); // Acquire the mutex\n            logMessage(`Thread ${id} has entered the critical section.`);\n            statusDiv.textContent = `Thread ${id} is working...`;\n\n            // Simulate some work\n            await new Promise(resolve => setTimeout(resolve, 2000));\n\n            logMessage(`Thread ${id} is leaving the critical section.`);\n            statusDiv.textContent = `Thread ${id} has finished.`;\n            mutex.release(); // Release the mutex\n        }\n\n        function startMutexOperation() {\n            for (let i = 1; i <= 5; i++) {\n                setTimeout(() => criticalSection(i), i * 500); // Stagger the calls\n            }\n        }\n\n        document.getElementById('start').addEventListener('click', startMutexOperation);\n\n    </script>\n</body>\n</html>"
