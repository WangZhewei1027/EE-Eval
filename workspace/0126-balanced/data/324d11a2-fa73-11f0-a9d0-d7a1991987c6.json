    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Trie Data Structure Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 20px;\n        }\n        input {\n            padding: 10px;\n            margin-top: 10px;\n            width: 300px;\n        }\n        button {\n            padding: 10px;\n            margin-left: 10px;\n        }\n        #output {\n            margin-top: 20px;\n            white-space: pre-wrap;\n        }\n    </style>\n</head>\n<body>\n    <h1>Trie Data Structure Demo</h1>\n    <input type=\"text\" id=\"wordInput\" placeholder=\"Enter a word\" />\n    <button onclick=\"insertWord()\">Insert Word</button>\n    <button onclick=\"searchWord()\">Search Word</button>\n    <button onclick=\"displayTrie()\">Display Trie</button>\n    <div id=\"output\"></div>\n\n    <script>\n        class TrieNode {\n            constructor() {\n                this.children = {};\n                this.isEndOfWord = false;\n            }\n        }\n\n        class Trie {\n            constructor() {\n                this.root = new TrieNode();\n            }\n\n            insert(word) {\n                let node = this.root;\n                for (let char of word) {\n                    if (!node.children[char]) {\n                        node.children[char] = new TrieNode();\n                    }\n                    node = node.children[char];\n                }\n                node.isEndOfWord = true;\n            }\n\n            search(word) {\n                let node = this.root;\n                for (let char of word) {\n                    if (!node.children[char]) {\n                        return false;\n                    }\n                    node = node.children[char];\n                }\n                return node.isEndOfWord;\n            }\n\n            display(node = this.root, prefix = '') {\n                let result = '';\n                if (node.isEndOfWord) {\n                    result += prefix + '\\n';\n                }\n                for (let char in node.children) {\n                    result += this.display(node.children[char], prefix + char);\n                }\n                return result;\n            }\n        }\n\n        const trie = new Trie();\n\n        function insertWord() {\n            const input = document.getElementById('wordInput').value;\n            trie.insert(input);\n            document.getElementById('wordInput').value = '';\n            document.getElementById('output').innerText = `Inserted: ${input}`;\n        }\n\n        function searchWord() {\n            const input = document.getElementById('wordInput').value;\n            const found = trie.search(input);\n            document.getElementById('output').innerText = `Search \"${input}\": ${found ? \"Found\" : \"Not Found\"}`;\n        }\n\n        function displayTrie() {\n            const trieStructure = trie.display();\n            document.getElementById('output').innerText = `Trie Structure:\\n${trieStructure}`;\n        }\n    </script>\n</body>\n</html>"
