    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Max Heap Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-top: 50px;\n        }\n        #heap {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin-bottom: 20px;\n        }\n        .node {\n            width: 40px;\n            height: 40px;\n            border: 2px solid #007bff;\n            border-radius: 50%;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            margin: 5px;\n            position: relative;\n        }\n        .line {\n            width: 2px;\n            height: 30px;\n            background-color: #007bff;\n            position: absolute;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Max Heap Visualization</h1>\n<div id=\"heap\"></div>\n\n<input type=\"number\" id=\"value\" placeholder=\"Enter a number\" />\n<button onclick=\"insert()\">Insert</button>\n\n<script>\n    class MaxHeap {\n        constructor() {\n            this.heap = [];\n        }\n\n        insert(value) {\n            this.heap.push(value);\n            this.bubbleUp();\n            this.drawHeap();\n        }\n\n        bubbleUp() {\n            let index = this.heap.length - 1;\n            const element = this.heap[index];\n\n            while (index > 0) {\n                const parentIndex = Math.floor((index - 1) / 2);\n                const parent = this.heap[parentIndex];\n\n                if (element <= parent) break;\n\n                this.heap[index] = parent;\n                index = parentIndex;\n            }\n            this.heap[index] = element;\n        }\n\n        drawHeap() {\n            const heapDiv = document.getElementById('heap');\n            heapDiv.innerHTML = '';\n            this.drawLevel(heapDiv, 0, 0);\n        }\n\n        drawLevel(parent, level, index) {\n            if (index >= this.heap.length) return;\n\n            if (level === 0) {\n                const node = this.createNode(this.heap[index]);\n                parent.appendChild(node);\n            } else {\n                const levelDiv = document.createElement('div');\n                const leftIndex = 2 * index + 1;\n                const rightIndex = 2 * index + 2;\n\n                levelDiv.appendChild(this.createNode(this.heap[index]));\n\n                if (leftIndex < this.heap.length) {\n                    const leftNode = this.createNode(this.heap[leftIndex]);\n                    levelDiv.appendChild(this.createLine());\n                    levelDiv.appendChild(leftNode);\n                }\n\n                if (rightIndex < this.heap.length) {\n                    const rightNode = this.createNode(this.heap[rightIndex]);\n                    levelDiv.appendChild(this.createLine());\n                    levelDiv.appendChild(rightNode);\n                }\n\n                parent.appendChild(levelDiv);\n            }\n\n            this.drawLevel(parent, level + 1, 2 * index + 1);\n            this.drawLevel(parent, level + 1, 2 * index + 2);\n        }\n\n        createNode(value) {\n            const node = document.createElement('div');\n            node.classList.add('node');\n            node.innerText = value;\n            return node;\n        }\n\n        createLine() {\n            const line = document.createElement('div');\n            line.classList.add('line');\n            return line;\n        }\n    }\n\n    const maxHeap = new MaxHeap();\n\n    function insert() {\n        const input = document.getElementById('value');\n        const value = parseInt(input.value);\n\n        if (!isNaN(value)) {\n            maxHeap.insert(value);\n            input.value = '';\n        }\n    }\n</script>\n\n</body>\n</html>"
