    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>PageRank Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root {\n      --bg: #0f1724;\n      --panel: #0b1220;\n      --accent: #4fd1c5;\n      --muted: #9aa8c7;\n      --card: #0f172b;\n      --glass: rgba(255,255,255,0.02);\n    }\n    html,body { height:100%; margin:0; font-family: Inter, Roboto, system-ui, -apple-system, \"Segoe UI\", \"Helvetica Neue\", Arial; background: linear-gradient(180deg,#07101a 0%, #081425 100%); color:#cfe8f2; }\n    .app {\n      display:flex;\n      height:100vh;\n      gap:12px;\n      padding:12px;\n      box-sizing:border-box;\n    }\n    .panel {\n      width:360px;\n      min-width:260px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.03);\n      border-radius:12px;\n      padding:14px;\n      box-sizing:border-box;\n      display:flex;\n      flex-direction:column;\n      gap:12px;\n      backdrop-filter: blur(6px);\n    }\n    h1 { margin:0; font-size:18px; color:#e6f6fb; }\n    p.lead { margin:0; color:var(--muted); font-size:13px; line-height:1.4; }\n    .controls { display:flex; flex-direction:column; gap:10px; }\n    .row { display:flex; gap:8px; align-items:center; }\n    .btn {\n      background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border:1px solid rgba(255,255,255,0.04);\n      padding:8px 10px;\n      color:#dff8f3;\n      border-radius:8px;\n      cursor:pointer;\n      font-size:13px;\n      flex-shrink:0;\n    }\n    .btn.warn { border-color: #ff6b6b; color:#ffd7d7; }\n    .btn.ghost { background:transparent; border-style:dashed; color:var(--muted); }\n    label { font-size:13px; color:var(--muted); display:flex; gap:8px; align-items:center; }\n    input[type=range] { width:160px; }\n    .small { font-size:12px; color:var(--muted); }\n    .status { font-size:13px; color:#cbeef3; background:rgba(255,255,255,0.02); padding:8px; border-radius:8px; border:1px solid rgba(255,255,255,0.02); }\n    .canvas-wrap {\n      flex:1;\n      position:relative;\n      border-radius:12px;\n      overflow:hidden;\n      border:1px solid rgba(255,255,255,0.02);\n      background: radial-gradient(ellipse at 30% 10%, rgba(79,209,197,0.03), transparent 10%), linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));\n    }\n    svg { width:100%; height:100%; display:block; }\n    .legend { display:flex; gap:8px; align-items:center; font-size:12px; color:var(--muted); }\n    .muted { color:var(--muted); font-size:12px; }\n    .mode { display:flex; gap:6px; flex-wrap:wrap; }\n    .mode .btn { padding:6px 8px; font-size:12px; }\n    .info { font-size:13px; color:var(--muted); line-height:1.4; }\n    .matrix {\n      max-height:180px;\n      overflow:auto;\n      background:var(--glass);\n      padding:8px;\n      border-radius:8px;\n      border:1px solid rgba(255,255,255,0.02);\n      color:#cfe8f2;\n      font-size:12px;\n    }\n    table { border-collapse:collapse; width:100%; }\n    th, td { padding:6px 8px; text-align:left; border-bottom:1px dashed rgba(255,255,255,0.02); font-family:monospace; font-size:12px; color:var(--muted); }\n    .rank-bar { height:8px; border-radius:6px; background:linear-gradient(90deg,#2dd4bf,#06b6d4); }\n    .node-label { pointer-events:none; font-size:12px; fill:#031722; font-weight:600; }\n    .small-muted { font-size:12px; color:var(--muted); }\n    .footer { font-size:12px; color:var(--muted); margin-top:auto; }\n    .flex-between { display:flex; justify-content:space-between; align-items:center; gap:8px; }\n    .hint { font-size:12px; color:#9fbfca; }\n    .controls-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <div class=\"panel\">\n      <div>\n        <h1>PageRank — Interactive Demo</h1>\n        <p class=\"lead\">Explore how PageRank distributes importance in a directed graph. Add nodes and links, then run iterations to see ranks converge. Try different damping factors and observe dangling nodes.</p>\n      </div>\n\n      <div class=\"controls\">\n        <div class=\"row flex-between\">\n          <div class=\"mode\">\n            <button id=\"mode-drag\" class=\"btn\">Drag</button>\n            <button id=\"mode-edge\" class=\"btn\">Add Edge</button>\n            <button id=\"mode-delete\" class=\"btn ghost\">Delete</button>\n          </div>\n          <div class=\"small muted\">Mode</div>\n        </div>\n\n        <div class=\"row\">\n          <button id=\"add-node\" class=\"btn\">Add Node</button>\n          <button id=\"random-graph\" class=\"btn\">Random Graph</button>\n          <button id=\"reset-graph\" class=\"btn ghost\">Reset</button>\n        </div>\n\n        <div class=\"row\">\n          <button id=\"step\" class=\"btn\">Step</button>\n          <button id=\"run\" class=\"btn\">Run</button>\n          <button id=\"pause\" class=\"btn ghost\">Pause</button>\n          <button id=\"stop\" class=\"btn warn\">Stop</button>\n        </div>\n\n        <div class=\"row\">\n          <label class=\"small-muted\">Damping\n            <input id=\"damping\" type=\"range\" min=\"0\" max=\"99\" value=\"85\" />\n          </label>\n          <div id=\"damping-val\" class=\"small-muted\">0.85</div>\n        </div>\n\n        <div class=\"row\">\n          <label class=\"small-muted\">Speed\n            <input id=\"speed\" type=\"range\" min=\"10\" max=\"1000\" value=\"200\" />\n          </label>\n          <div id=\"speed-val\" class=\"small-muted\">200 ms</div>\n        </div>\n\n        <div class=\"row\">\n          <div class=\"status\" id=\"status\">Iteration: 0 · L1 change: 0.000</div>\n        </div>\n\n        <div class=\"row\">\n          <div class=\"info\">\n            How it works (brief): PageRank assigns every node a score. Each iteration:\n            PR(i) = (1 - d)/N + d * sum(PR(j)/outdeg(j)) over all j linking to i.\n            Dangling nodes (no outlinks) distribute their rank equally to all nodes.\n          </div>\n        </div>\n\n        <div class=\"row\">\n          <div class=\"small-muted\">Adjacency & ranks</div>\n        </div>\n\n        <div class=\"matrix\" id=\"matrix\"></div>\n\n        <div class=\"footer\">\n          Tip: Select \"Add Edge\" then click a source node and a target node to create a directed link. Click nodes to delete in \"Delete\" mode.\n        </div>\n      </div>\n    </div>\n\n    <div class=\"canvas-wrap\" id=\"canvas-wrap\">\n      <svg id=\"svg\" viewBox=\"0 0 1200 800\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n          <marker id=\"arrow\" viewBox=\"0 -5 10 10\" refX=\"14\" refY=\"0\" markerWidth=\"7\" markerHeight=\"7\" orient=\"auto\" fill=\"#9fd8de\">\n            <path d=\"M0,-5L10,0L0,5\"></path>\n          </marker>\n          <filter id=\"glow\">\n            <feGaussianBlur stdDeviation=\"2.8\" result=\"coloredBlur\"/>\n            <feMerge>\n              <feMergeNode in=\"coloredBlur\"/>\n              <feMergeNode in=\"SourceGraphic\"/>\n            </feMerge>\n          </filter>\n        </defs>\n\n        <g id=\"edges\"></g>\n        <g id=\"nodes\"></g>\n      </svg>\n    </div>\n  </div>\n\n<script>\n/*\n PageRank Interactive Demo\n - Single file, no external libs\n - Directed graph with simple force layout + drag\n - PageRank iterative solver with damping & dangling handling\n*/\n\n// Utilities\nconst clamp = (v,a,b)=>Math.max(a,Math.min(b,v));\nconst rand = (a,b)=>a + Math.random()*(b-a);\nconst svg = document.getElementById('svg');\nconst edgesG = document.getElementById('edges');\nconst nodesG = document.getElementById('nodes');\nconst matrixEl = document.getElementById('matrix');\nconst statusEl = document.getElementById('status');\n\nlet width = 1200, height = 800;\nsvg.setAttribute('viewBox', `0 0 ${width} ${height}`);\n\n// Graph model\nlet nodes = [];\nlet edges = []; // {from: id, to: id}\nlet nextId = 1;\n\n// PageRank state\nlet damping = 0.85;\nlet iter = 0;\nlet running = false;\nlet runTimer = null;\nlet speed = 200; // ms\nlet lastL1 = 0;\nlet mode = 'drag'; // drag | edge | delete\nlet edgePendingSource = null;\n\n// Initialize with a small example graph\nfunction initExample() {\n  nodes = [];\n  edges = [];\n  nextId = 1;\n  // Create 5 nodes\n  for (let i=0;i<5;i++){\n    addNodeAt(width*0.25 + Math.cos(i/5*Math.PI*2)*160 + rand(-20,20),\n              height*0.5 + Math.sin(i/5*Math.PI*2)*160 + rand(-20,20));\n  }\n  // some directed links\n  addEdge(1,2); addEdge(1,3); addEdge(2,3); addEdge(3,1); addEdge(4,3); addEdge(5,3);\n  // Node 4 has no outgoing links (dangling)\n  resetRanks();\n  render();\n  updateMatrix();\n  iter = 0;\n  updateStatus();\n}\n\nfunction addNodeAt(x,y){\n  const id = nextId++;\n  nodes.push({\n    id,\n    x:x ?? rand(200,width-200),\n    y:y ?? rand(120,height-120),\n    vx:0, vy:0,\n    rank: 1, // will normalize later\n  });\n  return id;\n}\n\nfunction findNode(id){ return nodes.find(n=>n.id===id); }\n\nfunction addEdge(from,to){\n  if (from===to) return;\n  if (!findNode(from) || !findNode(to)) return;\n  if (edges.some(e=>e.from===from && e.to===to)) return;\n  edges.push({from,to});\n}\n\nfunction removeNode(id){\n  nodes = nodes.filter(n=>n.id!==id);\n  edges = edges.filter(e=>e.from!==id && e.to!==id);\n}\n\nfunction removeEdge(from,to){\n  edges = edges.filter(e=> !(e.from===from && e.to===to));\n}\n\nfunction resetRanks(){\n  const N = nodes.length || 1;\n  nodes.forEach(n=> n.rank = 1/N );\n}\n\nfunction normalizeRanks(){\n  const sum = nodes.reduce((s,n)=>s + n.rank, 0) || 1;\n  nodes.forEach(n=> n.rank /= sum);\n}\n\n// PageRank step: compute one iteration\nfunction pageRankStep(){\n  if (nodes.length===0) return {delta:0};\n  const N = nodes.length;\n  const d = damping;\n  const idToIndex = new Map(nodes.map((n,i)=>[n.id,i]));\n  const outdeg = new Array(N).fill(0);\n  for (const e of edges){\n    const i = idToIndex.get(e.from);\n    if (i!==undefined) outdeg[i]++;\n  }\n  // dangling sum\n  let danglingSum = 0;\n  for (let i=0;i<N;i++) if (outdeg[i]===0) danglingSum += nodes[i].rank;\n\n  const newRanks = new Array(N).fill((1-d)/N + d * (danglingSum / N));\n  // add contributions\n  for (const e of edges){\n    const fromIdx = idToIndex.get(e.from);\n    const toIdx = idToIndex.get(e.to);\n    if (fromIdx===undefined || toIdx===undefined) continue;\n    if (outdeg[fromIdx] === 0) continue;\n    newRanks[toIdx] += d * nodes[fromIdx].rank / outdeg[fromIdx];\n  }\n\n  // compute L1 change\n  let l1 = 0;\n  for (let i=0;i<N;i++){\n    l1 += Math.abs(newRanks[i] - nodes[i].rank);\n    nodes[i].rank = newRanks[i];\n  }\n  normalizeRanks();\n  iter++;\n  updateStatus(l1);\n  updateMatrix();\n  return {delta: l1};\n}\n\n// UI & rendering\nfunction render(){\n  // edges\n  edgesG.innerHTML = '';\n  // create arrows for directed edges; compute positions\n  for (const e of edges){\n    const a = findNode(e.from);\n    const b = findNode(e.to);\n    if (!a || !b) continue;\n    // line from a to b with arrow\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n    // compute offset so arrows don't overlap node circles\n    const dx = b.x - a.x, dy = b.y - a.y;\n    const dist = Math.hypot(dx,dy) || 1;\n    const rFrom = 18;\n    const rTo = 18 + 2*Math.log(1 + (b.rank*100));\n    const sx = a.x + (dx/dist)*rFrom;\n    const sy = a.y + (dy/dist)*rFrom;\n    const ex = b.x - (dx/dist)*rTo;\n    const ey = b.y - (dy/dist)*rTo;\n    // Use a slight curve when nodes are not colinear\n    const mx = (sx + ex)/2 + (dy/dist)*10;\n    const my = (sy + ey)/2 - (dx/dist)*10;\n    const dAttr = `M ${sx.toFixed(2)} ${sy.toFixed(2)} Q ${mx.toFixed(2)} ${my.toFixed(2)} ${ex.toFixed(2)} ${ey.toFixed(2)}`;\n    path.setAttribute('d', dAttr);\n    path.setAttribute('stroke', '#7fd8de');\n    path.setAttribute('stroke-width', '1.5');\n    path.setAttribute('fill', 'none');\n    path.setAttribute('marker-end','url(#arrow)');\n    path.setAttribute('opacity','0.9');\n    edgesG.appendChild(path);\n  }\n\n  // nodes\n  nodesG.innerHTML = '';\n  // Sort descending by rank to draw bigger first\n  const nodesToDraw = [...nodes].sort((a,b)=>b.rank - a.rank);\n  for (const n of nodesToDraw){\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    g.setAttribute('transform', `translate(${n.x},${n.y})`);\n    g.classList.add('node');\n    g.dataset.id = n.id;\n\n    // circle with size proportional to rank\n    const baseR = 18;\n    const r = baseR + Math.log(1 + n.rank*100)*4;\n    const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n    circle.setAttribute('r', r);\n    // color map: small to large\n    const t = clamp((n.rank - 0)/(0.5 - 0), 0, 1);\n    const color = `rgba(${Math.floor(20 + 200*t)}, ${Math.floor(200 - 30*t)}, ${Math.floor(200 - 60*t)}, 0.95)`;\n    circle.setAttribute('fill', color);\n    circle.setAttribute('stroke', 'rgba(255,255,255,0.06)');\n    circle.setAttribute('stroke-width', '1');\n    circle.style.filter = 'url(#glow)';\n    g.appendChild(circle);\n\n    // rank text\n    const label = document.createElementNS('http://www.w3.org/2000/svg','text');\n    label.setAttribute('y', '4');\n    label.setAttribute('text-anchor','middle');\n    label.setAttribute('class','node-label');\n    label.textContent = `${n.id} (${n.rank.toFixed(3)})`;\n    g.appendChild(label);\n\n    // bar below node to visualize rank\n    const barWidth = 60;\n    const bar = document.createElementNS('http://www.w3.org/2000/svg','rect');\n    bar.setAttribute('x', -barWidth/2);\n    bar.setAttribute('y', r + 8);\n    bar.setAttribute('width', barWidth);\n    bar.setAttribute('height', 8);\n    bar.setAttribute('rx', 4);\n    bar.setAttribute('fill', 'rgba(255,255,255,0.04)');\n    g.appendChild(bar);\n    const fill = document.createElementNS('http://www.w3.org/2000/svg','rect');\n    fill.setAttribute('x', -barWidth/2 + 2);\n    fill.setAttribute('y', r + 10);\n    fill.setAttribute('height', 4);\n    fill.setAttribute('rx', 2);\n    const fillW = Math.max(4, Math.round((barWidth-4)*n.rank));\n    fill.setAttribute('width', fillW);\n    fill.setAttribute('fill', '#2dd4bf');\n    g.appendChild(fill);\n\n    nodesG.appendChild(g);\n\n    // add drag and click listeners\n    g.addEventListener('mousedown', nodeMouseDown(n));\n    g.addEventListener('touchstart', nodeTouchStart(n), {passive:false});\n  }\n}\n\n// interaction state for dragging\nlet dragging = null;\nlet dragOffset = {x:0,y:0};\n\nfunction nodeMouseDown(n){\n  return function(e){\n    e.preventDefault();\n    if (mode === 'edge') {\n      if (!edgePendingSource) {\n        edgePendingSource = n.id;\n        statusEl.textContent = `Selected source: ${n.id}. Click target to add edge.`;\n      } else {\n        if (edgePendingSource === n.id) {\n          // cancel\n          edgePendingSource = null;\n          updateStatus();\n        } else {\n          addEdge(edgePendingSource, n.id);\n          edgePendingSource = null;\n          render();\n          updateMatrix();\n          updateStatus();\n        }\n      }\n      return;\n    }\n    if (mode === 'delete') {\n      // delete this node\n      removeNode(n.id);\n      render();\n      updateMatrix();\n      return;\n    }\n    // drag mode\n    dragging = n;\n    const pt = getMousePos(e);\n    dragOffset.x = n.x - pt.x;\n    dragOffset.y = n.y - pt.y;\n    window.addEventListener('mousemove', onMouseMove);\n    window.addEventListener('mouseup', onMouseUp);\n  };\n}\n\nfunction nodeTouchStart(n){\n  return function(e){\n    e.preventDefault();\n    if (mode === 'edge') {\n      if (!edgePendingSource) {\n        edgePendingSource = n.id;\n        statusEl.textContent = `Selected source: ${n.id}. Tap target to add edge.`;\n      } else {\n        if (edgePendingSource === n.id) {\n          edgePendingSource = null;\n          updateStatus();\n        } else {\n          addEdge(edgePendingSource, n.id);\n          edgePendingSource = null;\n          render();\n          updateMatrix();\n          updateStatus();\n        }\n      }\n      return;\n    }\n    if (mode === 'delete') {\n      removeNode(n.id);\n      render();\n      updateMatrix();\n      return;\n    }\n    dragging = n;\n    const touch = e.touches[0];\n    const pt = getTouchPos(touch);\n    dragOffset.x = n.x - pt.x;\n    dragOffset.y = n.y - pt.y;\n    window.addEventListener('touchmove', onTouchMove, {passive:false});\n    window.addEventListener('touchend', onTouchEnd);\n  };\n}\n\nfunction onMouseMove(e){\n  if (!dragging) return;\n  const pt = getMousePos(e);\n  dragging.x = clamp(pt.x + dragOffset.x, 40, width-40);\n  dragging.y = clamp(pt.y + dragOffset.y, 40, height-40);\n  render();\n}\n\nfunction onMouseUp(){\n  dragging = null;\n  window.removeEventListener('mousemove', onMouseMove);\n  window.removeEventListener('mouseup', onMouseUp);\n}\n\nfunction onTouchMove(e){\n  if (!dragging) return;\n  const touch = e.touches[0];\n  const pt = getTouchPos(touch);\n  dragging.x = clamp(pt.x + dragOffset.x, 40, width-40);\n  dragging.y = clamp(pt.y + dragOffset.y, 40, height-40);\n  render();\n}\n\nfunction onTouchEnd(){\n  dragging = null;\n  window.removeEventListener('touchmove', onTouchMove);\n  window.removeEventListener('touchend', onTouchEnd);\n}\n\nfunction getMousePos(e){\n  const rect = svg.getBoundingClientRect();\n  const x = (e.clientX - rect.left) * (width / rect.width);\n  const y = (e.clientY - rect.top) * (height / rect.height);\n  return {x,y};\n}\nfunction getTouchPos(touch){\n  const rect = svg.getBoundingClientRect();\n  const x = (touch.clientX - rect.left) * (width / rect.width);\n  const y = (touch.clientY - rect.top) * (height / rect.height);\n  return {x,y};\n}\n\n// background click to add node quickly when in drag mode\nsvg.addEventListener('dblclick', (e)=>{\n  const pt = getMousePos(e);\n  addNodeAt(pt.x, pt.y);\n  resetRanks();\n  render();\n  updateMatrix();\n});\n\n// Controls\ndocument.getElementById('add-node').addEventListener('click', ()=>{\n  addNodeAt(rand(150,width-150), rand(120,height-120));\n  resetRanks();\n  render();\n  updateMatrix();\n});\n\ndocument.getElementById('random-graph').addEventListener('click', ()=>{\n  // generate N nodes and random directed edges\n  const N = Math.floor(rand(4,9));\n  nodes = [];\n  edges = [];\n  nextId = 1;\n  for (let i=0;i<N;i++){\n    addNodeAt(rand(120,width-120), rand(120,height-120));\n  }\n  for (let i=0;i<N;i++){\n    for (let j=0;j<N;j++){\n      if (i===j) continue;\n      if (Math.random() < 0.28) addEdge(nodes[i].id, nodes[j].id);\n    }\n  }\n  resetRanks();\n  iter = 0;\n  render();\n  updateMatrix();\n  updateStatus();\n});\n\ndocument.getElementById('reset-graph').addEventListener('click', ()=>{\n  initExample();\n});\n\ndocument.getElementById('mode-drag').addEventListener('click', ()=>{\n  setMode('drag');\n});\ndocument.getElementById('mode-edge').addEventListener('click', ()=>{\n  setMode('edge');\n});\ndocument.getElementById('mode-delete').addEventListener('click', ()=>{\n  setMode('delete');\n});\n\nfunction setMode(m){\n  mode = m;\n  document.querySelectorAll('.mode .btn').forEach(b=> b.classList.remove('active'));\n  if (m==='drag') document.getElementById('mode-drag').classList.add('active');\n  if (m==='edge') document.getElementById('mode-edge').classList.add('active');\n  if (m==='delete') document.getElementById('mode-delete').classList.add('active');\n  edgePendingSource = null;\n  updateStatus();\n}\n\n// step/run controls\ndocument.getElementById('step').addEventListener('click', ()=>{\n  pageRankStep();\n  render();\n});\n\ndocument.getElementById('run').addEventListener('click', ()=>{\n  if (running) return;\n  running = true;\n  runLoop();\n});\n\ndocument.getElementById('pause').addEventListener('click', ()=>{\n  running = false;\n  if (runTimer) { clearTimeout(runTimer); runTimer = null; }\n});\n\ndocument.getElementById('stop').addEventListener('click', ()=>{\n  running = false;\n  if (runTimer) { clearTimeout(runTimer); runTimer = null; }\n  iter = 0;\n  resetRanks();\n  render();\n  updateMatrix();\n  updateStatus();\n});\n\ndocument.getElementById('damping').addEventListener('input', (e)=>{\n  const v = +e.target.value;\n  damping = v/100;\n  document.getElementById('damping-val').textContent = damping.toFixed(2);\n});\n\ndocument.getElementById('speed').addEventListener('input', (e)=>{\n  speed = +e.target.value;\n  document.getElementById('speed-val').textContent = `${speed} ms`;\n});\n\nfunction runLoop(){\n  if (!running) return;\n  const res = pageRankStep();\n  render();\n  // stop when converged small change\n  if (res.delta < 1e-6) {\n    running = false;\n    updateStatus();\n    return;\n  }\n  runTimer = setTimeout(runLoop, speed);\n}\n\n// Status and matrix UI\nfunction updateStatus(l1){\n  l1 = l1 ?? lastL1;\n  lastL1 = l1 ?? lastL1;\n  statusEl.textContent = `Iteration: ${iter} · L1 change: ${ (l1||0).toFixed(6) } · Nodes: ${nodes.length} · Edges: ${edges.length}`;\n}\n\nfunction updateMatrix(){\n  // adjacency matrix and rank list\n  const idList = nodes.map(n=>n.id);\n  let html = '';\n  html += `<div style=\"margin-bottom:8px\"><strong>Ranks</strong></div>`;\n  const sorted = [...nodes].sort((a,b)=>b.rank - a.rank);\n  for (const n of sorted){\n    html += `<div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:6px\">\n      <div style=\"width:50%\">${n.id}</div>\n      <div style=\"width:40%;text-align:right\">${n.rank.toFixed(6)}</div>\n    </div>`;\n  }\n  html += `<hr style=\"border:none;border-top:1px dashed rgba(255,255,255,0.03);margin:8px 0\">`;\n  html += `<div style=\"margin-bottom:6px\"><strong>Adjacency (rows = from →, cols = to)</strong></div>`;\n  // header\n  html += '<div style=\"overflow:auto\"><table><thead><tr><th></th>';\n  for (const id of idList) html += `<th>${id}</th>`;\n  html += '</tr></thead><tbody>';\n  for (const from of idList){\n    html += `<tr><th>${from}</th>`;\n    for (const to of idList){\n      const present = edges.some(e=>e.from===from && e.to===to);\n      html += `<td style=\"color:${present ? '#8ef0ec' : 'rgba(255,255,255,0.06)'}\">${present ? '1' : '0'}</td>`;\n    }\n    html += '</tr>';\n  }\n  html += '</tbody></table></div>';\n  matrixEl.innerHTML = html;\n}\n\n// Simple force-like relaxation to keep layout pretty (runs continuously)\nlet lastTick = performance.now();\nfunction layoutTick(now){\n  const dt = Math.min(0.03, (now - lastTick)/1000);\n  lastTick = now;\n  // simple repulsion + spring edges\n  for (let i=0;i<nodes.length;i++){\n    let fx=0, fy=0;\n    for (let j=0;j<nodes.length;j++){\n      if (i===j) continue;\n      const a = nodes[i], b = nodes[j];\n      let dx = a.x - b.x, dy = a.y - b.y;\n      let dist2 = dx*dx + dy*dy + 0.01;\n      const minDist = 60;\n      if (dist2 < (minDist*minDist)){\n        const dist = Math.sqrt(dist2);\n        const push = (minDist - dist) * 0.08;\n        fx += (dx/dist) * push;\n        fy += (dy/dist) * push;\n      }\n    }\n    // spring toward center\n    const toCenterX = (width/2 - nodes[i].x) * 0.002;\n    const toCenterY = (height/2 - nodes[i].y) * 0.002;\n    nodes[i].vx = (nodes[i].vx + (fx + toCenterX)) * 0.92;\n    nodes[i].vy = (nodes[i].vy + (fy + toCenterY)) * 0.92;\n  }\n  // attract along edges\n  for (const e of edges){\n    const a = findNode(e.from), b = findNode(e.to);\n    if (!a || !b) continue;\n    const dx = b.x - a.x, dy = b.y - a.y;\n    const dist = Math.hypot(dx,dy) || 1;\n    const target = 160;\n    const diff = (dist - target) * 0.0008;\n    const ax = dx/dist * diff;\n    const ay = dy/dist * diff;\n    a.vx += ax;\n    a.vy += ay;\n    b.vx -= ax;\n    b.vy -= ay;\n  }\n  // integrate\n  for (const n of nodes){\n    if (dragging === n) continue; // do not move while dragging\n    n.x += n.vx;\n    n.y += n.vy;\n    // bounds\n    n.x = clamp(n.x, 30, width-30);\n    n.y = clamp(n.y, 30, height-30);\n  }\n  render();\n  requestAnimationFrame(layoutTick);\n}\n\n// Keyboard shortcuts\nwindow.addEventListener('keydown', (e)=>{\n  if (e.key === ' ') {\n    // toggle run/pause\n    if (running) {\n      running = false;\n    } else {\n      running = true; runLoop();\n    }\n  } else if (e.key === 'r') {\n    initExample();\n  }\n});\n\n// initial setup\nsetMode('drag');\ninitExample();\nrequestAnimationFrame(layoutTick);\n\n// responsiveness: resize svg viewbox if container changes\nnew ResizeObserver(()=> {\n  // no-op: viewBox fixed; we could adapt but keep it constant for simplicity\n}).observe(document.getElementById('canvas-wrap'));\n\n</script>\n</body>\n</html>"
