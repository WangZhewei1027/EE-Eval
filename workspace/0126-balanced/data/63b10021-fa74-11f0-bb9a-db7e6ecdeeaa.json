    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Insertion Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f0f0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    margin-bottom: 5px;\n  }\n  #container {\n    margin-top: 30px;\n    display: flex;\n    align-items: flex-end;\n    height: 300px;\n    width: 80vw;\n    max-width: 900px;\n    border: 1px solid #ccc;\n    background: white;\n    position: relative;\n  }\n  .bar {\n    margin: 0 2px;\n    background-color: #4a90e2;\n    width: 20px;\n    transition: background-color 0.3s;\n    position: relative;\n  }\n  .bar.current {\n    background-color: #e76f51;\n  }\n  .bar.compared {\n    background-color: #f4a261;\n  }\n  .bar.sorted {\n    background-color: #2a9d8f;\n  }\n  #controls {\n    margin-top: 20px;\n  }\n  button {\n    font-size: 16px;\n    margin-right: 10px;\n    padding: 8px 15px;\n    cursor: pointer;\n  }\n  #info {\n    max-width: 800px;\n    margin-top: 20px;\n    font-size: 18px;\n  }\n</style>\n</head>\n<body>\n<h1>Insertion Sort Visualization</h1>\n<div id=\"container\"></div>\n<div id=\"controls\">\n  <button id=\"newArrayBtn\">Generate New Array</button>\n  <button id=\"startBtn\">Start Sort</button>\n  <button id=\"stepBtn\" disabled>Step</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n  <label>\n    Speed:\n    <input type=\"range\" id=\"speedRange\" min=\"50\" max=\"1000\" value=\"300\" />\n  </label>\n</div>\n<div id=\"info\">\n  <p><strong>Insertion Sort Algorithm:</strong> It builds the final sorted array one element at a time by comparing the current element to its predecessors and inserting it into the correct position.</p>\n  <p>Red bar = Current element being inserted<br />\n  Orange bar = Element being compared<br />\n  Teal bars = Sorted portion</p>\n</div>\n\n<script>\n(() => {\n  const container = document.getElementById('container');\n  const newArrayBtn = document.getElementById('newArrayBtn');\n  const startBtn = document.getElementById('startBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const speedRange = document.getElementById('speedRange');\n\n  const NUM_BARS = 30;\n  const MAX_VALUE = 100;\n  let array = [];\n  let bars = [];\n\n  let i = 1;\n  let j = i;\n  let key = null;\n  let sorting = false;\n  let intervalId = null;\n  let speed = 300;\n\n  function generateArray() {\n    array = [];\n    for (let k = 0; k < NUM_BARS; k++) {\n      array.push(Math.floor(Math.random() * MAX_VALUE) + 1);\n    }\n    i = 1;\n    j = i;\n    key = null;\n    sorting = false;\n    clearInterval(intervalId);\n    intervalId = null;\n    startBtn.disabled = false;\n    stepBtn.disabled = true;\n    resetBtn.disabled = true;\n    renderArray();\n  }\n\n  function renderArray(highlightIndices = {}, sortedUpto = 0) {\n    container.innerHTML = '';\n    bars = [];\n\n    for(let index = 0; index < array.length; index++) {\n      const bar = document.createElement('div');\n      bar.classList.add('bar');\n      bar.style.height = (array[index] * 3) + 'px';\n      if (index === highlightIndices.current) {\n        bar.classList.add('current');\n      } else if (index === highlightIndices.compared) {\n        bar.classList.add('compared');\n      } else if (index < sortedUpto) {\n        bar.classList.add('sorted');\n      }\n      bars.push(bar);\n      container.appendChild(bar);\n    }\n  }\n\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  async function insertionSortAuto() {\n    sorting = true;\n    startBtn.disabled = true;\n    stepBtn.disabled = true;\n    resetBtn.disabled = false;\n    newArrayBtn.disabled = true;\n\n    for (let k = 1; k < array.length; k++) {\n      key = array[k];\n      let m = k - 1;\n      renderArray({current: k}, k);\n      await sleep(speed);\n\n      while(m >= 0 && array[m] > key) {\n        renderArray({current: k, compared: m}, k);\n        await sleep(speed);\n        array[m + 1] = array[m];\n        m--;\n        renderArray({current: k, compared: m + 1}, k);\n        await sleep(speed);\n      }\n      array[m+1] = key;\n      renderArray({}, k + 1);\n      await sleep(speed);\n    }\n    renderArray({}, array.length);\n    sorting = false;\n    startBtn.disabled = true;\n    stepBtn.disabled = true;\n    resetBtn.disabled = false;\n    newArrayBtn.disabled = false;\n  }\n\n  function insertionSortStep() {\n    if (i >= array.length) {\n      // Sorting finished\n      renderArray({}, array.length);\n      sorting = false;\n      startBtn.disabled = true;\n      stepBtn.disabled = true;\n      resetBtn.disabled = false;\n      newArrayBtn.disabled = false;\n      return;\n    }\n    if (key === null) {\n      key = array[i];\n      j = i - 1;\n      renderArray({current:i}, i);\n      return;\n    }\n    if (j >= 0 && array[j] > key) {\n      renderArray({current:i, compared:j}, i);\n      array[j+1] = array[j];\n      j--;\n      return;\n    }\n    array[j+1] = key;\n    i++;\n    key = null;\n    renderArray({}, i);\n  }\n\n  newArrayBtn.addEventListener('click', () => {\n    generateArray();\n  });\n\n  startBtn.addEventListener('click', () => {\n    if (sorting) return;\n    insertionSortAuto();\n  });\n\n  stepBtn.addEventListener('click', () => {\n    if (sorting) return;\n    sorting = true;\n    insertionSortStep();\n    if (i >= array.length) {\n      sorting = false;\n    }\n  });\n\n  resetBtn.addEventListener('click', () => {\n    generateArray();\n  });\n\n  speedRange.addEventListener('input', () => {\n    speed = parseInt(speedRange.value, 10);\n  });\n\n  // Initialize:\n  generateArray();\n  // Enable step mode:\n  stepBtn.disabled = false;\n})();\n</script>\n</body>\n</html>"
