    "content": "<html>\n<head>\n    <title>Merge Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>Merge Sort</h1>\n    <button id=\"merge-sort-btn\">Merge Sort</button>\n    <div id=\"merge-sort-output\"></div>\n\n    <script>\n        function mergeSort(arr) {\n            if (arr.length <= 1) {\n                return arr;\n            }\n\n            const mid = Math.floor(arr.length / 2);\n            const left = mergeSort(arr.slice(0, mid));\n            const right = mergeSort(arr.slice(mid));\n\n            return merge(left, right);\n        }\n\n        function merge(left, right) {\n            const merged = [];\n            let leftIndex = 0;\n            let rightIndex = 0;\n\n            while (leftIndex < left.length && rightIndex < right.length) {\n                if (left[leftIndex] <= right[rightIndex]) {\n                    merged.push(left[leftIndex]);\n                    leftIndex++;\n                } else {\n                    merged.push(right[rightIndex]);\n                    rightIndex++;\n                }\n            }\n\n            merged.push(...left.slice(leftIndex));\n            merged.push(...right.slice(rightIndex));\n\n            return merged;\n        }\n\n        const arr = [64, 34, 25, 12, 22, 11, 90];\n        const sortedArr = mergeSort(arr);\n        const output = document.getElementById('merge-sort-output');\n        output.innerHTML = 'Sorted array: ' + sortedArr.join(', ');\n\n        // Merge Sort Button Click Event\n        document.getElementById('merge-sort-btn').addEventListener('click', () => {\n            arr = [64, 34, 25, 12, 22, 11, 90];\n            const sortedArr = mergeSort(arr);\n            const output = document.getElementById('merge-sort-output');\n            output.innerHTML = 'Sorted array: ' + sortedArr.join(', ');\n        });\n    </script>\n</body>\n</html>"
