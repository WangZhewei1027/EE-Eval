    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Neural Networks Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background: #f4f4f4;\n            padding: 50px;\n        }\n        #canvas {\n            border: 1px solid #555;\n            display: block;\n            margin: 0 auto;\n        }\n        .info {\n            text-align: center;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n\n<h1>Simple Neural Network Demonstration</h1>\n<p>This demonstration will show how a simple neural network can learn to classify points.</p>\n\n<canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n<div class=\"info\">\n    <button id=\"trainBtn\">Train Neural Network</button>\n    <h2>Result:</h2>\n    <div id=\"result\"></div>\n</div>\n\n<script>\n    const canvas = document.getElementById('canvas');\n    const ctx = canvas.getContext('2d');\n    const width = canvas.width;\n    const height = canvas.height;\n\n    // Neural Network constructor\n    class NeuralNetwork {\n        constructor() {\n            this.weights = [\n                [Math.random(), Math.random()],\n                [Math.random(), Math.random()],\n                [Math.random(), Math.random()]\n            ];\n            this.learningRate = 0.1;\n        }\n\n        // Activation function\n        sigmoid(x) {\n            return 1 / (1 + Math.exp(-x));\n        }\n\n        // Predict function\n        predict(inputs) {\n            const sum = this.weights[0][0] * inputs[0] + this.weights[1][0] * inputs[1] + this.weights[2][0];\n            return this.sigmoid(sum);\n        }\n\n        // Train function\n        train(data) {\n            data.forEach((item) => {\n                const inputs = item.inputs;\n                const target = item.output;\n\n                // Predict output\n                const predicted = this.predict(inputs);\n                const error = target - predicted;\n\n                // Adjust weights\n                this.weights.forEach((weight, index) => {\n                    weight[0] += this.learningRate * error * inputs[index];\n                });\n            });\n        }\n    }\n\n    const nn = new NeuralNetwork();\n    const trainingData = [\n        { inputs: [0, 0], output: 0 },\n        { inputs: [0, 1], output: 1 },\n        { inputs: [1, 0], output: 1 },\n        { inputs: [1, 1], output: 0 }\n    ];\n\n    // Visualizing data points and neural network predictions\n    function draw(points, predictions) {\n        ctx.clearRect(0, 0, width, height);\n        ctx.fillStyle = 'black';\n        \n        // Draw data points\n        points.forEach((point, index) => {\n            ctx.beginPath();\n            ctx.arc(point[0] * width, point[1] * height, 5, 0, 2 * Math.PI);\n            ctx.fillStyle = point[2] === 1 ? 'blue' : 'red';\n            ctx.fill();\n        });\n\n        // Draw results of neural network\n        for (let x = 0; x <= width; x += 5) {\n            for (let y = 0; y <= height; y += 5) {\n                const prediction = nn.predict([x / width, y / height]);\n                ctx.fillStyle = prediction > 0.5 ? 'rgba(0, 0, 255, 0.2)' : 'rgba(255, 0, 0, 0.2)';\n                ctx.fillRect(x, y, 5, 5);\n            }\n        }\n    }\n\n    document.getElementById('trainBtn').onclick = function() {\n        for (let i = 0; i < 10000; i++) {\n            nn.train(trainingData);\n        }\n        const predictions = trainingData.map(item => nn.predict(item.inputs));\n        draw(trainingData.map((item, index) => [...item.inputs, item.output]), predictions);\n        document.getElementById('result').innerText = 'Neural Network Trained!';\n    };\n\n    draw(trainingData.map(item => [...item.inputs, item.output]), []);\n</script>\n\n</body>\n</html>"
