    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Ternary Search Demo</title>\n<style>\n  body {\n    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n    margin: 20px;\n    background: #fafafa;\n  }\n  h1 {\n    text-align: center;\n  }\n  #arrayContainer {\n    display: flex;\n    justify-content: center;\n    flex-wrap: wrap;\n    margin: 20px 0;\n  }\n  .element {\n    width: 35px;\n    height: 35px;\n    border: 2px solid #666;\n    margin: 3px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: #eee;\n    font-weight: bold;\n    border-radius: 4px;\n    user-select: none;\n  }\n  .low {\n    border-color: #2196f3;\n    background: #bbdefb;\n  }\n  .high {\n    border-color: #f44336;\n    background: #ffcdd2;\n  }\n  .mid1 {\n    border-color: #4caf50;\n    background: #c8e6c9;\n  }\n  .mid2 {\n    border-color: #ff9800;\n    background: #ffe0b2;\n  }\n  .found {\n    background: #8bc34a;\n    color: white;\n    border-color: #558b2f;\n  }\n  #info {\n    max-width: 600px;\n    margin: 0 auto 20px auto;\n    background: #fff;\n    border-radius: 6px;\n    padding: 12px;\n    box-shadow: 0 2px 5px rgb(0 0 0 / 0.1);\n    font-size: 1rem;\n    line-height: 1.4;\n  }\n  #controls {\n    max-width: 400px;\n    margin: 10px auto 40px auto;\n    text-align: center;\n  }\n  input[type=\"number\"] {\n    font-size: 1rem;\n    padding: 5px;\n    width: 80px;\n    margin-right: 12px;\n  }\n  button {\n    font-size: 1rem;\n    padding: 6px 15px;\n    cursor: pointer;\n    border: none;\n    background-color: #2196f3;\n    color: white;\n    border-radius: 4px;\n  }\n  button:disabled {\n    background-color: #90caf9;\n    cursor: not-allowed;\n  }\n  #log {\n    max-width: 600px;\n    margin: 0 auto;\n    background: #fff;\n    padding: 10px;\n    height: 240px;\n    overflow-y: auto;\n    border: 1px solid #ddd;\n    border-radius: 6px;\n    font-family: monospace;\n    font-size: 0.9rem;\n    white-space: pre-wrap;\n    line-height: 1.2;\n  }\n  @media (max-width: 600px) {\n    #arrayContainer {\n      justify-content: center;\n    }\n  }\n</style>\n</head>\n<body>\n<h1>Ternary Search Visualization</h1>\n<div id=\"info\">\n  <p><strong>Ternary search</strong> is a divide and conquer algorithm that works on sorted arrays. It splits the search interval into three parts using two mid indices and determines which part the target element lies in, then repeats the process on that segment.</p>\n  <p>It is similar to binary search but divides the array into three parts instead of two.</p>\n  <p>Algorithm steps:</p>\n  <ol>\n    <li>Calculate two mid points: mid1 and mid2.</li>\n    <li>If target equals array[mid1] or array[mid2], return the index.</li>\n    <li>If target is less than array[mid1], search in the left segment.</li>\n    <li>If target is greater than array[mid2], search in the right segment.</li>\n    <li>Otherwise search in the middle segment.</li>\n    <li>Repeat until element is found or interval is empty.</li>\n  </ol>\n</div>\n<div id=\"controls\">\n  <input type=\"number\" id=\"targetInput\" placeholder=\"Target number\" />\n  <button id=\"startBtn\">Start Search</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n<div id=\"arrayContainer\"></div>\n<div id=\"log\"></div>\n\n<script>\n  // Sorted array for search demo\n  const array = [];\n  const ARRAY_SIZE = 30;\n  for (let i = 1; i <= ARRAY_SIZE; i++) {\n    array.push(i * 3); // multiples of 3: 3,6,9,...\n  }\n\n  const arrayContainer = document.getElementById('arrayContainer');\n  const logContainer = document.getElementById('log');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const targetInput = document.getElementById('targetInput');\n\n  // Function to render array elements as boxes\n  function renderArray(highlight = {}) {\n    // highlight keys: low, high, mid1, mid2, foundIndex\n    arrayContainer.innerHTML = '';\n    for (let i = 0; i < array.length; i++) {\n      const el = document.createElement('div');\n      el.classList.add('element');\n      el.textContent = array[i];\n      if (i === highlight.low) el.classList.add('low');\n      if (i === highlight.high) el.classList.add('high');\n      if (i === highlight.mid1) el.classList.add('mid1');\n      if (i === highlight.mid2) el.classList.add('mid2');\n      if (i === highlight.foundIndex) el.classList.add('found');\n      arrayContainer.appendChild(el);\n    }\n  }\n\n  // Log helper\n  function log(text) {\n    logContainer.textContent += text + '\\n';\n    logContainer.scrollTop = logContainer.scrollHeight;\n  }\n\n  // Sleep helper (for animation delay)\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Ternary search algorithm with visualization\n  async function ternarySearch(arr, target) {\n    let low = 0;\n    let high = arr.length - 1;\n\n    while (low <= high) {\n      renderArray({ low, high });\n      await sleep(800);\n\n      const third = Math.floor((high - low) / 3);\n      const mid1 = low + third;\n      const mid2 = high - third;\n\n      renderArray({ low, high, mid1, mid2 });\n      log(`Searching between indexes ${low} and ${high}.`);\n      log(`mid1: ${mid1} (value: ${arr[mid1]}), mid2: ${mid2} (value: ${arr[mid2]})`);\n      await sleep(1000);\n\n      if (arr[mid1] === target) {\n        renderArray({ foundIndex: mid1 });\n        log(`Found target ${target} at index ${mid1}!`);\n        return mid1;\n      }\n      if (arr[mid2] === target) {\n        renderArray({ foundIndex: mid2 });\n        log(`Found target ${target} at index ${mid2}!`);\n        return mid2;\n      }\n      if (target < arr[mid1]) {\n        log(`Target ${target} is less than value at mid1 (${arr[mid1]}). Searching left segment.`);\n        high = mid1 - 1;\n      } else if (target > arr[mid2]) {\n        log(`Target ${target} is greater than value at mid2 (${arr[mid2]}). Searching right segment.`);\n        low = mid2 + 1;\n      } else {\n        log(`Target ${target} is between mid1 and mid2. Searching middle segment.`);\n        low = mid1 + 1;\n        high = mid2 - 1;\n      }\n      await sleep(800);\n    }\n\n    log(`Target ${target} not found in the array.`);\n    return -1;\n  }\n\n  // Initialize display\n  renderArray();\n\n  // Control buttons and input\n  startBtn.addEventListener('click', async () => {\n    let target = parseInt(targetInput.value, 10);\n    if (isNaN(target)) {\n      alert('Please enter a valid target number.');\n      return;\n    }\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n    targetInput.disabled = true;\n    logContainer.textContent = '';\n    log(`Starting ternary search for target: ${target}`);\n    await ternarySearch(array, target);\n    log('Search completed.');\n  });\n\n  resetBtn.addEventListener('click', () => {\n    targetInput.value = '';\n    targetInput.disabled = false;\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n    logContainer.textContent = '';\n    renderArray();\n  });\n</script>\n</body>\n</html>"
