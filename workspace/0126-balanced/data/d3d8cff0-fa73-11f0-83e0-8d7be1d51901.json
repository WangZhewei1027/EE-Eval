  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Process (OS) — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724; --panel:#0b1220; --accent:#2dd4bf; --muted:#94a3b8; --card:#0e1622;\n      --good:#22c55e; --warn:#f59e0b; --bad:#ef4444; color-scheme: dark;\n    }\n    html,body{height:100%;margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial;}\n    body{background:linear-gradient(180deg,#061025 0%, #071029 40%, #051020 100%); color:#e6eef6; padding:18px;}\n    h1{margin:0 0 8px;font-size:20px;}\n    p.lead{margin:0 0 12px;color:var(--muted);font-size:13px;}\n    .wrap{display:grid;grid-template-columns:360px 1fr;gap:16px;align-items:start;}\n    .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.03); padding:12px; border-radius:8px;}\n    .controls{position:sticky;top:18px;}\n    label{display:block;font-size:12px;color:var(--muted);margin-top:8px;}\n    input[type=\"number\"], select, input[type=\"text\"]{width:100%;padding:8px;border-radius:6px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:inherit;font-size:13px;}\n    button{padding:8px 10px;margin-top:10px;border-radius:8px;border:0;background:linear-gradient(90deg,var(--accent),#60a5fa);color:#021226;font-weight:600;cursor:pointer;}\n    button.secondary{background:transparent;border:1px solid rgba(255,255,255,0.04);color:var(--muted);font-weight:600;}\n    .small{font-size:12px;color:var(--muted);}\n    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:8px;}\n    .status-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}\n    .pill{padding:6px 8px;border-radius:999px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.03);font-size:13px}\n    .pill .dot{display:inline-block;width:10px;height:10px;border-radius:50%;margin-right:6px;vertical-align:middle}\n    .dot.ready{background:#60a5fa}\n    .dot.running{background:var(--accent)}\n    .dot.blocked{background:var(--warn)}\n    .dot.terminated{background:#94a3b8}\n    .main-panel{display:flex;flex-direction:column;gap:12px;}\n    .row{display:flex;gap:12px;align-items:center;}\n    .display-area{display:grid;grid-template-columns:1fr 360px;gap:12px;}\n    .canvas{background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));border-radius:8px;padding:12px;min-height:260px;border:1px solid rgba(255,255,255,0.03);}\n    .list{max-height:240px;overflow:auto;}\n    table{width:100%;border-collapse:collapse;font-size:13px}\n    th,td{padding:8px;text-align:left;border-bottom:1px dashed rgba(255,255,255,0.02);color:#e6eef6}\n    th{font-size:12px;color:var(--muted)}\n    .gantt{height:120px;overflow:auto;padding:8px;border-radius:6px;background:transparent;border:1px dashed rgba(255,255,255,0.02)}\n    .proc-bar{height:18px;border-radius:6px;margin-bottom:6px;display:flex;align-items:center;gap:8px;padding:0 6px;color:#021226;font-weight:700}\n    .log{max-height:180px;overflow:auto;background:rgba(0,0,0,0.12);padding:8px;border-radius:6px;font-family:monospace;font-size:12px;color:#dbeafe}\n    .footer{font-size:12px;color:var(--muted);margin-top:6px}\n    .diagram{width:100%;height:140px}\n    .muted{color:var(--muted)}\n    .kbd{background:rgba(255,255,255,0.02);padding:4px 6px;border-radius:6px;border:1px solid rgba(255,255,255,0.03);font-weight:600}\n    .mini{font-size:12px}\n    .legend{display:flex;gap:8px;flex-wrap:wrap}\n    .legend span{display:flex;gap:6px;align-items:center;padding:6px;border-radius:6px;background:rgba(255,255,255,0.015);font-size:12px}\n    .legend .s{width:12px;height:12px;border-radius:3px}\n    .s-ready{background:#60a5fa} .s-running{background:var(--accent)} .s-blocked{background:var(--warn)} .s-term{background:#94a3b8}\n    /* small screen */\n    @media (max-width:920px){\n      .wrap{grid-template-columns:1fr; }\n      .display-area{grid-template-columns:1fr;}\n    }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <div class=\"panel controls\">\n      <h1>Process — interactive concept demo</h1>\n      <p class=\"lead\">Visualize an operating system process: its lifecycle, scheduling, blocking (I/O), and termination. Create processes, run a scheduler, and watch state transitions.</p>\n\n      <div class=\"grid-2\">\n        <div>\n          <label>Scheduler</label>\n          <select id=\"scheduler\">\n            <option value=\"rr\">Round Robin (time quantum)</option>\n            <option value=\"priority\">Preemptive Priority</option>\n            <option value=\"fcfs\">First-Come First-Served</option>\n          </select>\n        </div>\n        <div>\n          <label>Time quantum (ticks)</label>\n          <input type=\"number\" id=\"quantum\" value=\"4\" min=\"1\" />\n        </div>\n      </div>\n\n      <label>New process name</label>\n      <input id=\"pname\" type=\"text\" placeholder=\"ProcessA\" />\n\n      <div class=\"grid-2\">\n        <div>\n          <label>CPU bursts total (1–5)</label>\n          <input id=\"bursts\" type=\"number\" min=\"1\" max=\"10\" value=\"2\" />\n        </div>\n        <div>\n          <label>Avg CPU time per burst (ticks)</label>\n          <input id=\"burstlen\" type=\"number\" min=\"1\" value=\"6\" />\n        </div>\n      </div>\n\n      <div class=\"grid-2\">\n        <div>\n          <label>IO chance after CPU (%)</label>\n          <input id=\"iochance\" type=\"number\" min=\"0\" max=\"100\" value=\"60\" />\n        </div>\n        <div>\n          <label>Avg IO time (ticks)</label>\n          <input id=\"iolength\" type=\"number\" min=\"1\" value=\"4\" />\n        </div>\n      </div>\n\n      <div class=\"grid-2\">\n        <div>\n          <label>Priority (0 high → 10 low)</label>\n          <input id=\"priority\" type=\"number\" min=\"0\" max=\"10\" value=\"5\" />\n        </div>\n        <div>\n          <label>Color (visual)</label>\n          <input id=\"color\" type=\"text\" value=\"#60a5fa\" />\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:8px;\">\n        <button id=\"createBtn\">Create process</button>\n        <button id=\"forkBtn\" class=\"secondary\">Fork selected</button>\n      </div>\n      <div style=\"display:flex;gap:8px;margin-top:8px;\">\n        <button id=\"startBtn\">Start</button>\n        <button id=\"pauseBtn\" class=\"secondary\">Pause</button>\n        <button id=\"stepBtn\" class=\"secondary\">Step</button>\n        <button id=\"resetBtn\" class=\"secondary\">Reset</button>\n      </div>\n\n      <div class=\"status-row\">\n        <div class=\"pill\"><span class=\"dot running\"></span> Running</div>\n        <div class=\"pill\"><span class=\"dot ready\"></span> Ready</div>\n        <div class=\"pill\"><span class=\"dot blocked\"></span> Blocked (I/O)</div>\n        <div class=\"pill\"><span class=\"dot terminated\"></span> Terminated</div>\n      </div>\n\n      <div style=\"margin-top:12px\">\n        <div class=\"mini muted\">Legend</div>\n        <div class=\"legend\" style=\"margin-top:6px\">\n          <span><i class=\"s s-ready\"></i> Ready</span>\n          <span><i class=\"s s-running\"></i> Running</span>\n          <span><i class=\"s s-blocked\"></i> Blocked</span>\n          <span><i class=\"s s-term\"></i> Terminated</span>\n        </div>\n      </div>\n\n      <div class=\"footer\">\n        <div style=\"margin-top:10px\"><strong>Process definition (short):</strong></div>\n        <div class=\"muted\" style=\"margin-top:6px\">A process is an instance of a running program with its own memory space, registers, and OS bookkeeping. Processes go through states (new → ready → running → waiting/blocked → terminated). This demo simulates scheduling, blocking for I/O, and context switching at tick granularity.</div>\n      </div>\n    </div>\n\n    <div class=\"main-panel\">\n      <div class=\"display-area\">\n        <div class=\"canvas panel\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n            <div>\n              <div class=\"small\">Simulation tick: <span id=\"tick\">0</span></div>\n              <div class=\"small\">CPU: <span id=\"cpuDisplay\">idle</span></div>\n            </div>\n            <div>\n              <div class=\"small\">Scheduler mode: <span id=\"modeDisplay\">RR</span></div>\n            </div>\n          </div>\n\n          <div style=\"margin-top:12px;display:flex;gap:8px;\">\n            <div style=\"flex:1\">\n              <div style=\"display:flex;gap:6px;align-items:center\">\n                <div class=\"small\">Ready queue</div>\n                <div id=\"readyCount\" class=\"pill\" style=\"padding:4px 8px\"></div>\n              </div>\n              <div id=\"readyList\" class=\"list\" style=\"margin-top:8px\"></div>\n            </div>\n            <div style=\"width:200px\">\n              <div class=\"small\">Blocked (I/O)</div>\n              <div id=\"blockedList\" class=\"list\" style=\"margin-top:8px\"></div>\n            </div>\n          </div>\n\n          <div style=\"margin-top:12px\">\n            <div class=\"small\">Process table</div>\n            <div style=\"margin-top:8px;max-height:180px;overflow:auto\">\n              <table id=\"ptable\">\n                <thead><tr><th>PID</th><th>Name</th><th>State</th><th>Prio</th><th>Rem CPU</th><th>Bursts</th></tr></thead>\n                <tbody></tbody>\n              </table>\n            </div>\n          </div>\n\n        </div>\n\n        <div class=\"panel\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div><strong>Gantt / History</strong></div>\n            <div class=\"small muted\">Bars show CPU bursts executed over time</div>\n          </div>\n\n          <div class=\"gantt\" id=\"gantt\"></div>\n\n          <div style=\"margin-top:10px\" class=\"small muted\">Event log</div>\n          <div id=\"log\" class=\"log\" style=\"margin-top:6px\"></div>\n        </div>\n      </div>\n\n      <div class=\"panel\" style=\"display:flex;gap:12px;align-items:flex-start;\">\n        <div style=\"flex:1\">\n          <div style=\"display:flex;gap:8px;align-items:center;justify-content:space-between\">\n            <div><strong>Process lifecycle diagram</strong></div>\n            <div class=\"small muted\">Animated token shows state transitions</div>\n          </div>\n          <svg id=\"diagram\" class=\"diagram\" viewBox=\"0 0 800 180\" preserveAspectRatio=\"xMidYMid meet\"></svg>\n        </div>\n\n        <div style=\"width:360px\">\n          <div><strong>Selected process controls</strong></div>\n          <div class=\"small muted\" style=\"margin-top:6px\">Click a process in the table to select it. You can send it to I/O, kill it, or change priority.</div>\n\n          <div style=\"margin-top:8px\">\n            <label>Selected PID</label>\n            <input id=\"selPid\" type=\"text\" disabled />\n            <label>Set priority</label>\n            <input id=\"setPrio\" type=\"number\" min=\"0\" max=\"10\" />\n            <div style=\"display:flex;gap:8px;\">\n              <button id=\"prioBtn\" class=\"secondary\">Set</button>\n              <button id=\"ioBtn\" class=\"secondary\">Send to I/O</button>\n              <button id=\"killBtn\" class=\"secondary\">Kill</button>\n            </div>\n          </div>\n\n          <div style=\"margin-top:12px\">\n            <strong>Concept notes</strong>\n            <div class=\"muted mini\" style=\"margin-top:6px\">\n              - Processes have private memory and kernel bookkeeping. Threads share memory within a process.<br/>\n              - Scheduling decides which process runs next; preemption may interrupt running process.<br/>\n              - Blocking occurs when process performs I/O and waits — it cannot run until I/O completes.<br/>\n              - Fork creates a child process with (simulated) copied state.\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n<script>\n/*\n  Interactive Process Simulator\n  - Single-file demo that simulates OS process lifecycle, scheduler (RR, Priority, FCFS),\n    blocking for I/O, forking, and termination.\n  - Ticks advance in discrete steps; each tick the running process consumes CPU time.\n*/\n\nconst state = {\n  tick: 0,\n  nextPid: 1,\n  ready: [],      // queue of PIDs (for RR/FCFS). For priority, it's sorted.\n  blocked: [],    // { pid, remainingIO }\n  running: null,  // pid\n  processes: {},  // pid -> process object\n  terminated: [],\n  history: [],    // {tick, pid}\n  runningSlice: 0,\n  runningUsedQuantum: 0,\n  runningQuantum: 4,\n  scheduler: 'rr',\n  runningInterval: null,\n  runningSpeedMs: 700\n};\n\nconst elements = {\n  pname: document.getElementById('pname'),\n  bursts: document.getElementById('bursts'),\n  burstlen: document.getElementById('burstlen'),\n  iochance: document.getElementById('iochance'),\n  iolength: document.getElementById('iolength'),\n  priority: document.getElementById('priority'),\n  color: document.getElementById('color'),\n  createBtn: document.getElementById('createBtn'),\n  forkBtn: document.getElementById('forkBtn'),\n  startBtn: document.getElementById('startBtn'),\n  pauseBtn: document.getElementById('pauseBtn'),\n  stepBtn: document.getElementById('stepBtn'),\n  resetBtn: document.getElementById('resetBtn'),\n  scheduler: document.getElementById('scheduler'),\n  quantum: document.getElementById('quantum'),\n\n  tick: document.getElementById('tick'),\n  cpuDisplay: document.getElementById('cpuDisplay'),\n  modeDisplay: document.getElementById('modeDisplay'),\n  readyList: document.getElementById('readyList'),\n  blockedList: document.getElementById('blockedList'),\n  readyCount: document.getElementById('readyCount'),\n  ptable: document.getElementById('ptable').querySelector('tbody'),\n  gantt: document.getElementById('gantt'),\n  log: document.getElementById('log'),\n  diagram: document.getElementById('diagram'),\n\n  selPid: document.getElementById('selPid'),\n  setPrio: document.getElementById('setPrio'),\n  prioBtn: document.getElementById('prioBtn'),\n  ioBtn: document.getElementById('ioBtn'),\n  killBtn: document.getElementById('killBtn'),\n  forkBtnEl: document.getElementById('forkBtn')\n};\n\nfunction randInt(mean){\n  // small random around mean\n  const v = Math.max(1, Math.round(Math.max(1, mean) * (0.6 + Math.random()*0.8)));\n  return v;\n}\n\nfunction logEvent(msg){\n  const s = `[t=${state.tick}] ${msg}`;\n  const el = document.createElement('div');\n  el.textContent = s;\n  elements.log.prepend(el);\n}\n\nfunction createProcess(opts = {}) {\n  const pid = state.nextPid++;\n  const name = opts.name || `P${pid}`;\n  const bursts = Math.max(1, parseInt(opts.bursts || 1));\n  const avgBurst = Math.max(1, parseInt(opts.burstlen || 4));\n  const ioChance = Math.min(100, Math.max(0, parseInt(opts.iochance || 50)));\n  const avgIO = Math.max(1, parseInt(opts.iolength || 3));\n  const prio = Math.max(0, Math.min(10, parseInt(opts.priority || 5)));\n  const color = opts.color || '#60a5fa';\n\n  // generate CPU bursts as array of lengths. After each CPU burst (except last) there may be IO.\n  const cpuBursts = [];\n  for(let i=0;i<bursts;i++){\n    cpuBursts.push(randInt(avgBurst));\n  }\n\n  const p = {\n    pid, name, color, priority: prio,\n    state: 'new',              // new, ready, running, blocked, terminated\n    cpuBursts,                // array of remaining cpu burst lengths\n    burstIndex: 0,\n    remainingInBurst: cpuBursts[0],\n    ioChance, avgIO,\n    arrivalTick: state.tick,\n    createdAt: Date.now()\n  };\n\n  state.processes[pid] = p;\n  // New processes immediately go to ready (simulating admission)\n  p.state = 'ready';\n  enqueueReady(pid);\n  logEvent(`Created ${name}(pid=${pid}) bursts=${cpuBursts.join(',')}`);\n\n  renderAll();\n  return pid;\n}\n\nfunction enqueueReady(pid){\n  const p = state.processes[pid];\n  if(!p) return;\n  p.state = 'ready';\n  if(state.scheduler === 'priority'){\n    // insert by priority (lower value = higher priority)\n    state.ready.push(pid);\n    state.ready.sort((a,b) => {\n      const pa = state.processes[a], pb = state.processes[b];\n      if(pa.priority !== pb.priority) return pa.priority - pb.priority;\n      return pa.arrivalTick - pb.arrivalTick;\n    });\n  } else {\n    state.ready.push(pid);\n  }\n}\n\nfunction pickNext(){\n  if(state.ready.length === 0) return null;\n  if(state.scheduler === 'rr' || state.scheduler === 'fcfs'){\n    // FCFS same as FIFO for our purposes (no preemption unless RR)\n    return state.ready.shift();\n  } else if(state.scheduler === 'priority'){\n    // already sorted\n    return state.ready.shift();\n  }\n  return state.ready.shift();\n}\n\nfunction startRunningLoop(){\n  if(state.runningInterval) return;\n  state.runningInterval = setInterval(()=> tick(), state.runningSpeedMs);\n}\n\nfunction pauseRunningLoop(){\n  if(state.runningInterval){\n    clearInterval(state.runningInterval);\n    state.runningInterval = null;\n  }\n}\n\nfunction stepOnce(){\n  tick();\n}\n\nfunction resetSim(){\n  pauseRunningLoop();\n  state.tick = 0;\n  state.nextPid = 1;\n  state.ready = [];\n  state.blocked = [];\n  state.running = null;\n  state.processes = {};\n  state.terminated = [];\n  state.history = [];\n  state.runningSlice = 0;\n  state.runningUsedQuantum = 0;\n  elements.log.innerHTML = '';\n  elements.gantt.innerHTML = '';\n  renderAll();\n}\n\nfunction tick(){\n  // Advance time by one tick\n  state.tick += 1;\n  elements.tick.textContent = state.tick;\n  // Update blocked processes\n  for(let i=state.blocked.length-1;i>=0;i--){\n    const b = state.blocked[i];\n    b.remainingIO -= 1;\n    if(b.remainingIO <= 0){\n      // IO complete — enqueue ready\n      const pid = b.pid;\n      state.blocked.splice(i,1);\n      enqueueReady(pid);\n      logEvent(`I/O complete for pid=${pid} — moved to READY`);\n    }\n  }\n\n  // If nothing is running, pick next\n  if(state.running == null){\n    const next = pickNext();\n    if(next != null){\n      state.running = next;\n      const p = state.processes[next];\n      p.state = 'running';\n      state.runningUsedQuantum = 0;\n      logEvent(`Context switch — pid=${next} starts running`);\n    }\n  }\n\n  // If a running process exists, run one tick of CPU\n  if(state.running != null){\n    const pid = state.running;\n    const p = state.processes[pid];\n    if(!p){\n      state.running = null;\n    } else {\n      p.remainingInBurst -= 1;\n      state.runningUsedQuantum += 1;\n      state.history.push({tick: state.tick, pid});\n      // record in gantt: extend or create bar\n      addGantt(pid, p.color);\n\n      // Check if CPU burst finished\n      if(p.remainingInBurst <= 0){\n        p.burstIndex += 1;\n        if(p.burstIndex >= p.cpuBursts.length){\n          // process terminates\n          p.state = 'terminated';\n          state.terminated.push(pid);\n          logEvent(`pid=${pid} terminated`);\n          state.running = null;\n        } else {\n          // Decide if I/O occurs (probabilistic)\n          const doIO = Math.random()*100 < p.ioChance;\n          if(doIO){\n            const iolen = randInt(p.avgIO);\n            p.state = 'blocked';\n            state.blocked.push({pid, remainingIO: iolen});\n            // prepare next CPU burst\n            p.remainingInBurst = p.cpuBursts[p.burstIndex];\n            logEvent(`pid=${pid} finished CPU burst → BLOCKED for IO (${iolen} ticks)`);\n            state.running = null;\n          } else {\n            // immediate ready (no IO)\n            p.remainingInBurst = p.cpuBursts[p.burstIndex];\n            p.state = 'ready';\n            enqueueReady(pid);\n            logEvent(`pid=${pid} finished CPU burst → READY (no I/O)`);\n            state.running = null;\n          }\n        }\n      } else {\n        // If scheduler is preemptive (RR or priority with tie), handle quantum or preemption\n        if(state.scheduler === 'rr'){\n          const q = parseInt(elements.quantum.value) || 4;\n          if(state.runningUsedQuantum >= q){\n            // preempt\n            p.state = 'ready';\n            enqueueReady(pid);\n            state.running = null;\n            logEvent(`Time quantum expired — preempt pid=${pid}`);\n          }\n        } else if(state.scheduler === 'priority'){\n          // preempt if a higher priority process is in ready queue\n          if(state.ready.length > 0){\n            const topReady = state.processes[state.ready[0]];\n            if(topReady && topReady.priority < p.priority){\n              // preempt current\n              p.state = 'ready';\n              enqueueReady(pid);\n              state.running = null;\n              logEvent(`Preempt by higher priority pid=${topReady.pid} — preempted pid=${pid}`);\n            }\n          }\n        }\n      }\n    }\n  }\n\n  // update visuals\n  renderAll();\n}\n\nfunction renderAll(){\n  elements.modeDisplay.textContent = state.scheduler.toUpperCase();\n  elements.cpuDisplay.textContent = state.running ? `${state.processes[state.running].name}(pid=${state.running})` : 'idle';\n  // ready list\n  elements.readyList.innerHTML = '';\n  for(const pid of state.ready){\n    const p = state.processes[pid];\n    const el = document.createElement('div');\n    el.style.display = 'flex';\n    el.style.justifyContent = 'space-between';\n    el.style.padding = '6px';\n    el.style.borderRadius = '6px';\n    el.style.marginBottom = '6px';\n    el.style.background = 'linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005))';\n    el.innerHTML = `<div style=\"display:flex;gap:8px;align-items:center\"><div style=\"width:10px;height:10px;border-radius:2px;background:${p.color}\"></div><div>${p.name} (pid:${pid})</div></div><div class=\"mini muted\">pr:${p.priority}</div>`;\n    elements.readyList.appendChild(el);\n  }\n  elements.readyCount.textContent = state.ready.length;\n\n  elements.blockedList.innerHTML = '';\n  for(const b of state.blocked){\n    const p = state.processes[b.pid];\n    const el = document.createElement('div');\n    el.style.padding = '6px';\n    el.style.borderRadius = '6px';\n    el.style.marginBottom = '6px';\n    el.style.display = 'flex';\n    el.style.justifyContent = 'space-between';\n    el.style.alignItems = 'center';\n    el.style.background = 'linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.005))';\n    el.innerHTML = `<div style=\"display:flex;gap:8px;align-items:center\"><div style=\"width:10px;height:10px;border-radius:2px;background:${p.color}\"></div><div>${p.name} (pid:${b.pid})</div></div><div class=\"mini muted\">${b.remainingIO}t</div>`;\n    elements.blockedList.appendChild(el);\n  }\n\n  // process table\n  elements.ptable.innerHTML = '';\n  for(const pidStr of Object.keys(state.processes).sort((a,b)=>a-b)){\n    const pid = parseInt(pidStr);\n    const p = state.processes[pid];\n    const tr = document.createElement('tr');\n    tr.style.cursor = 'pointer';\n    tr.onclick = ()=> selectPid(pid);\n    const stateText = p.state;\n    tr.innerHTML = `<td>${pid}</td><td>${p.name}</td><td>${stateText}</td><td>${p.priority}</td><td>${p.remainingInBurst}</td><td>${p.burstIndex+1}/${p.cpuBursts.length}</td>`;\n    elements.ptable.appendChild(tr);\n  }\n\n  // gantt: compress history to bars per pid rows\n  renderGantt();\n\n  // diagram animation token update\n  renderDiagram();\n}\n\nfunction addGantt(pid, color){\n  // append a tiny segment for this tick (grouped by pid)\n  // We'll track by building history and then render grouped bars\n  // elements.gantt will be rebuilt in renderGantt\n}\n\nfunction renderGantt(){\n  // Build rows per process that has history\n  elements.gantt.innerHTML = '';\n  const grouped = {};\n  for(const h of state.history){\n    grouped[h.pid] = grouped[h.pid] || [];\n    grouped[h.pid].push(h.tick);\n  }\n  // For deterministic ordering, list active+terminated processes\n  const pids = Array.from(new Set(Object.keys(grouped).map(x=>parseInt(x)).concat(Object.keys(state.processes).map(x=>parseInt(x)))));\n  pids.sort((a,b)=>a-b);\n\n  for(const pid of pids){\n    const p = state.processes[pid];\n    const row = document.createElement('div');\n    row.style.display = 'flex';\n    row.style.alignItems = 'center';\n    row.style.marginBottom = '6px';\n    const label = document.createElement('div');\n    label.textContent = p ? `${p.name}(pid:${pid})` : `pid:${pid}`;\n    label.style.width = '130px';\n    label.style.fontSize = '12px';\n    label.style.color = 'var(--muted)';\n    row.appendChild(label);\n\n    const barWrapper = document.createElement('div');\n    barWrapper.style.flex = '1';\n    barWrapper.style.display = 'flex';\n    barWrapper.style.alignItems = 'center';\n    barWrapper.style.gap = '2px';\n    barWrapper.style.overflowX = 'auto';\n    barWrapper.style.padding = '6px';\n    barWrapper.style.borderRadius = '6px';\n    barWrapper.style.background = 'rgba(255,255,255,0.01)';\n\n    const ticks = grouped[pid] || [];\n    // compress consecutive ticks into blocks\n    ticks.sort((a,b)=>a-b);\n    let i=0;\n    while(i < ticks.length){\n      let j = i+1;\n      while(j < ticks.length && ticks[j] === ticks[j-1]+1) j++;\n      const start = ticks[i];\n      const len = j - i;\n      const seg = document.createElement('div');\n      seg.style.minWidth = Math.max(8, len*10) + 'px';\n      seg.style.height = '18px';\n      seg.style.background = (p && p.color) ? p.color : '#94a3b8';\n      seg.style.borderRadius = '6px';\n      seg.title = `pid:${pid} ticks ${start}..${start+len-1}`;\n      seg.style.display = 'inline-block';\n      barWrapper.appendChild(seg);\n      i = j;\n    }\n\n    row.appendChild(barWrapper);\n    elements.gantt.appendChild(row);\n  }\n}\n\nfunction selectPid(pid){\n  const p = state.processes[pid];\n  if(!p) return;\n  elements.selPid.value = pid;\n  elements.setPrio.value = p.priority;\n}\n\nfunction setPriority(){\n  const pid = parseInt(elements.selPid.value);\n  const val = parseInt(elements.setPrio.value);\n  if(!state.processes[pid]) return;\n  state.processes[pid].priority = val;\n  // if it's in ready queue and scheduler is priority, re-sort\n  if(state.scheduler === 'priority'){\n    state.ready.sort((a,b) => {\n      const pa = state.processes[a], pb = state.processes[b];\n      if(pa.priority !== pb.priority) return pa.priority - pb.priority;\n      return pa.arrivalTick - pb.arrivalTick;\n    });\n  }\n  logEvent(`Set priority of pid=${pid} to ${val}`);\n  renderAll();\n}\n\nfunction sendToIO(){\n  const pid = parseInt(elements.selPid.value);\n  const p = state.processes[pid];\n  if(!p) return;\n  // If running, remove from CPU\n  if(state.running === pid){\n    state.running = null;\n    logEvent(`pid=${pid} forced to I/O (from running)`);\n  } else {\n    // remove from ready queue if present\n    const idx = state.ready.indexOf(pid);\n    if(idx >= 0) state.ready.splice(idx,1);\n    logEvent(`pid=${pid} forced to I/O (from ready)`);\n  }\n  // push to blocked with avg IO\n  const iolen = randInt(p.avgIO || parseInt(elements.iolength.value || 3));\n  p.state = 'blocked';\n  state.blocked.push({pid, remainingIO: iolen});\n  renderAll();\n}\n\nfunction killPid(){\n  const pid = parseInt(elements.selPid.value);\n  if(!state.processes[pid]) return;\n  // remove from all structures\n  delete state.processes[pid];\n  const ridx = state.ready.indexOf(pid);\n  if(ridx >= 0) state.ready.splice(ridx,1);\n  for(let i=state.blocked.length-1;i>=0;i--) if(state.blocked[i].pid === pid) state.blocked.splice(i,1);\n  if(state.running === pid) state.running = null;\n  state.terminated.push(pid);\n  logEvent(`pid=${pid} killed`);\n  renderAll();\n}\n\nfunction forkSelected(){\n  const pid = parseInt(elements.selPid.value);\n  if(!state.processes[pid]) return;\n  const parent = state.processes[pid];\n  const childName = `${parent.name}-child`;\n  // child inherits remaining bursts (copy)\n  const childBursts = parent.cpuBursts.slice(parent.burstIndex);\n  // split remaining of current burst into two halves (simple simulation)\n  const remaining = parent.remainingInBurst;\n  const childRemaining = Math.max(1, Math.floor(remaining/2));\n  const parentRem = Math.max(1, remaining - childRemaining);\n  const childObj = {\n    name: childName,\n    bursts: childBursts,\n  };\n  const childPid = createProcess({\n    name: childName,\n    bursts: childBursts.length,\n    burstlen: 2 + childRemaining,\n    iochance: parent.ioChance,\n    iolength: parent.avgIO,\n    priority: parent.priority,\n    color: parent.color\n  });\n  // adjust parent's remaining\n  parent.remainingInBurst = parentRem;\n  state.processes[childPid].remainingInBurst = childRemaining;\n  logEvent(`pid=${pid} forked → child pid=${childPid}`);\n  renderAll();\n}\n\nfunction setupDiagram(){\n  const svg = elements.diagram;\n  svg.innerHTML = '';\n  const w = 800, h = 180;\n  svg.setAttribute('viewBox', `0 0 ${w} ${h}`);\n  // positions\n  const positions = {\n    new: {x:80,y:90}, ready:{x:260,y:40}, running:{x:420,y:90}, blocked:{x:260,y:140}, terminated:{x:620,y:90}\n  };\n  // draw boxes and arrows\n  for(const [k,pos] of Object.entries(positions)){\n    const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n    const rect = document.createElementNS('http://www.w3.org/2000/svg','rect');\n    rect.setAttribute('x', pos.x-70);\n    rect.setAttribute('y', pos.y-28);\n    rect.setAttribute('rx',10);\n    rect.setAttribute('width',140);\n    rect.setAttribute('height',56);\n    rect.setAttribute('fill','rgba(255,255,255,0.02)');\n    rect.setAttribute('stroke','rgba(255,255,255,0.04)');\n    g.appendChild(rect);\n    const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n    text.setAttribute('x', pos.x);\n    text.setAttribute('y', pos.y+4);\n    text.setAttribute('text-anchor','middle');\n    text.setAttribute('fill','#cfe9f6');\n    text.setAttribute('font-size','14');\n    text.textContent = k.toUpperCase();\n    g.appendChild(text);\n    svg.appendChild(g);\n  }\n  // arrows: new->ready, ready->running, running->blocked, running->terminated, blocked->ready\n  function arrow(x1,y1,x2,y2){\n    const path = document.createElementNS('http://www.w3.org/2000/svg','path');\n    const dx = x2-x1, dy = y2-y1;\n    const mx = x1 + dx*0.5;\n    const my = y1 + dy*0.5;\n    const d = `M ${x1} ${y1} Q ${mx} ${my} ${x2} ${y2}`;\n    path.setAttribute('d',d);\n    path.setAttribute('fill','none');\n    path.setAttribute('stroke','rgba(255,255,255,0.03)');\n    path.setAttribute('marker-end','url(#arrowhead)');\n    svg.appendChild(path);\n  }\n  const defs = document.createElementNS('http://www.w3.org/2000/svg','defs');\n  const marker = document.createElementNS('http://www.w3.org/2000/svg','marker');\n  marker.setAttribute('id','arrowhead');\n  marker.setAttribute('markerWidth','10');\n  marker.setAttribute('markerHeight','7');\n  marker.setAttribute('refX','0');\n  marker.setAttribute('refY','3.5');\n  marker.setAttribute('orient','auto');\n  const arrowPath = document.createElementNS('http://www.w3.org/2000/svg','path');\n  arrowPath.setAttribute('d','M0,0 L0,7 L10,3.5 z');\n  arrowPath.setAttribute('fill','rgba(255,255,255,0.04)');\n  marker.appendChild(arrowPath);\n  defs.appendChild(marker);\n  svg.appendChild(defs);\n\n  arrow(150,90,190,90); // new->ready (short)\n  arrow(330,50,400,70); // ready->running\n  arrow(450,110,300,140); // running->blocked\n  arrow(470,70,600,70); // running->terminated\n  arrow(290,140,300,90); // blocked->ready\n\n  // add token (circle) to animate\n  const token = document.createElementNS('http://www.w3.org/2000/svg','circle');\n  token.setAttribute('id','diagramToken');\n  token.setAttribute('r','10');\n  token.setAttribute('fill', 'url(#gradToken)');\n  token.setAttribute('cx', positions.new.x);\n  token.setAttribute('cy', positions.new.y);\n  svg.appendChild(token);\n\n  // gradient for token\n  const grad = document.createElementNS('http://www.w3.org/2000/svg','radialGradient');\n  grad.setAttribute('id','gradToken');\n  const s1 = document.createElementNS('http://www.w3.org/2000/svg','stop'); s1.setAttribute('offset','0%'); s1.setAttribute('stop-color','#2dd4bf');\n  const s2 = document.createElementNS('http://www.w3.org/2000/svg','stop'); s2.setAttribute('offset','100%'); s2.setAttribute('stop-color','#60a5fa');\n  grad.appendChild(s1); grad.appendChild(s2);\n  const gdefs = document.createElementNS('http://www.w3.org/2000/svg','defs');\n  gdefs.appendChild(grad);\n  svg.appendChild(gdefs);\n\n  // store positions on the element for animation\n  svg.__positions = positions;\n}\nsetupDiagram();\n\nfunction renderDiagram(){\n  // Move the token depending on a representative process state:\n  const svg = elements.diagram;\n  const pos = svg.__positions;\n  const token = svg.querySelector('#diagramToken');\n  // pick a pid to show: prefer running, else ready else blocked else new\n  let dest = 'new';\n  if(state.running) dest = 'running';\n  else if(state.ready.length>0) dest = 'ready';\n  else if(state.blocked.length>0) dest = 'blocked';\n  else dest = 'new';\n  if(state.terminated.length > 0) dest = 'terminated';\n\n  const p = pos[dest];\n  if(!p) return;\n  // animate by direct set (smooth via CSS transition)\n  token.style.transition = 'cx 0.5s linear, cy 0.5s linear';\n  token.setAttribute('cx', p.x);\n  token.setAttribute('cy', p.y);\n}\n\n// wire up buttons\nelements.createBtn.addEventListener('click', ()=> {\n  createProcess({\n    name: elements.pname.value || undefined,\n    bursts: elements.bursts.value,\n    burstlen: elements.burstlen.value,\n    iochance: elements.iochance.value,\n    iolength: elements.iolength.value,\n    priority: elements.priority.value,\n    color: elements.color.value\n  });\n});\nelements.startBtn.addEventListener('click', ()=> {\n  state.scheduler = elements.scheduler.value;\n  state.runningQuantum = parseInt(elements.quantum.value) || 4;\n  startRunningLoop();\n  logEvent(`Simulation started (scheduler=${state.scheduler})`);\n});\nelements.pauseBtn.addEventListener('click', ()=> {\n  pauseRunningLoop();\n  logEvent('Simulation paused');\n});\nelements.stepBtn.addEventListener('click', ()=> {\n  state.scheduler = elements.scheduler.value;\n  state.runningQuantum = parseInt(elements.quantum.value) || 4;\n  stepOnce();\n});\nelements.resetBtn.addEventListener('click', ()=> {\n  if(confirm('Reset simulation?')) resetSim();\n});\nelements.scheduler.addEventListener('change', ()=> {\n  state.scheduler = elements.scheduler.value;\n  renderAll();\n});\nelements.quantum.addEventListener('change', ()=> {\n  state.runningQuantum = parseInt(elements.quantum.value) || 4;\n});\nelements.prioBtn.addEventListener('click', setPriority);\nelements.ioBtn.addEventListener('click', sendToIO);\nelements.killBtn.addEventListener('click', killPid);\nelements.forkBtnEl.addEventListener('click', forkSelected);\n\n// initial demo processes\ncreateProcess({name:'Init', bursts:2, burstlen:5, iochance:60, iolength:3, priority:2, color:'#60a5fa'});\ncreateProcess({name:'Worker', bursts:3, burstlen:7, iochance:70, iolength:4, priority:5, color:'#a78bfa'});\ncreateProcess({name:'IO-bound', bursts:4, burstlen:3, iochance:90, iolength:2, priority:7, color:'#f59e0b'});\n\nrenderAll();\n\n/* Tips shown in the UI:\n - Use Start to run the simulation; Pause to stop; Step to advance by one tick.\n - Try Round Robin with small quantum to see frequent context switches.\n - Use Priority scheduler to see higher-priority processes preempting lower-priority ones.\n - Fork selected process to simulate process creation.\n*/\n\n</script>\n</body>\n</html>"
