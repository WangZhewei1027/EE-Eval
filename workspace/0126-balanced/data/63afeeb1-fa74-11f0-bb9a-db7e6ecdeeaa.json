    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Stack Data Structure Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    background: #f4f7fa;\n    color: #333;\n    margin: 0;\n    padding: 20px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    color: #2c3e50;\n  }\n  #stack-container {\n    margin-top: 20px;\n    width: 200px;\n    min-height: 300px;\n    border: 2px solid #3498db;\n    border-radius: 6px;\n    background: #ecf0f1;\n    position: relative;\n  }\n  .stack-element {\n    width: 180px;\n    height: 40px;\n    background: #2980b9;\n    margin: 6px auto;\n    border-radius: 4px;\n    color: white;\n    font-weight: bold;\n    line-height: 40px;\n    text-align: center;\n    box-shadow: 0 2px 5px rgba(0,0,0,0.15);\n    transition: transform 0.3s ease;\n  }\n  .stack-element.top {\n    background: #27ae60;\n    box-shadow: 0 0 10px #27ae60;\n  }\n  .controls {\n    margin-top: 30px;\n    display: flex;\n    gap: 10px;\n    flex-wrap: wrap;\n    justify-content: center;\n  }\n  input[type=\"text\"] {\n    padding: 8px;\n    font-size: 1rem;\n    border: 2px solid #3498db;\n    border-radius: 4px;\n    width: 140px;\n  }\n  button {\n    padding: 8px 16px;\n    font-size: 1rem;\n    background: #3498db;\n    border: none;\n    border-radius: 4px;\n    color: white;\n    cursor: pointer;\n    transition: background 0.25s ease;\n  }\n  button:hover:not(:disabled) {\n    background: #2980b9;\n  }\n  button:disabled {\n    background: #95a5a6;\n    cursor: not-allowed;\n  }\n  #message {\n    margin-top: 20px;\n    min-height: 24px;\n    font-size: 1rem;\n    font-weight: 600;\n    color: #c0392b;\n  }\n  #description {\n    max-width: 600px;\n    margin-bottom: 25px;\n    line-height: 1.5;\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n\n<h1>Stack Data Structure Demo</h1>\n<div id=\"description\">\n  A <strong>Stack</strong> is a linear data structure which follows the <em>Last In, First Out (LIFO)</em> principle.\n  You can <em>push</em> (add) elements onto the stack, <em>pop</em> (remove) elements from the top, and <em>peek</em> to see the top element without removing it.\n</div>\n\n<div id=\"stack-container\" aria-label=\"Stack visualization\" role=\"region\">\n  <!-- Stack elements will appear here -->\n</div>\n\n<div class=\"controls\">\n  <input type=\"text\" id=\"inputValue\" placeholder=\"Enter value\" aria-label=\"Value to push\" />\n  <button id=\"pushBtn\">Push</button>\n  <button id=\"popBtn\">Pop</button>\n  <button id=\"peekBtn\">Peek</button>\n  <button id=\"clearBtn\">Clear</button>\n</div>\n\n<div id=\"message\" aria-live=\"polite\" role=\"status\"></div>\n\n<script>\n  class Stack {\n    constructor() {\n      this.items = [];\n    }\n    push(element) {\n      this.items.push(element);\n    }\n    pop() {\n      if(this.isEmpty()) {\n        return null;\n      }\n      return this.items.pop();\n    }\n    peek() {\n      if(this.isEmpty()) {\n        return null;\n      }\n      return this.items[this.items.length - 1];\n    }\n    isEmpty() {\n      return this.items.length === 0;\n    }\n    clear() {\n      this.items = [];\n    }\n    size() {\n      return this.items.length;\n    }\n    getElements() {\n      return this.items.slice(); // return copy\n    }\n  }\n\n  const stack = new Stack();\n\n  const stackContainer = document.getElementById(\"stack-container\");\n  const inputValue = document.getElementById(\"inputValue\");\n  const pushBtn = document.getElementById(\"pushBtn\");\n  const popBtn = document.getElementById(\"popBtn\");\n  const peekBtn = document.getElementById(\"peekBtn\");\n  const clearBtn = document.getElementById(\"clearBtn\");\n  const message = document.getElementById(\"message\");\n\n  function renderStack() {\n    stackContainer.innerHTML = \"\";\n    const elements = stack.getElements();\n    // We'll display bottom element at bottom, top at top visually\n    // So reverse iterate to stack top at top:\n    for(let i = elements.length -1; i >= 0; i--) {\n      const elDiv = document.createElement(\"div\");\n      elDiv.className = \"stack-element\";\n      if(i === elements.length - 1) {\n        elDiv.classList.add(\"top\");\n      }\n      elDiv.textContent = elements[i];\n      stackContainer.appendChild(elDiv);\n    }\n    popBtn.disabled = stack.isEmpty();\n    peekBtn.disabled = stack.isEmpty();\n    clearBtn.disabled = stack.isEmpty();\n  }\n\n  function showMessage(msg, isError = false) {\n    message.textContent = msg;\n    message.style.color = isError ? \"#c0392b\" : \"#27ae60\";\n  }\n\n  pushBtn.addEventListener(\"click\", () => {\n    const val = inputValue.value.trim();\n    if(val === \"\") {\n      showMessage(\"Please enter a value to push.\", true);\n      return;\n    }\n    stack.push(val);\n    renderStack();\n    showMessage(`Pushed \"${val}\" onto the stack.`);\n    inputValue.value = \"\";\n    inputValue.focus();\n  });\n\n  popBtn.addEventListener(\"click\", () => {\n    const popped = stack.pop();\n    if(popped === null) {\n      showMessage(\"Stack is empty. Cannot pop.\", true);\n      return;\n    }\n    renderStack();\n    showMessage(`Popped \"${popped}\" from the stack.`);\n  });\n\n  peekBtn.addEventListener(\"click\", () => {\n    const top = stack.peek();\n    if(top === null) {\n      showMessage(\"Stack is empty. Nothing to peek.\", true);\n      return;\n    }\n    showMessage(`Top element is \"${top}\".`);\n  });\n\n  clearBtn.addEventListener(\"click\", () => {\n    stack.clear();\n    renderStack();\n    showMessage(\"Stack cleared.\");\n  });\n\n  inputValue.addEventListener(\"keydown\", (event) => {\n    if(event.key === \"Enter\") {\n      pushBtn.click();\n    }\n  });\n\n  // Initial render\n  renderStack();\n  showMessage(\"Stack is empty. Add elements by pushing values.\");\n</script>\n\n</body>\n</html>"
  },
