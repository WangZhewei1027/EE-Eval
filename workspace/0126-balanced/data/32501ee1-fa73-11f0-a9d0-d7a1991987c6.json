    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>K-Nearest Neighbors Demo</title>\n    <style>\n        body { font-family: Arial, sans-serif; }\n        canvas { border: 1px solid black; }\n    </style>\n</head>\n<body>\n    <h1>K-Nearest Neighbors (KNN) Demo</h1>\n    <canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n    <br>\n    <button id=\"classifyButton\">Classify Point</button>\n    <div>\n        <p>Click to add points (red = Class A, blue = Class B).</p>\n        <p>Classify the new point (green) by clicking \"Classify Point\".</p>\n    </div>\n    <script>\n        const canvas = document.getElementById(\"canvas\");\n        const context = canvas.getContext(\"2d\");\n\n        const points = [];\n        const classes = [];\n        let newPoint = null;\n        const k = 3; // Number of neighbors to consider\n\n        canvas.addEventListener(\"click\", (event) => {\n            const rect = canvas.getBoundingClientRect();\n            const x = event.clientX - rect.left;\n            const y = event.clientY - rect.top;\n\n            // Randomly assign color (class) for simplicity\n            const classType = Math.random() > 0.5 ? 'A' : 'B';\n            points.push({ x, y });\n            classes.push(classType);\n            drawPoints();\n        });\n\n        document.getElementById(\"classifyButton\").addEventListener(\"click\", () => {\n            if (newPoint) {\n                classifyNewPoint(newPoint.x, newPoint.y);\n            } else {\n                alert(\"Please add a new point by clicking on the canvas first!\");\n            }\n        });\n\n        canvas.addEventListener(\"dblclick\", (event) => {\n            const rect = canvas.getBoundingClientRect();\n            newPoint = {\n                x: event.clientX - rect.left,\n                y: event.clientY - rect.top\n            };\n            drawNewPoint(newPoint.x, newPoint.y);\n        });\n\n        function drawPoints() {\n            context.clearRect(0, 0, canvas.width, canvas.height);\n            points.forEach((point, index) => {\n                context.fillStyle = classes[index] === 'A' ? 'red' : 'blue';\n                context.beginPath();\n                context.arc(point.x, point.y, 5, 0, Math.PI * 2);\n                context.fill();\n            });\n            if (newPoint) {\n                drawNewPoint(newPoint.x, newPoint.y);\n            }\n        }\n\n        function drawNewPoint(x, y) {\n            context.fillStyle = 'green';\n            context.beginPath();\n            context.arc(x, y, 5, 0, Math.PI * 2);\n            context.fill();\n        }\n\n        function classifyNewPoint(x, y) {\n            const distances = points.map((point, index) => {\n                return {\n                    index: index,\n                    distance: Math.sqrt(Math.pow(point.x - x, 2) + Math.pow(point.y - y, 2))\n                };\n            });\n\n            // Sort by distance\n            distances.sort((a, b) => a.distance - b.distance);\n\n            // Select K nearest neighbors\n            const nearestNeighbors = distances.slice(0, k);\n\n            // Count classes\n            const classCount = {};\n            nearestNeighbors.forEach(neighbor => {\n                const className = classes[neighbor.index];\n                classCount[className] = (classCount[className] || 0) + 1;\n            });\n\n            // Determine majority class\n            const predictedClass = Object.keys(classCount).reduce((a, b) => classCount[a] > classCount[b] ? a : b);\n            alert(`Predicted class for the new point: ${predictedClass}`);\n        }\n    </script>\n</body>\n</html>"
  },
