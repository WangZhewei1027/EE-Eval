    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Load Balancing Simulation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            max-width: 900px;\n            margin: 0 auto;\n            padding: 20px;\n        }\n        .container {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 20px;\n            margin-bottom: 30px;\n        }\n        .server {\n            border: 2px solid #333;\n            border-radius: 8px;\n            padding: 15px;\n            flex: 1;\n            min-width: 200px;\n            background-color: #f5f5f5;\n        }\n        .server h3 {\n            margin-top: 0;\n            color: #333;\n        }\n        .request {\n            background-color: #4CAF50;\n            color: white;\n            padding: 5px 10px;\n            border-radius: 4px;\n            margin: 5px 0;\n            display: inline-block;\n        }\n        .controls {\n            margin: 20px 0;\n            padding: 15px;\n            background-color: #e9e9e9;\n            border-radius: 8px;\n        }\n        button {\n            padding: 8px 16px;\n            margin-right: 10px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n        }\n        button:hover {\n            background-color: #45a049;\n        }\n        .stats {\n            margin-top: 20px;\n            font-weight: bold;\n        }\n        .algorithm-selector {\n            margin: 15px 0;\n        }\n    </style>\n</head>\n<body>\n    <h1>Load Balancing Simulation</h1>\n    \n    <div class=\"controls\">\n        <h3>Controls</h3>\n        <button id=\"addRequest\">Add Request</button>\n        <button id=\"addMultiple\">Add 10 Requests</button>\n        <button id=\"reset\">Reset Simulation</button>\n        \n        <div class=\"algorithm-selector\">\n            <label for=\"algorithm\">Load Balancing Algorithm:</label>\n            <select id=\"algorithm\">\n                <option value=\"roundRobin\">Round Robin</option>\n                <option value=\"leastConnections\">Least Connections</option>\n                <option value=\"random\">Random</option>\n                <option value=\"ipHash\">IP Hash (simulated)</option>\n            </select>\n        </div>\n    </div>\n    \n    <div class=\"container\" id=\"serverContainer\">\n        <!-- Servers will be added here dynamically -->\n    </div>\n    \n    <div class=\"stats\">\n        <p>Total Requests: <span id=\"totalRequests\">0</span></p>\n        <p>Requests per server: <span id=\"requestsPerServer\">-</span></p>\n    </div>\n\n    <div>\n        <h3>How This Works:</h3>\n        <p>This simulation demonstrates how load balancers distribute incoming requests across multiple servers.</p>\n        <p>Try different algorithms to see how they affect request distribution:</p>\n        <ul>\n            <li><strong>Round Robin:</strong> Distributes requests sequentially to each server in order</li>\n            <li><strong>Least Connections:</strong> Sends new requests to the server with the fewest active connections</li>\n            <li><strong>Random:</strong> Randomly selects a server for each request</li>\n            <li><strong>IP Hash:</strong> Uses client IP to consistently route to the same server (simulated with random IPs)</li>\n        </ul>\n    </div>\n\n    <script>\n        // Load Balancer Simulation\n        document.addEventListener('DOMContentLoaded', function() {\n            const serverContainer = document.getElementById('serverContainer');\n            const addRequestBtn = document.getElementById('addRequest');\n            const addMultipleBtn = document.getElementById('addMultiple');\n            const resetBtn = document.getElementById('reset');\n            const algorithmSelect = document.getElementById('algorithm');\n            const totalRequestsSpan = document.getElementById('totalRequests');\n            const requestsPerServerSpan = document.getElementById('requestsPerServer');\n            \n            let servers = [];\n            let requestCounter = 0;\n            let lastServerIndex = -1;\n            \n            // Initialize the simulation with 3 servers\n            function initServers() {\n                serverContainer.innerHTML = '';\n                servers = [];\n                \n                for (let i = 0; i < 3; i++) {\n                    const server = document.createElement('div');\n                    server.className = 'server';\n                    server.id = 'server' + i;\n                    server.innerHTML = `<h3>Server ${i+1}</h3><div class=\"requests-container\"></div>`;\n                    serverContainer.appendChild(server);\n                    \n                    servers.push({\n                        element: server,\n                        requestCount: 0,\n                        requestsContainer: server.querySelector('.requests-container')\n                    });\n                }\n                \n                updateStats();\n            }\n            \n            // Add a request to the load balancer\n            function addRequest() {\n                requestCounter++;\n                totalRequestsSpan.textContent = requestCounter;\n                \n                const algorithm = algorithmSelect.value;\n                let selectedServerIndex;\n                \n                switch(algorithm) {\n                    case 'roundRobin':\n                        lastServerIndex = (lastServerIndex + 1) % servers.length;\n                        selectedServerIndex = lastServerIndex;\n                        break;\n                        \n                    case 'leastConnections':\n                        // Find server with least requests\n                        let minRequests = Infinity;\n                        servers.forEach((server, index) => {\n                            if (server.requestCount < minRequests) {\n                                minRequests = server.requestCount;\n                                selectedServerIndex = index;\n                            }\n                        });\n                        break;\n                        \n                    case 'random':\n                        selectedServerIndex = Math.floor(Math.random() * servers.length);\n                        break;\n                        \n                    case 'ipHash':\n                        // Simulate IP hashing by generating a \"client IP\" and hashing it\n                        const fakeIp = `192.168.${Math.floor(Math.random() * 255)}.${Math.floor(Math.random() * 255)}`;\n                        const hash = stringHash(fakeIp);\n                        selectedServerIndex = hash % servers.length;\n                        break;\n                }\n                \n                // Add request to selected server\n                const selectedServer = servers[selectedServerIndex];\n                selectedServer.requestCount++;\n                \n                const requestElement = document.createElement('div');\n                requestElement.className = 'request';\n                requestElement.textContent = `Req ${requestCounter}`;\n                selectedServer.requestsContainer.appendChild(requestElement);\n                \n                updateStats();\n            }\n            \n            // Simple string hash function for IP hashing simulation\n            function stringHash(str) {\n                let hash = 0;\n                for (let i = 0; i < str.length; i++) {\n                    const char = str.charCodeAt(i);\n                    hash = ((hash << 5) - hash) + char;\n                    hash |= 0; // Convert to 32bit integer\n                }\n                return Math.abs(hash);\n            }\n            \n            // Update statistics display\n            function updateStats() {\n                const counts = servers.map(s => s.requestCount);\n                requestsPerServerSpan.textContent = counts.join(', ');\n            }\n            \n            // Event listeners\n            addRequestBtn.addEventListener('click', addRequest);\n            \n            addMultipleBtn.addEventListener('click', function() {\n                for (let i = 0; i < 10; i++) {\n                    setTimeout(addRequest, i * 200);\n                }\n            });\n            \n            resetBtn.addEventListener('click', function() {\n                requestCounter = 0;\n                lastServerIndex = -1;\n                totalRequestsSpan.textContent = '0';\n                initServers();\n            });\n            \n            algorithmSelect.addEventListener('change', function() {\n                lastServerIndex = -1; // Reset for round robin\n            });\n            \n            // Initialize the simulation\n            initServers();\n        });\n    </script>\n</body>\n</html>"
  },
