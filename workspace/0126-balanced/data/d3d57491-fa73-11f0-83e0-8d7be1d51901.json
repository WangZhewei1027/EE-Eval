  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\"/>\n  <title>Red‑Black Tree — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/>\n  <style>\n    html,body { height:100%; margin:0; font-family: system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial; background:#f6f9fc; color:#111; }\n    .app { display:flex; flex-direction:column; height:100%; padding:14px; box-sizing:border-box; gap:12px; }\n    header { display:flex; gap:12px; align-items:center; }\n    h1 { font-size:18px; margin:0; }\n    .controls { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }\n    .controls input[type=\"number\"] { width:110px; padding:6px; border-radius:6px; border:1px solid #cbd5e1; }\n    button { padding:8px 10px; border-radius:8px; border:1px solid #cbd5e1; background:white; cursor:pointer;}\n    button.primary { background:#2563eb; color:white; border-color:#1e40af; }\n    button.danger { background:#fee2e2; border-color:#fecaca; }\n    .play-controls { display:flex; gap:6px; align-items:center; }\n    .panel { display:flex; gap:12px; align-items:flex-start; }\n    .canvas-wrap { background:white; border-radius:10px; padding:10px; box-shadow:0 6px 18px rgba(20,30,50,0.06); flex:1; min-height:420px; overflow:auto; }\n    .sidebar { width:360px; min-width:260px; max-width:420px; }\n    .legend { display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; }\n    .legend-item { display:flex; gap:6px; align-items:center; font-size:13px; color:#333; }\n    .key { width:18px; height:18px; border-radius:50%; display:inline-block; }\n    .red { background:#ef4444; box-shadow:0 0 0 3px rgba(239,68,68,0.12); }\n    .black { background:#111827; }\n    .highlight { width:18px; height:18px; border-radius:50%; box-sizing:border-box; border:3px solid; display:inline-block; background:transparent; }\n    .hl-z { border-color:#0369a1; }     /* z: blue */\n    .hl-p { border-color:#a16207; }     /* p: amber */\n    .hl-g { border-color:#b91c1c; }     /* g: red-dark */\n    .hl-u { border-color:#16a34a; }     /* u: green */\n    .info { font-size:13px; color:#334155; margin-top:8px; line-height:1.4; }\n    svg { width:100%; height:520px; }\n    .desc { margin-top:8px; padding:8px; background:#f8fafc; border-radius:8px; border:1px solid #e6eef8; font-size:13px; color:#111827; min-height:36px; }\n    footer { font-size:13px; color:#475569; margin-top:6px; }\n    .small { font-size:12px; color:#475569; }\n    .status { margin-left:6px; font-weight:600; color:#0f172a; }\n    .slider { width:120px; }\n  </style>\n</head>\n<body>\n  <div class=\"app\">\n    <header>\n      <h1>Red‑Black Tree — Interactive Demo</h1>\n      <div class=\"controls\" style=\"margin-left:auto;\">\n        <input id=\"valInput\" type=\"number\" placeholder=\"value (integer)\"/>\n        <button id=\"insertBtn\" class=\"primary\" title=\"Insert value\">Insert</button>\n        <button id=\"rndBtn\" title=\"Insert random value\">Insert Random</button>\n        <button id=\"bulkBtn\" title=\"Insert sample sequence\">Insert Sample Sequence</button>\n        <button id=\"clearBtn\" class=\"danger\" title=\"Clear tree\">Clear</button>\n      </div>\n    </header>\n\n    <div class=\"panel\">\n      <div class=\"canvas-wrap\">\n        <svg id=\"svgCanvas\" viewBox=\"0 0 1200 520\" preserveAspectRatio=\"xMidYMin meet\"></svg>\n      </div>\n\n      <aside class=\"sidebar\">\n        <div class=\"play-controls\">\n          <button id=\"prevBtn\" title=\"Previous step\">&larr;</button>\n          <button id=\"nextBtn\" title=\"Next step\">&rarr;</button>\n          <button id=\"playBtn\" title=\"Auto-play\">Play</button>\n          <div class=\"small\">Speed:\n            <input id=\"speed\" type=\"range\" min=\"100\" max=\"2000\" value=\"700\" class=\"slider\"/>\n          </div>\n          <div class=\"small status\" id=\"stepCounter\">Step: 0 / 0</div>\n        </div>\n\n        <div class=\"desc\" id=\"descBox\">No steps yet. Insert values to see the insertion algorithm and balancing (rotations & recoloring).</div>\n\n        <div class=\"legend\">\n          <div class=\"legend-item\"><span class=\"key red\"></span> Red node</div>\n          <div class=\"legend-item\"><span class=\"key black\"></span> Black node</div>\n          <div class=\"legend-item\"><span class=\"highlight hl-z\"></span> z (current)</div>\n          <div class=\"legend-item\"><span class=\"highlight hl-p\"></span> parent</div>\n          <div class=\"legend-item\"><span class=\"highlight hl-g\"></span> grandparent</div>\n          <div class=\"legend-item\"><span class=\"highlight hl-u\"></span> uncle</div>\n        </div>\n\n        <div class=\"info\">\n          This demo implements insertion into a Red‑Black Tree and records every step of the fix-up (cases 1–3).\n          Use Next/Prev to step, or Play to animate. Try sequences that force rotations and recoloring.\n        </div>\n\n        <footer>\n          Algorithm: classic CLRS-style RB-INSERT and RB-INSERT-FIXUP. Duplicates are ignored.\n        </footer>\n      </aside>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // --- Data structures: Node and Tree ---\n  let idCounter = 1;\n  function Node(val){\n    this.id = idCounter++;\n    this.val = val;\n    this.left = null;\n    this.right = null;\n    this.parent = null;\n    this.color = 'B'; // 'R' or 'B'\n  }\n\n  let root = null;\n  let snapshots = []; // each snapshot: {nodes: [...], rootId, highlights: {z,p,g,u}, desc}\n  let currentStep = -1;\n  let playing = false;\n  let playTimer = null;\n\n  // --- UI elements ---\n  const svg = document.getElementById('svgCanvas');\n  const insertBtn = document.getElementById('insertBtn');\n  const valInput = document.getElementById('valInput');\n  const rndBtn = document.getElementById('rndBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const bulkBtn = document.getElementById('bulkBtn');\n  const prevBtn = document.getElementById('prevBtn');\n  const nextBtn = document.getElementById('nextBtn');\n  const playBtn = document.getElementById('playBtn');\n  const descBox = document.getElementById('descBox');\n  const stepCounter = document.getElementById('stepCounter');\n  const speedInput = document.getElementById('speed');\n\n  // --- Utility helpers ---\n  function snapshot(desc, highlights){\n    // deep-copy nodes into array representation (by id)\n    const all = [];\n    const visited = new Set();\n    function traverse(n){\n      if(!n || visited.has(n.id)) return;\n      visited.add(n.id);\n      all.push({\n        id: n.id,\n        val: n.val,\n        color: n.color,\n        left: n.left ? n.left.id : null,\n        right: n.right ? n.right.id : null,\n        parent: n.parent ? n.parent.id : null\n      });\n      traverse(n.left);\n      traverse(n.right);\n    }\n    traverse(root);\n    snapshots.push({\n      nodes: all,\n      rootId: root ? root.id : null,\n      highlights: Object.assign({z:null,p:null,g:null,u:null}, highlights || {}),\n      desc: desc || ''\n    });\n    updateCounter();\n  }\n\n  function updateCounter(){\n    stepCounter.textContent = `Step: ${Math.max(0,currentStep+1)} / ${Math.max(0,snapshots.length)}`;\n  }\n\n  // --- Rotation helpers (modify actual node pointers, and snapshot after each) ---\n  function rotateLeft(x){\n    const y = x.right;\n    if(!y) return;\n    x.right = y.left;\n    if(y.left) y.left.parent = x;\n    y.parent = x.parent;\n    if(!x.parent) {\n      root = y;\n    } else if(x === x.parent.left) {\n      x.parent.left = y;\n    } else {\n      x.parent.right = y;\n    }\n    y.left = x;\n    x.parent = y;\n    snapshot(`rotateLeft(${x.val})`, {z: null, p: null, g: null, u: null});\n  }\n\n  function rotateRight(x){\n    const y = x.left;\n    if(!y) return;\n    x.left = y.right;\n    if(y.right) y.right.parent = x;\n    y.parent = x.parent;\n    if(!x.parent) {\n      root = y;\n    } else if(x === x.parent.right) {\n      x.parent.right = y;\n    } else {\n      x.parent.left = y;\n    }\n    y.right = x;\n    x.parent = y;\n    snapshot(`rotateRight(${x.val})`, {z: null, p: null, g: null, u: null});\n  }\n\n  // --- BST insert (no balancing) ---\n  function bstInsertNode(z){\n    let y = null;\n    let x = root;\n    while(x !== null){\n      y = x;\n      if(z.val < x.val) x = x.left;\n      else x = x.right;\n    }\n    z.parent = y;\n    if(!y) root = z;\n    else if(z.val < y.val) y.left = z;\n    else y.right = z;\n  }\n\n  // --- Main insertion algorithm with fix-up and snapshotting ---\n  function insertValue(val){\n    if(typeof val !== 'number' || !isFinite(val)) return;\n    // check duplicates\n    if(findNode(val)){ alert('Duplicate value ignored.'); return; }\n    const z = new Node(val);\n    z.color = 'R';\n    bstInsertNode(z);\n    snapshot(`Inserted ${val} as red node.`, {z: z.id});\n    insertFixup(z);\n    if(root) root.color = 'B';\n    snapshot(`Insertion complete: root is black.`, {z: null, p:null,g:null,u:null});\n  }\n\n  function insertFixup(z){\n    while(z.parent && z.parent.color === 'R'){\n      const p = z.parent;\n      const g = p.parent;\n      if(!g) break; // safety\n      if(p === g.left){\n        const y = g.right; // uncle\n        snapshot(`Fixup: z=${z.val}, parent=${p.val} (red), uncle=${y ? y.val : 'nil'}.`, {z:z.id, p: p.id, g: g.id, u: y? y.id : null});\n        if(y && y.color === 'R'){\n          // Case 1\n          p.color = 'B';\n          y.color = 'B';\n          g.color = 'R';\n          snapshot(`Case 1: parent and uncle recolored black; grandparent ${g.val} red.`, {z:z.id, p: p.id, g:g.id, u:y.id});\n          z = g;\n        } else {\n          if(z === p.right){\n            // Case 2\n            snapshot(`Case 2: z is right child -> rotateLeft(parent=${p.val}).`, {z:z.id, p:p.id, g:g.id, u: y? y.id : null});\n            z = p;\n            rotateLeft(z);\n          }\n          // Case 3\n          p.color = 'B';\n          g.color = 'R';\n          snapshot(`Case 3: parent ${p.val} black, grandparent ${g.val} red; rotateRight(grandparent).`, {z:z.id, p:p.id, g:g.id});\n          rotateRight(g);\n        }\n      } else {\n        // symmetric: parent is right child\n        const y = g.left; // uncle\n        snapshot(`Fixup: z=${z.val}, parent=${p.val} (red), uncle=${y ? y.val : 'nil'}.`, {z:z.id, p: p.id, g: g.id, u: y? y.id : null});\n        if(y && y.color === 'R'){\n          // Case 1\n          p.color = 'B';\n          y.color = 'B';\n          g.color = 'R';\n          snapshot(`Case 1 (sym): parent and uncle recolored black; grandparent ${g.val} red.`, {z:z.id, p:p.id, g:g.id, u:y.id});\n          z = g;\n        } else {\n          if(z === p.left){\n            // Case 2\n            snapshot(`Case 2 (sym): z is left child -> rotateRight(parent=${p.val}).`, {z:z.id, p:p.id, g:g.id, u: y? y.id : null});\n            z = p;\n            rotateRight(z);\n          }\n          // Case 3\n          p.color = 'B';\n          g.color = 'R';\n          snapshot(`Case 3 (sym): parent ${p.val} black, grandparent ${g.val} red; rotateLeft(grandparent).`, {z:z.id, p:p.id, g:g.id});\n          rotateLeft(g);\n        }\n      }\n    }\n  }\n\n  // --- Search for duplicates ---\n  function findNode(val){\n    let x = root;\n    while(x){\n      if(val === x.val) return x;\n      x = (val < x.val) ? x.left : x.right;\n    }\n    return null;\n  }\n\n  // --- Rendering snapshots ---\n  function renderStep(index){\n    if(index < 0 || index >= snapshots.length) return;\n    currentStep = index;\n    updateCounter();\n    const snap = snapshots[index];\n    descBox.textContent = snap.desc || '';\n    // Build map of nodes\n    const map = new Map();\n    snap.nodes.forEach(n => { map.set(n.id, Object.assign({}, n)); });\n    // Determine depth and compute positions using inorder ordering\n    const childrenMap = new Map();\n    map.forEach(n => childrenMap.set(n.id, {left:n.left, right:n.right, parent:n.parent}));\n    const rootId = snap.rootId;\n    // compute depth\n    const depth = new Map();\n    function setDepth(id, d){\n      if(id == null) return;\n      depth.set(id, d);\n      const n = map.get(id);\n      setDepth(n.left, d+1);\n      setDepth(n.right, d+1);\n    }\n    if(rootId) setDepth(rootId, 0);\n    // inorder indexing\n    let xCounter = 0;\n    const pos = new Map();\n    function inorder(id){\n      if(!id) return;\n      const n = map.get(id);\n      inorder(n.left);\n      const d = depth.get(id) || 0;\n      pos.set(id, {x: xCounter * 70 + 40, y: d * 80 + 40});\n      xCounter++;\n      inorder(n.right);\n    }\n    if(rootId) inorder(rootId);\n    const totalWidth = Math.max(700, xCounter * 70 + 40);\n    svg.setAttribute('viewBox', `0 0 ${totalWidth} 520`);\n    // Clear svg\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n    // Draw edges\n    map.forEach(n => {\n      if(n.left){\n        const p = pos.get(n.id);\n        const c = pos.get(n.left);\n        const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n        line.setAttribute('x1', p.x);\n        line.setAttribute('y1', p.y + 22);\n        line.setAttribute('x2', c.x);\n        line.setAttribute('y2', c.y - 22);\n        line.setAttribute('stroke', '#cbd5e1');\n        line.setAttribute('stroke-width', '2');\n        svg.appendChild(line);\n      }\n      if(n.right){\n        const p = pos.get(n.id);\n        const c = pos.get(n.right);\n        const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n        line.setAttribute('x1', p.x);\n        line.setAttribute('y1', p.y + 22);\n        line.setAttribute('x2', c.x);\n        line.setAttribute('y2', c.y - 22);\n        line.setAttribute('stroke', '#cbd5e1');\n        line.setAttribute('stroke-width', '2');\n        svg.appendChild(line);\n      }\n    });\n    // Draw nodes\n    map.forEach(n => {\n      const p = pos.get(n.id);\n      if(!p) return;\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      // circle\n      const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      circle.setAttribute('cx', p.x);\n      circle.setAttribute('cy', p.y);\n      circle.setAttribute('r', 20);\n      circle.setAttribute('fill', n.color === 'R' ? '#ef4444' : '#0f172a');\n      circle.setAttribute('stroke', '#e6eef8');\n      circle.setAttribute('stroke-width', '2');\n      g.appendChild(circle);\n      // label\n      const text = document.createElementNS('http://www.w3.org/2000/svg','text');\n      text.setAttribute('x', p.x);\n      text.setAttribute('y', p.y + 6);\n      text.setAttribute('font-size', '13');\n      text.setAttribute('fill', '#fff');\n      text.setAttribute('text-anchor', 'middle');\n      text.setAttribute('font-family', 'monospace');\n      text.textContent = String(n.val);\n      g.appendChild(text);\n\n      // highlights for z, p, g, u\n      const hl = snap.highlights || {};\n      if(hl.z === n.id || hl.p === n.id || hl.g === n.id || hl.u === n.id){\n        const ring = document.createElementNS('http://www.w3.org/2000/svg','circle');\n        ring.setAttribute('cx', p.x);\n        ring.setAttribute('cy', p.y);\n        ring.setAttribute('r', 26);\n        ring.setAttribute('fill', 'none');\n        ring.setAttribute('stroke-width', '4');\n        if(hl.z === n.id) ring.setAttribute('stroke', '#0369a1');\n        else if(hl.p === n.id) ring.setAttribute('stroke', '#a16207');\n        else if(hl.g === n.id) ring.setAttribute('stroke', '#b91c1c');\n        else if(hl.u === n.id) ring.setAttribute('stroke', '#16a34a');\n        ring.setAttribute('stroke-opacity', '0.95');\n        svg.appendChild(ring);\n      }\n\n      svg.appendChild(g);\n    });\n  }\n\n  // --- Navigation and playback ---\n  function goToStep(i){\n    if(i < 0) i = 0;\n    if(i >= snapshots.length) i = snapshots.length - 1;\n    if(snapshots.length === 0){ currentStep = -1; updateCounter(); descBox.textContent = 'No steps yet.'; while(svg.firstChild) svg.removeChild(svg.firstChild); return; }\n    renderStep(i);\n  }\n\n  function nextStep(){\n    if(currentStep < snapshots.length - 1) goToStep(currentStep + 1);\n    else { stopPlaying(); }\n  }\n  function prevStep(){\n    if(currentStep > 0) goToStep(currentStep - 1);\n  }\n\n  function play(){\n    if(playing) return;\n    playing = true;\n    playBtn.textContent = 'Pause';\n    const step = () => {\n      if(currentStep < snapshots.length - 1){\n        nextStep();\n        playTimer = setTimeout(step, Number(speedInput.value) || 700);\n      } else {\n        stopPlaying();\n      }\n    };\n    step();\n  }\n\n  function stopPlaying(){\n    playing = false;\n    playBtn.textContent = 'Play';\n    if(playTimer) { clearTimeout(playTimer); playTimer = null; }\n  }\n\n  // --- UI events ---\n  insertBtn.addEventListener('click', ()=>{\n    const v = Number(valInput.value);\n    if(!Number.isFinite(v)){ alert('Enter a valid integer.'); return; }\n    // capture baseline snapshot count before insertion\n    insertValue(Math.trunc(v));\n    // jump to last step\n    goToStep(snapshots.length - 1);\n  });\n\n  rndBtn.addEventListener('click', ()=>{\n    const v = Math.floor(Math.random()*99) + 1;\n    valInput.value = v;\n    insertBtn.click();\n  });\n\n  bulkBtn.addEventListener('click', ()=>{\n    // a sample sequence that forces various cases\n    const seq = [41, 38, 31, 12, 19, 8];\n    // If tree isn't empty, use additional ones\n    const base = root ? [50, 20, 60, 25, 24, 23] : [];\n    const full = base.concat(seq);\n    full.forEach((v,i) => {\n      setTimeout(()=>{ valInput.value = v; insertBtn.click(); }, i * 150);\n    });\n  });\n\n  clearBtn.addEventListener('click', ()=>{\n    root = null;\n    snapshots = [];\n    currentStep = -1;\n    stopPlaying();\n    updateCounter();\n    descBox.textContent = 'Cleared. Insert values to see the insertion algorithm.';\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n  });\n\n  prevBtn.addEventListener('click', ()=>{ stopPlaying(); prevStep(); });\n  nextBtn.addEventListener('click', ()=>{ stopPlaying(); nextStep(); });\n  playBtn.addEventListener('click', ()=>{ if(playing) stopPlaying(); else play(); });\n\n  // allow pressing Enter in input to insert\n  valInput.addEventListener('keydown', (e)=>{\n    if(e.key === 'Enter') insertBtn.click();\n  });\n\n  // initialize with an explanatory snapshot\n  snapshot('Empty tree. Start inserting nodes to watch how the Red-Black Tree balances itself.');\n  goToStep(0);\n\n  // expose a couple of convenience functions in console for advanced users\n  window.rb_demo = {\n    getRoot: ()=>root,\n    snapshots: ()=>snapshots,\n    goToStep: goToStep,\n    insertValue: (v)=>{ valInput.value = v; insertBtn.click(); }\n  };\n})();\n</script>\n</body>\n</html>"
  },
