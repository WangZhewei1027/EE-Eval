    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>CPU Scheduling Simulation</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f4f4f4;\n            margin: 0;\n            padding: 20px;\n        }\n        #simulation {\n            border: 1px solid #ccc;\n            padding: 10px;\n            background: white;\n        }\n        #processTable {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 20px;\n        }\n        #processTable th, #processTable td {\n            border: 1px solid #ccc;\n            padding: 10px;\n            text-align: center;\n        }\n        #processTable th {\n            background-color: #f0f0f0;\n        }\n    </style>\n</head>\n<body>\n\n<h1>CPU Scheduling Simulation</h1>\n<p>Select a scheduling algorithm:</p>\n<select id=\"schedulingAlgorithm\">\n    <option value=\"fcfs\">First-Come, First-Served (FCFS)</option>\n    <option value=\"sjf\">Shortest Job First (SJF)</option>\n    <option value=\"rr\">Round Robin (RR)</option>\n</select>\n<button onclick=\"runScheduling()\">Run Scheduling</button>\n\n<div id=\"simulation\" style=\"display: none;\">\n    <h2>Process Execution Order</h2>\n    <table id=\"processTable\">\n        <thead>\n            <tr>\n                <th>Process</th>\n                <th>Burst Time</th>\n                <th>Completion Time</th>\n            </tr>\n        </thead>\n        <tbody id=\"processBody\">\n        </tbody>\n    </table>\n</div>\n\n<script>\n    const processes = [\n        { id: \"P1\", burstTime: 5 },\n        { id: \"P2\", burstTime: 2 },\n        { id: \"P3\", burstTime: 8 },\n        { id: \"P4\", burstTime: 3 },\n        { id: \"P5\", burstTime: 6 },\n    ];\n\n    function runScheduling() {\n        const algorithm = document.getElementById('schedulingAlgorithm').value;\n        let result;\n\n        switch (algorithm) {\n            case 'fcfs':\n                result = firstComeFirstServe(processes);\n                break;\n            case 'sjf':\n                result = shortestJobFirst([...processes]);\n                break;\n            case 'rr':\n                result = roundRobin(processes, 3);\n                break;\n        }\n\n        displayResults(result);\n    }\n\n    function firstComeFirstServe(processes) {\n        let time = 0;\n        return processes.map(proc => {\n            time += proc.burstTime;\n            return { ...proc, completionTime: time };\n        });\n    }\n\n    function shortestJobFirst(processes) {\n        let time = 0;\n        processes.sort((a, b) => a.burstTime - b.burstTime);\n        return processes.map(proc => {\n            time += proc.burstTime;\n            return { ...proc, completionTime: time };\n        });\n    }\n\n    function roundRobin(processes, quantum) {\n        let time = 0;\n        const queue = [...processes];\n        const completionTimes = [];\n        while (queue.length > 0) {\n            const currentProc = queue.shift();\n            if (currentProc.burstTime > quantum) {\n                time += quantum;\n                currentProc.burstTime -= quantum;\n                queue.push(currentProc);\n            } else {\n                time += currentProc.burstTime;\n                completionTimes.push({ ...currentProc, completionTime: time });\n                currentProc.burstTime = 0;\n            }\n        }\n        return completionTimes;\n    }\n\n    function displayResults(processes) {\n        const processBody = document.getElementById('processBody');\n        processBody.innerHTML = '';\n        processes.forEach(proc => {\n            const row = `<tr>\n                <td>${proc.id}</td>\n                <td>${proc.burstTime}</td>\n                <td>${proc.completionTime}</td>\n            </tr>`;\n            processBody.insertAdjacentHTML('beforeend', row);\n        });\n        document.getElementById('simulation').style.display = 'block';\n    }\n</script>\n\n</body>\n</html>"
