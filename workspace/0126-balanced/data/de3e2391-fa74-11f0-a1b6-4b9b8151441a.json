    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Neural Network Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 0;\n            padding: 20px;\n            background-color: #f5f5f5;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        h1 {\n            color: #333;\n        }\n        .network-container {\n            display: flex;\n            justify-content: space-around;\n            align-items: center;\n            width: 800px;\n            height: 400px;\n            background-color: white;\n            border-radius: 10px;\n            box-shadow: 0 4px 8px rgba(0,0,0,0.1);\n            margin-bottom: 20px;\n            position: relative;\n        }\n        .layer {\n            display: flex;\n            flex-direction: column;\n            justify-content: space-around;\n            height: 80%;\n        }\n        .neuron {\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background-color: #4CAF50;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            color: white;\n            font-weight: bold;\n            position: relative;\n            z-index: 1;\n        }\n        .weights {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: 0;\n        }\n        .weight {\n            position: absolute;\n            background-color: rgba(0,0,0,0.1);\n        }\n        .controls {\n            margin-top: 20px;\n        }\n        button {\n            padding: 10px 15px;\n            background-color: #4CAF50;\n            color: white;\n            border: none;\n            border-radius: 4px;\n            cursor: pointer;\n            margin: 0 5px;\n        }\n        button:hover {\n            background-color: #45a049;\n        }\n        input {\n            padding: 8px;\n            width: 50px;\n        }\n        .input-layer .neuron {\n            background-color: #2196F3;\n        }\n        .output-layer .neuron {\n            background-color: #f44336;\n        }\n        .explanation {\n            max-width: 800px;\n            background-color: white;\n            padding: 20px;\n            border-radius: 10px;\n            box-shadow: 0 2px 5px rgba(0,0,0,0.1);\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Neural Network Visualization</h1>\n    \n    <div class=\"network-container\" id=\"network-container\">\n        <div class=\"layer input-layer\">\n            <div class=\"neuron\">X1</div>\n            <div class=\"neuron\">X2</div>\n            <div class=\"neuron\">X3</div>\n        </div>\n        <div class=\"layer hidden-layer\">\n            <div class=\"neuron\">H1</div>\n            <div class=\"neuron\">H2</div>\n        </div>\n        <div class=\"layer output-layer\">\n            <div class=\"neuron\">Y</div>\n        </div>\n        <div class=\"weights\" id=\"weights\"></div>\n    </div>\n    \n    <div class=\"controls\">\n        <button onclick=\"activateNetwork()\">Run Forward Pass</button>\n        <button onclick=\"randomizeWeights()\">Randomize Weights</button>\n    </div>\n    \n    <div class=\"explanation\">\n        <h2>What is a Neural Network?</h2>\n        <p>A neural network is a series of algorithms that attempts to recognize underlying relationships in a set of data through a process that mimics the way the human brain operates. In this visualization:</p>\n        <ul>\n            <li><strong>Blue neurons (X1-X3)</strong> represent the input layer</li>\n            <li><strong>Green neurons (H1-H2)</strong> represent the hidden layer</li>\n            <li><strong>Red neuron (Y)</strong> represents the output</li>\n            <li>The connecting lines represent weights between neurons</li>\n        </ul>\n        <p>Each neuron's activation is calculated by taking the weighted sum of inputs from the previous layer, then applying an activation function (here we use sigmoid).</p>\n    </div>\n\n    <script>\n        // Visualization variables\n        const animationDuration = 1000; // ms\n        let weights = [];\n        \n        // Initialize the network\n        function initNetwork() {\n            // Input to hidden weights (3 inputs x 2 hidden)\n            weights[0] = [\n                [Math.random() * 2 - 1, Math.random() * 2 - 1],\n                [Math.random() * 2 - 1, Math.random() * 2 - 1],\n                [Math.random() * 2 - 1, Math.random() * 2 - 1]\n            ];\n            \n            // Hidden to output weights (2 hidden x 1 output)\n            weights[1] = [\n                [Math.random() * 2 - 1],\n                [Math.random() * 2 - 1]\n            ];\n            \n            drawWeights();\n        }\n        \n        // Draw the weight connections between neurons\n        function drawWeights() {\n            const container = document.getElementById('weights');\n            container.innerHTML = '';\n            \n            const layers = document.querySelectorAll('.layer');\n            \n            // Draw input to hidden weights\n            const inputs = layers[0].querySelectorAll('.neuron');\n            const hidden = layers[1].querySelectorAll('.neuron');\n            \n            inputs.forEach((input, i) => {\n                hidden.forEach((h, j) => {\n                    const weight = weights[0][i][j];\n                    const line = document.createElement('div');\n                    line.className = 'weight';\n                    \n                    // Position the line between neurons\n                    const startX = input.offsetLeft + input.offsetWidth/2;\n                    const startY = input.offsetTop + input.offsetHeight/2;\n                    const endX = h.offsetLeft - layers[1].offsetLeft + h.offsetWidth/2;\n                    const endY = h.offsetTop - layers[1].offsetTop + h.offsetHeight/2;\n                    \n                    // Line styling based on weight value\n                    const lineWidth = Math.abs(weight) * 3 + 1;\n                    const color = weight > 0 ? 'rgba(76, 175, 80, 0.5)' : 'rgba(244, 67, 54, 0.5)';\n                    \n                    line.style.width = `${Math.sqrt(Math.pow(endX - startX, 2) + Math.pow(endY - startY, 2))}px`;\n                    line.style.height = `${lineWidth}px`;\n                    line.style.left = `${startX}px`;\n                    line.style.top = `${startY - lineWidth/2}px`;\n                    line.style.backgroundColor = color;\n                    \n                    // Angle calculation\n                    const angle = Math.atan2(endY - startY, endX - startX) * 180 / Math.PI;\n                    line.style.transform = `rotate(${angle}deg)`;\n                    line.style.transformOrigin = '0 0';\n                    \n                    container.appendChild(line);\n                });\n            });\n            \n            // Draw hidden to output weights\n            const output = layers[2].querySelectorAll('.neuron');\n            \n            hidden.forEach((h, i) => {\n                output.forEach((out, j) => {\n                    const weight = weights[1][i][j];\n                    const line = document.createElement('div');\n                    line.className = 'weight';\n                    \n                    const startX = h.offsetLeft - layers[1].offsetLeft + h.offsetWidth/2;\n                    const startY = h.offsetTop - layers[1].offsetTop + h.offsetHeight/2;\n                    const endX = out.offsetLeft - layers[2].offsetLeft + out.offsetWidth/2;\n                    const endY = out.offsetTop - layers[2].offsetTop + out.offsetHeight/2;\n                    \n                    const lineWidth = Math.abs(weight) * 3 + 1;\n                    const color = weight > 0 ? 'rgba(76, 175, 80, 0.5)' : 'rgba(244, 67, 54, 0.5)';\n                    \n                    line.style.width = `${Math.sqrt(Math.pow(endX - startX, 2) + Math.pow(endY - startY, 2))}px`;\n                    line.style.height = `${lineWidth}px`;\n                    line.style.left = `${startX}px`;\n                    line.style.top = `${startY - lineWidth/2}px`;\n                    line.style.backgroundColor = color;\n                    \n                    const angle = Math.atan2(endY - startY, endX - startX) * 180 / Math.PI;\n                    line.style.transform = `rotate(${angle}deg)`;\n                    line.style.transformOrigin = '0 0';\n                    \n                    container.appendChild(line);\n                });\n            });\n        }\n        \n        // Sigmoid activation function\n        function sigmoid(x) {\n            return 1 / (1 + Math.exp(-x));\n        }\n        \n        // Simulate a forward pass through the network\n        function activateNetwork() {\n            const layers = document.querySelectorAll('.layer');\n            \n            // Reset all neuron activations\n            layers.forEach(layer => {\n                const neurons = layer.querySelectorAll('.neuron');\n                neurons.forEach(neuron => {\n                    neuron.style.transform = 'scale(1)';\n                    neuron.style.backgroundColor = neuron.classList.contains('input-layer') ? '#2196F3' : \n                                                  neuron.classList.contains('output-layer') ? '#f44336' : '#4CAF50';\n                });\n            });\n            \n            // Random input values\n            const inputs = [Math.random(), Math.random(), Math.random()];\n            const inputNeurons = layers[0].querySelectorAll('.neuron');\n            \n            // Animate input neurons\n            inputNeurons.forEach((neuron, i) => {\n                setTimeout(() => {\n                    neuron.style.transform = `scale(${1 + inputs[i]*0.5})`;\n                    neuron.textContent = inputs[i].toFixed(2);\n                }, 100);\n            });\n            \n            // Calculate hidden layer activations\n            setTimeout(() => {\n                const hiddenNeurons = layers[1].querySelectorAll('.neuron');\n                const hiddenActivations = [0, 0];\n                \n                // Weighted sum for each hidden neuron\n                hiddenActivations[0] = sigmoid(\n                    inputs[0] * weights[0][0][0] + \n                    inputs[1] * weights[0][1][0] + \n                    inputs[2] * weights[0][2][0]\n                );\n                \n                hiddenActivations[1] = sigmoid(\n                    inputs[0] * weights[0][0][1] + \n                    inputs[1] * weights[0][1][1] + \n                    inputs[2] * weights[0][2][1]\n                );\n                \n                // Animate hidden neurons\n                hiddenNeurons.forEach((neuron, i) => {\n                    setTimeout(() => {\n                        neuron.style.transform = `scale(${1 + hiddenActivations[i]*0.5})`;\n                        neuron.textContent = hiddenActivations[i].toFixed(2);\n                        neuron.style.backgroundColor = `rgb(${Math.floor(76 + hiddenActivations[i]*(255-76))}, \n                                                           ${Math.floor(175 - hiddenActivations[i]*(175-0))}, \n                                                           ${Math.floor(80 - hiddenActivations[i]*(80-0))})`;\n                    }, 100 * (i + 1));\n                });\n                \n                // Calculate output activation\n                setTimeout(() => {\n                    const outputNeuron = layers[2].querySelector('.neuron');\n                    const outputActivation = sigmoid(\n                        hiddenActivations[0] * weights[1][0][0] + \n                        hiddenActivations[1] * weights[1][1][0]\n                    );\n                    \n                    setTimeout(() => {\n                        outputNeuron.style.transform = `scale(${1 + outputActivation*0.5})`;\n                        outputNeuron.textContent = outputActivation.toFixed(2);\n                        outputNeuron.style.backgroundColor = `rgb(${Math.floor(244 - outputActivation*(244-76))}, \n                                                               ${Math.floor(67 + outputActivation*(175-67))}, \n                                                               ${Math.floor(54 - outputActivation*(54-0))})`;\n                    }, 200);\n                }, 300);\n            }, 400);\n        }\n        \n        // Randomize all weights\n        function randomizeWeights() {\n            weights[0] = [\n                [Math.random() * 2 - 1, Math.random() * 2 - 1],\n                [Math.random() * 2 - 1, Math.random() * 2 - 1],\n                [Math.random() * 2 - 1, Math.random() * 2 - 1]\n            ];\n            \n            weights[1] = [\n                [Math.random() * 2 - 1],\n                [Math.random() * 2 - 1]\n            ];\n            \n            drawWeights();\n        }\n        \n        // Initialize on load\n        window.onload = function() {\n            initNetwork();\n        };\n    </script>\n</body>\n</html>"
