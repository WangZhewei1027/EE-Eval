    "content": "<html>\n<head>\n    <title>Set Demo</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>Set Demo</h1>\n    <p id=\"set-demo\"></p>\n    <script>\n        let mySet = new Set([1, 2, 3, 4, 5, 6]);\n        console.log(\"Initial Set:\", Array.from(mySet));\n        \n        mySet.add(7);\n        console.log(\"After adding 7:\", Array.from(mySet));\n        \n        mySet.delete(3);\n        console.log(\"After deleting 3:\", Array.from(mySet));\n        \n        console.log(\"Set contains 3:\", mySet.has(3));\n        \n        mySet.clear();\n        console.log(\"After clearing Set:\", Array.from(mySet));\n        \n        mySet.add(7);\n        mySet.add(8);\n        console.log(\"After adding 8:\", Array.from(mySet));\n        \n        console.log(\"Set contains 7:\", mySet.has(7));\n        \n        console.log(\"Set contains 8:\", mySet.has(8));\n        \n        mySet.delete(8);\n        console.log(\"After deleting 8:\", Array.from(mySet));\n        \n        console.log(\"Set contains 8:\", mySet.has(8));\n        \n        mySet.delete(3);\n        mySet.delete(4);\n        console.log(\"After deleting 3 and 4:\", Array.from(mySet));\n        \n        console.log(\"Set contains 3 and 4:\", mySet.has(3) && mySet.has(4));\n    </script>\n</body>\n</html>"
