    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Depth-First Search (DFS) Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 0;\n    overflow: hidden;\n    display: flex;\n    flex-direction: column;\n    height: 100vh;\n    background: #1e1e1e;\n    color: #ddd;\n  }\n  h1 {\n    text-align: center;\n    margin: 1rem 0 0.5rem 0;\n  }\n  #container {\n    flex: 1;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    background: #2b2b2b;\n  }\n  svg {\n    background: #333;\n    border-radius: 8px;\n  }\n  .node {\n    cursor: pointer;\n    stroke: #aaa;\n    stroke-width: 2px;\n    fill: #555;\n    transition: fill 0.3s, stroke 0.3s;\n  }\n  .node.visited {\n    fill: #4caf50;\n    stroke: #81c784;\n  }\n  .node.current {\n    fill: #2196f3;\n    stroke: #64b5f6;\n  }\n  .node.start {\n    fill: #ff9800;\n    stroke: #ffb74d;\n  }\n  .edge {\n    stroke: #999;\n    stroke-width: 2px;\n  }\n  .edge.visited {\n    stroke: #4caf50;\n    stroke-width: 3px;\n  }\n  #controls {\n    padding: 0.6rem;\n    background: #222;\n    display: flex;\n    justify-content: center;\n    gap: 1rem;\n  }\n  button {\n    background: #444;\n    border: none;\n    color: #ddd;\n    padding: 0.5rem 1rem;\n    font-size: 1rem;\n    border-radius: 4px;\n    cursor: pointer;\n    transition: background-color 0.3s;\n  }\n  button:hover:not(:disabled) {\n    background: #666;\n  }\n  button:disabled {\n    opacity: 0.5;\n    cursor: default;\n  }\n  #legend {\n    margin: 1rem auto;\n    width: 90%;\n    max-width: 600px;\n    font-size: 0.9rem;\n    display: flex;\n    justify-content: space-around;\n  }\n  #legend div {\n    display: flex;\n    align-items: center;\n    gap: 0.4rem;\n  }\n  #legend .box {\n    width: 18px;\n    height: 18px;\n    border-radius: 4px;\n    border: 2px solid #aaa;\n  }\n  #legend .visited {\n    background: #4caf50;\n    border-color: #81c784;\n  }\n  #legend .current {\n    background: #2196f3;\n    border-color: #64b5f6;\n  }\n  #legend .start {\n    background: #ff9800;\n    border-color: #ffb74d;\n  }\n</style>\n</head>\n<body>\n<h1>Depth-First Search (DFS) Visualization</h1>\n<div id=\"container\">\n<svg width=\"800\" height=\"600\" viewBox=\"0 0 800 600\" id=\"graph\"></svg>\n</div>\n<div id=\"controls\">\n  <button id=\"startBtn\">Start DFS</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n<div id=\"legend\">\n  <div><div class=\"box start\"></div> Start Node</div>\n  <div><div class=\"box current\"></div> Current Node</div>\n  <div><div class=\"box visited\"></div> Visited Node / Edge</div>\n</div>\n\n<script>\n// Graph Data: adjacency list with node positions for visualization\nconst nodes = [\n  { id: 'A', x: 100, y: 100 },\n  { id: 'B', x: 300, y: 100 },\n  { id: 'C', x: 500, y: 100 },\n  { id: 'D', x: 700, y: 100 },\n  { id: 'E', x: 200, y: 250 },\n  { id: 'F', x: 400, y: 250 },\n  { id: 'G', x: 600, y: 250 },\n  { id: 'H', x: 150, y: 400 },\n  { id: 'I', x: 350, y: 400 },\n  { id: 'J', x: 550, y: 400 },\n  { id: 'K', x: 700, y: 400 }\n];\n\n// adjacency list edges: undirected graph\nconst edges = [\n  ['A','B'], ['A','E'], ['B','C'], ['B','F'], ['C','D'], ['C','G'],\n  ['E','F'], ['E','H'], ['F','G'], ['F','I'], ['G','J'], ['D','K'],\n  ['J','K']\n];\n\n// Create lookup maps\nconst nodeById = new Map(nodes.map(n => [n.id, n]));\nconst adjacency = new Map();\nnodes.forEach(n => adjacency.set(n.id, []));\nedges.forEach(([u,v]) => {\n  adjacency.get(u).push(v);\n  adjacency.get(v).push(u);\n});\n\n// SVG Elements\nconst svg = document.getElementById('graph');\n\n// Draw edges as lines\nconst edgeElements = [];\nedges.forEach(([u,v], i) => {\n  const n1 = nodeById.get(u);\n  const n2 = nodeById.get(v);\n  const line = document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n  line.setAttribute('x1', n1.x);\n  line.setAttribute('y1', n1.y);\n  line.setAttribute('x2', n2.x);\n  line.setAttribute('y2', n2.y);\n  line.setAttribute('class', 'edge');\n  line.dataset.nodes = JSON.stringify([u,v]);\n  svg.appendChild(line);\n  edgeElements.push(line);\n});\n\n// Draw nodes as circles with labels\nconst nodeElements = new Map();\nnodes.forEach(n => {\n  const g = document.createElementNS(\"http://www.w3.org/2000/svg\", \"g\");\n  g.classList.add('node');\n  g.dataset.id = n.id;\n  g.setAttribute('transform', `translate(${n.x},${n.y})`);\n  const circle = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n  circle.setAttribute('r', 20);\n  circle.setAttribute('class', 'node-circle');\n  g.appendChild(circle);\n  const text = document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n  text.textContent = n.id;\n  text.setAttribute('text-anchor', 'middle');\n  text.setAttribute('dy', '0.35em');\n  text.setAttribute('fill', '#ddd');\n  text.setAttribute('font-weight', 'bold');\n  g.appendChild(text);\n  svg.appendChild(g);\n  nodeElements.set(n.id, g);\n});\n\n// Visual state helpers\nfunction setNodeState(id, state) {\n  const el = nodeElements.get(id);\n  if (!el) return;\n  el.classList.remove('visited', 'current', 'start');\n  if(state) el.classList.add(state);\n}\n\nfunction setEdgeVisited(u, v) {\n  const key1 = JSON.stringify([u,v]);\n  const key2 = JSON.stringify([v,u]);\n  // find edge line with matching nodes\n  for(const line of edgeElements){\n    const nodesArr = JSON.parse(line.dataset.nodes);\n    if (\n      (nodesArr[0] === u && nodesArr[1] === v) ||\n      (nodesArr[1] === u && nodesArr[0] === v)\n    ) {\n      line.classList.add('visited');\n      break;\n    }\n  }\n}\n\nfunction resetVisualization(){\n  nodeElements.forEach((el) => el.classList.remove('visited', 'current', 'start'));\n  edgeElements.forEach(l => l.classList.remove('visited'));\n}\n\n// DFS Algorithm Visualization\nconst startNode = 'A';\nlet visited = new Set();\nlet stack = [];\nlet animationInterval = null;\nlet animationSpeed = 600; // ms between steps\n\nfunction dfsStep() {\n  if(stack.length === 0) {\n    // end animation\n    clearInterval(animationInterval);\n    animationInterval = null;\n    buttons.start.disabled = false;\n    buttons.reset.disabled = false;\n    return;\n  }\n  // Current node from top of stack\n  const current = stack[stack.length - 1];\n\n  setNodeState(current, 'current');\n\n  // Delay previous current if any\n  if(dfsStep.prevNode && dfsStep.prevNode !== current){\n    setNodeState(dfsStep.prevNode, 'visited');\n  }\n  dfsStep.prevNode = current;\n  \n  let foundUnvisited = false;\n  for (let neighbor of adjacency.get(current)) {\n    if (!visited.has(neighbor)) {\n      visited.add(neighbor);\n      stack.push(neighbor);\n      setEdgeVisited(current, neighbor);\n      foundUnvisited = true;\n      break;\n    }\n  }\n  if(!foundUnvisited) {\n    stack.pop();\n    setNodeState(current, 'visited'); // done here\n  }\n}\n\ndfsStep.prevNode = null;\n\n// Controls and start/reset logic\nconst buttons = {\n  start: document.getElementById('startBtn'),\n  reset: document.getElementById('resetBtn')\n};\n\nbuttons.start.addEventListener('click', () => {\n  resetVisualization();\n  visited = new Set();\n  stack = [];\n  setNodeState(startNode, 'start');\n  visited.add(startNode);\n  stack.push(startNode);\n\n  buttons.start.disabled = true;\n  buttons.reset.disabled = true;\n\n  animationInterval = setInterval(dfsStep, animationSpeed);\n});\n\nbuttons.reset.addEventListener('click', () => {\n  if(animationInterval) {\n    clearInterval(animationInterval);\n    animationInterval = null;\n  }\n  resetVisualization();\n  buttons.start.disabled = false;\n  buttons.reset.disabled = true;\n  dfsStep.prevNode = null;\n});\n\n// Initialize with reset state\nbuttons.reset.disabled = true;\n\n</script>\n</body>\n</html>"
