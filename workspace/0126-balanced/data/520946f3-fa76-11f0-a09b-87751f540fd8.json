    "content": "<html>\n<head>\n    <title>Floyd-Warshall Algorithm</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <h1>Floyd-Warshall Algorithm</h1>\n    <p>This algorithm is used to find the shortest path between all pairs of nodes in a weighted graph.</p>\n    <button id=\"run-floyd-warshall\">Run Floyd-Warshall Algorithm</button>\n    <div id=\"graph\"></div>\n\n    <script>\n        const runFloydWarshall = async () => {\n            const graph = {\n                'A': { 'B': 2, 'C': 3 },\n                'B': { 'A': 2, 'B': 4, 'C': 1 },\n                'C': { 'A': 3, 'B': 1, 'C': 2 }\n            };\n\n            const shortestDistances = {};\n\n            for (const node in graph) {\n                shortestDistances[node] = {};\n                for (const neighbor in graph[node]) {\n                    shortestDistances[node][neighbor] = Infinity;\n                }\n            }\n\n            for (const node in graph) {\n                for (const neighbor in graph[node]) {\n                    for (const otherNeighbor in graph[node]) {\n                        if (neighbor !== otherNeighbor && graph[node][neighbor] + graph[neighbor][otherNeighbor] < shortestDistances[node][otherNeighbor]) {\n                            shortestDistances[node][otherNeighbor] = graph[node][neighbor] + graph[neighbor][otherNeighbor];\n                        }\n                    }\n                }\n            }\n\n            const result = {};\n\n            for (const node in graph) {\n                result[node] = {};\n                for (const neighbor in graph[node]) {\n                    result[node][neighbor] = shortestDistances[node][neighbor];\n                }\n            }\n\n            console.log(\"Shortest Distances:\");\n            console.log(result);\n\n            const matrix = Object.values(result).map(row => row.map(distance => distance));\n            const matrixHtml = matrix.map(row => row.join(\"<tr><td>\" + row.join(\" | \") + \"</td></tr>\"));\n\n            document.getElementById(\"graph\").innerHTML = matrixHtml.join(\"\");\n        };\n\n        runFloydWarshall();\n    </script>\n</body>\n</html>"
