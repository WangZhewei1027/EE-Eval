  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Jump Search - Interactive Demo</title>\n<style>\n  :root{\n    --bg:#0f1724;\n    --card:#0b1220;\n    --accent:#3b82f6;\n    --muted:#94a3b8;\n    --good:#10b981;\n    --bad:#ef4444;\n    --glass: rgba(255,255,255,0.03);\n    font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n  }\n  html,body{height:100%;margin:0;background:linear-gradient(180deg,#071122 0%, #081427 60%);color:#e6eef8;}\n  .wrap{max-width:1100px;margin:28px auto;padding:20px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));box-shadow:0 10px 30px rgba(2,6,23,0.7);}\n  header{display:flex;align-items:center;gap:18px;margin-bottom:18px}\n  h1{font-size:20px;margin:0}\n  p.lead{margin:0;color:var(--muted);font-size:13px}\n  .content{display:grid;grid-template-columns:1fr 360px;gap:18px;margin-top:14px}\n  .panel{background:var(--card);padding:12px;border-radius:10px;box-shadow:inset 0 1px 0 rgba(255,255,255,0.02)}\n  .controls{display:grid;gap:8px}\n  label{font-size:12px;color:var(--muted);display:flex;justify-content:space-between;align-items:center}\n  .row{display:flex;gap:8px;align-items:center}\n  input[type=range]{width:100%}\n  button{background:linear-gradient(180deg,var(--accent),#1e63d6);border:0;color:white;padding:8px 10px;border-radius:8px;cursor:pointer}\n  button.secondary{background:transparent;border:1px solid rgba(255,255,255,0.06)}\n  .controls .small{font-size:13px;color:var(--muted)}\n  .array-wrap{padding:12px;border-radius:10px;display:flex;flex-direction:column;gap:10px}\n  .array{display:flex;flex-wrap:wrap;gap:6px;padding:6px;background:var(--glass);border-radius:8px;justify-content:flex-start}\n  .cell{min-width:44px;padding:10px;border-radius:8px;background:rgba(255,255,255,0.03);text-align:center;color:#dbeafe;font-weight:600;box-shadow:inset 0 -6px 10px rgba(2,6,23,0.4)}\n  .cell.small{min-width:36px;padding:8px;font-size:13px}\n  .cell.checked{background:linear-gradient(180deg,#18344a, #0e2a3f);box-shadow:0 4px 10px rgba(2,6,23,0.6)}\n  .cell.jump{outline:3px solid rgba(59,130,246,0.3);box-shadow:0 8px 18px rgba(59,130,246,0.12)}\n  .cell.block{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(17,24,39,0.12));outline:2px dashed rgba(255,255,255,0.02)}\n  .cell.found{background:linear-gradient(180deg,#16a34a,#059669);box-shadow:0 10px 30px rgba(5,150,105,0.15)}\n  .info{display:flex;gap:8px;flex-wrap:wrap;align-items:center}\n  .chip{background:rgba(255,255,255,0.03);padding:6px 8px;border-radius:8px;color:var(--muted);font-size:13px}\n  .stats{display:flex;gap:10px;align-items:center;flex-wrap:wrap}\n  .code{background:#041228;padding:10px;border-radius:8px;color:#cfe9ff;font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\",monospace;font-size:13px;line-height:1.5;overflow:auto;max-height:300px}\n  .code-line{display:block;padding:2px 6px;border-radius:6px}\n  .code-line.current{background:linear-gradient(90deg, rgba(59,130,246,0.14), rgba(59,130,246,0.06));color:#e6f0ff}\n  .small-muted{font-size:12px;color:var(--muted)}\n  footer{margin-top:12px;font-size:12px;color:var(--muted)}\n  .target-input{display:flex;gap:6px;align-items:center}\n  .target-input input[type=number]{width:100px;padding:6px;border-radius:8px;border:0;background:rgba(255,255,255,0.02);color:inherit}\n  .legend{display:flex;gap:8px;align-items:center;margin-top:6px}\n  .legend .box{width:12px;height:12px;border-radius:3px;display:inline-block}\n  .legend .text{font-size:12px;color:var(--muted)}\n  .legend .jump{background:rgba(59,130,246,0.9)}\n  .legend .checked{background:linear-gradient(180deg,#18344a,#0e2a3f)}\n  .legend .found{background:#10b981}\n  .btn-row{display:flex;gap:8px;flex-wrap:wrap}\n  .muted-note{font-size:13px;color:var(--muted)}\n  @media (max-width:920px){ .content{grid-template-columns:1fr} }\n</style>\n</head>\n<body>\n<div class=\"wrap\" role=\"application\" aria-label=\"Jump Search Demonstration\">\n  <header>\n    <div>\n      <h1>Jump Search — Interactive Visualization</h1>\n      <p class=\"lead\">Explore how Jump Search locates a target in a sorted array by jumping fixed steps and then performing a linear scan within a block.</p>\n    </div>\n  </header>\n\n  <div class=\"content\">\n    <main class=\"panel\" aria-live=\"polite\">\n      <div class=\"array-wrap\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center;\">\n          <div class=\"info\">\n            <div class=\"chip\">Array length: <span id=\"len\">25</span></div>\n            <div class=\"chip\">Jump size: <span id=\"jumpSizeLabel\">5</span></div>\n            <div class=\"chip\">Comparisons: <strong id=\"comp\">0</strong></div>\n            <div class=\"chip\">Status: <strong id=\"status\">Idle</strong></div>\n          </div>\n          <div class=\"controls\">\n            <div class=\"row small-muted\">\n              <div class=\"muted-note\">Speed</div>\n              <input id=\"speed\" type=\"range\" min=\"50\" max=\"1200\" value=\"350\">\n            </div>\n          </div>\n        </div>\n\n        <div class=\"array\" id=\"array\" aria-hidden=\"false\" style=\"margin-top:8px;\"></div>\n\n        <div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:8px;\">\n          <div class=\"legend\">\n            <span class=\"box jump\"></span><span class=\"text\">Jump position</span>\n            <span style=\"width:8px\"></span>\n            <span class=\"box checked\"></span><span class=\"text\">Linear-checked</span>\n            <span style=\"width:8px\"></span>\n            <span class=\"box found\"></span><span class=\"text\">Found</span>\n          </div>\n          <div class=\"small-muted\">Array is sorted ascending with unique values</div>\n        </div>\n      </div>\n\n      <div style=\"display:flex;gap:10px;margin-top:12px;align-items:center;flex-wrap:wrap\">\n        <div class=\"target-input\">\n          <label class=\"small-muted\" for=\"target\">Target value</label>\n          <input id=\"target\" type=\"number\" aria-label=\"Target value\">\n          <button id=\"pickRandom\" class=\"secondary\">Pick Random</button>\n        </div>\n\n        <div style=\"display:flex;gap:6px;\">\n          <button id=\"generate\" class=\"secondary\">Generate Array</button>\n          <button id=\"start\">Start</button>\n          <button id=\"step\" class=\"secondary\">Step</button>\n          <button id=\"pause\" class=\"secondary\">Pause</button>\n          <button id=\"reset\" class=\"secondary\">Reset</button>\n        </div>\n      </div>\n\n      <div style=\"margin-top:12px;display:flex;gap:8px;align-items:center;flex-wrap:wrap\">\n        <label style=\"display:flex;gap:8px;align-items:center;\">\n          <span class=\"small-muted\">Array Size</span>\n          <input id=\"size\" type=\"range\" min=\"10\" max=\"80\" value=\"25\">\n        </label>\n        <label style=\"display:flex;gap:8px;align-items:center;\">\n          <span class=\"small-muted\">Jump size (0 = sqrt(n))</span>\n          <input id=\"jump\" type=\"range\" min=\"0\" max=\"30\" value=\"5\">\n        </label>\n        <label style=\"display:flex;gap:8px;align-items:center;\">\n          <input id=\"autopick\" type=\"checkbox\" checked>\n          <span class=\"small-muted\">Auto-pick target from array</span>\n        </label>\n      </div>\n\n      <div style=\"margin-top:12px;display:flex;gap:10px;align-items:center;flex-wrap:wrap\">\n        <div class=\"stats\">\n          <div class=\"chip\">Algorithm: Jump Search</div>\n          <div class=\"chip\">Worst: O(√n) jumps + O(√n) linear</div>\n          <div class=\"chip\">Average: O(√n)</div>\n        </div>\n      </div>\n\n      <div style=\"margin-top:12px;\">\n        <div class=\"code\" id=\"code\">\n          <div id=\"line1\" class=\"code-line\">function jumpSearch(arr, target) {</div>\n          <div id=\"line2\" class=\"code-line\">  const n = arr.length;</div>\n          <div id=\"line3\" class=\"code-line\">  const step = Math.floor(Math.sqrt(n)); // jump size</div>\n          <div id=\"line4\" class=\"code-line\">  let prev = 0;</div>\n          <div id=\"line5\" class=\"code-line\">  while (arr[Math.min(step, n)-1] < target) {</div>\n          <div id=\"line6\" class=\"code-line\">    prev = step;</div>\n          <div id=\"line7\" class=\"code-line\">    step += Math.floor(Math.sqrt(n));</div>\n          <div id=\"line8\" class=\"code-line\">    if (prev >= n) return -1;</div>\n          <div id=\"line9\" class=\"code-line\">  }</div>\n          <div id=\"line10\" class=\"code-line\">  // linear search in block</div>\n          <div id=\"line11\" class=\"code-line\">  for (let i = prev; i < Math.min(step, n); i++) {</div>\n          <div id=\"line12\" class=\"code-line\">    if (arr[i] === target) return i;</div>\n          <div id=\"line13\" class=\"code-line\">  }</div>\n          <div id=\"line14\" class=\"code-line\">  return -1;</div>\n          <div id=\"line15\" class=\"code-line\">}</div>\n        </div>\n      </div>\n    </main>\n\n    <aside class=\"panel\" aria-hidden=\"false\">\n      <div style=\"display:flex;flex-direction:column;gap:12px;\">\n        <div>\n          <strong>Controls</strong>\n          <p class=\"small-muted\" style=\"margin-top:6px\">Adjust parameters and step through the algorithm. Use \"Start\" for autoplay. \"Step\" advances one action.</p>\n        </div>\n\n        <div>\n          <label>Array Size: <strong id=\"sizeLabel\">25</strong></label>\n          <input id=\"sizeSide\" type=\"range\" min=\"10\" max=\"80\" value=\"25\">\n        </div>\n\n        <div>\n          <label>Jump Size (0 = auto sqrt): <strong id=\"jumpLabel\">5</strong></label>\n          <input id=\"jumpSide\" type=\"range\" min=\"0\" max=\"30\" value=\"5\">\n        </div>\n\n        <div>\n          <label>Animation speed (ms delay): <strong id=\"speedLabel\">350</strong></label>\n          <input id=\"speedSide\" type=\"range\" min=\"50\" max=\"1200\" value=\"350\">\n        </div>\n\n        <div>\n          <strong>Result</strong>\n          <div style=\"margin-top:6px\" class=\"small-muted\">Index: <span id=\"resIndex\">-</span> &nbsp; Value: <span id=\"resValue\">-</span></div>\n        </div>\n\n        <div>\n          <strong>Notes</strong>\n          <p class=\"small-muted\" style=\"margin-top:6px\">Jump Search works on sorted arrays. Best choose jump ≈ √n for optimal comparisons.</p>\n        </div>\n      </div>\n    </aside>\n  </div>\n\n  <footer>\n    Tip: Try different jump sizes and array lengths to see how the number of comparisons changes.\n  </footer>\n</div>\n\n<script>\n(() => {\n  // DOM elements\n  const arrayEl = document.getElementById('array');\n  const lenEl = document.getElementById('len');\n  const compEl = document.getElementById('comp');\n  const statusEl = document.getElementById('status');\n  const jumpSizeLabel = document.getElementById('jumpSizeLabel');\n  const sizeSlider = document.getElementById('size');\n  const sizeLabel = document.getElementById('sizeLabel');\n  const sizeSide = document.getElementById('sizeSide');\n  const jumpSlider = document.getElementById('jump');\n  const jumpLabel = document.getElementById('jumpLabel');\n  const jumpSide = document.getElementById('jumpSide');\n  const speed = document.getElementById('speed');\n  const speedSide = document.getElementById('speedSide');\n  const speedLabel = document.getElementById('speedLabel');\n  const generateBtn = document.getElementById('generate');\n  const startBtn = document.getElementById('start');\n  const pauseBtn = document.getElementById('pause');\n  const stepBtn = document.getElementById('step');\n  const resetBtn = document.getElementById('reset');\n  const pickRandom = document.getElementById('pickRandom');\n  const targetInput = document.getElementById('target');\n  const autopick = document.getElementById('autopick');\n  const compCountEl = document.getElementById('comp');\n  const resIndex = document.getElementById('resIndex');\n  const resValue = document.getElementById('resValue');\n  const lenDisplay = document.getElementById('len');\n  const codeLines = Array.from(document.querySelectorAll('.code-line'));\n\n  // state\n  let arr = [];\n  let n = 25;\n  let jumpSize = 5;\n  let running = false;\n  let paused = false;\n  let delay = 350;\n  let comparisons = 0;\n  let gen = null;\n  let animTimer = null;\n  let lastAction = null;\n\n  // helpers\n  function randInt(min, max){ return Math.floor(Math.random()*(max-min+1))+min; }\n  function createArray(length){\n    const a = [];\n    let val = randInt(0,3);\n    for(let i=0;i<length;i++){\n      val += randInt(1,5);\n      a.push(val);\n    }\n    return a;\n  }\n\n  function renderArray(){\n    arrayEl.innerHTML = '';\n    arr.forEach((v,i)=>{\n      const div = document.createElement('div');\n      div.className = 'cell';\n      if (n>40) div.classList.add('small');\n      div.dataset.index = i;\n      div.textContent = v;\n      arrayEl.appendChild(div);\n    });\n    lenEl.textContent = n;\n    sizeLabel.textContent = n;\n    sizeSide.value = n;\n    lenDisplay.textContent = n;\n    jumpSizeLabel.textContent = jumpSize === 0 ? `auto (${Math.floor(Math.sqrt(n))})` : jumpSize;\n    jumpLabel.textContent = jumpSlider.value;\n    jumpSide.value = jumpSlider.value;\n  }\n\n  function clearHighlights(){\n    Array.from(arrayEl.children).forEach(c=>{\n      c.classList.remove('checked','jump','found','block');\n    });\n    codeLines.forEach(l=>l.classList.remove('current'));\n  }\n\n  function highlightLine(i){\n    codeLines.forEach(l=>l.classList.remove('current'));\n    const el = document.getElementById('line'+i);\n    if(el) el.classList.add('current');\n  }\n\n  // generator that yields steps of jump search\n  function* jumpSearchGenerator(arr, target, m){\n    const n = arr.length;\n    let step = m;\n    let prev = 0;\n\n    // handle edge cases\n    if (n === 0) { yield {type:'notfound'}; return; }\n\n    // Jumps\n    while (arr[Math.min(step, n)-1] < target) {\n      // indicate check of block end\n      yield {type:'jump', index: Math.min(step, n)-1, prev, step, checkVal: arr[Math.min(step,n)-1]};\n      // advance\n      prev = step;\n      step += m;\n      if (prev >= n) { yield {type:'notfound'}; return; }\n    }\n\n    // Now linear search in block [prev, min(step,n)-1]\n    yield {type:'block', prev, end: Math.min(step, n)-1};\n    for (let i = prev; i < Math.min(step, n); i++) {\n      yield {type:'check', index:i, value:arr[i]};\n      if (arr[i] === target) { yield {type:'found', index:i, value:arr[i]}; return; }\n    }\n    yield {type:'notfound'};\n  }\n\n  // perform one step from generator\n  function performStep(state){\n    lastAction = state;\n    switch(state.type){\n      case 'jump':\n        comparisons++;\n        updateComp();\n        clearHighlights();\n        // mark jumped indices as checked up to prev-1 maybe, and highlight jump position\n        if (state.prev > 0){\n          for(let k=0;k<state.prev;k++){\n            const c = arrayEl.children[k];\n            if(c) c.classList.add('checked');\n          }\n        }\n        const jumpIndex = state.index;\n        const jumpCell = arrayEl.children[jumpIndex];\n        if (jumpCell) jumpCell.classList.add('jump');\n        highlightLine(5);\n        statusEl.textContent = `Jump checked arr[${jumpIndex}] = ${state.checkVal}`;\n        break;\n\n      case 'block':\n        clearHighlights();\n        // highlight block range\n        for(let i=state.prev;i<=state.end;i++){\n          const c = arrayEl.children[i];\n          if(c) c.classList.add('block');\n        }\n        highlightLine(10);\n        statusEl.textContent = `Block determined: indices [${state.prev} .. ${state.end}]`;\n        break;\n\n      case 'check':\n        comparisons++;\n        updateComp();\n        // mark this index as being linearly checked\n        const ci = arrayEl.children[state.index];\n        if(ci){\n          ci.classList.add('checked');\n        }\n        highlightLine(11);\n        statusEl.textContent = `Linear check arr[${state.index}] = ${state.value}`;\n        break;\n\n      case 'found':\n        const fcell = arrayEl.children[state.index];\n        if(fcell) { fcell.classList.add('found'); }\n        statusEl.textContent = `Found at index ${state.index}`;\n        resIndex.textContent = state.index;\n        resValue.textContent = state.value;\n        highlightLine(12);\n        running = false;\n        break;\n\n      case 'notfound':\n        statusEl.textContent = 'Target not found';\n        resIndex.textContent = '-';\n        resValue.textContent = '-';\n        highlightLine(14);\n        running = false;\n        break;\n    }\n  }\n\n  function updateComp(){ compEl.textContent = comparisons; compCountEl.textContent = comparisons; }\n\n  function startAuto(){\n    if (running) return;\n    // prepare generator\n    prepareAndStart();\n    if (!gen) return;\n    running = true;\n    paused = false;\n    statusEl.textContent = 'Running';\n    function stepLoop(){\n      if (!running || paused) return;\n      const next = gen.next();\n      if (next.done) { running=false; return; }\n      performStep(next.value);\n      // stop if found or notfound\n      if (next.value.type==='found' || next.value.type==='notfound'){ running=false; return; }\n      animTimer = setTimeout(stepLoop, delay);\n    }\n    stepLoop();\n  }\n\n  function pause(){\n    paused = true;\n    running = false;\n    if (animTimer) clearTimeout(animTimer);\n    statusEl.textContent = 'Paused';\n  }\n\n  function reset(){\n    if(animTimer) clearTimeout(animTimer);\n    running=false;\n    paused=false;\n    comparisons=0;\n    updateComp();\n    statusEl.textContent = 'Idle';\n    resIndex.textContent = '-';\n    resValue.textContent = '-';\n    clearHighlights();\n  }\n\n  function prepareAndStart(){\n    reset();\n    // ensure target is set\n    let targetVal = parseInt(targetInput.value,10);\n    if (isNaN(targetVal)){\n      if (autopick.checked && arr.length>0){\n        const idx = randInt(0,arr.length-1);\n        targetVal = arr[idx];\n        targetInput.value = targetVal;\n      } else {\n        statusEl.textContent = 'Set a numeric target';\n        return;\n      }\n    }\n    // compute jump size\n    let m = parseInt(jumpSlider.value,10);\n    if (m === 0){\n      m = Math.max(1, Math.floor(Math.sqrt(n)));\n    }\n    jumpSize = m;\n    jumpSizeLabel.textContent = jumpSize === 0 ? `auto (${Math.floor(Math.sqrt(n))})` : jumpSize;\n    // create generator\n    gen = jumpSearchGenerator(arr, targetVal, m);\n  }\n\n  // single step manually\n  function singleStep(){\n    if (!gen){\n      prepareAndStart();\n      if (!gen) return;\n      running = false;\n      paused = true;\n    }\n    const next = gen.next();\n    if (next.done){\n      statusEl.textContent = 'Done';\n      gen = null;\n      return;\n    }\n    performStep(next.value);\n    if (next.value.type==='found' || next.value.type==='notfound'){\n      gen = null;\n    }\n  }\n\n  // UI bindings\n  generateBtn.addEventListener('click', ()=>{\n    n = parseInt(sizeSlider.value,10);\n    arr = createArray(n);\n    // choose target automatically if requested\n    if (autopick.checked){\n      const idx = randInt(0,n-1);\n      targetInput.value = arr[idx];\n    } else {\n      targetInput.value = '';\n    }\n    reset();\n    renderArray();\n  });\n\n  // pick random target\n  pickRandom.addEventListener('click', ()=>{\n    if (arr.length===0) return;\n    const idx = randInt(0,arr.length-1);\n    targetInput.value = arr[idx];\n  });\n\n  startBtn.addEventListener('click', ()=>{\n    delay = parseInt(speed.value,10);\n    startAuto();\n  });\n\n  pauseBtn.addEventListener('click', ()=>{ pause(); });\n\n  stepBtn.addEventListener('click', ()=>{\n    singleStep();\n  });\n\n  resetBtn.addEventListener('click', ()=>{\n    // reset highlights, counters, keep same array\n    reset();\n    clearHighlights();\n  });\n\n  // sliders sync\n  sizeSlider.addEventListener('input', (e)=>{ sizeLabel.textContent = e.target.value; sizeSide.value = e.target.value; });\n  sizeSide.addEventListener('input', (e)=>{ sizeSlider.value = e.target.value; sizeLabel.textContent = e.target.value; });\n\n  jumpSlider.addEventListener('input', (e)=>{\n    jumpSide.value = e.target.value;\n    jumpLabel.textContent = e.target.value;\n    jumpSizeLabel.textContent = e.target.value === '0' ? `auto (${Math.floor(Math.sqrt(n))})` : e.target.value;\n  });\n  jumpSide.addEventListener('input', (e)=>{\n    jumpSlider.value = e.target.value;\n    jumpLabel.textContent = e.target.value;\n    jumpSizeLabel.textContent = e.target.value === '0' ? `auto (${Math.floor(Math.sqrt(n))})` : e.target.value;\n  });\n\n  speed.addEventListener('input', (e)=>{ speedSide.value = e.target.value; speedLabel.textContent = e.target.value; });\n  speedSide.addEventListener('input', (e)=>{ speed.value = e.target.value; speedLabel.textContent = e.target.value; });\n\n  // initial setup\n  n = parseInt(sizeSlider.value,10);\n  arr = createArray(n);\n  targetInput.value = arr[randInt(0,n-1)];\n  renderArray();\n  updateComp();\n\n  // allow clicking a cell to set target\n  arrayEl.addEventListener('click', (ev)=>{\n    const cell = ev.target.closest('.cell');\n    if(!cell) return;\n    const idx = parseInt(cell.dataset.index,10);\n    if (!isNaN(idx)){\n      targetInput.value = arr[idx];\n    }\n  });\n\n  // keyboard shortcuts\n  document.addEventListener('keydown', (e)=>{\n    if (e.key === ' '){ e.preventDefault(); startAuto(); }\n    if (e.key === 'p'){ pause(); }\n    if (e.key === 's'){ singleStep(); }\n    if (e.key === 'r'){ reset(); }\n  });\n\n})();\n</script>\n</body>\n</html>"
  },
