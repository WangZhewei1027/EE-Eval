    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Exponential Search Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f7f9fc;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    color: #2c3e50;\n  }\n  .container {\n    max-width: 700px;\n    margin: 0 auto;\n  }\n  label {\n    font-weight: bold;\n  }\n  input[type=\"text\"], input[type=\"number\"] {\n    width: 100%;\n    padding: 0.5rem;\n    margin: 0.3rem 0 1rem 0;\n    font-size: 1rem;\n    box-sizing: border-box;\n  }\n  button {\n    background-color: #2980b9;\n    color: white;\n    border: none;\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    cursor: pointer;\n    border-radius: 4px;\n    transition: background-color 0.2s ease;\n  }\n  button:hover {\n    background-color: #1f5f85;\n  }\n  .output {\n    margin-top: 1.5rem;\n    background: white;\n    border: 1px solid #ddd;\n    padding: 1rem;\n    border-radius: 4px;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n  .explanation {\n    background: #eaf4fc;\n    border-left: 4px solid #2980b9;\n    padding: 1rem;\n    margin: 1.5rem 0;\n    border-radius: 4px;\n  }\n  .highlight {\n    background-color: #ffff99;\n  }\n  .array-container {\n    margin-top: 1rem;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 0.5rem;\n  }\n  .array-item {\n    width: 36px;\n    height: 36px;\n    background-color: #ecf0f1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 3px;\n    user-select: none;\n    border: 1px solid #bdc3c7;\n    font-weight: 600;\n    cursor: default;\n  }\n  .array-item.current {\n    background-color: #3498db;\n    color: white;\n    border-color: #2980b9;\n    font-weight: bold;\n  }\n  .array-item.checked {\n    background-color: #95a5a6;\n    color: white;\n  }\n  .array-item.found {\n    background-color: #27ae60;\n    color: white;\n    font-weight: bold;\n  }\n  .steps {\n    margin-top: 1rem;\n    font-family: monospace;\n    white-space: pre-wrap;\n    background: #f0f3f7;\n    padding: 1rem;\n    border-radius: 4px;\n    max-height: 200px;\n    overflow-y: auto;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Exponential Search Visualization</h1>\n  <p>\n    Exponential Search is used to find the position of a target value in a sorted array. It works by first finding a range where the target could be by repeatedly doubling the index, then performs a Binary Search within that range.\n  </p>\n\n  <label for=\"arrayInput\">Sorted Array (comma separated numbers):</label>\n  <input id=\"arrayInput\" type=\"text\" value=\"1,3,5,7,9,12,15,18,21,24,27,30,33,36,39,42,45,48,51,54\" />\n\n  <label for=\"targetInput\">Target Value to Search:</label>\n  <input id=\"targetInput\" type=\"number\" value=\"27\" />\n\n  <button id=\"startSearch\">Start Exponential Search</button>\n\n  <div class=\"explanation\" id=\"explanation\">\n    Enter a sorted array and a target value, then click \"Start Exponential Search\" to see the step-by-step process.\n  </div>\n\n  <div>\n    <strong>Array Visualization:</strong>\n    <div class=\"array-container\" id=\"arrayContainer\"></div>\n  </div>\n\n  <div>\n    <strong>Search Steps:</strong>\n    <div class=\"steps\" id=\"steps\"></div>\n  </div>\n\n  <div class=\"output\" id=\"result\"></div>\n</div>\n\n<script>\n  const arrayInput = document.getElementById(\"arrayInput\");\n  const targetInput = document.getElementById(\"targetInput\");\n  const startSearch = document.getElementById(\"startSearch\");\n  const arrayContainer = document.getElementById(\"arrayContainer\");\n  const stepsEl = document.getElementById(\"steps\");\n  const resultEl = document.getElementById(\"result\");\n  const explanationEl = document.getElementById(\"explanation\");\n\n  // Utility to sleep for animation\n  function sleep(ms) {\n    return new Promise(r => setTimeout(r, ms));\n  }\n\n  // Render the array with highlights for current, checked or found indices\n  function renderArray(arr, highlight = {}) {\n    // highlight: {current: index, checked: [indices], found: index}\n    arrayContainer.innerHTML = \"\";\n    for (let i = 0; i < arr.length; i++) {\n      const div = document.createElement(\"div\");\n      div.textContent = arr[i];\n      div.className = \"array-item\";\n      if (i === highlight.current) div.classList.add(\"current\");\n      else if (highlight.checked && highlight.checked.includes(i)) div.classList.add(\"checked\");\n      else if (i === highlight.found) div.classList.add(\"found\");\n      arrayContainer.appendChild(div);\n    }\n  }\n\n  // Append a step message\n  function logStep(msg) {\n    stepsEl.textContent += msg + \"\\n\";\n    stepsEl.scrollTop = stepsEl.scrollHeight;\n  }\n\n  // Binary Search to use after exponential range found\n  async function binarySearch(arr, left, right, target) {\n    logStep(`Binary search in range [${left}...${right}]`);\n    while (left <= right) {\n      let mid = Math.floor(left + (right - left) / 2);\n      logStep(`Check middle index ${mid}, value ${arr[mid]}`);\n      renderArray(arr, { current: mid, checked: [] });\n      await sleep(700);\n      if (arr[mid] === target) {\n        logStep(`Found target ${target} at index ${mid}`);\n        renderArray(arr, { found: mid });\n        return mid;\n      } else if (arr[mid] < target) {\n        logStep(`Target is greater than ${arr[mid]}, search right half`);\n        left = mid + 1;\n      } else {\n        logStep(`Target is less than ${arr[mid]}, search left half`);\n        right = mid - 1;\n      }\n      await sleep(700);\n    }\n    logStep(`Target ${target} not found in the binary search range.`);\n    return -1;\n  }\n\n  // Exponential Search implementation with visualization\n  async function exponentialSearch(arr, target) {\n    stepsEl.textContent = \"\";\n    resultEl.textContent = \"\";\n    explanationEl.textContent = \"Starting Exponential Search...\";\n    renderArray(arr);\n\n    if (arr.length === 0) {\n      resultEl.textContent = \"Array is empty.\";\n      return -1;\n    }\n\n    if(arr[0] === target){\n      logStep(`Target is at index 0.`);\n      renderArray(arr, { found: 0 });\n      return 0;\n    }\n\n    let bound = 1;\n    logStep(`Start with bound = 1`);\n\n    // Find range for binary search by repeated doubling\n    while (bound < arr.length && arr[bound] < target) {\n      logStep(`Value at bound ${bound} is ${arr[bound]}, which is less than target ${target}. Double the bound.`);\n      renderArray(arr, { current: bound });\n      await sleep(800);\n      bound *= 2;\n    }\n\n    let left = Math.floor(bound / 2);\n    let right = Math.min(bound, arr.length - 1);\n\n    logStep(`Target may be between indexes [${left}...${right}], do binary search in this range.`);\n    explanationEl.textContent = `Found the range [${left}...${right}] by exponential doubling. Now performing binary search.`;\n\n    let index = await binarySearch(arr, left, right, target);\n    if (index === -1) {\n      resultEl.textContent = `Target ${target} not found in the array.`;\n    } else {\n      resultEl.textContent = `Target ${target} found at index ${index}.`;\n    }\n    explanationEl.textContent = \"Exponential Search finished.\";\n    return index;\n  }\n\n  startSearch.onclick = async () => {\n    let arr = arrayInput.value.split(\",\").map(x => parseInt(x.trim())).filter(x => !isNaN(x));\n    if (arr.length === 0) {\n      alert(\"Please enter a valid sorted array.\");\n      return;\n    }\n\n    // Check if sorted ascending order\n    for (let i = 1; i < arr.length; i++) {\n      if (arr[i] < arr[i - 1]) {\n        alert(\"Array must be sorted in ascending order for Exponential Search.\");\n        return;\n      }\n    }\n\n    let target = parseInt(targetInput.value);\n    if (isNaN(target)) {\n      alert(\"Please enter a valid number for the target.\");\n      return;\n    }\n\n    await exponentialSearch(arr, target);\n  };\n</script>\n</body>\n</html>"
