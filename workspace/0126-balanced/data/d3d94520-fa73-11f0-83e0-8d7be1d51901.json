  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Virtual Memory Simulator</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724; --panel:#0b1220; --muted:#9aa8c0; --accent:#40c4ff; --accent2:#7ef0c7;\n      --card:#0c1726; --good:#21d07a; --bad:#ff6b6b;\n    }\n    html,body{height:100%; margin:0; font-family:Inter,ui-sans-serif,system-ui,Segoe UI,Roboto,\"Helvetica Neue\",Arial; background:linear-gradient(180deg,#071025 0%, #061028 100%); color:#d8e6f3; }\n    .wrap{max-width:1200px;margin:20px auto;padding:18px;border-radius:12px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); box-shadow: 0 8px 30px rgba(2,6,23,0.7);}\n    h1{margin:0 0 6px;font-size:20px}\n    p.lead{margin:0 0 14px;color:var(--muted);font-size:13px}\n    .controls{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px}\n    .card{background:var(--card); padding:12px;border-radius:10px;flex:1; min-width:220px;border:1px solid rgba(255,255,255,0.03)}\n    label{display:block;font-size:12px;color:var(--muted);margin-bottom:6px}\n    input[type=number], input[type=text], select, textarea{width:100%;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.04); background:transparent;color:inherit; font-size:13px}\n    .row{display:flex;gap:10px}\n    .btn{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.05); color:var(--accent); padding:8px 10px;border-radius:8px; cursor:pointer}\n    .btn.secondary{color:var(--accent2)}\n    .btn.warn{color:var(--bad)}\n    .btn.small{padding:6px 8px;font-size:13px}\n    .layout{display:grid;grid-template-columns: 1fr 420px;gap:12px}\n    .vis{display:flex;flex-direction:column;gap:10px}\n    .panel{background:var(--panel);padding:10px;border-radius:10px;border:1px solid rgba(255,255,255,0.03)}\n    .tlb{display:flex;gap:8px;flex-wrap:wrap}\n    .tlb .entry{min-width:96px;padding:8px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));border:1px solid rgba(255,255,255,0.03);font-size:13px}\n    .grid{display:grid;gap:8px}\n    .ptable{display:grid;grid-template-columns: 1fr 70px 60px 60px 60px;align-items:center;gap:6px}\n    .ptable .head{font-size:12px;color:var(--muted);padding:6px}\n    .ptable .row{padding:6px;border-radius:6px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));border:1px solid rgba(255,255,255,0.02);font-size:13px}\n    .frames{display:flex;gap:8px;flex-wrap:wrap}\n    .frame{width:100px;height:60px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));border:1px solid rgba(255,255,255,0.03);display:flex;flex-direction:column;justify-content:center;align-items:center;font-size:13}\n    .frame.empty{opacity:0.45}\n    .legend{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted)}\n    .dot{width:10px;height:10px;border-radius:50%}\n    .dot.allocated{background:var(--accent)}\n    .dot.free{background:#576f86}\n    .log{height:220px;overflow:auto;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00)); padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.03); font-family:monospace; font-size:13px}\n    .stats{display:flex;gap:10px;flex-wrap:wrap}\n    .stat{background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;font-size:13px;min-width:120px}\n    .highlight{box-shadow:0 0 0 3px rgba(64,196,255,0.06) inset}\n    .small-muted{font-size:12px;color:var(--muted)}\n    footer{margin-top:12px;text-align:center;color:var(--muted);font-size:12px}\n    input[type=range]{width:100%}\n    .addr-preview{font-family:monospace;background:rgba(255,255,255,0.02);padding:8px;border-radius:6px}\n    @media(max-width:980px){ .layout{grid-template-columns: 1fr} .tlb .entry{min-width:140px} .frame{width:84px;height:56px} }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <h1>Virtual Memory Simulator</h1>\n    <p class=\"lead\">Interactive demonstration of virtual memory, paging, page tables, TLB, page faults and replacement. Configure the virtual address space, page size and physical frames, then generate or enter memory accesses and step through how addresses map to frames and when page faults occur.</p>\n\n    <div class=\"controls\">\n      <div class=\"card\">\n        <label>Virtual pages</label>\n        <input id=\"virtualPages\" type=\"number\" min=\"4\" max=\"256\" step=\"1\" value=\"16\">\n        <div style=\"height:8px\"></div>\n        <label>Page size (bytes)</label>\n        <input id=\"pageSize\" type=\"number\" min=\"4\" max=\"1024\" step=\"4\" value=\"64\">\n      </div>\n\n      <div class=\"card\">\n        <label>Physical frames</label>\n        <input id=\"numFrames\" type=\"number\" min=\"1\" max=\"64\" step=\"1\" value=\"4\">\n        <div style=\"height:8px\"></div>\n        <label>TLB entries</label>\n        <input id=\"tlbSize\" type=\"number\" min=\"0\" max=\"16\" step=\"1\" value=\"4\">\n      </div>\n\n      <div class=\"card\">\n        <label>Replacement algorithm</label>\n        <select id=\"algorithm\">\n          <option value=\"FIFO\">FIFO</option>\n          <option value=\"LRU\">LRU</option>\n          <option value=\"Clock\">Clock (2nd chance)</option>\n        </select>\n        <div style=\"height:8px\"></div>\n        <label>Access mode</label>\n        <select id=\"mode\">\n          <option value=\"R\">Read (R)</option>\n          <option value=\"W\">Write (W)</option>\n          <option value=\"Mixed\">Mixed: sequence-specified</option>\n        </select>\n      </div>\n\n      <div class=\"card\">\n        <label>Access sequence (comma-separated addresses, optionally add :W or :R)</label>\n        <textarea id=\"sequence\" rows=\"4\" placeholder=\"e.g. 10, 128:W, 34, 10:W\"></textarea>\n        <div style=\"height:8px\"></div>\n        <div class=\"row\">\n          <button class=\"btn\" id=\"genRandom\">Generate Random</button>\n          <button class=\"btn secondary\" id=\"initBtn\">Init</button>\n          <button class=\"btn warn\" id=\"resetBtn\">Reset</button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"layout\">\n      <div class=\"vis\">\n        <div class=\"panel\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:10px\">\n            <div>\n              <div class=\"small-muted\">TLB (Translation Lookaside Buffer)</div>\n              <div class=\"tlb\" id=\"tlbArea\"></div>\n            </div>\n            <div style=\"text-align:right\">\n              <div class=\"small-muted\">Access step</div>\n              <div class=\"addr-preview\" id=\"currentAddr\">-</div>\n            </div>\n          </div>\n\n          <div style=\"display:flex;gap:10px;align-items:center;margin-bottom:8px\">\n            <button class=\"btn small\" id=\"stepBtn\">Step</button>\n            <button class=\"btn small secondary\" id=\"runBtn\">Run</button>\n            <button class=\"btn small\" id=\"pauseBtn\">Pause</button>\n            <label style=\"margin-left:8px\" class=\"small-muted\">Speed</label>\n            <input id=\"speed\" type=\"range\" min=\"100\" max=\"2000\" value=\"600\">\n          </div>\n\n          <div style=\"display:flex;gap:8px;align-items:center;margin-bottom:10px\">\n            <label class=\"small-muted\">Mode for new accesses</label>\n            <select id=\"singleMode\" style=\"width:120px\">\n              <option value=\"R\">Read</option>\n              <option value=\"W\">Write</option>\n            </select>\n            <input id=\"singleAddr\" type=\"number\" min=\"0\" placeholder=\"Address\" style=\"width:140px;margin-left:6px\">\n            <button class=\"btn small\" id=\"accessBtn\">Access</button>\n          </div>\n\n          <div style=\"display:flex;gap:10px;align-items:center;margin-bottom:8px\">\n            <div class=\"legend\"><div class=\"dot free\"></div><div class=\"small-muted\">free</div></div>\n            <div class=\"legend\"><div class=\"dot allocated\"></div><div class=\"small-muted\">allocated</div></div>\n            <div style=\"flex:1\"></div>\n            <div class=\"small-muted\">Algorithm: <b id=\"algName\">FIFO</b></div>\n          </div>\n\n          <div style=\"display:flex;gap:12px;flex-wrap:wrap\">\n            <div style=\"flex:1\">\n              <div class=\"small-muted\">Page Table</div>\n              <div style=\"margin-top:8px\" class=\"ptable\" id=\"pageTable\">\n                <!-- header -->\n              </div>\n            </div>\n\n            <div style=\"width:300px\">\n              <div class=\"small-muted\">Physical Frames</div>\n              <div style=\"margin-top:8px\" class=\"frames\" id=\"framesArea\"></div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"panel\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px\">\n            <div class=\"small-muted\">Statistics</div>\n            <div class=\"small-muted\">Swap area shown at right</div>\n          </div>\n          <div class=\"stats\" id=\"statsArea\">\n            <div class=\"stat\">Accesses: <b id=\"stAccesses\">0</b></div>\n            <div class=\"stat\">TLB hits: <b id=\"stTlbHits\">0</b></div>\n            <div class=\"stat\">Page faults: <b id=\"stFaults\">0</b></div>\n            <div class=\"stat\">Swap-outs: <b id=\"stSwaps\">0</b></div>\n            <div class=\"stat\">Page hits: <b id=\"stPageHits\">0</b></div>\n            <div class=\"stat\">Hit rate: <b id=\"stHitRate\">0%</b></div>\n          </div>\n        </div>\n\n        <div class=\"panel\">\n          <div class=\"small-muted\">Log</div>\n          <div class=\"log\" id=\"log\"></div>\n        </div>\n      </div>\n\n      <div>\n        <div class=\"panel\" style=\"margin-bottom:12px\">\n          <div class=\"small-muted\">Swap / Evicted Pages</div>\n          <div id=\"swapArea\" style=\"margin-top:8px\"></div>\n        </div>\n\n        <div class=\"panel\">\n          <div class=\"small-muted\">Help & explanation</div>\n          <div style=\"margin-top:8px;font-size:13px;color:var(--muted)\">\n            This simulator models a simple paging virtual memory system:\n            <ul style=\"margin:6px 0 0 18px;padding:0\">\n              <li>Virtual addresses = page number + offset (page size configurable).</li>\n              <li>A TLB caches recent page→frame translations (optional).</li>\n              <li>On access: check TLB → page table. If the page isn't resident, a page fault occurs and the page is loaded into a physical frame. If no free frame, an existing page is evicted using the selected replacement algorithm. Writes set the page dirty and must be swapped-out if evicted.</li>\n              <li>Use Step to advance one access, Run to replay the sequence automatically.</li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <footer>Built for learning: virtual pages, page tables, TLB, page faults and replacement.</footer>\n  </div>\n\n  <script>\n    // Virtual Memory Simulator - Single-file\n    (function(){\n      // UI elements\n      const virtualPagesEl = document.getElementById('virtualPages');\n      const pageSizeEl = document.getElementById('pageSize');\n      const numFramesEl = document.getElementById('numFrames');\n      const tlbSizeEl = document.getElementById('tlbSize');\n      const algorithmEl = document.getElementById('algorithm');\n      const modeEl = document.getElementById('mode');\n      const sequenceEl = document.getElementById('sequence');\n      const initBtn = document.getElementById('initBtn');\n      const resetBtn = document.getElementById('resetBtn');\n      const genRandomBtn = document.getElementById('genRandom');\n      const tlbArea = document.getElementById('tlbArea');\n      const pageTableEl = document.getElementById('pageTable');\n      const framesArea = document.getElementById('framesArea');\n      const swapArea = document.getElementById('swapArea');\n      const logEl = document.getElementById('log');\n      const stAccesses = document.getElementById('stAccesses');\n      const stTlbHits = document.getElementById('stTlbHits');\n      const stFaults = document.getElementById('stFaults');\n      const stSwaps = document.getElementById('stSwaps');\n      const stPageHits = document.getElementById('stPageHits');\n      const stHitRate = document.getElementById('stHitRate');\n      const stepBtn = document.getElementById('stepBtn');\n      const runBtn = document.getElementById('runBtn');\n      const pauseBtn = document.getElementById('pauseBtn');\n      const speedEl = document.getElementById('speed');\n      const currentAddrEl = document.getElementById('currentAddr');\n      const algNameEl = document.getElementById('algName');\n      const singleAddrEl = document.getElementById('singleAddr');\n      const singleModeEl = document.getElementById('singleMode');\n      const accessBtn = document.getElementById('accessBtn');\n\n      // State\n      let numVirtualPages = 16;\n      let pageSize = 64;\n      let numFrames = 4;\n      let tlbSize = 4;\n      let algorithm = 'FIFO';\n      let accessModeGlobal = 'R';\n\n      let pageTable = []; // entries: {valid, frame, dirty, referenced, swapped}\n      let frames = []; // frames: {page: number|null, loadedAt: tick, referenced}\n      let freeFrames = [];\n      let tlb = []; // entries: {page, frame, time}\n      let swap = {}; // map page->true (evicted)\n      let seq = []; // sequence of accesses: {addr, op}\n      let seqIdx = 0;\n      let stats = {accesses:0, tlbHits:0, faults:0, swaps:0, pageHits:0};\n      let ticker = 0;\n      let running = false;\n      let runTimer = null;\n      let clockHand = 0; // for Clock algorithm\n\n      function log(msg, type='info'){\n        const now = new Date().toLocaleTimeString();\n        const line = document.createElement('div');\n        line.textContent = `[${now}] ${msg}`;\n        if(type==='error') line.style.color = 'var(--bad)';\n        logEl.prepend(line);\n      }\n\n      function initStructures(){\n        // read inputs\n        numVirtualPages = clamp(parseInt(virtualPagesEl.value)||16, 4, 256);\n        pageSize = clamp(parseInt(pageSizeEl.value)||64, 4, 4096);\n        numFrames = clamp(parseInt(numFramesEl.value)||4, 1, 128);\n        tlbSize = clamp(parseInt(tlbSizeEl.value)||4, 0, 32);\n        algorithm = algorithmEl.value;\n        accessModeGlobal = modeEl.value;\n        algNameEl.textContent = algorithm;\n\n        // initialize page table\n        pageTable = [];\n        for(let i=0;i<numVirtualPages;i++){\n          pageTable.push({valid:false, frame:null, dirty:false, referenced:false, swapped:false});\n        }\n        // frames\n        frames = [];\n        for(let i=0;i<numFrames;i++){\n          frames.push({page:null, loadedAt:0, referenced:false});\n        }\n        freeFrames = [...Array(numFrames).keys()];\n\n        // TLB\n        tlb = [];\n        for(let i=0;i<tlbSize;i++) tlb.push(null);\n\n        swap = {};\n        seqIdx = 0;\n        ticker = 0;\n        clockHand = 0;\n\n        stats = {accesses:0, tlbHits:0, faults:0, swaps:0, pageHits:0};\n        updateUI();\n        log(`Initialized: ${numVirtualPages} pages, page size ${pageSize} bytes, ${numFrames} frames, TLB ${tlbSize} entries, algorithm=${algorithm}`);\n      }\n\n      function clamp(v,min,max){ return Math.max(min, Math.min(max, v)); }\n\n      function parseSequence(){\n        // parse sequence textarea based on current mode option\n        const text = sequenceEl.value.trim();\n        seq = [];\n        if(text.length===0){\n          // nothing - keep empty\n          return;\n        }\n        const parts = text.split(',');\n        for(let p of parts){\n          p = p.trim();\n          if(!p) continue;\n          let op = null;\n          let addrStr = p;\n          if(p.includes(':')){\n            const sp = p.split(':');\n            addrStr = sp[0].trim();\n            op = sp[1].trim().toUpperCase() === 'W' ? 'W' : 'R';\n          } else {\n            if(accessModeGlobal === 'Mixed') op = 'R';\n            else op = accessModeGlobal;\n          }\n          const addr = parseInt(addrStr);\n          if(Number.isNaN(addr)) continue;\n          seq.push({addr:addr, op:op});\n        }\n      }\n\n      function generateRandom(){\n        // create random sequence matching current address space\n        parseInputsToVars();\n        const count = Math.max(8, Math.round(numVirtualPages * 2));\n        const arr = [];\n        for(let i=0;i<count;i++){\n          const page = randInt(0, numVirtualPages-1);\n          const offset = randInt(0, pageSize-1);\n          const addr = page * pageSize + offset;\n          let op = (Math.random() < 0.25) ? 'W' : 'R';\n          arr.push(`${addr}${op==='W'?':W':''}`);\n        }\n        sequenceEl.value = arr.join(', ');\n        parseSequence();\n        seqIdx = 0;\n        updateUI();\n      }\n\n      function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n\n      function parseInputsToVars(){\n        numVirtualPages = clamp(parseInt(virtualPagesEl.value)||16, 4, 256);\n        pageSize = clamp(parseInt(pageSizeEl.value)||64, 4, 4096);\n        numFrames = clamp(parseInt(numFramesEl.value)||4, 1, 128);\n        tlbSize = clamp(parseInt(tlbSizeEl.value)||4, 0, 32);\n        algorithm = algorithmEl.value;\n        accessModeGlobal = modeEl.value;\n      }\n\n      // Update UI visualization\n      function updateUI(){\n        // TLB\n        tlbArea.innerHTML = '';\n        for(let i=0;i<tlb.length;i++){\n          const e = tlb[i];\n          const div = document.createElement('div');\n          div.className = 'entry';\n          if(e){\n            div.innerHTML = `<div style=\"font-weight:600\">Entry ${i}</div><div>VPN=${e.page} → F=${e.frame}</div><div class=\"small-muted\">time:${e.time}</div>`;\n          } else {\n            div.innerHTML = `<div style=\"font-weight:600\">Entry ${i}</div><div class=\"small-muted\">empty</div>`;\n            div.style.opacity = '0.6';\n          }\n          tlbArea.appendChild(div);\n        }\n\n        // Page table header\n        pageTableEl.innerHTML = '';\n        ['VPN','Valid','Frame','Dirty','Swapped'].forEach(h=>{\n          const hd = document.createElement('div'); hd.className='head'; hd.textContent = h; pageTableEl.appendChild(hd);\n        });\n        for(let i=0;i<pageTable.length;i++){\n          const e = pageTable[i];\n          const r = document.createElement('div'); r.className='row';\n          const validTxt = e.valid ? 'Yes' : 'No';\n          const frameTxt = e.valid ? e.frame : '-';\n          const dirtyTxt = e.dirty ? 'Yes' : '-';\n          const swappedTxt = e.swapped ? 'Yes' : '-';\n          r.innerHTML = `<div style=\"font-weight:600\">#${i}</div><div>${validTxt}</div><div>${frameTxt}</div><div>${dirtyTxt}</div><div>${swappedTxt}</div>`;\n          if(e.valid) r.classList.add('highlight');\n          pageTableEl.appendChild(r);\n        }\n\n        // Frames\n        framesArea.innerHTML = '';\n        for(let i=0;i<frames.length;i++){\n          const f = frames[i];\n          const div = document.createElement('div'); div.className = 'frame';\n          if(f.page === null){\n            div.classList.add('empty');\n            div.innerHTML = `<div>F${i}</div><div class=\"small-muted\">free</div>`;\n          } else {\n            const p = pageTable[f.page];\n            div.innerHTML = `<div style=\"font-weight:700\">F${i} → P${f.page}</div><div class=\"small-muted\">loaded:${f.loadedAt} ref:${p.referenced?1:0}</div>`;\n            if(p.dirty) div.style.boxShadow = '0 0 0 3px rgba(255,107,107,0.06) inset';\n          }\n          framesArea.appendChild(div);\n        }\n\n        // Swap area\n        swapArea.innerHTML = '';\n        const keys = Object.keys(swap);\n        if(keys.length===0){\n          swapArea.innerHTML = '<div class=\"small-muted\">No evicted pages</div>';\n        } else {\n          const ul = document.createElement('div');\n          ul.style.display = 'flex'; ul.style.flexWrap = 'wrap'; ul.style.gap = '6px';\n          keys.forEach(k=>{\n            const box = document.createElement('div');\n            box.style.padding='8px'; box.style.borderRadius='6px'; box.style.background='rgba(255,255,255,0.02)'; box.style.fontFamily='monospace';\n            box.textContent = `P${k}`;\n            ul.appendChild(box);\n          });\n          swapArea.appendChild(ul);\n        }\n\n        // stats\n        stAccesses.textContent = stats.accesses;\n        stTlbHits.textContent = stats.tlbHits;\n        stFaults.textContent = stats.faults;\n        stSwaps.textContent = stats.swaps;\n        stPageHits.textContent = stats.pageHits;\n        const hitRate = stats.accesses>0 ? Math.round((stats.tlbHits + stats.pageHits)/stats.accesses*100) : 0;\n        stHitRate.textContent = `${hitRate}%`;\n      }\n\n      // Core: access memory address\n      function accessAddress(addr, op='R', autocheckRange=true){\n        parseInputsToVars();\n        if(autocheckRange){\n          const maxAddr = numVirtualPages * pageSize - 1;\n          if(addr < 0 || addr > maxAddr){\n            log(`Address ${addr} out of range. Valid: 0..${maxAddr}`, 'error'); return;\n          }\n        }\n        const vpn = Math.floor(addr / pageSize);\n        const offset = addr % pageSize;\n        ticker++;\n        stats.accesses++;\n        currentAddrEl.textContent = `A=${addr} (P${vpn} + ${offset}) ${op}`;\n        log(`Accessing addr=${addr} → VPN=${vpn} (offset ${offset}) op=${op}`);\n        // 1) TLB lookup\n        let tlbHitIndex = -1;\n        for(let i=0;i<tlb.length;i++){\n          const e = tlb[i];\n          if(e && e.page === vpn){\n            tlbHitIndex = i; break;\n          }\n        }\n        if(tlbHitIndex >= 0){\n          stats.tlbHits++;\n          const e = tlb[tlbHitIndex];\n          // page should be resident\n          const frameNum = e.frame;\n          const pte = pageTable[vpn];\n          pte.referenced = true;\n          frames[frameNum].referenced = true;\n          frames[frameNum].loadedAt = ticker;\n          if(op==='W'){ pte.dirty = true; }\n          // update tlb time\n          tlb[tlbHitIndex].time = ticker;\n          log(`TLB hit: VPN ${vpn} → frame ${frameNum}`);\n          stats.pageHits++;\n          updateUI();\n          return;\n        }\n        // TLB miss\n        log(`TLB miss for VPN ${vpn}`);\n        // Check page table\n        const pte = pageTable[vpn];\n        if(pte.valid){\n          // page resident but TLB miss: update TLB\n          stats.pageHits++;\n          pte.referenced = true;\n          if(op==='W') pte.dirty = true;\n          // update frame referenced/time\n          frames[pte.frame].referenced = true;\n          frames[pte.frame].loadedAt = ticker;\n          insertToTLB(vpn, pte.frame);\n          log(`Page table hit: loaded in frame ${pte.frame}. Inserted into TLB.`);\n          updateUI();\n          return;\n        }\n        // Page fault\n        stats.faults++;\n        log(`Page fault: VPN ${vpn} not resident. Handling page fault...`);\n        handlePageFault(vpn, op);\n        updateUI();\n      }\n\n      function insertToTLB(page, frame){\n        if(tlbSize === 0) return;\n        // find empty slot\n        for(let i=0;i<tlb.length;i++){\n          if(tlb[i] === null){\n            tlb[i] = {page:page, frame:frame, time:ticker};\n            return;\n          }\n        }\n        // replacement: LRU (based on time)\n        let lruIdx = 0; let minTime = tlb[0].time;\n        for(let i=1;i<tlb.length;i++){\n          if(tlb[i].time < minTime){ minTime = tlb[i].time; lruIdx = i; }\n        }\n        tlb[lruIdx] = {page:page, frame:frame, time:ticker};\n      }\n\n      function handlePageFault(vpn, op){\n        // find free frame or evict\n        let frameNum = null;\n        if(freeFrames.length > 0){\n          frameNum = freeFrames.shift();\n          log(`Allocating free frame F${frameNum} for P${vpn}`);\n        } else {\n          // need to evict based on algorithm\n          if(algorithm === 'FIFO'){\n            // choose frame with smallest loadedAt\n            let oldest = 0; let minLoad = frames[0].loadedAt;\n            for(let i=1;i<frames.length;i++){\n              if(frames[i].loadedAt < minLoad){ minLoad = frames[i].loadedAt; oldest = i; }\n            }\n            frameNum = oldest;\n            log(`No free frame. Evicting (FIFO) frame F${frameNum} (page P${frames[frameNum].page})`);\n          } else if(algorithm === 'LRU'){\n            // choose frame least recently referenced (low loadedAt or referenced false)\n            let lru = 0; let minTime = frames[0].loadedAt;\n            for(let i=1;i<frames.length;i++){\n              if(frames[i].loadedAt < minTime){ minTime = frames[i].loadedAt; lru = i; }\n            }\n            frameNum = lru;\n            log(`No free frame. Evicting (LRU) frame F${frameNum} (page P${frames[frameNum].page})`);\n          } else if(algorithm === 'Clock'){\n            // second-chance clock\n            let cycles = 0;\n            while(true){\n              const f = frames[clockHand];\n              const p = f.page;\n              if(!pageTable[p].referenced){\n                frameNum = clockHand;\n                log(`No free frame. Evicting (Clock) frame F${frameNum} (page P${p})`);\n                // advance hand for next time\n                clockHand = (clockHand + 1) % frames.length;\n                break;\n              } else {\n                // give second chance\n                pageTable[p].referenced = false;\n                frames[clockHand].referenced = false;\n                clockHand = (clockHand + 1) % frames.length;\n                cycles++;\n                if(cycles > frames.length*2){\n                  // fallback\n                  frameNum = clockHand;\n                  break;\n                }\n              }\n            }\n            if(frameNum === null) frameNum = 0;\n          } else {\n            // default: evict frame 0\n            frameNum = 0;\n          }\n          // evict the page currently in that frame\n          const victim = frames[frameNum].page;\n          if(victim !== null){\n            const vpte = pageTable[victim];\n            // if dirty - simulate swap out\n            if(vpte.dirty){\n              stats.swaps++;\n              swap[victim] = true;\n              log(`Evicting dirty page P${victim} from F${frameNum} → swapped out`);\n            } else {\n              log(`Evicting clean page P${victim} from F${frameNum}`);\n            }\n            // invalidate victim\n            vpte.valid = false;\n            vpte.frame = null;\n            vpte.referenced = false;\n            vpte.dirty = false;\n            vpte.swapped = !!swap[victim];\n            // Remove from TLB if present\n            for(let i=0;i<tlb.length;i++){\n              if(tlb[i] && tlb[i].page === victim) tlb[i] = null;\n            }\n          }\n        }\n        // \"load\" vpn into frameNum\n        frames[frameNum].page = vpn;\n        frames[frameNum].loadedAt = ticker;\n        frames[frameNum].referenced = true;\n        pageTable[vpn].valid = true;\n        pageTable[vpn].frame = frameNum;\n        pageTable[vpn].referenced = true;\n        pageTable[vpn].dirty = (op === 'W');\n        // if it was previously swapped, mark it not swapped now\n        if(pageTable[vpn].swapped) pageTable[vpn].swapped = false;\n        // insert into TLB\n        insertToTLB(vpn, frameNum);\n        log(`Loaded P${vpn} into F${frameNum} (dirty=${pageTable[vpn].dirty})`);\n      }\n\n      // Step through the sequence once\n      function stepOnce(){\n        if(seq.length === 0){\n          parseSequence();\n          if(seq.length === 0){\n            log('No access sequence defined. Enter addresses or generate random.', 'error');\n            return;\n          }\n        }\n        if(seqIdx >= seq.length){\n          log('Sequence complete.');\n          running = false;\n          clearInterval(runTimer);\n          return;\n        }\n        const item = seq[seqIdx++];\n        accessAddress(item.addr, item.op);\n        updateUI();\n        if(seqIdx >= seq.length){\n          log('Sequence finished.');\n          running = false;\n          clearInterval(runTimer);\n        }\n      }\n\n      // Run automatically at speed\n      function runAuto(){\n        if(running) return;\n        running = true;\n        const interval = clamp(parseInt(speedEl.value)||600, 100, 5000);\n        runTimer = setInterval(()=>{\n          if(!running) { clearInterval(runTimer); return; }\n          stepOnce();\n          if(seqIdx >= seq.length) { running = false; clearInterval(runTimer); }\n        }, interval);\n      }\n\n      function pauseRun(){ running=false; clearInterval(runTimer); log('Run paused.'); }\n\n      // UI actions\n      initBtn.addEventListener('click', ()=>{\n        initStructures();\n        parseSequence();\n      });\n      resetBtn.addEventListener('click', ()=>{\n        initStructures();\n        sequenceEl.value = '';\n        seq = [];\n        seqIdx = 0;\n        log('Reset simulation.');\n      });\n      genRandomBtn.addEventListener('click', ()=>{\n        generateRandom();\n        initStructures(); // re-init to reset mappings\n        parseSequence();\n      });\n      stepBtn.addEventListener('click', ()=>{ parseSequence(); stepOnce(); });\n      runBtn.addEventListener('click', ()=>{\n        parseSequence();\n        runAuto();\n      });\n      pauseBtn.addEventListener('click', pauseRun);\n      speedEl.addEventListener('input', ()=>{ if(running){ pauseRun(); runAuto(); } });\n      algorithmEl.addEventListener('change', ()=>{ algNameEl.textContent = algorithmEl.value; });\n      accessBtn.addEventListener('click', ()=>{\n        const addr = parseInt(singleAddrEl.value);\n        const op = singleModeEl.value;\n        if(Number.isNaN(addr)){ log('Enter a valid address to access.','error'); return;}\n        accessAddress(addr, op, true);\n        updateUI();\n      });\n\n      // helpers\n      function resetAll(){ initStructures(); sequenceEl.value = ''; seq=[]; seqIdx=0; log('Simulator reset.'); }\n\n      // initialize defaults\n      initStructures();\n\n      // small demo prefill\n      sequenceEl.value = '10, 130:W, 64, 10, 130, 200, 12:W, 64, 300, 130';\n      parseSequence();\n\n    })();\n  </script>\n</body>\n</html>"
