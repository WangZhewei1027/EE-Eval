  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>JavaScript Arrays — Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root {\n      --bg: #0f1724;\n      --panel: #0b1220;\n      --accent: #60a5fa;\n      --muted: #94a3b8;\n      --card: #071029;\n      --success: #16a34a;\n      --danger: #f87171;\n      --code-bg: #001122;\n      --glass: rgba(255,255,255,0.03);\n    }\n    * { box-sizing: border-box; font-family: Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; }\n    body {\n      margin: 0;\n      background: linear-gradient(180deg,var(--bg), #071029 120%);\n      color: #e6eef8;\n      min-height: 100vh;\n      padding: 24px;\n    }\n    header {\n      display:flex;\n      gap:16px;\n      align-items:center;\n      margin-bottom:18px;\n    }\n    header h1 { margin:0; font-size:20px; letter-spacing: -0.3px; }\n    header p { margin:0; color:var(--muted); font-size:13px; }\n    .layout { display:flex; gap:18px; align-items:flex-start; }\n    .left, .right { background:var(--panel); border-radius:12px; padding:14px; box-shadow: 0 6px 24px rgba(2,6,23,0.6); }\n    .left { width: 520px; max-width: calc(100vw - 60px); }\n    .right { flex:1; min-width:320px; max-width:680px; }\n    .example {\n      background: linear-gradient(180deg,var(--card), rgba(255,255,255,0.02));\n      border-radius:10px;\n      padding:12px;\n      margin-bottom:12px;\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n    .ex-title { display:flex; justify-content:space-between; gap:12px; align-items:center; }\n    .ex-title h3 { margin:0; font-size:14px; }\n    .ex-desc { margin:6px 0 10px 0; color:var(--muted); font-size:13px; }\n    pre.code {\n      margin:0;\n      background: linear-gradient(180deg,var(--code-bg), rgba(0,0,0,0.4));\n      padding:12px;\n      border-radius:8px;\n      overflow:auto;\n      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", \"Courier New\", monospace;\n      font-size:13px;\n      color:#daebff;\n      border: 1px solid rgba(255,255,255,0.03);\n    }\n    .controls { display:flex; gap:8px; margin-top:8px; }\n    button {\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));\n      color:#e6eef8;\n      border:1px solid rgba(255,255,255,0.04);\n      padding:8px 10px;\n      border-radius:8px;\n      cursor:pointer;\n      font-size:13px;\n    }\n    button.ghost { background:transparent; border:1px dashed rgba(255,255,255,0.03); color:var(--muted); }\n    button.primary { background: linear-gradient(180deg, rgba(96,165,250,0.18), rgba(96,165,250,0.08)); border:1px solid rgba(96,165,250,0.18); color:var(--accent); }\n    .actions { display:flex; gap:8px; align-items:center; }\n    .top-actions { display:flex; gap:8px; margin-bottom:12px; align-items:center; }\n    #output {\n      background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n      border-radius:10px;\n      padding:12px;\n      height:560px;\n      overflow:auto;\n      border: 1px solid rgba(255,255,255,0.02);\n    }\n    .log { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, \"Roboto Mono\", monospace; font-size:13px; color:#cfe9ff; margin:6px 0; white-space:pre-wrap; }\n    .meta { color:var(--muted); font-size:12px; margin-bottom:6px; }\n    .warn { color:#ffd580; }\n    .err { color:var(--danger); }\n    .small { font-size:12px; color:var(--muted); }\n    footer { margin-top:18px; color:var(--muted); font-size:12px; }\n    .copy-btn { margin-left:auto; background:transparent; border:0; color:var(--muted); cursor:pointer; padding:4px 8px; border-radius:6px; }\n    .example-row { display:flex; gap:8px; align-items:flex-start; }\n    @media (max-width:980px){ .layout { flex-direction:column; } .left, .right { width:100%; } #output { height:360px; } }\n  </style>\n</head>\n<body>\n  <header>\n    <div>\n      <h1>JavaScript Arrays — Interactive Demo</h1>\n      <p>Explore common Array concepts with runnable examples. Click \"Run\" to execute an example and see output below.</p>\n    </div>\n  </header>\n\n  <div class=\"layout\">\n    <div class=\"left\">\n      <div class=\"top-actions\">\n        <button id=\"runAll\" class=\"primary\">Run All</button>\n        <button id=\"clearOutput\" class=\"ghost\">Clear Output</button>\n        <div style=\"margin-left:auto\" class=\"small\">Examples: <span id=\"count\"></span></div>\n      </div>\n\n      <div id=\"examplesContainer\"></div>\n\n      <footer>\n        Tip: Examples use console.log to display results. Objects printed are the snapshot at log time.\n      </footer>\n    </div>\n\n    <div class=\"right\">\n      <div class=\"example\">\n        <div class=\"ex-title\"><h3>Output console</h3></div>\n        <div class=\"meta\">Outputs from running examples appear here. Use \"Clear Output\" to remove.</div>\n        <div id=\"output\" aria-live=\"polite\"></div>\n      </div>\n\n      <div class=\"example\" style=\"margin-top:12px\">\n        <h3 style=\"margin:0 0 6px 0\">Try your own code</h3>\n        <div class=\"ex-desc\">Enter JavaScript that uses console.log(...) to print results. It runs in a safe small scope with a custom console.</div>\n        <pre id=\"customCode\" class=\"code\" contenteditable spellcheck=\"false\">// Example:\n// const arr = [1,2,3];\n// console.log(arr.map(x => x*2));\n</pre>\n        <div class=\"controls\" style=\"margin-top:8px\">\n          <button id=\"runCustom\" class=\"primary\">Run Custom</button>\n          <button id=\"copyCustom\" class=\"ghost\">Copy Template</button>\n          <button id=\"clearCustom\" class=\"ghost\">Reset</button>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    // Examples data\n    const examples = [\n      {\n        id: 'creation',\n        title: 'Creation & Basic Access',\n        desc: 'Create arrays, access elements and the length property.',\n        code:\n`const arr = [10, 20, 30];\nconsole.log('arr =', arr);\nconsole.log('arr[0] =', arr[0]);\nconsole.log('arr[arr.length - 1] =', arr[arr.length - 1]);\nconsole.log('length =', arr.length);`\n      },\n      {\n        id: 'push-pop',\n        title: 'Push & Pop (stack)',\n        desc: 'Add/remove elements at the end.',\n        code:\n`let a = [1, 2];\nconsole.log('start:', a);\na.push(3);\nconsole.log('after push(3):', a);\nconst popped = a.pop();\nconsole.log('popped:', popped);\nconsole.log('after pop:', a);`\n      },\n      {\n        id: 'shift-unshift',\n        title: 'Shift & Unshift (queue-like)',\n        desc: 'Add/remove elements at the beginning.',\n        code:\n`let q = ['b', 'c'];\nconsole.log('start:', q);\nq.unshift('a');\nconsole.log('after unshift(\"a\"):', q);\nconst first = q.shift();\nconsole.log('shift() returned:', first);\nconsole.log('after shift:', q);`\n      },\n      {\n        id: 'slice-splice',\n        title: 'slice vs splice',\n        desc: 'slice is non-mutating; splice mutates.',\n        code:\n`const arr = [1, 2, 3, 4, 5];\nconst s = arr.slice(1, 4);\nconsole.log('original after slice:', arr);\nconsole.log('slice(1,4) =>', s);\n\nconst a = [1, 2, 3, 4, 5];\na.splice(2, 1, 'x', 'y'); // at index 2, remove 1 item, insert 'x','y'\nconsole.log('after splice:', a);`\n      },\n      {\n        id: 'map-filter-reduce',\n        title: 'map, filter, reduce',\n        desc: 'Functional transforms and aggregation.',\n        code:\n`const nums = [1, 2, 3, 4];\nconsole.log('nums:', nums);\n\nconst squares = nums.map(n => n * n);\nconsole.log('map -> squares:', squares);\n\nconst evens = nums.filter(n => n % 2 === 0);\nconsole.log('filter -> evens:', evens);\n\nconst sum = nums.reduce((acc, n) => acc + n, 0);\nconsole.log('reduce -> sum:', sum);`\n      },\n      {\n        id: 'iteration',\n        title: 'Iteration: forEach, for..of, for..in',\n        desc: 'Different ways to iterate arrays.',\n        code:\n`const letters = ['a', 'b', 'c'];\nconsole.log('letters:', letters);\n\nletters.forEach((v, i) => console.log('forEach', i, v));\nfor (const v of letters) console.log('for..of', v);\nfor (const i in letters) console.log('for..in', i, letters[i]);`\n      },\n      {\n        id: 'reference-copy',\n        title: 'Reference behavior & shallow copy',\n        desc: 'Arrays are objects; copy by reference vs shallow copying with spread.',\n        code:\n`const original = [{id:1}, {id:2}];\nconst refCopy = original;          // same array reference\nconst shallowCopy = [...original]; // new array, same element references\n\nconsole.log('original === refCopy?', original === refCopy);\nconsole.log('original === shallowCopy?', original === shallowCopy);\n\nrefCopy.push({id:3});\nconsole.log('after refCopy.push -> original:', original);\n\nshallowCopy[0].id = 99;\nconsole.log('after shallowCopy[0].id=99 -> original:', original);`\n      },\n      {\n        id: 'sparse',\n        title: 'Sparse arrays & length',\n        desc: 'Arrays can have holes; length reflects highest index + 1.',\n        code:\n`const a = [];\na[5] = 'five';\nconsole.log('array:', a);\nconsole.log('length:', a.length);\nconsole.log('index 0 in array?', 0 in a);\nconsole.log('index 5 in array?', 5 in a);\nconsole.log('iteration via for..of (skips holes):');\nfor (const v of a) console.log(v);`\n      },\n      {\n        id: 'from-of',\n        title: 'Array.from, Array.of, Array(n)',\n        desc: 'Create arrays from iterables or with specific shapes.',\n        code:\n`console.log('Array.from(\"hello\") =>', Array.from('hello'));\nconsole.log('Array.of(7) =>', Array.of(7));\nconsole.log('Array(3) =>', Array(3)); // creates [ <3 empty items> ]`;\n      },\n      {\n        id: 'sort',\n        title: 'Sorting arrays',\n        desc: 'Default lexicographic sort vs numeric compare.',\n        code:\n`const nums = [10, 2, 30];\nconsole.log('original:', nums);\nconsole.log('default sort (strings):', nums.slice().sort());\nconsole.log('numeric sort:', nums.slice().sort((a,b) => a - b));`\n      },\n      {\n        id: 'flat-flatMap',\n        title: 'flat & flatMap',\n        desc: 'Flatten nested arrays and map-then-flatten.',\n        code:\n`const nested = [1, [2, 3], [4, [5]]];\nconsole.log('nested:', nested);\nconsole.log('flat() -> depth 1:', nested.flat());\nconsole.log('flat(2) -> depth 2:', nested.flat(2));\n\nconsole.log('flatMap example:', [1,2,3].flatMap(x => [x, x*2]));`\n      },\n      {\n        id: 'typed',\n        title: 'Typed arrays',\n        desc: 'TypedArray (like Uint8Array) is not a plain Array.',\n        code:\n`const ta = new Uint8Array([10, 20, 30]);\nconsole.log('typed array:', ta);\nconsole.log('Array.isArray(ta)?', Array.isArray(ta));\nconsole.log('you can convert: Array.from(ta) =>', Array.from(ta));`\n      },\n      {\n        id: 'array-like',\n        title: 'Array-like objects',\n        desc: 'Convert array-like structures with length into arrays.',\n        code:\n`const arrLike = {0: 'a', 1: 'b', length: 2};\nconsole.log('array-like:', arrLike);\nconsole.log('Array.from(arrLike) =>', Array.from(arrLike));`\n      },\n      {\n        id: 'unique-set',\n        title: 'Remove duplicates with Set',\n        desc: 'Use Set to get unique elements quickly.',\n        code:\n`const dup = [1, 2, 2, 3, 3, 3];\nconsole.log('original:', dup);\nconsole.log('unique:', [...new Set(dup)]);`\n      }\n    ];\n\n    const examplesContainer = document.getElementById('examplesContainer');\n    const output = document.getElementById('output');\n    const countSpan = document.getElementById('count');\n\n    countSpan.textContent = examples.length;\n\n    // Utility: create a nicely formatted output entry\n    function appendOutput(title, lines = [], kind = 'log') {\n      const wrapper = document.createElement('div');\n      wrapper.className = 'log';\n      if (kind === 'warn') wrapper.classList.add('warn');\n      if (kind === 'err') wrapper.classList.add('err');\n\n      const time = new Date().toLocaleTimeString();\n      const header = document.createElement('div');\n      header.className = 'small';\n      header.style.marginBottom = '6px';\n      header.style.color = 'var(--muted)';\n      header.textContent = `${time} — ${title}`;\n      wrapper.appendChild(header);\n\n      const content = document.createElement('div');\n      content.style.whiteSpace = 'pre-wrap';\n      content.textContent = lines.join('\\\\n');\n      wrapper.appendChild(content);\n\n      output.appendChild(wrapper);\n      output.scrollTop = output.scrollHeight;\n    }\n\n    // Run code with a custom console passed into a Function scope,\n    // so we don't override the global console.\n    function runExampleCode(title, code) {\n      const logs = [];\n      const customConsole = {\n        log: (...args) => logs.push(args.map(formatValue).join(' ')),\n        warn: (...args) => logs.push(args.map(formatValue).join(' ')),\n        error: (...args) => logs.push(args.map(formatValue).join(' ')),\n      };\n\n      try {\n        // Use Function to provide console as local binding\n        const fn = new Function('console', code);\n        fn(customConsole);\n        appendOutput(title, logs.length ? logs : ['(no output)'], 'log');\n      } catch (err) {\n        appendOutput(title, [String(err)], 'err');\n        console.error(err);\n      }\n    }\n\n    // Pretty format values for the mini-console.\n    function formatValue(v) {\n      try {\n        if (v === null) return 'null';\n        if (v === undefined) return 'undefined';\n        if (typeof v === 'string') return v;\n        if (typeof v === 'number' || typeof v === 'boolean') return String(v);\n        if (Array.isArray(v)) return JSON.stringify(v, replacer, 2);\n        if (v instanceof Uint8Array || ArrayBuffer.isView(v)) {\n          return `${v.constructor.name}(${Array.from(v).join(', ')})`;\n        }\n        if (typeof v === 'object') return JSON.stringify(v, replacer, 2);\n        return String(v);\n      } catch (e) {\n        return String(v);\n      }\n    }\n\n    function replacer(key, value) {\n      if (typeof value === 'bigint') return value.toString() + 'n';\n      if (typeof value === 'function') return `[Function: ${value.name || 'anonymous'}]`;\n      return value;\n    }\n\n    // Build UI for each example\n    examples.forEach((ex, idx) => {\n      const container = document.createElement('div');\n      container.className = 'example';\n\n      const titleRow = document.createElement('div');\n      titleRow.className = 'ex-title';\n      const title = document.createElement('h3');\n      title.textContent = (idx + 1) + '. ' + ex.title;\n      const copyBtn = document.createElement('button');\n      copyBtn.className = 'copy-btn';\n      copyBtn.title = 'Copy code';\n      copyBtn.textContent = 'Copy';\n      titleRow.appendChild(title);\n      titleRow.appendChild(copyBtn);\n\n      const desc = document.createElement('div');\n      desc.className = 'ex-desc';\n      desc.textContent = ex.desc;\n\n      const codePre = document.createElement('pre');\n      codePre.className = 'code';\n      codePre.textContent = ex.code;\n\n      const controls = document.createElement('div');\n      controls.className = 'controls';\n      const runBtn = document.createElement('button');\n      runBtn.textContent = 'Run';\n      runBtn.className = 'primary';\n      const inspectBtn = document.createElement('button');\n      inspectBtn.textContent = 'Run + Inspect';\n      inspectBtn.title = 'Run and show raw result snapshot (same output as Run if example uses console.log)';\n      inspectBtn.className = '';\n      controls.appendChild(runBtn);\n      controls.appendChild(inspectBtn);\n\n      container.appendChild(titleRow);\n      container.appendChild(desc);\n      container.appendChild(codePre);\n      container.appendChild(controls);\n      examplesContainer.appendChild(container);\n\n      // Handlers\n      runBtn.addEventListener('click', () => {\n        runExampleCode(ex.title, ex.code);\n      });\n\n      inspectBtn.addEventListener('click', () => {\n        // Wrap code to capture return and console outputs as string\n        const wrapperCode = `\n(() => {\n  // We'll still use console for logs; but also return a snapshot if possible.\n  try {\n    const result = (function(){\n      ${ex.code}\n      return undefined;\n    })();\n    console.log('[[returned]]', result);\n  } catch (err) {\n    console.error(err);\n    throw err;\n  }\n})();\n`;\n        runExampleCode(ex.title + ' (inspect)', wrapperCode);\n      });\n\n      copyBtn.addEventListener('click', async () => {\n        try {\n          await navigator.clipboard.writeText(ex.code);\n          copyBtn.textContent = 'Copied!';\n          setTimeout(() => copyBtn.textContent = 'Copy', 1200);\n        } catch (e) {\n          copyBtn.textContent = 'Failed';\n          setTimeout(() => copyBtn.textContent = 'Copy', 1200);\n        }\n      });\n    });\n\n    // Global controls\n    document.getElementById('clearOutput').addEventListener('click', () => {\n      output.innerHTML = '';\n    });\n\n    document.getElementById('runAll').addEventListener('click', () => {\n      for (const ex of examples) {\n        runExampleCode(ex.title, ex.code);\n      }\n    });\n\n    // Custom code area handlers\n    const customElem = document.getElementById('customCode');\n    document.getElementById('runCustom').addEventListener('click', () => {\n      const code = customElem.textContent;\n      if (!code.trim()) {\n        appendOutput('Custom run', ['(no code provided)'], 'warn');\n        return;\n      }\n      runExampleCode('Custom code', code);\n    });\n\n    document.getElementById('copyCustom').addEventListener('click', async () => {\n      const template = `// Example:\n// const arr = [1, 2, 3];\n// console.log(arr.map(x => x * 2));`;\n      try {\n        await navigator.clipboard.writeText(template);\n        alert('Template copied to clipboard. Paste into the editor.');\n      } catch {\n        alert('Copy failed. You can select and copy manually.');\n      }\n    });\n\n    document.getElementById('clearCustom').addEventListener('click', () => {\n      customElem.textContent = '// Example:\\\\n// const arr = [1, 2, 3];\\\\n// console.log(arr.map(x => x * 2));';\n    });\n\n    // Small accessibility: allow Tab in the contenteditable pre\n    customElem.addEventListener('keydown', (e) => {\n      if (e.key === 'Tab') {\n        e.preventDefault();\n        const sel = window.getSelection();\n        if (!sel.rangeCount) return;\n        const range = sel.getRangeAt(0);\n        const tabNode = document.createTextNode('  ');\n        range.insertNode(tabNode);\n        range.setStartAfter(tabNode);\n        range.setEndAfter(tabNode);\n        sel.removeAllRanges();\n        sel.addRange(range);\n      }\n    });\n\n    // Initial example run for first one (optional)\n    // runExampleCode(examples[0].title, examples[0].code);\n  </script>\n</body>\n</html>"
  },
