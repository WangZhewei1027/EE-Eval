    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>DNS Concept Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2em;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    color: #005a9c;\n  }\n  #dns-form {\n    margin-bottom: 1.5em;\n  }\n  input[type=\"text\"] {\n    padding: 0.5em;\n    font-size: 1em;\n    width: 300px;\n    max-width: 80vw;\n  }\n  button {\n    padding: 0.55em 1em;\n    font-size: 1em;\n    margin-left: 0.5em;\n    cursor: pointer;\n  }\n  #result {\n    background: #fff;\n    border: 1px solid #ddd;\n    padding: 1em;\n    max-width: 500px;\n    word-break: break-word;\n    box-shadow: 0 2px 5px rgba(0,0,0,0.1);\n  }\n  p.explanation {\n    max-width: 700px;\n    line-height: 1.5;\n  }\n  mark {\n    background-color: #fffb91;\n  }\n</style>\n</head>\n<body>\n\n<h1>Understanding DNS (Domain Name System)</h1>\n\n<p class=\"explanation\">\n  The <strong>Domain Name System (DNS)</strong> is like the <mark>\"phonebook\"</mark> of the internet. Humans use domain names\n  like <code>example.com</code> to visit websites, but computers access websites using IP addresses like <code>93.184.216.34</code>.\n</p>\n\n<p class=\"explanation\">\n  DNS translates (or <em>resolves</em>) these human-friendly domain names into IP addresses that computers use to communicate.\n</p>\n\n<form id=\"dns-form\">\n  <label for=\"domain-input\">Enter a domain name:</label><br />\n  <input type=\"text\" id=\"domain-input\" placeholder=\"e.g. example.com\" required />\n  <button type=\"submit\">Resolve</button>\n</form>\n\n<div id=\"result\" aria-live=\"polite\"></div>\n\n<script>\n  /*\n    This demo simulates DNS resolution by mapping some example domains to their IP addresses.\n    In real usage, DNS lookup happens at the OS or network level.\n  */\n\n  const dnsTable = {\n    \"example.com\": [\"93.184.216.34\"],\n    \"google.com\": [\"142.250.190.14\", \"142.250.190.78\", \"142.250.190.46\"],\n    \"mozilla.org\": [\"44.236.72.129\"],\n    \"wikipedia.org\": [\"208.80.154.224\"],\n    \"github.com\": [\"140.82.114.3\"],\n    \"stackoverflow.com\": [\"151.101.65.69\"],\n    \"localhost\": [\"127.0.0.1\"],\n  };\n\n  const form = document.getElementById(\"dns-form\");\n  const input = document.getElementById(\"domain-input\");\n  const result = document.getElementById(\"result\");\n\n  function sanitize(str) {\n    const div = document.createElement('div');\n    div.textContent = str;\n    return div.innerHTML;\n  }\n\n  form.addEventListener(\"submit\", (e) => {\n    e.preventDefault();\n    const domain = input.value.trim().toLowerCase();\n\n    if (!domain) {\n      result.innerHTML = \"<em>Please enter a domain name.</em>\";\n      return;\n    }\n\n    // Simple validation: domain format (very basic)\n    const domainRegex = /^(?!-)[a-z0-9-]{1,63}(?<!-)(\\.[a-z]{2,})+$/i;\n    // We allow single label (e.g., localhost) for demo:\n    const singleLabelRegex = /^[a-z0-9-]{1,63}$/i;\n\n    if (!(domainRegex.test(domain) || singleLabelRegex.test(domain))) {\n      result.innerHTML = `<em>\"${sanitize(domain)}\" is not a valid domain name format.</em>`;\n      return;\n    }\n\n    if (dnsTable[domain]) {\n      const ips = dnsTable[domain];\n      result.innerHTML = `<strong>Domain:</strong> ${sanitize(domain)}<br>\n        <strong>Resolved IP address${ips.length > 1 ? \"es\" : \"\"}:</strong><br> \n        <ul>${ips.map(ip => `<li>${sanitize(ip)}</li>`).join('')}</ul>`;\n    } else {\n      result.innerHTML = `<em>Sorry, domain \"<strong>${sanitize(domain)}</strong>\" could not be resolved in this demo DNS table.</em>`;\n    }\n  });\n</script>\n\n</body>\n</html>"
