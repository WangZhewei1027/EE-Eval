  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <title>Interactive Linear Regression Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial; margin: 16px; color:#111; background: #f7f9fc; }\n    h1 { margin: 6px 0 12px 0; font-size:20px; }\n    .container { display:flex; gap:16px; align-items:flex-start; }\n    .panel { background: #fff; border-radius:8px; padding:12px; box-shadow: 0 2px 8px rgba(20,30,40,0.06); }\n    #plot { border-radius:6px; background: linear-gradient(180deg, #ffffff, #f3f8ff); cursor: crosshair; }\n    .controls { width:320px; }\n    label { display:block; font-size:13px; margin-top:8px; color:#333; }\n    button { margin:6px 6px 6px 0; padding:8px 10px; border-radius:6px; border:1px solid #cfd9e9; background:#eaf1ff; cursor:pointer; }\n    button.important { background:#2b7be3; color:#fff; border-color:#1f66d6; }\n    input[type=range] { width:100%; }\n    .row { display:flex; gap:8px; align-items:center; margin-top:8px; flex-wrap:wrap; }\n    .small { font-size:12px; color:#555; }\n    .stats { margin-top:10px; font-size:13px; }\n    .hint { font-size:12px; color:#666; margin-top:8px; }\n    .muted { color:#666; font-size:13px; }\n    pre { background:#f3f6fb; padding:8px; border-radius:6px; overflow:auto; }\n    .toggle { display:inline-flex; align-items:center; gap:6px; }\n    .toggle input { transform:scale(1.1); }\n    footer { margin-top:12px; font-size:12px; color:#666; }\n    a { color:#1e66d1; text-decoration:none; }\n  </style>\n</head>\n<body>\n  <h1>Interactive Linear Regression - Visual Explanation</h1>\n  <div class=\"container\">\n    <div class=\"panel\">\n      <canvas id=\"plot\" width=\"760\" height=\"420\"></canvas>\n      <div class=\"hint\">Click to add points. Shift+Click nearest point to remove. Use controls on the right to fit and explore.</div>\n    </div>\n\n    <div class=\"panel controls\">\n      <div>\n        <label>Dataset</label>\n        <div class=\"row\">\n          <button id=\"btnRandom\">Generate Random</button>\n          <button id=\"btnClear\">Clear</button>\n          <button id=\"btnFit\" class=\"important\">Fit (Closed-form)</button>\n        </div>\n\n        <label>Random Points</label>\n        <div class=\"row\">\n          <input id=\"nPoints\" type=\"range\" min=\"5\" max=\"200\" value=\"30\">\n          <div class=\"small\" id=\"nPointsVal\">30</div>\n        </div>\n\n        <label>Noise (σ)</label>\n        <div class=\"row\">\n          <input id=\"noise\" type=\"range\" min=\"0\" max=\"80\" value=\"12\">\n          <div class=\"small\" id=\"noiseVal\">12</div>\n        </div>\n\n        <label>Regression Visualization</label>\n        <div class=\"row\">\n          <button id=\"btnToggleResiduals\">Toggle Residuals</button>\n          <button id=\"btnTogglePoints\">Toggle Points</button>\n          <button id=\"btnResetView\">Reset View</button>\n        </div>\n\n        <label>Gradient Descent</label>\n        <div class=\"row\">\n          <button id=\"btnStartGD\">Start GD</button>\n          <button id=\"btnStopGD\">Stop</button>\n          <button id=\"btnStepGD\">Step</button>\n        </div>\n\n        <label>GD controls</label>\n        <div class=\"row\">\n          <div style=\"flex:1\">\n            <input id=\"lr\" type=\"range\" min=\"0.0001\" max=\"1\" step=\"0.0001\" value=\"0.02\">\n            <div class=\"small\">Learning rate <span id=\"lrVal\">0.02</span></div>\n          </div>\n          <div style=\"width:80px\">\n            <input id=\"gdIters\" type=\"number\" min=\"1\" step=\"1\" value=\"100\" style=\"width:100%\">\n          </div>\n        </div>\n\n        <label>Manual line (drag to change)</label>\n        <div class=\"row\">\n          <button id=\"btnShowManual\">Show Manual Line</button>\n          <button id=\"btnLockManual\">Lock Manual</button>\n        </div>\n\n        <div class=\"stats\">\n          <div><strong>Closed-form:</strong> <span id=\"equation\">m = -, b = -</span></div>\n          <div><strong>GD:</strong> <span id=\"equationGD\">m = -, b = -</span></div>\n          <div><strong>MSE:</strong> <span id=\"mse\">-</span></div>\n          <div><strong>R²:</strong> <span id=\"r2\">-</span></div>\n          <div><strong>SSE:</strong> <span id=\"sse\">-</span></div>\n          <div><strong>Points:</strong> <span id=\"nPts\">0</span></div>\n        </div>\n\n        <label>Options</label>\n        <div class=\"row\">\n          <label class=\"toggle\"><input id=\"showGDLine\" type=\"checkbox\" checked> Show GD Line</label>\n          <label class=\"toggle\"><input id=\"showClosedLine\" type=\"checkbox\" checked> Show Closed-form Line</label>\n          <label class=\"toggle\"><input id=\"showResiduals\" type=\"checkbox\"> Show Residuals</label>\n        </div>\n\n        <div class=\"muted\">\n          Explanation: Linear regression fits a line y = m*x + b to minimize squared errors. \"Closed-form\" uses the normal equation (optimal solution). Gradient descent iteratively updates m and b to reduce mean squared error.\n        </div>\n      </div>\n      <footer>Built entirely with HTML5 Canvas and JavaScript.</footer>\n    </div>\n  </div>\n\n  <script>\n  // Interactive Linear Regression Demo\n  // - Add/remove points by clicking\n  // - Generate random points\n  // - Fit closed-form solution\n  // - Visualize gradient descent (GD)\n  // - Toggle residuals, show stats (SSE, MSE, R^2)\n\n  (() => {\n    // Canvas and drawing\n    const canvas = document.getElementById('plot');\n    const ctx = canvas.getContext('2d');\n\n    const W = canvas.width;\n    const H = canvas.height;\n    const margin = {left:50, right:20, top:20, bottom:50};\n    const plotW = W - margin.left - margin.right;\n    const plotH = H - margin.top - margin.bottom;\n\n    // Data points (in data coordinate space)\n    let points = [];\n    // Default axis range (will autoscale)\n    let xrange = [0, 100];\n    let yrange = [0, 100];\n\n    // Closed-form solution\n    let closed = {m: NaN, b: NaN};\n\n    // Gradient descent state\n    let gd = {\n      m: 0,\n      b: 0,\n      running: false,\n      iter: 0\n    };\n\n    // Manual line (draggable)\n    let manual = {enabled: false, lock: false, dragging: false, m: 0, b: 0};\n\n    // UI elements\n    const btnRandom = document.getElementById('btnRandom');\n    const btnClear = document.getElementById('btnClear');\n    const btnFit = document.getElementById('btnFit');\n    const btnStartGD = document.getElementById('btnStartGD');\n    const btnStopGD = document.getElementById('btnStopGD');\n    const btnStepGD = document.getElementById('btnStepGD');\n    const btnToggleResiduals = document.getElementById('btnToggleResiduals');\n    const btnTogglePoints = document.getElementById('btnTogglePoints');\n    const btnResetView = document.getElementById('btnResetView');\n    const btnShowManual = document.getElementById('btnShowManual');\n    const btnLockManual = document.getElementById('btnLockManual');\n\n    const nPoints = document.getElementById('nPoints');\n    const nPointsVal = document.getElementById('nPointsVal');\n    const noise = document.getElementById('noise');\n    const noiseVal = document.getElementById('noiseVal');\n    const lr = document.getElementById('lr');\n    const lrVal = document.getElementById('lrVal');\n    const gdIters = document.getElementById('gdIters');\n\n    const equation = document.getElementById('equation');\n    const equationGD = document.getElementById('equationGD');\n    const mseEl = document.getElementById('mse');\n    const r2El = document.getElementById('r2');\n    const sseEl = document.getElementById('sse');\n    const nPtsEl = document.getElementById('nPts');\n\n    const showGDLine = document.getElementById('showGDLine');\n    const showClosedLine = document.getElementById('showClosedLine');\n    const showResiduals = document.getElementById('showResiduals');\n\n    // Toggles\n    let showPoints = true;\n\n    // Utility: transform data point -> canvas pixel\n    function dataToPixel([x,y]) {\n      const sx = (x - xrange[0]) / (xrange[1] - xrange[0]);\n      const sy = (y - yrange[0]) / (yrange[1] - yrange[0]);\n      return [\n        margin.left + sx * plotW,\n        margin.top + (1 - sy) * plotH\n      ];\n    }\n    function pixelToData(px, py) {\n      const sx = (px - margin.left) / plotW;\n      const sy = 1 - (py - margin.top) / plotH;\n      return [\n        xrange[0] + sx * (xrange[1] - xrange[0]),\n        yrange[0] + sy * (yrange[1] - yrange[0])\n      ];\n    }\n\n    // Autoscale range based on points with padding\n    function autoscale() {\n      if (points.length === 0) {\n        xrange = [0, 100]; yrange = [0, 100];\n        return;\n      }\n      let xmin = Infinity, xmax = -Infinity, ymin = Infinity, ymax = -Infinity;\n      for (const p of points) {\n        if (p[0] < xmin) xmin = p[0];\n        if (p[0] > xmax) xmax = p[0];\n        if (p[1] < ymin) ymin = p[1];\n        if (p[1] > ymax) ymax = p[1];\n      }\n      if (xmin === xmax) { xmin -= 1; xmax += 1; }\n      if (ymin === ymax) { ymin -= 1; ymax += 1; }\n      const padX = (xmax - xmin) * 0.12;\n      const padY = (ymax - ymin) * 0.12;\n      xrange = [xmin - padX, xmax + padX];\n      yrange = [ymin - padY, ymax + padY];\n    }\n\n    // Draw axes, grid, points, lines, residuals\n    function draw() {\n      ctx.clearRect(0,0,W,H);\n\n      // Background\n      ctx.fillStyle = '#fff';\n      ctx.fillRect(margin.left, margin.top, plotW, plotH);\n\n      // Grid lines and ticks\n      ctx.strokeStyle = '#e6eefc';\n      ctx.lineWidth = 1;\n      // choose 5 ticks\n      const xticks = 6;\n      const yticks = 6;\n      ctx.beginPath();\n      for (let i=0;i<=xticks;i++) {\n        const x = margin.left + i/xticks * plotW;\n        ctx.moveTo(x, margin.top);\n        ctx.lineTo(x, margin.top + plotH);\n      }\n      for (let j=0;j<=yticks;j++) {\n        const y = margin.top + j/yticks * plotH;\n        ctx.moveTo(margin.left, y);\n        ctx.lineTo(margin.left + plotW, y);\n      }\n      ctx.stroke();\n\n      // Axes border\n      ctx.strokeStyle = '#cbdaf5';\n      ctx.strokeRect(margin.left, margin.top, plotW, plotH);\n\n      // Axis labels (min/max)\n      ctx.fillStyle = '#334';\n      ctx.font = '12px system-ui, sans-serif';\n      ctx.textAlign = 'center';\n      for (let i=0;i<=xticks;i++) {\n        const sx = i/xticks;\n        const x = margin.left + sx * plotW;\n        const val = xrange[0] + sx * (xrange[1] - xrange[0]);\n        ctx.fillText(roundTo(val,2), x, H - 12);\n      }\n      ctx.textAlign = 'right';\n      for (let j=0;j<=yticks;j++) {\n        const sy = j/yticks;\n        const y = margin.top + sy * plotH;\n        const val = yrange[1] - sy * (yrange[1] - yrange[0]);\n        ctx.fillText(roundTo(val,2), margin.left - 8, y+4);\n      }\n\n      // Draw residuals if requested\n      if (showResiduals.checked && points.length > 0) {\n        if (showClosedLine.checked && !isNaN(closed.m)) {\n          ctx.strokeStyle = 'rgba(255,99,71,0.6)';\n          ctx.lineWidth = 1.5;\n          for (const p of points) {\n            const yhat = closed.m * p[0] + closed.b;\n            const a = dataToPixel(p);\n            const b = dataToPixel([p[0], yhat]);\n            ctx.beginPath();\n            ctx.moveTo(a[0], a[1]);\n            ctx.lineTo(b[0], b[1]);\n            ctx.stroke();\n          }\n        }\n      }\n\n      // Draw closed-form line\n      if (showClosedLine.checked && !isNaN(closed.m)) {\n        ctx.strokeStyle = '#2b7be3';\n        ctx.lineWidth = 2;\n        const x0 = xrange[0], x1 = xrange[1];\n        const p0 = dataToPixel([x0, closed.m * x0 + closed.b]);\n        const p1 = dataToPixel([x1, closed.m * x1 + closed.b]);\n        ctx.beginPath();\n        ctx.moveTo(p0[0], p0[1]);\n        ctx.lineTo(p1[0], p1[1]);\n        ctx.stroke();\n\n        // Label\n        ctx.fillStyle = '#2b7be3';\n        ctx.font = '12px sans-serif';\n        ctx.textAlign = 'left';\n        const midx = (p0[0]+p1[0])/2;\n        const midy = (p0[1]+p1[1])/2;\n        ctx.fillText('Closed-form', midx + 6, midy - 6);\n      }\n\n      // Draw GD line\n      if (showGDLine.checked) {\n        ctx.strokeStyle = '#ff9900';\n        ctx.lineWidth = 2;\n        const x0 = xrange[0], x1 = xrange[1];\n        const p0 = dataToPixel([x0, gd.m * x0 + gd.b]);\n        const p1 = dataToPixel([x1, gd.m * x1 + gd.b]);\n        ctx.beginPath();\n        ctx.moveTo(p0[0], p0[1]);\n        ctx.lineTo(p1[0], p1[1]);\n        ctx.stroke();\n\n        // Label\n        ctx.fillStyle = '#ff9900';\n        ctx.font = '12px sans-serif';\n        ctx.textAlign = 'right';\n        const midx = (p0[0]+p1[0])/2;\n        const midy = (p0[1]+p1[1])/2;\n        ctx.fillText('GD', midx - 6, midy + 14);\n      }\n\n      // Draw manual line (if enabled)\n      if (manual.enabled) {\n        ctx.strokeStyle = manual.lock ? '#6b34b8' : '#8b5cf6';\n        ctx.lineWidth = 2;\n        const x0 = xrange[0], x1 = xrange[1];\n        const p0 = dataToPixel([x0, manual.m * x0 + manual.b]);\n        const p1 = dataToPixel([x1, manual.m * x1 + manual.b]);\n        ctx.beginPath();\n        ctx.moveTo(p0[0], p0[1]);\n        ctx.lineTo(p1[0], p1[1]);\n        ctx.stroke();\n        ctx.fillStyle = manual.lock ? '#6b34b8' : '#8b5cf6';\n        ctx.font = '12px sans-serif';\n        ctx.fillText('Manual', p1[0] - 6, p1[1] + 14);\n      }\n\n      // Draw points\n      if (showPoints && points.length > 0) {\n        for (const p of points) {\n          const [px,py] = dataToPixel(p);\n          ctx.beginPath();\n          ctx.fillStyle = '#334';\n          ctx.strokeStyle = '#fff';\n          ctx.lineWidth = 1;\n          ctx.arc(px,py,5,0,Math.PI*2);\n          ctx.fill();\n          ctx.stroke();\n        }\n      }\n    }\n\n    // Rounds for display\n    function roundTo(v, d=3) {\n      if (!isFinite(v)) return '-';\n      const factor = Math.pow(10, d);\n      return Math.round(v*factor)/factor;\n    }\n\n    // Fit closed-form (least squares)\n    function fitClosedForm() {\n      const n = points.length;\n      if (n === 0) {\n        closed.m = NaN; closed.b = NaN; return;\n      }\n      let sx = 0, sy = 0;\n      for (const p of points) { sx += p[0]; sy += p[1]; }\n      const xbar = sx / n, ybar = sy / n;\n      let num = 0, den = 0;\n      for (const p of points) {\n        num += (p[0] - xbar) * (p[1] - ybar);\n        den += (p[0] - xbar) * (p[0] - xbar);\n      }\n      if (den === 0) { closed.m = 0; closed.b = ybar; }\n      else { closed.m = num / den; closed.b = ybar - closed.m * xbar; }\n      updateStats();\n    }\n\n    // Compute SSE, MSE, R2 (with closed-form predictions)\n    function computeStatsLine(m, b) {\n      const n = points.length;\n      if (n === 0) return {sse:0, mse:0, r2:NaN};\n      let sse = 0, ss_tot = 0;\n      let sy = 0;\n      for (const p of points) sy += p[1];\n      const ybar = sy / n;\n      for (const p of points) {\n        const yhat = m * p[0] + b;\n        sse += (p[1] - yhat) * (p[1] - yhat);\n        ss_tot += (p[1] - ybar) * (p[1] - ybar);\n      }\n      const mse = sse / n;\n      const r2 = ss_tot === 0 ? NaN : Math.max(0, 1 - sse / ss_tot);\n      return {sse, mse, r2};\n    }\n\n    function updateStats() {\n      const n = points.length;\n      nPtsEl.textContent = n;\n      if (!isNaN(closed.m)) {\n        equation.textContent = 'y = ' + roundTo(closed.m,4) + ' x + ' + roundTo(closed.b,4);\n      } else {\n        equation.textContent = '-';\n      }\n      if (!isNaN(gd.m)) {\n        equationGD.textContent = 'y = ' + roundTo(gd.m,4) + ' x + ' + roundTo(gd.b,4);\n      } else {\n        equationGD.textContent = '-';\n      }\n      const stats = (!isNaN(closed.m)) ? computeStatsLine(closed.m, closed.b) : {sse:'-', mse:'-', r2:'-'};\n      sseEl.textContent = isFinite(stats.sse) ? roundTo(stats.sse,4) : '-';\n      mseEl.textContent = isFinite(stats.mse) ? roundTo(stats.mse,4) : '-';\n      r2El.textContent = isFinite(stats.r2) ? roundTo(stats.r2,4) : '-';\n    }\n\n    // Gradient descent update (batch)\n    function gradientDescentStep(alpha) {\n      const n = points.length;\n      if (n === 0) return;\n      let dm = 0, db = 0;\n      for (const p of points) {\n        const pred = gd.m * p[0] + gd.b;\n        const err = pred - p[1];\n        dm += (2/n) * err * p[0];\n        db += (2/n) * err;\n      }\n      gd.m -= alpha * dm;\n      gd.b -= alpha * db;\n      gd.iter += 1;\n      updateStats();\n    }\n\n    // Generate random dataset with underlying slope and intercept, plus gaussian noise\n    function generateRandom(n, noiseSigma) {\n      points = [];\n      // choose true line\n      const trueM = randRange(-1.5, 1.8);\n      const trueB = randRange(-40, 40);\n      // choose x range\n      const xmin = randRange(-40, -5);\n      const xmax = randRange(5, 100);\n      for (let i=0;i<n;i++) {\n        const x = randRange(xmin, xmax);\n        const y = trueM * x + trueB + gaussianNoise() * noiseSigma;\n        points.push([x,y]);\n      }\n      // initialize gd to zero or closed solution\n      autoscale();\n      fitClosedForm();\n      gd.m = closed.m; gd.b = closed.b;\n      manual.m = closed.m; manual.b = closed.b;\n      updateStats();\n      draw();\n    }\n\n    // Helpers\n    function randRange(a,b) { return a + Math.random()*(b-a); }\n    // Box-Muller\n    function gaussianNoise() {\n      let u=0,v=0;\n      while(u===0) u=Math.random();\n      while(v===0) v=Math.random();\n      return Math.sqrt(-2*Math.log(u)) * Math.cos(2*Math.PI*v);\n    }\n\n    // Event handlers\n    canvas.addEventListener('mousedown', (ev) => {\n      const rect = canvas.getBoundingClientRect();\n      const px = ev.clientX - rect.left;\n      const py = ev.clientY - rect.top;\n      const [x,y] = pixelToData(px, py);\n      // Shift+Click: remove nearest point\n      if (ev.shiftKey) {\n        if (points.length > 0) {\n          let minIdx = -1, minDist = Infinity;\n          for (let i=0;i<points.length;i++) {\n            const dx = points[i][0] - x, dy = points[i][1] - y;\n            const d = dx*dx + dy*dy;\n            if (d < minDist) { minDist = d; minIdx = i; }\n          }\n          if (minIdx >= 0) {\n            points.splice(minIdx,1);\n            autoscale();\n            updateStats();\n            draw();\n          }\n        }\n        return;\n      }\n\n      // If manual line is enabled and user clicked near line, start dragging manual line\n      if (manual.enabled && !manual.lock) {\n        // distance from click to line (vertical distance in data coords)\n        const yline = manual.m * x + manual.b;\n        const d = Math.abs(y - yline);\n        // threshold in data coordinates (approx)\n        const thresholdData = (yrange[1]-yrange[0]) * 0.05;\n        if (d < thresholdData) {\n          manual.dragging = true;\n          manual.dragStart = {px,py, xm:x, ym:y, m0: manual.m, b0: manual.b};\n          return;\n        }\n      }\n\n      // Otherwise add a point\n      points.push([x,y]);\n      autoscale();\n      updateStats();\n      draw();\n    });\n\n    window.addEventListener('mousemove', (ev) => {\n      if (manual.dragging && manual.enabled && !manual.lock) {\n        const rect = canvas.getBoundingClientRect();\n        const px = ev.clientX - rect.left;\n        const py = ev.clientY - rect.top;\n        const [x,y] = pixelToData(px, py);\n        // compute delta: user dragging a reference point on line; update b preserving slope or adjust slope?\n        // We'll let drag change intercept such that at the clicked x the line passes through new y.\n        // new_b = y - m*x\n        manual.b = y - manual.m * x;\n        updateStats();\n        draw();\n      }\n    });\n\n    window.addEventListener('mouseup', (ev) => {\n      if (manual.dragging) {\n        manual.dragging = false;\n      }\n    });\n\n    // Controls\n    nPoints.addEventListener('input', () => nPointsVal.textContent = nPoints.value);\n    noise.addEventListener('input', () => noiseVal.textContent = noise.value);\n    lr.addEventListener('input', () => lrVal.textContent = lr.value);\n\n    btnRandom.addEventListener('click', () => {\n      generateRandom(parseInt(nPoints.value,10), parseFloat(noise.value));\n    });\n\n    btnClear.addEventListener('click', () => {\n      points = [];\n      closed.m = NaN; closed.b = NaN;\n      gd.m = 0; gd.b = 0; gd.iter = 0; gd.running = false;\n      manual = {enabled:false, lock:false, dragging:false, m:0, b:0};\n      autoscale();\n      updateStats();\n      draw();\n    });\n\n    btnFit.addEventListener('click', () => {\n      autoscale();\n      fitClosedForm();\n      // initialize GD to closed form so GD can be compared\n      gd.m = closed.m; gd.b = closed.b; gd.iter = 0;\n      manual.m = closed.m; manual.b = closed.b;\n      updateStats();\n      draw();\n    });\n\n    btnStartGD.addEventListener('click', () => {\n      if (points.length === 0) return;\n      gd.running = true;\n      // if gd has NaN, initialize\n      if (!isFinite(gd.m)) { gd.m = 0; gd.b = 0; }\n      runGD();\n    });\n\n    btnStopGD.addEventListener('click', () => {\n      gd.running = false;\n    });\n\n    btnStepGD.addEventListener('click', () => {\n      if (points.length === 0) return;\n      gradientDescentStep(parseFloat(lr.value));\n      draw();\n    });\n\n    btnToggleResiduals.addEventListener('click', () => {\n      showResiduals.checked = !showResiduals.checked;\n      draw();\n    });\n\n    btnTogglePoints.addEventListener('click', () => {\n      showPoints = !showPoints;\n      draw();\n    });\n\n    btnResetView.addEventListener('click', () => {\n      autoscale();\n      draw();\n    });\n\n    btnShowManual.addEventListener('click', () => {\n      manual.enabled = !manual.enabled;\n      // by default set manual to closed-form if available\n      if (manual.enabled && isFinite(closed.m)) {\n        manual.m = closed.m; manual.b = closed.b;\n      }\n      draw();\n    });\n\n    btnLockManual.addEventListener('click', () => {\n      manual.lock = !manual.lock;\n      draw();\n    });\n\n    showGDLine.addEventListener('change', draw);\n    showClosedLine.addEventListener('change', draw);\n    showResiduals.addEventListener('change', draw);\n\n    // GD main loop\n    function runGD() {\n      const maxSteps = parseInt(gdIters.value, 10) || 100;\n      let steps = 0;\n      function step() {\n        if (!gd.running) return;\n        if (points.length === 0) { gd.running = false; return; }\n        gradientDescentStep(parseFloat(lr.value));\n        draw();\n        steps++;\n        if (steps < maxSteps && gd.running) {\n          // schedule next iteration quickly, but allow UI responsiveness\n          requestAnimationFrame(step);\n        } else {\n          // stop after maxSteps\n          // allow user to continue by clicking Start again\n          gd.running = false;\n        }\n      }\n      // run first animation frame\n      requestAnimationFrame(step);\n    }\n\n    // Compute initial axes and draw\n    autoscale();\n    draw();\n\n    // Utility: update stats when points change\n    function refresh() {\n      autoscale();\n      updateStats();\n      draw();\n    }\n\n    // Initialize with some default data\n    generateRandom(30, 12);\n\n    // Expose some debugging to console (optional)\n    window._lrDemo = {points, fitClosedForm, gradientDescentStep, closed, gd, manual, refresh};\n\n  })();\n  </script>\n</body>\n</html>"
  },
  "messages": [
