    "content": "<html>\n<head>\n    <title>Quick Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #result {\n            font-size: 24px;\n            font-weight: bold;\n            margin-top: 20px;\n        }\n    </style>\n</head>\n<body>\n    <h1>Quick Sort</h1>\n    <button id=\"sort-button\">Sort</button>\n    <div id=\"result\"></div>\n\n    <script>\n        function quickSort(arr) {\n            if (arr.length <= 1) {\n                return arr;\n            }\n            let pivot = arr[Math.floor(arr.length / 2)];\n            let left = [];\n            let right = [];\n            for (let i = 0; i < arr.length; i++) {\n                if (arr[i] < pivot) {\n                    left.push(arr[i]);\n                } else {\n                    right.push(arr[i]);\n                }\n            }\n            return quickSort(left).concat(pivot, quickSort(right));\n        }\n\n        let arr = [9, 4, 7, 1, 5, 3, 6, 8, 2];\n        let sortedArr = quickSort(arr);\n        document.getElementById(\"result\").innerHTML = \"Sorted array: \" + sortedArr.join(', ');\n    </script>\n</body>\n</html>"
