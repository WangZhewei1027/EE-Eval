    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>AVL Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #tree {\n            width: 50%;\n            margin: 40px auto;\n            text-align: center;\n        }\n    </style>\n</head>\n<body>\n    <h1>AVL Tree</h1>\n    <div id=\"tree\"></div>\n\n    <script>\n        class Node {\n            constructor(key, left = null, right = null) {\n                this.key = key;\n                this.left = left;\n                this.right = right;\n            }\n        }\n\n        class AVLTree {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(key) {\n                this.root = this._insert(this.root, key);\n            }\n\n            _insert(node, key) {\n                if (node === null) {\n                    return new Node(key);\n                }\n\n                if (key < node.key) {\n                    node.left = this._insert(node.left, key);\n                } else {\n                    node.right = this._insert(node.right, key);\n                }\n\n                // Balance the tree\n                if (this._balance(node) > 1) {\n                    if (key < node.left.key) {\n                        return this._rightRotate(node);\n                    } else {\n                        node.left = this._leftRotate(node.left);\n                        return this._rightRotate(node);\n                    }\n                }\n\n                if (this._balance(node) < -1) {\n                    if (key > node.right.key) {\n                        return this._leftRotate(node);\n                    } else {\n                        node.right = this._rightRotate(node.right);\n                        return this._leftRotate(node);\n                    }\n                }\n\n                return node;\n            }\n\n            _balance(node) {\n                let height = this._getHeight(node);\n                return height - 1;\n            }\n\n            _getHeight(node) {\n                if (node === null) {\n                    return 0;\n                }\n\n                return Math.max(this._getHeight(node.left), this._getHeight(node.right)) + 1;\n            }\n\n            _leftRotate(node) {\n                let newRoot = node.right;\n                node.right = newRoot.left;\n                newRoot.left = node;\n                return newRoot;\n            }\n\n            _rightRotate(node) {\n                let newRoot = node.left;\n                node.left = newRoot.right;\n                newRoot.right = node;\n                return newRoot;\n            }\n\n            _printTree(node, level = 0) {\n                if (node !== null) {\n                    this._printTree(node.right, level + 1);\n                    console.log('  '.repeat(level) + node.key + ' ');\n                    this._printTree(node.left, level + 1);\n                }\n            }\n        }\n\n        let tree = new AVLTree();\n        tree.insert(10);\n        tree.insert(20);\n        tree.insert(5);\n        tree.insert(15);\n        tree.insert(25);\n        tree.insert(7);\n        tree.insert(12);\n        tree.insert(18);\n        tree.insert(22);\n        tree.insert(17);\n\n        tree._printTree(tree.root);\n    </script>\n</body>\n</html>"
