  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>TCP/IP Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{\n      --bg:#0f1724; --card:#0b1220; --accent:#2dd4bf; --muted:#98a0b3; --good:#16a34a; --bad:#ef4444;\n    }\n    html,body{height:100%;margin:0;font-family:Inter,Segoe UI,Roboto,Arial;color:#e6eef8;background:linear-gradient(180deg,#071026 0%, #071226 60%);-webkit-font-smoothing:antialiased}\n    .container{max-width:1100px;margin:24px auto;padding:20px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:12px;box-shadow:0 6px 30px rgba(2,6,23,0.6)}\n    h1{margin:0 0 6px;font-size:20px;color:var(--accent)}\n    p.lead{margin:6px 0 18px;color:var(--muted);font-size:13px}\n    .row{display:flex;gap:18px;align-items:flex-start}\n    .left{flex:1;min-width:320px}\n    .right{width:420px}\n    .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.03);padding:12px;border-radius:10px;color:#cfe7ff}\n    .controls{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n    button{background:transparent;border:1px solid rgba(255,255,255,0.06);color:var(--accent);padding:8px 10px;border-radius:8px;cursor:pointer}\n    button.secondary{color:var(--muted)}\n    button.danger{color:var(--bad);border-color:rgba(239,68,68,0.15)}\n    .hosts{position:relative;height:320px;margin-top:12px;border-radius:8px;overflow:hidden;background:linear-gradient(90deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));border:1px solid rgba(255,255,255,0.02)}\n    .host{position:absolute;top:30px;width:230px;height:260px;border-radius:10px;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border:1px solid rgba(255,255,255,0.03);padding:12px;box-sizing:border-box}\n    .host.left{left:20px}\n    .host.right{right:20px}\n    .host h3{margin:0;font-size:14px;color:var(--accent)}\n    .host .meta{font-size:12px;color:var(--muted);margin-top:6px}\n    .layer{margin-top:12px;font-size:12px}\n    .wire{position:absolute;left:280px;right:280px;top:45%;height:2px;background:linear-gradient(90deg,#1e3a8a33,#06b6d433);opacity:0.6;border-radius:2px}\n    .packet{position:absolute;padding:6px 8px;border-radius:6px;background:linear-gradient(180deg,#0ea5a733,#0284c733);color:#011428;font-weight:600;font-size:13px;box-shadow:0 6px 20px rgba(2,6,23,0.6);transform:translateY(-50%);pointer-events:auto;cursor:pointer}\n    .packet .sub{font-weight:600;font-size:11px;color:#032a3a;display:block;margin-top:4px}\n    .log{height:240px;overflow:auto;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.00));border-radius:8px;padding:8px;margin-top:8px;font-size:13px;color:var(--muted)}\n    .small{font-size:12px;color:var(--muted)}\n    .status{margin-top:8px;font-size:13px}\n    .legend{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n    .chip{padding:6px 8px;border-radius:999px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.03);font-size:12px}\n    .controls input[type=range]{width:120px}\n    .infoBlock{background:rgba(255,255,255,0.02);border-radius:8px;padding:8px;margin-top:10px;font-size:13px;color:var(--muted)}\n    .footer{margin-top:14px;font-size:12px;color:var(--muted)}\n    .ipBox{display:inline-block;padding:4px 6px;border-radius:6px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.03);font-size:12px;color:#cfe7ff;margin-right:6px}\n    /* small tooltips/details */\n    .details{position:absolute;z-index:30;padding:8px;border-radius:8px;background:#031826;color:#aee3f0;border:1px solid rgba(255,255,255,0.06);font-size:12px;pointer-events:none;opacity:0;transition:opacity .12s}\n    .bad{color:var(--bad)}\n    .good{color:var(--good)}\n    .muted{color:var(--muted)}\n    .controls .toggle{display:flex;align-items:center;gap:6px}\n  </style>\n</head>\n<body>\n  <div class=\"container\" id=\"app\">\n    <h1>TCP/IP Interactive Demo</h1>\n    <p class=\"lead\">Visualize how TCP runs on top of IP: connection handshake, sequencing, acknowledgements and retransmission. Click controls to step through or run an automated transfer. Hover packets during transit to inspect headers.</p>\n\n    <div class=\"row\">\n      <div class=\"left panel\">\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <div>\n            <div style=\"font-size:13px;color:var(--muted)\">Hosts</div>\n            <div style=\"font-weight:700;color:#d9fff7\">Client ↔ Server</div>\n          </div>\n          <div class=\"legend\">\n            <div class=\"chip\">IP: network layer routing</div>\n            <div class=\"chip\">TCP: reliable transport</div>\n            <div class=\"chip\">Window: flow control</div>\n          </div>\n        </div>\n\n        <div class=\"hosts\" id=\"space\">\n          <div class=\"host left\" id=\"client\">\n            <h3>Client</h3>\n            <div class=\"meta\">IP <span class=\"ipBox\" id=\"cli-ip\">10.0.0.1</span> Port <span class=\"ipBox\" id=\"cli-port\">50000</span></div>\n            <div class=\"layer\"><strong>Application:</strong> sends \"GET /index\"</div>\n            <div class=\"layer\"><strong>Transport:</strong> TCP</div>\n            <div class=\"layer\"><strong>Network:</strong> IPv4</div>\n            <div class=\"layer small\">Seq: <span id=\"cli-seq\">0</span> | Ack: <span id=\"cli-ack\">0</span> | Window: <span id=\"cli-win\">6</span></div>\n          </div>\n\n          <div class=\"host right\" id=\"server\">\n            <h3>Server</h3>\n            <div class=\"meta\">IP <span class=\"ipBox\" id=\"srv-ip\">10.0.0.2</span> Port <span class=\"ipBox\" id=\"srv-port\">80</span></div>\n            <div class=\"layer\"><strong>Application:</strong> responds with content</div>\n            <div class=\"layer\"><strong>Transport:</strong> TCP</div>\n            <div class=\"layer\"><strong>Network:</strong> IPv4</div>\n            <div class=\"layer small\">Seq: <span id=\"srv-seq\">0</span> | Ack: <span id=\"srv-ack\">0</span> | Window: <span id=\"srv-win\">6</span></div>\n          </div>\n\n          <div class=\"wire\"></div>\n        </div>\n\n        <div style=\"margin-top:12px;display:flex;gap:10px;align-items:center;justify-content:space-between\">\n          <div class=\"controls\">\n            <button id=\"btn-hand\">Start 3-way Handshake</button>\n            <button id=\"btn-send\" class=\"secondary\">Send Data (3 segments)</button>\n            <button id=\"btn-auto\" class=\"secondary\">Run Auto Transfer</button>\n            <button id=\"btn-loss\" class=\"danger\">Toggle Packet Loss: OFF</button>\n            <button id=\"btn-reset\" class=\"secondary\">Reset</button>\n          </div>\n\n          <div style=\"text-align:right\">\n            <div class=\"small\">RTT (ms)</div>\n            <input type=\"range\" id=\"rtt\" min=\"50\" max=\"1200\" value=\"220\">\n            <div class=\"small\">Timeout: <span id=\"rtt-val\">220</span> ms</div>\n          </div>\n        </div>\n\n        <div class=\"infoBlock\">\n          <strong>How it works</strong>\n          <div class=\"small\" style=\"margin-top:6px\">TCP ensures reliable, ordered delivery over IP. This demo shows the SYN → SYN-ACK → ACK handshake, sending segments with sequence numbers, acknowledgements, sliding window, and retransmission if a packet is lost before being acknowledged.</div>\n        </div>\n      </div>\n\n      <div class=\"right\">\n        <div class=\"panel\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <div style=\"font-size:13px;color:var(--muted)\">Packet Log</div>\n            <div class=\"small muted\">Hover moving packet to inspect headers</div>\n          </div>\n          <div class=\"log\" id=\"log\"></div>\n          <div class=\"status\">\n            Connection: <span id=\"conn-state\" class=\"muted\">CLOSED</span>\n          </div>\n          <div style=\"margin-top:8px;display:flex;gap:6px;flex-wrap:wrap\">\n            <div class=\"chip\">SND.NXT: <span id=\"snd-nxt\">0</span></div>\n            <div class=\"chip\">RCV.NXT: <span id=\"rcv-nxt\">0</span></div>\n            <div class=\"chip\">CWND: <span id=\"cwnd\">6</span></div>\n          </div>\n\n          <div class=\"footer\">This is a simplified educational simulation—sequence numbers and windows are small integers for clarity.</div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"details\" id=\"details\"></div>\n  </div>\n\n<script>\n/*\n  TCP/IP Interactive Demo\n  - Single-file demo showing TCP handshake, segmented data transfer, ACKs, and retransmission.\n  - Click \"Start 3-way Handshake\", then \"Send Data\". Toggle packet loss to see retransmit.\n  - Hover packets while they move to inspect a simplified IP/TCP header.\n*/\n\n// DOM references\nconst space = document.getElementById('space');\nconst btnHand = document.getElementById('btn-hand');\nconst btnSend = document.getElementById('btn-send');\nconst btnAuto = document.getElementById('btn-auto');\nconst btnLoss = document.getElementById('btn-loss');\nconst btnReset = document.getElementById('btn-reset');\nconst logEl = document.getElementById('log');\nconst rttRange = document.getElementById('rtt');\nconst rttVal = document.getElementById('rtt-val');\nconst details = document.getElementById('details');\nconst connStateEl = document.getElementById('conn-state');\n\nconst cliSeqEl = document.getElementById('cli-seq');\nconst cliAckEl = document.getElementById('cli-ack');\nconst cliWinEl = document.getElementById('cli-win');\nconst srvSeqEl = document.getElementById('srv-seq');\nconst srvAckEl = document.getElementById('srv-ack');\nconst srvWinEl = document.getElementById('srv-win');\n\nconst sndNxt = document.getElementById('snd-nxt');\nconst rcvNxt = document.getElementById('rcv-nxt');\nconst cwndEl = document.getElementById('cwnd');\n\nrttVal.textContent = rttRange.value;\n\n// Simulation parameters and state\nlet simulation = {\n  lossEnabled: false,\n  rtt: Number(rttRange.value),\n  packets: [], // moving packets on screen\n  tickHandle: null,\n  nextPacketId: 1,\n  connState: 'CLOSED', // CLOSED, SYN_SENT, ESTABLISHED\n  client: { ip: '10.0.0.1', port: 50000, seq: 1000, ack: 0, win: 6 },\n  server: { ip: '10.0.0.2', port: 80, seq: 5000, ack: 0, win: 6 },\n  snd_nxt: 0, rcv_nxt: 0, cwnd: 6,\n  outstanding: {}, // seq -> packet info for retransmission\n  autoMode: false\n};\n\n// Initialize displayed values\nfunction refreshStatus(){\n  document.getElementById('cli-ip').textContent = simulation.client.ip;\n  document.getElementById('srv-ip').textContent = simulation.server.ip;\n  document.getElementById('cli-port').textContent = simulation.client.port;\n  document.getElementById('srv-port').textContent = simulation.server.port;\n  cliSeqEl.textContent = simulation.client.seq;\n  cliAckEl.textContent = simulation.client.ack;\n  cliWinEl.textContent = simulation.client.win;\n  srvSeqEl.textContent = simulation.server.seq;\n  srvAckEl.textContent = simulation.server.ack;\n  srvWinEl.textContent = simulation.server.win;\n  connStateEl.textContent = simulation.connState;\n  sndNxt.textContent = simulation.snd_nxt;\n  rcvNxt.textContent = simulation.rcv_nxt;\n  cwndEl.textContent = simulation.cwnd;\n}\n\n// Logging utility\nfunction log(text, cls){\n  const el = document.createElement('div');\n  el.innerHTML = `<span class=\"small muted\">[${new Date().toLocaleTimeString()}]</span> ${text}`;\n  if(cls) el.classList.add(cls);\n  logEl.prepend(el);\n}\n\n// UI actions\nrttRange.addEventListener('input', () => {\n  simulation.rtt = Number(rttRange.value);\n  rttVal.textContent = rttRange.value;\n});\n\nbtnLoss.addEventListener('click', () => {\n  simulation.lossEnabled = !simulation.lossEnabled;\n  btnLoss.textContent = `Toggle Packet Loss: ${simulation.lossEnabled ? 'ON' : 'OFF'}`;\n  btnLoss.style.borderColor = simulation.lossEnabled ? 'rgba(239,68,68,0.35)' : 'rgba(255,255,255,0.06)';\n});\n\n// Reset\nbtnReset.addEventListener('click', resetSimulation);\n\n// Handshake\nbtnHand.addEventListener('click', async () => {\n  if(simulation.connState !== 'CLOSED') {\n    log('Connection already in progress or open.', 'muted');\n    return;\n  }\n  await doThreeWayHandshake();\n});\n\n// Send data\nbtnSend.addEventListener('click', () => {\n  if(simulation.connState !== 'ESTABLISHED') {\n    log('Connection not established. Run handshake first.', 'muted');\n    return;\n  }\n  sendDataSegments(3);\n});\n\n// Auto transfer\nbtnAuto.addEventListener('click', () => {\n  simulation.autoMode = !simulation.autoMode;\n  btnAuto.textContent = simulation.autoMode ? 'Stop Auto' : 'Run Auto Transfer';\n  if(simulation.autoMode) {\n    runAuto();\n  }\n});\n\nfunction runAuto(){\n  if(!simulation.autoMode) return;\n  if(simulation.connState === 'CLOSED'){\n    doThreeWayHandshake().then(()=> {\n      if(simulation.autoMode) sendDataSegments(8,true);\n    });\n  } else if(simulation.connState === 'ESTABLISHED'){\n    sendDataSegments(8,true);\n  }\n}\n\n// Reset everything to initial\nfunction resetSimulation(){\n  // clear packets\n  for(const p of simulation.packets.slice()) removePacket(p);\n  simulation.packets = [];\n  simulation.nextPacketId = 1;\n  simulation.connState = 'CLOSED';\n  simulation.client.seq = 1000;\n  simulation.client.ack = 0;\n  simulation.server.seq = 5000;\n  simulation.server.ack = 0;\n  simulation.snd_nxt = 0;\n  simulation.rcv_nxt = 0;\n  simulation.cwnd = 6;\n  simulation.outstanding = {};\n  simulation.autoMode = false;\n  btnAuto.textContent = 'Run Auto Transfer';\n  logEl.innerHTML = '';\n  log('Simulation reset.');\n  refreshStatus();\n}\n\n// Packet creation and DOM animation\nfunction makePacket(opts){\n  // opts: direction ('c2s' or 's2c'), type ('SYN','SYN-ACK','ACK','DATA'), seq, ack, len\n  const id = simulation.nextPacketId++;\n  const div = document.createElement('div');\n  div.className = 'packet';\n  div.dataset.id = id;\n  div.style.top = (space.offsetTop + 50 + Math.random()*140) + 'px';\n  // starting x depends on direction\n  const leftHost = document.querySelector('.host.left');\n  const rightHost = document.querySelector('.host.right');\n  const spaceRect = space.getBoundingClientRect();\n  const startX = opts.direction === 'c2s' ? leftHost.getBoundingClientRect().right - spaceRect.left : rightHost.getBoundingClientRect().left - spaceRect.left - 80;\n  div.style.left = startX + 'px';\n  div.innerHTML = `${opts.type} <span class=\"sub\">${opts.seq ? 'seq=' + opts.seq : ''}${opts.len ? ' len=' + opts.len : ''}</span>`;\n  space.appendChild(div);\n\n  // attach interaction for header details\n  div.addEventListener('mouseenter', (e) => {\n    showDetails(opts, e.clientX, e.clientY);\n  });\n  div.addEventListener('mousemove', (e) => {\n    showDetails(opts, e.clientX, e.clientY);\n  });\n  div.addEventListener('mouseleave', () => {\n    hideDetails();\n  });\n\n  const pkt = {\n    id, el: div, opts, progress: 0, status: 'moving', createdAt: Date.now()\n  };\n  simulation.packets.push(pkt);\n  return pkt;\n}\n\nfunction removePacket(pkt){\n  try{\n    space.removeChild(pkt.el);\n  }catch(e){}\n  simulation.packets = simulation.packets.filter(p => p.id !== pkt.id);\n}\n\n// show small details box\nfunction showDetails(opts, x, y){\n  const ipHeader = `IP: ${opts.direction==='c2s' ? simulation.client.ip : simulation.server.ip} → ${opts.direction==='c2s' ? simulation.server.ip : simulation.client.ip}`;\n  const tcpHeader = `TCP: ${opts.type} | srcPort=${opts.direction==='c2s'?simulation.client.port:simulation.server.port} dstPort=${opts.direction==='c2s'?simulation.server.port:simulation.client.port}`;\n  const seq = opts.seq ? `Seq: ${opts.seq}` : '';\n  const ack = opts.ack ? `Ack: ${opts.ack}` : '';\n  const len = opts.len ? `Len: ${opts.len}` : '';\n  const lines = [ipHeader, tcpHeader, seq, ack, len].filter(Boolean).join('<br>');\n  details.innerHTML = lines;\n  details.style.left = (x + 12) + 'px';\n  details.style.top = (y + 12) + 'px';\n  details.style.opacity = '1';\n}\n\nfunction hideDetails(){\n  details.style.opacity = '0';\n}\n\n// Movement and delivery\nfunction tick(){\n  const dt = 16; // approximate ms per tick\n  const toDeliver = [];\n  for(const pkt of simulation.packets.slice()){\n    if(pkt.status !== 'moving') continue;\n    const el = pkt.el;\n    const rect = el.getBoundingClientRect();\n    const spaceRect = space.getBoundingClientRect();\n    // travel time scales with RTT: half RTT to cross\n    const travel = simulation.rtt / 2;\n    pkt.progress += dt / travel;\n    // linear interpolation\n    const leftHost = document.querySelector('.host.left').getBoundingClientRect();\n    const rightHost = document.querySelector('.host.right').getBoundingClientRect();\n    const startX = pkt.opts.direction==='c2s' ? leftHost.right - spaceRect.left : rightHost.left - spaceRect.left - 80;\n    const endX = pkt.opts.direction==='c2s' ? rightHost.left - spaceRect.left - 120 : leftHost.right - spaceRect.left + 20;\n    const x = startX + (endX - startX) * Math.min(pkt.progress,1);\n    el.style.left = x + 'px';\n    // slight vertical bob\n    const topBase = parseFloat(el.style.top);\n    el.style.top = (topBase + Math.sin(pkt.progress * Math.PI * 2) * 4) + 'px';\n    // when progress >= 1, deliver\n    if(pkt.progress >= 1){\n      // packet might be dropped if loss enabled\n      if(simulation.lossEnabled && Math.random() < 0.25 && pkt.opts.type !== 'ACK'){\n        // drop it\n        pkt.status = 'dropped';\n        el.style.opacity = '0.18';\n        el.style.transform = 'translateY(-50%) scale(0.9)';\n        el.style.background = 'linear-gradient(180deg,#ff333366,#ff444433)';\n        log(`Packet #${pkt.id} (${pkt.opts.type}) DROPPED in transit`, 'bad');\n        // still remove after short delay\n        setTimeout(()=> removePacket(pkt), 900);\n        // Do not call deliver callbacks\n      } else {\n        pkt.status = 'delivered';\n        toDeliver.push(pkt);\n      }\n    }\n  }\n  // deliver after loop to avoid mutation problems\n  for(const pkt of toDeliver){\n    deliverPacket(pkt);\n    removePacket(pkt);\n  }\n  // retransmission timers\n  checkRetransmissions();\n  // schedule next\n  simulation.tickHandle = requestAnimationFrame(tick);\n}\n\n// deliver to destination host (handle TCP/IP actions)\nfunction deliverPacket(pkt){\n  const o = pkt.opts;\n  const from = o.direction === 'c2s' ? 'client' : 'server';\n  const to = o.direction === 'c2s' ? 'server' : 'client';\n\n  const src = simulation[from];\n  const dst = simulation[to];\n\n  // IP layer: would route; simplified: immediate delivery to host's TCP\n  log(`Delivered ${o.type} from ${src.ip}:${from === 'client' ? src.port : src.port} → ${dst.ip}`, 'good');\n\n  // Process TCP types\n  if(o.type === 'SYN'){\n    if(to === 'server'){\n      // server receives SYN: set ack to seq+1, send SYN-ACK\n      simulation.server.ack = o.seq + 1;\n      simulation.server.seq = simulation.server.seq; // initial sequence (unchanged)\n      refreshStatus();\n      // send SYN-ACK back\n      scheduleSend('s2c', 'SYN-ACK', simulation.server.seq, simulation.server.ack, 0);\n      // increment server seq for SYN as occupying one\n      simulation.server.seq += 1;\n      refreshStatus();\n    }\n  } else if(o.type === 'SYN-ACK'){\n    if(to === 'client'){\n      // client receives SYN-ACK, updates ack to server_seq+1, send ACK\n      simulation.client.ack = o.seq + 1;\n      simulation.client.seq = simulation.client.seq; // previous\n      refreshStatus();\n      // send final ACK\n      scheduleSend('c2s', 'ACK', simulation.client.seq, simulation.client.ack, 0);\n      // connection established after client sends ACK (we'll mark when delivered)\n    }\n  } else if(o.type === 'ACK'){\n    // generic ACK: could be final handshake ack or data ack\n    // If from server to client and ack matches client sequencing, handshake complete\n    if(from === 'client' && to === 'server'){\n      // client's ACK to server (final handshake ACK or data ack)\n      // If server was waiting for handshake ack and ack equals server.seq, handshake done\n      if(simulation.connState !== 'ESTABLISHED' && simulation.client.ack === simulation.server.seq){\n        simulation.connState = 'ESTABLISHED';\n        log('Connection ESTABLISHED (3-way handshake complete)', 'good');\n      }\n    } else if(from === 'server' && to === 'client'){\n      // server acking client's data: update client outstanding\n      handleAckAtSender(o.ack);\n    } else if(from === 'client' && to === 'server'){\n      // client acking server data\n      handleAckAtReceiver(o.ack);\n    }\n    refreshStatus();\n  } else if(o.type === 'DATA'){\n    // deliver data to receiving side: update rcv_nxt, send ACK\n    const recv = dst;\n    // accept if seq matches expected rcv_nxt\n    if(simulation.rcv_nxt === 0) simulation.rcv_nxt = o.seq; // initial\n    if(o.seq === simulation.rcv_nxt){\n      simulation.rcv_nxt = o.seq + o.len; // advance\n      // server/client ack\n      const ackNum = simulation.rcv_nxt;\n      scheduleSend(o.direction === 'c2s' ? 's2c' : 'c2s', 'ACK', (o.direction === 'c2s' ? simulation.server.seq : simulation.client.seq), ackNum, 0);\n      log(`Received DATA seq=${o.seq} len=${o.len} accepted, sending ACK ${ackNum}`, 'good');\n    } else {\n      // out-of-order: send duplicate ACK for current rcv_nxt\n      const ackNum = simulation.rcv_nxt;\n      scheduleSend(o.direction === 'c2s' ? 's2c' : 'c2s', 'ACK', (o.direction === 'c2s' ? simulation.server.seq : simulation.client.seq), ackNum, 0);\n      log(`Received out-of-order DATA seq=${o.seq} (expected ${simulation.rcv_nxt}), sending dup ACK ${ackNum}`, 'muted');\n    }\n    refreshStatus();\n  }\n}\n\n// handle ack at client side acknowledging sent data\nfunction handleAckAtSender(ackNum){\n  // remove outstanding segments with seq < ackNum\n  const removed = [];\n  for(const seq in simulation.outstanding){\n    if(Number(seq) < ackNum){\n      removed.push(seq);\n      delete simulation.outstanding[seq];\n    }\n  }\n  if(removed.length){\n    log(`ACK ${ackNum} received - cleared outstanding seq < ${ackNum}`, 'good');\n  } else {\n    // could be dup ack\n    log(`ACK ${ackNum} received (no outstanding cleared)`, 'muted');\n  }\n  // if no outstanding, maybe finish auto mode\n  if(Object.keys(simulation.outstanding).length === 0 && simulation.autoMode){\n    log('All outstanding segments acknowledged.');\n    // optionally stop or continue transfer\n  }\n  refreshStatus();\n}\n\n// For client acknowledging server (not heavily used here)\nfunction handleAckAtReceiver(ackNum){\n  // simple update\n  log(`Receiver ACK ${ackNum}`, 'muted');\n  refreshStatus();\n}\n\n// schedule a packet with a short small delay (simulate processing)\nfunction scheduleSend(direction, type, seq, ack, len){\n  setTimeout(()=>{\n    const pkt = makePacket({direction,type,seq,ack,len});\n    // for DATA from client to server, register outstanding for retransmission if from client\n    if(direction === 'c2s' && type === 'DATA'){\n      // track by seq\n      simulation.outstanding[seq] = {seq, len, sentAt: Date.now(), attempts:1, pktId:pkt.id};\n      simulation.snd_nxt = seq + len;\n      log(`Sent DATA seq=${seq} len=${len} (outstanding)`, 'muted');\n    } else if(direction === 'c2s' && type === 'ACK'){\n      // final handshake ack from client -> server: after delivered we will mark ESTABLISHED\n      log(`Sent ACK seq=${seq} ack=${ack}`, 'muted');\n    } else {\n      // other types\n      log(`Sent ${type} seq=${seq} ack=${ack}`, 'muted');\n    }\n  }, Math.max(20, Math.random()*60));\n}\n\n// 3-Way handshake implementation\nasync function doThreeWayHandshake(){\n  resetSimulation(); // start fresh\n  simulation.connState = 'SYN_SENT';\n  refreshStatus();\n  log('Client: sending SYN', 'muted');\n  // client sends SYN with initial seq\n  scheduleSend('c2s','SYN', simulation.client.seq, 0, 0);\n  // start the tick if not running\n  if(!simulation.tickHandle) simulation.tickHandle = requestAnimationFrame(tick);\n  // We will mark established when server's ACK arrives (handled in delivery)\n  // To help user, add a timeout check that after some time sets ESTABLISHED if handshake completed:\n  // (no additional code needed—delivered ACK causes state change)\n}\n\n// send multiple data segments from client to server implementing simple retransmit timer\nfunction sendDataSegments(count, fromAuto=false){\n  if(!simulation.tickHandle) simulation.tickHandle = requestAnimationFrame(tick);\n  // keep seq from client seq (client.seq was initial value); we will use snd_nxt as pointer\n  let baseSeq = simulation.client.seq; // note: earlier in handshake client.seq hasn't been incremented except SYN usage; we keep data seq starting at this\n  if(simulation.connState !== 'ESTABLISHED'){\n    log('Connection not established; cannot send data.', 'muted');\n    return;\n  }\n  // send segments sized 1..2 for clarity\n  for(let i=0;i<count;i++){\n    const segLen = 1; // small for clarity\n    const seq = simulation.client.seq + i*segLen;\n    // schedule send with small spacing (simulate pipeline)\n    setTimeout(()=> {\n      scheduleSend('c2s','DATA', seq, 0, segLen);\n      // update outstanding\n    }, i*120);\n  }\n  // update client seq pointer\n  simulation.snd_nxt = simulation.client.seq + count;\n  simulation.outstanding = simulation.outstanding || {};\n  refreshStatus();\n}\n\n// Retransmission: if outstanding segment not acked within RTT*1.5, retransmit\nfunction checkRetransmissions(){\n  const now = Date.now();\n  const rto = Math.max(100, simulation.rtt * 1.6);\n  for(const seqStr in simulation.outstanding){\n    const o = simulation.outstanding[seqStr];\n    if(now - o.sentAt > rto){\n      // retransmit\n      log(`RTO: retransmitting seq=${o.seq} (attempt ${o.attempts+1})`, 'bad');\n      o.sentAt = now;\n      o.attempts += 1;\n      // re-send packet\n      scheduleSend('c2s','DATA', o.seq, 0, o.len);\n      // exponential backoff could be applied\n    }\n  }\n}\n\n// Start animation loop on load\n(function init(){\n  refreshStatus();\n  log('Ready. Click \"Start 3-way Handshake\" to begin.', 'muted');\n  // tick starts when needed\n})();\n\n// ensure cleanup on unload\nwindow.addEventListener('beforeunload', () => {\n  if(simulation.tickHandle) cancelAnimationFrame(simulation.tickHandle);\n});\n</script>\n</body>\n</html>"
