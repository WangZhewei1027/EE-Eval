    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<title>Depth-First Search (DFS) Visualization</title>\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<style>\n  :root{\n    --bg:#0f1724;\n    --panel:#0b1220;\n    --muted:#9aa4b2;\n    --accent:#7dd3fc;\n    --good:#10b981;\n    --bad:#ef4444;\n    --wall:#111827;\n    --cell:#0b1223;\n  }\n  html,body{height:100%;margin:0;background:linear-gradient(180deg,#071023 0%, #071827 100%);font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial; color:#e6eef6;}\n  .app{display:flex;gap:18px;padding:18px;box-sizing:border-box;height:100%;}\n  .left{\n    width:680px;\n    background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));\n    border-radius:12px;padding:16px;box-shadow:0 6px 24px rgba(2,6,23,0.6);\n    display:flex;flex-direction:column;gap:12px;\n  }\n  .gridWrap{background:linear-gradient(180deg,#081022, #0d1626);border-radius:10px;padding:12px;display:flex;justify-content:center;align-items:center;}\n  .grid{display:grid;border-radius:6px;overflow:hidden;user-select:none;}\n  .cell{\n    width:26px;height:26px;border:1px solid rgba(255,255,255,0.03);box-sizing:border-box;display:flex;align-items:center;justify-content:center;font-size:11px;color:transparent;\n    transition:background-color 120ms linear, transform 80ms ease;\n  }\n  .cell.wall{background:var(--wall);cursor:pointer;}\n  .cell.empty{background:var(--cell);cursor:pointer;}\n  .cell.start{background:var(--good);color:#022; font-weight:700;}\n  .cell.goal{background:var(--bad);color:#fff; font-weight:700;}\n  .cell.visited{background:#2bb7f0;color:#022;}\n  .cell.explored{background:#60a5fa;color:#022;}\n  .cell.path{background:#7c3aed;color:#fff;}\n  .cell.stackTop{outline:3px solid rgba(255,248,200,0.12);}\n  .controls{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}\n  button, select{background:transparent;border:1px solid rgba(255,255,255,0.06);padding:8px 12px;border-radius:8px;color:var(--muted);cursor:pointer;}\n  button.primary{background:linear-gradient(90deg,#06b6d4,#7c3aed);border:none;color:white;font-weight:600;}\n  button.warn{background:linear-gradient(90deg,#ef4444,#f97316);border:none;color:white;}\n  .modeBtns{display:flex;gap:6px;}\n  .modeBtns button.active{border-color:rgba(125,211,252,0.18);color:var(--accent);box-shadow:0 4px 16px rgba(21,163,184,0.06)}\n  .side{flex:1;display:flex;flex-direction:column;gap:12px;}\n  .panel{background:linear-gradient(180deg,#071220,#071220);padding:12px;border-radius:10px;border:1px solid rgba(255,255,255,0.03);box-shadow:0 6px 18px rgba(2,6,23,0.6);}\n  .panel h3{margin:0 0 8px 0;font-size:14px;color:var(--accent);}\n  label{font-size:13px;color:var(--muted);display:block;margin-bottom:6px;}\n  .row{display:flex;gap:8px;align-items:center;}\n  .stackList{max-height:180px;overflow:auto;padding:6px;border-radius:8px;background:linear-gradient(180deg, rgba(255,255,255,0.015), transparent);border:1px solid rgba(255,255,255,0.02);}\n  .stackItem{padding:6px;border-radius:6px;margin-bottom:6px;background:rgba(255,255,255,0.01);font-family:monospace;color:var(--muted);font-size:13px;}\n  .legend{display:flex;gap:8px;flex-wrap:wrap;}\n  .legend .item{display:flex;gap:6px;align-items:center;font-size:13px;color:var(--muted);}\n  .square{width:18px;height:18px;border-radius:4px;}\n  .info{font-size:13px;color:var(--muted);line-height:1.4;}\n  .pseudocode{font-family:monospace;background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;color:var(--muted);font-size:13px;white-space:pre;}\n  footer{font-size:12px;color:var(--muted);text-align:center;margin-top:6px;}\n  input[type=\"range\"]{width:140px;}\n  .small{font-size:12px;color:var(--muted);}\n  @media (max-width:980px){ .app{flex-direction:column;padding:12px;} .left{width:100%} }\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <div class=\"left panel\">\n    <div class=\"row\" style=\"justify-content:space-between;align-items:center\">\n      <div>\n        <h3 style=\"margin:0;color:var(--accent)\">Depth-First Search — Interactive</h3>\n        <div class=\"small\">Draw walls, set start and goal, then run DFS to explore.</div>\n      </div>\n      <div style=\"display:flex;gap:8px;align-items:center\">\n        <button id=\"runBtn\" class=\"primary\">Run DFS</button>\n        <button id=\"stepBtn\">Step</button>\n        <button id=\"stopBtn\">Stop</button>\n      </div>\n    </div>\n\n    <div class=\"controls\">\n      <div class=\"modeBtns\" title=\"Choose drawing mode\">\n        <button id=\"modeWall\" class=\"active\">Wall</button>\n        <button id=\"modeStart\">Start</button>\n        <button id=\"modeGoal\">Goal</button>\n        <button id=\"eraseBtn\">Erase</button>\n      </div>\n      <label class=\"small\" style=\"margin:0 8px 0 0;\">Speed</label>\n      <input id=\"speed\" type=\"range\" min=\"20\" max=\"800\" value=\"160\">\n      <label class=\"small\" id=\"speedLabel\">160 ms</label>\n      <button id=\"clearVisited\">Clear Visited</button>\n      <button id=\"resetAll\" class=\"warn\">Reset</button>\n    </div>\n\n    <div class=\"gridWrap\">\n      <div id=\"grid\" class=\"grid\" aria-hidden=\"true\"></div>\n    </div>\n\n    <div style=\"display:flex;gap:10px;justify-content:space-between;align-items:center;\">\n      <div class=\"legend\">\n        <div class=\"item\"><div class=\"square\" style=\"background:var(--good)\"></div> Start</div>\n        <div class=\"item\"><div class=\"square\" style=\"background:var(--bad)\"></div> Goal</div>\n        <div class=\"item\"><div class=\"square\" style=\"background:#2bb7f0\"></div> Visited (pushed)</div>\n        <div class=\"item\"><div class=\"square\" style=\"background:#60a5fa\"></div> Explored (popped)</div>\n        <div class=\"item\"><div class=\"square\" style=\"background:#7c3aed\"></div> Final path</div>\n        <div class=\"item\"><div class=\"square\" style=\"background:var(--wall)\"></div> Wall</div>\n      </div>\n      <div class=\"small\">Grid: <span id=\"gridSize\">20×20</span></div>\n    </div>\n\n  </div>\n\n  <div class=\"side\">\n    <div class=\"panel\">\n      <h3>Algorithm</h3>\n      <div class=\"info\">\n        Depth-First Search explores as far as possible along each branch before backtracking.\n        This demo uses an explicit stack (iterative DFS). You can watch nodes get pushed to the stack,\n        popped for exploration, and see the final path when the goal is reached (if reachable).\n      </div>\n      <div style=\"height:10px\"></div>\n      <div class=\"pseudocode\">\nDFS(start, goal):\n  stack = [start]\n  parent[start] = null\n  visited = set(start)\n\n  while stack not empty:\n    node = stack.pop()\n    if node == goal: return reconstruct_path(parent,node)\n    for neighbor in neighbors(node):\n      if neighbor not in visited and not wall:\n        visited.add(neighbor)\n        parent[neighbor] = node\n        stack.push(neighbor)\n      end\n    end\n  end\n  return \"no path\"\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <h3>Call Stack / Stack (top-first)</h3>\n      <div id=\"stack\" class=\"stackList\"></div>\n    </div>\n\n    <div class=\"panel\">\n      <h3>Controls & Info</h3>\n      <div class=\"row\" style=\"justify-content:space-between;\">\n        <button id=\"toggleOrder\">Order: Up,Right,Down,Left</button>\n        <button id=\"resizeBtn\">Resize Grid</button>\n      </div>\n      <div style=\"height:8px\"></div>\n      <label class=\"small\">Modes:</label>\n      <div class=\"small\">\n        - Wall: click/drag to paint walls. Erase: remove walls. Set Start/Goal: click a cell.<br>\n        - Run: animates DFS automatically. Step: advances one DFS operation per press.\n      </div>\n      <div style=\"height:8px\"></div>\n      <div class=\"small\">Tip: Use \"Clear Visited\" to keep walls/start/goal and run again.</div>\n    </div>\n\n    <footer>DFS visualizer — iterative (stack) example</footer>\n  </div>\n</div>\n\n<script>\n(() => {\n  // Configuration\n  let rows = 20, cols = 20;\n  const gridEl = document.getElementById('grid');\n  const gridSizeEl = document.getElementById('gridSize');\n  const stackEl = document.getElementById('stack');\n  const speedEl = document.getElementById('speed');\n  const speedLabel = document.getElementById('speedLabel');\n  const runBtn = document.getElementById('runBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const stopBtn = document.getElementById('stopBtn');\n  const clearVisitedBtn = document.getElementById('clearVisited');\n  const resetAllBtn = document.getElementById('resetAll');\n  const modeWall = document.getElementById('modeWall');\n  const modeStart = document.getElementById('modeStart');\n  const modeGoal = document.getElementById('modeGoal');\n  const eraseBtn = document.getElementById('eraseBtn');\n  const toggleOrderBtn = document.getElementById('toggleOrder');\n  const resizeBtn = document.getElementById('resizeBtn');\n\n  // State\n  let mode = 'wall'; // wall | start | goal | erase\n  let isMouseDown = false;\n  let start = {r: 0, c: 0};\n  let goal = {r: rows - 1, c: cols - 1};\n  let cells = []; // 2D array of cell objects\n  let visited = new Set();\n  let parent = new Map();\n  let stack = [];\n  let exploring = false;\n  let stepping = false;\n  let speed = Number(speedEl.value);\n  let order = ['up','right','down','left']; // neighbor order\n\n  // Helpers\n  function key(r,c){ return r+','+c; }\n  function parseKey(k){ const [r,c]=k.split(',').map(Number); return {r,c}; }\n\n  function makeGrid(r,c){\n    rows = r; cols = c;\n    gridEl.style.gridTemplateColumns = `repeat(${cols}, 26px)`;\n    gridEl.style.gridTemplateRows = `repeat(${rows}, 26px)`;\n    gridEl.innerHTML = '';\n    cells = Array.from({length:rows},(_,ridx)=>Array.from({length:cols},(_,cidx)=>{\n      const el = document.createElement('div');\n      el.className = 'cell empty';\n      el.dataset.r = ridx;\n      el.dataset.c = cidx;\n      el.title = `${ridx},${cidx}`;\n      gridEl.appendChild(el);\n      return {el, r:ridx, c:cidx, wall:false};\n    }));\n    // default start/goal\n    start = {r: Math.floor(rows/4), c: Math.floor(cols/4)};\n    goal = {r: Math.floor(rows*3/4), c: Math.floor(cols*3/4)};\n    setCellType(start.r,start.c,'start');\n    setCellType(goal.r,goal.c,'goal');\n    gridSizeEl.textContent = `${rows}×${cols}`;\n  }\n\n  function setCellType(r,c,type){\n    const cell = cells[r][c];\n    cell.el.className = 'cell';\n    if(type === 'wall'){\n      cell.wall = true;\n      cell.el.classList.add('wall');\n    } else {\n      cell.wall = false;\n      if(type === 'start') cell.el.classList.add('start');\n      else if(type === 'goal') cell.el.classList.add('goal');\n      else cell.el.classList.add('empty');\n    }\n  }\n\n  function clearVisited(keepWalls=true){\n    visited.clear();\n    parent.clear();\n    stack = [];\n    document.querySelectorAll('.cell.visited').forEach(e=>{ e.classList.remove('visited'); e.classList.add('empty'); });\n    document.querySelectorAll('.cell.explored').forEach(e=>{ e.classList.remove('explored'); if(!e.classList.contains('start') && !e.classList.contains('goal')) e.classList.add('empty'); });\n    document.querySelectorAll('.cell.path').forEach(e=>{ e.classList.remove('path'); if(!e.classList.contains('start') && !e.classList.contains('goal')) e.classList.add('empty'); });\n    // ensure walls remain only if keepWalls true; if false, clear all walls\n    if(!keepWalls){\n      for(let r=0;r<rows;r++) for(let c=0;c<cols;c++) cells[r][c].wall=false;\n      document.querySelectorAll('.cell.wall').forEach(e=>e.classList.remove('wall'));\n    }\n    updateStackView();\n  }\n\n  function resetAll(){\n    exploring = false;\n    stepping = false;\n    clearVisited(false);\n    // reset start/goal to defaults\n    makeGrid(rows,cols);\n  }\n\n  function neighbors(r,c){\n    const out = [];\n    for(const dir of order){\n      if(dir==='up' && r>0) out.push({r:r-1,c});\n      if(dir==='down' && r<rows-1) out.push({r:r+1,c});\n      if(dir==='left' && c>0) out.push({r,c:c-1});\n      if(dir==='right' && c<cols-1) out.push({r,c:c+1});\n    }\n    return out;\n  }\n\n  function updateCellVisual(r,c){\n    const k = key(r,c);\n    const cell = cells[r][c];\n    const el = cell.el;\n    // reset classification except walls/start/goal\n    if(cell.wall){ el.className='cell wall'; return; }\n    if(start.r===r && start.c===c){ el.className='cell start'; return; }\n    if(goal.r===r && goal.c===c){ el.className='cell goal'; return; }\n    // other classes may be set already: visited/explored/path/empty\n  }\n\n  function updateStackView(){\n    stackEl.innerHTML = '';\n    for(let i = stack.length-1;i>=0;i--){ // show top first\n      const s = stack[i];\n      const div = document.createElement('div');\n      div.className='stackItem';\n      div.textContent=`(${s.r}, ${s.c})`;\n      stackEl.appendChild(div);\n    }\n    // mark stack top visually in grid\n    document.querySelectorAll('.cell.stackTop').forEach(e=>e.classList.remove('stackTop'));\n    if(stack.length>0){\n      const t = stack[stack.length-1];\n      const el = cells[t.r][t.c].el;\n      el.classList.add('stackTop');\n    }\n  }\n\n  // DFS algorithm (iterative). We'll implement a step generator for step-by-step control.\n  function* dfsGenerator(){\n    visited = new Set();\n    parent = new Map();\n    stack = [];\n    stack.push({r:start.r,c:start.c});\n    parent.set(key(start.r,start.c), null);\n    visited.add(key(start.r,start.c));\n    // mark visited visually (pushed)\n    cells[start.r][start.c].el.classList.add('visited');\n\n    updateStackView();\n    yield; // allow UI update before starting main loop\n\n    while(stack.length>0){\n      const node = stack.pop();\n      const nodeKey = key(node.r,node.c);\n      // mark popped/explored\n      // If it was previously visited (pushed) keep that class but also add explored\n      if(!cells[node.r][node.c].el.classList.contains('explored'))\n        cells[node.r][node.c].el.classList.add('explored');\n      updateStackView();\n      yield;\n\n      // check goal\n      if(node.r===goal.r && node.c===goal.c){\n        // reconstruct path\n        let curKey = nodeKey;\n        const path = [];\n        while(curKey !== null){\n          const p = parseKey(curKey);\n          path.push(p);\n          curKey = parent.get(curKey);\n        }\n        // draw path\n        for(const p of path){\n          if(!(p.r===start.r && p.c===start.c) && !(p.r===goal.r && p.c===goal.c)){\n            const el = cells[p.r][p.c].el;\n            el.classList.remove('visited','explored');\n            el.classList.add('path');\n          }\n        }\n        updateStackView();\n        yield {found:true};\n        return;\n      }\n\n      // explore neighbors\n      const neigh = neighbors(node.r,node.c);\n      for(const nb of neigh){\n        const k = key(nb.r,nb.c);\n        if(visited.has(k)) continue;\n        if(cells[nb.r][nb.c].wall) continue;\n        // visit (push)\n        visited.add(k);\n        parent.set(k, nodeKey);\n        stack.push({r:nb.r,c:nb.c});\n        cells[nb.r][nb.c].el.classList.add('visited');\n        updateStackView();\n        yield;\n      }\n    }\n\n    yield {found:false};\n  }\n\n  // Controller for animation\n  let gen = null;\n  let runTimer = null;\n  function runAuto(){\n    if(exploring) return;\n    exploring = true;\n    stepping = false;\n    gen = dfsGenerator();\n    // kickstart\n    gen.next();\n    runTimer = setInterval(()=>{\n      const res = gen.next();\n      if(res.done){\n        exploring = false;\n        clearInterval(runTimer);\n        runTimer = null;\n      } else if(res.value && typeof res.value === 'object'){\n        exploring = false;\n        clearInterval(runTimer);\n        runTimer = null;\n        // final state reached: res.value.found says if found\n        if(res.value.found === true){\n          // nothing more\n        } else {\n          // no path found\n        }\n      }\n    }, speed);\n  }\n\n  function stepOnce(){\n    if(!exploring){\n      exploring = true;\n      stepping = true;\n      gen = dfsGenerator();\n      gen.next(); // initial\n    }\n    const res = gen.next();\n    if(res.done){\n      exploring = false;\n      stepping = false;\n    } else if(res.value && typeof res.value==='object'){\n      exploring = false;\n      stepping = false;\n    }\n  }\n\n  function stopRun(){\n    exploring = false;\n    stepping = false;\n    if(runTimer){ clearInterval(runTimer); runTimer=null; }\n    gen = null;\n    // clean stack top highlights\n    document.querySelectorAll('.cell.stackTop').forEach(e=>e.classList.remove('stackTop'));\n  }\n\n  // Event wiring\n  function setMode(newMode){\n    mode = newMode;\n    document.querySelectorAll('.modeBtns button').forEach(b=>b.classList.remove('active'));\n    if(mode==='wall') modeWall.classList.add('active');\n    if(mode==='start') modeStart.classList.add('active');\n    if(mode==='goal') modeGoal.classList.add('active');\n    if(mode==='erase') eraseBtn.classList.add('active');\n  }\n\n  // Mouse interactions on grid\n  gridEl.addEventListener('mousedown', e=>{\n    if(e.target.classList.contains('cell')){\n      isMouseDown = true;\n      handleCellInteraction(e.target);\n    }\n  });\n  gridEl.addEventListener('mousemove', e=>{\n    if(isMouseDown && e.target.classList.contains('cell')){\n      handleCellInteraction(e.target, true);\n    }\n  });\n  document.addEventListener('mouseup', ()=>{ isMouseDown = false; });\n\n  function handleCellInteraction(el, dragging=false){\n    if(exploring) return; // prevent edits while running\n    const r = Number(el.dataset.r);\n    const c = Number(el.dataset.c);\n    if(mode === 'wall'){\n      // toggle wall on press, paint on drag\n      cells[r][c].wall = true;\n      el.className='cell wall';\n      // ensure not start/goal\n      if(start.r===r && start.c===c){ start = findAnyEmpty(); }\n      if(goal.r===r && goal.c===c){ goal = findAnyEmpty(start); }\n      updateCellVisual(start.r,start.c);\n      updateCellVisual(goal.r,goal.c);\n    } else if(mode === 'erase'){\n      cells[r][c].wall = false;\n      el.classList.remove('wall','visited','explored','path');\n      el.classList.add('empty');\n    } else if(mode === 'start'){\n      // set start, ensure we don't put start on a wall\n      cells[start.r][start.c].el.classList.remove('start');\n      start = {r,c};\n      cells[r][c].wall = false;\n      el.classList.remove('wall','visited','explored','path');\n      el.classList.add('start');\n    } else if(mode === 'goal'){\n      cells[goal.r][goal.c].el.classList.remove('goal');\n      goal = {r,c};\n      cells[r][c].wall = false;\n      el.classList.remove('wall','visited','explored','path');\n      el.classList.add('goal');\n    }\n  }\n\n  function findAnyEmpty(prefer){\n    for(let r=0;r<rows;r++){\n      for(let c=0;c<cols;c++){\n        if(!cells[r][c].wall && !(prefer && r===prefer.r && c===prefer.c)) return {r,c};\n      }\n    }\n    return {r:0,c:0};\n  }\n\n  // Buttons and UI\n  modeWall.addEventListener('click',()=>setMode('wall'));\n  modeStart.addEventListener('click',()=>setMode('start'));\n  modeGoal.addEventListener('click',()=>setMode('goal'));\n  eraseBtn.addEventListener('click',()=>setMode('erase'));\n\n  runBtn.addEventListener('click', ()=> {\n    clearInterval(runTimer);\n    runTimer = null;\n    clearVisited(true);\n    runAuto();\n  });\n  stepBtn.addEventListener('click', ()=> {\n    if(!stepping){\n      clearVisited(true);\n      stepOnce();\n    } else {\n      stepOnce();\n    }\n  });\n  stopBtn.addEventListener('click', ()=> stopRun());\n\n  clearVisitedBtn.addEventListener('click', ()=> {\n    stopRun();\n    clearVisited(true);\n  });\n\n  resetAllBtn.addEventListener('click', ()=> {\n    stopRun();\n    resetAll();\n  });\n\n  speedEl.addEventListener('input', ()=>{\n    speed = Number(speedEl.value);\n    speedLabel.textContent = `${speed} ms`;\n    if(runTimer){\n      clearInterval(runTimer);\n      runTimer = setInterval(()=>{\n        const res = gen.next();\n        if(res.done){ exploring=false; clearInterval(runTimer); runTimer=null; }\n      }, speed);\n    }\n  });\n\n  toggleOrderBtn.addEventListener('click', ()=>{\n    if(order[0]==='up'){\n      order = ['left','up','right','down'];\n      toggleOrderBtn.textContent = 'Order: Left,Up,Right,Down';\n    } else {\n      order = ['up','right','down','left'];\n      toggleOrderBtn.textContent = 'Order: Up,Right,Down,Left';\n    }\n  });\n\n  resizeBtn.addEventListener('click', ()=>{\n    stopRun();\n    const input = prompt('Enter grid size as rows,cols (e.g. 20,20):', `${rows},${cols}`);\n    if(!input) return;\n    const parts = input.split(',').map(x=>parseInt(x.trim(),10));\n    if(parts.length!==2 || isNaN(parts[0]) || isNaN(parts[1]) || parts[0]<4 || parts[1]<4 || parts[0]>60 || parts[1]>60){\n      alert('Invalid size. Use two numbers between 4 and 60.');\n      return;\n    }\n    makeGrid(parts[0],parts[1]);\n  });\n\n  // initial setup\n  makeGrid(rows,cols);\n\n  // small accessibility: allow keyboard arrows to move start / goal while holding S or G (optional)\n  // but avoid complexity; keep simple.\n\n  // Expose some utility to console for debugging\n  window._dfsViz = {\n    cells, start, goal, clearVisited, resetAll, runAuto, stepOnce\n  };\n\n})();\n</script>\n</body>\n</html>"
  },
