  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Backpropagation Demonstration</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    body { font-family: system-ui, -apple-system, \"Segoe UI\", Roboto, Arial; margin: 12px; color: #111; }\n    h1 { font-size: 20px; margin: 6px 0 12px; }\n    #app { display: flex; gap: 16px; }\n    #left { width: 520px; }\n    #canvasWrap { background:#fff; border:1px solid #ddd; padding:8px; border-radius:8px; }\n    svg { width: 500px; height: 300px; display:block; }\n    .controls { margin-top: 10px; display:flex; gap:8px; flex-wrap:wrap; }\n    button { padding:6px 10px; border-radius:6px; border:1px solid #bbb; background:white; cursor:pointer; }\n    button:active { transform: translateY(1px); }\n    label { font-size:13px; margin-right:6px; display:inline-flex; align-items:center; gap:6px; }\n    input[type=\"range\"] { vertical-align: middle; }\n    .info { margin-top: 10px; font-size: 13px; background:#fafafa; border:1px solid #eee; padding:8px; border-radius:8px; }\n    table { border-collapse: collapse; font-size:13px; margin-top:8px;}\n    td, th { padding:6px 8px; border-bottom:1px solid #f0f0f0; text-align:left; }\n    .small { font-size:12px; color: #555; }\n    #chart { width: 320px; height: 120px; background: #fff; border:1px solid #eee; margin-top:8px; border-radius:6px; }\n    select { padding:6px; border-radius:6px; }\n  </style>\n</head>\n<body>\n  <h1>Backpropagation interactive demo (2-2-1 network)</h1>\n  <div id=\"app\">\n    <div id=\"left\">\n      <div id=\"canvasWrap\">\n        <svg id=\"netSvg\" viewBox=\"0 0 500 300\"></svg>\n      </div>\n\n      <div class=\"controls\">\n        <label>Dataset\n          <select id=\"datasetSelect\">\n            <option value=\"AND\">AND</option>\n            <option value=\"OR\">OR</option>\n            <option value=\"XOR\">XOR</option>\n            <option value=\"CUSTOM\">CUSTOM: [0,1]->1 etc</option>\n          </select>\n        </label>\n\n        <label>Learning rate\n          <input id=\"lr\" type=\"range\" min=\"0.01\" max=\"1.0\" step=\"0.01\" value=\"0.3\">\n          <span id=\"lrVal\" class=\"small\">0.30</span>\n        </label>\n\n        <button id=\"resetBtn\">Reset weights</button>\n        <button id=\"forwardBtn\">Forward</button>\n        <button id=\"backpropBtn\">Backprop (compute deltas)</button>\n        <button id=\"updateBtn\">Apply Update</button>\n        <button id=\"stepBtn\">Step (F+B+U)</button>\n        <button id=\"trainBtn\">Train 1000</button>\n        <button id=\"stopBtn\" disabled>Stop</button>\n      </div>\n\n      <div class=\"info\">\n        <div><strong>Current sample:</strong> <span id=\"sampleIdx\">0</span> / <span id=\"nSamples\">4</span></div>\n        <div class=\"small\">Inputs: <span id=\"inputsText\"></span> → Target: <span id=\"targetText\"></span></div>\n        <div style=\"margin-top:6px;\">\n          <strong>Activations</strong> — hidden: <span id=\"hActs\"></span> • output: <span id=\"oAct\"></span>\n        </div>\n        <div style=\"margin-top:6px;\">\n          <strong>Deltas (local gradients)</strong> — hidden: <span id=\"hDeltas\"></span> • output: <span id=\"oDelta\"></span>\n        </div>\n        <div style=\"margin-top:6px;\">\n          <strong>Loss (MSE over dataset)</strong> — <span id=\"mseVal\">–</span>\n        </div>\n\n        <div id=\"chart\"></div>\n      </div>\n    </div>\n\n    <div id=\"right\">\n      <div class=\"info\">\n        <div><strong>Weights (input → hidden)</strong></div>\n        <table id=\"wIHtable\"><tbody></tbody></table>\n\n        <div style=\"margin-top:8px;\"><strong>Weights (hidden → output)</strong></div>\n        <table id=\"wHOtable\"><tbody></tbody></table>\n\n        <div style=\"margin-top:8px;\"><strong>Biases</strong></div>\n        <table id=\"biasTable\"><tbody></tbody></table>\n\n        <div style=\"margin-top:8px;\" class=\"small\">\n          Use \"Step\" to execute: Forward → Backprop → Update. Select dataset then train to see weights adjust.\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n/*\nBackpropagation interactive demo\nNetwork: 2 inputs, 2 hidden units, 1 output (sigmoid activations).\nPer-sample online training (stochastic).\nControls allow stepping through forward, computing deltas, applying weight updates,\nand running multiple training iterations while showing activations, deltas, and MSE.\n*/\n\n(function(){\n  // Utility\n  function randn(a,b){ return a + (b-a)*Math.random(); }\n  function sigmoid(x){ return 1 / (1 + Math.exp(-x)); }\n  function dsig(y){ return y * (1 - y); } // derivative with respect to activation\n  function mse(dataset, net){ let s=0; for(let p of dataset){ let out = net.forward(p.x); s += (p.y - out[2][0])**2; } return s/dataset.length; }\n\n  // Model state\n  let net = {\n    // weight matrices: wIH: hidden x input (2x2), wHO: output x hidden (1x2), biases: bh (2), bo (1)\n    wIH: [[0,0],[0,0]],\n    wHO: [[0,0]],\n    bh: [0,0],\n    bo: [0],\n    // forward cache: store nets and activations for use in backprop\n    cache: {x:[0,0], netH:[0,0], aH:[0,0], netO:0, aO:0}\n  };\n\n  // Dataset options\n  const datasets = {\n    \"AND\": [ {x:[0,0], y:0}, {x:[0,1], y:0}, {x:[1,0], y:0}, {x:[1,1], y:1} ],\n    \"OR\":  [ {x:[0,0], y:0}, {x:[0,1], y:1}, {x:[1,0], y:1}, {x:[1,1], y:1} ],\n    \"XOR\": [ {x:[0,0], y:0}, {x:[0,1], y:1}, {x:[1,0], y:1}, {x:[1,1], y:0} ],\n    \"CUSTOM\": [ {x:[0,0], y:0}, {x:[0,1], y:1}, {x:[1,0], y:0}, {x:[1,1], y:1} ]\n  };\n\n  let datasetName = 'AND';\n  let dataset = datasets[datasetName].slice();\n\n  // Training control\n  let sampleIndex = 0;\n  let learningRate = parseFloat(document.getElementById('lr').value);\n  let running = false;\n  let trainLoopId = null;\n  let history = [];\n\n  // Initialize weights randomly\n  function initWeights() {\n    for(let i=0;i<2;i++){\n      for(let j=0;j<2;j++) net.wIH[i][j] = randn(-1,1);\n    }\n    for(let j=0;j<2;j++) net.wHO[0][j] = randn(-1,1);\n    net.bh = [randn(-1,1), randn(-1,1)];\n    net.bo = [randn(-1,1)];\n    net.cache = {x:[0,0], netH:[0,0], aH:[0,0], netO:0, aO:0};\n    history = [];\n    updateUI();\n    drawNetwork();\n  }\n\n  // Forward pass for one input: returns arrays: [inputs, hiddenActs, outputAct]\n  net.forward = function(x){\n    this.cache.x = x.slice();\n    // hidden nets and activations\n    let netH = [0,0], aH = [0,0];\n    for(let i=0;i<2;i++){\n      netH[i] = this.bh[i];\n      for(let j=0;j<2;j++) netH[i] += this.wIH[i][j] * x[j];\n      aH[i] = sigmoid(netH[i]);\n    }\n    this.cache.netH = netH;\n    this.cache.aH = aH;\n    // output\n    let netO = this.bo[0];\n    for(let j=0;j<2;j++) netO += this.wHO[0][j] * aH[j];\n    let aO = sigmoid(netO);\n    this.cache.netO = netO;\n    this.cache.aO = aO;\n    return [x, aH, aO];\n  };\n\n  // Backpropagation: compute deltas and gradients for current sample in cache\n  function computeBackprop() {\n    const x = net.cache.x;\n    const aH = net.cache.aH;\n    const aO = net.cache.aO;\n    const target = dataset[sampleIndex].y;\n    // output delta\n    const deltaO = (target - aO) * dsig(aO); // gradient of error wrt netO\n    // hidden deltas\n    const deltaH = [0,0];\n    for(let i=0;i<2;i++){\n      deltaH[i] = dsig(aH[i]) * (net.wHO[0][i] * deltaO);\n    }\n    // gradients (for a single sample)\n    const grad_wHO = [ deltaO * aH[0], deltaO * aH[1] ];\n    const grad_bo = [ deltaO ];\n    const grad_wIH = [\n      [ deltaH[0]*x[0], deltaH[0]*x[1] ],\n      [ deltaH[1]*x[0], deltaH[1]*x[1] ]\n    ];\n    const grad_bh = [ deltaH[0], deltaH[1] ];\n\n    // Attach to cache for UI\n    net.cache.deltaO = deltaO;\n    net.cache.deltaH = deltaH;\n    net.cache.grad_wHO = grad_wHO;\n    net.cache.grad_wIH = grad_wIH;\n    net.cache.grad_bo = grad_bo;\n    net.cache.grad_bh = grad_bh;\n\n    updateUI();\n    drawNetwork();\n  }\n\n  // Apply weight updates using computed grads and current learning rate\n  function applyUpdate() {\n    const lr = learningRate;\n    if(!net.cache.grad_wHO) computeBackprop(); // ensure grads available\n    // update wHO, bo\n    for(let j=0;j<2;j++){\n      net.wHO[0][j] += lr * net.cache.grad_wHO[j];\n    }\n    net.bo[0] += lr * net.cache.grad_bo[0];\n    // update wIH, bh\n    for(let i=0;i<2;i++){\n      for(let j=0;j<2;j++){\n        net.wIH[i][j] += lr * net.cache.grad_wIH[i][j];\n      }\n      net.bh[i] += lr * net.cache.grad_bh[i];\n    }\n    updateUI();\n    drawNetwork();\n  }\n\n  // Compute MSE across dataset and append to history\n  function computeMSEandLog() {\n    const v = mse(dataset, net);\n    history.push(v);\n    if(history.length > 200) history.shift();\n    document.getElementById('mseVal').textContent = v.toFixed(5);\n    drawChart();\n  }\n\n  // Single training iteration (one sample): forward->backprop->update. Advance sample index.\n  function trainStep() {\n    // random sample or sequential? Use sequential to illustrate cycling.\n    const p = dataset[sampleIndex];\n    net.forward(p.x);\n    computeBackprop();\n    applyUpdate();\n    computeMSEandLog();\n    sampleIndex = (sampleIndex + 1) % dataset.length;\n    updateUI();\n  }\n\n  // UI bindings\n  const svg = document.getElementById('netSvg');\n  const lrInput = document.getElementById('lr');\n  const lrVal = document.getElementById('lrVal');\n  const sampleIdxEl = document.getElementById('sampleIdx');\n  const nSamplesEl = document.getElementById('nSamples');\n  const inputsText = document.getElementById('inputsText');\n  const targetText = document.getElementById('targetText');\n  const hActs = document.getElementById('hActs');\n  const oAct = document.getElementById('oAct');\n  const hDeltas = document.getElementById('hDeltas');\n  const oDelta = document.getElementById('oDelta');\n  const wIHtable = document.querySelector('#wIHtable tbody');\n  const wHOtable = document.querySelector('#wHOtable tbody');\n  const biasTable = document.querySelector('#biasTable tbody');\n  const forwardBtn = document.getElementById('forwardBtn');\n  const backpropBtn = document.getElementById('backpropBtn');\n  const updateBtn = document.getElementById('updateBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const trainBtn = document.getElementById('trainBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const stopBtn = document.getElementById('stopBtn');\n  const datasetSelect = document.getElementById('datasetSelect');\n\n  // Draw network as SVG\n  function drawNetwork() {\n    // layout coordinates\n    const coords = {\n      inputs: [ [60,80], [60,220] ],\n      hidden: [ [250,110], [250,190] ],\n      output: [ [420,150] ],\n      biasH: [ [250,40], [250,40] ],\n      biasO: [ [420,40] ]\n    };\n    // clear svg\n    while(svg.firstChild) svg.removeChild(svg.firstChild);\n\n    // draw weights: input->hidden\n    for(let i=0;i<2;i++){\n      for(let j=0;j<2;j++){\n        const x1 = coords.inputs[j][0], y1 = coords.inputs[j][1];\n        const x2 = coords.hidden[i][0], y2 = coords.hidden[i][1];\n        const w = net.wIH[i][j];\n        const color = w>=0 ? '#1b7f1b' : '#bf3b3b';\n        const thickness = Math.min(8, 1 + Math.abs(w)*4);\n        const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n        line.setAttribute('x1', x1); line.setAttribute('y1', y1);\n        line.setAttribute('x2', x2); line.setAttribute('y2', y2);\n        line.setAttribute('stroke', color); line.setAttribute('stroke-width', thickness);\n        line.setAttribute('opacity', 0.8);\n        svg.appendChild(line);\n        // weight text\n        const tx = document.createElementNS('http://www.w3.org/2000/svg','text');\n        tx.setAttribute('x', (x1+x2)/2 + 6);\n        tx.setAttribute('y', (y1+y2)/2 - 6);\n        tx.setAttribute('font-size', '12');\n        tx.setAttribute('fill', '#333');\n        tx.textContent = w.toFixed(3);\n        svg.appendChild(tx);\n      }\n    }\n    // hidden->output\n    for(let j=0;j<2;j++){\n      const x1 = coords.hidden[j][0], y1 = coords.hidden[j][1];\n      const x2 = coords.output[0][0], y2 = coords.output[0][1];\n      const w = net.wHO[0][j];\n      const color = w>=0 ? '#1b7f1b' : '#bf3b3b';\n      const thickness = Math.min(10, 1 + Math.abs(w)*5);\n      const line = document.createElementNS('http://www.w3.org/2000/svg','line');\n      line.setAttribute('x1', x1); line.setAttribute('y1', y1);\n      line.setAttribute('x2', x2); line.setAttribute('y2', y2);\n      line.setAttribute('stroke', color); line.setAttribute('stroke-width', thickness);\n      svg.appendChild(line);\n      const tx = document.createElementNS('http://www.w3.org/2000/svg','text');\n      tx.setAttribute('x', (x1+x2)/2 + 6);\n      tx.setAttribute('y', (y1+y2)/2 - 6);\n      tx.setAttribute('font-size', '12');\n      tx.setAttribute('fill', '#333');\n      tx.textContent = w.toFixed(3);\n      svg.appendChild(tx);\n    }\n\n    // draw nodes\n    function drawNode(x,y,label,fill='#fff') {\n      const g = document.createElementNS('http://www.w3.org/2000/svg','g');\n      const c = document.createElementNS('http://www.w3.org/2000/svg','circle');\n      c.setAttribute('cx', x); c.setAttribute('cy', y); c.setAttribute('r', 22);\n      c.setAttribute('fill', fill); c.setAttribute('stroke', '#777'); c.setAttribute('stroke-width', '1');\n      g.appendChild(c);\n      const t = document.createElementNS('http://www.w3.org/2000/svg','text');\n      t.setAttribute('x', x); t.setAttribute('y', y+5);\n      t.setAttribute('font-size', '13'); t.setAttribute('text-anchor','middle'); t.setAttribute('fill','#111');\n      t.textContent = label;\n      g.appendChild(t);\n      svg.appendChild(g);\n    }\n\n    // inputs\n    drawNode(coords.inputs[0][0], coords.inputs[0][1], 'x0');\n    drawNode(coords.inputs[1][0], coords.inputs[1][1], 'x1');\n    // hidden with activations in small label\n    for(let i=0;i<2;i++){\n      let fill = '#fff';\n      if(net.cache.aH && net.cache.aH[i] !== undefined) {\n        // shade by activation\n        const v = net.cache.aH[i];\n        const val = Math.round(240 - v*120);\n        fill = `rgb(${val},${val},255)`;\n      }\n      drawNode(coords.hidden[i][0], coords.hidden[i][1], 'h'+i, fill);\n      // small activation number\n      if(net.cache.aH && net.cache.aH[i] !== undefined){\n        const t = document.createElementNS('http://www.w3.org/2000/svg','text');\n        t.setAttribute('x', coords.hidden[i][0]); t.setAttribute('y', coords.hidden[i][1]+36);\n        t.setAttribute('font-size', '11'); t.setAttribute('text-anchor','middle'); t.setAttribute('fill','#333');\n        t.textContent = net.cache.aH[i].toFixed(3);\n        svg.appendChild(t);\n      }\n    }\n    // output\n    let outFill = '#fff';\n    if(net.cache.aO !== undefined) {\n      const v = net.cache.aO;\n      const val = Math.round(240 - v*150);\n      outFill = `rgb(${val},255,${val})`;\n    }\n    drawNode(coords.output[0][0], coords.output[0][1], 'o', outFill);\n    if(net.cache.aO !== undefined){\n      const t = document.createElementNS('http://www.w3.org/2000/svg','text');\n      t.setAttribute('x', coords.output[0][0]); t.setAttribute('y', coords.output[0][1]+36);\n      t.setAttribute('font-size', '11'); t.setAttribute('text-anchor','middle'); t.setAttribute('fill','#333');\n      t.textContent = net.cache.aO.toFixed(3);\n      svg.appendChild(t);\n    }\n    // biases text (only numbers)\n    for(let i=0;i<2;i++){\n      const tx = document.createElementNS('http://www.w3.org/2000/svg','text');\n      tx.setAttribute('x', coords.hidden[i][0]-28);\n      tx.setAttribute('y', coords.hidden[i][1]-36);\n      tx.setAttribute('font-size','11'); tx.setAttribute('fill','#555');\n      tx.textContent = 'b=' + net.bh[i].toFixed(3);\n      svg.appendChild(tx);\n    }\n    const txo = document.createElementNS('http://www.w3.org/2000/svg','text');\n    txo.setAttribute('x', coords.output[0][0]-28);\n    txo.setAttribute('y', coords.output[0][1]-36);\n    txo.setAttribute('font-size','11'); txo.setAttribute('fill','#555');\n    txo.textContent = 'b=' + net.bo[0].toFixed(3);\n    svg.appendChild(txo);\n\n    // deltas arrow if present\n    if(net.cache.deltaH){\n      for(let i=0;i<2;i++){\n        const dx = net.cache.deltaH[i];\n        const tx = document.createElementNS('http://www.w3.org/2000/svg','text');\n        tx.setAttribute('x', coords.hidden[i][0]+36);\n        tx.setAttribute('y', coords.hidden[i][1]+6);\n        tx.setAttribute('font-size','12'); tx.setAttribute('fill','#aa00aa');\n        tx.textContent = 'δ=' + dx.toFixed(4);\n        svg.appendChild(tx);\n      }\n    }\n    if(net.cache.deltaO !== undefined){\n      const tx = document.createElementNS('http://www.w3.org/2000/svg','text');\n      tx.setAttribute('x', coords.output[0][0]+36);\n      tx.setAttribute('y', coords.output[0][1]+6);\n      tx.setAttribute('font-size','12'); tx.setAttribute('fill','#aa00aa');\n      tx.textContent = 'δ=' + net.cache.deltaO.toFixed(4);\n      svg.appendChild(tx);\n    }\n  }\n\n  // Update numeric UI tables and texts\n  function updateUI() {\n    document.getElementById('lrVal').textContent = learningRate.toFixed(2);\n    sampleIdxEl.textContent = sampleIndex;\n    nSamplesEl.textContent = dataset.length;\n    const cur = dataset[sampleIndex];\n    inputsText.textContent = '[' + cur.x.join(', ') + ']';\n    targetText.textContent = cur.y;\n    // activations\n    if(net.cache.aH){\n      hActs.textContent = net.cache.aH.map(v=>v.toFixed(3)).join(' , ');\n    } else hActs.textContent = '–';\n    oAct.textContent = net.cache.aO !== undefined ? net.cache.aO.toFixed(4) : '–';\n    // deltas\n    if(net.cache.deltaH) hDeltas.textContent = net.cache.deltaH.map(v=>v.toFixed(4)).join(' , '); else hDeltas.textContent='–';\n    oDelta.textContent = net.cache.deltaO !== undefined ? net.cache.deltaO.toFixed(5) : '–';\n\n    // tables for weights\n    wIHtable.innerHTML = '';\n    for(let i=0;i<2;i++){\n      const tr = document.createElement('tr');\n      const th = document.createElement('th'); th.textContent = 'h'+i+' ←';\n      const td0 = document.createElement('td'); td0.textContent = 'w['+i+'][0] = ' + net.wIH[i][0].toFixed(5);\n      const td1 = document.createElement('td'); td1.textContent = 'w['+i+'][1] = ' + net.wIH[i][1].toFixed(5);\n      tr.appendChild(th); tr.appendChild(td0); tr.appendChild(td1);\n      wIHtable.appendChild(tr);\n    }\n    wHOtable.innerHTML = '';\n    const tr = document.createElement('tr');\n    const th = document.createElement('th'); th.textContent = 'o ←';\n    const td0 = document.createElement('td'); td0.textContent = 'wHO[0] = ' + net.wHO[0][0].toFixed(5);\n    const td1 = document.createElement('td'); td1.textContent = 'wHO[1] = ' + net.wHO[0][1].toFixed(5);\n    tr.appendChild(th); tr.appendChild(td0); tr.appendChild(td1);\n    wHOtable.appendChild(tr);\n\n    biasTable.innerHTML = '';\n    const tr2 = document.createElement('tr'); tr2.innerHTML = '<th>bh</th><td>' + net.bh[0].toFixed(5) + '</td><td>' + net.bh[1].toFixed(5) + '</td>';\n    const tr3 = document.createElement('tr'); tr3.innerHTML = '<th>bo</th><td colspan=\"2\">' + net.bo[0].toFixed(5) + '</td>';\n    biasTable.appendChild(tr2); biasTable.appendChild(tr3);\n  }\n\n  // Chart of MSE history\n  const chart = document.getElementById('chart');\n  const chartCanvas = document.createElement('canvas');\n  chartCanvas.width = 320; chartCanvas.height = 120;\n  chart.appendChild(chartCanvas);\n  const cx = chartCanvas.getContext('2d');\n  function drawChart() {\n    cx.clearRect(0,0,chartCanvas.width,chartCanvas.height);\n    cx.fillStyle = '#fff'; cx.fillRect(0,0,chartCanvas.width,chartCanvas.height);\n    cx.strokeStyle = '#ddd'; for(let i=0;i<chartCanvas.width;i+=40){ cx.beginPath(); cx.moveTo(i,0); cx.lineTo(i,chartCanvas.height); cx.stroke(); }\n    // draw line\n    if(history.length === 0) return;\n    const max = Math.max(...history);\n    const min = Math.min(...history);\n    const range = Math.max(1e-6, max - min);\n    cx.strokeStyle = '#1177cc'; cx.lineWidth = 2;\n    cx.beginPath();\n    for(let i=0;i<history.length;i++){\n      const x = Math.round(i/(history.length-1 || 1) * (chartCanvas.width-8)) + 4;\n      const y = chartCanvas.height - 4 - Math.round((history[i]-min)/range * (chartCanvas.height-8));\n      if(i===0) cx.moveTo(x,y); else cx.lineTo(x,y);\n    }\n    cx.stroke();\n    // last value text\n    cx.fillStyle = '#333'; cx.font = '12px system-ui';\n    cx.fillText('MSE: ' + history[history.length-1].toFixed(5), 6, 14);\n  }\n\n  // Event listeners\n  lrInput.addEventListener('input', function(e){ learningRate = parseFloat(this.value); lrVal.textContent = learningRate.toFixed(2); });\n  forwardBtn.addEventListener('click', function(){ net.forward(dataset[sampleIndex].x); updateUI(); drawNetwork(); });\n  backpropBtn.addEventListener('click', function(){ net.forward(dataset[sampleIndex].x); computeBackprop(); });\n  updateBtn.addEventListener('click', function(){ applyUpdate(); computeMSEandLog(); });\n  stepBtn.addEventListener('click', function(){ trainStep(); });\n  resetBtn.addEventListener('click', function(){ initWeights(); computeMSEandLog(); });\n  datasetSelect.addEventListener('change', function(){\n    datasetName = this.value;\n    dataset = datasets[datasetName].slice();\n    sampleIndex = 0;\n    history = [];\n    updateUI();\n    computeMSEandLog();\n  });\n\n  trainBtn.addEventListener('click', function(){\n    if(running) return;\n    running = true;\n    trainBtn.disabled = true;\n    stopBtn.disabled = false;\n    // run 1000 steps or until stopped\n    let steps = 1000;\n    (function loop(){\n      if(!running || steps<=0){ running=false; trainBtn.disabled=false; stopBtn.disabled=true; return; }\n      // do a chunk to keep UI responsive\n      for(let k=0;k<8 && steps>0;k++){\n        trainStep();\n        steps--;\n      }\n      trainLoopId = requestAnimationFrame(loop);\n    })();\n  });\n  stopBtn.addEventListener('click', function(){ running=false; trainBtn.disabled=false; stopBtn.disabled=true; if(trainLoopId) cancelAnimationFrame(trainLoopId); });\n\n  // Initial setup\n  initWeights();\n  computeMSEandLog();\n\n  // keyboard shortcuts\n  window.addEventListener('keydown', function(e){\n    if(e.key === ' ') { e.preventDefault(); trainStep(); }\n    else if(e.key === 'f') { net.forward(dataset[sampleIndex].x); updateUI(); drawNetwork(); }\n    else if(e.key === 'b') { net.forward(dataset[sampleIndex].x); computeBackprop(); }\n    else if(e.key === 'u') { applyUpdate(); computeMSEandLog(); }\n  });\n\n  // Expose a brief explanation within the page (small)\n  const expl = document.createElement('div');\n  expl.className = 'small';\n  expl.style.marginTop = '10px';\n  expl.innerHTML = 'This demo uses a small network: 2 inputs → 2 hidden → 1 output. Sigmoid activations. Backprop computes local gradients (δ) at output and hidden layers, multiplies by inputs/activations to get weight gradients, and updates weights using the learning rate. Use Step to run a single training iteration (forward → backprop → update).';\n  document.getElementById('right').appendChild(expl);\n\n})();\n</script>\n</body>\n</html>"
