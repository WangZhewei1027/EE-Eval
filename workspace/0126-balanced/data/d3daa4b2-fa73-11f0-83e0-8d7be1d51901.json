  "question": "Integration Testing",
  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Integration Testing Demo (Single File)</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root{ --bg:#0f1724; --card:#0b1220; --muted:#95a3b8; --accent:#7dd3fc; --ok:#4ade80; --bad:#fb7185; --panel:#071025; --glass: rgba(255,255,255,0.03);}\n    body{font-family:Inter,ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,\"Helvetica Neue\",Arial; margin:0; background:linear-gradient(180deg,#071025 0%, #071a2a 100%); color:#dbe7f3; -webkit-font-smoothing:antialiased;}\n    .wrap{max-width:1100px;margin:28px auto;padding:20px;}\n    header{display:flex;align-items:center;gap:18px;margin-bottom:18px;}\n    h1{margin:0;font-size:20px;}\n    p.lead{margin:0;color:var(--muted);font-size:13px}\n    .layout{display:grid;grid-template-columns:360px 1fr;gap:18px;margin-top:18px;}\n    .card{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.03); padding:14px;border-radius:10px; box-shadow: 0 6px 18px rgba(2,6,23,0.6);}\n    .sidebar .section{margin-bottom:12px;}\n    .muted{color:var(--muted);font-size:13px}\n    .controls{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}\n    button{background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01)); border:1px solid rgba(255,255,255,0.04); padding:8px 10px;border-radius:8px;color:#e6f6ff;cursor:pointer}\n    button.primary{background:linear-gradient(180deg,var(--accent), rgba(124,58,237,0.18)); color:#032027}\n    button.ghost{background:transparent;border:1px dashed rgba(255,255,255,0.03)}\n    .tests-list{max-height:260px; overflow:auto;padding:6px;border-radius:8px;background:var(--panel); border:1px solid rgba(255,255,255,0.02)}\n    label.test-item{display:flex;align-items:center;gap:8px;padding:8px;border-radius:6px;border:1px solid transparent}\n    label.test-item:hover{background:var(--glass)}\n    input[type=\"checkbox\"]{width:16px;height:16px}\n    .main .section{margin-bottom:14px;}\n    .panel-log{height:320px;overflow:auto;background:#00111a;padding:10px;border-radius:8px;font-family:monospace;color:#bfeaf7;font-size:13px;border:1px solid rgba(255,255,255,0.02)}\n    .results{display:flex;gap:10px;align-items:center;margin-bottom:8px}\n    .badge{padding:6px 10px;border-radius:999px;font-weight:600;background:rgba(255,255,255,0.03);font-size:13px}\n    .badge.pass{background:linear-gradient(90deg,#052e17,#114f2a); color:var(--ok); border:1px solid rgba(74,222,128,0.12)}\n    .badge.fail{background:linear-gradient(90deg,#3d0710,#5b0b12); color:var(--bad); border:1px solid rgba(251,113,133,0.08)}\n    .test-item.pass{border-left:4px solid var(--ok)}\n    .test-item.fail{border-left:4px solid var(--bad)}\n    .test-details{font-family:monospace;background:#051323;padding:10px;border-radius:8px;color:#bfeaf7;font-size:12px;margin-top:8px}\n    .mini{font-size:12px;color:var(--muted)}\n    .code{background:#021220;padding:10px;border-radius:8px;color:#bfeaf7;font-family:monospace;font-size:12px;max-height:220px; overflow:auto;border:1px solid rgba(255,255,255,0.02)}\n    .form-row{display:flex;gap:8px}\n    .input{padding:8px;border-radius:6px;border:1px solid rgba(255,255,255,0.04);background:transparent;color:inherit;flex:1}\n    .status-dot{width:10px;height:10px;border-radius:50%}\n    .status-dot.ok{background:var(--ok)}\n    .status-dot.bad{background:var(--bad)}\n    footer{margin-top:18px;color:var(--muted);font-size:13px}\n    .tiny{font-size:12px;color:var(--muted)}\n    .info{background:rgba(255,255,255,0.02);padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.02);color:var(--muted);font-size:13px}\n    .flex{display:flex;align-items:center;gap:8px}\n    .spacer{flex:1}\n    .test-summary{display:flex;gap:8px;align-items:center}\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <header>\n      <div style=\"width:64px;height:64px;border-radius:12px;background:linear-gradient(135deg,#072238,#0b2f48);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:20px\">IT</div>\n      <div>\n        <h1>Integration Testing — Interactive Demo</h1>\n        <p class=\"lead\">See how multiple modules interact, how to write async integration tests, and how to use test doubles (mocks) to simulate subsystems.</p>\n      </div>\n    </header>\n\n    <div class=\"layout\">\n      <div class=\"card sidebar\">\n        <div class=\"section\">\n          <div class=\"muted\">Test Controls</div>\n          <div class=\"controls\" style=\"margin-top:8px\">\n            <button id=\"runAll\" class=\"primary\">Run All Tests</button>\n            <button id=\"runSelected\">Run Selected</button>\n            <button id=\"resetEnv\" class=\"ghost\">Reset Environment</button>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <div class=\"muted\">Test Suites</div>\n          <div class=\"tests-list\" id=\"testsList\" aria-hidden=\"false\">\n            <!-- Tests will be injected -->\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <div class=\"muted\">Network Simulation</div>\n          <div style=\"margin-top:8px\" class=\"mini\">You can change the default API latency for tests.</div>\n          <div style=\"display:flex;gap:8px;margin-top:8px;align-items:center\">\n            <input id=\"latencyRange\" type=\"range\" min=\"0\" max=\"1500\" value=\"250\" />\n            <div class=\"mini\" id=\"latencyValue\">250ms</div>\n          </div>\n          <div style=\"margin-top:8px\" class=\"tiny\">Toggle error simulation to force API failures:</div>\n          <div style=\"display:flex;gap:8px;margin-top:6px\">\n            <label style=\"display:flex;gap:6px;align-items:center\"><input id=\"forceError\" type=\"checkbox\" /> Force API Error</label>\n            <label style=\"display:flex;gap:6px;align-items:center\"><input id=\"useStorage\" type=\"checkbox\" checked /> Use In-Memory Storage (tests)</label>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <div class=\"muted\">Notes</div>\n          <div class=\"info\" style=\"margin-top:8px\">\n            Integration tests exercise how modules work together (API client + auth + UI + storage). They often use test doubles (mocks, stubs, fakes) for external systems (network, databases) to control behaviors and edge cases.\n          </div>\n        </div>\n\n      </div>\n\n      <div class=\"card main\">\n        <div class=\"section results\">\n          <div class=\"test-summary\">\n            <div class=\"badge\" id=\"summaryTotal\">0 tests</div>\n            <div class=\"badge pass\" id=\"summaryPass\" style=\"display:none\">0 passed</div>\n            <div class=\"badge fail\" id=\"summaryFail\" style=\"display:none\">0 failed</div>\n          </div>\n          <div class=\"spacer\"></div>\n          <div class=\"mini\">Click a test to show details and re-run it individually.</div>\n        </div>\n\n        <div class=\"section\">\n          <div style=\"display:flex;align-items:center;gap:10px;margin-bottom:8px\">\n            <div class=\"muted\">Integration Test Log</div>\n            <div class=\"spacer\"></div>\n            <div class=\"mini\">Time: <span id=\"runTime\">-</span></div>\n          </div>\n          <div class=\"panel-log\" id=\"log\"></div>\n        </div>\n\n        <div class=\"section\">\n          <div class=\"muted\">System Under Test (simplified)</div>\n          <div style=\"display:flex;gap:10px;margin-top:8px\">\n            <div style=\"flex:1\">\n              <div class=\"mini\">UI Playground</div>\n              <div id=\"uiPlayground\" style=\"margin-top:8px;padding:10px;border-radius:8px;background:#01121a;border:1px solid rgba(255,255,255,0.02)\"></div>\n            </div>\n            <div style=\"width:420px\">\n              <div class=\"mini\">Modules (click to view source)</div>\n              <div id=\"modules\" style=\"margin-top:8px;display:flex;flex-direction:column;gap:8px\">\n                <!-- Module buttons -->\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"section\">\n          <div class=\"muted\">Code (modules & tests)</div>\n          <div class=\"code\" id=\"codeView\">Select a module or test to view code</div>\n        </div>\n\n        <footer>\n          <div class=\"tiny\">This demo uses a tiny test runner (no external libs). Integration tests here are intentionally simple and synchronous or use small async promises to illustrate patterns: async flows, setup/teardown, fakes, and assertions.</div>\n        </footer>\n      </div>\n    </div>\n  </div>\n\n  <script>\n  /*****************************************************************************\n   * Integration Testing Demo — Single File\n   * - A small \"system\" composed of ApiClient, UserService, Storage, and UIController.\n   * - A minimal test runner supporting async tests, beforeEach/afterEach, and simple assertions.\n   * - Several integration tests show typical scenarios (success, failure, persistence).\n   *****************************************************************************/\n\n  // ---------- Utilities ----------\n  const $ = (id)=>document.getElementById(id);\n  const logEl = $('log');\n  const codeView = $('codeView');\n  const uiPlayground = $('uiPlayground');\n  const testsListEl = $('testsList');\n  const modulesEl = $('modules');\n  const latencyRange = $('latencyRange');\n  const latencyValue = $('latencyValue');\n  const forceError = $('forceError');\n  const useStorage = $('useStorage');\n  const runAllBtn = $('runAll');\n  const runSelectedBtn = $('runSelected');\n  const resetEnvBtn = $('resetEnv');\n  const summaryTotal = $('summaryTotal');\n  const summaryPass = $('summaryPass');\n  const summaryFail = $('summaryFail');\n  const runTimeEl = $('runTime');\n\n  function now(){ return Date.now(); }\n  function sleep(ms){ return new Promise(res=>setTimeout(res, ms)); }\n  function clearLog(){ logEl.textContent=''; }\n  function appendLog(text, cls){ const d=document.createElement('div'); d.textContent=text; if(cls) d.className=cls; logEl.appendChild(d); logEl.scrollTop = logEl.scrollHeight; }\n  function formatMs(ms){ return ms<1000? ms+'ms' : (ms/1000).toFixed(2)+'s'; }\n\n  // ---------- Simple Test Runner ----------\n  const TestRunner = (() => {\n    const tests = [];\n    let beforeEachHook = null;\n    let afterEachHook = null;\n    let beforeAllHook = null;\n    let afterAllHook = null;\n\n    function test(name, fn){\n      tests.push({ name, fn });\n      return { name, fn };\n    }\n    function beforeEach(fn){ beforeEachHook = fn; }\n    function afterEach(fn){ afterEachHook = fn; }\n    function beforeAll(fn){ beforeAllHook = fn; }\n    function afterAll(fn){ afterAllHook = fn; }\n    async function run(selectedNames=null){\n      clearLog();\n      appendLog('Test run started — ' + new Date().toLocaleTimeString());\n      const start = now();\n      let total=0, passed=0, failed=0;\n      if(beforeAllHook) await maybeAsyncRun(beforeAllHook, 'beforeAll');\n      for(const t of tests){\n        if(selectedNames && !selectedNames.includes(t.name)) continue;\n        total++;\n        appendLog('→ Running: ' + t.name);\n        const tStart = now();\n        try{\n          if(beforeEachHook) await maybeAsyncRun(beforeEachHook, 'beforeEach');\n          await maybeAsyncRun(()=>t.fn(TestContext), `test:${t.name}`);\n          if(afterEachHook) await maybeAsyncRun(afterEachHook, 'afterEach');\n          const dur = now()-tStart;\n          appendLog('✓ Passed: ' + t.name + ' ('+formatMs(dur)+')', 'pass');\n          markTestUI(t.name, true, dur);\n          passed++;\n        }catch(err){\n          const dur = now()-tStart;\n          appendLog('✗ Failed: ' + t.name + ' ('+formatMs(dur)+')', 'fail');\n          appendLog('  Error: ' + (err && err.message ? err.message : String(err)));\n          appendLog((err && err.stack) ? err.stack.split('\\n').slice(0,6).join('\\n') : '');\n          markTestUI(t.name, false, dur, err);\n          failed++;\n        }\n      }\n      if(afterAllHook) await maybeAsyncRun(afterAllHook, 'afterAll');\n      const totalDur = now()-start;\n      appendLog('Test run complete — ' + total + ' tests — ' + passed + ' passed, ' + failed + ' failed. Duration: ' + formatMs(totalDur));\n      updateSummary(total, passed, failed);\n      runTimeEl.textContent = formatMs(totalDur);\n    }\n\n    async function maybeAsyncRun(fn, name){\n      // Support functions returning promises or synchronous.\n      const r = fn();\n      if(r && typeof r.then === 'function') return await r;\n      return r;\n    }\n\n    function updateSummary(total, passed, failed){\n      summaryTotal.textContent = `${total} tests`;\n      summaryPass.style.display = passed ? 'inline-block':'none';\n      summaryFail.style.display = failed ? 'inline-block':'none';\n      summaryPass.textContent = `${passed} passed`;\n      summaryFail.textContent = `${failed} failed`;\n    }\n\n    function list(){ return tests.slice(); }\n\n    return { test, beforeEach, afterEach, beforeAll, afterAll, run, list };\n  })();\n\n  // ---------- Simple Assertion Helpers ----------\n  const assert = {\n    equal(actual, expected, message){\n      if(actual !== expected) throw new Error(message || `expected ${JSON.stringify(expected)}, got ${JSON.stringify(actual)}`);\n    },\n    ok(val, message){\n      if(!val) throw new Error(message || `expected truthy value, got ${JSON.stringify(val)}`);\n    },\n    throwsAsync: async function(fn, message){\n      try{\n        await fn();\n      }catch(e){ return; }\n      throw new Error(message || 'Expected function to throw an error (async), but it did not.');\n    }\n  };\n\n  // ---------- System Under Test: Modules ----------\n  // We'll keep module source as strings for display and reuse.\n  const moduleSources = {};\n\n  // StorageService (pluggable, default is in-memory for tests)\n  moduleSources.StorageService = `\n  class StorageService {\n    constructor(adapter = null){\n      // adapter must implement getItem(key), setItem(key, value), removeItem(key)\n      this.adapter = adapter || {\n        _store: {},\n        getItem(k){ return this._store[k] ?? null; },\n        setItem(k,v){ this._store[k] = String(v); },\n        removeItem(k){ delete this._store[k]; }\n      };\n    }\n    get(key){ return this.adapter.getItem(key); }\n    set(key, value){ this.adapter.setItem(key, String(value)); }\n    remove(key){ this.adapter.removeItem(key); }\n  }`.trim();\n\n  // ApiClient (allows injection of fetch-like function; we will mock)\n  moduleSources.ApiClient = `\n  class ApiClient {\n    constructor(fetchImpl, latencyMs = 250){\n      this.fetch = fetchImpl || (async (url, opts) => { return fetch(url, opts); });\n      this.latency = latencyMs;\n    }\n    async authenticate(username, password){\n      // Simulate network latency and a JSON response similar to many auth APIs\n      await new Promise(res => setTimeout(res, this.latency));\n      // We expect fetch to be a stub in tests; by default we'll emulate an endpoint.\n      return await this.fetch('/auth', { method: 'POST', body: JSON.stringify({username,password}) });\n    }\n  }`.trim();\n\n  // UserService (uses ApiClient and StorageService)\n  moduleSources.UserService = `\n  class UserService {\n    constructor(apiClient, storage){\n      this.api = apiClient;\n      this.storage = storage;\n      this.token = null;\n      this.user = null;\n    }\n    async login(username, password){\n      const res = await this.api.authenticate(username, password);\n      if(res.status === 200){\n        const payload = await res.json();\n        this.token = payload.token;\n        this.user = payload.user;\n        this.storage.set('auth.token', this.token);\n        this.storage.set('auth.user', JSON.stringify(this.user));\n        return { ok:true, user:this.user };\n      } else {\n        // Map other statuses to a recognizable error\n        const body = await (res.json().catch(()=>({})));\n        throw new Error(body.message || 'Authentication failed');\n      }\n    }\n    logout(){\n      this.token = null; this.user = null;\n      this.storage.remove('auth.token'); this.storage.remove('auth.user');\n    }\n    loadFromStorage(){\n      const token = this.storage.get('auth.token');\n      const userJson = this.storage.get('auth.user');\n      if(token && userJson){\n        try{\n          this.token = token;\n          this.user = JSON.parse(userJson);\n          return true;\n        }catch(e){\n          return false;\n        }\n      }\n      return false;\n    }\n  }`.trim();\n\n  // UIController (renders login form and interacts with UserService)\n  moduleSources.UIController = `\n  class UIController {\n    constructor(container, userService){\n      this.container = container;\n      this.userService = userService;\n      this.root = document.createElement('div');\n      this.container.appendChild(this.root);\n      this.render();\n    }\n    clear(){\n      this.root.innerHTML = '';\n    }\n    render(){\n      this.clear();\n      const form = document.createElement('div');\n      form.style.display='flex';\n      form.style.flexDirection='column';\n      form.style.gap='8px';\n      // Username input\n      const u = document.createElement('input');\n      u.placeholder = 'username';\n      u.className='input';\n      u.value = 'alice';\n      const p = document.createElement('input');\n      p.placeholder = 'password';\n      p.type='password';\n      p.className='input';\n      p.value = 'password123';\n      const btn = document.createElement('button');\n      btn.textContent = 'Login';\n      btn.onclick = async () => {\n        this.showMessage('Logging in…');\n        try{\n          const r = await this.userService.login(u.value, p.value);\n          this.showMessage('Welcome ' + r.user.name, true);\n          this.showUser(r.user);\n        }catch(e){\n          this.showMessage('Error: ' + e.message, false);\n        }\n      };\n      const msg = document.createElement('div');\n      msg.className='mini';\n      msg.style.marginTop='6px';\n      this.msgEl = msg;\n      form.appendChild(u); form.appendChild(p); form.appendChild(btn); form.appendChild(msg);\n      this.root.appendChild(form);\n      // area to display account info\n      const info = document.createElement('div');\n      info.style.marginTop='10px';\n      info.className='mini';\n      this.infoEl = info;\n      this.root.appendChild(info);\n    }\n    showMessage(text, ok){\n      this.msgEl.textContent = text;\n      this.msgEl.style.color = ok ? '#8ff2cf' : '#ff9aa2';\n    }\n    showUser(user){\n      this.infoEl.textContent = 'Logged in as: ' + user.name + ' (id: ' + user.id + ')';\n    }\n    teardown(){\n      this.container.removeChild(this.root);\n    }\n  }`.trim();\n\n  // Register module display buttons\n  function makeModuleButton(name, source){\n    const btn = document.createElement('button');\n    btn.textContent = name;\n    btn.onclick = ()=>{ codeView.textContent = source; };\n    modulesEl.appendChild(btn);\n  }\n  Object.entries(moduleSources).forEach(([n,s]) => makeModuleButton(n, s));\n\n  // ---------- Mock Helpers for Tests ----------\n  // A fake fetch generator allowing controlled responses\n  function makeFakeFetch({ succeed=true, user={ id: 'u1', name:'Alice' }, token='tok-123', latency=250 }){\n    return async function(url, opts){\n      // For integration tests we return objects that mimic the fetch Response interface we use.\n      await sleep(latency);\n      if(!succeed){\n        return {\n          status: 401,\n          json: async ()=>({ message: 'Invalid credentials' })\n        };\n      }\n      return {\n        status: 200,\n        json: async ()=>({ token, user })\n      };\n    };\n  }\n\n  // In-memory storage adapter used in tests (so we do not use browser localStorage)\n  function makeInMemoryStorage(){\n    const store = {};\n    return {\n      getItem(k){ return store[k] ?? null; },\n      setItem(k,v){ store[k] = String(v); },\n      removeItem(k){ delete store[k]; }\n    };\n  }\n\n  // Default environment factory to create fresh instances between tests\n  function createEnvironment({ latency=250, forceApiError=false, storageAdapter=null } = {}){\n    const fetchImpl = makeFakeFetch({ succeed: !forceApiError, latency });\n    const api = new ApiClient(fetchImpl, latency);\n    const storageService = new StorageService(storageAdapter || makeInMemoryStorage());\n    const userService = new UserService(api, storageService);\n    // Ensure UI container is cleared\n    uiPlayground.innerHTML = '';\n    const uiCtrl = new UIController(uiPlayground, userService);\n    return { api, storageService, userService, uiCtrl, fetchImpl };\n  }\n\n  // ---------- Evaluate Module Source Strings to Real Classes ----------\n  // We will eval the module source code in this single-file demo to create classes.\n  // (In a real project, these are individual modules.)\n  function evalModules(){\n    // eslint-disable-next-line no-eval\n    eval(moduleSources.StorageService);\n    // eslint-disable-next-line no-eval\n    eval(moduleSources.ApiClient);\n    // eslint-disable-next-line no-eval\n    eval(moduleSources.UserService);\n    // eslint-disable-next-line no-eval\n    eval(moduleSources.UIController);\n  }\n  evalModules();\n\n  // ---------- Test Context Provided to Each Test ----------\n  const TestContext = {\n    createEnv: (opts)=> createEnvironment(opts)\n  };\n\n  // ---------- Integration Tests ----------\n  // We'll register tests that exercise multiple modules together.\n  TestRunner.beforeEach(async ()=>{\n    // Before each test reflect UI options (latency, forced error, storage choice)\n    clearLog();\n    appendLog('Setting up environment for next test...');\n  });\n\n  TestRunner.afterEach(async ()=>{\n    // Light teardown: clear playground to avoid leaking UI components between tests.\n    uiPlayground.innerHTML = '';\n    appendLog('Tear down complete.');\n  });\n\n  // Test 1: Successful login flow (ApiClient + UserService + UI)\n  TestRunner.test('Login Success Flow', async (ctx)=>{\n    const latency = Number(latencyRange.value);\n    const env = ctx.createEnv({ latency, forceApiError: false });\n    appendLog('Created env with latency ' + latency + 'ms');\n    // Simulate UI click by calling the UIController button handler programmatically.\n    // We'll use pre-filled credentials from the UI.\n    // Find the Login button in the UI root.\n    const btn = env.uiCtrl.root.querySelector('button');\n    // Click -> should call userService.login which uses the ApiClient.fetch (fake)\n    btn.click();\n    // Wait a bit longer than the latency to allow async flow to complete\n    await sleep(latency + 30);\n    // Assertions:\n    assert.ok(env.userService.token, 'token should be stored in userService');\n    assert.equal(env.userService.user.name, 'Alice', 'user name should be Alice');\n    assert.equal(env.storageService.get('auth.token'), env.userService.token, 'token persisted to storage');\n    // UI should show user's name\n    assert.ok(env.uiCtrl.infoEl.textContent.includes('Alice'), 'UI should display the logged-in user');\n  });\n\n  // Test 2: Login Failure Flow (401)\n  TestRunner.test('Login Failure Flow', async (ctx)=>{\n    const latency = Number(latencyRange.value);\n    const env = ctx.createEnv({ latency, forceApiError: true });\n    appendLog('Created env forcing API failure; latency ' + latency + 'ms');\n    const btn = env.uiCtrl.root.querySelector('button');\n    btn.click();\n    // Wait for response\n    await sleep(latency + 30);\n    // Expect that userService.token is still null and storage not set\n    assert.equal(env.userService.token, null, 'token must not be set on failure');\n    assert.equal(env.storageService.get('auth.token'), null, 'storage token must not be set on failure');\n    // UI should display an error message\n    assert.ok(env.uiCtrl.msgEl.textContent.toLowerCase().includes('error'), 'UI must show an error message');\n  });\n\n  // Test 3: Session Persistence (load from storage)\n  TestRunner.test('Session Persistence (loadFromStorage)', async (ctx)=>{\n    const latency = Number(latencyRange.value);\n    // Start with a successful login environment\n    const env = ctx.createEnv({ latency, forceApiError: false });\n    appendLog('Logging in to populate storage...');\n    const btn = env.uiCtrl.root.querySelector('button');\n    btn.click();\n    await sleep(latency + 30);\n    // Simulate page reload: create a fresh UI & UserService but reuse the same storage adapter\n    const storageAdapter = env.storageService.adapter || env.storageService.adapter;\n    const newApi = new ApiClient(makeFakeFetch({ succeed:true, latency }), latency);\n    const newStorageService = new StorageService(storageAdapter);\n    const newUserService = new UserService(newApi, newStorageService);\n    const newUi = new UIController(uiPlayground, newUserService);\n    // Now load from storage\n    const loaded = newUserService.loadFromStorage();\n    assert.ok(loaded, 'Should have loaded session from storage');\n    assert.ok(newUserService.token, 'token must be present after load');\n    // UI should be able to display user after manual showUser call (since we didn't wire auto-load to UI)\n    newUi.showUser(newUserService.user);\n    assert.ok(newUi.infoEl.textContent.includes('Alice'), 'New UI should show the persisted user');\n    // teardown manual\n    newUi.teardown();\n  });\n\n  // Register tests in UI list\n  function renderTestList(){\n    testsListEl.innerHTML = '';\n    const tests = TestRunner.list();\n    for(const t of tests){\n      const id = 't_' + Math.random().toString(36).slice(2,8);\n      const label = document.createElement('label');\n      label.className = 'test-item';\n      const chk = document.createElement('input');\n      chk.type='checkbox';\n      chk.checked = true;\n      chk.dataset.testName = t.name;\n      label.appendChild(chk);\n      const span = document.createElement('div');\n      span.style.flex='1';\n      span.innerHTML = `<div style=\"font-weight:600\">${t.name}</div><div class=\"mini\">Integration test combining API, auth, storage and UI</div>`;\n      label.appendChild(span);\n      label.onclick = (e)=>{\n        // If clicking the label (not the checkbox), show code\n        if(e.target.tagName.toLowerCase() !== 'input'){\n          codeView.textContent = t.fn.toString();\n          // highlight selected\n          Array.from(testsListEl.querySelectorAll('label')).forEach(l=>l.style.boxShadow='none');\n          label.style.boxShadow = 'inset 0 0 0 1px rgba(125,211,252,0.08)';\n        }\n      };\n      testsListEl.appendChild(label);\n      // Add click to run test individually\n      const runBtn = document.createElement('button');\n      runBtn.textContent='Run';\n      runBtn.style.marginLeft='8px';\n      runBtn.onclick = (ev)=>{\n        ev.stopPropagation();\n        runSingleTest(t.name);\n      };\n      label.appendChild(runBtn);\n    }\n    summaryTotal.textContent = `${tests.length} tests`;\n  }\n\n  async function runSingleTest(name){\n    clearLog();\n    appendLog('Running single test: ' + name);\n    // Replace beforeAll/afterAll temporarily not to conflict\n    const all = TestRunner.list().map(t=>t.name);\n    await TestRunner.run([name]);\n  }\n\n  // Mark test UI with pass/fail\n  function markTestUI(name, passed, dur, err){\n    // Find the label that contains the test name\n    const labels = testsListEl.querySelectorAll('label');\n    for(const l of labels){\n      if(l.textContent.includes(name)){\n        l.classList.remove('pass','fail');\n        l.classList.add(passed ? 'pass' : 'fail');\n        // attach small details\n        let details = l.querySelector('.test-details');\n        if(details) details.remove();\n        details = document.createElement('div');\n        details.className = 'test-details';\n        details.textContent = (passed? 'Passed':'Failed') + ' — ' + formatMs(dur) + (err ? ('\\n' + (err.message || err)): '');\n        l.appendChild(details);\n      }\n    }\n  }\n\n  // Wire up controls\n  runAllBtn.onclick = async ()=>{ await TestRunner.run(); };\n  runSelectedBtn.onclick = async ()=>{\n    // gather selected tests\n    const chks = Array.from(testsListEl.querySelectorAll('input[type=checkbox]'));\n    const selected = chks.filter(c=>c.checked).map(c=>c.dataset.testName);\n    if(selected.length===0){ alert('Select at least one test'); return; }\n    await TestRunner.run(selected);\n  };\n  resetEnvBtn.onclick = ()=>{\n    // Reset simulation options to defaults\n    latencyRange.value = 250; latencyValue.textContent='250ms';\n    forceError.checked = false;\n    useStorage.checked = true;\n    uiPlayground.innerHTML = '';\n    clearLog();\n    appendLog('Environment reset.');\n  };\n  latencyRange.oninput = ()=>{ latencyValue.textContent = latencyRange.value + 'ms'; };\n\n  // Initial render\n  renderTestList();\n  codeView.textContent = [\n    moduleSources.StorageService,\n    moduleSources.ApiClient,\n    moduleSources.UserService,\n    moduleSources.UIController\n  ].join('\\n\\n// ----------------\\n');\n\n  // Run initial test set when clicking a module shows its code\n  // Also wire module source buttons to display code (already wired above)\n\n  // For convenience, run all tests on load after a slight delay\n  appendLog('Ready. Use the controls on the left to run integration tests.');\n  // Pre-select test module view on load\n  window.addEventListener('load', ()=> {\n    // intentionally do not auto-run tests; user should trigger.\n  });\n\n  // Optional: allow clicking codeView to copy\n  codeView.onclick = async ()=>{\n    try{\n      await navigator.clipboard.writeText(codeView.textContent);\n      appendLog('Code copied to clipboard.');\n    }catch(e){\n      appendLog('Copy failed: ' + e.message);\n    }\n  };\n\n  // Expose a tiny helper to open quick walkthrough in the log\n  function demoWalkthrough(){\n    appendLog('Walkthrough:');\n    appendLog('1) \"Login Success Flow\" uses a fake API that returns 200 and ensures UI + storage update.');\n    appendLog('2) \"Login Failure Flow\" forces API to return 401; userService must not store a token and UI shows an error.');\n    appendLog('3) \"Session Persistence\" demonstrates writing to storage then re-loading from it.');\n    appendLog('Try toggling \"Force API Error\" and run the tests again to see how behavior changes.');\n  }\n  demoWalkthrough();\n\n  </script>\n</body>\n</html>"
