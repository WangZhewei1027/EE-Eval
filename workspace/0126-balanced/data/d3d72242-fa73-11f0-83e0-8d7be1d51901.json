  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <title>Bellman-Ford Algorithm Interactive Demo</title>\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <style>\n    :root { --bg:#1e1f26; --panel:#0f1720; --accent:#2dd4bf; --muted:#9aa4b2; --card:#111318; }\n    html,body{height:100%;margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n    body{background:linear-gradient(180deg,#0b1220 0%, #07111a 100%); color:#e6eef6; display:flex; align-items:stretch; }\n    .sidebar{width:360px; min-width:280px; background:linear-gradient(180deg,var(--panel),#071322); padding:16px; box-sizing:border-box; border-right:1px solid rgba(255,255,255,0.03);}\n    .title{font-weight:700; font-size:18px; margin-bottom:8px; color:var(--accent);}\n    .desc{color:var(--muted); font-size:13px; margin-bottom:12px; line-height:1.35;}\n    .controls{display:flex; flex-wrap:wrap; gap:8px; margin-bottom:12px;}\n    button, select, input[type=\"number\"]{background:transparent; border:1px solid rgba(255,255,255,0.06); color:inherit; padding:8px 10px; border-radius:8px; cursor:pointer;}\n    button.primary{background:linear-gradient(90deg,var(--accent),#60a5fa); color:#021219; border:none;}\n    .small{font-size:13px;padding:6px 8px;}\n    .muted{color:var(--muted); font-size:13px;}\n    .canvasWrap{flex:1; position:relative; display:flex; align-items:stretch; justify-content:center; padding:12px;}\n    canvas{background:linear-gradient(180deg,#071226, #05101a); border-radius:8px; box-shadow:0 6px 30px rgba(2,6,23,0.6); cursor:crosshair;}\n    .infoBox{margin-top:12px;background:rgba(255,255,255,0.02); padding:10px; border-radius:8px; font-size:13px;}\n    .row{display:flex; gap:8px; margin-bottom:8px; align-items:center;}\n    .legend{display:flex; gap:8px; align-items:center; font-size:13px; margin-top:8px;}\n    .chip{height:14px; width:14px; border-radius:3px; display:inline-block;}\n    .log{max-height:150px; overflow:auto; margin-top:10px; font-size:13px; color:var(--muted); background:rgba(255,255,255,0.01); padding:8px; border-radius:6px;}\n    .hint{font-size:12px;color:var(--muted); margin-top:6px;}\n    .edgeList{max-height:120px; overflow:auto; font-size:13px; margin-top:6px;}\n    .nodeLabel{font-weight:700;}\n    .footer{position:absolute; bottom:12px; left:12px; color:var(--muted); font-size:12px;}\n    a{color:var(--accent);}\n  </style>\n</head>\n<body>\n  <div class=\"sidebar\">\n    <div class=\"title\">Bellman-Ford Algorithm — Interactive Demo</div>\n    <div class=\"desc\">\n      Build or use a sample directed graph (weights can be negative). Step through the Bellman-Ford algorithm to compute shortest paths from a chosen source. The algorithm relaxes all edges V-1 times and can detect negative-weight cycles.\n    </div>\n\n    <div class=\"controls\">\n      <select id=\"sample\">\n        <option value=\"sample1\">Sample: small negative edge</option>\n        <option value=\"sample2\">Sample: negative cycle</option>\n        <option value=\"sample3\">Sample: random graph</option>\n      </select>\n\n      <button id=\"loadSample\" class=\"small\">Load</button>\n      <button id=\"clear\" class=\"small\">Clear</button>\n    </div>\n\n    <div class=\"row\">\n      <label class=\"muted\" style=\"width:62px\">Source:</label>\n      <select id=\"sourceSelect\"></select>\n      <button id=\"init\" class=\"small primary\">Initialize</button>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"step\" class=\"small\">Step</button>\n      <button id=\"run\" class=\"small\">Auto</button>\n      <button id=\"nextIter\" class=\"small\">Next Iteration</button>\n      <button id=\"reset\" class=\"small\">Reset</button>\n    </div>\n\n    <div class=\"row\">\n      <button id=\"checkNeg\" class=\"small\">Check Negative Cycle</button>\n      <button id=\"addNodeBtn\" class=\"small\">Add Node</button>\n      <button id=\"addEdgeBtn\" class=\"small\">Add Edge</button>\n    </div>\n\n    <div class=\"infoBox\">\n      <div class=\"muted\">Instructions:</div>\n      <ul style=\"padding-left:18px;margin:6px 0 0 0\">\n        <li>Click canvas to add nodes (or use Add Node).</li>\n        <li>Click a node then another to create a directed edge (you'll be prompted for weight).</li>\n        <li>Drag nodes to reposition. Use Initialize to pick source and start.</li>\n        <li>Use Step to relax the next edge, Next Iteration to finish current pass, Auto to play.</li>\n      </ul>\n\n      <div class=\"legend\" style=\"margin-top:10px\">\n        <div class=\"chip\" style=\"background:#e2e8f0\"></div> <span class=\"muted\">Nodes (id / distance)</span>\n      </div>\n      <div class=\"legend\">\n        <div class=\"chip\" style=\"background:rgba(45,212,191,0.9)\"></div> <span class=\"muted\">Edge just relaxed (success)</span>\n      </div>\n      <div class=\"legend\">\n        <div class=\"chip\" style=\"background:#f97316\"></div> <span class=\"muted\">Edge considered (current)</span>\n      </div>\n\n      <div class=\"edgeList\" id=\"edgeList\"></div>\n\n      <div class=\"log\" id=\"log\"></div>\n    </div>\n\n    <div style=\"margin-top:10px\" class=\"hint\">\n      Tip: Use the \"Sample: negative cycle\" to see how the algorithm detects cycles that make shortest paths undefined.\n    </div>\n  </div>\n\n  <div class=\"canvasWrap\">\n    <canvas id=\"canvas\" width=\"1000\" height=\"700\"></canvas>\n    <div class=\"footer\">Click nodes to create edges. Drag nodes to move. Distances show current known shortest distances.</div>\n  </div>\n\n<script>\n/*\n  Bellman-Ford Interactive Demo\n  - Directed graph with weights (negative allowed)\n  - Interactive construction and step-by-step execution\n  - Visualization: nodes, edges, highlights on relax\n*/\n\n// Canvas and drawing setup\nconst canvas = document.getElementById('canvas');\nconst ctx = canvas.getContext('2d');\nlet W = canvas.width, H = canvas.height;\n\n// Graph data\nlet nodes = []; // {id,x,y}\nlet edges = []; // {id, from, to, weight}\nlet nextNodeId = 0;\nlet nextEdgeId = 0;\n\n// Interaction state\nlet dragging = null;\nlet dragOffset = {x:0,y:0};\nlet addingEdgeMode = false;\nlet selectedNodeForEdge = null;\nlet addNodeMode = false;\n\n// Algorithm state\nlet distances = {}; // id->number or Infinity\nlet predecessor = {}; // id->prev id or null\nlet initialized = false;\nlet iteration = 0; // 1..V-1\nlet edgeIndex = 0;\nlet playing = false;\nlet playTimer = null;\nlet logEl = document.getElementById('log');\n\n// DOM elements\nconst sourceSelect = document.getElementById('sourceSelect');\nconst edgeListEl = document.getElementById('edgeList');\n\nfunction resetAll(){\n  nodes = [];\n  edges = [];\n  nextNodeId = 0;\n  nextEdgeId = 0;\n  clearAlgorithmState();\n  render();\n}\n\nfunction clearAlgorithmState(){\n  distances = {};\n  predecessor = {};\n  initialized = false;\n  iteration = 0;\n  edgeIndex = 0;\n  stopAuto();\n  updateLog(\"Algorithm reset.\");\n  updateSourceOptions();\n  render();\n}\n\nfunction updateLog(msg){\n  const time = new Date().toLocaleTimeString();\n  logEl.innerHTML = `<div style=\"margin-bottom:6px\">[${time}] ${escapeHtml(msg)}</div>` + logEl.innerHTML;\n}\n\nfunction escapeHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\n\n// Basic utilities\nfunction findNodeAt(x,y){\n  for(let i=nodes.length-1;i>=0;i--){\n    const n = nodes[i];\n    const dx = x-n.x, dy=y-n.y;\n    if(Math.sqrt(dx*dx+dy*dy) <= 22) return n;\n  }\n  return null;\n}\n\nfunction addNode(x,y){\n  const n = {id: nextNodeId++, x, y};\n  nodes.push(n);\n  updateSourceOptions();\n  render();\n  return n;\n}\n\nfunction addEdge(fromId,toId,weight){\n  const e = {id: nextEdgeId++, from: fromId, to: toId, weight: Number(weight)};\n  edges.push(e);\n  renderEdgeList();\n  render();\n  return e;\n}\n\nfunction renderEdgeList(){\n  if(edges.length===0){ edgeListEl.innerHTML = '<div class=\"muted\">No edges</div>'; return; }\n  edgeListEl.innerHTML = edges.map(e=>{\n    const f = nodes.find(n=>n.id===e.from), t = nodes.find(n=>n.id===e.to);\n    return `<div style=\"padding:6px;border-radius:6px;margin-bottom:4px;background:rgba(255,255,255,0.01)\">\n      <b>${f ? f.id:''}</b> → <b>${t? t.id:''}</b> &nbsp; <span class=\"muted\">w=${e.weight}</span>\n    </div>`;\n  }).join('');\n}\n\n// Drawing\nfunction draw(){\n  ctx.clearRect(0,0,W,H);\n\n  // draw edges\n  for(let i=0;i<edges.length;i++){\n    const e = edges[i];\n    const from = nodes.find(n=>n.id===e.from);\n    const to = nodes.find(n=>n.id===e.to);\n    if(!from || !to) continue;\n    drawEdge(from,to,e);\n  }\n\n  // draw nodes\n  for(let n of nodes){\n    drawNode(n);\n  }\n}\n\nfunction drawEdge(a,b,e){\n  const dx = b.x - a.x, dy = b.y - a.y;\n  const dist = Math.sqrt(dx*dx+dy*dy);\n  const ux = dx/dist, uy = dy/dist;\n  const startX = a.x + ux*24, startY = a.y + uy*24;\n  const endX = b.x - ux*24, endY = b.y - uy*24;\n\n  // Compute visual styles for current algorithm state\n  let stroke = 'rgba(255,255,255,0.06)';\n  let width = 1.5;\n  let fill = 'rgba(255,255,255,0.9)';\n  if(initialized && iteration>0){\n    const idx = edges.indexOf(e);\n    if(idx === edgeIndex && iteration <= Math.max(0, nodes.length-1)){\n      stroke = '#fb923c'; // current\n      width = 3;\n    }\n  }\n\n  ctx.beginPath();\n  ctx.moveTo(startX,startY);\n  ctx.lineTo(endX,endY);\n  ctx.strokeStyle = stroke;\n  ctx.lineWidth = width;\n  ctx.stroke();\n\n  // arrow head\n  const arrowSize = 8;\n  ctx.beginPath();\n  ctx.moveTo(endX, endY);\n  ctx.lineTo(endX - ux*arrowSize - uy*arrowSize*0.5, endY - uy*arrowSize + ux*arrowSize*0.5);\n  ctx.lineTo(endX - ux*arrowSize + uy*arrowSize*0.5, endY - uy*arrowSize - ux*arrowSize*0.5);\n  ctx.closePath();\n  ctx.fillStyle = stroke;\n  ctx.fill();\n\n  // weight label at midpoint\n  const midX = (startX+endX)/2 + (-uy)*12; // offset perpendicular a bit\n  const midY = (startY+endY)/2 + (ux)*12;\n  ctx.fillStyle = 'rgba(230,238,246,0.95)';\n  ctx.font = '13px Inter, Arial';\n  ctx.fillText(e.weight, midX - 6, midY + 4);\n\n  // if this edge was recently relaxed successfully, draw a green glow\n  if(e._justRelaxed){\n    ctx.beginPath();\n    ctx.moveTo(startX,startY);\n    ctx.lineTo(endX,endY);\n    ctx.strokeStyle = 'rgba(34,197,94,0.95)';\n    ctx.lineWidth = 4;\n    ctx.stroke();\n    // remove mark after drawing (transient)\n    // we'll clear after a short time via timeout\n  }\n}\n\nfunction drawNode(n){\n  // circle\n  ctx.beginPath();\n  ctx.arc(n.x,n.y,22,0,Math.PI*2);\n  ctx.fillStyle = '#0b1220';\n  ctx.fill();\n  ctx.lineWidth = 2;\n  ctx.strokeStyle = 'rgba(255,255,255,0.06)';\n  ctx.stroke();\n\n  // id\n  ctx.fillStyle = '#e6eef6';\n  ctx.font = 'bold 14px Inter,Arial';\n  ctx.textAlign = 'center';\n  ctx.fillText(n.id, n.x, n.y - 2);\n\n  // distance label below\n  const dist = (initialized && distances[n.id]!==undefined) ? distances[n.id] : '∞';\n  const pred = (predecessor[n.id]!==undefined && predecessor[n.id]!==null) ? `⟵${predecessor[n.id]}` : '';\n  ctx.fillStyle = '#9aa4b2';\n  ctx.font = '12px Inter,Arial';\n  ctx.fillText(String(dist) + (pred? ' ' + pred : ''), n.x, n.y + 18);\n}\n\n// Rendering loop\nfunction render(){\n  draw();\n  renderEdgeList();\n}\n\n// Interaction handlers\ncanvas.addEventListener('mousedown', (ev)=>{\n  const rect = canvas.getBoundingClientRect();\n  const x = ev.clientX - rect.left, y = ev.clientY - rect.top;\n  const n = findNodeAt(x,y);\n  if(addNodeMode){\n    addNode(x,y);\n    addNodeMode = false;\n    document.getElementById('addNodeBtn').classList.remove('active');\n    return;\n  }\n  if(addingEdgeMode){\n    if(n){\n      if(selectedNodeForEdge==null){\n        selectedNodeForEdge = n;\n        updateLog(`Selected node ${n.id} as edge source. Click target node.`);\n      } else if(selectedNodeForEdge.id === n.id){\n        selectedNodeForEdge = null;\n        updateLog('Edge creation canceled (same node).');\n      } else {\n        const weight = prompt(`Weight for edge ${selectedNodeForEdge.id} → ${n.id}:`, \"0\");\n        if(weight !== null && !isNaN(Number(weight))){\n          addEdge(selectedNodeForEdge.id, n.id, Number(weight));\n          updateLog(`Added edge ${selectedNodeForEdge.id} → ${n.id} (w=${Number(weight)})`);\n        } else {\n          updateLog('Edge creation canceled or invalid weight.');\n        }\n        selectedNodeForEdge = null;\n      }\n    }\n    return;\n  }\n\n  if(n){\n    dragging = n;\n    dragOffset.x = x - n.x;\n    dragOffset.y = y - n.y;\n  } else {\n    // create a node by clicking blank space\n    addNode(x,y);\n    updateLog('Added node ' + (nextNodeId-1));\n  }\n});\n\ncanvas.addEventListener('mousemove', (ev)=>{\n  if(!dragging) return;\n  const rect = canvas.getBoundingClientRect();\n  const x = ev.clientX - rect.left, y = ev.clientY - rect.top;\n  dragging.x = x - dragOffset.x;\n  dragging.y = y - dragOffset.y;\n  render();\n});\n\ncanvas.addEventListener('mouseup', ()=>{ dragging = null; });\ncanvas.addEventListener('mouseleave', ()=>{ dragging = null; });\n\n// Buttons and controls\ndocument.getElementById('addNodeBtn').addEventListener('click', ()=>{\n  addNodeMode = !addNodeMode;\n  document.getElementById('addNodeBtn').classList.toggle('active', addNodeMode);\n  updateLog(addNodeMode ? 'Click canvas to add a node.' : 'Add node mode off.');\n});\n\ndocument.getElementById('addEdgeBtn').addEventListener('click', ()=>{\n  addingEdgeMode = !addingEdgeMode;\n  selectedNodeForEdge = null;\n  document.getElementById('addEdgeBtn').classList.toggle('active', addingEdgeMode);\n  updateLog(addingEdgeMode ? 'Click a node to select edge source, then a node to select target.' : 'Add edge mode off.');\n});\n\ndocument.getElementById('clear').addEventListener('click', ()=>{\n  if(!confirm('Clear the entire graph?')) return;\n  resetAll();\n});\n\ndocument.getElementById('loadSample').addEventListener('click', ()=>{\n  const v = document.getElementById('sample').value;\n  loadSample(v);\n});\n\ndocument.getElementById('init').addEventListener('click', ()=>{\n  initializeAlgorithm();\n});\n\ndocument.getElementById('step').addEventListener('click', ()=>{\n  stepOnce();\n});\n\ndocument.getElementById('run').addEventListener('click', ()=>{\n  if(playing) stopAuto(); else startAuto();\n});\n\ndocument.getElementById('nextIter').addEventListener('click', ()=>{\n  finishIteration();\n});\n\ndocument.getElementById('reset').addEventListener('click', ()=>{\n  clearAlgorithmState();\n});\n\ndocument.getElementById('checkNeg').addEventListener('click', ()=>{\n  checkNegativeCycle();\n});\n\n// Auto-play\nfunction startAuto(){\n  if(!initialized){\n    updateLog('Initialize first (pick a source).');\n    return;\n  }\n  if(playing) return;\n  playing = true;\n  document.getElementById('run').textContent = 'Stop';\n  playTimer = setInterval(()=>{\n    const finished = stepOnce();\n    if(finished){\n      stopAuto();\n    }\n  }, 700);\n}\n\nfunction stopAuto(){\n  playing = false;\n  document.getElementById('run').textContent = 'Auto';\n  if(playTimer) clearInterval(playTimer);\n  playTimer = null;\n}\n\n// Algorithm: initialization\nfunction updateSourceOptions(){\n  // populate source select with node ids\n  const prev = sourceSelect.value;\n  sourceSelect.innerHTML = nodes.map(n=>`<option value=\"${n.id}\">${n.id}</option>`).join('');\n  if(prev && [...sourceSelect.options].some(o=>o.value===prev)) sourceSelect.value = prev;\n  if(!sourceSelect.value && nodes.length>0) sourceSelect.value = nodes[0].id;\n}\n\nfunction initializeAlgorithm(){\n  if(nodes.length===0){ updateLog('No nodes in graph.'); return; }\n  const s = Number(sourceSelect.value);\n  distances = {};\n  predecessor = {};\n  for(const n of nodes){\n    distances[n.id]=Infinity;\n    predecessor[n.id]=null;\n  }\n  distances[s]=0;\n  initialized = true;\n  iteration = 1;\n  edgeIndex = 0;\n  // clear any transient marks\n  for(const e of edges) delete e._justRelaxed;\n  updateLog(`Initialized. Source = ${s}. Ready to relax edges (V=${nodes.length}).`);\n  render();\n}\n\n// Algorithm: step once (relax next edge)\nfunction stepOnce(){\n  if(!initialized){\n    updateLog('Please initialize (pick a source) before stepping.');\n    return false;\n  }\n  const V = nodes.length;\n  if(iteration <= Math.max(0,V-1)){\n    if(edges.length === 0){\n      updateLog('No edges to relax.');\n      iteration = V; // fast-forward\n      return true;\n    }\n    if(edgeIndex >= edges.length){\n      // end of this iteration\n      updateLog(`Finished iteration ${iteration} of ${Math.max(0,V-1)}.`);\n      iteration++;\n      edgeIndex = 0;\n      render();\n      return iteration > Math.max(0,V-1);\n    }\n    const e = edges[edgeIndex];\n    // highlight current edge\n    updateLog(`Considering edge ${e.from} → ${e.to} (w=${e.weight}) [iter ${iteration}]`);\n    // relaxation\n    const u = e.from, v = e.to, w = e.weight;\n    const du = distances[u], dv = distances[v];\n    let changed = false;\n    if(du !== Infinity && du + w < dv){\n      distances[v] = du + w;\n      predecessor[v] = u;\n      changed = true;\n      e._justRelaxed = true;\n      // remove the mark after a short delay\n      setTimeout(()=>{ e._justRelaxed = false; render(); }, 600);\n      updateLog(`Relaxed: distance[${v}] updated to ${distances[v]} via ${u}`);\n    } else {\n      updateLog('No update.');\n    }\n    edgeIndex++;\n    render();\n    return false;\n  } else {\n    updateLog('All V-1 iterations completed. You can check for negative cycles.');\n    return true;\n  }\n}\n\n// Finish current iteration by running through remaining edges\nfunction finishIteration(){\n  if(!initialized){ updateLog('Initialize first.'); return; }\n  const V = nodes.length;\n  if(iteration > Math.max(0,V-1)){ updateLog('All iterations done.'); return; }\n  while(edgeIndex < edges.length){\n    // perform relax without delay\n    const e = edges[edgeIndex];\n    const u = e.from, v = e.to, w = e.weight;\n    const du = distances[u], dv = distances[v];\n    if(du !== Infinity && du + w < dv){\n      distances[v] = du + w;\n      predecessor[v] = u;\n      e._justRelaxed = true;\n      setTimeout(()=>{ e._justRelaxed = false; render(); }, 500);\n    }\n    edgeIndex++;\n  }\n  updateLog(`Completed iteration ${iteration}.`);\n  iteration++;\n  edgeIndex = 0;\n  render();\n}\n\n// Negative cycle detection\nfunction checkNegativeCycle(){\n  if(!initialized){ updateLog('Initialize first.'); return; }\n  const V = nodes.length;\n  // perform one more pass: if any edge can be relaxed, negative cycle exists\n  let found = [];\n  for(const e of edges){\n    const u = e.from, v = e.to, w = e.weight;\n    const du = distances[u], dv = distances[v];\n    if(du !== Infinity && du + w < dv){\n      found.push(e);\n    }\n  }\n  if(found.length===0){\n    updateLog('No negative-weight cycle detected (no relaxations possible in V-th pass).');\n  } else {\n    for(const f of found) {\n      f._justRelaxed = true;\n    }\n    render();\n    updateLog('Negative-weight cycle detected: some edges can still be relaxed (highlighted). Shortest paths undefined.');\n  }\n}\n\n// Sample graphs\nfunction loadSample(name){\n  nodes = [];\n  edges = [];\n  nextNodeId = 0;\n  nextEdgeId = 0;\n  if(name === 'sample1'){\n    // small graph with a negative edge but no negative cycle\n    const A = addNode(200,160);\n    const B = addNode(420,120);\n    const C = addNode(340,280);\n    const D = addNode(160,320);\n    addEdge(A.id, B.id, 6);\n    addEdge(A.id, D.id, 7);\n    addEdge(B.id, C.id, 5);\n    addEdge(B.id, D.id, 8);\n    addEdge(B.id, A.id, -4);\n    addEdge(C.id, B.id, -2);\n    addEdge(D.id, C.id, 9);\n    updateLog('Loaded sample 1: small graph with a negative edge (no negative cycle).');\n  } else if(name==='sample2'){\n    // negative cycle example\n    const n0 = addNode(180,160);\n    const n1 = addNode(360,120);\n    const n2 = addNode(520,160);\n    const n3 = addNode(460,300);\n    const n4 = addNode(240,300);\n    addEdge(n0.id,n1.id,1);\n    addEdge(n1.id,n2.id,-2);\n    addEdge(n2.id,n3.id,1);\n    addEdge(n3.id,n4.id,-1);\n    addEdge(n4.id,n1.id,-1); // creates negative cycle 1->2->3->4->1 sum negative\n    addEdge(n0.id,n4.id,4);\n    updateLog('Loaded sample 2: graph with a negative-weight cycle.');\n  } else if(name==='sample3'){\n    // random directed graph\n    for(let i=0;i<6;i++){\n      addNode(100 + (i%3)*260 + (Math.random()*60-30), 120 + Math.floor(i/3)*240 + (Math.random()*60-30));\n    }\n    // connect random edges\n    for(let i=0;i<10;i++){\n      const a = nodes[Math.floor(Math.random()*nodes.length)];\n      const b = nodes[Math.floor(Math.random()*nodes.length)];\n      if(a.id===b.id) continue;\n      const w = Math.floor(Math.random()*21)-10; // -10..10\n      addEdge(a.id,b.id,w);\n    }\n    updateLog('Loaded sample 3: random graph.');\n  }\n  clearAlgorithmState();\n  updateSourceOptions();\n  render();\n}\n\n// initialize with a default sample\nloadSample('sample1');\n\n// update source options when nodes change\nupdateSourceOptions();\n\n// small convenience to make canvas responsive-ish (keeps fixed size for simplicity)\nwindow.addEventListener('resize', ()=>{/* nothing for simplicity */});\n\n// Keyboard shortcuts\nwindow.addEventListener('keydown',(ev)=>{\n  if(ev.key===' '){ ev.preventDefault(); stepOnce(); }\n  if(ev.key==='r'){ ev.preventDefault(); startAuto(); }\n  if(ev.key==='Escape'){ addingEdgeMode=false; addNodeMode=false; selectedNodeForEdge=null; updateLog('Modes cleared.'); }\n});\n\n</script>\n</body>\n</html>"
  },
