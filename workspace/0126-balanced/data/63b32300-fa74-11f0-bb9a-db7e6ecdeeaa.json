    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>ACID Properties Demonstration</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2rem;\n      background: #f0f4f8;\n      color: #333;\n    }\n    h1, h2 {\n      text-align: center;\n      color: #2c3e50;\n    }\n    section {\n      background: white;\n      border-radius: 8px;\n      padding: 1rem 2rem 2rem 2rem;\n      margin: 1.5rem auto;\n      max-width: 700px;\n      box-shadow: 0 4px 8px rgba(0,0,0,0.1);\n    }\n    button {\n      background-color: #2980b9;\n      border: none;\n      padding: 0.5rem 1.2rem;\n      color: white;\n      font-weight: bold;\n      border-radius: 4px;\n      cursor: pointer;\n      margin-top: 1rem;\n      font-size: 1rem;\n      transition: background-color 0.2s ease;\n    }\n    button:hover {\n      background-color: #3498db;\n    }\n    .log {\n      margin-top: 1rem;\n      background: #ecf0f1;\n      border-radius: 4px;\n      padding: 0.5rem 1rem;\n      font-family: monospace;\n      height: 120px;\n      overflow-y: auto;\n      white-space: pre-wrap;\n      border: 1px solid #bdc3c7;\n    }\n    .acid-property {\n      font-weight: bold;\n      color: #2980b9;\n    }\n    .explanation {\n      margin-top: 0.3rem;\n      font-size: 0.9rem;\n      color: #555;\n      font-style: italic;\n    }\n    .error {\n      color: #c0392b;\n      font-weight: bold;\n    }\n    .success {\n      color: #27ae60;\n      font-weight: bold;\n    }\n  </style>\n</head>\n<body>\n  <h1>ACID Properties of Database Transactions</h1>\n  <section>\n    <h2>Simulated Bank Account Transfer</h2>\n    <p>\n      This demonstration simulates a simple banking transaction transferring money \n      from <strong>Account A</strong> to <strong>Account B</strong>. It illustrates \n      the <span class=\"acid-property\">ACID</span> properties:\n    </p>\n    <ul>\n      <li><span class=\"acid-property\">Atomicity:</span> All steps succeed or none do.</li>\n      <li><span class=\"acid-property\">Consistency:</span> The data remains valid after the transaction.</li>\n      <li><span class=\"acid-property\">Isolation:</span> Transactions appear independent and isolated.</li>\n      <li><span class=\"acid-property\">Durability:</span> Once committed, changes persist.</li>\n    </ul>\n    <p><em>Try the transfer buttons and watch the logs below.</em></p>\n    <div>\n      <strong>Account Balances:</strong>\n      <ul>\n        <li>Account A: $<span id=\"accountA\">1000</span></li>\n        <li>Account B: $<span id=\"accountB\">500</span></li>\n      </ul>\n    </div>\n    <div>\n      <label>\n        Transfer Amount: $\n        <input type=\"number\" id=\"transferAmount\" value=\"100\" min=\"1\" max=\"2000\" />\n      </label>\n    </div>\n    <div>\n      <button id=\"transferSuccess\">Transfer (Successful)</button>\n      <button id=\"transferFail\">Transfer (Simulate Failure)</button>\n    </div>\n    <div class=\"log\" id=\"log\" aria-live=\"polite\"></div>\n  </section>\n\n  <section>\n    <h2>Explanation of ACID Properties</h2>\n    <ul>\n      <li><span class=\"acid-property\">Atomicity:</span> Either the entire transfer completes (money debited and credited) or nothing happens if an error occurs.</li>\n      <li><span class=\"acid-property\">Consistency:</span> Account balances never become negative, and total money remains constant.</li>\n      <li><span class=\"acid-property\">Isolation:</span> Each transfer runs isolated — intermediate states aren't visible.</li>\n      <li><span class=\"acid-property\">Durability:</span> Changes are saved to <em>localStorage</em>, so data persists even if you reload the page.</li>\n    </ul>\n  </section>\n\n  <script>\n    // Using localStorage to simulate durability\n    const STORAGE_KEY = 'acid_account_balances';\n\n    // Initialize balances if none saved\n    function initBalances() {\n      const saved = localStorage.getItem(STORAGE_KEY);\n      if (saved) {\n        return JSON.parse(saved);\n      } else {\n        const accounts = { A: 1000, B: 500 };\n        localStorage.setItem(STORAGE_KEY, JSON.stringify(accounts));\n        return accounts;\n      }\n    }\n    \n    let accounts = initBalances();\n\n    const accountADoc = document.getElementById('accountA');\n    const accountBDoc = document.getElementById('accountB');\n    const logEl = document.getElementById('log');\n    const transferAmountInput = document.getElementById('transferAmount');\n\n    // Utility to log messages\n    function log(message, type) {\n      const time = new Date().toLocaleTimeString();\n      const spanClass = type === 'error' ? 'error' : type === 'success' ? 'success' : '';\n      logEl.innerHTML += `[${time}] <span class=\"${spanClass}\">${message}</span>\\n`;\n      logEl.scrollTop = logEl.scrollHeight;\n    }\n\n    function updateDisplay() {\n      accountADoc.textContent = accounts.A.toFixed(2);\n      accountBDoc.textContent = accounts.B.toFixed(2);\n    }\n\n    function saveBalances() {\n      localStorage.setItem(STORAGE_KEY, JSON.stringify(accounts));\n    }\n\n    /* \n      Transaction function simulating ACID properties.\n      transfer(amount, shouldFail)\n      - amount: number to transfer from A to B.\n      - shouldFail: boolean - when true, simulate failure mid-transaction.\n    */\n    async function transfer(amount, shouldFail = false) {\n      log(`Starting transfer of $${amount.toFixed(2)} from Account A to Account B.`);\n      \n      // Atomicity & Isolation: create a private copy (transaction context)\n      let transaction = {\n        A: accounts.A,\n        B: accounts.B,\n        committed: false,\n      };\n\n      try {\n        // Step 1: Validate amount\n        if (amount <= 0) throw new Error('Transfer amount must be positive.');\n\n        // Step 2: Check sufficient funds (Consistency)\n        if (transaction.A < amount) {\n          throw new Error('Insufficient funds in Account A.');\n        }\n\n        // Step 3: Debit Account A\n        transaction.A -= amount;\n        log(`Debited $${amount.toFixed(2)} from Account A. Temporary balance: $${transaction.A.toFixed(2)}.`);\n\n        // Insert delay to simulate processing time and demonstrate isolation\n        await delay(500);\n\n        // Step 4: Simulate failure if requested before crediting Account B\n        if (shouldFail) throw new Error('Simulated failure during transaction.');\n\n        // Step 5: Credit Account B\n        transaction.B += amount;\n        log(`Credited $${amount.toFixed(2)} to Account B. Temporary balance: $${transaction.B.toFixed(2)}.`);\n\n        // Step 6: Final consistency check (total should be constant)\n        const totalBefore = accounts.A + accounts.B;\n        const totalAfter = transaction.A + transaction.B;\n        if (Math.abs(totalBefore - totalAfter) > 0.01) {\n          throw new Error('Consistency violated: total balance mismatch.');\n        }\n\n        // Commit transaction (Durability)\n        accounts = { A: transaction.A, B: transaction.B };\n        saveBalances();\n        updateDisplay();\n        transaction.committed = true;\n\n        log('Transaction committed successfully.', 'success');\n      } catch (error) {\n        // Abort transaction (Atomicity)\n        log(`Transaction aborted: ${error.message}`, 'error');\n        log('No changes applied. Data remains consistent.', 'error');\n      }\n    }\n\n    // Helper delay function (ms)\n    function delay(ms) {\n      return new Promise(resolve => setTimeout(resolve, ms));\n    }\n\n    // Bind buttons\n    document.getElementById('transferSuccess').addEventListener('click', () => {\n      const amount = parseFloat(transferAmountInput.value);\n      if (isNaN(amount)) {\n        log('Invalid transfer amount.', 'error');\n        return;\n      }\n      transfer(amount, false);\n    });\n\n    document.getElementById('transferFail').addEventListener('click', () => {\n      const amount = parseFloat(transferAmountInput.value);\n      if (isNaN(amount)) {\n        log('Invalid transfer amount.', 'error');\n        return;\n      }\n      transfer(amount, true);\n    });\n\n    // Initialize display on page load\n    updateDisplay();\n    log('Welcome! You can perform transfers to see ACID properties in action.');\n  </script>\n</body>\n</html>"
