      "runBothBtn.addEventListener('click', ()=>{ stopAutoPlay(); resetStats(); const t = parseInt(targetInput.value); const interp = interpolationSearchGen(array, t); let resI; while(true){ const n = interp.next(); if(n.done){ resI = n.value; break; } } log(`Interpolation: probes=${resI.probes} index=${resI.index}`); const bin = binarySearchGen(array, t); let resB; while(true){ const n = bin.next(); if(n.done){ resB = n.value; break; } } log(`Binary: probes=${resB.probes} index=${resB.index}`); state.probes = resI.probes; state.comps = resI.comps; state.iters = resI.iters; state.found = resI.index; updateStats(); if(resI.index !== -1) highlight({low:0, high:array.length-1, pos:resI.index, found:resI.index, visited:new Set()}); });",
