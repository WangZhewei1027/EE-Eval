{
  "meta": {
    "concept": "Symmetric Cryptography",
    "topic": "Symmetric Key Encryption and Decryption",
    "educational_goal": "Demonstrate encryption and decryption using symmetric keys",
    "expected_interactions": [
      "encrypt",
      "decrypt",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_EncryptStart",
      "label": "EncryptStart",
      "type": "atomic",
      "entry_actions": [
        "readInputText()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_Encrypting",
      "label": "Encrypting",
      "type": "atomic",
      "entry_actions": [
        "performEncryption()",
        "generateCipherText()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DecryptionStart",
      "label": "DecryptionStart",
      "type": "atomic",
      "entry_actions": [
        "readCipherText()",
        "highlightCipherInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S6_Decrypting",
      "label": "Decrypting",
      "type": "atomic",
      "entry_actions": [
        "performDecryption()",
        "generatePlainText()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S7_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllFields()",
        "resetInterface()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksEncrypt",
      "event_type": "user_action",
      "description": "User clicks the Encrypt button"
    },
    {
      "id": "UserClicksDecrypt",
      "event_type": "user_action",
      "description": "User clicks the Decrypt button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "EncryptionComplete",
      "event_type": "system_event",
      "description": "Encryption process complete"
    },
    {
      "id": "DecryptionComplete",
      "event_type": "system_event",
      "description": "Decryption process complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_EncryptStart",
      "event": "UserClicksEncrypt",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInputText()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputText",
        "dom:encryptButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_EncryptStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateText()",
        "prepareEncryption()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_Encrypting",
      "event": "InputValidationComplete",
      "guard": "validText",
      "actions": [
        "parseInputText()",
        "beginEncryption()"
      ],
      "expected_observables": [
        "dom:encryptionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_EncryptStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Encrypting",
      "to": "S0_Idle",
      "event": "EncryptionComplete",
      "guard": "encryptionSuccessful",
      "actions": [
        "displayCipherText()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:cipherTextVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S5_DecryptionStart",
      "event": "UserClicksDecrypt",
      "guard": "cipherTextNotEmpty",
      "actions": [
        "captureCipherText()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readCipherText",
        "dom:decryptButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S5_DecryptionStart",
      "to": "S6_Decrypting",
      "event": "DecryptionComplete",
      "guard": "decryptionSuccessful",
      "actions": [
        "displayPlainText()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:plainTextVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S7_Resetting",
      "event": "UserClicksReset",
      "guard": "fieldsNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S7_Resetting",
      "to": "S0_Idle",
      "event": "DecryptionComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:fieldsCleared",
        "dom:interfaceReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "encrypt",
    "decrypt",
    "reset",
    "output"
  ]
}