{
  "meta": {
    "concept": "Depth-First Search",
    "topic": "Depth-First Search Algorithm Visualization",
    "educational_goal": "Demonstrate DFS traversal on a graph",
    "expected_interactions": [
      "start",
      "pause",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_StartDFS",
      "label": "StartDFS",
      "type": "atomic",
      "entry_actions": [
        "highlightStartNode()",
        "disableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S2_Traversing",
      "label": "Traversing",
      "type": "operation",
      "entry_actions": [
        "performDFS()",
        "updateTraversalVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_Paused",
      "label": "Paused",
      "type": "atomic",
      "entry_actions": [
        "pauseTraversal()",
        "showPauseIndicator()"
      ],
      "exit_actions": [
        "clearPauseIndicator()"
      ]
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearTraversal()",
        "resetGraphVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStart",
      "event_type": "user_action",
      "description": "User clicks the Start button"
    },
    {
      "id": "UserClicksPause",
      "event_type": "user_action",
      "description": "User clicks the Pause button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "TraversalComplete",
      "event_type": "system_event",
      "description": "DFS traversal completes successfully"
    },
    {
      "id": "PauseRequested",
      "event_type": "system_event",
      "description": "Pause requested during traversal"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_StartDFS",
      "event": "UserClicksStart",
      "guard": "graphNotEmpty",
      "actions": [
        "captureStartNode()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startButtonClicked",
        "dom:startNodeHighlighted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_StartDFS",
      "to": "S2_Traversing",
      "event": "TraversalComplete",
      "guard": "startNodeValid",
      "actions": [
        "beginTraversal()",
        "updateVisualization()"
      ],
      "expected_observables": [
        "dom:traversalStarted"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Traversing",
      "to": "S3_Paused",
      "event": "PauseRequested",
      "guard": "true",
      "actions": [
        "pauseTraversal()",
        "showPauseIndicator()"
      ],
      "expected_observables": [
        "dom:traversalPaused"
      ],
      "timeout": 500
    },
    {
      "from": "S3_Paused",
      "to": "S2_Traversing",
      "event": "UserClicksStart",
      "guard": "true",
      "actions": [
        "resumeTraversal()",
        "clearPauseIndicator()"
      ],
      "expected_observables": [
        "dom:traversalResumed"
      ],
      "timeout": 500
    },
    {
      "from": "S2_Traversing",
      "to": "S0_Idle",
      "event": "TraversalComplete",
      "guard": "traversalFinished",
      "actions": [
        "enableControls()",
        "clearTraversalData()"
      ],
      "expected_observables": [
        "dom:traversalComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start",
    "pause",
    "reset",
    "graph_visualization"
  ]
}