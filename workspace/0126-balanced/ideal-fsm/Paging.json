{
  "meta": {
    "concept": "Paging",
    "topic": "Memory Paging Visualization",
    "educational_goal": "Demonstrate paging mechanism in memory management",
    "expected_interactions": [
      "load_page",
      "evict_page",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderMemory()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_LoadPageStart",
      "label": "LoadPageStart",
      "type": "atomic",
      "entry_actions": [
        "readPageNumber()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingPageNumber",
      "label": "ValidatingPageNumber",
      "type": "atomic",
      "entry_actions": [
        "validatePageNumber()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_LoadingPage",
      "label": "LoadingPage",
      "type": "atomic",
      "entry_actions": [
        "findPageFrame()",
        "loadPageIntoFrame()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_UpdatingMemory",
      "label": "UpdatingMemory",
      "type": "atomic",
      "entry_actions": [
        "updateMemoryVisualization()",
        "animatePageLoad()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_MemoryResetting",
      "label": "MemoryResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllPages()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksLoadPage",
      "event_type": "user_action",
      "description": "User clicks the Load Page button"
    },
    {
      "id": "UserEntersPageNumber",
      "event_type": "user_action",
      "description": "User enters page number in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "PageNumberValidationComplete",
      "event_type": "system_event",
      "description": "Page number validation completes successfully"
    },
    {
      "id": "PageNumberValidationFailed",
      "event_type": "system_event",
      "description": "Page number validation fails"
    },
    {
      "id": "PageLoadComplete",
      "event_type": "system_event",
      "description": "Page loading and memory update complete"
    },
    {
      "id": "MemoryResetComplete",
      "event_type": "system_event",
      "description": "Memory reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_LoadPageStart",
      "event": "UserClicksLoadPage",
      "guard": "inputNotEmpty",
      "actions": [
        "capturePageNumber()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readPageNumber",
        "dom:loadPageButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_LoadPageStart",
      "to": "S2_ValidatingPageNumber",
      "event": "PageNumberValidationComplete",
      "guard": "pageNumberIsValid",
      "actions": [
        "validatePageNumber()",
        "preparePageLoad()"
      ],
      "expected_observables": [
        "dom:pageNumberValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingPageNumber",
      "to": "S4_LoadingPage",
      "event": "PageNumberValidationComplete",
      "guard": "validPageNumber",
      "actions": [
        "parsePageNumber()",
        "beginPageLoad()"
      ],
      "expected_observables": [
        "dom:pageLoadStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_LoadPageStart",
      "to": "S3_ErrorAlert",
      "event": "PageNumberValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_LoadingPage",
      "to": "S5_UpdatingMemory",
      "event": "PageLoadComplete",
      "guard": "pageLoadedSuccessfully",
      "actions": [
        "updateMemoryStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:memoryStructureChanged",
        "dom:newPageVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_UpdatingMemory",
      "to": "S0_Idle",
      "event": "PageLoadComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_MemoryResetting",
      "event": "UserClicksReset",
      "guard": "memoryNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_MemoryResetting",
      "to": "S0_Idle",
      "event": "MemoryResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:memoryCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "load_page",
    "reset",
    "memory_visualization"
  ]
}