{
  "meta": {
    "concept": "TCP/IP",
    "topic": "TCP/IP Protocol Suite",
    "educational_goal": "Demonstrate TCP connection establishment and data transmission",
    "expected_interactions": [
      "connect",
      "sendData",
      "disconnect",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderNetworkTopology()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_Connecting",
      "label": "Connecting",
      "type": "atomic",
      "entry_actions": [
        "initiateConnection()",
        "showConnectingStatus()"
      ],
      "exit_actions": [
        "clearConnectingStatus()"
      ]
    },
    {
      "id": "S2_Connected",
      "label": "Connected",
      "type": "atomic",
      "entry_actions": [
        "showConnectedStatus()",
        "enableDataTransfer()"
      ],
      "exit_actions": [
        "disableDataTransfer()"
      ]
    },
    {
      "id": "S3_SendingData",
      "label": "SendingData",
      "type": "atomic",
      "entry_actions": [
        "sendDataPacket()",
        "showDataTransferAnimation()"
      ],
      "exit_actions": [
        "clearDataTransferAnimation()"
      ]
    },
    {
      "id": "S4_Disconnecting",
      "label": "Disconnecting",
      "type": "atomic",
      "entry_actions": [
        "initiateDisconnection()",
        "showDisconnectingStatus()"
      ],
      "exit_actions": [
        "clearDisconnectingStatus()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "resetNetwork()",
        "clearAllConnections()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksConnect",
      "event_type": "user_action",
      "description": "User clicks the Connect button"
    },
    {
      "id": "ConnectionEstablished",
      "event_type": "system_event",
      "description": "TCP connection established successfully"
    },
    {
      "id": "UserClicksSendData",
      "event_type": "user_action",
      "description": "User clicks the Send Data button"
    },
    {
      "id": "DataSent",
      "event_type": "system_event",
      "description": "Data packet sent successfully"
    },
    {
      "id": "UserClicksDisconnect",
      "event_type": "user_action",
      "description": "User clicks the Disconnect button"
    },
    {
      "id": "DisconnectionComplete",
      "event_type": "system_event",
      "description": "TCP disconnection completed"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "NetworkResetComplete",
      "event_type": "system_event",
      "description": "Network reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_Connecting",
      "event": "UserClicksConnect",
      "guard": "networkAvailable",
      "actions": [
        "disableControls()",
        "startConnectionProcess()"
      ],
      "expected_observables": [
        "dom:connectButtonClicked",
        "dom:connectingStatusVisible"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_Connecting",
      "to": "S2_Connected",
      "event": "ConnectionEstablished",
      "guard": "connectionSuccessful",
      "actions": [
        "enableDataTransfer()",
        "updateConnectionStatus()"
      ],
      "expected_observables": [
        "dom:connectedStatusVisible"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Connected",
      "to": "S3_SendingData",
      "event": "UserClicksSendData",
      "guard": "dataReadyToSend",
      "actions": [
        "prepareDataPacket()",
        "sendData()"
      ],
      "expected_observables": [
        "dom:dataTransferAnimationVisible"
      ],
      "timeout": 1500
    },
    {
      "from": "S3_SendingData",
      "to": "S2_Connected",
      "event": "DataSent",
      "guard": "dataSentSuccessfully",
      "actions": [
        "clearDataPacket()",
        "updateTransferStatus()"
      ],
      "expected_observables": [
        "dom:dataTransferComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Connected",
      "to": "S4_Disconnecting",
      "event": "UserClicksDisconnect",
      "guard": "connectionActive",
      "actions": [
        "initiateDisconnectionProcess()",
        "showDisconnectingStatus()"
      ],
      "expected_observables": [
        "dom:disconnectingStatusVisible"
      ],
      "timeout": 2000
    },
    {
      "from": "S4_Disconnecting",
      "to": "S0_Idle",
      "event": "DisconnectionComplete",
      "guard": "disconnectionSuccessful",
      "actions": [
        "clearConnectionStatus()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:disconnectedStatusVisible"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "networkNotEmpty",
      "actions": [
        "confirmReset()",
        "beginNetworkReset()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "NetworkResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetNetworkTopology()"
      ],
      "expected_observables": [
        "dom:networkCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "connect",
    "sendData",
    "disconnect",
    "reset",
    "network_visualization"
  ]
}