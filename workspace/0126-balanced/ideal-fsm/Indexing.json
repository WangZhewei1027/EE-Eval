{
  "meta": {
    "concept": "Indexing",
    "topic": "Indexing in Databases",
    "educational_goal": "Demonstrate how indexing improves search efficiency",
    "expected_interactions": [
      "create_index",
      "search",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderDatabase()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_CreateIndexStart",
      "label": "CreateIndexStart",
      "type": "atomic",
      "entry_actions": [
        "readIndexFieldInput()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingIndexField",
      "label": "ValidatingIndexField",
      "type": "atomic",
      "entry_actions": [
        "validateIndexField()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_CreatingIndex",
      "label": "CreatingIndex",
      "type": "atomic",
      "entry_actions": [
        "buildIndex()",
        "updateIndexVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_Searching",
      "label": "Searching",
      "type": "atomic",
      "entry_actions": [
        "performSearch()",
        "highlightSearchResults()"
      ],
      "exit_actions": [
        "clearSearchHighlight()"
      ]
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearIndex()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCreateIndex",
      "event_type": "user_action",
      "description": "User clicks the Create Index button"
    },
    {
      "id": "UserEntersIndexField",
      "event_type": "user_action",
      "description": "User enters field name for indexing"
    },
    {
      "id": "UserClicksSearch",
      "event_type": "user_action",
      "description": "User clicks the Search button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "IndexFieldValidationComplete",
      "event_type": "system_event",
      "description": "Index field validation completes successfully"
    },
    {
      "id": "IndexFieldValidationFailed",
      "event_type": "system_event",
      "description": "Index field validation fails"
    },
    {
      "id": "IndexCreationComplete",
      "event_type": "system_event",
      "description": "Index creation and update complete"
    },
    {
      "id": "SearchComplete",
      "event_type": "system_event",
      "description": "Search operation complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_CreateIndexStart",
      "event": "UserClicksCreateIndex",
      "guard": "inputNotEmpty",
      "actions": [
        "captureIndexField()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readIndexFieldInput",
        "dom:createIndexButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_CreateIndexStart",
      "to": "S2_ValidatingIndexField",
      "event": "IndexFieldValidationComplete",
      "guard": "fieldIsValid",
      "actions": [
        "validateField()",
        "prepareIndexCreation()"
      ],
      "expected_observables": [
        "dom:indexFieldValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingIndexField",
      "to": "S4_CreatingIndex",
      "event": "IndexFieldValidationComplete",
      "guard": "validField",
      "actions": [
        "parseFieldInput()",
        "beginIndexCreation()"
      ],
      "expected_observables": [
        "dom:indexCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_CreateIndexStart",
      "to": "S3_ErrorAlert",
      "event": "IndexFieldValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_CreatingIndex",
      "to": "S0_Idle",
      "event": "IndexCreationComplete",
      "guard": "indexCreatedSuccessfully",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:indexCreated"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Searching",
      "event": "UserClicksSearch",
      "guard": "indexExists",
      "actions": [
        "executeSearch()",
        "highlightResults()"
      ],
      "expected_observables": [
        "dom:searchInitiated"
      ],
      "timeout": 2000
    },
    {
      "from": "S5_Searching",
      "to": "S0_Idle",
      "event": "SearchComplete",
      "guard": "searchFinished",
      "actions": [
        "enableControls()",
        "clearSearchInput()"
      ],
      "expected_observables": [
        "dom:searchResultsDisplayed"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "indexExists",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:indexCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "create_index",
    "search",
    "reset",
    "index_visualization"
  ]
}