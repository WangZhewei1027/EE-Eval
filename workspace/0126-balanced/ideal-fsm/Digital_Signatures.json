{
  "meta": {
    "concept": "DigitalSignatures",
    "topic": "Digital Signature Demonstration",
    "educational_goal": "Illustrate the process of creating and verifying digital signatures",
    "expected_interactions": [
      "create_signature",
      "verify_signature",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_CreatingSignature",
      "label": "CreatingSignature",
      "type": "atomic",
      "entry_actions": [
        "captureInputData()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_VerifyingSignature",
      "label": "VerifyingSignature",
      "type": "atomic",
      "entry_actions": [
        "captureSignatureData()",
        "highlightVerificationInput()"
      ],
      "exit_actions": [
        "clearVerificationHighlight()"
      ]
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_SignatureCreated",
      "label": "SignatureCreated",
      "type": "atomic",
      "entry_actions": [
        "generateSignature()",
        "displaySignature()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_SignatureVerified",
      "label": "SignatureVerified",
      "type": "atomic",
      "entry_actions": [
        "verifySignature()",
        "showVerificationResult()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllData()",
        "resetInterface()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCreateSignature",
      "event_type": "user_action",
      "description": "User clicks the Create Signature button"
    },
    {
      "id": "UserClicksVerifySignature",
      "event_type": "user_action",
      "description": "User clicks the Verify Signature button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "SignatureCreationComplete",
      "event_type": "system_event",
      "description": "Signature creation completes successfully"
    },
    {
      "id": "SignatureVerificationComplete",
      "event_type": "system_event",
      "description": "Signature verification completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_CreatingSignature",
      "event": "UserClicksCreateSignature",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:createSignatureButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_CreatingSignature",
      "to": "S4_SignatureCreated",
      "event": "SignatureCreationComplete",
      "guard": "signatureCreatedSuccessfully",
      "actions": [
        "displaySignature()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:signatureDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S0_Idle",
      "to": "S2_VerifyingSignature",
      "event": "UserClicksVerifySignature",
      "guard": "inputNotEmpty",
      "actions": [
        "captureVerificationInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:verifySignatureButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S2_VerifyingSignature",
      "to": "S5_SignatureVerified",
      "event": "SignatureVerificationComplete",
      "guard": "verificationSuccessful",
      "actions": [
        "showVerificationResult()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:verificationResultDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_CreatingSignature",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_VerifyingSignature",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusVerificationInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "dataNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:dataCleared",
        "dom:interfaceReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "create_signature",
    "verify_signature",
    "reset",
    "signature_display"
  ]
}