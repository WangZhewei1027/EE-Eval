{
  "meta": {
    "concept": "ACID Properties",
    "topic": "Database Transaction Management",
    "educational_goal": "Illustrate the ACID properties in database transactions",
    "expected_interactions": [
      "start_transaction",
      "commit",
      "rollback",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderTransactionState()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_TransactionStarted",
      "label": "TransactionStarted",
      "type": "atomic",
      "entry_actions": [
        "initializeTransaction()",
        "highlightTransaction()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_CommittingTransaction",
      "label": "CommittingTransaction",
      "type": "atomic",
      "entry_actions": [
        "validateCommit()",
        "showCommitFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_RollbackTransaction",
      "label": "RollbackTransaction",
      "type": "atomic",
      "entry_actions": [
        "performRollback()",
        "showRollbackFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S5_ResettingTransaction",
      "label": "ResettingTransaction",
      "type": "atomic",
      "entry_actions": [
        "clearTransactionState()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserStartsTransaction",
      "event_type": "user_action",
      "description": "User starts a new transaction"
    },
    {
      "id": "UserCommitsTransaction",
      "event_type": "user_action",
      "description": "User commits the transaction"
    },
    {
      "id": "UserRollbacksTransaction",
      "event_type": "user_action",
      "description": "User rolls back the transaction"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CommitValidationComplete",
      "event_type": "system_event",
      "description": "Commit validation completes successfully"
    },
    {
      "id": "CommitValidationFailed",
      "event_type": "system_event",
      "description": "Commit validation fails"
    },
    {
      "id": "RollbackComplete",
      "event_type": "system_event",
      "description": "Rollback operation complete"
    },
    {
      "id": "TransactionResetComplete",
      "event_type": "system_event",
      "description": "Transaction reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_TransactionStarted",
      "event": "UserStartsTransaction",
      "guard": "true",
      "actions": [
        "captureTransactionStart()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:transactionStarted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_TransactionStarted",
      "to": "S2_CommittingTransaction",
      "event": "UserCommitsTransaction",
      "guard": "transactionValid",
      "actions": [
        "validateCommit()",
        "prepareCommit()"
      ],
      "expected_observables": [
        "dom:commitInitiated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_CommittingTransaction",
      "to": "S0_Idle",
      "event": "CommitValidationComplete",
      "guard": "commitSuccessful",
      "actions": [
        "finalizeCommit()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:commitSuccessful"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_TransactionStarted",
      "to": "S3_RollbackTransaction",
      "event": "UserRollbacksTransaction",
      "guard": "true",
      "actions": [
        "initiateRollback()",
        "performRollback()"
      ],
      "expected_observables": [
        "dom:rollbackInitiated"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_RollbackTransaction",
      "to": "S0_Idle",
      "event": "RollbackComplete",
      "guard": "rollbackSuccessful",
      "actions": [
        "finalizeRollback()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:rollbackSuccessful"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_CommittingTransaction",
      "to": "S4_ErrorAlert",
      "event": "CommitValidationFailed",
      "guard": "true",
      "actions": [
        "showError()",
        "focusTransaction()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetTransaction()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingTransaction",
      "event": "UserClicksReset",
      "guard": "transactionNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingTransaction",
      "to": "S0_Idle",
      "event": "TransactionResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetTransactionField()"
      ],
      "expected_observables": [
        "dom:transactionCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "transaction_input",
    "start_transaction",
    "commit",
    "rollback",
    "reset",
    "transaction_visualization"
  ]
}