{
  "meta": {
    "concept": "Asymmetric Cryptography",
    "topic": "Asymmetric Cryptography Visualization",
    "educational_goal": "Demonstrate key generation, encryption, and decryption",
    "expected_interactions": [
      "generate_keys",
      "encrypt",
      "decrypt",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_GeneratingKeys",
      "label": "GeneratingKeys",
      "type": "atomic",
      "entry_actions": [
        "startKeyGeneration()",
        "showKeyGenerationProgress()"
      ],
      "exit_actions": [
        "hideKeyGenerationProgress()"
      ]
    },
    {
      "id": "S2_KeysGenerated",
      "label": "KeysGenerated",
      "type": "atomic",
      "entry_actions": [
        "displayGeneratedKeys()",
        "enableEncryption()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_Encrypting",
      "label": "Encrypting",
      "type": "atomic",
      "entry_actions": [
        "readPlaintext()",
        "performEncryption()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_Encrypted",
      "label": "Encrypted",
      "type": "atomic",
      "entry_actions": [
        "displayCiphertext()",
        "enableDecryption()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_Decrypting",
      "label": "Decrypting",
      "type": "atomic",
      "entry_actions": [
        "readCiphertext()",
        "performDecryption()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_Decrypted",
      "label": "Decrypted",
      "type": "atomic",
      "entry_actions": [
        "displayDecryptedText()",
        "enableReset()"
      ],
      "exit_actions": []
    },
    {
      "id": "S7_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllFields()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksGenerateKeys",
      "event_type": "user_action",
      "description": "User clicks the Generate Keys button"
    },
    {
      "id": "KeyGenerationComplete",
      "event_type": "system_event",
      "description": "Key generation completes successfully"
    },
    {
      "id": "UserClicksEncrypt",
      "event_type": "user_action",
      "description": "User clicks the Encrypt button"
    },
    {
      "id": "EncryptionComplete",
      "event_type": "system_event",
      "description": "Encryption process completes successfully"
    },
    {
      "id": "UserClicksDecrypt",
      "event_type": "user_action",
      "description": "User clicks the Decrypt button"
    },
    {
      "id": "DecryptionComplete",
      "event_type": "system_event",
      "description": "Decryption process completes successfully"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_GeneratingKeys",
      "event": "UserClicksGenerateKeys",
      "guard": "true",
      "actions": [
        "disableControls()",
        "initiateKeyGeneration()"
      ],
      "expected_observables": [
        "dom:keyGenerationStarted"
      ],
      "timeout": 3000
    },
    {
      "from": "S1_GeneratingKeys",
      "to": "S2_KeysGenerated",
      "event": "KeyGenerationComplete",
      "guard": "keysGeneratedSuccessfully",
      "actions": [
        "storeKeys()",
        "enableEncryption()"
      ],
      "expected_observables": [
        "dom:keysDisplayed"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_KeysGenerated",
      "to": "S3_Encrypting",
      "event": "UserClicksEncrypt",
      "guard": "plaintextNotEmpty",
      "actions": [
        "capturePlaintext()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:encryptionStarted"
      ],
      "timeout": 2000
    },
    {
      "from": "S3_Encrypting",
      "to": "S4_Encrypted",
      "event": "EncryptionComplete",
      "guard": "encryptionSuccessful",
      "actions": [
        "storeCiphertext()",
        "enableDecryption()"
      ],
      "expected_observables": [
        "dom:ciphertextDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S4_Encrypted",
      "to": "S5_Decrypting",
      "event": "UserClicksDecrypt",
      "guard": "ciphertextNotEmpty",
      "actions": [
        "captureCiphertext()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:decryptionStarted"
      ],
      "timeout": 2000
    },
    {
      "from": "S5_Decrypting",
      "to": "S6_Decrypted",
      "event": "DecryptionComplete",
      "guard": "decryptionSuccessful",
      "actions": [
        "storeDecryptedText()",
        "enableReset()"
      ],
      "expected_observables": [
        "dom:decryptedTextDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S6_Decrypted",
      "to": "S7_Resetting",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetInitiated"
      ],
      "timeout": 500
    },
    {
      "from": "S7_Resetting",
      "to": "S0_Idle",
      "event": "UserClicksReset",
      "guard": "resetComplete",
      "actions": [
        "enableControls()",
        "clearAllFields()"
      ],
      "expected_observables": [
        "dom:resetComplete"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "generate_keys",
    "encrypt",
    "decrypt",
    "reset",
    "key_display",
    "plaintext_input",
    "ciphertext_display",
    "decrypted_text_display"
  ]
}