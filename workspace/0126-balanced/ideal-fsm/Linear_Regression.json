{
  "meta": {
    "concept": "LinearRegression",
    "topic": "Linear Regression Visualization",
    "educational_goal": "Demonstrate linear regression fitting and prediction",
    "expected_interactions": [
      "input_data",
      "fit_model",
      "predict",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputData",
      "label": "InputData",
      "type": "atomic",
      "entry_actions": [
        "readInputData()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingData",
      "label": "ValidatingData",
      "type": "atomic",
      "entry_actions": [
        "validateData()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_FittingModel",
      "label": "FittingModel",
      "type": "atomic",
      "entry_actions": [
        "computeRegression()",
        "updateModelParameters()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingGraph",
      "label": "DrawingGraph",
      "type": "atomic",
      "entry_actions": [
        "updateGraphVisualization()",
        "animateFitLine()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearGraphData()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsData",
      "event_type": "user_action",
      "description": "User inputs data points"
    },
    {
      "id": "UserClicksFit",
      "event_type": "user_action",
      "description": "User clicks the Fit Model button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DataValidationComplete",
      "event_type": "system_event",
      "description": "Data validation completes successfully"
    },
    {
      "id": "DataValidationFailed",
      "event_type": "system_event",
      "description": "Data validation fails"
    },
    {
      "id": "ModelFitComplete",
      "event_type": "system_event",
      "description": "Model fitting and graph update complete"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputData",
      "event": "UserInputsData",
      "guard": "dataNotEmpty",
      "actions": [
        "captureData()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:dataInputReceived"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputData",
      "to": "S2_ValidatingData",
      "event": "DataValidationComplete",
      "guard": "dataIsValid",
      "actions": [
        "validateDataPoints()",
        "prepareModelFitting()"
      ],
      "expected_observables": [
        "dom:dataValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingData",
      "to": "S4_FittingModel",
      "event": "DataValidationComplete",
      "guard": "validDataFormat",
      "actions": [
        "parseDataPoints()",
        "beginModelFitting()"
      ],
      "expected_observables": [
        "dom:modelFittingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputData",
      "to": "S3_ErrorAlert",
      "event": "DataValidationFailed",
      "guard": "dataIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_FittingModel",
      "to": "S5_DrawingGraph",
      "event": "ModelFitComplete",
      "guard": "modelFittedSuccessfully",
      "actions": [
        "updateGraphStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:graphStructureChanged",
        "dom:fitLineVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingGraph",
      "to": "S0_Idle",
      "event": "ModelFitComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "fit_model",
    "reset",
    "graph_visualization"
  ]
}