{
  "meta": {
    "concept": "Transaction",
    "topic": "Transaction Processing System",
    "educational_goal": "Demonstrate transaction initiation, validation, and completion",
    "expected_interactions": [
      "initiate",
      "validate",
      "complete",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderTransactionForm()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InitiateTransaction",
      "label": "InitiateTransaction",
      "type": "atomic",
      "entry_actions": [
        "captureTransactionDetails()",
        "highlightInputFields()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingTransaction",
      "label": "ValidatingTransaction",
      "type": "atomic",
      "entry_actions": [
        "validateTransactionDetails()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightErrorFields()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ProcessingTransaction",
      "label": "ProcessingTransaction",
      "type": "atomic",
      "entry_actions": [
        "processTransaction()",
        "updateTransactionStatus()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_TransactionComplete",
      "label": "TransactionComplete",
      "type": "atomic",
      "entry_actions": [
        "showCompletionMessage()",
        "updateUIForCompletion()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingTransaction",
      "label": "ResettingTransaction",
      "type": "atomic",
      "entry_actions": [
        "clearTransactionDetails()",
        "resetForm()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInitiate",
      "event_type": "user_action",
      "description": "User clicks the Initiate button"
    },
    {
      "id": "UserEntersTransactionDetails",
      "event_type": "user_action",
      "description": "User enters transaction details in the form"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "TransactionValidationComplete",
      "event_type": "system_event",
      "description": "Transaction validation completes successfully"
    },
    {
      "id": "TransactionValidationFailed",
      "event_type": "system_event",
      "description": "Transaction validation fails"
    },
    {
      "id": "TransactionProcessingComplete",
      "event_type": "system_event",
      "description": "Transaction processing and update complete"
    },
    {
      "id": "TransactionResetComplete",
      "event_type": "system_event",
      "description": "Transaction reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InitiateTransaction",
      "event": "UserClicksInitiate",
      "guard": "detailsNotEmpty",
      "actions": [
        "captureTransactionDetails()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:transactionDetailsCaptured",
        "dom:initiateButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InitiateTransaction",
      "to": "S2_ValidatingTransaction",
      "event": "TransactionValidationComplete",
      "guard": "detailsAreValid",
      "actions": [
        "validateDetails()",
        "prepareProcessing()"
      ],
      "expected_observables": [
        "dom:transactionValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingTransaction",
      "to": "S4_ProcessingTransaction",
      "event": "TransactionValidationComplete",
      "guard": "validDetails",
      "actions": [
        "parseTransactionDetails()",
        "beginProcessing()"
      ],
      "expected_observables": [
        "dom:transactionProcessingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InitiateTransaction",
      "to": "S3_ErrorAlert",
      "event": "TransactionValidationFailed",
      "guard": "detailsAreInvalid",
      "actions": [
        "showError()",
        "focusInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ProcessingTransaction",
      "to": "S5_TransactionComplete",
      "event": "TransactionProcessingComplete",
      "guard": "transactionProcessedSuccessfully",
      "actions": [
        "updateTransactionRecord()",
        "triggerCompletionUI()"
      ],
      "expected_observables": [
        "dom:transactionStatusUpdated",
        "dom:completionMessageVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_TransactionComplete",
      "to": "S0_Idle",
      "event": "TransactionProcessingComplete",
      "guard": "completionUIUpdated",
      "actions": [
        "enableControls()",
        "clearInputFields()"
      ],
      "expected_observables": [
        "dom:completionUIUpdated"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingTransaction",
      "event": "UserClicksReset",
      "guard": "transactionDetailsExist",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingTransaction",
      "to": "S0_Idle",
      "event": "TransactionResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:transactionDetailsCleared",
        "dom:formReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "initiate",
    "reset",
    "transaction_status"
  ]
}