{
  "meta": {
    "concept": "Multiset",
    "topic": "Multiset Operations Visualization",
    "educational_goal": "Demonstrate multiset addition and removal",
    "expected_interactions": [
      "add",
      "remove",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderMultiset()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddStart",
      "label": "AddStart",
      "type": "atomic",
      "entry_actions": [
        "readInputValue()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AddingElement",
      "label": "AddingElement",
      "type": "atomic",
      "entry_actions": [
        "addElementToMultiset()",
        "updateMultisetVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_RemovingElement",
      "label": "RemovingElement",
      "type": "atomic",
      "entry_actions": [
        "removeElementFromMultiset()",
        "updateMultisetVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_MultisetResetting",
      "label": "MultisetResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllElements()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAdd",
      "event_type": "user_action",
      "description": "User clicks the Add button"
    },
    {
      "id": "UserClicksRemove",
      "event_type": "user_action",
      "description": "User clicks the Remove button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters value in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "ElementAdditionComplete",
      "event_type": "system_event",
      "description": "Element addition and multiset update complete"
    },
    {
      "id": "ElementRemovalComplete",
      "event_type": "system_event",
      "description": "Element removal and multiset update complete"
    },
    {
      "id": "MultisetResetComplete",
      "event_type": "system_event",
      "description": "Multiset reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddStart",
      "event": "UserClicksAdd",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValue",
        "dom:addButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateValue()",
        "prepareAddition()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_AddingElement",
      "event": "InputValidationComplete",
      "guard": "validElement",
      "actions": [
        "parseInputValue()",
        "beginAddition()"
      ],
      "expected_observables": [
        "dom:elementAdditionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AddStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AddingElement",
      "to": "S0_Idle",
      "event": "ElementAdditionComplete",
      "guard": "additionSuccessful",
      "actions": [
        "updateMultisetStructure()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:multisetStructureChanged",
        "dom:newElementVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S5_RemovingElement",
      "event": "UserClicksRemove",
      "guard": "elementExists",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:removeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S5_RemovingElement",
      "to": "S0_Idle",
      "event": "ElementRemovalComplete",
      "guard": "removalSuccessful",
      "actions": [
        "updateMultisetStructure()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:multisetStructureChanged",
        "dom:elementRemoved"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S6_MultisetResetting",
      "event": "UserClicksReset",
      "guard": "multisetNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_MultisetResetting",
      "to": "S0_Idle",
      "event": "MultisetResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:multisetCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "add",
    "remove",
    "reset",
    "multiset_visualization"
  ]
}