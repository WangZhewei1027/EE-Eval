{
  "meta": {
    "concept": "Context Switching",
    "topic": "Operating System Process Management",
    "educational_goal": "Demonstrate the process of context switching between tasks",
    "expected_interactions": [
      "start",
      "switch",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderProcessList()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_StartProcess",
      "label": "StartProcess",
      "type": "atomic",
      "entry_actions": [
        "readProcessInput()",
        "highlightProcessInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingProcess",
      "label": "ValidatingProcess",
      "type": "atomic",
      "entry_actions": [
        "validateProcessInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ContextSwitching",
      "label": "ContextSwitching",
      "type": "atomic",
      "entry_actions": [
        "saveCurrentState()",
        "loadNextProcessState()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_UpdatingProcessList",
      "label": "UpdatingProcessList",
      "type": "atomic",
      "entry_actions": [
        "updateProcessVisualization()",
        "animateSwitch()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingProcesses",
      "label": "ResettingProcesses",
      "type": "atomic",
      "entry_actions": [
        "clearAllProcesses()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStart",
      "event_type": "user_action",
      "description": "User clicks the Start button"
    },
    {
      "id": "UserEntersProcess",
      "event_type": "user_action",
      "description": "User enters process details in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ProcessValidationComplete",
      "event_type": "system_event",
      "description": "Process validation completes successfully"
    },
    {
      "id": "ProcessValidationFailed",
      "event_type": "system_event",
      "description": "Process validation fails"
    },
    {
      "id": "ContextSwitchComplete",
      "event_type": "system_event",
      "description": "Context switch and process update complete"
    },
    {
      "id": "ProcessResetComplete",
      "event_type": "system_event",
      "description": "Process reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_StartProcess",
      "event": "UserClicksStart",
      "guard": "inputNotEmpty",
      "actions": [
        "captureProcessInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readProcessInput",
        "dom:startButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_StartProcess",
      "to": "S2_ValidatingProcess",
      "event": "ProcessValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateProcessDetails()",
        "prepareContextSwitch()"
      ],
      "expected_observables": [
        "dom:processValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingProcess",
      "to": "S4_ContextSwitching",
      "event": "ProcessValidationComplete",
      "guard": "validProcess",
      "actions": [
        "parseProcessDetails()",
        "beginContextSwitch()"
      ],
      "expected_observables": [
        "dom:contextSwitchStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_StartProcess",
      "to": "S3_ErrorAlert",
      "event": "ProcessValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusProcessInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetProcessInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ContextSwitching",
      "to": "S5_UpdatingProcessList",
      "event": "ContextSwitchComplete",
      "guard": "switchSuccessful",
      "actions": [
        "updateProcessStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:processStructureChanged",
        "dom:nextProcessVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_UpdatingProcessList",
      "to": "S0_Idle",
      "event": "ContextSwitchComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearProcessInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingProcesses",
      "event": "UserClicksReset",
      "guard": "processListNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingProcesses",
      "to": "S0_Idle",
      "event": "ProcessResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetProcessInputField()"
      ],
      "expected_observables": [
        "dom:processesCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "start",
    "reset",
    "process_visualization"
  ]
}