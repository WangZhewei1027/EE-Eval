{
  "meta": {
    "concept": "Time Complexity",
    "topic": "Understanding Time Complexity",
    "educational_goal": "Explain and visualize time complexity of algorithms",
    "expected_interactions": [
      "select_algorithm",
      "visualize",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderAlgorithmOptions()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AlgorithmSelected",
      "label": "AlgorithmSelected",
      "type": "atomic",
      "entry_actions": [
        "highlightSelection()",
        "fetchAlgorithmData()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Visualizing",
      "label": "Visualizing",
      "type": "operation",
      "entry_actions": [
        "generateVisualization()",
        "displayComplexityGraph()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S3_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearVisualization()",
        "resetSelection()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsAlgorithm",
      "event_type": "user_action",
      "description": "User selects an algorithm from the list"
    },
    {
      "id": "UserClicksVisualize",
      "event_type": "user_action",
      "description": "User clicks the Visualize button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "AlgorithmDataFetched",
      "event_type": "system_event",
      "description": "Algorithm data is successfully fetched"
    },
    {
      "id": "VisualizationComplete",
      "event_type": "system_event",
      "description": "Visualization process completes"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AlgorithmSelected",
      "event": "UserSelectsAlgorithm",
      "guard": "selectionValid",
      "actions": [
        "captureSelection()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:algorithmSelected"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_AlgorithmSelected",
      "to": "S2_Visualizing",
      "event": "AlgorithmDataFetched",
      "guard": "dataAvailable",
      "actions": [
        "prepareVisualization()",
        "startVisualization()"
      ],
      "expected_observables": [
        "dom:visualizationStarted"
      ],
      "timeout": 2000
    },
    {
      "from": "S2_Visualizing",
      "to": "S0_Idle",
      "event": "VisualizationComplete",
      "guard": "visualizationSuccess",
      "actions": [
        "enableControls()",
        "clearSelection()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S3_Resetting",
      "event": "UserClicksReset",
      "guard": "visualizationExists",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S3_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearSelection()"
      ],
      "expected_observables": [
        "dom:visualizationCleared"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "algorithm_selector",
    "visualize",
    "reset",
    "complexity_graph"
  ]
}