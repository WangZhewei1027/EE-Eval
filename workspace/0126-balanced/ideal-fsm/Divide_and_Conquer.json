{
  "meta": {
    "concept": "Divide and Conquer",
    "topic": "Divide and Conquer Algorithm Visualization",
    "educational_goal": "Illustrate the divide and conquer approach in algorithms",
    "expected_interactions": [
      "divide",
      "conquer",
      "combine",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInitialProblem()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_DivideStart",
      "label": "DivideStart",
      "type": "atomic",
      "entry_actions": [
        "captureProblemInput()",
        "highlightProblemArea()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Dividing",
      "label": "Dividing",
      "type": "atomic",
      "entry_actions": [
        "performDivision()",
        "showDivisionFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_Conquering",
      "label": "Conquering",
      "type": "atomic",
      "entry_actions": [
        "solveSubproblems()",
        "showConquerFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_Combining",
      "label": "Combining",
      "type": "atomic",
      "entry_actions": [
        "combineSolutions()",
        "showCombineFeedback()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllSteps()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksDivide",
      "event_type": "user_action",
      "description": "User clicks the Divide button"
    },
    {
      "id": "UserClicksConquer",
      "event_type": "user_action",
      "description": "User clicks the Conquer button"
    },
    {
      "id": "UserClicksCombine",
      "event_type": "user_action",
      "description": "User clicks the Combine button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DivisionComplete",
      "event_type": "system_event",
      "description": "Division of problem complete"
    },
    {
      "id": "ConquerComplete",
      "event_type": "system_event",
      "description": "Conquering subproblems complete"
    },
    {
      "id": "CombineComplete",
      "event_type": "system_event",
      "description": "Combining solutions complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_DivideStart",
      "event": "UserClicksDivide",
      "guard": "problemDefined",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:divideButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_DivideStart",
      "to": "S2_Dividing",
      "event": "DivisionComplete",
      "guard": "divisionSuccessful",
      "actions": [
        "performDivision()",
        "prepareConquer()"
      ],
      "expected_observables": [
        "dom:divisionPerformed"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Dividing",
      "to": "S3_Conquering",
      "event": "ConquerComplete",
      "guard": "subproblemsReady",
      "actions": [
        "solveSubproblems()",
        "prepareCombine()"
      ],
      "expected_observables": [
        "dom:conquerPerformed"
      ],
      "timeout": 1500
    },
    {
      "from": "S3_Conquering",
      "to": "S4_Combining",
      "event": "CombineComplete",
      "guard": "solutionsReady",
      "actions": [
        "combineSolutions()",
        "finalizeSolution()"
      ],
      "expected_observables": [
        "dom:combinePerformed"
      ],
      "timeout": 3000
    },
    {
      "from": "S4_Combining",
      "to": "S0_Idle",
      "event": "CombineComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "stepsPerformed",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:stepsCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "divide",
    "conquer",
    "combine",
    "reset",
    "visualization_area"
  ]
}