{
  "meta": {
    "concept": "Version Control",
    "topic": "Version Control System Interaction",
    "educational_goal": "Demonstrate basic version control operations",
    "expected_interactions": [
      "commit",
      "checkout",
      "merge",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderRepositoryState()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_CommitStart",
      "label": "CommitStart",
      "type": "atomic",
      "entry_actions": [
        "readCommitMessage()",
        "highlightCommitInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingCommit",
      "label": "ValidatingCommit",
      "type": "atomic",
      "entry_actions": [
        "validateCommitMessage()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_CommittingChanges",
      "label": "CommittingChanges",
      "type": "atomic",
      "entry_actions": [
        "stageChanges()",
        "createCommit()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_UpdatingRepository",
      "label": "UpdatingRepository",
      "type": "atomic",
      "entry_actions": [
        "updateRepositoryVisualization()",
        "animateCommit()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_RepositoryResetting",
      "label": "RepositoryResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllCommits()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCommit",
      "event_type": "user_action",
      "description": "User clicks the Commit button"
    },
    {
      "id": "UserEntersCommitMessage",
      "event_type": "user_action",
      "description": "User enters commit message in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CommitValidationComplete",
      "event_type": "system_event",
      "description": "Commit message validation completes successfully"
    },
    {
      "id": "CommitValidationFailed",
      "event_type": "system_event",
      "description": "Commit message validation fails"
    },
    {
      "id": "CommitOperationComplete",
      "event_type": "system_event",
      "description": "Commit operation and repository update complete"
    },
    {
      "id": "RepositoryResetComplete",
      "event_type": "system_event",
      "description": "Repository reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_CommitStart",
      "event": "UserClicksCommit",
      "guard": "messageNotEmpty",
      "actions": [
        "captureCommitMessage()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readCommitMessage",
        "dom:commitButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_CommitStart",
      "to": "S2_ValidatingCommit",
      "event": "CommitValidationComplete",
      "guard": "messageIsValid",
      "actions": [
        "validateMessage()",
        "prepareCommit()"
      ],
      "expected_observables": [
        "dom:commitMessageValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingCommit",
      "to": "S4_CommittingChanges",
      "event": "CommitValidationComplete",
      "guard": "validMessage",
      "actions": [
        "parseCommitMessage()",
        "beginCommit()"
      ],
      "expected_observables": [
        "dom:commitCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_CommitStart",
      "to": "S3_ErrorAlert",
      "event": "CommitValidationFailed",
      "guard": "messageIsEmpty",
      "actions": [
        "showError()",
        "focusCommitInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetCommitInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_CommittingChanges",
      "to": "S5_UpdatingRepository",
      "event": "CommitOperationComplete",
      "guard": "commitSuccessful",
      "actions": [
        "updateRepositoryStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:repositoryStructureChanged",
        "dom:newCommitVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_UpdatingRepository",
      "to": "S0_Idle",
      "event": "CommitOperationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearCommitInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_RepositoryResetting",
      "event": "UserClicksReset",
      "guard": "repositoryNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_RepositoryResetting",
      "to": "S0_Idle",
      "event": "RepositoryResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetCommitInputField()"
      ],
      "expected_observables": [
        "dom:repositoryCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "commit",
    "reset",
    "repository_visualization"
  ]
}