{
  "meta": {
    "concept": "Amortized Analysis",
    "topic": "Amortized Analysis of Algorithms",
    "educational_goal": "Understand amortized cost versus worst-case cost",
    "expected_interactions": [
      "input_sequence",
      "calculate_amortized_cost",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputSequence",
      "label": "InputSequence",
      "type": "atomic",
      "entry_actions": [
        "readInputSequence()",
        "highlightInputField()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingSequence",
      "label": "ValidatingSequence",
      "type": "atomic",
      "entry_actions": [
        "validateSequence()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_CalculatingAmortizedCost",
      "label": "CalculatingAmortizedCost",
      "type": "atomic",
      "entry_actions": [
        "computeAmortizedCost()",
        "updateVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DisplayResults",
      "label": "DisplayResults",
      "type": "atomic",
      "entry_actions": [
        "showResults()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearInputs()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsSequence",
      "event_type": "user_action",
      "description": "User inputs a sequence of operations"
    },
    {
      "id": "UserClicksCalculate",
      "event_type": "user_action",
      "description": "User clicks the Calculate button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "SequenceValidationComplete",
      "event_type": "system_event",
      "description": "Sequence validation completes successfully"
    },
    {
      "id": "SequenceValidationFailed",
      "event_type": "system_event",
      "description": "Sequence validation fails"
    },
    {
      "id": "AmortizedCostCalculationComplete",
      "event_type": "system_event",
      "description": "Amortized cost calculation complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputSequence",
      "event": "UserInputsSequence",
      "guard": "sequenceNotEmpty",
      "actions": [
        "captureSequence()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:sequenceInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputSequence",
      "to": "S2_ValidatingSequence",
      "event": "SequenceValidationComplete",
      "guard": "sequenceIsValid",
      "actions": [
        "validateSequence()",
        "prepareCalculation()"
      ],
      "expected_observables": [
        "dom:sequenceValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingSequence",
      "to": "S4_CalculatingAmortizedCost",
      "event": "SequenceValidationComplete",
      "guard": "validSequence",
      "actions": [
        "parseSequence()",
        "beginCalculation()"
      ],
      "expected_observables": [
        "dom:calculationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputSequence",
      "to": "S3_ErrorAlert",
      "event": "SequenceValidationFailed",
      "guard": "sequenceIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_CalculatingAmortizedCost",
      "to": "S5_DisplayResults",
      "event": "AmortizedCostCalculationComplete",
      "guard": "calculationSuccessful",
      "actions": [
        "updateResults()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:resultsDisplayed",
        "dom:visualizationUpdated"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DisplayResults",
      "to": "S0_Idle",
      "event": "AmortizedCostCalculationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "sequenceNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:inputsCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input_sequence",
    "calculate",
    "reset",
    "results_visualization"
  ]
}