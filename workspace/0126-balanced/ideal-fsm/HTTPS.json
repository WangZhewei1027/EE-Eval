{
  "meta": {
    "concept": "HTTPS",
    "topic": "HTTPS Protocol Visualization",
    "educational_goal": "Demonstrate HTTPS connection establishment and data encryption",
    "expected_interactions": [
      "connect",
      "validate",
      "encrypt",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderConnectionStatus()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_ConnectStart",
      "label": "ConnectStart",
      "type": "atomic",
      "entry_actions": [
        "readURLInput()",
        "highlightURLInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingCertificate",
      "label": "ValidatingCertificate",
      "type": "atomic",
      "entry_actions": [
        "validateCertificate()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_EncryptingData",
      "label": "EncryptingData",
      "type": "atomic",
      "entry_actions": [
        "establishSecureConnection()",
        "encryptData()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ConnectionEstablished",
      "label": "ConnectionEstablished",
      "type": "atomic",
      "entry_actions": [
        "updateConnectionVisualization()",
        "animateEncryption()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ConnectionResetting",
      "label": "ConnectionResetting",
      "type": "atomic",
      "entry_actions": [
        "terminateConnection()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksConnect",
      "event_type": "user_action",
      "description": "User clicks the Connect button"
    },
    {
      "id": "UserEntersURL",
      "event_type": "user_action",
      "description": "User enters URL in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CertificateValidationComplete",
      "event_type": "system_event",
      "description": "Certificate validation completes successfully"
    },
    {
      "id": "CertificateValidationFailed",
      "event_type": "system_event",
      "description": "Certificate validation fails"
    },
    {
      "id": "DataEncryptionComplete",
      "event_type": "system_event",
      "description": "Data encryption and secure connection establishment complete"
    },
    {
      "id": "ConnectionResetComplete",
      "event_type": "system_event",
      "description": "Connection reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_ConnectStart",
      "event": "UserClicksConnect",
      "guard": "urlNotEmpty",
      "actions": [
        "captureURL()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readURLInput",
        "dom:connectButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_ConnectStart",
      "to": "S2_ValidatingCertificate",
      "event": "CertificateValidationComplete",
      "guard": "certificateIsValid",
      "actions": [
        "validateCertificate()",
        "prepareEncryption()"
      ],
      "expected_observables": [
        "dom:certificateValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingCertificate",
      "to": "S4_EncryptingData",
      "event": "CertificateValidationComplete",
      "guard": "validCertificate",
      "actions": [
        "parseCertificate()",
        "beginEncryption()"
      ],
      "expected_observables": [
        "dom:encryptionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_ConnectStart",
      "to": "S3_ErrorAlert",
      "event": "CertificateValidationFailed",
      "guard": "certificateInvalid",
      "actions": [
        "showError()",
        "focusURLInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetURLInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_EncryptingData",
      "to": "S5_ConnectionEstablished",
      "event": "DataEncryptionComplete",
      "guard": "encryptionSuccessful",
      "actions": [
        "updateConnectionStatus()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:connectionStatusChanged",
        "dom:secureConnectionVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_ConnectionEstablished",
      "to": "S0_Idle",
      "event": "DataEncryptionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearURLInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ConnectionResetting",
      "event": "UserClicksReset",
      "guard": "connectionActive",
      "actions": [
        "confirmReset()",
        "beginTermination()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ConnectionResetting",
      "to": "S0_Idle",
      "event": "ConnectionResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetURLInputField()"
      ],
      "expected_observables": [
        "dom:connectionTerminated",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "connect",
    "reset",
    "connection_visualization"
  ]
}