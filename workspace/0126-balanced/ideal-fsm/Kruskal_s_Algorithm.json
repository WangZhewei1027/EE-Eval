{
  "meta": {
    "concept": "Kruskal's Algorithm",
    "topic": "Minimum Spanning Tree Construction",
    "educational_goal": "Demonstrate edge selection and MST formation using Kruskal's Algorithm",
    "expected_interactions": [
      "select_edge",
      "validate_cycle",
      "add_to_mst",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SelectingEdge",
      "label": "SelectingEdge",
      "type": "atomic",
      "entry_actions": [
        "highlightSelectableEdges()",
        "captureEdgeSelection()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingCycle",
      "label": "ValidatingCycle",
      "type": "atomic",
      "entry_actions": [
        "checkForCycle()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showCycleErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AddingToMST",
      "label": "AddingToMST",
      "type": "atomic",
      "entry_actions": [
        "addEdgeToMST()",
        "updateMSTVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearMSTEdges()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsEdge",
      "event_type": "user_action",
      "description": "User selects an edge to add to MST"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CycleValidationComplete",
      "event_type": "system_event",
      "description": "Cycle validation completes successfully"
    },
    {
      "id": "CycleValidationFailed",
      "event_type": "system_event",
      "description": "Cycle validation fails"
    },
    {
      "id": "EdgeAdditionComplete",
      "event_type": "system_event",
      "description": "Edge addition and MST update complete"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses cycle error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SelectingEdge",
      "event": "UserSelectsEdge",
      "guard": "edgeSelectable",
      "actions": [
        "captureEdgeSelection()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:edgeSelected"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SelectingEdge",
      "to": "S2_ValidatingCycle",
      "event": "CycleValidationComplete",
      "guard": "noCycleDetected",
      "actions": [
        "validateEdge()",
        "prepareEdgeAddition()"
      ],
      "expected_observables": [
        "dom:cycleValidationPassed"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingCycle",
      "to": "S4_AddingToMST",
      "event": "CycleValidationComplete",
      "guard": "validEdge",
      "actions": [
        "addEdgeToMST()",
        "beginVisualizationUpdate()"
      ],
      "expected_observables": [
        "dom:edgeAddedToMST"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_SelectingEdge",
      "to": "S3_ErrorAlert",
      "event": "CycleValidationFailed",
      "guard": "cycleDetected",
      "actions": [
        "showCycleError()",
        "focusEdgeSelection()"
      ],
      "expected_observables": [
        "dom:cycleErrorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetEdgeSelection()"
      ],
      "expected_observables": [
        "dom:cycleErrorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AddingToMST",
      "to": "S0_Idle",
      "event": "EdgeAdditionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearEdgeSelection()"
      ],
      "expected_observables": [
        "dom:mstVisualizationUpdated"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "mstNotEmpty",
      "actions": [
        "confirmReset()",
        "beginGraphClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetEdgeSelection()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "edge_selection",
    "reset",
    "mst_visualization"
  ]
}