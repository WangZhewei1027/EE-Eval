{
  "meta": {
    "concept": "HTTP",
    "topic": "HTTP Request/Response Cycle",
    "educational_goal": "Demonstrate HTTP request and response handling",
    "expected_interactions": [
      "send_request",
      "receive_response",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_RequestStart",
      "label": "RequestStart",
      "type": "atomic",
      "entry_actions": [
        "captureRequestDetails()",
        "highlightRequestInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingRequest",
      "label": "ValidatingRequest",
      "type": "atomic",
      "entry_actions": [
        "validateRequest()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_SendingRequest",
      "label": "SendingRequest",
      "type": "atomic",
      "entry_actions": [
        "sendHTTPRequest()",
        "showLoadingIndicator()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ReceivingResponse",
      "label": "ReceivingResponse",
      "type": "atomic",
      "entry_actions": [
        "processHTTPResponse()",
        "displayResponseData()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearRequestResponse()",
        "resetInterface()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksSendRequest",
      "event_type": "user_action",
      "description": "User clicks the Send Request button"
    },
    {
      "id": "UserEntersRequestDetails",
      "event_type": "user_action",
      "description": "User enters request details in input fields"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "RequestValidationComplete",
      "event_type": "system_event",
      "description": "Request validation completes successfully"
    },
    {
      "id": "RequestValidationFailed",
      "event_type": "system_event",
      "description": "Request validation fails"
    },
    {
      "id": "ResponseReceived",
      "event_type": "system_event",
      "description": "HTTP response received and processed"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_RequestStart",
      "event": "UserClicksSendRequest",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:requestButtonClicked",
        "dom:inputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_RequestStart",
      "to": "S2_ValidatingRequest",
      "event": "RequestValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateRequestDetails()",
        "prepareRequest()"
      ],
      "expected_observables": [
        "dom:requestValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingRequest",
      "to": "S4_SendingRequest",
      "event": "RequestValidationComplete",
      "guard": "validRequest",
      "actions": [
        "initiateHTTPRequest()",
        "showSendingIndicator()"
      ],
      "expected_observables": [
        "dom:requestSent"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_RequestStart",
      "to": "S3_ErrorAlert",
      "event": "RequestValidationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_SendingRequest",
      "to": "S5_ReceivingResponse",
      "event": "ResponseReceived",
      "guard": "responseReceivedSuccessfully",
      "actions": [
        "processResponseData()",
        "displayResponse()"
      ],
      "expected_observables": [
        "dom:responseDisplayed"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_ReceivingResponse",
      "to": "S0_Idle",
      "event": "ResponseReceived",
      "guard": "responseProcessed",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:responseProcessed"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "interfaceNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:interfaceCleared",
        "dom:resetComplete"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "send_request",
    "reset",
    "response_display"
  ]
}