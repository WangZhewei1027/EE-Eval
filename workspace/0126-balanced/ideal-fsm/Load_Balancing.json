{
  "meta": {
    "concept": "Load Balancing",
    "topic": "Load Balancing Visualization",
    "educational_goal": "Demonstrate load distribution across servers",
    "expected_interactions": [
      "add_server",
      "remove_server",
      "distribute_load",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderServers()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddServerStart",
      "label": "AddServerStart",
      "type": "atomic",
      "entry_actions": [
        "readServerInput()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingServerInput",
      "label": "ValidatingServerInput",
      "type": "atomic",
      "entry_actions": [
        "validateServerInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AddingServer",
      "label": "AddingServer",
      "type": "atomic",
      "entry_actions": [
        "createNewServer()",
        "updateServerList()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DistributingLoad",
      "label": "DistributingLoad",
      "type": "atomic",
      "entry_actions": [
        "calculateLoadDistribution()",
        "updateVisualization()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllServers()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAddServer",
      "event_type": "user_action",
      "description": "User clicks the Add Server button"
    },
    {
      "id": "UserEntersServerInput",
      "event_type": "user_action",
      "description": "User enters server details in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ServerInputValidationComplete",
      "event_type": "system_event",
      "description": "Server input validation completes successfully"
    },
    {
      "id": "ServerInputValidationFailed",
      "event_type": "system_event",
      "description": "Server input validation fails"
    },
    {
      "id": "ServerAdditionComplete",
      "event_type": "system_event",
      "description": "Server addition and list update complete"
    },
    {
      "id": "LoadDistributionComplete",
      "event_type": "system_event",
      "description": "Load distribution operation complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddServerStart",
      "event": "UserClicksAddServer",
      "guard": "inputNotEmpty",
      "actions": [
        "captureServerInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readServerInput",
        "dom:addServerButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddServerStart",
      "to": "S2_ValidatingServerInput",
      "event": "ServerInputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateServerDetails()",
        "prepareServerAddition()"
      ],
      "expected_observables": [
        "dom:serverInputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingServerInput",
      "to": "S4_AddingServer",
      "event": "ServerInputValidationComplete",
      "guard": "validServerDetails",
      "actions": [
        "parseServerInput()",
        "beginServerAddition()"
      ],
      "expected_observables": [
        "dom:serverCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AddServerStart",
      "to": "S3_ErrorAlert",
      "event": "ServerInputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AddingServer",
      "to": "S5_DistributingLoad",
      "event": "ServerAdditionComplete",
      "guard": "serverAddedSuccessfully",
      "actions": [
        "updateServerStructure()",
        "triggerLoadDistribution()"
      ],
      "expected_observables": [
        "dom:serverListChanged",
        "dom:newServerVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DistributingLoad",
      "to": "S0_Idle",
      "event": "LoadDistributionComplete",
      "guard": "distributionComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:distributionComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "serversNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:serversCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "add_server",
    "reset",
    "server_visualization"
  ]
}