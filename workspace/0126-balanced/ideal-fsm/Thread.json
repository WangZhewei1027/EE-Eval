{
  "meta": {
    "concept": "Thread",
    "topic": "Thread Management and Synchronization",
    "educational_goal": "Demonstrate thread creation, execution, and synchronization",
    "expected_interactions": [
      "create",
      "start",
      "synchronize",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderThreadUI()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_CreateThread",
      "label": "CreateThread",
      "type": "atomic",
      "entry_actions": [
        "readThreadParameters()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingParameters",
      "label": "ValidatingParameters",
      "type": "atomic",
      "entry_actions": [
        "validateParameters()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_StartingThread",
      "label": "StartingThread",
      "type": "atomic",
      "entry_actions": [
        "initializeThread()",
        "executeThread()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_SynchronizingThreads",
      "label": "SynchronizingThreads",
      "type": "atomic",
      "entry_actions": [
        "applySynchronization()",
        "updateThreadState()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingThreads",
      "label": "ResettingThreads",
      "type": "atomic",
      "entry_actions": [
        "terminateAllThreads()",
        "resetThreadUI()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCreate",
      "event_type": "user_action",
      "description": "User clicks the Create button"
    },
    {
      "id": "UserEntersParameters",
      "event_type": "user_action",
      "description": "User enters thread parameters in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ParameterValidationComplete",
      "event_type": "system_event",
      "description": "Parameter validation completes successfully"
    },
    {
      "id": "ParameterValidationFailed",
      "event_type": "system_event",
      "description": "Parameter validation fails"
    },
    {
      "id": "ThreadStartComplete",
      "event_type": "system_event",
      "description": "Thread start and execution complete"
    },
    {
      "id": "ThreadSynchronizationComplete",
      "event_type": "system_event",
      "description": "Thread synchronization operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_CreateThread",
      "event": "UserClicksCreate",
      "guard": "parametersNotEmpty",
      "actions": [
        "captureParameters()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readThreadParameters",
        "dom:createButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_CreateThread",
      "to": "S2_ValidatingParameters",
      "event": "ParameterValidationComplete",
      "guard": "parametersAreValid",
      "actions": [
        "validateThreadParameters()",
        "prepareThreadStart()"
      ],
      "expected_observables": [
        "dom:parametersValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingParameters",
      "to": "S4_StartingThread",
      "event": "ParameterValidationComplete",
      "guard": "validParameters",
      "actions": [
        "parseThreadParameters()",
        "beginThreadExecution()"
      ],
      "expected_observables": [
        "dom:threadExecutionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_CreateThread",
      "to": "S3_ErrorAlert",
      "event": "ParameterValidationFailed",
      "guard": "parametersAreEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_StartingThread",
      "to": "S5_SynchronizingThreads",
      "event": "ThreadStartComplete",
      "guard": "threadStartedSuccessfully",
      "actions": [
        "updateThreadState()",
        "triggerSynchronization()"
      ],
      "expected_observables": [
        "dom:threadStateChanged",
        "dom:threadRunning"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_SynchronizingThreads",
      "to": "S0_Idle",
      "event": "ThreadSynchronizationComplete",
      "guard": "synchronizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:synchronizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingThreads",
      "event": "UserClicksReset",
      "guard": "threadsNotEmpty",
      "actions": [
        "confirmReset()",
        "beginTerminationOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingThreads",
      "to": "S0_Idle",
      "event": "ThreadSynchronizationComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:threadsCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "create",
    "reset",
    "thread_visualization"
  ]
}