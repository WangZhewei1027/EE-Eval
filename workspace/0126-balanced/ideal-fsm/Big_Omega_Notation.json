{
  "meta": {
    "concept": "Big-Omega Notation",
    "topic": "Algorithm Complexity Analysis",
    "educational_goal": "Understand and apply Big-Omega notation for lower bound analysis",
    "expected_interactions": [
      "input_function",
      "validate",
      "compare",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputStart",
      "label": "InputStart",
      "type": "atomic",
      "entry_actions": [
        "readInputFunction()",
        "highlightInputField()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingFunction",
      "label": "ValidatingFunction",
      "type": "atomic",
      "entry_actions": [
        "validateFunctionSyntax()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ComparingFunctions",
      "label": "ComparingFunctions",
      "type": "atomic",
      "entry_actions": [
        "compareWithOmega()",
        "showComparisonResult()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearInputField()",
        "resetInterface()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsFunction",
      "event_type": "user_action",
      "description": "User inputs a function for analysis"
    },
    {
      "id": "UserClicksValidate",
      "event_type": "user_action",
      "description": "User clicks the Validate button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "FunctionValidationComplete",
      "event_type": "system_event",
      "description": "Function validation completes successfully"
    },
    {
      "id": "FunctionValidationFailed",
      "event_type": "system_event",
      "description": "Function validation fails"
    },
    {
      "id": "ComparisonComplete",
      "event_type": "system_event",
      "description": "Function comparison with Big-Omega complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputStart",
      "event": "UserInputsFunction",
      "guard": "inputNotEmpty",
      "actions": [
        "captureFunctionInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputFunction",
        "dom:inputFieldFocused"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputStart",
      "to": "S2_ValidatingFunction",
      "event": "UserClicksValidate",
      "guard": "inputIsValid",
      "actions": [
        "validateFunction()",
        "prepareComparison()"
      ],
      "expected_observables": [
        "dom:functionValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingFunction",
      "to": "S4_ComparingFunctions",
      "event": "FunctionValidationComplete",
      "guard": "validFunction",
      "actions": [
        "beginComparison()",
        "displayComparison()"
      ],
      "expected_observables": [
        "dom:comparisonStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputStart",
      "to": "S3_ErrorAlert",
      "event": "FunctionValidationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ComparingFunctions",
      "to": "S0_Idle",
      "event": "ComparisonComplete",
      "guard": "comparisonSuccessful",
      "actions": [
        "enableControls()",
        "clearInputField()"
      ],
      "expected_observables": [
        "dom:comparisonResultDisplayed"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "inputFieldNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ComparisonComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInterface()"
      ],
      "expected_observables": [
        "dom:interfaceReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "validate",
    "reset",
    "comparison_visualization"
  ]
}