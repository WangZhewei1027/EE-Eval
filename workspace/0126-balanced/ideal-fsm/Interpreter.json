{
  "meta": {
    "concept": "Interpreter",
    "topic": "Programming Language Interpreter",
    "educational_goal": "Demonstrate how an interpreter processes code",
    "expected_interactions": [
      "loadCode",
      "execute",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInterface()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_LoadingCode",
      "label": "LoadingCode",
      "type": "atomic",
      "entry_actions": [
        "readCodeInput()",
        "highlightCodeInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingCode",
      "label": "ValidatingCode",
      "type": "atomic",
      "entry_actions": [
        "validateCode()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ExecutingCode",
      "label": "ExecutingCode",
      "type": "atomic",
      "entry_actions": [
        "interpretCode()",
        "showExecutionProgress()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ExecutionComplete",
      "label": "ExecutionComplete",
      "type": "atomic",
      "entry_actions": [
        "displayOutput()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_ResettingInterpreter",
      "label": "ResettingInterpreter",
      "type": "atomic",
      "entry_actions": [
        "clearCodeInput()",
        "resetOutput()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksLoadCode",
      "event_type": "user_action",
      "description": "User clicks the Load Code button"
    },
    {
      "id": "UserEntersCode",
      "event_type": "user_action",
      "description": "User enters code in input field"
    },
    {
      "id": "UserClicksExecute",
      "event_type": "user_action",
      "description": "User clicks the Execute button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CodeValidationComplete",
      "event_type": "system_event",
      "description": "Code validation completes successfully"
    },
    {
      "id": "CodeValidationFailed",
      "event_type": "system_event",
      "description": "Code validation fails"
    },
    {
      "id": "ExecutionComplete",
      "event_type": "system_event",
      "description": "Code execution completes successfully"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_LoadingCode",
      "event": "UserClicksLoadCode",
      "guard": "codeNotEmpty",
      "actions": [
        "captureCodeInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:codeInputRead",
        "dom:loadCodeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_LoadingCode",
      "to": "S2_ValidatingCode",
      "event": "CodeValidationComplete",
      "guard": "codeIsValid",
      "actions": [
        "validateCodeSyntax()",
        "prepareExecution()"
      ],
      "expected_observables": [
        "dom:codeValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingCode",
      "to": "S4_ExecutingCode",
      "event": "CodeValidationComplete",
      "guard": "validSyntax",
      "actions": [
        "parseCode()",
        "beginExecution()"
      ],
      "expected_observables": [
        "dom:executionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_LoadingCode",
      "to": "S3_ErrorAlert",
      "event": "CodeValidationFailed",
      "guard": "codeIsEmpty",
      "actions": [
        "showError()",
        "focusCodeInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetCodeInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ExecutingCode",
      "to": "S5_ExecutionComplete",
      "event": "ExecutionComplete",
      "guard": "executionSuccessful",
      "actions": [
        "updateOutputDisplay()",
        "triggerCompletionVisualization()"
      ],
      "expected_observables": [
        "dom:outputDisplayed",
        "dom:executionVisualizationComplete"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_ExecutionComplete",
      "to": "S0_Idle",
      "event": "ExecutionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearCodeInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingInterpreter",
      "event": "UserClicksReset",
      "guard": "outputNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingInterpreter",
      "to": "S0_Idle",
      "event": "ExecutionComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetCodeInputField()"
      ],
      "expected_observables": [
        "dom:outputCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "code_input",
    "load_code",
    "execute",
    "reset",
    "output_display"
  ]
}