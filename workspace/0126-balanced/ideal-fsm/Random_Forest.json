{
  "meta": {
    "concept": "RandomForest",
    "topic": "Random Forest Visualization",
    "educational_goal": "Demonstrate Random Forest training and prediction",
    "expected_interactions": [
      "train",
      "predict",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderForest()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_TrainingStart",
      "label": "TrainingStart",
      "type": "atomic",
      "entry_actions": [
        "readTrainingData()",
        "highlightTrainingInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingTrainingData",
      "label": "ValidatingTrainingData",
      "type": "atomic",
      "entry_actions": [
        "validateTrainingData()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_TrainingForest",
      "label": "TrainingForest",
      "type": "atomic",
      "entry_actions": [
        "initializeForest()",
        "trainTrees()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingForest",
      "label": "DrawingForest",
      "type": "atomic",
      "entry_actions": [
        "updateForestVisualization()",
        "animateTraining()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ForestResetting",
      "label": "ForestResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllTrees()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksTrain",
      "event_type": "user_action",
      "description": "User clicks the Train button"
    },
    {
      "id": "UserEntersTrainingData",
      "event_type": "user_action",
      "description": "User enters training data"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "TrainingDataValidationComplete",
      "event_type": "system_event",
      "description": "Training data validation completes successfully"
    },
    {
      "id": "TrainingDataValidationFailed",
      "event_type": "system_event",
      "description": "Training data validation fails"
    },
    {
      "id": "ForestTrainingComplete",
      "event_type": "system_event",
      "description": "Forest training and update complete"
    },
    {
      "id": "ForestResetComplete",
      "event_type": "system_event",
      "description": "Forest reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_TrainingStart",
      "event": "UserClicksTrain",
      "guard": "trainingDataNotEmpty",
      "actions": [
        "captureTrainingData()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readTrainingData",
        "dom:trainButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_TrainingStart",
      "to": "S2_ValidatingTrainingData",
      "event": "TrainingDataValidationComplete",
      "guard": "trainingDataIsValid",
      "actions": [
        "validateTrainingData()",
        "prepareTraining()"
      ],
      "expected_observables": [
        "dom:trainingDataValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingTrainingData",
      "to": "S4_TrainingForest",
      "event": "TrainingDataValidationComplete",
      "guard": "validData",
      "actions": [
        "parseTrainingData()",
        "beginTraining()"
      ],
      "expected_observables": [
        "dom:forestTrainingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_TrainingStart",
      "to": "S3_ErrorAlert",
      "event": "TrainingDataValidationFailed",
      "guard": "trainingDataIsEmpty",
      "actions": [
        "showError()",
        "focusTrainingInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetTrainingInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_TrainingForest",
      "to": "S5_DrawingForest",
      "event": "ForestTrainingComplete",
      "guard": "forestTrainedSuccessfully",
      "actions": [
        "updateForestStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:forestStructureChanged",
        "dom:newTreesVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingForest",
      "to": "S0_Idle",
      "event": "ForestTrainingComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearTrainingInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ForestResetting",
      "event": "UserClicksReset",
      "guard": "forestNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ForestResetting",
      "to": "S0_Idle",
      "event": "ForestResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetTrainingInputField()"
      ],
      "expected_observables": [
        "dom:forestCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "train",
    "reset",
    "forest_visualization"
  ]
}