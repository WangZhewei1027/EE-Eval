{
  "meta": {
    "concept": "Dynamic Typing",
    "topic": "Dynamic Typing in Programming Languages",
    "educational_goal": "Illustrate how dynamic typing works and its implications",
    "expected_interactions": [
      "assign",
      "changeType",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderVariable()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AssignStart",
      "label": "AssignStart",
      "type": "atomic",
      "entry_actions": [
        "readInputValue()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AssigningValue",
      "label": "AssigningValue",
      "type": "atomic",
      "entry_actions": [
        "assignValueToVariable()",
        "updateVariableType()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_UpdatingVisualization",
      "label": "UpdatingVisualization",
      "type": "atomic",
      "entry_actions": [
        "updateVariableVisualization()",
        "animateTypeChange()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingVariable",
      "label": "ResettingVariable",
      "type": "atomic",
      "entry_actions": [
        "clearVariable()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAssign",
      "event_type": "user_action",
      "description": "User clicks the Assign button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters value in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "ValueAssignmentComplete",
      "event_type": "system_event",
      "description": "Value assignment and type update complete"
    },
    {
      "id": "VariableResetComplete",
      "event_type": "system_event",
      "description": "Variable reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AssignStart",
      "event": "UserClicksAssign",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValue",
        "dom:assignButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AssignStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateValue()",
        "prepareAssignment()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_AssigningValue",
      "event": "InputValidationComplete",
      "guard": "validInput",
      "actions": [
        "parseInputValue()",
        "beginAssignment()"
      ],
      "expected_observables": [
        "dom:valueAssignmentStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AssignStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AssigningValue",
      "to": "S5_UpdatingVisualization",
      "event": "ValueAssignmentComplete",
      "guard": "valueAssignedSuccessfully",
      "actions": [
        "updateVariableStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:variableStructureChanged",
        "dom:newValueVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_UpdatingVisualization",
      "to": "S0_Idle",
      "event": "ValueAssignmentComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingVariable",
      "event": "UserClicksReset",
      "guard": "variableNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingVariable",
      "to": "S0_Idle",
      "event": "VariableResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:variableCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "assign",
    "reset",
    "variable_visualization"
  ]
}