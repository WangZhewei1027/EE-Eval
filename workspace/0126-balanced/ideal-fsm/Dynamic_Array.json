{
  "meta": {
    "concept": "Dynamic Array",
    "topic": "Dynamic Array Operations",
    "educational_goal": "Demonstrate dynamic array resizing and element manipulation",
    "expected_interactions": [
      "add",
      "remove",
      "resize",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddStart",
      "label": "AddStart",
      "type": "atomic",
      "entry_actions": [
        "readInputValue()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AddingElement",
      "label": "AddingElement",
      "type": "atomic",
      "entry_actions": [
        "checkCapacity()",
        "appendElement()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ResizingArray",
      "label": "ResizingArray",
      "type": "atomic",
      "entry_actions": [
        "doubleCapacity()",
        "updateVisualization()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ArrayResetting",
      "label": "ArrayResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllElements()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAdd",
      "event_type": "user_action",
      "description": "User clicks the Add button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters value in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "ElementAdditionComplete",
      "event_type": "system_event",
      "description": "Element addition and array update complete"
    },
    {
      "id": "ArrayResizeComplete",
      "event_type": "system_event",
      "description": "Array resize operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddStart",
      "event": "UserClicksAdd",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValue",
        "dom:addButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateValue()",
        "prepareAddition()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_AddingElement",
      "event": "InputValidationComplete",
      "guard": "validElement",
      "actions": [
        "parseInputValue()",
        "beginAddition()"
      ],
      "expected_observables": [
        "dom:elementAdditionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AddStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AddingElement",
      "to": "S5_ResizingArray",
      "event": "ElementAdditionComplete",
      "guard": "capacityExceeded",
      "actions": [
        "resizeArray()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:arrayResized",
        "dom:newElementVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_ResizingArray",
      "to": "S0_Idle",
      "event": "ArrayResizeComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ArrayResetting",
      "event": "UserClicksReset",
      "guard": "arrayNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ArrayResetting",
      "to": "S0_Idle",
      "event": "ArrayResizeComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:arrayCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "add",
    "reset",
    "array_visualization"
  ]
}