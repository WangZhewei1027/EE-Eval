{
  "meta": {
    "concept": "GreedyAlgorithms",
    "topic": "Greedy Algorithm Visualization",
    "educational_goal": "Illustrate the process of greedy choice and solution construction",
    "expected_interactions": [
      "select",
      "validate",
      "construct",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderProblem()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SelectingChoice",
      "label": "SelectingChoice",
      "type": "atomic",
      "entry_actions": [
        "highlightChoices()",
        "captureUserSelection()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingChoice",
      "label": "ValidatingChoice",
      "type": "atomic",
      "entry_actions": [
        "validateSelection()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ConstructingSolution",
      "label": "ConstructingSolution",
      "type": "atomic",
      "entry_actions": [
        "applyGreedyChoice()",
        "updateSolutionVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_SolutionComplete",
      "label": "SolutionComplete",
      "type": "atomic",
      "entry_actions": [
        "displayFinalSolution()",
        "animateCompletion()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingProblem",
      "label": "ResettingProblem",
      "type": "atomic",
      "entry_actions": [
        "clearSolution()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsChoice",
      "event_type": "user_action",
      "description": "User selects a choice from available options"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ChoiceValidationComplete",
      "event_type": "system_event",
      "description": "Choice validation completes successfully"
    },
    {
      "id": "ChoiceValidationFailed",
      "event_type": "system_event",
      "description": "Choice validation fails"
    },
    {
      "id": "SolutionConstructionComplete",
      "event_type": "system_event",
      "description": "Solution construction and visualization complete"
    },
    {
      "id": "ProblemResetComplete",
      "event_type": "system_event",
      "description": "Problem reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SelectingChoice",
      "event": "UserSelectsChoice",
      "guard": "choiceAvailable",
      "actions": [
        "captureSelection()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:choiceSelected"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SelectingChoice",
      "to": "S2_ValidatingChoice",
      "event": "ChoiceValidationComplete",
      "guard": "selectionIsValid",
      "actions": [
        "validateChoice()",
        "prepareConstruction()"
      ],
      "expected_observables": [
        "dom:choiceValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingChoice",
      "to": "S4_ConstructingSolution",
      "event": "ChoiceValidationComplete",
      "guard": "validChoice",
      "actions": [
        "applyChoice()",
        "beginConstruction()"
      ],
      "expected_observables": [
        "dom:solutionConstructionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_SelectingChoice",
      "to": "S3_ErrorAlert",
      "event": "ChoiceValidationFailed",
      "guard": "selectionIsInvalid",
      "actions": [
        "showError()",
        "focusSelection()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetSelection()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ConstructingSolution",
      "to": "S5_SolutionComplete",
      "event": "SolutionConstructionComplete",
      "guard": "solutionConstructedSuccessfully",
      "actions": [
        "updateSolutionStructure()",
        "triggerCompletionAnimation()"
      ],
      "expected_observables": [
        "dom:solutionStructureUpdated",
        "dom:finalSolutionVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_SolutionComplete",
      "to": "S0_Idle",
      "event": "SolutionConstructionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearSelection()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingProblem",
      "event": "UserClicksReset",
      "guard": "solutionNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingProblem",
      "to": "S0_Idle",
      "event": "ProblemResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetSelectionField()"
      ],
      "expected_observables": [
        "dom:problemCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "choice_selector",
    "validate",
    "reset",
    "solution_visualization"
  ]
}