{
  "meta": {
    "concept": "Process",
    "topic": "Process Management Visualization",
    "educational_goal": "Demonstrate process creation and termination",
    "expected_interactions": [
      "create",
      "terminate",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderProcessList()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_CreateStart",
      "label": "CreateStart",
      "type": "atomic",
      "entry_actions": [
        "readInputValue()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_CreatingProcess",
      "label": "CreatingProcess",
      "type": "atomic",
      "entry_actions": [
        "allocateResources()",
        "createNewProcess()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_UpdatingProcessList",
      "label": "UpdatingProcessList",
      "type": "atomic",
      "entry_actions": [
        "updateProcessVisualization()",
        "animateCreation()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ProcessResetting",
      "label": "ProcessResetting",
      "type": "atomic",
      "entry_actions": [
        "terminateAllProcesses()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCreate",
      "event_type": "user_action",
      "description": "User clicks the Create button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters process name in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "ProcessCreationComplete",
      "event_type": "system_event",
      "description": "Process creation and list update complete"
    },
    {
      "id": "ProcessResetComplete",
      "event_type": "system_event",
      "description": "Process reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_CreateStart",
      "event": "UserClicksCreate",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValue",
        "dom:createButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_CreateStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateValue()",
        "prepareCreation()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_CreatingProcess",
      "event": "InputValidationComplete",
      "guard": "validName",
      "actions": [
        "parseInputValue()",
        "beginCreation()"
      ],
      "expected_observables": [
        "dom:processCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_CreateStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_CreatingProcess",
      "to": "S5_UpdatingProcessList",
      "event": "ProcessCreationComplete",
      "guard": "processCreatedSuccessfully",
      "actions": [
        "updateProcessStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:processListChanged",
        "dom:newProcessVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_UpdatingProcessList",
      "to": "S0_Idle",
      "event": "ProcessCreationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ProcessResetting",
      "event": "UserClicksReset",
      "guard": "processListNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ProcessResetting",
      "to": "S0_Idle",
      "event": "ProcessResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:processListCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "create",
    "reset",
    "process_visualization"
  ]
}