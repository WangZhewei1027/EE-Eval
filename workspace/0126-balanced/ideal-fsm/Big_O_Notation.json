{
  "meta": {
    "concept": "Big-O Notation",
    "topic": "Algorithm Complexity Analysis",
    "educational_goal": "Teach the basics of Big-O notation and its application in analyzing algorithm efficiency",
    "expected_interactions": [
      "input_function",
      "analyze",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderUI()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputFunction",
      "label": "InputFunction",
      "type": "atomic",
      "entry_actions": [
        "highlightInputField()",
        "captureFunctionInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Analyzing",
      "label": "Analyzing",
      "type": "atomic",
      "entry_actions": [
        "analyzeFunction()",
        "showAnalysisFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AnalysisComplete",
      "label": "AnalysisComplete",
      "type": "atomic",
      "entry_actions": [
        "displayBigONotation()",
        "highlightResult()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllInputs()",
        "resetUI()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsFunction",
      "event_type": "user_action",
      "description": "User inputs a function to analyze"
    },
    {
      "id": "UserClicksAnalyze",
      "event_type": "user_action",
      "description": "User clicks the Analyze button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "FunctionAnalysisComplete",
      "event_type": "system_event",
      "description": "Function analysis completes successfully"
    },
    {
      "id": "FunctionAnalysisFailed",
      "event_type": "system_event",
      "description": "Function analysis fails"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputFunction",
      "event": "UserInputsFunction",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:functionInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputFunction",
      "to": "S2_Analyzing",
      "event": "UserClicksAnalyze",
      "guard": "inputIsValid",
      "actions": [
        "validateFunction()",
        "beginAnalysis()"
      ],
      "expected_observables": [
        "dom:analysisStarted"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Analyzing",
      "to": "S4_AnalysisComplete",
      "event": "FunctionAnalysisComplete",
      "guard": "analysisSuccessful",
      "actions": [
        "displayResult()",
        "highlightBigO()"
      ],
      "expected_observables": [
        "dom:bigONotationDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputFunction",
      "to": "S3_ErrorAlert",
      "event": "FunctionAnalysisFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AnalysisComplete",
      "to": "S0_Idle",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "clearResult()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:resultCleared"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetUI()"
      ],
      "expected_observables": [
        "dom:uiReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "analyze",
    "reset",
    "result_display"
  ]
}