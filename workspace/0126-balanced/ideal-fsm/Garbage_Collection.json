{
  "meta": {
    "concept": "Garbage Collection",
    "topic": "Memory Management",
    "educational_goal": "Demonstrate garbage collection process and effects",
    "expected_interactions": [
      "allocate",
      "deallocate",
      "trigger_gc",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderMemoryState()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AllocatingMemory",
      "label": "AllocatingMemory",
      "type": "atomic",
      "entry_actions": [
        "readAllocationRequest()",
        "highlightAllocationInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_DeallocatingMemory",
      "label": "DeallocatingMemory",
      "type": "atomic",
      "entry_actions": [
        "readDeallocationRequest()",
        "highlightDeallocationInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_TriggeringGC",
      "label": "TriggeringGC",
      "type": "atomic",
      "entry_actions": [
        "initiateGarbageCollection()",
        "showGCAnimation()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearMemoryState()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAllocate",
      "event_type": "user_action",
      "description": "User clicks the Allocate button"
    },
    {
      "id": "UserClicksDeallocate",
      "event_type": "user_action",
      "description": "User clicks the Deallocate button"
    },
    {
      "id": "UserClicksTriggerGC",
      "event_type": "user_action",
      "description": "User clicks the Trigger GC button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "AllocationComplete",
      "event_type": "system_event",
      "description": "Memory allocation completes successfully"
    },
    {
      "id": "DeallocationComplete",
      "event_type": "system_event",
      "description": "Memory deallocation completes successfully"
    },
    {
      "id": "GCComplete",
      "event_type": "system_event",
      "description": "Garbage collection process completes"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Memory reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AllocatingMemory",
      "event": "UserClicksAllocate",
      "guard": "inputNotEmpty",
      "actions": [
        "captureAllocationInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:allocationInputRead",
        "dom:allocateButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AllocatingMemory",
      "to": "S0_Idle",
      "event": "AllocationComplete",
      "guard": "allocationSuccessful",
      "actions": [
        "updateMemoryState()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:memoryStateUpdated"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S2_DeallocatingMemory",
      "event": "UserClicksDeallocate",
      "guard": "inputNotEmpty",
      "actions": [
        "captureDeallocationInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:deallocationInputRead",
        "dom:deallocateButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S2_DeallocatingMemory",
      "to": "S0_Idle",
      "event": "DeallocationComplete",
      "guard": "deallocationSuccessful",
      "actions": [
        "updateMemoryState()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:memoryStateUpdated"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S3_TriggeringGC",
      "event": "UserClicksTriggerGC",
      "guard": "memoryNotEmpty",
      "actions": [
        "confirmGC()",
        "beginGCOperation()"
      ],
      "expected_observables": [
        "dom:gcButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S3_TriggeringGC",
      "to": "S0_Idle",
      "event": "GCComplete",
      "guard": "gcSuccessful",
      "actions": [
        "updateMemoryState()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:gcCompleted",
        "dom:memoryStateUpdated"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "memoryNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:memoryCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_AllocatingMemory",
      "to": "S4_ErrorAlert",
      "event": "AllocationComplete",
      "guard": "allocationFailed",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_DeallocatingMemory",
      "to": "S4_ErrorAlert",
      "event": "DeallocationComplete",
      "guard": "deallocationFailed",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    }
  ],
  "components": [
    "input",
    "allocate",
    "deallocate",
    "trigger_gc",
    "reset",
    "memory_visualization"
  ]
}