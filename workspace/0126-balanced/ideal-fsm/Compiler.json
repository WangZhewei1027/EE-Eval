{
  "meta": {
    "concept": "Compiler",
    "topic": "Compiler Process Visualization",
    "educational_goal": "Demonstrate the stages of compilation",
    "expected_interactions": [
      "input_code",
      "compile",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderCompilerStages()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputCode",
      "label": "InputCode",
      "type": "atomic",
      "entry_actions": [
        "readCodeInput()",
        "highlightInputField()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingCode",
      "label": "ValidatingCode",
      "type": "atomic",
      "entry_actions": [
        "validateCodeSyntax()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_CompilingCode",
      "label": "CompilingCode",
      "type": "atomic",
      "entry_actions": [
        "startCompilationProcess()",
        "showCompilationProgress()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_CompilationComplete",
      "label": "CompilationComplete",
      "type": "atomic",
      "entry_actions": [
        "displayCompiledOutput()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_ResettingCompiler",
      "label": "ResettingCompiler",
      "type": "atomic",
      "entry_actions": [
        "clearCodeInput()",
        "resetCompilerStages()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCompile",
      "event_type": "user_action",
      "description": "User clicks the Compile button"
    },
    {
      "id": "UserEntersCode",
      "event_type": "user_action",
      "description": "User enters code in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CodeValidationComplete",
      "event_type": "system_event",
      "description": "Code validation completes successfully"
    },
    {
      "id": "CodeValidationFailed",
      "event_type": "system_event",
      "description": "Code validation fails"
    },
    {
      "id": "CompilationProcessComplete",
      "event_type": "system_event",
      "description": "Compilation process completes successfully"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputCode",
      "event": "UserEntersCode",
      "guard": "codeNotEmpty",
      "actions": [
        "captureCodeInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:codeInputCaptured",
        "dom:compileButtonEnabled"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputCode",
      "to": "S2_ValidatingCode",
      "event": "CodeValidationComplete",
      "guard": "codeIsValid",
      "actions": [
        "validateCode()",
        "prepareCompilation()"
      ],
      "expected_observables": [
        "dom:codeValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingCode",
      "to": "S4_CompilingCode",
      "event": "CodeValidationComplete",
      "guard": "validSyntax",
      "actions": [
        "parseCodeInput()",
        "beginCompilation()"
      ],
      "expected_observables": [
        "dom:compilationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputCode",
      "to": "S3_ErrorAlert",
      "event": "CodeValidationFailed",
      "guard": "codeIsInvalid",
      "actions": [
        "showError()",
        "focusInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_CompilingCode",
      "to": "S5_CompilationComplete",
      "event": "CompilationProcessComplete",
      "guard": "compilationSuccessful",
      "actions": [
        "updateCompiledOutput()",
        "triggerOutputDisplay()"
      ],
      "expected_observables": [
        "dom:compiledOutputVisible",
        "dom:compilationProgressComplete"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_CompilationComplete",
      "to": "S0_Idle",
      "event": "CompilationProcessComplete",
      "guard": "outputDisplayed",
      "actions": [
        "enableControls()",
        "clearCodeInput()"
      ],
      "expected_observables": [
        "dom:outputDisplayComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingCompiler",
      "event": "UserClicksReset",
      "guard": "codeNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingCompiler",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:compilerReset",
        "dom:stagesCleared"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "code_input",
    "compile",
    "reset",
    "compiler_visualization"
  ]
}