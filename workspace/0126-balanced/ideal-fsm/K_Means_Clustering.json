{
  "meta": {
    "concept": "K-Means Clustering",
    "topic": "K-Means Clustering Visualization",
    "educational_goal": "Demonstrate K-Means clustering process",
    "expected_interactions": [
      "set_parameters",
      "initialize",
      "iterate",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderClusters()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SetParameters",
      "label": "SetParameters",
      "type": "atomic",
      "entry_actions": [
        "readInputValues()",
        "highlightInputFields()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Initializing",
      "label": "Initializing",
      "type": "atomic",
      "entry_actions": [
        "initializeCentroids()",
        "showInitializationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_Iterating",
      "label": "Iterating",
      "type": "atomic",
      "entry_actions": [
        "assignClusters()",
        "updateCentroids()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingClusters",
      "label": "DrawingClusters",
      "type": "atomic",
      "entry_actions": [
        "updateClusterVisualization()",
        "animateIteration()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllClusters()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInitialize",
      "event_type": "user_action",
      "description": "User clicks the Initialize button"
    },
    {
      "id": "UserEntersParameters",
      "event_type": "user_action",
      "description": "User enters parameters in input fields"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InitializationComplete",
      "event_type": "system_event",
      "description": "Initialization completes successfully"
    },
    {
      "id": "InitializationFailed",
      "event_type": "system_event",
      "description": "Initialization fails"
    },
    {
      "id": "IterationComplete",
      "event_type": "system_event",
      "description": "Iteration and cluster update complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SetParameters",
      "event": "UserClicksInitialize",
      "guard": "parametersNotEmpty",
      "actions": [
        "captureParameters()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValues",
        "dom:initializeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SetParameters",
      "to": "S2_Initializing",
      "event": "InitializationComplete",
      "guard": "parametersAreValid",
      "actions": [
        "validateParameters()",
        "prepareInitialization()"
      ],
      "expected_observables": [
        "dom:parametersValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Initializing",
      "to": "S4_Iterating",
      "event": "InitializationComplete",
      "guard": "initializationSuccessful",
      "actions": [
        "startIteration()",
        "beginClusterAssignment()"
      ],
      "expected_observables": [
        "dom:iterationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_SetParameters",
      "to": "S3_ErrorAlert",
      "event": "InitializationFailed",
      "guard": "parametersInvalid",
      "actions": [
        "showError()",
        "focusInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Iterating",
      "to": "S5_DrawingClusters",
      "event": "IterationComplete",
      "guard": "clustersUpdatedSuccessfully",
      "actions": [
        "updateClusterStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:clusterStructureChanged",
        "dom:clustersVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingClusters",
      "to": "S0_Idle",
      "event": "IterationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInputFields()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "clustersNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:clustersCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "initialize",
    "reset",
    "cluster_visualization"
  ]
}