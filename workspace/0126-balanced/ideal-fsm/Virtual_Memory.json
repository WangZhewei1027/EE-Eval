{
  "meta": {
    "concept": "VirtualMemory",
    "topic": "Virtual Memory Management",
    "educational_goal": "Demonstrate virtual memory allocation and paging",
    "expected_interactions": [
      "allocate",
      "deallocate",
      "access",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderMemoryMap()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AllocateStart",
      "label": "AllocateStart",
      "type": "atomic",
      "entry_actions": [
        "readAllocationInput()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingAllocation",
      "label": "ValidatingAllocation",
      "type": "atomic",
      "entry_actions": [
        "validateAllocationInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AllocatingMemory",
      "label": "AllocatingMemory",
      "type": "atomic",
      "entry_actions": [
        "findAllocationSpace()",
        "allocateMemoryBlock()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_UpdatingMemoryMap",
      "label": "UpdatingMemoryMap",
      "type": "atomic",
      "entry_actions": [
        "updateMemoryVisualization()",
        "animateAllocation()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_MemoryResetting",
      "label": "MemoryResetting",
      "type": "atomic",
      "entry_actions": [
        "clearMemoryBlocks()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAllocate",
      "event_type": "user_action",
      "description": "User clicks the Allocate button"
    },
    {
      "id": "UserEntersAllocationInput",
      "event_type": "user_action",
      "description": "User enters allocation size in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "AllocationValidationComplete",
      "event_type": "system_event",
      "description": "Allocation input validation completes successfully"
    },
    {
      "id": "AllocationValidationFailed",
      "event_type": "system_event",
      "description": "Allocation input validation fails"
    },
    {
      "id": "MemoryAllocationComplete",
      "event_type": "system_event",
      "description": "Memory allocation and map update complete"
    },
    {
      "id": "MemoryResetComplete",
      "event_type": "system_event",
      "description": "Memory reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AllocateStart",
      "event": "UserClicksAllocate",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readAllocationInput",
        "dom:allocateButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AllocateStart",
      "to": "S2_ValidatingAllocation",
      "event": "AllocationValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateAllocationSize()",
        "prepareAllocation()"
      ],
      "expected_observables": [
        "dom:allocationInputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingAllocation",
      "to": "S4_AllocatingMemory",
      "event": "AllocationValidationComplete",
      "guard": "validSize",
      "actions": [
        "parseAllocationInput()",
        "beginAllocation()"
      ],
      "expected_observables": [
        "dom:memoryBlockCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AllocateStart",
      "to": "S3_ErrorAlert",
      "event": "AllocationValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AllocatingMemory",
      "to": "S5_UpdatingMemoryMap",
      "event": "MemoryAllocationComplete",
      "guard": "memoryAllocatedSuccessfully",
      "actions": [
        "updateMemoryStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:memoryStructureChanged",
        "dom:newMemoryBlockVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_UpdatingMemoryMap",
      "to": "S0_Idle",
      "event": "MemoryAllocationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_MemoryResetting",
      "event": "UserClicksReset",
      "guard": "memoryNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_MemoryResetting",
      "to": "S0_Idle",
      "event": "MemoryResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:memoryCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "allocate",
    "reset",
    "memory_visualization"
  ]
}