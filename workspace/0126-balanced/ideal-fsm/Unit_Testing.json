{
  "meta": {
    "concept": "UnitTesting",
    "topic": "Unit Testing Framework",
    "educational_goal": "Demonstrate writing and executing unit tests",
    "expected_interactions": [
      "writeTest",
      "runTest",
      "viewResults",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderEditor()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_WritingTest",
      "label": "WritingTest",
      "type": "atomic",
      "entry_actions": [
        "highlightEditor()",
        "captureTestInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_RunningTest",
      "label": "RunningTest",
      "type": "atomic",
      "entry_actions": [
        "executeTestSuite()",
        "showRunningIndicator()"
      ],
      "exit_actions": [
        "hideRunningIndicator()"
      ]
    },
    {
      "id": "S3_ViewingResults",
      "label": "ViewingResults",
      "type": "atomic",
      "entry_actions": [
        "displayTestResults()",
        "highlightResults()"
      ],
      "exit_actions": [
        "clearResultsHighlight()"
      ]
    },
    {
      "id": "S4_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearEditor()",
        "resetTestEnvironment()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserWritesTest",
      "event_type": "user_action",
      "description": "User writes a test in the editor"
    },
    {
      "id": "UserClicksRun",
      "event_type": "user_action",
      "description": "User clicks the Run Test button"
    },
    {
      "id": "TestExecutionComplete",
      "event_type": "system_event",
      "description": "Test execution completes"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    },
    {
      "id": "TestExecutionFailed",
      "event_type": "system_event",
      "description": "Test execution fails"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_WritingTest",
      "event": "UserWritesTest",
      "guard": "editorIsEmpty",
      "actions": [
        "captureTestInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:editorHighlighted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_WritingTest",
      "to": "S2_RunningTest",
      "event": "UserClicksRun",
      "guard": "testIsValid",
      "actions": [
        "validateTest()",
        "startTestExecution()"
      ],
      "expected_observables": [
        "dom:runButtonClicked"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_RunningTest",
      "to": "S3_ViewingResults",
      "event": "TestExecutionComplete",
      "guard": "executionSuccessful",
      "actions": [
        "showResults()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:resultsDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_RunningTest",
      "to": "S4_ErrorAlert",
      "event": "TestExecutionFailed",
      "guard": "executionFailed",
      "actions": [
        "showError()",
        "focusEditor()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetEditor()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "editorNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "TestExecutionComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetEditorField()"
      ],
      "expected_observables": [
        "dom:editorCleared",
        "dom:environmentReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "editor",
    "run",
    "reset",
    "results_display"
  ]
}