{
  "meta": {
    "concept": "K-Nearest Neighbors",
    "topic": "K-Nearest Neighbors Algorithm Visualization",
    "educational_goal": "Demonstrate KNN classification and visualization",
    "expected_interactions": [
      "set_k",
      "add_point",
      "classify",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderVisualization()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SetK",
      "label": "SetK",
      "type": "atomic",
      "entry_actions": [
        "readKValue()",
        "highlightKInput()"
      ],
      "exit_actions": [
        "clearKHighlight()"
      ]
    },
    {
      "id": "S2_AddingPoint",
      "label": "AddingPoint",
      "type": "atomic",
      "entry_actions": [
        "capturePointCoordinates()",
        "highlightPointInput()"
      ],
      "exit_actions": [
        "clearPointHighlight()"
      ]
    },
    {
      "id": "S3_Classifying",
      "label": "Classifying",
      "type": "atomic",
      "entry_actions": [
        "computeDistances()",
        "identifyNeighbors()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_DrawingResult",
      "label": "DrawingResult",
      "type": "atomic",
      "entry_actions": [
        "updateVisualization()",
        "animateClassification()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllPoints()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSetsK",
      "event_type": "user_action",
      "description": "User sets the value of K"
    },
    {
      "id": "UserAddsPoint",
      "event_type": "user_action",
      "description": "User adds a new data point"
    },
    {
      "id": "UserClicksClassify",
      "event_type": "user_action",
      "description": "User clicks the Classify button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ClassificationComplete",
      "event_type": "system_event",
      "description": "Classification and visualization update complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SetK",
      "event": "UserSetsK",
      "guard": "kValueValid",
      "actions": [
        "captureKValue()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:kValueCaptured"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S2_AddingPoint",
      "event": "UserAddsPoint",
      "guard": "pointCoordinatesValid",
      "actions": [
        "capturePointData()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:pointAdded"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_AddingPoint",
      "to": "S0_Idle",
      "event": "UserClicksClassify",
      "guard": "true",
      "actions": [
        "prepareClassification()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:classificationPrepared"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S3_Classifying",
      "event": "UserClicksClassify",
      "guard": "dataPointsExist",
      "actions": [
        "startClassification()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:classificationStarted"
      ],
      "timeout": 2000
    },
    {
      "from": "S3_Classifying",
      "to": "S4_DrawingResult",
      "event": "ClassificationComplete",
      "guard": "classificationSuccessful",
      "actions": [
        "updateResultVisualization()",
        "triggerResultAnimation()"
      ],
      "expected_observables": [
        "dom:resultVisualized"
      ],
      "timeout": 3000
    },
    {
      "from": "S4_DrawingResult",
      "to": "S0_Idle",
      "event": "ClassificationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInputs()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "dataPointsExist",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetInitiated"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:resetComplete"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input_k",
    "add_point",
    "classify",
    "reset",
    "visualization_area"
  ]
}