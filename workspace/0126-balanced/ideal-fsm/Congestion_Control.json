{
  "meta": {
    "concept": "CongestionControl",
    "topic": "Network Congestion Control Mechanisms",
    "educational_goal": "Illustrate congestion detection and control strategies",
    "expected_interactions": [
      "detect",
      "adjust",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderNetworkStatus()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_DetectingCongestion",
      "label": "DetectingCongestion",
      "type": "atomic",
      "entry_actions": [
        "monitorNetworkTraffic()",
        "highlightDetectionProcess()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_CongestionDetected",
      "label": "CongestionDetected",
      "type": "atomic",
      "entry_actions": [
        "showCongestionAlert()",
        "highlightAlert()"
      ],
      "exit_actions": [
        "clearAlert()"
      ]
    },
    {
      "id": "S3_AdjustingFlow",
      "label": "AdjustingFlow",
      "type": "atomic",
      "entry_actions": [
        "calculateAdjustment()",
        "applyFlowControl()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_VisualizingAdjustment",
      "label": "VisualizingAdjustment",
      "type": "atomic",
      "entry_actions": [
        "updateNetworkVisualization()",
        "animateAdjustment()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_ResettingNetwork",
      "label": "ResettingNetwork",
      "type": "atomic",
      "entry_actions": [
        "clearNetworkData()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksDetect",
      "event_type": "user_action",
      "description": "User clicks the Detect button"
    },
    {
      "id": "CongestionDetected",
      "event_type": "system_event",
      "description": "Congestion is detected in the network"
    },
    {
      "id": "UserClicksAdjust",
      "event_type": "user_action",
      "description": "User clicks the Adjust button"
    },
    {
      "id": "AdjustmentComplete",
      "event_type": "system_event",
      "description": "Flow adjustment and network update complete"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "NetworkResetComplete",
      "event_type": "system_event",
      "description": "Network reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses congestion alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_DetectingCongestion",
      "event": "UserClicksDetect",
      "guard": "networkActive",
      "actions": [
        "startDetectionProcess()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:detectButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_DetectingCongestion",
      "to": "S2_CongestionDetected",
      "event": "CongestionDetected",
      "guard": "congestionExists",
      "actions": [
        "triggerAlert()",
        "prepareAdjustment()"
      ],
      "expected_observables": [
        "dom:congestionAlertShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_CongestionDetected",
      "to": "S3_AdjustingFlow",
      "event": "UserClicksAdjust",
      "guard": "adjustmentPossible",
      "actions": [
        "calculateNewFlow()",
        "beginAdjustment()"
      ],
      "expected_observables": [
        "dom:adjustmentStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S3_AdjustingFlow",
      "to": "S4_VisualizingAdjustment",
      "event": "AdjustmentComplete",
      "guard": "adjustmentSuccessful",
      "actions": [
        "updateNetworkStatus()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:networkStatusChanged",
        "dom:adjustmentVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S4_VisualizingAdjustment",
      "to": "S0_Idle",
      "event": "AdjustmentComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearAdjustmentData()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingNetwork",
      "event": "UserClicksReset",
      "guard": "networkNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingNetwork",
      "to": "S0_Idle",
      "event": "NetworkResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetNetworkField()"
      ],
      "expected_observables": [
        "dom:networkCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "detect",
    "adjust",
    "reset",
    "network_visualization"
  ]
}