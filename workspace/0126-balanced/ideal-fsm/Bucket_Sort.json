{
  "meta": {
    "concept": "BucketSort",
    "topic": "Bucket Sort Visualization",
    "educational_goal": "Demonstrate bucket sort algorithm",
    "expected_interactions": [
      "sort",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SortStart",
      "label": "SortStart",
      "type": "atomic",
      "entry_actions": [
        "readInputArray()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInputArray()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_DistributingToBuckets",
      "label": "DistributingToBuckets",
      "type": "atomic",
      "entry_actions": [
        "distributeElementsToBuckets()",
        "updateBucketVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_SortingBuckets",
      "label": "SortingBuckets",
      "type": "atomic",
      "entry_actions": [
        "sortEachBucket()",
        "updateBucketSortingVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_ConcatenatingBuckets",
      "label": "ConcatenatingBuckets",
      "type": "atomic",
      "entry_actions": [
        "concatenateBuckets()",
        "updateFinalArrayVisualization()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S7_ArrayResetting",
      "label": "ArrayResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllBuckets()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksSort",
      "event_type": "user_action",
      "description": "User clicks the Sort button"
    },
    {
      "id": "UserEntersArray",
      "event_type": "user_action",
      "description": "User enters array in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "BucketDistributionComplete",
      "event_type": "system_event",
      "description": "Distribution of elements to buckets complete"
    },
    {
      "id": "BucketSortingComplete",
      "event_type": "system_event",
      "description": "Sorting of individual buckets complete"
    },
    {
      "id": "ConcatenationComplete",
      "event_type": "system_event",
      "description": "Concatenation of sorted buckets complete"
    },
    {
      "id": "ArrayResetComplete",
      "event_type": "system_event",
      "description": "Array reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SortStart",
      "event": "UserClicksSort",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInputArray()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputArray",
        "dom:sortButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SortStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateArray()",
        "prepareSorting()"
      ],
      "expected_observables": [
        "dom:arrayValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_DistributingToBuckets",
      "event": "InputValidationComplete",
      "guard": "validArray",
      "actions": [
        "parseInputArray()",
        "beginDistribution()"
      ],
      "expected_observables": [
        "dom:bucketDistributionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_SortStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_DistributingToBuckets",
      "to": "S5_SortingBuckets",
      "event": "BucketDistributionComplete",
      "guard": "distributionSuccessful",
      "actions": [
        "sortBuckets()",
        "triggerBucketSortingVisualization()"
      ],
      "expected_observables": [
        "dom:bucketSortingStarted",
        "dom:bucketContentsVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_SortingBuckets",
      "to": "S6_ConcatenatingBuckets",
      "event": "BucketSortingComplete",
      "guard": "sortingComplete",
      "actions": [
        "concatenateSortedBuckets()",
        "triggerConcatenationVisualization()"
      ],
      "expected_observables": [
        "dom:concatenationStarted"
      ],
      "timeout": 2000
    },
    {
      "from": "S6_ConcatenatingBuckets",
      "to": "S0_Idle",
      "event": "ConcatenationComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S7_ArrayResetting",
      "event": "UserClicksReset",
      "guard": "arrayNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S7_ArrayResetting",
      "to": "S0_Idle",
      "event": "ArrayResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:arrayCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "sort",
    "reset",
    "bucket_visualization"
  ]
}