{
  "meta": {
    "concept": "Type System",
    "topic": "Type System Visualization",
    "educational_goal": "Demonstrate type checking and inference",
    "expected_interactions": [
      "input",
      "check",
      "infer",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderTypeSystem()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputStart",
      "label": "InputStart",
      "type": "atomic",
      "entry_actions": [
        "readInputExpression()",
        "highlightInputField()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingExpression",
      "label": "ValidatingExpression",
      "type": "atomic",
      "entry_actions": [
        "validateExpression()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_CheckingTypes",
      "label": "CheckingTypes",
      "type": "atomic",
      "entry_actions": [
        "performTypeChecking()",
        "updateTypeAnnotations()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_InferencingTypes",
      "label": "InferencingTypes",
      "type": "atomic",
      "entry_actions": [
        "performTypeInference()",
        "updateInferenceVisualization()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_SystemResetting",
      "label": "SystemResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllExpressions()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCheck",
      "event_type": "user_action",
      "description": "User clicks the Check button"
    },
    {
      "id": "UserEntersExpression",
      "event_type": "user_action",
      "description": "User enters expression in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ExpressionValidationComplete",
      "event_type": "system_event",
      "description": "Expression validation completes successfully"
    },
    {
      "id": "ExpressionValidationFailed",
      "event_type": "system_event",
      "description": "Expression validation fails"
    },
    {
      "id": "TypeCheckingComplete",
      "event_type": "system_event",
      "description": "Type checking and annotations complete"
    },
    {
      "id": "TypeInferenceComplete",
      "event_type": "system_event",
      "description": "Type inference operation complete"
    },
    {
      "id": "SystemResetComplete",
      "event_type": "system_event",
      "description": "System reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputStart",
      "event": "UserClicksCheck",
      "guard": "expressionNotEmpty",
      "actions": [
        "captureExpression()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputExpression",
        "dom:checkButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputStart",
      "to": "S2_ValidatingExpression",
      "event": "ExpressionValidationComplete",
      "guard": "expressionIsValid",
      "actions": [
        "validateExpression()",
        "prepareTypeChecking()"
      ],
      "expected_observables": [
        "dom:expressionValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingExpression",
      "to": "S4_CheckingTypes",
      "event": "ExpressionValidationComplete",
      "guard": "validExpression",
      "actions": [
        "beginTypeChecking()",
        "updateAnnotations()"
      ],
      "expected_observables": [
        "dom:typeCheckingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InputStart",
      "to": "S3_ErrorAlert",
      "event": "ExpressionValidationFailed",
      "guard": "expressionIsEmpty",
      "actions": [
        "showError()",
        "focusInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_CheckingTypes",
      "to": "S5_InferencingTypes",
      "event": "TypeCheckingComplete",
      "guard": "typesCheckedSuccessfully",
      "actions": [
        "performInference()",
        "triggerInferenceVisualization()"
      ],
      "expected_observables": [
        "dom:inferenceVisualizationUpdated",
        "dom:annotationsVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_InferencingTypes",
      "to": "S0_Idle",
      "event": "TypeInferenceComplete",
      "guard": "inferenceComplete",
      "actions": [
        "enableControls()",
        "clearInputField()"
      ],
      "expected_observables": [
        "dom:inferenceComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_SystemResetting",
      "event": "UserClicksReset",
      "guard": "systemNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_SystemResetting",
      "to": "S0_Idle",
      "event": "SystemResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:systemCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "check",
    "reset",
    "type_visualization"
  ]
}