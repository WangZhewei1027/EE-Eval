{
  "meta": {
    "concept": "Monitor",
    "topic": "Monitor Configuration and Usage",
    "educational_goal": "Teach users how to configure and use monitor settings",
    "expected_interactions": [
      "adjust_brightness",
      "change_resolution",
      "reset_settings"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderMonitorSettings()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AdjustingBrightness",
      "label": "AdjustingBrightness",
      "type": "atomic",
      "entry_actions": [
        "readBrightnessInput()",
        "highlightBrightnessControl()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ChangingResolution",
      "label": "ChangingResolution",
      "type": "atomic",
      "entry_actions": [
        "readResolutionInput()",
        "highlightResolutionControl()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ApplyingSettings",
      "label": "ApplyingSettings",
      "type": "atomic",
      "entry_actions": [
        "applyMonitorSettings()",
        "updateMonitorDisplay()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ResettingSettings",
      "label": "ResettingSettings",
      "type": "atomic",
      "entry_actions": [
        "resetMonitorSettings()",
        "updateMonitorDisplay()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserAdjustsBrightness",
      "event_type": "user_action",
      "description": "User adjusts the brightness control"
    },
    {
      "id": "UserChangesResolution",
      "event_type": "user_action",
      "description": "User changes the resolution setting"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "BrightnessAdjustmentComplete",
      "event_type": "system_event",
      "description": "Brightness adjustment completes successfully"
    },
    {
      "id": "ResolutionChangeComplete",
      "event_type": "system_event",
      "description": "Resolution change completes successfully"
    },
    {
      "id": "SettingsResetComplete",
      "event_type": "system_event",
      "description": "Settings reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AdjustingBrightness",
      "event": "UserAdjustsBrightness",
      "guard": "brightnessInputValid",
      "actions": [
        "captureBrightnessInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:brightnessControlAdjusted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AdjustingBrightness",
      "to": "S4_ApplyingSettings",
      "event": "BrightnessAdjustmentComplete",
      "guard": "brightnessAdjustmentSuccessful",
      "actions": [
        "applyBrightness()",
        "updateDisplay()"
      ],
      "expected_observables": [
        "dom:brightnessUpdated"
      ],
      "timeout": 1500
    },
    {
      "from": "S0_Idle",
      "to": "S2_ChangingResolution",
      "event": "UserChangesResolution",
      "guard": "resolutionInputValid",
      "actions": [
        "captureResolutionInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:resolutionControlChanged"
      ],
      "timeout": 2000
    },
    {
      "from": "S2_ChangingResolution",
      "to": "S4_ApplyingSettings",
      "event": "ResolutionChangeComplete",
      "guard": "resolutionChangeSuccessful",
      "actions": [
        "applyResolution()",
        "updateDisplay()"
      ],
      "expected_observables": [
        "dom:resolutionUpdated"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AdjustingBrightness",
      "to": "S3_ErrorAlert",
      "event": "BrightnessAdjustmentFailed",
      "guard": "brightnessInputInvalid",
      "actions": [
        "showError()",
        "focusBrightnessControl()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ChangingResolution",
      "to": "S3_ErrorAlert",
      "event": "ResolutionChangeFailed",
      "guard": "resolutionInputInvalid",
      "actions": [
        "showError()",
        "focusResolutionControl()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ApplyingSettings",
      "to": "S0_Idle",
      "event": "BrightnessAdjustmentComplete",
      "guard": "settingsAppliedSuccessfully",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:settingsApplied"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_ApplyingSettings",
      "to": "S0_Idle",
      "event": "ResolutionChangeComplete",
      "guard": "settingsAppliedSuccessfully",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:settingsApplied"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingSettings",
      "event": "UserClicksReset",
      "guard": "settingsNotDefault",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingSettings",
      "to": "S0_Idle",
      "event": "SettingsResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:settingsReset",
        "dom:displayReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "brightness_control",
    "resolution_control",
    "reset",
    "monitor_display"
  ]
}