{
  "meta": {
    "concept": "Static Typing",
    "topic": "Static Typing in Programming Languages",
    "educational_goal": "Understand and apply static typing principles",
    "expected_interactions": [
      "defineType",
      "assignValue",
      "checkType",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderTypeDefinitions()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_DefineTypeStart",
      "label": "DefineTypeStart",
      "type": "atomic",
      "entry_actions": [
        "readTypeInput()",
        "highlightTypeInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingType",
      "label": "ValidatingType",
      "type": "atomic",
      "entry_actions": [
        "validateTypeInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AssigningValue",
      "label": "AssigningValue",
      "type": "atomic",
      "entry_actions": [
        "readValueInput()",
        "checkTypeCompatibility()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_CheckingType",
      "label": "CheckingType",
      "type": "atomic",
      "entry_actions": [
        "verifyTypeAssignment()",
        "showTypeCheckResult()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllDefinitions()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksDefineType",
      "event_type": "user_action",
      "description": "User clicks the Define Type button"
    },
    {
      "id": "UserEntersTypeInput",
      "event_type": "user_action",
      "description": "User enters type definition in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "TypeValidationComplete",
      "event_type": "system_event",
      "description": "Type validation completes successfully"
    },
    {
      "id": "TypeValidationFailed",
      "event_type": "system_event",
      "description": "Type validation fails"
    },
    {
      "id": "ValueAssignmentComplete",
      "event_type": "system_event",
      "description": "Value assignment and type check complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_DefineTypeStart",
      "event": "UserClicksDefineType",
      "guard": "inputNotEmpty",
      "actions": [
        "captureTypeInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readTypeInputValue",
        "dom:defineTypeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_DefineTypeStart",
      "to": "S2_ValidatingType",
      "event": "TypeValidationComplete",
      "guard": "typeIsValid",
      "actions": [
        "validateTypeDefinition()",
        "prepareTypeAssignment()"
      ],
      "expected_observables": [
        "dom:typeInputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingType",
      "to": "S4_AssigningValue",
      "event": "TypeValidationComplete",
      "guard": "validType",
      "actions": [
        "parseTypeDefinition()",
        "beginValueAssignment()"
      ],
      "expected_observables": [
        "dom:valueAssignmentStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_DefineTypeStart",
      "to": "S3_ErrorAlert",
      "event": "TypeValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusTypeInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetTypeInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AssigningValue",
      "to": "S5_CheckingType",
      "event": "ValueAssignmentComplete",
      "guard": "valueAssignedSuccessfully",
      "actions": [
        "updateTypeStructure()",
        "triggerTypeCheckVisualization()"
      ],
      "expected_observables": [
        "dom:typeStructureChanged",
        "dom:valueAssignmentVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_CheckingType",
      "to": "S0_Idle",
      "event": "ValueAssignmentComplete",
      "guard": "typeCheckComplete",
      "actions": [
        "enableControls()",
        "clearTypeInput()"
      ],
      "expected_observables": [
        "dom:typeCheckComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "definitionsNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetTypeInputField()"
      ],
      "expected_observables": [
        "dom:definitionsCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "defineType",
    "reset",
    "type_visualization"
  ]
}