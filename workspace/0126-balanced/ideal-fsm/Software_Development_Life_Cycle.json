{
  "meta": {
    "concept": "Software Development Life Cycle",
    "topic": "SDLC Process Visualization",
    "educational_goal": "Illustrate the phases of SDLC",
    "expected_interactions": [
      "start",
      "next_phase",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderSDLCPhases()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_StartingSDLC",
      "label": "StartingSDLC",
      "type": "atomic",
      "entry_actions": [
        "highlightStartPhase()",
        "showPhaseDescription()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_PhaseTransition",
      "label": "PhaseTransition",
      "type": "operation",
      "entry_actions": [
        "transitionToNextPhase()",
        "updatePhaseVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ResettingSDLC",
      "label": "ResettingSDLC",
      "type": "atomic",
      "entry_actions": [
        "clearAllPhases()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStart",
      "event_type": "user_action",
      "description": "User clicks the Start button"
    },
    {
      "id": "UserClicksNextPhase",
      "event_type": "user_action",
      "description": "User clicks the Next Phase button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "PhaseTransitionComplete",
      "event_type": "system_event",
      "description": "Phase transition completes successfully"
    },
    {
      "id": "SDLCResetComplete",
      "event_type": "system_event",
      "description": "SDLC reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_StartingSDLC",
      "event": "UserClicksStart",
      "guard": "true",
      "actions": [
        "beginSDLCProcess()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startButtonClicked",
        "dom:phaseHighlighted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_StartingSDLC",
      "to": "S2_PhaseTransition",
      "event": "UserClicksNextPhase",
      "guard": "nextPhaseAvailable",
      "actions": [
        "prepareNextPhase()",
        "transitionPhase()"
      ],
      "expected_observables": [
        "dom:nextPhaseButtonClicked",
        "dom:phaseTransitioned"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_PhaseTransition",
      "to": "S0_Idle",
      "event": "PhaseTransitionComplete",
      "guard": "allPhasesCompleted",
      "actions": [
        "enableControls()",
        "clearPhaseHighlight()"
      ],
      "expected_observables": [
        "dom:phaseTransitionComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S3_ResettingSDLC",
      "event": "UserClicksReset",
      "guard": "sdlcNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S3_ResettingSDLC",
      "to": "S0_Idle",
      "event": "SDLCResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetPhaseVisualization()"
      ],
      "expected_observables": [
        "dom:sdlcCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start",
    "next_phase",
    "reset",
    "sdlc_visualization"
  ]
}