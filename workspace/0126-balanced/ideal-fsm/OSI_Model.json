{
  "meta": {
    "concept": "OSI Model",
    "topic": "Open Systems Interconnection Model",
    "educational_goal": "Explain the OSI model layers and their functions",
    "expected_interactions": [
      "select_layer",
      "view_details",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderModel()",
        "enableLayerSelection()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_LayerSelected",
      "label": "LayerSelected",
      "type": "atomic",
      "entry_actions": [
        "highlightLayer()",
        "displayLayerInfo()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ViewingDetails",
      "label": "ViewingDetails",
      "type": "atomic",
      "entry_actions": [
        "showLayerDetails()"
      ],
      "exit_actions": [
        "hideLayerDetails()"
      ]
    },
    {
      "id": "S3_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllHighlights()",
        "resetView()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsLayer",
      "event_type": "user_action",
      "description": "User selects a layer of the OSI model"
    },
    {
      "id": "UserViewsDetails",
      "event_type": "user_action",
      "description": "User views details of the selected layer"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DetailsViewed",
      "event_type": "system_event",
      "description": "Details of the selected layer have been viewed"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_LayerSelected",
      "event": "UserSelectsLayer",
      "guard": "layerIsSelectable",
      "actions": [
        "captureLayerSelection()",
        "disableOtherSelections()"
      ],
      "expected_observables": [
        "dom:layerHighlighted"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_LayerSelected",
      "to": "S2_ViewingDetails",
      "event": "UserViewsDetails",
      "guard": "layerIsSelected",
      "actions": [
        "fetchLayerDetails()",
        "displayDetails()"
      ],
      "expected_observables": [
        "dom:detailsDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_ViewingDetails",
      "to": "S0_Idle",
      "event": "DetailsViewed",
      "guard": "detailsViewed",
      "actions": [
        "enableLayerSelection()",
        "clearDetails()"
      ],
      "expected_observables": [
        "dom:detailsCleared"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S3_Resetting",
      "event": "UserClicksReset",
      "guard": "modelNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetInitiated"
      ],
      "timeout": 500
    },
    {
      "from": "S3_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableLayerSelection()",
        "resetModelView()"
      ],
      "expected_observables": [
        "dom:modelReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "layer_selection",
    "details_view",
    "reset_button",
    "model_visualization"
  ]
}