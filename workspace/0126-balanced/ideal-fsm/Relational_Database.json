{
  "meta": {
    "concept": "RelationalDatabase",
    "topic": "Relational Database Operations",
    "educational_goal": "Demonstrate basic CRUD operations in a relational database",
    "expected_interactions": [
      "create",
      "read",
      "update",
      "delete",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderDatabase()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_CreatingRecord",
      "label": "CreatingRecord",
      "type": "atomic",
      "entry_actions": [
        "readInputValues()",
        "highlightInputFields()"
      ],
      "exit_actions": [
        "clearHighlights()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_UpdatingRecord",
      "label": "UpdatingRecord",
      "type": "atomic",
      "entry_actions": [
        "findRecordToUpdate()",
        "applyUpdates()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DeletingRecord",
      "label": "DeletingRecord",
      "type": "atomic",
      "entry_actions": [
        "findRecordToDelete()",
        "confirmDeletion()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_ReadingRecords",
      "label": "ReadingRecords",
      "type": "atomic",
      "entry_actions": [
        "fetchAllRecords()",
        "displayRecords()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S7_ResettingDatabase",
      "label": "ResettingDatabase",
      "type": "atomic",
      "entry_actions": [
        "clearAllRecords()",
        "resetDatabaseView()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksCreate",
      "event_type": "user_action",
      "description": "User clicks the Create button"
    },
    {
      "id": "UserClicksRead",
      "event_type": "user_action",
      "description": "User clicks the Read button"
    },
    {
      "id": "UserClicksUpdate",
      "event_type": "user_action",
      "description": "User clicks the Update button"
    },
    {
      "id": "UserClicksDelete",
      "event_type": "user_action",
      "description": "User clicks the Delete button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "RecordCreationComplete",
      "event_type": "system_event",
      "description": "Record creation complete"
    },
    {
      "id": "RecordUpdateComplete",
      "event_type": "system_event",
      "description": "Record update complete"
    },
    {
      "id": "RecordDeletionComplete",
      "event_type": "system_event",
      "description": "Record deletion complete"
    },
    {
      "id": "DatabaseResetComplete",
      "event_type": "system_event",
      "description": "Database reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_CreatingRecord",
      "event": "UserClicksCreate",
      "guard": "inputFieldsNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValues",
        "dom:createButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_CreatingRecord",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateValues()",
        "prepareCreation()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S6_ReadingRecords",
      "event": "RecordCreationComplete",
      "guard": "recordCreatedSuccessfully",
      "actions": [
        "updateDatabase()",
        "refreshView()"
      ],
      "expected_observables": [
        "dom:recordCreated",
        "dom:databaseUpdated"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_CreatingRecord",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S4_UpdatingRecord",
      "event": "UserClicksUpdate",
      "guard": "recordExists",
      "actions": [
        "selectRecord()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:updateButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S4_UpdatingRecord",
      "to": "S6_ReadingRecords",
      "event": "RecordUpdateComplete",
      "guard": "updateSuccessful",
      "actions": [
        "applyChanges()",
        "refreshView()"
      ],
      "expected_observables": [
        "dom:recordUpdated",
        "dom:databaseUpdated"
      ],
      "timeout": 1500
    },
    {
      "from": "S0_Idle",
      "to": "S5_DeletingRecord",
      "event": "UserClicksDelete",
      "guard": "recordExists",
      "actions": [
        "selectRecord()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:deleteButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S5_DeletingRecord",
      "to": "S6_ReadingRecords",
      "event": "RecordDeletionComplete",
      "guard": "deletionSuccessful",
      "actions": [
        "removeRecord()",
        "refreshView()"
      ],
      "expected_observables": [
        "dom:recordDeleted",
        "dom:databaseUpdated"
      ],
      "timeout": 1500
    },
    {
      "from": "S0_Idle",
      "to": "S7_ResettingDatabase",
      "event": "UserClicksReset",
      "guard": "databaseNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S7_ResettingDatabase",
      "to": "S0_Idle",
      "event": "DatabaseResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputFields()"
      ],
      "expected_observables": [
        "dom:databaseCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "create",
    "read",
    "update",
    "delete",
    "reset",
    "database_visualization"
  ]
}