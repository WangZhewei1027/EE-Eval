{
  "meta": {
    "concept": "DesignPatterns",
    "topic": "Design Patterns Visualization",
    "educational_goal": "Illustrate the use and implementation of design patterns",
    "expected_interactions": [
      "selectPattern",
      "viewExample",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderPatternList()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SelectingPattern",
      "label": "SelectingPattern",
      "type": "atomic",
      "entry_actions": [
        "highlightPatternSelection()",
        "showPatternDetails()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ViewingExample",
      "label": "ViewingExample",
      "type": "atomic",
      "entry_actions": [
        "displayPatternExample()",
        "animateExample()"
      ],
      "exit_actions": [
        "clearExample()"
      ]
    },
    {
      "id": "S3_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllSelections()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsPattern",
      "event_type": "user_action",
      "description": "User selects a design pattern from the list"
    },
    {
      "id": "UserViewsExample",
      "event_type": "user_action",
      "description": "User clicks to view an example of the selected pattern"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "PatternSelectionComplete",
      "event_type": "system_event",
      "description": "Pattern selection completes successfully"
    },
    {
      "id": "ExampleViewComplete",
      "event_type": "system_event",
      "description": "Pattern example view completes"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SelectingPattern",
      "event": "UserSelectsPattern",
      "guard": "patternIsSelected",
      "actions": [
        "capturePatternSelection()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:patternSelected"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SelectingPattern",
      "to": "S2_ViewingExample",
      "event": "UserViewsExample",
      "guard": "exampleAvailable",
      "actions": [
        "prepareExampleView()",
        "beginExampleAnimation()"
      ],
      "expected_observables": [
        "dom:exampleDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_ViewingExample",
      "to": "S0_Idle",
      "event": "ExampleViewComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearExampleView()"
      ],
      "expected_observables": [
        "dom:exampleViewCleared"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S3_Resetting",
      "event": "UserClicksReset",
      "guard": "selectionsMade",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetInitiated"
      ],
      "timeout": 500
    },
    {
      "from": "S3_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetPatternList()"
      ],
      "expected_observables": [
        "dom:allCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "pattern_list",
    "view_example",
    "reset",
    "pattern_visualization"
  ]
}