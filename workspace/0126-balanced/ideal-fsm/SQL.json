{
  "meta": {
    "concept": "SQL",
    "topic": "SQL Query Execution",
    "educational_goal": "Teach basic SQL query execution and result visualization",
    "expected_interactions": [
      "execute",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderQueryArea()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_QueryStart",
      "label": "QueryStart",
      "type": "atomic",
      "entry_actions": [
        "readQueryInput()",
        "highlightQueryInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingQuery",
      "label": "ValidatingQuery",
      "type": "atomic",
      "entry_actions": [
        "validateQuery()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ExecutingQuery",
      "label": "ExecutingQuery",
      "type": "atomic",
      "entry_actions": [
        "executeSQLQuery()",
        "fetchResults()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DisplayResults",
      "label": "DisplayResults",
      "type": "atomic",
      "entry_actions": [
        "updateResultsVisualization()",
        "animateResultsDisplay()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingQuery",
      "label": "ResettingQuery",
      "type": "atomic",
      "entry_actions": [
        "clearQueryInput()",
        "resetResultsVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksExecute",
      "event_type": "user_action",
      "description": "User clicks the Execute button"
    },
    {
      "id": "UserEntersQuery",
      "event_type": "user_action",
      "description": "User enters SQL query in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "QueryValidationComplete",
      "event_type": "system_event",
      "description": "Query validation completes successfully"
    },
    {
      "id": "QueryValidationFailed",
      "event_type": "system_event",
      "description": "Query validation fails"
    },
    {
      "id": "QueryExecutionComplete",
      "event_type": "system_event",
      "description": "Query execution and result fetching complete"
    },
    {
      "id": "QueryResetComplete",
      "event_type": "system_event",
      "description": "Query reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_QueryStart",
      "event": "UserClicksExecute",
      "guard": "queryNotEmpty",
      "actions": [
        "captureQueryInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readQueryInput",
        "dom:executeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_QueryStart",
      "to": "S2_ValidatingQuery",
      "event": "QueryValidationComplete",
      "guard": "queryIsValid",
      "actions": [
        "validateQuerySyntax()",
        "prepareExecution()"
      ],
      "expected_observables": [
        "dom:queryValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingQuery",
      "to": "S4_ExecutingQuery",
      "event": "QueryValidationComplete",
      "guard": "validSQL",
      "actions": [
        "parseQueryInput()",
        "beginExecution()"
      ],
      "expected_observables": [
        "dom:queryExecutionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_QueryStart",
      "to": "S3_ErrorAlert",
      "event": "QueryValidationFailed",
      "guard": "queryIsEmpty",
      "actions": [
        "showError()",
        "focusQueryInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetQueryInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ExecutingQuery",
      "to": "S5_DisplayResults",
      "event": "QueryExecutionComplete",
      "guard": "resultsFetchedSuccessfully",
      "actions": [
        "updateResultsStructure()",
        "triggerResultsVisualization()"
      ],
      "expected_observables": [
        "dom:resultsStructureChanged",
        "dom:resultsVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DisplayResults",
      "to": "S0_Idle",
      "event": "QueryExecutionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearQueryInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingQuery",
      "event": "UserClicksReset",
      "guard": "resultsNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingQuery",
      "to": "S0_Idle",
      "event": "QueryResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetQueryInputField()"
      ],
      "expected_observables": [
        "dom:queryCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "execute",
    "reset",
    "results_visualization"
  ]
}