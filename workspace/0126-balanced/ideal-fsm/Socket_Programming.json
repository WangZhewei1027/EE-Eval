{
  "meta": {
    "concept": "SocketProgramming",
    "topic": "Socket Programming Basics",
    "educational_goal": "Teach basic socket connection, data transmission, and disconnection",
    "expected_interactions": [
      "connect",
      "send",
      "receive",
      "disconnect",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderUI()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_Connecting",
      "label": "Connecting",
      "type": "atomic",
      "entry_actions": [
        "initiateConnection()",
        "showConnectingStatus()"
      ],
      "exit_actions": [
        "clearConnectingStatus()"
      ]
    },
    {
      "id": "S2_Connected",
      "label": "Connected",
      "type": "atomic",
      "entry_actions": [
        "showConnectedStatus()",
        "enableDataTransfer()"
      ],
      "exit_actions": [
        "disableDataTransfer()"
      ]
    },
    {
      "id": "S3_SendingData",
      "label": "SendingData",
      "type": "atomic",
      "entry_actions": [
        "sendData()",
        "showSendingStatus()"
      ],
      "exit_actions": [
        "clearSendingStatus()"
      ]
    },
    {
      "id": "S4_ReceivingData",
      "label": "ReceivingData",
      "type": "atomic",
      "entry_actions": [
        "receiveData()",
        "showReceivingStatus()"
      ],
      "exit_actions": [
        "clearReceivingStatus()"
      ]
    },
    {
      "id": "S5_Disconnecting",
      "label": "Disconnecting",
      "type": "atomic",
      "entry_actions": [
        "initiateDisconnection()",
        "showDisconnectingStatus()"
      ],
      "exit_actions": [
        "clearDisconnectingStatus()"
      ]
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "resetConnection()",
        "clearAllStatuses()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksConnect",
      "event_type": "user_action",
      "description": "User clicks the Connect button"
    },
    {
      "id": "ConnectionEstablished",
      "event_type": "system_event",
      "description": "Connection to the server is established"
    },
    {
      "id": "UserClicksSend",
      "event_type": "user_action",
      "description": "User clicks the Send button"
    },
    {
      "id": "DataSent",
      "event_type": "system_event",
      "description": "Data is successfully sent"
    },
    {
      "id": "DataReceived",
      "event_type": "system_event",
      "description": "Data is received from the server"
    },
    {
      "id": "UserClicksDisconnect",
      "event_type": "user_action",
      "description": "User clicks the Disconnect button"
    },
    {
      "id": "DisconnectionComplete",
      "event_type": "system_event",
      "description": "Disconnection from the server is complete"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_Connecting",
      "event": "UserClicksConnect",
      "guard": "validServerAddress",
      "actions": [
        "captureServerAddress()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:connectButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_Connecting",
      "to": "S2_Connected",
      "event": "ConnectionEstablished",
      "guard": "connectionSuccess",
      "actions": [
        "enableDataTransfer()",
        "showConnectedStatus()"
      ],
      "expected_observables": [
        "dom:connectionEstablished"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Connected",
      "to": "S3_SendingData",
      "event": "UserClicksSend",
      "guard": "dataReadyToSend",
      "actions": [
        "prepareData()",
        "sendData()"
      ],
      "expected_observables": [
        "dom:dataSendingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S3_SendingData",
      "to": "S2_Connected",
      "event": "DataSent",
      "guard": "dataSentSuccessfully",
      "actions": [
        "clearSendingStatus()",
        "enableDataTransfer()"
      ],
      "expected_observables": [
        "dom:dataSent"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Connected",
      "to": "S4_ReceivingData",
      "event": "DataReceived",
      "guard": "dataReceivedSuccessfully",
      "actions": [
        "processReceivedData()",
        "showReceivedData()"
      ],
      "expected_observables": [
        "dom:dataReceived"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Connected",
      "to": "S5_Disconnecting",
      "event": "UserClicksDisconnect",
      "guard": "true",
      "actions": [
        "initiateDisconnection()",
        "disableDataTransfer()"
      ],
      "expected_observables": [
        "dom:disconnectButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Disconnecting",
      "to": "S0_Idle",
      "event": "DisconnectionComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearConnectionStatus()"
      ],
      "expected_observables": [
        "dom:disconnectionComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "DisconnectionComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetUI()"
      ],
      "expected_observables": [
        "dom:resetComplete"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "connect",
    "send",
    "disconnect",
    "reset",
    "status_display"
  ]
}