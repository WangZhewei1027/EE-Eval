{
  "meta": {
    "concept": "Backtracking",
    "topic": "Backtracking Algorithm Visualization",
    "educational_goal": "Demonstrate the process of backtracking to solve constraint satisfaction problems",
    "expected_interactions": [
      "start",
      "step",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderInitialProblem()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_StartingBacktracking",
      "label": "StartingBacktracking",
      "type": "atomic",
      "entry_actions": [
        "initializeBacktracking()",
        "highlightStart()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Stepping",
      "label": "Stepping",
      "type": "atomic",
      "entry_actions": [
        "executeStep()",
        "highlightCurrentStep()"
      ],
      "exit_actions": [
        "clearStepHighlight()"
      ]
    },
    {
      "id": "S3_BacktrackingComplete",
      "label": "BacktrackingComplete",
      "type": "atomic",
      "entry_actions": [
        "showCompletionMessage()",
        "highlightSolution()"
      ],
      "exit_actions": [
        "clearSolutionHighlight()"
      ]
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllSteps()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStart",
      "event_type": "user_action",
      "description": "User clicks the Start button"
    },
    {
      "id": "UserClicksStep",
      "event_type": "user_action",
      "description": "User clicks the Step button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "StepExecutionComplete",
      "event_type": "system_event",
      "description": "A backtracking step completes"
    },
    {
      "id": "BacktrackingComplete",
      "event_type": "system_event",
      "description": "Backtracking process completes successfully"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_StartingBacktracking",
      "event": "UserClicksStart",
      "guard": "problemIsLoaded",
      "actions": [
        "disableControls()",
        "startBacktracking()"
      ],
      "expected_observables": [
        "dom:startButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_StartingBacktracking",
      "to": "S2_Stepping",
      "event": "StepExecutionComplete",
      "guard": "stepIsValid",
      "actions": [
        "prepareNextStep()",
        "enableStepControl()"
      ],
      "expected_observables": [
        "dom:stepInitialized"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Stepping",
      "to": "S2_Stepping",
      "event": "UserClicksStep",
      "guard": "moreStepsAvailable",
      "actions": [
        "executeNextStep()"
      ],
      "expected_observables": [
        "dom:stepExecuted"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_Stepping",
      "to": "S3_BacktrackingComplete",
      "event": "BacktrackingComplete",
      "guard": "solutionFound",
      "actions": [
        "displaySolution()",
        "finalizeVisualization()"
      ],
      "expected_observables": [
        "dom:solutionDisplayed"
      ],
      "timeout": 3000
    },
    {
      "from": "S3_BacktrackingComplete",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearSolution()"
      ],
      "expected_observables": [
        "dom:solutionCleared"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "problemIsLoaded",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetProblemState()"
      ],
      "expected_observables": [
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start",
    "step",
    "reset",
    "visualization_area"
  ]
}