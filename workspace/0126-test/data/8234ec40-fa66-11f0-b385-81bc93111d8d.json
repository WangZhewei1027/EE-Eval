    "content": "<html>\n<head>\n    <title>Bubble Sort</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        table {\n            border-collapse: collapse;\n        }\n        th, td {\n            border: 1px solid #ddd;\n            padding: 8px;\n            text-align: left;\n        }\n    </style>\n</head>\n<body>\n    <h1>Bubble Sort</h1>\n    <p>Enter numbers separated by spaces:</p>\n    <input type=\"text\" id=\"numbers\" placeholder=\"Enter numbers separated by spaces\">\n    <button id=\"sort-button\">Sort</button>\n    <table id=\"sorted-table\">\n        <tr>\n            <th>Number</th>\n        </tr>\n        <tr id=\"sorted-row\"></tr>\n    </table>\n\n    <script>\n        const numbers = document.getElementById('numbers');\n        const sortButton = document.getElementById('sort-button');\n        const sortedTable = document.getElementById('sorted-table');\n        const sortedRow = document.getElementById('sorted-row');\n\n        sortButton.addEventListener('click', () => {\n            const numbersArray = numbers.value.split(' ').map(Number);\n            console.log(numbersArray);\n\n            let i = 0;\n            while (i < numbersArray.length) {\n                for (let j = i + 1; j < numbersArray.length; j++) {\n                    if (numbersArray[i] > numbersArray[j]) {\n                        // Swap numbers\n                        [numbersArray[i], numbersArray[j]] = [numbersArray[j], numbersArray[i]];\n                        // Add the swapped numbers to the sorted row\n                        sortedRow.innerHTML = '';\n                        for (let k = 0; k < numbersArray.length; k++) {\n                            if (k === i) {\n                                sortedRow.insertAdjacentHTML('beforeend', '<th>' + numbersArray[k] + '</th>');\n                            } else {\n                                sortedRow.insertAdjacentHTML('beforeend', '<td>' + numbersArray[k] + '</td>');\n                            }\n                        }\n                        sortedRow.insertAdjacentHTML('beforeend', '<tr><td>' + numbersArray[i] + '</td></tr>');\n                        sortedRow.insertAdjacentHTML('beforeend', '<tr><td>' + numbersArray[j] + '</td></tr>');\n                        i++;\n                    }\n                }\n            }\n            sortedTable.innerHTML = '';\n            sortedRow.innerHTML = '';\n            for (let i = 0; i < numbersArray.length; i++) {\n                sortedTable.insertAdjacentHTML('beforeend', '<td>' + numbersArray[i] + '</td>');\n            }\n        });\n    </script>\n</body>\n</html>"
