    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        #tree {\n            margin: 20px;\n            width: 300px;\n            border: 1px solid #ccc;\n            padding: 10px;\n            border-radius: 5px;\n            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n        }\n        .node {\n            padding: 10px;\n            border-bottom: 1px solid #ccc;\n        }\n        .node:hover {\n            border-bottom: 2px solid #ccc;\n        }\n        .node:hover .left-child {\n            transform: rotateX(45deg);\n        }\n        .node:hover .right-child {\n            transform: rotateX(-45deg);\n        }\n        .node:hover .leaf {\n            display: block;\n        }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree</h1>\n    <form id=\"tree-form\">\n        <input type=\"text\" id=\"root\" placeholder=\"Enter the root of the BST\">\n        <button id=\"add-tree\">Add</button>\n    </form>\n    <div id=\"tree-container\"></div>\n\n    <script>\n        let tree = null;\n        let nodes = [];\n\n        function addNode(root) {\n            if (!root) {\n                return;\n            }\n\n            let input = document.getElementById('root').value;\n            let node = {};\n\n            if (root.left) {\n                node.left = addNode(root.left);\n            } else {\n                node.left = null;\n            }\n\n            if (root.right) {\n                node.right = addNode(root.right);\n            } else {\n                node.right = null;\n            }\n\n            node.value = input;\n            node.left = null;\n            node.right = null;\n\n            nodes.push(node);\n\n            if (input === '1') {\n                tree = new BinarySearchTree(root);\n            }\n        }\n\n        function displayTree(node) {\n            if (node) {\n                let children = node.left ? '<div class=\"left-child\"></div>' : '<div class=\"left-child\"></div>';\n                let leaf = node.value === '1' ? '<div class=\"leaf\"></div>' : '<div class=\"leaf\"></div>';\n\n                let html = `<div class=\"node\">\n                            <div class=\"node-value\">${node.value}</div>\n                            ${children}\n                            ${leaf}\n                        </div>`;\n\n                document.getElementById('tree-container').innerHTML += html;\n            }\n        }\n\n        function addTree() {\n            let root = document.getElementById('root').value;\n            addNode(root);\n            displayTree(tree);\n        }\n\n        function displayAllTrees() {\n            for (let node of nodes) {\n                displayTree(node);\n            }\n        }\n\n        addTree();\n    </script>\n</body>\n</html>"
