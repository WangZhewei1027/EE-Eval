    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Bubble Sort</title>\n    <style>\n        table, th, td {\n            border: 1px solid black;\n        }\n    </style>\n</head>\n<body>\n    <h1>Bubble Sort</h1>\n    <table border=\"1\">\n        <tr>\n            <th>Number</th>\n            <th>Pass</th>\n            <th>Swap</th>\n        </tr>\n        <tr>\n            <td>5</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n        <tr>\n            <td>4</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n        <tr>\n            <td>3</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n        <tr>\n            <td>2</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n        <tr>\n            <td>1</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n        <tr>\n            <td>0</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n        <tr>\n            <td>0</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n        <tr>\n            <td>0</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n        <tr>\n            <td>0</td>\n            <td>0</td>\n            <td>0</td>\n        </tr>\n    </table>\n    <script>\n        function bubbleSort(arr, n) {\n            let swapped = true;\n            while (swapped) {\n                swapped = false;\n                for (let i = 0; i < n - 1; i++) {\n                    if (arr[i] > arr[i + 1]) {\n                        let temp = arr[i];\n                        arr[i] = arr[i + 1];\n                        arr[i + 1] = temp;\n                        swapped = true;\n                    }\n                }\n            }\n            return arr;\n        }\n\n        let arr = [5, 4, 3, 2, 1, 0];\n        let n = arr.length;\n        console.log(\"Original array:\", arr);\n        arr = bubbleSort(arr, n);\n        console.log(\"Sorted array:\", arr);\n    </script>\n</body>\n</html>"
