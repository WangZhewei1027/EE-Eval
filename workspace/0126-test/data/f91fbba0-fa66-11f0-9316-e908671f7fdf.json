  "answer": {
    "role": "assistant",
    "content": "<html>\n<head>\n    <title>Binary Search Tree</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n        }\n        \n        #tree {\n            width: 80%;\n            margin: 40px auto;\n            padding: 20px;\n            border: 1px solid #ccc;\n            border-radius: 10px;\n            box-shadow: 0 0 10px rgba(0,0,0,0.1);\n        }\n        \n        .node {\n            padding: 20px;\n            border-bottom: 1px solid #ccc;\n        }\n        \n        .node:hover {\n            cursor: pointer;\n        }\n        \n        .node:hover .left {\n            background-color: #f0f0f0;\n        }\n        \n        .node:hover .right {\n            background-color: #ccc;\n        }\n        \n        .node:hover .value {\n            color: #333;\n        }\n    </style>\n</head>\n<body>\n    <h1>Binary Search Tree</h1>\n    <input type=\"text\" id=\"search-input\" placeholder=\"Enter a value\">\n    <button id=\"search-btn\">Search</button>\n    <div id=\"tree\"></div>\n\n    <script>\n        class Node {\n            constructor(value, left = null, right = null) {\n                this.value = value;\n                this.left = left;\n                this.right = right;\n            }\n        }\n\n        class BST {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(value) {\n                if (this.root === null) {\n                    this.root = new Node(value);\n                } else {\n                    this._insert(this.root, value);\n                }\n            }\n\n            _insert(node, value) {\n                if (value < node.value) {\n                    if (node.left === null) {\n                        node.left = new Node(value);\n                    } else {\n                        this._insert(node.left, value);\n                    }\n                } else {\n                    if (node.right === null) {\n                        node.right = new Node(value);\n                    } else {\n                        this._insert(node.right, value);\n                    }\n                }\n            }\n\n            search(value) {\n                return this._search(this.root, value);\n            }\n\n            _search(node, value) {\n                if (node === null) {\n                    return null;\n                }\n                if (value < node.value) {\n                    return this._search(node.left, value);\n                } else if (value > node.value) {\n                    return this._search(node.right, value);\n                } else {\n                    return node.value;\n                }\n            }\n\n            inorder() {\n                this._inorder(this.root);\n            }\n\n            _inorder(node) {\n                if (node !== null) {\n                    this._inorder(node.left);\n                    document.getElementById(\"tree\").innerHTML += \"<span class='node'>\" + node.value + \"</span>\";\n                    this._inorder(node.right);\n                }\n            }\n        }\n\n        const bst = new BST();\n\n        document.getElementById(\"search-input\").addEventListener(\"input\", () => {\n            const value = document.getElementById(\"search-input\").value;\n            bst.search(value);\n            bst.inorder();\n        });\n\n        document.getElementById(\"search-btn\").addEventListener(\"click\", () => {\n            const value = document.getElementById(\"search-input\").value;\n            const result = bst.search(value);\n            document.getElementById(\"tree\").innerHTML = \"<span class='node'>\" + result + \"</span>\";\n        });\n    </script>\n</body>\n</html>"
  },
