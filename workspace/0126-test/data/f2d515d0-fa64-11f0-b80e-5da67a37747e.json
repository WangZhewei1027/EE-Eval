    "content": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Binary Search Tree Visualization</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            margin: 0;\n            padding: 20px;\n            background-color: #f4f4f4;\n        }\n        .bst-node {\n            border: 1px solid #333;\n            border-radius: 5px;\n            padding: 10px;\n            text-align: center;\n            position: relative;\n        }\n        .tree {\n            display: flex;\n            justify-content: center;\n            margin-bottom: 20px;\n        }\n        .connection {\n            position: absolute;\n            width: 50px;\n            height: 20px;\n            background-color: transparent;\n        }\n    </style>\n</head>\n<body>\n\n    <h1>Binary Search Tree Visualization</h1>\n    <input type=\"number\" id=\"valueInput\" placeholder=\"Enter a number\" />\n    <button onclick=\"insertNode()\">Insert Node</button>\n    <div id=\"bstContainer\"></div>\n\n    <script>\n        class Node {\n            constructor(value) {\n                this.value = value;\n                this.left = null;\n                this.right = null;\n            }\n        }\n\n        class BinarySearchTree {\n            constructor() {\n                this.root = null;\n            }\n\n            insert(value) {\n                const node = new Node(value);\n                if (this.root === null) {\n                    this.root = node;\n                } else {\n                    this.insertNode(this.root, node);\n                }\n            }\n\n            insertNode(root, node) {\n                if (node.value < root.value) {\n                    if (root.left === null) {\n                        root.left = node;\n                    } else {\n                        this.insertNode(root.left, node);\n                    }\n                } else {\n                    if (root.right === null) {\n                        root.right = node;\n                    } else {\n                        this.insertNode(root.right, node);\n                    }\n                }\n            }\n\n            // Method to visualize the tree\n            visualize() {\n                const container = document.getElementById(\"bstContainer\");\n                container.innerHTML = \"\"; // clear current tree visualization\n                this.createTree(this.root, container);\n            }\n\n            createTree(node, parentContainer) {\n                if (node !== null) {\n                    const nodeDiv = document.createElement(\"div\");\n                    nodeDiv.className = \"bst-node\";\n                    nodeDiv.textContent = node.value;\n\n                    parentContainer.appendChild(nodeDiv);\n\n                    // Recursively create the left and right subtrees\n                    const leftContainer = document.createElement(\"div\");\n                    const rightContainer = document.createElement(\"div\");\n                    \n                    leftContainer.className = \"tree\";\n                    rightContainer.className = \"tree\";\n\n                    // Draw connections\n                    if (node.left) {\n                        const leftConnection = document.createElement(\"div\");\n                        leftConnection.className = \"connection\";\n                        leftContainer.appendChild(leftConnection);\n                    }\n\n                    if (node.right) {\n                        const rightConnection = document.createElement(\"div\");\n                        rightConnection.className = \"connection\";\n                        rightContainer.appendChild(rightConnection);\n                    }\n\n                    this.createTree(node.left, leftContainer);\n                    this.createTree(node.right, rightContainer);\n\n                    parentContainer.appendChild(leftContainer);\n                    parentContainer.appendChild(rightContainer);\n                }\n            }\n        }\n\n        const bst = new BinarySearchTree();\n\n        function insertNode() {\n            const value = parseInt(document.getElementById(\"valueInput\").value);\n            if (!isNaN(value)) {\n                bst.insert(value);\n                bst.visualize();\n                document.getElementById(\"valueInput\").value = ''; // clear input\n            } else {\n                alert(\"Please enter a valid number.\");\n            }\n        }\n    </script>\n</body>\n</html>"
