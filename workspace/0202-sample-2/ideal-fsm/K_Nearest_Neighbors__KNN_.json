{
  "meta": {
    "concept": "K-Nearest Neighbors",
    "topic": "KNN Algorithm Visualization",
    "educational_goal": "Demonstrate KNN classification and distance calculation",
    "expected_interactions": [
      "select_k",
      "add_point",
      "classify",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SelectK",
      "label": "SelectK",
      "type": "atomic",
      "entry_actions": [
        "highlightKSelector()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_AddingPoint",
      "label": "AddingPoint",
      "type": "atomic",
      "entry_actions": [
        "capturePointCoordinates()",
        "highlightGraphArea()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_Classifying",
      "label": "Classifying",
      "type": "atomic",
      "entry_actions": [
        "calculateDistances()",
        "findNearestNeighbors()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_ShowResult",
      "label": "ShowResult",
      "type": "atomic",
      "entry_actions": [
        "displayClassificationResult()",
        "highlightResult()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllPoints()",
        "resetGraph()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSelectsK",
      "event_type": "user_action",
      "description": "User selects the value of K"
    },
    {
      "id": "UserAddsPoint",
      "event_type": "user_action",
      "description": "User adds a new point to the graph"
    },
    {
      "id": "UserClicksClassify",
      "event_type": "user_action",
      "description": "User clicks the Classify button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ClassificationComplete",
      "event_type": "system_event",
      "description": "Classification process completes"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SelectK",
      "event": "UserSelectsK",
      "guard": "kIsValid",
      "actions": [
        "setKValue()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:kValueSelected"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_SelectK",
      "to": "S2_AddingPoint",
      "event": "UserAddsPoint",
      "guard": "pointIsValid",
      "actions": [
        "addPointToGraph()",
        "prepareForClassification()"
      ],
      "expected_observables": [
        "dom:pointAdded"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_AddingPoint",
      "to": "S3_Classifying",
      "event": "UserClicksClassify",
      "guard": "true",
      "actions": [
        "startClassification()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:classificationStarted"
      ],
      "timeout": 2000
    },
    {
      "from": "S3_Classifying",
      "to": "S4_ShowResult",
      "event": "ClassificationComplete",
      "guard": "true",
      "actions": [
        "showResult()",
        "highlightNeighbors()"
      ],
      "expected_observables": [
        "dom:classificationResultDisplayed"
      ],
      "timeout": 1500
    },
    {
      "from": "S4_ShowResult",
      "to": "S0_Idle",
      "event": "ClassificationComplete",
      "guard": "resultAcknowledged",
      "actions": [
        "enableControls()",
        "clearTemporaryHighlights()"
      ],
      "expected_observables": [
        "dom:resultAcknowledged"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetInitiated"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetKValue()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:controlsReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "k_selector",
    "add_point",
    "classify",
    "reset",
    "graph_visualization"
  ]
}