{
  "meta": {
    "concept": "K-Means Clustering",
    "topic": "K-Means Clustering Visualization",
    "educational_goal": "Demonstrate K-Means clustering process",
    "expected_interactions": [
      "initialize",
      "assign",
      "update",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderClusters()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InitializeStart",
      "label": "InitializeStart",
      "type": "atomic",
      "entry_actions": [
        "readInputValue()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AssigningClusters",
      "label": "AssigningClusters",
      "type": "atomic",
      "entry_actions": [
        "assignDataPoints()",
        "updateVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_UpdatingCentroids",
      "label": "UpdatingCentroids",
      "type": "atomic",
      "entry_actions": [
        "calculateNewCentroids()",
        "animateCentroidUpdate()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ClusteringResetting",
      "label": "ClusteringResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllClusters()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInitialize",
      "event_type": "user_action",
      "description": "User clicks the Initialize button"
    },
    {
      "id": "UserEntersInput",
      "event_type": "user_action",
      "description": "User enters number of clusters in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "ClusterAssignmentComplete",
      "event_type": "system_event",
      "description": "Cluster assignment complete"
    },
    {
      "id": "CentroidUpdateComplete",
      "event_type": "system_event",
      "description": "Centroid update complete"
    },
    {
      "id": "ClusteringResetComplete",
      "event_type": "system_event",
      "description": "Clustering reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InitializeStart",
      "event": "UserClicksInitialize",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputValue",
        "dom:initializeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InitializeStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateValue()",
        "prepareClustering()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_AssigningClusters",
      "event": "InputValidationComplete",
      "guard": "validNumber",
      "actions": [
        "parseInputValue()",
        "beginClusterAssignment()"
      ],
      "expected_observables": [
        "dom:clusterAssignmentStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InitializeStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_AssigningClusters",
      "to": "S5_UpdatingCentroids",
      "event": "ClusterAssignmentComplete",
      "guard": "assignmentSuccessful",
      "actions": [
        "updateClusterVisualization()",
        "triggerCentroidUpdate()"
      ],
      "expected_observables": [
        "dom:clusterVisualizationUpdated",
        "dom:centroidUpdateStarted"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_UpdatingCentroids",
      "to": "S0_Idle",
      "event": "CentroidUpdateComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ClusteringResetting",
      "event": "UserClicksReset",
      "guard": "clustersNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ClusteringResetting",
      "to": "S0_Idle",
      "event": "ClusteringResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:clustersCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "initialize",
    "reset",
    "cluster_visualization"
  ]
}