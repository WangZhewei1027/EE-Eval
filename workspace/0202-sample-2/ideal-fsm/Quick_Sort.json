{
  "meta": {
    "concept": "QuickSort",
    "topic": "Quick Sort Algorithm Visualization",
    "educational_goal": "Demonstrate the process of quick sort",
    "expected_interactions": [
      "start_sort",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_Sorting",
      "label": "Sorting",
      "type": "operation",
      "entry_actions": [
        "disableControls()",
        "highlightPivot()"
      ],
      "exit_actions": [
        "clearHighlights()"
      ]
    },
    {
      "id": "S2_Partitioning",
      "label": "Partitioning",
      "type": "atomic",
      "entry_actions": [
        "partitionArray()",
        "showPartitioning()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_Sorted",
      "label": "Sorted",
      "type": "atomic",
      "entry_actions": [
        "showSortedArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearArray()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStartSort",
      "event_type": "user_action",
      "description": "User clicks the Start Sort button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "PartitionComplete",
      "event_type": "system_event",
      "description": "Partitioning of the array is complete"
    },
    {
      "id": "SortComplete",
      "event_type": "system_event",
      "description": "Sorting process is complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_Sorting",
      "event": "UserClicksStartSort",
      "guard": "arrayNotEmpty",
      "actions": [
        "startSortingProcess()",
        "selectPivot()"
      ],
      "expected_observables": [
        "dom:startSortButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_Sorting",
      "to": "S2_Partitioning",
      "event": "PartitionComplete",
      "guard": "pivotSelected",
      "actions": [
        "performPartition()",
        "updateArrayVisualization()"
      ],
      "expected_observables": [
        "dom:partitioningVisualized"
      ],
      "timeout": 3000
    },
    {
      "from": "S2_Partitioning",
      "to": "S1_Sorting",
      "event": "PartitionComplete",
      "guard": "morePartitionsNeeded",
      "actions": [
        "selectNextPivot()",
        "continueSorting()"
      ],
      "expected_observables": [
        "dom:nextPivotSelected"
      ],
      "timeout": 2000
    },
    {
      "from": "S2_Partitioning",
      "to": "S3_Sorted",
      "event": "SortComplete",
      "guard": "arraySorted",
      "actions": [
        "finalizeSorting()",
        "displaySortedArray()"
      ],
      "expected_observables": [
        "dom:arraySorted"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "arrayNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:arrayCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start_sort",
    "reset",
    "array_visualization"
  ]
}