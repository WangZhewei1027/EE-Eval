{
  "meta": {
    "concept": "Dijkstra’s Algorithm",
    "topic": "Shortest Path Finding",
    "educational_goal": "Demonstrate Dijkstra's algorithm for finding shortest paths in a graph",
    "expected_interactions": [
      "set_start_node",
      "set_end_node",
      "run_algorithm",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SettingStartNode",
      "label": "SettingStartNode",
      "type": "atomic",
      "entry_actions": [
        "highlightStartNodeInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_SettingEndNode",
      "label": "SettingEndNode",
      "type": "atomic",
      "entry_actions": [
        "highlightEndNodeInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_RunningAlgorithm",
      "label": "RunningAlgorithm",
      "type": "operation",
      "entry_actions": [
        "executeDijkstra()",
        "showProgress()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_DisplayResults",
      "label": "DisplayResults",
      "type": "atomic",
      "entry_actions": [
        "highlightShortestPath()",
        "displayPathCost()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearGraph()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSetsStartNode",
      "event_type": "user_action",
      "description": "User sets the start node"
    },
    {
      "id": "UserSetsEndNode",
      "event_type": "user_action",
      "description": "User sets the end node"
    },
    {
      "id": "UserRunsAlgorithm",
      "event_type": "user_action",
      "description": "User clicks the Run Algorithm button"
    },
    {
      "id": "AlgorithmComplete",
      "event_type": "system_event",
      "description": "Dijkstra's algorithm completes execution"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SettingStartNode",
      "event": "UserSetsStartNode",
      "guard": "nodeExists",
      "actions": [
        "captureStartNode()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startNodeSelected"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_SettingStartNode",
      "to": "S2_SettingEndNode",
      "event": "UserSetsEndNode",
      "guard": "nodeExists",
      "actions": [
        "captureEndNode()",
        "prepareAlgorithm()"
      ],
      "expected_observables": [
        "dom:endNodeSelected"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_SettingEndNode",
      "to": "S3_RunningAlgorithm",
      "event": "UserRunsAlgorithm",
      "guard": "nodesValid",
      "actions": [
        "startAlgorithm()",
        "showAlgorithmProgress()"
      ],
      "expected_observables": [
        "dom:algorithmRunning"
      ],
      "timeout": 3000
    },
    {
      "from": "S3_RunningAlgorithm",
      "to": "S4_DisplayResults",
      "event": "AlgorithmComplete",
      "guard": "pathFound",
      "actions": [
        "displayResults()",
        "highlightPath()"
      ],
      "expected_observables": [
        "dom:resultsDisplayed",
        "dom:pathHighlighted"
      ],
      "timeout": 2000
    },
    {
      "from": "S4_DisplayResults",
      "to": "S0_Idle",
      "event": "AlgorithmComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearInputs()"
      ],
      "expected_observables": [
        "dom:controlsEnabled"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginGraphClear()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingGraph",
      "to": "S0_Idle",
      "event": "AlgorithmComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputs()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start_node_input",
    "end_node_input",
    "run_algorithm",
    "reset",
    "graph_visualization"
  ]
}